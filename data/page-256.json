{"id":256,"ayahs":[{"number":6,"arabic":"وَإِذْ قَالَ مُوسَىٰ لِقَوْمِهِ ٱذْكُرُوا۟ نِعْمَةَ ٱللَّهِ عَلَيْكُمْ إِذْ أَنجَىٰكُم مِّنْ ءَالِ فِرْعَوْنَ يَسُومُونَكُمْ سُوٓءَ ٱلْعَذَابِ وَيُذَبِّحُونَ أَبْنَآءَكُمْ وَيَسْتَحْيُونَ نِسَآءَكُمْ ۚ وَفِى ذَٰلِكُم بَلَآءٌۭ مِّن رَّبِّكُمْ عَظِيمٌۭ","translation":"And, lo Moses spoke [thus] unto his people: \"Remember the blessings which God bestowed upon you when He saved you from Pharaoh's people who afflicted you with cruel suffering, and slaughtered your sons, and spared [only] your women -which was an awesome trial from your Sustainer.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1756.mp3","surahId":14,"words":[{"id":7009,"position":1,"arabic":"وَإِذْ","translation":"এবং স্মরণ করো যখন","audioUrl":"wbw/014_006_001.mp3","charTypeName":"word"},{"id":7010,"position":2,"arabic":"قَالَ","translation":"বলেছিলো","audioUrl":"wbw/014_006_002.mp3","charTypeName":"word"},{"id":7011,"position":3,"arabic":"مُوسَىٰ","translation":"মুসা","audioUrl":"wbw/014_006_003.mp3","charTypeName":"word"},{"id":7012,"position":4,"arabic":"لِقَوْمِهِ","translation":"তার জাতিকে","audioUrl":"wbw/014_006_004.mp3","charTypeName":"word"},{"id":7013,"position":5,"arabic":"ٱذْكُرُوا۟","translation":"\"তোমরা স্মরণ করো","audioUrl":"wbw/014_006_005.mp3","charTypeName":"word"},{"id":7014,"position":6,"arabic":"نِعْمَةَ","translation":"অনুগ্রহ","audioUrl":"wbw/014_006_006.mp3","charTypeName":"word"},{"id":7015,"position":7,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/014_006_007.mp3","charTypeName":"word"},{"id":7016,"position":8,"arabic":"عَلَيْكُمْ","translation":"তোমাদের উপর","audioUrl":"wbw/014_006_008.mp3","charTypeName":"word"},{"id":7017,"position":9,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/014_006_009.mp3","charTypeName":"word"},{"id":7018,"position":10,"arabic":"أَنجَىٰكُم","translation":"তোমাদের তিনি রক্ষা করেন","audioUrl":"wbw/014_006_010.mp3","charTypeName":"word"},{"id":7019,"position":11,"arabic":"مِّنْ","translation":"থেকে","audioUrl":"wbw/014_006_011.mp3","charTypeName":"word"},{"id":7020,"position":12,"arabic":"ءَالِ","translation":"সম্প্রদায়","audioUrl":"wbw/014_006_012.mp3","charTypeName":"word"},{"id":7021,"position":13,"arabic":"فِرْعَوْنَ","translation":"ফিরাউনের","audioUrl":"wbw/014_006_013.mp3","charTypeName":"word"},{"id":7022,"position":14,"arabic":"يَسُومُونَكُمْ","translation":"তোমাদের উপর তারা প্রয়োগ করতো","audioUrl":"wbw/014_006_014.mp3","charTypeName":"word"},{"id":7023,"position":15,"arabic":"سُوٓءَ","translation":"নিকৃষ্ট","audioUrl":"wbw/014_006_015.mp3","charTypeName":"word"},{"id":7024,"position":16,"arabic":"ٱلْعَذَابِ","translation":"শাস্তি","audioUrl":"wbw/014_006_016.mp3","charTypeName":"word"},{"id":7025,"position":17,"arabic":"وَيُذَبِّحُونَ","translation":"এবং তারা জবেহ করতো","audioUrl":"wbw/014_006_017.mp3","charTypeName":"word"},{"id":7026,"position":18,"arabic":"أَبْنَآءَكُمْ","translation":"তোমাদের পুত্রসন্তানদেরকে","audioUrl":"wbw/014_006_018.mp3","charTypeName":"word"},{"id":7027,"position":19,"arabic":"وَيَسْتَحْيُونَ","translation":"ও তারা জীবিত রাখতো","audioUrl":"wbw/014_006_019.mp3","charTypeName":"word"},{"id":7028,"position":20,"arabic":"نِسَآءَكُمْ ۚ","translation":"তোমাদের মেয়েদেরকে","audioUrl":"wbw/014_006_020.mp3","charTypeName":"word"},{"id":7030,"position":21,"arabic":"وَفِى","translation":"এবং মধ্যে (ছিলো)","audioUrl":"wbw/014_006_022.mp3","charTypeName":"word"},{"id":7031,"position":22,"arabic":"ذَٰلِكُم","translation":"এর তোমাদের জন্যে","audioUrl":"wbw/014_006_023.mp3","charTypeName":"word"},{"id":7032,"position":23,"arabic":"بَلَآءٌۭ","translation":"পরীক্ষা","audioUrl":"wbw/014_006_024.mp3","charTypeName":"word"},{"id":7033,"position":24,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/014_006_025.mp3","charTypeName":"word"},{"id":7034,"position":25,"arabic":"رَّبِّكُمْ","translation":"তোমাদের রবের","audioUrl":"wbw/014_006_026.mp3","charTypeName":"word"},{"id":7035,"position":26,"arabic":"عَظِيمٌۭ","translation":"বিরাট\"","audioUrl":"wbw/014_006_027.mp3","charTypeName":"word"},{"id":7036,"position":27,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"وَإِذْ تَأَذَّنَ رَبُّكُمْ لَئِن شَكَرْتُمْ لَأَزِيدَنَّكُمْ ۖ وَلَئِن كَفَرْتُمْ إِنَّ عَذَابِى لَشَدِيدٌۭ","translation":"And [remember the time] when your Sustainer made [this promise] known: 'If you are grateful [to Me], I shall most certainly give you more and more; but if you are ungrateful, verily, My chastisement will be severe indeed!\"'","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1757.mp3","surahId":14,"words":[{"id":8324,"position":1,"arabic":"وَإِذْ","translation":"এবং (স্মরণ করো) যখন","audioUrl":"wbw/014_007_001.mp3","charTypeName":"word"},{"id":8325,"position":2,"arabic":"تَأَذَّنَ","translation":"ঘোষণা করেন","audioUrl":"wbw/014_007_002.mp3","charTypeName":"word"},{"id":8326,"position":3,"arabic":"رَبُّكُمْ","translation":"তোমার রব","audioUrl":"wbw/014_007_003.mp3","charTypeName":"word"},{"id":8327,"position":4,"arabic":"لَئِن","translation":"\"অবশ্যই যদি","audioUrl":"wbw/014_007_004.mp3","charTypeName":"word"},{"id":8328,"position":5,"arabic":"شَكَرْتُمْ","translation":"তোমরা কৃতজ্ঞ হও","audioUrl":"wbw/014_007_005.mp3","charTypeName":"word"},{"id":8329,"position":6,"arabic":"لَأَزِيدَنَّكُمْ ۖ","translation":"এবং তোমাদের অবশ্যই অধিক দিবো","audioUrl":"wbw/014_007_006.mp3","charTypeName":"word"},{"id":8331,"position":7,"arabic":"وَلَئِن","translation":"আর অবশ্যই যদি","audioUrl":"wbw/014_007_008.mp3","charTypeName":"word"},{"id":8332,"position":8,"arabic":"كَفَرْتُمْ","translation":"তোমরা অকৃতজ্ঞ হও","audioUrl":"wbw/014_007_009.mp3","charTypeName":"word"},{"id":8333,"position":9,"arabic":"إِنَّ","translation":"নিশ্চয়ই (তবে)","audioUrl":"wbw/014_007_010.mp3","charTypeName":"word"},{"id":8334,"position":10,"arabic":"عَذَابِى","translation":"আমার শাস্তি","audioUrl":"wbw/014_007_011.mp3","charTypeName":"word"},{"id":8335,"position":11,"arabic":"لَشَدِيدٌۭ","translation":"অবশ্যই কঠোর\"","audioUrl":"wbw/014_007_012.mp3","charTypeName":"word"},{"id":8336,"position":12,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"وَقَالَ مُوسَىٰٓ إِن تَكْفُرُوٓا۟ أَنتُمْ وَمَن فِى ٱلْأَرْضِ جَمِيعًۭا فَإِنَّ ٱللَّهَ لَغَنِىٌّ حَمِيدٌ","translation":"And Moses added: \"If you should [ever] deny the truth-you and whoever else lives on earth, all of you-[know that,] verily, God is indeed self-sufficient, ever to be praised!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1758.mp3","surahId":14,"words":[{"id":9479,"position":1,"arabic":"وَقَالَ","translation":"এবং বলেছিলো","audioUrl":"wbw/014_008_001.mp3","charTypeName":"word"},{"id":9480,"position":2,"arabic":"مُوسَىٰٓ","translation":"মুসা","audioUrl":"wbw/014_008_002.mp3","charTypeName":"word"},{"id":9481,"position":3,"arabic":"إِن","translation":"\"যদি","audioUrl":"wbw/014_008_003.mp3","charTypeName":"word"},{"id":9482,"position":4,"arabic":"تَكْفُرُوٓا۟","translation":"অস্বীকার করো","audioUrl":"wbw/014_008_004.mp3","charTypeName":"word"},{"id":9483,"position":5,"arabic":"أَنتُمْ","translation":"তোমরা","audioUrl":"wbw/014_008_005.mp3","charTypeName":"word"},{"id":9484,"position":6,"arabic":"وَمَن","translation":"ও যা কিছু","audioUrl":"wbw/014_008_006.mp3","charTypeName":"word"},{"id":9485,"position":7,"arabic":"فِى","translation":"মধ্যে আছে","audioUrl":"wbw/014_008_007.mp3","charTypeName":"word"},{"id":9486,"position":8,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/014_008_008.mp3","charTypeName":"word"},{"id":9487,"position":9,"arabic":"جَمِيعًۭا","translation":"সকলেই","audioUrl":"wbw/014_008_009.mp3","charTypeName":"word"},{"id":9488,"position":10,"arabic":"فَإِنَّ","translation":"তবুও নিশ্চয়ই","audioUrl":"wbw/014_008_010.mp3","charTypeName":"word"},{"id":9489,"position":11,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/014_008_011.mp3","charTypeName":"word"},{"id":9490,"position":12,"arabic":"لَغَنِىٌّ","translation":"অবশ্যই অভাবমুক্ত","audioUrl":"wbw/014_008_012.mp3","charTypeName":"word"},{"id":9491,"position":13,"arabic":"حَمِيدٌ","translation":"প্রশংসিত\"","audioUrl":"wbw/014_008_013.mp3","charTypeName":"word"},{"id":9492,"position":14,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"أَلَمْ يَأْتِكُمْ نَبَؤُا۟ ٱلَّذِينَ مِن قَبْلِكُمْ قَوْمِ نُوحٍۢ وَعَادٍۢ وَثَمُودَ ۛ وَٱلَّذِينَ مِنۢ بَعْدِهِمْ ۛ لَا يَعْلَمُهُمْ إِلَّا ٱللَّهُ ۚ جَآءَتْهُمْ رُسُلُهُم بِٱلْبَيِّنَٰتِ فَرَدُّوٓا۟ أَيْدِيَهُمْ فِىٓ أَفْوَٰهِهِمْ وَقَالُوٓا۟ إِنَّا كَفَرْنَا بِمَآ أُرْسِلْتُم بِهِۦ وَإِنَّا لَفِى شَكٍّۢ مِّمَّا تَدْعُونَنَآ إِلَيْهِ مُرِيبٍۢ","translation":"HAVE THE STORIES of those [deniers of the truth] who lived before you never yet come within your ken - [the stories of] the people of Noah, and of [the tribes of] `Ad and Thamud, and of those who came after them? None knows them [now] save God. There came unto them their apostles with all evidence of the truth -but they covered their mouths with their hands and answered: \"Behold, we refuse to regard as true the message with which you [claim to] have been entrusted; and, behold, we are in grave doubt, amounting to suspicion, about [the meaning of] your call to us!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1759.mp3","surahId":14,"words":[{"id":10640,"position":1,"arabic":"أَلَمْ","translation":"কাছে কি","audioUrl":"wbw/014_009_001.mp3","charTypeName":"word"},{"id":10641,"position":2,"arabic":"يَأْتِكُمْ","translation":"আসে নি তোমাদের","audioUrl":"wbw/014_009_002.mp3","charTypeName":"word"},{"id":10642,"position":3,"arabic":"نَبَؤُا۟","translation":"সংবাদ","audioUrl":"wbw/014_009_003.mp3","charTypeName":"word"},{"id":10643,"position":4,"arabic":"ٱلَّذِينَ","translation":"(তাদের) যারা","audioUrl":"wbw/014_009_004.mp3","charTypeName":"word"},{"id":10644,"position":5,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/014_009_005.mp3",