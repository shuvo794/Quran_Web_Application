{"id":80,"ayahs":[{"number":15,"arabic":"وَٱلَّٰتِى يَأْتِينَ ٱلْفَٰحِشَةَ مِن نِّسَآئِكُمْ فَٱسْتَشْهِدُوا۟ عَلَيْهِنَّ أَرْبَعَةًۭ مِّنكُمْ ۖ فَإِن شَهِدُوا۟ فَأَمْسِكُوهُنَّ فِى ٱلْبُيُوتِ حَتَّىٰ يَتَوَفَّىٰهُنَّ ٱلْمَوْتُ أَوْ يَجْعَلَ ٱللَّهُ لَهُنَّ سَبِيلًۭا","translation":"AND AS FOR those of your women who become guilty of immoral conduct, call upon four from among you who have witnessed their guilt; and if these bear witness thereto, confine the guilty women to their houses until death takes them away or God opens for them a way [through repentance].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/508.mp3","surahId":4,"words":[{"id":16900,"position":1,"arabic":"وَٱلَّـٰتِى","translation":"এবং যে সব মহিলা","audioUrl":"wbw/004_015_001.mp3","charTypeName":"word"},{"id":16901,"position":2,"arabic":"يَأْتِينَ","translation":"লিপ্ত হয়","audioUrl":"wbw/004_015_002.mp3","charTypeName":"word"},{"id":16902,"position":3,"arabic":"ٱلْفَـٰحِشَةَ","translation":"ব্যভিচারে","audioUrl":"wbw/004_015_003.mp3","charTypeName":"word"},{"id":16903,"position":4,"arabic":"مِن","translation":"মধ্য হতে","audioUrl":"wbw/004_015_004.mp3","charTypeName":"word"},{"id":16904,"position":5,"arabic":"نِّسَآئِكُمْ","translation":"তোমাদের নারীদের","audioUrl":"wbw/004_015_005.mp3","charTypeName":"word"},{"id":16905,"position":6,"arabic":"فَٱسْتَشْهِدُوا۟","translation":"তবে তোমরা সাক্ষী চাও","audioUrl":"wbw/004_015_006.mp3","charTypeName":"word"},{"id":16906,"position":7,"arabic":"عَلَيْهِنَّ","translation":"তাদের উপর","audioUrl":"wbw/004_015_007.mp3","charTypeName":"word"},{"id":16907,"position":8,"arabic":"أَرْبَعَةًۭ","translation":"চার (জনের)","audioUrl":"wbw/004_015_008.mp3","charTypeName":"word"},{"id":16908,"position":9,"arabic":"مِّنكُمْ ۖ","translation":"তোমাদের মধ্য থেকে","audioUrl":"wbw/004_015_009.mp3","charTypeName":"word"},{"id":16910,"position":10,"arabic":"فَإِن","translation":"যদি অতঃপর","audioUrl":"wbw/004_015_011.mp3","charTypeName":"word"},{"id":16911,"position":11,"arabic":"شَهِدُوا۟","translation":"তারা সাক্ষী দেয়","audioUrl":"wbw/004_015_012.mp3","charTypeName":"word"},{"id":16912,"position":12,"arabic":"فَأَمْسِكُوهُنَّ","translation":"তোমরা আবদ্ধ কর তবে তাদেরকে","audioUrl":"wbw/004_015_013.mp3","charTypeName":"word"},{"id":16913,"position":13,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/004_015_014.mp3","charTypeName":"word"},{"id":16914,"position":14,"arabic":"ٱلْبُيُوتِ","translation":"(তাদের) ঘরগুলোর","audioUrl":"wbw/004_015_015.mp3","charTypeName":"word"},{"id":16915,"position":15,"arabic":"حَتَّىٰ","translation":"যতক্ষণ না","audioUrl":"wbw/004_015_016.mp3","charTypeName":"word"},{"id":16916,"position":16,"arabic":"يَتَوَفَّىٰهُنَّ","translation":"তাদের উঠিয়ে নেয়","audioUrl":"wbw/004_015_017.mp3","charTypeName":"word"},{"id":16917,"position":17,"arabic":"ٱلْمَوْتُ","translation":"মৃত্যু","audioUrl":"wbw/004_015_018.mp3","charTypeName":"word"},{"id":16918,"position":18,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/004_015_019.mp3","charTypeName":"word"},{"id":16919,"position":19,"arabic":"يَجْعَلَ","translation":"করে দেন","audioUrl":"wbw/004_015_020.mp3","charTypeName":"word"},{"id":16920,"position":20,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/004_015_021.mp3","charTypeName":"word"},{"id":16921,"position":21,"arabic":"لَهُنَّ","translation":"তাদের জন্য","audioUrl":"wbw/004_015_022.mp3","charTypeName":"word"},{"id":16922,"position":22,"arabic":"سَبِيلًۭا","translation":"কোন পথ","audioUrl":"wbw/004_015_023.mp3","charTypeName":"word"},{"id":16923,"position":23,"arabic":"١٥","translation":"(১৫)","audioUrl":null,"charTypeName":"end"}]},{"number":16,"arabic":"وَٱلَّذَانِ يَأْتِيَٰنِهَا مِنكُمْ فَـَٔاذُوهُمَا ۖ فَإِن تَابَا وَأَصْلَحَا فَأَعْرِضُوا۟ عَنْهُمَآ ۗ إِنَّ ٱللَّهَ كَانَ تَوَّابًۭا رَّحِيمًا","translation":"And punish [thus] both of the guilty parties; but if they both repent and mend their ways, leave them alone: for, behold, God is an acceptor of repentance, a dispenser of grace.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/509.mp3","surahId":4,"words":[{"id":18020,"position":1,"arabic":"وَٱلَّذَانِ","translation":"এবং যে দুজন","audioUrl":"wbw/004_016_001.mp3","charTypeName":"word"},{"id":18021,"position":2,"arabic":"يَأْتِيَـٰنِهَا","translation":"তাতে লিপ্ত হবে","audioUrl":"wbw/004_016_002.mp3","charTypeName":"word"},{"id":18022,"position":3,"arabic":"مِنكُمْ","translation":"তোমাদের মধ্য হতে","audioUrl":"wbw/004_016_003.mp3","charTypeName":"word"},{"id":18023,"position":4,"arabic":"فَـَٔاذُوهُمَا ۖ","translation":"তাদের দুজনকে অতঃপর শাস্তি দাও","audioUrl":"wbw/004_016_004.mp3","charTypeName":"word"},{"id":18025,"position":5,"arabic":"فَإِن","translation":"অতঃপর যদি","audioUrl":"wbw/004_016_006.mp3","charTypeName":"word"},{"id":18026,"position":6,"arabic":"تَابَا","translation":"দুজনে তওবা করে","audioUrl":"wbw/004_016_007.mp3","charTypeName":"word"},{"id":18027,"position":7,"arabic":"وَأَصْلَحَا","translation":"ও দুজনে সংশোধন হয়","audioUrl":"wbw/004_016_008.mp3","charTypeName":"word"},{"id":18028,"position":8,"arabic":"فَأَعْرِضُوا۟","translation":"তোমরা তবে উপেক্ষা কর","audioUrl":"wbw/004_016_009.mp3","charTypeName":"word"},{"id":18029,"position":9,"arabic":"عَنْهُمَآ ۗ","translation":"তাদের দুজনকে (অর্থাৎ মাফ করে দাও)","audioUrl":"wbw/004_016_010.mp3","charTypeName":"word"},{"id":18031,"position":10,"arabic":"إِنَّ","translation":"নিশ্চয়","audioUrl":"wbw/004_016_012.mp3","charTypeName":"word"},{"id":18032,"position":11,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/004_016_013.mp3","charTypeName":"word"},{"id":18033,"position":12,"arabic":"كَانَ","translation":"হলেন","audioUrl":"wbw/004_016_014.mp3","charTypeName":"word"},{"id":18034,"position":13,"arabic":"تَوَّابًۭا","translation":"বড়ই ক্ষমাশীল","audioUrl":"wbw/004_016_015.mp3","charTypeName":"word"},{"id":18035,"position":14,"arabic":"رَّحِيمًا","translation":"মেহেরবান","audioUrl":"wbw/004_016_016.mp3","charTypeName":"word"},{"id":18036,"position":15,"arabic":"١٦","translation":"(১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":17,"arabic":"إِنَّمَا ٱلتَّوْبَةُ عَلَى ٱللَّهِ لِلَّذِينَ يَعْمَلُونَ ٱلسُّوٓءَ بِجَهَٰلَةٍۢ ثُمَّ يَتُوبُونَ مِن قَرِيبٍۢ فَأُو۟لَٰٓئِكَ يَتُوبُ ٱللَّهُ عَلَيْهِمْ ۗ وَكَانَ ٱللَّهُ عَلِيمًا حَكِيمًۭا","translation":"Verily, God's acceptance of repentance relates only to those who do evil out of ignorance and then repent before their time runs out: and it is they unto whom God will turn again in His mercy - for God is all-knowing, wise;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/510.mp3","surahId":4,"words":[{"id":19018,"position":1,"arabic":"إِنَّمَا","translation":"মুলতঃ","audioUrl":"wbw/004_017_001.mp3","charTypeName":"word"},{"id":19019,"position":2,"arabic":"ٱلتَّوْبَةُ","translation":"তওবা","audioUrl":"wbw/004_017_002.mp3","charTypeName":"word"},{"id":19020,"position":3,"arabic":"عَلَى","translation":"কাছে","audioUrl":"wbw/004_017_003.mp3","charTypeName":"word"},{"id":19021,"position":4,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/004_017_004.mp3","charTypeName":"word"},{"id":19022,"position":5,"arabic":"لِلَّذِينَ","translation":"(তাদের) জন্য যারা","audioUrl":"wbw/004_017_005.mp3","charTypeName":"word"},{"id":19023,"position":6,"arabic":"يَعْمَلُونَ","translation":"কাজ করে","audioUrl":"wbw/004_017_006.mp3","charTypeName":"word"},{"id":19024,"position":7,"arabic":"ٱلسُّوٓءَ","translation":"মন্দ","audioUrl":"wbw/004_017_007.mp3","charTypeName":"word"},{"id":19025,"position":8,"arabic":"بِجَهَـٰلَةٍۢ","translation":"অজ্ঞতার কারণে","audioUrl":"wbw/004_017_008.mp3","charTypeName":"word"},{"id":19026,"position":9,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/004_017_009.mp3","charTypeName":"word"},{"id":19027,"position":10,"arabic":"يَتُوبُونَ","translation":"তারা তওবা করে","audioUrl":"wbw/004_017_010.mp3","charTypeName":"word"},{"id":19028,"position":11,"arabic":"مِن","translation":"(থেকে)","audioUrl":"wbw/004_017_011.mp3","charTypeName":"word"},{"id":19029,"position":12,"arabic":"قَرِيبٍۢ","translation":"অবিলম্বে","audioUrl":"wbw/004_017_012.mp3","charTypeName":"word"},{"id":19030,"position":13,"arabic":"فَأُو۟لَـٰٓئِكَ","translation":"ঐসব লোক অতঃপর","audioUrl":"wbw/004_017_013.mp3","charTypeName":"word"},{"id":19031,"position":14,"arabic":"يَتُوبُ","translation":"ক্ষমাশীল হন","audioUrl":"wbw/004_017_014.mp3","charTypeName":"word"},{"id":19032,"position":15,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/004_017_015.mp3","charTypeName":"word"},{"id":19033,"position":16,"arabic":"عَلَيْهِمْ ۗ","translation":"তাদের উপর","audioUrl":"wbw/004_017_016.mp3","charTypeName":"word"},{"id":19035,"position":17,"arabic":"وَكَانَ","translation":"এবং হলেন","audioUrl":"wbw/004_017_018.mp3","charTypeName":"word"},{"id":19036,"position":18,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/004_017_019.mp3","charTypeName":"word"},{"id":19037,"position":19,"arabic":"عَلِيمًا","translation":"সর্বজ্ঞ","audioUrl":"wbw/004_017_020.mp3","charTypeName":"word"},{"id":19038,"position":20,"arabic":"حَكِيمًۭا","translation":"প্রজ্ঞাময়","audioUrl":"wbw/004_017_021.mp3","charTypeName":"word"},{"id":19039,"position":21,"arabic":"١٧","translation":"(১৭)","audioUrl":null,"charTypeName":"end"}]},{"number":18,"arabic":"وَلَيْسَتِ ٱلتَّوْبَةُ لِلَّذِينَ يَعْمَلُونَ ٱلسَّيِّـَٔاتِ حَتَّىٰٓ إِذَا حَضَرَ أَحَدَهُمُ ٱلْمَوْتُ قَالَ إِنِّى تُبْتُ ٱلْـَٰٔنَ وَلَا ٱلَّذِينَ يَمُوتُونَ وَهُمْ كُفَّارٌ ۚ أُو۟لَٰٓئِكَ أَعْتَدْنَا لَهُمْ عَذَابًا أَلِيمًۭا","translation":"whereas repentance shall not be accepted from those who do evil deeds until their dying hour and then say, \"Behold, I now repent\"; nor from those who die as deniers of the truth: it is these for whom We have readied grievous suffering.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/511.mp3","surahId":4,"words":[{"id":20144,"position":1,"arabic":"وَلَيْسَتِ","translation":"এবং নয়","audioUrl":"wbw/004_018_001.mp3","charTypeName":"wor