04_018_017.mp3","charTypeName":"word"},{"id":20161,"position":18,"arabic":"وَهُمْ","translation":"তারা এ অবস্থায় যে","audioUrl":"wbw/004_018_018.mp3","charTypeName":"word"},{"id":20162,"position":19,"arabic":"كُفَّارٌ ۚ","translation":"কাফির","audioUrl":"wbw/004_018_019.mp3","charTypeName":"word"},{"id":20164,"position":20,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐসব লোক","audioUrl":"wbw/004_018_021.mp3","charTypeName":"word"},{"id":20165,"position":21,"arabic":"أَعْتَدْنَا","translation":"আমরা তৈরী করে রেখেছি","audioUrl":"wbw/004_018_022.mp3","charTypeName":"word"},{"id":20166,"position":22,"arabic":"لَهُمْ","translation":"তাদের জন্য","audioUrl":"wbw/004_018_023.mp3","charTypeName":"word"},{"id":20167,"position":23,"arabic":"عَذَابًا","translation":"আজাব","audioUrl":"wbw/004_018_024.mp3","charTypeName":"word"},{"id":20168,"position":24,"arabic":"أَلِيمًۭا","translation":"বড় যন্ত্রণাদায়ক","audioUrl":"wbw/004_018_025.mp3","charTypeName":"word"},{"id":20169,"position":25,"arabic":"١٨","translation":"(১৮)","audioUrl":null,"charTypeName":"end"}]},{"number":19,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ لَا يَحِلُّ لَكُمْ أَن تَرِثُوا۟ ٱلنِّسَآءَ كَرْهًۭا ۖ وَلَا تَعْضُلُوهُنَّ لِتَذْهَبُوا۟ بِبَعْضِ مَآ ءَاتَيْتُمُوهُنَّ إِلَّآ أَن يَأْتِينَ بِفَٰحِشَةٍۢ مُّبَيِّنَةٍۢ ۚ وَعَاشِرُوهُنَّ بِٱلْمَعْرُوفِ ۚ فَإِن كَرِهْتُمُوهُنَّ فَعَسَىٰٓ أَن تَكْرَهُوا۟ شَيْـًۭٔا وَيَجْعَلَ ٱللَّهُ فِيهِ خَيْرًۭا كَثِيرًۭا","translation":"O YOU who have attained to faith! It is not lawful for you to [try to] become heirs to your wives [by holding onto them] against their will; and neither shall you keep them under constraint with a view to taking away anything of what you may have given them, unless it be that they have become guilty, in an obvious man­ner, of immoral conduct. And consort with your wives in a goodly manner; for if you dislike them, it may well be that you dislike something which God might yet make a source of abundant good.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/512.mp3","surahId":4,"words":[{"id":21209,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"ওহে","audioUrl":"wbw/004_019_001.mp3","charTypeName":"word"},{"id":21210,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/004_019_002.mp3","charTypeName":"word"},{"id":21211,"position":3,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছ","audioUrl":"wbw/004_019_003.mp3","charTypeName":"word"},{"id":21212,"position":4,"arabic":"لَا","translation":"না","audioUrl":"wbw/004_019_004.mp3","charTypeName":"word"},{"id":21213,"position":5,"arabic":"يَحِلُّ","translation":"বৈধ হবে","audioUrl":"wbw/004_019_005.mp3","charTypeName":"word"},{"id":21214,"position":6,"arabic":"لَكُمْ","translation":"তোমাদের জন্য","audioUrl":"wbw/004_019_006.mp3","charTypeName":"word"},{"id":21215,"position":7,"arabic":"أَن","translation":"যে","audioUrl":"wbw/004_019_007.mp3","charTypeName":"word"},{"id":21216,"position":8,"arabic":"تَرِثُوا۟","translation":"তোমরা উত্তরাধিকারী হবে","audioUrl":"wbw/004_019_008.mp3","charTypeName":"word"},{"id":21217,"position":9,"arabic":"ٱلنِّسَآءَ","translation":"স্ত্রীলোকদের","audioUrl":"wbw/004_019_009.mp3","charTypeName":"word"},{"id":21218,"position":10,"arabic":"كَرْهًۭا ۖ","translation":"জোরপূর্বক","audioUrl":"wbw/004_019_010.mp3","charTypeName":"word"},{"id":21220,"position":11,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/004_019_012.mp3","charTypeName":"word"},{"id":21221,"position":12,"arabic":"تَعْضُلُوهُنَّ","translation":"তোমরা বাধা দিও (বিবাহবন্ধন হতে) তাদেরকে","audioUrl":"wbw/004_019_013.mp3","charTypeName":"word"},{"id":21222,"position":13,"arabic":"لِتَذْهَبُوا۟","translation":"তোমরা নেয়ার জন্য","audioUrl":"wbw/004_019_014.mp3","charTypeName":"word"},{"id":21223,"position":14,"arabic":"بِبَعْضِ","translation":"কিছু অংশ","audioUrl":"wbw/004_019_015.mp3","charTypeName":"word"},{"id":21224,"position":15,"arabic":"مَآ","translation":"যা","audioUrl":"wbw/004_019_016.mp3","charTypeName":"word"},{"id":21225,"posit