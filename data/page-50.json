{"id":50,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ الٓمٓ","translation":"Alif. Lam. Mim.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/294.mp3","surahId":3,"words":[{"id":16,"position":1,"arabic":"الٓمٓ","translation":"আলিফ লা-ম মী-ম","audioUrl":"wbw/003_001_001.mp3","charTypeName":"word"},{"id":17,"position":2,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"ٱللَّهُ لَآ إِلَٰهَ إِلَّا هُوَ ٱلْحَىُّ ٱلْقَيُّومُ","translation":"GOD - there is no deity save Him, the Ever-Living, the Self-Subsistent Fount of All Being!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/295.mp3","surahId":3,"words":[{"id":1183,"position":1,"arabic":"ٱللَّهُ","translation":"আল্লাহ (এমন সত্তা)","audioUrl":"wbw/003_002_001.mp3","charTypeName":"word"},{"id":1184,"position":2,"arabic":"لَآ","translation":"নেই","audioUrl":"wbw/003_002_002.mp3","charTypeName":"word"},{"id":1185,"position":3,"arabic":"إِلَـٰهَ","translation":"কোনো ইলাহ","audioUrl":"wbw/003_002_003.mp3","charTypeName":"word"},{"id":1186,"position":4,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/003_002_004.mp3","charTypeName":"word"},{"id":1187,"position":5,"arabic":"هُوَ","translation":"তিনি","audioUrl":"wbw/003_002_005.mp3","charTypeName":"word"},{"id":1188,"position":6,"arabic":"ٱلْحَىُّ","translation":"(তিনিই) চিরঞ্জীব","audioUrl":"wbw/003_002_006.mp3","charTypeName":"word"},{"id":1189,"position":7,"arabic":"ٱلْقَيُّومُ","translation":"সর্বসত্তার ধারক","audioUrl":"wbw/003_002_007.mp3","charTypeName":"word"},{"id":1190,"position":8,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"نَزَّلَ عَلَيْكَ ٱلْكِتَٰبَ بِٱلْحَقِّ مُصَدِّقًۭا لِّمَا بَيْنَ يَدَيْهِ وَأَنزَلَ ٱلتَّوْرَىٰةَ وَٱلْإِنجِيلَ","translation":"Step by step has He bestowed upon thee from on high this divine writ, setting forth the truth which confirms whatever there still remains [of earlier revelations]: for it is He who has bestowed from on high the Torah and the Gospel","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/296.mp3","surahId":3,"words":[{"id":2239,"position":1,"arabic":"نَزَّلَ","translation":"তিনি অবতীর্ণ করেছেন","audioUrl":"wbw/003_003_001.mp3","charTypeName":"word"},{"id":2240,"position":2,"arabic":"عَلَيْكَ","translation":"তোমার উপর","audioUrl":"wbw/003_003_002.mp3","charTypeName":"word"},{"id":2241,"position":3,"arabic":"ٱلْكِتَـٰبَ","translation":"কিতাব","audioUrl":"wbw/003_003_003.mp3","charTypeName":"word"},{"id":2242,"position":4,"arabic":"بِٱلْحَقِّ","translation":"সত্যসহ","audioUrl":"wbw/003_003_004.mp3","charTypeName":"word"},{"id":2243,"position":5,"arabic":"مُصَدِّقًۭا","translation":"সত্যায়নকারী","audioUrl":"wbw/003_003_005.mp3","charTypeName":"word"},{"id":2244,"position":6,"arabic":"لِّمَا","translation":"তার জন্য যা","audioUrl":"wbw/003_003_006.mp3","charTypeName":"word"},{"id":2245,"position":7,"arabic":"بَيْنَ","translation":"মাঝে","audioUrl":"wbw/003_003_007.mp3","charTypeName":"word"},{"id":2246,"position":8,"arabic":"يَدَيْهِ","translation":"(এসেছে হাতের) তার পূর্বে","audioUrl":"wbw/003_003_008.mp3","charTypeName":"word"},{"id":2247,"position":9,"arabic":"وَأَنزَلَ","translation":"এবং তিনি অবতীর্ণ করেছেন","audioUrl":"wbw/003_003_009.mp3","charTypeName":"word"},{"id":2248,"position":10,"arabic":"ٱلتَّوْرَىٰةَ","translation":"তওরাত","audioUrl":"wbw/003_003_010.mp3","charTypeName":"word"},{"id":2249,"position":11,"arabic":"وَٱلْإِنجِيلَ","translation":"ও ইঞ্জীল","audioUrl":"wbw/003_003_011.mp3","charTypeName":"word"},{"id":2250,"position":12,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"مِن قَبْلُ هُدًۭى لِّلنَّاسِ وَأَنزَلَ ٱلْفُرْقَانَ ۗ إِنَّ ٱلَّذِينَ كَفَرُوا۟ بِـَٔايَٰتِ ٱللَّهِ لَهُمْ عَذَابٌۭ شَدِيدٌۭ ۗ وَٱللَّهُ عَزِيزٌۭ ذُو ٱنتِقَامٍ","translation":"aforetime, as a guidance unto mankind, and it is He who has bestowed [upon man] the standard by which to discern the true from the false. Behold, as for those who are bent on denying God's messages - grievous suffering awaits them: for God is almighty, an avenger of evil.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/297.mp3","surahId":3,"words":[{"id":3561,"position":1,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/003_004_001.mp3","charTypeName":"word"},{"id":3562,"position":2,"arabic":"قَبْلُ","translation":"ইতিপূর্ব","audioUrl":"wbw/003_004_002.mp3","charTypeName":"word"},{"id":3563,"position":3,"arabic":"هُدًۭى","translation":"সঠিকপথ (হিসেবে)","audioUrl":"wbw/003_004_003.mp3","charTypeName":"word"},{"id":3564,"position":4,"arabic":"لِّلنَّاسِ","translation":"মানুষের জন্য","audioUrl":"wbw/003_004_004.mp3","charTypeName":"word"},{"id":3565,"position":5,"arabic":"وَأَنزَلَ","translation":"এবং তিনি অবতীর্ণ করেছেন","audioUrl":"wbw/003_004_005.mp3","charTypeName":"word"},{"id":3566,"position":6,"arabic":"ٱلْفُرْقَانَ ۗ","translation":"ফুরকান(ন্যায়-অন্যায়ের মীমাংসা)","audioUrl":"wbw/003_004_006.mp3","charTypeName":"word"},{"id":3568,"position":7,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/003_004_008.mp3","charTypeName":"word"},{"id":3569,"position":8,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/003_004_009.mp3","charTypeName":"word"},{"id":3570,"position":9,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/003_004_010.mp3","charTypeName":"word"},{"id":3571,"position":10,"arabic":"بِـَٔايَـٰتِ","translation":"নিদর্শনগুলোর প্রতি","audioUrl":"wbw/003_004_011.mp3","charTypeName":"word"},{"id":3572,"position":11,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/003_004_012.mp3","charTypeName":"word"},{"id":3573,"position":12,"arabic":"لَهُمْ","translation":"তাদের জন্য","audioUrl":"wbw/003_004_013.mp3","charTypeName":"word"},{"id":3574,"position":13,"arabic":"عَذَابٌۭ","translation":"শাস্তি (রয়েছে)","audioUrl":"wbw/003_004_014.mp3","charTypeName":"word"},{"id":3575,"position":14,"arabic":"شَدِيدٌۭ ۗ","tran