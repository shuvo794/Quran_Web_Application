lation":"আর না","audioUrl":"wbw/003_005_009.mp3","charTypeName":"word"},{"id":4927,"position":10,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/003_005_010.mp3","charTypeName":"word"},{"id":4928,"position":11,"arabic":"ٱلسَّمَآءِ","translation":"আকাশের","audioUrl":"wbw/003_005_011.mp3","charTypeName":"word"},{"id":4929,"position":12,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"هُوَ ٱلَّذِى يُصَوِّرُكُمْ فِى ٱلْأَرْحَامِ كَيْفَ يَشَآءُ ۚ لَآ إِلَٰهَ إِلَّا هُوَ ٱلْعَزِيزُ ٱلْحَكِيمُ","translation":"He it is who shapes you in the wombs as He wills. There is no deity save Him, the Almighty, the Truly Wise.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/299.mp3","surahId":3,"words":[{"id":6166,"position":1,"arabic":"هُوَ","translation":"তিনিই (সেই সত্তা)","audioUrl":"wbw/003_006_001.mp3","charTypeName":"word"},{"id":6167,"position":2,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/003_006_002.mp3","charTypeName":"word"},{"id":6168,"position":3,"arabic":"يُصَوِّرُكُمْ","translation":"আকৃতি গঠন করেন তোমাদের","audioUrl":"wbw/003_006_003.mp3","charTypeName":"word"},{"id":6169,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/003_006_004.mp3","charTypeName":"word"},{"id":6170,"position":5,"arabic":"ٱلْأَرْحَامِ","translation":"মাতৃগর্ভসমূহের","audioUrl":"wbw/003_006_005.mp3","charTypeName":"word"},{"id":6171,"position":6,"arabic":"كَيْفَ","translation":"যেভাবে","audioUrl":"wbw/003_006_006.mp3","charTypeName":"word"},{"id":6172,"position":7,"arabic":"يَشَآءُ ۚ","translation":"তিনি চান","audioUrl":"wbw/003_006_007.mp3","charTypeName":"word"},{"id":6174,"position":8,"arabic":"لَآ","translation":"নেই","audioUrl":"wbw/003_006_009.mp3","charTypeName":"word"},{"id":6175,"position":9,"arabic":"إِلَـٰهَ","translation":"কোনো ইলাহ","audioUrl":"wbw/003_006_010.mp3","charTypeName":"word"},{"id":6176,"position":10,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/003_006_011.mp3","charTypeName":"word"},{"id":6177,"position":11,"arabic":"هُوَ","translation":"তিনি","audioUrl":"wbw/003_006_012.mp3","charTypeName":"word"},{"id":6178,"position":12,"arabic":"ٱلْعَزِيزُ","translation":"পরাক্রমশালী","audioUrl":"wbw/003_006_013.mp3","charTypeName":"word"},{"id":6179,"position":13,"arabic":"ٱلْحَكِيمُ","translation":"মহাবিজ্ঞ","audioUrl":"wbw/003_006_014.mp3","charTypeName":"word"},{"id":6180,"position":14,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"هُوَ ٱلَّذِىٓ أَنزَلَ عَلَيْكَ ٱلْكِتَٰبَ مِنْهُ ءَايَٰتٌۭ مُّحْكَمَٰتٌ هُنَّ أُمُّ ٱلْكِتَٰبِ وَأُخَرُ مُتَشَٰبِهَٰتٌۭ ۖ فَأَمَّا ٱلَّذِينَ فِى قُلُوبِهِمْ زَيْغٌۭ فَيَتَّبِعُونَ مَا تَشَٰبَهَ مِنْهُ ٱبْتِغَآءَ ٱلْفِتْنَةِ وَٱبْتِغَآءَ تَأْوِيلِهِۦ ۗ وَمَا يَعْلَمُ تَأْوِيلَهُۥٓ إِلَّا ٱللَّهُ ۗ وَٱلرَّٰسِخُونَ فِى ٱلْعِلْمِ يَقُولُونَ ءَامَنَّا بِهِۦ كُلٌّۭ مِّنْ عِندِ رَبِّنَا ۗ وَمَا يَذَّكَّرُ إِلَّآ أُو۟لُوا۟ ٱلْأَلْبَٰبِ","translation":"He it is who has bestowed upon thee from on high this divine writ, containing messages that are clear in and by themselves - and these are the essence of the divine writ - as well as others that are allegorical. Now those whose hearts are given to swerving from the truth go after that part of the divine writ which has been expressed in allegory, seeking out [what is bound to create] confusion, and seeking [to arrive at] its final meaning [in an arbitrary manner]; but none save God knows its final meaning. Hence, those who are deeply rooted in knowledge say: \"We believe in it; the whole [of the divine writ] is from our Sustainer - albeit none takes this to heart save those who are endowed with insight.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/300.mp3","surahId":3,"words":[{"id":7504,"position":1,"arabic":"هُوَ","translation":"তিনিই (সেই সত্তা)","audioUrl":"wbw/003_007_001.mp3","charTypeName":"word"},{"id":7505,"position":2,"arabic":"ٱلَّذِىٓ","translation":"যিনি","audioUrl":"wbw/003_007_002.m