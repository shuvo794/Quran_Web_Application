{"id":547,"ayahs":[{"number":10,"arabic":"وَٱلَّذِينَ جَآءُو مِنۢ بَعْدِهِمْ يَقُولُونَ رَبَّنَا ٱغْفِرْ لَنَا وَلِإِخْوَٰنِنَا ٱلَّذِينَ سَبَقُونَا بِٱلْإِيمَٰنِ وَلَا تَجْعَلْ فِى قُلُوبِنَا غِلًّۭا لِّلَّذِينَ ءَامَنُوا۟ رَبَّنَآ إِنَّكَ رَءُوفٌۭ رَّحِيمٌ","translation":"And so, they who come after them pray: “O our Sustainer! Forgive us our sins, as well as those of our brethren who preceded us in faith, and let not our hearts entertain any unworthy thoughts or feelings against [any of] those who have attained to faith. O our Sustainer! Verily, Thou art compassionate, a dispenser of grace!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5136.mp3","surahId":59,"words":[{"id":11275,"position":1,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/059_010_001.mp3","charTypeName":"word"},{"id":11276,"position":2,"arabic":"جَآءُو","translation":"এসেছে","audioUrl":"wbw/059_010_002.mp3","charTypeName":"word"},{"id":11277,"position":3,"arabic":"مِنۢ","translation":"মধ্য হতে","audioUrl":"wbw/059_010_003.mp3","charTypeName":"word"},{"id":11278,"position":4,"arabic":"بَعْدِهِمْ","translation":"তাদের পরে","audioUrl":"wbw/059_010_004.mp3","charTypeName":"word"},{"id":11279,"position":5,"arabic":"يَقُولُونَ","translation":"তারা বলে","audioUrl":"wbw/059_010_005.mp3","charTypeName":"word"},{"id":11280,"position":6,"arabic":"رَبَّنَا","translation":"\"হে আমাদের রব","audioUrl":"wbw/059_010_006.mp3","charTypeName":"word"},{"id":11281,"position":7,"arabic":"ٱغْفِرْ","translation":"ক্ষমা কর","audioUrl":"wbw/059_010_007.mp3","charTypeName":"word"},{"id":11282,"position":8,"arabic":"لَنَا","translation":"আমাদের","audioUrl":"wbw/059_010_008.mp3","charTypeName":"word"},{"id":11283,"position":9,"arabic":"وَلِإِخْوَٰنِنَا","translation":"ও আমাদের ভাই দেরকে","audioUrl":"wbw/059_010_009.mp3","charTypeName":"word"},{"id":11284,"position":10,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/059_010_010.mp3","charTypeName":"word"},{"id":11285,"position":11,"arabic":"سَبَقُونَا","translation":"আমাদের অগ্রণী হয়েছে","audioUrl":"wbw/059_010_011.mp3","charTypeName":"word"},{"id":11286,"position":12,"arabic":"بِٱلْإِيمَـٰنِ","translation":"ইমানের ক্ষেত্রে","audioUrl":"wbw/059_010_012.mp3","charTypeName":"word"},{"id":11287,"position":13,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/059_010_013.mp3","charTypeName":"word"},{"id":11288,"position":14,"arabic":"تَجْعَلْ","translation":"রেখো","audioUrl":"wbw/059_010_014.mp3","charTypeName":"word"},{"id":11289,"position":15,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/059_010_015.mp3","charTypeName":"word"},{"id":11290,"position":16,"arabic":"قُلُوبِنَا","translation":"আমদের অন্তর গুলোর","audioUrl":"wbw/059_010_016.mp3","charTypeName":"word"},{"id":11291,"position":17,"arabic":"غِلًّۭا","translation":"হিংসা বিদ্বেষ","audioUrl":"wbw/059_010_017.mp3","charTypeName":"word"},{"id":11292,"position":18,"arabic":"لِّلَّذِينَ","translation":"যারাা (তাদের) জন্য","audioUrl":"wbw/059_010_018.mp3","charTypeName":"word"},{"id":11293,"position":19,"arabic":"ءَامَنُوا۟","translation":"ইমান এনেছে","audioUrl":"wbw/059_010_019.mp3","charTypeName":"word"},{"id":11294,"position":20,"arabic":"رَبَّنَآ","translation":"হে আমাাদের রব","audioUrl":"wbw/059_010_020.mp3","charTypeName":"word"},{"id":11295,"position":21,"arabic":"إِنَّكَ","translation":"তুমি নিশ্চয়","audioUrl":"wbw/059_010_021.mp3","charTypeName":"word"},{"id":11296,"position":22,"arabic":"رَءُوفٌۭ","translation":"দয়ালু","audioUrl":"wbw/059_010_022.mp3","charTypeName":"word"},{"id":11297,"position":23,"arabic":"رَّحِيمٌ","translation":"মেহেরবান\"","audioUrl":"wbw/059_010_023.mp3","charTypeName":"word"},{"id":11298,"position":24,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"۞ أَلَمْ تَرَ إِلَى ٱلَّذِينَ نَافَقُوا۟ يَقُولُونَ لِإِخْوَٰنِهِمُ ٱلَّذِينَ كَفَرُوا۟ مِنْ أَهْلِ ٱلْكِتَٰبِ لَئِنْ أُخْرِجْتُمْ لَنَخْرُجَنَّ مَعَكُمْ وَلَا نُطِيعُ فِيكُمْ أَحَدًا أَبَدًۭا وَإِن قُوتِلْتُمْ لَنَنصُرَنَّكُمْ وَٱللَّهُ يَشْهَدُ إِنَّهُمْ لَكَٰذِبُونَ","translation":"ART THOU NOT aware of how those who would always dissemble [their real feelings] speak to their truth-denying brethren from among the followers of earlier revelation: “If you are driven away, we shall most certainly go forth with you, and shall never pay heed to anyone against you; and if war is waged against you, we shall most certainly come to your succour.” But God bears witness that they are most flagrantly lying:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5137.mp3","surahId":59,"words":[{"id":12604,"position":1,"arabic":"۞ أَلَمْ","translation":"নাইকি","audioUrl":"wbw/059_011_002.mp3","charTypeName":"word"},{"id":12605,"position":2,"arabic":"تَرَ","translation":"তুমি দেখ","audioUrl":"wbw/059_011_003.mp3","charTypeName":"word"},{"id":12606,"position":3,"arabic":"إِلَى","translation":"প্রতি","audioUrl":"wbw/059_011_004.mp3","charTypeName":"word"},{"id":12607,"position":4,"arabic":"ٱلَّذِينَ","translation":"(তাদের) যারা","audioUrl":"wbw/059_011_005.mp3","charTypeName":"word"},{"id":12608,"position":5,"arabic":"نَافَقُوا۟","translation":"মুনাফেকী করেছে","audioUrl":"wbw/059_011_006.mp3","charTypeName":"word"},{"id":12609,"position":6,"arabic":"يَقُولُونَ","translation":"তারা বলেে","audioUrl":"wbw/059_011_007.mp3","charTypeName":"word"},{"id":12610,"position":7,"arabic":"لِإِخْوَٰنِهِمُ","translation":"তাদের ভাই দের","audioUrl":"wbw/059_011_008.mp3","charTypeName":"word"},{"id":12611,"position":8,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/059_011_009.mp3","charTypeName":"word"},{"id":12612,"position":9,"arabic":"كَفَرُوا۟","translation":"কুফুরি করেছে","audioUrl":"wbw/059_011_010.mp3","charTypeName":"word"},{"id":12613,"position":10,"arabic":"مِنْ","translation":"মধ্যে","audioUrl":"wbw/059_011_011.mp3","charTypeName":"word"},{"id":12614,"position":11,"arabic":"أَهْلِ","translation":"আহলে","audioUrl":"wbw/059_011_012.mp3","charTypeName":"word"},{"id":12615,"position":12,"arabic":"ٱلْكِتَـٰبِ","translation":"কিতাবদের","audioUrl":"wbw/059_011_013.mp3","charTypeName":"word"},{"id":12616,"position":13,"arabic":"لَئِنْ","translation":"\"যদি নিশ্চয়","audioUrl":"wbw/059_011_014.mp3","charTypeName":"word"},{"id":12617,"position":14,"arabic":"أُخْرِجْتُمْ","translation":"তোমরা বহিষ্কৃত হও","audioUrl":"wbw/059_011_015.mp3","charTypeName":"word"},{"id":12618,"position":15,"arabic":"لَنَخْرُجَنَّ","translation":"আমরা বের হব অবশ্যই","audioUrl":"wbw/059_011_016.mp3","charTypeName":"word"},{"id":12619,"position":16,"arabic":"مَعَكُمْ","translation":"তোমাদের সাথে","audioUrl":"wbw/059_011_017.mp3","charTypeName":"word"},{"id":12620,"position":17,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/059_011_018.mp3","charTypeName":"word"},{"id":12621,"position":18,"arabic":"نُطِيعُ","translation":"আনুগত্য করব আমরা","audioUrl":"wbw/059_011_019.mp3","charTypeName":"word"},{"id":12622,"position":19,"arabic":"فِيكُمْ","translation":"তোমাদের ব্যাপারে","audioUrl":"wbw/059_011_020.mp3","charTypeName":"word"},{"id":12623,"position":20,"arabic":"أَحَدًا","translation":"কারও","audioUrl":"wbw/059_011_021.mp3","charTypeName":"word"},{"id":12624,"position":21,"arabic":"أَبَدًۭا","translation":"কখনও","audioUrl":"wbw/059_011_022.mp3","charTypeName":"word"},{"id":12625,"position":22,"arabic":"وَإِن","translation":"এবং যদি","audioUrl":"wbw/059_011_023.mp3","charTypeName":"word"},{"id":12626,"position":23,"arabic":"قُوتِلْتُمْ","translation":"তোমাদের (বিরুদ্ধে) যুদ্ধ করা হয়","audioUrl":"wbw/059_011_024.mp3","charTypeName":"word"},{"id":12627,"position":24,"arabic":"لَنَنصُرَنَّكُمْ","translation":"তোমাদের সাহায্য আমরা অবশ্যই করব\"","audioUrl":"wbw/059_011_025.mp3","charTypeName":"word"},{"id":12628,"position":25,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/059_011_026.mp3","charTypeName":"word"},{"id":12629,"position":26,"arabic":"يَشْهَدُ","translation":"সাক্ষ্য দিচ্ছেন","audioUrl":"wbw/059_011_027.mp3","charTypeName"