2_008.mp3","charTypeName":"word"},{"id":13940,"position":9,"arabic":"يَنصُرُونَهُمْ","translation":"তাদের সাহায্য তারা করবে","audioUrl":"wbw/059_012_009.mp3","charTypeName":"word"},{"id":13941,"position":10,"arabic":"وَلَئِن","translation":"এবং যদি নিশ্চয়","audioUrl":"wbw/059_012_010.mp3","charTypeName":"word"},{"id":13942,"position":11,"arabic":"نَّصَرُوهُمْ","translation":"তাদের তারা সাহায্য করেও","audioUrl":"wbw/059_012_011.mp3","charTypeName":"word"},{"id":13943,"position":12,"arabic":"لَيُوَلُّنَّ","translation":"অবশ্যই","audioUrl":"wbw/059_012_012.mp3","charTypeName":"word"},{"id":13944,"position":13,"arabic":"ٱلْأَدْبَـٰرَ","translation":"পৃষ্ঠ প্রদর্শন করবে","audioUrl":"wbw/059_012_013.mp3","charTypeName":"word"},{"id":13945,"position":14,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/059_012_014.mp3","charTypeName":"word"},{"id":13946,"position":15,"arabic":"لَا","translation":"না","audioUrl":"wbw/059_012_015.mp3","charTypeName":"word"},{"id":13947,"position":16,"arabic":"يُنصَرُونَ","translation":"তাদের  সাহায্য করা হবে","audioUrl":"wbw/059_012_016.mp3","charTypeName":"word"},{"id":13948,"position":17,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]},{"number":13,"arabic":"لَأَنتُمْ أَشَدُّ رَهْبَةًۭ فِى صُدُورِهِم مِّنَ ٱللَّهِ ۚ ذَٰلِكَ بِأَنَّهُمْ قَوْمٌۭ لَّا يَفْقَهُونَ","translation":"Nay, [O believers,] you arouse in their bosoms a fear more intense than [even their fear of] God: this, because they are people who fail to grasp the truth.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5139.mp3","surahId":59,"words":[{"id":15073,"position":1,"arabic":"لَأَنتُمْ","translation":"তোমরা প্রকৃত পক্ষে","audioUrl":"wbw/059_013_001.mp3","charTypeName":"word"},{"id":15074,"position":2,"arabic":"أَشَدُّ","translation":"অধিকতর","audioUrl":"wbw/059_013_002.mp3","charTypeName":"word"},{"id":15075,"position":3,"arabic":"رَهْبَةًۭ","translation":"ভয়ংকর","audioUrl":"wbw/059_013_003.mp3","charTypeName":"word"},{"id":