{"id":141,"ayahs":[{"number":102,"arabic":"ذَٰلِكُمُ ٱللَّهُ رَبُّكُمْ ۖ لَآ إِلَٰهَ إِلَّا هُوَ ۖ خَٰلِقُ كُلِّ شَىْءٍۢ فَٱعْبُدُوهُ ۚ وَهُوَ عَلَىٰ كُلِّ شَىْءٍۢ وَكِيلٌۭ","translation":"Such is God, your Sustainer: there is no deity save Him, the Creator of everything: worship, then, Him alone -for it is He who has everything in His care.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/891.mp3","surahId":6,"words":[{"id":72006,"position":1,"arabic":"ذَٰلِكُمُ","translation":"এই (হচ্ছেন)","audioUrl":"wbw/006_102_001.mp3","charTypeName":"word"},{"id":72007,"position":2,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌","audioUrl":"wbw/006_102_002.mp3","charTypeName":"word"},{"id":72008,"position":3,"arabic":"رَبُّكُمْ ۖ","translation":"তোমাদের রব","audioUrl":"wbw/006_102_003.mp3","charTypeName":"word"},{"id":72010,"position":4,"arabic":"لَآ","translation":"নেই","audioUrl":"wbw/006_102_005.mp3","charTypeName":"word"},{"id":72011,"position":5,"arabic":"إِلَـٰهَ","translation":"কোনো ইলাহ","audioUrl":"wbw/006_102_006.mp3","charTypeName":"word"},{"id":72012,"position":6,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/006_102_007.mp3","charTypeName":"word"},{"id":72013,"position":7,"arabic":"هُوَ ۖ","translation":"তিনি","audioUrl":"wbw/006_102_008.mp3","charTypeName":"word"},{"id":72015,"position":8,"arabic":"خَـٰلِقُ","translation":"তিনি স্রষ্টা","audioUrl":"wbw/006_102_010.mp3","charTypeName":"word"},{"id":72016,"position":9,"arabic":"كُلِّ","translation":"সব","audioUrl":"wbw/006_102_011.mp3","charTypeName":"word"},{"id":72017,"position":10,"arabic":"شَىْءٍۢ","translation":"কিছুরই","audioUrl":"wbw/006_102_012.mp3","charTypeName":"word"},{"id":72018,"position":11,"arabic":"فَٱعْبُدُوهُ ۚ","translation":"সুতরাং তোমরা ইবাদাত করো তাঁরই","audioUrl":"wbw/006_102_013.mp3","charTypeName":"word"},{"id":72020,"position":12,"arabic":"وَهُوَ","translation":"এবং তিনিই","audioUrl":"wbw/006_102_015.mp3","charTypeName":"word"},{"id":72021,"position":13,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/006_102_016.mp3","charTypeName":"word"},{"id":72022,"position":14,"arabic":"كُلِّ","translation":"সব","audioUrl":"wbw/006_102_017.mp3","charTypeName":"word"},{"id":72023,"position":15,"arabic":"شَىْءٍۢ","translation":"কিছুর","audioUrl":"wbw/006_102_018.mp3","charTypeName":"word"},{"id":72024,"position":16,"arabic":"وَكِيلٌۭ","translation":"তত্ত্বাবধায়ক","audioUrl":"wbw/006_102_019.mp3","charTypeName":"word"},{"id":72025,"position":17,"arabic":"١٠٢","translation":"(১০২)","audioUrl":null,"charTypeName":"end"}]},{"number":103,"arabic":"لَّا تُدْرِكُهُ ٱلْأَبْصَٰرُ وَهُوَ يُدْرِكُ ٱلْأَبْصَٰرَ ۖ وَهُوَ ٱللَّطِيفُ ٱلْخَبِيرُ","translation":"No human vision can encompass Him, whereas He encompasses all human vision: for He alone is unfathomable, all-aware.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/892.mp3","surahId":6,"words":[{"id":72166,"position":1,"arabic":"لَّا","translation":"না","audioUrl":"wbw/006_103_001.mp3","charTypeName":"word"},{"id":72167,"position":2,"arabic":"تُدْرِكُهُ","translation":"পেতে পারে তাঁকে","audioUrl":"wbw/006_103_002.mp3","charTypeName":"word"},{"id":72168,"position":3,"arabic":"ٱلْأَبْصَـٰرُ","translation":"দৃষ্টিশক্তিসমূহ","audioUrl":"wbw/006_103_003.mp3","charTypeName":"word"},{"id":72169,"position":4,"arabic":"وَهُوَ","translation":"বরং তিনি","audioUrl":"wbw/006_103_004.mp3","charTypeName":"word"},{"id":72170,"position":5,"arabic":"يُدْرِكُ","translation":"অধিকার করে আছেন","audioUrl":"wbw/006_103_005.mp3","charTypeName":"word"},{"id":72171,"position":6,"arabic":"ٱلْأَبْصَـٰرَ ۖ","translation":"দৃষ্টিশক্তিসমূহকে","audioUrl":"wbw/006_103_006.mp3","charTypeName":"word"},{"id":72173,"position":7,"arabic":"وَهُوَ","translation":"এবং তিনি","audioUrl":"wbw/006_103_008.mp3","charTypeName":"word"},{"id":72174,"position":8,"arabic":"ٱللَّطِيفُ","translation":"সূক্ষ্মদর্শী","audioUrl":"wbw/006_103_009.mp3","charTypeName":"word"},{"id":72175,"position":9,"arabic":"ٱلْخَبِيرُ","translation":"সম্যক অবহিত","audioUrl":"wbw/006_103_010.mp3","charTypeName":"word"},{"id":72176,"position":10,"arabic":"١٠٣","translation":"(১০৩)","audioUrl":null,"charTypeName":"end"}]},{"number":104,"arabic":"قَدْ جَآءَكُم بَصَآئِرُ مِن رَّبِّكُمْ ۖ فَمَنْ أَبْصَرَ فَلِنَفْسِهِۦ ۖ وَمَنْ عَمِىَ فَعَلَيْهَا ۚ وَمَآ أَنَا۠ عَلَيْكُم بِحَفِيظٍۢ","translation":"Means of insight have now come unto you from your Sustainer [through this divine writ]. Whoever, therefore, chooses to see, does so for his own good; and whoever chooses to remain blind, does so to his own hurt. And [say unto the blind of heart]: \"I am not your keeper.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/893.mp3","surahId":6,"words":[{"id":72517,"position":1,"arabic":"قَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/006_104_001.mp3","charTypeName":"word"},{"id":72518,"position":2,"arabic":"جَآءَكُم","translation":"কাছে এসেছে তোমাদের","audioUrl":"wbw/006_104_002.mp3","charTypeName":"word"},{"id":72519,"position":3,"arabic":"بَصَآئِرُ","translation":"প্রত্যক্ষ প্রমাণ (অন্তর্দৃষ্টির আলো)","audioUrl":"wbw/006_104_003.mp3","charTypeName":"word"},{"id":72520,"position":4,"arabic":"مِن","translation":"পক্ষ হতে","audioUrl":"wbw/006_104_004.mp3","charTypeName":"word"},{"id":72521,"position":5,"arabic":"رَّبِّكُمْ ۖ","translation":"তোমাদের রবের","audioUrl":"wbw/006_104_005.mp3","charTypeName":"word"},{"id":72523,"position":6,"arabic":"فَمَنْ","translation":"অতএব যে","audioUrl":"wbw/006_104_007.mp3","charTypeName":"word"},{"id":72524,"position":7,"arabic":"أَبْصَرَ","translation":"দেখবে","audioUrl":"wbw/006_104_008.mp3","charTypeName":"word"},{"id":72525,"position":8,"arabic":"فَلِنَفْسِهِۦ ۖ","translation":"(তা) তবে জন্যে নিজের তার","audioUrl":"wbw/006_104_009.mp3","charTypeName":"word"},{"id":72527,"position":9,"arabic":"وَمَنْ","translation":"এবং যে","audioUrl":"wbw/006_104_011.mp3","charTypeName":"word"},{"id":72528,"position":10,"arabic":"عَمِىَ","translation":"অন্ধ হবে","audioUrl":"wbw/006_104_012.mp3","charTypeName":"word"},{"id":72529,"position":11,"arabic":"فَعَلَيْهَا ۚ","translation":"(তার ক্ষতি) তবে তার বিরুদ্ধে যাবে","audioUrl":"wbw/006_104_013.mp3","charTypeName":"word"},{"id":72531,"position":12,"arabic":"وَمَآ","translation":"এবং নই","audioUrl":"wbw/006_104_015.mp3","charTypeName":"word"},{"id":72532,"position":13,"arabic":"أَنَا۠","translation":"আমি","audioUrl":"wbw/006_104_016.mp3","charTypeName":"word"},{"id":72533,"position":14,"arabic":"عَلَيْكُم","translation":"উপর তোমাদের","audioUrl":"wbw/006_104_017.mp3","charTypeName":"word"},{"id":72534,"position":15,"arabic":"بِحَفِيظٍۢ","translation":"কোন রক্ষক","audioUrl":"wbw/006_104_018.mp3","charTypeName":"word"},{"id":72535,"position":16,"arabic":"١٠٤","translation":"(১০৪)","audioUrl":null,"charTypeName":"end"}]},{"number":105,"arabic":"وَكَذَٰلِكَ نُصَرِّفُ ٱلْءَايَٰتِ وَلِيَقُولُوا۟ دَرَسْتَ وَلِنُبَيِّنَهُۥ لِقَوْمٍۢ يَعْلَمُونَ","translation":"And thus do We give many facets to Our messages. And to the end that they might say, \"Thou hast taken [all this] well to heart,\" and that We might make it clear unto people of [innate] knowledge,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/894.mp3","surahId":6,"words":[{"id":72791,"position":1,"arabic":"وَكَذَٰلِكَ","translation":"এবং এভাবে","audioUrl":"wbw/006_105_001.mp3","charTypeName":"word"},{"id":72792,"position":2,"arabic":"نُصَرِّفُ","translation":"বারবার বর্ণনা করি আমরা","audioUrl":"wbw/006_105_002.mp3","charTypeName":"word"},{"id":72793,"position":3,"arabic":"ٱلْـَٔايَـٰتِ","translation":"নিদর্শনাবলী","audioUrl":"wbw/006_105_003.mp3","charTypeName":"word"},{"id":72794,"position":4,"arabic":"وَلِيَقُولُوا۟","translation":"এবং তারা যেন (না) বলে","audioUrl":"wbw/006_105_004.mp3","charTypeName":"word"},{"id":72795,"position":5,"arabic":"دَرَسْتَ","translation":"\"তুমি পড়েছো (কারো কাছে)\"","audioUrl":"wbw/006_105_005.mp3","charTypeName":"word"},{"id":72796,"position":6,"arabic":"وَلِنُبَيِّنَهُۥ","translation":"এবং যেন আমরা স্পষ্ট বর্ণনা করি তা","audioUrl":"wbw/006_105_006.mp3","charTypeName":"word"},{"id":72797,"position":7,"arabic":"لِقَوْمٍۢ","translation":"(সেসব) জন্যে সম্প্রদায়ের","audioUrl":"wbw/006_105_007.mp3","charTypeName":"word"},{"id":72798,"position":8,"arabic":"يَعْلَمُونَ","translation":"(যারা) জ্ঞান রাখে","audioUrl":"wbw/006_105_008.mp3","charTypeName":"word"},{"id":72799,"position":9,"arabic":"١٠٥","translation":"(১০৫)","audioUrl":null,"charTypeName":"end"}]},{"number":106,"arabic":"ٱتَّبِعْ مَآ أُوحِىَ إِلَيْكَ مِن رَّبِّكَ ۖ لَآ إِلَٰهَ إِلَّا هُوَ ۖ وَأَعْرِضْ عَنِ ٱلْمُشْرِكِينَ","translation":"follow thou what has been revealed unto thee by thy Sustainer - save whom there is no deity - and turn thy back upon all who ascribe divinity to aught beside Him.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/895.mp3","surahId":6,"words":[{"id":72988,"position":1,"arabic":"ٱتَّبِعْ","translation":"তুমি অনুসরণ করো","audioUrl":"wbw/006_106_001.mp3","charTypeName":"word"},{"id":72989,"position":2,"arabic":"مَآ","translation":"যা","audioUrl":"wbw/006_106_002.mp3","charTypeName":"word"},{"id":72990,"position":3,"arabic":"أُوحِىَ","translation":"ওহী করা হয়েছে","audioUrl":"wbw/006_106_003.mp3","charTypeName":"word"},{"id":72991,"position":4,"arabic":"إِلَيْكَ","translation":"প্রতি তোমার","audioUrl":"wbw/006_106_004.mp3","charTypeName":"word"},{"id":72992,"position":5,"arabic":"مِن","translation":"পক্ষ হতে","audioUrl":"wbw/006_106_005.mp3","charTypeName":"word"},{"id":72993,"position":6,"arabic":"رَّبِّكَ ۖ","translation":"তোমার রবের","audioUrl":"wbw/006_106_006.mp3","charTypeName":"word"},{"id":72995,"position":7,"arabic":"لَآ","translation":"নেই","audioUrl":"wbw/006_106_008.mp3","charTypeName":"word"},{"id":72996,"position":8,"arabic":"إِلَـٰهَ","translation":"কোনো ইলাহ","audioUrl":"wbw/006_106_009.mp3","charTypeName":"word"},{"id":72997,"position":9,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/006_106_010.mp3","charTypeName":"word"},{"id":72998,"position":10,"arabic":"هُوَ ۖ","translation":"তিনি","audioUrl":"wbw/006_106_011.mp3","charTypeName":"word"},{"id":73000,"position":11,"arabic":"وَأَعْرِضْ","translation":"এবং উপেক্ষা করো (মুখ ফিরাও)","audioUrl":"wbw/006_106_013.mp3","charTypeName":"word"},{"id":73001,"position":12,"arabic":"عَنِ","translation":"হতে","audioUrl":"wbw/006_106_014.mp3","charTypeName":"word"},{"id":73002,"position":13,"arabic":"ٱلْمُشْرِكِينَ","translation":"মুশরিকদের","audioUrl":"wbw/006_106_015.mp3","charTypeName":"word"},{"id":73003,"position":14,"arabic":"١٠٦","translation":"(১০৬)","audioUrl":null,"charTypeName":"end"}]},{"number":107,"arabic":"وَلَوْ شَآءَ ٱللَّهُ مَآ أَشْرَكُوا۟ ۗ وَمَا جَعَلْنَٰكَ عَلَيْهِمْ حَفِيظًۭا ۖ وَمَآ أَنتَ عَلَيْهِم بِوَكِيلٍۢ","translation":"Yet if God had so willed, they would not have ascribed divinity to aught beside Him; hence, We have not made thee their keeper, and neither art thou responsible for their conduct.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/896.mp3","surahId":6,"words":[{"id":73261,"position":1,"arabic":"وَلَوْ","translation":"এবং যদি","audioUrl":"wbw/006_107_001.mp3","charTypeName":"word"},{"id":73262,"position":2,"arabic":"شَآءَ","translation":"ইচ্ছে করতেন","audioUrl":"wbw/006_107_002.mp3","charTypeName":"word"},{"id":73263,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌","audioUrl":"wbw/006_107_003.mp3","charTypeName":"word"},{"id":73264,"position":4,"arabic":"مَآ","translation":"না","audioUrl":"wbw/006_107_004.mp3","charTypeName":"word"},{"id":73265,"position":5,"arabic":"أَشْرَكُوا۟ ۗ","translation":"তাঁর শিরক করতো","audioUrl":"wbw/006_107_005.mp3","charTypeName":"word"},{"id":73267,"position":6,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/006_107_007.mp3","charTypeName":"word"},{"id":73268,"position":7,"arabic":"جَعَلْنَـٰكَ","translation":"আমরা নিযুক্ত করেছি তোমাকে","audioUrl":"wbw/006_107_008.mp3","charTypeName":"word"},{"id":73269,"position":8,"arabic":"عَلَيْهِمْ","translation":"উপর তাদের","audioUrl":"wbw/006_107_009.mp3","charTypeName":"word"},{"id":73270,"position":9,"arabic":"حَفِيظًۭا ۖ","translation":"কোনো সংরক্ষক","audioUrl":"wbw/006_107_010.mp3","charTypeName":"word"},{"id":73272,"position":10,"arabic":"وَمَآ","translation":"আর নও","audioUrl":"wbw/006_107_012.mp3","charTypeName":"word"},{"id":73273,"position":11,"arabic":"أَنتَ","translation":"তুমি","audioUrl":"wbw/006_107_013.mp3","charTypeName":"word"},{"id":73274,"position":12,"arabic":"عَلَيْهِم","translation":"উপর তাদের","audioUrl":"wbw/006_107_014.mp3","charTypeName":"word"},{"id":73275,"position":13,"arabic":"بِوَكِيلٍۢ","translation":"কোনো অভিভাবক","audioUrl":"wbw/006_107_015.mp3","charTypeName":"word"},{"id":73276,"position":14,"arabic":"١٠٧","translation":"(১০৭)","audioUrl":null,"charTypeName":"end"}]},{"number":108,"arabic":"وَلَا تَسُبُّوا۟ ٱلَّذِينَ يَدْعُونَ مِن دُونِ ٱللَّهِ فَيَسُبُّوا۟ ٱللَّهَ عَدْوًۢا بِغَيْرِ عِلْمٍۢ ۗ كَذَٰلِكَ زَيَّنَّا لِكُلِّ أُمَّةٍ عَمَلَهُمْ ثُمَّ إِلَىٰ رَبِّهِم مَّرْجِعُهُمْ فَيُنَبِّئُهُم بِمَا كَانُوا۟ يَعْمَلُونَ","translation":"But do not revile those [beings] whom they invoke instead of God, lest they revile God out of spite, and in ignorance: for, goodly indeed have We made their own doings appear unto every community In time, [however,] unto their Sustainer they must return: and then He will make them [truly] understand all that they were doing.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/897.mp3","surahId":6,"words":[{"id":73499,"position":1,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/006_108_001.mp3","charTypeName":"word"},{"id":73500,"position":2,"arabic":"تَسُبُّوا۟","translation":"তোমরা গালি দিও","audioUrl":"wbw/006_108_002.mp3","charTypeName":"word"},{"id":73501,"position":3,"arabic":"ٱلَّذِينَ","translation":"যাদেরকে","audioUrl":"wbw/006_108_003.mp3","charTypeName":"word"},{"id":73502,"position":4,"arabic":"يَدْعُونَ","translation":"তারা ডাকে","audioUrl":"wbw/006_108_004.mp3","charTypeName":"word"},{"id":73503,"position":5,"arabic":"مِن","translation":"দিয়ে","audioUrl":"wbw/006_108_005.mp3","charTypeName":"word"},{"id":73504,"position":6,"arabic":"دُونِ","translation":"বাদ","audioUrl":"wbw/006_108_006.mp3","charTypeName":"word"},{"id":73505,"position":7,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌কে","audioUrl":"wbw/006_108_007.mp3","charTypeName":"word"},{"id":73506,"position":8,"arabic":"فَيَسُبُّوا۟","translation":"তবে তারা গালি দিবে","audioUrl":"wbw/006_108_008.mp3","charTypeName":"word"},{"id":73507,"position":9,"arabic":"ٱللَّهَ","translation":"আল্লাহ্‌কে","audioUrl":"wbw/006_108_009.mp3","charTypeName":"word"},{"id":73508,"position":10,"arabic":"عَدْوًۢا","translation":"সীমালঙ্ঘন করে","audioUrl":"wbw/006_108_010.mp3","charTypeName":"word"},{"id":73509,"position":11,"arabic":"بِغَيْرِ","translation":"ছাড়া","audioUrl":"wbw/006_108_011.mp3","charTypeName":"word"},{"id":73510,"position":12,"arabic":"عِلْمٍۢ ۗ","translation":"কোনো জ্ঞান (মূর্খতাবশতঃ)","audioUrl":"wbw/006_108_012.mp3","charTypeName":"word"},{"id":73512,"position":13,"arabic":"كَذَٰلِكَ","translation":"এভাবে","audioUrl":"wbw/006_108_014.mp3","charTypeName":"word"},{"id":73513,"position":14,"arabic":"زَيَّنَّا","translation":"সুশোভিত করেছি আমরা","audioUrl":"wbw/006_108_015.mp3","charTypeName":"word"},{"id":73514,"position":15,"arabic":"لِكُلِّ","translation":"জন্যে প্রত্যেক","audioUrl":"wbw/006_108_016.mp3","charTypeName":"word"},{"id":73515,"position":16,"arabic":"أُمَّةٍ","translation":"সম্প্রদায়ের","audioUrl":"wbw/006_108_017.mp3","charTypeName":"word"},{"id":73516,"position":17,"arabic":"عَمَلَهُمْ","translation":"কাজকে তাদের","audioUrl":"wbw/006_108_018.mp3","charTypeName":"word"},{"id":73517,"position":18,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/006_108_019.mp3","charTypeName":"word"},{"id":73518,"position":19,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/006_108_020.mp3","charTypeName":"word"},{"id":73519,"position":20,"arabic":"رَبِّهِم","translation":"রবের তাদের","audioUrl":"wbw/006_108_021.mp3","charTypeName":"word"},{"id":73520,"position":21,"arabic":"مَّرْجِعُهُمْ","translation":"প্রত্যাবর্তন তাদের (হবে)","audioUrl":"wbw/006_108_022.mp3","charTypeName":"word"},{"id":73521,"position":22,"arabic":"فَيُنَبِّئُهُم","translation":"অতঃপর তাদের জানিয়ে দিবেন","audioUrl":"wbw/006_108_023.mp3","charTypeName":"word"},{"id":73522,"position":23,"arabic":"بِمَا","translation":"সে সম্বন্ধে যা","audioUrl":"wbw/006_108_024.mp3","charTypeName":"word"},{"id":73523,"position":24,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/006_108_025.mp3","charTypeName":"word"},{"id":73524,"position":25,"arabic":"يَعْمَلُونَ","translation":"তারা কাজ করতে","audioUrl":"wbw/006_108_026.mp3","charTypeName":"word"},{"id":73525,"position":26,"arabic":"١٠٨","translation":"(১০৮)","audioUrl":null,"charTypeName":"end"}]},{"number":109,"arabic":"وَأَقْسَمُوا۟ بِٱللَّهِ جَهْدَ أَيْمَٰنِهِمْ لَئِن جَآءَتْهُمْ ءَايَةٌۭ لَّيُؤْمِنُنَّ بِهَا ۚ قُلْ إِنَّمَا ٱلْءَايَٰتُ عِندَ ٱللَّهِ ۖ وَمَا يُشْعِرُكُمْ أَنَّهَآ إِذَا جَآءَتْ لَا يُؤْمِنُونَ","translation":"Now they swear by God with their most solemn oaths that if a miracle were shown to them, they would indeed believe in this [divine writ]. Say: \"Miracles are in the power of God alone.\" And for all you know, even if one should be shown to them, they would not believe","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/898.mp3","surahId":6,"words":[{"id":73904,"position":1,"arabic":"وَأَقْسَمُوا۟","translation":"এবং তারা শপথ করে বলে","audioUrl":"wbw/006_109_001.mp3","charTypeName":"word"},{"id":73905,"position":2,"arabic":"بِٱللَّهِ","translation":"নামে আল্লাহ্‌র","audioUrl":"wbw/006_109_002.mp3","charTypeName":"word"},{"id":73906,"position":3,"arabic":"جَهْدَ","translation":"কঠিন","audioUrl":"wbw/006_109_003.mp3","charTypeName":"word"},{"id":73907,"position":4,"arabic":"أَيْمَـٰنِهِمْ","translation":"শপথগুলো তাদের","audioUrl":"wbw/006_109_004.mp3","charTypeName":"word"},{"