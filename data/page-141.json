006_109_022.mp3","charTypeName":"word"},{"id":73926,"position":21,"arabic":"يُؤْمِنُونَ","translation":"তারা ঈমান আনবে","audioUrl":"wbw/006_109_023.mp3","charTypeName":"word"},{"id":73927,"position":22,"arabic":"١٠٩","translation":"(১০৯)","audioUrl":null,"charTypeName":"end"}]},{"number":110,"arabic":"وَنُقَلِّبُ أَفْـِٔدَتَهُمْ وَأَبْصَٰرَهُمْ كَمَا لَمْ يُؤْمِنُوا۟ بِهِۦٓ أَوَّلَ مَرَّةٍۢ وَنَذَرُهُمْ فِى طُغْيَٰنِهِمْ يَعْمَهُونَ","translation":"so long as We keep their hearts and their eyes turned [away from the truth], even as they did not believe in it in the first instance: and [so] We shall leave them in their overweening arrogance, blindly stumbling to and fro.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/899.mp3","surahId":6,"words":[{"id":74095,"position":1,"arabic":"وَنُقَلِّبُ","translation":"এবং ফিরিয়ে দিবো আমরা","audioUrl":"wbw/006_110_001.mp3","charTypeName":"word"},{"id":74096,"position":2,"arabic":"أَفْـِٔدَتَهُمْ","translation":"অন্তরগুলোকে তাদের","audioUrl":"wbw/006_110_002.mp3","charTypeName":"word"},{"id":74097,"position":3,"arabic":"وَأَبْصَـٰرَهُمْ","translation":"ও দৃষ্টিগুলোকে তাদের","audioUrl":"wbw/006_110_003.mp3","charTypeName":"word"},{"id":74098,"position":4,"arabic":"كَمَا","translation":"যেমন","audioUrl":"wbw/006_110_004.mp3","charTypeName":"word"},{"id":74099,"position":5,"arabic":"لَمْ","translation":"নি","audioUrl":"wbw/006_110_005.mp3","charTypeName":"word"},{"id":74100,"position":6,"arabic":"يُؤْمِنُوا۟","translation":"তারা ঈমান আনে","audioUrl":"wbw/006_110_006.mp3","charTypeName":"word"},{"id":74101,"position":7,"arabic":"بِهِۦٓ","translation":"উপর তার","audioUrl":"wbw/006_110_007.mp3","charTypeName":"word"},{"id":74102,"position":8,"arabic":"أَوَّلَ","translation":"প্রথম","audioUrl":"wbw/006_110_008.mp3","charTypeName":"word"},{"id":74103,"position":9,"arabic":"مَرَّةٍۢ","translation":"বার","audioUrl":"wbw/006_110_009.mp3","charTypeName":"word"},{"id":74104,"position":10,"arabic":"وَنَذَرُهُمْ","translation":"ও ছেড়ে দিবো আমরা তাদের","audioUrl":"wbw/006_110_010.mp3","charTypeName":"word"},{"id":74105,"position":11,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/006_110_011.mp3","charTypeName":"word"},{"id":74106,"position":12,"arabic":"طُغْيَـٰنِهِمْ","translation":"অবাধ্যতার তাদের","audioUrl":"wbw/006_110_012.mp3","charTypeName":"word"},{"id":74107,"position":13,"arabic":"يَعْمَهُونَ","translation":"তারা উদ্ভ্রান্ত হয়ে ঘুরে বেড়াবে","audioUrl":"wbw/006_110_013.mp3","charTypeName":"word"},{"id":74108,"position":14,"arabic":"١١٠","translation":"(১১০)","audioUrl":null,"charTypeName":"end"}]}]}