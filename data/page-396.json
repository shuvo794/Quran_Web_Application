},{"id":66502,"position":4,"arabic":"أَن","translation":"যে","audioUrl":"wbw/028_086_004.mp3","charTypeName":"word"},{"id":66503,"position":5,"arabic":"يُلْقَىٰٓ","translation":"অবতীর্ণ করা হবে","audioUrl":"wbw/028_086_005.mp3","charTypeName":"word"},{"id":66504,"position":6,"arabic":"إِلَيْكَ","translation":"প্রতি তোমার","audioUrl":"wbw/028_086_006.mp3","charTypeName":"word"},{"id":66505,"position":7,"arabic":"ٱلْكِتَـٰبُ","translation":"কিতাব","audioUrl":"wbw/028_086_007.mp3","charTypeName":"word"},{"id":66506,"position":8,"arabic":"إِلَّا","translation":"কিন্তু (এটা মাত্র)","audioUrl":"wbw/028_086_008.mp3","charTypeName":"word"},{"id":66507,"position":9,"arabic":"رَحْمَةًۭ","translation":"অনুগ্রহ","audioUrl":"wbw/028_086_009.mp3","charTypeName":"word"},{"id":66508,"position":10,"arabic":"مِّن","translation":"পক্ষ হ'তে","audioUrl":"wbw/028_086_010.mp3","charTypeName":"word"},{"id":66509,"position":11,"arabic":"رَّبِّكَ ۖ","translation":"তোমার রবের","audioUrl":"wbw/028_086_011.mp3","charTypeName":"word"},{"id":66511,"position":12,"arabic":"فَلَا","translation":"সুতরাং না","audioUrl":"wbw/028_086_013.mp3","charTypeName":"word"},{"id":66512,"position":13,"arabic":"تَكُونَنَّ","translation":"তুমি কখনও হয়ো","audioUrl":"wbw/028_086_014.mp3","charTypeName":"word"},{"id":66513,"position":14,"arabic":"ظَهِيرًۭا","translation":"সাহায্যকারী","audioUrl":"wbw/028_086_015.mp3","charTypeName":"word"},{"id":66514,"position":15,"arabic":"لِّلْكَـٰفِرِينَ","translation":"জন্যে কাফেরদের","audioUrl":"wbw/028_086_016.mp3","charTypeName":"word"},{"id":66515,"position":16,"arabic":"٨٦","translation":"(৮৬)","audioUrl":null,"charTypeName":"end"}]},{"number":87,"arabic":"وَلَا يَصُدُّنَّكَ عَنْ ءَايَٰتِ ٱللَّهِ بَعْدَ إِذْ أُنزِلَتْ إِلَيْكَ ۖ وَٱدْعُ إِلَىٰ رَبِّكَ ۖ وَلَا تَكُونَنَّ مِنَ ٱلْمُشْرِكِينَ","translation":"and never let them turn thee away from God’s messages after they have been bestowed upon thee from on high: instead summon [all men] to thy Sustainer. And never be of those who ascribe divinity to aught but Him,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3339.mp3","surahId":28,"words":[{"id":66960,"position":1,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/028_087_001.mp3","charTypeName":"word"},{"id":66961,"position":2,"arabic":"يَصُدُّنَّكَ","translation":"তোমাকে কিছুতেই (যেন) ফিরিয়ে রাখতে পারে","audioUrl":"wbw/028_087_002.mp3","charTypeName":"word"},{"id":66962,"position":3,"arabic":"عَنْ","translation":"হ'তে","audioUrl":"wbw/028_087_003.mp3","charTypeName":"word"},{"id":66963,"position":4,"arabic":"ءَايَـٰتِ","translation":"আয়াত","audioUrl":"wbw/028_087_004.mp3","charTypeName":"word"},{"id":66964,"position":5,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/028_087_005.mp3","charTypeName":"word"},{"id":66965,"position":6,"arabic":"بَعْدَ","translation":"এরপর","audioUrl":"wbw/028_087_006.mp3","charTypeName":"word"},{"id":66966,"position":7,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/028_087_007.mp3","charTypeName":"word"},{"id":66967,"position":8,"arabic":"أُنزِلَتْ","translation":"অবতীর্ণ করা হয়েছে","audioUrl":"wbw/028_087_008.mp3","charTypeName":"word"},{"id":66968,"position":9,"arabic":"إِلَيْكَ ۖ","translation":"প্রতি তোমার","audioUrl":"wbw/028_087_009.mp3","charTypeName":"word"},{"id":66970,"position":10,"arabic":"وَٱدْعُ","translation":"আর আহবান করো","audioUrl":"wbw/028_087_011.mp3","charTypeName":"word"},{"id":66971,"position":11,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/028_087_012.mp3","charTypeName":"word"},{"id":66972,"position":12,"arabic":"رَبِّكَ ۖ","translation":"তোমার রবের","audioUrl":"wbw/028_087_013.mp3","charTypeName":"word"},{"id":66974,"position":13,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/028_087_015.mp3","charTypeName":"word"},{"id":66975,"position":14,"arabic":"تَكُونَنَّ","translation":"তুমি কিছুতেই হয়ো","audioUrl":"wbw/028_087_016.mp3","charTypeName":"word"},{"id":66976,"position":15,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত