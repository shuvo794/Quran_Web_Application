quran/audio/128/ar.alafasy/3342.mp3","surahId":29,"words":[{"id":1828,"position":1,"arabic":"أَحَسِبَ","translation":"কি মনে করেছে","audioUrl":"wbw/029_002_001.mp3","charTypeName":"word"},{"id":1829,"position":2,"arabic":"ٱلنَّاسُ","translation":"মানুষ","audioUrl":"wbw/029_002_002.mp3","charTypeName":"word"},{"id":1830,"position":3,"arabic":"أَن","translation":"যে","audioUrl":"wbw/029_002_003.mp3","charTypeName":"word"},{"id":1831,"position":4,"arabic":"يُتْرَكُوٓا۟","translation":"তাদেরকে ছেড়ে দেয়া হবে","audioUrl":"wbw/029_002_004.mp3","charTypeName":"word"},{"id":1832,"position":5,"arabic":"أَن","translation":"(এ কথায়) যে","audioUrl":"wbw/029_002_005.mp3","charTypeName":"word"},{"id":1833,"position":6,"arabic":"يَقُولُوٓا۟","translation":"তারা বলবে","audioUrl":"wbw/029_002_006.mp3","charTypeName":"word"},{"id":1834,"position":7,"arabic":"ءَامَنَّا","translation":"\"ঈমান এনেছি আমরা\"","audioUrl":"wbw/029_002_007.mp3","charTypeName":"word"},{"id":1835,"position":8,"arabic":"وَهُمْ","translation":"আর তাদেরকে","audioUrl":"wbw/029_002_008.mp3","charTypeName":"word"},{"id":1836,"position":9,"arabic":"لَا","translation":"না","audioUrl":"wbw/029_002_009.mp3","charTypeName":"word"},{"id":1837,"position":10,"arabic":"يُفْتَنُونَ","translation":"পরীক্ষা করা হবে","audioUrl":"wbw/029_002_010.mp3","charTypeName":"word"},{"id":1838,"position":11,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"وَلَقَدْ فَتَنَّا ٱلَّذِينَ مِن قَبْلِهِمْ ۖ فَلَيَعْلَمَنَّ ٱللَّهُ ٱلَّذِينَ صَدَقُوا۟ وَلَيَعْلَمَنَّ ٱلْكَٰذِبِينَ","translation":"Yea, indeed, We did test those who lived before them; and so, [too, shall be tested the people now living: and] most certainly will God mark out those who prove themselves true, and most certainly will He mark out those who are lying.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3343.mp3","surahId":29,"words":[{"id":2997,"position":1,"arabic":"وَلَقَدْ","translation":"অথচ নিশ্চয়ই","audioUrl":"wbw/029_003_001.mp3","charTypeName":"word"},{"id":2998,"position":2,"arabic":"فَتَنَّا","translation":"পরীক্ষা করেছি আমরা","audioUrl":"wbw/029_003_002.mp3","charTypeName":"word"},{"id":2999,"position":3,"arabic":"ٱلَّذِينَ","translation":"(তাদেরকে) যারা","audioUrl":"wbw/029_003_003.mp3","charTypeName":"word"},{"id":3000,"position":4,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/029_003_004.mp3","charTypeName":"word"},{"id":3001,"position":5,"arabic":"قَبْلِهِمْ ۖ","translation":"পূর্ব ছিলো তাদের","audioUrl":"wbw/029_003_005.mp3","charTypeName":"word"},{"id":3003,"position":6,"arabic":"فَلَيَعْلَمَنَّ","translation":"অতএব অবশ্যই জেনে নিবেন","audioUrl":"wbw/029_003_007.mp3","charTypeName":"word"},{"id":3004,"position":7,"arabic":"ٱللَّهُ","translation":"আল্লাহ্","audioUrl":"wbw/029_003_008.mp3","charTypeName":"word"},{"id":3005,"position":8,"arabic":"ٱلَّذِينَ","translation":"(তাদেরকে) যারা","audioUrl":"wbw/029_003_009.mp3","charTypeName":"word"},{"id":3006,"position":9,"arabic":"صَدَقُوا۟","translation":"সত্য বলেছে","audioUrl":"wbw/029_003_010.mp3","charTypeName":"word"},{"id":3007,"position":10,"arabic":"وَلَيَعْلَمَنَّ","translation":"আর অবশ্যই জেনে নিবেন","audioUrl":"wbw/029_003_011.mp3","charTypeName":"word"},{"id":3008,"position":11,"arabic":"ٱلْكَـٰذِبِينَ","translation":"মিথ্যাবাদীদেরকে","audioUrl":"wbw/029_003_012.mp3","charTypeName":"word"},{"id":3009,"position":12,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"أَمْ حَسِبَ ٱلَّذِينَ يَعْمَلُونَ ٱلسَّيِّـَٔاتِ أَن يَسْبِقُونَا ۚ سَآءَ مَا يَحْكُمُونَ","translation":"Or do they think - they who do evil deeds [while claiming to have attained to faith] - that they can escape Us? Bad, indeed, is their judgment!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3344.mp3","surahId":29,"words":[{"id":4329,"position":1,"arabic":"أَمْ","translation":"কি","audioUrl":"wbw/029_004_001.mp3","charTypeName":"word"},{"id":4330,"position":2,"arabic":"حَسِبَ","translation":"মনে করেছে","audioUrl":"wbw/029_004_002.mp3","charTypeName":"word"},{"id":4331,"position":3,"arabic":"ٱلَّذِينَ","translation":"(তারা) যারা","audioUrl":"wbw/029_004_003.mp3","charTypeName":"word"},{"id":4332,"position":4,"arabic":"يَعْمَلُونَ","translation":"কাজ করে","audioUrl":"wbw/029_004_004.mp3","charTypeName":"word"},{"id":4333,"position":5,"arabic":"ٱلسَّيِّـَٔاتِ","translation":"মন্দ","audioUrl":"wbw/029_004_005.mp3","charTypeName":"word"},{"id":4334,"position":6,"arabic":"أَن","translation":"যে","audioUrl":"wbw/029_004_006.mp3","charTypeName":"word"},{"id":4335,"position":7,"arabic":"يَسْبِقُونَا ۚ","translation":"তারা ছাড়িয়ে যাবে অামাদেরকে","audioUrl":"wbw/029_004_007.mp3","charTypeName":"word"},{"id":4337,"position":8,"arabic":"سَآءَ","translation":"কত খারাপ","audioUrl":"wbw/029_004_009.mp3","charTypeName":"word"},{"id":4338,"position":9,"arabic":"مَا","translation":"যা","audioUrl":"wbw/029_004_010.mp3","charTypeName":"word"},{"id":4339,"position":10,"arabic":"يَحْكُمُونَ","translation":"তারা সিদ্ধান্ত নিয়েছে","audioUrl":"wbw/029_004_011.mp3","charTypeName":"word"},{"id":4340,"position":11,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"مَن كَانَ يَرْجُوا۟ لِقَآءَ ٱللَّهِ فَإِنَّ أَجَلَ ٱللَّهِ لَءَاتٍۢ ۚ وَهُوَ ٱلسَّمِيعُ ٱلْعَلِيمُ","translation":"Whoever looks forward [with hope and awe] to meeting God [on Resurrection Day, let him be ready for it]: for, behold, the end set by God [for every­one’s life] is bound to come - and He alone is all-hearing, all-knowing!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3345.mp3","surahId":29,"words":[{"id":5598,"position":1,"arabic":"مَن","translation":"যে","audioUrl":"wbw/029_005_001.mp3","charTypeName":"word"},{"id":5599,"position":2,"arabic":"كَانَ","translation":"সে হলো","audioUrl":"wbw/029_005_002.mp3","charTypeName":"word"},{"id":5600,"position":3,"arabic":"يَرْجُوا۟","translation":"সে কামনা করে","audioUrl":"wbw/029_005_003.mp3","charTypeName":"word"},{"id":5601,"position":4,"arabic":"لِقَآءَ","translation":"সাক্ষাত","audioUrl":"wbw/029_005_004.mp3","charTypeName":"word"},{"id":5602,"position":5,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌র","audioUrl":"wbw/029_005_005.mp3","charTypeName":"word"},{"id":5603,"position":6,"arabic":"فَإِنَّ","translation":"(সে জানুক) তবে নিশ্চয়ই","audioUrl":"wbw/029_005_006.mp3","charTypeName":"word"},{"id":5604,"position":7,"arabic":"أَجَلَ","translation":"নির্ধারিত সময়","audioUrl":"wbw/029_005_007.mp3","charTypeName":"word"},{"id":5605,"position":8,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌র","audioUrl":"wbw/029_005_008.mp3","charTypeName":"word"},{"id":5606,"position":9,"arabic":"لَـَٔاتٍۢ ۚ","translation":"অবশ্যই আসবে","audioUrl":"wbw/029_005_009.mp3","charTypeName":"word"},{"id":5608,"position":10,"arabic":"وَهُوَ","translation":"এবং তিনিই","audioUrl":"wbw/029_005_011.mp3","charTypeName":"word"},{"id":5609,"position":11,"arabic":"ٱلسَّمِيعُ","translation":"সবকিছু শুনেন","audioUrl":"wbw/029_005_012.mp3","charTypeName":"word"},{"id":5610,"position":12,"arabic":"ٱلْعَلِيمُ","translation":"সবকিছু জানেন","audioUrl":"wbw/029_005_013.mp3","charTypeName":"word"},{"id":5611,"position":13,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"وَمَن جَٰهَدَ فَإِنَّمَا يُجَٰهِدُ لِنَفْسِهِۦٓ ۚ إِنَّ ٱللَّهَ لَغَنِىٌّ عَنِ ٱلْعَٰلَمِينَ","translation":"Hence, whoever strives hard [in God’s cause] does so only for his own good: for, verily, God does not stand in need of anything in all the worlds!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3346.mp3","surahId":29,"words":[{"id":6880,"position":1,"arabic":"وَمَن","translation":"এবং যে","audioUrl":"wbw/029_006_001.mp3","charTypeName":"word"},{"id":6881,"position":2,"arabic":"جَـٰهَدَ","translation":"জিহাদ (সংগ্রাম সাধনা) করে","audioUrl":"wbw/029_006_002.mp3","charTypeName":"word"},{"id":6882,"position":3,"arabic":"فَإِنَّمَا","translation":"তবে শুধুমাত্র","audioUrl":"wbw/029_006_003.mp3","charTypeName":"word"},{"id":6883,"position":4,"arabic":"يُجَـٰهِدُ","translation":"সে জিহাদ (সংগ্রাম সাধনা)করে","audioUrl":"wbw/029_006_004.mp3","charTypeName":"word"},{"id":6884,"position":5,"arabic":"لِنَفْسِهِۦٓ ۚ","translation":"জন্যে নিজের তার","audioUrl":"wbw/029_006_005.mp3","charTypeName":"word"},{"id":6886,"position":6,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/029_006_007.mp3","charTypeName":"word"},{"id":6887,"position":7,"arabic":"ٱللَّهَ","translation":"আল্লাহ্‌","audioUrl":"wbw/029_006_008.mp3","charTypeName":"word"},{"id":6888,"position":8,"arabic":"لَغَنِىٌّ","translation":"অবশ্যই অমুখাপেক্ষী","audioUrl":"wbw/029_006_009.mp3","charTypeName":"word"},{"id":6889,"position":9,"arabic":"عَنِ","translation":"হ'তে","audioUrl":"wbw/029_006_010.mp3","charTypeName":"word"},{"id":6890,"position":10,"arabic":"ٱلْعَـٰلَمِينَ","translation":"বিশ্ববাসী","audioUrl":"wbw/029_006_011.mp3","charTypeName":"word"},{"id":6891,"position":11,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]}]}