{"id":105,"ayahs":[{"number":171,"arabic":"يَٰٓأَهْلَ ٱلْكِتَٰبِ لَا تَغْلُوا۟ فِى دِينِكُمْ وَلَا تَقُولُوا۟ عَلَى ٱللَّهِ إِلَّا ٱلْحَقَّ ۚ إِنَّمَا ٱلْمَسِيحُ عِيسَى ٱبْنُ مَرْيَمَ رَسُولُ ٱللَّهِ وَكَلِمَتُهُۥٓ أَلْقَىٰهَآ إِلَىٰ مَرْيَمَ وَرُوحٌۭ مِّنْهُ ۖ فَـَٔامِنُوا۟ بِٱللَّهِ وَرُسُلِهِۦ ۖ وَلَا تَقُولُوا۟ ثَلَٰثَةٌ ۚ ٱنتَهُوا۟ خَيْرًۭا لَّكُمْ ۚ إِنَّمَا ٱللَّهُ إِلَٰهٌۭ وَٰحِدٌۭ ۖ سُبْحَٰنَهُۥٓ أَن يَكُونَ لَهُۥ وَلَدٌۭ ۘ لَّهُۥ مَا فِى ٱلسَّمَٰوَٰتِ وَمَا فِى ٱلْأَرْضِ ۗ وَكَفَىٰ بِٱللَّهِ وَكِيلًۭا","translation":"O FOLLOWERS of the Gospel! Do not overstep the bounds [of truth] in your religious beliefs, and do not say of God anything but the truth. The Christ Jesus, son of Mary, was but God's Apostle - [the fulfilment of] His promise which He had conveyed unto Mary - and a soul created by Him. Believe, then, in God and His apostles, and do not say, \"[God is] a trinity\". Desist [from this assertion] for your own good. God is but One God; utterly remote is He, in His glory, from having a son: unto Him belongs all that is in the heavens and all that is on earth; and none is as worthy of trust as God.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/664.mp3","surahId":4,"words":[{"id":82924,"position":1,"arabic":"يَـٰٓأَهْلَ","translation":"হে আহলি","audioUrl":"wbw/004_171_001.mp3","charTypeName":"word"},{"id":82925,"position":2,"arabic":"ٱلْكِتَـٰبِ","translation":"কিতাব","audioUrl":"wbw/004_171_002.mp3","charTypeName":"word"},{"id":82926,"position":3,"arabic":"لَا","translation":"না","audioUrl":"wbw/004_171_003.mp3","charTypeName":"word"},{"id":82927,"position":4,"arabic":"تَغْلُوا۟","translation":"তোমরা বাড়াবাড়ি করো","audioUrl":"wbw/004_171_004.mp3","charTypeName":"word"},{"id":82928,"position":5,"arabic":"فِى","translation":"ব্যাপারে","audioUrl":"wbw/004_171_005.mp3","charTypeName":"word"},{"id":82929,"position":6,"arabic":"دِينِكُمْ","translation":"তোমাদের দ্বীনের","audioUrl":"wbw/004_171_006.mp3","charTypeName":"word"},{"id":82930,"position":7,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/004_171_007.mp3","charTypeName":"word"},{"id":82931,"position":8,"arabic":"تَقُولُوا۟","translation":"তোমরা বলো","audioUrl":"wbw/004_171_008.mp3","charTypeName":"word"},{"id":82932,"position":9,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/004_171_009.mp3","charTypeName":"word"},{"id":82933,"position":10,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/004_171_010.mp3","charTypeName":"word"},{"id":82934,"position":11,"arabic":"إِلَّا","translation":"এছাড়া যা","audioUrl":"wbw/004_171_011.mp3","charTypeName":"word"},{"id":82935,"position":12,"arabic":"ٱلْحَقَّ ۚ","translation":"হক","audioUrl":"wbw/004_171_012.mp3","charTypeName":"word"},{"id":82937,"position":13,"arabic":"إِنَّمَا","translation":"মূলত","audioUrl":"wbw/004_171_014.mp3","charTypeName":"word"},{"id":82938,"position":14,"arabic":"ٱلْمَسِيحُ","translation":"মসীহ","audioUrl":"wbw/004_171_015.mp3","charTypeName":"word"},{"id":82939,"position":15,"arabic":"عِيسَى","translation":"ঈসা","audioUrl":"wbw/004_171_016.mp3","charTypeName":"word"},{"id":82940,"position":16,"arabic":"ٱبْنُ","translation":"পুত্র","audioUrl":"wbw/004_171_017.mp3","charTypeName":"word"},{"id":82941,"position":17,"arabic":"مَرْيَمَ","translation":"মারইয়ামের","audioUrl":"wbw/004_171_018.mp3","charTypeName":"word"},{"id":82942,"position":18,"arabic":"رَسُولُ","translation":"(তিনি ছিলেন) রাসূল","audioUrl":"wbw/004_171_019.mp3","charTypeName":"word"},{"id":82943,"position":19,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/004_171_020.mp3","charTypeName":"word"},{"id":82944,"position":20,"arabic":"وَكَلِمَتُهُۥٓ","translation":"ও তাঁর ফরমান","audioUrl":"wbw/004_171_021.mp3","charTypeName":"word"},{"id":82945,"position":21,"arabic":"أَلْقَىٰهَآ","translation":"যা তিনি প্রেরণ করেন","audioUrl":"wbw/004_171_022.mp3","charTypeName":"word"},{"id":82946,"position":22,"arabic":"إِلَىٰ","translation":"প্রতি","audioUrl":"wbw/004_171_023.mp3","charTypeName":