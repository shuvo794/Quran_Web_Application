":"وَٰحِدٌۭ ۖ","translation":"একই","audioUrl":"wbw/004_171_043.mp3","charTypeName":"word"},{"id":82968,"position":39,"arabic":"سُبْحَـٰنَهُۥٓ","translation":"তিনি পবিত্র","audioUrl":"wbw/004_171_045.mp3","charTypeName":"word"},{"id":82969,"position":40,"arabic":"أَن","translation":"(এ হতে) যে","audioUrl":"wbw/004_171_046.mp3","charTypeName":"word"},{"id":82970,"position":41,"arabic":"يَكُونَ","translation":"হবে","audioUrl":"wbw/004_171_047.mp3","charTypeName":"word"},{"id":82971,"position":42,"arabic":"لَهُۥ","translation":"তার","audioUrl":"wbw/004_171_048.mp3","charTypeName":"word"},{"id":82972,"position":43,"arabic":"وَلَدٌۭ ۘ","translation":"কোন সন্তান","audioUrl":"wbw/004_171_049.mp3","charTypeName":"word"},{"id":82974,"position":44,"arabic":"لَّهُۥ","translation":"তারই","audioUrl":"wbw/004_171_051.mp3","charTypeName":"word"},{"id":82975,"position":45,"arabic":"مَا","translation":"যা কিছু আছে","audioUrl":"wbw/004_171_052.mp3","charTypeName":"word"},{"id":82976,"position":46,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/004_171_053.mp3","charTypeName":"word"},{"id":82977,"position":47,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আসমানসমূহের","audioUrl":"wbw/004_171_054.mp3","charTypeName":"word"},{"id":82978,"position":48,"arabic":"وَمَا","translation":"ও যা কিছু (আছে)","audioUrl":"wbw/004_171_055.mp3","charTypeName":"word"},{"id":82979,"position":49,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/004_171_056.mp3","charTypeName":"word"},{"id":82980,"position":50,"arabic":"ٱلْأَرْضِ ۗ","translation":"পৃথিবীর","audioUrl":"wbw/004_171_057.mp3","charTypeName":"word"},{"id":82982,"position":51,"arabic":"وَكَفَىٰ","translation":"এবং যথেষ্ট","audioUrl":"wbw/004_171_059.mp3","charTypeName":"word"},{"id":82983,"position":52,"arabic":"بِٱللَّهِ","translation":"আল্লাহই","audioUrl":"wbw/004_171_060.mp3","charTypeName":"word"},{"id":82984,"position":53,"arabic":"وَكِيلًۭا","translation":"কর্মবিধায়ক হিসেবে","audioUrl":"wbw/004_171_061.mp3","charTypeName":"word"},{"id":82985,"position":54,"arabic":"١٧١","translation":"(১৭১)","audioUrl":null,"charTypeName":"end"}]},{"number":172,"arabic":"لَّن يَسْتَنكِفَ ٱلْمَسِيحُ أَن يَكُونَ عَبْدًۭا لِّلَّهِ وَلَا ٱلْمَلَٰٓئِكَةُ ٱلْمُقَرَّبُونَ ۚ وَمَن يَسْتَنكِفْ عَنْ عِبَادَتِهِۦ وَيَسْتَكْبِرْ فَسَيَحْشُرُهُمْ إِلَيْهِ جَمِيعًۭا","translation":"Never did the Christ feel too proud to be God's servant, nor do the angels who are near unto Him. And those who feel too proud to serve Him and glory in their arrogance [should know that on Judgment Day] He will gather them all unto Himself:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/665.mp3","surahId":4,"words":[{"id":83096,"position":1,"arabic":"لَّن","translation":"কক্ষনো না","audioUrl":"wbw/004_172_001.mp3","charTypeName":"word"},{"id":83097,"position":2,"arabic":"يَسْتَنكِفَ","translation":"হেয় জ্ঞান করে","audioUrl":"wbw/004_172_002.mp3","charTypeName":"word"},{"id":83098,"position":3,"arabic":"ٱلْمَسِيحُ","translation":"মসীহ","audioUrl":"wbw/004_172_003.mp3","charTypeName":"word"},{"id":83099,"position":4,"arabic":"أَن","translation":"(যে)","audioUrl":"wbw/004_172_004.mp3","charTypeName":"word"},{"id":83100,"position":5,"arabic":"يَكُونَ","translation":"হওয়াতে","audioUrl":"wbw/004_172_005.mp3","charTypeName":"word"},{"id":83101,"position":6,"arabic":"عَبْدًۭا","translation":"বান্দা","audioUrl":"wbw/004_172_006.mp3","charTypeName":"word"},{"id":83102,"position":7,"arabic":"لِّلَّهِ","translation":"আল্লাহর","audioUrl":"wbw/004_172_007.mp3","charTypeName":"word"},{"id":83103,"position":8,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/004_172_008.mp3","charTypeName":"word"},{"id":83104,"position":9,"arabic":"ٱلْمَلَـٰٓئِكَةُ","translation":"ফেরেশতারাও","audioUrl":"wbw/004_172_009.mp3","charTypeName":"word"},{"id":83105,"position":10,"arabic":"ٱلْمُقَرَّبُونَ ۚ","translation":"(যারা) ঘনিষ্ঠ","audioUrl":"wbw/004_172_010.mp3","charTypeName":"word"},{"id":83107,"position":11,"arabic":"وَمَن","translation":"এবং যে","audioUrl":"wbw/004_172_012.mp3","charTypeName":"word"},{"id":83108,"position":12,"arabic":"يَسْتَنكِفْ","translation":"হেয় জ্ঞান করে","audioUrl":"wbw/004_172_013.mp3","charTypeName":"word"},{"id":83109,"position":13,"arabic":"عَنْ","translation":"হতে","audioUrl":"wbw/004_172_014.mp3","charTypeName":"word"},{"id":83110,"position":14,"arabic":"عِبَادَتِهِۦ","translation":"তাঁর বন্দেগী","audioUrl":"wbw/004_172_015.mp3","charTypeName":"word"},{"id":83111,"position":15,"arabic":"وَيَسْتَكْبِرْ","translation":"ও অহংকার করে","audioUrl":"wbw/004_172_016.mp3","charTypeName":"word"},{"id":83112,"position":16,"arabic":"فَسَيَحْشُرُهُمْ","translation":"একত্র করবেন তবে তাদের","audioUrl":"wbw/004_172_017.mp3","charTypeName":"word"},{"id":83113,"position":17,"arabic":"إِلَيْهِ","translation":"তাঁর দিকে","audioUrl":"wbw/004_172_018.mp3","charTypeName":"word"},{"id":83114,"position":18,"arabic":"جَمِيعًۭا","translation":"সকলকে","audioUrl":"wbw/004_172_019.mp3","charTypeName":"word"},{"id":83115,"position":19,"arabic":"١٧٢","translation":"(১৭২)","audioUrl":null,"charTypeName":"end"}]},{"number":173,"arabic":"فَأَمَّا ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ فَيُوَفِّيهِمْ أُجُورَهُمْ وَيَزِيدُهُم مِّن فَضْلِهِۦ ۖ وَأَمَّا ٱلَّذِينَ ٱسْتَنكَفُوا۟ وَٱسْتَكْبَرُوا۟ فَيُعَذِّبُهُمْ عَذَابًا أَلِيمًۭا وَلَا يَجِدُونَ لَهُم مِّن دُونِ ٱللَّهِ وَلِيًّۭا وَلَا نَصِيرًۭا","translation":"whereupon unto those who attained to faith and did good deeds He will grant their just rewards, and give them yet more out of His bounty; whereas those who felt too proud and gloried in their arrogance He will chastise with grievous suffering: and they shall find none to protect them from God, and none to bring them succour.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/666.mp3","surahId":4,"words":[{"id":83161,"position":1,"arabic":"فَأَمَّا","translation":"অতঃপর","audioUrl":"wbw/004_173_001.mp3","charTypeName":"word"},{"id":83162,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audi