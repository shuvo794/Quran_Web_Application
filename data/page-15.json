{"id":15,"ayahs":[{"number":94,"arabic":"قُلْ إِن كَانَتْ لَكُمُ ٱلدَّارُ ٱلْءَاخِرَةُ عِندَ ٱللَّهِ خَالِصَةًۭ مِّن دُونِ ٱلنَّاسِ فَتَمَنَّوُا۟ ٱلْمَوْتَ إِن كُنتُمْ صَٰدِقِينَ","translation":"Say: \"If an afterlife with God is to be for you alone, to the exclusion of all other people, then. you should long for death-if what you say is true!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/101.mp3","surahId":2,"words":[{"id":69599,"position":1,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/002_094_001.mp3","charTypeName":"word"},{"id":69600,"position":2,"arabic":"إِن","translation":"''যদি","audioUrl":"wbw/002_094_002.mp3","charTypeName":"word"},{"id":69601,"position":3,"arabic":"كَانَتْ","translation":"হয় (নির্দিষ্ট)","audioUrl":"wbw/002_094_003.mp3","charTypeName":"word"},{"id":69602,"position":4,"arabic":"لَكُمُ","translation":"তোমাদের জন্য","audioUrl":"wbw/002_094_004.mp3","charTypeName":"word"},{"id":69603,"position":5,"arabic":"ٱلدَّارُ","translation":"ঘর","audioUrl":"wbw/002_094_005.mp3","charTypeName":"word"},{"id":69604,"position":6,"arabic":"ٱلْـَٔاخِرَةُ","translation":"আখিরাতের","audioUrl":"wbw/002_094_006.mp3","charTypeName":"word"},{"id":69605,"position":7,"arabic":"عِندَ","translation":"কাছে","audioUrl":"wbw/002_094_007.mp3","charTypeName":"word"},{"id":69606,"position":8,"arabic":"ٱللَّهِ","translation":"আল্লাহ","audioUrl":"wbw/002_094_008.mp3","charTypeName":"word"},{"id":69607,"position":9,"arabic":"خَالِصَةًۭ","translation":"কেবল (তোমাদেরই)","audioUrl":"wbw/002_094_009.mp3","charTypeName":"word"},{"id":69608,"position":10,"arabic":"مِّن","translation":"থেকে(দিয়ে)","audioUrl":"wbw/002_094_010.mp3","charTypeName":"word"},{"id":69609,"position":11,"arabic":"دُونِ","translation":"ব্যতীত(বাদ)","audioUrl":"wbw/002_094_011.mp3","charTypeName":"word"},{"id":69610,"position":12,"arabic":"ٱلنَّاسِ","translation":"(সমগ্র)মানুষকে","audioUrl":"wbw/002_094_012.mp3","charTypeName":"word"},{"id":69611,"position":13,"arabic":"فَتَمَنَّوُا۟"