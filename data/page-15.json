:69791,"position":8,"arabic":"عَلِيمٌۢ","translation":"খুবই অবহিত","audioUrl":"wbw/002_095_009.mp3","charTypeName":"word"},{"id":69792,"position":9,"arabic":"بِٱلظَّـٰلِمِينَ","translation":"সীমালঙ্ঘঙ্কারীদের সম্পর্কে","audioUrl":"wbw/002_095_010.mp3","charTypeName":"word"},{"id":69793,"position":10,"arabic":"٩٥","translation":"(৯৫)","audioUrl":null,"charTypeName":"end"}]},{"number":96,"arabic":"وَلَتَجِدَنَّهُمْ أَحْرَصَ ٱلنَّاسِ عَلَىٰ حَيَوٰةٍۢ وَمِنَ ٱلَّذِينَ أَشْرَكُوا۟ ۚ يَوَدُّ أَحَدُهُمْ لَوْ يُعَمَّرُ أَلْفَ سَنَةٍۢ وَمَا هُوَ بِمُزَحْزِحِهِۦ مِنَ ٱلْعَذَابِ أَن يُعَمَّرَ ۗ وَٱللَّهُ بَصِيرٌۢ بِمَا يَعْمَلُونَ","translation":"And thou wilt most certainly find that they cling to life more eagerly than any other people, even more than those who are bent on ascribing divinity to other beings beside God: every one of them would love to live a thousand years, although the grant of long life could not save him from suffering [in the hereafter]: for God sees all that they do.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/103.mp3","surahId":2,"words":[{"id":69993,"position":1,"arabic":"وَلَتَجِدَنَّهُمْ","translation":"এবং তোমরা অবশ্যই তাদেরকে পাবে","audioUrl":"wbw/002_096_001.mp3","charTypeName":"word"},{"id":69994,"position":2,"arabic":"أَحْرَصَ","translation":"অত্যধিক লোভী","audioUrl":"wbw/002_096_002.mp3","charTypeName":"word"},{"id":69995,"position":3,"arabic":"ٱلنَّاسِ","translation":"মানুষের মধ্যে","audioUrl":"wbw/002_096_003.mp3","charTypeName":"word"},{"id":69996,"position":4,"arabic":"عَلَىٰ","translation":"প্রতি","audioUrl":"wbw/002_096_004.mp3","charTypeName":"word"},{"id":69997,"position":5,"arabic":"حَيَوٰةٍۢ","translation":"বেঁচে থাকার","audioUrl":"wbw/002_096_005.mp3","charTypeName":"word"},{"id":69998,"position":6,"arabic":"وَمِنَ","translation":"এবং (তাদের) চেয়েও","audioUrl":"wbw/002_096_006.mp3","charTypeName":"word"},{"id":69999,"position":7,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/002_096_007.mp3","charTypeN