ic.network/quran/audio/128/ar.alafasy/766.mp3","surahId":5,"words":[{"id":70343,"position":1,"arabic":"۞ جَعَلَ","translation":"নির্ধারিত করেছেন","audioUrl":"wbw/005_097_002.mp3","charTypeName":"word"},{"id":70344,"position":2,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/005_097_003.mp3","charTypeName":"word"},{"id":70345,"position":3,"arabic":"ٱلْكَعْبَةَ","translation":"ক্বাবা","audioUrl":"wbw/005_097_004.mp3","charTypeName":"word"},{"id":70346,"position":4,"arabic":"ٱلْبَيْتَ","translation":"ঘরকে","audioUrl":"wbw/005_097_005.mp3","charTypeName":"word"},{"id":70347,"position":5,"arabic":"ٱلْحَرَامَ","translation":"সম্মানিত","audioUrl":"wbw/005_097_006.mp3","charTypeName":"word"},{"id":70348,"position":6,"arabic":"قِيَـٰمًۭا","translation":"(কল্যাণ) প্রতিষ্ঠার উপকরণ","audioUrl":"wbw/005_097_007.mp3","charTypeName":"word"},{"id":70349,"position":7,"arabic":"لِّلنَّاسِ","translation":"জন্যে মানুষের","audioUrl":"wbw/005_097_008.mp3","charTypeName":"word"},{"id":70350,"position":8,"arabic":"وَٱلشَّهْرَ","translation":"ও মাস","audioUrl":"wbw/005_097_009.mp3","charTypeName":"word"},{"id":70351,"position":9,"arabic":"ٱلْحَرَامَ","translation":"সম্মানিত","audioUrl":"wbw/005_097_010.mp3","charTypeName":"word"},{"id":70352,"position":10,"arabic":"وَٱلْهَدْىَ","translation":"ও কোরবানির জন্যে কাবায় পাঠানো জন্তু","audioUrl":"wbw/005_097_011.mp3","charTypeName":"word"},{"id":70353,"position":11,"arabic":"وَٱلْقَلَـٰٓئِدَ ۚ","translation":"ও গলায় মালা পরানো পশু","audioUrl":"wbw/005_097_012.mp3","charTypeName":"word"},{"id":70355,"position":12,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/005_097_014.mp3","charTypeName":"word"},{"id":70356,"position":13,"arabic":"لِتَعْلَمُوٓا۟","translation":"যেন তোমরা জানো","audioUrl":"wbw/005_097_015.mp3","charTypeName":"word"},{"id":70357,"position":14,"arabic":"أَنَّ","translation":"যে","audioUrl":"wbw/005_097_016.mp3","charTypeName":"word"},{"id":70358,"position":15,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":