{"id":124,"ayahs":[{"number":96,"arabic":"أُحِلَّ لَكُمْ صَيْدُ ٱلْبَحْرِ وَطَعَامُهُۥ مَتَٰعًۭا لَّكُمْ وَلِلسَّيَّارَةِ ۖ وَحُرِّمَ عَلَيْكُمْ صَيْدُ ٱلْبَرِّ مَا دُمْتُمْ حُرُمًۭا ۗ وَٱتَّقُوا۟ ٱللَّهَ ٱلَّذِىٓ إِلَيْهِ تُحْشَرُونَ","translation":"Lawful to you is all water-game, and what the sea brings forth, as a provision for you [who are settled] as well as for travellers, although you are forbidden to hunt on land while you are in the state of pilgrimage. And be conscious of God, unto whom you shall be gathered.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/765.mp3","surahId":5,"words":[{"id":70166,"position":1,"arabic":"أُحِلَّ","translation":"বৈধ করা হয়েছে","audioUrl":"wbw/005_096_001.mp3","charTypeName":"word"},{"id":70167,"position":2,"arabic":"لَكُمْ","translation":"জন্যে তোমাদের","audioUrl":"wbw/005_096_002.mp3","charTypeName":"word"},{"id":70168,"position":3,"arabic":"صَيْدُ","translation":"শিকার","audioUrl":"wbw/005_096_003.mp3","charTypeName":"word"},{"id":70169,"position":4,"arabic":"ٱلْبَحْرِ","translation":"সাগরের","audioUrl":"wbw/005_096_004.mp3","charTypeName":"word"},{"id":70170,"position":5,"arabic":"وَطَعَامُهُۥ","translation":"ও খাওয়া তা","audioUrl":"wbw/005_096_005.mp3","charTypeName":"word"},{"id":70171,"position":6,"arabic":"مَتَـٰعًۭا","translation":"ভোগ্যবস্তু হিসেবে (বৈধ)","audioUrl":"wbw/005_096_006.mp3","charTypeName":"word"},{"id":70172,"position":7,"arabic":"لَّكُمْ","translation":"জন্যে তোমাদের","audioUrl":"wbw/005_096_007.mp3","charTypeName":"word"},{"id":70173,"position":8,"arabic":"وَلِلسَّيَّارَةِ ۖ","translation":"এবং জন্যেও পর্যটকদের","audioUrl":"wbw/005_096_008.mp3","charTypeName":"word"},{"id":70175,"position":9,"arabic":"وَحُرِّمَ","translation":"কিন্তু নিষিদ্ধ করা হয়েছে","audioUrl":"wbw/005_096_010.mp3","charTypeName":"word"},{"id":70176,"position":10,"arabic":"عَلَيْكُمْ","translation":"উপর তোমাদের","audioUrl":"wbw/005_096_011.mp3","charTypeName":"word"},{"id":70177,"position":11,"arabic":"صَيْدُ",