{"id":374,"ayahs":[{"number":160,"arabic":"كَذَّبَتْ قَوْمُ لُوطٍ ٱلْمُرْسَلِينَ","translation":"[AND] the people of Lot gave the lie to [one of God’s] message-bearers","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3092.mp3","surahId":26,"words":[{"id":81848,"position":1,"arabic":"كَذَّبَتْ","translation":"মিথ্যারোপ করেছিলো","audioUrl":"wbw/026_160_001.mp3","charTypeName":"word"},{"id":81849,"position":2,"arabic":"قَوْمُ","translation":"জাতি","audioUrl":"wbw/026_160_002.mp3","charTypeName":"word"},{"id":81850,"position":3,"arabic":"لُوطٍ","translation":"লুতের","audioUrl":"wbw/026_160_003.mp3","charTypeName":"word"},{"id":81851,"position":4,"arabic":"ٱلْمُرْسَلِينَ","translation":"রাসূলদেরকে","audioUrl":"wbw/026_160_004.mp3","charTypeName":"word"},{"id":81852,"position":5,"arabic":"١٦٠","translation":"(১৬০)","audioUrl":null,"charTypeName":"end"}]},{"number":161,"arabic":"إِذْ قَالَ لَهُمْ أَخُوهُمْ لُوطٌ أَلَا تَتَّقُونَ","translation":"when their brother Lot said unto them: “Will you not be conscious of God?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3093.mp3","surahId":26,"words":[{"id":81888,"position":1,"arabic":"إِذْ","translation":"(স্মরণ করো) যখন","audioUrl":"wbw/026_161_001.mp3","charTypeName":"word"},{"id":81889,"position":2,"arabic":"قَالَ","translation":"বলেছিলো","audioUrl":"wbw/026_161_002.mp3","charTypeName":"word"},{"id":81890,"position":3,"arabic":"لَهُمْ","translation":"উদ্দেশ্যে তাদের","audioUrl":"wbw/026_161_003.mp3","charTypeName":"word"},{"id":81891,"position":4,"arabic":"أَخُوهُمْ","translation":"ভাই তাদের","audioUrl":"wbw/026_161_004.mp3","charTypeName":"word"},{"id":81892,"position":5,"arabic":"لُوطٌ","translation":"লুত","audioUrl":"wbw/026_161_005.mp3","charTypeName":"word"},{"id":81893,"position":6,"arabic":"أَلَا","translation":"\"কি না","audioUrl":"wbw/026_161_006.mp3","charTypeName":"word"},{"id":81894,"position":7,"arabic":"تَتَّقُونَ","translation":"তোমরা ভয় করবে","audioUrl":"wbw/026_161_007.mp3","charTypeName":"word"},{"id":81895,"position":8,"arabic":"١٦١","translation":"(১৬১)","audioUrl":null,"charTypeName":"end"}]},{"number":162,"arabic":"إِنِّى لَكُمْ رَسُولٌ أَمِينٌۭ","translation":"Behold, I am an apostle [sent by Him] to you, [and therefore] worthy of your trust:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3094.mp3","surahId":26,"words":[{"id":81989,"position":1,"arabic":"إِنِّى","translation":"নিশ্চয়ই আমি","audioUrl":"wbw/026_162_001.mp3","charTypeName":"word"},{"id":81990,"position":2,"arabic":"لَكُمْ","translation":"জন্যে তোমাদের","audioUrl":"wbw/026_162_002.mp3","charTypeName":"word"},{"id":81991,"position":3,"arabic":"رَسُولٌ","translation":"একজন রাসূল","audioUrl":"wbw/026_162_003.mp3","charTypeName":"word"},{"id":81992,"position":4,"arabic":"أَمِينٌۭ","translation":"বিশ্বস্ত","audioUrl":"wbw/026_162_004.mp3","charTypeName":"word"},{"id":81993,"position":5,"arabic":"١٦٢","translation":"(১৬২)","audioUrl":null,"charTypeName":"end"}]},{"number":163,"arabic":"فَٱتَّقُوا۟ ٱللَّهَ وَأَطِيعُونِ","translation":"be, then, conscious of God, and pay heed unto me!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3095.mp3","surahId":26,"words":[{"id":82096,"position":1,"arabic":"فَٱتَّقُوا۟","translation":"অতএব তোমরা ভয় করো","audioUrl":"wbw/026_163_001.mp3","charTypeName":"word"},{"id":82097,"position":2,"arabic":"ٱللَّهَ","translation":"আল্লাহকে","audioUrl":"wbw/026_163_002.mp3","charTypeName":"word"},{"id":82098,"position":3,"arabic":"وَأَطِيعُونِ","translation":"ও আমার আনুগত্য করো","audioUrl":"wbw/026_163_003.mp3","charTypeName":"word"},{"id":82099,"position":4,"arabic":"١٦٣","translation":"(১৬৩)","audioUrl":null,"charTypeName":"end"}]},{"number":164,"arabic":"وَمَآ أَسْـَٔلُكُمْ عَلَيْهِ مِنْ أَجْرٍ ۖ إِنْ أَجْرِىَ إِلَّا عَلَىٰ رَبِّ ٱلْعَٰلَمِينَ","translation":"“And no reward whatever do I ask of you for it: my reward rests with none but the Sustainer of all the worlds.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3096.mp3","surahId":26,"words":[{"id":82216,"position":1,"arabic":"وَمَآ","translation":"আর না","audioUrl":"wbw/026_164_001.mp3","charTypeName":"word"},{"id":82217,"position":2,"arabic":"أَسْـَٔلُكُمْ","translation":"তোমাদের (নিকট) আমি চাচ্ছি","audioUrl":"wbw/026_164_002.mp3","charTypeName":"word"},{"id":82218,"position":3,"arabic":"عَلَيْهِ","translation":"জন্যে এর","audioUrl":"wbw/026_164_003.mp3","charTypeName":"word"},{"id":82219,"position":4,"arabic":"مِنْ","translation":"কোনো","audioUrl":"wbw/026_164_004.mp3","charTypeName":"word"},{"id":82220,"position":5,"arabic":"أَجْرٍ ۖ","translation":"পারিশ্রমিক","audioUrl":"wbw/026_164_005.mp3","charTypeName":"word"},{"id":82222,"position":6,"arabic":"إِنْ","translation":"নেই","audioUrl":"wbw/026_164_007.mp3","charTypeName":"word"},{"id":82223,"position":7,"arabic":"أَجْرِىَ","translation":"আমার প্রতিদান (কারো নিকট)","audioUrl":"wbw/026_164_008.mp3","charTypeName":"word"},{"id":82224,"position":8,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/026_164_009.mp3","charTypeName":"word"},{"id":82225,"position":9,"arabic":"عَلَىٰ","translation":"নিকট","audioUrl":"wbw/026_164_010.mp3","charTypeName":"word"},{"id":82226,"position":10,"arabic":"رَبِّ","translation":"রবের","audioUrl":"wbw/026_164_011.mp3","charTypeName":"word"},{"id":82227,"position":11,"arabic":"ٱلْعَـٰلَمِينَ","translation":"বিশ্বজগতের","audioUrl":"wbw/026_164_012.mp3","charTypeName":"word"},{"id":82228,"position":12,"arabic":"١٦٤","translation":"(১৬৪)","audioUrl":null,"charTypeName":"end"}]},{"number":165,"arabic":"أَتَأْتُونَ ٱلذُّكْرَانَ مِنَ ٱلْعَٰلَمِينَ","translation":"“Must you, of all people, [lustfully] approach men,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3097.mp3","surahId":26,"words":[{"id":82328,"position":1,"arabic":"أَتَأْتُونَ","translation":"কি তোমরা উপগত হও","audioUrl":"wbw/026_165_001.mp3","charTypeName":"word"},{"id":82329,"position":2,"arabic":"ٱلذُّكْرَانَ","translation":"পুরুষদের (নিকট)","audioUrl":"wbw/026_165_002.mp3","charTypeName":"word"},{"id":82330,"position":3,"arabic":"مِنَ","translation":"মধ্য হ'তে","audioUrl":"wbw/026_165_003.mp3","charTypeName":"word"},{"id":82331,"position":4,"arabic":"ٱلْعَـٰلَمِينَ","translation":"বিশ্বজগতের","audioUrl":"wbw/026_165_004.mp3","charTypeName":"word"},{"id":82332,"position":5,"arabic":"١٦٥","translation":"(১৬৫)","audioUrl":null,"charTypeName":"end"}]},{"number":166,"arabic":"وَتَذَرُونَ مَا خَلَقَ لَكُمْ رَبُّكُم مِّنْ أَزْوَٰجِكُم ۚ بَلْ أَنتُمْ قَوْمٌ عَادُونَ","translation":"keeping yourselves aloof from all the [lawful] spouses whom your Sustainer has created for you? Nay, but you are people who transgress all bounds of what is right!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3098.mp3","surahId":26,"words":[{"id":82476,"position":1,"arabic":"وَتَذَرُونَ","translation":"ও তোমরা পরিহার করছো","audioUrl":"wbw/026_166_001.mp3","charTypeName":"word"},{"id":82477,"position":2,"arabic":"مَا","translation":"যা","audioUrl":"wbw/026_166_002.mp3","charTypeName":"word"},{"id":82478,"position":3,"arabic":"خَلَقَ","translation":"সৃষ্টি করেছেন","audioUrl":"wbw/026_166_003.mp3","charTypeName":"word"},{"id":82479,"position":4,"arabic":"لَكُمْ","translation":"জন্যে তোমাদের","audioUrl":"wbw/026_166_004.mp3","charTypeName":"word"},{"id":82480,"position":5,"arabic":"رَبُّكُم","translation":"রব তোমাদের","audioUrl":"wbw/026_166_005.mp3","charTypeName":"word"},{"id":82481,"position":6,"arabic":"مِّنْ","translation":"মধ্য থেকে","audioUrl":"wbw/026_166_006.mp3","charTypeName":"word"},{"id":82482,"position":7,"arabic":"أَزْوَٰجِكُم ۚ","translation":"তোমাদের স্ত্রীদের","audioUrl":"wbw/026_166_007.mp3","charTypeName":"word"},{"id":82484,"position":8,"arabic":"بَلْ","translation":"বরং","audioUrl":"wbw/026_166_009.mp3","charTypeName":"word"},{"id":82485,"position":9,"arabic":"أَنتُمْ","translation":"তোমরা","audioUrl":"wbw/026_166_010.mp3","charTypeName":"word"},{"id":82486,"position":10,"arabic":"قَوْمٌ","translation":"জাতি","audioUrl":"wbw/026_166_011.mp3","charTypeName":"word"},{"id":82487,"position":11,"arabic":"عَادُونَ","translation":"সীমালঙ্ঘনকারী\"","audioUrl":"wbw/026_166_012.mp3","charTypeName":"word"},{"id":82488,"position":12,"arabic":"١٦٦","translation":"(১৬৬)","audioUrl":null,"charTypeName":"end"}]},{"number":167,"arabic":"قَالُوا۟ لَئِن لَّمْ تَنتَهِ يَٰلُوطُ لَتَكُونَنَّ مِنَ ٱلْمُخْرَجِينَ","translation":"Said they: “Indeed, If thou desist not, O Lot, thou wilt most certainly be expelled [from this town­ship]!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3099.mp3","surahId":26,"words":[{"id":82522,"position":1,"arabic":"قَالُوا۟","translation":"তারা বললো","audioUrl":"wbw/026_167_001.mp3","charTypeName":"word"},{"id":82523,"position":2,"arabic":"لَئِن","translation":"\"অবশ্যই যদি","audioUrl":"wbw/026_167_002.mp3","charTypeName":"word"},{"id":82524,"position":3,"arabic":"لَّمْ","translation":"না","audioUrl":"wbw/026_167_003.mp3","charTypeName":"word"},{"id":82525,"position":4,"arabic":"تَنتَهِ","translation":"বিরত হও","audioUrl":"wbw/026_167_004.mp3","charTypeName":"word"},{"id":82526,"position":5,"arabic":"يَـٰلُوطُ","translation":"হে লুত","audioUrl":"wbw/026_167_005.mp3","charTypeName":"word"},{"id":82527,"position":6,"arabic":"لَتَكُونَنَّ","translation":"অবশ্যই তুমি হবে","audioUrl":"wbw/026_167_006.mp3","charTypeName":"word"},{"id":82528,"position":7,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/026_167_007.mp3","charTypeName":"word"},{"id":82529,"position":8,"arabic":"ٱلْمُخْرَجِينَ","translation":"বহিষ্কৃতদের\"","audioUrl":"wbw/026_167_008.mp3","charTypeName":"word"},{"id":82530,"position":9,"arabic":"١٦٧","translation":"(১৬৭)","audioUrl":null,"charTypeName":"end"}]},{"number":168,"arabic":"قَالَ إِنِّى لِعَمَلِكُم مِّنَ ٱلْقَالِينَ","translation":"[Lot] exclaimed: “Behold, I am one of those who utterly abhor your doings!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3100.mp3","surahId":26,"words":[{"id":82671,"position":1,"arabic":"قَالَ","translation":"(লুত) বললো","audioUrl":"wbw/026_168_001.mp3","charTypeName":"word"},{"id":82672,"position":2,"arabic":"إِنِّى","translation":"\"নিশ্চয়ই আমি","audioUrl":"wbw/026_168_002.mp3","charTypeName":"word"},{"id":82673,"position":3,"arabic":"لِعَمَلِكُم","translation":"জন্যে তোমাদের কাজের","audioUrl":"wbw/026_168_003.mp3","charTypeName":"word"},{"id":82674,"position":4,"arabic":"مِّنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/026_168_004.mp3","charTypeName":"word"},{"id":82675,"position":5,"arabic":"ٱلْقَالِينَ","translation":"ঘৃণাকারীদের","audioUrl":"wbw/026_168_005.mp3","charTypeName":"word"},{"id":82676,"position":6,"arabic":"١٦٨","translation":"(১৬৮)","audioUrl":null,"charTypeName":"end"}]},{"number":169,"arabic":"رَبِّ نَجِّنِى وَأَهْلِى مِمَّا يَعْمَلُونَ","translation":"[And then he prayed:] “O my Sustainer! Save me and my household from all that they are doing!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3101.mp3","surahId":26,"words":[{"id":82713,"position":1,"arabic":"رَبِّ","translation":"হে আমার রব","audioUrl":"wbw/026_169_001.mp3","charTypeName":"word"},{"id":82714,"position":2,"arabic":"نَجِّنِى","translation":"আমাকে রক্ষা করো","audioUrl":"wbw/026_169_002.mp3","charTypeName":"word"},{"id":82715,"position":3,"arabic":"وَأَهْلِى","translation":"ও আমার পরিবারকে","audioUrl":"wbw/026_169_003.mp3","charTypeName":"word"},{"id":82716,"position":4,"arabic":"مِمَّا","translation":"(তা) হ'তে যা","audioUrl":"wbw/026_169_004.mp3","charTypeName":"word"},{"id":82717,"position":5,"arabic":"يَعْمَلُونَ","translation":"তারা করেছে\"","audioUrl":"wbw/026_169_005.mp3","charTypeName":"word"},{"id":82718,"position":6,"arabic":"١٦٩","translation":"(১৬৯)","audioUrl":null,"charTypeName":"end"}]},{"number":170,"arabic":"فَنَجَّيْنَٰهُ وَأَهْلَهُۥٓ أَجْمَعِينَ","translation":"Thereupon We saved him and all his household –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3102.mp3","surahId":26,"words":[{"id":82869,"position":1,"arabic":"فَنَجَّيْنَـٰهُ","translation":"অতঃপর তাকে আমরা রক্ষা করলাম","audioUrl":"wbw/026_170_001.mp3","charTypeName":"word"},{"id":82870,"position":2,"arabic":"وَأَهْلَهُۥٓ","translation":"ও তার পরিবারকে","audioUrl":"wbw/026_170_002.mp3","charTypeName":"word"},{"id":82871,"position":3,"arabic":"أَجْمَعِينَ","translation":"সবাইকে (একযোগে)","audioUrl":"wbw/026_170_003.mp3","charTypeName":"word"},{"id":82872,"position":4,"arabic":"١٧٠","translation":"(১৭০)","audioUrl":null,"charTypeName":"end"}]},{"number":171,"arabic":"إِلَّا عَجُوزًۭا فِى ٱلْغَٰبِرِينَ","translation":"all but an old woman, who was among those that stayed behind;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3103.mp3","surahId":26,"words":[{"id":82899,"position":1,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/026_171_001.mp3","charTypeName":"word"},{"id":82900,"position":2,"arabic":"عَجُوزًۭا","translation":"এক বৃদ্ধা (তার স্ত্রী)","audioUrl":"wbw/026_171_002.mp3","charTypeName":"word"},{"id":82901,"position":3,"arabic":"فِى","translation":"(সে ছিলো) অন্তর্ভুক্ত","audioUrl":"wbw/026_171_003.mp3","charTypeName":"word"},{"id":82902,"position":4,"arabic":"ٱلْغَـٰبِرِينَ","translation":"পিছনে অবস্থানকারীদের","audioUrl":"wbw/026_171_004.mp3","charTypeName":"word"},{"id":82903,"position":5,"arabic":"١٧١","translation":"(১৭১)","audioUrl":null,"charTypeName":"end"}]},{"number":172,"arabic":"ثُمَّ دَمَّرْنَا ٱلْءَاخَرِينَ","translation":"and then We utterly destroyed the others,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3104.mp3","surahId":26,"words":[{"id":83075,"position":1,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/026_172_001.mp3","charTypeName":"word"},{"id":83076,"position":2,"arabic":"دَمَّرْنَا","translation":"আমরা ধ্বংস করলাম","audioUrl":"wbw/026_172_002.mp3","charTypeName":"word"},{"id":83077,"position":3,"arabic":"ٱلْـَٔاخَرِينَ","translation":"অন্যদেরকে","audioUrl":"wbw/026_172_003.mp3","charTypeName":"word"},{"id":83078,"position":4,"arabic":"١٧٢","translation":"(১৭২)","audioUrl":null,"charTypeName":"end"}]},{"number":173,"arabic":"وَأَمْطَرْنَا عَلَيْهِم مَّطَرًۭا ۖ فَسَآءَ مَطَرُ ٱلْمُنذَرِينَ","translation":"and rained down upon them a rain [of destruction]: and dire is such rain upon all who let themselves be warned [to no avail]!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3105.mp3","surahId":26,"words":[{"id":83207,"position":1,"arabic":"وَأَمْطَرْنَا","translation":"এবং আমরা বর্ষণ করেছিলাম","audioUrl":"wbw/026_173_001.mp3","charTypeName":"word"},{"id":83208,"position":2,"arabic":"عَلَيْهِم","translation":"উপর তাদের","audioUrl":"wbw/026_173_002.mp3","charTypeName":"word"},{"id":83209,"position":3,"arabic":"مَّطَرًۭا ۖ","translation":"এক বর্ষণ (শাস্তিমূলক)","audioUrl":"wbw/026_173_003.mp3","charTypeName":"word"},{"id":83211,"position":4,"arabic":"فَسَآءَ","translation":"অতএব কত নিকৃষ্ট","audioUrl":"wbw/026_173_005.mp3","charTypeName":"word"},{"id":83212,"position":5,"arabic":"مَطَرُ","translation":"বর্ষণ","audioUrl":"wbw/026_173_006.mp3","charTypeName":"word"},{"id":83213,"position":6,"arabic":"ٱلْمُنذَرِينَ","translation":"সতর্ককৃতদের (জন্যে)","audioUrl":"wbw/026_173_007.mp3","charTypeName":"word"},{"id":83214,"position":7,"arabic":"١٧٣","translation":"(১৭৩)","audioUrl":null,"charTypeName":"end"}]},{"number":174,"arabic":"إِنَّ فِى ذَٰلِكَ لَءَايَةًۭ ۖ وَمَا كَانَ أَكْثَرُهُم مُّؤْمِنِينَ","translation":"In this [story], behold, there is a message [unto men], even though most of them will not be­lieve [in it].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3106.mp3","surahId":26,"words":[{"id":83286,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/026_174_001.mp3","charTypeName":"word"},{"id":83287,"position":2,"arabic":"فِى","translation":"মধ্যে (আছে)","audioUrl":"wbw/026_174_002.mp3","charTypeName":"word"},{"id":83288,"position":3,"arabic":"ذَٰلِكَ","translation":"এর","audioUrl":"wbw/026_174_003.mp3","charTypeName":"word"},{"id":83289,"position":4,"arabic":"لَـَٔايَةًۭ ۖ","translation":"অবশ্যই নিদর্শন","audioUrl":"wbw/026_174_004.mp3","charTypeName":"word"},{"id":83291,"position":5,"arabic":"وَمَا","translation":"আর না","audioUrl":"wbw/026_174_006.mp3","charTypeName":"word"},{"id":83292,"position":6,"arabic":"كَانَ","translation":"ছিলো","audioUrl":"wbw/026_174_007.mp3","charTypeName":"word"},{"id":83293,"position":7,"arabic":"أَكْثَرُهُم","translation":"অধিকাংশই তাদের","audioUrl":"wbw/026_174_008.mp3","charTypeName":"word"},{"id":83294,"position":8,"arabic":"مُّؤْمِنِينَ","translation":"মু'মিন","audioUrl":"wbw/026_174_009.mp3","charTypeName":"word"},{"id":83295,"position":9,"arabic":"١٧٤","translation":"(১৭৪)","audioUrl":null,"charTypeName":"end"}]},{"number":175,"arabic":"وَإِنَّ رَبَّكَ لَهُوَ ٱلْعَزِيزُ ٱلرَّحِيمُ","translation":"But, verily, thy Sustainer - He alone - is almighty, a dispenser of grace!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3107.mp3","surahId":26,"words":[{"id":83305,"position":1,"arabic":"وَإِنَّ","translation":"অথচ নিশ্চয়ই","audioUrl":"wbw/026_175_001.mp3","charTypeName":"word"},{"id":83306,"position":2,"arabic":"رَبَّكَ","translation":"তোমার রব","audioUrl":"wbw/026_175_002.mp3","charTypeName":"word"},{"id":83307,"position":3,"arabic":"لَهُوَ","translation":"অবশ্যই তিনি","audioUrl":"wbw/026_175_003.mp3","charTypeName":"word"},{"id":83308,"position":4,"arabic":"ٱلْعَزِيزُ","translation":"পরাক্রমশালী","audioUrl":"wbw/026_175_004.mp3","charTypeName":"word"},{"id":83309,"position":5,"arabic":"ٱلرَّحِيمُ","translation":"পরম দয়ালু","audioUrl":"wbw/026_175_005.mp3","charTypeName":"word"},{"id":83310,"position":6,"arabic":"١٧٥","translation":"(১৭৫)","audioUrl":null,"charTypeName":"end"}]},{"number":176,"arabic":"كَذَّبَ أَصْحَٰبُ لْـَٔيْكَةِ ٱلْمُرْسَلِينَ","translation":"[AND] the dwellers of the wooded dales [of Madyan] gave the lie to [one of God’s] message-bearers","audio":"https://cdn.islamic.netw