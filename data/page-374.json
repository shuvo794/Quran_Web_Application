work/quran/audio/128/ar.alafasy/3110.mp3","surahId":26,"words":[{"id":83600,"position":1,"arabic":"إِنِّى","translation":"নিশ্চয়ই আমি","audioUrl":"wbw/026_178_001.mp3","charTypeName":"word"},{"id":83601,"position":2,"arabic":"لَكُمْ","translation":"জন্যে তোমাদের","audioUrl":"wbw/026_178_002.mp3","charTypeName":"word"},{"id":83602,"position":3,"arabic":"رَسُولٌ","translation":"একজন রাসূল","audioUrl":"wbw/026_178_003.mp3","charTypeName":"word"},{"id":83603,"position":4,"arabic":"أَمِينٌۭ","translation":"বিশ্বস্ত","audioUrl":"wbw/026_178_004.mp3","charTypeName":"word"},{"id":83604,"position":5,"arabic":"١٧٨","translation":"(১৭৮)","audioUrl":null,"charTypeName":"end"}]},{"number":179,"arabic":"فَٱتَّقُوا۟ ٱللَّهَ وَأَطِيعُونِ","translation":"be, then, conscious of God, and pay heed unto me!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3111.mp3","surahId":26,"words":[{"id":83733,"position":1,"arabic":"فَٱتَّقُوا۟","translation":"অতঃপর তোমরা ভয় করো","audioUrl":"wbw/026_179_001.mp3","charTypeName":"word"},{"id":83734,"position":2,"arabic":"ٱللَّهَ","translation":"আল্লাহকে","audioUrl":"wbw/026_179_002.mp3","charTypeName":"word"},{"id":83735,"position":3,"arabic":"وَأَطِيعُونِ","translation":"ও তোমরা আমার আনুগত্য করো","audioUrl":"wbw/026_179_003.mp3","charTypeName":"word"},{"id":83736,"position":4,"arabic":"١٧٩","translation":"(১৭৯)","audioUrl":null,"charTypeName":"end"}]},{"number":180,"arabic":"وَمَآ أَسْـَٔلُكُمْ عَلَيْهِ مِنْ أَجْرٍ ۖ إِنْ أَجْرِىَ إِلَّا عَلَىٰ رَبِّ ٱلْعَٰلَمِينَ","translation":"“And no reward whatever do I ask of you for it: my reward rests with none but the Sustainer of all the worlds.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3112.mp3","surahId":26,"words":[{"id":83792,"position":1,"arabic":"وَمَآ","translation":"আর না","audioUrl":"wbw/026_180_001.mp3","charTypeName":"word"},{"id":83793,"position":2,"arabic":"أَسْـَٔلُكُمْ","translation":"তোমাদের (নিকট) আমি চাচ্ছি","audioUrl":"wbw/026_180_002.mp3","charTypeName":"word"},{"id":83794,"position":3,"arabic":"عَلَيْهِ","translation":"জন্যে এর","audioUrl":"wbw/026_180_003.mp3","charTypeName":"word"},{"id":83795,"position":4,"arabic":"مِنْ","translation":"কোনো","audioUrl":"wbw/026_180_004.mp3","charTypeName":"word"},{"id":83796,"position":5,"arabic":"أَجْرٍ ۖ","translation":"প্রতিদান","audioUrl":"wbw/026_180_005.mp3","charTypeName":"word"},{"id":83798,"position":6,"arabic":"إِنْ","translation":"নেই","audioUrl":"wbw/026_180_007.mp3","charTypeName":"word"},{"id":83799,"position":7,"arabic":"أَجْرِىَ","translation":"আমার প্রতিদান (অন্য কারো নিকট)","audioUrl":"wbw/026_180_008.mp3","charTypeName":"word"},{"id":83800,"position":8,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/026_180_009.mp3","charTypeName":"word"},{"id":83801,"position":9,"arabic":"عَلَىٰ","translation":"নিকট","audioUrl":"wbw/026_180_010.mp3","charTypeName":"word"},{"id":83802,"position":10,"arabic":"رَبِّ","translation":"রবের","audioUrl":"wbw/026_180_011.mp3","charTypeName":"word"},{"id":83803,"position":11,"arabic":"ٱلْعَـٰلَمِينَ","translation":"বিশ্বজগতের","audioUrl":"wbw/026_180_012.mp3","charTypeName":"word"},{"id":83804,"position":12,"arabic":"١٨٠","translation":"(১৮০)","audioUrl":null,"charTypeName":"end"}]},{"number":181,"arabic":"۞ أَوْفُوا۟ ٱلْكَيْلَ وَلَا تَكُونُوا۟ مِنَ ٱلْمُخْسِرِينَ","translation":"“[Always] give full measure, and be not among those who [unjustly] cause loss [to others];","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3113.mp3","surahId":26,"words":[{"id":83914,"position":1,"arabic":"۞ أَوْفُوا۟","translation":"তোমরা পূর্ণ দাও","audioUrl":"wbw/026_181_002.mp3","charTypeName":"word"},{"id":83915,"position":2,"arabic":"ٱلْكَيْلَ","translation":"মাপ","audioUrl":"wbw/026_181_003.mp3","charTypeName":"word"},{"id":83916,"position":3,"arabic":"وَلَا","translation":"ও না","audioUrl":"wbw/026_181_004.mp3","charTypeName":"word"},{"id":83917,"position":4,"arabic":"تَكُونُوا۟","translation":"তোমরা হয়ো","audioUrl":"wbw/026_181_005.mp3","charTypeName":"word"},{"id":83918,"position":5,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/026_181_006.mp3","charTypeName":"word"},{"id":83919,"position":6,"arabic":"ٱلْمُخْسِرِينَ","translation":"মাপে কমদানকারীদের","audioUrl":"wbw/026_181_007.mp3","charTypeName":"word"},{"id":83920,"position":7,"arabic":"١٨١","translation":"(১৮১)","audioUrl":null,"charTypeName":"end"}]},{"number":182,"arabic":"وَزِنُوا۟ بِٱلْقِسْطَاسِ ٱلْمُسْتَقِيمِ","translation":"and [in all your dealings] weigh with a true balance,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3114.mp3","surahId":26,"words":[{"id":83943,"position":1,"arabic":"وَزِنُوا۟","translation":"এবং তোমরা ওজন করবে","audioUrl":"wbw/026_182_001.mp3","charTypeName":"word"},{"id":83944,"position":2,"arabic":"بِٱلْقِسْطَاسِ","translation":"দিয়ে দাঁড়িপাল্লা","audioUrl":"wbw/026_182_002.mp3","charTypeName":"word"},{"id":83945,"position":3,"arabic":"ٱلْمُسْتَقِيمِ","translation":"সঠিক","audioUrl":"wbw/026_182_003.mp3","charTypeName":"word"},{"id":83946,"position":4,"arabic":"١٨٢","translation":"(১৮২)","audioUrl":null,"charTypeName":"end"}]},{"number":183,"arabic":"وَلَا تَبْخَسُوا۟ ٱلنَّاسَ أَشْيَآءَهُمْ وَلَا تَعْثَوْا۟ فِى ٱلْأَرْضِ مُفْسِدِينَ","translation":"and do not deprive people of what is rightfully theirs; and do not act wickedly on earth by spreading corruption,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3115.mp3","surahId":26,"words":[{"id":84016,"position":1,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/026_183_001.mp3","charTypeName":"word"},{"id":84017,"position":2,"arabic":"تَبْخَسُوا۟","translation":"তোমরা কম দিবে","audioUrl":"wbw/026_183_002.mp3","charTypeName":"word"},{"id":84018,"position":3,"arabic":"ٱلنَّاسَ","translation":"মানুষকে","audioUrl":"wbw/026_183_003.mp3","charTypeName":"word"},{"id":84019,"position":4,"arabic":"أَشْيَآءَهُمْ","translation":"জিনিসগুলোকে তাদের","audioUrl":"wbw/026_183_004.mp3","charTypeName":"word"},{"id":84020,"position":5,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/026_183_005.mp3","charTypeName":"word"},{"id":84021,"position":6,"arabic":"تَعْثَوْا۟","translation":"গোলযোগ সৃষ্টি করো","audioUrl":"wbw/026_183_006.mp3","charTypeName":"word"},{"id":84022,"position":7,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/026_183_007.mp3","charTypeName":"word"},{"id":84023,"position":8,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/026_183_008.mp3","charTypeName":"word"},{"id":84024,"position":9,"arabic":"مُفْسِدِينَ","translation":"বিপর্যয় সৃষ্টিকারী হিসেবে","audioUrl":"wbw/026_183_009.mp3","charTypeName":"word"},{"id":84025,"position":10,"arabic":"١٨٣","translation":"(১৮৩)","audioUrl":null,"charTypeName":"end"}]}]}