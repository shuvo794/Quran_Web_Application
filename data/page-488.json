)","audioUrl":"wbw/042_045_027.mp3","charTypeName":"word"},{"id":45003,"position":26,"arabic":"عَذَابٍۢ","translation":"শাস্তির","audioUrl":"wbw/042_045_028.mp3","charTypeName":"word"},{"id":45004,"position":27,"arabic":"مُّقِيمٍۢ","translation":"স্থায়ী","audioUrl":"wbw/042_045_029.mp3","charTypeName":"word"},{"id":45005,"position":28,"arabic":"٤٥","translation":"(৪৫)","audioUrl":null,"charTypeName":"end"}]},{"number":46,"arabic":"وَمَا كَانَ لَهُم مِّنْ أَوْلِيَآءَ يَنصُرُونَهُم مِّن دُونِ ٱللَّهِ ۗ وَمَن يُضْلِلِ ٱللَّهُ فَمَا لَهُۥ مِن سَبِيلٍ","translation":"and will have no protector whatever to succour them against God: for he whom God lets go astray shall find no way [of escape].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4318.mp3","surahId":42,"words":[{"id":45730,"position":1,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/042_046_001.mp3","charTypeName":"word"},{"id":45731,"position":2,"arabic":"كَانَ","translation":"হবে","audioUrl":"wbw/042_046_002.mp3","charTypeName":"word"},{"id":45732,"position":3,"arabic":"لَهُم","translation":"তাদের জন্যে","audioUrl":"wbw/042_046_003.mp3","charTypeName":"word"},{"id":45733,"position":4,"arabic":"مِّنْ","translation":"কোনো","audioUrl":"wbw/042_046_004.mp3","charTypeName":"word"},{"id":45734,"position":5,"arabic":"أَوْلِيَآءَ","translation":"অভিভাবক","audioUrl":"wbw/042_046_005.mp3","charTypeName":"word"},{"id":45735,"position":6,"arabic":"يَنصُرُونَهُم","translation":"তাদেরকে সাহায্য করতে","audioUrl":"wbw/042_046_006.mp3","charTypeName":"word"},{"id":45736,"position":7,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/042_046_007.mp3","charTypeName":"word"},{"id":45737,"position":8,"arabic":"دُونِ","translation":"ছাড়া","audioUrl":"wbw/042_046_008.mp3","charTypeName":"word"},{"id":45738,"position":9,"arabic":"ٱللَّهِ ۗ","translation":"আল্লাহ","audioUrl":"wbw/042_046_009.mp3","charTypeName":"word"},{"id":45740,"position":10,"arabic":"وَمَن","translation":"এবং যাকে","audioUrl":"wbw/042_046_011.mp3","charTypeName":"word"},{"id":45741,"position":11,"arabic":"يُضْلِلِ","translation":"পথভ্রষ্ট করেন","audioUrl":"wbw/042_046_012.mp3","charTypeName":"word"},{"id":45742,"position":12,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/042_046_013.mp3","charTypeName":"word"},{"id":45743,"position":13,"arabic":"فَمَا","translation":"তখন নেই","audioUrl":"wbw/042_046_014.mp3","charTypeName":"word"},{"id":45744,"position":14,"arabic":"لَهُۥ","translation":"তার জন্যে","audioUrl":"wbw/042_046_015.mp3","charTypeName":"word"},{"id":45745,"position":15,"arabic":"مِن","translation":"কোনো","audioUrl":"wbw/042_046_016.mp3","charTypeName":"word"},{"id":45746,"position":16,"arabic":"سَبِيلٍ","translation":"পথ","audioUrl":"wbw/042_046_017.mp3","charTypeName":"word"},{"id":45747,"position":17,"arabic":"٤٦","translation":"(৪৬)","audioUrl":null,"charTypeName":"end"}]},{"number":47,"arabic":"ٱسْتَجِيبُوا۟ لِرَبِّكُم مِّن قَبْلِ أَن يَأْتِىَ يَوْمٌۭ لَّا مَرَدَّ لَهُۥ مِنَ ٱللَّهِ ۚ مَا لَكُم مِّن مَّلْجَإٍۢ يَوْمَئِذٍۢ وَمَا لَكُم مِّن نَّكِيرٍۢ","translation":"[Hence, O men,] respond to your Sustainer before there comes, at God’s behest, a Day on which there will be no turning back: [for] on that Day you will have no place of refuge, and neither will you be able to deny aught [of the wrong that you have done].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4319.mp3","surahId":42,"words":[{"id":46367,"position":1,"arabic":"ٱسْتَجِيبُوا۟","translation":"তোমরা ডাকে সাড়া দাও (মেনে নাও)","audioUrl":"wbw/042_047_001.mp3","charTypeName":"word"},{"id":46368,"position":2,"arabic":"لِرَبِّكُم","translation":"তোমাদের রবের (কথা)","audioUrl":"wbw/042_047_002.mp3","charTypeName":"word"},{"id":46369,"position":3,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/042_047_003.mp3","charTypeName":"word"},{"id":46370,"position":4,"arabic":"قَبْلِ","translation":"(এর) পূর্বেই","audioUrl":"wbw/042_047_004.mp3","charTypeName":"word"},{"id":46371,"position":5,"arabic":"أَن","translation":"যে","audioUrl":"wbw/042_047_005.mp3","charTypeName":"word"},{"id":46372,"position":6,"arabic":"يَأْتِىَ","translation":"আসবে","audioUrl":"wbw/042_047_006.mp3","charTypeName":"word"},{"id":46373,"position":7,"arabic":"يَوْمٌۭ","translation":"(এমন) দিন","audioUrl":"wbw/042_047_007.mp3","charTypeName":"word"},{"id":46374,"position":8,"arabic":"لَّا","translation":"নেই","audioUrl":"wbw/042_047_008.mp3","charTypeName":"word"},{"id":46375,"position":9,"arabic":"مَرَدَّ","translation":"প্রতিরোধ","audioUrl":"wbw/042_047_009.mp3","charTypeName":"word"},{"id":46376,"position":10,"arabic":"لَهُۥ","translation":"তার জন্যে","audioUrl":"wbw/042_047_010.mp3","charTypeName":"word"},{"id":46377,"position":11,"arabic":"مِنَ","translation":"থেকে","audioUrl":"wbw/042_047_011.mp3","charTypeName":"word"},{"id":46378,"position":12,"arabic":"ٱللَّهِ ۚ","translation":"আল্লাহর","audioUrl":"wbw/042_047_012.mp3","charTypeName":"word"},{"id":46380,"position":13,"arabic":"مَا","translation":"নেই","audioUrl":"wbw/042_047_014.mp3","charTypeName":"word"},{"id":46381,"position":14,"arabic":"لَكُم","translation":"তোমাদের জন্যে","audioUrl":"wbw/042_047_015.mp3","charTypeName":"word"},{"id":46382,"position":15,"arabic":"مِّن","translation":"কোনো","audioUrl":"wbw/042_047_016.mp3","charTypeName":"word"},{"id":46383,"position":16,"arabic":"مَّلْجَإٍۢ","translation":"আশ্রয়স্থল","audioUrl":"wbw/042_047_017.mp3","charTypeName":"word"},{"id":46384,"position":17,"arabic":"يَوْمَئِذٍۢ","translation":"সেদিন","audioUrl":"wbw/042_047_018.mp3","charTypeName":"word"},{"id":46385,"position":18,"arabic":"وَمَا","translation":"আর নেই","audioUrl":"wbw/042_047_019.mp3","charTypeName":"word"},{"id":46386,"position":19,"arabic":"لَكُم","translation":"তোমাদের জন্যে","audioUrl":"wbw/042_047_020.mp3","charTypeName":"word"},{"id":46387,"position":20,"arabic":"مِّن","translation":"কোনো","audioUrl":"wbw/042_047_021.mp3","charTypeName":"word"},{"id":46388,"position":21,"arabic":"نَّكِيرٍۢ","translation":"প্রতিরোধকারী","audioUrl":"wbw/042_047_022.mp3","charTypeName":"word"},{"id":46389,"position":22,"arabic":"٤٧","translation":"(৪৭)","audioUrl":null,"charTypeName":"end"}]},{"number":48,"arabic":"فَإِنْ أَعْرَضُوا۟ فَمَآ أَرْسَلْنَٰكَ عَلَيْهِمْ حَفِيظًا ۖ إِنْ عَلَيْكَ إِلَّا ٱلْبَلَٰغُ ۗ وَإِنَّآ إِذَآ أَذَقْنَا ٱلْإِنسَٰنَ مِنَّا رَحْمَةًۭ فَرِحَ بِهَا ۖ وَإِن تُصِبْهُمْ سَيِّئَةٌۢ بِمَا قَدَّمَتْ أَيْدِيهِمْ فَإِنَّ ٱلْإِنسَٰنَ كَفُورٌۭ","translation":"BUT IF they turn away [from thee, O Prophet, know that] We have not sent thee to be their keeper: thou art not bound to do more than deliver the message [entrusted to thee]. And, behold, [such as turn away from Our mes­sages are but impelled by the weakness and incon­stancy of human nature: thus,] when We give man a taste of Our grace, he is prone to exult in it; but if misfortune befalls [any of] them in result of what their own hands have sent forth, then, behold, man shows how bereft he is of all gratitude!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4320.mp3","surahId":42,"words":[{"id":47112,"position":1,"arabic":"فَإِنْ","translation":"অতএব যদি","audioUrl":"wbw/042_048_001.mp3","charTypeName":"word"},{"id":47113,"position":2,"arabic":"أَعْرَضُوا۟","translation":"তারা মুখ ফেরায়","audioUrl":"wbw/042_048_002.mp3","charTypeName":"word"},{"id":47114,"position":3,"arabic":"فَمَآ","translation":"তবে না","audioUrl":"wbw/042_048_003.mp3","charTypeName":"word"},{"id":47115,"position":4,"arabic":"أَرْسَلْنَـٰكَ","translation":"তোমাকে আমরা পাঠিয়েছি","audioUrl":"wbw/042_048_004.mp3","charTypeName":"word"},{"id":47116,"position":5,"arabic":"عَلَيْهِمْ","translation":"তাদের উপর","audioUrl":"wbw/042_048_005.mp3","charTypeName":"word"},{"id":47117,"position":6,"arabic":"حَفِيظًا ۖ","translation":"রক্ষক করে","audioUrl":"wbw/042_048_006.mp3","charTypeName":"word"},{"id":47119,"position":7,"arabic":"إِنْ","translation":"নেই","audioUrl":"wbw/042_048_008.mp3","charTypeName":"word"},{"id":47120,"position":8,