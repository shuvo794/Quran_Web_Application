003.mp3","charTypeName":"word"},{"id":83340,"position":4,"arabic":"ٱلضَّلَـٰلَةَ","translation":"ভ্রান্তপথ","audioUrl":"wbw/002_175_004.mp3","charTypeName":"word"},{"id":83341,"position":5,"arabic":"بِٱلْهُدَىٰ","translation":"সঠিকপথের পরিবর্তে","audioUrl":"wbw/002_175_005.mp3","charTypeName":"word"},{"id":83342,"position":6,"arabic":"وَٱلْعَذَابَ","translation":"এবং শাস্তি","audioUrl":"wbw/002_175_006.mp3","charTypeName":"word"},{"id":83343,"position":7,"arabic":"بِٱلْمَغْفِرَةِ ۚ","translation":"ক্ষমার পরিবর্তে","audioUrl":"wbw/002_175_007.mp3","charTypeName":"word"},{"id":83345,"position":8,"arabic":"فَمَآ","translation":"অতঃপর কতই না","audioUrl":"wbw/002_175_009.mp3","charTypeName":"word"},{"id":83346,"position":9,"arabic":"أَصْبَرَهُمْ","translation":"ধৈর্যশীল","audioUrl":"wbw/002_175_010.mp3","charTypeName":"word"},{"id":83347,"position":10,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/002_175_011.mp3","charTypeName":"word"},{"id":83348,"position":11,"arabic":"ٱلنَّارِ","translation":"আগুনের","audioUrl":"wbw/002_175_012.mp3","charTypeName":"word"},{"id":83349,"position":12,"arabic":"١٧٥","translation":"(১৭৫)","audioUrl":null,"charTypeName":"end"}]},{"number":176,"arabic":"ذَٰلِكَ بِأَنَّ ٱللَّهَ نَزَّلَ ٱلْكِتَٰبَ بِٱلْحَقِّ ۗ وَإِنَّ ٱلَّذِينَ ٱخْتَلَفُوا۟ فِى ٱلْكِتَٰبِ لَفِى شِقَاقٍۭ بَعِيدٍۢ","translation":"Thus it is: since it is God who bestows the divine writ from on high, setting forth the truth, all those who set their own views against the divine writ are, verily, most deeply in the wrong.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/183.mp3","surahId":2,"words":[{"id":83366,"position":1,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/002_176_001.mp3","charTypeName":"word"},{"id":83367,"position":2,"arabic":"بِأَنَّ","translation":"এজন্য যে","audioUrl":"wbw/002_176_002.mp3","charTypeName":"word"},{"id":83368,"position":3,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/002_176_003.mp3","charTypeName":"word"},{"id":83369,"position":4,"arabic":"نَزَّلَ","translation":"অবতীর্ণ করেছেন","audioUrl":"wbw/002_176_004.mp3","charTypeName":"word"},{"id":83370,"position":5,"arabic":"ٱلْكِتَـٰبَ","translation":"কিতাব","audioUrl":"wbw/002_176_005.mp3","charTypeName":"word"},{"id":83371,"position":6,"arabic":"بِٱلْحَقِّ ۗ","translation":"সত্য সহকারে","audioUrl":"wbw/002_176_006.mp3","charTypeName":"word"},{"id":83373,"position":7,"arabic":"وَإِنَّ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/002_176_008.mp3","charTypeName":"word"},{"id":83374,"position":8,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/002_176_009.mp3","charTypeName":"word"},{"id":83375,"position":9,"arabic":"ٱخْتَلَفُوا۟","translation":"মতভেদ করেছে","audioUrl":"wbw/002_176_010.mp3","charTypeName":"word"},{"id":83376,"position":10,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/002_176_011.mp3","charTypeName":"word"},{"id":83377,"position":11,"arabic":"ٱلْكِتَـٰبِ","translation":"কিতাবের","audioUrl":"wbw/002_176_012.mp3","charTypeName":"word"},{"id":83378,"position":12,"arabic":"لَفِى","translation":"অবশ্যই মধ্যে(আছে)","audioUrl":"wbw/002_176_013.mp3","charTypeName":"word"},{"id":83379,"position":13,"arabic":"شِقَاقٍۭ","translation":"বিশুদ্ধতার","audioUrl":"wbw/002_176_014.mp3","charTypeName":"word"},{"id":83380,"position":14,"arabic":"بَعِيدٍۢ","translation":"(প্রকৃত সত্য হতে) বহুদূরে","audioUrl":"wbw/002_176_015.mp3","charTypeName":"word"},{"id":83381,"position":15,"arabic":"١٧٦","translation":"(১৭৬)","audioUrl":null,"charTypeName":"end"}]}]}