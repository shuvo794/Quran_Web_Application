rl":"wbw/017_015_021.mp3","charTypeName":"word"},{"id":16847,"position":19,"arabic":"حَتَّىٰ","translation":"যতক্ষণ  না","audioUrl":"wbw/017_015_022.mp3","charTypeName":"word"},{"id":16848,"position":20,"arabic":"نَبْعَثَ","translation":"পাঠাই আমরা","audioUrl":"wbw/017_015_023.mp3","charTypeName":"word"},{"id":16849,"position":21,"arabic":"رَسُولًۭا","translation":"কোনো রাসূল","audioUrl":"wbw/017_015_024.mp3","charTypeName":"word"},{"id":16850,"position":22,"arabic":"١٥","translation":"(১৫)","audioUrl":null,"charTypeName":"end"}]},{"number":16,"arabic":"وَإِذَآ أَرَدْنَآ أَن نُّهْلِكَ قَرْيَةً أَمَرْنَا مُتْرَفِيهَا فَفَسَقُوا۟ فِيهَا فَحَقَّ عَلَيْهَا ٱلْقَوْلُ فَدَمَّرْنَٰهَا تَدْمِيرًۭا","translation":"But when [this has been done, and] it is Our will to destroy a community, We convey Our last warning to those of its people who have lost themselves entirely in the pursuit of pleasures; and [if] they [continue to] act sinfully, the sentence [of doom] passed on the community takes effect, and We break it to smithereens.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2045.mp3","surahId":17,"words":[{"id":17986,"position":1,"arabic":"وَإِذَآ","translation":"এবং যখন","audioUrl":"wbw/017_016_001.mp3","charTypeName":"word"},{"id":17987,"position":2,"arabic":"أَرَدْنَآ","translation":"আমরা চাই","audioUrl":"wbw/017_016_002.mp3","charTypeName":"word"},{"id":17988,"position":3,"arabic":"أَن","translation":"যে","audioUrl":"wbw/017_016_003.mp3","charTypeName":"word"},{"id":17989,"position":4,"arabic":"نُّهْلِكَ","translation":"ধ্বংস করবো আমরা","audioUrl":"wbw/017_016_004.mp3","charTypeName":"word"},{"id":17990,"position":5,"arabic":"قَرْيَةً","translation":"কোনো জনপদকে","audioUrl":"wbw/017_016_005.mp3","charTypeName":"word"},{"id":17991,"position":6,"arabic":"أَمَرْنَا","translation":"আমরা আদেশ দিই","audioUrl":"wbw/017_016_006.mp3","charTypeName":"word"},{"id":17992,"position":7,"arabic":"مُتْرَفِيهَا","translation":"তার সমৃদ্ধশালী লোকদেরকে (সৎকর্মের)","audioUrl":"wbw/017_016_007.mp3","charTypeName":"word"},{"id":17993,"position":8,"arabic":"فَفَسَقُوا۟","translation":"কিন্তু তারা অসৎ কর্ম করে","audioUrl":"wbw/017_016_008.mp3","charTypeName":"word"},{"id":17994,"position":9,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/017_016_009.mp3","charTypeName":"word"},{"id":17995,"position":10,"arabic":"فَحَقَّ","translation":"তখন অবধারিত হয়","audioUrl":"wbw/017_016_010.mp3","charTypeName":"word"},{"id":17996,"position":11,"arabic":"عَلَيْهَا","translation":"উপর তার","audioUrl":"wbw/017_016_011.mp3","charTypeName":"word"},{"id":17997,"position":12,"arabic":"ٱلْقَوْلُ","translation":"(শাস্তির) আদেশ","audioUrl":"wbw/017_016_012.mp3","charTypeName":"word"},{"id":17998,"position":13,"arabic":"فَدَمَّرْنَـٰهَا","translation":"অতঃপর তা আমরা বিধ্বংস করি","audioUrl":"wbw/017_016_013.mp3","charTypeName":"word"},{"id":17999,"position":14,"arabic":"تَدْمِيرًۭا","translation":"ধ্বংস","audioUrl":"wbw/017_016_014.mp3","charTypeName":"word"},{"id":18000,"position":15,"arabic":"١٦","translation":"(১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":17,"arabic":"وَكَمْ أَهْلَكْنَا مِنَ ٱلْقُرُونِ مِنۢ بَعْدِ نُوحٍۢ ۗ وَكَفَىٰ بِرَبِّكَ بِذُنُوبِ عِبَادِهِۦ خَبِيرًۢا بَصِيرًۭا","translation":"And how many a generation have We [thus] destroyed after [the time of] Noah! For, none has the like of thy Sustainer's awareness and insight into His creatures' sins.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2046.mp3","surahId":17,"words":[{"id":18987,"position":1,"arabic":"وَكَمْ","translation":"এবং কত","audioUrl":"wbw/017_017_001.mp3","charTypeName":"word"},{"id":18988,"position":2,"arabic":"أَهْلَكْنَا","translation":"ধ্বংস করেছি আমরা","audioUrl":"wbw/017_017_002.mp3","charTypeName":"word"},{"id":18989,"position":3,"arabic":"مِنَ","translation":"থেকে","audioUrl":"wbw/017_017_003.mp3","charTypeName":"word"},{"id":18990,"position":4,"arabic":"ٱلْقُرُونِ","translation":"মানবগোষ্ঠী","audioUrl":"wbw/017_017_004.mp