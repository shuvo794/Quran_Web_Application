{"id":283,"ayahs":[{"number":8,"arabic":"عَسَىٰ رَبُّكُمْ أَن يَرْحَمَكُمْ ۚ وَإِنْ عُدتُّمْ عُدْنَا ۘ وَجَعَلْنَا جَهَنَّمَ لِلْكَٰفِرِينَ حَصِيرًا","translation":"Your Sustainer may well show mercy unto you; but if you revert [to sinning], We shall revert [to chastising you]. And [remember this:] We have ordained that [in the hereafter] hell shall close upon all who deny the truth.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2037.mp3","surahId":17,"words":[{"id":8486,"position":1,"arabic":"عَسَىٰ","translation":"\"আশা করা যায়","audioUrl":"wbw/017_008_001.mp3","charTypeName":"word"},{"id":8487,"position":2,"arabic":"رَبُّكُمْ","translation":"তোমাদের রব","audioUrl":"wbw/017_008_002.mp3","charTypeName":"word"},{"id":8488,"position":3,"arabic":"أَن","translation":"যে","audioUrl":"wbw/017_008_003.mp3","charTypeName":"word"},{"id":8489,"position":4,"arabic":"يَرْحَمَكُمْ ۚ","translation":"তোমাদের উপর দয়া করবেন","audioUrl":"wbw/017_008_004.mp3","charTypeName":"word"},{"id":8491,"position":5,"arabic":"وَإِنْ","translation":"কিন্তু যদি","audioUrl":"wbw/017_008_006.mp3","charTypeName":"word"},{"id":8492,"position":6,"arabic":"عُدتُّمْ","translation":"পুনরাবৃত্তি করো তোমরা","audioUrl":"wbw/017_008_007.mp3","charTypeName":"word"},{"id":8493,"position":7,"arabic":"عُدْنَا ۘ","translation":"পুনরাবৃত্তি করবো আমরা","audioUrl":"wbw/017_008_008.mp3","charTypeName":"word"},{"id":8495,"position":8,"arabic":"وَجَعَلْنَا","translation":"এবং আমরা বানিয়েছি","audioUrl":"wbw/017_008_010.mp3","charTypeName":"word"},{"id":8496,"position":9,"arabic":"جَهَنَّمَ","translation":"জাহান্নামকে","audioUrl":"wbw/017_008_011.mp3","charTypeName":"word"},{"id":8497,"position":10,"arabic":"لِلْكَـٰفِرِينَ","translation":"জন্যে কাফিরদের","audioUrl":"wbw/017_008_012.mp3","charTypeName":"word"},{"id":8498,"position":11,"arabic":"حَصِيرًا","translation":"কারাগার\"","audioUrl":"wbw/017_008_013.mp3","charTypeName":"word"},{"id":8499,"position":12,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"إِنَّ هَٰذَا ٱلْقُرْءَانَ يَهْدِى لِلَّتِى هِىَ أَقْوَمُ وَيُبَشِّرُ ٱلْمُؤْمِنِينَ ٱلَّذِينَ يَعْمَلُونَ ٱلصَّٰلِحَٰتِ أَنَّ لَهُمْ أَجْرًۭا كَبِيرًۭا","translation":"VERILY, this Qur'an shows the way to all that is most upright, and gives the believers who do good deeds the glad tiding that theirs will be a great reward;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2038.mp3","surahId":17,"words":[{"id":9677,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/017_009_001.mp3","charTypeName":"word"},{"id":9678,"position":2,"arabic":"هَـٰذَا","translation":"এই","audioUrl":"wbw/017_009_002.mp3","charTypeName":"word"},{"id":9679,"position":3,"arabic":"ٱلْقُرْءَانَ","translation":"কুরআন","audioUrl":"wbw/017_009_003.mp3","charTypeName":"word"},{"id":9680,"position":4,"arabic":"يَهْدِى","translation":"পথ দেখায়","audioUrl":"wbw/017_009_004.mp3","charTypeName":"word"},{"id":9681,"position":5,"arabic":"لِلَّتِى","translation":"সেই দিকে","audioUrl":"wbw/017_009_005.mp3","charTypeName":"word"},{"id":9682,"position":6,"arabic":"هِىَ","translation":"যা","audioUrl":"wbw/017_009_006.mp3","charTypeName":"word"},{"id":9683,"position":7,"arabic":"أَقْوَمُ","translation":"সরলতম","audioUrl":"wbw/017_009_007.mp3","charTypeName":"word"},{"id":9684,"position":8,"arabic":"وَيُبَشِّرُ","translation":"ও সুসংবাদ দেয়","audioUrl":"wbw/017_009_008.mp3","charTypeName":"word"},{"id":9685,"position":9,"arabic":"ٱلْمُؤْمِنِينَ","translation":"মু'মিনদেরকে","audioUrl":"wbw/017_009_009.mp3","charTypeName":"word"},{"id":9686,"position":10,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/017_009_010.mp3","charTypeName":"word"},{"id":9687,"position":11,"arabic":"يَعْمَلُونَ","translation":"কাজ করে","audioUrl":"wbw/017_009_011.mp3","charTypeName":"word"},{"id":9688,"position":12,"arabic":"ٱلصَّـٰلِحَـٰتِ","translation":"সৎ","audioUrl":"wbw/017_009_012.mp3","charTypeName":"word"},{"id":9689,"position":13,"arabic":"أَنَّ","translation":"যে","audioUrl":"wbw/017_009_013.mp3","charTypeName":"word"},{"id":9690,"position":14,"arabic":"لَهُمْ","translation":"জন্যে তাদের","audioUrl":"wbw/017_009_014.mp3","charTypeName":"word"},{"id":9691,"position":15,"arabic":"أَجْرًۭا","translation":"পুরস্কার (রয়েছে)","audioUrl":"wbw/017_009_015.mp3","charTypeName":"word"},{"id":9692,"position":16,"arabic":"كَبِيرًۭا","translation":"বিরাট","audioUrl":"wbw/017_009_016.mp3","charTypeName":"word"},{"id":9693,"position":17,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"وَأَنَّ ٱلَّذِينَ لَا يُؤْمِنُونَ بِٱلْءَاخِرَةِ أَعْتَدْنَا لَهُمْ عَذَابًا أَلِيمًۭا","translation":"and [it announces, too,] that We have readied grievous suffering for those who will not believe in the life to come.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2039.mp3","surahId":17,"words":[{"id":10829,"position":1,"arabic":"وَأَنَّ","translation":"এবং (এও) যে","audioUrl":"wbw/017_010_001.mp3","charTypeName":"word"},{"id":10830,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/017_010_002.mp3","charTypeName":"word"},{"id":10831,"position":3,"arabic":"لَا","translation":"না","audioUrl":"wbw/017_010_003.mp3","charTypeName":"word"},{"id":10832,"position":4,"arabic":"يُؤْمِنُونَ","translation":"বিশ্বাস করে","audioUrl":"wbw/017_010_004.mp3","charTypeName":"word"},{"id":10833,"position":5,"arabic":"بِٱلْـَٔاخِرَةِ","translation":"প্রতি আখিরাতের","audioUrl":"wbw/017_010_005.mp3","charTypeName":"word"},{"id":10834,"position":6,"arabic":"أَعْتَدْنَا","translation":"প্রস্তুত রেখেছি আমরা","audioUrl":"wbw/017_010_006.mp3","charTypeName":"word"},{"id":10835,"position":7,"arabic":"لَهُمْ","translation":"জন্যে তাদের","audioUrl":"wbw/017_010_007.mp3","charTypeName":"word"},{"id":10836,"position":8,"arabic":"عَذَابًا","translation":"শাস্তি","audioUrl":"wbw/017_010_008.mp3","charTypeName":"word"},{"id":10837,"position":9,"arabic":"أَلِيمًۭا","translation":"নিদারুণ","audioUrl":"wbw/017_010_009.mp3","charTypeName":"word"},{"id":10838,"position":10,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"وَيَدْعُ ٱلْإِنسَٰنُ بِٱلشَّرِّ دُعَآءَهُۥ بِٱلْخَيْرِ ۖ وَكَانَ ٱلْإِنسَٰنُ عَجُولًۭا","translation":"As it is, man [often] prays for things that are bad as if he were praying for something that is good: for man is prone to be hasty [in his judgments].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2040.mp3","surahId":17,"words":[{"id":12081,"position":1,"arabic":"وَيَدْعُ","translation":"এবং কামনা করে","audioUrl":"wbw/017_011_001.mp3","charTypeName":"word"},{"id":12082,"position":2,"arabic":"ٱلْإِنسَـٰنُ","translation":"মানুষ","audioUrl":"wbw/017_011_002.mp3","charTypeName":"word"},{"id":12083,"position":3,"arabic":"بِٱلشَّرِّ","translation":"অকল্যাণের","audioUrl":"wbw/017_011_003.mp3","charTypeName":"word"},{"id":12084,"position":4,"arabic":"دُعَآءَهُۥ","translation":"তার কামনা (করা উচিত যেমন)","audioUrl":"wbw/017_011_004.mp3","charTypeName":"word"},{"id":12085,"position":5,"arabic":"بِٱلْخَيْرِ ۖ","translation":"কল্যাণের","audioUrl":"wbw/017_011_005.mp3","charTypeName":"word"},{"id":12087,"position":6,"arabic":"وَكَانَ","translation":"এবং হলো","audioUrl":"wbw/017_011_007.mp3","charTypeName":"word"},{"id":12088,"position":7,"arabic":"ٱلْإِنسَـٰنُ","translation":"মানুষ","audioUrl":"wbw/017_011_008.mp3","charTypeName":"word"},{"id":12089,"position":8,"arabic":"عَجُولًۭا","translation":"তাড়াহুড়াকারী","audioUrl":"wbw/017_011_009.mp3","charTypeName":"word"},{"id":12090,"position":9,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]},{"number":12,"arabic":"وَجَعَلْنَا ٱلَّيْلَ وَٱلنَّهَارَ ءَايَتَيْنِ ۖ فَمَحَوْنَآ ءَايَةَ ٱلَّيْلِ وَجَعَلْنَآ ءَايَةَ ٱلنَّهَارِ مُبْصِرَةًۭ لِّتَبْتَغُوا۟ فَضْلًۭا مِّن رَّبِّكُمْ وَلِتَعْلَمُوا۟ عَدَدَ ٱلسِّنِينَ وَٱلْحِسَابَ ۚ وَكُلَّ شَىْءٍۢ فَصَّلْنَٰهُ تَفْصِيلًۭا","translation":"And We have established the night and the day as two symbols; and thereupon We have effaced the symbol of night and set up [in its place] the light giving symbol of day, so that you might seek to obtain your Sustainer's bounty and be aware of the passing years and of the reckoning [that is bound to come]. For clearly, most clearly, have We spelt out everything!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2041.mp3","surahId":17,"words":[{"id":13393,"position":1,"arabic":"وَجَعَلْنَا","translation":"এবং আমরা করেছি","audioUrl":"wbw/017_012_001.mp3","charTypeName":"word"},{"id":13394,"position":2,"arabic":"ٱلَّيْلَ","translation":"রাতকে","audioUrl":"wbw/017_012_002.mp3","charTypeName":"word"},{"id":13395,"position":3,"arabic":"وَٱلنَّهَارَ","translation":"ও দিনকে","audioUrl":"wbw/017_012_003.mp3","charTypeName":"word"},{"id":13396,"position":4,"arabic":"ءَايَتَيْنِ ۖ","translation":"দু'টি নিদর্শন","audioUrl":"wbw/017_012_004.mp3","charTypeName":"word"},{"id":13398,"position":5,"arabic":"فَمَحَوْنَآ","translation":"অতঃপর আমরা নিষ্প্রভ করেছি","audioUrl":"wbw/017_012_006.mp3","charTypeName":"word"},{"id":13399,"position":6,"arabic":"ءَايَةَ","translation":"নিদর্শনকে","audioUrl":"wbw/017_012_007.mp3","charTypeName":"word"},{"id":13400,"position":7,"arabic":"ٱلَّيْلِ","translation":"রাতের","audioUrl":"wbw/017_012_008.mp3","charTypeName":"word"},{"id":13401,"position":8,"arabic":"وَجَعَلْنَآ","translation":"এবং আমরা করেছি","audioUrl":"wbw/017_012_009.mp3","charTypeName":"word"},{"id":13402,"position":9,"arabic":"ءَايَةَ","translation":"নিদর্শনকে","audioUrl":"wbw/017_012_010.mp3","charTypeName":"word"},{"id":13403,"position":10,"arabic":"ٱلنَّهَارِ","translation":"দিনের","audioUrl":"wbw/017_012_011.mp3","charTypeName":"word"},{"id":13404,"position":11,"arabic":"مُبْصِرَةًۭ","translation":"উজ্জ্বল","audioUrl":"wbw/017_012_012.mp3","charTypeName":"word"},{"id":13405,"position":12,"arabic":"لِّتَبْتَغُوا۟","translation":"যেন তোমরা সন্ধান করতে পারো","audioUrl":"wbw/017_012_013.mp3","charTypeName":"word"},{"id":13406,"position":13,"arabic":"فَضْلًۭا","translation":"অনুগ্রহ","audioUrl":"wbw/017_012_014.mp3","charTypeName":"word"},{"id":13407,"position":14,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/017_012_015.mp3","charTypeName":"word"},{"id":13408,"position":15,"arabic":"رَّبِّكُمْ","translation":"তোমাদের রবের","audioUrl":"wbw/017_012_016.mp3","charTypeName":"word"},{"id":13409,"position":16,"arabic":"وَلِتَعْلَمُوا۟","translation":"এবং যেন তোমরা জানো","audioUrl":"wbw/017_012_017.mp3","charTypeName":"word"},{"id":13410,"position":17,"arabic":"عَدَدَ","translation":"গণনা","audioUrl":"wbw/017_012_018.mp3","charTypeName":"word"},{"id":13411,"position":18,"arabic":"ٱلسِّنِينَ","translation":"বছর সমূহের","audioUrl":"wbw/017_012_019.mp3","charTypeName":"word"},{"id":13412,"position":19,"arabic":"وَٱلْحِسَابَ ۚ","translation":"ও হিসেবের","audioUrl":"wbw/017_012_020.mp3","charTypeName":"word"},{"id":13414,"position":20,"arabic":"وَكُلَّ","translation":"এবং প্রত্যেক","audioUrl":"wbw/017_012_022.mp3","charTypeName":"word"},{"id":13415,"position":21,"arabic":"شَىْءٍۢ","translation":"বস্তু","audioUrl":"wbw/017_012_023.mp3","charTypeName":"word"},{"id":13416,"position":22,"arabic":"فَصَّلْنَـٰهُ","translation":"তা আমরা বিশদ বর্ণনা করেছি","audioUrl":"wbw/017_012_024.mp3","charTypeName":"word"},{"id":13417,"position":23,"arabic":"تَفْصِيلًۭا","translation":"বিশদ বর্ণনা","audioUrl":"wbw/017_012_025.mp3","charTypeName":"word"},{"id":13418,"position":24,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]},{"number":13,"arabic":"وَكُلَّ إِنسَٰنٍ أَلْزَمْنَٰهُ طَٰٓئِرَهُۥ فِى عُنُقِهِۦ ۖ وَنُخْرِجُ لَهُۥ يَوْمَ ٱلْقِيَٰمَةِ كِتَٰبًۭا يَلْقَىٰهُ مَنشُورًا","translation":"And every human being's destiny have We tied to his neck; and on the Day of Resurrection We shall bring forth for him a record which he will find wide open;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2042.mp3","surahId":17,"words":[{"id":14663,"position":1,"arabic":"وَكُلَّ","translation":"এবং প্রত্যেক","audioUrl":"wbw/017_013_001.mp3","charTypeName":"word"},{"id":14664,"position":2,"arabic":"إِنسَـٰنٍ","translation":"মানুষের","audioUrl":"wbw/017_013_002.mp3","charTypeName":"word"},{"id":14665,"position":3,"arabic":"أَلْزَمْنَـٰهُ","translation":"তাকে আমরা ঝুলিয়ে দিয়েছি","audioUrl":"wbw/017_013_003.mp3","charTypeName":"word"},{"id":14666,"position":4,"arabic":"طَـٰٓئِرَهُۥ","translation":"তার কৃতকর্মকে","audioUrl":"wbw/017_013_004.mp3","charTypeName":"word"},{"id":14667,"position":5,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/017_013_005.mp3","charTypeName":"word"},{"id":14668,"position":6,"arabic":"عُنُقِهِۦ ۖ","translation":"তার গলার","audioUrl":"wbw/017_013_006.mp3","charTypeName":"word"},{"id":14670,"position":7,"arabic":"وَنُخْرِجُ","translation":"এবং বের করবো আমরা","audioUrl":"wbw/017_013_008.mp3","charTypeName":"word"},{"id":14671,"position":8,"arabic":"لَهُۥ","translation":"জন্যে তার","audioUrl":"wbw/017_013_009.mp3","charTypeName":"word"},{"id":14672,"position":9,"arabic":"يَوْمَ","translation":"দিনে","audioUrl":"wbw/017_013_010.mp3","charTypeName":"word"},{"id":14673,"position":10,"arabic":"ٱلْقِيَـٰمَةِ","translation":"ক্বিয়ামাতের","audioUrl":"wbw/017_013_011.mp3","charTypeName":"word"},{"id":14674,"position":11,"arabic":"كِتَـٰبًۭا","translation":"কিতাব (স্বরুপ)","audioUrl":"wbw/017_013_012.mp3","charTypeName":"word"},{"id":14675,"position":12,"arabic":"يَلْقَىٰهُ","translation":"তা পাবে সে","audioUrl":"wbw/017_013_013.mp3","charTypeName":"word"},{"id":14676,"position":13,"arabic":"مَنشُورًا","translation":"খোলা","audioUrl":"wbw/017_013_014.mp3","charTypeName":"word"},{"id":14677,"position":14,"arabic":"١٣","translation":"(১৩)","audioUrl":null,"charTypeName":"end"}]},{"number":14,"arabic":"ٱقْرَأْ كِتَٰبَكَ كَفَىٰ بِنَفْسِكَ ٱلْيَوْمَ عَلَيْكَ حَسِيبًۭا","translation":"[and he will be told:] \"Read this thy record,! Sufficient is thine own self today to make out thine account!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2043.mp3","surahId":17,"words":[{"id":15752,"position":1,"arabic":"ٱقْرَأْ","translation":"\"পড়ো","audioUrl":"wbw/017_014_001.mp3","charTypeName":"word"},{"id":15753,"position":2,"arabic":"كِتَـٰبَكَ","translation":"তোমরা কিতাব (কর্মফল)","audioUrl":"wbw/017_014_002.mp3","charTypeName":"word"},{"id":15754,"position":3,"arabic":"كَفَىٰ","translation":"যথেষ্ট","audioUrl":"wbw/017_014_003.mp3","charTypeName":"word"},{"id":15755,"position":4,"arabic":"بِنَفْسِكَ","translation":"নিয়ে তুমি নিজেই","audioUrl":"wbw/017_014_004.mp3","charTypeName":"word"},{"id":15756,"position":5,"arabic":"ٱلْيَوْمَ","translation":"আজ","audioUrl":"wbw/017_014_005.mp3","charTypeName":"word"},{"id":15757,"position":6,"arabic":"عَلَيْكَ","translation":"তোমার উপর","audioUrl":"wbw/017_014_006.mp3","charTypeName":"word"},{"id":15758,"position":7,"arabic":"حَسِيبًۭا","translation":"হিসাব গ্রহণকারী হিসেবে\"","audioUrl":"wbw/017_014_007.mp3","charTypeName":"word"},{"id":15759,"position":8,"arabic":"١٤","translation":"(১৪)","audioUrl":null,"charTypeName":"end"}]},{"number":15,"arabic":"مَّنِ ٱهْتَدَىٰ فَإِنَّمَا يَهْتَدِى لِنَفْسِهِۦ ۖ وَمَن ضَلَّ فَإِنَّمَا يَضِلُّ عَلَيْهَا ۚ وَلَا تَزِرُ وَازِرَةٌۭ وِزْرَ أُخْرَىٰ ۗ وَمَا كُنَّا مُعَذِّبِينَ حَتَّىٰ نَبْعَثَ رَسُولًۭا","translation":"Whoever chooses to follow the right path, follows it but for his own good; and whoever goes astray, goes but astray to his own hurt; and no bearer of burdens shall be made to bear another\" burden. Moreover. We would never chastise [any community for the wrong they may do] ere We have sent an apostle [to them].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2044.mp3","surahId":17,"words":[{"id":16826,"position":1,"arabic":"مَّنِ","translation":"যে","audioUrl":"wbw/017_015_001.mp3","charTypeName":"word"},{"id":16827,"position":2,"arabic":"ٱهْتَدَىٰ","translation":"সৎপথে চলে","audioUrl":"wbw/017_015_002.mp3","charTypeName":"word"},{"id":16828,