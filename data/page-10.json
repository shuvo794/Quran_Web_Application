{"id":10,"ayahs":[{"number":62,"arabic":"إِنَّ ٱلَّذِينَ ءَامَنُوا۟ وَٱلَّذِينَ هَادُوا۟ وَٱلنَّصَٰرَىٰ وَٱلصَّٰبِـِٔينَ مَنْ ءَامَنَ بِٱللَّهِ وَٱلْيَوْمِ ٱلْءَاخِرِ وَعَمِلَ صَٰلِحًۭا فَلَهُمْ أَجْرُهُمْ عِندَ رَبِّهِمْ وَلَا خَوْفٌ عَلَيْهِمْ وَلَا هُمْ يَحْزَنُونَ","translation":"VERILY, those who have attained to faith [in this divine writ], as well as those who follow the Jewish faith, and the Christians, and the Sabians -all who believe in God and the Last Day and do righteous deeds-shall have their reward with their Sustainer; and no fear need they have, and neither shall they grieve.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/69.mp3","surahId":2,"words":[{"id":55484,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/002_062_001.mp3","charTypeName":"word"},{"id":55485,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/002_062_002.mp3","charTypeName":"word"},{"id":55486,"position":3,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/002_062_003.mp3","charTypeName":"word"},{"id":55487,"position":4,"arabic":"وَٱلَّذِينَ","translation":"কিংবা যারা","audioUrl":"wbw/002_062_004.mp3","charTypeName":"word"},{"id":55488,"position":5,"arabic":"هَادُوا۟","translation":"ইহুদী হয়েছে","audioUrl":"wbw/002_062_005.mp3","charTypeName":"word"},{"id":55489,"position":6,"arabic":"وَٱلنَّصَـٰرَىٰ","translation":"এবং খ্রিষ্টান","audioUrl":"wbw/002_062_006.mp3","charTypeName":"word"},{"id":55490,"position":7,"arabic":"وَٱلصَّـٰبِـِٔينَ","translation":"ও সাবী","audioUrl":"wbw/002_062_007.mp3","charTypeName":"word"},{"id":55491,"position":8,"arabic":"مَنْ","translation":"যে (কেউ)","audioUrl":"wbw/002_062_008.mp3","charTypeName":"word"},{"id":55492,"position":9,"arabic":"ءَامَنَ","translation":"ঈমান আনবে","audioUrl":"wbw/002_062_009.mp3","charTypeName":"word"},{"id":55493,"position":10,"arabic":"بِٱللَّهِ","translation":"আল্লাহ্‌র উপর","audioUrl":"wbw/002_062_010.mp3","charTypeName":"word"},{"id":55494,"position":11,"arabic":"وَٱلْيَوْمِ","translation":"ও দিনে","audioUrl":"wbw/002_062_011.mp3","charTypeName":"word"},{"id":55495,"position":12,"arabic":"ٱلْـَٔاخِرِ","translation":"আখিরাতের","audioUrl":"wbw/002_062_012.mp3","charTypeName":"word"},{"id":55496,"position":13,"arabic":"وَعَمِلَ","translation":"এবং কাজ করবে","audioUrl":"wbw/002_062_013.mp3","charTypeName":"word"},{"id":55497,"position":14,"arabic":"صَـٰلِحًۭا","translation":"সৎ","audioUrl":"wbw/002_062_014.mp3","charTypeName":"word"},{"id":55498,"position":15,"arabic":"فَلَهُمْ","translation":"ফলে তাদের জন্য","audioUrl":"wbw/002_062_015.mp3","charTypeName":"word"},{"id":55499,"position":16,"arabic":"أَجْرُهُمْ","translation":"তাদের পুরস্কার (থাকবে)","audioUrl":"wbw/002_062_016.mp3","charTypeName":"word"},{"id":55500,"position":17,"arabic":"عِندَ","translation":"কাছে","audioUrl":"wbw/002_062_017.mp3","charTypeName":"word"},{"id":55501,"position":18,"arabic":"رَبِّهِمْ","translation":"তাদের রবের","audioUrl":"wbw/002_062_018.mp3","charTypeName":"word"},{"id":55502,"position":19,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/002_062_019.mp3","charTypeName":"word"},{"id":55503,"position":20,"arabic":"خَوْفٌ","translation":"ভয় (থাকবে)","audioUrl":"wbw/002_062_020.mp3","charTypeName":"word"},{"id":55504,"position":21,"arabic":"عَلَيْهِمْ","translation":"তাদের জন্য","audioUrl":"wbw/002_062_021.mp3","charTypeName":"word"},{"id":55505,"position":22,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/002_062_022.mp3","charTypeName":"word"},{"id":55506,"position":23,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/002_062_023.mp3","charTypeName":"word"},{"id":55507,"position":24,"arabic":"يَحْزَنُونَ","translation":"দুঃখিত হবে","audioUrl":"wbw/002_062_024.mp3","charTypeName":"word"},{"id":55508,"position":25,"arabic":"٦٢","translation":"(৬২)","audioUrl":null,"charTypeName":"end"}]},{"number":63,"arabic":"وَإِذْ أَخَذْنَا مِيثَٰقَكُمْ وَرَفَعْنَا فَوْقَكُمُ ٱلطُّورَ خُذُوا۟ مَآ ءَاتَيْنَٰكُم بِقُوَّةٍۢ وَٱذْكُرُوا۟ مَا فِيهِ لَعَلَّكُمْ تَتَّقُونَ","translation":"AND LO! We accepted your solemn pledge, raising Mount Sinai high above you, [and saying;] \"Hold fast with [all your] strength unto what We have vouchsafed you, and bear in mind all that is therein, so that you might remain conscious of God!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/70.mp3","surahId":2,"words":[{"id":56031,"position":1,"arabic":"وَإِذْ","translation":"এবং (স্মরণ করো) যখন","audioUrl":"wbw/002_063_001.mp3","charTypeName":"word"},{"id":56032,"position":2,"arabic":"أَخَذْنَا","translation":"আমরা গ্রহণ করেছিলাম","audioUrl":"wbw/002_063_002.mp3","charTypeName":"word"},{"id":56033,"position":3,"arabic":"مِيثَـٰقَكُمْ","translation":"তোমাদের প্রতিশ্রুতি","audioUrl":"wbw/002_063_003.mp3","charTypeName":"word"},{"id":56034,"position":4,"arabic":"وَرَفَعْنَا","translation":"এবং আমরা উঠিয়ে নিয়েছিলাম","audioUrl":"wbw/002_063_004.mp3","charTypeName":"word"},{"id":56035,"position":5,"arabic":"فَوْقَكُمُ","translation":"তোমাদের উপর","audioUrl":"wbw/002_063_005.mp3","charTypeName":"word"},{"id":56036,"position":6,"arabic":"ٱلطُّورَ","translation":"তুর পাহাড়","audioUrl":"wbw/002_063_006.mp3","charTypeName":"word"},{"id":56037,"position":7,"arabic":"خُذُوا۟","translation":"''(আর বলেছিলাম)তোমরা গ্রহণ করো","audioUrl":"wbw/002_063_007.mp3","charTypeName":"word"},{"id":56038,"position":8,"arabic":"مَآ","translation":"যা","audioUrl":"wbw/002_063_008.mp3","charTypeName":"word"},{"id":56039,"position":9,"arabic":"ءَاتَيْنَـٰكُم","translation":"তোমাদেরকে আমরা দিয়েছি","audioUrl":"wbw/002_063_009.mp3","charTypeName":"word"},{"id":56040,"position":10,"arabic":"بِقُوَّةٍۢ","translation":"শক্তভাবে","audioUrl":"wbw/002_063_010.mp3","charTypeName":"word"},{"id":56041,"position":11,"arabic":"وَٱذْكُرُوا۟","translation":"এবং তোমরা স্মরণ রাখো","audioUrl":"wbw/002_063_011.mp3","charTypeName":"word"},{"id":56042,"position":12,"arabic":"مَا","translation":"(তা)যা","audioUrl":"wbw/002_063_012.mp3","charTypeName":"word"},{"id":56043,"position":13,"arabic":"فِيهِ","translation":"তার মধ্যে(আছে)","audioUrl":"wbw/002_063_013.mp3","charTypeName":"word"},{"id":56044,"position":14,"arabic":"لَعَلَّكُمْ","translation":"তোমরা যাতে","audioUrl":"wbw/002_063_014.mp3","charTypeName":"word"},{"id":56045,"position":15,"arabic":"تَتَّقُونَ","translation":"তাকওয়া অবলম্বন করতে পার''","audioUrl":"wbw/002_063_015.mp3","charTypeName":"word"},{"id":56046,"position":16,"arabic":"٦٣","translation":"(৬৩)","audioUrl":null,"charTypeName":"end"}]},{"number":64,"arabic":"ثُمَّ تَوَلَّيْتُم مِّنۢ بَعْدِ ذَٰلِكَ ۖ فَلَوْلَا فَضْلُ ٱللَّهِ عَلَيْكُمْ وَرَحْمَتُهُۥ لَكُنتُم مِّنَ ٱلْخَٰسِرِينَ","translation":"And you turned away after that-! And had it not been for God's favour upon you and His grace, you would surely have found yourselves among the lost;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/71.mp3","surahId":2,"words":[{"id":56925,"position":1,"arabic":"ثُمَّ","translation":"আবার","audioUrl":"wbw/002_064_001.mp3","charTypeName":"word"},{"id":56926,"position":2,"arabic":"تَوَلَّيْتُم","translation":"তোমরা ফিরে গিয়েছিলে","audioUrl":"wbw/002_064_002.mp3","charTypeName":"word"},{"id":56927,"position":3,"arabic":"مِّنۢ","translation":"(থেকে)","audioUrl":"wbw/002_064_003.mp3","charTypeName":"word"},{"id":56928,"position":4,"arabic":"بَعْدِ","translation":"পর থেকে","audioUrl":"wbw/002_064_004.mp3","charTypeName":"word"},{"id":56929,"position":5,"arabic":"ذَٰلِكَ ۖ","translation":"এর","audioUrl":"wbw/002_064_005.mp3","charTypeName":"word"},{"id":56931,"position":6,"arabic":"فَلَوْلَا","translation":"যদি তাই না (হতো)","audioUrl":"wbw/002_064_007.mp3","charTypeName":"word"},{"id":56932,"position":7,"arabic":"فَضْلُ","translation":"অনুগ্রহ","audioUrl":"wbw/002_064_008.mp3","charTypeName":"word"},{"id":56933,"position":8,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌র","audioUrl":"wbw/002_064_009.mp3","charTypeName":"word"},{"id":56934,"position":9,"arabic":"عَلَيْكُمْ","translation":"তোমাদের উপর","audioUrl":"wbw/002_064_010.mp3","charTypeName":"word"},{"id":56935,"position":10,"arabic":"وَرَحْمَتُهُۥ","translation":"ও তার দয়া","audioUrl":"wbw/002_064_011.mp3","charTypeName":"word"},{"id":56936,"position":11,"arabic":"لَكُنتُم","translation":"তোমরা অবশ্যই হতে","audioUrl":"wbw/002_064_012.mp3","charTypeName":"word"},{"id":56937,"position":12,"arabic":"مِّنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/002_064_013.mp3","charTypeName":"word"},{"id":56938,"position":13,"arabic":"ٱلْخَـٰسِرِينَ","translation":"ক্ষতিগ্রস্তদের","audioUrl":"wbw/002_064_014.mp3","charTypeName":"word"},{"id":56939,"position":14,"arabic":"٦٤","translation":"(৬৪)","audioUrl":null,"charTypeName":"end"}]},{"number":65,"arabic":"وَلَقَدْ عَلِمْتُمُ ٱلَّذِينَ ٱعْتَدَوْا۟ مِنكُمْ فِى ٱلسَّبْتِ فَقُلْنَا لَهُمْ كُونُوا۟ قِرَدَةً خَٰسِـِٔينَ","translation":"for you are well aware of those from among you who profaned the Sabbath, whereupon We said unto them, \"Be as apes despicable!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/72.mp3","surahId":2,"words":[{"id":57071,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/002_065_001.mp3","charTypeName":"word"},{"id":57072,"position":2,"arabic":"عَلِمْتُمُ","translation":"তোমরা জেনেছো","audioUrl":"wbw/002_065_002.mp3","charTypeName":"word"},{"id":57073,"position":3,"arabic":"ٱلَّذِينَ","translation":"তাদেরকে যারা","audioUrl":"wbw/002_065_003.mp3","charTypeName":"word"},{"id":57074,"position":4,"arabic":"ٱعْتَدَوْا۟","translation":"সীমালঙ্ঘন করেছিল","audioUrl":"wbw/002_065_004.mp3","charTypeName":"word"},{"id":57075,"position":5,"arabic":"مِنكُمْ","translation":"তোমাদের মধ্য হতে","audioUrl":"wbw/002_065_005.mp3","charTypeName":"word"},{"id":57076,"position":6,"arabic":"فِى","translation":"সম্পর্কে","audioUrl":"wbw/002_065_006.mp3","charTypeName":"word"},{"id":57077,"position":7,"arabic":"ٱلسَّبْتِ","translation":"শনিবারের (বিধান)","audioUrl":"wbw/002_065_007.mp3","charTypeName":"word"},{"id":570