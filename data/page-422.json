{"id":422,"ayahs":[{"number":31,"arabic":"۞ وَمَن يَقْنُتْ مِنكُنَّ لِلَّهِ وَرَسُولِهِۦ وَتَعْمَلْ صَٰلِحًۭا نُّؤْتِهَآ أَجْرَهَا مَرَّتَيْنِ وَأَعْتَدْنَا لَهَا رِزْقًۭا كَرِيمًۭا","translation":"But if any of you devoutly obeys God and His Apostle and does good deeds, on her shall We bestow her reward twice-over: for We shall have readied for her a most excellent sustenance [in the life to come].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3564.mp3","surahId":33,"words":[{"id":34070,"position":1,"arabic":"۞ وَمَن","translation":"এবং যে","audioUrl":"wbw/033_031_002.mp3","charTypeName":"word"},{"id":34071,"position":2,"arabic":"يَقْنُتْ","translation":"অনুগত হবে","audioUrl":"wbw/033_031_003.mp3","charTypeName":"word"},{"id":34072,"position":3,"arabic":"مِنكُنَّ","translation":"মধ্য হ'তে তোমাদের","audioUrl":"wbw/033_031_004.mp3","charTypeName":"word"},{"id":34073,"position":4,"arabic":"لِلَّهِ","translation":"প্রতি আল্লাহরই","audioUrl":"wbw/033_031_005.mp3","charTypeName":"word"},{"id":34074,"position":5,"arabic":"وَرَسُولِهِۦ","translation":"ও রাসূলের তাঁর","audioUrl":"wbw/033_031_006.mp3","charTypeName":"word"},{"id":34075,"position":6,"arabic":"وَتَعْمَلْ","translation":"ও কাজ করবে","audioUrl":"wbw/033_031_007.mp3","charTypeName":"word"},{"id":34076,"position":7,"arabic":"صَـٰلِحًۭا","translation":"সৎ","audioUrl":"wbw/033_031_008.mp3","charTypeName":"word"},{"id":34077,"position":8,"arabic":"نُّؤْتِهَآ","translation":"আমরা দিবো তাকে","audioUrl":"wbw/033_031_009.mp3","charTypeName":"word"},{"id":34078,"position":9,"arabic":"أَجْرَهَا","translation":"পুরস্কার তার","audioUrl":"wbw/033_031_010.mp3","charTypeName":"word"},{"id":34079,"position":10,"arabic":"مَرَّتَيْنِ","translation":"দু’বার","audioUrl":"wbw/033_031_011.mp3","charTypeName":"word"},{"id":34080,"position":11,"arabic":"وَأَعْتَدْنَا","translation":"এবং প্রস্তুত করে রেখেছি আমরা","audioUrl":"wbw/033_031_012.mp3","charTypeName":"word"},{"id":34081,"position":12,"arabic":"لَهَا","translation":"জন্যে তার","audioUrl":"wbw/033_031_013.mp3","charTypeName":"word"},{"id":34082,"position":13,"arabic":"رِزْقًۭا","translation":"জীবিকা","audioUrl":"wbw/033_031_014.mp3","charTypeName":"word"},{"id":34083,"position":14,"arabic":"كَرِيمًۭا","translation":"সম্মানজনক","audioUrl":"wbw/033_031_015.mp3","charTypeName":"word"},{"id":34084,"position":15,"arabic":"٣١","translation":"(৩১)","audioUrl":null,"charTypeName":"end"}]},{"number":32,"arabic":"يَٰنِسَآءَ ٱلنَّبِىِّ لَسْتُنَّ كَأَحَدٍۢ مِّنَ ٱلنِّسَآءِ ۚ إِنِ ٱتَّقَيْتُنَّ فَلَا تَخْضَعْنَ بِٱلْقَوْلِ فَيَطْمَعَ ٱلَّذِى فِى قَلْبِهِۦ مَرَضٌۭ وَقُلْنَ قَوْلًۭا مَّعْرُوفًۭا","translation":"O wives of the Prophet! You are not like any of the [other] women, provided that you remain [truly] conscious of God. Hence, be not over-soft in your speech, lest any whose heart is diseased should be moved to desire [you]: but, withal, speak in a kindly way.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3565.mp3","surahId":33,"words":[{"id":34996,"position":1,"arabic":"يَـٰنِسَآءَ","translation":"হে স্ত্রীগণ","audioUrl":"wbw/033_032_001.mp3","charTypeName":"word"},{"id":34997,"position":2,"arabic":"ٱلنَّبِىِّ","translation":"নাবীর","audioUrl":"wbw/033_032_002.mp3","charTypeName":"word"},{"id":34998,"position":3,"arabic":"لَسْتُنَّ","translation":"তোমরা নও","audioUrl":"wbw/033_032_003.mp3","charTypeName":"word"},{"id":34999,"position":4,"arabic":"كَأَحَدٍۢ","translation":"মতো একজনের","audioUrl":"wbw/033_032_004.mp3","charTypeName":"word"},{"id":35000,"position":5,"arabic":"مِّنَ","translation":"অন্য কোনো","audioUrl":"wbw/033_032_005.mp3","charTypeName":"word"},{"id":35001,"position":6,"arabic":"ٱلنِّسَآءِ ۚ","translation":"নারীদের","audioUrl":"wbw/033_032_006.mp3","charTypeName":"word"},{"id":35003,"position":7,"arabic":"إِنِ","translation":"যদি","audioUrl":"wbw/033_032_008.mp3","charTypeName":"word"},{"id":35004,"position":8,"arabic":"ٱتَّقَيْتُنَّ","translation":"তোমরা ভয় করো","audioUrl":"wbw/033_032_009.mp3","charTypeName":"word"},{"id":35005,"position":9,"arabic":"فَلَا","translation":"তবে না","audioUrl":"wbw/033_032_010.mp3","charTypeName":"word"},{"id":35006,"position":10,"arabic":"تَخْضَعْنَ","translation":"কোমল করো","audioUrl":"wbw/033_032_011.mp3","charTypeName":"word"},{"id":35007,"position":11,"arabic":"بِٱلْقَوْلِ","translation":"(অন্য পুরুষদের সাথে) কথাকে","audioUrl":"wbw/033_032_012.mp3","charTypeName":"word"},{"id":35008,"position":12,"arabic":"فَيَطْمَعَ","translation":"ফলে প্রলুদ্ধ হয়","audioUrl":"wbw/033_032_013.mp3","charTypeName":"word"},{"id":35009,"position":13,"arabic":"ٱلَّذِى","translation":"(সে) যার","audioUrl":"wbw/033_032_014.mp3","charTypeName":"word"},{"id":35010,"position":14,"arabic":"فِى","translation":"আছে","audioUrl":"wbw/033_032_015.mp3","charTypeName":"word"},{"id":35011,"position":15,"arabic":"قَلْبِهِۦ","translation":"অন্তরে তার","audioUrl":"wbw/033_032_016.mp3","charTypeName":"word"},{"id":35012,"position":16,"arabic":"مَرَضٌۭ","translation":"রোগ","audioUrl":"wbw/033_032_017.mp3","charTypeName":"word"},{"id":35013,"position":17,"arabic":"وَقُلْنَ","translation":"বরং তোমরা বলো","audioUrl":"wbw/033_032_018.mp3","charTypeName":"word"},{"id":35014,"position":18,"arabic":"قَوْلًۭا","translation":"কথা","audioUrl":"wbw/033_032_019.mp3","charTypeName":"word"},{"id":35015,"position":19,"arabic":"مَّعْرُوفًۭا","translation":"সঙ্গতভাবে","audioUrl":"wbw/033_032_020.mp3","charTypeName":"word"},{"id":35016,"position":20,"arabic":"٣٢","translation":"(৩২)","audioUrl":null,"charTypeName":"end"}]},{"number":33,"arabic":"وَقَرْنَ فِى بُيُوتِكُنَّ وَلَا تَبَرَّجْنَ تَبَرُّجَ ٱلْجَٰهِلِيَّةِ ٱلْأُولَىٰ ۖ وَأَقِمْنَ ٱلصَّلَوٰةَ وَءَاتِينَ ٱلزَّكَوٰةَ وَأَطِعْنَ ٱللَّهَ وَرَسُولَهُۥٓ ۚ إِنَّمَا يُرِيدُ ٱللَّهُ لِيُذْهِبَ عَنكُمُ ٱلرِّجْسَ أَهْلَ ٱلْبَيْتِ وَيُطَهِّرَكُمْ تَطْهِيرًۭا","translation":"And abide quietly in your homes, and do not flaunt your charms as they used to flaunt them in the old days of pagan ignorance; and be constant in prayer, and render the purifying dues, and pay heed unto God and His Apostle: for God only wants to remove from you all that might be loathsome, O you members of the [Prophet’s] household, and to purify you to utmost purity.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3566.mp3","surahId":33,"words":[{"id":35869,"position":1,"arabic":"وَقَرْنَ","translation":"এবং তোমরা অবস্থান করো","audioUrl":"wbw/033_033_001.mp3","charTypeName":"word"},{"id":35870,"position":2,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/033_033_002.mp3","charTypeName":"word"},{"id":35871,"position":3,"arabic":"بُيُوتِكُنَّ","translation":"ঘরগুলোর তোমাদের","audioUrl":"wbw/033_033_003.mp3","charTypeName":"word"},{"id":35872,"position":4,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/033_033_004.mp3","charTypeName":"word"},{"id":35873,"position":5,"arabic":"تَبَرَّجْنَ","translation":"তোমরা প্রদর্শন করো","audioUrl":"wbw/033_033_005.mp3","charTypeName":"word"},{"id":35874,"position":6,"arabic":"تَبَرُّجَ","translation":"প্রদর্শনী","audioUrl":"wbw/033_033_006.mp3","charTypeName":"word"},{"id":35875,"position":7,"arabic":"ٱلْجَـٰهِلِيَّةِ","translation":"অজ্ঞযুগের","audioUrl":"wbw/033_033_007.mp3","charTypeName":"word"},{"id":35876,"position":8,"arabic":"ٱلْأُولَىٰ ۖ","translation":"প্রাচীন","audioUrl":"wbw/033_033_008.mp3","charTypeName":"word"},{"id":35878,"position":9,"arabic":"وَأَقِمْنَ","translation":"এবং তোমরা প্রতিষ্ঠিত করো","audioUrl":"wbw/033_033_010.mp3","charTypeName":"word"},{"id":35879,"position":10,"arabic":"ٱلصَّلَوٰةَ","translation":"সালাত","audioUrl":"wbw/033_033_011.mp3","charTypeName":"word"},{"id":35880,"position":11,"arabic":"وَءَاتِينَ","translation":"ও তোমরা আদায় করো","audioUrl":"wbw/033_033_012.mp3","charTypeName":"word"},{"id":35881,"position":12,"arabic":"ٱلزَّكَوٰةَ","translation":"যাকাত","audioUrl":"wbw/033_033_013.mp3","charTypeName":"word"},{"id":35882,"position":13,"arabic":"وَأَطِعْنَ","translation":"এবং তোমরা আনুগত্য করো","audioUrl":"wbw/033_033_014.mp3","charTypeName":"word"},{"id":35883,"position":14,"arabic":"ٱللَّهَ","translation":"আল্লাহর","audioUrl":"wbw/033_033_015.mp3","charTypeName":"word"},{"id":35884,"position":15,"arabic":"وَرَسُولَهُۥٓ ۚ","translation":"ও রাসূলের তাঁর","audioUrl":"wbw/033_033_016.mp3","charTypeName":"word"},{"id":35886,"position":16,"arabic":"إِنَّمَا","translation":"কেবল","audioUrl":"wbw/033_033_018.mp3","charTypeName":"word"},{"id":35887,"position":17,"arabic":"يُرِيدُ","translation":"চান","audioUrl":"wbw/033_033_019.mp3","charTypeName":"word"},{"id":35888,"position":18,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌","audioUrl":"wbw/033_033_020.mp3","charTypeName":"word"},{"id":35889,"position":19,"arabic":"لِيُذْهِبَ","translation":"যাতে দূর করে দেন","audioUrl":"wbw/033_033_021.mp3","charTypeName":"word"},{"id":35890,"position":20,"arabic":"عَنكُمُ","translation":"হ'তে তোমাদের","audioUrl":"wbw/033_033_022.mp3","charTypeName":"word"},{"id":35891,"position":21,"arabic":"ٱلرِّجْسَ","translation":"অপবিত্রতা","audioUrl":"wbw/033_033_023.mp3","charTypeName":"word"},{"id":35892,"position":22,"arabic":"أَهْلَ","translation":"(অর্থাৎ হ'তে) বাসিন্দাদের","audioUrl":"wbw/033_033_024.mp3","charTypeName":"word"},{"id":35893,"position":23,"arabic":"ٱلْبَيْتِ","translation":"(নাবীর) ঘরের","audioUrl":"wbw/033_033_025.mp3","charTypeName":"word"},{"id":35894,"position":24,"arabic":"وَيُطَهِّرَكُمْ","translation":"এবং পবিত্র করবেন তোমাদেরকে","audioUrl":"wbw/033_033_026.mp3","charTypeName":"word"},{"id":35895,"position":25,"arabic":"تَطْهِيرًۭا","translation":"সম্পূর্ণ পবিত্র","audioUrl":"wbw/033_033_027.mp3","charTypeName":"word"},{"id":35896,"position":26,"arabic":"٣٣","translation":"(৩৩)","audioUrl":null,"charTypeName":"end"}]},{"number":34,"arabic":"وَٱذْكُرْنَ مَا يُتْلَىٰ فِى بُيُوتِكُنَّ مِنْ ءَايَٰتِ ٱللَّهِ وَٱلْحِكْمَةِ ۚ إِنَّ ٱللَّهَ كَانَ لَطِيفًا خَبِيرًا","translation":"And bear in mind all that is recited in your homes of God’s messages and [His] wisdom: for God is unfathomable [in His wisdom], all-aware.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3567.mp3","surahId":33,"words":[{"id":36759,"position":1,"arabic":"وَٱذْكُرْنَ","translation":"এবং তোমরা স্মরণ করো","audioUrl":"wbw/033_034_001.mp3","charTypeName":"word"},{"id":36760,"position":2,"arabic":"مَا","translation":"যা","audioUrl":"wbw/033_034_002.mp3","charTypeName":"word"},{"id":36761,"position":3,"arabic":"يُتْلَىٰ","translation":"তিলাওয়াত করা হয়","audioUrl":"wbw/033_034_003.mp3","charTypeName":"word"},{"id":36762,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/033_034_004.mp3","charTypeName":"word"},{"id":36763,"position":5,"arabic":"بُيُوتِكُنَّ","translation":"তোমাদের ঘরগুলোর","audioUrl":"wbw/033_034_005.mp3","charTypeName":"word"},{"id":36764,"position":6,"arabic":"مِنْ","translation":"থেকে","audioUrl":"wbw/033_034_006.mp3","charTypeName":"word"},{"id":36765,"position":7,"arabic":"ءَايَـٰتِ","translation":"আয়াতসমূহ","audioUrl":"wbw/033_034_007.mp3","charTypeName":"word"},{"id":36766,"position":8,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/033_034_008.mp3","charTypeName":"word"},{"id":36767,"position":9,"arabic":"وَٱلْحِكْمَةِ ۚ","translation":"ও প্রজ্ঞার কথা","audioUrl":"wbw/033_034_009.mp3","charTypeName":"word"},{"id":36769,"position":10,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/033_034_011.mp3","charTypeName":"word"},{"id":36770,"position":11,"arabic":"ٱللَّهَ","translation":"আল্লাহ্‌","audioUrl":"wbw/033_034_012.mp3","charTypeName":"word"},{"id":36771,"position":12,"arabic":"كَانَ","translation":"হলেন","audioUrl":"wbw/033_034_013.mp3","charTypeName":"word"},{"id":36772,"position":13,"arabic":"لَطِيفًا","translation":"সূক্ষ্মদর্শী","audioUrl":"wbw/033_034_014.mp3","charTypeName":"word"},{"id":36773,"position":14,"arabic":"خَبِيرًا","translation":"খুব অবহিত","audioUrl":"wbw/033_034_015.mp3","charTypeName":"word"},{"id":36774,"position":15,"arabic":"٣٤","translation":"(৩৪)","audioUrl":null,"charTypeName":"end"}]},{"number":35,"arabic":"إِنَّ ٱلْمُسْلِمِينَ وَٱلْمُسْلِمَٰتِ وَٱلْمُؤْمِنِينَ وَٱلْمُؤْمِنَٰتِ وَٱلْقَٰنِتِينَ وَٱلْقَٰنِتَٰتِ وَٱلصَّٰدِقِينَ وَٱلصَّٰدِقَٰتِ وَٱلصَّٰبِرِينَ وَٱلصَّٰبِرَٰتِ وَٱلْخَٰشِعِينَ وَٱلْخَٰشِعَٰتِ وَٱلْمُتَصَدِّقِينَ وَٱلْمُتَصَدِّقَٰتِ وَٱلصَّٰٓئِمِينَ وَٱلصَّٰٓئِمَٰتِ وَٱلْحَٰفِظِينَ فُرُوجَهُمْ وَٱلْحَٰفِظَٰتِ وَٱلذَّٰكِرِينَ ٱللَّهَ كَثِيرًۭا وَٱلذَّٰكِرَٰتِ أَعَدَّ ٱللَّهُ لَهُم مَّغْفِرَةًۭ وَأَجْرًا عَظِيمًۭا","translation":"VERILY, for all men and women who have sur­rendered themselves unto God, and all believing men and believing women, and all truly devout men and truly devout women, and all men and women who are true to their word, and all men and women who are patient in adversity, and all men and women who humble themselves [before God], and all men and women who give in charity, and all self-denying men and self-denying women, and all men and women who are mindful of their chastity, and all men and women who remember God unceasingly: for [all of] them has God readied forgiveness of sins and a mighty reward.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3568.mp3","surahId":33,"words":[{"id":37572,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/033_035_001.mp3","charTypeName":"word"},{"id":37573,"position":2,"arabic":"ٱلْمُسْلِمِينَ","translation":"মুসলমান পুরুষগণ","audioUrl":"wbw/033_035_002.mp3","charTypeName":"word"},{"id":37574,"position":3,"arabic":"وَٱلْمُسْلِمَـٰتِ","translation":"ও মুসলমান নারীগণ","audioUrl":"wbw/033_035_003.mp3","charTypeName":"word"},{"id":37575,"position":4,"arabic":"وَٱلْمُؤْمِنِينَ","translation":"এবং মু’মিন পুরুষগণ","audioUrl":"wbw/033_035_004.mp3","charTypeName":"word"},{"id":37576,"position":5,"arabic":"وَٱلْمُؤْمِنَـٰتِ","translation":"ও মুু’মিনা নারীগণ","audioUrl":"wbw/033_035_005.mp3","charTypeName":"word"},{"id":37577,"position":6,"arabic":"وَٱلْقَـٰنِتِينَ","translation":"এবং অনুগত পুরুষগণ","audioUrl":"wbw/033_035_006.mp3","charTypeName":"word"}