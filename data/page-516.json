{"id":516,"ayahs":[{"number":5,"arabic":"وَلَوْ أَنَّهُمْ صَبَرُوا۟ حَتَّىٰ تَخْرُجَ إِلَيْهِمْ لَكَانَ خَيْرًۭا لَّهُمْ ۚ وَٱللَّهُ غَفُورٌۭ رَّحِيمٌۭ","translation":"for, if they had the patience [to wait] until thou come forth to them [of thine own accord], it would be for their own good. Still, God is much forgiving, a dispenser of grace.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4617.mp3","surahId":49,"words":[{"id":4840,"position":1,"arabic":"وَلَوْ","translation":"এবং যদি (এমন হতো)","audioUrl":"wbw/049_005_001.mp3","charTypeName":"word"},{"id":4841,"position":2,"arabic":"أَنَّهُمْ","translation":"যে তারা","audioUrl":"wbw/049_005_002.mp3","charTypeName":"word"},{"id":4842,"position":3,"arabic":"صَبَرُوا۟","translation":"ধৈর্য ধরত","audioUrl":"wbw/049_005_003.mp3","charTypeName":"word"},{"id":4843,"position":4,"arabic":"حَتَّىٰ","translation":"যতক্ষণ না","audioUrl":"wbw/049_005_004.mp3","charTypeName":"word"},{"id":4844,"position":5,"arabic":"تَخْرُجَ","translation":"তুমি বের হতে","audioUrl":"wbw/049_005_005.mp3","charTypeName":"word"},{"id":4845,"position":6,"arabic":"إِلَيْهِمْ","translation":"তাদের দিকে","audioUrl":"wbw/049_005_006.mp3","charTypeName":"word"},{"id":4846,"position":7,"arabic":"لَكَانَ","translation":"হতো অবশ্যই","audioUrl":"wbw/049_005_007.mp3","charTypeName":"word"},{"id":4847,"position":8,"arabic":"خَيْرًۭا","translation":"উত্তম","audioUrl":"wbw/049_005_008.mp3","charTypeName":"word"},{"id":4848,"position":9,"arabic":"لَّهُمْ ۚ","translation":"তাদের জন্যে","audioUrl":"wbw/049_005_009.mp3","charTypeName":"word"},{"id":4850,"position":10,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ্","audioUrl":"wbw/049_005_011.mp3","charTypeName":"word"},{"id":4851,"position":11,"arabic":"غَفُورٌۭ","translation":"ক্ষমাশীল","audioUrl":"wbw/049_005_012.mp3","charTypeName":"word"},{"id":4852,"position":12,"arabic":"رَّحِيمٌۭ","translation":"পরম দয়ালু","audioUrl":"wbw/049_005_013.mp3","charTypeName":"word"},{"id":4853,"position":13,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوٓا۟ إِن جَآءَكُمْ فَاسِقٌۢ بِنَبَإٍۢ فَتَبَيَّنُوٓا۟ أَن تُصِيبُوا۟ قَوْمًۢا بِجَهَٰلَةٍۢ فَتُصْبِحُوا۟ عَلَىٰ مَا فَعَلْتُمْ نَٰدِمِينَ","translation":"O YOU who have attained to faith! If any iniquitous person comes to you with a [slanderous] tale, use your discernment, lest you hurt people unwittingly and afterwards be filled with remorse for what you have done.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4618.mp3","surahId":49,"words":[{"id":6077,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/049_006_001.mp3","charTypeName":"word"},{"id":6078,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/049_006_002.mp3","charTypeName":"word"},{"id":6079,"position":3,"arabic":"ءَامَنُوٓا۟","translation":"ঈমান এনেছ","audioUrl":"wbw/049_006_003.mp3","charTypeName":"word"},{"id":6080,"position":4,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/049_006_004.mp3","charTypeName":"word"},{"id":6081,"position":5,"arabic":"جَآءَكُمْ","translation":"তোমাদের কাছে আসে","audioUrl":"wbw/049_006_005.mp3","charTypeName":"word"},{"id":6082,"position":6,"arabic":"فَاسِقٌۢ","translation":"কোনো সত্যত্যাগী","audioUrl":"wbw/049_006_006.mp3","charTypeName":"word"},{"id":6083,"position":7,"arabic":"بِنَبَإٍۢ","translation":"কোনো খবর নিয়ে","audioUrl":"wbw/049_006_007.mp3","charTypeName":"word"},{"id":6084,"position":8,"arabic":"فَتَبَيَّنُوٓا۟","translation":"তোমরা তখন পরীক্ষা করো","audioUrl":"wbw/049_006_008.mp3","charTypeName":"word"},{"id":6085,"position":9,"arabic":"أَن","translation":"(এমন না হয়) যে","audioUrl":"wbw/049_006_009.mp3","charTypeName":"word"},{"id":6086,"position":10,"arabic":"تُصِيبُوا۟","translation":"তোমরা ক্ষতি করে বস","audioUrl":"wbw/049_006_010.mp3","charTypeName":"word"},{"id":6087,"position":11,"arabic":"قَوْمًۢا","translation":"সম্প্রদায়কে","audioUrl":"wbw/049_006_011.mp3","charTypeName":"word"},{"id":6088,"position":12,"arabic":"بِجَهَـٰلَةٍۢ","translation":"অজ্ঞতার কারণে","audioUrl":"wbw/049_006_012.mp3","charTypeName":"word"},{"id":6089,"position":13,"arabic":"فَتُصْبِحُوا۟","translation":"তাহলে","audioUrl":"wbw/049_006_013.mp3","charTypeName":"word"},{"id":6090,"position":14,"arabic":"عَلَىٰ","translation":"জন্য","audioUrl":"wbw/049_006_014.mp3","charTypeName":"word"},{"id":6091,"position":15,"arabic":"مَا","translation":"যা","audioUrl":"wbw/049_006_015.mp3","charTypeName":"word"},{"id":6092,"position":16,"arabic":"فَعَلْتُمْ","translation":"তোমরা করেছ","audioUrl":"wbw/049_006_016.mp3","charTypeName":"word"},{"id":6093,"position":17,"arabic":"نَـٰدِمِينَ","translation":"অনুতাপকারী/ লজ্জিত","audioUrl":"wbw/049_006_017.mp3","charTypeName":"word"},{"id":6094,"position":18,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"وَٱعْلَمُوٓا۟ أَنَّ فِيكُمْ رَسُولَ ٱللَّهِ ۚ لَوْ يُطِيعُكُمْ فِى كَثِيرٍۢ مِّنَ ٱلْأَمْرِ لَعَنِتُّمْ وَلَٰكِنَّ ٱللَّهَ حَبَّبَ إِلَيْكُمُ ٱلْإِيمَٰنَ وَزَيَّنَهُۥ فِى قُلُوبِكُمْ وَكَرَّهَ إِلَيْكُمُ ٱلْكُفْرَ وَٱلْفُسُوقَ وَٱلْعِصْيَانَ ۚ أُو۟لَٰٓئِكَ هُمُ ٱلرَّٰشِدُونَ","translation":"And know that God’s Apostle is among you: were he to comply with your inclinations in each and every case, you would be bound to come to harm [as a community]. But as it is, God has caused [your] faith to be dear to you, and has given it beauty in your hearts, and has made hateful to you all denial of the truth, and all iniquity, and all rebellion [against what is good]. Such indeed are they who follow the right course","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4619.mp3","surahId":49,"words":[{"id":7393,"position":1,"arabic":"وَٱعْلَمُوٓا۟","translation":"এবং তোমরা জেনে রাখ","audioUrl":"wbw/049_007_001.mp3","charTypeName":"word"},{"id":7394,"position":2,"arabic":"أَنَّ","translation":"যে","audioUrl":"wbw/049_007_002.mp3","charTypeName":"word"},{"id":7395,"position":3,"arabic":"فِيكُمْ","translation":"তোমাদের মধ্যে (আছে)","audioUrl":"wbw/049_007_003.mp3","charTypeName":"word"},{"id":7396,"position":4,"arabic":"رَسُولَ","translation":"রাসুল","audioUrl":"wbw/049_007_004.mp3","charTypeName":"word"},{"id":7397,"position":5,"arabic":"ٱللَّهِ ۚ","translation":"আল্লাহর","audioUrl":"wbw/049_007_005.mp3","charTypeName":"word"},{"id":7399,"position":6,"arabic":"لَوْ","translation":"যদি","audioUrl":"wbw/049_007_007.mp3","charTypeName":"word"},{"id":7400,"position":7,"arabic":"يُطِيعُكُمْ","translation":"তোমাদের মেনে নেয় সে","audioUrl":"wbw/049_007_008.mp3","charTypeName":"word"},{"id":7401,"position":8,"arabic":"فِى","translation":"ভাগ","audioUrl":"wbw/049_007_009.mp3","charTypeName":"word"},{"id":7402,"position":9,"arabic":"كَثِيرٍۢ","translation":"বেশির","audioUrl":"wbw/049_007_010.mp3","charTypeName":"word"},{"id":7403,"position":10,"arabic":"مِّنَ","translation":"থেকে","audioUrl":"wbw/049_007_011.mp3","charTypeName":"word"},{"id":7404,"position":11,"arabic":"ٱلْأَمْرِ","translation":"ব্যাপারে","audioUrl":"wbw/049_007_012.mp3","charTypeName":"word"},{"id":7405,"position":12,"arabic":"لَعَنِتُّمْ","translation":"তোমরা অবশ্যই কষ্ট পাবে","audioUrl":"wbw/049_007_013.mp3","charTypeName":"word"},{"id":7406,"position":13,"arabic":"وَلَـٰكِنَّ","translation":"কিন্তু","audioUrl":"wbw/049_007_014.mp3","charTypeName":"word"},{"id":7407,"position":14,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/049_007_015.mp3","charTypeName":"word"},{"id":7408,"position":15,"arabic":"حَبَّبَ","translation":"প্রিয় করেছেন","audioUrl":"wbw/049_007_016.mp3","charTypeName":"word"},{"id":7409,"position":16,"arabic":"إِلَيْكُمُ","translation":"তোমাদের কাছে","audioUrl":"wbw/049_007_017.mp3","charTypeName":"word"},{"id":7410,"position":17,"arabic":"ٱلْإِيمَـٰنَ","translation":"ঈমানকে","audioUrl":"wbw/049_007_018.mp3","charTypeName":"word"},{"id":7411,"position":18,"arabic":"وَزَيَّنَهُۥ","translation":"এবং তা শোভন করে দিয়েছেন","audioUrl":"wbw/049_007_019.mp3","charTypeName":"word"},{"id":7412,"position":19,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/049_007_020.mp3","charTypeName":"word"},{"id":7413,"position":20,"arabic":"قُلُوبِكُمْ","translation":"তোমাদের অন্তরের","audioUrl":"wbw/049_007_021.mp3","charTypeName":"word"},{"id":7414,"position":21,"arabic":"وَكَرَّهَ","translation":"এবং অপ্রিয় করে দিয়েছেন","audioUrl":"wbw/049_007_022.mp3","charTypeName":"word"},{"id":7415,"position":22,"arabic":"إِلَيْكُمُ","translation":"তোমাদের কাছে","audioUrl":"wbw/049_007_023.mp3","charTypeName":"word"},{"id":7416,"position":23,"arabic":"ٱلْكُفْرَ","translation":"কুফরী/ অবিশ্বাস","audioUrl":"wbw/049_007_024.mp3","charTypeName":"word"},{"id":7417,"position":24,"arabic":"وَٱلْفُسُوقَ","translation":"ও সত্যত্যাগ","audioUrl":"wbw/049_007_025.mp3","charTypeName":"word"},{"id":7418,"position":25,"arabic":"وَٱلْعِصْيَانَ ۚ","translation":"এবং অবাধ্যতা (প্রতি)","audioUrl":"wbw/049_007_026.mp3","charTypeName":"word"},{"id":7420,"position":26,"arabic":"أُو۟لَـٰٓئِكَ","translation":"এসব লোক","audioUrl":"wbw/049_007_028.mp3","charTypeName":"word"},{"id":7421,"position":27,"arabic":"هُمُ","translation":"তারাই","audioUrl":"wbw/049_007_029.mp3","charTypeName":"word"},{"id":7422,"position":28,"arabic":"ٱلرَّٰشِدُونَ","translation":"সঠিক পথগামী","audioUrl":"wbw/049_007_030.mp3","charTypeName":"word"},{"id":7423,"position":29,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"فَضْلًۭا مِّنَ ٱللَّهِ وَنِعْمَةًۭ ۚ وَٱللَّهُ عَلِيمٌ حَكِيمٌۭ","translation":"through God’s bounty and favour; and God is all-knowing, truly wise.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4620.mp3","surahId":49,"words":[{"id":8684,"position":1,"arabic":"فَضْلًۭا","translation":"অনুগ্রহে","audioUrl":"wbw/049_008_001.mp3","charTypeName":"word"},{"id":8685,"position":2,"arabic":"مِّنَ","translation":"পক্ষ হতে","audioUrl":"wbw/049_008_002.mp3","charTypeName":"word"},{"id":8686,"position":3,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/049_008_003.mp3","charTypeName":"word"},{"id":8687,"position":4,"arabic":"وَنِعْمَةًۭ ۚ","translation":"ও (তাঁর) অনুগ্রহ","audioUrl":"wbw/049_008_004.mp3","charTypeName":"word"},{"id":8689,"position":5,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/049_008_006.mp3","charTypeName":"word"},{"id":8690,"position":6,"arabic":"عَلِيمٌ","translation":"সবকিছু জানেন","audioUrl":"wbw/049_008_007.mp3","charTypeName":"word"},{"id":8691,"position":7,"arabic":"حَكِيمٌۭ","translation":"প্রজ্ঞাময়","audioUrl":"wbw/049_008_008.mp3","charTypeName":"word"},{"id":8692,"position":8,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"وَإِن طَآئِفَتَانِ مِنَ ٱلْمُؤْمِنِينَ ٱقْتَتَلُوا۟ فَأَصْلِحُوا۟ بَيْنَهُمَا ۖ فَإِنۢ بَغَتْ إِحْدَىٰهُمَا عَلَى ٱلْأُخْرَىٰ فَقَٰتِلُوا۟ ٱلَّتِى تَبْغِى حَتَّىٰ تَفِىٓءَ إِلَىٰٓ أَمْرِ ٱللَّهِ ۚ فَإِن فَآءَتْ فَأَصْلِحُوا۟ بَيْنَهُمَا بِٱلْعَدْلِ وَأَقْسِطُوٓا۟ ۖ إِنَّ ٱللَّهَ يُحِبُّ ٱلْمُقْسِطِينَ","translation":"Hence, if two groups of believers fall to fighting, make peace between them; but then, if one of the two [groups] goes on acting wrongfully towards the other, fight against the one that acts wrongfully until it reverts to God’s commandment; and if they revert, make peace between them with justice, and deal equitably [with them]: for verily, God loves those who act equitably!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4621.mp3","surahId":49,"words":[{"id":9877,"position":1,"arabic":"وَإِن","translation":"এবং যদি","audioUrl":"wbw/049_009_001.mp3","charTypeName":"word"},{"id":9878,"position":2,"arabic":"طَآئِفَتَانِ","translation":"দুটি দল","audioUrl":"wbw/049_009_002.mp3","charTypeName":"word"},{"id":9879,"position":3,"arabic":"مِنَ","translation":"মধ্য হতে","audioUrl":"wbw/049_009_003.mp3","charTypeName":"word"},{"id":9880,"position":4,"arabic":"ٱلْمُؤْمِنِينَ","translation":"মু'মিনদের","audioUrl":"wbw/049_009_004.mp3","charTypeName":"word"},{"id":9881,"position":5,"arabic":"ٱقْتَتَلُوا۟","translation":"পরস্পরে যুদ্ধে লিপ্ত হয়","audioUrl":"wbw/049_009_005.mp3","charTypeName":"word"},{"id":9882,"position":6,"arabic":"فَأَصْلِحُوا۟","translation":"তবে তোমরা  মীমাংসা করে দাও","audioUrl":"wbw/049_009_006.mp3","charTypeName":"word"},{"id":9883,"position":7,"arabic":"بَيْنَهُمَا ۖ","translation":"তাদের উভয়ের মাঝে","audioUrl":"wbw/049_009_007.mp3","charTypeName":"word"},{"id":9885,"position":8,"arabic":"فَإِنۢ","translation":"যদি অতঃপর","audioUrl":"wbw/049_009_009.mp3","charTypeName":"word"},{"id":9886,"position":9,"arabic":"بَغَتْ","translation":"সীমালংঘন করে","audioUrl":"wbw/049_009_010.mp3","charTypeName":"word"},{"id":9887,"position":10,"arabic":"إِحْدَىٰهُمَا","translation":"তাদের একদল","audioUrl":"wbw/049_009_011.mp3","charTypeName":"word"},{"id":9888,"position":11,"arabic":"عَلَى","translation":"বিরুদ্ধে","audioUrl":"wbw/049_009_012.mp3","charTypeName":"word"},{"id":9889,"position":12,"arabic":"ٱلْأُخْرَىٰ","translation":"অন্যের","audioUrl":"wbw/049_009_013.mp3","charTypeName":"word"},{"id":9890,"position":13,"arabic":"فَقَـٰتِلُوا۟","translation":"তবে তোমরা  যুদ্ধ করো","audioUrl":"wbw/049_009_014.mp3","charTypeName":"word"},{"id":9891,"position":14,"arabic":"ٱلَّتِى","translation":"(তার বিরুদ্ধে) যে","audioUrl":"wbw/049_009_015.mp3","charTypeName":"word"},{"id":9892,"position":15,"arabic":"تَبْغِى","translation":"সীমালংঘন করে","audioUrl":"wbw/049_009_016.mp3","charTypeName":"word"},{"id":9893,"position":16,"arabic":"حَتَّىٰ","translation":"যতক্ষণ না","audioUrl":"wbw/049_009_017.mp3","charTypeName":"word"},{"id":9894,"position":17,"arabic":"تَفِىٓءَ","translation":"ফিরে আসে","audioUrl":"wbw/049_009_018.mp3","charTypeName":"word"},{"id":9895,"position":18,"arabic":"إِلَىٰٓ","translation":"দিকে","audioUrl":"wbw/049_009_019.mp3","charTypeName":"word"},{"id":9896,"position":19,"arabic":"أَمْرِ","translation":"নির্দেশের","audioUrl":"wbw/049_009_020.mp3","charTypeName":"word"},{"id":9897,"position":20,"arabic":"ٱللَّهِ ۚ","translation":"আল্লাহর","audioUrl":"wbw/049_009_021.mp3","charTypeName":"word"},{"id":9899,"position":21,"arabic":"فَإِن","translation":"যদি অতঃপর","audioUrl":"wbw/049_009_023.mp3","charTypeName":"word"},{"id":9900,"position":22,"arabic":"فَآءَتْ","translation":"ফিরে আসে","audioUrl":"wbw/049_009_024.mp3","charTypeName":"word"},{"id":9901,"position":23,"arabic":"فَأَصْلِحُوا۟","translation":"তবে তোমরা মীমাংসা করে দাও","audioUrl":"wbw/049_009_025.mp3","charTypeName":"word"},{"id":9902,"position":24,"arabic":"بَيْنَهُمَا","translation":"তাদের উভয়ের মাঝে","audioUrl":"wbw/049_009_026.mp3","charTypeName":"word"},{"id":9903,"position":25,"arabic":"بِٱلْعَدْلِ","translation":"ন্যায়ানুগভাবে","audioUrl":"wbw/049_009_027.mp3","charTypeName":"word"},{"id":9904,"position":26,"arabic":"وَأَقْسِطُوٓا۟ ۖ","translation":"এবং তোমরা সুবিচার করো","audioUrl":"wbw/049_009_028.mp3","charTypeName":"word"},{"id":9906,"position":27,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/049_009_030.mp3","charTypeName":"word"},{"id":9907,"position":28,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/049_009_031.mp3","charTypeName":"word"},{"id":9908,"position":29,"arabic":"يُحِبُّ","translation":"পছন্দ করেন","audioUrl":"wbw/049_009_032.mp3","charTypeName":"word"},{"id":9909,"position":30,"arabic":"ٱلْمُقْسِطِينَ","translation":"সুবিচারকারীদেরকে","audioUrl":"wbw/049_009_033.mp3","charTypeName":"word"},{"id":9910,"position":31,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"إِنَّمَا ٱلْمُؤْمِنُونَ إِخْوَةٌۭ فَأَصْلِحُوا۟ بَيْنَ أَخَوَيْكُمْ ۚ وَٱتَّقُوا۟ ٱللَّهَ لَعَلَّكُمْ تُرْحَمُونَ","translation":"All believers are but brethren. Hence, [when­ever they are at odds,] make peace between your two brethren, and remain conscious of God, so that you might be graced with His mercy.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4622.mp3","surahId":49,"words":[{"id":11091,"position":1,"arabic":"إِنَّمَا","translation":"প্রকৃতপক্ষে","audioUrl":"wbw/049_010_001.mp3","charTypeName":"word"},{"id":11092,"position":2,"arabic":"ٱلْمُؤْمِنُونَ","translation":"মু'মিনরা","audioUrl":"wbw/049_010_002.mp3","charTypeName":"word"},{"id":11093,"position":3,"arabic":"إِخْوَةٌۭ","translation":"(পরস্পরে) ভাই ভাই","audioUrl":"wbw/049_010_003.mp3","charTypeName":"word"},{"id":11094,"position":4,"arabic":"فَأَصْلِحُوا۟","translation":"অতএব তোমরা  মীমাংসা করে দাও","audioUrl":"wbw/049_010_004.mp3","charTypeName":"word"},{"id":11095,"position":5,"arabic":"بَيْنَ","translation":"মাঝে","audioUrl":"wbw/049_010_005.mp3","charTypeName":"word"},{"id":11096,"position":6,"arabic":"أَخَوَيْكُمْ ۚ","translation":"তোমাদের দুই ভাইয়ের","audioUrl":"wbw/049_010_006.mp3","charTypeName":"word"},{"id":11098,"position":7,"arabic":"وَٱتَّقُوا۟","translation":"এবং তোমরা ভয় করো","audioUrl":"wbw/049_010_008.mp3","charTypeName":"word"},{"id":11099,"position":8,"arabic":"ٱللَّهَ","translation":"আল্লাহকে","audioUrl":"wbw/049_010_009.mp3","charTypeName":"word"},{"id":11100,"position":9,"arabic":"لَعَلَّكُمْ","translation":"তোমাদের উপর সম্ভবতঃ","audioUrl":"wbw/049_010_010.mp3","charTypeName":"word"},{"id":11101,"position":10,"arabic":"تُرْحَمُونَ","translation":"অনুগ্রহ করা হবে","audioUrl":"wbw/049_010_011.mp3","charTypeName":"word"},{"id":11102,"position":11,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ لَا يَسْخَرْ قَوْمٌۭ مِّن قَوْمٍ عَسَىٰٓ أَن يَكُونُوا۟ خَيْرًۭا مِّنْهُمْ وَلَا نِسَآءٌۭ مِّن نِّسَآءٍ عَسَىٰٓ أَن يَكُنَّ خَيْرًۭا مِّنْهُنَّ ۖ وَلَا تَلْمِزُوٓا۟ أَنفُسَكُمْ وَلَا تَنَابَزُوا۟ بِٱلْأَلْقَٰبِ ۖ بِئْسَ ٱلِٱسْمُ ٱلْفُسُوقُ بَعْدَ ٱلْإِيمَٰنِ ۚ وَمَن لَّمْ يَتُبْ فَأُو۟لَٰٓئِكَ هُمُ ٱلظَّٰلِمُونَ","translation":"O YOU who have attained to faith! No men shall deride [other] men: it may well be that those [whom they deride] are better than themselves; and no women [shall deride other] women: it may well be that those [whom they deride] are better than them­selves. And neither shall you defame one another, nor insult one another by [opprobrious] epithets: evil is all imputation of iniquity after [one has attained to] faith; and they who [become guilty thereof and] do not repent - it is they, they who are evildoers!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4623.mp3","surahId":49,"words":[{"id":12383,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/049_011_001.mp3","charTypeName":"word"},{"id":12384,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/049_011_002.mp3","charTypeName":"word"},{"id":12385,"position":3,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছ","audioUrl":"wbw/049_011_003.mp3","charTypeName":"word"},{"id":12386,"position":4,"arabic":"لَا","translation":"না","audioUrl":"wbw/049_011_004.mp3","charTypeName":"word"},{"id":12387,"position":5,"arabic":"يَسْخَرْ","translation":"উপহাস করে (যেন)","audioUrl":"wbw/049_011_005.mp3","charTypeName":"word"},{"id":12388,"position":6,"arabic":"قَوْمٌۭ","translation":"কোনো পুরুষ","audioUrl":"wbw/049_011_006.mp3","charTypeName":"word"},{"id":12389,"position":7,"arabic":"مِّن","translation":"মধ্য থেকে","audioUrl":"wbw/049_011_007.mp3","charTypeName":"word"},{"id":12390,"position":8,"arabic":"قَوْمٍ","translation":"(অন্য) কোনো পুরুষের","audioUrl":"wbw/049_011_008.mp3","charTypeName":"word"},{"id":12391,"position":9,"arabic":"عَسَىٰٓ","translation":"হয়তো (যাদের বিদ্রুপ করা হচ্ছে)","audioUrl":"wbw/049_011_009.mp3","charTypeName":"word"},{"id":12392,"position":10,"arabic":"أَن","translation":"যে","audioUrl":"wbw/049_011_010.mp3","charTypeName":"word"},{"id":12393,"position":11,"arabic":"يَكُونُوا۟","translation":"তারা হবে","audioUrl":"wbw/049_011_011.mp3","charTypeName":"word"},{"id":12394,"position":12,"arabic":"خَيْرًۭا","translation":"উত্তম","audioUrl":"wbw/049_011_012.mp3","charTypeName":"word"},{"id":12395,"position":13,"arabic":"مِّنْهُمْ","translation":"তাদের