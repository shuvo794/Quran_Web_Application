{"id":368,"ayahs":[{"number":20,"arabic":"قَالَ فَعَلْتُهَآ إِذًۭا وَأَنَا۠ مِنَ ٱلضَّآلِّينَ","translation":"Replied [Moses]: “I committed it while I was still going astray;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2952.mp3","surahId":26,"words":[{"id":23215,"position":1,"arabic":"قَالَ","translation":"(মূসা) বললো","audioUrl":"wbw/026_020_001.mp3","charTypeName":"word"},{"id":23216,"position":2,"arabic":"فَعَلْتُهَآ","translation":"\"তা আমি করেছিলাম","audioUrl":"wbw/026_020_002.mp3","charTypeName":"word"},{"id":23217,"position":3,"arabic":"إِذًۭا","translation":"তখন (সে সময়)","audioUrl":"wbw/026_020_003.mp3","charTypeName":"word"},{"id":23218,"position":4,"arabic":"وَأَنَا۠","translation":"যখন আমি (ছিলাম)","audioUrl":"wbw/026_020_004.mp3","charTypeName":"word"},{"id":23219,"position":5,"arabic":"مِنَ","translation":"অন্তর্ভূক্ত","audioUrl":"wbw/026_020_005.mp3","charTypeName":"word"},{"id":23220,"position":6,"arabic":"ٱلضَّآلِّينَ","translation":"পথভ্রষ্টদের","audioUrl":"wbw/026_020_006.mp3","charTypeName":"word"},{"id":23221,"position":7,"arabic":"٢٠","translation":"(২০)","audioUrl":null,"charTypeName":"end"}]},{"number":21,"arabic":"فَفَرَرْتُ مِنكُمْ لَمَّا خِفْتُكُمْ فَوَهَبَ لِى رَبِّى حُكْمًۭا وَجَعَلَنِى مِنَ ٱلْمُرْسَلِينَ","translation":"and I fled from you because I feared you. But [since] then my Sustainer has endowed me with the ability to judge [between right and wrong], and has made me one of [His] message-­bearers.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2953.mp3","surahId":26,"words":[{"id":24003,"position":1,"arabic":"فَفَرَرْتُ","translation":"অতঃপর আমি পালিয়ে গেলাম","audioUrl":"wbw/026_021_001.mp3","charTypeName":"word"},{"id":24004,"position":2,"arabic":"مِنكُمْ","translation":"হ'তে তোমাদের","audioUrl":"wbw/026_021_002.mp3","charTypeName":"word"},{"id":24005,"position":3,"arabic":"لَمَّا","translation":"যখন","audioUrl":"wbw/026_021_003.mp3","charTypeName":"word"},{"id":24006,"position":4,"arabic":"خِفْتُكُمْ","translation":"ভয় করেছিলাম তোমাদেরকে","audioUrl":"wbw/026_021_004.mp3","charTypeName":"word"},{"id":24007,"position":5,"arabic":"فَوَهَبَ","translation":"অতঃপর দান করলেন","audioUrl":"wbw/026_021_005.mp3","charTypeName":"word"},{"id":24008,"position":6,"arabic":"لِى","translation":"জন্যে আমার","audioUrl":"wbw/026_021_006.mp3","charTypeName":"word"},{"id":24009,"position":7,"arabic":"رَبِّى","translation":"আমার রব","audioUrl":"wbw/026_021_007.mp3","charTypeName":"word"},{"id":24010,"position":8,"arabic":"حُكْمًۭا","translation":"প্রজ্ঞা","audioUrl":"wbw/026_021_008.mp3","charTypeName":"word"},{"id":24011,"position":9,"arabic":"وَجَعَلَنِى","translation":"এবং আমাকে করলেন","audioUrl":"wbw/026_021_009.mp3","charTypeName":"word"},{"id":24012,"position":10,"arabic":"مِنَ","translation":"অন্তর্ভূক্ত","audioUrl":"wbw/026_021_010.mp3","charTypeName":"word"},{"id":24013,"position":11,"arabic":"ٱلْمُرْسَلِينَ","translation":"রাসূলদের","audioUrl":"wbw/026_021_011.mp3","charTypeName":"word"},{"id":24014,"position":12,"arabic":"٢١","translation":"(২১)","audioUrl":null,"charTypeName":"end"}]},{"number":22,"arabic":"وَتِلْكَ نِعْمَةٌۭ تَمُنُّهَا عَلَىَّ أَنْ عَبَّدتَّ بَنِىٓ إِسْرَٰٓءِيلَ","translation":"And [as for] that favour of which thou so tauntingly remindest me - [was it not] due to thy having enslaved the children of Israel?”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2954.mp3","surahId":26,"words":[{"id":25023,"position":1,"arabic":"وَتِلْكَ","translation":"আর ঐ","audioUrl":"wbw/026_022_001.mp3","charTypeName":"word"},{"id":25024,"position":2,"arabic":"نِعْمَةٌۭ","translation":"অনুগ্রহ","audioUrl":"wbw/026_022_002.mp3","charTypeName":"word"},{"id":25025,"position":3,"arabic":"تَمُنُّهَا","translation":"যা তুমি দয়া দেখাচ্ছো","audioUrl":"wbw/026_022_003.mp3","charTypeName":"word"},{"id":25026,"position":4,"arabic":"عَلَىَّ","translation":"আমার উপর (তা কি)","audioUrl":"wbw/026_022_004.mp3","charTypeName":"word"},{"id":25027,"position"