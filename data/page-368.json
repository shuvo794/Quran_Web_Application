026_035_001.mp3","charTypeName":"word"},{"id":37403,"position":2,"arabic":"أَن","translation":"যে","audioUrl":"wbw/026_035_002.mp3","charTypeName":"word"},{"id":37404,"position":3,"arabic":"يُخْرِجَكُم","translation":"সে বের করবে তোমাদেরকে","audioUrl":"wbw/026_035_003.mp3","charTypeName":"word"},{"id":37405,"position":4,"arabic":"مِّنْ","translation":"হ'তে","audioUrl":"wbw/026_035_004.mp3","charTypeName":"word"},{"id":37406,"position":5,"arabic":"أَرْضِكُم","translation":"দেশ তোমাদের","audioUrl":"wbw/026_035_005.mp3","charTypeName":"word"},{"id":37407,"position":6,"arabic":"بِسِحْرِهِۦ","translation":"সাহায্যে তাঁর জাদুর","audioUrl":"wbw/026_035_006.mp3","charTypeName":"word"},{"id":37408,"position":7,"arabic":"فَمَاذَا","translation":"অতঃপর কি","audioUrl":"wbw/026_035_007.mp3","charTypeName":"word"},{"id":37409,"position":8,"arabic":"تَأْمُرُونَ","translation":"তোমরা পরামর্শ দিচ্ছো\"","audioUrl":"wbw/026_035_008.mp3","charTypeName":"word"},{"id":37410,"position":9,"arabic":"٣٥","translation":"(৩৫)","audioUrl":null,"charTypeName":"end"}]},{"number":36,"arabic":"قَالُوٓا۟ أَرْجِهْ وَأَخَاهُ وَٱبْعَثْ فِى ٱلْمَدَآئِنِ حَٰشِرِينَ","translation":"They answered: “Let him and his brother wait a while, and send unto all cities heralds","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2968.mp3","surahId":26,"words":[{"id":38275,"position":1,"arabic":"قَالُوٓا۟","translation":"তারা বললো","audioUrl":"wbw/026_036_001.mp3","charTypeName":"word"},{"id":38276,"position":2,"arabic":"أَرْجِهْ","translation":"\"তাঁর (ব্যাপার) স্থগিত রাখুন","audioUrl":"wbw/026_036_002.mp3","charTypeName":"word"},{"id":38277,"position":3,"arabic":"وَأَخَاهُ","translation":"ও তাঁর ভায়ের (ব্যাপারে)","audioUrl":"wbw/026_036_003.mp3","charTypeName":"word"},{"id":38278,"position":4,"arabic":"وَٱبْعَثْ","translation":"এবং পাঠিয়ে দিন","audioUrl":"wbw/026_036_004.mp3","charTypeName":"word"},{"id":38279,"position":5,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/026_036_005.mp3","charTyp