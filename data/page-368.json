bic":"ٱلَّذِىٓ","translation":"যাকে","audioUrl":"wbw/026_027_004.mp3","charTypeName":"word"},{"id":30026,"position":5,"arabic":"أُرْسِلَ","translation":"পাঠানো হয়েছে","audioUrl":"wbw/026_027_005.mp3","charTypeName":"word"},{"id":30027,"position":6,"arabic":"إِلَيْكُمْ","translation":"প্রতি তোমাদের","audioUrl":"wbw/026_027_006.mp3","charTypeName":"word"},{"id":30028,"position":7,"arabic":"لَمَجْنُونٌۭ","translation":"অবশ্যই পাগল\"","audioUrl":"wbw/026_027_007.mp3","charTypeName":"word"},{"id":30029,"position":8,"arabic":"٢٧","translation":"(২৭)","audioUrl":null,"charTypeName":"end"}]},{"number":28,"arabic":"قَالَ رَبُّ ٱلْمَشْرِقِ وَٱلْمَغْرِبِ وَمَا بَيْنَهُمَآ ۖ إِن كُنتُمْ تَعْقِلُونَ","translation":"[But Moses] went on: “[He of whom I speak is] the Sustainer of the east and the west and of all that is between the two”- as you would know] if you would but use your reason!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2960.mp3","surahId":26,"words":[{"id":31098,"position":1,"arabic":"قَالَ","translation":"(মূসা) বললো","audioUrl":"wbw/026_028_001.mp3","charTypeName":"word"},{"id":31099,"position":2,"arabic":"رَبُّ","translation":"\"(তিনি তো) রব","audioUrl":"wbw/026_028_002.mp3","charTypeName":"word"},{"id":31100,"position":3,"arabic":"ٱلْمَشْرِقِ","translation":"পূর্বের","audioUrl":"wbw/026_028_003.mp3","charTypeName":"word"},{"id":31101,"position":4,"arabic":"وَٱلْمَغْرِبِ","translation":"এবং পশ্চিমের","audioUrl":"wbw/026_028_004.mp3","charTypeName":"word"},{"id":31102,"position":5,"arabic":"وَمَا","translation":"এবং যা কিছু (আছে)","audioUrl":"wbw/026_028_005.mp3","charTypeName":"word"},{"id":31103,"position":6,"arabic":"بَيْنَهُمَآ ۖ","translation":"উভয়ের মাঝে তাদের","audioUrl":"wbw/026_028_006.mp3","charTypeName":"word"},{"id":31105,"position":7,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/026_028_008.mp3","charTypeName":"word"},{"id":31106,"position":8,"arabic":"كُنتُمْ","translation":"তোমরা থাকো","audioUrl":"wbw/026_028_009.mp3","c