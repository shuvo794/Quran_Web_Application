tion":"(মূসা) বললো","audioUrl":"wbw/026_024_001.mp3","charTypeName":"word"},{"id":27153,"position":2,"arabic":"رَبُّ","translation":"\"রব","audioUrl":"wbw/026_024_002.mp3","charTypeName":"word"},{"id":27154,"position":3,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশমন্ডলীর","audioUrl":"wbw/026_024_003.mp3","charTypeName":"word"},{"id":27155,"position":4,"arabic":"وَٱلْأَرْضِ","translation":"ও পৃথিবীর","audioUrl":"wbw/026_024_004.mp3","charTypeName":"word"},{"id":27156,"position":5,"arabic":"وَمَا","translation":"এবং যা কিছু (আছে)","audioUrl":"wbw/026_024_005.mp3","charTypeName":"word"},{"id":27157,"position":6,"arabic":"بَيْنَهُمَآ ۖ","translation":"উভয়ের মাঝে তাদের","audioUrl":"wbw/026_024_006.mp3","charTypeName":"word"},{"id":27159,"position":7,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/026_024_008.mp3","charTypeName":"word"},{"id":27160,"position":8,"arabic":"كُنتُم","translation":"হও তোমরা","audioUrl":"wbw/026_024_009.mp3","charTypeName":"word"},{"id":27161,"position":9,"arabic":"مُّوقِنِينَ","translation":"দৃঢ় বিশ্বাসী\"","audioUrl":"wbw/026_024_010.mp3","charTypeName":"word"},{"id":27162,"position":10,"arabic":"٢٤","translation":"(২৪)","audioUrl":null,"charTypeName":"end"}]},{"number":25,"arabic":"قَالَ لِمَنْ حَوْلَهُۥٓ أَلَا تَسْتَمِعُونَ","translation":"Said [Pharaoh] unto those around him: “Did you hear [what he said]?”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2957.mp3","surahId":26,"words":[{"id":28179,"position":1,"arabic":"قَالَ","translation":"(ফিরআউন) বললো","audioUrl":"wbw/026_025_001.mp3","charTypeName":"word"},{"id":28180,"position":2,"arabic":"لِمَنْ","translation":"তাদেরকে (যারা ছিলো)","audioUrl":"wbw/026_025_002.mp3","charTypeName":"word"},{"id":28181,"position":3,"arabic":"حَوْلَهُۥٓ","translation":"চারপাশে তার","audioUrl":"wbw/026_025_003.mp3","charTypeName":"word"},{"id":28182,"position":4,"arabic":"أَلَا","translation":"\"কি না","audioUrl":"wbw/026_025_004.mp3","charTypeName":"word"},{"id":28183,"position":5,