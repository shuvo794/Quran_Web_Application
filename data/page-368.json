62.mp3","surahId":26,"words":[{"id":32937,"position":1,"arabic":"قَالَ","translation":"(মূসা) বললো","audioUrl":"wbw/026_030_001.mp3","charTypeName":"word"},{"id":32938,"position":2,"arabic":"أَوَلَوْ","translation":"\"কি যদিও","audioUrl":"wbw/026_030_002.mp3","charTypeName":"word"},{"id":32939,"position":3,"arabic":"جِئْتُكَ","translation":"তোমাদের (কাছে) আসি আমি","audioUrl":"wbw/026_030_003.mp3","charTypeName":"word"},{"id":32940,"position":4,"arabic":"بِشَىْءٍۢ","translation":"নিয়ে এক বস্তু (নিদর্শন)","audioUrl":"wbw/026_030_004.mp3","charTypeName":"word"},{"id":32941,"position":5,"arabic":"مُّبِينٍۢ","translation":"সুস্পষ্ট (তবুও)\"","audioUrl":"wbw/026_030_005.mp3","charTypeName":"word"},{"id":32942,"position":6,"arabic":"٣٠","translation":"(৩০)","audioUrl":null,"charTypeName":"end"}]},{"number":31,"arabic":"قَالَ فَأْتِ بِهِۦٓ إِن كُنتَ مِنَ ٱلصَّٰدِقِينَ","translation":"[Pharaoh] answered: “Produce it, then, if thou art a man of truth!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2963.mp3","surahId":26,"words":[{"id":33807,"position":1,"arabic":"قَالَ","translation":"(ফিরআউন) বললো","audioUrl":"wbw/026_031_001.mp3","charTypeName":"word"},{"id":33808,"position":2,"arabic":"فَأْتِ","translation":"\"তবে আসো","audioUrl":"wbw/026_031_002.mp3","charTypeName":"word"},{"id":33809,"position":3,"arabic":"بِهِۦٓ","translation":"নিয়ে তা","audioUrl":"wbw/026_031_003.mp3","charTypeName":"word"},{"id":33810,"position":4,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/026_031_004.mp3","charTypeName":"word"},{"id":33811,"position":5,"arabic":"كُنتَ","translation":"তুমি হও","audioUrl":"wbw/026_031_005.mp3","charTypeName":"word"},{"id":33812,"position":6,"arabic":"مِنَ","translation":"অন্তর্ভূক্ত","audioUrl":"wbw/026_031_006.mp3","charTypeName":"word"},{"id":33813,"position":7,"arabic":"ٱلصَّـٰدِقِينَ","translation":"সত্যবাদীদের\"","audioUrl":"wbw/026_031_007.mp3","charTypeName":"word"},{"id":33814,"position":8,"arabic":"٣١","translation":"(৩১)","audioUrl"