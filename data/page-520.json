":7,"arabic":"رَبِّكَ","translation":"তোমার রবের","audioUrl":"wbw/050_039_007.mp3","charTypeName":"word"},{"id":40864,"position":8,"arabic":"قَبْلَ","translation":"পূর্বে","audioUrl":"wbw/050_039_008.mp3","charTypeName":"word"},{"id":40865,"position":9,"arabic":"طُلُوعِ","translation":"উদয়ের","audioUrl":"wbw/050_039_009.mp3","charTypeName":"word"},{"id":40866,"position":10,"arabic":"ٱلشَّمْسِ","translation":"সূর্যের","audioUrl":"wbw/050_039_010.mp3","charTypeName":"word"},{"id":40867,"position":11,"arabic":"وَقَبْلَ","translation":"ও পূর্বে","audioUrl":"wbw/050_039_011.mp3","charTypeName":"word"},{"id":40868,"position":12,"arabic":"ٱلْغُرُوبِ","translation":"(সূর্য) অস্তের","audioUrl":"wbw/050_039_012.mp3","charTypeName":"word"},{"id":40869,"position":13,"arabic":"٣٩","translation":"(৩৯)","audioUrl":null,"charTypeName":"end"}]},{"number":40,"arabic":"وَمِنَ ٱلَّيْلِ فَسَبِّحْهُ وَأَدْبَٰرَ ٱلسُّجُودِ","translation":"and in the night, too, extol His glory, and at every prayer’s end.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4670.mp3","surahId":50,"words":[{"id":41157,"position":1,"arabic":"وَمِنَ","translation":"এবং কিছু অংশে","audioUrl":"wbw/050_040_001.mp3","charTypeName":"word"},{"id":41158,"position":2,"arabic":"ٱلَّيْلِ","translation":"রাতের","audioUrl":"wbw/050_040_002.mp3","charTypeName":"word"},{"id":41159,"position":3,"arabic":"فَسَبِّحْهُ","translation":"অতঃপর তাঁর পবিত্রতা ঘোষণা করো","audioUrl":"wbw/050_040_003.mp3","charTypeName":"word"},{"id":41160,"position":4,"arabic":"وَأَدْبَـٰرَ","translation":"এবং পরে","audioUrl":"wbw/050_040_004.mp3","charTypeName":"word"},{"id":41161,"position":5,"arabic":"ٱلسُّجُودِ","translation":"(নামাজের) সিজদাসমূহেরও","audioUrl":"wbw/050_040_005.mp3","charTypeName":"word"},{"id":41162,"position":6,"arabic":"٤٠","translation":"(৪০)","audioUrl":null,"charTypeName":"end"}]},{"number":41,"arabic":"وَٱسْتَمِعْ يَوْمَ يُنَادِ ٱلْمُنَادِ مِن مَّكَانٍۢ قَرِيبٍۢ","translation":"And [always] listen for the day when He who issues the call [of death] shall call [thee] from close-by;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4671.mp3","surahId":50,"words":[{"id":42055,"position":1,"arabic":"وَٱسْتَمِعْ","translation":"এবং শোনো","audioUrl":"wbw/050_041_001.mp3","charTypeName":"word"},{"id":42056,"position":2,"arabic":"يَوْمَ","translation":"যে দিন","audioUrl":"wbw/050_041_002.mp3","charTypeName":"word"},{"id":42057,"position":3,"arabic":"يُنَادِ","translation":"ডাকবে","audioUrl":"wbw/050_041_003.mp3","charTypeName":"word"},{"id":42058,"position":4,"arabic":"ٱلْمُنَادِ","translation":"একজন ঘোষণাকারী","audioUrl":"wbw/050_041_004.mp3","charTypeName":"word"},{"id":42059,"position":5,"arabic":"مِن","translation":"হতে","audioUrl":"wbw/050_041_005.mp3","charTypeName":"word"},{"id":42060,"position":6,"arabic":"مَّكَانٍۢ","translation":"স্থান","audioUrl":"wbw/050_041_006.mp3","charTypeName":"word"},{"id":42061,"position":7,"arabic":"قَرِيبٍۢ","translation":"নিকটবর্তী","audioUrl":"wbw/050_041_007.mp3","charTypeName":"word"},{"id":42062,"position":8,"arabic":"٤١","translation":"(৪১)","audioUrl":null,"charTypeName":"end"}]},{"number":42,"arabic":"يَوْمَ يَسْمَعُونَ ٱلصَّيْحَةَ بِٱلْحَقِّ ۚ ذَٰلِكَ يَوْمُ ٱلْخُرُوجِ","translation":"[and bethink thyself, too, of] the Day on which all [human beings] will in truth hear the final blast - that Day of [their] coming-forth [from death].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4672.mp3","surahId":50,"words":[{"id":42796,"position":1,"arabic":"يَوْمَ","translation":"সেদিন","audioUrl":"wbw/050_042_001.mp3","charTypeName":"word"},{"id":42797,"position":2,"arabic":"يَسْمَعُونَ","translation":"তারা শুনতে পারবে","audioUrl":"wbw/050_042_002.mp3","charTypeName":"word"},{"id":42798,"position":3,"arabic":"ٱلصَّيْحَةَ","translation":"মহাগর্জন","audioUrl":"wbw/050_042_003.mp3","charTypeName":"word"},{"id":42799,"position":4,"arabic":"بِٱلْحَقِّ ۚ","translation":"যথাযথভাবে","audioUrl":"wbw/050_042_004.mp3","charTypeName":"word"},{"id":42801,"position":5,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/050_042_006.mp3","charTypeName":"word"},{"id":42802,"position":6,"arabic":"يَوْمُ","translation":"দিন","audioUrl":"wbw/050_042_007.mp3","charTypeName":"word"},{"id":42803,"position":7,"arabic":"ٱلْخُرُوجِ","translation":"(কবর হতে) বের হওয়ার","audioUrl":"wbw/050_042_008.mp3","charTypeName":"word"},{"id":42804,"position":8,"arabic":"٤٢","translation":"(৪২)","audioUrl":null,"charTypeName":"end"}]},{"number":43,"arabic":"إِنَّا نَحْنُ نُحْىِۦ وَنُمِيتُ وَإِلَيْنَا ٱلْمَصِيرُ","translation":"Verily, it is We who grant life and deal death; and with Us will be all journeys’ end","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4673.mp3","surahId":50,"words":[{"id":43572,"position":1,"arabic":"إِنَّا","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/050_043_001.mp3","charTypeName":"word"},{"id":43573,"position":2,"arabic":"نَحْنُ","translation":"আমরাই","audioUrl":"wbw/050_043_002.mp3","charTypeName":"word"},{"id":43574,"position":3,"arabic":"نُحْىِۦ","translation":"জীবন দিই","audioUrl":"wbw/050_043_003.mp3","charTypeName":"word"},{"id":43575,"position":4,"arabic":"وَنُمِيتُ","translation":"এবং মৃত্যু দিই আমরাই","audioUrl":"wbw/050_043_004.mp3","charTypeName":"word"},{"id":43576,"position":5,"arabic":"وَإِلَيْنَا","translation":"এবং আমাদের দিকেই","audioUrl":"wbw/050_043_005.mp3","charTypeName":"word"},{"id":43577,"position":6,"arabic":"ٱلْمَصِيرُ","translation":"প্রত্যাবর্তনস্থল","audioUrl":"wbw/050_043_006.mp3","charTypeName":"word"},{"id":43578,"position":7,"arabic":"٤٣","translation":"(৪৩)","audioUrl":null,"charTypeName":"end"}]},{"number":44,"arabic":"يَوْمَ تَشَقَّقُ ٱلْأَرْضُ عَنْهُمْ سِرَاعًۭا ۚ ذَٰلِكَ حَشْرٌ عَلَيْنَا يَسِيرٌۭ","translation":"on the Day when the earth is riven asunder all around them as they hasten forth [towards God’s judgment]: that gathering will be easy for Us [to encompass].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4674.mp3","surahId":50,"words":[{"id":44693,"position":1,"arabic":"يَوْمَ","translation":"যেদিন","audioUrl":"wbw/050_044_001.mp3","charTypeName":"word"},{"id":44694,"position":2,"arabic":"تَشَقَّقُ","translation":"বিদীর্ণ হবে","audioUrl":"wbw/050_044_002.mp3","charTypeName":"word"},{"id":44695,"position":3,"arabic":"ٱلْأَرْضُ","translation":"পৃথিবী","audioUrl":"wbw/050_044_003.mp3","charTypeName":"word"},{"id":44696,"position":4,"arabic":"عَنْهُمْ","translation":"তাদের ভিতর হতে","audioUrl":"wbw/050_044_004.mp3","charTypeName":"word"},{"id":44697,"position":5,"arabic":"سِرَاعًۭا ۚ","translation":"ত্রস্তব্যস্ত","audioUrl":"wbw/050_044_005.mp3","charTypeName":"word"},{"id":44699,"position":6,"arabic":"ذَٰلِكَ","translation":"এই","audioUrl":"wbw/050_044_007.mp3","charTypeName":"word"},{"id":44700,"position":7,"arabic":"حَشْرٌ","translation":"সমবেত করা","audioUrl":"wbw/050_044_008.mp3","charTypeName":"word"},{"id":44701,"position":8,"arabic":"عَلَيْنَا","translation":"আমাদের উপর","audioUrl":"wbw/050_044_009.mp3","charTypeName":"word"},{"id":44702,"position":9,"arabic":"يَسِيرٌۭ","translation":"খুবই সহজ","audioUrl":"wbw/050_044_010.mp3","charTypeName":"word"},{"id":44703,"position":10,"arabic":"٤٤","translation":"(৪৪)","audioUrl":null,"charTypeName":"end"}]},{"number":45,"arabic":"نَّحْنُ أَعْلَمُ بِمَا يَقُولُونَ ۖ وَمَآ أَنتَ عَلَيْهِم بِجَبَّارٍۢ ۖ فَذَكِّرْ بِٱلْقُرْءَانِ مَن يَخَافُ وَعِيدِ","translation":"Fully aware are We of what they [who deny resurrection] do say; and thou canst by no means force them [to believe in it]. Yet none the less, remind, through this Qur’an, all such as may fear My warning.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4675.mp3","surahId":50,"words":[{"id":45089,"position":1,"arabic":"نَّحْنُ","translation":"(হে নবী) আমরা","audioUrl":"wbw/050_045_001.mp3","charTypeName":"word"},{"id":45090,"position":2,"arabic":"أَعْلَمُ","translation":"খুব জানি","audioUrl":"wbw/050_045_002.mp3","charTypeName":"word"},{"id":45091,"position":3,"arabic":"بِمَا","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/050_045_003.mp3","charTypeName":"word"},{"id":45092,"position":4,"arabic":"يَقُولُونَ ۖ","translation":"তারা বলেছে","audioUrl":"wbw/050_045_004.mp3","charTypeName":"word"},{"id":45094,"position":5,"arabic":"وَمَآ","translation":"এবং না","audioUrl":"wbw/050_045_006.mp3","charTypeName":"word"},{"id":45095,"position":6,"arabic":"أَنتَ","translation":"তুমি","audioUrl":"wbw/050_045_007.mp3","charTypeName":"word"},{"id":45096,"position":7,"arabic":"عَلَيْهِم","translation":"তাদের উপর","audioUrl":"wbw/050_045_008.mp3","charTypeName":"word"},{"id":45097,"position":8,"arabic":"بِجَبَّارٍۢ ۖ","translation":"জবরদস্তিকারী","audioUrl":"wbw/050_045_009.mp3","charTypeName":"word"},{"id":45099,"position":9,"arabic":"فَذَكِّرْ","translation":"সুতরাং উপদেশ দাও","audioUrl":"wbw/050_045_011.mp3","charTypeName":"word"},{"id":45100,"position":10,"arabic":"بِٱلْقُرْءَانِ","translation":"কুরআনের সাহায্যে","audioUrl":"wbw/050_045_012.mp3","charTypeName":"word"},{"id":45101,"position":11,"arabic":"مَن","translation":"(তাকে) যে","audioUrl":"wbw/050_045_013.mp3","charTypeName":"word"},{"id":45102,"position":12,"arabic":"يَخَافُ","translation":"ভয় করে","audioUrl":"wbw/050_045_014.mp3","charTypeName":"word"},{"id":45103,"position":13,"arabic":"وَعِيدِ","translation":"আমার সতর্কীকরণকে","audioUrl":"wbw/050_045_015.mp3","charTypeName":"word"},{"id":45104,"position":14,"arabic":"٤٥","translation":"(৪৫)","audioUrl":null,"charTypeName":"end"}]},{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلذَّٰرِيَٰتِ ذَرْوًۭا","translation":"CONSIDER the winds that scatter the dust far and wide,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4676.mp3","surahId":51,"words":[{"id":269,"position":1,"arabic":"وَٱلذَّٰرِيَـٰتِ","translation":"শপথ বিক্ষিপ্তকারীদের (অর্থাৎ বাতাসের)","audioUrl":"wbw/051_001_001.mp3","charTypeName":"word"},{"id":270,"position":2,"arabic":"ذَرْوًۭا","translation":"বিক্ষিপ্ত করার ম