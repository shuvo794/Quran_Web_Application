":"word"},{"id":38771,"position":10,"arabic":"أَلْقَى","translation":"নিবিষ্ট করে","audioUrl":"wbw/050_037_010.mp3","charTypeName":"word"},{"id":38772,"position":11,"arabic":"ٱلسَّمْعَ","translation":"কান","audioUrl":"wbw/050_037_011.mp3","charTypeName":"word"},{"id":38773,"position":12,"arabic":"وَهُوَ","translation":"এমতাবস্থায় সে","audioUrl":"wbw/050_037_012.mp3","charTypeName":"word"},{"id":38774,"position":13,"arabic":"شَهِيدٌۭ","translation":"উপস্থিত (মনেপ্রাণে)","audioUrl":"wbw/050_037_013.mp3","charTypeName":"word"},{"id":38775,"position":14,"arabic":"٣٧","translation":"(৩৭)","audioUrl":null,"charTypeName":"end"}]},{"number":38,"arabic":"وَلَقَدْ خَلَقْنَا ٱلسَّمَٰوَٰتِ وَٱلْأَرْضَ وَمَا بَيْنَهُمَا فِى سِتَّةِ أَيَّامٍۢ وَمَا مَسَّنَا مِن لُّغُوبٍۢ","translation":"and [who knows that] We have indeed created the heavens and the earth and all that is between them in six aeons, and [that] no weariness could ever touch Us.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4668.mp3","surahId":50,"words":[{"id":39658,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/050_038_001.mp3","charTypeName":"word"},{"id":39659,"position":2,"arabic":"خَلَقْنَا","translation":"আমরা সৃষ্টি করেছি","audioUrl":"wbw/050_038_002.mp3","charTypeName":"word"},{"id":39660,"position":3,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশ","audioUrl":"wbw/050_038_003.mp3","charTypeName":"word"},{"id":39661,"position":4,"arabic":"وَٱلْأَرْضَ","translation":"এবং পৃথিবীকে","audioUrl":"wbw/050_038_004.mp3","charTypeName":"word"},{"id":39662,"position":5,"arabic":"وَمَا","translation":"এবং যা কিছু (আছে)","audioUrl":"wbw/050_038_005.mp3","charTypeName":"word"},{"id":39663,"position":6,"arabic":"بَيْنَهُمَا","translation":"উভয়ের মাঝে","audioUrl":"wbw/050_038_006.mp3","charTypeName":"word"},{"id":39664,"position":7,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/050_038_007.mp3","charTypeName":"word"},{"id":39665,"position":8,"arabic":"سِتَّةِ","transla