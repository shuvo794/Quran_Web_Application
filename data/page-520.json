{"id":520,"ayahs":[{"number":36,"arabic":"وَكَمْ أَهْلَكْنَا قَبْلَهُم مِّن قَرْنٍ هُمْ أَشَدُّ مِنْهُم بَطْشًۭا فَنَقَّبُوا۟ فِى ٱلْبِلَٰدِ هَلْ مِن مَّحِيصٍ","translation":"AND HOW MANY a generation have We destroyed before those [who now deny the truth] people of greater might than theirs; but [when Our chastise­ment befell them,] they became wanderers on the face of the earth, seeking no more than a place of refuge","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4666.mp3","surahId":50,"words":[{"id":37932,"position":1,"arabic":"وَكَمْ","translation":"এবং কত","audioUrl":"wbw/050_036_001.mp3","charTypeName":"word"},{"id":37933,"position":2,"arabic":"أَهْلَكْنَا","translation":"আমরা ধ্বংস করেছি","audioUrl":"wbw/050_036_002.mp3","charTypeName":"word"},{"id":37934,"position":3,"arabic":"قَبْلَهُم","translation":"তাদের পূর্বে","audioUrl":"wbw/050_036_003.mp3","charTypeName":"word"},{"id":37935,"position":4,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/050_036_004.mp3","charTypeName":"word"},{"id":37936,"position":5,"arabic":"قَرْنٍ","translation":"জনগোষ্ঠী","audioUrl":"wbw/050_036_005.mp3","charTypeName":"word"},{"id":37937,"position":6,"arabic":"هُمْ","translation":"তারা (ছিল)","audioUrl":"wbw/050_036_006.mp3","charTypeName":"word"},{"id":37938,"position":7,"arabic":"أَشَدُّ","translation":"অধিক প্রবল","audioUrl":"wbw/050_036_007.mp3","charTypeName":"word"},{"id":37939,"position":8,"arabic":"مِنْهُم","translation":"তাদের চেয়েও","audioUrl":"wbw/050_036_008.mp3","charTypeName":"word"},{"id":37940,"position":9,"arabic":"بَطْشًۭا","translation":"শক্তিতে","audioUrl":"wbw/050_036_009.mp3","charTypeName":"word"},{"id":37941,"position":10,"arabic":"فَنَقَّبُوا۟","translation":"অতঃপর তারা  ভ্রমণ করত","audioUrl":"wbw/050_036_010.mp3","charTypeName":"word"},{"id":37942,"position":11,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/050_036_011.mp3","charTypeName":"word"},{"id":37943,"position":12,"arabic":"ٱلْبِلَـٰدِ","translation":"দেশ বিদেশের","au