{"id":350,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ سُورَةٌ أَنزَلْنَٰهَا وَفَرَضْنَٰهَا وَأَنزَلْنَا فِيهَآ ءَايَٰتٍۭ بَيِّنَٰتٍۢ لَّعَلَّكُمْ تَذَكَّرُونَ","translation":"A Surah [is this] which We have bestowed from on high, and which We have laid down in plain terms; and in it have We bestowed from on high messages which are clear [in themselves], so that you might keep [them] in mind.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2792.mp3","surahId":24,"words":[{"id":663,"position":1,"arabic":"سُورَةٌ","translation":"(এটা) একটি সূরা","audioUrl":"wbw/024_001_001.mp3","charTypeName":"word"},{"id":664,"position":2,"arabic":"أَنزَلْنَـٰهَا","translation":"তা আমরা অবতীর্ণ করেছি","audioUrl":"wbw/024_001_002.mp3","charTypeName":"word"},{"id":665,"position":3,"arabic":"وَفَرَضْنَـٰهَا","translation":"ও এর (বিধানকে) আমরা ফরজ করেছি","audioUrl":"wbw/024_001_003.mp3","charTypeName":"word"},{"id":666,"position":4,"arabic":"وَأَنزَلْنَا","translation":"এবং আমরা অবতীর্ণ করেছি","audioUrl":"wbw/024_001_004.mp3","charTypeName":"word"},{"id":667,"position":5,"arabic":"فِيهَآ","translation":"তার মধ্যে","audioUrl":"wbw/024_001_005.mp3","charTypeName":"word"},{"id":668,"position":6,"arabic":"ءَايَـٰتٍۭ","translation":"আয়াতসমূহ","audioUrl":"wbw/024_001_006.mp3","charTypeName":"word"},{"id":669,"position":7,"arabic":"بَيِّنَـٰتٍۢ","translation":"সুস্পষ্ট","audioUrl":"wbw/024_001_007.mp3","charTypeName":"word"},{"id":670,"position":8,"arabic":"لَّعَلَّكُمْ","translation":"সম্ভবতঃ তোমরা","audioUrl":"wbw/024_001_008.mp3","charTypeName":"word"},{"id":671,"position":9,"arabic":"تَذَكَّرُونَ","translation":"উপদেশ গ্রহণ করবে","audioUrl":"wbw/024_001_009.mp3","charTypeName":"word"},{"id":672,"position":10,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"ٱلزَّانِيَةُ وَٱلزَّانِى فَٱجْلِدُوا۟ كُلَّ وَٰحِدٍۢ مِّنْهُمَا مِا۟ئَةَ جَلْدَةٍۢ ۖ وَلَا تَأْخُذْكُم بِهِمَا رَأْفَةٌۭ فِى دِينِ ٱللَّهِ إِن كُنتُمْ تُؤْمِنُونَ بِٱللَّهِ وَٱلْيَوْمِ ٱلْءَاخِرِ ۖ وَلْيَشْهَدْ عَذَابَهُمَا طَآئِفَةٌۭ مِّنَ ٱلْمُؤْمِنِينَ","translation":"AS FOR the adulteress and the adulterer flog each of them with a hundred stripes, and let not compassion with them keep you from [carrying out] this law of God, if you [truly] believe in God and the Last Day; and let a group of the believers witness their chastisement.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2793.mp3","surahId":24,"words":[{"id":1662,"position":1,"arabic":"ٱلزَّانِيَةُ","translation":"ব্যভিচারিণী","audioUrl":"wbw/024_002_001.mp3","charTypeName":"word"},{"id":1663,"position":2,"arabic":"وَٱلزَّانِى","translation":"ও ব্যভিচারী","audioUrl":"wbw/024_002_002.mp3","charTypeName":"word"},{"id":1664,"position":3,"arabic":"فَٱجْلِدُوا۟","translation":"অতঃপর তোমরা দোররা মারবে","audioUrl":"wbw/024_002_003.mp3","charTypeName":"word"},{"id":1665,"position":4,"arabic":"كُلَّ","translation":"প্রত্যেক","audioUrl":"wbw/024_002_004.mp3","charTypeName":"word"},{"id":1666,"position":5,"arabic":"وَٰحِدٍۢ","translation":"একজনকে","audioUrl":"wbw/024_002_005.mp3","charTypeName":"word"},{"id":1667,"position":6,"arabic":"مِّنْهُمَا","translation":"তাদের দুজনার মধ্য হ'তে","audioUrl":"wbw/024_002_006.mp3","charTypeName":"word"},{"id":1668,"position":7,"arabic":"مِا۟ئَةَ","translation":"একশত","audioUrl":"wbw/024_002_007.mp3","charTypeName":"word"},{"id":1669,"position":8,"arabic":"جَلْدَةٍۢ ۖ","translation":"দোররা","audioUrl":"wbw/024_002_008.mp3","charTypeName":"word"},{"id":1671,"position":9,"arabic":"وَلَا","translation":"আর না (যেন)","audioUrl":"wbw/024_002_010.mp3","charTypeName":"word"},{"id":1672,"position":10,"arabic":"تَأْخُذْكُم","translation":"তোমাদেরকে প্রভাবিত করে","audioUrl":"wbw/024_002_011.mp3","charTypeName":"word"},{"id":1673,"position":11,"arabic":"بِهِمَا","translation":"প্রতি তাদের দু'জনের","audioUrl":"wbw/024_002_012.mp3","charTypeName":"word"},{"id":1674,"position":12,"arabic":"رَأْفَةٌۭ","translation":"দয়া অনুকম্পা","audioUrl":"wbw/024_002_013.mp3","charTypeName":"word"},{"id":1675,"position":13,"arabic":"فِى","translation":"ব্যাপারে","audioUrl":"wbw/024_002_014.mp3","charTypeName":"word"},{"id":1676,"position":14,"arabic":"دِينِ","translation":"দ্বীনের","audioUrl":"wbw/024_002_015.mp3","charTypeName":"word"},{"id":1677,"position":15,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/024_002_016.mp3","charTypeName":"word"},{"id":1678,"position":16,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/024_002_017.mp3","charTypeName":"word"},{"id":1679,"position":17,"arabic":"كُنتُمْ","translation":"তোমরা থাকো","audioUrl":"wbw/024_002_018.mp3","charTypeName":"word"},{"id":1680,"position":18,"arabic":"تُؤْمِنُونَ","translation":"তোমরা ঈমান আনো","audioUrl":"wbw/024_002_019.mp3","charTypeName":"word"},{"id":1681,"position":19,"arabic":"بِٱللَّهِ","translation":"প্রতি আল্লাহর","audioUrl":"wbw/024_002_020.mp3","charTypeName":"word"},{"id":1682,"position":20,"arabic":"وَٱلْيَوْمِ","translation":"ও দিনের","audioUrl":"wbw/024_002_021.mp3","charTypeName":"word"},{"id":1683,"position":21,"arabic":"ٱلْـَٔاخِرِ ۖ","translation":"শেষ (প্রতি)","audioUrl":"wbw/024_002_022.mp3","charTypeName":"word"},{"id":1685,"position":22,"arabic":"وَلْيَشْهَدْ","translation":"আর যেন প্রত্যক্ষ করে","audioUrl":"wbw/024_002_024.mp3","charTypeName":"word"},{"id":1686,"position":23,"arabic":"عَذَابَهُمَا","translation":"দু'জনের শাস্তি তাদের","audioUrl":"wbw/024_002_025.mp3","charTypeName":"word"},{"id":1687,"position":24,"arabic":"طَآئِفَةٌۭ","translation":"একদল","audioUrl":"wbw/024_002_026.mp3","charTypeName":"word"},{"id":1688,"position":25,"arabic":"مِّنَ","translation":"মধ্য হ'তে","audioUrl":"wbw/024_002_027.mp3","charTypeName":"word"},{"id":1689,"position":26,"arabic":"ٱلْمُؤْمِنِينَ","translation":"মু'মিনদের","audioUrl":"wbw/024_002_028.mp3","charTypeName":"word"},{"id":1690,"position":27,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"ٱلزَّانِى لَا يَنكِحُ إِلَّا زَانِيَةً أَوْ مُشْرِكَةًۭ وَٱلزَّانِيَةُ لَا يَنكِحُهَآ إِلَّا زَانٍ أَوْ مُشْرِكٌۭ ۚ وَحُرِّمَ ذَٰلِكَ عَلَى ٱلْمُؤْمِنِينَ","translation":"[Both are equally guilty:] the adulterer couples with none other than an adulteress - that is, a woman who accords [to her own lust] a place side by side with God; and with the adulteress couples none other than an adulterer - that is, a man who accords [to his own lust] a place side by side with God: and this is forbidden unto the believers.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2794.mp3","surahId":24,"words":[{"id":2862,"position":1,"arabic":"ٱلزَّانِى","translation":"ব্যভিচারী","audioUrl":"wbw/024_003_001.mp3","charTypeName":"word"},{"id":2863,"position":2,"arabic":"لَا","translation":"না","audioUrl":"wbw/024_003_002.mp3","charTypeName":"word"},{"id":2864,"position":3,"arabic":"يَنكِحُ","translation":"বিয়ে করবে (অন্য কাউকে)","audioUrl":"wbw/024_003_003.mp3","charTypeName":"word"},{"id":2865,"position":4,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/024_003_004.mp3","charTypeName":"word"},{"id":2866,"position":5,"arabic":"زَانِيَةً","translation":"ব্যভিচারিণীকে","audioUrl":"wbw/024_003_005.mp3","charTypeName":"word"},{"id":2867,"position":6,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/024_003_006.mp3","charTypeName":"word"},{"id":2868,"position":7,"arabic":"مُشْرِكَةًۭ","translation":"মুশরিক নারীকে","audioUrl":"wbw/024_003_007.mp3","charTypeName":"word"},{"id":2869,"position":8,"arabic":"وَٱلزَّانِيَةُ","translation":"আর ব্যভিচারিণী","audioUrl":"wbw/024_003_008.mp3","charTypeName":"word"},{"id":2870,"position":9,"arabic":"لَا","translation":"না","audioUrl":"wbw/024_003_009.mp3","charTypeName":"word"},{"id":2871,"position":10,"arabic":"يَنكِحُهَآ","translation":"তাকে বিয়ে করবে (অন্য কেউ)","audioUrl":"wbw/024_003_010.mp3","charTypeName":"word"},{"id":2872,"position":11,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/024_003_011.mp3","charTypeName":"word"},{"id":2873,"position":12,"arabic":"زَانٍ","translation":"ব্যভিচারী","audioUrl":"wbw/024_003_012.mp3","charTypeName":"word"},{"id":2874,"position":13,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/024_003_013.mp3","charTypeName":"word"},{"id":2875,"position":14,"arabic":"مُشْرِكٌۭ ۚ","translation":"মুশরিক","audioUrl":"wbw/024_003_014.mp3","charTypeName":"word"},{"id":2877,"position":15,"arabic":"وَحُرِّمَ","translation":"এবং নিষিদ্ধ করা হলো","audioUrl":"wbw/024_003_016.mp3","charTypeName":"word"},{"id":2878,"position":16,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/024_003_017.mp3","charTypeName":"word"},{"id":2879,"position":17,"arabic":"عَلَى","translation":"জন্যে","audioUrl":"wbw/024_003_018.mp3","charTypeName":"word"},{"id":2880,"position":18,"arabic":"ٱلْمُؤْمِنِينَ","translation":"মু'মিনদের","audioUrl":"wbw/024_003_019.mp3","charTypeName":"word"},{"id":2881,"position":19,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"وَٱلَّذِينَ يَرْمُونَ ٱلْمُحْصَنَٰتِ ثُمَّ لَمْ يَأْتُوا۟ بِأَرْبَعَةِ شُهَدَآءَ فَٱجْلِدُوهُمْ ثَمَٰنِينَ جَلْدَةًۭ وَلَا تَقْبَلُوا۟ لَهُمْ شَهَٰدَةً أَبَدًۭا ۚ وَأُو۟لَٰٓئِكَ هُمُ ٱلْفَٰسِقُونَ","translation":"And as for those who accuse chaste women [of adultery], and then are unable to produce four witnesses [in support of their accusation], flog them with eighty stripes and ever after refuse to accept from them any testimony - since it is they, they that are truly depraved!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2795.mp3","surahId":24,"words":[{"id":4145,"position":1,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/024_004_001.mp3","charTypeName":"word"},{"id":4146,"position":2,"arabic":"يَرْمُونَ","translation":"অপবাদ দেয়","audioUrl":"wbw/024_004_002.mp3","charTypeName":"word"},{"id":4147,"position":3,"arabic":"ٱلْمُحْصَنَـٰتِ","translation":"পবিত্র রমণীদেরকে","audioUrl":"wbw/024_004_003.mp3","charTypeName":"word"},{"id":4148,"positi