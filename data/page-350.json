.mp3","charTypeName":"word"},{"id":4165,"position":20,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"إِلَّا ٱلَّذِينَ تَابُوا۟ مِنۢ بَعْدِ ذَٰلِكَ وَأَصْلَحُوا۟ فَإِنَّ ٱللَّهَ غَفُورٌۭ رَّحِيمٌۭ","translation":"excepting [from this interdict] only those who afterwards repent and made amends: for, behold, God is much forgiving, a dispenser of grace.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2796.mp3","surahId":24,"words":[{"id":5436,"position":1,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/024_005_001.mp3","charTypeName":"word"},{"id":5437,"position":2,"arabic":"ٱلَّذِينَ","translation":"(তারা) যারা","audioUrl":"wbw/024_005_002.mp3","charTypeName":"word"},{"id":5438,"position":3,"arabic":"تَابُوا۟","translation":"তওবা করেছে","audioUrl":"wbw/024_005_003.mp3","charTypeName":"word"},{"id":5439,"position":4,"arabic":"مِنۢ","translation":"থেকে","audioUrl":"wbw/024_005_004.mp3","charTypeName":"word"},{"id":5440,"position":5,"arabic":"بَعْدِ","translation":"পর","audioUrl":"wbw/024_005_005.mp3","charTypeName":"word"},{"id":5441,"position":6,"arabic":"ذَٰلِكَ","translation":"এর","audioUrl":"wbw/024_005_006.mp3","charTypeName":"word"},{"id":5442,"position":7,"arabic":"وَأَصْلَحُوا۟","translation":"ও সংশোধন করেছে","audioUrl":"wbw/024_005_007.mp3","charTypeName":"word"},{"id":5443,"position":8,"arabic":"فَإِنَّ","translation":"তাহ'লে নিশ্চয়ই","audioUrl":"wbw/024_005_008.mp3","charTypeName":"word"},{"id":5444,"position":9,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/024_005_009.mp3","charTypeName":"word"},{"id":5445,"position":10,"arabic":"غَفُورٌۭ","translation":"ক্ষমাশীল","audioUrl":"wbw/024_005_010.mp3","charTypeName":"word"},{"id":5446,"position":11,"arabic":"رَّحِيمٌۭ","translation":"পরম দয়ালু","audioUrl":"wbw/024_005_011.mp3","charTypeName":"word"},{"id":5447,"position":12,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"وَٱلَّذِينَ ي