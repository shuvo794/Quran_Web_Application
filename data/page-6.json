:"word"},{"id":32718,"position":26,"arabic":"مَا","translation":"যা","audioUrl":"wbw/002_030_028.mp3","charTypeName":"word"},{"id":32719,"position":27,"arabic":"لَا","translation":"না","audioUrl":"wbw/002_030_029.mp3","charTypeName":"word"},{"id":32720,"position":28,"arabic":"تَعْلَمُونَ","translation":"তোমরা জান''","audioUrl":"wbw/002_030_030.mp3","charTypeName":"word"},{"id":32721,"position":29,"arabic":"٣٠","translation":"(৩০)","audioUrl":null,"charTypeName":"end"}]},{"number":31,"arabic":"وَعَلَّمَ ءَادَمَ ٱلْأَسْمَآءَ كُلَّهَا ثُمَّ عَرَضَهُمْ عَلَى ٱلْمَلَٰٓئِكَةِ فَقَالَ أَنۢبِـُٔونِى بِأَسْمَآءِ هَٰٓؤُلَآءِ إِن كُنتُمْ صَٰدِقِينَ","translation":"And He imparted unto Adam the names of all things; then He brought them within the ken of the angels and said: \"Declare unto Me the names of these [things], if what you say is true.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/38.mp3","surahId":2,"words":[{"id":33595,"position":1,"arabic":"وَعَلَّمَ","translation":"এবং শিখালেন","audioUrl":"wbw/002_031_001.mp3","charTypeName":"word"},{"id":33596,"position":2,"arabic":"ءَادَمَ","translation":"আদমকে","audioUrl":"wbw/002_031_002.mp3","charTypeName":"word"},{"id":33597,"position":3,"arabic":"ٱلْأَسْمَآءَ","translation":"নামসমূহ","audioUrl":"wbw/002_031_003.mp3","charTypeName":"word"},{"id":33598,"position":4,"arabic":"كُلَّهَا","translation":"সবকিছুর","audioUrl":"wbw/002_031_004.mp3","charTypeName":"word"},{"id":33599,"position":5,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/002_031_005.mp3","charTypeName":"word"},{"id":33600,"position":6,"arabic":"عَرَضَهُمْ","translation":"সেগুলো উপস্থাপন করলেন","audioUrl":"wbw/002_031_006.mp3","charTypeName":"word"},{"id":33601,"position":7,"arabic":"عَلَى","translation":"সামনে","audioUrl":"wbw/002_031_007.mp3","charTypeName":"word"},{"id":33602,"position":8,"arabic":"ٱلْمَلَـٰٓئِكَةِ","translation":"ফেরেশতাদের","audioUrl":"wbw/002_031_008.mp3","charTypeName":"word"},{"id":33603,"position":9,"arabic":"فَقَالَ","translation":"এরপর বললেন","audioUrl":"wbw/002_031_009.mp3","charTypeName":"word"},{"id":33604,"position":10,"arabic":"أَنۢبِـُٔونِى","translation":"''আমাকে অবহিত করো","audioUrl":"wbw/002_031_010.mp3","charTypeName":"word"},{"id":33605,"position":11,"arabic":"بِأَسْمَآءِ","translation":"নাম সম্পর্কে","audioUrl":"wbw/002_031_011.mp3","charTypeName":"word"},{"id":33606,"position":12,"arabic":"هَـٰٓؤُلَآءِ","translation":"এসবের","audioUrl":"wbw/002_031_012.mp3","charTypeName":"word"},{"id":33607,"position":13,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/002_031_013.mp3","charTypeName":"word"},{"id":33608,"position":14,"arabic":"كُنتُمْ","translation":"তোমরা হও","audioUrl":"wbw/002_031_014.mp3","charTypeName":"word"},{"id":33609,"position":15,"arabic":"صَـٰدِقِينَ","translation":"সত্যবাদী''","audioUrl":"wbw/002_031_015.mp3","charTypeName":"word"},{"id":33610,"position":16,"arabic":"٣١","translation":"(৩১)","audioUrl":null,"charTypeName":"end"}]},{"number":32,"arabic":"قَالُوا۟ سُبْحَٰنَكَ لَا عِلْمَ لَنَآ إِلَّا مَا عَلَّمْتَنَآ ۖ إِنَّكَ أَنتَ ٱلْعَلِيمُ ٱلْحَكِيمُ","translation":"They replied: \"Limitless art Thou in Thy glory! No knowledge have we save that which Thou hast imparted unto us. Verily, Thou alone art all-knowing, truly wise.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/39.mp3","surahId":2,"words":[{"id":34673,"position":1,"arabic":"قَالُوا۟","translation":"তারা বলেছিল","audioUrl":"wbw/002_032_001.mp3","charTypeName":"word"},{"id":34674,"position":2,"arabic":"سُبْحَـٰنَكَ","translation":"''আপনি পবিত্র","audioUrl":"wbw/002_032_002.mp3","charTypeName":"word"},{"id":34675,"position":3,"arabic":"لَا","translation":"না (আছে)","audioUrl":"wbw/002_032_003.mp3","charTypeName":"word"},{"id":34676,"position":4,"arabic":"عِلْمَ","translation":"জ্ঞান","audioUrl":"wbw/002_032_004.mp3","charTypeName":"word"},{"id":34677,"position":5,"arabic":"لَنَآ","translation":"আমাদের","audioUrl":"wbw/002_032_005.mp3","charTypeName":"word"