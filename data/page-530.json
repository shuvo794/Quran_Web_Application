{"id":530,"ayahs":[{"number":28,"arabic":"وَنَبِّئْهُمْ أَنَّ ٱلْمَآءَ قِسْمَةٌۢ بَيْنَهُمْ ۖ كُلُّ شِرْبٍۢ مُّحْتَضَرٌۭ","translation":"And let them know that the water [of their wells] is to be divided between them, with each share of water equitably apportioned.”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4874.mp3","surahId":54,"words":[{"id":30749,"position":1,"arabic":"وَنَبِّئْهُمْ","translation":"এবং তাদের জানিয়ে দাও","audioUrl":"wbw/054_028_001.mp3","charTypeName":"word"},{"id":30750,"position":2,"arabic":"أَنَّ","translation":"যে","audioUrl":"wbw/054_028_002.mp3","charTypeName":"word"},{"id":30751,"position":3,"arabic":"ٱلْمَآءَ","translation":"পানি","audioUrl":"wbw/054_028_003.mp3","charTypeName":"word"},{"id":30752,"position":4,"arabic":"قِسْمَةٌۢ","translation":"পালা করে দেওয়া হলো (হয়েছে)","audioUrl":"wbw/054_028_004.mp3","charTypeName":"word"},{"id":30753,"position":5,"arabic":"بَيْنَهُمْ ۖ","translation":"তাদের মাঝে","audioUrl":"wbw/054_028_005.mp3","charTypeName":"word"},{"id":30755,"position":6,"arabic":"كُلُّ","translation":"প্রত্যেকে","audioUrl":"wbw/054_028_007.mp3","charTypeName":"word"},{"id":30756,"position":7,"arabic":"شِرْبٍۢ","translation":"পান করতে","audioUrl":"wbw/054_028_008.mp3","charTypeName":"word"},{"id":30757,"position":8,"arabic":"مُّحْتَضَرٌۭ","translation":"উপস্থিত হবে (পালাক্রমে)","audioUrl":"wbw/054_028_009.mp3","charTypeName":"word"},{"id":30758,"position":9,"arabic":"٢٨","translation":"(২৮)","audioUrl":null,"charTypeName":"end"}]},{"number":29,"arabic":"فَنَادَوْا۟ صَاحِبَهُمْ فَتَعَاطَىٰ فَعَقَرَ","translation":"But they summoned their [boldest] companion, and he ventured [upon the evil deed], and cruelly slaughtered [the animal]:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4875.mp3","surahId":54,"words":[{"id":31830,"position":1,"arabic":"فَنَادَوْا۟","translation":"তারা অতঃপর ডাকল","audioUrl":"wbw/054_029_001.mp3","charTypeName":"word"},{"id":31831,"position":2,"arabic":"صَاحِبَه