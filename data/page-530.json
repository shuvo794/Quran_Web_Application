network/quran/audio/128/ar.alafasy/4887.mp3","surahId":54,"words":[{"id":42080,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/054_041_001.mp3","charTypeName":"word"},{"id":42081,"position":2,"arabic":"جَآءَ","translation":"এসেছিল","audioUrl":"wbw/054_041_002.mp3","charTypeName":"word"},{"id":42082,"position":3,"arabic":"ءَالَ","translation":"সম্প্রদায়ের (কাছে)","audioUrl":"wbw/054_041_003.mp3","charTypeName":"word"},{"id":42083,"position":4,"arabic":"فِرْعَوْنَ","translation":"ফিরআউনের","audioUrl":"wbw/054_041_004.mp3","charTypeName":"word"},{"id":42084,"position":5,"arabic":"ٱلنُّذُرُ","translation":"সতর্ককারীরা","audioUrl":"wbw/054_041_005.mp3","charTypeName":"word"},{"id":42085,"position":6,"arabic":"٤١","translation":"(৪১)","audioUrl":null,"charTypeName":"end"}]},{"number":42,"arabic":"كَذَّبُوا۟ بِـَٔايَٰتِنَا كُلِّهَا فَأَخَذْنَٰهُمْ أَخْذَ عَزِيزٍۢ مُّقْتَدِرٍ","translation":"they, too, gave the lie to all Our messages: and thereupon We took them to task as only the Almighty, who determines all things, can take to task.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4888.mp3","surahId":54,"words":[{"id":42977,"position":1,"arabic":"كَذَّبُوا۟","translation":"তারা মিথ্যা বলেছিল","audioUrl":"wbw/054_042_001.mp3","charTypeName":"word"},{"id":42978,"position":2,"arabic":"بِـَٔايَـٰتِنَا","translation":"আমাদের নিদর্শনের","audioUrl":"wbw/054_042_002.mp3","charTypeName":"word"},{"id":42979,"position":3,"arabic":"كُلِّهَا","translation":"সবগুলোকেই","audioUrl":"wbw/054_042_003.mp3","charTypeName":"word"},{"id":42980,"position":4,"arabic":"فَأَخَذْنَـٰهُمْ","translation":"ফলে তাদেরকে আমরা পাকড়াও করলাম","audioUrl":"wbw/054_042_004.mp3","charTypeName":"word"},{"id":42981,"position":5,"arabic":"أَخْذَ","translation":"পাকড়াও","audioUrl":"wbw/054_042_005.mp3","charTypeName":"word"},{"id":42982,"position":6,"arabic":"عَزِيزٍۢ","translation":"পরাক্রমশালীর","audioUrl":"wbw/054_042_006.mp3","charTypeName":"word"},{"id":42983,"position":7,"arabic":"مُّقْتَدِرٍ","translation":"মহাশক্তিমানের","audioUrl":"wbw/054_042_007.mp3","charTypeName":"word"},{"id":42984,"position":8,"arabic":"٤٢","translation":"(৪২)","audioUrl":null,"charTypeName":"end"}]},{"number":43,"arabic":"أَكُفَّارُكُمْ خَيْرٌۭ مِّنْ أُو۟لَٰٓئِكُمْ أَمْ لَكُم بَرَآءَةٌۭ فِى ٱلزُّبُرِ","translation":"ARE, THEN, those of you who [now] deny the truth better than those others - or have you, per­chance, [been promised] immunity in the [ancient] books of [divine] wisdom?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4889.mp3","surahId":54,"words":[{"id":43608,"position":1,"arabic":"أَكُفَّارُكُمْ","translation":"তোমাদের কাফিররা কি","audioUrl":"wbw/054_043_001.mp3","charTypeName":"word"},{"id":43609,"position":2,"arabic":"خَيْرٌۭ","translation":"উত্তম","audioUrl":"wbw/054_043_002.mp3","charTypeName":"word"},{"id":43610,"position":3,"arabic":"مِّنْ","translation":"চেয়ে","audioUrl":"wbw/054_043_003.mp3","charTypeName":"word"},{"id":43611,"position":4,"arabic":"أُو۟لَـٰٓئِكُمْ","translation":"ঐসব লোকদের","audioUrl":"wbw/054_043_004.mp3","charTypeName":"word"},{"id":43612,"position":5,"arabic":"أَمْ","translation":"কিংবা","audioUrl":"wbw/054_043_005.mp3","charTypeName":"word"},{"id":43613,"position":6,"arabic":"لَكُم","translation":"তোমাদের জন্যে আছে","audioUrl":"wbw/054_043_006.mp3","charTypeName":"word"},{"id":43614,"position":7,"arabic":"بَرَآءَةٌۭ","translation":"(লিখিত) মুক্তির সনদ","audioUrl":"wbw/054_043_007.mp3","charTypeName":"word"},{"id":43615,"position":8,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/054_043_008.mp3","charTypeName":"word"},{"id":43616,"position":9,"arabic":"ٱلزُّبُرِ","translation":"(পূর্বের) গ্রন্থসমূহের","audioUrl":"wbw/054_043_009.mp3","charTypeName":"word"},{"id":43617,"position":10,"arabic":"٤٣","translation":"(৪৩)","audioUrl":null,"charTypeName":"end"}]},{"number":44,"arabic":"أَمْ يَقُولُونَ نَحْنُ جَمِيعٌۭ مُّنتَصِرٌۭ","translation":"Or do they say, “We are a group united, [and