{"id":183,"ayahs":[{"number":46,"arabic":"وَأَطِيعُوا۟ ٱللَّهَ وَرَسُولَهُۥ وَلَا تَنَٰزَعُوا۟ فَتَفْشَلُوا۟ وَتَذْهَبَ رِيحُكُمْ ۖ وَٱصْبِرُوٓا۟ ۚ إِنَّ ٱللَّهَ مَعَ ٱلصَّٰبِرِينَ","translation":"And pay heed unto God and His Apostle, and do not [allow yourselves to] be at variance with one another, lest you lose heart and your moral strength desert you. And be patient in adversity: for, verily, God is with those who are patient in adversity.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1206.mp3","surahId":8,"words":[{"id":46258,"position":1,"arabic":"وَأَطِيعُوا۟","translation":"এবং তোমরা আনুগত্য করো","audioUrl":"wbw/008_046_001.mp3","charTypeName":"word"},{"id":46259,"position":2,"arabic":"ٱللَّهَ","translation":"আল্লাহর","audioUrl":"wbw/008_046_002.mp3","charTypeName":"word"},{"id":46260,"position":3,"arabic":"وَرَسُولَهُۥ","translation":"ও রাসূলের তাঁর","audioUrl":"wbw/008_046_003.mp3","charTypeName":"word"},{"id":46261,"position":4,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/008_046_004.mp3","charTypeName":"word"},{"id":46262,"position":5,"arabic":"تَنَـٰزَعُوا۟","translation":"তোমরা বিবাদ করো","audioUrl":"wbw/008_046_005.mp3","charTypeName":"word"},{"id":46263,"position":6,"arabic":"فَتَفْشَلُوا۟","translation":"তাহ'লে তোমরা সাহস হারাবে","audioUrl":"wbw/008_046_006.mp3","charTypeName":"word"},{"id":46264,"position":7,"arabic":"وَتَذْهَبَ","translation":"ও চলে যাবে","audioUrl":"wbw/008_046_007.mp3","charTypeName":"word"},{"id":46265,"position":8,"arabic":"رِيحُكُمْ ۖ","translation":"শক্তি তোমাদের","audioUrl":"wbw/008_046_008.mp3","charTypeName":"word"},{"id":46267,"position":9,"arabic":"وَٱصْبِرُوٓا۟ ۚ","translation":"এবং তোমরা ধৈর্য ধরো","audioUrl":"wbw/008_046_010.mp3","charTypeName":"word"},{"id":46269,"position":10,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/008_046_012.mp3","charTypeName":"word"},{"id":46270,"position":11,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/008_046_013.mp3","charTypeName":"word"},{"id":46271,"position":12,"arabic":"مَعَ","translation":"সাথে (থাকেন)","audioUrl":"wbw/008_046_014.mp3","charTypeName":"word"},{"id":46272,"position":13,"arabic":"ٱلصَّـٰبِرِينَ","translation":"ধৈর্যশীলদের","audioUrl":"wbw/008_046_015.mp3","charTypeName":"word"},{"id":46273,"position":14,"arabic":"٤٦","translation":"(৪৬)","audioUrl":null,"charTypeName":"end"}]},{"number":47,"arabic":"وَلَا تَكُونُوا۟ كَٱلَّذِينَ خَرَجُوا۟ مِن دِيَٰرِهِم بَطَرًۭا وَرِئَآءَ ٱلنَّاسِ وَيَصُدُّونَ عَن سَبِيلِ ٱللَّهِ ۚ وَٱللَّهُ بِمَا يَعْمَلُونَ مُحِيطٌۭ","translation":"And be not like those [unbelievers] who went forth from their homelands full of self-conceit and a desire to be seen and praised by men for they were trying to turn others away from the path of God -the while God encompassed all their doings [with His might].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1207.mp3","surahId":8,"words":[{"id":46500,"position":1,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/008_047_001.mp3","charTypeName":"word"},{"id":46501,"position":2,"arabic":"تَكُونُوا۟","translation":"তোমরা হয়ো","audioUrl":"wbw/008_047_002.mp3","charTypeName":"word"},{"id":46502,"position":3,"arabic":"كَٱلَّذِينَ","translation":"(তাদের) মতো যারা","audioUrl":"wbw/008_047_003.mp3","charTypeName":"word"},{"id":46503,"position":4,"arabic":"خَرَجُوا۟","translation":"বের হয়েছিলো","audioUrl":"wbw/008_047_004.mp3","charTypeName":"word"},{"id":46504,"position":5,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/008_047_005.mp3","charTypeName":"word"},{"id":46505,"position":6,"arabic":"دِيَـٰرِهِم","translation":"ঘরগুলো তাদের","audioUrl":"wbw/008_047_006.mp3","charTypeName":"word"},{"id":46506,"position":7,"arabic":"بَطَرًۭا","translation":"গর্বভরে","audioUrl":"wbw/008_047_007.mp3","charTypeName":"word"},{"id":46507,"position":8,"arabic":"وَرِئَآءَ","translation":"ও দেখানোর (জন্যে)","audioUrl":"wbw/008_047_008.mp3","charTypeName":"word"},{"id":46508,"position":9,"arabic":"ٱلنَّاسِ","translation":"লোকদের","audioUrl":"wbw/008_047_009.mp3","charTypeName":"word"},{"id":46509,"position":10,"arabic":"وَيَصُدُّونَ","translation":"ও তারা বাধা দেয়","audioUrl":"wbw/008_047_010.mp3","charTypeName":"word"},{"id":46510,"position":11,"arabic":"عَن","translation":"হতে","audioUrl":"wbw/008_047_011.mp3","charTypeName":"word"},{"id":46511,"position":12,"arabic":"سَبِيلِ","translation":"পথ","audioUrl":"wbw/008_047_012.mp3","charTypeName":"word"},{"id":46512,"position":13,"arabic":"ٱللَّهِ ۚ","translation":"আল্লাহর","audioUrl":"wbw/008_047_013.mp3","charTypeName":"word"},{"id":46514,"position":14,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/008_047_015.mp3","charTypeName":"word"},{"id":46515,"position":15,"arabic":"بِمَا","translation":"ঐবিষয়ে যা","audioUrl":"wbw/008_047_016.mp3","charTypeName":"word"},{"id":46516,"position":16,"arabic":"يَعْمَلُونَ","translation":"তারা কাজ করেছে","audioUrl":"wbw/008_047_017.mp3","charTypeName":"word"},{"id":46517,"position":17,"arabic":"مُحِيطٌۭ","translation":"পরিবেষ্টনকারী","audioUrl":"wbw/008_047_018.mp3","charTypeName":"word"},{"id":46518,"position":18,"arabic":"٤٧","translation":"(৪৭)","audioUrl":null,"charTypeName":"end"}]},{"number":48,"arabic":"وَإِذْ زَيَّنَ لَهُمُ ٱلشَّيْطَٰنُ أَعْمَٰلَهُمْ وَقَالَ لَا غَالِبَ لَكُمُ ٱلْيَوْمَ مِنَ ٱلنَّاسِ وَإِنِّى جَارٌۭ لَّكُمْ ۖ فَلَمَّا تَرَآءَتِ ٱلْفِئَتَانِ نَكَصَ عَلَىٰ عَقِبَيْهِ وَقَالَ إِنِّى بَرِىٓءٌۭ مِّنكُمْ إِنِّىٓ أَرَىٰ مَا لَا تَرَوْنَ إِنِّىٓ أَخَافُ ٱللَّهَ ۚ وَٱللَّهُ شَدِيدُ ٱلْعِقَابِ","translation":"And, lo, Satan made all their doings seem goodly to them, and said, \"No one can overcome you this day, for, behold, I shall be your protector!\" but as soon as the two hosts came within sight of one another, he turned on his heels and said, \"Behold, I am not responsible for you: behold, I see something that you do not see: behold, I fear God-for God is severe in retribution!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1208.mp3","surahId":8,"words":[{"id":47511,"position":1,"arabic":"وَإِذْ","translation":"এবং যখন","audioUrl":"wbw/008_048_001.mp3","charTypeName":"word"},{"id":47512,"position":2,"arabic":"زَيَّنَ","translation":"শোভন করেছিলো","audioUrl":"wbw/008_048_002.mp3","charTypeName":"word"},{"id":47513,"position":3,"arabic":"لَهُمُ","translation":"জন্যে তাদের","audioUrl":"wbw/008_048_003.mp3","charTypeName":"word"},{"id":47514,"position":4,"arabic":"ٱلشَّيْطَـٰنُ","translation":"শয়তান","audioUrl":"wbw/008_048_004.mp3","charTypeName":"word"},{"id":47515,"position":5,"arabic":"أَعْمَـٰلَهُمْ","translation":"কাজগুলোকে তাদের","audioUrl":"wbw/008_048_005.mp3","charTypeName":"word"},{"id":47516,"position":6,"arabic":"وَقَالَ","translation":"এবং বলেছিলো","audioUrl":"wbw/008_048_006.mp3","charTypeName":"word"},{"id":47517,"position":7,"arabic":"لَا","translation":"\"না","audioUrl":"wbw/008_048_007.mp3","charTypeName":"word"},{"id":47518,"position":8,"arabic":"غَالِبَ","translation":"বিজয়ী হবে","audioUrl":"wbw/008_048_008.mp3","charTypeName":"word"},{"id":47519,"position":9,"arabic":"لَكُمُ","translation":"উপর তোমাদের","audioUrl":"wbw/008_048_009.mp3","charTypeName":"word"},{"id":47520,"position":10,"arabic":"ٱلْيَوْمَ","translation":"আজ","audioUrl":"wbw/008_048_010.mp3","charTypeName":"word"},{"id":47521,"position":11,"arabic":"مِنَ","translation":"মধ্য থেকে (কেউ)","audioUrl":"wbw/008_048_011.mp3","charTypeName":"word"},{"id":47522,"position":12,"arabic":"ٱلنَّاسِ","translation":"মানুষদের","audioUrl":"wbw/008_048_012.mp3","charTypeName":"word"},{"id":47523,"position":13,"arabic":"وَإِنِّى","translation":"এবং নিশ্চয়ই আমি","audioUrl":"wbw/008_048_013.mp3","charTypeName":"word"},{"id":47524,"position":14,"arabic":"جَارٌۭ","translation":"প্রতিবেশী","audioUrl":"wbw/008_048_014.mp3","charTypeName":"word"},{"id":47525,"position":15,"arabic":"لَّكُمْ ۖ","translation":"তোমাদের\"","audioUrl":"wbw/008_048_015.mp3","charTypeName":"word"},{"id":47527,"position":16,"arabic":"فَلَمَّا","translation":"অতঃপর যখন","audioUrl":"wbw/008_048_017.mp3","charTypeName":"word"},{"id":47528,"position":17,"arabic":"تَرَآءَتِ","translation":"পরস্পরে সম্মুখীন হলো","audioUrl":"wbw/008_048_018.mp3","charTypeName":"word"},{"id":47529,"position":18,"arabic":"ٱلْفِئَتَانِ","translation":"দু'দল","audioUrl":"wbw/008_048_019.mp3","charTypeName":"word"},{"id":47530,"position":19,"arabic":"نَكَصَ","translation":"সে সড়ে পড়লো","audioUrl":"wbw/008_048_020.mp3","charTypeName":"word"},{"id":47531,"position":20,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/008_048_021.mp3","charTypeName":"word"},{"id":47532,"position":21,"arabic":"عَقِبَيْهِ","translation":"দু'গোড়ালীর (অর্থাৎ পেছন দিকে)","audioUrl":"wbw/008_048_022.mp3","charTypeName":"word"},{"id":47533,"position":22,"arabic":"وَقَالَ","translation":"এবং বললো","audioUrl":"wbw/008_048_023.mp3","charTypeName":"word"},{"id":47534,"position":23,"arabic":"إِنِّى","translation":"\"নিশ্চয়ই আমি","audioUrl":"wbw/008_048_024.mp3","charTypeName":"word"},{"id":47535,"position":24,"arabic":"بَرِىٓءٌۭ","translation":"দায়িত্বমুক্ত","audioUrl":"wbw/008_048_025.mp3","charTypeName":"word"},{"id":47536,"position":25,"arabic":"مِّنكُمْ","translation":"থেকে তোমাদের","audioUrl":"wbw/008_048_026.mp3","charTypeName":"word"},{"id":47537,"position":26,"arabic":"إِنِّىٓ","translation":"নিশ্চয়ই আমি","audioUrl":"wbw/008_048_027.mp3","charTypeName":"word"},{"id":47538,"position":27,"arabic":"أَرَىٰ","translation":"দেখছি (ফেরেশতাদের)","audioUrl":"wbw/008_048_028.mp3","charTypeName":"word"},{"id":47539,"position":28,"arabic":"مَا","translation":"যা","audioUrl":"wbw/008_048_029.mp3","charTypeName":"word"},{"id":47540,"position":29,"arabic":"لَا","translation":"না","audioUrl":"wbw/008_048_030.mp3","charTypeName":"word"},{"id":47541,"position":30,"arabic":"تَرَوْنَ","translation":"তোমরা দেখতে পাচ্ছো","audioUrl":"wbw/008_048_031.mp3","charTypeName":"word"},{"id":47542,"position":31,"arabic":"إِنِّىٓ","translation":"নিশ্চয়ই আমি","audioUrl":"wbw/008_048_032.mp3","charTypeName":"word"},{"id":47543,"position":32,"arabic":"أَخَافُ","translation":"ভয় করি","audioUrl":"wbw/008_048_033.mp3","charTypeName":"word"},{"id":47544,"position":33,"arabic":"ٱللَّهَ ۚ","translation":"আল্লাহকে","audioUrl":"wbw/008_048_034.mp3","charTypeName":"word"},{"id":47546,"position":34,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/008_048_036.mp3","charTypeName":"word"},{"id":47547,"position":35,"arabic":"شَدِيدُ","translation":"কঠোর","audioUrl":"wbw/008_048_037.mp3","charTypeName":"word"},{"id":47548,"position":36,"arabic":"ٱلْعِقَابِ","translation":"দন্ডদানে\"","audioUrl":"wbw/008_048_038.mp3","charTypeName":"word"},{"id":47549,"position":37,"arabic":"٤٨","translation":"(৪৮)","audioUrl":null,"charTypeName":"end"}]},{"number":49,"arabic":"إِذْ يَقُولُ ٱلْمُنَٰفِقُونَ وَٱلَّذِينَ فِى قُلُوبِهِم مَّرَضٌ غَرَّ هَٰٓؤُلَآءِ دِينُهُمْ ۗ وَمَن يَتَوَكَّلْ عَلَى ٱللَّهِ فَإِنَّ ٱللَّهَ عَزِيزٌ حَكِيمٌۭ","translation":"At the same time, the hypocrites and those in whose hearts was disease were saying, \"Their faith has deluded these [believers]!\" But he who places his trust in God [knows that], verily, God is almighty, wise.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1209.mp3","surahId":8,"words":[{"id":47751,"position":1,"arabic":"إِذْ","translation":"(স্মরণ করো) যখন","audioUrl":"wbw/008_049_001.mp3","charTypeName":"word"},{"id":47752,"position":2,"arabic":"يَقُولُ","translation":"বলেছিলো","audioUrl":"wbw/008_049_002.mp3","charTypeName":"word"},{"id":47753,"position":3,"arabic":"ٱلْمُنَـٰفِقُونَ","translation":"মুনাফিক্বরা","audioUrl":"wbw/008_049_003.mp3","charTypeName":"word"},{"id":47754,"position":4,"arabic":"وَٱلَّذِينَ","translation":"ও যাদের","audioUrl":"wbw/008_049_004.mp3","charTypeName":"word"},{"id":47755,"position":5,"arabic":"فِى","translation":"মধ্যে (আছে)","audioUrl":"wbw/008_049_005.mp3","charTypeName":"word"},{"id":47756,"position":6,"arabic":"قُلُوبِهِم","translation":"অন্তরসমূহে তাদের","audioUrl":"wbw/008_049_006.mp3","charTypeName":"word"},{"id":47757,"position":7,"arabic":"مَّرَضٌ","translation":"রোগ","audioUrl":"wbw/008_049_007.mp3","charTypeName":"word"},{"id":47758,"position":8,"arabic":"غَرَّ","translation":"\"ধোঁকা দিয়েছে","audioUrl":"wbw/008_049_008.mp3","charTypeName":"word"},{"id":47759,"position":9,"arabic":"هَـٰٓؤُلَآءِ","translation":"এদেরকে","audioUrl":"wbw/008_049_009.mp3","charTypeName":"word"},{"id":47760,"position":10,"arabic":"دِينُهُمْ ۗ","translation":"দীন তাদের\"","audioUrl":"wbw/008_049_010.mp3","charTypeName":"word"},{"id":47762,"position":11,"arabic":"وَمَن","translation":"অথচ যে কেউ","audioUrl":"wbw/008_049_012.mp3","charTypeName":"word"},{"id":47763,"position":12,"arabic":"يَتَوَكَّلْ","translation":"নির্ভর করে","audioUrl":"wbw/008_049_013.mp3","charTypeName":"word"},{"id":47764,"position":13,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/008_049_014.mp3","charTypeName":"word"},{"id":47765,"position":14,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/008_049_015.mp3","charTypeName":"word"},{"id":47766,"position":15,"arabic":"فَإِنَّ","translation":"তবে নিশ্চয়ই","audioUrl":"wbw/008_049_016.mp3","charTypeName":"word"},{"id":47767,"position":16,"arabic":"ٱللَّهَ","translation":"আল্লাহই","audioUrl":"wbw/008_049_017.mp3","charTypeName":"word"},{"id":47768,"position":17,"arabic":"عَزِيزٌ","translation":"পরাক্রমশালী","audioUrl":"wbw/008_049_018.mp3","charTypeName":"word"},{"id":47769,"position":18,"arabic":"حَكِيمٌۭ","translation":"মহাবিজ্ঞ\"","audioUrl":"wbw/008_049_019.mp3","charTypeName":"word"},{"id":47770,"position":19,"arabic":"٤٩","translation":"(৪৯)","audioUrl":null,"charTypeName":"end"}]},{"number":50,"arabic":"وَلَوْ تَرَىٰٓ إِذْ يَتَوَفَّى ٱلَّذِينَ كَفَرُوا۟ ۙ ٱلْمَلَٰٓئِكَةُ يَضْرِبُونَ وُجُوهَهُمْ وَأَدْبَٰرَهُمْ وَذُوقُوا۟ عَذَابَ ٱلْحَرِيقِ","translation":"AND IF thou couldst but see [how it will be] when He causes those who are bent on denying the truth to die: the angels will strike their faces: and their backs, and [will say]: \"Taste suffering through fire","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1210.mp3","surahId":8,"words":[{"id":48650,"position":1,"arabic":"وَلَوْ","translation":"এবং যদি","audioUrl":"wbw/008_050_001.mp3","charTypeName":"word"},{"id":48651,"position":2,"arabic":"تَرَىٰٓ","translation":"দেখতে তুমি","audioUrl":"wbw/008_050_002.mp3","charTypeName":"word"},{"id":48652,"position":3,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/008_050_003.mp3","charTypeName":"word"},{"id":48653,"position":4,"arabic":"يَتَوَفَّى","translation":"প্রাণ কেড়ে নেয়","audioUrl":"wbw/008_050_004.mp3","charTypeName":"word"},{"id":48654,"position":5,"arabic":"ٱلَّذِينَ","translation":"(তাদেরকে) যারা","audioUrl":"wbw/008_050_005.mp3","charTypeName":"word"},{"id":48655,"position":6,"arabic":"كَفَرُوا۟ ۙ","translation":"অবিশ্বাস করেছে","audioUrl":"wbw/008_050_006.mp3","charTypeName":"word"},{"id":48657,"position":7,"arabic":"ٱلْمَلَـٰٓئِكَةُ","translation":"ফেরেশতারা","audioUrl":"wbw/008_050_008.mp3","charTypeName":"word"},{"id":48658,"position":8,"arabic":"يَضْرِبُونَ","translation":"তারা আঘাত করে","audioUrl":"wbw/008_050_009.mp3","charTypeName":"word"},{"id":48659,"position":9,"arabic":"وُجُوهَهُمْ","translation":"মুখমণ্ডলগুলোতে তাদের","audioUrl":"wbw/008_050_010.mp3","charTypeName":"word"},{"id":48660,"position":10,"arabic":"وَأَدْبَـٰرَهُمْ","translation":"ও পিঠগুলোতে তাদের","audioUrl":"wbw/008_050_011.mp3","charTypeName":"word"},{"id":48661,"position":11,"arabic":"وَذُوقُوا۟","translation":"\"এবং (বলো) তোমরা স্বাদ নাও","audioUrl":"wbw/008_050_012.mp3","charTypeName":"word"},{"id":48662,"position":12,"arabic":"عَذَابَ","translation":"শাস্তির","audioUrl":"wbw/008_050_013.mp3","charTypeName":"word"},{"id":48663,"position":13,"arabic":"ٱلْحَرِيقِ","translation":"দহনের\"","audioUrl":"wbw/008_050_014.mp3","charTypeName":"word"},{"id":48664,"position":14,"arabic":"٥٠","translation":"(৫০)","audioUrl":null,"charTypeName":"end"}]},{"number":51,"arabic":"ذَٰلِكَ بِمَا قَدَّمَتْ أَيْدِيكُمْ وَأَنَّ ٱللَّهَ لَيْسَ بِظَلَّٰمٍۢ لِّلْعَبِيدِ","translation":"in return for what your own hands have wrought - for, never does God do the least wrong to His creatures!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1211.mp3","surahId":8,"words":[{"id":49190,"position":1,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/008_051_001.mp3","charTypeName":"word"},{"id":49191,"position":2,"arabic":"بِمَا","translation":"একারণে যা","audioUrl":"wbw/008_051_002.mp3","charTypeName":"word"},{"id":49192,"position":3,"arabic":"قَدَّمَتْ","translation":"আগে পাঠিয়েছে","audioUrl":"wbw/008_051_003.mp3","charTypeName":"word"},{"id":49193,"position":4,"arabic":"أَيْدِيكُمْ","translation":"হাতগুলো তাদের","audioUrl":"wbw/008_051_004.mp3","charTypeName":"word"},{"id":49194,"position":5,"arabic":"وَأَنَّ","translation":"এবং (এটা সত্য যে)","audioUrl":"wbw/008_051_005.mp3","charTypeName":"word"},{"id":49195,"position":6,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/008_051_006.mp3","charTypeName":"word"},{"id":49196,"position":7,"arabic":"لَيْسَ","translation":"নন","audioUrl":"wbw/008_051_007.mp3","charTypeName":"word"},{"id":49197,"position":8,"arabic":"بِظَلَّـٰمٍۢ","translation":"অত্যাচারী","audioUrl":"wbw/008_051_008.mp3","charTypeName":"word"},{"id":49198,"position":9,"arabic":"لِّلْعَبِيدِ","translation":"প্রতি দাসদের","audioUrl":"wbw/008_051_009.mp3","charTypeName":"word"},{"id":49199,"position":10,"arabic":"٥١","translation":"(৫১)","audioUrl":null,"charTypeName":"end"}]},{"number":52,"arabic":"كَدَأْبِ ءَالِ فِرْعَوْنَ ۙ وَٱلَّذِينَ مِن قَبْلِهِمْ ۚ كَفَرُوا۟ بِـَٔايَٰتِ ٱللَّهِ فَأَخَذَهُمُ ٱللَّهُ بِذُنُوبِهِمْ ۗ إِنَّ ٱللَّهَ قَوِىٌّۭ شَدِيدُ ٱلْعِقَابِ","translation":"[To them shall happen.] the like of what happened to Pharaoh's people and those who lived before them: they denied the truth of God's messagesand so God took them to task for their sins. Verily, God is powerful, severe in retribution!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1212.mp3","surahId":8,"words":[{"id":49863,"position":1,"arabic":"كَدَأْبِ","translation":"মতো অভ্যাসের","audioUrl":"wbw/008_052_001.mp3","charTypeName":"word"},{"id":49864,"position":2,"arabic":"ءَالِ","translation":"বংশধরদের","audioUrl":"wbw/008_052_002.mp3","charTypeName":"word"},{"id":49865,"position":3,"arabic":"فِرْعَوْنَ ۙ","translation":"ফিরাউনের","audioUrl":"wbw/008_052_003.mp3","charTypeName":"word"},{"id":49867,"position":4,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা(ছিলো)","audioUrl":"wbw/008_052_005.mp3","charTypeName":"word"},{"id":49868,"position":5,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/008_052_006.mp3","charTypeName":"word"},{"id":49869,"position":6,"arabic":"قَبْلِهِمْ ۚ","translation":"পূর্ব তাদের(এদের সাথে তাই হবে)","audioUrl":"wbw/008_052_007.mp3","charTypeName":"word"},{"id":49871,"position":7,"arabic":"كَفَرُوا۟","translation":"তারা অবিশ্বাস করেছিলো","audioUrl":"wbw/008_052_009.mp3","charTypeName":"word"},{"id":49872,"position":8,"arabic":"بِـَٔايَـٰتِ","translation":"সাথে নিদর্শনগুলোর","audioUrl":"wbw/008_052_010.mp3","charTypeName":"word"},{"id":49873,"position":9,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/008_052_011.mp3","charTypeName":"word"},{"id":49874,"position":10,"arabic":"فَأَخَذَهُمُ","translation":"তাই ধরেছিলেন তাদেরকে","audioUrl":"wbw/008_052_012.mp3","charTypeName":"word"},{"id":49875,"position":11,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/008_052_013.mp3","charTypeName":"word"},{"id":49876,"position":12,"arabic":"بِذُنُوبِهِمْ ۗ","translation":"কারণে পাপগুলোর তাদের","audioUrl":"wbw/008_052_014.mp3","charTypeName":"word"},{"id":49878,"position":13,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/008_052_016.mp3","charTypeName":"word"},{"id":49879,"position":14,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/008_052_017.mp3","charTypeName":"word"},{"id":49880,"position":15,"arabic":"قَوِىٌّۭ","transl