034_047_007.mp3","charTypeName":"word"},{"id":46886,"position":8,"arabic":"إِنْ","translation":"(মূলতঃ) নেই","audioUrl":"wbw/034_047_009.mp3","charTypeName":"word"},{"id":46887,"position":9,"arabic":"أَجْرِىَ","translation":"পুরস্কার আমার","audioUrl":"wbw/034_047_010.mp3","charTypeName":"word"},{"id":46888,"position":10,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/034_047_011.mp3","charTypeName":"word"},{"id":46889,"position":11,"arabic":"عَلَى","translation":"কাছে","audioUrl":"wbw/034_047_012.mp3","charTypeName":"word"},{"id":46890,"position":12,"arabic":"ٱللَّهِ ۖ","translation":"আল্লাহরই","audioUrl":"wbw/034_047_013.mp3","charTypeName":"word"},{"id":46892,"position":13,"arabic":"وَهُوَ","translation":"এবং তিনি","audioUrl":"wbw/034_047_015.mp3","charTypeName":"word"},{"id":46893,"position":14,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/034_047_016.mp3","charTypeName":"word"},{"id":46894,"position":15,"arabic":"كُلِّ","translation":"সব","audioUrl":"wbw/034_047_017.mp3","charTypeName":"word"},{"id":46895,"position":16,"arabic":"شَىْءٍۢ","translation":"কিছুর","audioUrl":"wbw/034_047_018.mp3","charTypeName":"word"},{"id":46896,"position":17,"arabic":"شَهِيدٌۭ","translation":"প্রত্যক্ষ সাক্ষী\"","audioUrl":"wbw/034_047_019.mp3","charTypeName":"word"},{"id":46897,"position":18,"arabic":"٤٧","translation":"(৪৭)","audioUrl":null,"charTypeName":"end"}]},{"number":48,"arabic":"قُلْ إِنَّ رَبِّى يَقْذِفُ بِٱلْحَقِّ عَلَّٰمُ ٱلْغُيُوبِ","translation":"Say: “Verily, my Sustainer hurls the truth [against all that is false] He who fully knows all the things that are beyond the reach of a created being’s perception!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3654.mp3","surahId":34,"words":[{"id":47104,"position":1,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/034_048_001.mp3","charTypeName":"word"},{"id":47105,"position":2,"arabic":"إِنَّ","translation":"\"নিশ্চয়ই","audioUrl":"wbw/034_048_002.mp3","charTypeName":"word"},{"id":4