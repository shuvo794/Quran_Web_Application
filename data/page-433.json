{"id":433,"ayahs":[{"number":40,"arabic":"وَيَوْمَ يَحْشُرُهُمْ جَمِيعًۭا ثُمَّ يَقُولُ لِلْمَلَٰٓئِكَةِ أَهَٰٓؤُلَآءِ إِيَّاكُمْ كَانُوا۟ يَعْبُدُونَ","translation":"And [as for those who now deny the truth,] one Day He will gather them all together, and will ask the angels, “Was it you that they were wont to worship?”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3646.mp3","surahId":34,"words":[{"id":41795,"position":1,"arabic":"وَيَوْمَ","translation":"এবং যেদিন","audioUrl":"wbw/034_040_001.mp3","charTypeName":"word"},{"id":41796,"position":2,"arabic":"يَحْشُرُهُمْ","translation":"তিনি একত্র করবেন তাদের","audioUrl":"wbw/034_040_002.mp3","charTypeName":"word"},{"id":41797,"position":3,"arabic":"جَمِيعًۭا","translation":"সকলকে","audioUrl":"wbw/034_040_003.mp3","charTypeName":"word"},{"id":41798,"position":4,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/034_040_004.mp3","charTypeName":"word"},{"id":41799,"position":5,"arabic":"يَقُولُ","translation":"বলবেন","audioUrl":"wbw/034_040_005.mp3","charTypeName":"word"},{"id":41800,"position":6,"arabic":"لِلْمَلَـٰٓئِكَةِ","translation":"ফেরেশতাদেরকে","audioUrl":"wbw/034_040_006.mp3","charTypeName":"word"},{"id":41801,"position":7,"arabic":"أَهَـٰٓؤُلَآءِ","translation":"\"কি এরাই","audioUrl":"wbw/034_040_007.mp3","charTypeName":"word"},{"id":41802,"position":8,"arabic":"إِيَّاكُمْ","translation":"\"তোমাদেরকে","audioUrl":"wbw/034_040_008.mp3","charTypeName":"word"},{"id":41803,"position":9,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/034_040_009.mp3","charTypeName":"word"},{"id":41804,"position":10,"arabic":"يَعْبُدُونَ","translation":"তারা ইবাদাত করতো\"","audioUrl":"wbw/034_040_010.mp3","charTypeName":"word"},{"id":41805,"position":11,"arabic":"٤٠","translation":"(৪০)","audioUrl":null,"charTypeName":"end"}]},{"number":41,"arabic":"قَالُوا۟ سُبْحَٰنَكَ أَنتَ وَلِيُّنَا مِن دُونِهِم ۖ بَلْ كَانُوا۟ يَعْبُدُونَ ٱلْجِنَّ ۖ أَكْثَرُهُم بِهِم مُّؤْمِنُونَ","translation":"They will answer: “Limitless art Thou in Thy glory! Thou [alone] art close unto us, not they! Nay, [when they thought that they were worshipping us,] they were but [blindly] worshipping forces concealed from their senses; most of them believed in them.”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3647.mp3","surahId":34,"words":[{"id":42557,"position":1,"arabic":"قَالُوا۟","translation":"তারা বলবে","audioUrl":"wbw/034_041_001.mp3","charTypeName":"word"},{"id":42558,"position":2,"arabic":"سُبْحَـٰنَكَ","translation":"\"আপনার সত্ত্বা পবিত্র","audioUrl":"wbw/034_041_002.mp3","charTypeName":"word"},{"id":42559,"position":3,"arabic":"أَنتَ","translation":"আপনিই","audioUrl":"wbw/034_041_003.mp3","charTypeName":"word"},{"id":42560,"position":4,"arabic":"وَلِيُّنَا","translation":"আমাদের অভিভাবক","audioUrl":"wbw/034_041_004.mp3","charTypeName":"word"},{"id":42561,"position":5,"arabic":"مِن","translation":"ছাড়া","audioUrl":"wbw/034_041_005.mp3","charTypeName":"word"},{"id":42562,"position":6,"arabic":"دُونِهِم ۖ","translation":"তারা","audioUrl":"wbw/034_041_006.mp3","charTypeName":"word"},{"id":42564,"position":7,"arabic":"بَلْ","translation":"বরং","audioUrl":"wbw/034_041_008.mp3","charTypeName":"word"},{"id":42565,"position":8,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/034_041_009.mp3","charTypeName":"word"},{"id":42566,"position":9,"arabic":"يَعْبُدُونَ","translation":"তারা ইবাদাত করতো","audioUrl":"wbw/034_041_010.mp3","charTypeName":"word"},{"id":42567,"position":10,"arabic":"ٱلْجِنَّ ۖ","translation":"জিনদের","audioUrl":"wbw/034_041_011.mp3","charTypeName":"word"},{"id":42569,"position":11,"arabic":"أَكْثَرُهُم","translation":"অধিকাংশ তাদের","audioUrl":"wbw/034_041_013.mp3","charTypeName":"word"},{"id":42570,"position":12,"arabic":"بِهِم","translation":"উপর তাদের","audioUrl":"wbw/034_041_014.mp3","charTypeName":"word"},{"id":42571,"position":13,"arabic":"مُّؤْمِنُونَ","translation":"বিশ্বাসী (ছিলো)\"","audioUrl":"wbw/034_041_015.mp3","charTypeName":"word"},{"id":42572,"position":14,"arabic":"٤١","translation":"(৪১)","audioUrl":null,"charTypeName":"end"}]},{"number":42,"arabic":"فَٱلْيَوْمَ لَا يَمْلِكُ بَعْضُكُمْ لِبَعْضٍۢ نَّفْعًۭا وَلَا ضَرًّۭا وَنَقُولُ لِلَّذِينَ ظَلَمُوا۟ ذُوقُوا۟ عَذَابَ ٱلنَّارِ ٱلَّتِى كُنتُم بِهَا تُكَذِّبُونَ","translation":"And [on that Day God will say]: “None of you [created beings] has today any power to benefit or to harm another!” And [then] We shall say unto those who had been bent on evildoing: “Taste [now] that suffering through fire which you were wont to call a lie!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3648.mp3","surahId":34,"words":[{"id":43257,"position":1,"arabic":"فَٱلْيَوْمَ","translation":"সুতরাং আজ","audioUrl":"wbw/034_042_001.mp3","charTypeName":"word"},{"id":43258,"position":2,"arabic":"لَا","translation":"না","audioUrl":"wbw/034_042_002.mp3","charTypeName":"word"},{"id":43259,"position":3,"arabic":"يَمْلِكُ","translation":"ক্ষমতা হবে","audioUrl":"wbw/034_042_003.mp3","charTypeName":"word"},{"id":43260,"position":4,"arabic":"بَعْضُكُمْ","translation":"কেউ তোমাদের","audioUrl":"wbw/034_042_004.mp3","charTypeName":"word"},{"id":43261,"position":5,"arabic":"لِبَعْضٍۢ","translation":"জন্যে কারো","audioUrl":"wbw/034_042_005.mp3","charTypeName":"word"},{"id":43262,"position":6,"arabic":"نَّفْعًۭا","translation":"উপকার করার","audioUrl":"wbw/034_042_006.mp3","charTypeName":"word"},{"id":43263,"position":7,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/034_042_007.mp3","charTypeName":"word"},{"id":43264,"position":8,"arabic":"ضَرًّۭا","translation":"ক্ষতি করার","audioUrl":"wbw/034_042_008.mp3","charTypeName":"word"},{"id":43265,"position":9,"arabic":"وَنَقُولُ","translation":"এবং আমরা বলবো","audioUrl":"wbw/034_042_009.mp3","charTypeName":"word"},{"id":43266,"position":10,"arabic":"لِلَّذِينَ","translation":"উদ্দেশ্যে (তাদের) যারা","audioUrl":"wbw/034_042_010.mp3","charTypeName":"word"},{"id":43267,"position":11,"arabic":"ظَلَمُوا۟","translation":"সীমালঙ্ঘন করেছিলো","audioUrl":"wbw/034_042_011.mp3","charTypeName":"word"},{"id":43268,"position":12,"arabic":"ذُوقُوا۟","translation":"\"তোমরা আস্বাদন করো","audioUrl":"wbw/034_042_012.mp3","charTypeName":"word"},{"id":43269,"position":13,"arabic":"عَذَابَ","translation":"শাস্তির","audioUrl":"wbw/034_042_013.mp3","charTypeName":"word"},{"id":43270,"position":14,"arabic":"ٱلنَّارِ","translation":"আগুনের","audioUrl":"wbw/034_042_014.mp3","charTypeName":"word"},{"id":43271,"position":15,"arabic":"ٱلَّتِى","translation":"যা","audioUrl":"wbw/034_042_015.mp3","charTypeName":"word"},{"id":43272,"position":16,"arabic":"كُنتُم","translation":"তোমরা ছিলে","audioUrl":"wbw/034_042_016.mp3","charTypeName":"word"},{"id":43273,"position":17,"arabic":"بِهَا","translation":"সম্পর্কে সে","audioUrl":"wbw/034_042_017.mp3","charTypeName":"word"},{"id":43274,"position":18,"arabic":"تُكَذِّبُونَ","translation":"অস্বীকার করতে\"","audioUrl":"wbw/034_042_018.mp3","charTypeName":"word"},{"id":43275,"position":19,"arabic":"٤٢","translation":"(৪২)","audioUrl":null,"charTypeName":"end"}]},{"number":43,"arabic":"وَإِذَا تُتْلَىٰ عَلَيْهِمْ ءَايَٰتُنَا بَيِّنَٰتٍۢ قَالُوا۟ مَا هَٰذَآ إِلَّا رَجُلٌۭ يُرِيدُ أَن يَصُدَّكُمْ عَمَّا كَانَ يَعْبُدُ ءَابَآؤُكُمْ وَقَالُوا۟ مَا هَٰذَآ إِلَّآ إِفْكٌۭ مُّفْتَرًۭى ۚ وَقَالَ ٱلَّذِينَ كَفَرُوا۟ لِلْحَقِّ لَمَّا جَآءَهُمْ إِنْ هَٰذَآ إِلَّا سِحْرٌۭ مُّبِينٌۭ","translation":"For [thus it is:] whenever Our messages are conveyed unto them in all their clarity, they [who are bent on denying the truth] say [to one another], “This [Muhammad] is nothing but a man who wants to turn you away from what your forefathers were wont to worship!” And they say, “This [Qur’an] is nothing but a falsehood invented [by man]!” And [finally,] they who are bent on denying the truth speak thus of the truth when it comes to them: “This is clearly nothing but spellbinding eloquence!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3649.mp3","surahId":34,"words":[{"id":44025,"position":1,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/034_043_001.mp3","charTypeName":"word"},{"id":44026,"position":2,"arabic":"تُتْلَىٰ","translation":"তিলাওয়াত করা হয়","audioUrl":"wbw/034_043_002.mp3","charTypeName":"word"},{"id":44027,"position":3,"arabic":"عَلَيْهِمْ","translation":"কাছে তাদের","audioUrl":"wbw/034_043_003.mp3","charTypeName":"word"},{"id":44028,"position":4,"arabic":"ءَايَـٰتُنَا","translation":"আয়াতগুলো আমাদের","audioUrl":"wbw/034_043_004.mp3","charTypeName":"word"},{"id":44029,"position":5,"arabic":"بَيِّنَـٰتٍۢ","translation":"সুস্পষ্ট","audioUrl":"wbw/034_043_005.mp3","charTypeName":"word"},{"id":44030,"position":6,"arabic":"قَالُوا۟","translation":"তারা বলে","audioUrl":"wbw/034_043_006.mp3","charTypeName":"word"},{"id":44031,"position":7,"arabic":"مَا","translation":"\"নয়","audioUrl":"wbw/034_043_007.mp3","charTypeName":"word"},{"id":44032,"position":8,"arabic":"هَـٰذَآ","translation":"এই সে","audioUrl":"wbw/034_043_008.mp3","charTypeName":"word"},{"id":44033,"position":9,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/034_043_009.mp3","charTypeName":"word"},{"id":44034,"position":10,"arabic":"رَجُلٌۭ","translation":"একজন মানুষ","audioUrl":"wbw/034_043_010.mp3","charTypeName":"word"},{"id":44035,"position":11,"arabic":"يُرِيدُ","translation":"সে চায়","audioUrl":"wbw/034_043_011.mp3","charTypeName":"word"},{"id":44036,"position":12,"arabic":"أَن","translation":"যে","audioUrl":"wbw/034_043_012.mp3","charTypeName":"word"},{"id":44037,"position":13,"arabic":"يَصُدَّكُمْ","translation":"বাধা দিবে তোমাদিগকে","audioUrl":"wbw/034_043_013.mp3","charTypeName":"word"},{"id":44038,"position":14,"arabic":"عَمَّا","translation":"(ঐগুলো) হ'তে যার","audioUrl":"wbw/034_043_014.mp3","charTypeName":"word"},{"id":44039,"position":15,"arabic":"كَانَ","translation":"সে ছিলো","audioUrl":"wbw/034_043_015.mp3","charTypeName":"word"},{"id":44040,"position":16,"arabic":"يَعْبُدُ","translation":"ইবাদাত করে এসেছে","audioUrl":"wbw/034_043_016.mp3","charTypeName":"word"},{"id":44041,"position":17,"arabic":"ءَابَآؤُكُمْ","translation":"পিতৃপুরুষরা তোমাদের\"","audioUrl":"wbw/034_043_017.mp3","charTypeName":"word"},{"id":44042,"position":18,"arabic":"وَقَالُوا۟","translation":"এবং তারা বলে","audioUrl":"wbw/034_043_018.mp3","charTypeName":"word"},{"id":44043,"position":19,"arabic":"مَا","translation":"\"নয়","audioUrl":"wbw/034_043_019.mp3","charTypeName":"word"},{"id":44044,"position":20,"arabic":"هَـٰذَآ","translation":"এই (কুরআন)","audioUrl":"wbw/034_043_020.mp3","charTypeName":"word"},{"id":44045,"position":21,"arabic":"إِلَّآ","translation":"এ ছাড়া","audioUrl":"wbw/034_043_021.mp3","charTypeName":"word"},{"id":44046,"position":22,"arabic":"إِفْكٌۭ","translation":"মিথ্যা রচনা","audioUrl":"wbw/034_043_022.mp3","charTypeName":"word"},{"id":44047,"position":23,"arabic":"مُّفْتَرًۭى ۚ","translation":"মনগড়া\"","audioUrl":"wbw/034_043_023.mp3","charTypeName":"word"},{"id":44049,"position":24,"arabic":"وَقَالَ","translation":"এবং বলে","audioUrl":"wbw/034_043_025.mp3","charTypeName":"word"},{"id":44050,"position":25,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/034_043_026.mp3","charTypeName":"word"},{"id":44051,"position":26,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/034_043_027.mp3","charTypeName":"word"},{"id":44052,"position":27,"arabic":"لِلْحَقِّ","translation":"প্রতি সত্যের","audioUrl":"wbw/034_043_028.mp3","charTypeName":"word"},{"id":44053,"position":28,"arabic":"لَمَّا","translation":"যখন","audioUrl":"wbw/034_043_029.mp3","charTypeName":"word"},{"id":44054,"position":29,"arabic":"جَآءَهُمْ","translation":"এসেছে তাদের (কাছে)","audioUrl":"wbw/034_043_030.mp3","charTypeName":"word"},{"id":44055,"position":30,"arabic":"إِنْ","translation":"\"নয়","audioUrl":"wbw/034_043_031.mp3","charTypeName":"word"},{"id":44056,"position":31,"arabic":"هَـٰذَآ","translation":"এটা","audioUrl":"wbw/034_043_032.mp3","charTypeName":"word"},{"id":44057,"position":32,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/034_043_033.mp3","charTypeName":"word"},{"id":44058,"position":33,"arabic":"سِحْرٌۭ","translation":"জাদু","audioUrl":"wbw/034_043_034.mp3","charTypeName":"word"},{"id":44059,"position":34,"arabic":"مُّبِينٌۭ","translation":"সুস্পষ্ট\"","audioUrl":"wbw/034_043_035.mp3","charTypeName":"word"},{"id":44060,"position":35,"arabic":"٤٣","translation":"(৪৩)","audioUrl":null,"charTypeName":"end"}]},{"number":44,"arabic":"وَمَآ ءَاتَيْنَٰهُم مِّن كُتُبٍۢ يَدْرُسُونَهَا ۖ وَمَآ أَرْسَلْنَآ إِلَيْهِمْ قَبْلَكَ مِن نَّذِيرٍۢ","translation":"And yet, [O Muhammad,] never have We vouchsafed them any revelations which they could quote, and neither have We sent unto them any warner before thee.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3650.mp3","surahId":34,"words":[{"id":44811,"position":1,"arabic":"وَمَآ","translation":"অথচ না","audioUrl":"wbw/034_044_001.mp3","charTypeName":"word"},{"id":44812,"position":2,"arabic":"ءَاتَيْنَـٰهُم","translation":"আমরা দিয়েছি তাদেরকে","audioUrl":"wbw/034_044_002.mp3","charTypeName":"word"},{"id":44813,"position":3,"arabic":"مِّن","translation":"(কোন কিতাব) মধ্য হ'তে","audioUrl":"wbw/034_044_003.mp3","charTypeName":"word"},{"id":44814,"position":4,"arabic":"كُتُبٍۢ","translation":"কিতাবসমূহের","audioUrl":"wbw/034_044_004.mp3","charTypeName":"word"},{"id":44815,"position":5,"arabic":"يَدْرُسُونَهَا ۖ","translation":"তারা অধ্যয়ন করতো যা","audioUrl":"wbw/034_044_005.mp3","charTypeName":"word"},{"id":44817,"position":6,"arabic":"وَمَآ","translation":"আর না","audioUrl":"wbw/034_044_007.mp3","charTypeName":"word"},{"id":44818,"position":7,"arabic":"أَرْسَلْنَآ","translation":"পাঠিয়েছি অামরা","audioUrl":"wbw/034_044_008.mp3","charTypeName":"word"},{"id":44819,"position":8,"arabic":"إِلَيْهِمْ","translation":"কাছে তোমার","audioUrl":"wbw/034_044_009.mp3","charTypeName":"word"},{"id":44820,"position":9,"arabic":"قَبْلَكَ","translation":"পূর্বে তোমার","audioUrl":"wbw/034_044_010.mp3","charTypeName":"word"},{"id":44821,"position":10,"arabic":"مِن","translation":"কোনো","audioUrl":"wbw/034_044_011.mp3","charTypeName":"word"},{"id":44822,"position":11,"arabic":"نَّذِيرٍۢ","translation":"সতর্ককারী","audioUrl":"wbw/034_044_012.mp3","charTypeName":"word"},{"id":44823,"position":12,"arabic":"٤٤","translation":"(৪৪)","audioUrl":null,"charTypeName":"end"}]},{"number":45,"arabic":"وَكَذَّبَ ٱلَّذِينَ مِن قَبْلِهِمْ وَمَا بَلَغُوا۟ مِعْشَارَ مَآ ءَاتَيْنَٰهُمْ فَكَذَّبُوا۟ رُسُلِى ۖ فَكَيْفَ كَانَ نَكِيرِ","translation":"Thus, too, gave the lie to the truth [many of] those who lived before them; and although those [earlier people] had not attained to even a tenth of [the evidence of the truth] which We have vouch­safed unto these [late successors of theirs], yet when they gave the lie to My apostles, how awesome was My rejection!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3651.mp3","surahId":34,"words":[{"id":45449,"position":1,"arabic":"وَكَذَّبَ","translation":"এবং মিথ্যারোপ করেছিলো","audioUrl":"wbw/034_045_001.mp3","charTypeName":"word"},{"id":45450,"position":2,"arabic":"ٱلَّذِينَ","translation":"(তারাও) যারা","audioUrl":"wbw/034_045_002.mp3","charTypeName":"word"},{"id":45451,"position":3,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/034_045_003.mp3","charTypeName":"word"},{"id":45452,"position":4,"arabic":"قَبْلِهِمْ","translation":"পূর্ব (ছিলো)তাদের","audioUrl":"wbw/034_045_004.mp3","charTypeName":"word"},{"id":45453,"position":5,"arabic":"وَمَا","translation":"এবং নি","audioUrl":"wbw/034_045_005.mp3","charTypeName":"word"},{"id":45454,"position":6,"arabic":"بَلَغُوا۟","translation":"(এদের কাছে) পৌঁছেছে","audioUrl":"wbw/034_045_006.mp3","charTypeName":"word"},{"id":45455,"position":7,"arabic":"مِعْشَارَ","translation":"দশ ভাগের এক ভাগও","audioUrl":"wbw/034_045_007.mp3","charTypeName":"word"},{"id":45456,"position":8,"arabic":"مَآ","translation":"যা","audioUrl":"wbw/034_045_008.mp3","charTypeName":"word"},{"id":45457,"position":9,"arabic":"ءَاتَيْنَـٰهُمْ","translation":"আমরা (ওদেরকে) দিয়েছিলাম","audioUrl":"wbw/034_045_009.mp3","charTypeName":"word"},{"id":45458,"position":10,"arabic":"فَكَذَّبُوا۟","translation":"কিন্তু মিথ্যারোপ করেছিলো ওরা","audioUrl":"wbw/034_045_010.mp3","charTypeName":"word"},{"id":45459,"position":11,"arabic":"رُسُلِى ۖ","translation":"রাসূলদেরকে আমার","audioUrl":"wbw/034_045_011.mp3","charTypeName":"word"},{"id":45461,"position":12,"arabic":"فَكَيْفَ","translation":"(দেখো) তখন কেমন","audioUrl":"wbw/034_045_013.mp3","charTypeName":"word"},{"id":45462,"position":13,"arabic":"كَانَ","translation":"ছিলো","audioUrl":"wbw/034_045_014.mp3","charTypeName":"word"},{"id":45463,"position":14,"arabic":"نَكِيرِ","translation":"আমার শাস্তি","audioUrl":"wbw/034_045_015.mp3","charTypeName":"word"},{"id":45464,"position":15,"arabic":"٤٥","translation":"(৪৫)","audioUrl":null,"charTypeName":"end"}]},{"number":46,"arabic":"۞ قُلْ إِنَّمَآ أَعِظُكُم بِوَٰحِدَةٍ ۖ أَن تَقُومُوا۟ لِلَّهِ مَثْنَىٰ وَفُرَٰدَىٰ ثُمَّ تَتَفَكَّرُوا۟ ۚ مَا بِصَاحِبِكُم مِّن جِنَّةٍ ۚ إِنْ هُوَ إِلَّا نَذِيرٌۭ لَّكُم بَيْنَ يَدَىْ عَذَابٍۢ شَدِيدٍۢ","translation":"Say: “I counsel you one thing only: Be [ever­ conscious of] standing before God, whether you are in the company of others or alone; and then bethink yourselves [that] there is no madness in [this pro­phet,] your fellow-man: he is only a warner to you of suffering severe to come.”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3652.mp3","surahId":34,"words":[{"id":45667,"position":1,"arabic":"۞ قُلْ","translation":"বলো","audioUrl":"wbw/034_046_002.mp3","charTypeName":"word"},{"id":45668,"position":2,"arabic":"إِنَّمَآ","translation":"\"কেবল","audioUrl":"wbw/034_046_003.mp3","charTypeName":"word"},{"id":45669,"position":3,"arabic":"أَعِظُكُم","translation":"আমি উপদেশ দিচ্ছি তোমাদেরকে","audioUrl":"wbw/034_046_004.mp3","charTypeName":"word"},{"id":45670,"position":4,"arabic":"بِوَٰحِدَةٍ ۖ","translation":"সম্পর্কে একটি (বিষয়)","audioUrl":"wbw/034_046_005.mp3","charTypeName":"word"},{"id":45672,"position":5,"arabic":"أَن","translation":"যে","audioUrl":"wbw/034_046_007.mp3","charTypeName":"word"},{"id":45673,"position":6,"arabic":"تَقُومُوا۟","translation":"তোমরা দাঁড়াও","audioUrl":"wbw/034_046_008.mp3","charTypeName":"word"},{"id":45674,"position":7,"arabic":"لِلَّهِ","translation":"উদ্দেশ্যে আল্লাহ তা'লার","audioUrl":"wbw/034_046_009.mp3","charTypeName":"word"},{"id":45675,"position":8,"arabic":"مَثْنَىٰ","translation":"দুই দুই জন","audioUrl":"wbw/034_046_010.mp3","charTypeName":"word"},{"id":45676,"position":9,"arabic":"وَفُرَٰدَىٰ","translation":"অথবা এক এক জন","audioUrl":"wbw/034_046_011.mp3","charTypeName":"word"},{"id":45677,"position":10,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/034_046_012.mp3","charTypeName":"word"},{"id":45678,"position":11,"arabic":"تَتَفَكَّرُوا۟ ۚ","translation":"তোমরা চিন্তা করে দেখো\"","audioUrl":"wbw/034_046_013.mp3","charTypeName":"word"},{"id":45680,"position":12,"arabic":"مَا","translation":"নেই","audioUrl":"wbw/034_046_015.mp3","charTypeName":"word"},{"id":45681,"position":13,"arabic":"بِصَاحِبِكُم","translation":"মধ্যে সাথীর তোমাদের","audioUrl":"wbw/034_046_016.mp3","charTypeName":"word"},{"id":45682,"position":14,"arabic":"مِّن","translation":"কোনো","audioUrl":"wbw/034_046_017.mp3","charTypeName":"word"},{"id":45683,"position":15,"arabic":"جِنَّةٍ ۚ","translation":"পাগলামীর (লেশমাত্রও)","audioUrl":"wbw/034_046_018.mp3","charTypeName":"word"},{"id":45685,"position":16,"arabic":"إِنْ","translation":"নয়","audioUrl":"wbw/034_046_020.mp3","charTypeName":"word"},{"id":45686,"position":17,"arabic":"هُوَ","translation":"সে","audioUrl":"wbw/034_046_021.mp3","charTypeName":"word"},{"id":45687,"position":18,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/034_046_022.mp3","charTypeName":"word"},{"id":45688,"position":19,"arabic":"نَذِيرٌۭ","translation":"একজন সতর্ককারী","audioUrl":"wbw/034_046_023.mp3","charTypeNam