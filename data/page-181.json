"translation":"ক্ষতিগ্রস্ত","audioUrl":"wbw/008_037_019.mp3","charTypeName":"word"},{"id":38834,"position":19,"arabic":"٣٧","translation":"(৩৭)","audioUrl":null,"charTypeName":"end"}]},{"number":38,"arabic":"قُل لِّلَّذِينَ كَفَرُوٓا۟ إِن يَنتَهُوا۟ يُغْفَرْ لَهُم مَّا قَدْ سَلَفَ وَإِن يَعُودُوا۟ فَقَدْ مَضَتْ سُنَّتُ ٱلْأَوَّلِينَ","translation":"Tell those who are bent on denying the truth that if they desist, all that is past shall be forgiven them; but if they revert [to their wrongdoing], let them remember what happened to the like of them in times gone by.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1198.mp3","surahId":8,"words":[{"id":39705,"position":1,"arabic":"قُل","translation":"বলো","audioUrl":"wbw/008_038_001.mp3","charTypeName":"word"},{"id":39706,"position":2,"arabic":"لِّلَّذِينَ","translation":"উদ্দেশ্যে (তাদের) যারা","audioUrl":"wbw/008_038_002.mp3","charTypeName":"word"},{"id":39707,"position":3,"arabic":"كَفَرُوٓا۟","translation":"অবিশ্বাস করেছে","audioUrl":"wbw/008_038_003.mp3","charTypeName":"word"},{"id":39708,"position":4,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/008_038_004.mp3","charTypeName":"word"},{"id":39709,"position":5,"arabic":"يَنتَهُوا۟","translation":"তারা বিরত হয়","audioUrl":"wbw/008_038_005.mp3","charTypeName":"word"},{"id":39710,"position":6,"arabic":"يُغْفَرْ","translation":"ক্ষমা করে দেয়া হবে","audioUrl":"wbw/008_038_006.mp3","charTypeName":"word"},{"id":39711,"position":7,"arabic":"لَهُم","translation":"প্রতি তাদের","audioUrl":"wbw/008_038_007.mp3","charTypeName":"word"},{"id":39712,"position":8,"arabic":"مَّا","translation":"যা","audioUrl":"wbw/008_038_008.mp3","charTypeName":"word"},{"id":39713,"position":9,"arabic":"قَدْ","translation":"নিশ্চিত","audioUrl":"wbw/008_038_009.mp3","charTypeName":"word"},{"id":39714,"position":10,"arabic":"سَلَفَ","translation":"অতীত হয়েছে","audioUrl":"wbw/008_038_010.mp3","charTypeName":"word"},{"id":39715,"position":11,"arabic":"وَإِن","translation":"কিন্তু