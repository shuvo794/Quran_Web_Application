{"id":181,"ayahs":[{"number":34,"arabic":"وَمَا لَهُمْ أَلَّا يُعَذِّبَهُمُ ٱللَّهُ وَهُمْ يَصُدُّونَ عَنِ ٱلْمَسْجِدِ ٱلْحَرَامِ وَمَا كَانُوٓا۟ أَوْلِيَآءَهُۥٓ ۚ إِنْ أَوْلِيَآؤُهُۥٓ إِلَّا ٱلْمُتَّقُونَ وَلَٰكِنَّ أَكْثَرَهُمْ لَا يَعْلَمُونَ","translation":"But what have they [now] in their favour that God should not chastise them-seeing that they bar [the believers] from the Inviolable House of Worship, although they are not its [rightful] guardians? None but the God-conscious can be its guardians: but of this most of these [evildoers] are unaware;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1194.mp3","surahId":8,"words":[{"id":36468,"position":1,"arabic":"وَمَا","translation":"এবং (এখন এমন) কি (রয়েছে)","audioUrl":"wbw/008_034_001.mp3","charTypeName":"word"},{"id":36469,"position":2,"arabic":"لَهُمْ","translation":"জন্যে তাদের","audioUrl":"wbw/008_034_002.mp3","charTypeName":"word"},{"id":36470,"position":3,"arabic":"أَلَّا","translation":"যে না","audioUrl":"wbw/008_034_003.mp3","charTypeName":"word"},{"id":36471,"position":4,"arabic":"يُعَذِّبَهُمُ","translation":"শাস্তি দিবেন তাদের","audioUrl":"wbw/008_034_004.mp3","charTypeName":"word"},{"id":36472,"position":5,"arabic":"ٱللَّهُ","translation":"আল্লাহ (যখন তুমি নাই)","audioUrl":"wbw/008_034_005.mp3","charTypeName":"word"},{"id":36473,"position":6,"arabic":"وَهُمْ","translation":"আর তারা","audioUrl":"wbw/008_034_006.mp3","charTypeName":"word"},{"id":36474,"position":7,"arabic":"يَصُدُّونَ","translation":"(পথ) রোধ করছে","audioUrl":"wbw/008_034_007.mp3","charTypeName":"word"},{"id":36475,"position":8,"arabic":"عَنِ","translation":"হতে","audioUrl":"wbw/008_034_008.mp3","charTypeName":"word"},{"id":36476,"position":9,"arabic":"ٱلْمَسْجِدِ","translation":"মাসজীদুল","audioUrl":"wbw/008_034_009.mp3","charTypeName":"word"},{"id":36477,"position":10,"arabic":"ٱلْحَرَامِ","translation":"হারাম","audioUrl":"wbw/008_034_010.mp3","charTypeName":"word"},{"id":36478,"position":11,"arabic":"وَمَا","translation":"অথচ না","audioUrl":"wbw/008_034_011.mp3","charTypeName":"word"},{"id":36479,"position":12,"arabic":"كَانُوٓا۟","translation":"তারা হলো","audioUrl":"wbw/008_034_012.mp3","charTypeName":"word"},{"id":36480,"position":13,"arabic":"أَوْلِيَآءَهُۥٓ ۚ","translation":"তত্ত্বাবধায়ক তার","audioUrl":"wbw/008_034_013.mp3","charTypeName":"word"},{"id":36482,"position":14,"arabic":"إِنْ","translation":"(প্রকৃতপক্ষে) না","audioUrl":"wbw/008_034_015.mp3","charTypeName":"word"},{"id":36483,"position":15,"arabic":"أَوْلِيَآؤُهُۥٓ","translation":"তত্ত্বাবধায়ক তার","audioUrl":"wbw/008_034_016.mp3","charTypeName":"word"},{"id":36484,"position":16,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/008_034_017.mp3","charTypeName":"word"},{"id":36485,"position":17,"arabic":"ٱلْمُتَّقُونَ","translation":"(যারা) মুত্তাক্বী","audioUrl":"wbw/008_034_018.mp3","charTypeName":"word"},{"id":36486,"position":18,"arabic":"وَلَـٰكِنَّ","translation":"কিন্তু","audioUrl":"wbw/008_034_019.mp3","charTypeName":"word"},{"id":36487,"position":19,"arabic":"أَكْثَرَهُمْ","translation":"অধিকাংশ তাদের","audioUrl":"wbw/008_034_020.mp3","charTypeName":"word"},{"id":36488,"position":20,"arabic":"لَا","translation":"না","audioUrl":"wbw/008_034_021.mp3","charTypeName":"word"},{"id":36489,"position":21,"arabic":"يَعْلَمُونَ","translation":"জানে","audioUrl":"wbw/008_034_022.mp3","charTypeName":"word"},{"id":36490,"position":22,"arabic":"٣٤","translation":"(৩৪)","audioUrl":null,"charTypeName":"end"}]},{"number":35,"arabic":"وَمَا كَانَ صَلَاتُهُمْ عِندَ ٱلْبَيْتِ إِلَّا مُكَآءًۭ وَتَصْدِيَةًۭ ۚ فَذُوقُوا۟ ٱلْعَذَابَ بِمَا كُنتُمْ تَكْفُرُونَ","translation":"and their prayers before the Temple are nothing but whistling and clapping of hands. Taste then, [O unbelievers,] this chastisement as an outcome of your persistent denial of the truth!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1195.mp3","surahId":8,"words":[{"id":37177,"position":1,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/008_035_001.mp3","charTypeName":"word"},{"id":37178,"position":2,"arabic":"كَانَ","translation":"ছিলো","audioUrl":"wbw/008_035_002.mp3","charTypeName":"word"},{"id":37179,"position":3,"arabic":"صَلَاتُهُمْ","translation":"সালাত তাদের","audioUrl":"wbw/008_035_003.mp3","charTypeName":"word"},{"id":37180,"position":4,"arabic":"عِندَ","translation":"কাছে","audioUrl":"wbw/008_035_004.mp3","charTypeName":"word"},{"id":37181,"position":5,"arabic":"ٱلْبَيْتِ","translation":"(কা'বা) ঘরের","audioUrl":"wbw/008_035_005.mp3","charTypeName":"word"},{"id":37182,"position":6,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/008_035_006.mp3","charTypeName":"word"},{"id":37183,"position":7,"arabic":"مُكَآءًۭ","translation":"শিষ দেওয়া","audioUrl":"wbw/008_035_007.mp3","charTypeName":"word"},{"id":37184,"position":8,"arabic":"وَتَصْدِيَةًۭ ۚ","translation":"ও করতালি বাজানো","audioUrl":"wbw/008_035_008.mp3","charTypeName":"word"},{"id":37186,"position":9,"arabic":"فَذُوقُوا۟","translation":"অতএব তোমরা স্বাদ নাও","audioUrl":"wbw/008_035_010.mp3","charTypeName":"word"},{"id":37187,"position":10,"arabic":"ٱلْعَذَابَ","translation":"শাস্তির","audioUrl":"wbw/008_035_011.mp3","charTypeName":"word"},{"id":37188,"position":11,"arabic":"بِمَا","translation":"এ কারণে যা","audioUrl":"wbw/008_035_012.mp3","charTypeName":"word"},{"id":37189,"position":12,"arabic":"كُنتُمْ","translation":"তোমরা ছিলে","audioUrl":"wbw/008_035_013.mp3","charTypeName":"word"},{"id":37190,"position":13,"arabic":"تَكْفُرُونَ","translation":"তোমরা অবিশ্বাস করতে","audioUrl":"wbw/008_035_014.mp3","charTypeName":"word"},{"id":37191,"position":14,"arabic":"٣٥","translation":"(৩৫)","audioUrl":null,"charTypeName":"end"}]},{"number":36,"arabic":"إِنَّ ٱلَّذِينَ كَفَرُوا۟ يُنفِقُونَ أَمْوَٰلَهُمْ لِيَصُدُّوا۟ عَن سَبِيلِ ٱللَّهِ ۚ فَسَيُنفِقُونَهَا ثُمَّ تَكُونُ عَلَيْهِمْ حَسْرَةًۭ ثُمَّ يُغْلَبُونَ ۗ وَٱلَّذِينَ كَفَرُوٓا۟ إِلَىٰ جَهَنَّمَ يُحْشَرُونَ","translation":"Behold, those who are bent on denying the truth are spending their riches in order to turn others away from the path of God; and they will go on spending them until they become [a source of] intense regret for them; and then they will be overcome! And those who [until their death] have denied the truth shall be gathered unto hell,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1196.mp3","surahId":8,"words":[{"id":37978,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/008_036_001.mp3","charTypeName":"word"},{"id":37979,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/008_036_002.mp3","charTypeName":"word"},{"id":37980,"position":3,"arabic":"كَفَرُوا۟","translation":"অবিশ্বাস করেছে","audioUrl":"wbw/008_036_003.mp3","charTypeName":"word"},{"id":37981,"position":4,"arabic":"يُنفِقُونَ","translation":"তারা ব্যয় করে","audioUrl":"wbw/008_036_004.mp3","charTypeName":"word"},{"id":37982,"position":5,"arabic":"أَمْوَٰلَهُمْ","translation":"সম্পদসমূহকে তাদের","audioUrl":"wbw/008_036_005.mp3","charTypeName":"word"},{"id":37983,"position":6,"arabic":"لِيَصُدُّوا۟","translation":"জন্যে বাধা দেওয়ার","audioUrl":"wbw/008_036_006.mp3","charTypeName":"word"},{"id":37984,"position":7,"arabic":"عَن","translation":"হতে","audioUrl":"wbw/008_036_007.mp3","charTypeName":"word"},{"id":37985,"position":8,"arabic":"سَبِيلِ","translation":"পথ","audioUrl":"wbw/008_036_008.mp3","charTypeName":"word"},{"id":37986,"position":9,"arabic":"ٱللَّهِ ۚ","translation":"আল্লাহর","audioUrl":"wbw/008_036_009.mp3","charTypeName":"word"},{"id":37988,"position":10,"arabic":"فَسَيُنفِقُونَهَا","translation":"অতঃপর অচিরেই তারা খরচ করতে থাকবে তা","audioUrl":"wbw/008_036_011.mp3","charTypeName":"word"},{"id":37989,"position":11,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/008_036_012.mp3","charTypeName":"word"},{"id":37990,"position":12,"arabic":"تَكُونُ","translation":"তা হবে","audioUrl":"wbw/008_036_013.mp3","charTypeName":"word"},{"id":37991,"position":13,"arabic":"عَلَيْهِمْ","translation":"উপর তাদের","audioUrl":"wbw/008_036_014.mp3","charTypeName":"word"},{"id":37992,"position":14,"arabic":"حَسْرَةًۭ","translation":"অাক্ষেপ","audioUrl":"wbw/008_036_015.mp3","charTypeName":"word"},{"id":37993,"position":15,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/008_036_016.mp3","charTypeName":"word"},{"id":37994,"position":16,"arabic":"يُغْلَبُونَ ۗ","translation":"তারা পরাজিত হবে","audioUrl":"wbw/008_036_017.mp3","charTypeName":"word"},{"id":37996,"position":17,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/008_036_019.mp3","charTypeName":"word"},{"id":37997,"position":18,"arabic":"كَفَرُوٓا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/008_036_020.mp3","charTypeName":"word"},{"id":37998,"position":19,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/008_036_021.mp3","charTypeName":"word"},{"id":37999,"position":20,"arabic":"جَهَنَّمَ","translation":"জাহান্নামের","audioUrl":"wbw/008_036_022.mp3","charTypeName":"word"},{"id":38000,"position":21,"arabic":"يُحْشَرُونَ","translation":"তাদের একত্র করা হবে","audioUrl":"wbw/008_036_023.mp3","charTypeName":"word"},{"id":38001,"position":22,"arabic":"٣٦","translation":"(৩৬)","audioUrl":null,"charTypeName":"end"}]},{"number":37,"arabic":"لِيَمِيزَ ٱللَّهُ ٱلْخَبِيثَ مِنَ ٱلطَّيِّبِ وَيَجْعَلَ ٱلْخَبِيثَ بَعْضَهُۥ عَلَىٰ بَعْضٍۢ فَيَرْكُمَهُۥ جَمِيعًۭا فَيَجْعَلَهُۥ فِى جَهَنَّمَ ۚ أُو۟لَٰٓئِكَ هُمُ ٱلْخَٰسِرُونَ","translation":"so that God might separate the bad from the good, and join the bad with one another, and link them all together [within His condemnation], and then place them in hell. They, they are the lost!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1197.mp3","surahId":8,"words":[{"id":38815,"position":1,"arabic":"لِيَمِيزَ","translation":"যেন পৃথক করেন","audioUrl":"wbw/008_037_001.mp3","charTypeName":"word"},{"id":38816,"position":2,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/008_037_002.mp3","charTypeName":"word"},{"id":388