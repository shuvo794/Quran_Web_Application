{"id":121,"ayahs":[{"number":77,"arabic":"قُلْ يَٰٓأَهْلَ ٱلْكِتَٰبِ لَا تَغْلُوا۟ فِى دِينِكُمْ غَيْرَ ٱلْحَقِّ وَلَا تَتَّبِعُوٓا۟ أَهْوَآءَ قَوْمٍۢ قَدْ ضَلُّوا۟ مِن قَبْلُ وَأَضَلُّوا۟ كَثِيرًۭا وَضَلُّوا۟ عَن سَوَآءِ ٱلسَّبِيلِ","translation":"Say: \"O followers of the Gospel! Do not overstep the bounds [of truth] in your religious beliefs; and do not follow the errant views of people who have gone astray aforetime, and have led many [others] astray, and are still straying from the right path.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/746.mp3","surahId":5,"words":[{"id":63084,"position":1,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/005_077_001.mp3","charTypeName":"word"},{"id":63085,"position":2,"arabic":"يَـٰٓأَهْلَ","translation":"\"হে অধিকারীরা","audioUrl":"wbw/005_077_002.mp3","charTypeName":"word"},{"id":63086,"position":3,"arabic":"ٱلْكِتَـٰبِ","translation":"কিতাবের","audioUrl":"wbw/005_077_003.mp3","charTypeName":"word"},{"id":63087,"position":4,"arabic":"لَا","translation":"না","audioUrl":"wbw/005_077_004.mp3","charTypeName":"word"},{"id":63088,"position":5,"arabic":"تَغْلُوا۟","translation":"তোমরা বাড়াবাড়ি করো","audioUrl":"wbw/005_077_005.mp3","charTypeName":"word"},{"id":63089,"position":6,"arabic":"فِى","translation":"ব্যাপারে","audioUrl":"wbw/005_077_006.mp3","charTypeName":"word"},{"id":63090,"position":7,"arabic":"دِينِكُمْ","translation":"দীনের তোমাদের","audioUrl":"wbw/005_077_007.mp3","charTypeName":"word"},{"id":63091,"position":8,"arabic":"غَيْرَ","translation":"নয়","audioUrl":"wbw/005_077_008.mp3","charTypeName":"word"},{"id":63092,"position":9,"arabic":"ٱلْحَقِّ","translation":"ন্যায়","audioUrl":"wbw/005_077_009.mp3","charTypeName":"word"},{"id":63093,"position":10,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/005_077_010.mp3","charTypeName":"word"},{"id":63094,"position":11,"arabic":"تَتَّبِعُوٓا۟","translation":"তোমরা অনুসরণ করো","audioUrl":"wbw/005_077_011.mp3","charTypeName":"word"},{"id":63095,"position":12,"arabic":"أَهْوَآءَ","translation":"খেয়ালখুশির","audioUrl":"wbw/005_077_012.mp3","charTypeName":"word"},{"id":63096,"position":13,"arabic":"قَوْمٍۢ","translation":"সম্প্রদায়ের","audioUrl":"wbw/005_077_013.mp3","charTypeName":"word"},{"id":63097,"position":14,"arabic":"قَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/005_077_014.mp3","charTypeName":"word"},{"id":63098,"position":15,"arabic":"ضَلُّوا۟","translation":"তারা পথভ্রষ্ট হয়েছে","audioUrl":"wbw/005_077_015.mp3","charTypeName":"word"},{"id":63099,"position":16,"arabic":"مِن","translation":"থেকেও","audioUrl":"wbw/005_077_016.mp3","charTypeName":"word"},{"id":63100,"position":17,"arabic":"قَبْلُ","translation":"পূর্ব","audioUrl":"wbw/005_077_017.mp3","charTypeName":"word"},{"id":63101,"position":18,"arabic":"وَأَضَلُّوا۟","translation":"ও তারা পথভ্রষ্ট করেছে","audioUrl":"wbw/005_077_018.mp3","charTypeName":"word"},{"id":63102,"position":19,"arabic":"كَثِيرًۭا","translation":"অনেককে","audioUrl":"wbw/005_077_019.mp3","charTypeName":"word"},{"id":63103,"position":20,"arabic":"وَضَلُّوا۟","translation":"এবং তারা ভ্রষ্ট হয়েছে","audioUrl":"wbw/005_077_020.mp3","charTypeName":"word"},{"id":63104,"position":21,"arabic":"عَن","translation":"হতে","audioUrl":"wbw/005_077_021.mp3","charTypeName":"word"},{"id":63105,"position":22,"arabic":"سَوَآءِ","translation":"সরল সোজা","audioUrl":"wbw/005_077_022.mp3","charTypeName":"word"},{"id":63106,"position":23,"arabic":"ٱلسَّبِيلِ","translation":"পথ","audioUrl":"wbw/005_077_023.mp3","charTypeName":"word"},{"id":63107,"position":24,"arabic":"٧٧","translation":"(৭৭)","audioUrl":null,"charTypeName":"end"}]},{"number":78,"arabic":"لُعِنَ ٱلَّذِينَ كَفَرُوا۟ مِنۢ بَنِىٓ إِسْرَٰٓءِيلَ عَلَىٰ لِسَانِ دَاوُۥدَ وَعِيسَى ٱبْنِ مَرْيَمَ ۚ ذَٰلِكَ بِمَا عَصَوا۟ وَّكَانُوا۟ يَعْتَدُونَ","translation":"THOSE of the children of Israel who were bent on denying the truth have [already] been cursed by the tongue of David and of Jesus, the son of Mary? this, because they rebelled [against God] and persisted in transgressing the bounds of what is right.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/747.mp3","surahId":5,"words":[{"id":63275,"position":1,"arabic":"لُعِنَ","translation":"অভিশাপ করা হয়েছে","audioUrl":"wbw/005_078_001.mp3","charTypeName":"word"},{"id":63276,"position":2,"arabic":"ٱلَّذِينَ","translation":"(তাদেরকে) যারা","audioUrl":"wbw/005_078_002.mp3","charTypeName":"word"},{"id":63277,"position":3,"arabic":"كَفَرُوا۟","translation":"অবিশ্বাস করেছে","audioUrl":"wbw/005_078_003.mp3","charTypeName":"word"},{"id":63278,"position":4,"arabic":"مِنۢ","translation":"মধ্য হতে","audioUrl":"wbw/005_078_004.mp3","charTypeName":"word"},{"id":63279,"position":5,"arabic":"بَنِىٓ","translation":"বনী","audioUrl":"wbw/005_078_005.mp3","charTypeName":"word"},{"id":63280,"position":6,"arabic":"إِسْرَٰٓءِيلَ","translation":"ইসরাঈলদের","audioUrl":"wbw/005_078_006.mp3","charTypeName":"word"},{"id":63281,"position":7,"arabic":"عَلَىٰ","translation":"মাধ্যমে","audioUrl":"wbw/005_078_007.mp3","charTypeName":"word"},{"id":63282,"position":8,"arabic":"لِسَانِ","translation":"ভাষার","audioUrl":"wbw/005_078_008.mp3","charTypeName":"word"},{"id":63283,"position":9,"arabic":"دَاوُۥدَ","translation":"দাউদের","audioUrl":"wbw/005_078_009.mp3","charTypeName":"word"},{"id":63284,"position":10,"arabic":"وَعِيسَى","translation":"ও ঈসার","audioUrl":"wbw/005_078_010.mp3","charTypeName":"word"},{"id":63285,"position":11,"arabic":"ٱبْنِ","translation":"পুত্র","audioUrl":"wbw/005_078_011.mp3","charTypeName":"word"},{"id":63286,"position":12,"arabic":"مَرْيَمَ ۚ","translation":"মারইয়ামের","audioUrl":"wbw/005_078_012.mp3","charTypeName":"word"},{"id":63288,"position":13,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/005_078_014.mp3","charTypeName":"word"},{"id":63289,"position":14,"arabic":"بِمَا","translation":"এ কারণে যে","audioUrl":"wbw/005_078_015.mp3","charTypeName":"word"},{"id":63290,"position":15,"arabic":"عَصَوا۟","translation":"তারা অবাধ্য হয়েছিলো","audioUrl":"wbw/005_078_016.mp3","charTypeName":"word"},{"id":63291,"position":16,"arabic":"وَّكَانُوا۟","translation":"ও তারা ছিলো","audioUrl":"wbw/005_078_017.mp3","charTypeName":"word"},{"id":63292,"position":17,"arabic":"يَعْتَدُونَ","translation":"তারা সীমালঙ্ঘন করতো","audioUrl":"wbw/005_078_018.mp3","charTypeName":"word"},{"id":63293,"position":18,"arabic":"٧٨","translation":"(৭৮)","audioUrl":null,"charTypeName":"end"}]},{"number":79,"arabic":"كَانُوا۟ لَا يَتَنَاهَوْنَ عَن مُّنكَرٍۢ فَعَلُوهُ ۚ لَبِئْسَ مَا كَانُوا۟ يَفْعَلُونَ","translation":"They would not prevent one another from doing whatever hateful things they did: vile indeed was what they were wont to do!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/748.mp3","surahId":5,"words":[{"id":63695,"position":1,"arabic":"كَانُوا۟","translation":"তারা ছিলো (এমন যে)","audioUrl":"wbw/005_079_001.mp3","charTypeName":"word"},{"id":63696,"position":2,"arabic":"لَا","translation":"না","audioUrl":"wbw/005_079_002.mp3","charTypeName":"word"},{"id":63697,"position":3,"arabic":"يَتَنَاهَوْنَ","translation":"তারা পরস্পরে নিষেধ করতো","audioUrl":"wbw/005_079_003.mp3","charTypeName":"word"},{"id":63698,"position":4,"arabic":"عَن","translation":"হতে","audioUrl":"wbw/005_079_004.mp3","charTypeName":"word"},{"id":63699,"position":5,"arabic":"مُّنكَرٍۢ","translation":"অন্যায় কাজ","audioUrl":"wbw/005_079_005.mp3","charTypeName":"word"},{"id":63700,"position":6,"arabic":"فَعَلُوهُ ۚ","translation":"তারা করতো যা","audioUrl":"wbw/005_079_006.mp3","charTypeName":"word"},{"id":63702,"position":7,"arabic":"لَبِئْسَ","translation":"অবশ্যই নিকৃষ্ট","audioUrl":"wbw/005_079_008.mp3","charTypeName":"word"},{"id":63703,"position":8,"arabic":"مَا","translation":"যা","audioUrl":"wbw/005_079_009.mp3","charTypeName":"word"},{"id":63704,"position":9,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/005_079_010.mp3","charTypeName":"word"},{"id":63705,"position":10,"arabic":"يَفْعَلُونَ","translation":"তারা করতে","audioUrl":"wbw/005_079_011.mp3","charTypeName":"word"},{"id":63706,"position":11,"arabic":"٧٩","translation":"(৭৯)","audioUrl":null,"charTypeName":"end"}]},{"number":80,"arabic":"تَرَىٰ كَثِيرًۭا مِّنْهُمْ يَتَوَلَّوْنَ ٱلَّذِينَ كَفَرُوا۟ ۚ لَبِئْسَ مَا قَدَّمَتْ لَهُمْ أَنفُسُهُمْ أَن سَخِطَ ٱللَّهُ عَلَيْهِمْ وَفِى ٱلْعَذَابِ هُمْ خَٰلِدُونَ","translation":"[And now] thou canst see many of them allying themselves with those who are bent on denying the truth! [So] vile indeed is what their passions make them do that God has condemned them; and in suffering shall they abide.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/749.mp3","surahId":5,"words":[{"id":64254,"position":1,"arabic":"تَرَىٰ","translation":"তুমি দেখছো (আজ)","audioUrl":"wbw/005_080_001.mp3","charTypeName":"word"},{"id":64255,"position":2,"arabic":"كَثِيرًۭا","translation":"অনেককে","audioUrl":"wbw/005_080_002.mp3","charTypeName":"word"},{"id":64256,"position":3,"arabic":"مِّنْهُمْ","translation":"মধ্য হতে তাদের","audioUrl":"wbw/005_080_003.mp3","charTypeName":"word"},{"id":64257,"position":4,"arabic":"يَتَوَلَّوْنَ","translation":"তারা বন্ধুত্ব করে","audioUrl":"wbw/005_080_004.mp3","charTypeName":"word"},{"id":64258,"position":5,"arabic":"ٱلَّذِينَ","translation":"(তাদের সাথে) যারা","audioUrl":"wbw/005_080_005.mp3","charTypeName":"word"},{"id":64259,"position":6,"arabic":"كَفَرُوا۟ ۚ","translation":"অবিশ্বাস করেছে","audioUrl":"wbw/005_080_006.mp3","charTypeName":"word"},{"id":64261,"position":7,"arabic":"لَبِئْسَ","translation":"অবশ্যই নিকৃষ্ট","audioUrl":"wbw/005_080_008.mp3","charTypeName":"word"},{"id":64262,"position":8,"arabic":"مَا","translation":"যা","audioUrl":"wbw/005_080_009.mp3","charTypeName":"word"},{"id":64263,"position":9,"arabic":"قَدَّمَتْ","translation":"আগে পাঠিয়েছে","audioUrl":"wbw/005_080_010.mp3","charTypeName":"word"},{"id":64264,"position":10,"arabic":"لَهُمْ","translation":"জন্যে তাদের","audioUrl":"wbw/005_080_011.mp3","charTypeName":"word"},{"id":64265,"position":11,"arabic":"أَنفُسُهُمْ","translation":"প্রবৃত্তিসমূহ তাদের","audioUrl":"wbw/005_080_012.mp3","charTypeName":"word"},{"id":64266,"position":12,"arabic":"أَن","translation":"এ জন্যে","audioUrl":"wbw/005_080_013.mp3","charTypeName":"word"},{"id":64267,"position":13,"arabic":"سَخِطَ","translation":"অসন্তুষ্ট হয়েছেন","audioUrl":"wbw/005_080_014.mp3","charTypeName":"word"},{"id":64268,"position":14,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/005_080_015.mp3","charTypeName":"word"},{"id":64269,"position":15,"arabic":"عَلَيْهِمْ","translation":"উপর তাদের","audioUrl":"wbw/005_080_016.mp3","charTypeName":"word"},{"id":64270,"position":16,"arabic":"وَفِى","translation":"এবং মধ্যে","audioUrl":"wbw/005_080_017.mp3","charTypeName":"word"},{"id":64271,"position":17,"arabic":"ٱلْعَذَابِ","translation":"শাস্তির","audioUrl":"wbw/005_080_018.mp3","charTypeName":"word"},{"id":64272,"position":18,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/005_080_019.mp3","charTypeName":"word"},{"id":64273,"position":19,"arabic":"خَـٰلِدُونَ","translation":"চিরস্থায়ী হবে","audioUrl":"wbw/005_080_020.mp3","charTypeName":"word"},{"id":64274,"position":20,"arabic":"٨٠","translation":"(৮০)","audioUrl":null,"charTypeName":"end"}]},{"number":81,"arabic":"وَلَوْ كَانُوا۟ يُؤْمِنُونَ بِٱللَّهِ وَٱلنَّبِىِّ وَمَآ أُنزِلَ إِلَيْهِ مَا ٱتَّخَذُوهُمْ أَوْلِيَآءَ وَلَٰكِنَّ كَثِيرًۭا مِّنْهُمْ فَٰسِقُونَ","translation":"For, if they [truly] believed in God and their Prophet and all that was bestowed upon him from on high, they would not take those [deniers of the truth] for their allies: but most of them are iniquitous.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/750.mp3","surahId":5,"words":[{"id":64794,"position":1,"arabic":"وَلَوْ","translation":"এবং যদি","audioUrl":"wbw/005_081_001.mp3","charTypeName":"word"},{"id":64795,"position":2,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/005_081_002.mp3","charTypeName":"word"},{"id":64796,"position":3,"arabic":"يُؤْمِنُونَ","translation":"তারা ঈমান আনতো","audioUrl":"wbw/005_081_003.mp3","charTypeName":"word"},{"id":64797,"position":4,"arabic":"بِٱللَّهِ","translation":"উপর আল্লাহর","audioUrl":"wbw/005_081_004.mp3","charTypeName":"word"},{"id":64798,"position":5,"arabic":"وَٱلنَّبِىِّ","translation":"ও নাবীর (উপর)","audioUrl":"wbw/005_081_005.mp3","charTypeName":"word"},{"id":64799,"position":6,"arabic":"وَمَآ","translation":"ও যা","audioUrl":"wbw/005_081_006.mp3","charTypeName":"word"},{"id":64800,"position":7,"arabic":"أُنزِلَ","translation":"অবতীর্ণ করা হয়েছে","audioUrl":"wbw/005_081_007.mp3","charTypeName":"word"},{"id":64801,"position":8,"arabic":"إِلَيْهِ","translation":"প্রতি তার","audioUrl":"wbw/005_081_008.mp3","charTypeName":"word"},{"id":64802,"position":9,"arabic":"مَا","translation":"(তবে) না","audioUrl":"wbw/005_081_009.mp3","charTypeName":"word"},{"id":64803,"position":10,"arabic":"ٱتَّخَذُوهُمْ","translation":"তারা গ্রহণ করতো তাদেরকে","audioUrl":"wbw/005_081_010.mp3","charTypeName":"word"},{"id":64804,"position":11,"arabic":"أَوْلِيَآءَ","translation":"বন্ধুরূপে","audioUrl":"wbw/005_081_011.mp3","charTypeName":"word"},{"id":64805,"position":12,"arabic":"وَلَـٰكِنَّ","translation":"কিন্তু","audioUrl":"wbw/005_081_012.mp3","charTypeName":"word"},{"id":64806,"position":13,"arabic":"كَثِيرًۭا","translation":"অনেকেই","audioUrl":"wbw/005_081_013.mp3","charTypeName":"word"},{"id":64807,"position":14,"arabic":"مِّنْهُمْ","translation":"মধ্য হতে তাদের","audioUrl":"wbw/005_081_014.mp3","charTypeName":"word"},{"id":64808,"position":15,"arabic":"فَـٰسِقُونَ","translation":"সত্যত্যাগী","audioUrl":"wbw/005_081_015.mp3","charTypeName":"word"},{"id":64809,"position":16,"arabic":"٨١","translation":"(৮১)","audioUrl":null,"charTypeName":"end"}]},{"number":82,"arabic":"۞ لَتَجِدَنَّ أَشَدَّ ٱلنَّاسِ عَدَٰوَةًۭ لِّلَّذِينَ ءَامَنُوا۟ ٱلْيَهُودَ وَٱلَّذِينَ أَشْرَكُوا۟ ۖ وَلَتَجِدَنَّ أَقْرَبَهُم مَّوَدَّةًۭ لِّلَّذِينَ ءَامَنُوا۟ ٱلَّذِينَ قَالُوٓا۟ إِنَّا نَصَٰرَىٰ ۚ ذَٰلِكَ بِأَنَّ مِنْهُمْ قِسِّيسِينَ وَرُهْبَانًۭا وَأَنَّهُمْ لَا يَسْتَكْبِرُونَ","translation":"Thou wilt surely find that, of all people, the most hostile to those who believe [in this divine writ] are the Jews as well as those who are bent on ascribing divinity to aught beside God; and thou wilt surely find that, of all people, they who say, \"Behold, we are Christians,\" come closest to feeling affection for those who believe [in this divine writ]: this is so because there are priests and monks among them, and because these are not given to arrogance.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/751.mp3","surahId":5,"words":[{"id":65127,"position":1,"arabic":"۞ لَتَجِدَنَّ","translation":"অবশ্যই তুমি পাবে","audioUrl":"wbw/005_082_002.mp3","charTypeName":"word"},{"id":65128,"position":2,"arabic":"أَشَدَّ","translation":"সর্বাধিক উগ্র","audioUrl":"wbw/005_082_003.mp3","charTypeName":"word"},{"id":65129,"position":3,"arabic":"ٱلنَّاسِ","translation":"মানুষের (মধ্যে)","audioUrl":"wbw/005_082_004.mp3","charTypeName":"word"},{"id":65130,"position":4,"arabic":"عَدَٰوَةًۭ","translation":"শত্রুতায়","audioUrl":"wbw/005_082_005.mp3","charTypeName":"word"},{"id":65131,"position":5,"arabic":"لِّلَّذِينَ","translation":"জন্যে তাদের(যারা)","audioUrl":"wbw/005_082_006.mp3","charTypeName":"word"},{"id":65132,"position":6,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/005_082_007.mp3","charTypeName":"word"},{"id":65133,"position":7,"arabic":"ٱلْيَهُودَ","translation":"ইয়াহুদীদেরকে","audioUrl":"wbw/005_082_008.mp3","charTypeName":"word"},{"id":65134,"position":8,"arabic":"وَٱلَّذِينَ","translation":"ও যারা","audioUrl":"wbw/005_082_009.mp3","charTypeName":"word"},{"id":65135,"position":9,"arabic":"أَشْرَكُوا۟ ۖ","translation":"শিরক করেছে (তাদেরকে)","audioUrl":"wbw/005_082_010.mp3","charTypeName":"word"},{"id":65137,"position":10,"arabic":"وَلَتَجِدَنَّ","translation":"এবং অবশ্যই তুমি পাবে","audioUrl":"wbw/005_082_012.mp3","charTypeName":"word"},{"id":65138,"position":11,"arabic":"أَقْرَبَهُم","translation":"নিকটবর্তী তাদেরকে","audioUrl":"wbw/005_082_013.mp3","charTypeName":"word"},{"id":65139,"position":12,"arabic":"مَّوَدَّةًۭ","translation":"বন্ধুত্বে","audioUrl":"wbw/005_082_014.mp3","charTypeName":"word"},{"id":65140,"position":13,"arabic":"لِّلَّذِينَ","translation":"জন্যে তাদের(যারা)","audioUrl":"wbw/005_082_015.mp3","charTypeName":"word"},{"id":65141,"position":14,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/005_082_016.mp3","charTypeName":"word"},{"id":65142,"position":15,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/005_082_017.mp3","charTypeName":"word"},{"id":65143,"position":16,"arabic":"قَالُوٓا۟","translation":"বলে","audioUrl":"wbw/005_082_018.mp3","charTypeName":"word"},{"id":65144,"position":17,"arabic":"إِنَّا","translation":"\"নিশ্চয়ই আমরা","audioUrl":"wbw/005_082_019.mp3","charTypeName":"word"},{"id":65145,"position":18,"arabic":"نَصَـٰرَىٰ ۚ","translation":"খ্রিষ্টান\"","audioUrl":"wbw/005_082_020.mp3","charTypeName":"word"},{"id":65147,"position":19,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/005_082_022.mp3","charTypeName":"word"},{"id":65148,"position":20,"arabic":"بِأَنَّ","translation":"জন্যে যে এ","audioUrl":"wbw/005_082_023.mp3","charTypeName":"word"},{"id":65149,"position":21,"arabic":"مِنْهُمْ","translation":"মধ্য থেকে তাদের","audioUrl":"wbw/005_082_024.mp3","charTypeName":"word"},{"id":65150,"position":22,"arabic":"قِسِّيسِينَ","translation":"(অনেক) পন্ডিত(রয়েছে)","audioUrl":"wbw/005_082_025.mp3","charTypeName":"word"},{"id":65151,"position":23,"arabic":"وَرُهْبَانًۭا","translation":"ও (আছে) সংসারবিরাগী (অনেক) ফকির","audioUrl":"wbw/005_082_026.mp3","charTypeName":"word"},{"id":65152,"position":24,"arabic":"وَأَنَّهُمْ","translation":"এবং (এও) যে তারা","audioUrl":"wbw/005_082_027.mp3","charTypeName":"word"},{"id":65153,"position":25,"arabic":"لَا","translation":"না","audioUrl":"wbw/005_082_028.mp3","c