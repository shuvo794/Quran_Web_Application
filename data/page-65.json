{"id":65,"ayahs":[{"number":116,"arabic":"إِنَّ ٱلَّذِينَ كَفَرُوا۟ لَن تُغْنِىَ عَنْهُمْ أَمْوَٰلُهُمْ وَلَآ أَوْلَٰدُهُم مِّنَ ٱللَّهِ شَيْـًۭٔا ۖ وَأُو۟لَٰٓئِكَ أَصْحَٰبُ ٱلنَّارِ ۚ هُمْ فِيهَا خَٰلِدُونَ","translation":"[But,] behold, as for those who are bent on denying the truth - neither their worldly possessions nor their children will in the least avail them against God: and it is they who are destined for the fire, therein to abide.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/409.mp3","surahId":3,"words":[{"id":75666,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়","audioUrl":"wbw/003_116_001.mp3","charTypeName":"word"},{"id":75667,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/003_116_002.mp3","charTypeName":"word"},{"id":75668,"position":3,"arabic":"كَفَرُوا۟","translation":"কুফরী করেছে","audioUrl":"wbw/003_116_003.mp3","charTypeName":"word"},{"id":75669,"position":4,"arabic":"لَن","translation":"কক্ষণ না","audioUrl":"wbw/003_116_004.mp3","charTypeName":"word"},{"id":75670,"position":5,"arabic":"تُغْنِىَ","translation":"উপকারে আসবে","audioUrl":"wbw/003_116_005.mp3","charTypeName":"word"},{"id":75671,"position":6,"arabic":"عَنْهُمْ","translation":"তাদের জন্যে","audioUrl":"wbw/003_116_006.mp3","charTypeName":"word"},{"id":75672,"position":7,"arabic":"أَمْوَٰلُهُمْ","translation":"তাদের ধনসম্পদ","audioUrl":"wbw/003_116_007.mp3","charTypeName":"word"},{"id":75673,"position":8,"arabic":"وَلَآ","translation":"আর না","audioUrl":"wbw/003_116_008.mp3","charTypeName":"word"},{"id":75674,"position":9,"arabic":"أَوْلَـٰدُهُم","translation":"সন্তান সন্ততি তাদের","audioUrl":"wbw/003_116_009.mp3","charTypeName":"word"},{"id":75675,"position":10,"arabic":"مِّنَ","translation":"হতে","audioUrl":"wbw/003_116_010.mp3","charTypeName":"word"},{"id":75676,"position":11,"arabic":"ٱللَّهِ","translation":"আল্লাহ","audioUrl":"wbw/003_116_011.mp3","charTypeName":"word"},{"id":75677,"position":12,"arabic":"شَيْـًۭٔا ۖ","translation":"কিছু মাত্রই","audioUrl":"wbw/003_116_012.mp3","charTypeName":"word"},{"id":75679,"position":13,"arabic":"وَأُو۟لَـٰٓئِكَ","translation":"এবং ঐসব লোক","audioUrl":"wbw/003_116_014.mp3","charTypeName":"word"},{"id":75680,"position":14,"arabic":"أَصْحَـٰبُ","translation":"অধিবাসী","audioUrl":"wbw/003_116_015.mp3","charTypeName":"word"},{"id":75681,"position":15,"arabic":"ٱلنَّارِ ۚ","translation":"জাহান্নামের আগুনের","audioUrl":"wbw/003_116_016.mp3","charTypeName":"word"},{"id":75683,"position":16,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/003_116_018.mp3","charTypeName":"word"},{"id":75684,"position":17,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/003_116_019.mp3","charTypeName":"word"},{"id":75685,"position":18,"arabic":"خَـٰلِدُونَ","translation":"চিরস্থায়ী হবে","audioUrl":"wbw/003_116_020.mp3","charTypeName":"word"},{"id":75686,"position":19,"arabic":"١١٦","translation":"(১১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":117,"arabic":"مَثَلُ مَا يُنفِقُونَ فِى هَٰذِهِ ٱلْحَيَوٰةِ ٱلدُّنْيَا كَمَثَلِ رِيحٍۢ فِيهَا صِرٌّ أَصَابَتْ حَرْثَ قَوْمٍۢ ظَلَمُوٓا۟ أَنفُسَهُمْ فَأَهْلَكَتْهُ ۚ وَمَا ظَلَمَهُمُ ٱللَّهُ وَلَٰكِنْ أَنفُسَهُمْ يَظْلِمُونَ","translation":"The parable of what they spend on the life of this world is that of an icy wind which smites the tilth of people who have sinned against themselves, and destroys it: for, it is not God who does them wrong, but it is they who are wronging themselves.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/410.mp3","surahId":3,"words":[{"id":75741,"position":1,"arabic":"مَثَلُ","translation":"উদাহরণ","audioUrl":"wbw/003_117_001.mp3","charTypeName":"word"},{"id":75742,"position":2,"arabic":"مَا","translation":"যা","audioUrl":"wbw/003_117_002.mp3","charTypeName":"word"},{"id":75743,"position":3,"arabic":"يُنفِقُونَ","translation":"তারা খরচ করে","audioUrl":"wbw/003_117_003.mp3","charTypeName":"word"},{"id":75744,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/003_117_004.mp3","charTypeName":"word"},{"id":75745,"position":5,"arabic":"هَـٰذِهِ","translation":"এই","audioUrl":"wbw/003_117_005.mp3","charTypeName":"word"},{"id":75746,"position":6,"arabic":"ٱلْحَيَوٰةِ","translation":"জীবনে","audioUrl":"wbw/003_117_006.mp3","charTypeName":"word"},{"id":75747,"position":7,"arabic":"ٱلدُّنْيَا","translation":"দুনিয়ার","audioUrl":"wbw/003_117_007.mp3","charTypeName":"word"},{"id":75748,"position":8,"arabic":"كَمَثَلِ","translation":"উদাহরণ যেমন","audioUrl":"wbw/003_117_008.mp3","charTypeName":"word"},{"id":75749,"position":9,"arabic":"رِيحٍۢ","translation":"বায়ু","audioUrl":"wbw/003_117_009.mp3","charTypeName":"word"},{"id":75750,"position":10,"arabic":"فِيهَا","translation":"তার মধ্যে আছে","audioUrl":"wbw/003_117_010.mp3","charTypeName":"word"},{"id":75751,"position":11,"arabic":"صِرٌّ","translation":"ভীষণ ঠান্ডা","audioUrl":"wbw/003_117_011.mp3","charTypeName":"word"},{"id":75752,"position":12,"arabic":"أَصَابَتْ","translation":"তা পড়ে","audioUrl":"wbw/003_117_012.mp3","charTypeName":"word"},{"id":75753,"position":13,"arabic":"حَرْثَ","translation":"ক্ষেতে","audioUrl":"wbw/003_117_013.mp3","charTypeName":"word"},{"id":75754,"position":14,"arabic":"قَوْمٍۢ","translation":"লোকদের","audioUrl":"wbw/003_117_014.mp3","charTypeName":"word"},{"id":75755,"position":15,"arabic":"ظَلَمُوٓا۟","translation":"জুলুম করেছে (যারা)","audioUrl":"wbw/003_117_015.mp3","charTypeName":"word"},{"id":75756,"position":16,"arabic":"أَنفُسَهُمْ","translation":"তাদের নিজেদের (উপর)","audioUrl":"wbw/003_117_016.mp3","charTypeName":"word"},{"id":75757,"position":17,"arabic":"فَأَهْلَكَتْهُ ۚ","translation":"অতঃপর তা বরবাদ করে দেয়","audioUrl":"wbw/003_117_017.mp3","charTypeName":"word"},{"id":75759,"position":18,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/003_117_019.mp3","charTypeName":"word"},{"id":75760,"position":19,"arabic":"ظَلَمَهُمُ","translation":"তাদের উপর জুলুম করেছেন","audioUrl":"wbw/003_117_020.mp3","charTypeName":"word"},{"id":75761,"position":20,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/003_117_021.mp3","charTypeName":"word"},{"id":75762,"position":21,"arabic":"وَلَـٰكِنْ","translation":"কিন্তু","audioUrl":"wbw/003_117_022.mp3","charTypeName":"word"},{"id":75763,"position":22,"arabic":"أَنفُسَهُمْ","translation":"তারা নিজেরা (নিজেদের উপর)","audioUrl":"wbw/003_117_023.mp3","charTypeName":"word"},{"id":75764,"position":23,"arabic":"يَظْلِمُونَ","translation":"জুলুম করেছিল","audioUrl":"wbw/003_117_024.mp3","charTypeName":"word"},{"id":75765,"position":24,"arabic":"١١٧","translation":"(১১৭)","audioUrl":null,"charTypeName":"end"}]},{"number":118,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ لَا تَتَّخِذُوا۟ بِطَانَةًۭ مِّن دُونِكُمْ لَا يَأْلُونَكُمْ خَبَالًۭا وَدُّوا۟ مَا عَنِتُّمْ قَدْ بَدَتِ ٱلْبَغْضَآءُ مِنْ أَفْوَٰهِهِمْ وَمَا تُخْفِى صُدُورُهُمْ أَكْبَرُ ۚ قَدْ بَيَّنَّا لَكُمُ ٱلْءَايَٰتِ ۖ إِن كُنتُمْ تَعْقِلُونَ","translation":"O YOU who have attained to faith! Do not take for your bosom-friends people who are not of your kind. They spare no effort to corrupt you; they would love to see you in distress. Vehement hatred has already come into the open from out of their mouths, but what their hearts conceal is yet worse. We have indeed made the signs [thereof] clear unto you, if you would but use your reason.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/411.mp3","surahId":3,"words":[{"id":75988,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"ওহে","audioUrl":"wbw/003_118_001.mp3","charTypeName":"word"},{"id":75989,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/003_118_002.mp3","charTypeName":"word"},{"id":75990,"position":3,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছ","audioUrl":"wbw/003_118_003.mp3","charTypeName":"word"},{"id":75991,"position":4,"arabic":"لَا","translation":"না","audioUrl":"wbw/003_118_004.mp3","charTypeName":"word"},{"id":75992,"position":5,"arabic":"تَتَّخِذُوا۟","translation":"তোমরা গ্রহণ করো","audioUrl":"wbw/003_118_005.mp3","charTypeName":"word"},{"id":75993,"position":6,"arabic":"بِطَانَةًۭ","translation":"অন্তরঙ্গ বন্ধু (হিসেবে)","audioUrl":"wbw/003_118_006.mp3","charTypeName":"word"},{"id":75994,"position":7,"arabic":"مِّن","translation":"(থেকে)","audioUrl":"wbw/003_118_007.mp3","charTypeName":"word"},{"id":75995,"position":8,"arabic":"دُونِكُمْ","translation":"তোমাদের ছাড়া (অমুসলমানদেরকে)","audioUrl":"wbw/003_118_008.mp3","charTypeName":"word"},{"id":75996,"position":9,"arabic":"لَا","translation":"না","audioUrl":"wbw/003_118_009.mp3","charTypeName":"word"},{"id":75997,"position":10,"arabic":"يَأْلُونَكُمْ","translation":"তারা তোমাদের সুযোগ ছাড়ে","audioUrl":"wbw/003_118_010.mp3","charTypeName":"word"},{"id":75998,"position":11,"arabic":"خَبَالًۭا","translation":"অনিষ্ট সাধনে","audioUrl":"wbw/003_118_011.mp3","charTypeName":"word"},{"id":75999,"position":12,"arabic":"وَدُّوا۟","translation":"তারা কামনা করে","audioUrl":"wbw/003_118_012.mp3","charTypeName":"word"},{"id":76000,"position":13,"arabic":"مَا","translation":"(তাই) যাতে","audioUrl":"wbw/003_118_013.mp3","charTypeName":"word"},{"id":76001,"position":14,"arabic":"عَنِتُّمْ","translation":"তোমরা অসুবিধায় পড়","audioUrl":"wbw/003_118_014.mp3","charTypeName":"word"},{"id":76002,"position":15,"arabic":"قَدْ","translation":"নিশ্চয়","audioUrl":"wbw/003_118_015.mp3","charTypeName":"word"},{"id":76003,"position":16,"arabic":"بَدَتِ","translation":"প্রকাশ পেয়েছে","audioUrl":"wbw/003_118_016.mp3","charTypeName":"word"},{"id":76004,"position":17,"arabic":"ٱلْبَغْضَآءُ","translation":"বিদ্বেষ","audioUrl":"wbw/003_118_017.mp3","charTypeName":"word"},{"id":76005,"position":18,"arabic":"مِنْ","translation":"হতে","audioUrl":"wbw/003_118_018.mp3","charTypeName":"word"},{"id":76006,"position":19,"arabic":"أَفْوَٰهِهِمْ","translation":"তাদের মুখগুলো","audioUrl":"wbw/003_118_019.mp3","charTypeName":"word"},{"id":76007,"position":20,"arabic":"وَمَا","translation":"এবং যা","audioUrl":"wbw/003_118_020.mp3","charTypeName":"word"},{