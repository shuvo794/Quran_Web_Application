{"id":238,"ayahs":[{"number":23,"arabic":"وَرَٰوَدَتْهُ ٱلَّتِى هُوَ فِى بَيْتِهَا عَن نَّفْسِهِۦ وَغَلَّقَتِ ٱلْأَبْوَٰبَ وَقَالَتْ هَيْتَ لَكَ ۚ قَالَ مَعَاذَ ٱللَّهِ ۖ إِنَّهُۥ رَبِّىٓ أَحْسَنَ مَثْوَاىَ ۖ إِنَّهُۥ لَا يُفْلِحُ ٱلظَّٰلِمُونَ","translation":"And [it so happened that] she in whose house he was living [conceived a passion for him and] sought to make him yield himself unto her; and she bolted the doors and said, \"Come thou unto me!\" [But Joseph] answered: \"May God preserve me! Behold, goodly has my master made my stay [in this house]! Verily, to no good end come they that do [such] wrong!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1619.mp3","surahId":12,"words":[{"id":26176,"position":1,"arabic":"وَرَٰوَدَتْهُ","translation":"এবং তাকে ফুসলিয়েছিলো","audioUrl":"wbw/012_023_001.mp3","charTypeName":"word"},{"id":26177,"position":2,"arabic":"ٱلَّتِى","translation":"(সেই মহিলা) যার","audioUrl":"wbw/012_023_002.mp3","charTypeName":"word"},{"id":26178,"position":3,"arabic":"هُوَ","translation":"সে (ছিলো)","audioUrl":"wbw/012_023_003.mp3","charTypeName":"word"},{"id":26179,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/012_023_004.mp3","charTypeName":"word"},{"id":26180,"position":5,"arabic":"بَيْتِهَا","translation":"তার ঘরের","audioUrl":"wbw/012_023_005.mp3","charTypeName":"word"},{"id":26181,"position":6,"arabic":"عَن","translation":"প্রতি","audioUrl":"wbw/012_023_006.mp3","charTypeName":"word"},{"id":26182,"position":7,"arabic":"نَّفْسِهِۦ","translation":"তার নিজের (আত্মসংবরণ)","audioUrl":"wbw/012_023_007.mp3","charTypeName":"word"},{"id":26183,"position":8,"arabic":"وَغَلَّقَتِ","translation":"এবং বন্ধ করলো (মহিলাটি)","audioUrl":"wbw/012_023_008.mp3","charTypeName":"word"},{"id":26184,"position":9,"arabic":"ٱلْأَبْوَٰبَ","translation":"দরজাগুলো","audioUrl":"wbw/012_023_009.mp3","charTypeName":"word"},{"id":26185,"position":10,"arabic":"وَقَالَتْ","translation":"এবং বললো","audioUrl":"wbw/012_023_010.mp3","charTypeName":"word"},{"id":26186,"position":11,"arabic":"هَيْتَ","translation":"\"চলে এসো","audioUrl":"wbw/012_023_011.mp3","charTypeName":"word"},{"id":26187,"position":12,"arabic":"لَكَ ۚ","translation":"তোমাকে বলছি\"","audioUrl":"wbw/012_023_012.mp3","charTypeName":"word"},{"id":26189,"position":13,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/012_023_014.mp3","charTypeName":"word"},{"id":26190,"position":14,"arabic":"مَعَاذَ","translation":"\"আশ্রয় চাই","audioUrl":"wbw/012_023_015.mp3","charTypeName":"word"},{"id":26191,"position":15,"arabic":"ٱللَّهِ ۖ","translation":"\"আল্লাহর","audioUrl":"wbw/012_023_016.mp3","charTypeName":"word"},{"id":26193,"position":16,"arabic":"إِنَّهُۥ","translation":"নিশ্চয়ই তিনি","audioUrl":"wbw/012_023_018.mp3","charTypeName":"word"},{"id":26194,"position":17,"arabic":"رَبِّىٓ","translation":"আমার রব","audioUrl":"wbw/012_023_019.mp3","charTypeName":"word"},{"id":26195,"position":18,"arabic":"أَحْسَنَ","translation":"উত্তম ব্যবস্হা করেছেন","audioUrl":"wbw/012_023_020.mp3","charTypeName":"word"},{"id":26196,"position":19,"arabic":"مَثْوَاىَ ۖ","translation":"আমার বসবাসের","audioUrl":"wbw/012_023_021.mp3","charTypeName":"word"},{"id":26198,"position":20,"arabic":"إِنَّهُۥ","translation":"নিশ্চয়ই","audioUrl":"wbw/012_023_023.mp3","charTypeName":"word"},{"id":26199,"position":21,"arabic":"لَا","translation":"না","audioUrl":"wbw/012_023_024.mp3","charTypeName":"word"},{"id":26200,"position":22,"arabic":"يُفْلِحُ","translation":"সফল হয়","audioUrl":"wbw/012_023_025.mp3","charTypeName":"word"},{"id":26201,"position":23,"arabic":"ٱلظَّـٰلِمُونَ","translation":"সীমালঙ্ঘনকারীরা\"","audioUrl":"wbw/012_023_026.mp3","charTypeName":"word"},{"id":26202,"position":24,"arabic":"٢٣","translation":"(২৩)","audioUrl":null,"charTypeName":"end"}]},{"number":24,"arabic":"وَلَقَدْ هَمَّتْ بِهِۦ ۖ وَهَمَّ بِهَا لَوْلَآ أَن رَّءَا بُرْهَٰنَ رَبِّهِۦ ۚ كَذَٰلِكَ لِنَصْرِفَ عَنْهُ ٱلسُّوٓءَ وَٱلْفَحْشَآءَ ۚ إِنَّهُۥ مِنْ عِبَادِنَا ٱلْمُخْلَصِينَ","translation":"And, indeed, she desired him, and he desired her; [and he would have succumbed] had he not seen [in this temptation] an evidence of his Sustainer's truth: thus [We willed it to be] in order that We might avert from him all evil and all deeds of abomination -for, behold, he was truly one of Our servants.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1620.mp3","surahId":12,"words":[{"id":27212,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/012_024_001.mp3","charTypeName":"word"},{"id":27213,"position":2,"arabic":"هَمَّتْ","translation":"আসক্ত হয়েছিলো (সে মহিলা)","audioUrl":"wbw/012_024_002.mp3","charTypeName":"word"},{"id":27214,"position":3,"arabic":"بِهِۦ ۖ","translation":"প্রতি তার","audioUrl":"wbw/012_024_003.mp3","charTypeName":"word"},{"id":27216,"position":4,"arabic":"وَهَمَّ","translation":"এবং সেও আসক্ত হতো","audioUrl":"wbw/012_024_005.mp3","charTypeName":"word"},{"id":27217,"position":5,"arabic":"بِهَا","translation":"প্রতি তার","audioUrl":"wbw/012_024_006.mp3","charTypeName":"word"},{"id":27218,"position":6,"arabic":"لَوْلَآ","translation":"যদি না","audioUrl":"wbw/012_024_007.mp3","charTypeName":"word"},{"id":27219,"position":7,"arabic":"أَن","translation":"যে","audioUrl":"wbw/012_024_008.mp3","charTypeName":"word"},{"id":27220,"position":8,"arabic":"رَّءَا","translation":"সে দেখতো","audioUrl":"wbw/012_024_009.mp3","charTypeName":"word"},{"id":27221,"position":9,"arabic":"بُرْهَـٰنَ","translation":"নিদর্শন","audioUrl":"wbw/012_024_010.mp3","charTypeName":"word"},{"id":27222,"position":10,"arabic":"رَبِّهِۦ ۚ","translation":"তার রবের","audioUrl":"wbw/012_024_011.mp3","charTypeName":"word"},{"id":27224,"position":11,"arabic":"كَذَٰلِكَ","translation":"এভাবে (ঘটলো)","audioUrl":"wbw/012_024_013.mp3","charTypeName":"word"},{"id":27225,"position":12,"arabic":"لِنَصْرِفَ","translation":"যেন আমরা ফিরিয়ে রাখি","audioUrl":"wbw/012_024_014.mp3","charTypeName":"word"},{"id":27226,"position":13,"arabic":"عَنْهُ","translation":"তার থেকে","audioUrl":"wbw/012_024_015.mp3","charTypeName":"word"},{"id":27227,"position":14,"arabic":"ٱلسُّوٓءَ","translation":"মন্দ","audioUrl":"wbw/012_024_016.mp3","charTypeName":"word"},{"id":27228,"position":15,"arabic":"وَٱلْفَحْشَآءَ ۚ","translation":"ও অশ্লীলতা","audioUrl":"wbw/012_024_017.mp3","charTypeName":"word"},{"id":27230,"position":16,"arabic":"إِنَّهُۥ","translation":"নিশ্চয়ই সে (ছিলো)","audioUrl":"wbw/012_024_019.mp3","charTypeName":"word"},{"id":27231,"position":17,"arabic":"مِنْ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/012_024_020.mp3","charTypeName":"word"},{"id":27232,"position":18,"arabic":"عِبَادِنَا","translation":"আমাদের দাসদের","audioUrl":"wbw/012_024_021.mp3","charTypeName":"word"},{"id":27233,"position":19,"arabic":"ٱلْمُخْلَصِينَ","translation":"(যারা ছিলো) বিশুদ্ধ চিত্ত","audioUrl":"wbw/012_024_022.mp3","charTypeName":"word"},{"id":27234,"position":20,"arabic":"٢٤","translation":"(২৪)","audioUrl":null,"charTypeName":"end"}]},{"number":25,"arabic":"وَٱسْتَبَقَا ٱلْبَابَ وَقَدَّتْ قَمِيصَهُۥ مِن دُبُرٍۢ وَأَلْفَيَا سَيِّدَهَا لَدَا ٱلْبَابِ ۚ قَالَتْ مَا جَزَآءُ مَنْ أَرَادَ بِأَهْلِكَ سُوٓءًا إِلَّآ أَن يُسْجَنَ أَوْ عَذَابٌ أَلِيمٌۭ","translation":"And they both rushed to the door; and she [grasped and] rent his tunic from behind-and [lo!] they met her lord at the door! Said she: \"What ought to be the punishment of one who had evil designs on [the virtue of] thy wife - [what] but imprisonment or a [yet more] grievous chastisement?\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1621.mp3","surahId":12,"words":[{"id":28239,"position":1,"arabic":"وَٱسْتَبَقَا","translation":"এবং উভয়ে দৌঁড়ে গেলো","audioUrl":"wbw/012_025_001.mp3","charTypeName":"word"},{"id":28240,"position":2,"arabic":"ٱلْبَابَ","translation":"দরজার দিকে","audioUrl":"wbw/012_025_002.mp3","charTypeName":"word"},{"id":28241,"position":3,"arabic":"وَقَدَّتْ","translation":"এবং (রমণী) সে ছিঁড়ে ফেললো","audioUrl":"wbw/012_025_003.mp3","charTypeName":"word"},{"id":28242,"position":4,"arabic":"قَمِيصَهُۥ","translation":"তার জামা","audioUrl":"wbw/012_025_004.mp3","charTypeName":"word"},{"id":28243,"position":5,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/012_025_005.mp3","charTypeName":"word"},{"id":28244,"position":6,"arabic":"دُبُرٍۢ","translation":"পিছন","audioUrl":"wbw/012_025_006.mp3","charTypeName":"word"},{"id":28245,"position":7,"arabic":"وَأَلْفَيَا","translation":"এবং উভয়ে পেলো","audioUrl":"wbw/012_025_007.mp3","charTypeName":"word"},{"id":28246,"position":8,"arabic":"سَيِّدَهَا","translation":"তার স্বামীকে","audioUrl":"wbw/012_025_008.mp3","charTypeName":"word"},{"id":28247,"position":9,"arabic":"لَدَا","translation":"কাছে","audioUrl":"wbw/012_025_009.mp3","charTypeName":"word"},{"id":28248,"position":10,"arabic":"ٱلْبَابِ ۚ","translation":"দরজার","audioUrl":"wbw/012_025_010.mp3","charTypeName":"word"},{"id":28250,"position":11,"arabic":"قَالَتْ","translation":"(রমনী) সে বললো","audioUrl":"wbw/012_025_012.mp3","charTypeName":"word"},{"id":28251,"position":12,"arabic":"مَا","translation":"\"কি","audioUrl":"wbw/012_025_013.mp3","charTypeName":"word"},{"id":28252,"position":13,"arabic":"جَزَآءُ","translation":"শাস্তি (হ'তে পারে)","audioUrl":"wbw/012_025_014.mp3","charTypeName":"word"},{"id":28253,"position":14,"arabic":"مَنْ","translation":"যে","audioUrl":"wbw/012_025_015.mp3","charTypeName":"word"},{"id":28254,"position":15,"arabic":"أَرَادَ","translation":"কামনা করে","audioUrl":"wbw/012_025_016.mp3","charTypeName":"word"},{"id":28255,"position":16,"arabic":"بِأَهْلِكَ","translation":"সাথে তোমার পরিবারের","audioUrl":"wbw/012_025_017.mp3","charTypeName":"word"},{"id":28256,"position":17,"arabic":"سُوٓءًا","translation":"কুকর্ম","audioUrl":"wbw/012_025_018.mp3","charTypeName":"word"},{"id":28257,"position":18,"arabic":"إِلَّآ","translation":"এ ছাড়া (কি অন্য কিছু)","audioUrl":"wbw/012_025_019.mp3","charTypeName":"word"},{"id":28258,"position":19,"arabic":"أَن","translation":"যে","audioUrl":"wbw/012_025_020.mp3","charTypeName":"word"},{"id":28259,"position":20,"arabic":"يُسْجَنَ","translation":"বন্দী করা হবে","audioUrl":"wbw/012_025_021.mp3","charTypeName":"word"},{"id":28260,"position":21,"arabic":"أَوْ","translation":"বা","audioUrl":"wbw/012_025_022.mp3","charTypeName":"word"},{"id":28261,"position":22,"arabic":"عَذَابٌ","translation":"কোন শাস্তি","audioUrl":"wbw/012_025_023.mp3","charTypeName":"word"},{"id":28262,"position":23,"arabic":"أَلِيمٌۭ","translation":"নিদারুণ\"","audioUrl":"wbw/012_025_024.mp3","charTypeName":"word"},{"id":28263,"position":24,"arabic":"٢٥","translation":"(২৫)","audioUrl":null,"charTypeName":"end"}]},{"number":26,"arabic":"قَالَ هِىَ رَٰوَدَتْنِى عَن نَّفْسِى ۚ وَشَهِدَ شَاهِدٌۭ مِّنْ أَهْلِهَآ إِن كَانَ قَمِيصُهُۥ قُدَّ مِن قُبُلٍۢ فَصَدَقَتْ وَهُوَ مِنَ ٱلْكَٰذِبِينَ","translation":"[Joseph] exclaimed: \"It was she who sought to make me yield myself unto her!\" Now one of those present, a member of her own household, suggested this: If his tunic has been torn from the front, then she is telling the truth, and he is a liar;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1622.mp3","surahId":12,"words":[{"id":29192,"position":1,"arabic":"قَالَ","translation":"(ইউসুফ) বললো","audioUrl":"wbw/012_026_001.mp3","charTypeName":"word"},{"id":29193,"position":2,"arabic":"هِىَ","translation":"\"সে (মহিলা)","audioUrl":"wbw/012_026_002.mp3","charTypeName":"word"},{"id":29194,"position":3,"arabic":"رَٰوَدَتْنِى","translation":"আমাকে ফুসলিয়েছিলো","audioUrl":"wbw/012_026_003.mp3","charTypeName":"word"},{"id":29195,"position":4,"arabic":"عَن","translation":"হ'তে","audioUrl":"wbw/012_026_004.mp3","charTypeName":"word"},{"id":29196,"position":5,"arabic":"نَّفْسِى ۚ","translation":"আমার নিজের (আত্মসংবরণ)\"","audioUrl":"wbw/012_026_005.mp3","charTypeName":"word"},{"id":29198,"position":6,"arabic":"وَشَهِدَ","translation":"এবং সাক্ষ্য দেয়","audioUrl":"wbw/012_026_007.mp3","charTypeName":"word"},{"id":29199,"position":7,"arabic":"شَاهِدٌۭ","translation":"এক সাক্ষ্যদাতা","audioUrl":"wbw/012_026_008.mp3","charTypeName":"word"},{"id":29200,"position":8,"arabic":"مِّنْ","translation":"মধ্য হ'তে","audioUrl":"wbw/012_026_009.mp3","charTypeName":"word"},{"id":29201,"position":9,"arabic":"أَهْلِهَآ","translation":"তার পরিবারের","audioUrl":"wbw/012_026_010.mp3","charTypeName":"word"},{"id":29202,"position":10,"arabic":"إِن","translation":"\"যদি","audioUrl":"wbw/012_026_011.mp3","charTypeName":"word"},{"id":29203,"position":11,"arabic":"كَانَ","translation":"হয়","audioUrl":"wbw/012_026_012.mp3","charTypeName":"word"},{"id":29204,"position":12,"arabic":"قَمِيصُهُۥ","translation":"তার জামা","audioUrl":"wbw/012_026_013.mp3","charTypeName":"word"},{"id":29205,"position":13,"arabic":"قُدَّ","translation":"ছেঁড়া","audioUrl":"wbw/012_026_014.mp3","charTypeName":"word"},{"id":29206,"position":14,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/012_026_015.mp3","charTypeName":"word"},{"id":29207,"position":15,"arabic":"قُبُلٍۢ","translation":"সামনের দিক","audioUrl":"wbw/012_026_016.mp3","charTypeName":"word"},{"id":29208,"position":16,"arabic":"فَصَدَقَتْ","translation":"তবে সে (রমনী) সত্য বলেছে","audioUrl":"wbw/012_026_017.mp3","charTypeName":"word"},{"id":29209,"position":17,"arabic":"وَهُوَ","translation":"এবং সে (ইউসুফ)","audioUrl":"wbw/012_026_018.mp3","charTypeName":"word"},{"id":29210,"position":18,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/012_026_019.mp3","charTypeName":"word"},{"id":29211,"position":19,"arabic":"ٱلْكَـٰذِبِينَ","translation":"মিথ্যাবাদীদের","audioUrl":"wbw/012_026_020.mp3","charTypeName":"word"},{"id":29212,"position":20,"arabic":"٢٦","translation":"(২৬)","audioUrl":null,"charTypeName":"end"}]},{"number":27,"arabic":"وَإِن كَانَ قَمِيصُهُۥ قُدَّ مِن دُبُرٍۢ فَكَذَبَتْ وَهُوَ مِنَ ٱلصَّٰدِقِينَ","translation":"but if his tunic has been torn from behind, then she is lying, and he is speaking the truth.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1623.mp3","surahId":12,"words":[{"id":30114,"position":1,"arabic":"وَإِن","translation":"আর যদি","audioUrl":"wbw/012_027_001.mp3","charTypeName":"word"},{"id":30115,"position":2,"arabic":"كَانَ","translation":"হয়","audioUrl":"wbw/012_027_002.mp3","charTypeName":"word"},{"id":30116,"position":3,"arabic":"قَمِيصُهُۥ","translation":"তার জামা","audioUrl":"wbw/012_027_003.mp3","charTypeName":"word"},{"id":30117,"position":4,"arabic":"قُدَّ","translation":"ছেঁড়া","audioUrl":"wbw/012_027_004.mp3","charTypeName":"word"},{"id":30118,"position":5,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/012_027_005.mp3","charTypeName":"word"},{"id":30119,"position":6,"arabic":"دُبُرٍۢ","translation":"পিছনের দিক","audioUrl":"wbw/012_027_006.mp3","charTypeName":"word"},{"id":30120,"position":7,"arabic":"فَكَذَبَتْ","translation":"তবে সে (রমনী) মিথ্যা বলেছে","audioUrl":"wbw/012_027_007.mp3","charTypeName":"word"},{"id":30121,"position":8,"arabic":"وَهُوَ","translation":"এবং সে (ইউসুফ)","audioUrl":"wbw/012_027_008.mp3","charTypeName":"word"},{"id":30122,"position":9,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/012_027_009.mp3","charTypeName":"word"},{"id":30123,"position":10,"arabic":"ٱلصَّـٰدِقِينَ","translation":"সত্যবাদীদের\"","audioUrl":"wbw/012_027_010.mp3","charTypeName":"word"},{"id":30124,"position":11,"arabic":"٢٧","translation":"(২৭)","audioUrl":null,"charTypeName":"end"}]},{"number":28,"arabic":"فَلَمَّا رَءَا قَمِيصَهُۥ قُدَّ مِن دُبُرٍۢ قَالَ إِنَّهُۥ مِن كَيْدِكُنَّ ۖ إِنَّ كَيْدَكُنَّ عَظِيمٌۭ","translation":"And when (her husband] saw that his tunic was torn from behind, he said: \"Behold, this is [an instance] of your guile, O womankind! Verily, awesome is your guile!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1624.mp3","surahId":12,"words":[{"id":31170,"position":1,"arabic":"فَلَمَّا","translation":"অতঃপর যখন","audioUrl":"wbw/012_028_001.mp3","charTypeName":"word"},{"id":31171,"position":2,"arabic":"رَءَا","translatio