{"id":400,"ayahs":[{"number":31,"arabic":"وَلَمَّا جَآءَتْ رُسُلُنَآ إِبْرَٰهِيمَ بِٱلْبُشْرَىٰ قَالُوٓا۟ إِنَّا مُهْلِكُوٓا۟ أَهْلِ هَٰذِهِ ٱلْقَرْيَةِ ۖ إِنَّ أَهْلَهَا كَانُوا۟ ظَٰلِمِينَ","translation":"And so, when Our [heavenly] messengers came to Abraham with the glad tiding [of the birth of Isaac], they [also] said, “Behold, we are about to destroy the people of that land, for its people are truly evildoers!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3371.mp3","surahId":29,"words":[{"id":33958,"position":1,"arabic":"وَلَمَّا","translation":"এবং যখন","audioUrl":"wbw/029_031_001.mp3","charTypeName":"word"},{"id":33959,"position":2,"arabic":"جَآءَتْ","translation":"আসলো","audioUrl":"wbw/029_031_002.mp3","charTypeName":"word"},{"id":33960,"position":3,"arabic":"رُسُلُنَآ","translation":"দূতগণ আমাদের(ফেরেশতারা)","audioUrl":"wbw/029_031_003.mp3","charTypeName":"word"},{"id":33961,"position":4,"arabic":"إِبْرَٰهِيمَ","translation":"ইবরাহীমের (নিকট)","audioUrl":"wbw/029_031_004.mp3","charTypeName":"word"},{"id":33962,"position":5,"arabic":"بِٱلْبُشْرَىٰ","translation":"নিয়ে সুসংবাদ","audioUrl":"wbw/029_031_005.mp3","charTypeName":"word"},{"id":33963,"position":6,"arabic":"قَالُوٓا۟","translation":"তারা বললো","audioUrl":"wbw/029_031_006.mp3","charTypeName":"word"},{"id":33964,"position":7,"arabic":"إِنَّا","translation":"\"নিশ্চয়ই আমরা","audioUrl":"wbw/029_031_007.mp3","charTypeName":"word"},{"id":33965,"position":8,"arabic":"مُهْلِكُوٓا۟","translation":"ধ্বংসকারী","audioUrl":"wbw/029_031_008.mp3","charTypeName":"word"},{"id":33966,"position":9,"arabic":"أَهْلِ","translation":"এই","audioUrl":"wbw/029_031_009.mp3","charTypeName":"word"},{"id":33967,"position":10,"arabic":"هَـٰذِهِ","translation":"অধিবাসীদেরকে","audioUrl":"wbw/029_031_010.mp3","charTypeName":"word"},{"id":33968,"position":11,"arabic":"ٱلْقَرْيَةِ ۖ","translation":"জনপদের","audioUrl":"wbw/029_031_011.mp3","charTypeName":"word"},{"id":33970,"position":12,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/029_031_013.mp3","charTypeName":"word"},{"id":33971,"position":13,"arabic":"أَهْلَهَا","translation":"অধিবাসীরা তার","audioUrl":"wbw/029_031_014.mp3","charTypeName":"word"},{"id":33972,"position":14,"arabic":"كَانُوا۟","translation":"ছিলো","audioUrl":"wbw/029_031_015.mp3","charTypeName":"word"},{"id":33973,"position":15,"arabic":"ظَـٰلِمِينَ","translation":"সীমালঙ্ঘনকারী\"","audioUrl":"wbw/029_031_016.mp3","charTypeName":"word"},{"id":33974,"position":16,"arabic":"٣١","translation":"(৩১)","audioUrl":null,"charTypeName":"end"}]},{"number":32,"arabic":"قَالَ إِنَّ فِيهَا لُوطًۭا ۚ قَالُوا۟ نَحْنُ أَعْلَمُ بِمَن فِيهَا ۖ لَنُنَجِّيَنَّهُۥ وَأَهْلَهُۥٓ إِلَّا ٱمْرَأَتَهُۥ كَانَتْ مِنَ ٱلْغَٰبِرِينَ","translation":"[And when Abraham] exclaimed, “But Lot lives there!” - they answered: We know fully well who is there; most certainly we shall save him and his household - all but his wife: she will indeed be among those that stay behind.”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3372.mp3","surahId":29,"words":[{"id":34888,"position":1,"arabic":"قَالَ","translation":"(ইবরাহীম) বললো","audioUrl":"wbw/029_032_001.mp3","charTypeName":"word"},{"id":34889,"position":2,"arabic":"إِنَّ","translation":"\"নিশ্চয়ই","audioUrl":"wbw/029_032_002.mp3","charTypeName":"word"},{"id":34890,"position":3,"arabic":"فِيهَا","translation":"মধ্যে তার(আছে)","audioUrl":"wbw/029_032_003.mp3","charTypeName":"word"},{"id":34891,"position":4,"arabic":"لُوطًۭا ۚ","translation":"লুত\"","audioUrl":"wbw/029_032_004.mp3","charTypeName":"word"},{"id":34893,"position":5,"arabic":"قَالُوا۟","translation":"তারা বললো","audioUrl":"wbw/029_032_006.mp3","charTypeName":"word"},{"id":34894,"position":6,"arabic":"نَحْنُ","translation":"\"আমরা","audioUrl":"wbw/029_032_007.mp3","charTypeName":"word"},{"id":34895,"position":7,"arabic":"أَعْلَمُ","translation":"খুব জানি","audioUrl":"wbw/029_032_008.mp3","charTypeName":"word"},{"id":34896,"position":8,"arabic":"بِمَن","translation":"সে সম্পর্কে কারা","audioUrl":"wbw/029_032_009.mp3","charTypeName":"word"},{"id":34897,"position":9,"arabic":"فِيهَا ۖ","translation":"মধ্যে তার(আছে)","audioUrl":"wbw/029_032_010.mp3","charTypeName":"word"},{"id":34899,"position":10,"arabic":"لَنُنَجِّيَنَّهُۥ","translation":"অবশ্যই রক্ষা করবোই তাকে","audioUrl":"wbw/029_032_012.mp3","charTypeName":"word"},{"id":34900,"position":11,"arabic":"وَأَهْلَهُۥٓ","translation":"ও পরিবারকে তার","audioUrl":"wbw/029_032_013.mp3","charTypeName":"word"},{"id":34901,"position":12,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/029_032_014.mp3","charTypeName":"word"},{"id":34902,"position":13,"arabic":"ٱمْرَأَتَهُۥ","translation":"স্ত্রীকে তার","audioUrl":"wbw/029_032_015.mp3","charTypeName":"word"},{"id":34903,"position":14,"arabic":"كَانَتْ","translation":"সে ছিলো","audioUrl":"wbw/029_032_016.mp3","charTypeName":"word"},{"id":34904,"position":15,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/029_032_017.mp3","charTypeName":"word"},{"id":34905,"position":16,"arabic":"ٱلْغَـٰبِرِينَ","translation":"পিছনে অবস্হানকারীদের","audioUrl":"wbw/029_032_018.mp3","charTypeName":"word"},{"id":34906,"position":17,"arabic":"٣٢","translation":"(৩২)","audioUrl":null,"charTypeName":"end"}]},{"number":33,"arabic":"وَلَمَّآ أَن جَآءَتْ رُسُلُنَا لُوطًۭا سِىٓءَ بِهِمْ وَضَاقَ بِهِمْ ذَرْعًۭا وَقَالُوا۟ لَا تَخَفْ وَلَا تَحْزَنْ ۖ إِنَّا مُنَجُّوكَ وَأَهْلَكَ إِلَّا ٱمْرَأَتَكَ كَانَتْ مِنَ ٱلْغَٰبِرِينَ","translation":"And when Our messengers came unto Lot, he was sorely grieved on their account, seeing that it was beyond his power to shield them; but they said: “Fear not, and grieve not! Behold, we shall save thee and thy household - all but thy wife: she will indeed be among those that stay behind.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3373.mp3","surahId":29,"words":[{"id":35684,"position":1,"arabic":"وَلَمَّآ","translation":"এবং যখন","audioUrl":"wbw/029_033_001.mp3","charTypeName":"word"},{"id":35685,"position":2,"arabic":"أَن","translation":"যে","audioUrl":"wbw/029_033_002.mp3","charTypeName":"word"},{"id":35686,"position":3,"arabic":"جَآءَتْ","translation":"আসলো","audioUrl":"wbw/029_033_003.mp3","charTypeName":"word"},{"id":35687,"position":4,"arabic":"رُسُلُنَا","translation":"দূতগণ আমাদের(ফেরেশতারা)","audioUrl":"wbw/029_033_004.mp3","charTypeName":"word"},{"id":35688,"position":5,"arabic":"لُوطًۭا","translation":"লুতের (নিকট)","audioUrl":"wbw/029_033_005.mp3","charTypeName":"word"},{"id":35689,"position":6,"arabic":"سِىٓءَ","translation":"সে বিষন্ন হলো","audioUrl":"wbw/029_033_006.mp3","charTypeName":"word"},{"id":35690,"position":7,"arabic":"بِهِمْ","translation":"কারণে তাদের","audioUrl":"wbw/029_033_007.mp3","charTypeName":"word"},{"id":35691,"position":8,"arabic":"وَضَاقَ","translation":"এবং সংকীর্ণ হলো","audioUrl":"wbw/029_033_008.mp3","charTypeName":"word"},{"id":35692,"position":9,"arabic":"بِهِمْ","translation":"কারণে তাদের","audioUrl":"wbw/029_033_009.mp3","charTypeName":"word"},{"id":35693,"position":10,"arabic":"ذَرْعًۭا","translation":"শক্তিতে (অর্থাৎ অসহায় হলো)","audioUrl":"wbw/029_033_010.mp3","charTypeName":"word"},{"id":35694,"position":11,"arabic":"وَقَالُوا۟","translation":"এবং তারা বললো","audioUrl":"wbw/029_033_011.mp3","charTypeName":"word"},{"id":35695,"position":12,"arabic":"لَا","translation":"\"না","audioUrl":"wbw/029_033_012.mp3","charTypeName":"word"},{"id":35696,"position":13,"arabic":"تَخَفْ","translation":"ভয় করো","audioUrl":"wbw/029_033_013.mp3","charTypeName":"word"},{"id":35697,"position":14,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/029_033_014.mp3","charTypeName":"word"},{"id":35698,"position":15,"arabic":"تَحْزَنْ ۖ","translation":"দুশ্চিন্তা করো","audioUrl":"wbw/029_033_015.mp3","charTypeName":"word"},{"id":35700,"position":16,"arabic":"إِنَّا","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/029_033_017.mp3","charTypeName":"word"},{"id":35701,"position":17,"arabic":"مُنَجُّوكَ","translation":"তোমাকে রক্ষাকারী","audioUrl":"wbw/029_033_018.mp3","charTypeName":"word"},{"id":35702,"position":18,"arabic":"وَأَهْلَكَ","translation":"ও তোমার পরিবারকে","audioUrl":"wbw/029_033_019.mp3","charTypeName":"word"},{"id":35703,"position":19,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/029_033_020.mp3","charTypeName":"word"},{"id":35704,"position":20,"arabic":"ٱمْرَأَتَكَ","translation":"তোমার স্ত্রীকে","audioUrl":"wbw/029_033_021.mp3","charTypeName":"word"},{"id":35705,"position":21,"arabic":"كَانَتْ","translation":"সে ছিলো","audioUrl":"wbw/029_033_022.mp3","charTypeName":"word"},{"id":35706,"position":22,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/029_033_023.mp3","charTypeName":"word"},{"id":35707,"position":23,"arabic":"ٱلْغَـٰبِرِينَ","translation":"পিছনে অবস্থানকারীদের","audioUrl":"wbw/029_033_024.mp3","charTypeName":"word"},{"id":35708,"position":24,"arabic":"٣٣","translation":"(৩৩)","audioUrl":null,"charTypeName":"end"}]},{"number":34,"arabic":"إِنَّا مُنزِلُونَ عَلَىٰٓ أَهْلِ هَٰذِهِ ٱلْقَرْيَةِ رِجْزًۭا مِّنَ ٱلسَّمَآءِ بِمَا كَانُوا۟ يَفْسُقُونَ","translation":"Verily, we shall bring down upon the people of this land a horror from heaven in requital of all their iniquitous doings!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3374.mp3","surahId":29,"words":[{"id":36642,"position":1,"arabic":"إِنَّا","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/029_034_001.mp3","charTypeName":"word"},{"id":36643,"position":2,"arabic":"مُنزِلُونَ","translation":"অবতরণকারী","audioUrl":"wbw/029_034_002.mp3","charTypeName":"word"},{"id":36644,"position":3,"arabic":"عَلَىٰٓ","translation":"উপর","audioUrl":"wbw/029_034_003.mp3","charTypeName":"word"},{"id":36645,"position":4,"arabic":"أَهْلِ","translation":"অধিবাসীদের","audioUrl":"wbw/029_034_004.mp3","charTypeName":"word"},{"id":36646,"position":5,"arabic":"هَـٰذِهِ","translation":"এই","audioUrl":"wbw/029_034_005.mp3","charTypeName":"word"},{"id":36647,"position":6,"arabic":"ٱلْقَرْيَةِ","translation":"জনপদের","audioUrl":"wbw/029_034_006.mp3","charTypeName":"word"},{"id":36648,"position":7,"arabic":"رِجْزًۭا","translation":"শাস্তি","audioUrl":"wbw/029_034_007.mp3","charTypeName":"word"},{"id":36649,"position":8,"arabic":"مِّنَ","translation":"হ'তে","audioUrl":"wbw/029_034_008.mp3","charTypeName":"word"},{"id":36650,"position":9,"arabic":"ٱلسَّمَآءِ","translation":"আকাশ","audioUrl":"wbw/029_034_009.mp3","charTypeName":"word"},{"id":36651,"position":10,"arabic":"بِمَا","translation":"এ কারণে যা","audioUrl":"wbw/029_034_010.mp3","charTypeName":"word"},{"id":36652,"position":11,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/029_034_011.mp3","charTypeName":"word"},{"id":36653,"position":12,"arabic":"يَفْسُقُونَ","translation":"তারা পাপাচার করে\"","audioUrl":"wbw/029_034_012.mp3","charTypeName":"word"},{"id":36654,"position":13,"arabic":"٣٤","translation":"(৩৪)","audioUrl":null,"charTypeName":"end"}]},{"number":35,"arabic":"وَلَقَد تَّرَكْنَا مِنْهَآ ءَايَةًۢ بَيِّنَةًۭ لِّقَوْمٍۢ يَعْقِلُونَ","translation":"And [so it happened; and] thereof, indeed, We have left a clear sign for people who use their reason.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3375.mp3","surahId":29,"words":[{"id":37508,"position":1,"arabic":"وَلَقَد","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/029_035_001.mp3","charTypeName":"word"},{"id":37509,"position":2,"arabic":"تَّرَكْنَا","translation":"আমরা রেখে দিয়েছি","audioUrl":"wbw/029_035_002.mp3","charTypeName":"word"},{"id":37510,"position":3,"arabic":"مِنْهَآ","translation":"হ:তে তা","audioUrl":"wbw/029_035_003.mp3","charTypeName":"word"},{"id":37511,"position":4,"arabic":"ءَايَةًۢ","translation":"একটি নিদর্শন","audioUrl":"wbw/029_035_004.mp3","charTypeName":"word"},{"id":37512,"position":5,"arabic":"بَيِّنَةًۭ","translation":"সুস্পষ্ট","audioUrl":"wbw/029_035_005.mp3","charTypeName":"word"},{"id":37513,"position":6,"arabic":"لِّقَوْمٍۢ","translation":"জন্যে সম্প্রদায়ের","audioUrl":"wbw/029_035_006.mp3","charTypeName":"word"},{"id":37514,"position":7,"arabic":"يَعْقِلُونَ","translation":"(যারা)বিবেক কাজে লাগায়","audioUrl":"wbw/029_035_007.mp3","charTypeName":"word"},{"id":37515,"position":8,"arabic":"٣٥","translation":"(৩৫)","audioUrl":null,"charTypeName":"end"}]},{"number":36,"arabic":"وَإِلَىٰ مَدْيَنَ أَخَاهُمْ شُعَيْبًۭا فَقَالَ يَٰقَوْمِ ٱعْبُدُوا۟ ٱللَّهَ وَٱرْجُوا۟ ٱلْيَوْمَ ٱلْءَاخِرَ وَلَا تَعْثَوْا۟ فِى ٱلْأَرْضِ مُفْسِدِينَ","translation":"AND UNTO [the people of] Madyan [We sent] their brother Shu’ayb who thereupon said: “O my peo­ple! Worship God [alone], and look forward to the Last Day, and do not act wickedly on earth by spreading corruption!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3376.mp3","surahId":29,"words":[{"id":38381,"position":1,"arabic":"وَإِلَىٰ","translation":"এবং প্রতি","audioUrl":"wbw/029_036_001.mp3","charTypeName":"word"},{"id":38382,"position":2,"arabic":"مَدْيَنَ","translation":"মাদয়ানবাসীদের","audioUrl":"wbw/029_036_002.mp3","charTypeName":"word"},{"id":38383,"position":3,"arabic":"أَخَاهُمْ","translation":"ভাই তাদের","audioUrl":"wbw/029_036_003.mp3","charTypeName":"word"},{"id":38384,"position":4,"arabic":"شُعَيْبًۭا","translation":"শুয়াইবকে (আমরা প্রেরণ করি)","audioUrl":"wbw/029_036_004.mp3","charTypeName":"word"},{"id":38385,"position":5,"arabic":"فَقَالَ","translation":"অতঃপর সে বলেছিলো","audioUrl":"wbw/029_036_005.mp3","charTypeName":"word"},{"id":38386,"position":6,"arabic":"يَـٰقَوْمِ","translation":"\"হে আমার জাতি","audioUrl":"wbw/029_036_006.mp3","charTypeName":"word"},{"id":38387,"position":7,"arabic":"ٱعْبُدُوا۟","translation":"তোমরা ইবাদাত করো","audioUrl":"wbw/029_036_007.mp3","charTypeName":"word"},{"id":38388,"position":8,"arabic":"ٱللَّهَ","translation":"আল্লাহ্‌র","audioUrl":"wbw/029_036_008.mp3","charTypeName":"word"},{"id":38389,"position":9,"arabic":"وَٱرْجُوا۟","translation":"ও (ভালো) আশা রাখো","audioUrl":"wbw/029_036_009.mp3","charTypeName":"word"},{"id":38390,"position":10,"arabic":"ٱلْيَوْمَ","translation":"দিনের","audioUrl":"wbw/029_036_010.mp3","charTypeName":"word"},{"id":38391,"position":11,"arabic":"ٱلْـَٔاخِرَ","translation":"শেষ","audioUrl":"wbw/029_036_011.mp3","charTypeName":"word"},{"id":38392,"position":12,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/029_036_012.mp3","charTypeName":"word"},{"id":38393,"position":13,"arabic":"تَعْثَوْا۟","translation":"তোমরা বাড়াবাড়ি করো","audioUrl":"wbw/029_036_013.mp3","charTypeName":"word"},{"id":38394,"position":14,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/029_036_014.mp3","charTypeName":"word"},{"id":38395,"position":15,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/029_036_015.mp3","charTypeName":"word"},{"id":38396,"position":16,"arabic":"مُفْسِدِينَ","translation":"বিপর্যয় সৃষ্টিকারী হয়ে\"","audioUrl":"wbw/029_036_016.mp3","charTypeName":"word"},{"id":38397,"position":17,"arabic":"٣٦","translation":"(৩৬)","audioUrl":null,"charTypeName":"end"}]},{"number":37,"arabic":"فَكَذَّبُوهُ فَأَخَذَتْهُمُ ٱلرَّجْفَةُ فَأَصْبَحُوا۟ فِى دَارِهِمْ جَٰثِمِينَ","translation":"But they gave him the lie. Thereupon an earthquake overtook them: and then they lay lifeless, in their very homes, on the ground.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3377.mp3","surahId":29,"words":[{"id":39225,"position":1,"arabic":"فَكَذَّبُوهُ","translation":"অতঃপর তারা মিথ্যা সাব্যস্ত করলো তাকে","audioUrl":"wbw/029_037_001.mp3","charTypeName":"word"},{"id":39226,"position":2,"arabic":"فَأَخَذَتْهُمُ","translation":"তখন গ্রাস করলো তাদেরকে","audioUrl":"wbw/029_037_002.mp3","charTypeName":"word"},{"id":39227,"position":3,"arabic":"ٱلرَّجْفَةُ","translation":"ভূমিকম্প","audioUrl":"wbw/029_037_003.mp3","charTypeName":"word"},{"id":39228,"position":4,"arabic":"فَأَصْبَحُوا۟","translation":"ফলে তারা হয়ে গেলো","audioUrl":"wbw/029_037_004.mp3","charTypeName":"word"},{"id":39229,"position":5,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/029_037_005.mp3","charTypeName":"word"},{"id":39230,"position":6,"arabic":"دَارِهِمْ","translation":"ঘরবাড়ির তাদের","audioUrl":"wbw/029_037_006.mp3","charTypeName":"word"},{"id":39231,"position":7,"arabic":"جَـٰثِمِينَ","translation":"নতজানু অবস্থায় (অর্থাৎ মরে পড়ে রইলো)","audioUrl":"wbw/029_037_007.mp3","charTypeName":"word"},{"id":39232,"position":8,"arabic":"٣٧","translation":"(৩৭)","audioUrl":null,"charTypeName":"end"}]},{"number":38,"arabic":"وَعَادًۭا وَثَمُودَا۟ وَقَد تَّبَيَّنَ لَكُم مِّن مَّسَٰكِنِهِمْ ۖ وَزَيَّنَ لَهُمُ ٱلشَّيْطَٰنُ أَعْمَٰلَهُمْ فَصَدَّهُمْ عَنِ ٱلسَّبِيلِ وَكَانُوا۟ مُسْتَبْصِرِينَ","translation":"AND [the tribes of] Ad and Thamud [too, did We destroy -] as should have become obvious to you from [whatever there remains of] their dwellings. [They perished] because Satan had made their [sinful] doings seem goodly to them, and thus had barred them from the path [of God] despite their having been endowed with the ability to perceive the truth.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3378.mp3","surahId":29,"words":[{"id":40028,"position":1,"arabic":"وَعَادًۭا","translation":"এবং আ'দ","audioUrl":"wbw/029_038_001.mp3","charTypeName":"word"},{"id":40029,"position":2,"arabic":"وَثَمُودَا۟","translation":"ও সামূদকেও (ধ্বংস করেছি)","audioUrl":"wbw/029_038_002.mp3","charTypeName":"word"},{"id":40030,"position":3,"arabic":"وَقَد","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/029_038_003.mp3","charTypeName":"word"},{"id":40031,"position":4,"arabic":"تَّبَيَّنَ","translation":"সুস্পষ্ট হয়েছে (তাদের ধ্বংস)","audioUrl":"wbw/029_038_004.mp3","charTypeName":"word"},{"id":40032,"position":5,"arabic":"لَكُم","translation":"জন্যে তোমাদের","audioUrl":"wbw/029_038_005.mp3","charTypeName":"word"},{"id":40033,"position":6,"arabic":"مِّن","translation":"হ'তে","audioUrl":"wbw/029_038_006.mp3","charTypeName":"word"},{"id":40034,"position":7,"arabic":"مَّسَـٰكِنِهِمْ ۖ","translation":"ঘরবাড়িসমূহ তাদের","audioUrl":"wbw/029_038_007.mp3","charTypeName":"word"},{"id":40036,"position":8,"arabic":"وَزَيَّنَ","translation":"শোভন করেছিলো","audioUrl":"wbw/029_038_009.mp3","charTypeName":"word"},{"id":40037,"position":9,"arabic":"لَهُمُ","translation":"নিকট তাদের","audioUrl":"wbw/029_038_010.mp3","charTypeName":"word"},{"id":40038,"position":10,"arabic":"ٱلشَّيْطَـٰنُ","translation":"শয়তান","audioUrl":"wbw/029_038_011.mp3","charTypeName":"word"},{"id":40039,"position":11,"arabic":"أَعْمَـٰلَهُمْ","translation":"কাজগুলোকে তাদের","audioUrl":"wbw/029_038_012.mp3","charTypeName":"word"},{"id":40040,"position":12,"arabic":"فَصَدَّهُمْ","translation":"অতঃপর বাঁধা দিয়েছিলো তাদেরকে","audioUrl":"wbw/029_038_013.mp3","charTypeName":"word"},{"id":40041,"position":13,"arabic":"عَنِ","translation":"হ'তে","audioUrl":"wbw/029_038_014.mp3","charTypeName":"word"},{"id":40042,"position":14,"arabic":"ٱلسَّبِيلِ","translation":"(সঠিক) পথ","audioUrl":"wbw/029_038_015.mp3","charTypeName":"word"},{"id":40043,"position":15,"arabic":"وَكَانُوا۟","translation":"কিন্তু তারা ছিলো","audioUrl":"wbw/029_038_016.mp3","charTypeName":"word"},{"id":40044,"position":16,"arabic":"مُسْتَبْصِرِينَ","translation":"কাণ্ডজ্ঞানসম্পন্ন বিচক্ষণ","audioUrl":"wbw/029_038_017.mp3","charTypeName":"word"},{"id":40045,"position":17,"arabic":"٣٨","translation":"(৩৮)","audioUrl":null,"charTypeName":"end"}]}]}