ame":"word"},{"id":84706,"position":3,"arabic":"لَا","translation":"না","audioUrl":"wbw/007_191_003.mp3","charTypeName":"word"},{"id":84707,"position":4,"arabic":"يَخْلُقُ","translation":"সৃষ্টি করতে পারে","audioUrl":"wbw/007_191_004.mp3","charTypeName":"word"},{"id":84708,"position":5,"arabic":"شَيْـًۭٔا","translation":"কোনো কিছু","audioUrl":"wbw/007_191_005.mp3","charTypeName":"word"},{"id":84709,"position":6,"arabic":"وَهُمْ","translation":"অথচ তাদেরকে","audioUrl":"wbw/007_191_006.mp3","charTypeName":"word"},{"id":84710,"position":7,"arabic":"يُخْلَقُونَ","translation":"সৃষ্টি করা হয়","audioUrl":"wbw/007_191_007.mp3","charTypeName":"word"},{"id":84711,"position":8,"arabic":"١٩١","translation":"(১৯১)","audioUrl":null,"charTypeName":"end"}]},{"number":192,"arabic":"وَلَا يَسْتَطِيعُونَ لَهُمْ نَصْرًۭا وَلَآ أَنفُسَهُمْ يَنصُرُونَ","translation":"and neither are able to give them succour nor can succour themselves,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1146.mp3","surahId":7,"words":[{"id":84737,"position":1,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/007_192_001.mp3","charTypeName":"word"},{"id":84738,"position":2,"arabic":"يَسْتَطِيعُونَ","translation":"তারা সামর্থ্য রাখে","audioUrl":"wbw/007_192_002.mp3","charTypeName":"word"},{"id":84739,"position":3,"arabic":"لَهُمْ","translation":"জন্যে তাদের","audioUrl":"wbw/007_192_003.mp3","charTypeName":"word"},{"id":84740,"position":4,"arabic":"نَصْرًۭا","translation":"সাহায্য করতে","audioUrl":"wbw/007_192_004.mp3","charTypeName":"word"},{"id":84741,"position":5,"arabic":"وَلَآ","translation":"আর না","audioUrl":"wbw/007_192_005.mp3","charTypeName":"word"},{"id":84742,"position":6,"arabic":"أَنفُسَهُمْ","translation":"তাদের নিজেদের জন্যে","audioUrl":"wbw/007_192_006.mp3","charTypeName":"word"},{"id":84743,"position":7,"arabic":"يَنصُرُونَ","translation":"তারা সাহায্য করতে পারর","audioUrl":"wbw/007_192_007.mp3","charTypeName":"word"},{"id":84744,"position":8,"arabic":"١٩٢","translati