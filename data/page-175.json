rd"},{"id":84802,"position":13,"arabic":"١٩٣","translation":"(১৯৩)","audioUrl":null,"charTypeName":"end"}]},{"number":194,"arabic":"إِنَّ ٱلَّذِينَ تَدْعُونَ مِن دُونِ ٱللَّهِ عِبَادٌ أَمْثَالُكُمْ ۖ فَٱدْعُوهُمْ فَلْيَسْتَجِيبُوا۟ لَكُمْ إِن كُنتُمْ صَٰدِقِينَ","translation":"Verily, all those whom you invoke beside God are but created beings like yourselves: invoke them, then, and let them answer your prayer - if what you claim is true!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1148.mp3","surahId":7,"words":[{"id":84825,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/007_194_001.mp3","charTypeName":"word"},{"id":84826,"position":2,"arabic":"ٱلَّذِينَ","translation":"যাদের (কাছে)","audioUrl":"wbw/007_194_002.mp3","charTypeName":"word"},{"id":84827,"position":3,"arabic":"تَدْعُونَ","translation":"তোমরা প্রার্থনা করো","audioUrl":"wbw/007_194_003.mp3","charTypeName":"word"},{"id":84828,"position":4,"arabic":"مِن","translation":"দিয়ে","audioUrl":"wbw/007_194_004.mp3","charTypeName":"word"},{"id":84829,"position":5,"arabic":"دُونِ","translation":"ছেড়ে","audioUrl":"wbw/007_194_005.mp3","charTypeName":"word"},{"id":84830,"position":6,"arabic":"ٱللَّهِ","translation":"আল্লাহকে","audioUrl":"wbw/007_194_006.mp3","charTypeName":"word"},{"id":84831,"position":7,"arabic":"عِبَادٌ","translation":"তারা দাস","audioUrl":"wbw/007_194_007.mp3","charTypeName":"word"},{"id":84832,"position":8,"arabic":"أَمْثَالُكُمْ ۖ","translation":"মতো তোমাদেরই","audioUrl":"wbw/007_194_008.mp3","charTypeName":"word"},{"id":84834,"position":9,"arabic":"فَٱدْعُوهُمْ","translation":"তাহ'লে তোমরা ডেকে দেখো তাদেরকে","audioUrl":"wbw/007_194_010.mp3","charTypeName":"word"},{"id":84835,"position":10,"arabic":"فَلْيَسْتَجِيبُوا۟","translation":"তখন তারা সাড়া দিক","audioUrl":"wbw/007_194_011.mp3","charTypeName":"word"},{"id":84836,"position":11,"arabic":"لَكُمْ","translation":"তোমাদের","audioUrl":"wbw/007_194_012.mp3","charTypeName":"word"},{"id":84837,"position":