TypeName":"word"},{"id":41232,"position":34,"arabic":"يَـٰمُوسَىٰ","translation":"হে মূসা","audioUrl":"wbw/020_040_037.mp3","charTypeName":"word"},{"id":41233,"position":35,"arabic":"٤٠","translation":"(৪০)","audioUrl":null,"charTypeName":"end"}]},{"number":41,"arabic":"وَٱصْطَنَعْتُكَ لِنَفْسِى","translation":"for I have chosen thee for Mine Own service.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2389.mp3","surahId":20,"words":[{"id":42077,"position":1,"arabic":"وَٱصْطَنَعْتُكَ","translation":"এবং তোমাকে আমি প্রস্তুত করেছি","audioUrl":"wbw/020_041_001.mp3","charTypeName":"word"},{"id":42078,"position":2,"arabic":"لِنَفْسِى","translation":"আমার নিজের (কাজের) জন্যে","audioUrl":"wbw/020_041_002.mp3","charTypeName":"word"},{"id":42079,"position":3,"arabic":"٤١","translation":"(৪১)","audioUrl":null,"charTypeName":"end"}]},{"number":42,"arabic":"ٱذْهَبْ أَنتَ وَأَخُوكَ بِـَٔايَٰتِى وَلَا تَنِيَا فِى ذِكْرِى","translation":"\"Go forth, [then,] thou and thy brother, with My messages, and never tire of remembering Me:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2390.mp3","surahId":20,"words":[{"id":42865,"position":1,"arabic":"ٱذْهَبْ","translation":"যাও","audioUrl":"wbw/020_042_001.mp3","charTypeName":"word"},{"id":42866,"position":2,"arabic":"أَنتَ","translation":"তুমি","audioUrl":"wbw/020_042_002.mp3","charTypeName":"word"},{"id":42867,"position":3,"arabic":"وَأَخُوكَ","translation":"ও তোমার ভাই","audioUrl":"wbw/020_042_003.mp3","charTypeName":"word"},{"id":42868,"position":4,"arabic":"بِـَٔايَـٰتِى","translation":"নিয়ে আমার নির্দেশনাবলী","audioUrl":"wbw/020_042_004.mp3","charTypeName":"word"},{"id":42869,"position":5,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/020_042_005.mp3","charTypeName":"word"},{"id":42870,"position":6,"arabic":"تَنِيَا","translation":"তোমরা দু'জনে আসল্য করো","audioUrl":"wbw/020_042_006.mp3","charTypeName":"word"},{"id":42871,"position":7,"arabic":"فِى","translation":"ক্ষেত্রে","audioUrl":"wbw/020_042_007.mp3","charTypeName":"word"},{"id":42872,"position":8,"arabic":"ذِكْرِى","translation":"আমার স্মরণের","audioUrl":"wbw/020_042_008.mp3","charTypeName":"word"},{"id":42873,"position":9,"arabic":"٤٢","translation":"(৪২)","audioUrl":null,"charTypeName":"end"}]},{"number":43,"arabic":"ٱذْهَبَآ إِلَىٰ فِرْعَوْنَ إِنَّهُۥ طَغَىٰ","translation":"go forth, both of you, unto Pharaoh: for, verily, he has transgressed all bounds of equity!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2391.mp3","surahId":20,"words":[{"id":43602,"position":1,"arabic":"ٱذْهَبَآ","translation":"দু'জনে যাও","audioUrl":"wbw/020_043_001.mp3","charTypeName":"word"},{"id":43603,"position":2,"arabic":"إِلَىٰ","translation":"নিকট","audioUrl":"wbw/020_043_002.mp3","charTypeName":"word"},{"id":43604,"position":3,"arabic":"فِرْعَوْنَ","translation":"ফিরআউনের","audioUrl":"wbw/020_043_003.mp3","charTypeName":"word"},{"id":43605,"position":4,"arabic":"إِنَّهُۥ","translation":"সে নিশ্চয়ই","audioUrl":"wbw/020_043_004.mp3","charTypeName":"word"},{"id":43606,"position":5,"arabic":"طَغَىٰ","translation":"সীমালঙ্ঘন করেছে","audioUrl":"wbw/020_043_005.mp3","charTypeName":"word"},{"id":43607,"position":6,"arabic":"٤٣","translation":"(৪৩)","audioUrl":null,"charTypeName":"end"}]},{"number":44,"arabic":"فَقُولَا لَهُۥ قَوْلًۭا لَّيِّنًۭا لَّعَلَّهُۥ يَتَذَكَّرُ أَوْ يَخْشَىٰ","translation":"But speak unto him in a mild manner, so that he might bethink himself or [at least] be filled with apprehension.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2392.mp3","surahId":20,"words":[{"id":44704,"position":1,"arabic":"فَقُولَا","translation":"অতঃপর দু'জনে বলবে","audioUrl":"wbw/020_044_001.mp3","charTypeName":"word"},{"id":44705,"position":2,"arabic":"لَهُۥ","translation":"তার সাথে","audioUrl":"wbw/020_044_002.mp3","charTypeName":"word"},{"id":44706,"position":3,"arabic":"قَوْلًۭا","translation":"কথা","audioUrl":"wbw/020_044_003.mp3","charTypeName":"word"},{"id":44707,"position":4,"arabic":"لَّيِّنًۭا","translation":"নম্রভাবে","audioUrl":"wbw/020_044_004.mp3","charTypeName":"word"},{"id":44708,"position":5,"arabic":"لَّعَلَّهُۥ","translation":"সে সম্ভবতঃ","audioUrl":"wbw/020_044_005.mp3","charTypeName":"word"},{"id":44709,"position":6,"arabic":"يَتَذَكَّرُ","translation":"উপদেশ গ্রহণ করবে","audioUrl":"wbw/020_044_006.mp3","charTypeName":"word"},{"id":44710,"position":7,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/020_044_007.mp3","charTypeName":"word"},{"id":44711,"position":8,"arabic":"يَخْشَىٰ","translation":"ভয় করবে\"","audioUrl":"wbw/020_044_008.mp3","charTypeName":"word"},{"id":44712,"position":9,"arabic":"٤٤","translation":"(৪৪)","audioUrl":null,"charTypeName":"end"}]},{"number":45,"arabic":"قَالَا رَبَّنَآ إِنَّنَا نَخَافُ أَن يَفْرُطَ عَلَيْنَآ أَوْ أَن يَطْغَىٰ","translation":"The two [brothers] said: \"O our Sustainer! Verily, we fear lest he act hastily with regard to us, or lest he [continue to] transgress all bounds of equity.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2393.mp3","surahId":20,"words":[{"id":45366,"position":1,"arabic":"قَالَا","translation":"তারা (দু'জনে) বললো","audioUrl":"wbw/020_045_001.mp3","charTypeName":"word"},{"id":45367,"position":2,"arabic":"رَبَّنَآ","translation":"\"হে আমাদের রব","audioUrl":"wbw/020_045_002.mp3","charTypeName":"word"},{"id":45368,"position":3,"arabic":"إِنَّنَا","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/020_045_003.mp3","charTypeName":"word"},{"id":45369,"position":4,"arabic":"نَخَافُ","translation":"আশংকা করি আমরা","audioUrl":"wbw/020_045_004.mp3","charTypeName":"word"},{"id":45370,"position":5,"arabic":"أَن","translation":"যে","audioUrl":"wbw/020_045_005.mp3","charTypeName":"word"},{"id":45371,"position":6,"arabic":"يَفْرُطَ","translation":"ফিরআউন দুর্ব্যবহার করবে","audioUrl":"wbw/020_045_006.mp3","charTypeName":"word"},{"id":45372,"position":7,"arabic":"عَلَيْنَآ","translation":"আমাদের সাথে","audioUrl":"wbw/020_045_007.mp3","charTypeName":"word"},{"id":45373,"position":8,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/020_045_008.mp3","charTypeName":"word"},{"id":45374,"position":9,"arabic":"أَن","translation":"যে","audioUrl":"wbw/020_045_009.mp3","charTypeName":"word"},{"id":45375,"position":10,"arabic":"يَطْغَىٰ","translation":"সে সীমালংঘন করবে\"","audioUrl":"wbw/020_045_010.mp3","charTypeName":"word"},{"id":45376,"position":11,"arabic":"٤٥","translation":"(৪৫)","audioUrl":null,"charTypeName":"end"}]},{"number":46,"arabic":"قَالَ لَا تَخَافَآ ۖ إِنَّنِى مَعَكُمَآ أَسْمَعُ وَأَرَىٰ","translation":"Answered He: \"Fear not! Verily, I shall be with you two, hearing and seeing [all].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2394.mp3","surahId":20,"words":[{"id":46205,"position":1,"arabic":"قَالَ","translation":"তিনি বললেন","audioUrl":"wbw/020_046_001.mp3","charTypeName":"word"},{"id":46206,"position":2,"arabic":"لَا","translation":"\"না","audioUrl":"wbw/020_046_002.mp3","charTypeName":"word"},{"id":46207,"position":3,"arabic":"تَخَافَآ ۖ","translation":"তোমরা দু'জনে ভয় করো","audioUrl":"wbw/020_046_003.mp3","charTypeName":"word"},{"id":46209,"position":4,"arabic":"إِنَّنِى","translation":"আমি নিশ্চয়ই","audioUrl":"wbw/020_046_005.mp3","charTypeName":"word"},{"id":46210,"position":5,"arabic":"مَعَكُمَآ","translation":"তোমাদের দু'জনের সাথে (আছি)","audioUrl":"wbw/020_046_006.mp3","charTypeName":"word"},{"id":46211,"position":6,"arabic":"أَسْمَعُ","translation":"আমি শুনি (সবকিছু)","audioUrl":"wbw/020_046_007.mp3","charTypeName":"word"},{"id":46212,"position":7,"arabic":"وَأَرَىٰ","translation":"ও আমি দেখি (সবকিছু)","audioUrl":"wbw/020_046_008.mp3","charTypeName":"word"},{"id":46213,"position":8,"arabic":"٤٦","translation":"(৪৬)","audioUrl":null,"charTypeName":"end"}]},{"number":47,"arabic":"فَأْتِيَاهُ فَقُولَآ إِنَّا رَسُولَا رَبِّكَ فَأَرْسِلْ مَعَنَا بَنِىٓ إِسْرَٰٓءِيلَ وَلَا تُعَذِّبْهُمْ ۖ قَدْ جِئْنَٰكَ بِـَٔايَةٍۢ مِّن رَّبِّكَ ۖ وَٱلسَّلَٰمُ عَلَىٰ مَنِ ٱتَّبَعَ ٱلْهُدَىٰٓ","translation":"Go, then; you two unto him and say, `Behold, we are apostles sent by thy Sustainer: let, then, the children of Israel go with us, and cause them not to suffer [any longer]. We have now come unto thee with a message from thy Sustainer; and [know that His] peace shall be [only] on those who follow [His] guidance:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2395.mp3","surahId":20,"words":[{"id":46737,"position":1,"arabic":"فَأْتِيَاهُ","translation":"সুতরাং তার কাছে দু'জনে যাও","audioUrl":"wbw/020_047_001.mp3","charTypeName":"word"},{"id":46738,"position":2,"arabic":"فَقُولَآ","translation":"অতঃপর দু'জনে বলো","audioUrl":"wbw/020_047_002.mp3","charTypeName":"word"},{"id":46739,"position":3,"arabic":"إِنَّا","translation":"\"নিশ্চয়ই আমরা","audioUrl":"wbw/020_047_003.mp3","charTypeName":"word"},{"id":46740,"position":4,"arabic":"رَسُولَا","translation":"দুই রাসূল","audioUrl":"wbw/020_047_004.mp3","charTypeName":"word"},{"id":46741,"position":5,"arabic":"رَبِّكَ","translation":"তোমার রবের","audioUrl":"wbw/020_047_005.mp3","charTypeName":"word"},{"id":46742,"position":6,"arabic":"فَأَرْسِلْ","translation":"সুতরাং পাঠাও","audioUrl":"wbw/020_047_006.mp3","charTypeName":"word"},{"id":46743,"position":7,"arabic":"مَعَنَا","translation":"আমাদের সাথে","audioUrl":"wbw/020_047_007.mp3","charTypeName":"word"},{"id":46744,"position":8,"arabic":"بَنِىٓ","translation":"বনী","audioUrl":"wbw/020_047_008.mp3","charTypeName":"word"},{"id":46745,"position":9,"arabic":"إِسْرَٰٓءِيلَ","translation":"ইসরাঈলকে","audioUrl":"wbw/020_047_009.mp3","charTypeName":"word"},{"id":46746,"position":10,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/020_047_010.mp3","charTypeName":"word"},{"id":46747,"position":11,"arabic":"تُعَذِّبْهُمْ ۖ","translation":"তাদেরকে শাস্তি দিও","audioUrl":"wbw/020_047_011.mp3","charTypeName":"word"},{"id":46749,"position":12,"arabic":"قَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/020_047_013.mp3","charTypeName":"word"},{"id"