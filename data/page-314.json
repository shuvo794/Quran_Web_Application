ord"},{"id":49179,"position":3,"arabic":"بَالُ","translation":"অবস্থা","audioUrl":"wbw/020_051_003.mp3","charTypeName":"word"},{"id":49180,"position":4,"arabic":"ٱلْقُرُونِ","translation":"শত শত বছরের বংশধরদের","audioUrl":"wbw/020_051_004.mp3","charTypeName":"word"},{"id":49181,"position":5,"arabic":"ٱلْأُولَىٰ","translation":"পূর্বের\"","audioUrl":"wbw/020_051_005.mp3","charTypeName":"word"},{"id":49182,"position":6,"arabic":"٥١","translation":"(৫১)","audioUrl":null,"charTypeName":"end"}]}]}