{"id":314,"ayahs":[{"number":38,"arabic":"إِذْ أَوْحَيْنَآ إِلَىٰٓ أُمِّكَ مَا يُوحَىٰٓ","translation":"when We inspired thy mother with this inspiration:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2386.mp3","surahId":20,"words":[{"id":39698,"position":1,"arabic":"إِذْ","translation":"(স্মরণ করো) যখন","audioUrl":"wbw/020_038_001.mp3","charTypeName":"word"},{"id":39699,"position":2,"arabic":"أَوْحَيْنَآ","translation":"আমরা ইঙ্গিত করেছিলাম","audioUrl":"wbw/020_038_002.mp3","charTypeName":"word"},{"id":39700,"position":3,"arabic":"إِلَىٰٓ","translation":"প্রতি","audioUrl":"wbw/020_038_003.mp3","charTypeName":"word"},{"id":39701,"position":4,"arabic":"أُمِّكَ","translation":"তোমার মার","audioUrl":"wbw/020_038_004.mp3","charTypeName":"word"},{"id":39702,"position":5,"arabic":"مَا","translation":"(এভাবে) যা","audioUrl":"wbw/020_038_005.mp3","charTypeName":"word"},{"id":39703,"position":6,"arabic":"يُوحَىٰٓ","translation":"ওহী করা হয়।","audioUrl":"wbw/020_038_006.mp3","charTypeName":"word"},{"id":39704,"position":7,"arabic":"٣٨","translation":"(৩৮)","audioUrl":null,"charTypeName":"end"}]},{"number":39,"arabic":"أَنِ ٱقْذِفِيهِ فِى ٱلتَّابُوتِ فَٱقْذِفِيهِ فِى ٱلْيَمِّ فَلْيُلْقِهِ ٱلْيَمُّ بِٱلسَّاحِلِ يَأْخُذْهُ عَدُوٌّۭ لِّى وَعَدُوٌّۭ لَّهُۥ ۚ وَأَلْقَيْتُ عَلَيْكَ مَحَبَّةًۭ مِّنِّى وَلِتُصْنَعَ عَلَىٰ عَيْنِىٓ","translation":"Place him in a chest and throw it into the river, and thereupon the river will cast him ashore, [and] one who is an enemy unto Me and an enemy unto him will adopt him. \"And [thus early] I spread Mine Own love over thee -and [this] in order that thou might be formed under Mine eye.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2387.mp3","surahId":20,"words":[{"id":40494,"position":1,"arabic":"أَنِ","translation":"\"যে","audioUrl":"wbw/020_039_001.mp3","charTypeName":"word"},{"id":40495,"position":2,"arabic":"ٱقْذِفِيهِ","translation":"তাকে নিক্ষেপ করো (অর্থাৎ রেখে দাও)","audioUrl":"wbw/020_039_002.mp3","charTypeName":"word"},{"id":40496,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/020_039_003.mp3","charTypeName":"word"},{"id":40497,"position":4,"arabic":"ٱلتَّابُوتِ","translation":"সিন্দুকের","audioUrl":"wbw/020_039_004.mp3","charTypeName":"word"},{"id":40498,"position":5,"arabic":"فَٱقْذِفِيهِ","translation":"অতঃপর তা নিক্ষেপ করো (অর্থাৎ ভাসিয়ে দাও)","audioUrl":"wbw/020_039_005.mp3","charTypeName":"word"},{"id":40499,"position":6,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/020_039_006.mp3","charTypeName":"word"},{"id":40500,"position":7,"arabic":"ٱلْيَمِّ","translation":"নদীর","audioUrl":"wbw/020_039_007.mp3","charTypeName":"word"},{"id":40501,"position":8,"arabic":"فَلْيُلْقِهِ","translation":"অতঃপর তা ঠেলে দিবে","audioUrl":"wbw/020_039_008.mp3","charTypeName":"word"},{"id":40502,"position":9,"arabic":"ٱلْيَمُّ","translation":"নদী","audioUrl":"wbw/020_039_009.mp3","charTypeName":"word"},{"id":40503,"position":10,"arabic":"بِٱلسَّاحِلِ","translation":"তীরের দিকে","audioUrl":"wbw/020_039_010.mp3","charTypeName":"word"},{"id":40504,"position":11,"arabic":"يَأْخُذْهُ","translation":"তা তুলে নিবে","audioUrl":"wbw/020_039_011.mp3","charTypeName":"word"},{"id":40505,"position":12,"arabic":"عَدُوٌّۭ","translation":"শত্রু","audioUrl":"wbw/020_039_012.mp3","charTypeName":"word"},{"id":40506,"position":13,"arabic":"لِّى","translation":"আমার","audioUrl":"wbw/020_039_013.mp3","charTypeName":"word"},{"id":40507,"position":14,"arabic":"وَعَدُوٌّۭ","translation":"ও শত্রু","audioUrl":"wbw/020_039_014.mp3","charTypeName":"word"},{"id":40508,"position":15,"arabic":"لَّهُۥ ۚ","translation":"তার\"","audioUrl":"wbw/020_039_015.mp3","charTypeName":"word"},{"id":40510,"position":16,"arabic":"وَأَلْقَيْتُ","translation":"এবং আমি ঢেলে দিয়েছিলাম","audioUrl":"wbw/020_039_017.mp3","charTypeName":"word"},{"id":40511,"position":17,"arabic":"عَلَيْكَ","translation":"তোমার উপর","audioUrl":"wbw/020_039_018.mp3","charTypeName":"word"},{"id":40512,"position":18,"arabic":"مَحَبَّةًۭ","translation":"ভালবাসা","audioUrl":"wbw/020_039_019.mp3","charTypeName":"word"},{"id":40513,"position":19,"arabic":"مِّنِّى","translation":"আমার পক্ষ হ'তে","audioUrl":"wbw/020_039_020.mp3","charTypeName":"word"},{"id":40514,"position":20,"arabic":"وَلِتُصْنَعَ","translation":"এবং তুমি লালিতপালিত হও যেন","audioUrl":"wbw/020_039_021.mp3","charTypeName":"word"},{"id":40515,"position":21,"arabic":"عَلَىٰ","translation":"সামনে","audioUrl":"wbw/020_039_022.mp3","charTypeName":"word"},{"id":40516,"position":22,"arabic":"عَيْنِىٓ","translation":"আমার চোখের","audioUrl":"wbw/020_039_023.mp3","charTypeName":"word"},{"id":40517,"position":23,"arabic":"٣٩","translation":"(৩৯)","audioUrl":null,"charTypeName":"end"}]},{"number":40,"arabic":"إِذْ تَمْشِىٓ أُخْتُكَ فَتَقُولُ هَلْ أَدُلُّكُمْ عَلَىٰ مَن يَكْفُلُهُۥ ۖ فَرَجَعْنَٰكَ إِلَىٰٓ أُمِّكَ كَىْ تَقَرَّ عَيْنُهَا وَلَا تَحْزَنَ ۚ وَقَتَلْتَ نَفْسًۭا فَنَجَّيْنَٰكَ مِنَ ٱلْغَمِّ وَفَتَنَّٰكَ فُتُونًۭا ۚ فَلَبِثْتَ سِنِينَ فِىٓ أَهْلِ مَدْيَنَ ثُمَّ جِئْتَ عَلَىٰ قَدَرٍۢ يَٰمُوسَىٰ","translation":"\"[And thou wert under Mine eye] when thy sister went forth and said [to Pharaoh's people], 'Shall I guide you unto [a woman] who might take charge of him?'' And so We returned thee unto thy mother, so that her eye be gladdened, and that she might not sorrow [any longer]. \"And [when thou camest of age, thou didst slay a man: but We did save thee from all grief, although We tried thee with various trials. \"And then thou didst sojourn for years among the people of Madyan; and now thou hast come [here] as ordained [by Me], O Moses:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2388.mp3","surahId":20,"words":[{"id":41196,"position":1,"arabic":"إِذْ","translation":"(স্মরণ করো) যখন","audioUrl":"wbw/020_040_001.mp3","charTypeName":"word"},{"id":41197,"position":2,"arabic":"تَمْشِىٓ","translation":"চলেছিলো","audioUrl":"wbw/020_040_002.mp3","charTypeName":"word"},{"id":41198,"position":3,"arabic":"أُخْتُكَ","translation":"তোমার বোন","audioUrl":"wbw/020_040_003.mp3","charTypeName":"word"},{"id":41199,"position":4,"arabic":"فَتَقُولُ","translation":"অতঃপর বলেছিলো","audioUrl":"wbw/020_040_004.mp3","charTypeName":"word"},{"id":41200,"position":5,"arabic":"هَلْ","translation":"\"কি","audioUrl":"wbw/020_040_005.mp3","charTypeName":"word"},{"id":41201,"position":6,"arabic":"أَدُلُّكُمْ","translation":"তোমাদের খোঁজ দিবো","audioUrl":"wbw/020_040_006.mp3","charTypeName":"word"},{"id":41202,"position":7,"arabic":"عَلَىٰ","translation":"এ বিষয়ে (যে)","audioUrl":"wbw/020_040_007.mp3","charTypeName":"word"},{"id":41203,"position":8,"arabic":"مَن","translation":"কে","audioUrl":"wbw/020_040_008.mp3","charTypeName":"word"},{"id":41204,"position":9,"arabic":"يَكْفُلُهُۥ ۖ","translation":"তাকে লালন-পালন করতে পারে\"","audioUrl":"wbw/020_040_009.mp3","charTypeName":"word"},{"id":41206,"position":10,"arabic":"فَرَجَعْنَـٰكَ","translation":"তখন তোমাকে আমরা ফিরিয়ে দিলাম","audioUrl":"wbw/020_040_011.mp3","charTypeName":"word"},{"id":41207,"position":11,"arabic":"إِلَىٰٓ","translation":"কাছে","audioUrl":"wbw/020_040_012.mp3","charTypeName":"word"},{"id":41208,"position":12,"arabic":"أُمِّكَ","translation":"তোমার মায়ের","audioUrl":"wbw/020_040_013.mp3","charTypeName":"word"},{"id":41209,"position":13,"arabic":"كَىْ","translation":"যেন","audioUrl":"wbw/020_040_014.mp3","charTypeName":"word"},{"id":41210,"position":14,"arabic":"تَقَرَّ","translation":"জুড়ায়","audioUrl":"wbw/020_040_015.mp3","charTypeName":"word"},{"id":41211,"position":15,"arabic":"عَيْنُهَا","translation":"তার চোখ","audioUrl":"wbw/020_040_016.mp3","charTypeName":"word"},{"id":41212,"position":16,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/020_040_017.mp3","charTypeName":"word"},{"id":41213,"position":17,"arabic":"تَحْزَنَ ۚ","translation":"দুঃখ পায়","audioUrl":"wbw/020_040_018.mp3","charTypeName":"word"},{"id":41215,"position":18,"arabic":"وَقَتَلْتَ","translation":"এবং (স্মরণ করো) তুমি হত্যা করেছিলে","audioUrl":"wbw/0