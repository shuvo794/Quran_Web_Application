TypeName":"word"},{"id":47251,"position":4,"arabic":"إِلَيْنَآ","translation":"প্রতি আমাদের","audioUrl":"wbw/020_048_004.mp3","charTypeName":"word"},{"id":47252,"position":5,"arabic":"أَنَّ","translation":"যে","audioUrl":"wbw/020_048_005.mp3","charTypeName":"word"},{"id":47253,"position":6,"arabic":"ٱلْعَذَابَ","translation":"শাস্তি","audioUrl":"wbw/020_048_006.mp3","charTypeName":"word"},{"id":47254,"position":7,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/020_048_007.mp3","charTypeName":"word"},{"id":47255,"position":8,"arabic":"مَن","translation":"(তার) যে","audioUrl":"wbw/020_048_008.mp3","charTypeName":"word"},{"id":47256,"position":9,"arabic":"كَذَّبَ","translation":"মিথ্যারোপ করবে","audioUrl":"wbw/020_048_009.mp3","charTypeName":"word"},{"id":47257,"position":10,"arabic":"وَتَوَلَّىٰ","translation":"ও মুখ ফিরাবে (অমান্য করবে)\"","audioUrl":"wbw/020_048_010.mp3","charTypeName":"word"},{"id":47258,"position":11,"arabic":"٤٨","translation":"(৪৮)","audioUrl":null,"charTypeName":"end"}]},{"number":49,"arabic":"قَالَ فَمَن رَّبُّكُمَا يَٰمُوسَىٰ","translation":"[But when God's message was conveyed unto Pharaoh,] he said: \"Who, now, is this Sustainer of you two, O Moses?\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2397.mp3","surahId":20,"words":[{"id":47869,"position":1,"arabic":"قَالَ","translation":"(ফিরআউন) বললো","audioUrl":"wbw/020_049_001.mp3","charTypeName":"word"},{"id":47870,"position":2,"arabic":"فَمَن","translation":"\"তাহ'লে কে","audioUrl":"wbw/020_049_002.mp3","charTypeName":"word"},{"id":47871,"position":3,"arabic":"رَّبُّكُمَا","translation":"তোমাদের দু'জনের রব","audioUrl":"wbw/020_049_003.mp3","charTypeName":"word"},{"id":47872,"position":4,"arabic":"يَـٰمُوسَىٰ","translation":"হে মূসা\"","audioUrl":"wbw/020_049_004.mp3","charTypeName":"word"},{"id":47873,"position":5,"arabic":"٤٩","translation":"(৪৯)","audioUrl":null,"charTypeName":"end"}]},{"number":50,"arabic":"قَالَ رَبُّنَا ٱلَّذِىٓ أَعْطَىٰ كُلَّ شَىْءٍ خَلْقَهُ