},{"id":69523,"position":10,"arabic":"يَقْرَءُونَ","translation":"পাঠ করে","audioUrl":"wbw/010_094_010.mp3","charTypeName":"word"},{"id":69524,"position":11,"arabic":"ٱلْكِتَـٰبَ","translation":"কিতাব","audioUrl":"wbw/010_094_011.mp3","charTypeName":"word"},{"id":69525,"position":12,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/010_094_012.mp3","charTypeName":"word"},{"id":69526,"position":13,"arabic":"قَبْلِكَ ۚ","translation":"পূর্ব তোমার","audioUrl":"wbw/010_094_013.mp3","charTypeName":"word"},{"id":69528,"position":14,"arabic":"لَقَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/010_094_015.mp3","charTypeName":"word"},{"id":69529,"position":15,"arabic":"جَآءَكَ","translation":"কাছে এসেছে তোমার","audioUrl":"wbw/010_094_016.mp3","charTypeName":"word"},{"id":69530,"position":16,"arabic":"ٱلْحَقُّ","translation":"(প্রকৃত) সত্য","audioUrl":"wbw/010_094_017.mp3","charTypeName":"word"},{"id":69531,"position":17,"arabic":"مِن","translation":"পক্ষ হতে","audioUrl":"wbw/010_094_018.mp3","charTypeName":"word"},{"id":69532,"position":18,"arabic":"رَّبِّكَ","translation":"তোমার রবের","audioUrl":"wbw/010_094_019.mp3","charTypeName":"word"},{"id":69533,"position":19,"arabic":"فَلَا","translation":"অতএব না","audioUrl":"wbw/010_094_020.mp3","charTypeName":"word"},{"id":69534,"position":20,"arabic":"تَكُونَنَّ","translation":"তুমি হয়ো","audioUrl":"wbw/010_094_021.mp3","charTypeName":"word"},{"id":69535,"position":21,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/010_094_022.mp3","charTypeName":"word"},{"id":69536,"position":22,"arabic":"ٱلْمُمْتَرِينَ","translation":"সন্দিহানদের","audioUrl":"wbw/010_094_023.mp3","charTypeName":"word"},{"id":69537,"position":23,"arabic":"٩٤","translation":"(৯৪)","audioUrl":null,"charTypeName":"end"}]},{"number":95,"arabic":"وَلَا تَكُونَنَّ مِنَ ٱلَّذِينَ كَذَّبُوا۟ بِـَٔايَٰتِ ٱللَّهِ فَتَكُونَ مِنَ ٱلْخَٰسِرِينَ","translation":"and neither be among those who are bent on giving the lie to God's messages, lest thou find thyself amon