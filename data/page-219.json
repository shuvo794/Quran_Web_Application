{"id":219,"ayahs":[{"number":89,"arabic":"قَالَ قَدْ أُجِيبَت دَّعْوَتُكُمَا فَٱسْتَقِيمَا وَلَا تَتَّبِعَآنِّ سَبِيلَ ٱلَّذِينَ لَا يَعْلَمُونَ","translation":"[God] answered: \"Accepted is this your prayer! Continue, then, both of you, steadfastly on the right way, and follow not the path of those who have no knowledge [of right and wrong].\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1453.mp3","surahId":10,"words":[{"id":67789,"position":1,"arabic":"قَالَ","translation":"তিনি (আল্লাহ)বললেন","audioUrl":"wbw/010_089_001.mp3","charTypeName":"word"},{"id":67790,"position":2,"arabic":"قَدْ","translation":"\"নিশ্চয়ই","audioUrl":"wbw/010_089_002.mp3","charTypeName":"word"},{"id":67791,"position":3,"arabic":"أُجِيبَت","translation":"গৃহীত হলো","audioUrl":"wbw/010_089_003.mp3","charTypeName":"word"},{"id":67792,"position":4,"arabic":"دَّعْوَتُكُمَا","translation":"তোমাদের দু'জনের দু'আ","audioUrl":"wbw/010_089_004.mp3","charTypeName":"word"},{"id":67793,"position":5,"arabic":"فَٱسْتَقِيمَا","translation":"অতএব দু'জন দৃঢ় থাকো","audioUrl":"wbw/010_089_005.mp3","charTypeName":"word"},{"id":67794,"position":6,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/010_089_006.mp3","charTypeName":"word"},{"id":67795,"position":7,"arabic":"تَتَّبِعَآنِّ","translation":"দু'জনে অনুসরণ করো","audioUrl":"wbw/010_089_007.mp3","charTypeName":"word"},{"id":67796,"position":8,"arabic":"سَبِيلَ","translation":"পথ","audioUrl":"wbw/010_089_008.mp3","charTypeName":"word"},{"id":67797,"position":9,"arabic":"ٱلَّذِينَ","translation":"(তাদের) যারা","audioUrl":"wbw/010_089_009.mp3","charTypeName":"word"},{"id":67798,"position":10,"arabic":"لَا","translation":"না","audioUrl":"wbw/010_089_010.mp3","charTypeName":"word"},{"id":67799,"position":11,"arabic":"يَعْلَمُونَ","translation":"তারা জানে\"","audioUrl":"wbw/010_089_011.mp3","charTypeName":"word"},{"id":67800,"position":12,"arabic":"٨٩","translation":"(৮৯)","audioUrl":null,"charTypeName":"end"}]},{"number":90,"arabic":"۞ وَجَٰوَزْنَا بِبَنِىٓ إِسْرَٰٓءِيلَ ٱلْبَحْرَ فَأَتْبَعَهُمْ فِرْعَوْنُ وَجُنُودُهُۥ بَغْيًۭا وَعَدْوًا ۖ حَتَّىٰٓ إِذَآ أَدْرَكَهُ ٱلْغَرَقُ قَالَ ءَامَنتُ أَنَّهُۥ لَآ إِلَٰهَ إِلَّا ٱلَّذِىٓ ءَامَنَتْ بِهِۦ بَنُوٓا۟ إِسْرَٰٓءِيلَ وَأَنَا۠ مِنَ ٱلْمُسْلِمِينَ","translation":"And We brought the children of Israel across the sea; and thereupon Pharaoh and his hosts pursued them with vehement insolence and tyranny, until [they were overwhelmed by the waters of the sea. And] when he was about to drown, [Pharaoh] exclaimed: \"I have come to believe that there is no deity save Him in whom the children of Israel believe, and I am of those who surrender themselves unto Him!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1454.mp3","surahId":10,"words":[{"id":68112,"position":1,"arabic":"۞ وَجَـٰوَزْنَا","translation":"এবং পার করালাম আমরা","audioUrl":"wbw/010_090_002.mp3","charTypeName":"word"},{"id":68113,"position":2,"arabic":"بِبَنِىٓ","translation":"সহ সন্তানদের","audioUrl":"wbw/010_090_003.mp3","charTypeName":"word"},{"id":68114,"position":3,"arabic":"إِسْرَٰٓءِيلَ","translation":"ইসরাঈলের","audioUrl":"wbw/010_090_004.mp3","charTypeName":"word"},{"id":68115,"position":4,"arabic":"ٱلْبَحْرَ","translation":"সাগর","audioUrl":"wbw/010_090_005.mp3","charTypeName":"word"},{"id":68116,"position":5,"arabic":"فَأَتْبَعَهُمْ","translation":"অতঃপর পিছনে ধাওয়া করলো তাদের","audioUrl":"wbw/010_090_006.mp3","charTypeName":"word"},{"id":68117,"position":6,"arabic":"فِرْعَوْنُ","translation":"ফিরাউন","audioUrl":"wbw/010_090_007.mp3","charTypeName":"word"},{"id":68118,"position":7,"arabic":"وَجُنُودُهُۥ","translation":"ও সৈন্যবাহিনী তার","audioUrl":"wbw/010_090_008.mp3","charTypeName":"word"},{"id":68119,"position":8,"arabic":"بَغْيًۭا","translation":"সীমালঙ্ঘন","audioUrl":"wbw/010_090_009.mp3","charTypeName":"word"},{"id":68120,"position":9,"arabic":"وَعَدْوًا ۖ","translation":"এবং শত্রুতাবশতঃ","audioUrl":"wbw/010_090_010.mp3","charTypeName":"word"},{"id":68122,"position":10,"arabic":"حَتَّىٰٓ","translation":"এমনকি","audioUrl":"wbw/010_090_012.mp3","charTypeName":"word"},{"id":68123,"position":11,"arabic":"إِذَآ","translation":"যখন","audioUrl":"wbw/010_090_013.mp3","charTypeName":"word"},{"id":68124,"position":12,"arabic":"أَدْرَكَهُ","translation":"পেলো তাকে","audioUrl":"wbw/010_090_014.mp3","charTypeName":"word"},{"id":68125,"position":13,"arabic":"ٱلْغَرَقُ","translation":"ডুবে যাওয়া (অর্থাৎ সাগরে ডুবে যাচ্ছিলো)","audioUrl":"wbw/010_090_015.mp3","charTypeName":"word"},{"id":68126,"position":14,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/010_090_016.mp3","charTypeName":"word"},{"id":68127,"position":15,"arabic":"ءَامَنتُ","translation":"\"আমি ঈমান আনলাম","audioUrl":"wbw/010_090_017.mp3","charTypeName":"word"},{"id":68128,"position":16,"arabic":"أَنَّهُۥ","translation":"এই (বলে) যে","audioUrl":"wbw/010_090_018.mp3","charTypeName":"word"},{"id":68129,"position":17,"arabic":"لَآ","translation":"নেই","audioUrl":"wbw/010_090_019.mp3","charTypeName":"word"},{"id":68130,"position":18,"arabic":"إِلَـٰهَ","translation":"কোনো ইলাহ","audioUrl":"wbw/010_090_020.mp3","charTypeName":"word"},{"id":68131,"position":19,"arabic":"إِلَّا","translation":"(তিনি) ছাড়া","audioUrl":"wbw/010_090_021.mp3","charTypeName":"word"},{"id":68132,"position":20,"arabic":"ٱلَّذِىٓ","translation":"যিনি (সেই সত্ত্বা)","audioUrl":"wbw/010_090_022.mp3","charTypeName":"word"},{"id":68133,"position":21,"arabic":"ءَامَنَتْ","translation":"ঈমান এনেছে","audioUrl":"wbw/010_090_023.mp3","charTypeName":"word"},{"id":68134,"position":22,"arabic":"بِهِۦ","translation":"উপর তার","audioUrl":"wbw/010_090_024.mp3","charTypeName":"word"},{"id":68135,"position":23,"arabic":"بَنُوٓا۟","translation":"সন্তানরা","audioUrl":"wbw/010_090_025.mp3","charTypeName":"word"},{"id":68136,"position":24,"arabic":"إِسْرَٰٓءِيلَ","translation":"ইসরাঈলের","audioUrl":"wbw/010_090_026.mp3","charTypeName":"word"},{"id":68137,"position":25,"arabic":"وَأَنَا۠","translation":"এবং আমি","audioUrl":"wbw/010_090_027.mp3","charTypeName":"word"},{"id":68138,"position":26,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/010_090_028.mp3","charTypeName":"word"},{"id":68139,"position":27,"arabic":"ٱلْمُسْلِمِينَ","translation":"আত্মসমর্পনকারীদের (অর্থাৎ মুসলমানদের)\"","audioUrl":"wbw/010_090_029.mp3","charTypeName":"word"},{"id":68140,"position":28,"arabic":"٩٠","translation":"(৯০)","audioUrl":null,"charTypeName":"end"}]},{"number":91,"arabic":"ءَآلْـَٰٔنَ وَقَدْ عَصَيْتَ قَبْلُ وَكُنتَ مِنَ ٱلْمُفْسِدِينَ","translation":"[But God said:] \"Now? -when ever before this thou hast been rebelling [against Us], and hast been among those who spread corruption?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1455.mp3","surahId":10,"words":[{"id":68472,"position":1,"arabic":"ءَآلْـَٔـٰنَ","translation":"\"কি এখন (ঈমান আনলে)","audioUrl":"wbw/010_091_001.mp3","charTypeName":"word"},{"id":68473,"position":2,"arabic":"وَقَدْ","translation":"অথচ নিশ্চয়ই","audioUrl":"wbw/010_091_002.mp3","charTypeName":"word"},{"id":68474,"position":3,"arabic":"عَصَيْتَ","translation":"তুমি অমান্য করেছো","audioUrl":"wbw/010_091_003.mp3","charTypeName":"word"},{"id":68475,"position":4,"arabic":"قَبْلُ","translation":"পূর্বে","audioUrl":"wbw/010_091_004.mp3","charTypeName":"word"},{"id":68476,"position":5,"arabic":"وَكُنتَ","translation":"এবং তুমি ছিলে","audioUrl":"wbw/010_091_005.mp3","charTypeName":"word"},{"id":68477,"position":6,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/010_091_006.mp3","charTypeName":"word"},{"id":68478,"position":7,"arabic":"ٱلْمُفْسِدِينَ","translation":"বিপর্যয়কারীদের\"","audioUrl":"wbw/010_091_007.mp3","charTypeName":"word"},{"id":68479,"position":8,"arabic":"٩١","translation":"(৯১)","audioUrl":null,"charTypeName":"end"}]},{"number":92,"arabic":"فَٱلْيَوْمَ نُنَجِّيكَ بِبَدَنِكَ لِتَكُونَ لِمَنْ خَلْفَكَ ءَايَةًۭ ۚ وَإِنَّ كَثِيرًۭا مِّنَ ٱلنَّاسِ عَنْ ءَايَٰتِنَا لَغَٰفِلُونَ","translation":"[Nay,] but today We shall save only thy body, so that thou mayest be a [warning] sign unto those who will come after thee: for, behold, a good many people are heedless of Our messages!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1456.mp3","surahId":10,"words":[{"id":68739,"position":1,"arabic":"فَٱلْيَوْمَ","translation":"সুতরাং আজ","audioUrl":"wbw/010_092_001.mp3","charTypeName":"word"},{"id":68740,"position":2,"arabic":"نُنَجِّيكَ","translation":"তোমাকে আমরা রক্ষা করবো","audioUrl":"wbw/010_092_002.mp3","charTypeName":"word"},{"id":68741,"position":3,"arabic":"بِبَدَنِكَ","translation":"দ্বারা তোমার শরীর (অর্থাৎ তোমার লাশকে)","audioUrl":"wbw/010_092_003.mp3","charTypeName":"word"},{"id":68742,"position":4,"arabic":"لِتَكُونَ","translation":"যেন তুমি হও","audioUrl":"wbw/010_092_004.mp3","charTypeName":"word"},{"id":68743,"position":5,"arabic":"لِمَنْ","translation":"(তাদের) জন্যে যারা","audioUrl":"wbw/010_092_005.mp3","charTypeName":"word"},{"id":68744,"position":6,"arabic":"خَلْفَكَ","translation":"তোমার পরবর্তীতে (আসবে)","audioUrl":"wbw/010_092_006.mp3","charTypeName":"word"},{"id":68745,"position":7,"arabic":"ءَايَةًۭ ۚ","translation":"একটি নিদর্শন","audioUrl":"wbw/010_092_007.mp3","charTypeName":"word"},{"id":68747,"position":8,"arabic":"وَإِنَّ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/010_092_009.mp3","charTypeName":"word"},{"id":68748,"position":9,"arabic":"كَثِيرًۭا","translation":"অনেকে","audioUrl":"wbw/010_092_010.mp3","charTypeName":"word"},{"id":68749,"position":10,"arabic":"مِّنَ","translation":"মধ্য হতে","audioUrl":"wbw/010_092_011.mp3","charTypeName":"word"},{"id":68750,"position":11,"arabic":"ٱلنَّاسِ","translation":"মানুষের","audioUrl":"wbw/010_092_012.mp3","charTypeName":"word"},{"id":68751,"position":12,"arabic":"عَنْ","translation":"সম্বন্ধে","audioUrl":"wbw/010_092_013.mp3","charTypeName":"word"},{"id":68752,"position":13,"arabic":"ءَايَـٰتِنَا","translation":"নিদর্শনাবলী আমাদের","audioUrl":"wbw/010_092_014.mp3","charTypeName":"word"},{"id":68753,"position":14,"arabic":"لَغَـٰفِلُونَ","translation":"অবশ্যই উদাসীন\"","audioUrl":"wbw/010_092_015.mp3","charTypeName":"word"},{"id":68754,"position":15,"arabic":"٩٢","translation":"(৯২)","audioUrl":null,"charTypeName":"end"}]},{"number":93,"arabic":"وَلَقَدْ بَوَّأْنَا بَنِىٓ إِسْرَٰٓءِيلَ مُبَوَّأَ صِدْقٍۢ وَرَزَقْنَٰهُم مِّنَ ٱلطَّيِّبَٰتِ فَمَا ٱخْتَلَفُوا۟ حَتَّىٰ جَآءَهُمُ ٱلْعِلْمُ ۚ إِنَّ رَبَّكَ يَقْضِى بَيْنَهُمْ يَوْمَ ٱلْقِيَٰمَةِ فِيمَا كَانُوا۟ فِيهِ يَخْتَلِفُونَ","translation":"And [thereafter], indeed, We assigned unto the children of Israel a most goodly abode, and provided for them sustenance out of the good things of life. And it was not until knowledge [of God's revelation] was vouchsafed to them that they began to hold divergent views: [but,] verily, thy Sustainer will judge between them on Resurrection Day regarding all on which they were wont to differ.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1457.mp3","surahId":10,"words":[{"id":68973,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/010_093_001.mp3","charTypeName":"word"},{"id":68974,"position":2,"arabic":"بَوَّأْنَا","translation":"আমরা বসবাস করিয়েছি","audioUrl":"wbw/010_093_002.mp3","charTypeName":"word"},{"id":68975,"position":3,"arabic":"بَنِىٓ","translation":"সন্তানদেরকে","audioUrl":"wbw/010_093_003.mp3","charTypeName":"word"},{"id":68976,"position":4,"arabic":"إِسْرَٰٓءِيلَ","translation":"ইসরাঈলের","audioUrl":"wbw/010_093_004.mp3","charTypeName":"word"},{"id":68977,"position":5,"arabic":"مُبَوَّأَ","translation":"আবাসভূমিতে","audioUrl":"wbw/010_093_005.mp3","charTypeName":"word"},{"id":68978,"position":6,"arabic":"صِدْقٍۢ","translation":"উত্তম","audioUrl":"wbw/010_093_006.mp3","charTypeName":"word"},{"id":68979,"position":7,"arabic":"وَرَزَقْنَـٰهُم","translation":"ও জীবিকা দিয়েছি আমরা তাদের","audioUrl":"wbw/010_093_007.mp3","charTypeName":"word"},{"id":68980,"position":8,"arabic":"مِّنَ","translation":"থেকে","audioUrl":"wbw/010_093_008.mp3","charTypeName":"word"},{"id":68981,"position":9,"arabic":"ٱلطَّيِّبَـٰتِ","translation":"পবিত্র জিনিসগুলো","audioUrl":"wbw/010_093_009.mp3","charTypeName":"word"},{"id":68982,"position":10,"arabic":"فَمَا","translation":"অতঃপর না","audioUrl":"wbw/010_093_010.mp3","charTypeName":"word"},{"id":68983,"position":11,"arabic":"ٱخْتَلَفُوا۟","translation":"তারা বিভেদ করেছে","audioUrl":"wbw/010_093_011.mp3","charTypeName":"word"},{"id":68984,"position":12,"arabic":"حَتَّىٰ","translation":"যতক্ষণ না","audioUrl":"wbw/010_093_012.mp3","charTypeName":"word"},{"id":68985,"position":13,"arabic":"جَآءَهُمُ","translation":"কাছে এসেছে তাদের","audioUrl":"wbw/010_093_013.mp3","charTypeName":"word"},{"id":68986,"position":14,"arabic":"ٱلْعِلْمُ ۚ","translation":"(সত্যিকার) জ্ঞান","audioUrl":"wbw/010_093_014.mp3","charTypeName":"word"},{"id":68988,"position":15,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/010_093_016.mp3","charTypeName":"word"},{"id":68989,"position":16,"arabic":"رَبَّكَ","translation":"তোমার রব","audioUrl":"wbw/010_093_017.mp3","charTypeName":"word"},{"id":68990,"position":17,"arabic":"يَقْضِى","translation":"মীমাংসা করে দিবেন","audioUrl":"wbw/010_093_018.mp3","charTypeName":"word"},{"id":68991,"position":18,"arabic":"بَيْنَهُمْ","translation":"মাঝে তাদের","audioUrl":"wbw/010_093_019.mp3","charTypeName":"word"},{"id":68992,"position":19,"arabic":"يَوْمَ","translation":"দিনে","audioUrl":"wbw/010_093_020.mp3","charTypeName":"word"},{"id":68993,"position":20,"arabic":"ٱلْقِيَـٰمَةِ","translation":"ক্বিয়ামাতের","audioUrl":"wbw/010_093_021.mp3","charTypeName":"word"},{"id":68994,"position":21,"arabic":"فِيمَا","translation":"সে বিষয়ে যা","audioUrl":"wbw/010_093_022.mp3","charTypeName":"word"},{"id":68995,"position":22,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/010_093_023.mp3","charTypeName":"word"},{"id":68996,"position":23,"arabic":"فِيهِ","translation":"মধ্যে তার","audioUrl":"wbw/010_093_024.mp3","charTypeName":"word"},{"i