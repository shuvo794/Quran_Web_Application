/010_097_006.mp3","charTypeName":"word"},{"id":70378,"position":7,"arabic":"ٱلْعَذَابَ","translation":"শাস্তি","audioUrl":"wbw/010_097_007.mp3","charTypeName":"word"},{"id":70379,"position":8,"arabic":"ٱلْأَلِيمَ","translation":"নিদারুণ","audioUrl":"wbw/010_097_008.mp3","charTypeName":"word"},{"id":70380,"position":9,"arabic":"٩٧","translation":"(৯৭)","audioUrl":null,"charTypeName":"end"}]}]}