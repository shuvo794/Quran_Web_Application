oUrl":"wbw/002_184_002.mp3","charTypeName":"word"},{"id":84069,"position":3,"arabic":"فَمَن","translation":"যে অতঃপর","audioUrl":"wbw/002_184_004.mp3","charTypeName":"word"},{"id":84070,"position":4,"arabic":"كَانَ","translation":"হবে","audioUrl":"wbw/002_184_005.mp3","charTypeName":"word"},{"id":84071,"position":5,"arabic":"مِنكُم","translation":"তোমাদের মধ্যে","audioUrl":"wbw/002_184_006.mp3","charTypeName":"word"},{"id":84072,"position":6,"arabic":"مَّرِيضًا","translation":"অসুস্থ","audioUrl":"wbw/002_184_007.mp3","charTypeName":"word"},{"id":84073,"position":7,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/002_184_008.mp3","charTypeName":"word"},{"id":84074,"position":8,"arabic":"عَلَىٰ","translation":"মধ্যে","audioUrl":"wbw/002_184_009.mp3","charTypeName":"word"},{"id":84075,"position":9,"arabic":"سَفَرٍۢ","translation":"সফরের","audioUrl":"wbw/002_184_010.mp3","charTypeName":"word"},{"id":84076,"position":10,"arabic":"فَعِدَّةٌۭ","translation":"সংখ্যা (পূরণ করবে)","audioUrl":"wbw/002_184_011.mp3","charTypeName":"word"},{"id":84077,"position":11,"arabic":"مِّنْ","translation":"থেকে","audioUrl":"wbw/002_184_012.mp3","charTypeName":"word"},{"id":84078,"position":12,"arabic":"أَيَّامٍ","translation":"দিনগুলো","audioUrl":"wbw/002_184_013.mp3","charTypeName":"word"},{"id":84079,"position":13,"arabic":"أُخَرَ ۚ","translation":"অন্যান্য","audioUrl":"wbw/002_184_014.mp3","charTypeName":"word"},{"id":84081,"position":14,"arabic":"وَعَلَى","translation":"এবং উপর","audioUrl":"wbw/002_184_016.mp3","charTypeName":"word"},{"id":84082,"position":15,"arabic":"ٱلَّذِينَ","translation":"(তাদের) যারা","audioUrl":"wbw/002_184_017.mp3","charTypeName":"word"},{"id":84083,"position":16,"arabic":"يُطِيقُونَهُۥ","translation":"তার সামর্থ্য রাখে (কিন্তু রাখবে না)","audioUrl":"wbw/002_184_018.mp3","charTypeName":"word"},{"id":84084,"position":17,"arabic":"فِدْيَةٌۭ","translation":"বিনিময় দিবে","audioUrl":"wbw/002_184_019.mp3","charTypeName":"word"},{"id":84085,"position":18,"arabic":"طَعَامُ","translation":"খাদ্য দান করে","audioUrl":"wbw/002_184_020.mp3","charTypeName":"word"},{"id":84086,"position":19,"arabic":"مِسْكِينٍۢ ۖ","translation":"এক অভাবগ্রস্তকে","audioUrl":"wbw/002_184_021.mp3","charTypeName":"word"},{"id":84088,"position":20,"arabic":"فَمَن","translation":"যে অতঃপর","audioUrl":"wbw/002_184_023.mp3","charTypeName":"word"},{"id":84089,"position":21,"arabic":"تَطَوَّعَ","translation":"স্বেচ্ছায় করে (অতিরিক্ত)","audioUrl":"wbw/002_184_024.mp3","charTypeName":"word"},{"id":84090,"position":22,"arabic":"خَيْرًۭا","translation":"কোনো কল্যাণ","audioUrl":"wbw/002_184_025.mp3","charTypeName":"word"},{"id":84091,"position":23,"arabic":"فَهُوَ","translation":"তাহলে তা","audioUrl":"wbw/002_184_026.mp3","charTypeName":"word"},{"id":84092,"position":24,"arabic":"خَيْرٌۭ","translation":"উত্তম","audioUrl":"wbw/002_184_027.mp3","charTypeName":"word"},{"id":84093,"position":25,"arabic":"لَّهُۥ ۚ","translation":"তার জন্যে","audioUrl":"wbw/002_184_028.mp3","charTypeName":"word"},{"id":84095,"position":26,"arabic":"وَأَن","translation":"কিন্তু যে","audioUrl":"wbw/002_184_030.mp3","charTypeName":"word"},{"id":84096,"position":27,"arabic":"تَصُومُوا۟","translation":"তোমাদের রোজা(সাওম) রাখবে","audioUrl":"wbw/002_184_031.mp3","charTypeName":"word"},{"id":84097,"position":28,"arabic":"خَيْرٌۭ","translation":"উত্তম","audioUrl":"wbw/002_184_032.mp3","charTypeName":"word"},{"id":84098,"position":29,"arabic":"لَّكُمْ ۖ","translation":"তোমাদের জন্যে","audioUrl":"wbw/002_184_033.mp3","charTypeName":"word"},{"id":84100,"position":30,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/002_184_035.mp3","charTypeName":"word"},{"id":84101,"position":31,"arabic":"كُنتُمْ","translation":"তোমরা","audioUrl":"wbw/002_184_036.mp3","charTypeName":"word"},{"id":84102,"position":32,"arabic":"تَعْلَمُونَ","translation":"জানতে","audioUrl":"wbw/002_184_037.mp3","charTypeName":"word"},{"id":84103,"position":33,"arabic":"١٨٤","translation":"(১৮৪)","audioUrl":null,"charTypeName":"end"}]},{"number":185,"arabic":"شَهْرُ رَمَضَانَ ٱلَّذِىٓ أُنزِلَ فِيهِ ٱلْقُرْءَانُ هُدًۭى لِّلنَّاسِ وَبَيِّنَٰتٍۢ مِّنَ ٱلْهُدَىٰ وَٱلْفُرْقَانِ ۚ فَمَن شَهِدَ مِنكُمُ ٱلشَّهْرَ فَلْيَصُمْهُ ۖ وَمَن كَانَ مَرِيضًا أَوْ عَلَىٰ سَفَرٍۢ فَعِدَّةٌۭ مِّنْ أَيَّامٍ أُخَرَ ۗ يُرِيدُ ٱللَّهُ بِكُمُ ٱلْيُسْرَ وَلَا يُرِيدُ بِكُمُ ٱلْعُسْرَ وَلِتُكْمِلُوا۟ ٱلْعِدَّةَ وَلِتُكَبِّرُوا۟ ٱللَّهَ عَلَىٰ مَا هَدَىٰكُمْ وَلَعَلَّكُمْ تَشْكُرُونَ","translation":"It was the month of Ramadan in which the Qur'an was [first] bestowed from on high as a guidance unto man and a self-evident proof of that guidance, and as the standard by which to discern the true from the false. Hence, whoever of you lives to see this month shall fast throughout it; but he that is ill, or on a journey, [shall fast instead for the same] number of other days. God wills that you shall have ease, and does not will you to suffer hardship; but [He desires] that you complete the number [of days required], and that you extol God for His having guided you aright, and that you render your thanks [unto Him].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/192.mp3","surahId":2,"words":[{"id":84131,"position":1,"arabic":"شَهْرُ","translation":"মাস","audioUrl":"wbw/002_185_001.mp3","charTypeName":"word"},{"id":84132,"position":2,"arabic":"رَمَضَانَ","translation":"রমাদান","audioUrl":"wbw/002_185_002.mp3","charTypeName":"word"},{"id":84133,"position":3,"arabic":"ٱلَّذِىٓ","translation":"যা","audioUrl":"wbw/002_185_003.mp3","charTypeName":"word"},{"id":84134,"position":4,"arabic":"أُنزِلَ","translation":"অবতীর্ণ করা হয়েছে","audioUrl":"wbw/002_185_004.mp3","charTypeName":"word"},{"id":84135,"position":5,"arabic":"فِيهِ","translation":"তার মধ্যে","audioUrl":"wbw/002_185_005.mp3","charTypeName":"word"},{"id":84136,"position":6,"arabic":"ٱلْقُرْءَانُ","translation":"কুরআন (যা)","audioUrl":"wbw/002_185_006.mp3","charTypeName":"word"},{"id":84137,"position":7,"arabic":"هُدًۭى","translation":"সঠিক পথ নির্দেশনা","a