{"id":28,"ayahs":[{"number":182,"arabic":"فَمَنْ خَافَ مِن مُّوصٍۢ جَنَفًا أَوْ إِثْمًۭا فَأَصْلَحَ بَيْنَهُمْ فَلَآ إِثْمَ عَلَيْهِ ۚ إِنَّ ٱللَّهَ غَفُورٌۭ رَّحِيمٌۭ","translation":"If, however, one has reason to fear that the testator has committed a mistake or a [deliberate] wrong, and thereupon brings about a settlement between the heirs, he will incur no sin [thereby]. Verily, God is much-forgiving, a dispenser of grace.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/189.mp3","surahId":2,"words":[{"id":83925,"position":1,"arabic":"فَمَنْ","translation":"যে তবে","audioUrl":"wbw/002_182_001.mp3","charTypeName":"word"},{"id":83926,"position":2,"arabic":"خَافَ","translation":"ভয় করে","audioUrl":"wbw/002_182_002.mp3","charTypeName":"word"},{"id":83927,"position":3,"arabic":"مِن","translation":"হতে","audioUrl":"wbw/002_182_003.mp3","charTypeName":"word"},{"id":83928,"position":4,"arabic":"مُّوصٍۢ","translation":"ওসীয়তকারী","audioUrl":"wbw/002_182_004.mp3","charTypeName":"word"},{"id":83929,"position":5,"arabic":"جَنَفًا","translation":"পক্ষপাতিত্বের","audioUrl":"wbw/002_182_005.mp3","charTypeName":"word"},{"id":83930,"position":6,"arabic":"أَوْ","translation":"বা","audioUrl":"wbw/002_182_006.mp3","charTypeName":"word"},{"id":83931,"position":7,"arabic":"إِثْمًۭا","translation":"অন্যায়ের","audioUrl":"wbw/002_182_007.mp3","charTypeName":"word"},{"id":83932,"position":8,"arabic":"فَأَصْلَحَ","translation":"তারপর সে মীমাংসা করে দেবে","audioUrl":"wbw/002_182_008.mp3","charTypeName":"word"},{"id":83933,"position":9,"arabic":"بَيْنَهُمْ","translation":"তাদের মাঝে","audioUrl":"wbw/002_182_009.mp3","charTypeName":"word"},{"id":83934,"position":10,"arabic":"فَلَآ","translation":"তবে নেই","audioUrl":"wbw/002_182_010.mp3","charTypeName":"word"},{"id":83935,"position":11,"arabic":"إِثْمَ","translation":"কোনো গোনাহ","audioUrl":"wbw/002_182_011.mp3","charTypeName":"word"},{"id":83936,"position":12,"arabic":"عَلَيْهِ ۚ","translation":"তার উপর","audioUrl":"wbw/002_182_012.mp3","charTypeName":"word"},{"id":83938,"position":13,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/002_182_014.mp3","charTypeName":"word"},{"id":83939,"position":14,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/002_182_015.mp3","charTypeName":"word"},{"id":83940,"position":15,"arabic":"غَفُورٌۭ","translation":"ক্ষমাশীল","audioUrl":"wbw/002_182_016.mp3","charTypeName":"word"},{"id":83941,"position":16,"arabic":"رَّحِيمٌۭ","translation":"পরমদয়ালু","audioUrl":"wbw/002_182_017.mp3","charTypeName":"word"},{"id":83942,"position":17,"arabic":"١٨٢","translation":"(১৮২)","audioUrl":null,"charTypeName":"end"}]},{"number":183,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ كُتِبَ عَلَيْكُمُ ٱلصِّيَامُ كَمَا كُتِبَ عَلَى ٱلَّذِينَ مِن قَبْلِكُمْ لَعَلَّكُمْ تَتَّقُونَ","translation":"O YOU who have attained to faith! Fasting is ordained for you as it was ordained for those before you, so that you might remain conscious of God:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/190.mp3","surahId":2,"words":[{"id":83971,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/002_183_001.mp3","charTypeName":"word"},{"id":83972,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/002_183_002.mp3","charTypeName":"word"},{"id":83973,"position":3,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/002_183_003.mp3","charTypeName":"word"},{"id":83974,"position":4,"arabic":"كُتِبَ","translation":"ফরজ করা হয়েছে","audioUrl":"wbw/002_183_004.mp3","charTypeName":"word"},{"id":83975,"position":5,"arabic":"عَلَيْكُمُ","translation":"তোমাদের উপর","audioUrl":"wbw/002_183_005.mp3","charTypeName":"word"},{"id":83976,"position":6,"arabic":"ٱلصِّيَامُ","translation":"রোযা(সাওম)","audioUrl":"wbw/002_183_006.mp3","charTypeName":"word"},{"id":83977,"position":7,"arabic":"كَمَا","translation":"যেমন","audioUrl":"wbw/002_183_007.mp3","charTypeName":"word"},{"id":83978,"position":8,"arabic":"كُتِبَ","translation":"ফ