p3","charTypeName":"word"},{"id":920,"position":2,"arabic":"مُوسَى","translation":"মূসাকে","audioUrl":"wbw/017_002_002.mp3","charTypeName":"word"},{"id":921,"position":3,"arabic":"ٱلْكِتَـٰبَ","translation":"কিতাব","audioUrl":"wbw/017_002_003.mp3","charTypeName":"word"},{"id":922,"position":4,"arabic":"وَجَعَلْنَـٰهُ","translation":"ও তাকে আমরা বানিয়েছিলাম","audioUrl":"wbw/017_002_004.mp3","charTypeName":"word"},{"id":923,"position":5,"arabic":"هُدًۭى","translation":"পথ নির্দেশক","audioUrl":"wbw/017_002_005.mp3","charTypeName":"word"},{"id":924,"position":6,"arabic":"لِّبَنِىٓ","translation":"জন্যে বনী","audioUrl":"wbw/017_002_006.mp3","charTypeName":"word"},{"id":925,"position":7,"arabic":"إِسْرَٰٓءِيلَ","translation":"ইসরাঈলদের","audioUrl":"wbw/017_002_007.mp3","charTypeName":"word"},{"id":926,"position":8,"arabic":"أَلَّا","translation":"\"যে না","audioUrl":"wbw/017_002_008.mp3","charTypeName":"word"},{"id":927,"position":9,"arabic":"تَتَّخِذُوا۟","translation":"তোমরা গ্রহণ করো","audioUrl":"wbw/017_002_009.mp3","charTypeName":"word"},{"id":928,"position":10,"arabic":"مِن","translation":"ছাড়া","audioUrl":"wbw/017_002_010.mp3","charTypeName":"word"},{"id":929,"position":11,"arabic":"دُونِى","translation":"আমাকে","audioUrl":"wbw/017_002_011.mp3","charTypeName":"word"},{"id":930,"position":12,"arabic":"وَكِيلًۭا","translation":"কর্মবিধায়ক\"","audioUrl":"wbw/017_002_012.mp3","charTypeName":"word"},{"id":931,"position":13,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"ذُرِّيَّةَ مَنْ حَمَلْنَا مَعَ نُوحٍ ۚ إِنَّهُۥ كَانَ عَبْدًۭا شَكُورًۭا","translation":"O you descendants of those whom We caused to be borne (in the ark] with Noah! Behold, he was a most grateful servant (of Ours]!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2032.mp3","surahId":17,"words":[{"id":2326,"position":1,"arabic":"ذُرِّيَّةَ","translation":"(তোমরা) বংশধর","audioUrl":"wbw/017_003_001.mp3","charTypeName":"word"},{"id":2327,"position":2,"arabic":"مَنْ","translation":"তাদের (যাদেরকে)","audioUrl":"wbw/017_003_002.mp3","charTypeName":"word"},{"id":2328,"position":3,"arabic":"حَمَلْنَا","translation":"আমরা আরোহণ করিয়েছিলাম","audioUrl":"wbw/017_003_003.mp3","charTypeName":"word"},{"id":2329,"position":4,"arabic":"مَعَ","translation":"সাথে","audioUrl":"wbw/017_003_004.mp3","charTypeName":"word"},{"id":2330,"position":5,"arabic":"نُوحٍ ۚ","translation":"নূহের","audioUrl":"wbw/017_003_005.mp3","charTypeName":"word"},{"id":2332,"position":6,"arabic":"إِنَّهُۥ","translation":"নিশ্চয়ই সে","audioUrl":"wbw/017_003_007.mp3","charTypeName":"word"},{"id":2333,"position":7,"arabic":"كَانَ","translation":"ছিলো","audioUrl":"wbw/017_003_008.mp3","charTypeName":"word"},{"id":2334,"position":8,"arabic":"عَبْدًۭا","translation":"দাস","audioUrl":"wbw/017_003_009.mp3","charTypeName":"word"},{"id":2335,"position":9,"arabic":"شَكُورًۭا","translation":"পরম কৃতজ্ঞ","audioUrl":"wbw/017_003_010.mp3","charTypeName":"word"},{"id":2336,"position":10,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"وَقَضَيْنَآ إِلَىٰ بَنِىٓ إِسْرَٰٓءِيلَ فِى ٱلْكِتَٰبِ لَتُفْسِدُنَّ فِى ٱلْأَرْضِ مَرَّتَيْنِ وَلَتَعْلُنَّ عُلُوًّۭا كَبِيرًۭا","translation":"And we made [this] known to the children of Israel through revelation: Twice, indeed, will you spread corruption on earth and will indeed become grossly overbearing!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2033.mp3","surahId":17,"words":[{"id":3272,"position":1,"arabic":"وَقَضَيْنَآ","translation":"এবং আমরা সতর্ক করেছিলাম","audioUrl":"wbw/017_004_001.mp3","charTypeName":"word"},{"id":3273,"position":2,"arabic":"إِلَىٰ","translation":"প্রতি","audioUrl":"wbw/017_004_002.mp3","charTypeName":"word"},{"id":3274,"position":3,"arabic":"بَنِىٓ","translation":"বনী","audioUrl":"wbw/017_004_003.mp3","charTypeName":"word"},{"id":3275,"position":4,"arabic":"إِسْرَٰٓءِيلَ","translation":"ইসরাঈলকে","audioUrl":"wbw/017_004_004.mp3","charTypeName":"word"},{"id":3276,"position":5,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/017_004_005.mp3","charTypeName":"word"},{"id":3277,"position":6,"arabic":"ٱلْكِتَـٰبِ","translation":"কিতাবের","audioUrl":"wbw/017_004_006.mp3","charTypeName":"word"},{"id":3278,"position":7,"arabic":"لَتُفْسِدُنَّ","translation":"\"অবশ্যই তোমরা বিপর্যয় করবে","audioUrl":"wbw/017_004_007.mp3","charTypeName":"word"},{"id":3279,"position":8,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/017_004_008.mp3","charTypeName":"word"},{"id":3280,"position":9,"arabic":"ٱلْأَرْضِ","translation":"দেশের","audioUrl":"wbw/017_004_009.mp3","charTypeName":"word"},{"id":3281,"position":10,"arabic":"مَرَّتَيْنِ","translation":"দু'বার","audioUrl":"wbw/017_004_010.mp3","charTypeName":"word"},{"id":3282,"position":11,"arabic":"وَلَتَعْلُنَّ","translation":"এবং অবশ্যই তোমরা বিদ্রোহ করবে","audioUrl":"wbw/017_004_011.mp3","charTypeName":"word"},{"id":3283,"position":12,"arabic":"عُلُوًّۭا","translation":"বিদ্রোহ","audioUrl":"wbw/017_004_012.mp3","charTypeName":"word"},{"id":3284,"position":13,"arabic":"كَبِيرًۭا","translation":"বিরাট\"","audioUrl":"wbw/017_004_013.mp3","charTypeName":"word"},{"id":3285,"position":14,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"فَإِذَا جَآءَ وَعْدُ أُولَىٰهُمَا بَعَثْنَا عَلَيْكُمْ عِبَادًۭا لَّنَآ أُو۟لِى بَأْسٍۢ شَدِيدٍۢ فَجَاسُوا۟ خِلَٰلَ ٱلدِّيَارِ ۚ وَكَانَ وَعْدًۭا مَّفْعُولًۭا","translation":"Hence, when the prediction of the first of those two [periods of iniquity] came true, We sent against you some of Our bondmen of terrible prowess in war, and they wrought havoc throughout the land: and so the prediction was fulfilled.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2034.mp3","surahId":17,"words":[{"id":4591,"position":1,"arabic":"فَإِذَا","translation":"অতঃপর যখন","audioUrl":"wbw/017_005_001.mp3","charTypeName":"word"},{"id":4592,"position":2,"arabic":"جَآءَ","translation":"