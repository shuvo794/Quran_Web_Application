{"id":282,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ سُبْحَٰنَ ٱلَّذِىٓ أَسْرَىٰ بِعَبْدِهِۦ لَيْلًۭا مِّنَ ٱلْمَسْجِدِ ٱلْحَرَامِ إِلَى ٱلْمَسْجِدِ ٱلْأَقْصَا ٱلَّذِى بَٰرَكْنَا حَوْلَهُۥ لِنُرِيَهُۥ مِنْ ءَايَٰتِنَآ ۚ إِنَّهُۥ هُوَ ٱلسَّمِيعُ ٱلْبَصِيرُ","translation":"LIMITLESS in His glory is He who transported His servant by night from the Inviolable House of Worship [at Mecca] to the Remote House of Worship [, at Jerusalem] - the environs of which We had blessed -so that We might show him some of Our symbols: for, verily, He alone is all-hearing, all-seeing.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2030.mp3","surahId":17,"words":[{"id":72,"position":1,"arabic":"سُبْحَـٰنَ","translation":"মহিমাময় (সত্ত্বা)","audioUrl":"wbw/017_001_001.mp3","charTypeName":"word"},{"id":73,"position":2,"arabic":"ٱلَّذِىٓ","translation":"(তিনি) যিনি","audioUrl":"wbw/017_001_002.mp3","charTypeName":"word"},{"id":74,"position":3,"arabic":"أَسْرَىٰ","translation":"ভ্রমণ করালেন","audioUrl":"wbw/017_001_003.mp3","charTypeName":"word"},{"id":75,"position":4,"arabic":"بِعَبْدِهِۦ","translation":"তাঁর দাসকে","audioUrl":"wbw/017_001_004.mp3","charTypeName":"word"},{"id":76,"position":5,"arabic":"لَيْلًۭا","translation":"রাতে","audioUrl":"wbw/017_001_005.mp3","charTypeName":"word"},{"id":77,"position":6,"arabic":"مِّنَ","translation":"থেকে","audioUrl":"wbw/017_001_006.mp3","charTypeName":"word"},{"id":78,"position":7,"arabic":"ٱلْمَسْجِدِ","translation":"মাসজিদ","audioUrl":"wbw/017_001_007.mp3","charTypeName":"word"},{"id":79,"position":8,"arabic":"ٱلْحَرَامِ","translation":"হারাম","audioUrl":"wbw/017_001_008.mp3","charTypeName":"word"},{"id":80,"position":9,"arabic":"إِلَى","translation":"পর্যন্ত","audioUrl":"wbw/017_001_009.mp3","charTypeName":"word"},{"id":81,"position":10,"arabic":"ٱلْمَسْجِدِ","translation":"মাসজিদ","audioUrl":"wbw/017_001_010.mp3","charTypeName":"word"},{"id":82,"position":11,"arabic":"ٱلْأَقْصَا","translation":"আকসা