{"id":295,"ayahs":[{"number":16,"arabic":"وَإِذِ ٱعْتَزَلْتُمُوهُمْ وَمَا يَعْبُدُونَ إِلَّا ٱللَّهَ فَأْوُۥٓا۟ إِلَى ٱلْكَهْفِ يَنشُرْ لَكُمْ رَبُّكُم مِّن رَّحْمَتِهِۦ وَيُهَيِّئْ لَكُم مِّنْ أَمْرِكُم مِّرْفَقًۭا","translation":"Hence, now that you have withdrawn from them and from all that they worship instead of God, take refuge in that cave: God will spread His grace over you, and will endow you - whatever your [outward] condition - with all that your souls may need!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2156.mp3","surahId":18,"words":[{"id":18086,"position":1,"arabic":"وَإِذِ","translation":"এবং যখন","audioUrl":"wbw/018_016_001.mp3","charTypeName":"word"},{"id":18087,"position":2,"arabic":"ٱعْتَزَلْتُمُوهُمْ","translation":"তোমরা বিচ্ছিন্ন হয়েছো তাদের (থেকে)","audioUrl":"wbw/018_016_002.mp3","charTypeName":"word"},{"id":18088,"position":3,"arabic":"وَمَا","translation":"এবং যাদের","audioUrl":"wbw/018_016_003.mp3","charTypeName":"word"},{"id":18089,"position":4,"arabic":"يَعْبُدُونَ","translation":"তারা উপাসনা করে","audioUrl":"wbw/018_016_004.mp3","charTypeName":"word"},{"id":18090,"position":5,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/018_016_005.mp3","charTypeName":"word"},{"id":18091,"position":6,"arabic":"ٱللَّهَ","translation":"আল্লাহ্‌র","audioUrl":"wbw/018_016_006.mp3","charTypeName":"word"},{"id":18092,"position":7,"arabic":"فَأْوُۥٓا۟","translation":"তাহ'লে আশ্রয় নাও","audioUrl":"wbw/018_016_007.mp3","charTypeName":"word"},{"id":18093,"position":8,"arabic":"إِلَى","translation":"মধ্যে","audioUrl":"wbw/018_016_008.mp3","charTypeName":"word"},{"id":18094,"position":9,"arabic":"ٱلْكَهْفِ","translation":"গুহার","audioUrl":"wbw/018_016_009.mp3","charTypeName":"word"},{"id":18095,"position":10,"arabic":"يَنشُرْ","translation":"প্রশস্ত করবেন","audioUrl":"wbw/018_016_010.mp3","charTypeName":"word"},{"id":18096,"position":11,"arabic":"لَكُمْ","translation":"জন্যে তোমাদের","audioUrl":"wbw/018_016_011.mp3","charTypeName":"word"},{"id":18097,"position":12,"arabic":"رَبُّكُم","translation":"রব তোমাদের","audioUrl":"wbw/018_016_012.mp3","charTypeName":"word"},{"id":18098,"position":13,"arabic":"مِّن","translation":"সাহায্যে","audioUrl":"wbw/018_016_013.mp3","charTypeName":"word"},{"id":18099,"position":14,"arabic":"رَّحْمَتِهِۦ","translation":"তাঁর অনুগ্রহের","audioUrl":"wbw/018_016_014.mp3","charTypeName":"word"},{"id":18100,"position":15,"arabic":"وَيُهَيِّئْ","translation":"এবং তৈরি করে দিবেন","audioUrl":"wbw/018_016_015.mp3","charTypeName":"word"},{"id":18101,"position":16,"arabic":"لَكُم","translation":"জন্যে তোমাদের","audioUrl":"wbw/018_016_016.mp3","charTypeName":"word"},{"id":18102,"position":17,"arabic":"مِّنْ","translation":"থেকে","audioUrl":"wbw/018_016_017.mp3","charTypeName":"word"},{"id":18103,"position":18,"arabic":"أَمْرِكُم","translation":"কাজ তোমাদের","audioUrl":"wbw/018_016_018.mp3","charTypeName":"word"},{"id":18104,"position":19,"arabic":"مِّرْفَقًۭا","translation":"ফলপ্রসূ\"","audioUrl":"wbw/018_016_019.mp3","charTypeName":"word"},{"id":18105,"position":20,"arabic":"١٦","translation":"(১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":17,"arabic":"۞ وَتَرَى ٱلشَّمْسَ إِذَا طَلَعَت تَّزَٰوَرُ عَن كَهْفِهِمْ ذَاتَ ٱلْيَمِينِ وَإِذَا غَرَبَت تَّقْرِضُهُمْ ذَاتَ ٱلشِّمَالِ وَهُمْ فِى فَجْوَةٍۢ مِّنْهُ ۚ ذَٰلِكَ مِنْ ءَايَٰتِ ٱللَّهِ ۗ مَن يَهْدِ ٱللَّهُ فَهُوَ ٱلْمُهْتَدِ ۖ وَمَن يُضْلِلْ فَلَن تَجِدَ لَهُۥ وَلِيًّۭا مُّرْشِدًۭا","translation":"And [for many a year] thou might have seen the sun, on its rising, incline away from their cave on the right, and, on its setting, turn aside from them on the left, while they lived on in that spacious chamber, [bearing witness to] this of God's messages: He whom God guides, he alone has found the right way; whereas for him whom He lets go astray thou canst never find any protector who would point out the right way.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2157.mp3","surahId":18,"words":[{"id":19093,"position":1,"arabic":"۞ وَتَرَى","translation":"এবং তুমি দেখবে","audioUrl":"wbw/018_017_002.mp3","charTypeName":"word"},{"id":19094,"position":2,"arabic":"ٱلشَّمْسَ","translation":"সূর্যকে","audioUrl":"wbw/018_017_003.mp3","charTypeName":"word"},{"id":19095,"position":3,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/018_017_004.mp3","charTypeName":"word"},{"id":19096,"position":4,"arabic":"طَلَعَت","translation":"উদয় হয়","audioUrl":"wbw/018_017_005.mp3","charTypeName":"word"},{"id":19097,"position":5,"arabic":"تَّزَٰوَرُ","translation":"সরে যায়","audioUrl":"wbw/018_017_006.mp3","charTypeName":"word"},{"id":19098,"position":6,"arabic":"عَن","translation":"থেকে","audioUrl":"wbw/018_017_007.mp3","charTypeName":"word"},{"id":19099,"position":7,"arabic":"كَهْفِهِمْ","translation":"গুহা তাদের","audioUrl":"wbw/018_017_008.mp3","charTypeName":"word"},{"id":19100,"position":8,"arabic":"ذَاتَ","translation":"পাশ দিয়ে","audioUrl":"wbw/018_017_009.mp3","charTypeName":"word"},{"id":19101,"position":9,"arabic":"ٱلْيَمِينِ","translation":"ডান","audioUrl":"wbw/018_017_010.mp3","charTypeName":"word"},{"id":19102,"position":10,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/018_017_011.mp3","charTypeName":"word"},{"id":19103,"position":11,"arabic":"غَرَبَت","translation":"অস্ত যায়","audioUrl":"wbw/018_017_012.mp3","charTypeName":"word"},{"id":19104,"position":12,"arabic":"تَّقْرِضُهُمْ","translation":"তা অতিক্রম করে তাদেরকে","audioUrl":"wbw/018_017_013.mp3","charTypeName":"word"},{"id":19105,"position":13,"arabic":"ذَاتَ","translation":"পাশ দিয়ে","audioUrl":"wbw/018_017_014.mp3","charTypeName":"word"},{"id":19106,"position":14,"arabic":"ٱلشِّمَالِ","translation":"বাম","audioUrl":"wbw/018_017_015.mp3","charTypeName":"word"},{"id":19107,"position":15,"arabic":"وَهُمْ","translation":"অথচ তারা","audioUrl":"wbw/018_017_016.mp3","charTypeName":"word"},{"id":19108,"position":16,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/018_017_017.mp3","charTypeName":"word"},{"id":19109,"position":17,"arabic":"فَجْوَةٍۢ","translation":"প্রশস্ত চত্বরের","audioUrl":"wbw/018_017_018.mp3","charTypeName":"word"},{"id":19110,"position":18,"arabic":"مِّنْهُ ۚ","translation":"থেকে তা","audioUrl":"wbw/018_017_019.mp3","charTypeName":"word"},{"id":19112,"position":19,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/018_017_021.mp3","charTypeName":"word"},{"id":19113,"position":20,"arabic":"مِنْ","translation":"মধ্য থেকে","audioUrl":"wbw/018_017_022.mp3","charTypeName":"word"},{"id":19114,"position":21,"arabic":"ءَايَـٰتِ","translation":"নিদর্শনাদির","audioUrl":"wbw/018_017_023.mp3","charTypeName":"word"},{"id":19115,"position":22,"arabic":"ٱللَّهِ ۗ","translation":"আল্লাহ্‌র","audioUrl":"wbw/018_017_024.mp3","charTypeName":"word"},{"id":19117,"position":23,"arabic":"مَن","translation":"যাকে","audioUrl":"wbw/018_017_026.mp3","charTypeName":"word"},{"id":19118,"position":24,"arabic":"يَهْدِ","translation":"পথ দেখান","audioUrl":"wbw/018_017_027.mp3","charTypeName":"word"},{"id":19119,"position":25,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌","audioUrl":"wbw/018_017_028.mp3","charTypeName":"word"},{"id":19120,"position":26,"arabic":"فَهُوَ","translation":"অতঃপর সেই","audioUrl":"wbw/018_017_029.mp3","charTypeName":"word"},{"id":19121,"position":27,"arabic":"ٱلْمُهْتَدِ ۖ","translation":"সঠিক পথপ্রাপ্ত","audioUrl":"wbw/018_017_030.mp3","charTypeName":"word"},{"id":19123,"position":28,"arabic":"وَمَن","translation":"এবং যাকে","audioUrl":"wbw/018_017_032.mp3","charTypeName":"word"},{"id":19124,"position":29,"arabic":"يُضْلِلْ","translation":"পথভ্রষ্ট করেন","audioUrl":"wbw/018_017_033.mp3","charTypeName":"word"},{"id":19125,"position":30,"arabic":"فَلَن","translation":"তখন কখনও না","audioUrl":"wbw/018_017_034.mp3","charTypeName":"word"},{"id":19126,"position":31,"arabic":"تَجِدَ","translation":"তুমি পাবে","audioUrl":"wbw/018_017_035.mp3","charTypeName":"word"},{"id":19127,"position":32,"arabic":"لَهُۥ","translation":"জন্যে তার","audioUrl":"wbw/018_017_036.mp3","charTypeName":"word"},{"id":19128,"position":33,"arabic":"وَلِيًّۭا","translation":"কোনো অভিভাবক","audioUrl":"wbw/018_017_037.mp3","charTypeName":"word"},{"id":19129,"position":34,"arabic":"مُّرْشِدًۭا","translation":"কোনো পথ প্রদর্শক","audioUrl":"wbw/018_017_038.mp3","charTypeName":"word"},{"id":19130,"position":35,"arabic":"١٧","translation":"(১৭)","audioUrl":null,"charTypeName":"end"}]},{"number":18,"arabic":"وَتَحْسَبُهُمْ أَيْقَاظًۭا وَهُمْ رُقُودٌۭ ۚ وَنُقَلِّبُهُمْ ذَاتَ ٱلْيَمِينِ وَذَاتَ ٱلشِّمَالِ ۖ وَكَلْبُهُم بَٰسِطٌۭ ذِرَاعَيْهِ بِٱلْوَصِيدِ ۚ لَوِ ٱطَّلَعْتَ عَلَيْهِمْ لَوَلَّيْتَ مِنْهُمْ فِرَارًۭا وَلَمُلِئْتَ مِنْهُمْ رُعْبًۭا","translation":"And thou wouldst have thought that they were awake, whereas they lay asleep. And We caused them to turn over repeatedly, now to the right, now to the left; and their dog [lay] on the threshold, its forepaws outstretched. Hadst thou come upon them [unprepared], thou wouldst surely have turned away from them in flight, and wouldst surely have been filled with awe of them.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2158.mp3","surahId":18,"words":[{"id":20218,"position":1,"arabic":"وَتَحْسَبُهُمْ","translation":"এবং তুমি মনে করবে তাদের","audioUrl":"wbw/018_018_001.mp3","charTypeName":"word"},{"id":20219,"position":2,"arabic":"أَيْقَاظًۭا","translation":"জাগ্রত","audioUrl":"wbw/018_018_002.mp3","charTypeName":"word"},{"id":20220,"position":3,"arabic":"وَهُمْ","translation":"অথচ তারা (ছিলো)","audioUrl":"wbw/018_018_003.mp3","charTypeName":"word"},{"id":20221,"position":4,"arabic":"رُقُودٌۭ ۚ","translation":"ঘুমন্ত","audioUrl":"wbw/018_018_004.mp3","charTypeName":"word"},{"id":20223,"position":5,"arabic":"وَنُقَلِّبُهُمْ","translation":"এবং পাশ ফেরাতাম আমরা তাদের","audioUrl":"wbw/018_018_006.mp3","charTypeName":"word"},{"id":20224,"position":6,"arabic":"ذَاتَ","translation":"পাশে","audioUrl":"wbw/018_018_007.mp3","charTypeName":"word"},{"id":20225,"position":7,"arabic":"ٱلْيَمِينِ","translation":"ডান","audioUrl":"wbw/018_018_008.mp3","charTypeName":"word"},{"id":20226,"position":8,"arabic":"وَذَاتَ","translation":"ও পাশে","audioUrl":"wbw/018_018_009.mp3","charTypeName":"word"},{"id":20227,"position":9,"arabic":"ٱلشِّمَالِ ۖ","translation":"বাম","audioUrl":"wbw/018_018_010.mp3","charTypeName":"word"},{"id":20229,"position":10,"arabic":"وَكَلْبُهُم","translation":"এবং (ছিলো) তাদের কুকুর","audioUrl":"wbw/018_018_012.mp3","charTypeName":"word"},{"id":20230,"position":11,"arabic":"بَـٰسِطٌۭ","translation":"প্রসারিতকারী","audioUrl":"wbw/018_018_013.mp3","charTypeName":"word"},{"id":20231,"position":12,"arabic":"ذِرَاعَيْهِ","translation":"তার সামনের দু'পা","audioUrl":"wbw/018_018_014.mp3","charTypeName":"word"},{"id":20232,"position":13,"arabic":"بِٱلْوَصِيدِ ۚ","translation":"মধ্যে গর্তের মুখের","audioUrl":"wbw/018_018_015.mp3","charTypeName":"word"},{"id":20234,"position":14,"arabic":"لَوِ","translation":"যদি","audioUrl":"wbw/018_018_017.mp3","charTypeName":"word"},{"id":20235,"position":15,"arabic":"ٱطَّلَعْتَ","translation":"উঁকি মেরে দেখতে","audioUrl":"wbw/018_018_018.mp3","charTypeName":"word"},{"id":20236,"position":16,"arabic":"عَلَيْهِمْ","translation":"দিকে তাদের","audioUrl":"wbw/018_018_019.mp3","charTypeName":"word"},{"id":20237,"position":17,"arabic":"لَوَلَّيْتَ","translation":"অবশ্যই তুমি পিঠ ফিরাতে","audioUrl":"wbw/018_018_020.mp3","charTypeName":"word"},{"id":20238,"position":18,"arabic":"مِنْهُمْ","translation":"থেকে তাদের","audioUrl":"wbw/018_018_021.mp3","charTypeName":"word"},{"id":20239,"position":19,"arabic":"فِرَارًۭا","translation":"পালিয়ে","audioUrl":"wbw/018_018_022.mp3","charTypeName":"word"},{"id":20240,"position":20,"arabic":"وَلَمُلِئْتَ","translation":"এবং অবশ্যই সঞ্চার হতো","audioUrl":"wbw/018_018_023.mp3","charTypeName":"word"},{"id":20241,"position":21,"arabic":"مِنْهُمْ","translation":"থেকে তাদের","audioUrl":"wbw/018_018_024.mp3","charTypeName":"word"},{"id":20242,"position":22,"arabic":"رُعْبًۭا","translation":"ভয়","audioUrl":"wbw/018_018_025.mp3","charTypeName":"word"},{"id":20243,"position":23,"arabic":"١٨","translation":"(১৮)","audioUrl":null,"charTypeName":"end"}]},{"number":19,"arabic":"وَكَذَٰلِكَ بَعَثْنَٰهُمْ لِيَتَسَآءَلُوا۟ بَيْنَهُمْ ۚ قَالَ قَآئِلٌۭ مِّنْهُمْ كَمْ لَبِثْتُمْ ۖ قَالُوا۟ لَبِثْنَا يَوْمًا أَوْ بَعْضَ يَوْمٍۢ ۚ قَالُوا۟ رَبُّكُمْ أَعْلَمُ بِمَا لَبِثْتُمْ فَٱبْعَثُوٓا۟ أَحَدَكُم بِوَرِقِكُمْ هَٰذِهِۦٓ إِلَى ٱلْمَدِينَةِ فَلْيَنظُرْ أَيُّهَآ أَزْكَىٰ طَعَامًۭا فَلْيَأْتِكُم بِرِزْقٍۢ مِّنْهُ وَلْيَتَلَطَّفْ وَلَا يُشْعِرَنَّ بِكُمْ أَحَدًا","translation":"And so, [in the course of time,] We awakened them; and they began to ask one another [as to what had happened to them]. One of them asked: \"How long have you remained thus?\" [The others] answered: \"We have remained thus a day, or part of a day.\" Said they [who were endowed with deeper insight]: \"Your Sustainer knows best how long you have thus remained. Let, then, one of you go with these silver coins to the town, and let him find out what food is purest there, and bring you thereof [some] provisions. But let him behave with great care and by no means make anyone aware of you:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2159.mp3","surahId":18,"words":[{"id":21305,"position":1,"arabic":"وَكَذَٰلِكَ","translation":"এবং এভাবেই","audioUrl":"wbw/018_019_001.mp3","charTypeName":"word"},{"id":21306,"position":2,"arabic":"بَعَثْنَـٰهُمْ","translation":"আমরা উঠালাম তাদের","audioUrl":"wbw/018_019_002.mp3","charTypeName":"word"},{"id":21307,"position":3,"arabic":"لِيَتَسَآءَلُوا۟","translation":"যেন তারা পরস্পরে জিজ্ঞেস করে","audioUrl":"wbw/018_019_003.mp3","charTypeName":"word"},{"id":21308,"position":4,"arabic":"بَيْنَهُمْ ۚ","translation":"মাঝে তাদের","audioUrl":"wbw/018_019_004.mp3","charTypeName":"word"},{"id":21310,"position":5,"arabic":"قَالَ","translation":"বললো","audioUrl":"wbw/018_019_006.mp3","charTypeName":"word"},{"id":21311,"position":6,"arabic":"قَآئِلٌۭ","translation":