دِ ٱلْكُفَّارَ وَٱلْمُنَٰفِقِينَ وَٱغْلُظْ عَلَيْهِمْ ۚ وَمَأْوَىٰهُمْ جَهَنَّمُ ۖ وَبِئْسَ ٱلْمَصِيرُ","translation":"O PROPHET! Strive hard against the deniers of the truth and the hypocrites, and be adamant with them. And [if they do not repent,] their goal shall be hell - and how vile a journey’s end!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5238.mp3","surahId":66,"words":[{"id":10226,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/066_009_001.mp3","charTypeName":"word"},{"id":10227,"position":2,"arabic":"ٱلنَّبِىُّ","translation":"নবী","audioUrl":"wbw/066_009_002.mp3","charTypeName":"word"},{"id":10228,"position":3,"arabic":"جَـٰهِدِ","translation":"জিহাদ কর","audioUrl":"wbw/066_009_003.mp3","charTypeName":"word"},{"id":10229,"position":4,"arabic":"ٱلْكُفَّارَ","translation":"কাফেরদের (বিরুদ্ধে)","audioUrl":"wbw/066_009_004.mp3","charTypeName":"word"},{"id":10230,"position":5,"arabic":"وَٱلْمُنَـٰفِقِينَ","translation":"ও মুনাফিকদের","audioUrl":"wbw/066_009_005.mp3","charTypeName":"word"},{"id":10231,"position":6,"arabic":"وَٱغْلُظْ","translation":"এবং কঠোর হও","audioUrl":"wbw/066_009_006.mp3","charTypeName":"word"},{"id":10232,"position":7,"arabic":"عَلَيْهِمْ ۚ","translation":"তাদের উপর","audioUrl":"wbw/066_009_007.mp3","charTypeName":"word"},{"id":10234,"position":8,"arabic":"وَمَأْوَىٰهُمْ","translation":"এবং তাদের আশ্রয়স্থল","audioUrl":"wbw/066_009_009.mp3","charTypeName":"word"},{"id":10235,"position":9,"arabic":"جَهَنَّمُ ۖ","translation":"জাহান্নাম","audioUrl":"wbw/066_009_010.mp3","charTypeName":"word"},{"id":10237,"position":10,"arabic":"وَبِئْسَ","translation":"ও কত নিকৃষ্ট","audioUrl":"wbw/066_009_012.mp3","charTypeName":"word"},{"id":10238,"position":11,"arabic":"ٱلْمَصِيرُ","translation":"প্রত্যাবর্তনস্থল","audioUrl":"wbw/066_009_013.mp3","charTypeName":"word"},{"id":10239,"position":12,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"ضَرَبَ ٱللَّهُ مَثَلًۭا لِّلَّذِينَ كَفَرُوا۟ ٱمْرَأَتَ نُوحٍۢ وَٱمْرَأَتَ لُوطٍۢ ۖ كَانَتَا تَحْتَ عَبْدَيْنِ مِنْ عِبَادِنَا صَٰلِحَيْنِ فَخَانَتَاهُمَا فَلَمْ يُغْنِيَا عَنْهُمَا مِنَ ٱللَّهِ شَيْـًۭٔا وَقِيلَ ٱدْخُلَا ٱلنَّارَ مَعَ ٱلدَّٰخِلِينَ","translation":"For those who are bent on denying the truth God has propounded a parable in [the stories of] Noah's wife and Lot's wife: they were wedded to two of Our righteous servants, and each one betrayed her husband; and neither of the two [husbands] will be of any avail to these two women when they are told [on Judgment Day], \"Enter the fire with all those [other sinners] who enter it!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5239.mp3","surahId":66,"words":[{"id":11464,"position":1,"arabic":"ضَرَبَ","translation":"পেশ করেন","audioUrl":"wbw/066_010_001.mp3","charTypeName":"word"},{"id":11465,"position":2,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/066_010_002.mp3","charTypeName":"word"},{"id":11466,"position":3,"arabic":"مَثَلًۭا","translation":"দৃষ্টান্ত","audioUrl":"wbw/066_010_003.mp3","charTypeName":"word"},{"id":11467,"position":4,"arabic":"لِّلَّذِينَ","translation":"যারা জন্যে (তাদের)","audioUrl":"wbw/066_010_004.mp3","charTypeName":"word"},{"id":11468,"position":5,"arabic":"كَفَرُوا۟","translation":"কুফরি করেছে","audioUrl":"wbw/066_010_005.mp3","charTypeName":"word"},{"id":11469,"position":6,"arabic":"ٱمْرَأَتَ","translation":"স্ত্রীর","audioUrl":"wbw/066_010_006.mp3","charTypeName":"word"},{"id":11470,"position":7,"arabic":"نُوحٍۢ","translation":"নূহের","audioUrl":"wbw/066_010_007.mp3","charTypeName":"word"},{"id":11471,"position":8,"arabic":"وَٱمْرَأَتَ","translation":"ও স্ত্রীর","audioUrl":"wbw/066_010_008.mp3","charTypeName":"word"},{"id":11472,"position":9,"arabic":"لُوطٍۢ ۖ","translation":"লূতের","audioUrl":"wbw/066_010_009.mp3","charTypeName":"word"},{"id":11474,"position":10,"arabic":"كَانَتَا","translation":"তারা দু'জনে ছিল","audioUrl":"wbw/066_010_011.mp3","charTypeName":"wo