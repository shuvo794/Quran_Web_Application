14.mp3","charTypeName":"word"},{"id":6447,"position":15,"arabic":"لَّا","translation":"না","audioUrl":"wbw/066_006_015.mp3","charTypeName":"word"},{"id":6448,"position":16,"arabic":"يَعْصُونَ","translation":"তারা অমান্য করে","audioUrl":"wbw/066_006_016.mp3","charTypeName":"word"},{"id":6449,"position":17,"arabic":"ٱللَّهَ","translation":"আল্লাহকে","audioUrl":"wbw/066_006_017.mp3","charTypeName":"word"},{"id":6450,"position":18,"arabic":"مَآ","translation":"যা","audioUrl":"wbw/066_006_018.mp3","charTypeName":"word"},{"id":6451,"position":19,"arabic":"أَمَرَهُمْ","translation":"তাদের নির্দেশ দেন তিনি","audioUrl":"wbw/066_006_019.mp3","charTypeName":"word"},{"id":6452,"position":20,"arabic":"وَيَفْعَلُونَ","translation":"এবং তারা করে","audioUrl":"wbw/066_006_020.mp3","charTypeName":"word"},{"id":6453,"position":21,"arabic":"مَا","translation":"যা","audioUrl":"wbw/066_006_021.mp3","charTypeName":"word"},{"id":6454,"position":22,"arabic":"يُؤْمَرُونَ","translation":"তাদের নির্দেশ দেয়া হয়","audioUrl":"wbw/066_006_022.mp3","charTypeName":"word"},{"id":6455,"position":23,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ كَفَرُوا۟ لَا تَعْتَذِرُوا۟ ٱلْيَوْمَ ۖ إِنَّمَا تُجْزَوْنَ مَا كُنتُمْ تَعْمَلُونَ","translation":"[Hence,] O you who are bent on denying the truth, make no [empty] excuses today: [in the life to come] you shall be but recompensed for what you were doing [in this world].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5236.mp3","surahId":66,"words":[{"id":7841,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"\"ওহে","audioUrl":"wbw/066_007_001.mp3","charTypeName":"word"},{"id":7842,"position":2,"arabic":"ٱلَّذِينَ","translation":"\"যারা","audioUrl":"wbw/066_007_002.mp3","charTypeName":"word"},{"id":7843,"position":3,"arabic":"كَفَرُوا۟","translation":"\"কুফরী করেছ","audioUrl":"wbw/066_007_003.mp3","charTypeName":"word"},{"id":7844,"position":4,"arabic":"لَا","translation":"না","audioUrl":"wbw/066_007_004.mp3","charTypeName":"word"},{"id":7845,"position":5,"arabic":"تَعْتَذِرُوا۟","translation":"তোমরা ওজর পেশ করো","audioUrl":"wbw/066_007_005.mp3","charTypeName":"word"},{"id":7846,"position":6,"arabic":"ٱلْيَوْمَ ۖ","translation":"আজ","audioUrl":"wbw/066_007_006.mp3","charTypeName":"word"},{"id":7848,"position":7,"arabic":"إِنَّمَا","translation":"প্রকৃতপক্ষে","audioUrl":"wbw/066_007_008.mp3","charTypeName":"word"},{"id":7849,"position":8,"arabic":"تُجْزَوْنَ","translation":"তোমাদের প্রতিফল দেয়া হবে","audioUrl":"wbw/066_007_009.mp3","charTypeName":"word"},{"id":7850,"position":9,"arabic":"مَا","translation":"যা","audioUrl":"wbw/066_007_010.mp3","charTypeName":"word"},{"id":7851,"position":10,"arabic":"كُنتُمْ","translation":"তোমরা","audioUrl":"wbw/066_007_011.mp3","charTypeName":"word"},{"id":7852,"position":11,"arabic":"تَعْمَلُونَ","translation":"তোমরা কাজ করতেছিলে\"","audioUrl":"wbw/066_007_012.mp3","charTypeName":"word"},{"id":7853,"position":12,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ تُوبُوٓا۟ إِلَى ٱللَّهِ تَوْبَةًۭ نَّصُوحًا عَسَىٰ رَبُّكُمْ أَن يُكَفِّرَ عَنكُمْ سَيِّـَٔاتِكُمْ وَيُدْخِلَكُمْ جَنَّٰتٍۢ تَجْرِى مِن تَحْتِهَا ٱلْأَنْهَٰرُ يَوْمَ لَا يُخْزِى ٱللَّهُ ٱلنَّبِىَّ وَٱلَّذِينَ ءَامَنُوا۟ مَعَهُۥ ۖ نُورُهُمْ يَسْعَىٰ بَيْنَ أَيْدِيهِمْ وَبِأَيْمَٰنِهِمْ يَقُولُونَ رَبَّنَآ أَتْمِمْ لَنَا نُورَنَا وَٱغْفِرْ لَنَآ ۖ إِنَّكَ عَلَىٰ كُلِّ شَىْءٍۢ قَدِيرٌۭ","translation":"O you who have attained to faith! Turn unto God in sincere repentance: it may well be that your Sustainer will efface from you your bad deeds, and will admit you into gardens through which running waters flow, on a Day on which God will not shame the Prophet and those who share his faith: their light will spread rapidly before them, and on their right; [and] they will pray: \"O our Sustainer! Cause this our light to shine for us forever, and forgive us our sins: for, verily, Thou hast the power to will anything!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5237.mp3","surahId":66,"words":[{"id":8990,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"ওহে","audioUrl":"wbw/066_008_001.mp3","charTypeName":"word"},{"id":8991,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/066_008_002.mp3","charTypeName":"word"},{"id":8992,"position":3,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছ","audioUrl":"wbw/066_008_003.mp3","charTypeName":"word"},{"id":8993,"position":4,"arabic":"تُوبُوٓا۟","translation":"তোমরা তওবা কর","audioUrl":"wbw/066_008_004.mp3","charTypeName":"word"},{"id":8994,"position":5,"arabic":"إِلَى","translation":"নিকট","audioUrl":"wbw/066_008_005.mp3","charTypeName":"word"},{"id":8995,"position":6,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/066_008_006.mp3","charTypeName":"word"},{"id":8996,"position":7,"arabic":"تَوْبَةًۭ","translation":"তওবা","audioUrl":"wbw/066_008_007.mp3","charTypeName":"word"},{"id":8997,"position":8,"arabic":"نَّصُوحًا","translation":"খালেস","audioUrl":"wbw/066_008_008.mp3","charTypeName":"word"},{"id":8998,"position":9,"arabic":"عَسَىٰ","translation":"সম্ভবতঃ","audioUrl":"wbw/066_008_009.mp3","charTypeName":"word"},{"id":8999,"position":10,"arabic":"رَبُّكُمْ","translation":"তোমাদের রব","audioUrl":"wbw/066_008_010.mp3","charTypeName":"word"},{"id":9000,"position":11,"arabic":"أَن","translation":"যে","audioUrl":"wbw/066_008_011.mp3","charTypeName":"word"},{"id":9001,"position":12,"arabic":"يُكَفِّرَ","translation":"মোচন করবেন","audioUrl":"wbw/066_008_012.mp3","charTypeName":"word"},{"id":9002,"position":13,"arabic":"عَنكُمْ","translation":"তোমাদের থেকে","audioUrl":"wbw/066_008_013.mp3","charTypeName":"word"},{"id":9003,"position":14,"arabic":"سَيِّـَٔاتِكُمْ","translation":"তোমাদের দোষগুলো","audioUrl":"wbw/066_008_014.mp3","charTypeName":"word"},{"id":9004,"position":15,"arabic":"وَيُدْخِلَكُمْ","translation":"এবং তোমাদের প্রবেশ করাবেন","au