d"},{"id":15070,"position":3,"arabic":"ذَٰلِكَ","translation":"এর","audioUrl":"wbw/068_013_003.mp3","charTypeName":"word"},{"id":15071,"position":4,"arabic":"زَنِيمٍ","translation":"(এ কারণে) বদজাতও","audioUrl":"wbw/068_013_004.mp3","charTypeName":"word"},{"id":15072,"position":5,"arabic":"١٣","translation":"(১৩)","audioUrl":null,"charTypeName":"end"}]},{"number":14,"arabic":"أَن كَانَ ذَا مَالٍۢ وَبَنِينَ","translation":"Is it because he is possessed of worldly goods and children","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5285.mp3","surahId":68,"words":[{"id":16157,"position":1,"arabic":"أَن","translation":"যে","audioUrl":"wbw/068_014_001.mp3","charTypeName":"word"},{"id":16158,"position":2,"arabic":"كَانَ","translation":"সেছিলো","audioUrl":"wbw/068_014_002.mp3","charTypeName":"word"},{"id":16159,"position":3,"arabic":"ذَا","translation":"অধিকারী","audioUrl":"wbw/068_014_003.mp3","charTypeName":"word"},{"id":16160,"position":4,"arabic":"مَالٍۢ","translation":"মালের(ধন-সম্পদের)","audioUrl":"wbw/068_014_004.mp3","charTypeName":"word"},{"id":16161,"position":5,"arabic":"وَبَنِينَ","translation":"এবং সন্তানসন্ততির","audioUrl":"wbw/068_014_005.mp3","charTypeName":"word"},{"id":16162,"position":6,"arabic":"١٤","translation":"(১৪)","audioUrl":null,"charTypeName":"end"}]},{"number":15,"arabic":"إِذَا تُتْلَىٰ عَلَيْهِ ءَايَٰتُنَا قَالَ أَسَٰطِيرُ ٱلْأَوَّلِينَ","translation":"that, whenever Our messages are conveyed to him, such a one says, \"Fables of ancient times\"?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5286.mp3","surahId":68,"words":[{"id":17428,"position":1,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/068_015_001.mp3","charTypeName":"word"},{"id":17429,"position":2,"arabic":"تُتْلَىٰ","translation":"আবৃত্তি করা হয়","audioUrl":"wbw/068_015_002.mp3","charTypeName":"word"},{"id":17430,"position":3,"arabic":"عَلَيْهِ","translation":"তার নিকট","audioUrl":"wbw/068_015_003.mp3","charTypeName":"word"},{"id":17431,"posit