{"id":564,"ayahs":[{"number":27,"arabic":"فَلَمَّا رَأَوْهُ زُلْفَةًۭ سِيٓـَٔتْ وُجُوهُ ٱلَّذِينَ كَفَرُوا۟ وَقِيلَ هَٰذَا ٱلَّذِى كُنتُم بِهِۦ تَدَّعُونَ","translation":"Yet in the end, when they shall see that [fulfilment] close at hand, the faces of those who were bent on denying the truth will be stricken with grief; and they will be told, \"This it is that you were [so derisively] calling for!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5268.mp3","surahId":67,"words":[{"id":29774,"position":1,"arabic":"فَلَمَّا","translation":"যখন পরে","audioUrl":"wbw/067_027_001.mp3","charTypeName":"word"},{"id":29775,"position":2,"arabic":"رَأَوْهُ","translation":"তা দেখবে","audioUrl":"wbw/067_027_002.mp3","charTypeName":"word"},{"id":29776,"position":3,"arabic":"زُلْفَةًۭ","translation":"নিকটে","audioUrl":"wbw/067_027_003.mp3","charTypeName":"word"},{"id":29777,"position":4,"arabic":"سِيٓـَٔتْ","translation":"মলিন হবে","audioUrl":"wbw/067_027_004.mp3","charTypeName":"word"},{"id":29778,"position":5,"arabic":"وُجُوهُ","translation":"মুখগুলো","audioUrl":"wbw/067_027_005.mp3","charTypeName":"word"},{"id":29779,"position":6,"arabic":"ٱلَّذِينَ","translation":"যারা (তাদের)","audioUrl":"wbw/067_027_006.mp3","charTypeName":"word"},{"id":29780,"position":7,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/067_027_007.mp3","charTypeName":"word"},{"id":29781,"position":8,"arabic":"وَقِيلَ","translation":"এবং বলা হবে","audioUrl":"wbw/067_027_008.mp3","charTypeName":"word"},{"id":29782,"position":9,"arabic":"هَـٰذَا","translation":"\"এই","audioUrl":"wbw/067_027_009.mp3","charTypeName":"word"},{"id":29783,"position":10,"arabic":"ٱلَّذِى","translation":"যা (সেই)","audioUrl":"wbw/067_027_010.mp3","charTypeName":"word"},{"id":29784,"position":11,"arabic":"كُنتُم","translation":"তোমরা ছিলে","audioUrl":"wbw/067_027_011.mp3","charTypeName":"word"},{"id":29785,"position":12,"arabic":"بِهِۦ","translation":"তা সম্পর্কে","audioUrl":"wbw/067_027_012.mp3","charTypeName":"word"},{"id":29786,"position":13,"arabic":"تَدَّعُونَ","translation":"দাবি করতে\"","audioUrl":"wbw/067_027_013.mp3","charTypeName":"word"},{"id":29787,"position":14,"arabic":"٢٧","translation":"(২৭)","audioUrl":null,"charTypeName":"end"}]},{"number":28,"arabic":"قُلْ أَرَءَيْتُمْ إِنْ أَهْلَكَنِىَ ٱللَّهُ وَمَن مَّعِىَ أَوْ رَحِمَنَا فَمَن يُجِيرُ ٱلْكَٰفِرِينَ مِنْ عَذَابٍ أَلِيمٍۢ","translation":"SAY [O Prophet]: \"What do you think? Whether God destroys me and those who follow me, or graces us with His mercy - is there anyone that could protect [you] deniers of the truth from grievous suffering [in the life to come]?\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5269.mp3","surahId":67,"words":[{"id":30889,"position":1,"arabic":"قُلْ","translation":"বল","audioUrl":"wbw/067_028_001.mp3","charTypeName":"word"},{"id":30890,"position":2,"arabic":"أَرَءَيْتُمْ","translation":"\"তোমরা চিন্তা কি করেছ","audioUrl":"wbw/067_028_002.mp3","charTypeName":"word"},{"id":30891,"position":3,"arabic":"إِنْ","translation":"যদি","audioUrl":"wbw/067_028_003.mp3","charTypeName":"word"},{"id":30892,"position":4,"arabic":"أَهْلَكَنِىَ","translation":"আমাকে ধ্বংস করেন","audioUrl":"wbw/067_028_004.mp3","charTypeName":"word"},{"id":30893,"position":5,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/067_028_005.mp3","charTypeName":"word"},{"id":30894,"position":6,"arabic":"وَمَن","translation":"এবং যারা","audioUrl":"wbw/067_028_006.mp3","charTypeName":"word"},{"id":30895,"position":7,"arabic":"مَّعِىَ","translation":"আমার সাথে","audioUrl":"wbw/067_028_007.mp3","charTypeName":"word"},{"id":30896,"position":8,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/067_028_008.mp3","charTypeName":"word"},{"id":30897,"position":9,"arabic":"رَحِمَنَا","translation":"আমাদের প্রতি দয়া করেন","audioUrl":"wbw/067_028_009.mp3","charTypeName":"word"},{"id":30898,"position":10,"arabic":"فَمَن","translation":"কে কিন্তু","audioUrl":"wbw/067_028_010.mp3","charTypeName":"word"},{"id":30899,"position":11,"arabic":"يُجِيرُ","translation":"আশ্রয় দেবে","audioUrl":"wbw/067_028_011.mp3","charTypeName":"word"},{"id":30900,"position":12,"arabic":"ٱلْكَـٰفِرِينَ","translation":"অস্বীকার কারীদের","audioUrl":"wbw/067_028_012.mp3","charTypeName":"word"},{"id":30901,"position":13,"arabic":"مِنْ","translation":"থেকে","audioUrl":"wbw/067_028_013.mp3","charTypeName":"word"},{"id":30902,"position":14,"arabic":"عَذَابٍ","translation":"আযাব","audioUrl":"wbw/067_028_014.mp3","charTypeName":"word"},{"id":30903,"position":15,"arabic":"أَلِيمٍۢ","translation":"অত্যন্ত পীড়াদায়ক\"","audioUrl":"wbw/067_028_015.mp3","charTypeName":"word"},{"id":30904,"position":16,"arabic":"٢٨","translation":"(২৮)","audioUrl":null,"charTypeName":"end"}]},{"number":29,"arabic":"قُلْ هُوَ ٱلرَّحْمَٰنُ ءَامَنَّا بِهِۦ وَعَلَيْهِ تَوَكَّلْنَا ۖ فَسَتَعْلَمُونَ مَنْ هُوَ فِى ضَلَٰلٍۢ مُّبِينٍۢ","translation":"Say: \"He is the Most Gracious: we have attained to faith in Him, and in Him have we placed our trust; and in time you will come to know which of us was lost in manifest error.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5270.mp3","surahId":67,"words":[{"id":31905,"position":1,"arabic":"قُلْ","translation":"বল","audioUrl":"wbw/067_029_001.mp3","charTypeName":"word"},{"id":31906,"position":2,"arabic":"هُوَ","translation":"\"তিনিই","audioUrl":"wbw/067_029_002.mp3","charTypeName":"word"},{"id":31907,"position":3,"arabic":"ٱلرَّحْمَـٰنُ","translation":"পরম করুণাময়","audioUrl":"wbw/067_029_003.mp3","charTypeName":"word"},{"id":31908,"position":4,"arabic":"ءَامَنَّا","translation":"আমরা ঈমান এনেছি","audioUrl":"wbw/067_029_004.mp3","charTypeName":"word"},{"id":31909,"position":5,"arabic":"بِهِۦ","translation":"তার উপর","audioUrl":"wbw/067_029_005.mp3","charTypeName":"word"},{"id":31910,"position":6,"arabic":"وَعَلَيْهِ","translation":"এবং তার উপর","audioUrl":"wbw/067_029_006.mp3","charTypeName":"word"},{"id":31911,"position":7,"arabic":"تَوَكَّلْنَا ۖ","translation":"আমরা নির্ভর করেছি","audioUrl":"wbw/067_029_007.mp3","charTypeName":"word"},{"id":31913,"position":8,"arabic":"فَسَتَعْلَمُونَ","translation":"অতএব শীঘ্রই তোমরা জানতে পারবে","audioUrl":"wbw/067_029_009.mp3","charTypeName":"word"},{"id":31914,"position":9,"arabic":"مَنْ","translation":"কে","audioUrl":"wbw/067_029_010.mp3","charTypeName":"word"},{"id":31915,"position":10,"arabic":"هُوَ","translation":"সে","audioUrl":"wbw/067_029_011.mp3","charTypeName":"word"},{"id":31916,"position":11,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/067_029_012.mp3","charTypeName":"word"},{"id":31917,"position":12,"arabic":"ضَلَـٰلٍۢ","translation":"গুমরাহীর","audioUrl":"wbw/067_029_013.mp3","charTypeName":"word"},{"id":31918,"position":13,"arabic":"مُّبِينٍۢ","translation":"সুস্পষ্ট\"","audioUrl":"wbw/067_029_014.mp3","charTypeName":"word"},{"id":31919,"position":14,"arabic":"٢٩","translation":"(২৯)","audioUrl":null,"charTypeName":"end"}]},{"number":30,"arabic":"قُلْ أَرَءَيْتُمْ إِنْ أَصْبَحَ مَآؤُكُمْ غَوْرًۭا فَمَن يَأْتِيكُم بِمَآءٍۢ مَّعِينٍۭ","translation":"Say [unto those who deny the truth]: \"What do you think? If of a sudden all your water were to vanish underground, who [but God] could provide you with water from [new] unsullied springs?\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5271.mp3","surahId":67,"words":[{"id":32537,"position":1,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/067_030_001.mp3","charTypeName":"word"},{"id":32538,"position":2,"arabic":"أَرَءَيْتُمْ","translation":"\"তোমরা ভেবে কি দেখেছ","audioUrl":"wbw/067_030_002.mp3","charTypeName":"word"},{"id":32539,"position":3,"arabic":"إِنْ","translation":"যদি","audioUrl":"wbw/067_030_003.mp3","charTypeName":"word"},{"id":32540,"position":4,"arabic":"أَصْبَحَ","translation":"হয়ে যায়","audioUrl":"wbw/067_030_004.mp3","charTypeName":"word"},{"id":32541,"position":5,"arabic":"مَآؤُكُمْ","translation":"তোমাদের পানি","audioUrl":"wbw/067_030_005.mp3","charTypeName":"word"},{"id":32542,"position":6,"arabic":"غَوْرًۭا","translation":"ভূগর্ভস্থ","audioUrl":"wbw/067_030_006.mp3","charTypeName":"word"},{"id":32543,"position":7,"arabic":"فَمَن","translation":"কে তবে","audioUrl":"wbw/067_030_007.mp3","charTypeName":"word"},{"id":32544,"position":8,"arabic":"يَأْتِيكُم","translation":"তোমাদের কাছে আনবে","audioUrl":"wbw/067_030_008.mp3","charTypeName":"word"},{"id":32545,"position":9,"arabic":"بِمَآءٍۢ","translation":"পানি","audioUrl":"wbw/067_030_009.mp3","charTypeName":"word"},{"id":32546,"position":10,"arabic":"مَّعِينٍۭ","translation":"প্রবহমান\"","audioUrl":"wbw/067_030_010.mp3","charTypeName":"word"},{"id":32547,"position":11,"arabic":"٣٠","translation":"(৩০)","audioUrl":null,"charTypeName":"end"}]},{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ نٓ ۚ وَٱلْقَلَمِ وَمَا يَسْطُرُونَ","translation":"Nun. CONSIDER the pen, and all that they write [therewith]!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5272.mp3","surahId":68,"words":[{"id":582,"position":1,"arabic":"نٓ ۚ","translation":"নুন","audioUrl":"wbw/068_001_001.mp3","charTypeName":"word"},{"id":584,"position":2,"arabic":"وَٱلْقَلَمِ","translation":"কলমের শপথ","audioUrl":"wbw/068_001_003.mp3","charTypeName":"word"},{"id":585,"position":3,"arabic":"وَمَا","translation":"এবং যা","audioUrl":"wbw/068_001_004.mp3","charTypeName":"word"},{"id":586,"position":4,"arabic":"يَسْطُرُونَ","translation":"তারা লিখছে","audioUrl":"wbw/068_001_005.mp3","charTypeName":"word"},{"id":587,"position":5,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"مَآ أَنتَ بِنِعْمَةِ رَبِّكَ بِمَجْنُونٍۢ","translation":"Thou art not, by thy Sustainer's grace, a madman!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5273.mp3","surahId":68,"words":[{"id":1475,"position":1,"arabic":"مَآ","translation":"না","audioUrl":"wbw/068_002_001.mp3","charTypeName":"word"},{"id":1476,"position":2,"arabic":"أَنتَ","translation":"তু