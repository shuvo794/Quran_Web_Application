7877,"position":2,"arabic":"رَبَّكَ","translation":"তোমার রব,","audioUrl":"wbw/068_007_002.mp3","charTypeName":"word"},{"id":7878,"position":3,"arabic":"هُوَ","translation":"তিনিই","audioUrl":"wbw/068_007_003.mp3","charTypeName":"word"},{"id":7879,"position":4,"arabic":"أَعْلَمُ","translation":"সব জানেন","audioUrl":"wbw/068_007_004.mp3","charTypeName":"word"},{"id":7880,"position":5,"arabic":"بِمَن","translation":"কে","audioUrl":"wbw/068_007_005.mp3","charTypeName":"word"},{"id":7881,"position":6,"arabic":"ضَلَّ","translation":"ভ্রষ্ট হয়েছে","audioUrl":"wbw/068_007_006.mp3","charTypeName":"word"},{"id":7882,"position":7,"arabic":"عَن","translation":"থেকে","audioUrl":"wbw/068_007_007.mp3","charTypeName":"word"},{"id":7883,"position":8,"arabic":"سَبِيلِهِۦ","translation":"তার পথ,","audioUrl":"wbw/068_007_008.mp3","charTypeName":"word"},{"id":7884,"position":9,"arabic":"وَهُوَ","translation":"এবং তিনিই","audioUrl":"wbw/068_007_009.mp3","charTypeName":"word"},{"id":7885,"position":10,"arabic":"أَعْلَمُ","translation":"সব জানেন","audioUrl":"wbw/068_007_010.mp3","charTypeName":"word"},{"id":7886,"position":11,"arabic":"بِٱلْمُهْتَدِينَ","translation":"পথ প্রাপ্তদেরকে","audioUrl":"wbw/068_007_011.mp3","charTypeName":"word"},{"id":7887,"position":12,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"فَلَا تُطِعِ ٱلْمُكَذِّبِينَ","translation":"Hence, defer not to [the likes and dislikes of] those who give the lie to the truth:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5279.mp3","surahId":68,"words":[{"id":9067,"position":1,"arabic":"فَلَا","translation":"না অতএব","audioUrl":"wbw/068_008_001.mp3","charTypeName":"word"},{"id":9068,"position":2,"arabic":"تُطِعِ","translation":"মেনো","audioUrl":"wbw/068_008_002.mp3","charTypeName":"word"},{"id":9069,"position":3,"arabic":"ٱلْمُكَذِّبِينَ","translation":"মিথ্যারোপকারীদের।","audioUrl":"wbw/068_008_003.mp3","charTypeName":"word"},{"id":9070,"position":4,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"وَدُّوا۟ لَوْ تُدْهِنُ فَيُدْهِنُونَ","translation":"they would like thee to be soft [with them], so that they might be soft [with thee].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5280.mp3","surahId":68,"words":[{"id":10283,"position":1,"arabic":"وَدُّوا۟","translation":"তারা চাই","audioUrl":"wbw/068_009_001.mp3","charTypeName":"word"},{"id":10284,"position":2,"arabic":"لَوْ","translation":"যদি","audioUrl":"wbw/068_009_002.mp3","charTypeName":"word"},{"id":10285,"position":3,"arabic":"تُدْهِنُ","translation":"তুমি নমনীয় হও","audioUrl":"wbw/068_009_003.mp3","charTypeName":"word"},{"id":10286,"position":4,"arabic":"فَيُدْهِنُونَ","translation":"তবে তারা নমনীয় হবে","audioUrl":"wbw/068_009_004.mp3","charTypeName":"word"},{"id":10287,"position":5,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"وَلَا تُطِعْ كُلَّ حَلَّافٍۢ مَّهِينٍ","translation":"Furthermore, defer not to the contemptible swearer of oaths,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5281.mp3","surahId":68,"words":[{"id":11458,"position":1,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/068_010_001.mp3","charTypeName":"word"},{"id":11459,"position":2,"arabic":"تُطِعْ","translation":"অনুসরণ করে!","audioUrl":"wbw/068_010_002.mp3","charTypeName":"word"},{"id":11460,"position":3,"arabic":"كُلَّ","translation":"প্রত্যেক","audioUrl":"wbw/068_010_003.mp3","charTypeName":"word"},{"id":11461,"position":4,"arabic":"حَلَّافٍۢ","translation":"অত্যাধিক শপথকারী","audioUrl":"wbw/068_010_004.mp3","charTypeName":"word"},{"id":11462,"position":5,"arabic":"مَّهِينٍ","translation":"গুরুত্বহীন(ব্যক্তির)","audioUrl":"wbw/068_010_005.mp3","charTypeName":"word"},{"id":11463,"position":6,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"هَمَّازٍۢ مَّشَّآءٍۭ بِنَمِيمٍۢ","translation":"[or to] the sland