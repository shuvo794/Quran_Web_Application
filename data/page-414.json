{"id":414,"ayahs":[{"number":29,"arabic":"أَلَمْ تَرَ أَنَّ ٱللَّهَ يُولِجُ ٱلَّيْلَ فِى ٱلنَّهَارِ وَيُولِجُ ٱلنَّهَارَ فِى ٱلَّيْلِ وَسَخَّرَ ٱلشَّمْسَ وَٱلْقَمَرَ كُلٌّۭ يَجْرِىٓ إِلَىٰٓ أَجَلٍۢ مُّسَمًّۭى وَأَنَّ ٱللَّهَ بِمَا تَعْمَلُونَ خَبِيرٌۭ","translation":"Art thou not aware that it is God who makes the night grow longer by shortening the day, and makes the day grow longer by shortening the night, and that He has made the sun and the moon subservient [to His laws], each running its course for a term set [by Him] and that God is fully aware of all that you do?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3498.mp3","surahId":31,"words":[{"id":32224,"position":1,"arabic":"أَلَمْ","translation":"কি না","audioUrl":"wbw/031_029_001.mp3","charTypeName":"word"},{"id":32225,"position":2,"arabic":"تَرَ","translation":"তুমি দেখো","audioUrl":"wbw/031_029_002.mp3","charTypeName":"word"},{"id":32226,"position":3,"arabic":"أَنَّ","translation":"যে","audioUrl":"wbw/031_029_003.mp3","charTypeName":"word"},{"id":32227,"position":4,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/031_029_004.mp3","charTypeName":"word"},{"id":32228,"position":5,"arabic":"يُولِجُ","translation":"প্রবেশ করান","audioUrl":"wbw/031_029_005.mp3","charTypeName":"word"},{"id":32229,"position":6,"arabic":"ٱلَّيْلَ","translation":"রাতকে","audioUrl":"wbw/031_029_006.mp3","charTypeName":"word"},{"id":32230,"position":7,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/031_029_007.mp3","charTypeName":"word"},{"id":32231,"position":8,"arabic":"ٱلنَّهَارِ","translation":"দিনের","audioUrl":"wbw/031_029_008.mp3","charTypeName":"word"},{"id":32232,"position":9,"arabic":"وَيُولِجُ","translation":"ও প্রবেশ করান","audioUrl":"wbw/031_029_009.mp3","charTypeName":"word"},{"id":32233,"position":10,"arabic":"ٱلنَّهَارَ","translation":"দিনকে","audioUrl":"wbw/031_029_010.mp3","charTypeName":"word"},{"id":32234,"position":11,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/031_029_011.mp3","charTypeName":"word"},{"id":32235,"position":12,"arabic":"ٱلَّيْلِ","translation":"রাতের","audioUrl":"wbw/031_029_012.mp3","charTypeName":"word"},{"id":32236,"position":13,"arabic":"وَسَخَّرَ","translation":"এবং নিয়মাধীন করেছেন","audioUrl":"wbw/031_029_013.mp3","charTypeName":"word"},{"id":32237,"position":14,"arabic":"ٱلشَّمْسَ","translation":"সূর্যকে","audioUrl":"wbw/031_029_014.mp3","charTypeName":"word"},{"id":32238,"position":15,"arabic":"وَٱلْقَمَرَ","translation":"ও চাঁদকে","audioUrl":"wbw/031_029_015.mp3","charTypeName":"word"},{"id":32239,"position":16,"arabic":"كُلٌّۭ","translation":"প্রত্যেকে","audioUrl":"wbw/031_029_016.mp3","charTypeName":"word"},{"id":32240,"position":17,"arabic":"يَجْرِىٓ","translation":"চলছে","audioUrl":"wbw/031_029_017.mp3","charTypeName":"word"},{"id":32241,"position":18,"arabic":"إِلَىٰٓ","translation":"পর্যন্ত","audioUrl":"wbw/031_029_018.mp3","charTypeName":"word"},{"id":32242,"position":19,"arabic":"أَجَلٍۢ","translation":"কাল","audioUrl":"wbw/031_029_019.mp3","charTypeName":"word"},{"id":32243,"position":20,"arabic":"مُّسَمًّۭى","translation":"নির্দিষ্ট","audioUrl":"wbw/031_029_020.mp3","charTypeName":"word"},{"id":32244,"position":21,"arabic":"وَأَنَّ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/031_029_021.mp3","charTypeName":"word"},{"id":32245,"position":22,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/031_029_022.mp3","charTypeName":"word"},{"id":32246,"position":23,"arabic":"بِمَا","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/031_029_023.mp3","charTypeName":"word"},{"id":32247,"position":24,"arabic":"تَعْمَلُونَ","translation":"তোমরা করছো","audioUrl":"wbw/031_029_024.mp3","charTypeName":"word"},{"id":32248,"position":25,"arabic":"خَبِيرٌۭ","translation":"খুব অবহিত","audioUrl":"wbw/031_029_025.mp3","charTypeName":"word"},{"id":32249,"position":26,"arabic":"٢٩","translation":"(২৯)","audioUrl":null,"charTypeName":"end"}]},{"number":30,"arabic":"ذَٰلِكَ بِأَنَّ ٱللَّهَ هُوَ ٱلْحَقُّ وَأَنَّ مَا يَدْعُونَ مِن دُونِهِ ٱلْبَٰطِلُ وَأَنَّ ٱللَّهَ هُوَ ٱلْعَلِىُّ ٱلْكَبِيرُ","translation":"Thus it is, because God alone is the Ultimate Truth, so that all that men invoke instead of Him is sheer falsehood; and because God alone is exalted, truly great!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3499.mp3","surahId":31,"words":[{"id":33061,"position":1,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/031_030_001.mp3","charTypeName":"word"},{"id":33062,"position":2,"arabic":"بِأَنَّ","translation":"একারণে যে","audioUrl":"wbw/031_030_002.mp3","charTypeName":"word"},{"id":33063,"position":3,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/031_030_003.mp3","charTypeName":"word"},{"id":33064,"position":4,"arabic":"هُوَ","translation":"তিনিই","audioUrl":"wbw/031_030_004.mp3","charTypeName":"word"},{"id":33065,"position":5,"arabic":"ٱلْحَقُّ","translation":"সত্য","audioUrl":"wbw/031_030_005.mp3","charTypeName":"word"},{"id":33066,"position":6,"arabic":"وَأَنَّ","translation":"এবং (এও) যে","audioUrl":"wbw/031_030_006.mp3","charTypeName":"word"},{"id":33067,"position":7,"arabic":"مَا","translation":"যাকে","audioUrl":"wbw/031_030_007.mp3","charTypeName":"word"},{"id":33068,"position":8,"arabic":"يَدْعُونَ","translation":"তারা ডাকছে","audioUrl":"wbw/031_030_008.mp3","charTypeName":"word"},{"id":33069,"position":9,"arabic":"مِن","translation":"ছাড়া","audioUrl":"wbw/031_030_009.mp3","charTypeName":"word"},{"id":33070,"position":10,"arabic":"دُونِهِ","translation":"তাঁকে","audioUrl":"wbw/031_030_010.mp3","charTypeName":"word"},{"id":33071,"position":11,"arabic":"ٱلْبَـٰطِلُ","translation":"( তা সবই )অসত্য","audioUrl":"wbw/031_030_011.mp3","charTypeName":"word"},{"id":33072,"position":12,"arabic":"وَأَنَّ","translation":"এবং (এও সত্য) যে","audioUrl":"wbw/031_030_012.mp3","charTypeName":"word"},{"id":33073,"position":13,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/031_030_013.mp3","charTypeName":"word"},{"id":33074,"position":14,"arabic":"هُوَ","translation":"তিনিই","audioUrl":"wbw/031_030_014.mp3","charTypeName":"word"},{"id":33075,"position":15,"arabic":"ٱلْعَلِىُّ","translation":"সমুন্নত","audioUrl":"wbw/031_030_015.mp3","charTypeName":"word"},{"id":33076,"position":16,"arabic":"ٱلْكَبِيرُ","translation":"সুমহান","audioUrl":"wbw/031_030_016.mp3","charTypeName":"word"},{"id":33077,"position":17,"arabic":"٣٠","translation":"(৩০)","audioUrl":null,"charTypeName":"end"}]},{"number":31,"arabic":"أَلَمْ تَرَ أَنَّ ٱلْفُلْكَ تَجْرِى فِى ٱلْبَحْرِ بِنِعْمَتِ ٱللَّهِ لِيُرِيَكُم مِّنْ ءَايَٰتِهِۦٓ ۚ إِنَّ فِى ذَٰلِكَ لَءَايَٰتٍۢ لِّكُلِّ صَبَّارٍۢ شَكُورٍۢ","translation":"Art thou not aware how the ships speed through the sea by God’s favour, so that He might show you some of His wonders? Herein, behold, there are messages indeed for all who are wholly patient in adversity and deeply grate­ful [to God].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3500.mp3","surahId":31,"words":[{"id":33992,"position":1,"arabic":"أَلَمْ","translation":"কি না","audioUrl":"wbw/031_031_001.mp3","charTypeName":"word"},{"id":33993,"position":2,"arabic":"تَرَ","translation":"তুমি দেখো","audioUrl":"wbw/031_031_002.mp3","charTypeName":"word"},{"id":33994,"position":3,"arabic":"أَنَّ","translation":"যে","audioUrl":"wbw/031_031_003.mp3","charTypeName":"word"},{"id":33995,"position":4,"arabic":"ٱلْفُلْكَ","translation":"জলযান","audioUrl":"wbw/031_031_004.mp3","charTypeName":"word"},{"id":33996,"position":5,"arabic":"تَجْرِى","translation":"চলে","audioUrl":"wbw/031_031_005.mp3","charTypeName":"word"},{"id":33997,"position":6,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/031_031_006.mp3","charTypeName":"word"},{"id":33998,"position":7,"arabic":"ٱلْبَحْرِ","translation":"সমুদ্রের","audioUrl":"wbw/031_031_007.mp3","charTypeName":"word"},{"id":33999,"position":8,"arabic":"بِنِعْمَتِ","translation":"সাহায্যে অনুগ্রহের","audioUrl":"wbw/031_031_008.mp3","charTypeName":"word"},{"id":34000,"position":9,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/031_031_009.mp3","charTypeName":"word"},{"id":34001,"position":10,"arabic":"لِيُرِيَكُم","translation":"যেন তিনি তোমাদের দেখান","audioUrl":"wbw/031_031_010.mp3","charTypeName":"word"},{"id":34002,"position":11,"arabic":"مِّنْ","translation":"কিছু","audioUrl":"wbw/031_031_011.mp3","charTypeName":"word"},{"id":34003,"position":12,"arabic":"ءَايَـٰتِهِۦٓ ۚ","translation":"নির্দেশাবলী তাঁর","audioUrl":"wbw/031_031_012.mp3","charTypeName":"word"},{"id":34005,"position":13,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/031_031_014.mp3","charTypeName":"word"},{"id":34006,"position":14,"arabic":"فِى","translation":"মধ্যে (আছে)","audioUrl":"wbw/031_031_015.mp3","charTypeName":"word"},{"id":34007,"position":15,"arabic":"ذَٰلِكَ","translation":"এর","audioUrl":"wbw/031_031_016.mp3","charTypeName":"word"},{"id":34008,"position":16,"arabic":"لَـَٔايَـٰتٍۢ","translation":"অবশ্যই নিদর্শনাবলী","audioUrl":"wbw/031_031_017.mp3","charTypeName":"word"},{"id":34009,"position":17,"arabic":"لِّكُلِّ","translation":"জন্যে প্রত্যেক","audioUrl":"wbw/031_031_018.mp3","charTypeName":"word"},{"id":34010,"position":18,"arabic":"صَبَّارٍۢ","translation":"ধৈর্যশীলের","audioUrl":"wbw/031_031_019.mp3","charTypeName":"word"},{"id":34011,"position":19,"arabic":"شَكُورٍۢ","translation":"কৃতজ্ঞের","audioUrl":"wbw/031_031_020.mp3","charTypeName":"word"},{"id":34012,"position":20,"arabic":"٣١","translation":"(৩১)","audioUrl":null,"charTypeName":"end"}]},{"number":32,"arabic":"وَإِذَا غَشِيَهُم مَّوْجٌۭ كَٱلظُّلَلِ دَعَوُا۟ ٱللَّهَ مُخْلِصِينَ لَهُ ٱلدِّينَ فَلَمَّا نَجَّىٰهُمْ إِلَى ٱلْبَرِّ فَمِنْهُم مُّقْتَصِدٌۭ ۚ وَمَا يَجْحَدُ بِـَٔايَٰتِنَآ إِلَّا كُلُّ خَتَّارٍۢ كَفُورٍۢ","translation":"For [thus it is with most men:] when the waves engulf them like shadows [of death], they call unto God, sincere [at that moment] in their faith in Him alone: but as soon as He has brought them safe ashore, some of them stop half-way [between belief and unbelief] Yet none could knowingly reject Our messages unless he be utterly perfidious, ingrate.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3501.mp3","surahId":31,"words":[{"id":34957,"position":1,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/031_032_001.mp3","charTypeName":"word"},{"id":34958,"position":2,"arabic":"غَشِيَهُم","translation":"ঢেকে ফেলে তাদের","audioUrl":"wbw/031_032_002.mp3","charTypeName":"word"},{"id":34959,"position":3,"arabic":"مَّوْجٌۭ","translation":"ঢেউ","audioUrl":"wbw/031_032_003.mp3","charTypeName":"word"},{"id":34960,"position":4,"arabic":"كَٱلظُّلَلِ","translation":"মতো চাঁদোয়ার","audioUrl":"wbw/031_032_004.mp3","charTypeName":"word"},{"id":34961,"position":5,"arabic":"دَعَوُا۟","translation":"তারা ডাকে","audioUrl":"wbw/031_032_005.mp3","charTypeName":"word"},{"id":34962,"position":6,"arabic":"ٱللَّهَ","translation":"আল্লাহকে","audioUrl":"wbw/031_032_006.mp3","charTypeName":"word"},{"id":34963,"position":7,"arabic":"مُخْلِصِينَ","translation":"বিশুদ্ধ করে","audioUrl":"wbw/031_032_007.mp3","charTypeName":"word"},{"id":34964,"position":8,"arabic":"لَهُ","translation":"জন্যে তাঁর","audioUrl":"wbw/031_032_008.mp3","charTypeName":"word"},{"id":34965,"position":9,"arabic":"ٱلدِّينَ","translation":"আনুগত্যকে","audioUrl":"wbw/031_032_009.mp3","charTypeName":"word"},{"id":34966,"position":10,"arabic":"فَلَمَّا","translation":"অতঃপর যখন","audioUrl":"wbw/031_032_010.mp3","charTypeName":"word"},{"id":34967,"position":11,"arabic":"نَجَّىٰهُمْ","translation":"তিনিই উদ্ধার করেন তাদেরকে","audioUrl":"wbw/031_032_011.mp3","charTypeName":"word"},{"id":34968,"position":12,"arabic":"إِلَى","translation":"দিকে","audioUrl":"wbw/031_032_012.mp3","charTypeName":"word"},{"id":34969,"position":13,"arabic":"ٱلْبَرِّ","translation":"স্থলের","audioUrl":"wbw/031_032_013.mp3","charTypeName":"word"},{"id":34970,"position":14,"arabic":"فَمِنْهُم","translation":"তখন মধ্যে তাদের (কেউ কেউ)","audioUrl":"wbw/031_032_014.mp3","charTypeName":"word"},{"id":34971,"position":15,"arabic":"مُّقْتَصِدٌۭ ۚ","translation":"মধ্যম নীতি গ্রহন করে","audioUrl":"wbw/031_032_015.mp3","charTypeName":"word"},{"id":34973,"position":16,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/031_032_017.mp3","charTypeName":"word"},{"id":34974,"position":17,"arabic":"يَجْحَدُ","translation":"অস্বীকার করে (আর কেউ)","audioUrl":"wbw/031_032_018.mp3","charTypeName":"word"},{"id":34975,"position":18,"arabic":"بِـَٔايَـٰتِنَآ","translation":"প্রতি আমাদের নিদর্শনগুলোর","audioUrl":"wbw/031_032_019.mp3","charTypeName":"word"},{"id":34976,"position":19,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/031_032_020.mp3","charTypeName":"word"},{"id":34977,"position":20,"arabic":"كُلُّ","translation":"প্রত্যেক","audioUrl":"wbw/031_032_021.mp3","charTypeName":"word"},{"id":34978,"position":21,"arabic":"خَتَّارٍۢ","translation":"বিশ্বাসঘাতক","audioUrl":"wbw/031_032_022.mp3","charTypeName":"word"},{"id":34979,"position":22,"arabic":"كَفُورٍۢ","translation":"অকৃতজ্ঞ","audioUrl":"wbw/031_032_023.mp3","charTypeName":"word"},{"id":34980,"position":23,"arabic":"٣٢","translation":"(৩২)","audioUrl":null,"charTypeName":"end"}]},{"number":33,"arabic":"يَٰٓأَيُّهَا ٱلنَّاسُ ٱتَّقُوا۟ رَبَّكُمْ وَٱخْشَوْا۟ يَوْمًۭا لَّا يَجْزِى وَالِدٌ عَن وَلَدِهِۦ وَلَا مَوْلُودٌ هُوَ جَازٍ عَن وَالِدِهِۦ شَيْـًٔا ۚ إِنَّ وَعْدَ ٱللَّهِ حَقٌّۭ ۖ فَلَا تَغُرَّنَّكُمُ ٱلْحَيَوٰةُ ٱلدُّنْيَا وَلَا يَغُرَّنَّكُم بِٱللَّهِ ٱلْغَرُورُ","translation":"O MEN! Be conscious of your Sustainer, and stand in awe of the Day on which no parent will be of any avail to his child, nor a child will in the least avail his parent! Verily, God’s promise [of resurrection] is true in­deed: let not, then, the life of this world deludes you, and let not [your own] deceptive thoughts about God delude you!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3502.mp3","surahId":31,"words":[{"id":35728,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/031_033_001.mp3","c