09_001.mp3","charTypeName":"word"},{"id":10793,"position":2,"arabic":"أَفْلَحَ","translation":"সফল হলো","audioUrl":"wbw/091_009_002.mp3","charTypeName":"word"},{"id":10794,"position":3,"arabic":"مَن","translation":"যে","audioUrl":"wbw/091_009_003.mp3","charTypeName":"word"},{"id":10795,"position":4,"arabic":"زَكَّىٰهَا","translation":"তাকে পবিত্র করলো","audioUrl":"wbw/091_009_004.mp3","charTypeName":"word"},{"id":10796,"position":5,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"وَقَدْ خَابَ مَن دَسَّىٰهَا","translation":"and truly lost is he who buries it [in darkness].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6053.mp3","surahId":91,"words":[{"id":12039,"position":1,"arabic":"وَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/091_010_001.mp3","charTypeName":"word"},{"id":12040,"position":2,"arabic":"خَابَ","translation":"ব্যর্থ হলো","audioUrl":"wbw/091_010_002.mp3","charTypeName":"word"},{"id":12041,"position":3,"arabic":"مَن","translation":"যে","audioUrl":"wbw/091_010_003.mp3","charTypeName":"word"},{"id":12042,"position":4,"arabic":"دَسَّىٰهَا","translation":"তাকে কলুষিত করলো","audioUrl":"wbw/091_010_004.mp3","charTypeName":"word"},{"id":12043,"position":5,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"كَذَّبَتْ ثَمُودُ بِطَغْوَىٰهَآ","translation":"TO [THIS] TRUTH gave the lie, in their overweening arrogance, [the tribe of] Thamud,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6054.mp3","surahId":91,"words":[{"id":13328,"position":1,"arabic":"كَذَّبَتْ","translation":"মিথ্যারোপ করেছিল","audioUrl":"wbw/091_011_001.mp3","charTypeName":"word"},{"id":13329,"position":2,"arabic":"ثَمُودُ","translation":"সামূদ জাতি","audioUrl":"wbw/091_011_002.mp3","charTypeName":"word"},{"id":13330,"position":3,"arabic":"بِطَغْوَىٰهَآ","translation":"তার অবাধ্যতাবশতঃ","audioUrl":"wbw/091_011_003.mp3","charTypeName":"word"},{"id":13331,"position":4,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]},{"number":12,"arabic":"إِذِ ٱنۢبَعَثَ أَشْقَىٰهَا","translation":"when that most hapless wretch from among them rushed forward [to commit his evil deed],","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6055.mp3","surahId":91,"words":[{"id":14556,"position":1,"arabic":"إِذِ","translation":"যখন","audioUrl":"wbw/091_012_001.mp3","charTypeName":"word"},{"id":14557,"position":2,"arabic":"ٱنۢبَعَثَ","translation":"(তৎপর হয়ে)উঠলো","audioUrl":"wbw/091_012_002.mp3","charTypeName":"word"},{"id":14558,"position":3,"arabic":"أَشْقَىٰهَا","translation":"তার সবচেয়ে হতভাগা ব্যক্তি","audioUrl":"wbw/091_012_003.mp3","charTypeName":"word"},{"id":14559,"position":4,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]},{"number":13,"arabic":"فَقَالَ لَهُمْ رَسُولُ ٱللَّهِ نَاقَةَ ٱللَّهِ وَسُقْيَٰهَا","translation":"although God's apostle had told them, \"It is a she-camel belonging to God, so let her drink [and do her no harm]!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6056.mp3","surahId":91,"words":[{"id":15451,"position":1,"arabic":"فَقَالَ","translation":"অতঃপর বললো","audioUrl":"wbw/091_013_001.mp3","charTypeName":"word"},{"id":15452,"position":2,"arabic":"لَهُمْ","translation":"তাদেরকে","audioUrl":"wbw/091_013_002.mp3","charTypeName":"word"},{"id":15453,"position":3,"arabic":"رَسُولُ","translation":"রাসূল","audioUrl":"wbw/091_013_003.mp3","charTypeName":"word"},{"id":15454,"position":4,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/091_013_004.mp3","charTypeName":"word"},{"id":15455,"position":5,"arabic":"نَاقَةَ","translation":"\"(সাবধান)উষ্ট্রীকে","audioUrl":"wbw/091_013_005.mp3","charTypeName":"word"},{"id":15456,"position":6,"arabic":"ٱللَّهِ","translation":"আল্লাহর (স্পর্শ করো না)","audioUrl":"wbw/091_013_006.mp3","charTypeName":"word"},{"id":15457,"position":7,"arabic":"وَسُقْيَـٰهَا","translation":"ও তার পানি পান করায