{"id":91,"nameArabic":"سُورَةُ الشَّمۡسِ","nameEnglish":"Ash-Shams","nameTranslation":"The Sun","revelationType":"Meccan","numberOfAyahs":15,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلشَّمْسِ وَضُحَىٰهَا","translation":"CONSIDER the sun and its radiant brightness,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6044.mp3","surahId":91,"words":[{"id":793,"position":1,"arabic":"وَٱلشَّمْسِ","translation":"শপথ সূর্যের","audioUrl":"wbw/091_001_001.mp3","charTypeName":"word"},{"id":794,"position":2,"arabic":"وَضُحَىٰهَا","translation":"এবং তার কিরণের","audioUrl":"wbw/091_001_002.mp3","charTypeName":"word"},{"id":795,"position":3,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"وَٱلْقَمَرِ إِذَا تَلَىٰهَا","translation":"and the moon as it reflects the sun!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6045.mp3","surahId":91,"words":[{"id":1781,"position":1,"arabic":"وَٱلْقَمَرِ","translation":"শপথ চাঁদের","audioUrl":"wbw/091_002_001.mp3","charTypeName":"word"},{"id":1782,"position":2,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/091_002_002.mp3","charTypeName":"word"},{"id":1783,"position":3,"arabic":"تَلَىٰهَا","translation":"তার পিছে আসে","audioUrl":"wbw/091_002_003.mp3","charTypeName":"word"},{"id":1784,"position":4,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"وَٱلنَّهَارِ إِذَا جَلَّىٰهَا","translation":"Consider the day as it reveals the world,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6046.mp3","surahId":91,"words":[{"id":2093,"position":1,"arabic":"وَٱلنَّهَارِ","translation":"শপথ দিনের","audioUrl":"wbw/091_003_001.mp3","charTypeName":"word"},{"id":2094,"position":2,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/091_003_002.mp3","charTypeName":"word"},{"id":2095,"position":3,"arabic":"جَلَّىٰهَا","translation":"তাকে প্রকাশ করে","audioUrl":"wbw/091_003_003.mp3","charType