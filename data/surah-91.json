,"position":2,"arabic":"يَخَافُ","translation":"ভয় করেন তিনি","audioUrl":"wbw/091_015_002.mp3","charTypeName":"word"},{"id":16870,"position":3,"arabic":"عُقْبَـٰهَا","translation":"তাঁর (কাজের) পরিণতির","audioUrl":"wbw/091_015_003.mp3","charTypeName":"word"},{"id":16871,"position":4,"arabic":"١٥","translation":"(১৫)","audioUrl":null,"charTypeName":"end"}]}]}