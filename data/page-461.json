{"id":461,"ayahs":[{"number":22,"arabic":"أَفَمَن شَرَحَ ٱللَّهُ صَدْرَهُۥ لِلْإِسْلَٰمِ فَهُوَ عَلَىٰ نُورٍۢ مِّن رَّبِّهِۦ ۚ فَوَيْلٌۭ لِّلْقَٰسِيَةِ قُلُوبُهُم مِّن ذِكْرِ ٱللَّهِ ۚ أُو۟لَٰٓئِكَ فِى ضَلَٰلٍۢ مُّبِينٍ","translation":"Could, then, one whose bosom God has opened wide with willingness towards self-surrender unto Him, so that he is illumined by a light [that flows] from his Sustainer, [be likened to the blind and deaf of heart]? Woe, then, unto those whose hearts are hardened against all remembrance of God! They are most obviously lost in error!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4080.mp3","surahId":39,"words":[{"id":24376,"position":1,"arabic":"أَفَمَن","translation":"তবে কি যার","audioUrl":"wbw/039_022_001.mp3","charTypeName":"word"},{"id":24377,"position":2,"arabic":"شَرَحَ","translation":"খুলে দিয়েছেন","audioUrl":"wbw/039_022_002.mp3","charTypeName":"word"},{"id":24378,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/039_022_003.mp3","charTypeName":"word"},{"id":24379,"position":4,"arabic":"صَدْرَهُۥ","translation":"তার হৃদয়কে","audioUrl":"wbw/039_022_004.mp3","charTypeName":"word"},{"id":24380,"position":5,"arabic":"لِلْإِسْلَـٰمِ","translation":"ইসলামের জন্যে","audioUrl":"wbw/039_022_005.mp3","charTypeName":"word"},{"id":24381,"position":6,"arabic":"فَهُوَ","translation":"অতঃপর সে","audioUrl":"wbw/039_022_006.mp3","charTypeName":"word"},{"id":24382,"position":7,"arabic":"عَلَىٰ","translation":"(চলে)উপর","audioUrl":"wbw/039_022_007.mp3","charTypeName":"word"},{"id":24383,"position":8,"arabic":"نُورٍۢ","translation":"আলোর","audioUrl":"wbw/039_022_008.mp3","charTypeName":"word"},{"id":24384,"position":9,"arabic":"مِّن","translation":"পক্ষ হ'তে","audioUrl":"wbw/039_022_009.mp3","charTypeName":"word"},{"id":24385,"position":10,"arabic":"رَّبِّهِۦ ۚ","translation":"তার রবের (সে অন্যদের মতো কি?)","audioUrl":"wbw/039_022_010.mp3","charTypeName":"word"},{"id":24387,"position":11,"arabic":"فَوَيْلٌۭ","translation":"সুতরাং দুর্ভোগ","audioUrl":"wbw/039_022_012.mp3","charTypeName":"word"},{"id":24388,"position":12,"arabic":"لِّلْقَـٰسِيَةِ","translation":"(সেই লোকদের) জন্যে পাষাণের","audioUrl":"wbw/039_022_013.mp3","charTypeName":"word"},{"id":24389,"position":13,"arabic":"قُلُوبُهُم","translation":"যাদের অন্তরসমূহ","audioUrl":"wbw/039_022_014.mp3","charTypeName":"word"},{"id":24390,"position":14,"arabic":"مِّن","translation":"হ'তে","audioUrl":"wbw/039_022_015.mp3","charTypeName":"word"},{"id":24391,"position":15,"arabic":"ذِكْرِ","translation":"স্মরণ","audioUrl":"wbw/039_022_016.mp3","charTypeName":"word"},{"id":24392,"position":16,"arabic":"ٱللَّهِ ۚ","translation":"আল্লাহর","audioUrl":"wbw/039_022_017.mp3","charTypeName":"word"},{"id":24394,"position":17,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐসব লোক","audioUrl":"wbw/039_022_019.mp3","charTypeName":"word"},{"id":24395,"position":18,"arabic":"فِى","translation":"মধ্যে (রয়েছে)","audioUrl":"wbw/039_022_020.mp3","charTypeName":"word"},{"id":24396,"position":19,"arabic":"ضَلَـٰلٍۢ","translation":"বিভ্রান্তির","audioUrl":"wbw/039_022_021.mp3","charTypeName":"word"},{"id":24397,"position":20,"arabic":"مُّبِينٍ","translation":"সুস্পষ্ট","audioUrl":"wbw/039_022_022.mp3","charTypeName":"word"},{"id":24398,"position":21,"arabic":"٢٢","translation":"(২২)","audioUrl":null,"charTypeName":"end"}]},{"number":23,"arabic":"ٱللَّهُ نَزَّلَ أَحْسَنَ ٱلْحَدِيثِ كِتَٰبًۭا مُّتَشَٰبِهًۭا مَّثَانِىَ تَقْشَعِرُّ مِنْهُ جُلُودُ ٱلَّذِينَ يَخْشَوْنَ رَبَّهُمْ ثُمَّ تَلِينُ جُلُودُهُمْ وَقُلُوبُهُمْ إِلَىٰ ذِكْرِ ٱللَّهِ ۚ ذَٰلِكَ هُدَى ٱللَّهِ يَهْدِى بِهِۦ مَن يَشَآءُ ۚ وَمَن يُضْلِلِ ٱللَّهُ فَمَا لَهُۥ مِنْ هَادٍ","translation":"God bestows from on high the best of all teachings in the shape of a divine writ fully consistent within itself, repeating each statement [of the truth] in manifold forms [a divine writ] whereat shiver the skins of all who of their Sustainer stand in awe: [but] in the end their skins and their hearts do soften at the remembrance of [the grace of] God. Such is God’s guidance: He guides therewith him that wills [to be guided] whereas he whom God lets go astray can never find any guide","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4081.mp3","surahId":39,"words":[{"id":25434,"position":1,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/039_023_001.mp3","charTypeName":"word"},{"id":25435,"position":2,"arabic":"نَزَّلَ","translation":"অবতীর্ণ করেছেন","audioUrl":"wbw/039_023_002.mp3","charTypeName":"word"},{"id":25436,"position":3,"arabic":"أَحْسَنَ","translation":"উত্তম","audioUrl":"wbw/039_023_003.mp3","charTypeName":"word"},{"id":25437,"position":4,"arabic":"ٱلْحَدِيثِ","translation":"বাণী (সম্বলিত)","audioUrl":"wbw/039_023_004.mp3","charTypeName":"word"},{"id":25438,"position":5,"arabic":"كِتَـٰبًۭا","translation":"কিতাব","audioUrl":"wbw/039_023_005.mp3","charTypeName":"word"},{"id":25439,"position":6,"arabic":"مُّتَشَـٰبِهًۭا","translation":"সুসামঞ্জস্যপূর্ণ","audioUrl":"wbw/039_023_006.mp3","charTypeName":"word"},{"id":25440,"position":7,"arabic":"مَّثَانِىَ","translation":"পুনরাবৃত্ত","audioUrl":"wbw/039_023_007.mp3","charTypeName":"word"},{"id":25441,"position":8,"arabic":"تَقْشَعِرُّ","translation":"রোমাঞ্চিত হয়","audioUrl":"wbw/039_023_008.mp3","charTypeName":"word"},{"id":25442,"position":9,"arabic":"مِنْهُ","translation":"তা থেকে","audioUrl":"wbw/039_023_009.mp3","charTypeName":"word"},{"id":25443,"position":10,"arabic":"جُلُودُ","translation":"দেহ","audioUrl":"wbw/039_023_010.mp3","charTypeName":"word"},{"id":25444,"position":11,"arabic":"ٱلَّذِينَ","translation":"(তাদের) যারা","audioUrl":"wbw/039_023_011.mp3","charTypeName":"word"},{"id":25445,"position":12,"arabic":"يَخْشَوْنَ","translation":"ভয় করে","audioUrl":"wbw/039_023_012.mp3","charTypeName":"word"},{"id":25446,"position":13,"arabic":"رَبَّهُمْ","translation":"তাদের রবকে","audioUrl":"wbw/039_023_013.mp3","charTypeName":"word"},{"id":25447,"position":14,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/039_023_014.mp3","charTypeName":"word"},{"id":25448,"position":15,"arabic":"تَلِينُ","translation":"নরম হয়","audioUrl":"wbw/039_023_015.mp3","charTypeName":"word"},{"id":25449,"position":16,"arabic":"جُلُودُهُمْ","translation":"তাদের দেহ (সারা দেহ)","audioUrl":"wbw/039_023_016.mp3","charTypeName":"word"},{"id":25450,"position":17,"arabic":"وَقُلُوبُهُمْ","translation":"ও তাদের মনগুলো","audioUrl":"wbw/039_023_017.mp3","charTypeName":"word"},{"id":25451,"position":18,"arabic":"إِلَىٰ","translation":"প্রতি","audioUrl":"wbw/039_023_018.mp3","charTypeName":"word"},{"id":25452,"position":19,"arabic":"ذِكْرِ","translation":"স্মরণের","audioUrl":"wbw/039_023_019.mp3","charTypeName":"word"},{"id":25453,"position":20,"arabic":"ٱللَّهِ ۚ","translation":"আল্লাহর","audioUrl":"wbw/039_023_020.mp3","charTypeName":"word"},{"id":25455,"position":21,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/039_023_022.mp3","charTypeName":"word"},{"id":25456,"position":22,"arabic":"هُدَى","translation":"পথনির্দেশ","audioUrl":"wbw/039_023_023.mp3","charTypeName":"word"},{"id":25457,"position":23,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/039_023_024.mp3","charTypeName":"word"},{"id":25458,"position":24,"arabic":"يَهْدِى","translation":"সৎপথে চালান তিনি","audioUrl":"wbw/039_023_025.mp3","charTypeName":"word"},{"id":25459,"position":25,"arabic":"بِهِۦ","translation":"এ দিয়ে","audioUrl":"wbw/039_023_026.mp3","charTypeName":"word"},{"id":25460,"position":26,"arabic":"مَن","translation":"যাকে","audioUrl":"wbw/039_023_027.mp3","charTypeName":"word"},{"id":25461,"position":27,"arabic":"يَشَآءُ ۚ","translation":"তিনি চান","audioUrl":"wbw/039_023_028.mp3","charTypeName":"word"},{"id":25463,"position":28,"arabic":"وَمَن","translation":"এবং যাকে","audioUrl":"wbw/039_023_030.mp3","charTypeName":"word"},{"id":25464,"position":29,"arabic":"يُضْلِلِ","translation":"বিভ্রান্ত করেন","audioUrl":"wbw/039_023_031.mp3","charTypeName":"word"},{"id":25465,"position":30,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/039_023_032.mp3","charTypeName":"word"},{"id":25466,"position":31,"arabic":"فَمَا","translation":"তখন নেই","audioUrl":"wbw/039_023_033.mp3","charTypeName":"word"},{"id":25467,"position":32,"arabic":"لَهُۥ","translation":"তার","audioUrl":"wbw/039_023_034.mp3","charTypeName":"word"},{"id":25468,"position":33,"arabic":"مِنْ","translation":"কোনো","audioUrl":"wbw/039_023_035.mp3","charTypeName":"word"},{"id":25469,"position":34,"arabic":"هَادٍ","translation":"পথ প্রদর্শক","audioUrl":"wbw/039_023_036.mp3","charTypeName":"word"},{"id":25470,"position":35,"arabic":"٢٣","translation":"(২৩)","audioUrl":null,"charTypeName":"end"}]},{"number":24,"arabic":"أَفَمَن يَتَّقِى بِوَجْهِهِۦ سُوٓءَ ٱلْعَذَابِ يَوْمَ ٱلْقِيَٰمَةِ ۚ وَقِيلَ لِلظَّٰلِمِينَ ذُوقُوا۟ مَا كُنتُمْ تَكْسِبُونَ","translation":"Could, then, one who shall have nothing but is [bare] face to protect him from the awful suffering [that will befall him] on Resurrection Day [be likened to the God-conscious]? [On that Day,] the evildoers will be told: “Taste [now] what you have earned [in life]!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4082.mp3","surahId":39,"words":[{"id":26481,"position":1,"arabic":"أَفَمَن","translation":"তবে কি যে","audioUrl":"wbw/039_024_001.mp3","charTypeName":"word"},{"id":26482,"position":2,"arabic":"يَتَّقِى","translation":"ঠেকাতে চাইবে","audioUrl":"wbw/039_024_002.mp3","charTypeName":"word"},{"id":26483,"position":3,"arabic":"بِوَجْهِهِۦ","translation":"তার চেহারা দিয়ে","audioUrl":"wbw/039_024_003.mp3","charTypeName":"word"},{"id":26484,"position":4,"arabic":"سُوٓءَ","translation":"কঠিন","audioUrl":"wbw/039_024_004.mp3","charTypeName":"word"},{"id":26485,"position":5,"arabic":"ٱلْعَذَابِ","translation":"শাস্তিকে","audioUrl":"wbw/039_024_005.mp3","charTypeName":"word"},{"id":26486,"position":6,"arabic":"يَوْمَ","translation":"দিনে","audioUrl":"wbw/039_024_006.mp3","charTypeName":"word"},{"id":26487,"position":7,"arabic":"ٱلْقِيَـٰمَةِ ۚ","translation":"ক্বিয়ামাতের (বাঁচতে পারবে?)","audioUrl":"wbw/039_024_007.mp3","charTypeName":"word"},{"id":26489,"position":8,"arabic":"وَقِيلَ","translation":"এবং বলা হবে","audioUrl":"wbw/039_024_009.mp3","charTypeName":"word"},{"id":26490,"position":9,"arabic":"لِلظَّـٰلِمِينَ","translation":"সীমালঙ্ঘনকারীদেরকে","audioUrl":"wbw/039_024_010.mp3","charTypeName":"word"},{"id":26491,"position":10,"arabic":"ذُوقُوا۟","translation":"\"তোমরা স্বাদ নাও","audioUrl":"wbw/039_024_011.mp3","charTypeName":"word"},{"id":26492,"position":11,"arabic":"مَا","translation":"যা","audioUrl":"wbw/039_024_012.mp3","charTypeName":"word"},{"id":26493,"position":12,"arabic":"كُنتُمْ","translation":"তোমরা","audioUrl":"wbw/039_024_013.mp3","charTypeName":"word"},{"id":26494,"position":13,"arabic":"تَكْسِبُونَ","translation":"অর্জন করেছিলে\"","audioUrl":"wbw/039_024_014.mp3","charTypeName":"word"},{"id":26495,"position":14,"arabic":"٢٤","translation":"(২৪)","audioUrl":null,"charTypeName":"end"}]},{"number":25,"arabic":"كَذَّبَ ٱلَّذِينَ مِن قَبْلِهِمْ فَأَتَىٰهُمُ ٱلْعَذَابُ مِنْ حَيْثُ لَا يَشْعُرُونَ","translation":"Those who lived before them did [too] give the lie to the truth - whereupon suffering befell them without their having perceived whence it came:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4083.mp3","surahId":39,"words":[{"id":27499,"position":1,"arabic":"كَذَّبَ","translation":"মিথ্যারোপ করেছিলো","audioUrl":"wbw/039_025_001.mp3","charTypeName":"word"},{"id":27500,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা (ছিলো)","audioUrl":"wbw/039_025_002.mp3","charTypeName":"word"},{"id":27501,"position":3,"arabic":"مِن","translation":"পূর্বেও","audioUrl":"wbw/039_025_003.mp3","charTypeName":"word"},{"id":27502,"position":4,"arabic":"قَبْلِهِمْ","translation":"তাদের","audioUrl":"wbw/039_025_004.mp3","charTypeName":"word"},{"id":27503,"position":5,"arabic":"فَأَتَىٰهُمُ","translation":"তাদের উপর অতঃপর এসেছিলো","audioUrl":"wbw/039_025_005.mp3","charTypeName":"word"},{"id":27504,"position":6,"arabic":"ٱلْعَذَابُ","translation":"শাস্তি","audioUrl":"wbw/039_025_006.mp3","charTypeName":"word"},{"id":27505,"position":7,"arabic":"مِنْ","translation":"(এমনদিক) হ'তে","audioUrl":"wbw/039_025_007.mp3","charTypeName":"word"},{"id":27506,"position":8,"arabic":"حَيْثُ","translation":"যেদিকে","audioUrl":"wbw/039_025_008.mp3","charTypeName":"word"},{"id":27507,"position":9,"arabic":"لَا","translation":"না","audioUrl":"wbw/039_025_009.mp3","charTypeName":"word"},{"id":27508,"position":10,"arabic":"يَشْعُرُونَ","translation":"তারা কল্পনাও করে","audioUrl":"wbw/039_025_010.mp3","charTypeName":"word"},{"id":27509,"position":11,"arabic":"٢٥","translation":"(২৫)","audioUrl":null,"charTypeName":"end"}]},{"number":26,"arabic":"فَأَذَاقَهُمُ ٱللَّهُ ٱلْخِزْىَ فِى ٱلْحَيَوٰةِ ٱلدُّنْيَا ۖ وَلَعَذَابُ ٱلْءَاخِرَةِ أَكْبَرُ ۚ لَوْ كَانُوا۟ يَعْلَمُونَ","translation":"and thus God let them taste ignominy [even] in the life of this world. Yet [how] much greater will be the [sinners’] suffering in the life to come - if they [who now deny the truth] but knew it!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4084.mp3","surahId":39,"words":[{"id":28520,"position":1,"arabic":"فَأَذَاقَهُمُ","translation":"তাদেরকে ফলে আস্বাদন করালেন","audioUrl":"wbw/039_026_001.mp3","charTypeName":"word"},{"id":28521,"position":2,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/039_026_002.mp3","charTypeName":"word"},{"id":28522,"position":3,"arabic":"ٱلْخِزْىَ","translation":"অপমানের","audioUrl":"wbw/039_026_003.mp3","charTypeName":"word"},{"id":28523,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/039_026_004.mp3","charTypeName":"word"},{"id":28524,"position":5,"arabic":"ٱلْحَيَوٰةِ","translation":"জীবনের","audioUrl":"wbw/039_026_005.mp3","charTypeName":"word"},{"id":28525,"position":6,"arabic":"ٱلدُّنْيَا ۖ","translation":"পার্থিব","audioUrl":"wbw/039_026_006.mp3","charTypeName":"word"},{"id":28527,"position":7,"arabic":"وَلَعَذَابُ","translation":"আর শাস্তি অবশ্যই","audioUrl":"wbw/039_026_008.mp3","charTypeName":"word"},{"id":28528,"position":8,"arabic":"ٱلْـَٔاخِرَةِ","translation":"আখিরাতের","audioUrl":"wbw/039_026_009.mp3","charTypeName":"word"},{"id":28529,"position":9,"arabic":"أَكْبَرُ ۚ","translation":"কঠিন","audioUrl":"wbw/039_026_010.mp3","charTypeName":"word"},{"id":28531,"position":10,"arabic":"لَوْ","translation":"(হায়) যদি","audioUrl":"wbw/039_026_012.mp3","charTypeName":"word"},{"id":28532,"position":11,"arabic":"كَانُوا۟","translation":"তারা","audioUrl":"wbw/039_026_013.mp3","charTypeName":"word"},{"id":28533,"position":12,"arabic":"يَعْلَمُونَ","translation":"জানতো","audioUrl":"wbw/039_026_014.mp3","charTypeName":"word"},{"id":28534,"position":13,"arabic":"٢٦","translation":"(২৬)","audioUrl":null,"charTypeName":"end"}]},{"number":27,"arabic":"وَلَقَدْ ضَرَبْنَا لِلنَّاسِ فِى هَٰذَا ٱلْقُرْءَانِ مِن كُلِّ مَثَلٍۢ لَّعَلَّهُمْ يَتَذَكَّرُونَ","translation":"THUS, INDEED, have We propounded unto men all kinds of parables in this Qur’an, so that they might bethink themselves; [and We have revealed it]","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4085.mp3","surahId":39,"words":[{"id":29471,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/039_027_001.mp3","charTypeName":"word"},{"id":29472,"position":2,"arabic":"ضَرَبْنَا","translation":"আমরা পেশ করেছি","audioUrl":"wbw/039_027_002.mp3","charTypeName":"word"},{"id":29473,"position":3,"arabic":"لِلنَّاسِ","translation":"লোকদের জন্যে","audioUrl":"wbw/039_027_003.mp3","charTypeName":"word"},{"id":29474,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/039_027_004.mp3","charTypeName":"word"},{"id":29475,"position":5,"arabic":"هَـٰذَا","translation":"এই","audioUrl":"wbw/039_027_005.mp3","charTypeName":"word"},{"id":29476,"position":6,"arabic":"ٱلْقُرْءَانِ","translation":"কোরআনের","audioUrl":"wbw/039_027_006.mp3","charTypeName":"word"},{