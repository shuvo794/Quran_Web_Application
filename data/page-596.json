শপথ প্রথম প্রহরের","audioUrl":"wbw/093_001_001.mp3","charTypeName":"word"},{"id":71,"position":2,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"وَٱلَّيْلِ إِذَا سَجَىٰ","translation":"and the night when it grows still and dark.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6081.mp3","surahId":93,"words":[{"id":1191,"position":1,"arabic":"وَٱلَّيْلِ","translation":"শপথ রাতের","audioUrl":"wbw/093_002_001.mp3","charTypeName":"word"},{"id":1192,"position":2,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/093_002_002.mp3","charTypeName":"word"},{"id":1193,"position":3,"arabic":"سَجَىٰ","translation":"নিঝুম হয়","audioUrl":"wbw/093_002_003.mp3","charTypeName":"word"},{"id":1194,"position":4,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"مَا وَدَّعَكَ رَبُّكَ وَمَا قَلَىٰ","translation":"Thy Sustainer has not forsaken thee, nor does He scorn thee:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6082.mp3","surahId":93,"words":[{"id":2251,"position":1,"arabic":"مَا","translation":"না","audioUrl":"wbw/093_003_001.mp3","charTypeName":"word"},{"id":2252,"position":2,"arabic":"وَدَّعَكَ","translation":"তোমাকে ত্যাগ করেছেন","audioUrl":"wbw/093_003_002.mp3","charTypeName":"word"},{"id":2253,"position":3,"arabic":"رَبُّكَ","translation":"তোমার রব","audioUrl":"wbw/093_003_003.mp3","charTypeName":"word"},{"id":2254,"position":4,"arabic":"وَمَا","translation":"আর না","audioUrl":"wbw/093_003_004.mp3","charTypeName":"word"},{"id":2255,"position":5,"arabic":"قَلَىٰ","translation":"অসন্তুষ্ট হয়েছেন","audioUrl":"wbw/093_003_005.mp3","charTypeName":"word"},{"id":2256,"position":6,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"وَلَلْءَاخِرَةُ خَيْرٌۭ لَّكَ مِنَ ٱلْأُولَىٰ","translation":"for, indeed, the life to come will be better for thee than this earlier part [of thy life]!","audio":"https://cdn.islamic.ne