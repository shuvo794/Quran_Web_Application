{"id":197,"ayahs":[{"number":62,"arabic":"يَحْلِفُونَ بِٱللَّهِ لَكُمْ لِيُرْضُوكُمْ وَٱللَّهُ وَرَسُولُهُۥٓ أَحَقُّ أَن يُرْضُوهُ إِن كَانُوا۟ مُؤْمِنِينَ","translation":"[The hypocrites] swear to you by God [that they are acting in good faith], with a view to pleasing you [O believers] - the while it is God and His Apostle whose pleasure they should seek above all else, if indeed they are believers!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1297.mp3","surahId":9,"words":[{"id":55889,"position":1,"arabic":"يَحْلِفُونَ","translation":"তারা শপথ করে","audioUrl":"wbw/009_062_001.mp3","charTypeName":"word"},{"id":55890,"position":2,"arabic":"بِٱللَّهِ","translation":"নামে আল্লাহর","audioUrl":"wbw/009_062_002.mp3","charTypeName":"word"},{"id":55891,"position":3,"arabic":"لَكُمْ","translation":"জন্যে তোমাদের","audioUrl":"wbw/009_062_003.mp3","charTypeName":"word"},{"id":55892,"position":4,"arabic":"لِيُرْضُوكُمْ","translation":"যেন খুশি করতে পারে তোমাদেরকে","audioUrl":"wbw/009_062_004.mp3","charTypeName":"word"},{"id":55893,"position":5,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/009_062_005.mp3","charTypeName":"word"},{"id":55894,"position":6,"arabic":"وَرَسُولُهُۥٓ","translation":"ও রাসূল তাঁর","audioUrl":"wbw/009_062_006.mp3","charTypeName":"word"},{"id":55895,"position":7,"arabic":"أَحَقُّ","translation":"অধিকযোগ্য","audioUrl":"wbw/009_062_007.mp3","charTypeName":"word"},{"id":55896,"position":8,"arabic":"أَن","translation":"যে","audioUrl":"wbw/009_062_008.mp3","charTypeName":"word"},{"id":55897,"position":9,"arabic":"يُرْضُوهُ","translation":"তাকে সন্তুষ্ট করবে তারা","audioUrl":"wbw/009_062_009.mp3","charTypeName":"word"},{"id":55898,"position":10,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/009_062_010.mp3","charTypeName":"word"},{"id":55899,"position":11,"arabic":"كَانُوا۟","translation":"তারা হয়","audioUrl":"wbw/009_062_011.mp3","charTypeName":"word"},{"id":55900,"position":12,"arabic":"مُؤْمِنِينَ","translation":"মু'মিন","audioUrl":"wbw/009_062_012.mp3","charTypeName":"word"},{"id":55901,"position":13,"arabic":"٦٢","translation":"(৬২)","audioUrl":null,"charTypeName":"end"}]},{"number":63,"arabic":"أَلَمْ يَعْلَمُوٓا۟ أَنَّهُۥ مَن يُحَادِدِ ٱللَّهَ وَرَسُولَهُۥ فَأَنَّ لَهُۥ نَارَ جَهَنَّمَ خَٰلِدًۭا فِيهَا ۚ ذَٰلِكَ ٱلْخِزْىُ ٱلْعَظِيمُ","translation":"Do they not know that for him who sets himself against God and His Apostle there is in store the fire of hell, therein to abide -that most awesome disgrace?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1298.mp3","surahId":9,"words":[{"id":56346,"position":1,"arabic":"أَلَمْ","translation":"কি না","audioUrl":"wbw/009_063_001.mp3","charTypeName":"word"},{"id":56347,"position":2,"arabic":"يَعْلَمُوٓا۟","translation":"তারা জানে","audioUrl":"wbw/009_063_002.mp3","charTypeName":"word"},{"id":56348,"position":3,"arabic":"أَنَّهُۥ","translation":"নিশ্চিত যে","audioUrl":"wbw/009_063_003.mp3","charTypeName":"word"},{"id":56349,"position":4,"arabic":"مَن","translation":"যে ব্যক্তি","audioUrl":"wbw/009_063_004.mp3","charTypeName":"word"},{"id":56350,"position":5,"arabic":"يُحَادِدِ","translation":"বিরোধিতা করে","audioUrl":"wbw/009_063_005.mp3","charTypeName":"word"},{"id":56351,"position":6,"arabic":"ٱللَّهَ","translation":"আল্লাহর","audioUrl":"wbw/009_063_006.mp3","charTypeName":"word"},{"id":56352,"position":7,"arabic":"وَرَسُولَهُۥ","translation":"ও রাসূলের তাঁর (সাথে)","audioUrl":"wbw/009_063_007.mp3","charTypeName":"word"},{"id":56353,"position":8,"arabic":"فَأَنَّ","translation":"অতঃপর নিশ্চয়ই","audioUrl":"wbw/009_063_008.mp3","charTypeName":"word"},{"id":56354,"position":9,"arabic":"لَهُۥ","translation":"জন্যে তার(রয়েছে)","audioUrl":"wbw/009_063_009.mp3","charTypeName":"word"},{"id":56355,"position":10,"arabic":"نَارَ","translation":"আগুন","audioUrl":"wbw/009_063_010.mp3","charTypeName":"word"},{"id":56356,"position":11,"arabic":"جَهَنَّمَ","translation":"জাহান্নামের","audioUrl":"wbw/009_063_011.mp3","charTypeName":"word"},{"id":56357,"position":12,"arabic":"خَـٰلِدًۭا","translation":"সে চিরস্থায়ী হবে","audioUrl":"wbw/009_063_012.mp3","charTypeName":"word"},{"id":56358,"position":13,"arabic":"فِيهَا ۚ","translation":"মধ্যে তার","audioUrl":"wbw/009_063_013.mp3","charTypeName":"word"},{"id":56360,"position":14,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/009_063_015.mp3","charTypeName":"word"},{"id":56361,"position":15,"arabic":"ٱلْخِزْىُ","translation":"অপমান","audioUrl":"wbw/009_063_016.mp3","charTypeName":"word"},{"id":56362,"position":16,"arabic":"ٱلْعَظِيمُ","translation":"চরম","audioUrl":"wbw/009_063_017.mp3","charTypeName":"word"},{"id":56363,"position":17,"arabic":"٦٣","translation":"(৬৩)","audioUrl":null,"charTypeName":"end"}]},{"number":64,"arabic":"يَحْذَرُ ٱلْمُنَٰفِقُونَ أَن تُنَزَّلَ عَلَيْهِمْ سُورَةٌۭ تُنَبِّئُهُم بِمَا فِى قُلُوبِهِمْ ۚ قُلِ ٱسْتَهْزِءُوٓا۟ إِنَّ ٱللَّهَ مُخْرِجٌۭ مَّا تَحْذَرُونَ","translation":"[Some of] the hypocrites dread lest a [new] surah be revealed [in evidence] against them, making them understand what is [really] in their hearts. Say: \"Go on mocking! Behold, God will bring to light the very thing that you are dreading!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1299.mp3","surahId":9,"words":[{"id":56876,"position":1,"arabic":"يَحْذَرُ","translation":"ভয় করে","audioUrl":"wbw/009_064_001.mp3","charTypeName":"word"},{"id":56877,"position":2,"arabic":"ٱلْمُنَـٰفِقُونَ","translation":"মুনাফিকরা","audioUrl":"wbw/009_064_002.mp3","charTypeName":"word"},{"id":56878,"position":3,"arabic":"أَن","translation":"(যে) না","audioUrl":"wbw/009_064_003.mp3","charTypeName":"word"},{"id":56879,"position":4,"arabic":"تُنَزَّلَ","translation":"অবতীর্ণ হবে","audioUrl":"wbw/009_064_004.mp3","charTypeName":"word"},{"id":56880,"position":5,"arabic":"عَلَيْهِمْ","translation":"সম্পর্কে তাদের","audioUrl":"wbw/009_064_005.mp3","charTypeName":"word"},{"id":56881,"position":6,"arabic":"سُورَةٌۭ","translation":"কোনো সূরাহ","audioUrl":"wbw/009_064_006.mp3","charTypeName":"word"},{"id":56882,"position":7,"arabic":"تُنَبِّئُهُم","translation":"জানিয়ে দিবে তাদেরকে","audioUrl":"wbw/009_064_007.mp3","charTypeName":"word"},{"id":56883,"position":8,"arabic":"بِمَا","translation":"ঐ বিষয় যা","audioUrl":"wbw/009_064_008.mp3","charTypeName":"word"},{"id":56884,"position":9,"arabic":"فِى","translation":"মধ্যে (আছে)","audioUrl":"wbw/009_064_009.mp3","charTypeName":"word"},{"id":56885,"position":10,"arabic":"قُلُوبِهِمْ ۚ","translation":"অন্তরে তাদের","audioUrl":"wbw/009_064_010.mp3","charTypeName":"word"},{"id":56887,"position":11,"arabic":"قُلِ","translation":"বলো","audioUrl":"wbw/009_064_012.mp3","charTypeName":"word"},{"id":56888,"position":12,"arabic":"ٱسْتَهْزِءُوٓا۟","translation":"\"তোমরা ঠাট্টা করো","audioUrl":"wbw/009_064_013.mp3","charTypeName":"word"},{"id":56889,"position":13,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/009_064_014.mp3","charTypeName":"word"},{"id":56890,"position":14,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/009_064_015.mp3","charTypeName":"word"},{"id":56891,"position":15,"arabic":"مُخْرِجٌۭ","translation":"প্রকাশকারী","audioUrl":"wbw/009_064_016.mp3","charTypeName":"word"},{"id":56892,"position":16,"arabic":"مَّا","translation":"যা","audioUrl":"wbw/009_064_017.mp3","charTypeName":"word"},{"id":56893,"position":17,"arabic":"تَحْذَرُونَ","translation":"তোমরা ভয় করছো\"","audioUrl":"wbw/009_064_018.mp3","charTypeName":"word"},{"id":56894,"position":18,"arabic":"٦٤","translation":"(৬৪)","audioUrl":null,"charTypeName":"end"}]},{"number":65,"arabic":"وَلَئِن سَأَلْتَهُمْ لَيَقُولُنَّ إِنَّمَا كُنَّا نَخُوضُ وَنَلْعَبُ ۚ قُلْ أَبِٱللَّهِ وَءَايَٰتِهِۦ وَرَسُولِهِۦ كُنتُمْ تَسْتَهْزِءُونَ","translation":"Yet, indeed, if thou wert to question them. they would surely answer, \"We were only indulging in idle talk, and were playing [with words]. Say: \"Were you, then. mocking at God and His messages and His Apostle?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1300.mp3","surahId":9,"words":[{"id":56983,"position":1,"arabic":"وَلَئِن","translation":"এবং  অবশ্যই যদি","audioUrl":"wbw/009_065_001.mp3","charTypeName":"word"},{"id":56984,"position":2,"arabic":"سَأَلْتَهُمْ","translation":"তুমি প্রশ্ন করো তাদের","audioUrl":"wbw/009_065_002.mp3","charTypeName":"word"},{"id":56985,"position":3,"arabic":"لَيَقُولُنَّ","translation":"অবশ্যই তারা বলবেই","audioUrl":"wbw/009_065_003.mp3","charTypeName":"word"},{"id":56986,"position":4,"arabic":"إِنَّمَا","translation":"\"প্রকৃত পক্ষে","audioUrl":"wbw/009_065_004.mp3","charTypeName":"word"},{"id":56987,"position":5,"arabic":"كُنَّا","translation":"আমরা ছিলো","audioUrl":"wbw/009_065_005.mp3","charTypeName":"word"},{"id":56988,"position":6,"arabic":"نَخُوضُ","translation":"আলাপ-আলোচনা করতে","audioUrl":"wbw/009_065_006.mp3","charTypeName":"word"},{"id":56989,"position":7,"arabic":"وَنَلْعَبُ ۚ","translation":"ও আমরা কৌতুক করতেছিলাম\"","audioUrl":"wbw/009_065_007.mp3","charTypeName":"word"},{"id":56991,"position":8,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/009_065_009.mp3","charTypeName":"word"},{"id":56992,"position":9,"arabic":"أَبِٱللَّهِ","translation":"\"কি সাথে আল্লাহর","audioUrl":"wbw/009_065_010.mp3","charTypeName":"word"},{"id":56993,"position":10,"arabic":"وَءَايَـٰتِهِۦ","translation":"ও আয়াতের তাঁর(সাথে)","audioUrl":"wbw/009_065_011.mp3","charTypeName":"word"},{"id":56994,"position":11,"arabic":"وَرَسُولِهِۦ","translation":"ও রাসূলের তাঁর (সাথে)","audioUrl":"wbw/009_065_012.mp3","charTypeName":"word"},{"id":56995,"position":12,"arabic":"كُنتُمْ","translation":"তোমরা ছিলে","audioUrl":"wbw/009_065_013.mp3","charTypeName":"word"},{"id":56996,"position":13,"arabic":"تَسْتَهْزِءُونَ","translation":"তোমরা ঠাট্টা করতে\"","audioUrl":"wbw/009_065_014.mp3","charTypeName":"word"},{"id":56997,"position":14,"arabic":"٦٥","translation":"(৬৫)","audioUrl":null,"charTypeName":"end"}]},{"number":66,"arabic":"لَا تَعْتَذِرُوا۟ قَدْ كَفَرْتُم بَعْدَ إِيمَٰنِكُمْ ۚ إِن نَّعْفُ عَن طَآئِفَةٍۢ مِّنكُمْ نُعَذِّبْ طَآئِفَةًۢ بِأَنَّهُمْ كَانُوا۟ مُجْرِمِينَ","translation":"Do not offer [empty] excuses! You have indeed denied the truth after [having professed] your belief [in it] - Though We may efface the sin of some of you, We shall chastise others - seeing that they were lost in sin.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1301.mp3","surahId":9,"words":[{"id":57739,"position":1,"arabic":"لَا","translation":"না","audioUrl":"wbw/009_066_001.mp3","charTypeName":"word"},{"id":57740,"position":2,"arabic":"تَعْتَذِرُوا۟","translation":"তোমরা অজুহাত পেশ করো","audioUrl":"wbw/009_066_002.mp3","charTypeName":"word"},{"id":57741,"position":3,"arabic":"قَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/009_066_003.mp3","charTypeName":"word"},{"id":57742,"position":4,"arabic":"كَفَرْتُم","translation":"তোমার অবিশ্বাস করেছো","audioUrl":"wbw/009_066_004.mp3","charTypeName":"word"},{"id":57743,"position":5,"arabic":"بَعْدَ","translation":"পরেও","audioUrl":"wbw/009_066_005.mp3","charTypeName":"word"},{"id":57744,"position":6,"arabic":"إِيمَـٰنِكُمْ ۚ","translation":"তোমাদের ঈমান আনার","audioUrl":"wbw/009_066_006.mp3","charTypeName":"word"},{"id":57746,"position":7,"arabic":"إِن","translation":"যদিও","audioUrl":"wbw/009_066_008.mp3","charTypeName":"word"},{"id":57747,"position":8,"arabic":"نَّعْفُ","translation":"ক্ষমা করি আমরা","audioUrl":"wbw/009_066_009.mp3","charTypeName":"word"},{"id":57748,"position":9,"arabic":"عَن","translation":"হতে","audioUrl":"wbw/009_066_010.mp3","charTypeName":"word"},{"id":57749,"position":10,"arabic":"طَآئِفَةٍۢ","translation":"একদল (তার অপরাধ)","audioUrl":"wbw/009_066_011.mp3","charTypeName":"word"},{"id":57750,"position":11,"arabic":"مِّنكُمْ","translation":"মধ্য থেকে তোমাদের","audioUrl":"wbw/009_066_012.mp3","charTypeName":"word"},{"id":57751,"position":12,"arabic":"نُعَذِّبْ","translation":"আমরা (তবে)শাস্তি দিবো","audioUrl":"wbw/009_066_013.mp3","charTypeName":"word"},{"id":57752,"position":13,"arabic":"طَآئِفَةًۢ","translation":"(অপর)এক দলকে","audioUrl":"wbw/009_066_014.mp3","charTypeName":"word"},{"id":57753,"position":14,"arabic":"بِأَنَّهُمْ","translation":"কারণ নিশ্চয়ই তারা","audioUrl":"wbw/009_066_015.mp3","charTypeName":"word"},{"id":57754,"position":15,"arabic":"كَانُوا۟","translation":"ছিলো","audioUrl":"wbw/009_066_016.mp3","charTypeName":"word"},{"id":57755,"position":16,"arabic":"مُجْرِمِينَ","translation":"অপরাধী","audioUrl":"wbw/009_066_017.mp3","charTypeName":"word"},{"id":57756,"position":17,"arabic":"٦٦","translation":"(৬৬)","audioUrl":null,"charTypeName":"end"}]},{"number":67,"arabic":"ٱلْمُنَٰفِقُونَ وَٱلْمُنَٰفِقَٰتُ بَعْضُهُم مِّنۢ بَعْضٍۢ ۚ يَأْمُرُونَ بِٱلْمُنكَرِ وَيَنْهَوْنَ عَنِ ٱلْمَعْرُوفِ وَيَقْبِضُونَ أَيْدِيَهُمْ ۚ نَسُوا۟ ٱللَّهَ فَنَسِيَهُمْ ۗ إِنَّ ٱلْمُنَٰفِقِينَ هُمُ ٱلْفَٰسِقُونَ","translation":"The hypocrites, both men and women. are all of a kind: they enjoin the doing of what is wrong and forbid the doing of what is right and withhold their hands [from doing good]. They are oblivious of God, and so He is oblivious of them. Verily, the hypocrites-it is they, they who are truly iniquitously","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1302.mp3","surahId":9,"words":[{"id":58166,"position":1,"arabic":"ٱلْمُنَـٰفِقُونَ","translation":"মুনাফেক পুরুষ","audioUrl":"wbw/009_067_001.mp3","charTypeName":"word"},{"id":58167,"position":2,"arabic":"وَٱلْمُنَـٰفِقَـٰتُ","translation":"ও মুনাফেক নারী","audioUrl":"wbw/009_067_002.mp3","charTypeName":"word"},{"id":58168,"position":3,"arabic":"بَعْضُهُم","translation":"একে তারা","audioUrl":"wbw/009_067_003.mp3","charTypeName":"word"},{"id":58169,"position":4,"arabic":"مِّنۢ","translation":"অংশ","audioUrl":"wbw/009_067_004.mp3","charTypeName":"word"},{"id":58170,"position":5,"arabic":"بَعْضٍۢ ۚ","translation":"অপরের (অনুরূপ)","audioUrl":"wbw/009_067_005.mp3","charTypeName":"word"},{"id":58172,"position":6,"arabic":"يَأْمُرُونَ","translation":"তারা নির্দেশ দেয়","audioUrl":"wbw/009_067_007.mp3","charTypeName":"word"},{"id":58173,"position":7,"arabic":"بِٱلْمُنكَرِ","translation":"ব্যাপারে অন্যায় কাজের","audioUrl":"wbw/009_067_008.mp3","charTypeName":"word"},{"id":58174,"position":8,"arabic":"وَيَنْهَوْنَ","translation":"ও তারা নিষেধ করে","audioUrl":"wbw/009_067_009.mp3","charTypeName":"word"},{"id":58175,"position":9,"arabic":"عَنِ","translation":"হতে","audioUrl":"wbw/009_067_010.mp3","charTypeName":"word"},{"id":58176,"position":10,"arabic":"ٱلْمَعْرُوفِ","translation":"সৎ কাজ","audioUrl":"wbw/009_067_011.mp3","charTypeName":"word"},{"id":58177,"position":11,"arabic":"وَيَقْبِضُونَ","translation":"ও তারা গুটিয়ে রাখে","audioUrl":"wbw/009_067_012.mp3","charTypeName":"word"},{"id":58178,"position":12,"arabic":"أَيْدِيَهُمْ ۚ","translation":"হাত তাদের (ভালো কাজ হতে)","audioUrl":"wbw/009_067_013.mp3","charTypeName":"word"},{"id":58180,"position":13,"arabic":"نَسُوا۟","translation":"তারা ভুলে গেছে","audioUrl":"wbw/009_067_015.mp3","charTypeName":"word"},{"id":58181,"position":14,"arabic":"ٱللَّهَ","translation":"আল্লাহকে","audioUrl":"wbw/009_067_016.mp3","charTypeName":"word"},{"id":58182,"position":15,"arabic":"فَنَسِيَهُمْ ۗ","translation":"তাই তিনি ভুলে গেলেন তাদেরকে","audioUrl":"wbw/009_067_017.mp3","charTypeName":"word"},{"id":58184,"position":16,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/009_067_019.mp3","charTypeName":"word"},{"id":58185,"position":17,"arabic":"ٱلْمُنَـٰفِقِينَ","translation":"মুনাফিকরা","audioUrl":"wbw/009_067_020.mp3","charTypeName":"word"},{"id":58186,"position":18,"arabic":"هُمُ","translation":"তারাই","audioUrl":"wbw/009_067_021.mp3","charTypeName":"word"},{"id":58187,"position":19,"arabic":"ٱلْفَـٰسِقُونَ","translation":"সত্যত্যাগী","audioUrl":"wbw/009_067_022.mp3","charTypeName":"word"},{"id":58188,"position":20,"arabic":"٦٧","translation":"(৬৭)","audioUrl":null,"charTypeName":"end"}]},{"number":68,"arabic":"وَعَدَ ٱللَّهُ ٱلْمُنَٰفِقِينَ وَٱلْمُنَٰفِقَٰتِ وَٱلْكُفَّارَ نَارَ جَهَنَّمَ خَٰلِدِينَ فِيهَا ۚ هِىَ حَسْبُهُمْ ۚ وَلَعَنَهُمُ ٱللَّهُ ۖ وَلَهُمْ عَذَابٌۭ مُّقِيمٌۭ","translation":"God- has promised the hypocrites, both men and women-as well as the [outright] deniers of the _ truth-the fire of hell, therein to abide: this shall be their allotted_ portion. For, God has rejected them, and long-lasting suffering awaits them.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1303.mp3","surahId":9,"words":[{"id":58590,"position":1,"arabic":"وَعَدَ","translation":"প্রতিশ্রুতি দিয়েছেন","audioUrl":"wbw/009_068_001.mp3","charTypeName":"word"},{"id":58591,"position":2,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/009_068_002.mp3","charTypeName":"word"},{"id":58592,"position":3,"arabic":"ٱلْمُنَـٰفِقِينَ","translation":"মুনাফিক পুরুষদের (জন্যে)","audioUrl":"wbw/009_068_003.mp3","charTypeName":"word"},{"id":58593,"position":4,"arabic":"وَٱلْمُنَـٰفِقَـٰتِ","translation":"ও মুনাফিক নারীদের (জন্যে)","audioUrl":"wbw/009_068_004.mp3","charTypeName":"word"},{"id":58594,"position":5,"arabic":"وَٱلْكُفَّارَ","translation":"ও কাফেরদের (জন্যে)","audioUrl":"wbw/009_068_005.mp3","charTypeName":"word"},{"id":58595,"position":6,"arabic":"نَارَ","translation":"আগুন","audioUrl":"wbw/009_068_006.mp3","charTypeName":"word"},{"id":58596,"position":7,"arabic":"جَهَنَّمَ","translation":"জাহান্নামের","audioUrl":"wbw/009_068_007.mp3","charTypeName":"word"},{"id":58597,"position":8,"arabic":"خَـٰلِدِينَ","translation":"তারা চিরস্থায়ী হবে","audioUrl":"wbw/009_068_008.mp3","charTypeName":"word"},{"id":58598,"position":9,"arabic":"فِيهَا ۚ","translation":"মধ্যে তার","audioUrl":"wbw/009_068_009.mp3","charTypeName":"word"},{"id":58600,"position":10,"arabic":"هِىَ","translation":"তা","audioUrl":"wbw/009_068_011.mp3","charTypeName":"word"},{"id":58601,"position":11,"arabic":"حَسْبُهُمْ ۚ","translation":"তাদের জন্যে যথেষ্ঠ","audioUrl":"wbw/009_068_012.mp3","charTypeName":"word"},{"id":58603,"position":12,"arabic":"وَلَعَنَهُمُ","translatio