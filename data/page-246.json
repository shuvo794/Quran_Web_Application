":"٩٠","translation":"(৯০)","audioUrl":null,"charTypeName":"end"}]},{"number":91,"arabic":"قَالُوا۟ تَٱللَّهِ لَقَدْ ءَاثَرَكَ ٱللَّهُ عَلَيْنَا وَإِن كُنَّا لَخَٰطِـِٔينَ","translation":"[The brothers] said: \"By God! Most certainly has God raised thee high above us, and we were indeed but sinners!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1687.mp3","surahId":12,"words":[{"id":68553,"position":1,"arabic":"قَالُوا۟","translation":"তারা বললো","audioUrl":"wbw/012_091_001.mp3","charTypeName":"word"},{"id":68554,"position":2,"arabic":"تَٱللَّهِ","translation":"\"শপথ আল্লাহর","audioUrl":"wbw/012_091_002.mp3","charTypeName":"word"},{"id":68555,"position":3,"arabic":"لَقَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/012_091_003.mp3","charTypeName":"word"},{"id":68556,"position":4,"arabic":"ءَاثَرَكَ","translation":"তোমাকে প্রাধান্য দিয়েছেন","audioUrl":"wbw/012_091_004.mp3","charTypeName":"word"},{"id":68557,"position":5,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/012_091_005.mp3","charTypeName":"word"},{"id":68558,"position":6,"arabic":"عَلَيْنَا","translation":"আমাদের উপর","audioUrl":"wbw/012_091_006.mp3","charTypeName":"word"},{"id":68559,"position":7,"arabic":"وَإِن","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/012_091_007.mp3","charTypeName":"word"},{"id":68560,"position":8,"arabic":"كُنَّا","translation":"আমরা ছিলাম","audioUrl":"wbw/012_091_008.mp3","charTypeName":"word"},{"id":68561,"position":9,"arabic":"لَخَـٰطِـِٔينَ","translation":"অবশ্যই অপরাধী\"","audioUrl":"wbw/012_091_009.mp3","charTypeName":"word"},{"id":68562,"position":10,"arabic":"٩١","translation":"(৯১)","audioUrl":null,"charTypeName":"end"}]},{"number":92,"arabic":"قَالَ لَا تَثْرِيبَ عَلَيْكُمُ ٱلْيَوْمَ ۖ يَغْفِرُ ٱللَّهُ لَكُمْ ۖ وَهُوَ أَرْحَمُ ٱلرَّٰحِمِينَ","translation":"Said he: \"No reproach shall be uttered today against you. May God forgive you your sins: for He is the most merciful of the merciful!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1688.mp3","surahId":12,"words":[{"id":68592,"position":1,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/012_092_001.mp3","charTypeName":"word"},{"id":68593,"position":2,"arabic":"لَا","translation":"\"নেই","audioUrl":"wbw/012_092_002.mp3","charTypeName":"word"},{"id":68594,"position":3,"arabic":"تَثْرِيبَ","translation":"অভিযোগ","audioUrl":"wbw/012_092_003.mp3","charTypeName":"word"},{"id":68595,"position":4,"arabic":"عَلَيْكُمُ","translation":"বিরুদ্ধে তোমাদের","audioUrl":"wbw/012_092_004.mp3","charTypeName":"word"},{"id":68596,"position":5,"arabic":"ٱلْيَوْمَ ۖ","translation":"আজ","audioUrl":"wbw/012_092_005.mp3","charTypeName":"word"},{"id":68598,"position":6,"arabic":"يَغْفِرُ","translation":"মাফ করুন","audioUrl":"wbw/012_092_007.mp3","charTypeName":"word"},{"id":68599,"position":7,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌","audioUrl":"wbw/012_092_008.mp3","charTypeName":"word"},{"id":68600,"position":8,"arabic":"لَكُمْ ۖ","translation":"তোমাদেরকে","audioUrl":"wbw/012_092_009.mp3","charTypeName":"word"},{"id":68602,"position":9,"arabic":"وَهُوَ","translation":"এবং তিনিই","audioUrl":"wbw/012_092_011.mp3","charTypeName":"word"},{"id":68603,"position":10,"arabic":"أَرْحَمُ","translation":"শ্রেষ্ঠ দয়ালু","audioUrl":"wbw/012_092_012.mp3","charTypeName":"word"},{"id":68604,"position":11,"arabic":"ٱلرَّٰحِمِينَ","translation":"(সব) দয়াকারীদের (চেয়েও)","audioUrl":"wbw/012_092_013.mp3","charTypeName":"word"},{"id":68605,"position":12,"arabic":"٩٢","translation":"(৯২)","audioUrl":null,"charTypeName":"end"}]},{"number":93,"arabic":"ٱذْهَبُوا۟ بِقَمِيصِى هَٰذَا فَأَلْقُوهُ عَلَىٰ وَجْهِ أَبِى يَأْتِ بَصِيرًۭا وَأْتُونِى بِأَهْلِكُمْ أَجْمَعِينَ","translation":"[And now] go and take this tunic of mine and lay it over my father's face, and he will recover his sight. And thereupon come [back] to me with all your family.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1689.mp3","surahId":12,"words":[{"id":69281,"position":1,"arabic":"ٱذْهَبُوا۟","translation":"তোমরা যাও","audioUrl":"wbw/012_093_001.mp3","charTypeName":"word"},{"id":69282,"position":2,"arabic":"بِقَمِيصِى","translation":"নিয়ে আমার জামা","audioUrl":"wbw/012_093_002.mp3","charTypeName":"word"},{"id":69283,"position":3,"arabic":"هَـٰذَا","translation":"এই","audioUrl":"wbw/012_093_003.mp3","charTypeName":"word"},{"id":69284,"position":4,"arabic":"فَأَلْقُوهُ","translation":"অতঃপর তা রেখে দাও","audioUrl":"wbw/012_093_004.mp3","charTypeName":"word"},{"id":69285,"position":5,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/012_093_005.mp3","charTypeName":"word"},{"id":69286,"position":6,"arabic":"وَجْهِ","translation":"মুখের","audioUrl":"wbw/012_093_006.mp3","charTypeName":"word"},{"id":69287,"position":7,"arabic":"أَبِى","translation":"আমার পিতার","audioUrl":"wbw/012_093_007.mp3","charTypeName":"word"},{"id":69288,"position":8,"arabic":"يَأْتِ","translation":"ফিরে আসবে","audioUrl":"wbw/012_093_008.mp3","charTypeName":"word"},{"id":69289,"position":9,"arabic":"بَصِيرًۭا","translation":"(তার) দৃষ্টিশক্তি","audioUrl":"wbw/012_093_009.mp3","charTypeName":"word"},{"id":69290,"position":10,"arabic":"وَأْتُونِى","translation":"ও আমার কাছে নিয়ে আসো","audioUrl":"wbw/012_093_010.mp3","charTypeName":"word"},{"id":69291,"position":11,"arabic":"بِأَهْلِكُمْ","translation":"তোমাদের পরিবারের","audioUrl":"wbw/012_093_011.mp3","charTypeName":"word"},{"id":69292,"position":12,"arabic":"أَجْمَعِينَ","translation":"সকলকেই\"","audioUrl":"wbw/012_093_012.mp3","charTypeName":"word"},{"id":69293,"position":13,"arabic":"٩٣","translation":"(৯৩)","audioUrl":null,"charTypeName":"end"}]},{"number":94,"arabic":"وَلَمَّا فَصَلَتِ ٱلْعِيرُ قَالَ أَبُوهُمْ إِنِّى لَأَجِدُ رِيحَ يُوسُفَ ۖ لَوْلَآ أَن تُفَنِّدُونِ","translation":"AND AS SOON as the caravan [with which Jacob's sons were travelling] was on its way, their father said [to the people around him]: \"Behold, were it not that you might consider me a dotard, [I would say that] I truly feel the breath of Joseph [in the air]!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1690.mp3","surahId":12,"words":[{"id":69622,"position":1,"arabic":"وَلَمَّا","translation":"এবং যখন","audioUrl":"wbw/012_094_001.mp3","charTypeName":"word"},{"id":69623,"position":2,"arabic":"فَصَلَتِ","translation":"বেরিয়ে পড়লো","audioUrl":"wbw/012_094_002.mp3","charTypeName":"word"},{"id":69624,"position":3,"arabic":"ٱلْعِيرُ","translation":"যাত্রীদল","audioUrl":"wbw/012_094_003.mp3","charTypeName":"word"},{"id":69625,"position":4,"arabic":"قَالَ","translation":"বললো","audioUrl":"wbw/012_094_004.mp3","charTypeName":"word"},{"id":69626,"position":5,"arabic":"أَبُوهُمْ","translation":"তাদের পিতা","audioUrl":"wbw/012_094_005.mp3","charTypeName":"word"},{"id":69627,"position":6,"arabic":"إِنِّى","translation":"\"নিশ্চয়ই আমি","audioUrl":"wbw/012_094_006.mp3","charTypeName":"word"},{"id":69628,"position":7,"arabic":"لَأَجِدُ","translation":"অবশ্যই পাচ্ছি","audioUrl":"wbw/012_094_007.mp3","charTypeName":"word"},{"id":69629,"position":8,"arabic":"رِيحَ","translation":"ঘ্রাণ","audioUrl":"wbw/012_094_008.mp3","charTypeName":"word"},{"id":69630,"position":9,"arabic":"يُوسُفَ ۖ","translation":"ইউসুফের","audioUrl":"wbw/012_094_009.mp3","charTypeName":"word"},{"id":69632,"position":10,"arabic":"لَوْلَآ","translation":"যদি না","audioUrl":"wbw/012_094_011.mp3","charTypeName":"word"},{"id":69633,"position":11,"arabic":"أَن","translation":"যে","audioUrl":"wbw/012_094_012.mp3","charTypeName":"word"},{"id":69634,"position":12,"arabic":"تُفَنِّدُونِ","translation":"আমাকে তোমরা অপ্রকৃতিস্থ মনে করো\"","audioUrl":"wbw/012_094_013.mp3","charTypeName":"word"},{"id":69635,"position":13,"arabic":"٩٤","translation":"(৯৪)","audioUrl":null,"charTypeName":"end"}]},{"number":95,"arabic":"قَالُوا۟ تَٱللَّهِ إِنَّكَ لَفِى ضَلَٰلِكَ ٱلْقَدِيمِ","translation":"They answered: \"By God! Thou art indeed still lost in thy old aberration!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1691.mp3","surahId":12,"words":[{"id":69928,"position":1,"arabic":"قَالُوا۟","translation":"(লোকেরা) বললো","audioUrl":"wbw/012_095_001.mp3","charTypeName":"word"},{"id":69929,"position":2,"arabic":"تَٱللَّهِ","translation":"\"আল্লাহর শপথ","audioUrl":"wbw/012_095_002.mp3","charTypeName":"word"},{"id":69930,"position":3,"arabic":"إِنَّكَ","translation":"আপনি নিশ্চয় (রয়েছেন)","audioUrl":"wbw/012_095_003.mp3","charTypeName":"word"},{"id":69931,"position":4,"arabic":"لَفِى","translation":"অবশ্যই মধ্যে","audioUrl":"wbw/012_095_004.mp3","charTypeName":"word"},{"id":69932,"position":5,"arabic":"ضَلَـٰلِكَ","translation":"আপনার ভুলের","audioUrl":"wbw/012_095_005.mp3","charTypeName":"word"},{"id":69933,"position":6,"arabic":"ٱلْقَدِيمِ","translation":"পুরনো\"","audioUrl":"wbw/012_095_006.mp3","charTypeName":"word"},{"id":69934,"position":7,"arabic":"٩٥","translation":"(৯৫)","audioUrl":null,"charTypeName":"end"}]}]}