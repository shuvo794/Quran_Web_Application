67357,"position":17,"arabic":"عَلَيْنَآ ۖ","translation":"আমাদের","audioUrl":"wbw/012_088_017.mp3","charTypeName":"word"},{"id":67359,"position":18,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/012_088_019.mp3","charTypeName":"word"},{"id":67360,"position":19,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/012_088_020.mp3","charTypeName":"word"},{"id":67361,"position":20,"arabic":"يَجْزِى","translation":"প্রতিদান দেন","audioUrl":"wbw/012_088_021.mp3","charTypeName":"word"},{"id":67362,"position":21,"arabic":"ٱلْمُتَصَدِّقِينَ","translation":"দানকারীদেরকে\"","audioUrl":"wbw/012_088_022.mp3","charTypeName":"word"},{"id":67363,"position":22,"arabic":"٨٨","translation":"(৮৮)","audioUrl":null,"charTypeName":"end"}]},{"number":89,"arabic":"قَالَ هَلْ عَلِمْتُم مَّا فَعَلْتُم بِيُوسُفَ وَأَخِيهِ إِذْ أَنتُمْ جَٰهِلُونَ","translation":"Replied he: \"Do you remember what you did to Joseph and his brother when you were still unaware [of right and wrong]?\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1685.mp3","surahId":12,"words":[{"id":67835,"position":1,"arabic":"قَالَ","translation":"ইউসুফ (বললো)","audioUrl":"wbw/012_089_001.mp3","charTypeName":"word"},{"id":67836,"position":2,"arabic":"هَلْ","translation":"\"কি","audioUrl":"wbw/012_089_002.mp3","charTypeName":"word"},{"id":67837,"position":3,"arabic":"عَلِمْتُم","translation":"তোমরা জানো","audioUrl":"wbw/012_089_003.mp3","charTypeName":"word"},{"id":67838,"position":4,"arabic":"مَّا","translation":"যা","audioUrl":"wbw/012_089_004.mp3","charTypeName":"word"},{"id":67839,"position":5,"arabic":"فَعَلْتُم","translation":"তোমরা করেছো","audioUrl":"wbw/012_089_005.mp3","charTypeName":"word"},{"id":67840,"position":6,"arabic":"بِيُوسُفَ","translation":"ইউসুফের সাথে","audioUrl":"wbw/012_089_006.mp3","charTypeName":"word"},{"id":67841,"position":7,"arabic":"وَأَخِيهِ","translation":"ও তার ভাইয়ের (সাথে)","audioUrl":"wbw/012_089_007.mp3","charTypeName":"word"},{"id":67842,"position":8,"arabi