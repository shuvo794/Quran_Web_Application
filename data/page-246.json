{"id":246,"ayahs":[{"number":87,"arabic":"يَٰبَنِىَّ ٱذْهَبُوا۟ فَتَحَسَّسُوا۟ مِن يُوسُفَ وَأَخِيهِ وَلَا تَا۟يْـَٔسُوا۟ مِن رَّوْحِ ٱللَّهِ ۖ إِنَّهُۥ لَا يَا۟يْـَٔسُ مِن رَّوْحِ ٱللَّهِ إِلَّا ٱلْقَوْمُ ٱلْكَٰفِرُونَ","translation":"[Hence,] O my sons, go forth and try to obtain some tidings of Joseph and his brother; and do not lose hope of God's life-giving mercy: verily, none but people who deny the truth can ever lose hope of God's life-giving mercy.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1683.mp3","surahId":12,"words":[{"id":67048,"position":1,"arabic":"يَـٰبَنِىَّ","translation":"হে আমার ছেলেরা","audioUrl":"wbw/012_087_001.mp3","charTypeName":"word"},{"id":67049,"position":2,"arabic":"ٱذْهَبُوا۟","translation":"তোমরা যাও","audioUrl":"wbw/012_087_002.mp3","charTypeName":"word"},{"id":67050,"position":3,"arabic":"فَتَحَسَّسُوا۟","translation":"অতঃপর তোমরা খোঁজ করো","audioUrl":"wbw/012_087_003.mp3","charTypeName":"word"},{"id":67051,"position":4,"arabic":"مِن","translation":"এর","audioUrl":"wbw/012_087_004.mp3","charTypeName":"word"},{"id":67052,"position":5,"arabic":"يُوسُفَ","translation":"ইউসুফ","audioUrl":"wbw/012_087_005.mp3","charTypeName":"word"},{"id":67053,"position":6,"arabic":"وَأَخِيهِ","translation":"এবং তার ভাইকে","audioUrl":"wbw/012_087_006.mp3","charTypeName":"word"},{"id":67054,"position":7,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/012_087_007.mp3","charTypeName":"word"},{"id":67055,"position":8,"arabic":"تَا۟يْـَٔسُوا۟","translation":"তোমরা নিরাশ হয়ো","audioUrl":"wbw/012_087_008.mp3","charTypeName":"word"},{"id":67056,"position":9,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/012_087_009.mp3","charTypeName":"word"},{"id":67057,"position":10,"arabic":"رَّوْحِ","translation":"অনুগ্রহ","audioUrl":"wbw/012_087_010.mp3","charTypeName":"word"},{"id":67058,"position":11,"arabic":"ٱللَّهِ ۖ","translation":"আল্লাহর","audioUrl":"wbw/012_087_011.mp3","charTypeName":"word"},{"id":67060,"position":12,"arabic":