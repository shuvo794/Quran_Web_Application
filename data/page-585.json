{"id":585,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ عَبَسَ وَتَوَلَّىٰٓ","translation":"HE FROWNED and turned away","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5759.mp3","surahId":80,"words":[{"id":692,"position":1,"arabic":"عَبَسَ","translation":"সে ভ্রুকুঞ্চিত করল","audioUrl":"wbw/080_001_001.mp3","charTypeName":"word"},{"id":693,"position":2,"arabic":"وَتَوَلَّىٰٓ","translation":"ও (মুখ ফিরালো) অনাগ্রহ দেখালো","audioUrl":"wbw/080_001_002.mp3","charTypeName":"word"},{"id":694,"position":3,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"أَن جَآءَهُ ٱلْأَعْمَىٰ","translation":"because the blind man approached him!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5760.mp3","surahId":80,"words":[{"id":1718,"position":1,"arabic":"أَن","translation":"(এ জন্যে) যে","audioUrl":"wbw/080_002_001.mp3","charTypeName":"word"},{"id":1719,"position":2,"arabic":"جَآءَهُ","translation":"তার (কাছে) এসেছে","audioUrl":"wbw/080_002_002.mp3","charTypeName":"word"},{"id":1720,"position":3,"arabic":"ٱلْأَعْمَىٰ","translation":"এক অন্ধ","audioUrl":"wbw/080_002_003.mp3","charTypeName":"word"},{"id":1721,"position":4,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"وَمَا يُدْرِيكَ لَعَلَّهُۥ يَزَّكَّىٰٓ","translation":"Yet for all thou didst know, [O Muhammad,] he might perhaps have grown in purity,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5761.mp3","surahId":80,"words":[{"id":2814,"position":1,"arabic":"وَمَا","translation":"এবং কিসে","audioUrl":"wbw/080_003_001.mp3","charTypeName":"word"},{"id":2815,"position":2,"arabic":"يُدْرِيكَ","translation":"তোমাকে জানাবে","audioUrl":"wbw/080_003_002.mp3","charTypeName":"word"},{"id":2816,"position":3,"arabic":"لَعَلَّهُۥ","translation":"সে হয়তো","audioUrl":"wbw/080_003_003.mp3","charTypeName":"word"},{"id":2817,"position":4,"arabic":"يَزَّكَّىٰٓ","translation":"পরিশুদ্ধ হতো","audioUrl":"wbw/080_003_004.mp3","charTypeName":"word"},{"id":2818,"position":5,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"أَوْ يَذَّكَّرُ فَتَنفَعَهُ ٱلذِّكْرَىٰٓ","translation":"or have been reminded [of the truth], and helped by this reminder.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5762.mp3","surahId":80,"words":[{"id":4187,"position":1,"arabic":"أَوْ","translation":"বা","audioUrl":"wbw/080_004_001.mp3","charTypeName":"word"},{"id":4188,"position":2,"arabic":"يَذَّكَّرُ","translation":"উপদেশ গ্রহণ করতো","audioUrl":"wbw/080_004_002.mp3","charTypeName":"word"},{"id":4189,"position":3,"arabic":"فَتَنفَعَهُ","translation":"তাকে অতঃপর উপকার দিত","audioUrl":"wbw/080_004_003.mp3","charTypeName":"word"},{"id":4190,"position":4,"arabic":"ٱلذِّكْرَىٰٓ","translation":"উপদেশ","audioUrl":"wbw/080_004_004.mp3","charTypeName":"word"},{"id":4191,"position":5,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"أَمَّا مَنِ ٱسْتَغْنَىٰ","translation":"Now as for him who believes himself to be self-sufficient","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5763.mp3","surahId":80,"words":[{"id":5455,"position":1,"arabic":"أَمَّا","translation":"পক্ষান্তরে","audioUrl":"wbw/080_005_001.mp3","charTypeName":"word"},{"id":5456,"position":2,"arabic":"مَنِ","translation":"যে","audioUrl":"wbw/080_005_002.mp3","charTypeName":"word"},{"id":5457,"position":3,"arabic":"ٱسْتَغْنَىٰ","translation":"বেপরোয়া হলো (উন্নাসিকতা দেখালো)","audioUrl":"wbw/080_005_003.mp3","charTypeName":"word"},{"id":5458,"position":4,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"فَأَنتَ لَهُۥ تَصَدَّىٰ","translation":"to him didst thou give thy whole attention,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5764.mp3","surahId":80,"words":[{"id":6685,"position":1,"arabic":"فَأَنتَ","translation":"অথচ তুমি","audioUrl":"wbw/080_006_001.mp3","charTypeName":"word"},{"id":6686,"position":2,"arabic":"لَهُۥ","translation":"তার জন্যে","audioUrl":"wbw/080_006_002.mp3","charTypeName":"word"},{"id":6687,"position":3,"arabic":"تَصَدَّىٰ","translation":"মনযোগ দিচ্ছো","audioUrl":"wbw/080_006_003.mp3","charTypeName":"word"},{"id":6688,"position":4,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"وَمَا عَلَيْكَ أَلَّا يَزَّكَّىٰ","translation":"although thou art not accountable for his failure to attain to purity;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5765.mp3","surahId":80,"words":[{"id":8029,"position":1,"arabic":"وَمَا","translation":"কিন্তু নাই","audioUrl":"wbw/080_007_001.mp3","charTypeName":"word"},{"id":8030,"position":2,"arabic":"عَلَيْكَ","translation":"তোমার উপর (দায়িত্ব)","audioUrl":"wbw/080_007_002.mp3","charTypeName":"word"},{"id":8031,"position":3,"arabic":"أَلَّا","translation":"যদি না","audioUrl":"wbw/080_007_003.mp3","charTypeName":"word"},{"id":8032,"position":4,"arabic":"يَزَّكَّىٰ","translation":"সে পরিশুদ্ধ হয়","audioUrl":"wbw/080_007_004.mp3","charTypeName":"word"},{"id":8033,"position":5,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"وَأَمَّا مَن جَآءَكَ يَسْعَىٰ","translation":"but as for him who came unto thee full of eagerness","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5766.mp3","surahId":80,"words":[{"id":9193,"position":1,"arabic":"وَأَمَّا","translation":"আর অন্যপক্ষে","audioUrl":"wbw/080_008_001.mp3","charTypeName":"word"},{"id":9194,"position":2,"arabic":"مَن","translation":"যে","audioUrl":"wbw/080_008_002.mp3","charTypeName":"word"},{"id":9195,"position":3,"arabic":"جَآءَكَ","translation":"তোমার কাছে আসল","audioUrl":"wbw/080_008_003.mp3","charTypeName":"word"},{"id":9196,"position":4,"arabic":"يَسْعَىٰ","translation":"দৌড়ে","audioUrl":"wbw/080_008_004.mp3","charTypeName":"word"},{"id":9197,"position":5,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"وَهُوَ يَخْشَىٰ","translation":"and in awe [of God]","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5767.mp3","surahId":80,"words":[{"id":10408,"position":1,"arabic":"وَهُوَ","translation":"এবং সে","audioUrl":"wbw/080_009_001.mp3","charTypeName":"word"},{"id":10409,"position":2,"arabic":"يَخْشَىٰ","translation":"ভয় করে","audioUrl":"wbw/080_009_002.mp3","charTypeName":"word"},{"id":10410,"position":3,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"فَأَنتَ عَنْهُ تَلَهَّىٰ","translation":"him didst thou disregard!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5768.mp3","surahId":80,"words":[{"id":11634,"position":1,"arabic":"فَأَنتَ","translation":"অথচ তুমি","audioUrl":"wbw/080_010_001.mp3","charTypeName":"word"},{"id":11635,"position":2,"arabic":"عَنْهُ","translation":"তার থেকে","audioUrl":"wbw/080_010_002.mp3","charTypeName":"word"},{"id":11636,"position":3,"arabic":"تَلَهَّىٰ","translation":"অনীহা প্রকাশ করছ","audioUrl":"wbw/080_010_003.mp3","charTypeName":"word"},{"id":11637,"position":4,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"كَلَّآ إِنَّهَا تَذْكِرَةٌۭ","translation":"NAY, VERILY, these [messages] are but a reminder:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5769.mp3","surahId":80,"words":[{"id":13002,"position":1,"arabic":"كَلَّآ","translation":"কখনও না","audioUrl":"wbw/080_011_001.mp3","charTypeName":"word"},{"id":13003,"position":2,"arabic":"إِنَّهَا","translation":"নিশ্চয়ই তা","audioUrl":"wbw/080_011_002.mp3","charTypeName":"word"},{"id":13004,"position":3,"arabic":"تَذْكِرَةٌۭ","translation":"উপদেশ","audioUrl":"wbw/080_011_003.mp3","charTypeName":"word"},{"id":13005,"position":4,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]},{"number":12,"arabic":"فَمَن شَآءَ ذَكَرَهُۥ","translation":"and so, whoever is willing may remember Him","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5770.mp3","surahId":80,"words":[{"id":14324,"position":1,"arabic":"فَمَن","translation":"অতএব যে","audioUrl":"wbw/080_012_001.mp3","charTypeName":"word"},{"id":14325,"position":2,"arabic":"شَآءَ","translation":"চায়","audioUrl":"wbw/080_012_002.mp3","charTypeName":"word"},{"id":14326,"position":3,"arabic":"ذَكَرَهُۥ","translation":"(তা স্মরণ করবে) তা গ্রহণ করবে","audioUrl":"wbw/080_012_003.mp3","charTypeName":"word"},{"id":14327,"position":4,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]},{"number":13,"arabic":"فِى صُحُفٍۢ مُّكَرَّمَةٍۢ","translation":"in [the light of His] revelations blest with dignity,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5771.mp3","surahId":80,"words":[{"id":15695,"position":1,"arabic":"فِى","translation":"মধ্যে (লিপিবদ্ধ)","audioUrl":"wbw/080_013_001.mp3","charTypeName":"word"},{"id":15696,"position":2,"arabic":"صُحُفٍۢ","translation":"সহিফাসমূহের","audioUrl":"wbw/080_013_002.mp3","charTypeName":"word"},{"id":15697,"position":3,"arabic":"مُّكَرَّمَةٍۢ","translation":"(যা) সম্মানিত","audioUrl":"wbw/080_013_003.mp3","charTypeName":"word"},{"id":15698,"position":4,"arabic":"١٣","translation":"(১৩)","audioUrl":null,"charTypeName":"end"}]},{"number":14,"arabic":"مَّرْفُوعَةٍۢ مُّطَهَّرَةٍۭ","translation":"lofty and pure,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5772.mp3","surahId":80,"words":[{"id":16803,"position":1,"arabic":"مَّرْفُوعَةٍۢ","translation":"উচ্চ মর্যাদাসম্পন্ন","audioUrl":"wbw/080_014_001.mp3","charTypeName":"word"},{"id":16804,"position":2,"arabic":"مُّطَهَّرَةٍۭ","translation":"পবিত্র","audioUrl":"wbw/080_014_002.mp3","charTypeName":"word"},{"id":16805,"position":3,"arabic":"١٤","translation":"(১৪)","audioUrl":null,"charTypeName":"end"}]},{"number":15,"arabic":"بِأَيْدِى سَفَرَةٍۢ","translation":"[borne] by the hands of messengers","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5773.mp3","surahId":80,"words":[{"id":16813,"position":1,"arabic":"بِأَيْدِى","translation":"হাতে","audioUrl":"wbw/080_015_001.mp3","charTypeName":"word"},{"id":16814,"position":2,"arabic":"سَفَرَةٍۢ","translation":"দূতদের","audioUrl":"wbw/080_015_002.mp3","charTypeName":"word"},{"id":16815,"position":3,"arabic":"١٥","translation":"(১৫)","audioUrl":null,"charTypeName":"end"}]},{"number":16,"arabic":"كِرَامٍۭ بَرَرَةٍۢ","translation":"noble and most virtuous.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5774.mp3","surahId":80,"words":[{"id":17980,"position":1,"arabic":"كِرَامٍۭ","translation":"সম্মানিত","audioUrl":"wbw/080_016_001.mp3","charTypeName":"word"},{"id":17981,"position":2,"arabic":"بَرَرَةٍۢ","translation":"সততাসম্পন্ন","audioUrl":"wbw/080_016_002.mp3","charTypeName":"word"},{"id":17982,"position":3,"arabic":"١٦","translation":"(১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":17,"arabic":"قُتِلَ ٱلْإِنسَٰنُ مَآ أَكْفَرَهُۥ","translation":"[But only too often] man destroys himself: how stubbornly does he deny the truth!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5775.mp3","surahId":80,"words":[{"id":19197,"position":1,"arabic":"قُتِلَ","translation":"ধ্বংস হোক","audioUrl":"wbw/080_017_001.mp3","charTypeName":"word"},{"id":19198,"position":2,"arabic":"ٱلْإِنسَـٰنُ","translation":"মানুষ","audioUrl":"wbw/080_017_002.mp3","charTypeName":"word"},{"id":19199,"position":3,"arabic":"مَآ","translation":"কতই না","audioUrl":"wbw/080_017_003.mp3","charTypeName":"word"},{"id":19200,"position":4,"arabic":"أَكْفَرَهُۥ","translation":"তা অমান্যকারী","audioUrl":"wbw/080_017_004.mp3","charTypeName":"word"},{"id":19201,"position":5,"arabic":"١٧","translation":"(১৭)","audioUrl":null,"charTypeName":"end"}]},{"number":18,"arabic":"مِنْ أَىِّ شَىْءٍ خَلَقَهُۥ","translation":"[Does man ever consider] out of what substance [God] creates him?","audio":"https://cdn.islamic.netwo