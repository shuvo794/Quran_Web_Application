sy/5795.mp3","surahId":80,"words":[{"id":39058,"position":1,"arabic":"لِكُلِّ","translation":"জন্যে প্রত্যেক","audioUrl":"wbw/080_037_001.mp3","charTypeName":"word"},{"id":39059,"position":2,"arabic":"ٱمْرِئٍۢ","translation":"ব্যক্তির","audioUrl":"wbw/080_037_002.mp3","charTypeName":"word"},{"id":39060,"position":3,"arabic":"مِّنْهُمْ","translation":"তাদের মধ্যকার","audioUrl":"wbw/080_037_003.mp3","charTypeName":"word"},{"id":39061,"position":4,"arabic":"يَوْمَئِذٍۢ","translation":"সেদিন","audioUrl":"wbw/080_037_004.mp3","charTypeName":"word"},{"id":39062,"position":5,"arabic":"شَأْنٌۭ","translation":"(বিশেষ) অবস্থা","audioUrl":"wbw/080_037_005.mp3","charTypeName":"word"},{"id":39063,"position":6,"arabic":"يُغْنِيهِ","translation":"তাকে ব্যতিব্যস্ত করবে","audioUrl":"wbw/080_037_006.mp3","charTypeName":"word"},{"id":39064,"position":7,"arabic":"٣٧","translation":"(৩৭)","audioUrl":null,"charTypeName":"end"}]},{"number":38,"arabic":"وُجُوهٌۭ يَوْمَئِذٍۢ مُّسْفِرَةٌۭ","translation":"Some faces will on that Day be bright with happiness,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5796.mp3","surahId":80,"words":[{"id":39879,"position":1,"arabic":"وُجُوهٌۭ","translation":"(অনেক) মুখ","audioUrl":"wbw/080_038_001.mp3","charTypeName":"word"},{"id":39880,"position":2,"arabic":"يَوْمَئِذٍۢ","translation":"সেদিন","audioUrl":"wbw/080_038_002.mp3","charTypeName":"word"},{"id":39881,"position":3,"arabic":"مُّسْفِرَةٌۭ","translation":"উজ্জ্বল (হবে)","audioUrl":"wbw/080_038_003.mp3","charTypeName":"word"},{"id":39882,"position":4,"arabic":"٣٨","translation":"(৩৮)","audioUrl":null,"charTypeName":"end"}]},{"number":39,"arabic":"ضَاحِكَةٌۭ مُّسْتَبْشِرَةٌۭ","translation":"laughing, rejoicing at glad tidings.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5797.mp3","surahId":80,"words":[{"id":40700,"position":1,"arabic":"ضَاحِكَةٌۭ","translation":"সহাস্য","audioUrl":"wbw/080_039_001.mp3","charTypeName":"word"},{"id":40701,"position":2,"arabic":"مُّس