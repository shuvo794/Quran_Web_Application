mp3","charTypeName":"word"},{"id":5716,"position":27,"arabic":"غَفُورًۭا","translation":"ক্ষমাশীল","audioUrl":"wbw/033_005_030.mp3","charTypeName":"word"},{"id":5717,"position":28,"arabic":"رَّحِيمًا","translation":"পরম দয়ালু","audioUrl":"wbw/033_005_031.mp3","charTypeName":"word"},{"id":5718,"position":29,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"ٱلنَّبِىُّ أَوْلَىٰ بِٱلْمُؤْمِنِينَ مِنْ أَنفُسِهِمْ ۖ وَأَزْوَٰجُهُۥٓ أُمَّهَٰتُهُمْ ۗ وَأُو۟لُوا۟ ٱلْأَرْحَامِ بَعْضُهُمْ أَوْلَىٰ بِبَعْضٍۢ فِى كِتَٰبِ ٱللَّهِ مِنَ ٱلْمُؤْمِنِينَ وَٱلْمُهَٰجِرِينَ إِلَّآ أَن تَفْعَلُوٓا۟ إِلَىٰٓ أَوْلِيَآئِكُم مَّعْرُوفًۭا ۚ كَانَ ذَٰلِكَ فِى ٱلْكِتَٰبِ مَسْطُورًۭا","translation":"The Prophet has a higher claim on the believers than [they have on] their own selves, [seeing that he is as a father to them] and his wives are their mothers: and they who are [thus] closely related have, in accordance with God’s decree, a higher claim upon one another than [was even the case between] the believers [of Yathrib] and those who had migrated [there for the sake of God]. None the less, you are to act with utmost goodness towards your [other] close friends as well: this [too] is written down in God’s decree.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3539.mp3","surahId":33,"words":[{"id":6976,"position":1,"arabic":"ٱلنَّبِىُّ","translation":"নাবীই","audioUrl":"wbw/033_006_001.mp3","charTypeName":"word"},{"id":6977,"position":2,"arabic":"أَوْلَىٰ","translation":"অধিক ঘনিষ্ঠ","audioUrl":"wbw/033_006_002.mp3","charTypeName":"word"},{"id":6978,"position":3,"arabic":"بِٱلْمُؤْمِنِينَ","translation":"কাছে মু’মিনদের","audioUrl":"wbw/033_006_003.mp3","charTypeName":"word"},{"id":6979,"position":4,"arabic":"مِنْ","translation":"অপেক্ষা","audioUrl":"wbw/033_006_004.mp3","charTypeName":"word"},{"id":6980,"position":5,"arabic":"أَنفُسِهِمْ ۖ","translation":"নিজেদের তাদের","audioUrl":"wbw/033_006_005.mp3","charTypeName":"word"},{"id":6982,"position":6,"arabic":"وَأَزْوَٰجُهُۥٓ","translation":"এবং স্ত্রীগণ তার","audioUrl":"wbw/033_006_007.mp3","charTypeName":"word"},{"id":6983,"position":7,"arabic":"أُمَّهَـٰتُهُمْ ۗ","translation":"মা তাদের","audioUrl":"wbw/033_006_008.mp3","charTypeName":"word"},{"id":6985,"position":8,"arabic":"وَأُو۟لُوا۟","translation":"এবং অধিকারীরা","audioUrl":"wbw/033_006_010.mp3","charTypeName":"word"},{"id":6986,"position":9,"arabic":"ٱلْأَرْحَامِ","translation":"আত্নীয়তা-সম্পর্কের (নিকট আত্মীয়-স্বজনরা মু’মিন হ'লে)","audioUrl":"wbw/033_006_011.mp3","charTypeName":"word"},{"id":6987,"position":10,"arabic":"بَعْضُهُمْ","translation":"পরস্পরে তাদের","audioUrl":"wbw/033_006_012.mp3","charTypeName":"word"},{"id":6988,"position":11,"arabic":"أَوْلَىٰ","translation":"অধিক ঘনিষ্ঠ","audioUrl":"wbw/033_006_013.mp3","charTypeName":"word"},{"id":6989,"position":12,"arabic":"بِبَعْضٍۢ","translation":"সাথে পরস্পরের","audioUrl":"wbw/033_006_014.mp3","charTypeName":"word"},{"id":6990,"position":13,"arabic":"فِى","translation":"অনুসারে","audioUrl":"wbw/033_006_015.mp3","charTypeName":"word"},{"id":6991,"position":14,"arabic":"كِتَـٰبِ","translation":"বিধান","audioUrl":"wbw/033_006_016.mp3","charTypeName":"word"},{"id":6992,"position":15,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/033_006_017.mp3","charTypeName":"word"},{"id":6993,"position":16,"arabic":"مِنَ","translation":"চেয়ে","audioUrl":"wbw/033_006_018.mp3","charTypeName":"word"},{"id":6994,"position":17,"arabic":"ٱلْمُؤْمِنِينَ","translation":"(সাধারণ) মু’মিনদের","audioUrl":"wbw/033_006_019.mp3","charTypeName":"word"},{"id":6995,"position":18,"arabic":"وَٱلْمُهَـٰجِرِينَ","translation":"ও মুহাজিরদের","audioUrl":"wbw/033_006_020.mp3","charTypeName":"word"},{"id":6996,"position":19,"arabic":"إِلَّآ","translation":"তবে","audioUrl":"wbw/033_006_021.mp3","charTypeName":"word"},{"id":6997,"position":20,"arabic":"أَن","translation":"(এটা) যে","audioUrl":"wbw/033_006_022.mp3","charTypeName":"word"},{"id":6998,"position":21