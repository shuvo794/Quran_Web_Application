right path.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3537.mp3","surahId":33,"words":[{"id":4436,"position":1,"arabic":"مَّا","translation":"না","audioUrl":"wbw/033_004_001.mp3","charTypeName":"word"},{"id":4437,"position":2,"arabic":"جَعَلَ","translation":"সৃষ্টি করেছেন","audioUrl":"wbw/033_004_002.mp3","charTypeName":"word"},{"id":4438,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/033_004_003.mp3","charTypeName":"word"},{"id":4439,"position":4,"arabic":"لِرَجُلٍۢ","translation":"জন্যে কোনো ব্যক্তির","audioUrl":"wbw/033_004_004.mp3","charTypeName":"word"},{"id":4440,"position":5,"arabic":"مِّن","translation":"দিয়ে","audioUrl":"wbw/033_004_005.mp3","charTypeName":"word"},{"id":4441,"position":6,"arabic":"قَلْبَيْنِ","translation":"দু'টি হৃদয়","audioUrl":"wbw/033_004_006.mp3","charTypeName":"word"},{"id":4442,"position":7,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/033_004_007.mp3","charTypeName":"word"},{"id":4443,"position":8,"arabic":"جَوْفِهِۦ ۚ","translation":"অভ্যন্তরে তার","audioUrl":"wbw/033_004_008.mp3","charTypeName":"word"},{"id":4445,"position":9,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/033_004_010.mp3","charTypeName":"word"},{"id":4446,"position":10,"arabic":"جَعَلَ","translation":"বানিয়েছেন","audioUrl":"wbw/033_004_011.mp3","charTypeName":"word"},{"id":4447,"position":11,"arabic":"أَزْوَٰجَكُمُ","translation":"স্ত্রীদেরকে তোমাদের","audioUrl":"wbw/033_004_012.mp3","charTypeName":"word"},{"id":4448,"position":12,"arabic":"ٱلَّـٰٓـِٔى","translation":"যাদেরকে","audioUrl":"wbw/033_004_013.mp3","charTypeName":"word"},{"id":4449,"position":13,"arabic":"تُظَـٰهِرُونَ","translation":"তোমরা জিহার কর","audioUrl":"wbw/033_004_014.mp3","charTypeName":"word"},{"id":4450,"position":14,"arabic":"مِنْهُنَّ","translation":"মধ্যে হ'তে তাদের","audioUrl":"wbw/033_004_015.mp3","charTypeName":"word"},{"id":4451,"position":15,"arabic":"أُمَّهَـٰتِكُمْ ۚ","translation":"তোমাদের মা তোমাদের","audioUrl":"wbw/0