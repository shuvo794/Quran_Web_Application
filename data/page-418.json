ٱلدِّينِ وَمَوَٰلِيكُمْ ۚ وَلَيْسَ عَلَيْكُمْ جُنَاحٌۭ فِيمَآ أَخْطَأْتُم بِهِۦ وَلَٰكِن مَّا تَعَمَّدَتْ قُلُوبُكُمْ ۚ وَكَانَ ٱللَّهُ غَفُورًۭا رَّحِيمًا","translation":"[As for your adopted children,] call them by their [real] fathers’ names: this is more equitable in the sight of God; and if you know not who their fathers were, [call them] your brethren in faith and your friends. However, you will incur no sin if you err in this respect: [what really matters is] but what your hearts intend - for God is indeed much-forgiv­ing, a dispenser of grace!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3538.mp3","surahId":33,"words":[{"id":5687,"position":1,"arabic":"ٱدْعُوهُمْ","translation":"তোমরা ডাকো তাদেরকে","audioUrl":"wbw/033_005_001.mp3","charTypeName":"word"},{"id":5688,"position":2,"arabic":"لِـَٔابَآئِهِمْ","translation":"নিয়ে পিতাদের তাদের (সম্পর্কে)","audioUrl":"wbw/033_005_002.mp3","charTypeName":"word"},{"id":5689,"position":3,"arabic":"هُوَ","translation":"তা-ই","audioUrl":"wbw/033_005_003.mp3","charTypeName":"word"},{"id":5690,"position":4,"arabic":"أَقْسَطُ","translation":"অধিক ন্যায়সঙ্গত","audioUrl":"wbw/033_005_004.mp3","charTypeName":"word"},{"id":5691,"position":5,"arabic":"عِندَ","translation":"কাছে","audioUrl":"wbw/033_005_005.mp3","charTypeName":"word"},{"id":5692,"position":6,"arabic":"ٱللَّهِ ۚ","translation":"আল্লাহর","audioUrl":"wbw/033_005_006.mp3","charTypeName":"word"},{"id":5694,"position":7,"arabic":"فَإِن","translation":"অতঃপর যদি","audioUrl":"wbw/033_005_008.mp3","charTypeName":"word"},{"id":5695,"position":8,"arabic":"لَّمْ","translation":"না","audioUrl":"wbw/033_005_009.mp3","charTypeName":"word"},{"id":5696,"position":9,"arabic":"تَعْلَمُوٓا۟","translation":"তোমরা জানো","audioUrl":"wbw/033_005_010.mp3","charTypeName":"word"},{"id":5697,"position":10,"arabic":"ءَابَآءَهُمْ","translation":"পিতাদের তাদের(পরিচয়)","audioUrl":"wbw/033_005_011.mp3","charTypeName":"word"},{"id":5698,"position":11,"arabic":"فَإِخْوَٰنُك