{"id":418,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ يَٰٓأَيُّهَا ٱلنَّبِىُّ ٱتَّقِ ٱللَّهَ وَلَا تُطِعِ ٱلْكَٰفِرِينَ وَٱلْمُنَٰفِقِينَ ۗ إِنَّ ٱللَّهَ كَانَ عَلِيمًا حَكِيمًۭا","translation":"PROPHET! Remain conscious of God, and defer not to the deniers of the truth and the hypo­crites: for God is truly all-knowing, wise.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3534.mp3","surahId":33,"words":[{"id":798,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/033_001_001.mp3","charTypeName":"word"},{"id":799,"position":2,"arabic":"ٱلنَّبِىُّ","translation":"নাবী","audioUrl":"wbw/033_001_002.mp3","charTypeName":"word"},{"id":800,"position":3,"arabic":"ٱتَّقِ","translation":"ভয় করো","audioUrl":"wbw/033_001_003.mp3","charTypeName":"word"},{"id":801,"position":4,"arabic":"ٱللَّهَ","translation":"আল্লাহকে","audioUrl":"wbw/033_001_004.mp3","charTypeName":"word"},{"id":802,"position":5,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/033_001_005.mp3","charTypeName":"word"},{"id":803,"position":6,"arabic":"تُطِعِ","translation":"আনুগত্য করো","audioUrl":"wbw/033_001_006.mp3","charTypeName":"word"},{"id":804,"position":7,"arabic":"ٱلْكَـٰفِرِينَ","translation":"কাফিরদের","audioUrl":"wbw/033_001_007.mp3","charTypeName":"word"},{"id":805,"position":8,"arabic":"وَٱلْمُنَـٰفِقِينَ ۗ","translation":"আর (না) মুনাফিকদেরকে","audioUrl":"wbw/033_001_008.mp3","charTypeName":"word"},{"id":807,"position":9,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/033_001_010.mp3","charTypeName":"word"},{"id":808,"position":10,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/033_001_011.mp3","charTypeName":"word"},{"id":809,"position":11,"arabic":"كَانَ","translation":"হলেন","audioUrl":"wbw/033_001_012.mp3","charTypeName":"word"},{"id":810,"position":12,"arabic":"عَلِيمًا","translation":"সর্বজ্ঞ","audioUrl":"wbw/033_001_013.mp3","charTypeName":"word"},{"id":811,"position":13,"arabic":"حَكِيمًۭا","translati