{"id":144,"ayahs":[{"number":125,"arabic":"فَمَن يُرِدِ ٱللَّهُ أَن يَهْدِيَهُۥ يَشْرَحْ صَدْرَهُۥ لِلْإِسْلَٰمِ ۖ وَمَن يُرِدْ أَن يُضِلَّهُۥ يَجْعَلْ صَدْرَهُۥ ضَيِّقًا حَرَجًۭا كَأَنَّمَا يَصَّعَّدُ فِى ٱلسَّمَآءِ ۚ كَذَٰلِكَ يَجْعَلُ ٱللَّهُ ٱلرِّجْسَ عَلَى ٱلَّذِينَ لَا يُؤْمِنُونَ","translation":"And whomsoever God wills to guide, his bosom He opens wide with willingness towards self-surrender [unto Him]; and whomsoever He wills to let go astray, his bosom He causes to be tight and constricted, as if he were climbing unto the skies: it is thus that God inflicts horror upon those who will not believe.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/914.mp3","surahId":6,"words":[{"id":77201,"position":1,"arabic":"فَمَن","translation":"অতএব যাকে","audioUrl":"wbw/006_125_001.mp3","charTypeName":"word"},{"id":77202,"position":2,"arabic":"يُرِدِ","translation":"চান","audioUrl":"wbw/006_125_002.mp3","charTypeName":"word"},{"id":77203,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌","audioUrl":"wbw/006_125_003.mp3","charTypeName":"word"},{"id":77204,"position":4,"arabic":"أَن","translation":"যে","audioUrl":"wbw/006_125_004.mp3","charTypeName":"word"},{"id":77205,"position":5,"arabic":"يَهْدِيَهُۥ","translation":"সৎপথে পরিচালিত করবেন তাকে","audioUrl":"wbw/006_125_005.mp3","charTypeName":"word"},{"id":77206,"position":6,"arabic":"يَشْرَحْ","translation":"প্রশস্ত করে দেন","audioUrl":"wbw/006_125_006.mp3","charTypeName":"word"},{"id":77207,"position":7,"arabic":"صَدْرَهُۥ","translation":"হৃদয়কে তার","audioUrl":"wbw/006_125_007.mp3","charTypeName":"word"},{"id":77208,"position":8,"arabic":"لِلْإِسْلَـٰمِ ۖ","translation":"জন্যে ইসলামের","audioUrl":"wbw/006_125_008.mp3","charTypeName":"word"},{"id":77210,"position":9,"arabic":"وَمَن","translation":"এবং যাকে","audioUrl":"wbw/006_125_010.mp3","charTypeName":"word"},{"id":77211,"position":10,"arabic":"يُرِدْ","translation":"চান","audioUrl":"wbw/006_125_011.mp3","charTypeName":"word"},{"id":77212,"position":11,"arabic":"أَن","translation":"যে","audioUrl":"wbw/006_125_012.mp3","charTypeName":"word"},{"id":77213,"position":12,"arabic":"يُضِلَّهُۥ","translation":"বিপথগামী করবেন তাকে","audioUrl":"wbw/006_125_013.mp3","charTypeName":"word"},{"id":77214,"position":13,"arabic":"يَجْعَلْ","translation":"করেছেন","audioUrl":"wbw/006_125_014.mp3","charTypeName":"word"},{"id":77215,"position":14,"arabic":"صَدْرَهُۥ","translation":"হৃদয়কে তার","audioUrl":"wbw/006_125_015.mp3","charTypeName":"word"},{"id":77216,"position":15,"arabic":"ضَيِّقًا","translation":"ইসলামের অনুসরণে","audioUrl":"wbw/006_125_016.mp3","charTypeName":"word"},{"id":77217,"position":16,"arabic":"حَرَجًۭا","translation":"অতিশয় সংকীর্ণ","audioUrl":"wbw/006_125_017.mp3","charTypeName":"word"},{"id":77218,"position":17,"arabic":"كَأَنَّمَا","translation":"যেন (তার মনে হবে)","audioUrl":"wbw/006_125_018.mp3","charTypeName":"word"},{"id":77219,"position":18,"arabic":"يَصَّعَّدُ","translation":"সে আরোহণ করছে","audioUrl":"wbw/006_125_019.mp3","charTypeName":"word"},{"id":77220,"position":19,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/006_125_020.mp3","charTypeName":"word"},{"id":77221,"position":20,"arabic":"ٱلسَّمَآءِ ۚ","translation":"আকাশের","audioUrl":"wbw/006_125_021.mp3","charTypeName":"word"},{"id":77223,"position":21,"arabic":"كَذَٰلِكَ","translation":"এভাবে","audioUrl":"wbw/006_125_023.mp3","charTypeName":"word"},{"id":77224,"position":22,"arabic":"يَجْعَلُ","translation":"রাখেন","audioUrl":"wbw/006_125_024.mp3","charTypeName":"word"},{"id":77225,"position":23,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌","audioUrl":"wbw/006_125_025.mp3","charTypeName":"word"},{"id":77226,"position":24,"arabic":"ٱلرِّجْسَ","translation":"অপবিত্রতা","audioUrl":"wbw/006_125_026.mp3","charTypeName":"word"},{"id":77227,"position":25,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/006_125_027.mp3","charTypeName":"word"},{"id":77228,"position":26,"arabic":"ٱلَّذِينَ","translation":"(তাদের) যারা","audioUrl":"wbw/006_125_028.mp3","charTypeName":"word"},{"id":77229,"position":27,"arabic":"لَا","translation":"না","audioUrl":"wbw/006_125_029.mp3","charTypeName":"word"},{"id":77230,"position":28,"arabic":"يُؤْمِنُونَ","translation":"ঈমান আনে","audioUrl":"wbw/006_125_030.mp3","charTypeName":"word"},{"id":77231,"position":29,"arabic":"١٢٥","translation":"(১২৫)","audioUrl":null,"charTypeName":"end"}]},{"number":126,"arabic":"وَهَٰذَا صِرَٰطُ رَبِّكَ مُسْتَقِيمًۭا ۗ قَدْ فَصَّلْنَا ٱلْءَايَٰتِ لِقَوْمٍۢ يَذَّكَّرُونَ","translation":"And undeviating is this thy Sustainer's way. Clearly, indeed, have We spelled out these messages unto people who [are willing to] take them to heart!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/915.mp3","surahId":6,"words":[{"id":77312,"position":1,"arabic":"وَهَـٰذَا","translation":"এবং এই","audioUrl":"wbw/006_126_001.mp3","charTypeName":"word"},{"id":77313,"position":2,"arabic":"صِرَٰطُ","translation":"পথ","audioUrl":"wbw/006_126_002.mp3","charTypeName":"word"},{"id":77314,"position":3,"arabic":"رَبِّكَ","translation":"তোমার রবের","audioUrl":"wbw/006_126_003.mp3","charTypeName":"word"},{"id":77315,"position":4,"arabic":"مُسْتَقِيمًۭا ۗ","translation":"সরল-সঠিক (পথ)","audioUrl":"wbw/006_126_004.mp3","charTypeName":"word"},{"id":77317,"position":5,"arabic":"قَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/006_126_006.mp3","charTypeName":"word"},{"id":77318,"position":6,"arabic":"فَصَّلْنَا","translation":"বিশদ বর্ণনা করেছি আমরা","audioUrl":"wbw/006_126_007.mp3","charTypeName":"word"},{"id":77319,"position":7,"arabic":"ٱلْـَٔايَـٰتِ","translation":"নিদর্শনগুলোকে","audioUrl":"wbw/006_126_008.mp3","charTypeName":"word"},{"id":77320,"position":8,"arabic":"لِقَوْمٍۢ","translation":"জন্যে সম্প্রদায়ের","audioUrl":"wbw/006_126_009.mp3","charTypeName":"word"},{"id":77321,"position":9,"arabic":"يَذَّكَّرُونَ","translation":"(যারা) উপদেশ গ্রহণ করে","audioUrl":"wbw/006_126_010.mp3","charTypeName":"word"},{"id":77322,"position":10,"arabic":"١٢٦","translation":"(১২৬)","audioUrl":null,"charTypeName":"end"}]},{"number":127,"arabic":"۞ لَهُمْ دَارُ ٱلسَّلَٰمِ عِندَ رَبِّهِمْ ۖ وَهُوَ وَلِيُّهُم بِمَا كَانُوا۟ يَعْمَلُونَ","translation":"Theirs shall be an abode of peace with their Sustainer; and He shall be near unto them in result of what they have been doing.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/916.mp3","surahId":6,"words":[{"id":77586,"position":1,"arabic":"۞ لَهُمْ","translation":"জন্যে তাদের (রয়েছে)","audioUrl":"wbw/006_127_002.mp3","charTypeName":"word"},{"id":77587,"position":2,"arabic":"دَارُ","translation":"ঘর","audioUrl":"wbw/006_127_003.mp3","charTypeName":"word"},{"id":77588,"position":3,"arabic":"ٱلسَّلَـٰمِ","translation":"শান্তির","audioUrl":"wbw/006_127_004.mp3","charTypeName":"word"},{"id":77589,"position":4,"arabic":"عِندَ","translation":"নিকট","audioUrl":"wbw/006_127_005.mp3","charTypeName":"word"},{"id":77590,"position":5,"arabic":"رَبِّهِمْ ۖ","translation":"রবের তাদের","audioUrl":"wbw/006_127_006.mp3","charTypeName":"word"},{"id":77592,"position":6,"arabic":"وَهُوَ","translation":"এবং তিনি","audioUrl":"wbw/006_127_008.mp3","charTypeName":"word"},{"id":77593,"position":7,"arabic":"وَلِيُّهُم","translation":"অভিভাবক তাদের","audioUrl":"wbw/006_127_009.mp3","charTypeName":"word"},{"id":77594,"position":8,"arabic":"بِمَا","translation":"এ কারণে যা","audioUrl":"wbw/006_127_010.mp3","charTypeName":"word"},{"id":77595,"position":9,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/006_127_011.mp3","charTypeName":"word"},{"id":77596,"position":10,"arabic":"يَعْمَلُونَ","translation":"তারা কাজ করতে","audioUrl":"wbw/006_127_012.mp3","charTypeName":"word"},{"id":77597,"position":11,"arabic":"١٢٧","translation":"(১২৭)","audioUrl":null,"charTypeName":"end"}]},{"number":128,"arabic":"وَيَوْمَ يَحْشُرُهُمْ جَمِيعًۭا يَٰمَعْشَرَ ٱلْجِنِّ قَدِ ٱسْتَكْثَرْتُم مِّنَ ٱلْإِنسِ ۖ وَقَالَ أَوْلِيَآؤُهُم مِّنَ ٱلْإِنسِ رَبَّنَا ٱسْتَمْتَعَ بَعْضُنَا بِبَعْضٍۢ وَبَلَغْنَآ أَجَلَنَا ٱلَّذِىٓ أَجَّلْتَ لَنَا ۚ قَالَ ٱلنَّارُ مَثْوَىٰكُمْ خَٰلِدِينَ فِيهَآ إِلَّا مَا شَآءَ ٱللَّهُ ۗ إِنَّ رَبَّكَ حَكِيمٌ عَلِيمٌۭ","translation":"AND ON THE DAY when He shall gather them [all] together, [He will say:] \"O you who have lived in close communion with [evil] invisible beings! A great many [other] human beings have you ensnared! And those of the humans who were close to them will say: \"O our Sustainer! We did enjoy one another's fellowship [in life]; but (now that] we have reached the end of our term-the term which Thou hast laid down for us - (we see the error of our ways]!\" [But] He will say: \"The fire shall be your abode, therein to abide-unless God wills it otherwise.\" Verily, thy Sustainer is wise, all-knowing.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/917.mp3","surahId":6,"words":[{"id":77598,"position":1,"arabic":"وَيَوْمَ","translation":"এবং যেদিন","audioUrl":"wbw/006_128_001.mp3","charTypeName":"word"},{"id":77599,"position":2,"arabic":"يَحْشُرُهُمْ","translation":"একত্র করবেন তাদের (আল্লাহ্‌)","audioUrl":"wbw/006_128_002.mp3","charTypeName":"word"},{"id":77600,"position":3,"arabic":"جَمِيعًۭا","translation":"সকলকে (এবং বলবেন)","audioUrl":"wbw/006_128_003.mp3","charTypeName":"word"},{"id":77601,"position":4,"arabic":"يَـٰمَعْشَرَ","translation":"হে সম্প্রদায়","audioUrl":"wbw/006_128_004.mp3","charTypeName":"word"},{"id":77602,"position":5,"arabic":"ٱلْجِنِّ","translation":"জিনদের","audioUrl":"wbw/006_128_005.mp3","charTypeName":"word"},{"id":77603,"position":6,"arabic":"قَدِ","translation":"নিশ্চয়ই","audioUrl":"wbw/006_128_006.mp3","charTypeName":"word"},{"id":77604,"position":7,"arabic":"ٱسْتَكْثَرْتُم","translation":"অনেককে অনুগামী করেছো তোমরা","audioUrl":"wbw/006_128_007.mp3","charTypeName":"word"},{"id":77605,"position":8,"arabic":"مِّنَ","translation":"মধ্য হতে","audioUrl":"wbw/006_128_008.mp3","charTypeName":"word"},{"id":77606,"position":9,"arabic":"ٱلْإِنسِ ۖ","translation":"মানুষের\"","audioUrl":"wbw/0