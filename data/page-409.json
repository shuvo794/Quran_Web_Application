on":"নয়","audioUrl":"wbw/030_043_010.mp3","charTypeName":"word"},{"id":43959,"position":11,"arabic":"مَرَدَّ","translation":"টলে যাওয়ার","audioUrl":"wbw/030_043_011.mp3","charTypeName":"word"},{"id":43960,"position":12,"arabic":"لَهُۥ","translation":"তা","audioUrl":"wbw/030_043_012.mp3","charTypeName":"word"},{"id":43961,"position":13,"arabic":"مِنَ","translation":"পক্ষ থেকে","audioUrl":"wbw/030_043_013.mp3","charTypeName":"word"},{"id":43962,"position":14,"arabic":"ٱللَّهِ ۖ","translation":"আল্লাহর","audioUrl":"wbw/030_043_014.mp3","charTypeName":"word"},{"id":43964,"position":15,"arabic":"يَوْمَئِذٍۢ","translation":"সেদিন","audioUrl":"wbw/030_043_016.mp3","charTypeName":"word"},{"id":43965,"position":16,"arabic":"يَصَّدَّعُونَ","translation":"তারা বিভক্ত হয়ে পড়বে","audioUrl":"wbw/030_043_017.mp3","charTypeName":"word"},{"id":43966,"position":17,"arabic":"٤٣","translation":"(৪৩)","audioUrl":null,"charTypeName":"end"}]},{"number":44,"arabic":"مَن كَفَرَ فَعَلَيْهِ كُفْرُهُۥ ۖ وَمَنْ عَمِلَ صَٰلِحًۭا فَلِأَنفُسِهِمْ يَمْهَدُونَ","translation":"he who has denied the truth will have to bear [the burden of] his denial, whereas all who did what is right and just will have made goodly provision for themselves,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3453.mp3","surahId":30,"words":[{"id":44682,"position":1,"arabic":"مَن","translation":"যে","audioUrl":"wbw/030_044_001.mp3","charTypeName":"word"},{"id":44683,"position":2,"arabic":"كَفَرَ","translation":"অস্বীকার করবে","audioUrl":"wbw/030_044_002.mp3","charTypeName":"word"},{"id":44684,"position":3,"arabic":"فَعَلَيْهِ","translation":"তবে (পড়বে)উপর তার","audioUrl":"wbw/030_044_003.mp3","charTypeName":"word"},{"id":44685,"position":4,"arabic":"كُفْرُهُۥ ۖ","translation":"তার অস্বীকৃতির ( কুফল )","audioUrl":"wbw/030_044_004.mp3","charTypeName":"word"},{"id":44687,"position":5,"arabic":"وَمَنْ","translation":"এবং যারা","audioUrl":"wbw/030_044_006.mp3","charTypeName":"word"},{"id":44688,"position":6,"arabic":"عَمِلَ","translation":"কাজ করবে","audioUrl":"wbw/030_044_007.mp3","charTypeName":"word"},{"id":44689,"position":7,"arabic":"صَـٰلِحًۭا","translation":"সৎ","audioUrl":"wbw/030_044_008.mp3","charTypeName":"word"},{"id":44690,"position":8,"arabic":"فَلِأَنفُسِهِمْ","translation":"তবে জন্যে নিজেদের তাদের","audioUrl":"wbw/030_044_009.mp3","charTypeName":"word"},{"id":44691,"position":9,"arabic":"يَمْهَدُونَ","translation":"তারা সুখশয্যা তৈরী করে","audioUrl":"wbw/030_044_010.mp3","charTypeName":"word"},{"id":44692,"position":10,"arabic":"٤٤","translation":"(৪৪)","audioUrl":null,"charTypeName":"end"}]},{"number":45,"arabic":"لِيَجْزِىَ ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ مِن فَضْلِهِۦٓ ۚ إِنَّهُۥ لَا يُحِبُّ ٱلْكَٰفِرِينَ","translation":"so that He might reward, out of His bounty, those who have attained to faith and done righteous deeds. Verily, He does not love those who refuse to acknowledge the truth –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3454.mp3","surahId":30,"words":[{"id":45423,"position":1,"arabic":"لِيَجْزِىَ","translation":"যেন তিনি পুরস্কার দেন","audioUrl":"wbw/030_045_001.mp3","charTypeName":"word"},{"id":45424,"position":2,"arabic":"ٱلَّذِينَ","translation":"(তাদেরকে)যারা","audioUrl":"wbw/030_045_002.mp3","charTypeName":"word"},{"id":45425,"position":3,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/030_045_003.mp3","charTypeName":"word"},{"id":45426,"position":4,"arabic":"وَعَمِلُوا۟","translation":"ও কাজ করেছে","audioUrl":"wbw/030_045_004.mp3","charTypeName":"word"},{"id":45427,"position":5,"arabic":"ٱلصَّـٰلِحَـٰتِ","translation":"সৎ","audioUrl":"wbw/030_045_005.mp3","charTypeName":"word"},{"id":45428,"position":6,"arabic":"مِن","translation":"কারণে","audioUrl":"wbw/030_045_006.mp3","charTypeName":"word"},{"id":45429,"position":7,"arabic":"فَضْلِهِۦٓ ۚ","translation":"অনুগ্রহের তাঁর","audioUrl":"wbw/030_045_007.mp3","charTypeName":"word"},{"id":45431,"position":8,"arabic":"إِنَّهُۥ","translation":"নিশ্চয়ই তিনি","audioUrl":"wbw/030_045_009.mp3","charTypeName":"word"},{"id":45432,"position":9,"arabic":"لَا","translation":"না","audioUrl":"wbw/030_045_010.mp3","charTypeName":"word"},{"id":45433,"position":10,"arabic":"يُحِبُّ","translation":"ভালবাসেন","audioUrl":"wbw/030_045_011.mp3","charTypeName":"word"},{"id":45434,"position":11,"arabic":"ٱلْكَـٰفِرِينَ","translation":"কাফিরদেরকে","audioUrl":"wbw/030_045_012.mp3","charTypeName":"word"},{"id":45435,"position":12,"arabic":"٤٥","translation":"(৪৫)","audioUrl":null,"charTypeName":"end"}]},{"number":46,"arabic":"وَمِنْ ءَايَٰتِهِۦٓ أَن يُرْسِلَ ٱلرِّيَاحَ مُبَشِّرَٰتٍۢ وَلِيُذِيقَكُم مِّن رَّحْمَتِهِۦ وَلِتَجْرِىَ ٱلْفُلْكُ بِأَمْرِهِۦ وَلِتَبْتَغُوا۟ مِن فَضْلِهِۦ وَلَعَلَّكُمْ تَشْكُرُونَ","translation":"for among His wonders is this: He sends forth [His messages as He sends forth] the winds that bear glad tidings, so that He might give you a taste of His grace [through life-giving rains], and that ships might sail at His behest, and that you might go about in quest of some of His bounties, and that you might have cause to be grateful.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3455.mp3","surahId":30,"words":[{"id":45947,"position":1,"arabic":"وَمِنْ","translation":"এবং হ'তে","audioUrl":"wbw/030_046_001.mp3","charTypeName":"word"},{"id":45948,"position":2,"arabic":"ءَايَـٰتِهِۦٓ","translation":"নিদর্শনাবলী তাঁর","audioUrl":"wbw/030_046_002.mp3","charTypeName":"word"},{"id":45949,"position":3,"arabic":"أَن","translation":"( এও ) যে","audioUrl":"wbw/030_046_003.mp3","charTypeName":"word"},{"id":45950,"position":4,"arabic":"يُرْسِلَ","translation":"তিনি পাঠান","audioUrl":"wbw/030_046_004.mp3","charTypeName":"word"},{"id":45951,"position":5,"arabic":"ٱلرِّيَاحَ","translation":"বাতাস","audioUrl":"wbw/030_046_005.mp3","charTypeName":"word"},{"id":45952,"position":6,"arabic":"مُبَشِّرَٰتٍۢ","translation":"সুসংবাদ বাহক হিসাবে","audioUrl":"wbw/030_046_006.mp3","charTypeName":"word"},{"id":45953,"po