{"id":409,"ayahs":[{"number":42,"arabic":"قُلْ سِيرُوا۟ فِى ٱلْأَرْضِ فَٱنظُرُوا۟ كَيْفَ كَانَ عَٰقِبَةُ ٱلَّذِينَ مِن قَبْلُ ۚ كَانَ أَكْثَرُهُم مُّشْرِكِينَ","translation":"Say: “Go all over the earth, and behold what happened in the end to those [sinners] who lived before [you]: most of them were wont to ascribe divine qualities to things or beings other than God.”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3451.mp3","surahId":30,"words":[{"id":43216,"position":1,"arabic":"قُلْ","translation":"বলো( হে নাবী )","audioUrl":"wbw/030_042_001.mp3","charTypeName":"word"},{"id":43217,"position":2,"arabic":"سِيرُوا۟","translation":"\"তোমরা ভ্রমণ করো","audioUrl":"wbw/030_042_002.mp3","charTypeName":"word"},{"id":43218,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/030_042_003.mp3","charTypeName":"word"},{"id":43219,"position":4,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/030_042_004.mp3","charTypeName":"word"},{"id":43220,"position":5,"arabic":"فَٱنظُرُوا۟","translation":"অতঃপর লক্ষ্য করো","audioUrl":"wbw/030_042_005.mp3","charTypeName":"word"},{"id":43221,"position":6,"arabic":"كَيْفَ","translation":"কেমন","audioUrl":"wbw/030_042_006.mp3","charTypeName":"word"},{"id":43222,"position":7,"arabic":"كَانَ","translation":"ছিলো","audioUrl":"wbw/030_042_007.mp3","charTypeName":"word"},{"id":43223,"position":8,"arabic":"عَـٰقِبَةُ","translation":"( তাদের ) পরিণাম","audioUrl":"wbw/030_042_008.mp3","charTypeName":"word"},{"id":43224,"position":9,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/030_042_009.mp3","charTypeName":"word"},{"id":43225,"position":10,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/030_042_010.mp3","charTypeName":"word"},{"id":43226,"position":11,"arabic":"قَبْلُ ۚ","translation":"পূর্ব ( ছিলো )","audioUrl":"wbw/030_042_011.mp3","charTypeName":"word"},{"id":43228,"position":12,"arabic":"كَانَ","translation":"ছিলো","audioUrl":"wbw/030_042_013.mp3","charTypeName":"word"},{"id":43229,"positi