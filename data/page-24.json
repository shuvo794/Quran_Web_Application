{"id":24,"ayahs":[{"number":154,"arabic":"وَلَا تَقُولُوا۟ لِمَن يُقْتَلُ فِى سَبِيلِ ٱللَّهِ أَمْوَٰتٌۢ ۚ بَلْ أَحْيَآءٌۭ وَلَٰكِن لَّا تَشْعُرُونَ","translation":"And say not of those who are slain in God's cause, \"They are dead\": nay, they are alive, but you perceive it not.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/161.mp3","surahId":2,"words":[{"id":80931,"position":1,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/002_154_001.mp3","charTypeName":"word"},{"id":80932,"position":2,"arabic":"تَقُولُوا۟","translation":"তোমরা বলো","audioUrl":"wbw/002_154_002.mp3","charTypeName":"word"},{"id":80933,"position":3,"arabic":"لِمَن","translation":"(তাদের) যারা","audioUrl":"wbw/002_154_003.mp3","charTypeName":"word"},{"id":80934,"position":4,"arabic":"يُقْتَلُ","translation":"নিহত হয়","audioUrl":"wbw/002_154_004.mp3","charTypeName":"word"},{"id":80935,"position":5,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/002_154_005.mp3","charTypeName":"word"},{"id":80936,"position":6,"arabic":"سَبِيلِ","translation":"পথে","audioUrl":"wbw/002_154_006.mp3","charTypeName":"word"},{"id":80937,"position":7,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/002_154_007.mp3","charTypeName":"word"},{"id":80938,"position":8,"arabic":"أَمْوَٰتٌۢ ۚ","translation":"''মৃত","audioUrl":"wbw/002_154_008.mp3","charTypeName":"word"},{"id":80940,"position":9,"arabic":"بَلْ","translation":"বরং","audioUrl":"wbw/002_154_010.mp3","charTypeName":"word"},{"id":80941,"position":10,"arabic":"أَحْيَآءٌۭ","translation":"তারা জীবিত","audioUrl":"wbw/002_154_011.mp3","charTypeName":"word"},{"id":80942,"position":11,"arabic":"وَلَـٰكِن","translation":"কিন্তু","audioUrl":"wbw/002_154_012.mp3","charTypeName":"word"},{"id":80943,"position":12,"arabic":"لَّا","translation":"না","audioUrl":"wbw/002_154_013.mp3","charTypeName":"word"},{"id":80944,"position":13,"arabic":"تَشْعُرُونَ","translation":"তোমরা অনুভব কর","audioUrl":"wbw/002_154_014.mp3","charTypeName":"word"},{"id":80945,"position":14,"arabic":"١٥٤","translation":"(১৫৪)","audioUrl":null,"charTypeName":"end"}]},{"number":155,"arabic":"وَلَنَبْلُوَنَّكُم بِشَىْءٍۢ مِّنَ ٱلْخَوْفِ وَٱلْجُوعِ وَنَقْصٍۢ مِّنَ ٱلْأَمْوَٰلِ وَٱلْأَنفُسِ وَٱلثَّمَرَٰتِ ۗ وَبَشِّرِ ٱلصَّٰبِرِينَ","translation":"And most certainly shall We try you by means of danger, and hunger, and loss of worldly goods, of lives and of [labour's] fruits. But give glad tidings unto those who are patient in adversity","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/162.mp3","surahId":2,"words":[{"id":81072,"position":1,"arabic":"وَلَنَبْلُوَنَّكُم","translation":"এবং তোমাদের অবশ্যই পরীক্ষা করব আমরা","audioUrl":"wbw/002_155_001.mp3","charTypeName":"word"},{"id":81073,"position":2,"arabic":"بِشَىْءٍۢ","translation":"কিছু জিনিস দিয়ে","audioUrl":"wbw/002_155_002.mp3","charTypeName":"word"},{"id":81074,"position":3,"arabic":"مِّنَ","translation":"যেমন","audioUrl":"wbw/002_155_003.mp3","charTypeName":"word"},{"id":81075,"position":4,"arabic":"ٱلْخَوْفِ","translation":"ভয়","audioUrl":"wbw/002_155_004.mp3","charTypeName":"word"},{"id":81076,"position":5,"arabic":"وَٱلْجُوعِ","translation":"ও ক্ষুধা","audioUrl":"wbw/002_155_005.mp3","charTypeName":"word"},{"id":81077,"position":6,"arabic":"وَنَقْصٍۢ","translation":"ও ক্ষয়ক্ষতি","audioUrl":"wbw/002_155_006.mp3","charTypeName":"word"},{"id":81078,"position":7,"arabic":"مِّنَ","translation":"কিছু","audioUrl":"wbw/002_155_007.mp3","charTypeName":"word"},{"id":81079,"position":8,"arabic":"ٱلْأَمْوَٰلِ","translation":"ধনসম্পদের","audioUrl":"wbw/002_155_008.mp3","charTypeName":"word"},{"id":81080,"position":9,"arabic":"وَٱلْأَنفُسِ","translation":"ও জীবনের","audioUrl":"wbw/002_155_009.mp3","charTypeName":"word"},{"id":81081,"position":10,"arabic":"وَٱلثَّمَرَٰتِ ۗ","translation":"ও ফল ফসলাদির","audioUrl":"wbw/002_155_010.mp3","charTypeName":"word"},{"id":81083,"position":11,"arabic":"وَبَشِّرِ","translation":"এবং সুসংবাদ দাও","audioUrl":"wbw/002_155_012.mp3","charTypeName":"word"},{"id":81084,"position":12,"arabic":"ٱلصَّـٰبِرِينَ","translation":"(ঐসব) ধৈর্যশীলদের","audioUrl":"wbw/002_155_013.mp3","charTypeName":"word"},{"id":81085,"position":13,"arabic":"١٥٥","translation":"(১৫৫)","audioUrl":null,"charTypeName":"end"}]},{"number":156,"arabic":"ٱلَّذِينَ إِذَآ أَصَٰبَتْهُم مُّصِيبَةٌۭ قَالُوٓا۟ إِنَّا لِلَّهِ وَإِنَّآ إِلَيْهِ رَٰجِعُونَ","translation":"who, when calamity befalls them, say, \"Verily, unto God do we belong and, verily, unto Him we shall return.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/163.mp3","surahId":2,"words":[{"id":81203,"position":1,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/002_156_001.mp3","charTypeName":"word"},{"id":81204,"position":2,"arabic":"إِذَآ","translation":"যখন","audioUrl":"wbw/002_156_002.mp3","charTypeName":"word"},{"id":81205,"position":3,"arabic":"أَصَـٰبَتْهُم","translation":"তাদের উপর এসে পড়ে","audioUrl":"wbw/002_156_003.mp3","charTypeName":"word"},{"id":81206,"position":4,"arabic":"مُّصِيبَةٌۭ","translation":"কোনো বিপদ","audioUrl":"wbw/002_156_004.mp3","charTypeName":"word"},{"id":81207,"position":5,"arabic":"قَالُوٓا۟","translation":"(তখন) তারা বলে","audioUrl":"wbw/002_156_005.mp3","charTypeName":"word"},{"id":81208,"position":6,"arabic":"إِنَّا","translation":"''নিশ্চয়ই আমরা","audioUrl":"wbw/002_156_006.mp3","charTypeName":"word"},{"id":81209,"position":7,"arabic":"لِلَّهِ","translation":"আল্লাহরই জন্যে","audioUrl":"wbw/002_156_007.mp3","charTypeName":"word"},{"id":81210,"position":8,"arabic":"وَإِنَّآ","translation":"ও নিশ্চয়ই আমরা","audioUrl":"wbw/002_156_008.mp3","charTypeName":"word"},{"id":81211,"position":9,"arabic":"إِلَيْهِ","translation":"তাঁরই দিকে","audioUrl":"wbw/002_156_009.mp3","charTypeName":"word"},{"id":81212,"position":10,"arabic":"رَٰجِعُونَ","translation":"প্রত্যাবর্তনকারী''","audioUrl":"wbw/002_156_010.mp3","charTypeName":"word"},{"id":81213,"position":11,"arabic":"١٥٦","translation":"(১৫৬)","audioUrl":null,"charTypeName":"end"}]},{"number":157,"arabic":"أُو۟لَٰٓئِكَ عَلَيْهِمْ صَلَوَٰتٌۭ مِّن رَّبِّهِمْ وَرَحْمَةٌۭ ۖ وَأُو۟لَٰٓئِكَ هُمُ ٱلْمُهْتَدُونَ","translation":"It is they upon whom their Sustainer's blessings and grace are bestowed, and it is they, they who are on the right path!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/164.mp3","surahId":2,"words":[{"id":81338,"position":1,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐসব লোক","audioUrl":"wbw/002_157_001.mp3","charTypeName":"word"},{"id":81339,"position":2,"arabic":"عَلَيْهِمْ","translation":"তাদের উপর (রয়েছে)","audioUrl":"wbw/002_157_002.mp3","charTypeName":"word"},{"id":81340,"position":3,"arabic":"صَلَوَٰتٌۭ","translation":"বিপুল অনুগ্রহ","audioUrl":"wbw/002_157_003.mp3","charTypeName":"word"},{"id":81341,"position":4,"arabic":"مِّن","translation":"পক্ষ হতে","audioUrl":"wbw/002_157_004.mp3","charTypeName":"word"},{"id":81342,"position":5,"arabic":"رَّبِّهِمْ","translation":"তাদের রবের","audioUrl":"wbw/002_157_005.mp3","charTypeName":"word"},{"id":81343,"position":6,"arabic":"وَرَحْمَةٌۭ ۖ","translation":"এবং দয়া","audioUrl":"wbw/002_157_006.mp3","charTypeName":"word"},{"id":81345,"position":7,"arabic":"وَأُو۟لَـٰٓئِكَ","translation":"ঐসব লোক","audioUrl":"wbw/002_157_008.mp3","charTypeName":"word"},{"id":81346,"position":8,"arabic":"هُمُ","translation":"তারাই","audioUrl":"wbw/002_157_009.mp3","charTypeName":"word"},{"id":81347,"position":9,"arabic":"ٱلْمُهْتَدُونَ","translation":"সঠিক পথপ্রাপ্ত","audioUrl":"wbw/002_157_010.mp3","charTypeName":"word"},{"id":81348,"position":10,"arabic":"١٥٧","translation":"(১৫৭)","audioUrl":null,"charTypeName":"end"}]},{"number":158,"arabic":"۞ إِنَّ ٱلصَّفَا وَٱلْمَرْوَةَ مِن شَعَآئِرِ ٱللَّهِ ۖ فَمَنْ حَجَّ ٱلْبَيْتَ أَوِ ٱعْتَمَرَ فَلَا جُنَاحَ عَلَيْهِ أَن يَطَّوَّفَ بِهِمَا ۚ وَمَن تَطَوَّعَ خَيْرًۭا فَإِنَّ ٱللَّهَ شَاكِرٌ عَلِيمٌ","translation":"[Hence,] behold, As-Safa and Al-Marwah are among the symbols set up by God; and thus, no wrong does he who, having come to the Temple on pilgrimage or on a pious visit, strides to and fro between these two: for, if one does more good than he is bound to do-behold, God is responsive to gratitude, all-knowing.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/165.mp3","surahId":2,"words":[{"id":81540,"position":1,"arabic":"۞ إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/002_158_002.mp3","charTypeName":"word"},{"id":81541,"position":2,"arabic":"ٱلصَّفَا","translation":"সাফা","audioUrl":"wbw/002_158_003.mp3","charTypeName":"word"},{"id":81542,"position":3,"arabic":"وَٱلْمَرْوَةَ","translation":"ও মারওয়া","audioUrl":"wbw/002_158_004.mp3","charTypeName":"word"},{"id":81543,"position":4,"arabic":"مِن","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/002_158_005.mp3","charTypeName":"word"},{"id":81544,"position":5,"arabic":"شَعَآئِرِ","translation":"নিদর্শনসমূহের","audioUrl":"wbw/002_158_006.mp3","charTypeName":"word"},{"id":81545,"position":6,"arabic":"ٱللَّهِ ۖ","translation":"আল্লাহর","audioUrl":"wbw/002_158_007.mp3","charTypeName":"word"},{"id":81547,"position":7,"arabic":"فَمَنْ","translation":"সুতরাং যে","audioUrl":"wbw/002_158_009.mp3","charTypeName":"word"},{"id":81548,"position":8,"arabic":"حَجَّ","translation":"হজ্জ করবে","audioUrl":"wbw/002_158_010.mp3","charTypeName":"word"},{"id":81549,"position":9,"arabic":"ٱلْبَيْتَ","translation":"(কাবা) ঘরের","audioUrl":"wbw/002_158_011.mp3","charTypeName":"word"},{"id":81550,"position":10,"arabic":"أَوِ","translation":"বা","audioUrl":"wbw/002_158_012.mp3","charTypeName":"word"},{"id":81551,"position":11,"arabic":"ٱعْتَمَرَ","translation":"ওমরা করবে","audioUrl":"wbw/002_158_013.mp3","charTypeName":"word"},{"id":81552,"position":12,"arabic":"فَلَا","translation":"সেক্ষেত্রে নেই","audioUrl":"wbw/002_158_014.mp3","charTypeName":"word"},{"id":81553,"position":13,"arabic":"جُنَاحَ","translation":"কোনো পাপ","audioUrl":"wbw/002_158_015.mp3","charTypeName":"word"},{"id":81554,"position":14,"arabic":"عَلَيْهِ","translation":"তার জন্য","audioUrl":"wbw/002_158_016.mp3","charTypeName":"word"},{"id":81555,"position":15,"arabic":"أَن","translation":"যে","audioUrl":"wbw/002_158_017.mp3","charTypeName":"word"},{"id":81556,"position":16,"arabic":"يَطَّوَّفَ","translation":"সে প্রদক্ষিণ করবে","audioUrl":"wbw/002_158_018.mp3","charTypeName":"word"},{"id":81557,"position":17,"arabic":"بِهِمَا ۚ","translation":"তার দুইয়ের (মাঝে)","audioUrl":"wbw/002_158_019.mp3","charTypeName":"word"},{"id":81559,"position":18,"arabic":"وَمَن","translation":"আর যে কেউ","audioUrl":"wbw/002_158_021.mp3","charTypeName":"word"},{"id":81560,"position":19,"arabic":"تَطَوَّعَ","translation":"স্বেচ্ছায় করে","audioUrl":"wbw/002_158_022.mp3","charTypeName":"word"},{"id":81561,"position":20,"arabic":"خَيْرًۭا","translation":"কোনো কল্যাণ","audioUrl":"wbw/002_158_023.mp3","charTypeName":"word"},{"id":81562,"position":21,"arabic":"فَإِنَّ","translation":"নিশ্চয়ই তবে","audioUrl":"wbw/002_158_024.mp3","charTypeName":"word"},{"id":81563,"position":22,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/002_158_025.mp3","charTypeName":"word"},{"id":81564,"position":23,"arabic":"شَاكِرٌ","translation":"(তার) মূল্যদানকারী","audioUrl":"wbw/002_158_026.mp3","charTypeName":"word"},{"id":81565,"position":24,"arabic":"عَلِيمٌ","translation":"খুব অবহিত","audioUrl":"wbw/002_158_027.mp3","charTypeName":"word"},{"id":81566,"position":25,"arabic":"١٥٨","translation":"(১৫৮)","audioUrl":null,"charTypeName":"end"}]},{"number":159,"arabic":"إِنَّ ٱلَّذِينَ يَكْتُمُونَ مَآ أَنزَلْنَا مِنَ ٱلْبَيِّنَٰتِ وَٱلْهُدَىٰ مِنۢ بَعْدِ مَا بَيَّنَّٰهُ لِلنَّاسِ فِى ٱلْكِتَٰبِ ۙ أُو۟لَٰٓئِكَ يَلْعَنُهُمُ ٱللَّهُ وَيَلْعَنُهُمُ ٱللَّٰعِنُونَ","translation":"BEHOLD, as for those who suppress aught of the evidence of the truth and of the guidance which We have bestowed from on high, after We have made it clear unto mankind through the divine writ - these it is whom God will reject, and whom all who can judge will reject.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/166.mp3","surahId":2,"words":[{"id":81657,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/002_159_001.mp3","charTypeName":"word"},{"id":81658,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/002_159_002.mp3","charTypeName":"word"},{"id":81659,"position":3,"arabic":"يَكْتُمُونَ","translation":"গোপন করে","audioUrl":"wbw/002_159_003.mp3","charTypeName":"word"},{"id":81660,"position":4,"arabic":"مَآ","translation":"যা","audioUrl":"wbw/002_159_004.mp3","charTypeName":"word"},{"id":81661,"position":5,"arabic":"أَنزَلْنَا","translation":"আমরা অবতীর্ণ করেছি","audioUrl":"wbw/002_159_005.mp3","charTypeName":"word"},{"id":81662,"position":6,"arabic":"مِنَ","translation":"থেকে","audioUrl":"wbw/002_159_006.mp3","charTypeName":"word"},{"id":81663,"position":7,"arabic":"ٱلْبَيِّنَـٰتِ","translation":"স্পষ্ট নিদর্শনাদি","audioUrl":"wbw/002_159_007.mp3","charTypeName":"word"},{"id":81664,"position":8,"arabic":"وَٱلْهُدَىٰ","translation":"ও পথনির্দেশ","audioUrl":"wbw/002_159_008.mp3","charTypeName":"word"},{"id":81665,"position":9,"arabic":"مِنۢ","translation":"থেকে","audioUrl":"wbw/002_159_009.mp3","charTypeName":"word"},{"id":81666,"position":10,"arabic":"بَعْدِ","translation":"এর পরও","audioUrl":"wbw/002_159_010.mp3","charTypeName":"word"},{"id":81667,"position":11,"arabic":"مَا","translation":"যা","audioUrl":"wbw/002_159_011.mp3","charTypeName":"word"},{"id":81668,"position":12,"arabic":"بَيَّنَّـٰهُ","translation":"তা স্পষ্ট বর্ণনা করেছি আমরা","audioUrl":"wbw/002_159_012.mp3","charTypeName":"word"},{"id":81669,"position":13,"arabic":"لِلنَّاسِ","translation":"মানুষের জন্যে","audioUrl":"wbw/002_159_013.mp3","charTypeName":"word"},{"id":81670,"position":14,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/002_159_014.mp3","charTypeName":"word"},{"id":81671,"position":15,"arabic":"ٱلْكِتَـٰبِ ۙ","translation":"কিতাবের","audioUrl":"wbw/002_159_015.mp3","charTypeName":"word"},{"id":81673,"position":16,"arabic":"أُو۟لَـٰٓ