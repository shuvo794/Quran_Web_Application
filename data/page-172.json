{"id":172,"ayahs":[{"number":164,"arabic":"وَإِذْ قَالَتْ أُمَّةٌۭ مِّنْهُمْ لِمَ تَعِظُونَ قَوْمًا ۙ ٱللَّهُ مُهْلِكُهُمْ أَوْ مُعَذِّبُهُمْ عَذَابًۭا شَدِيدًۭا ۖ قَالُوا۟ مَعْذِرَةً إِلَىٰ رَبِّكُمْ وَلَعَلَّهُمْ يَتَّقُونَ","translation":"And whenever some people among them asked [those who tried to restrain the Sabbath-breakers], \"Why do you preach to people whom God is about to destroy or [at least] to chastise with suffering severe?\" -the pious ones would answer, \"In order to be free from blame before your Sustainer, and that these [transgressors, too,] might become conscious of Him.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1118.mp3","surahId":7,"words":[{"id":82280,"position":1,"arabic":"وَإِذْ","translation":"এবং যখন","audioUrl":"wbw/007_164_001.mp3","charTypeName":"word"},{"id":82281,"position":2,"arabic":"قَالَتْ","translation":"বলেছিলো","audioUrl":"wbw/007_164_002.mp3","charTypeName":"word"},{"id":82282,"position":3,"arabic":"أُمَّةٌۭ","translation":"একদল","audioUrl":"wbw/007_164_003.mp3","charTypeName":"word"},{"id":82283,"position":4,"arabic":"مِّنْهُمْ","translation":"মধ্যহতে তাদের","audioUrl":"wbw/007_164_004.mp3","charTypeName":"word"},{"id":82284,"position":5,"arabic":"لِمَ","translation":"\"কেন","audioUrl":"wbw/007_164_005.mp3","charTypeName":"word"},{"id":82285,"position":6,"arabic":"تَعِظُونَ","translation":"তোমরা সদুপদেশ দাও","audioUrl":"wbw/007_164_006.mp3","charTypeName":"word"},{"id":82286,"position":7,"arabic":"قَوْمًا ۙ","translation":"(এমন) সম্প্রদায়কে","audioUrl":"wbw/007_164_007.mp3","charTypeName":"word"},{"id":82288,"position":8,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/007_164_009.mp3","charTypeName":"word"},{"id":82289,"position":9,"arabic":"مُهْلِكُهُمْ","translation":"ধ্বংসকারী যাদের","audioUrl":"wbw/007_164_010.mp3","charTypeName":"word"},{"id":82290,"position":10,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/007_164_011.mp3","charTypeName":"word"},{"id":82291,"position":11,"arabic":"مُعَذِّبُهُمْ","translation":"শাস্তিদাতা তাদের","audioUrl":"wbw/007_164_012.mp3","charTypeName":"word"},{"id":82292,"position":12,"arabic":"عَذَابًۭا","translation":"শাস্তি","audioUrl":"wbw/007_164_013.mp3","charTypeName":"word"},{"id":82293,"position":13,"arabic":"شَدِيدًۭا ۖ","translation":"কঠোর\"","audioUrl":"wbw/007_164_014.mp3","charTypeName":"word"},{"id":82295,"position":14,"arabic":"قَالُوا۟","translation":"তারা বলেছিলো","audioUrl":"wbw/007_164_016.mp3","charTypeName":"word"},{"id":82296,"position":15,"arabic":"مَعْذِرَةً","translation":"\"অজুহাত পেশ(করার জন্যে)","audioUrl":"wbw/007_164_017.mp3","charTypeName":"word"},{"id":82297,"position":16,"arabic":"إِلَىٰ","translation":"কাছে","audioUrl":"wbw/007_164_018.mp3","charTypeName":"word"},{"id":82298,"position":17,"arabic":"رَبِّكُمْ","translation":"তোমাদের রবের","audioUrl":"wbw/007_164_019.mp3","charTypeName":"word"},{"id":82299,"position":18,"arabic":"وَلَعَلَّهُمْ","translation":"ও যাতে তারা","audioUrl":"wbw/007_164_020.mp3","charTypeName":"word"},{"id":82300,"position":19,"arabic":"يَتَّقُونَ","translation":"সংযত হয়\"","audioUrl":"wbw/007_164_021.mp3","charTypeName":"word"},{"id":82301,"position":20,"arabic":"١٦٤","translation":"(১৬৪)","audioUrl":null,"charTypeName":"end"}]},{"number":165,"arabic":"فَلَمَّا نَسُوا۟ مَا ذُكِّرُوا۟ بِهِۦٓ أَنجَيْنَا ٱلَّذِينَ يَنْهَوْنَ عَنِ ٱلسُّوٓءِ وَأَخَذْنَا ٱلَّذِينَ ظَلَمُوا۟ بِعَذَابٍۭ بَـِٔيسٍۭ بِمَا كَانُوا۟ يَفْسُقُونَ","translation":"And thereupon, when those [sinners] had forgotten all that they had been told to take to. heart, We saved those who had tried to prevent the doing of evil, and overwhelmed those who had been bent on evildoing with dreadful suffering for all their iniquity;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1119.mp3","surahId":7,"words":[{"id":82350,"position":1,"arabic":"فَلَمَّا","translation":"অতঃপর যখন","audioUrl":"wbw/007_165_001.mp3","charTypeName":"word"},{"id":82351,"position":2,"arabic":"نَسُوا۟","translation":"তারা ভুলে গেলো","audioUrl":"wbw/007_165_002.mp3","charTypeName":"word"},{"id":82352,"position":3,"arabic":"مَا","translation":"যা","audioUrl":"wbw/007_165_003.mp3","charTypeName":"word"},{"id":82353,"position":4,"arabic":"ذُكِّرُوا۟","translation":"তাদের উপদেশ দেয়া হয়েছিলো","audioUrl":"wbw/007_165_004.mp3","charTypeName":"word"},{"id":82354,"position":5,"arabic":"بِهِۦٓ","translation":"সম্বন্ধে সে","audioUrl":"wbw/007_165_005.mp3","charTypeName":"word"},{"id":82355,"position":6,"arabic":"أَنجَيْنَا","translation":"উদ্ধার করলাম আমরা","audioUrl":"wbw/007_165_006.mp3","charTypeName":"word"},{"id":82356,"position":7,"arabic":"ٱلَّذِينَ","translation":"(তাদেরকে) যারা","audioUrl":"wbw/007_165_007.mp3","charTypeName":"word"},{"id":82357,"position":8,"arabic":"يَنْهَوْنَ","translation":"বিরত ছিলো","audioUrl":"wbw/007_165_008.mp3","charTypeName":"word"},{"id":82358,"position":9,"arabic":"عَنِ","translation":"হতে","audioUrl":"wbw/007_165_009.mp3","charTypeName":"word"},{"id":82359,"position":10,"arabic":"ٱلسُّوٓءِ","translation":"মন্দ","audioUrl":"wbw/007_165_010.mp3","charTypeName":"word"},{"id":82360,"position":11,"arabic":"وَأَخَذْنَا","translation":"ও ধরলাম আমরা (তাদেরকে)","audioUrl":"wbw/007_165_011.mp3","charTypeName":"word"},{"id":82361,"position":12,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/007_165_012.mp3","charTypeName":"word"},{"id":82362,"position":13,"arabic":"ظَلَمُوا۟","translation":"সীমালঙ্ঘন করেছিলো","audioUrl":"wbw/007_165_013.mp3","charTypeName":"word"},{"id":82363,"position":14,"arabic":"بِعَذَابٍۭ","translation":"দিয়ে শাস্তি","audioUrl":"wbw/007_165_014.mp3","charTypeName":"word"},{"id":82364,"position":15,"arabic":"بَـِٔيسٍۭ","translation":"ভয়ানক","audioUrl":"wbw/007_165_015.mp3","charTypeName":"word"},{"id":82365,"position":16,"arabic":"بِمَا","translation":"এ কারণে যা","audioUrl":"wbw/007_165_016.mp3","charTypeName":"word"},{"id":82366,"position":17,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/007_165_017.mp3","charTypeName":"word"},{"id":82367,"position":18,"arabic":"يَفْسُقُونَ","translation":"তারা অবাধ্যতা করতে","audioUrl":"wbw/007_165_018.mp3","charTypeName":"word"},{"id":82368,"position":19,"arabic":"١٦٥","translation":"(১৬৫)","audioUrl":null,"charTypeName":"end"}]},{"number":166,"arabic":"فَلَمَّا عَتَوْا۟ عَن مَّا نُهُوا۟ عَنْهُ قُلْنَا لَهُمْ كُونُوا۟ قِرَدَةً خَٰسِـِٔينَ","translation":"and then, when they disdainfully persisted in doing what they had been forbidden to do, We said unto them: \"Be as apes despicable!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1120.mp3","surahId":7,"words":[{"id":82493,"position":1,"arabic":"فَلَمَّا","translation":"অতঃপর যখন","audioUrl":"wbw/007_166_001.mp3","charTypeName":"word"},{"id":82494,"position":2,"arabic":"عَتَوْا۟","translation":"তারা ঔদ্ধত্য প্রদর্শন করলো","audioUrl":"wbw/007_166_002.mp3","charTypeName":"word"},{"id":82495,"position":3,"arabic":"عَن","translation":"(তা) হতে","audioUrl":"wbw/007_166_003.mp3","charTypeName":"word"},{"id":82496,"position":4,"arabic":"مَّا","translation":"যা","audioUrl":"wbw/007_166_004.mp3","charTypeName":"word"},{"id":82497,"position":5,"arabic":"نُهُوا۟","translation":"তাদেরকে নিষেধ করা হয়েছিলো","audioUrl":"wbw/007_166_005.mp3","charTypeName":"word"},{"id":82498,"position":6,"arabic":"عَنْهُ","translation":"থেকে তা","audioUrl":"wbw/007_166_006.mp3","charTypeName":"word"},{"id":82499,"position":7,"arabic":"قُلْنَا","translation":"আমরা বললাম","audioUrl":"wbw/007_166_007.mp3","charTypeName":"word"},{"id":82500,"position":8,"arabic":"لَهُمْ","translation":"উদ্দেশ্যে তাদের","audioUrl":"wbw/007_166_008.mp3","charTypeName":"word"},{"id":82501,"position":9,"arabic":"كُونُوا۟","translation":"\"তোমরা হও","audioUrl":"wbw/007_166_009.mp3","charTypeName":"word"},{"id":82502,"position":10,"arabic":"قِرَدَةً","translation":"বানর","audioUrl":"wbw/007_166_010.mp3","charTypeName":"word"},{"id":82503,"position":11,"arabic":"خَـٰسِـِٔينَ","translation":"ঘৃণিত\"","audioUrl":"wbw/007_166_011.mp3","charTypeName":"word"},{"id":82504,"position":12,"arabic":"١٦٦","translation":"(১৬৬)","audioUrl":null,"charTypeName":"end"}]},{"number":167,"arabic":"وَإِذْ تَأَذَّنَ رَبُّكَ لَيَبْعَثَنَّ عَلَيْهِمْ إِلَىٰ يَوْمِ ٱلْقِيَٰمَةِ مَن يَسُومُهُمْ سُوٓءَ ٱلْعَذَابِ ۗ إِنَّ رَبَّكَ لَسَرِيعُ ٱلْعِقَابِ ۖ وَإِنَّهُۥ لَغَفُورٌۭ رَّحِيمٌۭ","translation":"And lo! Thy Sustainer made it known that most certainly He would rouse against them, unto Resurrection Day, people who would afflict them with cruel suffering: verily, thy Sustainer is swift in retribution - yet, verily, He is [also] much-forgiving, a dispenser of grace.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1121.mp3","surahId":7,"words":[{"id":82547,"position":1,"arabic":"وَإِذْ","translation":"ও স্মরণ করো","audioUrl":"wbw/007_167_001.mp3","charTypeName":"word"},{"id":82548,"position":2,"arabic":"تَأَذَّنَ","translation":"ঘোষণা দেন","audioUrl":"wbw/007_167_002.mp3","charTypeName":"word"},{"id":82549,"position":3,"arabic":"رَبُّكَ","translation":"তোমার রব","audioUrl":"wbw/007_167_003.mp3","charTypeName":"word"},{"id":82550,"position":4,"arabic":"لَيَبْعَثَنَّ","translation":"অবশ্যই তিনি পাঠাবেন","audioUrl":"wbw/007_167_004.mp3","charTypeName":"word"},{"id":82551,"position":5,"arabic":"عَلَيْهِمْ","translation":"উপর তাদের","audioUrl":"wbw/007_167_005.mp3","charTypeName":"word"},{"id":82552,"position":6,"arabic":"إِلَىٰ","translation":"পর্যন্ত","audioUrl":"wbw/007_167_006.mp3","charTypeName":"word"},{"id":82553,"position":7,"arabic":"يَوْمِ","translation":"দিন","audioUrl":"wbw/007_167_007.mp3","charTypeName":"word"},{"id":82554,"position":8,"arabic":"ٱلْقِيَـٰمَةِ","translation":"ক্বিয়ামাতের","audioUrl":"wbw/007_167_008.mp3","charTypeName":"word"},{"id":82555,"position":9,"arabic":"مَن","translation":"(এমন লোকদের) যারা","audioUrl":"wbw/007_167_009.mp3","charTypeName":"word"},{"id":82556,"position":10,"arabic":"يَسُومُهُمْ","translation":"কষ্ট দিবে তাদেরকে","audioUrl":"wbw/007_167_010.mp3","charTypeName":"word"},{"id":82557,"position":11,"arabic":"سُوٓءَ","translation":"নিকৃষ্ট","audioUrl":"wbw/007_167_011.mp3","charTypeName":"word"},{"id":82558,"position":12,"arabic":"ٱلْعَذَابِ ۗ","translation":"শাস্তি (দিয়ে)","audioUrl":"wbw/007_167_012.mp3","charTypeName":"word"},{"id":82560,"position":13,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/007_167_014.mp3","charTypeName":"word"},{"id":82561,"position":14,"arabic":"رَبَّكَ","translation":"তোমার রব","audioUrl":"wbw/007_167_015.mp3","charTypeName":"word"},{"id":82562,"position":15,"arabic":"لَسَرِيعُ","translation":"অবশ্যই দ্রুত","audioUrl":"wbw/007_167_016.mp3","charTypeName":"word"},{"id":82563,"position":16,"arabic":"ٱلْعِقَابِ ۖ","translation":"দন্ডদানে","audioUrl":"wbw/007_167_017.mp3","charTypeName":"word"},{"id":82565,"position":17,"arabic":"وَإِنَّهُۥ","translation":"এবং নিশ্চয়ই তিনি","audioUrl":"wbw/007_167_019.mp3","charTypeName":"word"},{"id":82566,"position":18,"arabic":"لَغَفُورٌۭ","translation":"অবশ্যই ক্ষমাশীলও","audioUrl":"wbw/007_167_020.mp3","charTypeName":"word"},{"id":82567,"position":19,"arabic":"رَّحِيمٌۭ","translation":"পরম দয়ালু","audioUrl":"wbw/007_167_021.mp3","charTypeName":"word"},{"id":82568,"position":20,"arabic":"١٦٧","translation":"(১৬৭)","audioUrl":null,"charTypeName":"end"}]},{"number":168,"arabic":"وَقَطَّعْنَٰهُمْ فِى ٱلْأَرْضِ أُمَمًۭا ۖ مِّنْهُمُ ٱلصَّٰلِحُونَ وَمِنْهُمْ دُونَ ذَٰلِكَ ۖ وَبَلَوْنَٰهُم بِٱلْحَسَنَٰتِ وَٱلسَّيِّـَٔاتِ لَعَلَّهُمْ يَرْجِعُونَ","translation":"And We dispersed them as [separate] communities all over the earth; some of them were righteous, and some of them less than that: and the latter We tried with blessings as well as with afflictions, so that they might mend their ways.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1122.mp3","surahId":7,"words":[{"id":82641,"position":1,"arabic":"وَقَطَّعْنَـٰهُمْ","translation":"এবং আমরা বিভক্ত করি তাদের","audioUrl":"wbw/007_168_001.mp3","charTypeName":"word"},{"id":82642,"position":2,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/007_168_002.mp3","charTypeName":"word"},{"id":82643,"position":3,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/007_168_003.mp3","charTypeName":"word"},{"id":82644,"position":4,"arabic":"أُمَمًۭا ۖ","translation":"(বিভিন্ন) দলে","audioUrl":"wbw/007_168_004.mp3","charTypeName":"word"},{"id":82646,"position":5,"arabic":"مِّنْهُمُ","translation":"কেউ তাদের (ছিলো)","audioUrl":"wbw/007_168_006.mp3","charTypeName":"word"},{"id":82647,"position":6,"arabic":"ٱلصَّـٰلِحُونَ","translation":"সৎকর্মশীল","audioUrl":"wbw/007_168_007.mp3","charTypeName":"word"},{"id":82648,"position":7,"arabic":"وَمِنْهُمْ","translation":"আবার কেউ তাদের (ছিলো)","audioUrl":"wbw/007_168_008.mp3","charTypeName":"word"},{"id":82649,"position":8,"arabic":"دُونَ","translation":"নয় এরূপ","audioUrl":"wbw/007_168_009.mp3","charTypeName":"word"},{"id":82650,"position":9,"arabic":"ذَٰلِكَ ۖ","translation":"তা","audioUrl":"wbw/007_168_010.mp3","charTypeName":"word"},{"id":82652,"position":10,"arabic":"وَبَلَوْنَـٰهُم","translation":"এবং আমরা পরীক্ষা করি তাদের","audioUrl":"wbw/007_168_012.mp3","charTypeName":"word"},{"id":82653,"position":11,"arabic":"بِٱلْحَسَنَـٰتِ","translation":"দিয়ে (অনেক) কল্যাণ","audioUrl":"wbw/007_168_013.mp3","charTypeName":"word"},{"id":82654,"position":12,"arabic":"وَٱلسَّيِّـَٔاتِ","translation":"ও অমঙ্গলসমূহ (দিয়েও)","audioUrl":"wbw/007_168_014.mp3","charTypeName":"word"},{"id":82655,"position":13,"arabic":"لَعَلَّهُمْ","translation":"যাতে তারা","audioUrl":"wbw/007_168_015.mp3","charTypeName":"word"},{"id":82656,"position":14,"arabic":"يَرْجِعُونَ","translation":"ফিরে আসে","audioUrl":"wbw/007_168_016.mp3","charTypeName":"word"},{"id":82657,"position":15,"arabic":"١٦٨","translation":"(১৬৮)","audioUrl":null,"charTypeName":"end"}]},{"number":169,"arabic":"فَخَلَفَ مِنۢ بَعْدِهِمْ خَلْفٌۭ وَرِثُوا۟ ٱلْكِتَٰبَ يَأْخُذُونَ عَرَضَ هَٰذَا ٱلْأَدْنَىٰ وَيَقُولُونَ سَيُغْفَرُ لَنَا وَإِن يَأْتِهِمْ عَرَضٌۭ مِّثْلُهُۥ يَأْخُذُوهُ ۚ أَلَمْ يُؤْخَذْ عَلَيْهِم مِّيثَٰقُ ٱلْكِتَٰبِ أَن لَّا يَقُولُوا۟ عَلَى ٱللَّهِ إِلَّا ٱلْحَقَّ وَدَرَسُوا۟ مَا فِيهِ ۗ وَٱلدَّارُ ٱلْءَاخِرَةُ خَيْرٌۭ لِّلَّذِينَ يَتَّقُونَ ۗ أَفَلَا تَعْقِلُونَ","translation":"And they have been succeeded by [new] generations who - [in spite of] having inherited the divine writ-clutch but at the fleeting good of this lower world and say, \"We shall be forgiven, the while they are ready, if another such fleeting good should come their way, to clutch at it [and sin again]. Have they not been solemnly pledged through the divine writ not to attribute unto God aught but what is true, and [have they not] read again and again all that is therein? Since the life in the hereafter is the better [of the two] for all who are conscious of God -will you not, then, use your reason?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1123.mp3","surahId":7,"words":[{"id":82764,"position":1,"arabic":"فَخَلَفَ","translation":"অতঃপর স্থলাভিষিক্ত হলো","audioUrl":"wbw/007_169_001.mp3","charTypeName":"word"},{"id":82765,"position":2,"arabic":"مِنۢ","translation":"থেকে","audioUrl":"wbw/007_169_002.mp3","charTypeName":"word"},{"id":82766,"position":3,"arabic":"بَعْدِهِمْ","translation":"পর তাদের","audioUrl":"wbw/007_169_003.mp3","charTypeName":"word"},{"id":82767,"position":4,"arabic":"خَلْفٌۭ","translation":"(অযোগ্য) উত্তরপুরুষরা","audioUrl":"wbw/007_169_004.mp3","charTypeName":"word"},{"id":82768,"position":5,"arabic":"وَرِثُوا۟","translation":"(যারা) উত্তরাধিকারী হয়েছিলো","audioUrl":"wbw/007_169_005.mp3","charTypeName":"word"},{"id":82769,"position":6,"arabic":"ٱلْكِتَـٰبَ","translation":"কিতাবের","audioUrl":"wbw/007_169_006.mp3","charTypeName":"word"},{"id":82770,"position":7,"arabic":"يَأْخُذُونَ","translation":"তারা গ্রহণ করে","audioUrl":"wbw/007_169_007.mp3","charTypeName":"word"},{"id":82771,"position":8,"arabic":"عَرَضَ","translation":"জীবন সামগ্রীকে","audioUrl":"wbw/007_169_008.mp3","charTypeName":"word"},{"id":82772,"position":9,"arabic":"هَـٰذَا","translation":"এই","audioUrl":"wbw/007_169_009.mp3","charTypeName":"word"},{"id":82773,"position":10,"arabic":"ٱلْأَدْنَىٰ","translation":"(দুনিয়ার) তুচ্ছ","audioUrl":"wbw/007_169_010.mp3","charTypeName":"word"},{"id":82774,"position":11,"arabic":"وَيَقُولُونَ","translation":"ও তারা বলে","audioUrl":"wbw/007_169_011.mp3","charTypeName":"word"},{"id":82775,"position":12,"arabic":"سَيُغْفَرُ","translation":"\"ক্ষমা করে দেয়া হবে\"","audioUrl":"wbw/007_169_012.mp3","charTypeName":"word"},{"id":82776,"position":13,"arabic":"لَنَا","translation":"\"আমাদেরকে\"","audioUrl":"wbw/007_169_013.mp3","charTypeName":"word"},{"id":82777,"position":14,"arabic":"وَإِن","translation":"এবং (আবারও) যদি","audioUrl":"wbw/007_169_014.mp3","charTypeName":"word"},{"id":82778,"position":15,"arabic":"يَأْتِهِمْ","translation":"কাছে আসে তাদের","audioUrl":"wbw/007_169_015.mp3","charTypeName":"word"},{"id":82779,"position":16,"arabic":"عَرَضٌۭ","translation":"জীবন সামগ্রী","audioUrl":"wbw/007_169_016.mp3","charTypeName":"word"},{"id":82780,"position":17,"arabic":"مِّثْلُهُۥ","translation":"অনুরূপ তার","audioUrl":"wbw/007_169_017.mp3","charTypeName":"word"},{"id":82781,"position":18,"arabic":"يَأْخُذُوهُ ۚ","translation":"তারা গ্রহণ করে তা","audioUrl":"wbw/007_169_018.mp3","charTypeName":"word"},{"id":82783,"position":19,"arabic":"أَلَمْ","translation":"কি নি","audioUrl":"wbw/007_169_020.mp3","charTypeName":"word"},{"id":82784,"position":20,"arabic":"يُؤْخَذْ","translation":"গ্রহন করা হয়","audioUrl":"wbw/007_169_021.mp3","charTypeName":"word"},{"id":82785,"position":21,"arabic":"عَلَيْهِم","translation":"থেকে তাদের","audioUrl":"wbw/007_169_022.mp3","charTypeName":"word"},{"id":82786,"position":22,"arabic":"مِّيثَـٰقُ","translation":"প্রতিশ্রুতি","audioUrl":"wbw/007_169_023.mp3","charTypeName":"word"},{"id":82787,"position":23,"arabic":"ٱلْكِتَـٰبِ","translation":"কিতাবের","audioUrl":"wbw/007_169_024.mp3","charTypeName":"word"},{"id":82788,"position"