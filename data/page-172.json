TypeName":"word"},{"id":82806,"position":40,"arabic":"تَعْقِلُونَ","translation":"তোমরা বুঝো","audioUrl":"wbw/007_169_043.mp3","charTypeName":"word"},{"id":82807,"position":41,"arabic":"١٦٩","translation":"(১৬৯)","audioUrl":null,"charTypeName":"end"}]},{"number":170,"arabic":"وَٱلَّذِينَ يُمَسِّكُونَ بِٱلْكِتَٰبِ وَأَقَامُوا۟ ٱلصَّلَوٰةَ إِنَّا لَا نُضِيعُ أَجْرَ ٱلْمُصْلِحِينَ","translation":"For [We shall requite] all those who hold fast to the divine writ and are constant in prayer: verily, We shall not fail to requite those who enjoin the doing of what is right!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1124.mp3","surahId":7,"words":[{"id":82808,"position":1,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/007_170_001.mp3","charTypeName":"word"},{"id":82809,"position":2,"arabic":"يُمَسِّكُونَ","translation":"আঁকড়ে থাকে","audioUrl":"wbw/007_170_002.mp3","charTypeName":"word"},{"id":82810,"position":3,"arabic":"بِٱلْكِتَـٰبِ","translation":"নিয়ে কিতাব","audioUrl":"wbw/007_170_003.mp3","charTypeName":"word"},{"id":82811,"position":4,"arabic":"وَأَقَامُوا۟","translation":"ও প্রতিষ্ঠা করে","audioUrl":"wbw/007_170_004.mp3","charTypeName":"word"},{"id":82812,"position":5,"arabic":"ٱلصَّلَوٰةَ","translation":"সালাতকে","audioUrl":"wbw/007_170_005.mp3","charTypeName":"word"},{"id":82813,"position":6,"arabic":"إِنَّا","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/007_170_006.mp3","charTypeName":"word"},{"id":82814,"position":7,"arabic":"لَا","translation":"না","audioUrl":"wbw/007_170_007.mp3","charTypeName":"word"},{"id":82815,"position":8,"arabic":"نُضِيعُ","translation":"আমরা নষ্ট করি","audioUrl":"wbw/007_170_008.mp3","charTypeName":"word"},{"id":82816,"position":9,"arabic":"أَجْرَ","translation":"প্রতিফল","audioUrl":"wbw/007_170_009.mp3","charTypeName":"word"},{"id":82817,"position":10,"arabic":"ٱلْمُصْلِحِينَ","translation":"সৎকর্মশীলদের","audioUrl":"wbw/007_170_010.mp3","charTypeName":"word"},{"id":82818,"position":11,"arabic":"١