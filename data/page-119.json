يدَنَّ كَثِيرًۭا مِّنْهُم مَّآ أُنزِلَ إِلَيْكَ مِن رَّبِّكَ طُغْيَٰنًۭا وَكُفْرًۭا ۖ فَلَا تَأْسَ عَلَى ٱلْقَوْمِ ٱلْكَٰفِرِينَ","translation":"Say: \"O followers of the Bible! You have no valid ground for your beliefs -unless you [truly] observe the Torah and the Gospel, and all that has been bestowed from on high upon you by your Sustainer!\" Yet all that has been bestowed from on high upon thee [O Prophet] by thy Sustainer is bound to make many of them yet more stubborn in their overweening arrogance and in their denial of the truth. But sorrow not over people who deny the truth:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/737.mp3","surahId":5,"words":[{"id":58655,"position":1,"arabic":"قُلْ","translation":"বল","audioUrl":"wbw/005_068_001.mp3","charTypeName":"word"},{"id":58656,"position":2,"arabic":"يَـٰٓأَهْلَ","translation":"\"হে অধিকারীরা","audioUrl":"wbw/005_068_002.mp3","charTypeName":"word"},{"id":58657,"position":3,"arabic":"ٱلْكِتَـٰبِ","translation":"কিতাবের","audioUrl":"wbw/005_068_003.mp3","charTypeName":"word"},{"id":58658,"position":4,"arabic":"لَسْتُمْ","translation":"নও তোমরা","audioUrl":"wbw/005_068_004.mp3","charTypeName":"word"},{"id":58659,"position":5,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/005_068_005.mp3","charTypeName":"word"},{"id":58660,"position":6,"arabic":"شَىْءٍ","translation":"কোনো কিছুর (দন্ডায়মান)","audioUrl":"wbw/005_068_006.mp3","charTypeName":"word"},{"id":58661,"position":7,"arabic":"حَتَّىٰ","translation":"যতক্ষণ না","audioUrl":"wbw/005_068_007.mp3","charTypeName":"word"},{"id":58662,"position":8,"arabic":"تُقِيمُوا۟","translation":"তোমরা প্রতিষ্ঠিত করো","audioUrl":"wbw/005_068_008.mp3","charTypeName":"word"},{"id":58663,"position":9,"arabic":"ٱلتَّوْرَىٰةَ","translation":"তাওরাত","audioUrl":"wbw/005_068_009.mp3","charTypeName":"word"},{"id":58664,"position":10,"arabic":"وَٱلْإِنجِيلَ","translation":"ও ইনজীল","audioUrl":"wbw/005_068_010.mp3","charTypeName":"word"},{"id":58665,"position":