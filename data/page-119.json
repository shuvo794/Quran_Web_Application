{"id":119,"ayahs":[{"number":65,"arabic":"وَلَوْ أَنَّ أَهْلَ ٱلْكِتَٰبِ ءَامَنُوا۟ وَٱتَّقَوْا۟ لَكَفَّرْنَا عَنْهُمْ سَيِّـَٔاتِهِمْ وَلَأَدْخَلْنَٰهُمْ جَنَّٰتِ ٱلنَّعِيمِ","translation":"If the followers of the Bible would but attain to [true] faith and God-consciousness, We should indeed efface their [previous] bad deeds, and indeed bring them into gardens of bliss;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/734.mp3","surahId":5,"words":[{"id":57375,"position":1,"arabic":"وَلَوْ","translation":"এবং যদি","audioUrl":"wbw/005_065_001.mp3","charTypeName":"word"},{"id":57376,"position":2,"arabic":"أَنَّ","translation":"(এমন হতো) যে","audioUrl":"wbw/005_065_002.mp3","charTypeName":"word"},{"id":57377,"position":3,"arabic":"أَهْلَ","translation":"অধিকারীরা","audioUrl":"wbw/005_065_003.mp3","charTypeName":"word"},{"id":57378,"position":4,"arabic":"ٱلْكِتَـٰبِ","translation":"কিতাবের","audioUrl":"wbw/005_065_004.mp3","charTypeName":"word"},{"id":57379,"position":5,"arabic":"ءَامَنُوا۟","translation":"ঈমান আনতো","audioUrl":"wbw/005_065_005.mp3","charTypeName":"word"},{"id":57380,"position":6,"arabic":"وَٱتَّقَوْا۟","translation":"এবং তারা ভয় করতো","audioUrl":"wbw/005_065_006.mp3","charTypeName":"word"},{"id":57381,"position":7,"arabic":"لَكَفَّرْنَا","translation":"অবশ্যই আমরা মুছে দিতাম","audioUrl":"wbw/005_065_007.mp3","charTypeName":"word"},{"id":57382,"position":8,"arabic":"عَنْهُمْ","translation":"থেকে তাদের","audioUrl":"wbw/005_065_008.mp3","charTypeName":"word"},{"id":57383,"position":9,"arabic":"سَيِّـَٔاتِهِمْ","translation":"দোষগুলো তাদের","audioUrl":"wbw/005_065_009.mp3","charTypeName":"word"},{"id":57384,"position":10,"arabic":"وَلَأَدْخَلْنَـٰهُمْ","translation":"এবং অবশ্যই আমরা প্রবেশ করাতাম তাদের","audioUrl":"wbw/005_065_010.mp3","charTypeName":"word"},{"id":57385,"position":11,"arabic":"جَنَّـٰتِ","translation":"জান্নাতে","audioUrl":"wbw/005_065_011.mp3","charTypeName":"word"},{"id":57386,"position":12,"arabic":"ٱلنَّعِيمِ","translation":"সুখকর","audioUrl":"wbw/005_065_012.mp3","charTypeName":"word"},{"id":57387,"position":13,"arabic":"٦٥","translation":"(৬৫)","audioUrl":null,"charTypeName":"end"}]},{"number":66,"arabic":"وَلَوْ أَنَّهُمْ أَقَامُوا۟ ٱلتَّوْرَىٰةَ وَٱلْإِنجِيلَ وَمَآ أُنزِلَ إِلَيْهِم مِّن رَّبِّهِمْ لَأَكَلُوا۟ مِن فَوْقِهِمْ وَمِن تَحْتِ أَرْجُلِهِم ۚ مِّنْهُمْ أُمَّةٌۭ مُّقْتَصِدَةٌۭ ۖ وَكَثِيرٌۭ مِّنْهُمْ سَآءَ مَا يَعْمَلُونَ","translation":"and if they would but truly observe the Torah and the Gospel and all [the revelation] that has been bestowed from on high upon them by their Sustainer, they would indeed partake of all the blessings of heaven and earth. Some of them do pursue a right course; but as for most of them -vile indeed is what they do!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/735.mp3","surahId":5,"words":[{"id":57770,"position":1,"arabic":"وَلَوْ","translation":"এবং যদি","audioUrl":"wbw/005_066_001.mp3","charTypeName":"word"},{"id":57771,"position":2,"arabic":"أَنَّهُمْ","translation":"যে তারা","audioUrl":"wbw/005_066_002.mp3","charTypeName":"word"},{"id":57772,"position":3,"arabic":"أَقَامُوا۟","translation":"প্রতিষ্ঠা করতো","audioUrl":"wbw/005_066_003.mp3","charTypeName":"word"},{"id":57773,"position":4,"arabic":"ٱلتَّوْرَىٰةَ","translation":"তাওরাত","audioUrl":"wbw/005_066_004.mp3","charTypeName":"word"},{"id":57774,"position":5,"arabic":"وَٱلْإِنجِيلَ","translation":"ও ইনজীল","audioUrl":"wbw/005_066_005.mp3","charTypeName":"word"},{"id":57775,"position":6,"arabic":"وَمَآ","translation":"এবং যা","audioUrl":"wbw/005_066_006.mp3","charTypeName":"word"},{"id":57776,"position":7,"arabic":"أُنزِلَ","translation":"অবতীর্ণ করা হয়েছে","audioUrl":"wbw/005_066_007.mp3","charTypeName":"word"},{"id":57777,"position":8,"arabic":"إِلَيْهِم","translation":"প্রতি তাদের","audioUrl":"wbw/005_066_008.mp3","charTypeName":"word"},{"id":57778,"position":9,"arabic":"مِّن","translation":"পক্ষ হতে","audioUrl":"wbw/005_066_009.mp3","charTypeName":"word"},{"id":57779,"position":10,"arabic":"رَّبِّهِمْ","translation":"তাদের রবের","audioUrl":"wbw/005_066_010.mp3","charTypeName":"word"},{"id":57780,"position":11,"arabic":"لَأَكَلُوا۟","translation":"অবশ্যই তারা খাবার পেতো","audioUrl":"wbw/005_066_011.mp3","charTypeName":"word"},{"id":57781,"position":12,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/005_066_012.mp3","charTypeName":"word"},{"id":57782,"position":13,"arabic":"فَوْقِهِمْ","translation":"উপর তাদের","audioUrl":"wbw/005_066_013.mp3","charTypeName":"word"},{"id":57783,"position":14,"arabic":"وَمِن","translation":"ও থেকে","audioUrl":"wbw/005_066_014.mp3","charTypeName":"word"},{"id":57784,"position":15,"arabic":"تَحْتِ","translation":"নিচ","audioUrl":"wbw/005_066_015.mp3","charTypeName":"word"},{"id":57785,"position":16,"arabic":"أَرْجُلِهِم ۚ","translation":"পায়ের তাদের","audioUrl":"wbw/005_066_016.mp3","charTypeName":"word"},{"id":57787,"position":17,"arabic":"مِّنْهُمْ","translation":"মধ্য থেকে তাদের","audioUrl":"wbw/005_066_018.mp3","charTypeName":"word"},{"id":57788,"position":18,"arabic":"أُمَّةٌۭ","translation":"একদল (আছে)","audioUrl":"wbw/005_066_019.mp3","charTypeName":"word"},{"id":57789,"position":19,"arabic":"مُّقْتَصِدَةٌۭ ۖ","translation":"সত্যপন্থী","audioUrl":"wbw/005_066_020.mp3","charTypeName":"word"},{"id":57791,"position":20,"arabic":"وَكَثِيرٌۭ","translation":"কিন্তু অধিকাংশই","audioUrl":"wbw/005_066_022.mp3","charTypeName":"word"},{"id":57792,"position":21,"arabic":"مِّنْهُمْ","translation":"মধ্য থেকে তাদের","audioUrl":"wbw/005_066_023.mp3","charTypeName":"word"},{"id":57793,"position":22,"arabic":"سَآءَ","translation":"নিকৃষ্ট","audioUrl":"wbw/005_066_024.mp3","charTypeName":"word"},{"id":57794,"position":23,"arabic":"مَا","translation":"যা","audioUrl":"wbw/005_066_025.mp3","charTypeName":"word"},{"id":57795,"position":24,"arabic":"يَعْمَلُونَ","translation":"তারা কাজ করছে","audioUrl":"wbw/005_066_026.mp3","charTypeName":"word"},{"id":57796,"position":25,"arabic":"٦٦","translation":"(৬৬)","audioUrl":null,"charTypeName":"end"}]},{"number":67,"arabic":"۞ يَٰٓأَيُّهَا ٱلرَّسُولُ بَلِّغْ مَآ أُنزِلَ إِلَيْكَ مِن رَّبِّكَ ۖ وَإِن لَّمْ تَفْعَلْ فَمَا بَلَّغْتَ رِسَالَتَهُۥ ۚ وَٱللَّهُ يَعْصِمُكَ مِنَ ٱلنَّاسِ ۗ إِنَّ ٱللَّهَ لَا يَهْدِى ٱلْقَوْمَ ٱلْكَٰفِرِينَ","translation":"O APOSTLE! Announce all that has been bestowed from on high upon thee by thy Sustainer: for unless thou doest it fully, thou wilt not have delivered His message [at all]. And God will protect thee from [unbelieving] men: behold, God does not guide people who refuse to acknowledge the truth.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/736.mp3","surahId":5,"words":[{"id":58263,"position":1,"arabic":"۞ يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/005_067_002.mp3","charTypeName":"word"},{"id":58264,"position":2,"arabic":"ٱلرَّسُولُ","translation":"রাসূল","audioUrl":"wbw/005_067_003.mp3","charTypeName":"word"},{"id":58265,"position":3,"arabic":"بَلِّغْ","translation":"প্রচার করো","audioUrl":"wbw/005_067_004.mp3","charTypeName":"word"},{"id":58266,"position":4,"arabic":"مَآ","translation":"যা","audioUrl":"wbw/005_067_005.mp3","charTypeName":"word"},{"id":58267,"position":5,"arabic":"أُنزِلَ","translation":"অবতীর্ণ করা হয়েছে","audioUrl":"wbw/005_067_006.mp3","charTypeName":"word"},{"id":58268,"position":6,"arabic":"إِلَيْكَ","translation":"প্রতি তোমার","audioUrl":"wbw/005_067_007.mp3","charTypeName":"word"},{"id":58269,"position":7,"arabic":"مِن","translation":"পক্ষ হতে","audioUrl":"wbw/005_067_008.mp3","charTypeName":"word"},{"id":58270,"position":8,"arabic":"رَّبِّكَ ۖ","translation":"তোমার রবের","audioUrl":"wbw/005_067_009.mp3","charTypeName":"word"},{"id":58272,"position":9,"arabic":"وَإِن","translation":"এবং যদি","audioUrl":"wbw/005_067_011.mp3","charTypeName":"word"},{"id":58273,"position":10,"arabic":"لَّمْ","translation":"না","audioUrl":"wbw/005_067_012.mp3","charTypeName":"word"},{"id":58274,"position":11,"arabic":"تَفْعَلْ","translation":"তুমি