e":"word"},{"id":79852,"position":24,"arabic":"أَوْ","translation":"বা","audioUrl":"wbw/006_145_024.mp3","charTypeName":"word"},{"id":79853,"position":25,"arabic":"فِسْقًا","translation":"অবৈধ (হওয়ার কারণ)","audioUrl":"wbw/006_145_025.mp3","charTypeName":"word"},{"id":79854,"position":26,"arabic":"أُهِلَّ","translation":"(জবাই করার সময়) নাম নেয়া হয়েছে","audioUrl":"wbw/006_145_026.mp3","charTypeName":"word"},{"id":79855,"position":27,"arabic":"لِغَيْرِ","translation":"উদ্দেশ্যে (অন্যের)ছাড়া","audioUrl":"wbw/006_145_027.mp3","charTypeName":"word"},{"id":79856,"position":28,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌","audioUrl":"wbw/006_145_028.mp3","charTypeName":"word"},{"id":79857,"position":29,"arabic":"بِهِۦ ۚ","translation":"উপর তার","audioUrl":"wbw/006_145_029.mp3","charTypeName":"word"},{"id":79859,"position":30,"arabic":"فَمَنِ","translation":"তবে যে","audioUrl":"wbw/006_145_031.mp3","charTypeName":"word"},{"id":79860,"position":31,"arabic":"ٱضْطُرَّ","translation":"নিরুপায় হয়ে (খায়)","audioUrl":"wbw/006_145_032.mp3","charTypeName":"word"},{"id":79861,"position":32,"arabic":"غَيْرَ","translation":"না","audioUrl":"wbw/006_145_033.mp3","charTypeName":"word"},{"id":79862,"position":33,"arabic":"بَاغٍۢ","translation":"অবাধ্য হয়ে","audioUrl":"wbw/006_145_034.mp3","charTypeName":"word"},{"id":79863,"position":34,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/006_145_035.mp3","charTypeName":"word"},{"id":79864,"position":35,"arabic":"عَادٍۢ","translation":"সীমালঙ্ঘন করে","audioUrl":"wbw/006_145_036.mp3","charTypeName":"word"},{"id":79865,"position":36,"arabic":"فَإِنَّ","translation":"তবে নিশ্চয়ই","audioUrl":"wbw/006_145_037.mp3","charTypeName":"word"},{"id":79866,"position":37,"arabic":"رَبَّكَ","translation":"তোমার রব (সে ক্ষেত্রে)","audioUrl":"wbw/006_145_038.mp3","charTypeName":"word"},{"id":79867,"position":38,"arabic":"غَفُورٌۭ","translation":"ক্ষমাশীল","audioUrl":"wbw/006_145_039.mp3","charTypeName":"word"},{"id":79868,"position":39,"arabic":"رَّحِيمٌۭ","translation":"পরম দয়ালু\"","audioUrl":"wbw/006_145_040.mp3","charTypeName":"word"},{"id":79869,"position":40,"arabic":"١٤٥","translation":"(১৪৫)","audioUrl":null,"charTypeName":"end"}]},{"number":146,"arabic":"وَعَلَى ٱلَّذِينَ هَادُوا۟ حَرَّمْنَا كُلَّ ذِى ظُفُرٍۢ ۖ وَمِنَ ٱلْبَقَرِ وَٱلْغَنَمِ حَرَّمْنَا عَلَيْهِمْ شُحُومَهُمَآ إِلَّا مَا حَمَلَتْ ظُهُورُهُمَآ أَوِ ٱلْحَوَايَآ أَوْ مَا ٱخْتَلَطَ بِعَظْمٍۢ ۚ ذَٰلِكَ جَزَيْنَٰهُم بِبَغْيِهِمْ ۖ وَإِنَّا لَصَٰدِقُونَ","translation":"And [only] unto those who followed the Jewish faith did We forbid all beasts that have claws; and We forbade unto them the fat of both oxen and sheep, excepting that which is in their backs or entrails or that which is within the bone: thus did We requite them for their evildoing-for, behold, We are true to Our word!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/935.mp3","surahId":6,"words":[{"id":79931,"position":1,"arabic":"وَعَلَى","translation":"এবং (তাদের) উপর","audioUrl":"wbw/006_146_001.mp3","charTypeName":"word"},{"id":79932,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/006_146_002.mp3","charTypeName":"word"},{"id":79933,"position":3,"arabic":"هَادُوا۟","translation":"ইয়াহুদী হয়েছে","audioUrl":"wbw/006_146_003.mp3","charTypeName":"word"},{"id":79934,"position":4,"arabic":"حَرَّمْنَا","translation":"নিষিদ্ধ করেছিলাম আমরা","audioUrl":"wbw/006_146_004.mp3","charTypeName":"word"},{"id":79935,"position":5,"arabic":"كُلَّ","translation":"সব","audioUrl":"wbw/006_146_005.mp3","charTypeName":"word"},{"id":79936,"position":6,"arabic":"ذِى","translation":"বিশিষ্ট","audioUrl":"wbw/006_146_006.mp3","charTypeName":"word"},{"id":79937,"position":7,"arabic":"ظُفُرٍۢ ۖ","translation":"নখর (জন্তু)","audioUrl":"wbw/006_146_007.mp3","charTypeName":"word"},{"id":79939,"position":8,"arabic":"وَمِنَ","translation":"এবং মধ্য হতে","audioUrl":"wbw/006_146_009.mp3","charTypeName":"word"},{"id":79940,"position":9,"arabic":"ٱلْبَقَرِ","translation