{"id":147,"ayahs":[{"number":143,"arabic":"ثَمَٰنِيَةَ أَزْوَٰجٍۢ ۖ مِّنَ ٱلضَّأْنِ ٱثْنَيْنِ وَمِنَ ٱلْمَعْزِ ٱثْنَيْنِ ۗ قُلْ ءَآلذَّكَرَيْنِ حَرَّمَ أَمِ ٱلْأُنثَيَيْنِ أَمَّا ٱشْتَمَلَتْ عَلَيْهِ أَرْحَامُ ٱلْأُنثَيَيْنِ ۖ نَبِّـُٔونِى بِعِلْمٍ إِن كُنتُمْ صَٰدِقِينَ","translation":"[His followers would have it that, in certain cases, any of these] four kinds of cattle of either sex [is unlawful to man]: either of the two sexes of sheep and of goats. Ask [them]: \"Is it the two males that He has forbidden, or the two females, or that which the wombs of the two females may contain? Tell me what you know in this respect, if what you say is true.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/932.mp3","surahId":6,"words":[{"id":79573,"position":1,"arabic":"ثَمَـٰنِيَةَ","translation":"(এসব পশু) আট","audioUrl":"wbw/006_143_001.mp3","charTypeName":"word"},{"id":79574,"position":2,"arabic":"أَزْوَٰجٍۢ ۖ","translation":"প্রকার","audioUrl":"wbw/006_143_002.mp3","charTypeName":"word"},{"id":79576,"position":3,"arabic":"مِّنَ","translation":"(যেমন) মধ্য হতে","audioUrl":"wbw/006_143_004.mp3","charTypeName":"word"},{"id":79577,"position":4,"arabic":"ٱلضَّأْنِ","translation":"মেষ (শ্রেণীর)","audioUrl":"wbw/006_143_005.mp3","charTypeName":"word"},{"id":79578,"position":5,"arabic":"ٱثْنَيْنِ","translation":"দু'টি (অর্থাৎ নর ও মাদী)","audioUrl":"wbw/006_143_006.mp3","charTypeName":"word"},{"id":79579,"position":6,"arabic":"وَمِنَ","translation":"এবং মধ্য হতে","audioUrl":"wbw/006_143_007.mp3","charTypeName":"word"},{"id":79580,"position":7,"arabic":"ٱلْمَعْزِ","translation":"ছাগল (শ্রেণীর)","audioUrl":"wbw/006_143_008.mp3","charTypeName":"word"},{"id":79581,"position":8,"arabic":"ٱثْنَيْنِ ۗ","translation":"দু'টি (অর্থাৎ নর ও মাদী)","audioUrl":"wbw/006_143_009.mp3","charTypeName":"word"},{"id":79583,"position":9,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/006_143_011.mp3","charTypeName":"word"},{"id":79584,"position":10,"arabic":"ءَآلذَّكَرَيْنِ","translation":"\"কি নর দু'টিকে","audioUrl":"wbw/006_143_012.mp3","charTypeName":"word"},{"id":79585,"position":11,"arabic":"حَرَّمَ","translation":"নিষিদ্ধ করেছেন (আল্লাহ্‌)","audioUrl":"wbw/006_143_013.mp3","charTypeName":"word"},{"id":79586,"position":12,"arabic":"أَمِ","translation":"না","audioUrl":"wbw/006_143_014.mp3","charTypeName":"word"},{"id":79587,"position":13,"arabic":"ٱلْأُنثَيَيْنِ","translation":"মাদি দু'টিকে","audioUrl":"wbw/006_143_015.mp3","charTypeName":"word"},{"id":79588,"position":14,"arabic":"أَمَّا","translation":"অথবা যা","audioUrl":"wbw/006_143_016.mp3","charTypeName":"word"},{"id":79589,"position":15,"arabic":"ٱشْتَمَلَتْ","translation":"ধারণ করেছে","audioUrl":"wbw/006_143_017.mp3","charTypeName":"word"},{"id":79590,"position":16,"arabic":"عَلَيْهِ","translation":"কাছে তার","audioUrl":"wbw/006_143_018.mp3","charTypeName":"word"},{"id":79591,"position":17,"arabic":"أَرْحَامُ","translation":"গর্ভসমূহ (অর্থাৎ বাচ্চা)","audioUrl":"wbw/006_143_019.mp3","charTypeName":"word"},{"id":79592,"position":18,"arabic":"ٱلْأُنثَيَيْنِ ۖ","translation":"মাদি দু'টির","audioUrl":"wbw/006_143_020.mp3","charTypeName":"word"},{"id":79594,"position":19,"arabic":"نَبِّـُٔونِى","translation":"আমাকে তোমরা জানাও","audioUrl":"wbw/006_143_022.mp3","charTypeName":"word"},{"id":79595,"position":20,"arabic":"بِعِلْمٍ","translation":"দিয়ে জ্ঞান","audioUrl":"wbw/006_143_023.mp3","charTypeName":"word"},{"id":79596,"position":21,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/006_143_024.mp3","charTypeName":"word"},{"id":79597,"position":22,"arabic":"كُنتُمْ","translation":"হও তোমরা","audioUrl":"wbw/006_143_025.mp3","charTypeName":"word"},{"id":79598,"position":23,"arabic":"صَـٰدِقِينَ","translation":"সত্যবাদী\"","audioUrl":"wbw/006_143_026.mp3","charTypeName":"word"},{"id":79599,"position":24,"arabic":"١٤٣","translation":"(১৪৩)","audioUrl":null,"charTypeName":"end"}]},{"number":144,"arabic":"وَمِنَ ٱلْإِبِلِ ٱثْنَيْنِ وَمِنَ ٱلْبَقَرِ ٱثْنَيْنِ ۗ قُلْ ءَآلذَّكَرَيْنِ حَرَّمَ أَمِ ٱلْأُنثَيَيْنِ أَمَّا ٱشْتَمَلَتْ عَلَيْهِ أَرْحَامُ ٱلْأُنثَيَيْنِ ۖ أَمْ كُنتُمْ شُهَدَآءَ إِذْ وَصَّىٰكُمُ ٱللَّهُ بِهَٰذَا ۚ فَمَنْ أَظْلَمُ مِمَّنِ ٱفْتَرَىٰ عَلَى ٱللَّهِ كَذِبًۭا لِّيُضِلَّ ٱلنَّاسَ بِغَيْرِ عِلْمٍ ۗ إِنَّ ٱللَّهَ لَا يَهْدِى ٱلْقَوْمَ ٱلظَّٰلِمِينَ","translation":"And [likewise they declare as unlawful] either of the two sexes of camels and of bovine cattle. Ask [them]: \"Is it the two males that He has forbidden, or the two females, or that which the wombs of the two females may contain? Is it, perchance, that you [yourselves] were witnesses when God enjoined [all] this upon you?\" And who could be more wicked than he who, without any [real] knowledge, attributes his own lying inventions to God, and thus leads people astray'? Behold, God does not grace [such] evildoing folk with His guidance.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/933.mp3","surahId":6,"words":[{"id":79600,"position":1,"arabic":"وَمِنَ","translation":"এবং মধ্য হতে","audioUrl":"wbw/006_144_001.mp3","charTypeName":"word"},{"id":79601,"position":2,"arabic":"ٱلْإِبِلِ","translation":"উট (শ্রেণীর)","audioUrl":"wbw/006_144_002.mp3","charTypeName":"word"},{"id":79602,"position":3,"arabic":"ٱثْنَيْنِ","translation":"দু'টি (অর্থাৎ নর ও মাদি)","audioUrl":"wbw/006_144_003.mp3","charTypeName":"word"},{"id":79603,"position":4,"arabic":"وَمِنَ","translation":"এবং মধ্য হতে","audioUrl":"wbw/006_144_004.mp3","charTypeName":"word"},{"id":79604,"position":5,"arabic":"ٱلْبَقَرِ","translation":"গরু (শ্রেণীর)","audioUrl":"wbw/006_144_005.mp3","charTypeName":"word"},{"id":79605,"position":6,"arabic":"ٱثْنَيْنِ ۗ","translation":"দু'টি (অর্থাৎ নর ও মাদি)","audioUrl":"wbw/006_144_006.mp3","charTypeName":"word"},{"id":79607,"position":7,"arabic":"قُلْ","translation":"বল","audioUrl":"wbw/006_144_008.mp3","charTypeName":"word"},{"id":79608,"position":8,"arabic":"ءَآلذَّكَرَيْنِ","translation":"\"কি নর দু'টি","audioUrl":"wbw/006_144_009.mp3","charTypeName":"word"},{"