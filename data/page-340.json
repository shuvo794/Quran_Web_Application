{"id":340,"ayahs":[{"number":65,"arabic":"أَلَمْ تَرَ أَنَّ ٱللَّهَ سَخَّرَ لَكُم مَّا فِى ٱلْأَرْضِ وَٱلْفُلْكَ تَجْرِى فِى ٱلْبَحْرِ بِأَمْرِهِۦ وَيُمْسِكُ ٱلسَّمَآءَ أَن تَقَعَ عَلَى ٱلْأَرْضِ إِلَّا بِإِذْنِهِۦٓ ۗ إِنَّ ٱللَّهَ بِٱلنَّاسِ لَرَءُوفٌۭ رَّحِيمٌۭ","translation":"Art thou not aware that it is God who has made subservient to you all that is on earth, and the ships that sail through the sea at His behest - and [that it is He who] holds the celestial bodies [in their orbits], so that they may not fall upon the earth otherwise than by His leave? Verily, God is most compassionate towards men, a dispenser of grace –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2660.mp3","surahId":22,"words":[{"id":57418,"position":1,"arabic":"أَلَمْ","translation":"নি কি","audioUrl":"wbw/022_065_001.mp3","charTypeName":"word"},{"id":57419,"position":2,"arabic":"تَرَ","translation":"তুমি দেখো","audioUrl":"wbw/022_065_002.mp3","charTypeName":"word"},{"id":57420,"position":3,"arabic":"أَنَّ","translation":"যে","audioUrl":"wbw/022_065_003.mp3","charTypeName":"word"},{"id":57421,"position":4,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/022_065_004.mp3","charTypeName":"word"},{"id":57422,"position":5,"arabic":"سَخَّرَ","translation":"অধীন করে দিয়েছেন","audioUrl":"wbw/022_065_005.mp3","charTypeName":"word"},{"id":57423,"position":6,"arabic":"لَكُم","translation":"জন্যে তোমাদের","audioUrl":"wbw/022_065_006.mp3","charTypeName":"word"},{"id":57424,"position":7,"arabic":"مَّا","translation":"যা কিছু","audioUrl":"wbw/022_065_007.mp3","charTypeName":"word"},{"id":57425,"position":8,"arabic":"فِى","translation":"মধ্যে (আছে)","audioUrl":"wbw/022_065_008.mp3","charTypeName":"word"},{"id":57426,"position":9,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/022_065_009.mp3","charTypeName":"word"},{"id":57427,"position":10,"arabic":"وَٱلْفُلْكَ","translation":"এবং নৌযানসমূহ","audioUrl":"wbw/022_065_010.mp3","charTypeName":"word"},{"id":57428,"position":11,"arabic":"تَجْرِى","translation":"চলাচল করে","audioUrl":"wbw/022_065_011.mp3","charTypeName":"word"},{"id":57429,"position":12,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/022_065_012.mp3","charTypeName":"word"},{"id":57430,"position":13,"arabic":"ٱلْبَحْرِ","translation":"সমুদ্রের","audioUrl":"wbw/022_065_013.mp3","charTypeName":"word"},{"id":57431,"position":14,"arabic":"بِأَمْرِهِۦ","translation":"তাঁর নির্দেশ অনুসারে","audioUrl":"wbw/022_065_014.mp3","charTypeName":"word"},{"id":57432,"position":15,"arabic":"وَيُمْسِكُ","translation":"এবং তিনি ধরে রেখেছেন","audioUrl":"wbw/022_065_015.mp3","charTypeName":"word"},{"id":57433,"position":16,"arabic":"ٱلسَّمَآءَ","translation":"আকাশকে","audioUrl":"wbw/022_065_016.mp3","charTypeName":"word"},{"id":57434,"position":17,"arabic":"أَن","translation":"যেন (না)","audioUrl":"wbw/022_065_017.mp3","charTypeName":"word"},{"id":57435,"position":18,"arabic":"تَقَعَ","translation":"পতিত হয়","audioUrl":"wbw/022_065_018.mp3","charTypeName":"word"},{"id":57436,"position":19,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/022_065_019.mp3","charTypeName":"word"},{"id":57437,"position":20,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/022_065_020.mp3","charTypeName":"word"},{"id":57438,"position":21,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/022_065_021.mp3","charTypeName":"word"},{"id":57439,"position":22,"arabic":"بِإِذْنِهِۦٓ ۗ","translation":"নিয়ে তাঁর অনুমতি","audioUrl":"wbw/022_065_022.mp3","charTypeName":"word"},{"id":57441,"position":23,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/022_065_024.mp3","charTypeName":"word"},{"id":57442,"position":24,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/022_065_025.mp3","charTypeName":"word"},{"id":57443,"position":25,"arabic":"بِٱلنَّاسِ","translation":"উপর মানুষের","audioUrl":"wbw/022_065_026.mp3","charTypeName":"word"},{"id":57444,"position":26,"arabic":"لَرَءُوفٌۭ","translation":"অবশ্যই দয়াপরবশ","audioUrl":"wbw/022_065_027.mp3","charTypeName":"word"},{"id":57445,"position":27,"arabic":"رَّحِيمٌۭ","translation":"পরম দয়ালু","audioUrl":"wbw/022_065_028.mp3","charTypeName":"word"},{"id":57446,"position":28,"arabic":"٦٥","translation":"(৬৫)","audioUrl":null,"charTypeName":"end"}]},{"number":66,"arabic":"وَهُوَ ٱلَّذِىٓ أَحْيَاكُمْ ثُمَّ يُمِيتُكُمْ ثُمَّ يُحْيِيكُمْ ۗ إِنَّ ٱلْإِنسَٰنَ لَكَفُورٌۭ","translation":"seeing that it is He who gave you life, and then will cause you to die, and then will bring you back to life: [but,] verily, bereft of all gratitude is man!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2661.mp3","surahId":22,"words":[{"id":57901,"position":1,"arabic":"وَهُوَ","translation":"এবং তিনিই","audioUrl":"wbw/022_066_001.mp3","charTypeName":"word"},{"id":57902,"position":2,"arabic":"ٱلَّذِىٓ","translation":"যিনি","audioUrl":"wbw/022_066_002.mp3","charTypeName":"word"},{"id":57903,"position":3,"arabic":"أَحْيَاكُمْ","translation":"জীবন দিয়েছেন তোমাদেরকে","audioUrl":"wbw/022_066_003.mp3","charTypeName":"word"},{"id":57904,"position":4,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/022_066_004.mp3","charTypeName":"word"},{"id":57905,"position":5,"arabic":"يُمِيتُكُمْ","translation":"তোমাদেরকে মৃত্যু দিবেন","audioUrl":"wbw/022_066_005.mp3","charTypeName":"word"},{"id":57906,"position":6,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/022_066_006.mp3","charTypeName":"word"},{"id":57907,"position":7,"arabic":"يُحْيِيكُمْ ۗ","translation":"তোমাদের জীবিত করবেন","audioUrl":"wbw/022_066_007.mp3","charTypeName":"word"},{"id":57909,"position":8,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/022_066_009.mp3","charTypeName":"word"},{"id":57910,"position":9,"arabic":"ٱلْإِنسَـٰنَ","translation":"মানুষ","audioUrl":"wbw/022_066_010.mp3","charTypeName":"word"},{"id":57911,"position":10,"arabic":"لَكَفُورٌۭ","translation":"অবশ্যই অকৃতজ্ঞ বড়","audioUrl":"wbw/022_066_011.mp3","charTypeName":"word"},{"id":57912,"position":11,"arabic":"٦٦","translation":"(৬৬)","audioUrl":null,"charTypeName":"end"}]},{"number":67,"arabic":"لِّكُلِّ أُمَّةٍۢ جَعَلْنَا مَنسَكًا هُمْ نَاسِكُوهُ ۖ فَلَا يُنَٰزِعُنَّكَ فِى ٱلْأَمْرِ ۚ وَٱدْعُ إِلَىٰ رَبِّكَ ۖ إِنَّكَ لَعَلَىٰ هُدًۭى مُّسْتَقِيمٍۢ","translation":"UNTO every community have We appointed [different] ways of worship, which they ought to observe. Hence, [O believer,] do not let those [who follow ways other than thine] draw thee into disputes on this score, but summon [them all] unto thy Sustainer: for, behold, thou art indeed on the right way.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2662.mp3","surahId":22,"words":[{"id":58066,"position":1,"arabic":"لِّكُلِّ","translation":"জন্যে প্রত্যেক","audioUrl":"wbw/022_067_001.mp3","charTypeName":"word"},{"id":58067,"position":2,"arabic":"أُمَّةٍۢ","translation":"জাতির","audioUrl":"wbw/022_067_002.mp3","charTypeName":"word"},{"id":58068,"position":3,"arabic":"جَعَلْنَا","translation":"আমরা নির্ধারণ করেছি","audioUrl":"wbw/022_067_003.mp3","charTypeName":"word"},{"id":58069,"position":4,"arabic":"مَنسَكًا","translation":"ইবাদাত পদ্ধতি","audioUrl":"wbw/022_067_004.mp3","charTypeName":"word"},{"id":58070,"position":5,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/022_067_005.mp3","charTypeName":"word"},{"id":58071,"position":6,"arabic":"نَاسِكُوهُ ۖ","translation":"সেই প্রথা অনুসরণকারী","audioUrl":"wbw/022_067_006.mp3","charTypeName":"word"},{"id":58073,"position":7,"arabic":"فَلَا","translation":"সুতরাং না (যেন)","audioUrl":"wbw/022_067_008.mp3","charTypeName":"word"},{"id":58074,"position":8,"arabic":"يُنَـٰزِعُنَّكَ","translation":"তোমার (সাথে) ঝগড়া করে","audioUrl":"wbw/022_067_009.mp3","charTypeName":"word"},{"id":58075,"position":9,"arabic":"فِى","translation":"নিয়ে","audioUrl":"wbw/022_067_010.mp3","charTypeName":"word"},{"id":58076,"position":10,"arabic":"ٱلْأَمْرِ ۚ","translation":"এই (ব্যাপার)","audioUrl":"wbw/022_067_011.mp3","charTypeName":"word"},{"id":58078,"position":11,"arabic":"وَٱدْعُ","translation":"এবং তুমি ডাকো","audioUrl":"wbw/022_067_013.mp3","charTypeName":"word"},{"id":58079,"position":12,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/022_067_014.mp3","charTypeName":"word"},{"id":58080,"position":13,"arabic":"رَبِّكَ ۖ","translation":"তোমার রবের","audioUrl":"wbw/022_067_015.mp3","charTypeName":"word"},{"id":58082,"position":14,"arabic":"إِنَّكَ","translation":"তুমি নিশ্চয়ই (আছো)","audioUrl":"wbw/022_067_017.mp3","charTypeName":"word"},{"id":58083,"position":15,"arabic":"لَعَلَىٰ","translation":"অবশ্যই উপর","audioUrl":"wbw/022_067_018.mp3","charTypeName":"word"},{"id":58084,"position":16,"arabic":"هُدًۭى","translation":"পথের","audioUrl":"wbw/022_067_019.mp3","charTypeName":"word"},{"id":58085,"position":17,"arabic":"مُّسْتَقِيمٍۢ","translation":"সরল সঠিক","audioUrl":"wbw/022_067_020.mp3","charTypeName":"word"},{"id":58086,"position":18,"arabic":"٦٧","translation":"(৬৭)","audioUrl":null,"charTypeName":"end"}]},{"number":68,"arabic":"وَإِن جَٰدَلُوكَ فَقُلِ ٱللَّهُ أَعْلَمُ بِمَا تَعْمَلُونَ","translation":"And if they [try to] argue with thee, say [only]: “God knows best what you are doing.”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2663.mp3","surahId":22,"words":[{"id":58647,"position":1,"arabic":"وَإِن","translation":"আর যদি","audioUrl":"wbw/022_068_001.mp3","charTypeName":"word"},{"id":58648,"position":2,"arabic":"جَـٰدَلُوكَ","translation":"তোমার সাথে তারা বিতর্ক করে","audioUrl":"wbw/022_068_002.mp3","charTypeName":"word"},{"id":58649,"position":3,"arabic":"فَقُلِ","translation":"তবে বলো","audioUrl":"wbw/022_068_003.mp3","charTypeName":"word"},{"id":58650,"position":4,"arabic":"ٱللَّهُ","translation":"\"আল্লাহ","audioUrl":"wbw/022_068_004.mp3","charTypeName":"word"},{"id":58651,"position":5,"arabic":"أَعْلَمُ","translation":"খুব জানেন","audioUrl":"wbw/022_068_005.mp3","charTypeName":"word"},{"id":58652,"position":6,"arabic":"بِمَا","translation":"যা সে বিষয়ে","audioUrl":"wbw/022_068_006.mp3","charTypeName":"word"},{"id":58653,"position":7,"arabic":"تَعْمَلُونَ","translation":"তোমরা কাজ করছো","audioUrl":"wbw/022_068_007.mp3","charTypeName":"word"},{"id":58654,"position":8,"arabic":"٦٨","translation":"(৬৮)","audioUrl":null,"charTypeName":"end"}]},{"number":69,"arabic":"ٱللَّهُ يَحْكُمُ بَيْنَكُمْ يَوْمَ ٱلْقِيَٰمَةِ فِيمَا كُنتُمْ فِيهِ تَخْتَلِفُونَ","translation":"[For, indeed,] God will judge between you [all] on Resurrection Day with regard to all on which you were wont to differ.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2664.mp3","surahId":22,"words":[{"id":59091,"position":1,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/022_069_001.mp3","charTypeName":"word"},{"id":59092,"position":2,"arabic":"يَحْكُمُ","translation":"মীমাংসা করে দিবেন","audioUrl":"wbw/022_069_002.mp3","charTypeName":"word"},{"id":59093,"position":3,"arabic":"بَيْنَكُمْ","translation":"তোমাদের মাঝে","audioUrl":"wbw/022_069_003.mp3","charTypeName":"word"},{"id":59094,"position":4,"arabic":"يَوْمَ","translation":"দিনে","audioUrl":"wbw/022_069_004.mp3","charTypeName":"word"},{"id":59095,"position":5,"arabic":"ٱلْقِيَـٰمَةِ","translation":"ক্বিয়ামাতের","audioUrl":"wbw/022_069_005.mp3","charTypeName":"word"},{"id":59096,"position":6,"arabic":"فِيمَا","translation":"সে বিষয়ে","audioUrl":"wbw/022_069_006.mp3","charTypeName":"word"},{"id":59097,"position":7,"arabic":"كُنتُمْ","translation":"তোমরা ছিলে","audioUrl":"wbw/022_069_007.mp3","charTypeName":"word"},{"id":59098,"position":8,"arabic":"فِيهِ","translation":"যার মধ্যে","audioUrl":"wbw/022_069_008.mp3","charTypeName":"word"},{"id":59099,"position":9,"arabic":"تَخْتَلِفُونَ","translation":"মতভেদ করতে\"","audioUrl":"wbw/022_069_009.mp3","charTypeName":"word"},{"id":59100,"position":10,"arabic":"٦٩","translation":"(৬৯)","audioUrl":null,"charTypeName":"end"}]},{"number":70,"arabic":"أَلَمْ تَعْلَمْ أَنَّ ٱللَّهَ يَعْلَمُ مَا فِى ٱلسَّمَآءِ وَٱلْأَرْضِ ۗ إِنَّ ذَٰلِكَ فِى كِتَٰبٍ ۚ إِنَّ ذَٰلِكَ عَلَى ٱللَّهِ يَسِيرٌۭ","translation":"Dost thou not know that God knows all that occurs in heaven as well as on earth? All this, behold, is in [God’s] record: verily, [to know] all this is easy for God.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2665.mp3","surahId":22,"words":[{"id":59732,"position":1,"arabic":"أَلَمْ","translation":"নি কি","audioUrl":"wbw/022_070_001.mp3","charTypeName":"word"},{"id":59733,"position":2,"arabic":"تَعْلَمْ","translation":"তুমি জানো","audioUrl":"wbw/022_070_002.mp3","charTypeName":"word"},{"id":59734,"position":3,"arabic":"أَنَّ","translation":"যে","audioUrl":"wbw/022_070_003.mp3","charTypeName":"word"},{"id":59735,"position":4,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/022_070_004.mp3","charTypeName":"word"},{"id":59736,"position":5,"arabic":"يَعْلَمُ","translation":"জানেন","audioUrl":"wbw/022_070_005.mp3","charTypeName":"word"},{"id":59737,"position":6,"arabic":"مَا","translation":"যা কিছু","audioUrl":"wbw/022_070_006.mp3","charTypeName":"word"},{"id":59738,"position":7,"arabic":"فِى","translation":"মধ্যে (আছে)","audioUrl":"wbw/022_070_007.mp3","charTypeName":"word"},{"id":59739,"position":8,"arabic":"ٱلسَّمَآءِ","translation":"আকাশের","audioUrl":"wbw/022_070_008.mp3","charTypeName":"word"},{"id":59740,"position":9,"arabic":"وَٱلْأَرْضِ ۗ","translation":"ও পৃথিবীতে","audioUrl":"wbw/022_070_009.mp3","charTypeName":"word"},{"id":59742,"position":10,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/022_070_011.mp3","charTypeName":"word"},{"id":59743,"position":11,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/022_070_012.mp3","charTypeName":"word"},{"id":59744,"position":12,"arabic":"فِى","translation":"মধ্যে (আছে)","audioUrl":"wbw/022_070_013.mp3","charTypeName":"word"},{"id":59745,"position":13,"arabic":"كِتَـٰبٍ ۚ","translation":"এক কিতাবে (লিপিবদ্ধ)","audioUrl":"wbw/022_070_014.mp3","charTypeName":"word"},{"id":59747,"position":14,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/022_070_016.mp3","charTypeName":"word"},{"id":59748,"position":15,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/022_070_017.mp3","charTypeName":"word"},{"id":59749,"position":16,"arabic":"عَلَى","translation":"নিকট","audioUrl":"wbw/022_070_018.mp3","charTypeName":"word"},{"id":59750,"position":17,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/022_070_019.mp3","charTypeName":"word"},{"id":59751,"position":18,"arabic":"يَسِيرٌۭ","translation":"সহজ","audioUrl":"wbw/022_070_020.mp3","charTypeName":"word"},{"id":59752,"position":19,"arabic":"٧٠","translation":"(৭০)","audioUrl":null,"charTypeName":"end"}]},{"number":71,"arabic":"وَيَعْبُدُونَ مِن دُونِ ٱللَّهِ مَا لَمْ يُنَزِّلْ بِهِۦ سُلْطَٰنًۭا وَمَا لَيْسَ لَهُم بِهِۦ عِلْمٌۭ ۗ وَمَا لِلظَّٰلِمِينَ مِن نَّصِيرٍۢ","translation":"And yet they [who claim to believe in Him often] worship [other beings or forces] beside God - something for which He has never bestoweed any warrant from on high, and [of the reality] whereof they cannot have any knowledge: and such evildoers shall have none to succour them [on Judgment Day].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2666.mp3","surahId":22,"words":[{"id":60260,"position":1,"arabic":"وَيَعْبُدُونَ","translation":"এবং তারা উপাসনা করে","audioUrl":"wbw/022_071_001.mp3","charTypeName":"word"},{"id":60261,"position":2,"arabic":"مِن","translation":"মধ্য হতে","audioUrl":"wbw/022_071_002.mp3","charTypeName":"word"},{"id":60262,"position":3,"arabic":"دُونِ","translation":"পরিবর্তে","audioUrl":"wbw/022_071_003.mp3","charTypeName":"word"},{"id":60263,"position":4,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌র","audioUrl":"wbw/022_071_004.mp3","charTypeName":"word"},{"id":60264,"position":5,"arabic":"مَا","translation":"(এমন কিছুর) যা","audioUrl":"wbw/022_071_005.mp3","charTypeName":"word"},{"id":60265,"position":6,"arabic":"لَمْ","translation":"নি","audioUrl":"wbw/022_071_006.mp3","charTypeName":"word"},{"id":60266,"position":7,"arabic":"يُنَزِّلْ","translation":"অবতীর্ণ করেন (আল্লাহ)","audioUrl":"wbw/022_071_007.mp3","charTypeName":"word"},{"id":60267,"position":8,"arabic":"بِهِۦ","translation":"সে সম্বন্ধে","audioUrl":"wbw/022_071_008.mp3","charTypeName":"word"},{"id":60268,"position":9,"arabic":"سُلْطَـٰنًۭا","translation":"কোন প্রমাণ","audioUrl":"wbw/022_071_009.mp3","charTypeName":"word"},{"id":60269,"position":10,"arabic":"وَمَا","translation":"আর যার","audioUrl":"wbw/022_071_010.mp3","charTypeName":"word"},{"id":60270,"position":11,"arabic":"لَيْسَ","translation":"নেই","audioUrl":"wbw/022_071_011.mp3","charTypeName":"word"},{"id":60271,"position":12,"arabic":"لَهُم","translation":"কাছে তাদের","audioUrl":"wbw/022_071_012.mp3","charTypeName":"word"},{"id":60272,"position":13,"arabic":"بِهِۦ","translation":"সম্বন্ধে সে","audioUrl":"wbw/022_071_013.mp3","charTypeName":"word"},{"id":60273,"position":14,"arabic":"عِلْمٌۭ ۗ","translation":"কোন জ্ঞান","audioUrl":"wbw/022_071_014.mp3","charTypeName":"word"},{"id":60275,"position":15,"arabic":"وَمَا","translation":"এবং নেই","audioUrl":"wbw/022_071_016.mp3","charTypeName":"word"},{"id":60276,"position":16,"arabic":"لِلظَّـٰلِمِينَ","translation":"জন্যে সীমালঙ্ঘনকারীদের","audioUrl":"wbw/022_071_017.mp3","charTypeName":"word"},{"id":60277,"position":17,"arabic":"مِن","translation":"কোন","audioUrl":"wbw/022_071_018.mp3","charTypeName":"word"},{"id":60278,"position":18,"arabic":"نَّصِيرٍۢ","translation":"সাহায্যকারী","audioUrl":"wbw/022_071_019.mp3","charTypeName":"word"},{"id":60279,"position":19,"arabic":"٧١","translation":"(৭১)","audioUrl":null,"charTypeName":"end"}]},{"number":72,"arabic":"وَإِذَا تُتْلَىٰ عَلَيْهِمْ ءَايَٰتُنَا بَيِّنَٰتٍۢ تَعْرِفُ فِى وُجُوهِ ٱلَّذِينَ كَفَرُوا۟ ٱلْمُنكَرَ ۖ يَكَادُونَ يَسْطُونَ بِٱلَّذِينَ يَتْلُونَ عَلَيْهِمْ ءَايَٰتِنَا ۗ قُلْ أَفَأُنَبِّئُكُم بِشَرٍّۢ مِّن ذَٰلِكُمُ ۗ ٱلنَّارُ وَعَدَهَا ٱللَّهُ ٱلَّذِينَ كَفَرُوا۟ ۖ وَبِئْسَ ٱلْمَصِيرُ","translation":"As it is, whenever Our messages are conveyed unto them in all their clarity, thou canst perceive utter repugnance on the faces of those who are bent on denying the truth: they would almost assault those who convey Our messages unto them! Say: “Shall I, then, tell you of something worse than what you feel at present? It is the fire [of the hereafter] that God has promised to those who are bent on denying the truth: and how vile a journey’s end!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2667.mp3","surahId":22,"words":[{"id":60590,"position":1,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/022_072_001.mp3","charTypeName":"word"},{"id":60591,"position":2,"arabic":"تُتْلَىٰ","translation":"তিলাওয়াত করা হয়","audioUrl":"wbw/022_072_002.mp3","charTypeName":"word"},{"id":60592,"position":3,"arabic":"عَلَيْهِمْ","translation":"তাদের নিকট","audioUrl":"wbw/022_072_003.mp3","charTypeName":"word"},{"id":60593,"position":4,"arabic":"ءَايَـٰتُنَا","translation":"আমাদের আয়াতগুলোকে","audioUrl":"wbw/022_072_004.mp3","charTypeName":"word"},{"id":60594,"position":5,"arabic":"بَيِّنَـٰتٍۢ","translation":"সুস্পষ্ট","audioUrl":"wbw/022_072_005.mp3","charTypeName":"word"},{"id":60595,"position":6,"arabic":"تَعْرِفُ","translation":"তুমি লক্ষ্য করবে","audioUrl":"wbw/022_072_006.mp3","charTypeName":"word"},{"id":60596,"position":7,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/022_072_007.mp3","charTypeName":"word"},{"id":60597,"position":8,"arabic":"وُجُوهِ","translation":"মুখমণ্ডলসমূহে","audioUrl":"wbw/022_072_008.mp3","charTypeName":"word"},{"id":60598,"position":9,"arabic":"ٱلَّذِينَ","translation":"(তাদের) যারা","audioUrl":"wbw/022_072_009.mp3","charTypeName":"word"},{"id":60599,"position":10,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/022_072_010.mp3","charTypeName":"word"},{"id":60600,"position":11,"arabic":"ٱلْمُنكَرَ ۖ","translation":"অসন্তোষের লক্ষণ","audioUrl":"wbw/022_072_011.mp3","charTypeName":"word"},{"id":60602,"position":12,"arabic":"يَكَادُونَ","translation":"তারা উপক্রম হয়","audioUrl