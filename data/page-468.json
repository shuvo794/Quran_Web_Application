{"id":468,"ayahs":[{"number":8,"arabic":"رَبَّنَا وَأَدْخِلْهُمْ جَنَّٰتِ عَدْنٍ ٱلَّتِى وَعَدتَّهُمْ وَمَن صَلَحَ مِنْ ءَابَآئِهِمْ وَأَزْوَٰجِهِمْ وَذُرِّيَّٰتِهِمْ ۚ إِنَّكَ أَنتَ ٱلْعَزِيزُ ٱلْحَكِيمُ","translation":"“And, O our Sustainer, bring them into the gardens of perpetual bliss which Thou hast promised them, together with the righteous from among their forebears, and their spouses, and their offspring - for, verily, Thou alone art almighty, truly wise –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4141.mp3","surahId":40,"words":[{"id":8500,"position":1,"arabic":"رَبَّنَا","translation":"হে আমাদের রব","audioUrl":"wbw/040_008_001.mp3","charTypeName":"word"},{"id":8501,"position":2,"arabic":"وَأَدْخِلْهُمْ","translation":"এবং তাদের প্রবেশ করাও","audioUrl":"wbw/040_008_002.mp3","charTypeName":"word"},{"id":8502,"position":3,"arabic":"جَنَّـٰتِ","translation":"জান্নাত সমূহে","audioUrl":"wbw/040_008_003.mp3","charTypeName":"word"},{"id":8503,"position":4,"arabic":"عَدْنٍ","translation":"চিরস্থায়ী","audioUrl":"wbw/040_008_004.mp3","charTypeName":"word"},{"id":8504,"position":5,"arabic":"ٱلَّتِى","translation":"যা","audioUrl":"wbw/040_008_005.mp3","charTypeName":"word"},{"id":8505,"position":6,"arabic":"وَعَدتَّهُمْ","translation":"তাদের তুমি প্রতিশ্রুতি দিয়েছো","audioUrl":"wbw/040_008_006.mp3","charTypeName":"word"},{"id":8506,"position":7,"arabic":"وَمَن","translation":"এবং যারা","audioUrl":"wbw/040_008_007.mp3","charTypeName":"word"},{"id":8507,"position":8,"arabic":"صَلَحَ","translation":"সৎকর্ম করেছে","audioUrl":"wbw/040_008_008.mp3","charTypeName":"word"},{"id":8508,"position":9,"arabic":"مِنْ","translation":"মধ্যে হ'তে","audioUrl":"wbw/040_008_009.mp3","charTypeName":"word"},{"id":8509,"position":10,"arabic":"ءَابَآئِهِمْ","translation":"তাদের বাপ-দাদাদের","audioUrl":"wbw/040_008_010.mp3","charTypeName":"word"},{"id":8510,"position":11,"arabic":"وَأَزْوَٰجِهِمْ","translation":"ও তাদের পতি-পত্নীদের","audioUrl":"wbw/040_008_011.mp3","charTypeName":"word"},{"id":8511,"position":12,"arabic":"وَذُرِّيَّـٰتِهِمْ ۚ","translation":"ও তাদের বংশধরদের","audioUrl":"wbw/040_008_012.mp3","charTypeName":"word"},{"id":8513,"position":13,"arabic":"إِنَّكَ","translation":"তুমি নিশ্চয়ই","audioUrl":"wbw/040_008_014.mp3","charTypeName":"word"},{"id":8514,"position":14,"arabic":"أَنتَ","translation":"তুমিই","audioUrl":"wbw/040_008_015.mp3","charTypeName":"word"},{"id":8515,"position":15,"arabic":"ٱلْعَزِيزُ","translation":"পরাক্রমশালী","audioUrl":"wbw/040_008_016.mp3","charTypeName":"word"},{"id":8516,"position":16,"arabic":"ٱلْحَكِيمُ","translation":"প্রজ্ঞাময়","audioUrl":"wbw/040_008_017.mp3","charTypeName":"word"},{"id":8517,"position":17,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"وَقِهِمُ ٱلسَّيِّـَٔاتِ ۚ وَمَن تَقِ ٱلسَّيِّـَٔاتِ يَوْمَئِذٍۢ فَقَدْ رَحِمْتَهُۥ ۚ وَذَٰلِكَ هُوَ ٱلْفَوْزُ ٱلْعَظِيمُ","translation":"and preserve them from [doing] evil deeds: for anyone whom on that Day [of Judgment] Thou wilt have preserved from [the taint of] evil deeds, him wilt Thou have graced with Thy mercy: and that, that will be the triumph supreme!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4142.mp3","surahId":40,"words":[{"id":9705,"position":1,"arabic":"وَقِهِمُ","translation":"এবং বাঁচাও তাদেরকে","audioUrl":"wbw/040_009_001.mp3","charTypeName":"word"},{"id":9706,"position":2,"arabic":"ٱلسَّيِّـَٔاتِ ۚ","translation":"(সব) মন্দ (হ'তে)","audioUrl":"wbw/040_009_002.mp3","charTypeName":"word"},{"id":9708,"position":3,"arabic":"وَمَن","translation":"এবং যাকে","audioUrl":"wbw/040_009_004.mp3","charTypeName":"word"},{"id":9709,"position":4,"arabic":"تَقِ","translation":"বাঁচাবে","audioUrl":"wbw/040_009_005.mp3","charTypeName":"word"},{"id":9710,"position":5,"arabic":"ٱلسَّيِّـَٔاتِ","translation":"(সব) মন্দ (হ'তে)","audioUrl":"wbw/040_009_006.mp3","charTypeName":"word"},{"id":9711,"position":6,"arabic":"يَوْمَئِذٍۢ","translation":"সেদিন","audioUrl":"wbw/040_009_007.mp3","charTypeName":"word"},{"id":9712,"position":7,"arabic":"فَقَدْ","translation":"তাহ'লে নিশ্চয়ই","audioUrl":"wbw/040_009_008.mp3","charTypeName":"word"},{"id":9713,"position":8,"arabic":"رَحِمْتَهُۥ ۚ","translation":"তাকে অনুগ্রহ করবে","audioUrl":"wbw/040_009_009.mp3","charTypeName":"word"},{"id":9715,"position":9,"arabic":"وَذَٰلِكَ","translation":"এবং এটা","audioUrl":"wbw/040_009_011.mp3","charTypeName":"word"},{"id":9716,"position":10,"arabic":"هُوَ","translation":"সেই","audioUrl":"wbw/040_009_012.mp3","charTypeName":"word"},{"id":9717,"position":11,"arabic":"ٱلْفَوْزُ","translation":"সাফল্য","audioUrl":"wbw/040_009_013.mp3","charTypeName":"word"},{"id":9718,"position":12,"arabic":"ٱلْعَظِيمُ","translation":"মহা\"","audioUrl":"wbw/040_009_014.mp3","charTypeName":"word"},{"id":9719,"position":13,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"إِنَّ ٱلَّذِينَ كَفَرُوا۟ يُنَادَوْنَ لَمَقْتُ ٱللَّهِ أَكْبَرُ مِن مَّقْتِكُمْ أَنفُسَكُمْ إِذْ تُدْعَوْنَ إِلَى ٱلْإِيمَٰنِ فَتَكْفُرُونَ","translation":"[But,] behold, as for those who are bent on denying the truth - [on that same Day] a voice will call out unto them: “Indeed, greater than your [present] loathing of yourselves was God’s loathing of you [at the time] when you were called unto faith but went on denying the truth!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4143.mp3","surahId":40,"words":[{"id":10839,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/040_010_001.mp3","charTypeName":"word"},{"id":10840,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/040_010_002.mp3","charTypeName":"word"},{"id":10841,"position":3,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/040_010_003.mp3","charTypeName":"word"},{"id":10842,"position":4,"arabic":"يُنَادَوْنَ","translation":"তাদের ডেকে বলা হবে","audioUrl":"wbw/040_010_004.mp3","charTypeName":"word"},{"id":10843,"position":5,"arabic":"لَمَقْتُ","translation":"ক্ষোভ অবশ্যই (ছিলো)","audioUrl":"wbw/040_010_005.mp3","charTypeName":"word"},{"id":10844,"position":6,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/040_010_006.mp3","charTypeName":"word"},{"id":10845,"position":7,"arabic":"أَكْبَرُ","translation":"অধিক (সেদিন)","audioUrl":"wbw/040_010_007.mp3","charTypeName":"word"},{"id":10846,"position":8,"arabic":"مِن","translation":"চেয়ে","audioUrl":"wbw/040_010_008.mp3","charTypeName":"word"},{"id":10847,"position":9,"arabic":"مَّقْتِكُمْ","translation":"তোমাদের (আজকের) ক্ষোভের","audioUrl":"wbw/040_010_009.mp3","charTypeName":"word"},{"id":10848,"position":10,"arabic":"أَنفُسَكُمْ","translation":"তোমাদের নিজেদের (উপর)","audioUrl":"wbw/040_010_010.mp3","charTypeName":"word"},{"id":10849,"position":11,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/040_010_011.mp3","charTypeName":"word"},{"id":10850,"position":12,"arabic":"تُدْعَوْنَ","translation":"তোমাদের ডাকা হতো","audioUrl":"wbw/040_010_012.mp3","charTypeName":"word"},{"id":10851,"position":13,"arabic":"إِلَى","translation":"দিকে","audioUrl":"wbw/040_010_013.mp3","charTypeName":"word"},{"id":10852,"position":14,"arabic":"ٱلْإِيمَـٰنِ","translation":"ঈমানের","audioUrl":"wbw/040_010_014.mp3","charTypeName":"word"},{"id":10853,"position":15,"arabic":"فَتَكْفُرُونَ","translation":"তখন তোমরা অস্বীকার করতে","audioUrl":"wbw/040_010_015.mp3","charTypeName":"word"},{"id":10854,"position":16,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"قَالُوا۟ رَبَّنَآ أَمَتَّنَا ٱثْنَتَيْنِ وَأَحْيَيْتَنَا ٱثْنَتَيْنِ فَٱعْتَرَفْنَا بِذُنُوبِنَا فَهَلْ إِلَىٰ خُرُوجٍۢ مِّن سَبِيلٍۢ","translation":"[Whereupon] they will exclaim: “O our Sus­tainer! Twice hast Thou caused us to die, just as twice Thou hast brought us to life!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4144.mp3","surahId":40,"words":[{"id":12091,"position":1,"arabic":"قَالُوا۟","translation":"তারা বলবে","audioUrl":"wbw/040_011_001.mp3","charTypeName":"word"},{"id":12092,"position":2,"arabic":"رَبَّنَآ","translation":"\"হে আমাদের রব","audioUrl":"wbw/040_011_002.mp3","charTypeName":"word"},{"id":12093,"position":3,"arabic":"أَمَتَّنَا","translation":"আমাদেরকে তুমি  মৃত্যু দিয়েছো","audioUrl":"wbw/040_011_003.mp3","charTypeName":"word"},{"id":12094,"position":4,"arabic":"ٱثْنَتَيْنِ","translation":"দু'বার","audioUrl":"wbw/040_011_004.mp3","charTypeName":"word"},{"id":12095,"position":5,"arabic":"وَأَحْيَيْتَنَا","translation":"ও আমাদেরকে তুমি জীবন দিয়েছো","audioUrl":"wbw/040_011_005.mp3","charTypeName":"word"},{"id":12096,"position":6,"arabic":"ٱثْنَتَيْنِ","translation":"দু'বার","audioUrl":"wbw/040_011_006.mp3","charTypeName":"word"},{"id":12097,"position":7,"arabic":"فَٱعْتَرَفْنَا","translation":"আমরা স্বীকার করছি এখন","audioUrl":"wbw/040_011_007.mp3","charTypeName":"word"},{"id":12098,"position":8,"arabic":"بِذُنُوبِنَا","translation":"আমাদের পাপসমূহকে","audioUrl":"wbw/040_011_008.mp3","charTypeName":"word"},{"id":12099,"position":9,"arabic":"فَهَلْ","translation":"এখন কি  (আছে)","audioUrl":"wbw/040_011_009.mp3","charTypeName":"word"},{"id":12100,"position":10,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/040_011_010.mp3","charTypeName":"word"},{"id":12101,"position":11,"arabic":"خُرُوجٍۢ","translation":"বের হওয়ার (পরিত্রাণের)","audioUrl":"wbw/040_011_011.mp3","charTypeName":"word"},{"id":12102,"position":12,"arabic":"مِّن","translation":"কোনো","audioUrl":"wbw/040_011_012.mp3","charTypeName":"word"},{"id":12103,"position":13,"arabic":"سَبِيلٍۢ","translation":"পথ\"","audioUrl":"wbw/040_011_013.mp3","charTypeName":"word"},{"id":12104,"position":14,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]},{"number":12,"arabic":"ذَٰلِكُم بِأَنَّهُۥٓ إِذَا دُعِىَ ٱللَّهُ وَحْدَهُۥ كَفَرْتُمْ ۖ وَإِن يُشْرَكْ بِهِۦ تُؤْمِنُوا۟ ۚ فَٱلْحُكْمُ لِلَّهِ ٱلْعَلِىِّ ٱلْكَبِيرِ","translation":"[And they will be told:] “This [has befallen you] because, whenever the One God was invoked, you denied this truth; whereas, when divinity was ascribed to aught beside Him, you believed [in it]! But all judgment rests with God, the Exalted, the Great!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4145.mp3","surahId":40,"words":[{"id":13419,"position":1,"arabic":"ذَٰلِكُم","translation":"\"(বলা হবে) তোমাদের এ (অবস্থা)","audioUrl":"wbw/040_012_001.mp3","charTypeName":"word"},{"id":13420,"position":2,"arabic":"بِأَنَّهُۥٓ","translation":"এ কারণে যে","audioUrl":"wbw/040_012_002.mp3","charTypeName":"word"},{"id":13421,"position":3,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/040_012_003.mp3","charTypeName":"word"},{"id":13422,"position":4,"arabic":"دُعِىَ","translation":"ডাকা হতো","audioUrl":"wbw/040_012_004.mp3","charTypeName":"word"},{"id":13423,"position":5,"arabic":"ٱللَّهُ","translation":"আল্লাহর (দিকে)","audioUrl":"wbw/040_012_005.mp3","charTypeName":"word"},{"id":13424,"position":6,"arabic":"وَحْدَهُۥ","translation":"তাঁর একত্বের (প্রতি)","audioUrl":"wbw/040_012_006.mp3","charTypeName":"word"},{"id":13425,"position":7,"arabic":"كَفَرْتُمْ ۖ","translation":"তোমরা অস্বীকার করতে","audioUrl":"wbw/040_012_007.mp3","charTypeName":"word"},{"id":13427,"position":8,"arabic":"وَإِن","translation":"এবং যদি","audioUrl":"wbw/040_012_009.mp3","charTypeName":"word"},{"id":13428,"position":9,"arabic":"يُشْرَكْ","translation":"শরিক করা হতো","audioUrl":"wbw/040_012_010.mp3","charTypeName":"word"},{"id":13429,"position":10,"arabic":"بِهِۦ","translation":"তাঁর সাথে (অন্য কাউকে)","audioUrl":"wbw/040_012_011.mp3","charTypeName":"word"},{"id":13430,"position":11,"arabic":"تُؤْمِنُوا۟ ۚ","translation":"তোমরা ঈমান আনতে","audioUrl":"wbw/040_012_012.mp3","charTypeName":"word"},{"id":13432,"position":12,"arabic":"فَٱلْحُكْمُ","translation":"বস্তুতঃ কর্তৃত্ব","audioUrl":"wbw/040_012_014.mp3","charTypeName":"word"},{"id":13433,"position":13,"arabic":"لِلَّهِ","translation":"আল্লাহরই","audioUrl":"wbw/040_012_015.mp3","charTypeName":"word"},{"id":13434,"position":14,"arabic":"ٱلْعَلِىِّ","translation":"(যিনি) সমুচ্চ","audioUrl":"wbw/040_012_016.mp3","charTypeName":"word"},{"id":13435,"position":15,"arabic":"ٱلْكَبِيرِ","translation":"মহান\"","audioUrl":"wbw/040_012_017.mp3","charTypeName":"word"},{"id":13436,"position":16,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]},{"number":13,"arabic":"هُوَ ٱلَّذِى يُرِيكُمْ ءَايَٰتِهِۦ وَيُنَزِّلُ لَكُم مِّنَ ٱلسَّمَآءِ رِزْقًۭا ۚ وَمَا يَتَذَكَّرُ إِلَّا مَن يُنِيبُ","translation":"HE IT IS who shows you His wonders [in all nature], and sends down sustenance for you from the sky: but none bethinks himself [thereof] save those who are wont to turn to God.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4146.mp3","surahId":40,"words":[{"id":14678,"position":1,"arabic":"هُوَ","translation":"তিনিই (আল্লাহ)","audioUrl":"wbw/040_013_001.mp3","charTypeName":"word"},{"id":14679,"position":2,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/040_013_002.mp3","charTypeName":"word"},{"id":14680,"position":3,"arabic":"يُرِيكُمْ","translation":"তোমাদেরকে দেখান","audioUrl":"wbw/040_013_003.mp3","charTypeName":"word"},{"id":14681,"position":4,"arabic":"ءَايَـٰتِهِۦ","translation":"নিদর্শনাবলী তাঁর","audioUrl":"wbw/040_013_004.mp3","charTypeName":"word"},{"id":14682,"position":5,"arabic":"وَيُنَزِّلُ","translation":"ও নামান","audioUrl":"wbw/040_013_005.mp3","charTypeName":"word"},{"id":14683,"position":6,"arabic":"لَكُم","translation":"তোমাদের জন্যে","audioUrl":"wbw/040_013_006.mp3","charTypeName":"word"},{"id":14684,"position":7,"arabic":"مِّنَ","translation":"হ'তে","audioUrl":"wbw/040_013_007.mp3","charTypeName":"word"},{"id":14685,"position":8,"arabic":"ٱلسَّمَآءِ","translation":"আকাশ","audioUrl":"wbw/040_013_008.mp3","charTypeName":"word"},{"id":14686,"position":9,"arabic":"رِزْقًۭا ۚ","translation":"জীবনের উপকরণ","audioUrl":"wbw/040_013_009.mp3","charTypeName":"word"},{"id":14688,"position":10,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/040_013_011.mp3","charTypeName":"word"},{"id":14689,"position":11,"arabic":"يَتَذَكَّرُ","translation":"শিক্ষাগ্রহণ করে","audioUrl":"wbw/040_013_012.mp3","charTypeName":"word"},{"id":14690,"position":12,"arabic":"إِلَّا","translation":"এ ব্যতীত","audioUrl":"wbw/040_013_013.mp3","charTypeName":"word"},{"id":14691,"position":13,"arabic":"مَن","translation":"যে","audioUrl":"wbw/040_013_014.mp3","charTypeName":"word"},{"id":14692,"position":14,"arabic":"يُنِيبُ","translation":"মুখ করে (আল্লাহর দিকে)","audioUrl":"wbw/040_013_015.mp3","charTypeName":"word"},{"id":14693,"position":15,"arabic":"١٣","translation":"(১৩)","audioUrl":null,"charTypeName":"end"}]},{"number":14,"arabic":"فَٱدْعُوا۟ ٱللَّهَ مُخْلِصِينَ لَهُ ٱلدِّينَ وَلَوْ كَرِهَ ٱلْكَٰفِرُونَ","translation":"Invoke, then, God, sincere in your faith in Him alone, however hateful this may be to those who deny the truth!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4147.mp3","surahId":40,"words":[{"id":15760,"position":1,"arabic":"فَٱدْعُوا۟","translation":"সুতরাং তোমরা ডাকো","audioUrl":"wbw/040_014_001.mp3","charTypeName":"word"},{"id":15761,"position":2,"arabic":"ٱللَّهَ","translation":"আল্লাহকে","audioUrl":"wbw/040_014_002.mp3","charTypeName":"word"},{"id":15762,"position":3,"arabic":"مُخْلِصِينَ","translation":"একনিষ্ঠ হয়ে","audioUrl":"wbw/040_014_003.mp3","charTypeName":"word"},{"id":15763,"position":4,"arabic":"لَهُ","translation":"তাঁরই জন্যে","audioUrl":"wbw/040_014_004.mp3","charTypeName":"word"},{"id":15764,"position":5,"arabic":"ٱلدِّينَ","translation":"আনুগত্যকে (নির্দিষ্ট করে)","audioUrl":"wbw/040_014_005.mp3","charTypeName":"word"},{"id":15765,"position":6,"arabic":"وَلَوْ","translation":"এবং যদিও","audioUrl":"wbw/040_014_006.mp3","charTypeName":"word"},{"id":15766,"position":7,"arabic":"كَرِهَ","translation":"অপছন্দ করে","audioUrl":"wbw/040_014_007.mp3","charTypeName":"word"},{"id":15767,"position":8,"arabic":"ٱلْكَـٰفِرُونَ","translation":"কাফেররা","audioUrl":"wbw/040_014_008.mp3","charTypeName":"word"},{"id":15768,"position":9,"arabic":"١٤","translation":"(১৪)","audioUrl":null,"charTypeName":"end"}]},{"number":15,"arabic":"رَفِيعُ ٱلدَّرَجَٰتِ ذُو ٱلْعَرْشِ يُلْقِى ٱلرُّوحَ مِنْ أَمْرِهِۦ عَلَىٰ مَن يَشَآءُ مِنْ عِبَادِهِۦ لِيُنذِرَ يَوْمَ ٱلتَّلَاقِ","translation":"High above all orders [of being] is He, in almightiness enthroned. By His Own will does He bestow inspiration upon whomever He wills of His servants, so as to warn [all human beings of the coming] of the Day when they shall meet Him","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4148.mp3","surahId":40,"words":[{"id":16851,"position":1,"arabic":"رَفِيعُ","translation":"সমুচ্চ","audioUrl":"wbw/040_015_001.mp3","charTypeName":"word"},{"id":16852,"position":2,"arabic":"ٱلدَّرَجَـٰتِ","translation":"মর্যাদাসমুহের (অধিকারী)","audioUrl":"wbw/040_015_002.mp3","charTypeName":"word"},{"id":16853,"position":3,"arabic":"ذُو","translation":"অধিপতি","audioUrl":"wbw/040_015_003.mp3","charTypeName":"word"},{"id":16854,"position":4,"arabic":"ٱلْعَرْشِ","translation":"আরশের","audioUrl":"wbw/040_015_004.mp3","charTypeName":"word"},{"id":16855,"position":5,"arabic":"يُلْقِى","translation":"প্রেরণ করেন","audioUrl":"wbw/040_015_005.mp3","charTypeName":"word"},{"id":16856,"position":6,"arabic":"ٱلرُّوحَ","translation":"রূহকে (অর্থাৎ ওহী)","audioUrl":"wbw/040_015_006.mp3","charTypeName":"word"},{"id":16857,"position":7,"arabic":"مِنْ","translation":"মধ্য হতে","audioUrl":"wbw/040_015_007.mp3","charTypeName":"word"},{"id":16858,"position":8,"arabic":"أَمْرِهِۦ","translation":"তাঁর নির্দেশে","audioUrl":"wbw/040_015_008.mp3","charTypeName":"word"},{"id":16859,"position":9,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/040_015_009.mp3","charTypeName":"word"},{"id":16860,"position":10,"arabic":"مَن","translation":"যাকে","audioUrl":"wbw/040_015_010.mp3","charTypeName":"word"},{"id":16861,"position":11,"arabic":"يَشَآءُ","translation":"ইচ্ছে