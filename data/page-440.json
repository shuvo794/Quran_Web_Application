{"id":440,"ayahs":[{"number":45,"arabic":"وَلَوْ يُؤَاخِذُ ٱللَّهُ ٱلنَّاسَ بِمَا كَسَبُوا۟ مَا تَرَكَ عَلَىٰ ظَهْرِهَا مِن دَآبَّةٍۢ وَلَٰكِن يُؤَخِّرُهُمْ إِلَىٰٓ أَجَلٍۢ مُّسَمًّۭى ۖ فَإِذَا جَآءَ أَجَلُهُمْ فَإِنَّ ٱللَّهَ كَانَ بِعِبَادِهِۦ بَصِيرًۢا","translation":"Now if God were to take men [at once] to task for whatever [wrong] they commit [on earth], He would not leave a single living creature upon its surface. However, He grants them respite for a term set [by Him]: but when their term comes to an end - then, verily, [they come to know that] God sees all that is in [the hearts of] His servants.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3705.mp3","surahId":35,"words":[{"id":45523,"position":1,"arabic":"وَلَوْ","translation":"এবং যদি","audioUrl":"wbw/035_045_001.mp3","charTypeName":"word"},{"id":45524,"position":2,"arabic":"يُؤَاخِذُ","translation":"পাকড়াও করতেন","audioUrl":"wbw/035_045_002.mp3","charTypeName":"word"},{"id":45525,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/035_045_003.mp3","charTypeName":"word"},{"id":45526,"position":4,"arabic":"ٱلنَّاسَ","translation":"মানুষকে","audioUrl":"wbw/035_045_004.mp3","charTypeName":"word"},{"id":45527,"position":5,"arabic":"بِمَا","translation":"এ কারণে যা","audioUrl":"wbw/035_045_005.mp3","charTypeName":"word"},{"id":45528,"position":6,"arabic":"كَسَبُوا۟","translation":"তারা কামাই করেছে","audioUrl":"wbw/035_045_006.mp3","charTypeName":"word"},{"id":45529,"position":7,"arabic":"مَا","translation":"না","audioUrl":"wbw/035_045_007.mp3","charTypeName":"word"},{"id":45530,"position":8,"arabic":"تَرَكَ","translation":"রেহাই দিতেন","audioUrl":"wbw/035_045_008.mp3","charTypeName":"word"},{"id":45531,"position":9,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/035_045_009.mp3","charTypeName":"word"},{"id":45532,"position":10,"arabic":"ظَهْرِهَا","translation":"তার পৃষ্ঠের","audioUrl":"wbw/035_045_010.mp3","charTypeName":"word"},{"id":45533,"position":11,"arabic":"مِن","translation":"কোনো","audioUrl":"wbw/035_045_011.mp3","charTypeName":"word"},{"id":45534,"position":12,"arabic":"دَآبَّةٍۢ","translation":"চলমান প্রাণীকেই","audioUrl":"wbw/035_045_012.mp3","charTypeName":"word"},{"id":45535,"position":13,"arabic":"وَلَـٰكِن","translation":"কিন্তু","audioUrl":"wbw/035_045_013.mp3","charTypeName":"word"},{"id":45536,"position":14,"arabic":"يُؤَخِّرُهُمْ","translation":"তাদের অবকাশ দিয়ে থাকেন তিনি","audioUrl":"wbw/035_045_014.mp3","charTypeName":"word"},{"id":45537,"position":15,"arabic":"إِلَىٰٓ","translation":"পর্যন্ত","audioUrl":"wbw/035_045_015.mp3","charTypeName":"word"},{"id":45538,"position":16,"arabic":"أَجَلٍۢ","translation":"একটা সময়","audioUrl":"wbw/035_045_016.mp3","charTypeName":"word"},{"id":45539,"position":17,"arabic":"مُّسَمًّۭى ۖ","translation":"নির্দিষ্ট","audioUrl":"wbw/035_045_017.mp3","charTypeName":"word"},{"id":45541,"position":18,"arabic":"فَإِذَا","translation":"অতঃপর যখন","audioUrl":"wbw/035_045_019.mp3","charTypeName":"word"},{"id":45542,"position":19,"arabic":"جَآءَ","translation":"আসবে","audioUrl":"wbw/035_045_020.mp3","charTypeName":"word"},{"id":45543,"position":20,"arabic":"أَجَلُهُمْ","translation":"তাদের সময়","audioUrl":"wbw/035_045_021.mp3","charTypeName":"word"},{"id":45544,"position":21,"arabic":"فَإِنَّ","translation":"নিশ্চযই় তখন","audioUrl":"wbw/035_045_022.mp3","charTypeName":"word"},{"id":45545,"position":22,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/035_045_023.mp3","charTypeName":"word"},{"id":45546,"position":23,"arabic":"كَانَ","translation":"হবেন","audioUrl":"wbw/035_045_024.mp3","charTypeName":"word"},{"id":45547,"position":24,"arabic":"بِعِبَادِهِۦ","translation":"তাঁর দাসদের সম্পর্কে","audioUrl":"wbw/035_045_025.mp3","charTypeName":"word"},{"id":45548,"position":25,"arabic":"بَصِيرًۢا","translation":"খুব দেখেন (অর্থাৎ দেখে নিবেন)","audioUrl":"wbw/035_045_026.mp3","charTypeName":"word"},{"id":45549,"position":26,"arabic":"٤٥","translation":"(৪৫)","audioUrl":n