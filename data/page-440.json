ioUrl":"wbw/036_004_001.mp3","charTypeName":"word"},{"id":4525,"position":2,"arabic":"صِرَٰطٍۢ","translation":"পথের","audioUrl":"wbw/036_004_002.mp3","charTypeName":"word"},{"id":4526,"position":3,"arabic":"مُّسْتَقِيمٍۢ","translation":"সরল সঠিক","audioUrl":"wbw/036_004_003.mp3","charTypeName":"word"},{"id":4527,"position":4,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"تَنزِيلَ ٱلْعَزِيزِ ٱلرَّحِيمِ","translation":"by [virtue of] what is being bestowed from on high by the Almighty, the Dispenser of Grace,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3710.mp3","surahId":36,"words":[{"id":5782,"position":1,"arabic":"تَنزِيلَ","translation":"(এই কোরআন) অবতীর্ণ করা","audioUrl":"wbw/036_005_001.mp3","charTypeName":"word"},{"id":5783,"position":2,"arabic":"ٱلْعَزِيزِ","translation":"পরাক্রমশালীর (পক্ষ হ'তে)","audioUrl":"wbw/036_005_002.mp3","charTypeName":"word"},{"id":5784,"position":3,"arabic":"ٱلرَّحِيمِ","translation":"(যিনি) পরম দয়ালু","audioUrl":"wbw/036_005_003.mp3","charTypeName":"word"},{"id":5785,"position":4,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"لِتُنذِرَ قَوْمًۭا مَّآ أُنذِرَ ءَابَآؤُهُمْ فَهُمْ غَٰفِلُونَ","translation":"[bestowed upon thee] so that thou mayest warn people whose forefathers had not been warned, and who therefore are unaware [of the meaning of right and wrong].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3711.mp3","surahId":36,"words":[{"id":7069,"position":1,"arabic":"لِتُنذِرَ","translation":"সতর্ক করো তুমি যেন","audioUrl":"wbw/036_006_001.mp3","charTypeName":"word"},{"id":7070,"position":2,"arabic":"قَوْمًۭا","translation":"(এমন) জাতিকে","audioUrl":"wbw/036_006_002.mp3","charTypeName":"word"},{"id":7071,"position":3,"arabic":"مَّآ","translation":"না","audioUrl":"wbw/036_006_003.mp3","charTypeName":"word"},{"id":7072,"position":4,"arabic":"أُنذِرَ","translation":"সতর্ক করা হয়েছে","audioUrl":"wbw/036_006_004.mp3","charTypeName":"word"},{"id":7073,"position":5,"arabic":"ءَابَآؤُهُمْ","translation":"তাদের পিতৃ-পুরুষদেরকে","audioUrl":"wbw/036_006_005.mp3","charTypeName":"word"},{"id":7074,"position":6,"arabic":"فَهُمْ","translation":"অতএব তারা","audioUrl":"wbw/036_006_006.mp3","charTypeName":"word"},{"id":7075,"position":7,"arabic":"غَـٰفِلُونَ","translation":"উদাসীন (হয়ে আছে)","audioUrl":"wbw/036_006_007.mp3","charTypeName":"word"},{"id":7076,"position":8,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"لَقَدْ حَقَّ ٱلْقَوْلُ عَلَىٰٓ أَكْثَرِهِمْ فَهُمْ لَا يُؤْمِنُونَ","translation":"Indeed, the word [of God’s condemnation] is bound to come true against most of them: for they will not believe.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3712.mp3","surahId":36,"words":[{"id":8380,"position":1,"arabic":"لَقَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/036_007_001.mp3","charTypeName":"word"},{"id":8381,"position":2,"arabic":"حَقَّ","translation":"অবধারিত হয়েছে","audioUrl":"wbw/036_007_002.mp3","charTypeName":"word"},{"id":8382,"position":3,"arabic":"ٱلْقَوْلُ","translation":"(শান্তির) বাণী","audioUrl":"wbw/036_007_003.mp3","charTypeName":"word"},{"id":8383,"position":4,"arabic":"عَلَىٰٓ","translation":"উপর","audioUrl":"wbw/036_007_004.mp3","charTypeName":"word"},{"id":8384,"position":5,"arabic":"أَكْثَرِهِمْ","translation":"তাদের অধিক অংশের","audioUrl":"wbw/036_007_005.mp3","charTypeName":"word"},{"id":8385,"position":6,"arabic":"فَهُمْ","translation":"সুতরাং তারা","audioUrl":"wbw/036_007_006.mp3","charTypeName":"word"},{"id":8386,"position":7,"arabic":"لَا","translation":"না","audioUrl":"wbw/036_007_007.mp3","charTypeName":"word"},{"id":8387,"position":8,"arabic":"يُؤْمِنُونَ","translation":"ঈমান আনবে","audioUrl":"wbw/036_007_008.mp3","charTypeName":"word"},{"id":8388,"position":9,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"إِنَّا جَعَلْنَا فِىٓ أَعْنَٰقِهِمْ أَغْلَٰلًۭا فَهِىَ إِلَى ٱلْأَذْقَانِ فَهُم مُّقْمَحُونَ","translation":"Behold, around their necks We have put shack­les, reaching up to their chins, so that their heads are forced up;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3713.mp3","surahId":36,"words":[{"id":9561,"position":1,"arabic":"إِنَّا","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/036_008_001.mp3","charTypeName":"word"},{"id":9562,"position":2,"arabic":"جَعَلْنَا","translation":"আমরা লাগিয়েছি","audioUrl":"wbw/036_008_002.mp3","charTypeName":"word"},{"id":9563,"position":3,"arabic":"فِىٓ","translation":"উপর","audioUrl":"wbw/036_008_003.mp3","charTypeName":"word"},{"id":9564,"position":4,"arabic":"أَعْنَـٰقِهِمْ","translation":"তাদের গলায়","audioUrl":"wbw/036_008_004.mp3","charTypeName":"word"},{"id":9565,"position":5,"arabic":"أَغْلَـٰلًۭا","translation":"বেড়িসমূহ","audioUrl":"wbw/036_008_005.mp3","charTypeName":"word"},{"id":9566,"position":6,"arabic":"فَهِىَ","translation":"তা তাই","audioUrl":"wbw/036_008_006.mp3","charTypeName":"word"},{"id":9567,"position":7,"arabic":"إِلَى","translation":"(রয়েছে) পর্যন্ত","audioUrl":"wbw/036_008_007.mp3","charTypeName":"word"},{"id":9568,"position":8,"arabic":"ٱلْأَذْقَانِ","translation":"চিবুকগুলো (শৃঙ্খলিত হয়ে)","audioUrl":"wbw/036_008_008.mp3","charTypeName":"word"},{"id":9569,"position":9,"arabic":"فَهُم","translation":"তারা এজন্য","audioUrl":"wbw/036_008_009.mp3","charTypeName":"word"},{"id":9570,"position":10,"arabic":"مُّقْمَحُونَ","translation":"ঊর্ধ্বমুখী (হয়ে আছে)","audioUrl":"wbw/036_008_010.mp3","charTypeName":"word"},{"id":9571,"position":11,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"وَجَعَلْنَا مِنۢ بَيْنِ أَيْدِيهِمْ سَدًّۭا وَمِنْ خَلْفِهِمْ سَدًّۭا فَأَغْشَيْنَٰهُمْ فَهُمْ لَا يُبْصِرُونَ","translation":"and We have set a barrier before them and a barrier behind them, and We have enshrouded them in veils so that they cannot see:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3714.mp3","surahId":36,"words":[{"id":10741,"position":1,"arabic":"وَجَعَلْنَا","translation":"এবং আমরা খাড়া করেছি","audioUrl":"wbw/036_009_001.mp3","charTypeName":"word"},{"id":10742,"position":2,"arabic":"مِنۢ","translation":"থেকে","audioUrl":"wbw/036_009_002.mp3","charTypeName":"word"},{"id":10743,"position":3,"arabic":"بَيْنِ","translation":"সামনে","audioUrl":"wbw/036_009_003.mp3","charTypeName":"word"},{"id":10744,"position":4,"arabic":"أَيْدِيهِمْ","translation":"তাদের","audioUrl":"wbw/036_009_004.mp3","charTypeName":"word"},{"id":10745,"position":5,"arabic":"سَدًّۭا","translation":"প্রাচীর","audioUrl":"wbw/036_009_005.mp3","charTypeName":"word"},{"id":10746,"position":6,"arabic":"وَمِنْ","translation":"ও থেকে","audioUrl":"wbw/036_009_006.mp3","charTypeName":"word"},{"id":10747,"position":7,"arabic":"خَلْفِهِمْ","translation":"তাদের পিছন","audioUrl":"wbw/036_009_007.mp3","charTypeName":"word"},{"id":10748,"position":8,"arabic":"سَدًّۭا","translation":"প্রাচীর","audioUrl":"wbw/036_009_008.mp3","charTypeName":"word"},{"id":10749,"position":9,"arabic":"فَأَغْشَيْنَـٰهُمْ","translation":"তাদেরকে আমরা এভাবে ঢেকে দিয়েছি","audioUrl":"wbw/036_009_009.mp3","charTypeName":"word"},{"id":10750,"position":10,"arabic":"فَهُمْ","translation":"তারা অতএব","audioUrl":"wbw/036_009_010.mp3","charTypeName":"word"},{"id":10751,"position":11,"arabic":"لَا","translation":"না","audioUrl":"wbw/036_009_011.mp3","charTypeName":"word"},{"id":10752,"position":12,"arabic":"يُبْصِرُونَ","translation":"দেখতে পায়","audioUrl":"wbw/036_009_012.mp3","charTypeName":"word"},{"id":10753,"position":13,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"وَسَوَآءٌ عَلَيْهِمْ ءَأَنذَرْتَهُمْ أَمْ لَمْ تُنذِرْهُمْ لَا يُؤْمِنُونَ","translation":"thus, it is all one to them whether thou warnest them or dost not warn them: they will not believe.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3715.mp3","surahId":36,"words":[{"id":11994,"position":1,"arabic":"وَسَوَآءٌ","translation":"এবং সমান","audioUrl":"wbw/036_010_001.mp3","charTypeName":"word"},{"id":11995,"position":2,"arabic":"عَلَيْهِمْ","translation":"তাদের পক্ষে","audioUrl":"wbw/036_010_002.mp3","charTypeName":"word"},{"id":11996,"position":3,"arabic":"ءَأَنذَرْتَهُمْ","translation":"তাদের তুমি সতর্ক করো কি","audioUrl":"wbw/036_010_003.mp3","charTypeName":"word"},{"id":11997,"position":4,"arabic":"أَمْ","translation":"বা","audioUrl":"wbw/036_010_004.mp3","charTypeName":"word"},{"id":11998,"position":5,"arabic":"لَمْ","translation":"নি","audioUrl":"wbw/036_010_005.mp3","charTypeName":"word"},{"id":11999,"position":6,"arabic":"تُنذِرْهُمْ","translation":"তাদের সতর্ক করো তুমি","audioUrl":"wbw/036_010_006.mp3","charTypeName":"word"},{"id":12000,"position":7,"arabic":"لَا","translation":"না","audioUrl":"wbw/036_010_007.mp3","charTypeName":"word"},{"id":12001,"position":8,"arabic":"يُؤْمِنُونَ","translation":"তারা ঈমান আনবে","audioUrl":"wbw/036_010_008.mp3","charTypeName":"word"},{"id":12002,"position":9,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"إِنَّمَا تُنذِرُ مَنِ ٱتَّبَعَ ٱلذِّكْرَ وَخَشِىَ ٱلرَّحْمَٰنَ بِٱلْغَيْبِ ۖ فَبَشِّرْهُ بِمَغْفِرَةٍۢ وَأَجْرٍۢ كَرِيمٍ","translation":"Thou canst [truly] warn only him who is willing to take the reminder to heart, and who stands in awe of the Most Gracious although He is beyond the reach of human perception: unto such, then, give the glad tiding of [God’s] forgiveness and of a most excellent reward!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3716.mp3","surahId":36,"words":[{"id":13300,"position":1,"arabic":"إِنَّمَا","translation":"প্রকৃতপক্ষে","audioUrl":"wbw/036_011_001.mp3","charTypeName":"word"},{"id":13301,"position":2,"arabic":"تُنذِرُ","translation":"সতর্ক করো তুমি","audioUrl":"wbw/036_011_002.mp3","charTypeName":"word"},{"id":13302,"position":3,"arabic":"مَنِ","translation":"(তাকে) যে","audioUrl":"wbw/036_011_003.mp3","charTypeName":"word"},{"id":13303,"position":4,"arabic":"ٱتَّبَعَ","translation":"মেনে চলে","audioUrl":"wbw/036_011_004.mp3","charTypeName":"word"},{"id":13304,"position":5,"arabic":"ٱلذِّكْرَ","translation":"উপদেশ","audioUrl":"wbw/036_011_005.mp3","charTypeName":"word"},{"id":13305,"position":6,"arabic":"وَخَشِىَ","translation":"ও ভয় করে","audioUrl":"wbw/036_011_006.mp3","charTypeName":"word"},{"id":13306,"position":7,"arabic":"ٱلرَّحْمَـٰنَ","translation":"দয়াময়কে","audioUrl":"wbw/036_011_007.mp3","charTypeName":"word"},{"id":13307,"position":8,"arabic":"بِٱلْغَيْبِ ۖ","translation":"না দেখা অবস্থায়","audioUrl":"wbw/036_011_008.mp3","charTypeName":"word"},{"id":13309,"position":9,"arabic":"فَبَشِّرْهُ","translation":"তাকে সুতরাং দাও সুসংবাদ","audioUrl":"wbw/036_011_010.mp3","charTypeName":"word"},{"id":13310,"position":10,"arabic":"بِمَغْفِرَةٍۢ","translation":"ক্ষমার","audioUrl":"wbw/036_011_011.mp3","charTypeName":"word"},{"id":13311,"position":11,"arabic":"وَأَجْرٍۢ","translation":"ও প্রতিফলের","audioUrl":"wbw/036_011_012.mp3","charTypeName":"word"},{"id":13312,"position":12,"arabic":"كَرِيمٍ","translation":"সম্মানজনক","audioUrl":"wbw/036_011_013.mp3","charTypeName":"word"},{"id":13313,"position":13,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]},{"number":12,"arabic":"إِنَّا نَحْنُ نُحْىِ ٱلْمَوْتَىٰ وَنَكْتُبُ مَا قَدَّمُوا۟ وَءَاثَٰرَهُمْ ۚ وَكُلَّ شَىْءٍ أَحْصَيْنَٰهُ فِىٓ إِمَامٍۢ مُّبِينٍۢ","translation":"Verily, We shall indeed bring the dead back to life; and We shall record whatever [deeds] they have sent ahead, and the traces [of good and evil] which they have left behind: for of all things do We take account in a record clear.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3717.mp3","surahId":36,"words":[{"id":14591,"position":1,"arabic":"إِنَّا","translation":"নিশ্চয়ই","audioUrl":"wbw/036_012_001.mp3","charTypeName":"word"},{"id":14592,"position":2,"arabic":"نَحْنُ","translation":"আমরা","audioUrl":"wbw/036_012_002.mp3","charTypeName":"word"},{"id":14593,"position":3,"arabic":"نُحْىِ","translation":"জীবিত করবো (একদিন)","audioUrl":"wbw/036_012_003.mp3","charTypeName":"word"},{"id":14594,"position":4,"arabic":"ٱلْمَوْتَىٰ","translation":"মৃতদেরকে","audioUrl":"wbw/036_012_004.mp3","charTypeName":"word"},{"id":14595,"position":5,"arabic":"وَنَكْتُبُ","translation":"এবং আমরা লিখে রাখি","audioUrl":"wbw/036_012_005.mp3","charTypeName":"word"},{"id":14596,"position":6,"arabic":"مَا","translation":"যা","audioUrl":"wbw/036_012_006.mp3","charTypeName":"word"},{"id":14597,"position":7,"arabic":"قَدَّمُوا۟","translation":"তারা আগে পাঠিয়েছে","audioUrl":"wbw/036_012_007.mp3","charTypeName":"word"},{"id":14598,"position":8,"arabic":"وَءَاثَـٰرَهُمْ ۚ","translation":"ও তাদের কীর্তিসমূহ (যা পিছনে রেখেছে)","audioUrl":"wbw/036_012_008.mp3","charTypeName":"word"},{"id":14600,"position":9,"arabic":"وَكُلَّ","translation":"এবং প্রত্যেক","audioUrl":"wbw/036_012_010.mp3","charTypeName":"word"},{"id":14601,"position":10,"arabic":"شَىْءٍ","translation":"জিনিস","audioUrl":"wbw/036_012_011.mp3","charTypeName":"word"},{"id":14602,"position":11,"arabic":"أَحْصَيْنَـٰهُ","translation":"তা আমরা সংরক্ষণ করেছি","audioUrl":"wbw/036_012_012.mp3","charTypeName":"word"},{"id":14603,"position":12,"arabic":"فِىٓ","translation":"মধ্যে","audioUrl":"wbw/036_012_013.mp3","charTypeName":"word"},{"id":14604,"position":13,"arabic":"إِمَامٍۢ","translation":"একটি কিতাবের","audioUrl":"wbw/036_012_014.mp3","charTypeName":"word"},{"id":14605,"position":14,"arabic":"مُّبِينٍۢ","translation":"সুস্পষ্ট","audioUrl":"wbw/036_012_015.mp3","charTypeName":"word"},{"id":14606,"position":15,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]}]}