{"id":131,"ayahs":[{"number":28,"arabic":"بَلْ بَدَا لَهُم مَّا كَانُوا۟ يُخْفُونَ مِن قَبْلُ ۖ وَلَوْ رُدُّوا۟ لَعَادُوا۟ لِمَا نُهُوا۟ عَنْهُ وَإِنَّهُمْ لَكَٰذِبُونَ","translation":"But nay -[they will say this only because] the truth which they used to conceal [from themselves] in the past will have become obvious to them; and if they were brought back [to life], they would return to the very thing which was forbidden to them: for behold, they are indeed liars!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/817.mp3","surahId":6,"words":[{"id":31185,"position":1,"arabic":"بَلْ","translation":"বরং","audioUrl":"wbw/006_028_001.mp3","charTypeName":"word"},{"id":31186,"position":2,"arabic":"بَدَا","translation":"প্রকাশ পাবে","audioUrl":"wbw/006_028_002.mp3","charTypeName":"word"},{"id":31187,"position":3,"arabic":"لَهُم","translation":"কাছে তাদের","audioUrl":"wbw/006_028_003.mp3","charTypeName":"word"},{"id":31188,"position":4,"arabic":"مَّا","translation":"যা","audioUrl":"wbw/006_028_004.mp3","charTypeName":"word"},{"id":31189,"position":5,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/006_028_005.mp3","charTypeName":"word"},{"id":31190,"position":6,"arabic":"يُخْفُونَ","translation":"তারা গোপন করতে","audioUrl":"wbw/006_028_006.mp3","charTypeName":"word"},{"id":31191,"position":7,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/006_028_007.mp3","charTypeName":"word"},{"id":31192,"position":8,"arabic":"قَبْلُ ۖ","translation":"পূর্ব","audioUrl":"wbw/006_028_008.mp3","charTypeName":"word"},{"id":31194,"position":9,"arabic":"وَلَوْ","translation":"এবং যদি","audioUrl":"wbw/006_028_010.mp3","charTypeName":"word"},{"id":31195,"position":10,"arabic":"رُدُّوا۟","translation":"তারা প্রত্যাবর্তিত হয়ও","audioUrl":"wbw/006_028_011.mp3","charTypeName":"word"},{"id":31196,"position":11,"arabic":"لَعَادُوا۟","translation":"অবশ্যই পুনরাবৃত্তি করবে","audioUrl":"wbw/006_028_012.mp3","charTypeName":"word"},{"id":31197,"position":12,"arabic":"لِمَا","translation":"যা কিছু","audioUrl":"wbw/006_028_013.mp3","charTypeName":"word"},{"id":31198,"position":13,"arabic":"نُهُوا۟","translation":"তাদের নিষেধ করা হয়েছিলো","audioUrl":"wbw/006_028_014.mp3","charTypeName":"word"},{"id":31199,"position":14,"arabic":"عَنْهُ","translation":"হতে তা","audioUrl":"wbw/006_028_015.mp3","charTypeName":"word"},{"id":31200,"position":15,"arabic":"وَإِنَّهُمْ","translation":"এবং নিশ্চয়ই তারা","audioUrl":"wbw/006_028_016.mp3","charTypeName":"word"},{"id":31201,"position":16,"arabic":"لَكَـٰذِبُونَ","translation":"অবশ্যই মিথ্যাবাদী","audioUrl":"wbw/006_028_017.mp3","charTypeName":"word"},{"id":31202,"position":17,"arabic":"٢٨","translation":"(২৮)","audioUrl":null,"charTypeName":"end"}]},{"number":29,"arabic":"وَقَالُوٓا۟ إِنْ هِىَ إِلَّا حَيَاتُنَا ٱلدُّنْيَا وَمَا نَحْنُ بِمَبْعُوثِينَ","translation":"And some [of the unbelievers] say, \"There is nothing beyond our life in this world, for We shall not be raised from the dead.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/818.mp3","surahId":6,"words":[{"id":32170,"position":1,"arabic":"وَقَالُوٓا۟","translation":"এবং তারা বলে","audioUrl":"wbw/006_029_001.mp3","charTypeName":"word"},{"id":32171,"position":2,"arabic":"إِنْ","translation":"\"নেই","audioUrl":"wbw/006_029_002.mp3","charTypeName":"word"},{"id":32172,"position":3,"arabic":"هِىَ","translation":"\"এটা (অর্থাৎ আখিরাতের জীবন)","audioUrl":"wbw/006_029_003.mp3","charTypeName":"word"},{"id":32173,"position":4,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/006_029_004.mp3","charTypeName":"word"},{"id":32174,"position":5,"arabic":"حَيَاتُنَا","translation":"জীবন আমাদের","audioUrl":"wbw/006_029_005.mp3","charTypeName":"word"},{"id":32175,"position":6,"arabic":"ٱلدُّنْيَا","translation":"পার্থিব","audioUrl":"wbw/006_029_006.mp3","charTypeName":"word"},{"id":32176,"position":7,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/006_029_007.mp3","charTypeName":"word"},{"id":32177,"position":8,"arabic":"نَحْنُ","translation":"আমরা","audioUrl":"wbw/006_029_008.mp3","charTypeName":"word"},{"id":32178,"position":9,"arabic":"بِمَبْعُوثِينَ","translation":"উত্থিত হবো\"","audioUrl":"wbw/006_029_009.mp3","charTypeName":"word"},{"id":32179,"position":10,"arabic":"٢٩","translation":"(২৯)","audioUrl":null,"charTypeName":"end"}]},{"number":30,"arabic":"وَلَوْ تَرَىٰٓ إِذْ وُقِفُوا۟ عَلَىٰ رَبِّهِمْ ۚ قَالَ أَلَيْسَ هَٰذَا بِٱلْحَقِّ ۚ قَالُوا۟ بَلَىٰ وَرَبِّنَا ۚ قَالَ فَذُوقُوا۟ ٱلْعَذَابَ بِمَا كُنتُمْ تَكْفُرُونَ","translation":"If thou couldst but see [them] when they shall be made to stand before their Sustainer [and] He will say, \"Is not this the truth?\" They will answer: \"Yea, indeed, by our Sustainer!\" [Whereupon] He will say: \"Taste, then, the suffering that comes from your having refused to acknowledge the truth!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/819.mp3","surahId":6,"words":[{"id":33005,"position":1,"arabic":"وَلَوْ","translation":"এবং যদি","audioUrl":"wbw/006_030_001.mp3","charTypeName":"word"},{"id":33006,"position":2,"arabic":"تَرَىٰٓ","translation":"দেখতে তুমি (সে অবস্থা)","audioUrl":"wbw/006_030_002.mp3","charTypeName":"word"},{"id":33007,"position":3,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/006_030_003.mp3","charTypeName":"word"},{"id":33008,"position":4,"arabic":"وُقِفُوا۟","translation":"তাদের দাঁড় করানো হবে","audioUrl":"wbw/006_030_004.mp3","charTypeName":"word"},{"id":33009,"position":5,"arabic":"عَلَىٰ","translation":"সামনে","audioUrl":"wbw/006_030_005.mp3","charTypeName":"word"},{"id":33010,"position":6,"arabic":"رَبِّهِمْ ۚ","translation":"রবের তাদের","audioUrl":"wbw/006_030_006.mp3","charTypeName":"word"},{"id":33012,"position":7,"arabic":"قَالَ","translation":"(আল্লাহ) বলবেন","audioUrl":"wbw/006_030_008.mp3","charTypeName":"word"},{"id":33013,"position":8,"arabic":"أَلَيْسَ","translation":"\"কি নয়","audioUrl":"wbw/006_030_009.mp3","charTypeName":"word"},{"id":33014,"position":9,"arabic":"هَـٰذَا","translation":"এই (উত্থান)","audioUrl":"wbw/006_030_010.mp3","charTypeName":"word"},{"id":33015,"position":10,"arabic":"بِٱلْحَقِّ ۚ","translation":"ভাবে সঠিক\"","audioUrl":"wbw/006_030_011.mp3","charTypeName":"word"},{"id":33017,"position":11,"arabic":"قَالُوا۟","translation":"তারা বলবে","audioUrl":"wbw/006_030_013.mp3","charTypeName":"word"},{"id":33018,"position":12,"arabic":"بَلَىٰ","translation":"\"হ্যাঁ","audioUrl":"wbw/006_030_014.mp3","charTypeName":"word"},{"id":33019,"position":13,"arabic":"وَرَبِّنَا ۚ","translation":"শপথ রবের আমাদের\"","audioUrl":"wbw/006_030_015.mp3","charTypeName":"word"},{"id":33021,"position":14,"arabic":"قَالَ","translation":"বলবেন তিনি","audioUrl":"wbw/006_030_017.mp3","charTypeName":"word"},{"id":33022,"position":15,"arabic":"فَذُوقُوا۟","translation":"\"তাহ'লে তোমরা স্বাদ নাও","audioUrl":"wbw/006_030_018.mp3","charTypeName":"word"},{"id":33023,"position":16,"arabic":"ٱلْعَذَابَ","translation":"শাস্তির","audioUrl":"wbw/006_030_019.mp3","charTypeName":"word"},{"id":33024,"position":17,"arabic":"بِمَا","translation":"এ কারণে যা","audioUrl":"wbw/006_030_020.mp3","charTypeName":"word"},{"id":33025,"position":18,"arabic":"كُنتُمْ","translation":"তোমরা ছিলে","audioUrl":"wbw/006_030_021.mp3","charTypeName":"word"},{"id":33026,"position":19,"arabic":"تَكْفُرُونَ","translation":"তোমরা অস্বীকার করতে\"","audioUrl":"wbw/006_030_022.mp3","charTypeName":"word"},{"id":33027,"position":20,"arabic":"٣٠","translation":"(৩০)","audioUrl":null,"charTypeName":"end"}]},{"number":31,"arabic":"قَدْ خَسِرَ ٱلَّذِينَ كَذَّبُوا۟ بِلِقَآءِ ٱللَّهِ ۖ حَتَّىٰٓ إِذَا جَآءَتْهُمُ ٱلسَّاعَةُ بَغْتَةًۭ قَالُوا۟ يَٰحَسْرَتَنَا عَلَىٰ مَا فَرَّطْنَا فِيهَا وَهُمْ يَحْمِلُونَ أَوْزَارَهُمْ عَلَىٰ ظُهُورِهِمْ ۚ أَلَا سَآءَ مَا يَزِرُونَ","translation":"Lost indeed are they who consider it a lie that they will have to meet God -till the Last Hour suddenly comes upon them, [and] they cry, \"Alas for us, that we disregarded it!\" - for they shall bear on their backs the burden of their sins: oh, how evil the load with which they shall be burdened!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/820.mp3","surahId":6,"words":[{"id":33929,"position":1,"arabic":"قَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/006_031_001.mp3","charTypeName":"word"},{"id":33930,"position":2,"arabic":"خَسِرَ","translation":"ক্ষতিগ্রস্ত হয়েছে","audioUrl":"wbw/006_031_002.mp3","charTypeName":"word"},{"id":33931,"position":3,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/006_031_003.mp3","charTypeName":"word"},{"id":33932,"position":4,"arabic":"كَذَّبُوا۟","translation":"মিথ্যা আরোপ করেছে","audioUrl":"wbw/006_031_004.mp3","charTypeName":"word"},{"id":33933,"position":5,"arabic":"بِلِقَآءِ","translation":"প্রতি সাক্ষাতের","audioUrl":"wbw/006_031_005.mp3","charTypeName":"word"},{"id":33934,"position":6,"arabic":"ٱللَّهِ ۖ","translation":"আল্লাহর","audioUrl":"wbw/006_031_006.mp3","charTypeName":"word"},{"id":33936,"position":7,"arabic":"حَتَّىٰٓ","translation":"এমনকি","audioUrl":"wbw/006_031_008.mp3","charTypeName":"word"},{"id":33937,"position":8,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/006_031_009.mp3","charTypeName":"word"},{"id":33938,"position":9,"arabic":"جَآءَتْهُمُ","translation":"কাছে আসবে তাদের","audioUrl":"wbw/006_031_010.mp3","charTypeName":"word"},{"id":33939,"position":10,"arabic":"ٱلسَّاعَةُ","translation":"ক্বিয়ামাত","audioUrl":"wbw/006_031_011.mp3","charTypeName":"word"},{"id":33940,"position":11,"arabic":"بَغْتَةًۭ","translation":"হঠাৎ","audioUrl":"wbw/006_031_012.mp3","charTypeName":"word"},{"id":33941,"position":12,"arabic":"قَالُوا۟","translation":"তারা বলবে","audioUrl":"wbw/006_031_013.mp3","charTypeName":"word"},{"id":33942,"position":13,"arabic":"يَـٰحَسْرَتَنَا","translation":"\"হায় আক্ষেপ আমাদের","audioUrl":"wbw/006_031_014.mp3","charTypeName":"word"},{"id":33943,"position":14,"arabic":"عَلَىٰ","translation":"এর উপর","audioUrl":"wbw/006_031_015.mp3","charTypeName":"word"},{"id":33944,"position":15,"arabic":"مَا","translation":"যা","audioUrl":"wbw/006_031_016.mp3","charTypeName":"word"},{"id":33945,"position":16,"arabic":"فَرَّطْنَا","translation":"অবজ্ঞা করেছি আমরা","audioUrl":"wbw/006_031_017.mp3","charTypeName":"word"},{"id":33946,"position":17,"arabic":"فِيهَا","translation":"মধ্যে তার\"","audioUrl":"wbw/006_031_018.mp3","charTypeName":"word"},{"id":33947,"position":18,"arabic":"وَهُمْ","translation":"এবং তারা","audioUrl":"wbw/006_031_019.mp3","charTypeName":"word"},{"id":33948,"position":19,"arabic":"يَحْمِلُونَ","translation":"বহন করবে","audioUrl":"wbw/006_031_020.mp3","charTypeName":"word"},{"id":33949,"position":20,"arabic":"أَوْزَارَهُمْ","translation":"বোঝাসমূহ তাদের","audioUrl":"wbw/006_031_021.mp3","charTypeName":"word"},{"id":33950,"position":21,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/006_031_022.mp3","charTypeName":"word"},{"id":33951,"position":22,"arabic":"ظُهُورِهِمْ ۚ","translation":"পিঠগুলোর তাদের","audioUrl":"wbw/006_031_023.mp3","charTypeName":"word"},{"id":33953,"position":23,"arabic":"أَلَا","translation":"সাবধান","audioUrl":"wbw/006_031_025.mp3","charTypeName":"word"},{"id":33954,"position":24,"arabic":"سَآءَ","translation":"নিকৃষ্ট","audioUrl":"wbw/006_031_026.mp3","charTypeName":"word"},{"id":33955,"position":25,"arabic":"مَا","translation":"যা","audioUrl":"wbw/006_031_027.mp3","charTypeName":"word"},{"id":33956,"position":26,"arabic":"يَزِرُونَ","translation":"তারা বহন করবে","audioUrl":"wbw/006_031_028.mp3","charTypeName":"word"},{"id":33957,"position":27,"arabic":"٣١","translation":"(৩১)","audioUrl":null,"charTypeName":"end"}]},{"number":32,"arabic":"وَمَا ٱلْحَيَوٰةُ ٱلدُّنْيَآ إِلَّا لَعِبٌۭ وَلَهْوٌۭ ۖ وَلَلدَّارُ ٱلْءَاخِرَةُ خَيْرٌۭ لِّلَّذِينَ يَتَّقُونَ ۗ أَفَلَا تَعْقِلُونَ","translation":"And nothing is the life of this world but a play and a passing delight; and the life in the hereafter is by far the better for all who are conscious of God. Will you not, then, use your reason?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/821.mp3","surahId":6,"words":[{"id":34872,"position":1,"arabic":"وَمَا","translation":"এবং নয়","audioUrl":"wbw/006_032_001.mp3","charTypeName":"word"},{"id":34873,"position":2,"arabic":"ٱلْحَيَوٰةُ","translation":"জীবন","audioUrl":"wbw/006_032_002.mp3","charTypeName":"word"},{"id":34874,"position":3,"arabic":"ٱلدُّنْيَآ","translation":"পার্থিব","audioUrl":"wbw/006_032_003.mp3","charTypeName":"word"},{"id":34875,"position":4,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/006_032_004.mp3","charTypeName":"word"},{"id":34876,"position":5,"arabic":"لَعِبٌۭ","translation":"ক্রীড়া","audioUrl":"wbw/006_032_005.mp3","charTypeName":"word"},{"id":34877,"position":6,"arabic":"وَلَهْوٌۭ ۖ","translation":"ও কৌতুক","audioUrl":"wbw/006_032_006.mp3","charTypeName":"word"},{"id":34879,"position":7,"arabic":"وَلَلدَّارُ","translation":"এবং অবশ্যই আবাস","audioUrl":"wbw/006_032_008.mp3","charTypeName":"word"},{"id":34880,"position":8,"arabic":"ٱلْـَٔاخِرَةُ","translation":"আখিরাতের","audioUrl":"wbw/006_032_009.mp3","charTypeName":"word"},{"id":34881,"position":9,"arabic":"خَيْرٌۭ","translation":"উত্তম","audioUrl":"wbw/006_032_010.mp3","charTypeName":"word"},{"id":34882,"position":10,"arabic":"لِّلَّذِينَ","translation":"জন্যে তাদের (যারা)","audioUrl":"wbw/006_032_011.mp3","charTypeName":"word"},{"id":34883,"position":11,"arabic":"يَتَّقُونَ ۗ","translation":"আত্মরক্ষা করে চলে","audioUrl":"wbw/006_032_012.mp3","charTypeName":"word"},{"id":34885,"position":12,"arabic":"أَفَلَا","translation":"কি তবুও না","audioUrl":"wbw/006_032_014.mp3","charTypeName":"word"},{"id":34886,"position":13,"arabic":"تَعْقِلُونَ","translation":"তোমরা বুঝবে","audioUrl":"wbw/006_032_015.mp3","charTypeName":"word"},{"id":34887,"position":14,"arabic":"٣٢","translation":"(৩২)","audioUrl":null,"charTypeName":"end"}]},{"number":33,"arabic":"قَدْ نَعْلَمُ إِنَّهُۥ لَيَحْزُنُكَ ٱلَّذِى يَقُولُونَ ۖ فَإِنَّهُمْ لَا يُكَذِّبُونَكَ وَلَٰكِنَّ ٱلظَّٰلِمِينَ بِـَٔايَٰتِ ٱللَّهِ يَجْحَدُونَ","translation":"Well do We know that what such people say grieves thee indeed: yet, behold, it is not thee to whom they give the lie, but God's messages do these evildoers deny.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/822.mp3","surahId":6,"words":[{"id":35668,"position":1,"arabic":"قَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/006_033_001.mp3","charTypeName":"word"},{"id":35669,"position":2,"arabic":"نَعْلَمُ","translation":"জানি আমরা","audioUrl":"wbw/006_033_002.mp3","charTypeName":"word"},{"id":35670,"position":3,"arabic":"إِنَّهُۥ","translation":"নিশ্চয়ই তা","audioUrl":"wbw/006_033_003.mp3","charTypeName":"word"},{"id":35671,"position":4,"arabic":"لَيَحْزُنُكَ","translation":"অবশ্যই দুঃখ দেয় তোমাকে","audioUrl":"wbw/006_033_004.mp3","charTypeName":"word"},{"id":35672,"position":5,"arabic":"ٱلَّذِى","translation":"যা","audioUrl":"wbw/006_033_005.mp3","charTypeName":"word"},{"id":35673,"position":6,"arabic":"يَقُولُونَ ۖ","translation":"তারা বলে","audioUrl":"wbw/006_033_006.mp3","charTypeName":"word"},{"id":35675,"position":7,"arabic":"فَإِنَّهُمْ","translation":"তবে নিশ্চয়ই তারা","audioUrl":"wbw/006_033_008.mp3","charTypeName":"word"},{"id":35676,"position":8,"arabic":"لَا","translation":"না","audioUrl":"wbw/006_033_009.mp3","charTypeName":"word"},{"id":35677,"position":9,"arabic":"يُكَذِّبُونَكَ","translation":"তোমাকে মিথ্যারোপ করে","audioUrl":"wbw/006_033_010.mp3","charTypeName":"word"},{"id":35678,"position":10,"arabic":"وَلَـٰكِنَّ","translation":"কিন্তু","audioUrl":"wbw/006_033_011.mp3","charTypeName":"word"},{"id":35679,"position":11,"arabic":"ٱلظَّـٰلِمِينَ","translation":"সীমালঙ্ঘনকারীরা","audioUrl":"wbw/006_033_012.mp3","charTypeName":"word"},{"id":35680,"position":12,"arabic":"بِـَٔايَـٰتِ","translation":"প্রতি নিদর্শনাবলীর","audioUrl":"wbw/006_033_013.mp3","charTypeName":"word"},{"id":35681,"position":13,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/006_033_014.mp3","charTypeName":"word"},{"id":35682,"position":14,"arabic":"يَجْحَدُونَ","translation":"অস্বীকার করেছে","audioUrl":"wbw/006_033_015.mp3","charTypeName":"word"},{"id":35683,"position":15,"arabic":"٣٣","translation":"(৩৩)","audioUrl":null,"charTypeName":"end"}]},{"number":34,"arabic":"وَلَقَدْ كُذِّبَتْ رُسُلٌۭ مِّن قَبْلِكَ فَصَبَرُوا۟ عَلَىٰ مَا كُذِّبُوا۟ وَأُوذُوا۟ حَتَّىٰٓ أَتَىٰهُمْ نَصْرُنَا ۚ وَلَا مُبَدِّلَ لِكَلِمَٰتِ ٱللَّهِ ۚ وَلَقَدْ جَآءَكَ مِن نَّبَإِى۟ ٱلْمُرْسَلِينَ","translation":"And, indeed, [even] before thy time have apostles been given the lie, and they endured with patience all those charges of falsehood, and all the hurt done to them, till succour came unto them from Us: for there is no power that could alter [the outcome of] God's promises. And some of the histories of those apostles have already come within thy ken.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/823.mp3","surahId":6,"words":[{"id":36617,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/006_034_001.mp3","charTypeName":"word"},{"id":36618,"position":2,"arabic":"كُذِّبَتْ","translation":"মিথ্যারোপ করা হয়েছে","audioUrl":"wbw/006_034_002.mp3","charTypeName":"word"},{"id":36619,"position":3,"arabic":"رُسُلٌۭ","translation":"রাসূলদেরকে","audioUrl":"wbw/006_034_003.mp3","charTypeName":"word"},{"id":36620,"position":4,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/006_034_004.mp3","charTypeName":"word"},{"id":36621,"position":5,"arabic":"قَبْلِكَ","translation":"পূর্ব তোমার","audioUrl":"wbw/006_034_005.mp3","charTypeName":"word"},{"id":36622,"position":6,"arabic":"فَصَبَرُوا۟","translation":"তবে তারা ধৈর্য্য ধরেছে","audioUrl":"wbw/006_034_006.mp3","charTypeName":"word"},{"id":36623,"position":7,"arabic":"عَلَىٰ","translation":"এর উপর","audioUrl":"wbw/006_034_007.mp3","charTypeName":"word"},{"id":36624,"position":8,"arabic":"مَا","translation":"যাকিছু","audioUrl":"wbw/006_034_008.mp3","charTypeName":"word"},{"id":36625,"position":9,"arabic":"كُذِّبُوا۟","translation":"তাদের মিথ্যারোপ করা হয়েছে","audioUrl":"wbw/006_034_009.mp3","charTypeName":"word"},{"id":36626,"position":10,"arabic":"وَأُوذُوا۟","translation":"ও তাদের কষ্ট দেয়া হয়েছে","audioUrl":"wbw/006_034_010.mp3","charTypeName":"word"},{"id":36627,"position":11,"arabic":"حَتَّىٰٓ","translation":"যতক্ষণ না","audioUrl":"wbw/006_034_011.mp3","charTypeName":"word"},{"id":36628,"position":12,"arabic":"أَتَىٰهُمْ","translation":"কাছে এসেছে তাদের","audioUrl":"wbw/006_034_012.mp3","charTypeName":"word"},{"id":36629,"position":13,"arabic":"نَصْرُنَا ۚ","translation":"সাহায্য আমাদের","audioUrl":"wbw/006_034_013.mp3","charTypeName":"word"},{"id":36631,"position":14,"arabic":"وَلَا","translation":"ও নেই","audioUrl":"wbw/006_034_015.mp3","charTypeName":"word"},{"id":36632,"position":15,"arabic":"مُبَدِّلَ","translation":"কোনো পরিবর্তনকারী","audioUrl":"wbw/006_034_016.mp3","charTypeName":"word"},{"id":36633,"position":16,"arabic":"لِكَلِمَـٰتِ","translation":"জন্যে বাণীসমূহের","audioUrl":"wbw/006_034_017.mp3","charTypeName":"word"},{"id":36634,"position":17,"arabic":"ٱللَّهِ ۚ","translation":"আল্লাহর","audioUrl":"wbw/006_034_018.mp3","charTypeName":"word"},{"id":36636,"position":18,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/006_034_020.mp3","charTypeName":"word"},{"id":36637,"position":19,"arabic":"جَآءَكَ","translation":"তোমার কাছে এসেছে","audioUrl":"wbw/006_034_021.mp3","charTypeName":"word"},{"id":36638,"position":20,"arabic":"مِن","translation":"কিছু","audioUrl":"wbw/006_034_022.mp3","charTypeName":"word"},{"id":36639,"position":21,"arabic":"نَّبَإِى۟","translation":"খবর","audioUrl":"wbw/006_034_023.mp3","charTypeName":"word"},{"id":36640,"position":22,"arabic":"ٱلْمُرْسَلِينَ","translation":"রাসূলদের (সম্পর্কে)","audioUrl":"wbw/006_034_024.mp3","charTypeName":"word"},{"id":36641,"position":23,"arabic":"٣٤","translation":"(৩৪)","audioUrl":null,"charTypeName":"end"}]},{"number":35,"arabic":"وَإِن كَانَ كَبُرَ عَلَيْكَ إِعْرَاضُهُمْ فَإِنِ ٱسْتَطَعْتَ أَن تَبْتَغِىَ نَفَقًۭا فِى ٱلْأَرْضِ أَوْ سُلَّمًۭا فِى ٱلسَّمَآءِ فَتَأْتِيَهُم بِـَٔايَةٍۢ ۚ وَلَوْ شَآءَ ٱللَّهُ لَجَمَعَهُمْ عَلَى ٱلْهُدَىٰ ۚ فَلَا تَكُونَنَّ مِنَ ٱلْجَٰهِلِينَ","translation":"And if it distress thee that those who deny the truth turn their backs on thee - why, then, if thou art able to go down deep into the earth or to ascend a ladder unto heaven in order to bring them a [yet more convincing] message, [do so;] but [remember that] had God so willed, He would indeed have gathered them all unto [His] guidance. Do not, therefore, allow thyself to ignore [God's ways].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/824.mp3","surahId":6,"words":[{"id":37477,"position":1,"arabic":"وَإِن","translation":"এবং যদি","audioUrl":"wbw/006_035_001.mp3","charTypeName":"word"},{"id":37478,"position":2,"arabic":"كَانَ","translation":"হয়","audioUrl":"wbw/006_035_002.mp3","charTypeName":"word"},{"id":37479,"position":3,"arabic":"كَبُرَ","translation":"কষ্টকর","audioUrl":"wbw/006_035_003.mp3","charTypeName":"word"},{"id":37480,"position":4,"arabic":"عَلَيْكَ","translation":"তোমার উপর","audioUrl":"wbw/006_035_004.mp3","charTypeName":"word"},{"id":37481,"position":5,"arabic":"إِعْرَاضُهُمْ","translation":"উপেক্ষা করা তাদের","audioUrl":"wbw/006_035_005.mp3","charTypeName":"word"},{"id":37482,"position":6,"arabic":"فَإِنِ","translation":"তবে যদি","audioUrl":"wbw/006_035_006.mp3","charTypeName":"word"},{"id":37483,"position":7,"arabic":"ٱسْتَطَعْتَ","translation":"তুমি সমর্থ হও","audioUrl":"wbw/006_035_007.mp3","charTypeName":"word"},{"id":37484,"position":8,"arabic":"أَن","translation":"যে","audioUrl":"wbw/006_035_008.mp3","charTypeName":"word"},{"id":37485,"position":9,"arabic":"تَبْتَغِىَ","translation":"সন্ধান করো তুমি","audioUrl":"wbw/006_035_009.mp3","charTypeName":"word"},{"id":37486,"position":10,"arabic":"نَفَقًۭا","translation":"কোনো সুড়ঙ্গ","audioUrl":"wbw/006_035_010.mp3","charTypeName":"word"},{"id":37487,"position":11,"arabic":"فِى","t