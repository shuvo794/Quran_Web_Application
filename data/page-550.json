{"id":550,"ayahs":[{"number":6,"arabic":"لَقَدْ كَانَ لَكُمْ فِيهِمْ أُسْوَةٌ حَسَنَةٌۭ لِّمَن كَانَ يَرْجُوا۟ ٱللَّهَ وَٱلْيَوْمَ ٱلْءَاخِرَ ۚ وَمَن يَتَوَلَّ فَإِنَّ ٱللَّهَ هُوَ ٱلْغَنِىُّ ٱلْحَمِيدُ","translation":"In them, indeed, you have a good example for everyone who looks forward [with hope and awe] to God and the Last Day. And if any turns away, [let him know that] God is truly self-sufficient, the One to whom all praise is due.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5156.mp3","surahId":60,"words":[{"id":6274,"position":1,"arabic":"لَقَدْ","translation":"নিশ্চই","audioUrl":"wbw/060_006_001.mp3","charTypeName":"word"},{"id":6275,"position":2,"arabic":"كَانَ","translation":"আছে","audioUrl":"wbw/060_006_002.mp3","charTypeName":"word"},{"id":6276,"position":3,"arabic":"لَكُمْ","translation":"তোমাদের জন্য","audioUrl":"wbw/060_006_003.mp3","charTypeName":"word"},{"id":6277,"position":4,"arabic":"فِيهِمْ","translation":"তাদের মধ্যে","audioUrl":"wbw/060_006_004.mp3","charTypeName":"word"},{"id":6278,"position":5,"arabic":"أُسْوَةٌ","translation":"আদর্শ","audioUrl":"wbw/060_006_005.mp3","charTypeName":"word"},{"id":6279,"position":6,"arabic":"حَسَنَةٌۭ","translation":"উত্তম","audioUrl":"wbw/060_006_006.mp3","charTypeName":"word"},{"id":6280,"position":7,"arabic":"لِّمَن","translation":"যে তার জন্য","audioUrl":"wbw/060_006_007.mp3","charTypeName":"word"},{"id":6281,"position":8,"arabic":"كَانَ","translation":"ছিল","audioUrl":"wbw/060_006_008.mp3","charTypeName":"word"},{"id":6282,"position":9,"arabic":"يَرْجُوا۟","translation":"আকাঙ্খা রাখে","audioUrl":"wbw/060_006_009.mp3","charTypeName":"word"},{"id":6283,"position":10,"arabic":"ٱللَّهَ","translation":"আল্লাহর","audioUrl":"wbw/060_006_010.mp3","charTypeName":"word"},{"id":6284,"position":11,"arabic":"وَٱلْيَوْمَ","translation":"ও দিনের","audioUrl":"wbw/060_006_011.mp3","charTypeName":"word"},{"id":6285,"position":12,"arabic":"ٱلْـَٔاخِرَ ۚ","translation":"শেষ","audioUrl":"wbw/060_006_012.mp3","charTypeName":"word"},{"id":6287,"position":13,"arabic":"وَمَن","translation":"এবং যে","audioUrl":"wbw/060_006_014.mp3","charTypeName":"word"},{"id":6288,"position":14,"arabic":"يَتَوَلَّ","translation":"মুখ ফিরাবে","audioUrl":"wbw/060_006_015.mp3","charTypeName":"word"},{"id":6289,"position":15,"arabic":"فَإِنَّ","translation":"নিশ্চ্চই তবে","audioUrl":"wbw/060_006_016.mp3","charTypeName":"word"},{"id":6290,"position":16,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/060_006_017.mp3","charTypeName":"word"},{"id":6291,"position":17,"arabic":"هُوَ","translation":"তিনিই","audioUrl":"wbw/060_006_018.mp3","charTypeName":"word"},{"id":6292,"position":18,"arabic":"ٱلْغَنِىُّ","translation":"অভাভহীন","audioUrl":"wbw/060_006_019.mp3","charTypeName":"word"},{"id":6293,"position":19,"arabic":"ٱلْحَمِيدُ","translation":"প্রসংসিত।","audioUrl":"wbw/060_006_020.mp3","charTypeName":"word"},{"id":6294,"position":20,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"۞ عَسَى ٱللَّهُ أَن يَجْعَلَ بَيْنَكُمْ وَبَيْنَ ٱلَّذِينَ عَادَيْتُم مِّنْهُم مَّوَدَّةًۭ ۚ وَٱللَّهُ قَدِيرٌۭ ۚ وَٱللَّهُ غَفُورٌۭ رَّحِيمٌۭ","translation":"[But] it may well be that God will bring about [mutual] affection between you [O believers] and some of those whom you [now] face as enemies: for, God is all-powerful - and God is much-forgiving, a dispenser of grace.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5157.mp3","surahId":60,"words":[{"id":7714,"position":1,"arabic":"۞ عَسَى","translation":"সম্ভবত","audioUrl":"wbw/060_007_002.mp3","charTypeName":"word"},{"id":7715,"position":2,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/060_007_003.mp3","charTypeName":"word"},{"id":7716,"position":3,"arabic":"أَن","translation":"যে","audioUrl":"wbw/060_007_004.mp3","charTypeName":"word"},{"id":7717,"position":4,"arabic":"يَجْعَلَ","translation":"সৃষ্টি করে দিবেন","audioUrl":"wbw/060_007_005.mp3","charTypeName":"word"},{"id":7718,"position":5,"arabic":"بَيْنَكُمْ","translation":"তোমাদের মাঝে","audioUrl":"wbw/060_007_006.mp3","charTypeName":"word"},{"id":7719,"position":6,"arabic":"وَبَيْنَ","translation":"ও মাঝে","audioUrl":"wbw/060_007_007.mp3","charTypeName":"word"},{"id":7720,"position":7,"arabic":"ٱلَّذِينَ","translation":"যাদের সাথে","audioUrl":"wbw/060_007_008.mp3","charTypeName":"word"},{"id":7721,"position":8,"arabic":"عَادَيْتُم","translation":"তোমরা শত্রুতা করেছো","audioUrl":"wbw/060_007_009.mp3","charTypeName":"word"},{"id":7722,"position":9,"arabic":"مِّنْهُم","translation":"তাদের মধ্যে","audioUrl":"wbw/060_007_010.mp3","charTypeName":"word"},{"id":7723,"position":10,"arabic":"مَّوَدَّةًۭ ۚ","translation":"বন্ধুত্ব","audioUrl":"wbw/060_007_011.mp3","charTypeName":"word"},{"id":7725,"position":11,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/060_007_013.mp3","charTypeName":"word"},{"id":7726,"position":12,"arabic":"قَدِيرٌۭ ۚ","translation":"সর্বশক্তিমান","audioUrl":"wbw/060_007_014.mp3","charTypeName":"word"},{"id":7728,"position":13,"arabic":"وَٱللَّهُ","translation":"ও আল্লাহ","audioUrl":"wbw/060_007_016.mp3","charTypeName":"word"},{"id":7729,"position":14,"arabic":"غَفُورٌۭ","translation":"ক্ষমাশীল","audioUrl":"wbw/060_007_017.mp3","charTypeName":"word"},{"id":7730,"position":15,"arabic":"رَّحِيمٌۭ","translation":"মেহেরবান","audioUrl":"wbw/060_007_018.mp3","charTypeName":"word"},{"id":7731,"position":16,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"لَّا يَنْهَىٰكُمُ ٱللَّهُ عَنِ ٱلَّذِينَ لَمْ يُقَٰتِلُوكُمْ فِى ٱلدِّينِ وَلَمْ يُخْرِجُوكُم مِّن دِيَٰرِكُمْ أَن تَبَرُّوهُمْ وَتُقْسِطُوٓا۟ إِلَيْهِمْ ۚ إِنَّ ٱللَّهَ يُحِبُّ ٱلْمُقْسِطِينَ","translation":"As for such [of the unbelievers] as do not fight against you on account of [your] faith, and neither drive you forth from your homelands, God does not forbid you to show them kindness and to behave towards them with full equity: for, verily, God loves those who act equitably.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5158.mp3","surahId":60,"words":[{"id":8885,"position":1,"arabic":"لَّا","translation":"না","audioUrl":"wbw/060_008_001.mp3","charTypeName":"word"},{"id":8886,"position":2,"arabic":"يَنْهَىٰكُمُ","translation":"তোমাদের নিষেধ করেন","audioUrl":"wbw/060_008_002.mp3","charTypeName":"word"},{"id":8887,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/060_008_003.mp3","charTypeName":"word"},{"id":8888,"position":4,"arabic":"عَنِ","translation":"থেকে","audioUrl":"wbw/060_008_004.mp3","charTypeName":"word"},{"id":8889,"position":5,"arabic":"ٱلَّذِينَ","translation":"তাদের যারা","audioUrl":"wbw/060_008_005.mp3","charTypeName":"word"},{"id":8890,"position":6,"arabic":"لَمْ","translation":"নাই","audioUrl":"wbw/060_008_006.mp3","charTypeName":"word"},{"id":8891,"position":7,"arabic":"يُقَـٰتِلُوكُمْ","translation":"যুদ্ধ করে তোমাদের সাথে","audioUrl":"wbw/060_008_007.mp3","charTypeName":"word"},{"id":8892,"position":8,"arabic":"فِى","translation":"ব্যাপারে","audioUrl":"wbw/060_008_008.mp3","charTypeName":"word"},{"id":8893,"position":9,"arabic":"ٱلدِّينِ","translation":"দ্বীনের","audioUrl":"wbw/060_008_009.mp3","charTypeName":"word"},{"id":8894,"position":10,"arabic":"وَلَمْ","translation":"এবং নাই","audioUrl":"wbw/060_008_010.mp3","charTypeName":"word"},{"id":8895,"position":11,"arabic":"يُخْرِجُوكُم","translation":"তোমাদের বহিষ্কৃত করে","audioUrl":"wbw/060_008_011.mp3","charTypeName":"word"},{"id":8896,"position":12,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/060_008_012.mp3","charTypeName":"word"},{"id":8897,"position":13,"arabic":"دِيَـٰرِكُمْ","translation":"তোমাদের ঘরগুলোকে","audioUrl":"wbw/060_008_013.mp3","charTypeName":"word"},{"id":8898,"position":14,"arabic":"أَن","translation":"যে","audioUrl":"wbw/060_008_014.mp3","charTypeName":"word"},{"id":8899,"position":15,"arabic":"تَبَرُّوهُمْ","translation":"তোমরা তাদের সাথে নেকী কর","audioUrl":"wbw/060_008_015.mp3","charTypeName":"word"},{"id":8900,"position":16,"arabic":"وَتُقْسِطُوٓا۟","translation":"ও তোমরা ন্যায় বিচার কর","audioUrl":"wbw/060_008_016.mp3","charTypeName":"word"},{"id":8901,"position":17,"arabic":"إِلَيْهِمْ ۚ","translation":"তাদের সহিত","audioUrl":"wbw/060_008_017.mp3","charTypeName":"word"},{"id":8903,"position":18,"arabic":"إِنَّ","translation":"নিশ্চয়","audioUrl":"wbw/060_008_019.mp3","charTypeName":"word"},{"id":8904,"position":19,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/060_008_020.mp3","charTypeName":"word"},{"id":8905,"position":20,"arabic":"يُحِبُّ","translation":"ভালোবাসেন","audioUrl":"wbw/060_008_021.mp3","charTypeName":"word"},{"id":8906,"position":21,"arabic":"ٱلْمُقْسِطِينَ","translation":"ন্যায়বিচারকারিদের","audioUrl":"wbw/060_008_022.mp3","charTypeName":"word"},{"id":8907,"position":22,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"إِنَّمَا يَنْهَىٰكُمُ ٱللَّهُ عَنِ ٱلَّذِينَ قَٰتَلُوكُمْ فِى ٱلدِّينِ وَأَخْرَجُوكُم مِّن دِيَٰرِكُمْ وَظَٰهَرُوا۟ عَلَىٰٓ إِخْرَاجِكُمْ أَن تَوَلَّوْهُمْ ۚ وَمَن يَتَوَلَّهُمْ فَأُو۟لَٰٓئِكَ هُمُ ٱلظَّٰلِمُونَ","translation":"God only forbids you to turn in friendship towards such as fight against you because of [your] faith, and drive you forth from your homelands, or aid [others] in driving you forth: and as for those [from among you] who turn towards them in friendship; it is they, they who are truly wrongdoers!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5159.mp3","surahId":60,"words":[{"id":10094,"position":1,"arabic":"إِنَّمَا","translation":"মূলতঃ","audioUrl":"wbw/060_009_001.mp3","charTypeName":"word"},{"id":10095,"position":2,"arabic":"يَنْهَىٰكُمُ","translation":"নিষেধ করেছেন","audioUrl":"wbw/060_009_002.mp3","charTypeName":"word"},{"id":10096,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/060_009_003.mp3","charTypeName":"word"},{"id":10097,"position":4,"arabic":"عَنِ","translation":"থেকে","audioUrl":"wbw/060_009_004.mp3","charTypeName":"word"},{"id":10098,"position":5,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/060_009_005.mp3","charTypeName":"word"},{"id":10099,"position":6,"arabic":"قَـٰتَلُوكُمْ","translation":"যুদ্ধ করেছে তোমাদের বিরুদ্ধে","audioUrl":"wbw/060_009_006.mp3","charTypeName":"word"},{"id":10100,"position":7,"arabic":"فِى","translation":"ব্যাপারে","audioUrl":"wbw/060_009_007.mp3","charTypeName":"word"},{"id":10101,"position":8,"arabic":"ٱلدِّينِ","translation":"দ্বীনের","audioUrl":"wbw/060_009_008.mp3","charTypeName":"word"},{"id":10102,"position":9,"arabic":"وَأَخْرَجُوكُم","translation":"ও যাদের বহিষ্কার করেছে","audioUrl":"wbw/060_009_009.mp3","charTypeName":"word"},{"id":10103,"position":10,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/060_009_010.mp3","charTypeName":"word"},{"id":10104,"position":11,"arabic":"دِيَـٰرِكُمْ","translation":"তোমাদের ঘরগুুলো","audioUrl":"wbw/060_009_011.mp3","charTypeName":"word"},{"id":10105,"position":12,"arabic":"وَظَـٰهَرُوا۟","translation":"এবং  তারা সাহায্য করেছে","audioUrl":"wbw/060_009_012.mp3","charTypeName":"word"},{"id":10106,"position":13,"arabic":"عَلَىٰٓ","translation":"ব্যাপারে","audioUrl":"wbw/060_009_013.mp3","charTypeName":"word"},{"id":10107,"position":14,"arabic":"إِخْرَاجِكُمْ","translation":"তোমাদের বহিিষ্কার","audioUrl":"wbw/060_009_014.mp3","charTypeName":"word"},{"id":10108,"position":15,"arabic":"أَن","translation":"যে","audioUrl":"wbw/060_009_015.mp3","charTypeName":"word"},{"id":10109,"position":16,"arabic":"تَوَلَّوْهُمْ ۚ","translation":"তাদের সাথেে তোমরা বন্ধুত্ব কর","audioUrl":"wbw/060_009_016.mp3","charTypeName":"word"},{"id":10111,"position":17,"arabic":"وَمَن","translation":"এবং যে","audioUrl":"wbw/060_009_018.mp3","charTypeName":"word"},{"id":10112,"position":18,"arabic":"يَتَوَلَّهُمْ","translation":"তাদের(সাথে) বন্ধুত্ব করে","audioUrl":"wbw/060_009_019.mp3","charTypeName":"word"},{"id":10113,"position":19,"arabic":"فَأُو۟لَـٰٓئِكَ","translation":"অতঃপর ঐসব লোক","audioUrl":"wbw/060_009_020.mp3","charTypeName":"word"},{"id":10114,"position":20,"arabic":"هُمُ","translation":"তারা","audioUrl":"wbw/060_009_021.mp3","charTypeName":"word"},{"id":10115,"position":21,"arabic":"ٱلظَّـٰلِمُونَ","translation":"যালিম","audioUrl":"wbw/060_009_022.mp3","charTypeName":"word"},{"id":10116,"position":22,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوٓا۟ إِذَا جَآءَكُمُ ٱلْمُؤْمِنَٰتُ مُهَٰجِرَٰتٍۢ فَٱمْتَحِنُوهُنَّ ۖ ٱللَّهُ أَعْلَمُ بِإِيمَٰنِهِنَّ ۖ فَإِنْ عَلِمْتُمُوهُنَّ مُؤْمِنَٰتٍۢ فَلَا تَرْجِعُوهُنَّ إِلَى ٱلْكُفَّارِ ۖ لَا هُنَّ حِلٌّۭ لَّهُمْ وَلَا هُمْ يَحِلُّونَ لَهُنَّ ۖ وَءَاتُوهُم مَّآ أَنفَقُوا۟ ۚ وَلَا جُنَاحَ عَلَيْكُمْ أَن تَنكِحُوهُنَّ إِذَآ ءَاتَيْتُمُوهُنَّ أُجُورَهُنَّ ۚ وَلَا تُمْسِكُوا۟ بِعِصَمِ ٱلْكَوَافِرِ وَسْـَٔلُوا۟ مَآ أَنفَقْتُمْ وَلْيَسْـَٔلُوا۟ مَآ أَنفَقُوا۟ ۚ ذَٰلِكُمْ حُكْمُ ٱللَّهِ ۖ يَحْكُمُ بَيْنَكُمْ ۚ وَٱللَّهُ عَلِيمٌ حَكِيمٌۭ","translation":"O YOU who have attained to faith! Whenever believing women come unto you, forsaking the domain of evil, examine them, [although only] God is fully aware of their faith; and if you have thus ascertained that they are believers, do not send them back to the deniers of the truth, [since] they are [no longer] lawful to their erstwhile husbands, and these are [no longer] lawful to them. None the less, you shall return to them whatever they have spent [on their wives by way of dower]; and [then, O believers,] you will be committing no sin if you marry them after giving them their dowers. On the other hand, hold not to the marriage-tie with women who [continue to] deny the truth, and ask but for [the return of] whatever you have spent [by way of dower] -just as they [whose wives have gone over to you] have the right to demand [the return of] whatever they have spent. Such is God's judgment: He judges between you [in equity] - for God is all-knowing, wise.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5160.mp3","surahId":60,"words":[{"id":11299,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"ওহেে","audioUrl":"wbw/060_010_001.mp3","charTypeName":"word"},{"id":11300,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/060_010_002.mp3","charTypeName":"word"},{"id":11301,"position":3,"arabic":"ءَامَنُوٓا۟","translation":"ঈমান এনেছ","audioUrl":"wbw/060_010_003.mp3","charTypeName":"word"},{"id":11302,"position":4,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/060_010_004.mp3","charTypeName":"word"},{"id":11303,"position":5,"arabic":"جَآءَكُمُ","translation":"তোমাদের কাাছে আসবে","audioUrl":"wbw/060_010_005.mp3","charTypeName":"word"},{"id":11304,"position":6,"arabic":"ٱلْمُؤْمِنَـٰتُ","translation":"মুমিন মহিলারা","audioUrl":"wbw/060_010_006.mp3","charTypeName":"word"},{"id":11305,"position":7,"arabic":"مُهَـٰجِرَٰتٍۢ","translation":"মুহাজির হয়ে","audioUrl":"wbw/060_010_007.mp3","charTypeName":"word"},{"id":11306,"position":8,"arabic":"فَٱمْتَحِنُوهُنَّ ۖ","translation":"তাদের তোমরা পরীক্ষা তখন","audioUrl":"wbw/060_010_008.mp3","charTypeName":"word"},{"id":11308,"position":9,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/060_010_010.mp3","charTypeName":"word"},{"id":11309,"position":10,"arabic":"أَعْلَمُ","translation":"খুব জানেন","audioUrl":"wbw/060_010_011.mp3","charTypeName":"word"},{"id":11310,"position":11,"arabic":"بِإِيمَـٰنِهِنَّ ۖ","translation":"তাদের ঈমান সম্পর্কে","audioUrl":"wbw/060_010_012.mp3","charTypeName":"word"},{"id":11312,"position":12,"arabic":"فَإِنْ","translation":"যদিি অতএব","audioUrl":"wbw/060_010_014.mp3","charTypeName":"word"},{"id":11313,"position":13,"arabic":"عَلِمْتُمُوهُنَّ","translation":"তাদের তোমরা জানতে পারো","audioUrl":"wbw/060_010_015.mp3","charTypeName":"word"},{"id":11314,"position":14,"arabic":"مُؤْمِنَـٰتٍۢ","translation":"মুমিন রূপে","audioUrl":"wbw/060_010_016.mp3","charTypeName":"word"},{"id":11315,"position":15,"arabic":"فَلَا","tr