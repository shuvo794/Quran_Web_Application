rl":"wbw/076_011_006.mp3","charTypeName":"word"},{"id":12892,"position":7,"arabic":"نَضْرَةًۭ","translation":"উৎফুল্লতা","audioUrl":"wbw/076_011_007.mp3","charTypeName":"word"},{"id":12893,"position":8,"arabic":"وَسُرُورًۭا","translation":"ও আনন্দ","audioUrl":"wbw/076_011_008.mp3","charTypeName":"word"},{"id":12894,"position":9,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]},{"number":12,"arabic":"وَجَزَىٰهُم بِمَا صَبَرُوا۟ جَنَّةًۭ وَحَرِيرًۭا","translation":"and will reward them for all their patience in adversity with a garden [of bliss] and with [garments of] silk.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5603.mp3","surahId":76,"words":[{"id":14499,"position":1,"arabic":"وَجَزَىٰهُم","translation":"এবং তাদের প্রতিদান","audioUrl":"wbw/076_012_001.mp3","charTypeName":"word"},{"id":14500,"position":2,"arabic":"بِمَا","translation":"যা বিনিময়ে","audioUrl":"wbw/076_012_002.mp3","charTypeName":"word"},{"id":14501,"position":3,"arabic":"صَبَرُوا۟","translation":"তারা সবর করেছে","audioUrl":"wbw/076_012_003.mp3","charTypeName":"word"},{"id":14502,"position":4,"arabic":"جَنَّةًۭ","translation":"জান্নাত","audioUrl":"wbw/076_012_004.mp3","charTypeName":"word"},{"id":14503,"position":5,"arabic":"وَحَرِيرًۭا","translation":"এবং রেশমীপোশাক","audioUrl":"wbw/076_012_005.mp3","charTypeName":"word"},{"id":14504,"position":6,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]},{"number":13,"arabic":"مُّتَّكِـِٔينَ فِيهَا عَلَى ٱلْأَرَآئِكِ ۖ لَا يَرَوْنَ فِيهَا شَمْسًۭا وَلَا زَمْهَرِيرًۭا","translation":"In that [garden] they will on couches recline, and will know therein neither [burning] sun nor cold severe,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5604.mp3","surahId":76,"words":[{"id":15270,"position":1,"arabic":"مُّتَّكِـِٔينَ","translation":"হেলান দিয়ে বসবে","audioUrl":"wbw/076_013_001.mp3","charTypeName":"word"},{"id":15271,"position":2,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/076_013_002.mp3","charTypeName":"word"},{"id":15272,"position":3,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/076_013_003.mp3","charTypeName":"word"},{"id":15273,"position":4,"arabic":"ٱلْأَرَآئِكِ ۖ","translation":"উচ্চাসনসমুহের","audioUrl":"wbw/076_013_004.mp3","charTypeName":"word"},{"id":15275,"position":5,"arabic":"لَا","translation":"না","audioUrl":"wbw/076_013_006.mp3","charTypeName":"word"},{"id":15276,"position":6,"arabic":"يَرَوْنَ","translation":"তারা দেখবে","audioUrl":"wbw/076_013_007.mp3","charTypeName":"word"},{"id":15277,"position":7,"arabic":"فِيهَا","translation":"তারমধ্যে","audioUrl":"wbw/076_013_008.mp3","charTypeName":"word"},{"id":15278,"position":8,"arabic":"شَمْسًۭا","translation":"রোদ্রতাপ","audioUrl":"wbw/076_013_009.mp3","charTypeName":"word"},{"id":15279,"position":9,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/076_013_010.mp3","charTypeName":"word"},{"id":15280,"position":10,"arabic":"زَمْهَرِيرًۭا","translation":"শীতের প্রকোপ","audioUrl":"wbw/076_013_011.mp3","charTypeName":"word"},{"id":15281,"position":11,"arabic":"١٣","translation":"(১৩)","audioUrl":null,"charTypeName":"end"}]},{"number":14,"arabic":"وَدَانِيَةً عَلَيْهِمْ ظِلَٰلُهَا وَذُلِّلَتْ قُطُوفُهَا تَذْلِيلًۭا","translation":"since its [blissful] shades will come down low over them, and low will hang down its clusters of fruit, most easy to reach.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5605.mp3","surahId":76,"words":[{"id":16329,"position":1,"arabic":"وَدَانِيَةً","translation":"এবং নিকটে থাকবে","audioUrl":"wbw/076_014_001.mp3","charTypeName":"word"},{"id":16330,"position":2,"arabic":"عَلَيْهِمْ","translation":"তাদের উপর","audioUrl":"wbw/076_014_002.mp3","charTypeName":"word"},{"id":16331,"position":3,"arabic":"ظِلَـٰلُهَا","translation":"তার ছায়া","audioUrl":"wbw/076_014_003.mp3","charTypeName":"word"},{"id":16332,"position":4,"arabic":"وَذُلِّلَتْ","translation":"এবং আয়ত্তাধীন করা হবে","audioUrl":"wbw/076_014_004.mp3","charTypeName":"word"},{"id":16333,"position":5,"arabic":"قُطُوفُهَا","translation":"তার ফলসমূহ","audioUrl":"wbw/076_014_005.mp3","charTypeName":"word"},{"id":16334,"position":6,"arabic":"تَذْلِيلًۭا","translation":"আয়ত্তাধীন (পূর্ণ)","audioUrl":"wbw/076_014_006.mp3","charTypeName":"word"},{"id":16335,"position":7,"arabic":"١٤","translation":"(১৪)","audioUrl":null,"charTypeName":"end"}]},{"number":15,"arabic":"وَيُطَافُ عَلَيْهِم بِـَٔانِيَةٍۢ مِّن فِضَّةٍۢ وَأَكْوَابٍۢ كَانَتْ قَوَارِيرَا۠","translation":"And they will be waited upon with vessels of silver and goblets that will [seem to] be crystal –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5606.mp3","surahId":76,"words":[{"id":17475,"position":1,"arabic":"وَيُطَافُ","translation":"এবং আবর্তিত করানো হবে","audioUrl":"wbw/076_015_001.mp3","charTypeName":"word"},{"id":17476,"position":2,"arabic":"عَلَيْهِم","translation":"তাদের উপর","audioUrl":"wbw/076_015_002.mp3","charTypeName":"word"},{"id":17477,"position":3,"arabic":"بِـَٔانِيَةٍۢ","translation":"পান পাত্রকে","audioUrl":"wbw/076_015_003.mp3","charTypeName":"word"},{"id":17478,"position":4,"arabic":"مِّن","translation":"(নির্মিত)","audioUrl":"wbw/076_015_004.mp3","charTypeName":"word"},{"id":17479,"position":5,"arabic":"فِضَّةٍۢ","translation":"রোপ্যের","audioUrl":"wbw/076_015_005.mp3","charTypeName":"word"},{"id":17480,"position":6,"arabic":"وَأَكْوَابٍۢ","translation":"ও পেয়ালাগুলো","audioUrl":"wbw/076_015_006.mp3","charTypeName":"word"},{"id":17481,"position":7,"arabic":"كَانَتْ","translation":"হবে","audioUrl":"wbw/076_015_007.mp3","charTypeName":"word"},{"id":17482,"position":8,"arabic":"قَوَارِيرَا۠","translation":"কাঁচের (মত)","audioUrl":"wbw/076_015_008.mp3","charTypeName":"word"},{"id":17483,"position":9,"arabic":"١٥","translation":"(১৫)","audioUrl":null,"charTypeName":"end"}]},{"number":16,"arabic":"قَوَارِيرَا۟ مِن فِضَّةٍۢ قَدَّرُوهَا تَقْدِيرًۭا","translation":"crystal-like, [but] of silver - the measure whereof they alo