en silk and brocade; and they will be adorned with bracelets of silver. And their Sustainer will them to drink of a drink most pure.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5612.mp3","surahId":76,"words":[{"id":23965,"position":1,"arabic":"عَـٰلِيَهُمْ","translation":"তাদের উপর","audioUrl":"wbw/076_021_001.mp3","charTypeName":"word"},{"id":23966,"position":2,"arabic":"ثِيَابُ","translation":"পোশাক","audioUrl":"wbw/076_021_002.mp3","charTypeName":"word"},{"id":23967,"position":3,"arabic":"سُندُسٍ","translation":"সুক্ষ রেশমের","audioUrl":"wbw/076_021_003.mp3","charTypeName":"word"},{"id":23968,"position":4,"arabic":"خُضْرٌۭ","translation":"সবুজ","audioUrl":"wbw/076_021_004.mp3","charTypeName":"word"},{"id":23969,"position":5,"arabic":"وَإِسْتَبْرَقٌۭ ۖ","translation":"এবং বুটিদার","audioUrl":"wbw/076_021_005.mp3","charTypeName":"word"},{"id":23971,"position":6,"arabic":"وَحُلُّوٓا۟","translation":"এবং তাদের অলংকার","audioUrl":"wbw/076_021_007.mp3","charTypeName":"word"},{"id":23972,"position":7,"arabic":"أَسَاوِرَ","translation":"কংকনের","audioUrl":"wbw/076_021_008.mp3","charTypeName":"word"},{"id":23973,"position":8,"arabic":"مِن","translation":"(নির্মিত)","audioUrl":"wbw/076_021_009.mp3","charTypeName":"word"},{"id":23974,"position":9,"arabic":"فِضَّةٍۢ","translation":"রৌপ্য","audioUrl":"wbw/076_021_010.mp3","charTypeName":"word"},{"id":23975,"position":10,"arabic":"وَسَقَىٰهُمْ","translation":"এবং তাদের পান করাবেন","audioUrl":"wbw/076_021_011.mp3","charTypeName":"word"},{"id":23976,"position":11,"arabic":"رَبُّهُمْ","translation":"তাদের রব","audioUrl":"wbw/076_021_012.mp3","charTypeName":"word"},{"id":23977,"position":12,"arabic":"شَرَابًۭا","translation":"পানীয়","audioUrl":"wbw/076_021_013.mp3","charTypeName":"word"},{"id":23978,"position":13,"arabic":"طَهُورًا","translation":"পবিত্র","audioUrl":"wbw/076_021_014.mp3","charTypeName":"word"},{"id":23979,"position":14,"arabic":"٢١","translation":"(২১)","audioUrl":null,"charTypeName":"end"}]},