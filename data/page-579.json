,"position":9,"arabic":"كَفُورًۭا","translation":"কাফির","audioUrl":"wbw/076_024_009.mp3","charTypeName":"word"},{"id":27301,"position":10,"arabic":"٢٤","translation":"(২৪)","audioUrl":null,"charTypeName":"end"}]},{"number":25,"arabic":"وَٱذْكُرِ ٱسْمَ رَبِّكَ بُكْرَةًۭ وَأَصِيلًۭا","translation":"and bear in mind thy Sustainer's name at morn and evening","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5616.mp3","surahId":76,"words":[{"id":28101,"position":1,"arabic":"وَٱذْكُرِ","translation":"এবং স্মরন কর","audioUrl":"wbw/076_025_001.mp3","charTypeName":"word"},{"id":28102,"position":2,"arabic":"ٱسْمَ","translation":"নামের","audioUrl":"wbw/076_025_002.mp3","charTypeName":"word"},{"id":28103,"position":3,"arabic":"رَبِّكَ","translation":"তোমার রবের","audioUrl":"wbw/076_025_003.mp3","charTypeName":"word"},{"id":28104,"position":4,"arabic":"بُكْرَةًۭ","translation":"সকাল","audioUrl":"wbw/076_025_004.mp3","charTypeName":"word"},{"id":28105,"position":5,"arabic":"وَأَصِيلًۭا","translation":"ও সন্ধ্যায়","audioUrl":"wbw/076_025_005.mp3","charTypeName":"word"},{"id":28106,"position":6,"arabic":"٢٥","translation":"(২৫)","audioUrl":null,"charTypeName":"end"}]}]}