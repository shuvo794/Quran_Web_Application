{"id":579,"ayahs":[{"number":6,"arabic":"عَيْنًۭا يَشْرَبُ بِهَا عِبَادُ ٱللَّهِ يُفَجِّرُونَهَا تَفْجِيرًۭا","translation":"a source [of bliss] whereof God's servants shall drink, seeing it flow in a flow abundant.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5597.mp3","surahId":76,"words":[{"id":6625,"position":1,"arabic":"عَيْنًۭا","translation":"একটি ঝর্না","audioUrl":"wbw/076_006_001.mp3","charTypeName":"word"},{"id":6626,"position":2,"arabic":"يَشْرَبُ","translation":"পান করবে","audioUrl":"wbw/076_006_002.mp3","charTypeName":"word"},{"id":6627,"position":3,"arabic":"بِهَا","translation":"তা থেকে","audioUrl":"wbw/076_006_003.mp3","charTypeName":"word"},{"id":6628,"position":4,"arabic":"عِبَادُ","translation":"বান্দারা","audioUrl":"wbw/076_006_004.mp3","charTypeName":"word"},{"id":6629,"position":5,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌র","audioUrl":"wbw/076_006_005.mp3","charTypeName":"word"},{"id":6630,"position":6,"arabic":"يُفَجِّرُونَهَا","translation":"তাকে তারা প্রবাহিত করবে","audioUrl":"wbw/076_006_006.mp3","charTypeName":"word"},{"id":6631,"position":7,"arabic":"تَفْجِيرًۭا","translation":"প্রবাহিত(যথা ইচ্ছা)","audioUrl":"wbw/076_006_007.mp3","charTypeName":"word"},{"id":6632,"position":8,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"يُوفُونَ بِٱلنَّذْرِ وَيَخَافُونَ يَوْمًۭا كَانَ شَرُّهُۥ مُسْتَطِيرًۭا","translation":"[The truly virtuous are] they [who] fulfil their vows, and stand in awe of a Day the woe of which is bound to spread far and wide,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5598.mp3","surahId":76,"words":[{"id":7959,"position":1,"arabic":"يُوفُونَ","translation":"তারা পূর্ণ করে","audioUrl":"wbw/076_007_001.mp3","charTypeName":"word"},{"id":7960,"position":2,"arabic":"بِٱلنَّذْرِ","translation":"মানতকে","audioUrl":"wbw/076_007_002.mp3","charTypeName":"word"},{"id":7961,"position":3,"arabic":"وَيَخَافُونَ","translation":"এবং তারা ভয় করে","audioUrl":"wbw/076_007_003.mp3","charTypeName":"word"},{"id":7962,"position":4,"arabic":"يَوْمًۭا","translation":"একদিনের","audioUrl":"wbw/076_007_004.mp3","charTypeName":"word"},{"id":7963,"position":5,"arabic":"كَانَ","translation":"হবে","audioUrl":"wbw/076_007_005.mp3","charTypeName":"word"},{"id":7964,"position":6,"arabic":"شَرُّهُۥ","translation":"তার বিপত্তি","audioUrl":"wbw/076_007_006.mp3","charTypeName":"word"},{"id":7965,"position":7,"arabic":"مُسْتَطِيرًۭا","translation":"সর্বত্রবিস্ত্রিত","audioUrl":"wbw/076_007_007.mp3","charTypeName":"word"},{"id":7966,"position":8,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"وَيُطْعِمُونَ ٱلطَّعَامَ عَلَىٰ حُبِّهِۦ مِسْكِينًۭا وَيَتِيمًۭا وَأَسِيرًا","translation":"and who give food - however great be their own want of it - unto the needy, and the orphan, and the captive,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5599.mp3","surahId":76,"words":[{"id":9123,"position":1,"arabic":"وَيُطْعِمُونَ","translation":"এবং তারা খাওয়ায়","audioUrl":"wbw/076_008_001.mp3","charTypeName":"word"},{"id":9124,"position":2,"arabic":"ٱلطَّعَامَ","translation":"খাবার","audioUrl":"wbw/076_008_002.mp3","charTypeName":"word"},{"id":9125,"position":3,"arabic":"عَلَىٰ","translation":"জন্য","audioUrl":"wbw/076_008_003.mp3","charTypeName":"word"},{"id":9126,"position":4,"arabic":"حُبِّهِۦ","translation":"তাঁর ভালবাসার","audioUrl":"wbw/076_008_004.mp3","charTypeName":"word"},{"id":9127,"position":5,"arabic":"مِسْكِينًۭا","translation":"অভাবগ্রস্থকে","audioUrl":"wbw/076_008_005.mp3","charTypeName":"word"},{"id":9128,"position":6,"arabic":"وَيَتِيمًۭا","translation":"ও ইয়াতীমকে","audioUrl":"wbw/076_008_006.mp3","charTypeName":"word"},{"id":9129,"position":7,"arabic":"وَأَسِيرًا","translation":"ও বন্দীকে","audioUrl":"wbw/076_008_007.mp3","charTypeName":"word"},{"id":9130,"position":8,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"إِنَّمَا