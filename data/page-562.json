,"arabic":"جَآءَنَا","translation":"এসেছিল আমাদের (কাছে)","audioUrl":"wbw/067_009_004.mp3","charTypeName":"word"},{"id":10244,"position":5,"arabic":"نَذِيرٌۭ","translation":"সতর্ককারী","audioUrl":"wbw/067_009_005.mp3","charTypeName":"word"},{"id":10245,"position":6,"arabic":"فَكَذَّبْنَا","translation":"তবে আমরা মিথ্যারোপ করেছিলাম","audioUrl":"wbw/067_009_006.mp3","charTypeName":"word"},{"id":10246,"position":7,"arabic":"وَقُلْنَا","translation":"এবং আমরা বলে ছিলাম","audioUrl":"wbw/067_009_007.mp3","charTypeName":"word"},{"id":10247,"position":8,"arabic":"مَا","translation":"\"নাই","audioUrl":"wbw/067_009_008.mp3","charTypeName":"word"},{"id":10248,"position":9,"arabic":"نَزَّلَ","translation":"নাযিল করেন","audioUrl":"wbw/067_009_009.mp3","charTypeName":"word"},{"id":10249,"position":10,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌","audioUrl":"wbw/067_009_010.mp3","charTypeName":"word"},{"id":10250,"position":11,"arabic":"مِن","translation":"কোন","audioUrl":"wbw/067_009_011.mp3","charTypeName":"word"},{"id":10251,"position":12,"arabic":"شَىْءٍ","translation":"কিছু","audioUrl":"wbw/067_009_012.mp3","charTypeName":"word"},{"id":10252,"position":13,"arabic":"إِنْ","translation":"নও","audioUrl":"wbw/067_009_013.mp3","charTypeName":"word"},{"id":10253,"position":14,"arabic":"أَنتُمْ","translation":"তোমরা","audioUrl":"wbw/067_009_014.mp3","charTypeName":"word"},{"id":10254,"position":15,"arabic":"إِلَّا","translation":"এছাড়া","audioUrl":"wbw/067_009_015.mp3","charTypeName":"word"},{"id":10255,"position":16,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/067_009_016.mp3","charTypeName":"word"},{"id":10256,"position":17,"arabic":"ضَلَـٰلٍۢ","translation":"গুমরাহীর","audioUrl":"wbw/067_009_017.mp3","charTypeName":"word"},{"id":10257,"position":18,"arabic":"كَبِيرٍۢ","translation":"বড়\"","audioUrl":"wbw/067_009_018.mp3","charTypeName":"word"},{"id":10258,"position":19,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"وَقَالُو