{"id":562,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ تَبَٰرَكَ ٱلَّذِى بِيَدِهِ ٱلْمُلْكُ وَهُوَ عَلَىٰ كُلِّ شَىْءٍۢ قَدِيرٌ","translation":"HALLOWED be He in whose hand all dominion rests, since He has the power to will anything:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5242.mp3","surahId":67,"words":[{"id":572,"position":1,"arabic":"تَبَـٰرَكَ","translation":"বড় বরকতময়","audioUrl":"wbw/067_001_001.mp3","charTypeName":"word"},{"id":573,"position":2,"arabic":"ٱلَّذِى","translation":"সেই(সত্তা)","audioUrl":"wbw/067_001_002.mp3","charTypeName":"word"},{"id":574,"position":3,"arabic":"بِيَدِهِ","translation":"যার হাতে","audioUrl":"wbw/067_001_003.mp3","charTypeName":"word"},{"id":575,"position":4,"arabic":"ٱلْمُلْكُ","translation":"কর্তৃত্ব","audioUrl":"wbw/067_001_004.mp3","charTypeName":"word"},{"id":576,"position":5,"arabic":"وَهُوَ","translation":"এবং তিনিই","audioUrl":"wbw/067_001_005.mp3","charTypeName":"word"},{"id":577,"position":6,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/067_001_006.mp3","charTypeName":"word"},{"id":578,"position":7,"arabic":"كُلِّ","translation":"সব","audioUrl":"wbw/067_001_007.mp3","charTypeName":"word"},{"id":579,"position":8,"arabic":"شَىْءٍۢ","translation":"কিছুর","audioUrl":"wbw/067_001_008.mp3","charTypeName":"word"},{"id":580,"position":9,"arabic":"قَدِيرٌ","translation":"ক্ষমতাবান","audioUrl":"wbw/067_001_009.mp3","charTypeName":"word"},{"id":581,"position":10,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"ٱلَّذِى خَلَقَ ٱلْمَوْتَ وَٱلْحَيَوٰةَ لِيَبْلُوَكُمْ أَيُّكُمْ أَحْسَنُ عَمَلًۭا ۚ وَهُوَ ٱلْعَزِيزُ ٱلْغَفُورُ","translation":"He who has created death as well as life, so that He might put you to a test [and thus show] which of you is best in conduct, and [make you realize that] He alone is almighty, truly forgiving.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5243.mp3","surahId":67,"words":[{"id":