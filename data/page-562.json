ll,"charTypeName":"end"}]},{"number":5,"arabic":"وَلَقَدْ زَيَّنَّا ٱلسَّمَآءَ ٱلدُّنْيَا بِمَصَٰبِيحَ وَجَعَلْنَٰهَا رُجُومًۭا لِّلشَّيَٰطِينِ ۖ وَأَعْتَدْنَا لَهُمْ عَذَابَ ٱلسَّعِيرِ","translation":"And, indeed, We have adorned the skies nearest to the earth with lights, and have made them the object of futile guesses for the evil ones [from among men]: and for them have We readied suffering through a blazing flame –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5246.mp3","surahId":67,"words":[{"id":5166,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়","audioUrl":"wbw/067_005_001.mp3","charTypeName":"word"},{"id":5167,"position":2,"arabic":"زَيَّنَّا","translation":"আমরা সাজিয়েছি","audioUrl":"wbw/067_005_002.mp3","charTypeName":"word"},{"id":5168,"position":3,"arabic":"ٱلسَّمَآءَ","translation":"আকাশকে","audioUrl":"wbw/067_005_003.mp3","charTypeName":"word"},{"id":5169,"position":4,"arabic":"ٱلدُّنْيَا","translation":"নিকটবর্তী","audioUrl":"wbw/067_005_004.mp3","charTypeName":"word"},{"id":5170,"position":5,"arabic":"بِمَصَـٰبِيحَ","translation":"প্রদীপরাশি দিয়ে","audioUrl":"wbw/067_005_005.mp3","charTypeName":"word"},{"id":5171,"position":6,"arabic":"وَجَعَلْنَـٰهَا","translation":"এবং তা আমরা বানিয়েছি","audioUrl":"wbw/067_005_006.mp3","charTypeName":"word"},{"id":5172,"position":7,"arabic":"رُجُومًۭا","translation":"নিক্ষেপ উপকরণ","audioUrl":"wbw/067_005_007.mp3","charTypeName":"word"},{"id":5173,"position":8,"arabic":"لِّلشَّيَـٰطِينِ ۖ","translation":"শয়তানদের জন্য","audioUrl":"wbw/067_005_008.mp3","charTypeName":"word"},{"id":5175,"position":9,"arabic":"وَأَعْتَدْنَا","translation":"এবং আমরা প্রস্তুত করে রেখেছি","audioUrl":"wbw/067_005_010.mp3","charTypeName":"word"},{"id":5176,"position":10,"arabic":"لَهُمْ","translation":"তাদের জন্যে","audioUrl":"wbw/067_005_011.mp3","charTypeName":"word"},{"id":5177,"position":11,"arabic":"عَذَابَ","translation":"শাস্তি","audioUrl":"wbw/067_005_012.mp3","charTypeName":"word"},{"id":5178,"