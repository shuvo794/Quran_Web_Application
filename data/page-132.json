":"رَبِّهِمْ","translation":"রবের তাদের","audioUrl":"wbw/006_038_023.mp3","charTypeName":"word"},{"id":40069,"position":22,"arabic":"يُحْشَرُونَ","translation":"তাদের একত্র করা হবে","audioUrl":"wbw/006_038_024.mp3","charTypeName":"word"},{"id":40070,"position":23,"arabic":"٣٨","translation":"(৩৮)","audioUrl":null,"charTypeName":"end"}]},{"number":39,"arabic":"وَٱلَّذِينَ كَذَّبُوا۟ بِـَٔايَٰتِنَا صُمٌّۭ وَبُكْمٌۭ فِى ٱلظُّلُمَٰتِ ۗ مَن يَشَإِ ٱللَّهُ يُضْلِلْهُ وَمَن يَشَأْ يَجْعَلْهُ عَلَىٰ صِرَٰطٍۢ مُّسْتَقِيمٍۢ","translation":"And they who give the lie to Our messages are deaf and dumb, in darkness deep. Whomever God wills, He lets go astray; and whomever He wills, He places upon a straight way.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/828.mp3","surahId":6,"words":[{"id":40814,"position":1,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/006_039_001.mp3","charTypeName":"word"},{"id":40815,"position":2,"arabic":"كَذَّبُوا۟","translation":"মিথ্যারোপ করেছে","audioUrl":"wbw/006_039_002.mp3","charTypeName":"word"},{"id":40816,"position":3,"arabic":"بِـَٔايَـٰتِنَا","translation":"নিয়ে নিদর্শনগুলোর আমাদের","audioUrl":"wbw/006_039_003.mp3","charTypeName":"word"},{"id":40817,"position":4,"arabic":"صُمٌّۭ","translation":"(তারা) বধির","audioUrl":"wbw/006_039_004.mp3","charTypeName":"word"},{"id":40818,"position":5,"arabic":"وَبُكْمٌۭ","translation":"ও বোবা","audioUrl":"wbw/006_039_005.mp3","charTypeName":"word"},{"id":40819,"position":6,"arabic":"فِى","translation":"(তারা আছে) মধ্যে","audioUrl":"wbw/006_039_006.mp3","charTypeName":"word"},{"id":40820,"position":7,"arabic":"ٱلظُّلُمَـٰتِ ۗ","translation":"অন্ধকারের","audioUrl":"wbw/006_039_007.mp3","charTypeName":"word"},{"id":40822,"position":8,"arabic":"مَن","translation":"যাকে","audioUrl":"wbw/006_039_009.mp3","charTypeName":"word"},{"id":40823,"position":9,"arabic":"يَشَإِ","translation":"ইচ্ছে করেন","audioUrl":"wbw/006_039_010.mp3","charTypeName":"word"},{"id":40824,"position":10,