{"id":132,"ayahs":[{"number":36,"arabic":"۞ إِنَّمَا يَسْتَجِيبُ ٱلَّذِينَ يَسْمَعُونَ ۘ وَٱلْمَوْتَىٰ يَبْعَثُهُمُ ٱللَّهُ ثُمَّ إِلَيْهِ يُرْجَعُونَ","translation":"Only they who listen [with their hearts] can respond to a call; and as for the dead [of heart], God [alone] can raise them from the dead, whereupon unto Him they shall return.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/825.mp3","surahId":6,"words":[{"id":38369,"position":1,"arabic":"۞ إِنَّمَا","translation":"প্রকৃতপক্ষে","audioUrl":"wbw/006_036_002.mp3","charTypeName":"word"},{"id":38370,"position":2,"arabic":"يَسْتَجِيبُ","translation":"ডাকে সাড়া দেয়","audioUrl":"wbw/006_036_003.mp3","charTypeName":"word"},{"id":38371,"position":3,"arabic":"ٱلَّذِينَ","translation":"(তারাই) যারা","audioUrl":"wbw/006_036_004.mp3","charTypeName":"word"},{"id":38372,"position":4,"arabic":"يَسْمَعُونَ ۘ","translation":"যারা শোনে","audioUrl":"wbw/006_036_005.mp3","charTypeName":"word"},{"id":38374,"position":5,"arabic":"وَٱلْمَوْتَىٰ","translation":"এবং মৃতদেরকে","audioUrl":"wbw/006_036_007.mp3","charTypeName":"word"},{"id":38375,"position":6,"arabic":"يَبْعَثُهُمُ","translation":"উজ্জীবিত করবেন তাদের","audioUrl":"wbw/006_036_008.mp3","charTypeName":"word"},{"id":38376,"position":7,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/006_036_009.mp3","charTypeName":"word"},{"id":38377,"position":8,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/006_036_010.mp3","charTypeName":"word"},{"id":38378,"position":9,"arabic":"إِلَيْهِ","translation":"দিকে তাঁরই","audioUrl":"wbw/006_036_011.mp3","charTypeName":"word"},{"id":38379,"position":10,"arabic":"يُرْجَعُونَ","translation":"তাদের ফিরিয়ে আনা হবে","audioUrl":"wbw/006_036_012.mp3","charTypeName":"word"},{"id":38380,"position":11,"arabic":"٣٦","translation":"(৩৬)","audioUrl":null,"charTypeName":"end"}]},{"number":37,"arabic":"وَقَالُوا۟ لَوْلَا نُزِّلَ عَلَيْهِ ءَايَةٌۭ مِّن رَّبِّهِۦ ۚ قُلْ إِنَّ ٱللَّهَ قَادِرٌ عَلَىٰٓ أَن يُنَزِّلَ ءَايَةً