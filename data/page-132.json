y might humble themselves:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/831.mp3","surahId":6,"words":[{"id":43204,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/006_042_001.mp3","charTypeName":"word"},{"id":43205,"position":2,"arabic":"أَرْسَلْنَآ","translation":"পাঠিয়েছি আমরা (রাসূলগণকে)","audioUrl":"wbw/006_042_002.mp3","charTypeName":"word"},{"id":43206,"position":3,"arabic":"إِلَىٰٓ","translation":"প্রতি","audioUrl":"wbw/006_042_003.mp3","charTypeName":"word"},{"id":43207,"position":4,"arabic":"أُمَمٍۢ","translation":"জাতিগুলোর)","audioUrl":"wbw/006_042_004.mp3","charTypeName":"word"},{"id":43208,"position":5,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/006_042_005.mp3","charTypeName":"word"},{"id":43209,"position":6,"arabic":"قَبْلِكَ","translation":"পূর্ব তোমার","audioUrl":"wbw/006_042_006.mp3","charTypeName":"word"},{"id":43210,"position":7,"arabic":"فَأَخَذْنَـٰهُم","translation":"অতঃপর আমরা ধরেছি তাদেরকে","audioUrl":"wbw/006_042_007.mp3","charTypeName":"word"},{"id":43211,"position":8,"arabic":"بِٱلْبَأْسَآءِ","translation":"দিয়ে অর্থসংকট","audioUrl":"wbw/006_042_008.mp3","charTypeName":"word"},{"id":43212,"position":9,"arabic":"وَٱلضَّرَّآءِ","translation":"ও দুঃখদৈন্য(দিয়ে)","audioUrl":"wbw/006_042_009.mp3","charTypeName":"word"},{"id":43213,"position":10,"arabic":"لَعَلَّهُمْ","translation":"যাতে তারা","audioUrl":"wbw/006_042_010.mp3","charTypeName":"word"},{"id":43214,"position":11,"arabic":"يَتَضَرَّعُونَ","translation":"বিনীত হয়","audioUrl":"wbw/006_042_011.mp3","charTypeName":"word"},{"id":43215,"position":12,"arabic":"٤٢","translation":"(৪২)","audioUrl":null,"charTypeName":"end"}]},{"number":43,"arabic":"فَلَوْلَآ إِذْ جَآءَهُم بَأْسُنَا تَضَرَّعُوا۟ وَلَٰكِن قَسَتْ قُلُوبُهُمْ وَزَيَّنَ لَهُمُ ٱلشَّيْطَٰنُ مَا كَانُوا۟ يَعْمَلُونَ","translation":"yet when the misfortune decreed by Us befell them, they did not humble themselves, but rather their hearts grew hard, for Satan had made 