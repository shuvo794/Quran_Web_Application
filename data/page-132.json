":"(৪৩)","audioUrl":null,"charTypeName":"end"}]},{"number":44,"arabic":"فَلَمَّا نَسُوا۟ مَا ذُكِّرُوا۟ بِهِۦ فَتَحْنَا عَلَيْهِمْ أَبْوَٰبَ كُلِّ شَىْءٍ حَتَّىٰٓ إِذَا فَرِحُوا۟ بِمَآ أُوتُوٓا۟ أَخَذْنَٰهُم بَغْتَةًۭ فَإِذَا هُم مُّبْلِسُونَ","translation":"Then, when they had forgotten all that they had been told to take to heart, We threw open to them the gates of all [good] things until -even as they were rejoicing in what they had been granted - We suddenly took them to task: and lo! they were broken in spirit;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/833.mp3","surahId":6,"words":[{"id":44745,"position":1,"arabic":"فَلَمَّا","translation":"অতঃপর যখন","audioUrl":"wbw/006_044_001.mp3","charTypeName":"word"},{"id":44746,"position":2,"arabic":"نَسُوا۟","translation":"তারা ভুলে গেল","audioUrl":"wbw/006_044_002.mp3","charTypeName":"word"},{"id":44747,"position":3,"arabic":"مَا","translation":"যা","audioUrl":"wbw/006_044_003.mp3","charTypeName":"word"},{"id":44748,"position":4,"arabic":"ذُكِّرُوا۟","translation":"তাদের উপদেশ দেয়া হয়েছিলো","audioUrl":"wbw/006_044_004.mp3","charTypeName":"word"},{"id":44749,"position":5,"arabic":"بِهِۦ","translation":"সম্পর্কে সে","audioUrl":"wbw/006_044_005.mp3","charTypeName":"word"},{"id":44750,"position":6,"arabic":"فَتَحْنَا","translation":"তখন খুলে দিলাম আমরা","audioUrl":"wbw/006_044_006.mp3","charTypeName":"word"},{"id":44751,"position":7,"arabic":"عَلَيْهِمْ","translation":"উপর তাদের","audioUrl":"wbw/006_044_007.mp3","charTypeName":"word"},{"id":44752,"position":8,"arabic":"أَبْوَٰبَ","translation":"(স্বচ্ছলতার) দরজাসমূহ","audioUrl":"wbw/006_044_008.mp3","charTypeName":"word"},{"id":44753,"position":9,"arabic":"كُلِّ","translation":"সব","audioUrl":"wbw/006_044_009.mp3","charTypeName":"word"},{"id":44754,"position":10,"arabic":"شَىْءٍ","translation":"কিছুর","audioUrl":"wbw/006_044_010.mp3","charTypeName":"word"},{"id":44755,"position":11,"arabic":"حَتَّىٰٓ","translation":"এমনকি","audioUrl":"wbw/006_044_011.mp3","charTypeName":"word"},{"id":44756,"position":12,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/006_044_012.mp3","charTypeName":"word"},{"id":44757,"position":13,"arabic":"فَرِحُوا۟","translation":"তারা উল্লসিত হলো","audioUrl":"wbw/006_044_013.mp3","charTypeName":"word"},{"id":44758,"position":14,"arabic":"بِمَآ","translation":"নিয়ে তা যা","audioUrl":"wbw/006_044_014.mp3","charTypeName":"word"},{"id":44759,"position":15,"arabic":"أُوتُوٓا۟","translation":"তাদের দেয়া হয়েছিলো","audioUrl":"wbw/006_044_015.mp3","charTypeName":"word"},{"id":44760,"position":16,"arabic":"أَخَذْنَـٰهُم","translation":"আমরা ধরলাম তাদের","audioUrl":"wbw/006_044_016.mp3","charTypeName":"word"},{"id":44761,"position":17,"arabic":"بَغْتَةًۭ","translation":"হঠাৎ","audioUrl":"wbw/006_044_017.mp3","charTypeName":"word"},{"id":44762,"position":18,"arabic":"فَإِذَا","translation":"ফলে তখন","audioUrl":"wbw/006_044_018.mp3","charTypeName":"word"},{"id":44763,"position":19,"arabic":"هُم","translation":"তারা","audioUrl":"wbw/006_044_019.mp3","charTypeName":"word"},{"id":44764,"position":20,"arabic":"مُّبْلِسُونَ","translation":"নিরাশ হয়ে পড়লো","audioUrl":"wbw/006_044_020.mp3","charTypeName":"word"},{"id":44765,"position":21,"arabic":"٤٤","translation":"(৪৪)","audioUrl":null,"charTypeName":"end"}]}]}