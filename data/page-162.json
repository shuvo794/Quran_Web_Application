followers]: \"Indeed, if you follow Shu'ayb, you will, verily, be the losers!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1044.mp3","surahId":7,"words":[{"id":67967,"position":1,"arabic":"وَقَالَ","translation":"এবং বললো","audioUrl":"wbw/007_090_001.mp3","charTypeName":"word"},{"id":67968,"position":2,"arabic":"ٱلْمَلَأُ","translation":"প্রধান ব্যক্তিরা","audioUrl":"wbw/007_090_002.mp3","charTypeName":"word"},{"id":67969,"position":3,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/007_090_003.mp3","charTypeName":"word"},{"id":67970,"position":4,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করেছিলো","audioUrl":"wbw/007_090_004.mp3","charTypeName":"word"},{"id":67971,"position":5,"arabic":"مِن","translation":"মধ্য হতে","audioUrl":"wbw/007_090_005.mp3","charTypeName":"word"},{"id":67972,"position":6,"arabic":"قَوْمِهِۦ","translation":"জাতির তার","audioUrl":"wbw/007_090_006.mp3","charTypeName":"word"},{"id":67973,"position":7,"arabic":"لَئِنِ","translation":"\"অবশ্যই যদি","audioUrl":"wbw/007_090_007.mp3","charTypeName":"word"},{"id":67974,"position":8,"arabic":"ٱتَّبَعْتُمْ","translation":"অনুসরণ করো তোমরা","audioUrl":"wbw/007_090_008.mp3","charTypeName":"word"},{"id":67975,"position":9,"arabic":"شُعَيْبًا","translation":"শুয়াইবের","audioUrl":"wbw/007_090_009.mp3","charTypeName":"word"},{"id":67976,"position":10,"arabic":"إِنَّكُمْ","translation":"নিশ্চয়ই তোমরা","audioUrl":"wbw/007_090_010.mp3","charTypeName":"word"},{"id":67977,"position":11,"arabic":"إِذًۭا","translation":"তাহলে (হবে)","audioUrl":"wbw/007_090_011.mp3","charTypeName":"word"},{"id":67978,"position":12,"arabic":"لَّخَـٰسِرُونَ","translation":"অবশ্যই ক্ষতিগ্রস্ত\"","audioUrl":"wbw/007_090_012.mp3","charTypeName":"word"},{"id":67979,"position":13,"arabic":"٩٠","translation":"(৯০)","audioUrl":null,"charTypeName":"end"}]},{"number":91,"arabic":"فَأَخَذَتْهُمُ ٱلرَّجْفَةُ فَأَصْبَحُوا۟ فِى دَارِهِمْ جَٰثِمِينَ","translation":"Thereupon an earthquake overtook them: and then they lay lifeless, in their very homes, on the ground -","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1045.mp3","surahId":7,"words":[{"id":68546,"position":1,"arabic":"فَأَخَذَتْهُمُ","translation":"অতঃপর ধরলো তাদেরকে","audioUrl":"wbw/007_091_001.mp3","charTypeName":"word"},{"id":68547,"position":2,"arabic":"ٱلرَّجْفَةُ","translation":"ভুমিকম্পে","audioUrl":"wbw/007_091_002.mp3","charTypeName":"word"},{"id":68548,"position":3,"arabic":"فَأَصْبَحُوا۟","translation":"অতঃপর তারা হলো","audioUrl":"wbw/007_091_003.mp3","charTypeName":"word"},{"id":68549,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/007_091_004.mp3","charTypeName":"word"},{"id":68550,"position":5,"arabic":"دَارِهِمْ","translation":"ঘরের তাদের","audioUrl":"wbw/007_091_005.mp3","charTypeName":"word"},{"id":68551,"position":6,"arabic":"جَـٰثِمِينَ","translation":"উপুড় হয়ে পড়ে থাকা অবস্থায়(অর্থাৎ মৃত পড়ে রইল)","audioUrl":"wbw/007_091_006.mp3","charTypeName":"word"},{"id":68552,"position":7,"arabic":"٩١","translation":"(৯১)","audioUrl":null,"charTypeName":"end"}]},{"number":92,"arabic":"ٱلَّذِينَ كَذَّبُوا۟ شُعَيْبًۭا كَأَن لَّمْ يَغْنَوْا۟ فِيهَا ۚ ٱلَّذِينَ كَذَّبُوا۟ شُعَيْبًۭا كَانُوا۟ هُمُ ٱلْخَٰسِرِينَ","translation":"they who had given the lie to Shu'ayb - as though they had never lived there: they who had given the lie to Shu'ayb -it was they who were the losers!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1046.mp3","surahId":7,"words":[{"id":68663,"position":1,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/007_092_001.mp3","charTypeName":"word"},{"id":68664,"position":2,"arabic":"كَذَّبُوا۟","translation":"প্রত্যাখ্যান করেছিলো","audioUrl":"wbw/007_092_002.mp3","charTypeName":"word"},{"id":68665,"position":3,"arabic":"شُعَيْبًۭا","translation":"শুয়াইবকে","audioUrl":"wbw/007_092_003.mp3","charTypeName":"word"},{"id":68666,"position":4,"arabic":"كَأَن","translation":"(তারা এমন হলো) যেন","audioUrl":"wbw/007_092_004.mp3","charTypeName":"