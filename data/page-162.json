{"id":162,"ayahs":[{"number":88,"arabic":"۞ قَالَ ٱلْمَلَأُ ٱلَّذِينَ ٱسْتَكْبَرُوا۟ مِن قَوْمِهِۦ لَنُخْرِجَنَّكَ يَٰشُعَيْبُ وَٱلَّذِينَ ءَامَنُوا۟ مَعَكَ مِن قَرْيَتِنَآ أَوْ لَتَعُودُنَّ فِى مِلَّتِنَا ۚ قَالَ أَوَلَوْ كُنَّا كَٰرِهِينَ","translation":"Said the great ones among his people, who gloried in their arrogance: \"Most certainly, O Shu'ayb, we shall expel thee and thy fellow-believers from our land, unless you indeed return to our ways!\" Said [Shu'ayb]: \"Why, even though we abhor [them]?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1042.mp3","surahId":7,"words":[{"id":67407,"position":1,"arabic":"۞ قَالَ","translation":"বললো","audioUrl":"wbw/007_088_002.mp3","charTypeName":"word"},{"id":67408,"position":2,"arabic":"ٱلْمَلَأُ","translation":"প্রধানরা","audioUrl":"wbw/007_088_003.mp3","charTypeName":"word"},{"id":67409,"position":3,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/007_088_004.mp3","charTypeName":"word"},{"id":67410,"position":4,"arabic":"ٱسْتَكْبَرُوا۟","translation":"অহংকার করেছিলো","audioUrl":"wbw/007_088_005.mp3","charTypeName":"word"},{"id":67411,"position":5,"arabic":"مِن","translation":"মধ্য হতে","audioUrl":"wbw/007_088_006.mp3","charTypeName":"word"},{"id":67412,"position":6,"arabic":"قَوْمِهِۦ","translation":"জাতি তার","audioUrl":"wbw/007_088_007.mp3","charTypeName":"word"},{"id":67413,"position":7,"arabic":"لَنُخْرِجَنَّكَ","translation":"\"অবশ্যই আমরা বের করবো তোমাকে","audioUrl":"wbw/007_088_008.mp3","charTypeName":"word"},{"id":67414,"position":8,"arabic":"يَـٰشُعَيْبُ","translation":"হে শুয়াইব","audioUrl":"wbw/007_088_009.mp3","charTypeName":"word"},{"id":67415,"position":9,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/007_088_010.mp3","charTypeName":"word"},{"id":67416,"position":10,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/007_088_011.mp3","charTypeName":"word"},{"id":67417,"position":11,"arabic":"مَعَكَ","translation":"সাথে তোমার","audioUrl":"wbw/007_088_012.mp3","charTypeName":"word"},{"id":67418,"position":12,"arabic":"مِن","translation":"হতে","audioUrl":"wbw/007_088_013.mp3","charTypeName":"word"},{"id":67419,"position":13,"arabic":"قَرْيَتِنَآ","translation":"জনপদ আমাদের","audioUrl":"wbw/007_088_014.mp3","charTypeName":"word"},{"id":67420,"position":14,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/007_088_015.mp3","charTypeName":"word"},{"id":67421,"position":15,"arabic":"لَتَعُودُنَّ","translation":"অবশ্যই তোমরা ফিরে আসবে","audioUrl":"wbw/007_088_016.mp3","charTypeName":"word"},{"id":67422,"position":16,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/007_088_017.mp3","charTypeName":"word"},{"id":67423,"position":17,"arabic":"مِلَّتِنَا ۚ","translation":"দীনের আমাদের\"","audioUrl":"wbw/007_088_018.mp3","charTypeName":"word"},{"id":67425,"position":18,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/007_088_020.mp3","charTypeName":"word"},{"id":67426,"position":19,"arabic":"أَوَلَوْ","translation":"\"কি যদিও","audioUrl":"wbw/007_088_021.mp3","charTypeName":"word"},{"id":67427,"position":20,"arabic":"كُنَّا","translation":"আমরা হলাম (তোমাদের দীনকে)","audioUrl":"wbw/007_088_022.mp3","charTypeName":"word"},{"id":67428,"position":21,"arabic":"كَـٰرِهِينَ","translation":"অপছন্দকারী","audioUrl":"wbw/007_088_023.mp3","charTypeName":"word"},{"id":67429,"position":22,"arabic":"٨٨","translation":"(৮৮)","audioUrl":null,"charTypeName":"end"}]},{"number":89,"arabic":"قَدِ ٱفْتَرَيْنَا عَلَى ٱللَّهِ كَذِبًا إِنْ عُدْنَا فِى مِلَّتِكُم بَعْدَ إِذْ نَجَّىٰنَا ٱللَّهُ مِنْهَا ۚ وَمَا يَكُونُ لَنَآ أَن نَّعُودَ فِيهَآ إِلَّآ أَن يَشَآءَ ٱللَّهُ رَبُّنَا ۚ وَسِعَ رَبُّنَا كُلَّ شَىْءٍ عِلْمًا ۚ عَلَى ٱللَّهِ تَوَكَّلْنَا ۚ رَبَّنَا ٱفْتَحْ بَيْنَنَا وَبَيْنَ قَوْمِنَا بِٱلْحَقِّ وَأَنتَ خَيْرُ ٱلْفَٰتِحِينَ","translation":"We should be guilty of blaspheming against God were we to return to your ways after God has saved us from them! It is not conceivable that we should return to them-unless God, our Sustainer, so wills. All things does our Sustainer embrace within His knowledge; in God do we place our trust. O our Sustainer! Lay Thou open the truth between us and our people -for Thou art the best of all to lay open the truth!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1043.mp3","surahId":7,"words":[{"id":67623,"position":1,"arabic":"قَدِ","translation":"(সেক্ষেত্রে) নিশ্চয়ই","audioUrl":"wbw/007_089_001.mp3","charTypeName":"word"},{"id":67624,"position":2,"arabic":"ٱفْتَرَيْنَا","translation":"আরোপ করলাম আমরা","audioUrl":"wbw/007_089_002.mp3","charTypeName":"word"},{"id":67625,"position":3,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/007_089_003.mp3","charTypeName":"word"},{"id":67626,"position":4,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/007_089_004.mp3","charTypeName":"word"},{"id":67627,"position":5,"arabic":"كَذِبًا","translation":"মিথ্যা","audioUrl":"wbw/007_089_005.mp3","charTypeName":"word"},{"id":67628,"position":6,"arabic":"إِنْ","translation":"যদি","audioUrl":"wbw/007_089_006.mp3","charTypeName":"word"},{"id":67629,"position":7,"arabic":"عُدْنَا","translation":"ফিরে যাই আমরা","audioUrl":"wbw/007_089_007.mp3","charTypeName":"word"},{"id":67630,"position":8,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/007_089_008.mp3","charTypeName":"word"},{"id":67631,"position":9,"arabic":"مِلَّتِكُم","translation":"দীনের তোমাদের","audioUrl":"wbw/007_089_009.mp3","charTypeName":"word"},{"id":67632,"position":10,"arabic":"بَعْدَ","translation":"এর পরেও","audioUrl":"wbw/007_089_010.mp3","charTypeName":"word"},{"id":67633,"position":11,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/007_089_011.mp3","charTypeName":"word"},{"id":67634,"position":12,"arabic":"نَجَّىٰنَا","translation":"মুক্তি দিয়েছেন আমাদের","audioUrl":"wbw/007_089_012.mp3","charTypeName":"word"},{"id":67635,"position":13,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/007_089_013.mp3","charTypeName":"word"},{"id":67636,"position":14,"arabic":"مِنْهَا ۚ","translation":"হতে তা","audioUrl":"wbw/007_089_014.mp3","charTypeName":"word"},{"id":67638,"position":15,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/007_089_016.mp3","charTypeName":"word"},{"id":67639,"position":16,"arabic":"يَكُونُ","translation":"শোভা পায়","audioUrl":"wbw/007_089_017.mp3","charTypeName":"word"},{"id":67640,"position":17,"arabic":"لَنَآ","translation":"জন্যে আমাদের","audioUrl":"wbw/007_089_018.mp3","charTypeName":"word"},{"id":67641,"position":18,"arabic":"أَن","translation":"যে","audioUrl":"wbw/007_089_019.mp3","charTypeName":"word"},{"id":67642,"position":19,"arabic":"نَّعُودَ","translation":"আমরা ফিরবো","audioUrl":"wbw/007_089_020.mp3","charTypeName":"word"},{"id":67643,"position":20,"arabic":"فِيهَآ","translation":"মধ্যে তার","audioUrl":"wbw/007_089_021.mp3","charTypeName":"word"},{"id":67644,"position":21,"arabic":"إِلَّآ","translation":"তবে","audioUrl":"wbw/007_089_022.mp3","charTypeName":"word"},{"id":67645,"position":22,"arabic":"أَن","translation":"যদি","audioUrl":"wbw/007_089_023.mp3","charTypeName":"word"},{"id":67646,"position":23,"arabic":"يَشَآءَ","translation":"ইচ্ছে করেন","audioUrl":"wbw/007_089_024.mp3","charTypeName":"word"},{"id":67647,"position":24,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/007_089_025.mp3","charTypeName":"word"},{"id":67648,"position":25,"arabic":"رَبُّنَا ۚ","translation":"আমাদের রব","audioUrl":"wbw/007_089_026.mp3","charTypeName":"word"},{"id":67650,"position":26,"arabic":"وَسِعَ","translation":"পরিবেষ্টন করে আছেন","audioUrl":"wbw/007_089_028.mp3","charTypeName":"word"},{"id":67651,"position":27,"arabic":"رَبُّنَا","translation":"আমাদের রব","audioUrl":"wbw/007_089_029.mp3","charTypeName":"word"},{"id":67652,"position":28,"arabic":"كُلَّ","translation":"সব","audioUrl":"wbw/007_089_030.mp3","charTypeName":"word"},{"id":67653,"position":29,"arabic":"شَىْءٍ","translation":"কিছুকে","audioUrl":"wbw/007_089_031.mp3","charTypeName":"word"},{"id":67654,"position":30,"arab