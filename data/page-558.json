{"id":558,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ يَٰٓأَيُّهَا ٱلنَّبِىُّ إِذَا طَلَّقْتُمُ ٱلنِّسَآءَ فَطَلِّقُوهُنَّ لِعِدَّتِهِنَّ وَأَحْصُوا۟ ٱلْعِدَّةَ ۖ وَٱتَّقُوا۟ ٱللَّهَ رَبَّكُمْ ۖ لَا تُخْرِجُوهُنَّ مِنۢ بُيُوتِهِنَّ وَلَا يَخْرُجْنَ إِلَّآ أَن يَأْتِينَ بِفَٰحِشَةٍۢ مُّبَيِّنَةٍۢ ۚ وَتِلْكَ حُدُودُ ٱللَّهِ ۚ وَمَن يَتَعَدَّ حُدُودَ ٱللَّهِ فَقَدْ ظَلَمَ نَفْسَهُۥ ۚ لَا تَدْرِى لَعَلَّ ٱللَّهَ يُحْدِثُ بَعْدَ ذَٰلِكَ أَمْرًۭا","translation":"O PROPHET! When you [intend to divorce women, divorce them with a view to the waiting period appointed for them, and reckon the period [carefully], and be conscious of God, your Sustainer. Do not expel them from their homes; and neither shall they [be made to] leave unless they become openly guilty of immoral conduct. These, then, are the bounds set by God - and he who transgresses the bounds set by God does indeed sin against himself: [for, O man, although] thou knowest it not, after that [first breach] God may well cause something new to come about.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5218.mp3","surahId":65,"words":[{"id":508,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/065_001_001.mp3","charTypeName":"word"},{"id":509,"position":2,"arabic":"ٱلنَّبِىُّ","translation":"নবী","audioUrl":"wbw/065_001_002.mp3","charTypeName":"word"},{"id":510,"position":3,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/065_001_003.mp3","charTypeName":"word"},{"id":511,"position":4,"arabic":"طَلَّقْتُمُ","translation":"তোমরা তালাক দাও","audioUrl":"wbw/065_001_004.mp3","charTypeName":"word"},{"id":512,"position":5,"arabic":"ٱلنِّسَآءَ","translation":"স্ত্রীদের","audioUrl":"wbw/065_001_005.mp3","charTypeName":"word"},{"id":513,"position":6,"arabic":"فَطَلِّقُوهُنَّ","translation":"অতঃপর তাদের তোমরা তালাক দাও","audioUrl":"wbw/065_001_006.mp3","charTypeName":"word"},{"id":514,"position":7,"arabic":"لِعِدَّتِهِنَّ","translation":"তাদের ইদ্দতের জন্য","audioUrl":"wbw/065_001_007.mp3","charTypeName":"word"},{"id":515,"position":8,"arabic":"وَأَحْصُوا۟","translation":"ও তোমরা গণনা কর","audioUrl":"wbw/065_001_008.mp3","charTypeName":"word"},{"id":516,"position":9,"arabic":"ٱلْعِدَّةَ ۖ","translation":"ইদ্দত","audioUrl":"wbw/065_001_009.mp3","charTypeName":"word"},{"id":518,"position":10,"arabic":"وَٱتَّقُوا۟","translation":"এবং তোমরা ভয় কর","audioUrl":"wbw/065_001_011.mp3","charTypeName":"word"},{"id":519,"position":11,"arabic":"ٱللَّهَ","translation":"আল্লাহকে","audioUrl":"wbw/065_001_012.mp3","charTypeName":"word"},{"id":520,"position":12,"arabic":"رَبَّكُمْ ۖ","translation":"তোমাদের রব","audioUrl":"wbw/065_001_013.mp3","charTypeName":"word"},{"id":522,"position":13,"arabic":"لَا","translation":"না","audioUrl":"wbw/065_001_015.mp3","charTypeName":"word"},{"id":523,"position":14,"arabic":"تُخْرِجُوهُنَّ","translation":"তাদের তোমরা বের করো","audioUrl":"wbw/065_001_016.mp3","charTypeName":"word"},{"id":524,"position":15,"arabic":"مِنۢ","translation":"থেকে","audioUrl":"wbw/065_001_017.mp3","charTypeName":"word"},{"id":525,"position":16,"arabic":"بُيُوتِهِنَّ","translation":"তাদের ঘরগুলো","audioUrl":"wbw/065_001_018.mp3","charTypeName":"word"},{"id":526,"position":17,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/065_001_019.mp3","charTypeName":"word"},{"id":527,"position":18,"arabic":"يَخْرُجْنَ","translation":"তারা বের হবে","audioUrl":"wbw/065_001_020.mp3","charTypeName":"word"},{"id":528,"position":19,"arabic":"إِلَّآ","translation":"তবে","audioUrl":"wbw/065_001_021.mp3","charTypeName":"word"},{"id":529,"position":20,"arabic":"أَن","translation":"যদি","audioUrl":"wbw/065_001_022.mp3","charTypeName":"word"},{"id":530,"position":21,"arabic":"يَأْتِينَ","translation":"তারা লিপ্ত হয়","audioUrl":"wbw/065_001_023.mp3","charTypeName":"word"},{"id":531,"position":22,"arabic":"بِفَـٰحِشَةٍۢ","translation":"অশ্লীলতায়","audioUrl":"wbw/065_001_024.mp3","charTypeName":"word"},{"id":532,"position":23,"arabic":"مُّبَيِّن