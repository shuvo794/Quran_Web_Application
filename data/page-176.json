{"id":176,"ayahs":[{"number":196,"arabic":"إِنَّ وَلِۦِّىَ ٱللَّهُ ٱلَّذِى نَزَّلَ ٱلْكِتَٰبَ ۖ وَهُوَ يَتَوَلَّى ٱلصَّٰلِحِينَ","translation":"Verily, my protector is God, who has bestowed this divine writ from on high: for it is He who protects the righteous,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1150.mp3","surahId":7,"words":[{"id":84970,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/007_196_001.mp3","charTypeName":"word"},{"id":84971,"position":2,"arabic":"وَلِـِّۧىَ","translation":"আমার অভিভাবক","audioUrl":"wbw/007_196_002.mp3","charTypeName":"word"},{"id":84972,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/007_196_003.mp3","charTypeName":"word"},{"id":84973,"position":4,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/007_196_004.mp3","charTypeName":"word"},{"id":84974,"position":5,"arabic":"نَزَّلَ","translation":"অবতীর্ণ করেছেন","audioUrl":"wbw/007_196_005.mp3","charTypeName":"word"},{"id":84975,"position":6,"arabic":"ٱلْكِتَـٰبَ ۖ","translation":"কিতাব","audioUrl":"wbw/007_196_006.mp3","charTypeName":"word"},{"id":84977,"position":7,"arabic":"وَهُوَ","translation":"এবং তিনি","audioUrl":"wbw/007_196_008.mp3","charTypeName":"word"},{"id":84978,"position":8,"arabic":"يَتَوَلَّى","translation":"অভিভাবকত্ব করেন","audioUrl":"wbw/007_196_009.mp3","charTypeName":"word"},{"id":84979,"position":9,"arabic":"ٱلصَّـٰلِحِينَ","translation":"সৎকর্মশীলদের","audioUrl":"wbw/007_196_010.mp3","charTypeName":"word"},{"id":84980,"position":10,"arabic":"١٩٦","translation":"(১৯৬)","audioUrl":null,"charTypeName":"end"}]},{"number":197,"arabic":"وَٱلَّذِينَ تَدْعُونَ مِن دُونِهِۦ لَا يَسْتَطِيعُونَ نَصْرَكُمْ وَلَآ أَنفُسَهُمْ يَنصُرُونَ","translation":"whereas all those whom you invoke in His stead are neither able to give you succour nor can succour themselves;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1151.mp3","surahId":7,"words":[{"id":85105,"position":1,"arabic":"وَٱلَّذِينَ","translation":"এবং যাদের","audioUrl":"wbw/007_197_001.mp3","charTypeName":"word"},{"id":85106,"position":2,"arabic":"تَدْعُونَ","translation":"তোমরা আহবান করো","audioUrl":"wbw/007_197_002.mp3","charTypeName":"word"},{"id":85107,"position":3,"arabic":"مِن","translation":"দিয়ে","audioUrl":"wbw/007_197_003.mp3","charTypeName":"word"},{"id":85108,"position":4,"arabic":"دُونِهِۦ","translation":"ছেড়ে তাঁকে","audioUrl":"wbw/007_197_004.mp3","charTypeName":"word"},{"id":85109,"position":5,"arabic":"لَا","translation":"না","audioUrl":"wbw/007_197_005.mp3","charTypeName":"word"},{"id":85110,"position":6,"arabic":"يَسْتَطِيعُونَ","translation":"তারা সমর্থ হয়","audioUrl":"wbw/007_197_006.mp3","charTypeName":"word"},{"id":85111,"position":7,"arabic":"نَصْرَكُمْ","translation":"সাহায্য করতে তোমাদেরকে","audioUrl":"wbw/007_197_007.mp3","charTypeName":"word"},{"id":85112,"position":8,"arabic":"وَلَآ","translation":"এবং না","audioUrl":"wbw/007_197_008.mp3","charTypeName":"word"},{"id":85113,"position":9,"arabic":"أَنفُسَهُمْ","translation":"নিজেদেরকে তাদের","audioUrl":"wbw/007_197_009.mp3","charTypeName":"word"},{"id":85114,"position":10,"arabic":"يَنصُرُونَ","translation":"সাহায্য করতে পারে","audioUrl":"wbw/007_197_010.mp3","charTypeName":"word"},{"id":85115,"position":11,"arabic":"١٩٧","translation":"(১৯৭)","audioUrl":null,"charTypeName":"end"}]},{"number":198,"arabic":"وَإِن تَدْعُوهُمْ إِلَى ٱلْهُدَىٰ لَا يَسْمَعُوا۟ ۖ وَتَرَىٰهُمْ يَنظُرُونَ إِلَيْكَ وَهُمْ لَا يُبْصِرُونَ","translation":"and if you pray unto them for guidance, they do not hear; and though thou mayest imagine that they behold thee, they do not see.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1152.mp3","surahId":7,"words":[{"id":85193,"position":1,"arabic":"وَإِن","translation":"এবং যদি","audioUrl":"wbw/007_198_001.mp3","charTypeName":"word"},{"id":85194,"position":2,"arabic":"تَدْعُوهُمْ","translation":"আহবান করো তাদেরকে","audioUrl":"wbw/007_198_002.mp3","charTypeName":"word"},{"id":85195,"position":3,"arabic":"إِلَى","translation":"দিকে","audioUrl":"wbw/007_198_003.mp3","charTypeName":"word"},{"id":85196,"position":4,"arabic":"ٱلْهُدَىٰ","translation":"সৎপথের","audioUrl":"wbw/007_198_004.mp3","charTypeName":"word"},{"id":85197,"position":5,"arabic":"لَا","translation":"না","audioUrl":"wbw/007_198_005.mp3","charTypeName":"word"},{"id":85198,"position":6,"arabic":"يَسْمَعُوا۟ ۖ","translation":"তারা শুনতে পায়","audioUrl":"wbw/007_198_006.mp3","charTypeName":"word"},{"id":85200,"position":7,"arabic":"وَتَرَىٰهُمْ","translation":"এবং (বাহ্যতঃ)তুমি দেখতে পাবে তাদেরকে","audioUrl":"wbw/007_198_008.mp3","charTypeName":"word"},{"id":85201,"position":8,"arabic":"يَنظُرُونَ","translation":"তারা তাকাচ্ছে","audioUrl":"wbw/007_198_009.mp3","charTypeName":"word"},{"id":85202,"position":9,"arabic":"إِلَيْكَ","translation":"তোমার দিকে","audioUrl":"wbw/007_198_010.mp3","charTypeName":"word"},{"id":85203,"position":10,"arabic":"وَهُمْ","translation":"অথচ তারা","audioUrl":"wbw/007_198_011.mp3","charTypeName":"word"},{"id":85204,"position":11,"arabic":"لَا","translation":"না","audioUrl":"wbw/007_198_012.mp3","charTypeName":"word"},{"id":85205,"position":12,"arabic":"يُبْصِرُونَ","translation":"দেখতে পায়","audioUrl":"wbw/007_198_013.mp3","charTypeName":"word"},{"id":85206,"position":13,"arabic":"١٩٨","translation":"(১৯৮)","audioUrl":null,"charTypeName":"end"}]},{"number":199,"arabic":"خُذِ ٱلْعَفْوَ وَأْمُرْ بِٱلْعُرْفِ وَأَعْرِضْ عَنِ ٱلْجَٰهِلِينَ","translation":"MAKE due allowance for man's nature, and enjoin the doing of what is right; and leave alone all those who choose to remain ignorant.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1153.mp3","surahId":7,"words":[{"id":85207,"position":1,"arabic":"خُذِ","translation":"অবলম্বন করো","audioUrl":"wbw/007_199_001.mp3","charTypeName":"word"},{"id":85208,"position":2,"arabic":"ٱلْعَفْوَ","translation":"ক্ষমাশীলতা","audioUrl":"wbw/007_199_002.mp3","charTypeName":"word"},{"id":85209,"position":3,"arabic":"وَأْمُرْ","translation":"ও নির্দেশ দাও","audioUrl":"wbw/007_199_003.mp3","charTypeName":"word"},{"id":85210,"position":4,"arabic":"بِٱلْعُرْفِ","translation":"প্রতি সৎকাজের","audioUrl":"wbw/007_199_004.mp3","charTypeName":"word"},{"id":85211,"position":5,"arabic":"وَأَعْرِضْ","translation":"এবং উপেক্ষা করো","audioUrl":"wbw/007_199_005.mp3","charTypeName":"word"},{"id":85212,"position":6,"arabic":"عَنِ","translation":"থেকে","audioUrl":"wbw/007_199_006.mp3","charTypeName":"word"},{"id":85213,"position":7,"arabic":"ٱلْجَـٰهِلِينَ","translation":"মূর্খদের","audioUrl":"wbw/007_199_007.mp3","charTypeName":"word"},{"id":85214,"position":8,"arabic":"١٩٩","translation":"(১৯৯)","audioUrl":null,"charTypeName":"end"}]},{"number":200,"arabic":"وَإِمَّا يَنزَغَنَّكَ مِنَ ٱلشَّيْطَٰنِ نَزْغٌۭ فَٱسْتَعِذْ بِٱللَّهِ ۚ إِنَّهُۥ سَمِيعٌ عَلِيمٌ","translation":"And if it should happen that a prompting from Satan stirs thee up [to blind anger], seek refuge with God: behold, He is all-hearing, all-knowing.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1154.mp3","surahId":7,"words":[{"id":85301,"position":1,"arabic":"وَإِمَّا","translation":"এবং যদি","audioUrl":"wbw/007_200_001.mp3","charTypeName":"word"},{"id":85302,"position":2,"arabic":"يَنزَغَنَّكَ","translation":"তোমাকে প্ররোচিত করে","audioUrl":"wbw/007_200_002.mp3","charTypeName":"word"},{"id":85303,"position":3,"arabic":"مِنَ","translation":"পক্ষ হতে","audioUrl":"wbw/007_200_003.mp3","charTypeName":"word"},{"id":85304,"position":4,"arabic":"ٱلشَّيْطَـٰنِ","translation":"শয়তানের","audioUrl":"wbw/007_200_004.mp3","charTypeName":"word"},{"id":85305,"position":5,"arabic":"نَزْغٌۭ","translation":"কোনো কুমন্ত্রণা","audioUrl":"wbw/007_200_005.mp3","charTypeName":"word"},{"id":85306,"position":6,"arabic":"فَٱسْتَعِذْ","translation":"তবে তুমি অাশ্রয় চাও","audioUrl":"wbw/007_200_006.mp3","charTypeName":"word"},{"id":85307,"position":7,"arabic":"بِٱللَّهِ ۚ","translation":"কাছে আল্লাহর","audioUrl":"wbw/007_200_007.mp3","charTypeName":"word"},{"id":85309,"position":8,"arabic":"إِنَّهُۥ","translation":"নিশ্চয়ই তিনি","audioUrl":"wbw/007_200_009.mp3","charTypeName":"word"},{"id":85310,"position":9,"arabic":"سَمِيعٌ","translation":"সবকিছু শুনেন","audioUrl":"wbw/007_200_010.mp3","charTypeName":"word"},{"id":85311,"position":10,"arabic":"عَلِيمٌ","translation":"সবকিছুু জানেন","audioUrl":"wbw/007_200_011.mp3","charTypeName":"word"},{"id":85312,"position":11,"arabic":"٢٠٠","translation":"(২০০)","audioUrl":null,"charTypeName":"end"}]},{"number":201,"arabic":"إِنَّ ٱلَّذِينَ ٱتَّقَوْا۟ إِذَا مَسَّهُمْ طَٰٓئِفٌۭ مِّنَ ٱلشَّيْطَٰنِ تَذَكَّرُوا۟ فَإِذَا هُم مُّبْصِرُونَ","translation":"Verily, they who are conscious of God bethink themselves [of Him] whenever any dark suggestion from Satan touches them - whereupon, lo! they begin to see [things] clearly,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1155.mp3","surahId":7,"words":[{"id":85324,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/007_201_001.mp3","charTypeName":"word"},{"id":85325,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/007_201_002.mp3","charTypeName":"word"},{"id":85326,"position":3,"arabic":"ٱتَّقَوْا۟","translation":"তাকওয়া অবলম্বন করে","audioUrl":"wbw/007_201_003.mp3","charTypeName":"word"},{"id":85327,"position":4,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/007_201_004.mp3","charTypeName":"word"},{"id":85328,"position":5,"arabic":"مَسَّهُمْ","translation":"স্পর্শ করে তাদেরকে","audioUrl":"wbw/007_201_005.mp3","charTypeName":"word"},{"id":85329,"position":6,"arabic":"طَـٰٓئِفٌۭ","translation":"কোনো কুচিন্তা","audioUrl":"wbw/007_201_006.mp3","charTypeName":"word"},{"id":85330,"position":7,"arabic":"مِّنَ","translation":"পক্ষ হতে","audioUrl":"wbw/007_201_007.mp3","charTypeName":"word"},{"id":85331,"position":8,"arabic":"ٱلشَّيْطَـٰنِ","translation":"শয়তানের","audioUrl":"wbw/007_201_008.mp3","charTypeName":"word"},{"id":85332,"position":9,"arabic":"تَذَكَّرُوا۟","translation":"তারা স্মরণ করে (আল্লাহকে)","audioUrl":"wbw/007_201_009.mp3","charTypeName":"word"},{"id":85333,"position":10,"arabic":"فَإِذَا","translation":"অত:পর তখন","audioUrl":"wbw/007_201_010.mp3","charTypeName":"word"},{"id":85334,"position":11,"arabic":"هُم","translation":"তারা","audioUrl":"wbw/007_201_011.mp3","charTypeName":"word"},{"id":85335,"position":12,"arabic":"مُّبْصِرُونَ","translation":"দেখতে পায় (সঠিক পথ)","audioUrl":"wbw/007_201_012.mp3","charTypeName":"word"},{"id":85336,"position":13,"arabic":"٢٠١","translation":"(২০১)","audioUrl":null,"charTypeName":"end"}]},{"number":202,"arabic":"وَإِخْوَٰنُهُمْ يَمُدُّونَهُمْ فِى ٱلْغَىِّ ثُمَّ لَا يُقْصِرُونَ","translation":"even though their [godless] brethren would [like to] draw them into error: and then they cannot fail [to do what is right].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1156.mp3","surahId":7,"words":[{"id":85376,"position":1,"arabic":"وَإِخْوَٰنُهُمْ","translation":"এবং তাদের (বিভ্রান্ত) ভাইয়েরা","audioUrl":"wbw/007_202_001.mp3","charTypeName":"word"},{"id":85377,"position":2,"arabic":"يَمُدُّونَهُمْ","translation":"টেনে নেয় তাদেরকে","audioUrl":"wbw/007_202_002.mp3","charTypeName":"word"},{"id":85378,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/007_202_003.mp3","charTypeName":"word"},{"id":85379,"position":4,"arabic":"ٱلْغَىِّ","translation":"ভ্রান্তির","audioUrl":"wbw/007_202_004.mp3","charTypeName":"word"},{"id":85380,"position":5,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/007_202_005.mp3","charTypeName":"word"},{"id":85381,"position":6,"arabic":"لَا","translation":"না","audioUrl":"wbw/007_202_006.mp3","charTypeName":"word"},{"id":85382,"position":7,"arabic":"يُقْصِرُونَ","translation":"তারা ত্রুটি করে (বিভ্রান্তিতে রাখতে)","audioUrl":"wbw/007_202_007.mp3","charTypeName":"word"},{"id":85383,"position":8,"arabic":"٢٠٢","translation":"(২০২)","audioUrl":null,"charTypeName":"end"}]},{"number":203,"arabic":"وَإِذَا لَمْ تَأْتِهِم بِـَٔايَةٍۢ قَالُوا۟ لَوْلَا ٱجْتَبَيْتَهَا ۚ قُلْ إِنَّمَآ أَتَّبِعُ مَا يُوحَىٰٓ إِلَىَّ مِن رَّبِّى ۚ هَٰذَا بَصَآئِرُ مِن رَّبِّكُمْ وَهُدًۭى وَرَحْمَةٌۭ لِّقَوْمٍۢ يُؤْمِنُونَ","translation":"And yet, when thou [O Prophet] dost not produce any miracle for them, some [people] say, \"Why dost thou not seek to obtain it [from God]? Say: \"I only follow whatever is being revealed to me by my Sustainer: this [revelation] is a means of insight from your Sustainer, and a guidance and grace unto people who will believe.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1157.mp3","surahId":7,"words":[{"id":85414,"position":1,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/007_203_001.mp3","charTypeName":"word"},{"id":85415,"position":2,"arabic":"لَمْ","translation":"না","audioUrl":"wbw/007_203_002.mp3","charTypeName":"word"},{"id":85416,"position":3,"arabic":"تَأْتِهِم","translation":"তাদের কাছে আসো তুমি","audioUrl":"wbw/007_203_003.mp3","charTypeName":"word"},{"id":85417,"position":4,"arabic":"بِـَٔايَةٍۢ","translation":"কোনো নিদর্শন","audioUrl":"wbw/007_203_004.mp3","charTypeName":"word"},{"id":85418,"position":5,"arabic":"قَالُوا۟","translation":"তারা বলে","audioUrl":"wbw/007_203_005.mp3","charTypeName":"word"},{"id":85419,"position":6,"arabic":"لَوْلَا","translation":"\"কেন না","audioUrl":"wbw/007_203_006.mp3","charTypeName":"word"},{"id":85420,"position":7,"arabic":"ٱجْتَبَيْتَهَا ۚ","translation":"তুমি বেছে নিলে তা\"","audioUrl":"wbw/007_203_007.mp3","charTypeName":"word"},{"id":85422,"position":8,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/007_203_009.mp3","charTypeName":"word"},{"id":85423,"position":9,"arabic":"إِنَّمَآ","translation":"\"প্রকৃত পক্ষে","audioUrl":"wbw/007_203_010.mp3","charTypeName":"word"},{"id":85424,"position":10,"arabic":"أَتَّبِعُ","translation":"অনুসরণ করি আমি","audioUrl":"wbw/007_203_011.mp3","charTypeName":"word"},{"id":85425,"position":11,"arabic":"مَا","translation":"যা","audioUrl":"wbw/007_203_012.mp3","charTypeName":"word"},{"id":85426,"position":12,"arabic":"يُوحَىٰٓ","translation":"ওহী করা হয়","audioUrl":"wbw/007_203_013.mp3","charTypeName":"word"},{"id":85427,"position":13,"arabic":"إِلَىَّ","translation":"প্রতি আমার","audioUrl":"wbw/007_203_014.mp3","charTypeName":"word"},{"id":85428,"position":14,"arabic":"مِن","translation":"পক্ষ হতে","audioUrl":"wbw/007_203_015.mp3","charTypeName":"word"},{"id":85429,"position":15,"arabic":"رَّبِّى ۚ","translation":"আমার রবের","audioUrl":"wbw/007_203_016.mp3","charTypeName":"word"},{"id":85431,"position":16,"arabic":"هَـٰذَا","translation":"এটা","audioUrl":"wbw/007_203_018.mp3","charTypeName":"word"},{"id":85432,"position":17,"arabic":"بَصَآئِرُ","translation":"জ্ঞানালোক","audioUrl":"wbw/007_203_019.mp3","charTypeName":"word"},{"id":85433,"position":18,"arabic":"مِن","translation":"পক্ষ হতে","audioUrl":"wbw/007_203_020.mp3","charTypeName":"word"},{"id":85434,"position":19,"arabic":"رَّبِّكُمْ","translation":"তোমার রবের","audioUrl":"wbw/007_203_021.mp3","charTypeName":"word"},{"id":85435,"position":20,"arabic":"وَهُدًۭى","translation":"এবং পথনির্দেশ","audioUrl":"wbw/007_203_022.mp3","charTypeName":"word"},{"id":85436,"position":21,"arabic":"وَرَحْمَةٌۭ","translation":"এবং দয়া","audioUrl":"wbw/007_203_023.mp3","charTypeName":"word"},{"id":85437,"position":22,"arabic":"لِّقَوْمٍۢ","translation":"জন্যে ঐ সম্প্রদায়ের","audioUrl":"wbw/007_203_024.mp3","charTypeName":"word"},{"id":85438,"position":23,"arabic":"يُؤْمِنُونَ","translation":"(যারা) ঈমান আনে\"","audioUrl":"wbw/007_203_025.mp3","charTypeName":"word"},{"id":85439,"position":24,"arabic":"٢٠٣","translation":"(২০৩)","audioUrl":null,"charTypeName":"end"}]},{"number":204,"arabic":"وَإِذَا قُرِئَ ٱلْقُرْءَانُ فَٱسْتَمِعُوا۟ لَهُۥ وَأَنصِتُوا۟ لَعَلَّكُمْ تُرْحَمُونَ","translation":"Hence, when the Qur'an is voiced, hearken unto it, and listen in silence, so that you might be graced with [God's] mercy.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1158.mp3","surahId":7,"words":[{"id":85466,"position":1,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/007_204_001.mp3","charTypeName":"word"},{"id":85467,"position":2,"arabic":"قُرِئَ","translation":"তিলাওয়াত করা হয়","audioUrl":"wbw/007_204_002.mp3","charTypeName":"word"},{"id":85468,"position":3,"arabic":"ٱلْقُرْءَانُ","translation":"কুরআন","audioUrl":"wbw/007_204_003.mp3","charTypeName":"word"},{"id":85469,"position":4,"arabic":"فَٱسْتَمِعُوا۟","translation":"তখন তোমরা মনোযোগ দিয়ে শুনো","audioUrl":"wbw/007_204_004.mp3","charTypeName":"word"},{"id":85470,"position":5,"arabic":"لَهُۥ","translation":"প্রতি তার","audioUrl":"wbw/007_204_005.mp3","charTypeName":"word"},{"id":85471,"position":6,"arabic":"وَأَنصِتُوا۟","translation":"এবং তোমরা চুপ থাকো","audioUrl":"wbw/007_204_006.mp3","charTypeName":"word"},{"id":85472,"position":7,"arabic":"لَعَلَّكُمْ","translation":"যাতে তোমরা","audioUrl":"wbw/007_204_007.mp3","charTypeName":"word"},{"id":85473,"position":8,"arabic":"تُرْحَمُونَ","translation":"দয়াপ্রাপ্ত হও","audioUrl":"wbw/007_204_008.mp3","charTypeName":"word"},{"id":85474,"position":9,"arabic":"٢٠٤","translation":"(২০৪)","audioUrl":null,"charTypeName":"end"}]},{"number":205,"arabic":"وَٱذْكُر رَّبَّكَ فِى نَفْسِكَ تَضَرُّعًۭا وَخِيفَةًۭ وَدُونَ ٱلْجَهْرِ مِنَ ٱلْقَوْلِ بِٱلْغُدُوِّ وَٱلْءَاصَالِ وَلَا تَكُن مِّنَ ٱلْغَٰفِلِينَ","translation":"And bethink thyself of thy Sustainer humbly and with awe, and without raising thy voice, at morn and at evening; and do not allow thyself to be heedless.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1159.mp3","surahId":7,"words":[{"id":85496,"position":1,"arabic":"وَٱذْكُر","translation":"এবং স্মরণ করো","audioUrl":"wbw/007_205_001.mp3","charTypeName":"word"},{"id":85497,"position":2,"arabic":"رَّبَّكَ","translation":"তোমার রবকে","audioUrl":"wbw/007_205_002.mp3","charTypeName":"word"},{"id":85498,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/007_205_003.mp3","charTypeName":"word"},{"id":85499,"position":4,"arabic":"نَفْسِكَ","translation":"তোমার মনের","audioUrl":"wbw/007_205_004.mp3","charTypeName":"word"},{"id":85500,"position":5,"arabic":"تَضَرُّعًۭا","translation":"সবিনয়ে","audioUrl":"wbw/007_205_005.mp3","charTypeName":"word"},{"id":85501,"position":6,"arabic":"وَخِيفَةًۭ","translation":"ও ভয়ে","audioUrl":"wbw/007_205_006.mp3","charTypeName":"word"},{"id":85502,"position":7,"arabic":"وَدُونَ","translation":"এবং ছাড়া","audioUrl":"wbw/007_205_007.mp3","charTypeName":"word"},{"id":85503,"position":8,"arabic":"ٱلْجَهْرِ","translation":"উচ্চস্বর (অর্থাৎ নিরবে স্মরণ করো)","audioUrl":"wbw/007_205_008.mp3","charTypeName":"word"},{"id":85504,"position":9,"arabic":"مِنَ","translation":"মাধ্যমে","audioUrl":"wbw/007_205_009.mp3","charTypeName":"word"},{"id":85505,"position":10,"arabic":"ٱلْقَوْلِ","translation":"কথার","audioUrl":"wbw/007_205_010.mp3","charTypeName":"word"},{"id":85506,"position":11,"arabic":"بِٱلْغُدُوِّ","translation":"বেলায় সকাল","audioUrl":"wbw/007_205_011.mp3","charTypeName":"word"},{"id":85507,"position":12,"arabic":"وَٱلْـَٔاصَالِ","translation":"ও সন্ধ্যায়","audioUrl":"wbw/007_205_012.mp3","charTypeName":"word"},{"id":85508,"position":13,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/007_205_013.mp3","charTypeName":"word"},{"id":85509,"position":14,"arabic":"تَكُن","translation":"হয়ো","audioUrl":"wbw/007_205_014.mp3","charTypeName":"word"},{"id":85510,"position":15,"arabic":"مِّنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/007_205_015.mp3","charTypeName":"word"},{"id":85511,"position":16,"arabic":"ٱلْغَـٰفِلِينَ","translation":"উদাসীনদের","audioUrl":"wbw/007_205_016.mp3","charTypeName":"word"},{"id":85512,"position":17,"arabic":"٢٠٥","translation":"(২০৫)","audioUrl":null,"charTypeName":"end"}]},{"number":206,"arabic":"إِنَّ ٱلَّذِينَ عِندَ رَبِّكَ لَا يَسْتَكْبِرُونَ عَنْ عِبَادَتِهِۦ وَيُسَبِّحُونَهُۥ وَلَهُۥ يَسْجُدُونَ ۩","translation":"Behold, those who are near unto thy Sustainer are never too proud to worship Him; and they extol His limitless glory, and prostrate themselves before Him [alone].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1160.mp3","surahId":7,"words":[{"id":85534,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/007_206_001.mp3","charTypeName":"word"},{"id":85535,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা (অর্থাৎ ফেরেশতারা)","audioUrl":"wbw/007_206_002.mp3","charTypeName":"word"},{"id":85536,"position":3,"arabic":"عِندَ","translation":"নিকটে (রয়েছে)","audioUrl":"wbw/007_206_003.mp3","charTypeName":"word"},{"id":85537,"position":4,"arabic":"رَبِّكَ","translation":"তোমার রবের","audioUrl":"wbw/007_206_004.mp3","charTypeName":"word"},{"id":85538,"position":5,"arabic":"لَا","translation":"না","audioUrl":"wbw/007_206_005.mp3","charTypeName":"word"},{"id":85539,"position":6,"arabic":"يَسْتَكْبِرُونَ","translation":"তারা অহংকার করে","audioUrl":"wbw/007_206_006.mp3","charTypeName":"word"},{"id":85540,"position":7,"arabic":"عَنْ","translation":"ব্যাপারে","audioUrl":"wbw/007_206_007.mp3","charTypeName":"word"},{"id":85541,"position":8,"arabic":"عِبَادَتِهِۦ","translation":"ইবাদতের তাঁর","audioUrl":"wbw/007_206_008.mp3","charTypeName":"word"},{"id":85542,"position":9,"arabic":"وَيُسَبِّحُونَهُۥ","translation":"ও মহিমা ঘোষণা করে তাঁর","audioUrl":"wbw/007_206_009.mp3","charTypeName":"word"},{"id":85543,"position":10,"arabic":"وَلَهُۥ","translation":"এবং জন্যে তাঁর","audioUrl":"wbw/007_206_010.mp3","charTypeName":"word"},{"id":85544,"position":11,"arabic":"يَسْجُدُونَ ۩","translation":"তারা সিজদা করে","audioUrl":"wbw/007_206_011.mp3","charTypeName":"word"},{"id":85546,"position":12,"arabic":"٢٠٦","translation":"(২০৬)","audioUrl":null,"charTypeName":"end"}]}]}