{"id":241,"ayahs":[{"number":44,"arabic":"قَالُوٓا۟ أَضْغَٰثُ أَحْلَٰمٍۢ ۖ وَمَا نَحْنُ بِتَأْوِيلِ ٱلْأَحْلَٰمِ بِعَٰلِمِينَ","translation":"They answered: \" [This is one of] the most involved and confusing of dreams, and we have no deep knowledge of the real meaning of dreams.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1640.mp3","surahId":12,"words":[{"id":44672,"position":1,"arabic":"قَالُوٓا۟","translation":"তারা বলেছিলো","audioUrl":"wbw/012_044_001.mp3","charTypeName":"word"},{"id":44673,"position":2,"arabic":"أَضْغَـٰثُ","translation":"\"অর্থহীন","audioUrl":"wbw/012_044_002.mp3","charTypeName":"word"},{"id":44674,"position":3,"arabic":"أَحْلَـٰمٍۢ ۖ","translation":"স্বপ্ন","audioUrl":"wbw/012_044_003.mp3","charTypeName":"word"},{"id":44676,"position":4,"arabic":"وَمَا","translation":"এবং নই","audioUrl":"wbw/012_044_005.mp3","charTypeName":"word"},{"id":44677,"position":5,"arabic":"نَحْنُ","translation":"আমরা","audioUrl":"wbw/012_044_006.mp3","charTypeName":"word"},{"id":44678,"position":6,"arabic":"بِتَأْوِيلِ","translation":"সম্বন্ধে ব্যাখ্যা","audioUrl":"wbw/012_044_007.mp3","charTypeName":"word"},{"id":44679,"position":7,"arabic":"ٱلْأَحْلَـٰمِ","translation":"স্বপ্নের","audioUrl":"wbw/012_044_008.mp3","charTypeName":"word"},{"id":44680,"position":8,"arabic":"بِعَـٰلِمِينَ","translation":"অভিজ্ঞ\"","audioUrl":"wbw/012_044_009.mp3","charTypeName":"word"},{"id":44681,"position":9,"arabic":"٤٤","translation":"(৪৪)","audioUrl":null,"charTypeName":"end"}]},{"number":45,"arabic":"وَقَالَ ٱلَّذِى نَجَا مِنْهُمَا وَٱدَّكَرَ بَعْدَ أُمَّةٍ أَنَا۠ أُنَبِّئُكُم بِتَأْوِيلِهِۦ فَأَرْسِلُونِ","translation":"At that, the one of the two [erstwhile prisoners] who had been saved, and [who suddenly] remembered [Joseph] after all that time, spoke [thus]: \"It is I who can inform you of the real meaning of this [dream]; so let me go [in search of it].\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1641.mp3","surahId":12,"words":[{"id":45354,"position":1,"arabic":"وَقَالَ","translation":"এবং বললো","audioUrl":"wbw/012_045_001.mp3","charTypeName":"word"},{"id":45355,"position":2,"arabic":"ٱلَّذِى","translation":"যে","audioUrl":"wbw/012_045_002.mp3","charTypeName":"word"},{"id":45356,"position":3,"arabic":"نَجَا","translation":"মুক্তি পেয়েছিলো","audioUrl":"wbw/012_045_003.mp3","charTypeName":"word"},{"id":45357,"position":4,"arabic":"مِنْهُمَا","translation":"তাদের দু'জনের মধ্য হ'তে","audioUrl":"wbw/012_045_004.mp3","charTypeName":"word"},{"id":45358,"position":5,"arabic":"وَٱدَّكَرَ","translation":"এবং স্মরণ হলো (ইউসুফের কথা)","audioUrl":"wbw/012_045_005.mp3","charTypeName":"word"},{"id":45359,"position":6,"arabic":"بَعْدَ","translation":"পরে","audioUrl":"wbw/012_045_006.mp3","charTypeName":"word"},{"id":45360,"position":7,"arabic":"أُمَّةٍ","translation":"দীর্ঘকাল","audioUrl":"wbw/012_045_007.mp3","charTypeName":"word"},{"id":45361,"position":8,"arabic":"أَنَا۠","translation":"\"(সে বললো) আমি","audioUrl":"wbw/012_045_008.mp3","charTypeName":"word"},{"id":45362,"position":9,"arabic":"أُنَبِّئُكُم","translation":"তোমাদেরকে জানাবো","audioUrl":"wbw/012_045_009.mp3","charTypeName":"word"},{"id":45363,"position":10,"arabic":"بِتَأْوِيلِهِۦ","translation":"সম্বন্ধে তার ব্যখ্যা","audioUrl":"wbw/012_045_010.mp3","charTypeName":"word"},{"id":45364,"position":11,"arabic":"فَأَرْسِلُونِ","translation":"অতএব আমাকে তোমরা পাঠাও (কারাগারে)","audioUrl":"wbw/012_045_011.mp3","charTypeName":"word"},{"id":45365,"position":12,"arabic":"٤٥","translation":"(৪৫)","audioUrl":null,"charTypeName":"end"}]},{"number":46,"arabic":"يُوسُفُ أَيُّهَا ٱلصِّدِّيقُ أَفْتِنَا فِى سَبْعِ بَقَرَٰتٍۢ سِمَانٍۢ يَأْكُلُهُنَّ سَبْعٌ عِجَافٌۭ وَسَبْعِ سُنۢبُلَٰتٍ خُضْرٍۢ وَأُخَرَ يَابِسَٰتٍۢ لَّعَلِّىٓ أَرْجِعُ إِلَى ٱلنَّاسِ لَعَلَّهُمْ يَعْلَمُونَ","translation":"[And he went to see Joseph in the prison and said to him:] \"Joseph, O thou truthful one! Enlighten us about [the meaning of a dream in which] seven fat cows were being devoured by seven emaciated ones, and seven green ears [of wheat appeared] next to [seven] others that were withered - so that I may return [with thy explanation] unto the people [of the court, and] that they may come to know [what manner of man thou art]!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1642.mp3","surahId":12,"words":[{"id":46095,"position":1,"arabic":"يُوسُفُ","translation":"(সেখানে পৌঁছে বললো) ইউসুফ","audioUrl":"wbw/012_046_001.mp3","charTypeName":"word"},{"id":46096,"position":2,"arabic":"أَيُّهَا","translation":"হে","audioUrl":"wbw/012_046_002.mp3","charTypeName":"word"},{"id":46097,"position":3,"arabic":"ٱلصِّدِّيقُ","translation":"সত্যবাদী","audioUrl":"wbw/012_046_003.mp3","charTypeName":"word"},{"id":46098,"position":4,"arabic":"أَفْتِنَا","translation":"আমাদের অভিমত দাও","audioUrl":"wbw/012_046_004.mp3","charTypeName":"word"},{"id":46099,"position":5,"arabic":"فِى","translation":"(স্বপ্নের) ব্যাপারে","audioUrl":"wbw/012_046_005.mp3","charTypeName":"word"},{"id":46100,"position":6,"arabic":"سَبْعِ","translation":"(এমন যে) সাতটি","audioUrl":"wbw/012_046_006.mp3","charTypeName":"word"},{"id":46101,"position":7,"arabic":"بَقَرَٰتٍۢ","translation":"গাভী","audioUrl":"wbw/012_046_007.mp3","charTypeName":"word"},{"id":46102,"position":8,"arabic":"سِمَانٍۢ","translation":"মোটাসোটা","audioUrl":"wbw/012_046_008.mp3","charTypeName":"word"},{"id":46103,"position":9,"arabic":"يَأْكُلُهُنَّ","translation":"তাদের খাচ্ছে","audioUrl":"wbw/012_046_009.mp3","charTypeName":"word"},{"id":46104,"position":10,"arabic":"سَبْعٌ","translation":"সাতটি (গাভী)","audioUrl":"wbw/012_046_010.mp3","charTypeName":"word"},{"id":46105,"position":11,"arabic":"عِجَافٌۭ","translation":"শুঁটকো","audioUrl":"wbw/012_046_011.mp3","charTypeName":"word"},{"id":46106,"position":12,"arabic":"وَسَبْعِ","translation":"এবং সাতটি","audioUrl":"wbw/012_046_012.mp3","charTypeName":"word"},{"id":46107,"position":13,"arabic":"سُنۢبُلَـٰتٍ","translation":"শীষ","audioUrl":"wbw/012_046_013.mp3","charTypeName":"word"},{"id":46108,"position":14,"arabic":"خُضْرٍۢ","translation":"সবুজ সতেজ","audioUrl":"wbw/012_046_014.mp3","charTypeName":"word"},{"id":46109,"position":15,"arabic":"وَأُخَرَ","translation":"এবং অন্য","audioUrl":"wbw/012_046_015.mp3","charTypeName":"word"},{"id":46110,"position":16,"arabic":"يَابِسَـٰتٍۢ","translation":"(সাতটি) শুকনো","audioUrl":"wbw/012_046_016.mp3","charTypeName":"word"},{"id":46111,"position":17,"arabic":"لَّعَلِّىٓ","translation":"আমি যাতে","audioUrl":"wbw/012_046_017.mp3","charTypeName":"word"},{"id":46112,"position":18,"arabic":"أَرْجِعُ","translation":"ফিরে যাই","audioUrl":"wbw/012_046_018.mp3","charTypeName":"word"},{"id":46113,"position":19,"arabic":"إِلَى","translation":"কাছে","audioUrl":"wbw/012_046_019.mp3","charTypeName":"word"},{"id":46114,"position":20,"arabic":"ٱلنَّاسِ","translation":"লোকদের","audioUrl":"wbw/012_046_020.mp3","charTypeName":"word"},{"id":46115,"position":21,"arabic":"لَعَلَّهُمْ","translation":"তারা যাতে","audioUrl":"wbw/012_046_021.mp3","charTypeName":"word"},{"id":46116,"position":22,"arabic":"يَعْلَمُونَ","translation":"জানতে পারে (এর ব্যাখা)\"","audioUrl":"wbw/012_046_022.mp3","charTypeName":"word"},{"id":46117,"position":23,"arabic":"٤٦","translation":"(৪৬)","audioUrl":null,"charTypeName":"end"}]},{"number":47,"arabic":"قَالَ تَزْرَعُونَ سَبْعَ سِنِينَ دَأَبًۭا فَمَا حَصَدتُّمْ فَذَرُوهُ فِى سُنۢبُلِهِۦٓ إِلَّا قَلِيلًۭا مِّمَّا تَأْكُلُونَ","translation":"[Joseph] replied: \"You shall sow for seven years as usual; but let all [the grain] that you harvest remain [untouched] in its ear, excepting only a little, whereof you may eat:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1643.mp3","surahId":12,"words":[{"id":46705,"position":1,"arabic":"قَالَ","translation":"(ইউসুফ) বললো","audioUrl":"wbw/012_047_001.mp3","charTypeName":"word"},{"id":46706,"position":2,"arabic":"تَزْرَعُونَ","translation":"\"তোমরা চাষ করবে","audioUrl":"wbw/012_047_002.mp3","charTypeName":"word"},{"id":46707,"position":3,"arabic":"سَبْعَ","translation":"সাত","audioUrl":"wbw/012_047_003.mp3","charTypeName":"word"},{"id":46708,"position":4,"arabic":"سِنِينَ","translation":"বছর","audioUrl":"wbw/012_047_004.mp3","charTypeName":"word"},{"id":46709,"position":5,"arabic":"دَأَبًۭا","translation":"একটানা","audioUrl":"wbw/012_047_005.mp3","charTypeName":"word"},{"id":46710,"position":6,"arabic":"فَمَا","translation":"অতঃপর যা","audioUrl":"wbw/012_047_006.mp3","charTypeName":"word"},{"id":46711,"position":7,"arabic":"حَصَدتُّمْ","translation":"তোমরা ফসল কাটবে","audioUrl":"wbw/012_047_007.mp3","charTypeName":"word"},{"id":46712,"position":8,"arabic":"فَذَرُوهُ","translation":"তখন তা তোমরা রেখে দিবে","audioUrl":"wbw/012_047_008.mp3","charTypeName":"word"},{"id":46713,"position":9,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/012_047_009.mp3","charTypeName":"word"},{"id":46714,"position":10,"arabic":"سُنۢبُلِهِۦٓ","translation":"এর শীষগুলোর","audioUrl":"wbw/012_047_010.mp3","charTypeName":"word"},{"id":46715,"position":11,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/012_047_011.mp3","charTypeName":"word"},{"id":46716,"position":12,"arabic":"قَلِيلًۭا","translation":"সামান্য (পরিমাণ)","audioUrl":"wbw/012_047_012.mp3","charTypeName":"word"},{"id":46717,"position":13,"arabic":"مِّمَّا","translation":"তা হ'তে যা","audioUrl":"wbw/012_047_013.mp3","charTypeName":"word"},{"id":46718,"position":14,"arabic":"تَأْكُلُونَ","translation":"তোমরা খাবে","audioUrl":"wbw/012_047_014.mp3","charTypeName":"word"},{"id":46719,"position":15,"arabic":"٤٧","translation":"(৪৭)","audioUrl":null,"charTypeName":"end"}]},{"number":48,"arabic":"ثُمَّ يَأْتِى مِنۢ بَعْدِ ذَٰلِكَ سَبْعٌۭ شِدَادٌۭ يَأْكُلْنَ مَا قَدَّمْتُمْ لَهُنَّ إِلَّا قَلِيلًۭا مِّمَّا تُحْصِنُونَ","translation":"for, after that [period of seven good years] there will come seven hard [years] which will devour all that you shall have laid up for them, excepting only a little of that which you shall have kept in store.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1644.mp3","surahId":12,"words":[{"id":47232,"position":1,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/012_048_001.mp3","charTypeName":"word"},{"id":47233,"position":2,"arabic":"يَأْتِى","translation":"আসবে","audioUrl":"wbw/012_048_002.mp3","charTypeName":"word"},{"id":47234,"position":3,"arabic":"مِنۢ","translation":"থেকে","audioUrl":"wbw/012_048_003.mp3","charTypeName":"word"},{"id":47235,"position":4,"arabic":"بَعْدِ","translation":"পর","audioUrl":"wbw/012_048_004.mp3","charTypeName":"word"},{"id":47236,"position":5,"arabic":"ذَٰلِكَ","translation":"এর","audioUrl":"wbw/012_048_005.mp3","charTypeName":"word"},{"id":47237,"position":6,"arabic":"سَبْعٌۭ","translation":"সাত (বছর)","audioUrl":"wbw/012_048_006.mp3","charTypeName":"word"},{"id":47238,"position":7,"arabic":"شِدَادٌۭ","translation":"কঠিন (দুর্ভিক্ষের)","audioUrl":"wbw/012_048_007.mp3","charTypeName":"word"},{"id":47239,"position":8,"arabic":"يَأْكُلْنَ","translation":"(যখন) তারা খাবে","audioUrl":"wbw/012_048_008.mp3","charTypeName":"word"},{"id":47240,"position":9,"arabic":"مَا","translation":"যা","audioUrl":"wbw/012_048_009.mp3","charTypeName":"word"},{"id":47241,"position":10,"arabic":"قَدَّمْتُمْ","translation":"তোমরা জমিয়ে রেখেছো","audioUrl":"wbw/012_048_010.mp3","charTypeName":"word"},{"id":47242,"position":11,"arabic":"لَهُنَّ","translation":"তাদের জন্যে","audioUrl":"wbw/012_048_011.mp3","charTypeName":"word"},{"id":47243,"position":12,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/012_048_012.mp3","charTypeName":"word"},{"id":47244,"position":13,"arabic":"قَلِيلًۭا","translation":"সামান্য (পরিমাণ)","audioUrl":"wbw/012_048_013.mp3","charTypeName":"word"},{"id":47245,"position":14,"arabic":"مِّمَّا","translation":"তা হ'তে যা","audioUrl":"wbw/012_048_014.mp3","charTypeName":"word"},{"id":47246,"position":15,"arabic":"تُحْصِنُونَ","translation":"তোমরা বাঁচিয়ে রাখবে","audioUrl":"wbw/012_048_015.mp3","charTypeName":"word"},{"id":47247,"position":16,"arabic":"٤٨","translation":"(৪৮)","audioUrl":null,"charTypeName":"end"}]},{"number":49,"arabic":"ثُمَّ يَأْتِى مِنۢ بَعْدِ ذَٰلِكَ عَامٌۭ فِيهِ يُغَاثُ ٱلنَّاسُ وَفِيهِ يَعْصِرُونَ","translation":"And after that there will come a year in which the people will be delivered from all distress, and in which they will press [oil and wine as before].\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1645.mp3","surahId":12,"words":[{"id":48199,"position":1,"arabic":"ثُمَّ","translation":"তারপর","audioUrl":"wbw/012_049_001.mp3","charTypeName":"word"},{"id":48200,"position":2,"arabic":"يَأْتِى","translation":"আসবে","audioUrl":"wbw/012_049_002.mp3","charTypeName":"word"},{"id":48201,"position":3,"arabic":"مِنۢ","translation":"থেকে","audioUrl":"wbw/012_049_003.mp3","charTypeName":"word"},{"id":48202,"position":4,"arabic":"بَعْدِ","translation":"পর","audioUrl":"wbw/012_049_004.mp3","charTypeName":"word"},{"id":48203,"position":5,"arabic":"ذَٰلِكَ","translation":"এর","audioUrl":"wbw/012_049_005.mp3","charTypeName":"word"},{"id":48204,"position":6,"arabic":"عَامٌۭ","translation":"এক বছর","audioUrl":"wbw/012_049_006.mp3","charTypeName":"word"},{"id":48205,"position":7,"arabic":"فِيهِ","translation":"তার মধ্যে","audioUrl":"wbw/012_049_007.mp3","charTypeName":"word"},{"id":48206,"position":8,"arabic":"يُغَاثُ","translation":"প্রচুর বৃষ্টি হবে","audioUrl":"wbw/012_049_008.mp3","charTypeName":"word"},{"id":48207,"position":9,"arabic":"ٱلنَّاسُ","translation":"মানুষের জন্যে","audioUrl":"wbw/012_049_009.mp3","charTypeName":"word"},{"id":48208,"position":10,"arabic":"وَفِيهِ","translation":"এবং তার মধ্যে","audioUrl":"wbw/012_049_010.mp3","charTypeName":"word"},{"id":48209,"position":11,"arabic":"يَعْصِرُونَ","translation":"তারা ফলের রস নিংড়াবে\"","audioUrl":"wbw/012_049_011.mp3","charTypeName":"word"},{"id":48210,"position":12,"arabic":"٤٩","translation":"(৪৯)","audioUrl":null,"charTypeName":"end"}]},{"number":50,"arabic":"وَقَالَ ٱلْمَلِكُ ٱئْتُونِى بِهِۦ ۖ فَلَمَّا جَآءَهُ ٱلرَّسُولُ قَالَ ٱرْجِعْ إِلَىٰ رَبِّكَ فَسْـَٔلْهُ مَا بَالُ ٱلنِّسْوَةِ ٱلَّٰتِى قَطَّعْنَ أَيْدِيَهُنَّ ۚ إِنَّ رَبِّى بِكَيْدِهِنَّ عَلِيمٌۭ","translation":"And [as soon as Joseph's interpretation. was conveyed to him,] the King said: \"Bring him before me!\" But when the [King's] messenger came unto him, [Joseph] said: \"Go back to thy lord and ask him [first to find out the truth] about those women who cut their hands-for, behold, [until now it is] my Sustainer [alone who] has full knowledge of their guile!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1646.mp3","surahId":12,"words":[{"id":48860,"position":1,"arabic":"وَقَالَ","translation":"এবং (এসব শুনে) বললো","audioUrl":"wbw/012_050_001.mp3","charTypeName":"word"},{"id":48861,"position":2,"arabic":"ٱلْمَلِكُ","translation":"রাজা","audioUrl":"wbw/012_050_002.mp3","charTypeName":"word"},{"id":48862,"position":3,"arabic":"ٱئْتُونِى","translation":"\"আমার কাছে আসো\"","audioUrl":"wbw/012_050_003.mp3","charTypeName":"word"},{"id":48863,"position":4,"arabic":"بِهِۦ ۖ","translation":"\"নিয়ে তাকে\"","audioUrl":"wbw/012_050_004.mp3","charTypeName":"word"},{"id":48865,"position":5,"arabic":"فَلَمَّا","translation":"অতঃপর যখন","audioUrl":"wbw/012_050_006.mp3","charTypeName":"word"},{"id":48866,"position":6,"arabic":"جَآءَهُ","translation":"তার কাছে আসলো","audioUrl":"wbw/012_050_007.mp3","charTypeName":"word"},{"id":48867,"position":7,"arabic":"ٱلرَّسُولُ","translation":"দূত","audioUrl":"wbw/012_050_008.mp3","charTypeName":"word"},{"id":48868,"position":8,"arabic":"قَالَ","translation":"(ইউসুফ) বললো","audioUrl":"wbw/012_050_009.mp3","charTypeName":"word"},{"id":48869,"position":9,"arabic":"ٱرْجِعْ","translation":"\"তুমি ফিরে যাও","audioUrl":"wbw/012_050_010.mp3","charTypeName":"word"},{"id":48870,"position":10,"arabic":"إِلَىٰ","translation":"কাছে","audioUrl":"wbw/012_050_011.mp3","charTypeName":"word"},{"id":48871,"position":11,"arabic":"رَبِّكَ","translation":"তোমার প্রভুর","audioUrl":"wbw/012_050_012.mp3","charTypeName":"word"},{"id":48872,"position":12,"arabic":"فَسْـَٔلْهُ","translation":"অতঃপর তাকে জিজ্ঞেস করো","audioUrl":"wbw/012_050_013.mp3","charTypeName":"word"},{"id":48873,"position":13,"arabic":"مَا","translation":"কি (ছিলো)","audioUrl":"wbw/012_050_014.mp3","charTypeName":"word"},{"id":48874,"position":14,"arabic":"بَالُ","translation":"অবস্থা","audioUrl":"wbw/012_050_015.mp3","charTypeName":"word"},{"id":48875,"position":15,"arabic":"ٱلنِّسْوَةِ","translation":"মহিলাদের","audioUrl":"wbw/012_050_016.mp3","charTypeName":"word"},{"id":48876,"position":16,"arabic":"ٱلَّـٰتِى","translation":"যারা","audioUrl":"wbw/012_050_017.mp3","charTypeName":"word"},{"id":48877,"position":17,"arabic":"قَطَّعْنَ","translation":"কেটে ফেলেছিলো","audioUrl":"wbw/012_050_018.mp3","charTypeName":"word"},{"id":48878,"position":18,"arabic":"أَيْدِيَهُنَّ ۚ","translation":"তাদের হাতগুলো","audioUrl":"wbw/012_050_019.mp3","charTypeName":"word"},{"id":48880,"position":19,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/012_050_021.mp3","charTypeName":"word"},{"id":48881,"position":20,"arabic":"رَبِّى","translation":"আমার রব","audioUrl":"wbw/012_050_022.mp3","charTypeName":"word"},{"id":48882,"position":21,"arabic":"بِكَيْدِهِنَّ","translation":"সম্বন্ধে তাদের ছলনা","audioUrl":"wbw/012_050_023.mp3","charTypeName":"word"},{"id":48883,"position":22,"arabic":"عَلِيمٌۭ","translation":"খুব অবহিত\"","audioUrl":"wbw/012_050_024.mp3","charTypeName":"word"},{"id":48884,"position":23,"arabic":"٥٠","translation":"(৫০)","audioUrl":null,"charTypeName":"end"}]},{"number":51,"arabic":"قَالَ مَا خَطْبُكُنَّ إِذْ رَٰوَدتُّنَّ يُوسُفَ عَن نَّفْسِهِۦ ۚ قُلْنَ حَٰشَ لِلَّهِ مَا عَلِمْنَا عَلَيْهِ مِن سُوٓءٍۢ ۚ قَالَتِ ٱمْرَأَتُ ٱلْعَزِيزِ ٱلْـَٰٔنَ حَصْحَصَ ٱلْحَقُّ أَنَا۠ رَٰوَدتُّهُۥ عَن نَّفْسِهِۦ وَإِنَّهُۥ لَمِنَ ٱلصَّٰدِقِينَ","translation":"[Thereupon the King sent for those women; and when they came,] he asked: \"What was it that you hoped to achieve when you sought to make Joseph yield himself unto you?\" The women answered: \"God save us! We did not perceive the least evil [intention] on his part!\" [And] the wife of Joseph's former master exclaimed: \"Now has the truth come to light! It was I who sought to make him yield himself unto me - whereas he, behold, was indeed speaking the truth!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1647.mp3","surahId":12,"words":[{"id":49379,"position":1,"arabic":"قَالَ","translation":"(বাদশাহ) বললো","audioUrl":"wbw/012_051_001.mp3","charTypeName":"word"},{"id":49380,"position":2,"arabic":"مَا","translation":"\"কি (ছিলো)","audioUrl":"wbw/012_051_002.mp3","charTypeName":"word"},{"id":49381,"position":3,"arabic":"خَطْبُكُنَّ","translation":"হয়েছিলো তোমাদের","audioUrl":"wbw/012_051_003.mp3","charTypeName":"word"},{"id":49382,"position":4,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/012_051_004.mp3","charTypeName":"word"},{"id":49383,"position":5,"arabic":"رَٰوَدتُّنَّ","translation":"তোমরা ফুসলিয়েছিলে","audioUrl":"wbw/012_051_005.mp3","charTypeName":"word"},{"id":49384,"position":6,"arabic":"يُوسُفَ","translation":"ইউসুফকে","audioUrl":"wbw/012_051_006.mp3","charTypeName":"word"},{"id":49385,"position":7,"arabic":"عَن","translation":"হ'তে","audioUrl":"wbw/012_051_007.mp3","charTypeName":"word"},{"id":49386,"position":8,"arabic":"نَّفْسِهِۦ ۚ","translation":"তার নিজের (আত্মসংবরণ)\"","audioUrl":"wbw/012_051_008.mp3","charTypeName":"word"},{"id":49388,"position":9,"arabic":"قُلْنَ","translation":"তারা বললো","audioUrl":"wbw/012_051_010.mp3","charTypeName":"word"},{"id":49389,"position":10,"arabic":"حَـٰشَ","translation":"\"পবিত্রতা","audioUrl":"wbw/012_051_011.mp3","charTypeName":"word"},{"id":49390,"position":11,"arabic":"لِلَّهِ","translation":"\"জন্যে আল্লাহর","audioUrl":"wbw/012_051_012.mp3","charTypeName":"word"},{"id":49391,"position":12,"arabic":"مَا","translation":"না","audioUrl":"wbw/012_051_013.mp3","charTypeName":"word"},{"id":49392,"position":13,"arabic":"عَلِمْنَا","translation":"আমরা জানি","audioUrl":"wbw/012_051_014.mp3","charTypeName":"word"},{"id":49393,"position":14,"arabic":"عَلَيْهِ","translation":"মধ্যে তার","audioUrl":"wbw/012_051_015.mp3","charTypeName":"word"},{"id":49394,"position":15,"arabic":"مِن","translation":"কোন প্রকার","audioUrl":"wbw/012_051_016.mp3","charTypeName":"word"},{"id":49395,"position":16,"arabic":"سُوٓءٍۢ ۚ","translation":"দোষ\"","audioUrl":"wbw/012_051_017.mp3","charTypeName":"word"},{"id":49397,"position":17,"arabic":"قَالَتِ","translation":"বললো","audioUrl":"wbw/012_051_019.mp3","charTypeName":"word"},{"id":49398,"position":18,"arabic":"ٱمْرَأَتُ","translation":"স্ত্রী","audioUrl":"wbw/012_051_020.mp3","charTypeName":"word"},{"id":49399,"position":19,"arabic":"ٱلْعَزِيزِ","translation":"আযীযের","audioUrl":"wbw/012_051_021.mp3","charTypeName":"word"},{"id":49400,"position":20,"arabic":"ٱلْـَٔـٰنَ","translation":"\"এখন","audioUrl":"wbw/012_051_022.mp3","charTypeName":"word"},{"id":49401,"position":21,"arabic":"حَصْحَصَ","translation":"প্রকাশ পেলো","audioUrl":"wbw/012_051_023.mp3","charTypeName":"word"},{"id":49402,"position":22,"arabic":"ٱلْحَقُّ","translation":"সত্য","audioUrl":"wbw/012_051_024.mp3","charTypeName":"word"},{"id":49403,"position":23,"arabic":"أَنَا۠","translation":"আমি","audioUrl":"wbw/012_051_025.mp3","charTypeName":"word"},{"id":49404,"position":24,"arabic":"رَٰوَدتُّهُۥ","translation":"তাকে ফুসলিয়েছিলাম","audioUrl":"wbw/012_051_026.mp3","charTypeName":"word"},{"id":49405,"position":25,"arabic":"عَن","translation":"হ'তে","audioUrl":"wbw/012_051_027.mp3","charTypeName":"word"},{"id":49406,"position":26,"arabic":"نَّفْسِهِۦ","translation":"তার নিজের (আত্মসংবরণ)","audioUrl":"wbw/012_051_028.mp3","charTypeName":"word"},{"id":49407,"position":27,"arabic":"وَإِنَّهُۥ","translation":"এবং নিশ্চয়ই সে","audioUrl":"wbw/012_051_029.mp3","charTypeName":"word"},{"id":49408,"position":28,"arabic":"لَمِنَ","translation":"অবশ্যই অন্তর্ভুক্ত","audioUrl":"wbw/012_051_030.mp3","charTypeName":"word"},{"id":49409,"position":29,"arabic":"ٱلصَّـٰدِقِينَ","translation":"সত্যবাদীদের","audioUrl":"wbw/012_051_031.mp3","charTypeName":"word"},{"id":49410,"position":30,"arabic":"٥١","translation":"(৫১)","audioUrl":null,"charTypeName":"end"}]},{"number":52,"arabic":"ذَٰلِكَ لِيَعْلَمَ أَنِّى لَمْ أَخُنْهُ بِٱلْغَيْبِ وَأَنَّ ٱللَّهَ لَا يَهْدِى كَيْدَ ٱلْخَآئِنِينَ","translation":"[When Joseph learned what had happened, he said: \"I asked for] this, so that [my former master] might know that I did not betray him behind his back, and that God does not bless with His guidance the artful schemes of those who betray their trust.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1648.mp3","surahId":12,"words":[{"id":50152,"position":1,"arabic":"ذَٰلِكَ","translation":"এটা (এজন্যে)","audioUrl":"wbw/012_052_001.mp3","charTypeName":"word"},{"id":50153,"position":2,"arabic":"لِيَعْلَمَ","translation":"যেন সে জানে (আযীয)","audioUrl":"wbw/012_052_002.mp3","charTypeName":"word"},{"id":50154,"position":3,"arabic":"أَنِّى","translation":"যে আমি","audioUrl":"wbw/012_052_003.mp3","charTypeName":"word"},{"id":50155,"position":4,"arabic":"لَمْ","translation":"নি","audioUrl":"wbw/012_052_004.mp3","charTypeName":"word"},{"id":50156,"position":5,"arabic":"أَخُنْهُ","translation":"তার আমি বিশ্বাসঘাতকতা করি","audioUrl":"wbw/012_052_005.mp3","charTypeName":"word"},{"id":50157,"position":6,"arabic":"بِٱلْغَيْبِ","translation":"(তার) অনুপস্থিতিতে","audioUrl":"wbw/012_052_006.mp3","charTypeName":"word"},{"id":50158,"position":7,"arabic":"وَأَنَّ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/012_052_007.mp3","charTypeName":"word"},{"id":50159,"position":8,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/012_052_008.mp3","charTypeName":"word"},{"id":50160,"position":9,"arabic":"لَا","translation":"না","audioUrl":"wbw/012_052_009.mp3","charTypeName":"word"},{"id":50161,"position":10,"arabic":"يَهْدِى","translation":"সফল করেন","audioUrl":"wbw/012_052_010.mp3","charTypeName":"word"},{"id":50162,"position":11,"arabic":"كَيْدَ","translation":"ষড়যন্ত্র","audioUrl":"wbw/012_052_011.mp3","charTypeName":"word"},{"id":50163,"position":12,"arabic":"ٱلْخَآئِنِينَ","translation":"বিশ্বাসঘাতকদের\"","audioUrl":"wbw/012_052_012.mp3","charTypeName":"word"},{"id":50164,"position":13,"arabic":"٥٢","translation":"(৫২)","audioUrl":null,"charTypeName":"end"}]}]}