c":"ٱلطَّآئِفَتَيْنِ","translation":"দুইদলের(মধ্যে)","audioUrl":"wbw/008_007_005.mp3","charTypeName":"word"},{"id":7463,"position":6,"arabic":"أَنَّهَا","translation":"যে তা(আওতাধীন হবে)","audioUrl":"wbw/008_007_006.mp3","charTypeName":"word"},{"id":7464,"position":7,"arabic":"لَكُمْ","translation":"জন্যে তোমাদের","audioUrl":"wbw/008_007_007.mp3","charTypeName":"word"},{"id":7465,"position":8,"arabic":"وَتَوَدُّونَ","translation":"অথচ তোমরা চেয়েছিলে","audioUrl":"wbw/008_007_008.mp3","charTypeName":"word"},{"id":7466,"position":9,"arabic":"أَنَّ","translation":"যে","audioUrl":"wbw/008_007_009.mp3","charTypeName":"word"},{"id":7467,"position":10,"arabic":"غَيْرَ","translation":"নয়","audioUrl":"wbw/008_007_010.mp3","charTypeName":"word"},{"id":7468,"position":11,"arabic":"ذَاتِ","translation":"যুক্ত","audioUrl":"wbw/008_007_011.mp3","charTypeName":"word"},{"id":7469,"position":12,"arabic":"ٱلشَّوْكَةِ","translation":"কাঁটা","audioUrl":"wbw/008_007_012.mp3","charTypeName":"word"},{"id":7470,"position":13,"arabic":"تَكُونُ","translation":"তা হবে (সংঘর্ষশীল)","audioUrl":"wbw/008_007_013.mp3","charTypeName":"word"},{"id":7471,"position":14,"arabic":"لَكُمْ","translation":"জন্যে তোমাদের","audioUrl":"wbw/008_007_014.mp3","charTypeName":"word"},{"id":7472,"position":15,"arabic":"وَيُرِيدُ","translation":"কিন্তু চান","audioUrl":"wbw/008_007_015.mp3","charTypeName":"word"},{"id":7473,"position":16,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/008_007_016.mp3","charTypeName":"word"},{"id":7474,"position":17,"arabic":"أَن","translation":"যে","audioUrl":"wbw/008_007_017.mp3","charTypeName":"word"},{"id":7475,"position":18,"arabic":"يُحِقَّ","translation":"সত্যে পরিণত করতে","audioUrl":"wbw/008_007_018.mp3","charTypeName":"word"},{"id":7476,"position":19,"arabic":"ٱلْحَقَّ","translation":"সত্যকে","audioUrl":"wbw/008_007_019.mp3","charTypeName":"word"},{"id":7477,"position":20,"arabic":"بِكَلِمَـٰتِهِۦ","translation":"দিয়ে বাণীসমূহ তাঁর","audioUrl":"wbw/008_007_020.mp3","charTypeName":"word"},{"id":7478,"position":21,"arabic":"وَيَقْطَعَ","translation":"এবং কাটবেন","audioUrl":"wbw/008_007_021.mp3","charTypeName":"word"},{"id":7479,"position":22,"arabic":"دَابِرَ","translation":"মূল","audioUrl":"wbw/008_007_022.mp3","charTypeName":"word"},{"id":7480,"position":23,"arabic":"ٱلْكَـٰفِرِينَ","translation":"কাফেরদের","audioUrl":"wbw/008_007_023.mp3","charTypeName":"word"},{"id":7481,"position":24,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"لِيُحِقَّ ٱلْحَقَّ وَيُبْطِلَ ٱلْبَٰطِلَ وَلَوْ كَرِهَ ٱلْمُجْرِمُونَ","translation":"so that He might prove the truth to be true and the false to be false, however hateful this might be to those who were lost in sin.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1168.mp3","surahId":8,"words":[{"id":8719,"position":1,"arabic":"لِيُحِقَّ","translation":"যেন সত্যে পরিণত করেন","audioUrl":"wbw/008_008_001.mp3","charTypeName":"word"},{"id":8720,"position":2,"arabic":"ٱلْحَقَّ","translation":"সত্যকে","audioUrl":"wbw/008_008_002.mp3","charTypeName":"word"},{"id":8721,"position":3,"arabic":"وَيُبْطِلَ","translation":"ও অসত্যে পরিণত করেন","audioUrl":"wbw/008_008_003.mp3","charTypeName":"word"},{"id":8722,"position":4,"arabic":"ٱلْبَـٰطِلَ","translation":"অসত্যকে","audioUrl":"wbw/008_008_004.mp3","charTypeName":"word"},{"id":8723,"position":5,"arabic":"وَلَوْ","translation":"এবং যদিও (তা)","audioUrl":"wbw/008_008_005.mp3","charTypeName":"word"},{"id":8724,"position":6,"arabic":"كَرِهَ","translation":"অপছন্দ করে","audioUrl":"wbw/008_008_006.mp3","charTypeName":"word"},{"id":8725,"position":7,"arabic":"ٱلْمُجْرِمُونَ","translation":"অপরাধীরা","audioUrl":"wbw/008_008_007.mp3","charTypeName":"word"},{"id":8726,"position":8,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]}]}