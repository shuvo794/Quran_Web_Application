{"id":177,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ يَسْـَٔلُونَكَ عَنِ ٱلْأَنفَالِ ۖ قُلِ ٱلْأَنفَالُ لِلَّهِ وَٱلرَّسُولِ ۖ فَٱتَّقُوا۟ ٱللَّهَ وَأَصْلِحُوا۟ ذَاتَ بَيْنِكُمْ ۖ وَأَطِيعُوا۟ ٱللَّهَ وَرَسُولَهُۥٓ إِن كُنتُم مُّؤْمِنِينَ","translation":"HEY WILL ASK thee about the spoils of war. Say: \"All spoils of war belong to God and the Apostle.\" Remain, then, conscious of God, and keep alive the bonds of brotherhood among yourselves, and pay heed unto God and His Apostle, if you are [truly] believers!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1161.mp3","surahId":8,"words":[{"id":193,"position":1,"arabic":"يَسْـَٔلُونَكَ","translation":"তোমাকে তারা জিজ্ঞাসা করে","audioUrl":"wbw/008_001_001.mp3","charTypeName":"word"},{"id":194,"position":2,"arabic":"عَنِ","translation":"সম্পর্কে","audioUrl":"wbw/008_001_002.mp3","charTypeName":"word"},{"id":195,"position":3,"arabic":"ٱلْأَنفَالِ ۖ","translation":"যুদ্ধলব্ধ সম্পদ","audioUrl":"wbw/008_001_003.mp3","charTypeName":"word"},{"id":197,"position":4,"arabic":"قُلِ","translation":"বলো","audioUrl":"wbw/008_001_005.mp3","charTypeName":"word"},{"id":198,"position":5,"arabic":"ٱلْأَنفَالُ","translation":"\"যুদ্ধলব্ধ সম্পদ","audioUrl":"wbw/008_001_006.mp3","charTypeName":"word"},{"id":199,"position":6,"arabic":"لِلَّهِ","translation":"জন্যে আল্লাহর","audioUrl":"wbw/008_001_007.mp3","charTypeName":"word"},{"id":200,"position":7,"arabic":"وَٱلرَّسُولِ ۖ","translation":"ও রাসূলের (জন্যে)","audioUrl":"wbw/008_001_008.mp3","charTypeName":"word"},{"id":202,"position":8,"arabic":"فَٱتَّقُوا۟","translation":"অতএব তোমরা ভয় করো","audioUrl":"wbw/008_001_010.mp3","charTypeName":"word"},{"id":203,"position":9,"arabic":"ٱللَّهَ","translation":"আল্লাহকে","audioUrl":"wbw/008_001_011.mp3","charTypeName":"word"},{"id":204,"position":10,"arabic":"وَأَصْلِحُوا۟","translation":"এবং তোমরা সংশোধন করো","audioUrl":"wbw/008_001_012.mp3","charTypeName":"word"},{"id":205,"position":11,"arabic":"ذَاتَ"