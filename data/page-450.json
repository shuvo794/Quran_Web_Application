,"charTypeName":"word"},{"id":77353,"position":3,"arabic":"وَرَبَّ","translation":"ও রব","audioUrl":"wbw/037_126_003.mp3","charTypeName":"word"},{"id":77354,"position":4,"arabic":"ءَابَآئِكُمُ","translation":"তোমাদের পিতৃপুরুষদেরও\"","audioUrl":"wbw/037_126_004.mp3","charTypeName":"word"},{"id":77355,"position":5,"arabic":"ٱلْأَوَّلِينَ","translation":"পূর্বের\"","audioUrl":"wbw/037_126_005.mp3","charTypeName":"word"},{"id":77356,"position":6,"arabic":"١٢٦","translation":"(১২৬)","audioUrl":null,"charTypeName":"end"}]}]}