":5,"arabic":"١١٩","translation":"(১১৯)","audioUrl":null,"charTypeName":"end"}]},{"number":120,"arabic":"سَلَٰمٌ عَلَىٰ مُوسَىٰ وَهَٰرُونَ","translation":"“Peace be upon Moses and Aaron!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3908.mp3","surahId":37,"words":[{"id":76399,"position":1,"arabic":"سَلَـٰمٌ","translation":"\"সালাম (বর্ষিত হউক)","audioUrl":"wbw/037_120_001.mp3","charTypeName":"word"},{"id":76400,"position":2,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/037_120_002.mp3","charTypeName":"word"},{"id":76401,"position":3,"arabic":"مُوسَىٰ","translation":"মূসার","audioUrl":"wbw/037_120_003.mp3","charTypeName":"word"},{"id":76402,"position":4,"arabic":"وَهَـٰرُونَ","translation":"ও হারূনের\"","audioUrl":"wbw/037_120_004.mp3","charTypeName":"word"},{"id":76403,"position":5,"arabic":"١٢٠","translation":"(১২০)","audioUrl":null,"charTypeName":"end"}]},{"number":121,"arabic":"إِنَّا كَذَٰلِكَ نَجْزِى ٱلْمُحْسِنِينَ","translation":"Thus do We reward the doers of good –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3909.mp3","surahId":37,"words":[{"id":76544,"position":1,"arabic":"إِنَّا","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/037_121_001.mp3","charTypeName":"word"},{"id":76545,"position":2,"arabic":"كَذَٰلِكَ","translation":"এরূপে","audioUrl":"wbw/037_121_002.mp3","charTypeName":"word"},{"id":76546,"position":3,"arabic":"نَجْزِى","translation":"প্রতিফল দিই আমরা","audioUrl":"wbw/037_121_003.mp3","charTypeName":"word"},{"id":76547,"position":4,"arabic":"ٱلْمُحْسِنِينَ","translation":"সৎকর্মপরায়ণদের","audioUrl":"wbw/037_121_004.mp3","charTypeName":"word"},{"id":76548,"position":5,"arabic":"١٢١","translation":"(১২১)","audioUrl":null,"charTypeName":"end"}]},{"number":122,"arabic":"إِنَّهُمَا مِنْ عِبَادِنَا ٱلْمُؤْمِنِينَ","translation":"for those two were truly among Our believing ser­vants.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3910.mp3","surahId":37,"words":[{"id":76757,"position":1,"a