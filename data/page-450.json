{"id":450,"ayahs":[{"number":103,"arabic":"فَلَمَّآ أَسْلَمَا وَتَلَّهُۥ لِلْجَبِينِ","translation":"But as soon as the two had surrendered themselves to [what they thought to be] the will of God, and [Abraham] had laid him down on his face,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3891.mp3","surahId":37,"words":[{"id":72394,"position":1,"arabic":"فَلَمَّآ","translation":"যখন অতঃপর","audioUrl":"wbw/037_103_001.mp3","charTypeName":"word"},{"id":72395,"position":2,"arabic":"أَسْلَمَا","translation":"অনুগত হয়ে গেলো উভয়ে","audioUrl":"wbw/037_103_002.mp3","charTypeName":"word"},{"id":72396,"position":3,"arabic":"وَتَلَّهُۥ","translation":"এবং তাকে শুইয়ে দিলো","audioUrl":"wbw/037_103_003.mp3","charTypeName":"word"},{"id":72397,"position":4,"arabic":"لِلْجَبِينِ","translation":"উপুড় করে","audioUrl":"wbw/037_103_004.mp3","charTypeName":"word"},{"id":72398,"position":5,"arabic":"١٠٣","translation":"(১০৩)","audioUrl":null,"charTypeName":"end"}]},{"number":104,"arabic":"وَنَٰدَيْنَٰهُ أَن يَٰٓإِبْرَٰهِيمُ","translation":"We called out to him: “O Abraham,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3892.mp3","surahId":37,"words":[{"id":72668,"position":1,"arabic":"وَنَـٰدَيْنَـٰهُ","translation":"এবং তাকে আমরা ডাক দিলাম","audioUrl":"wbw/037_104_001.mp3","charTypeName":"word"},{"id":72669,"position":2,"arabic":"أَن","translation":"যে","audioUrl":"wbw/037_104_002.mp3","charTypeName":"word"},{"id":72670,"position":3,"arabic":"يَـٰٓإِبْرَٰهِيمُ","translation":"\"হে ইব্রাহীম","audioUrl":"wbw/037_104_003.mp3","charTypeName":"word"},{"id":72671,"position":4,"arabic":"١٠٤","translation":"(১০৪)","audioUrl":null,"charTypeName":"end"}]},{"number":105,"arabic":"قَدْ صَدَّقْتَ ٱلرُّءْيَآ ۚ إِنَّا كَذَٰلِكَ نَجْزِى ٱلْمُحْسِنِينَ","translation":"thou hast already fulfilled [the purpose of] that dream- vision!” Thus, verily, do We reward the doers of good:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3893.mp3","surahId":37,"words":[{"id":72910,"position":1,"arabic":"قَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/037_105_001.mp3","charTypeName":"word"},{"id":72911,"position":2,"arabic":"صَدَّقْتَ","translation":"তুমি সত্য করেছো","audioUrl":"wbw/037_105_002.mp3","charTypeName":"word"},{"id":72912,"position":3,"arabic":"ٱلرُّءْيَآ ۚ","translation":"স্বপ্নকে\"","audioUrl":"wbw/037_105_003.mp3","charTypeName":"word"},{"id":72914,"position":4,"arabic":"إِنَّا","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/037_105_005.mp3","charTypeName":"word"},{"id":72915,"position":5,"arabic":"كَذَٰلِكَ","translation":"এরূপে","audioUrl":"wbw/037_105_006.mp3","charTypeName":"word"},{"id":72916,"position":6,"arabic":"نَجْزِى","translation":"প্রতিফল দিই আমরা","audioUrl":"wbw/037_105_007.mp3","charTypeName":"word"},{"id":72917,"position":7,"arabic":"ٱلْمُحْسِنِينَ","translation":"সৎকর্মপরায়ণদের","audioUrl":"wbw/037_105_008.mp3","charTypeName":"word"},{"id":72918,"position":8,"arabic":"١٠٥","translation":"(১০৫)","audioUrl":null,"charTypeName":"end"}]},{"number":106,"arabic":"إِنَّ هَٰذَا لَهُوَ ٱلْبَلَٰٓؤُا۟ ٱلْمُبِينُ","translation":"for, behold, all this was indeed a trial, clear in itself.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3894.mp3","surahId":37,"words":[{"id":73174,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/037_106_001.mp3","charTypeName":"word"},{"id":73175,"position":2,"arabic":"هَـٰذَا","translation":"এটা","audioUrl":"wbw/037_106_002.mp3","charTypeName":"word"},{"id":73176,"position":3,"arabic":"لَهُوَ","translation":"তা অবশ্যই (ছিলো)","audioUrl":"wbw/037_106_003.mp3","charTypeName":"word"},{"id":73177,"position":4,"arabic":"ٱلْبَلَـٰٓؤُا۟","translation":"পরীক্ষা","audioUrl":"wbw/037_106_004.mp3","charTypeName":"word"},{"id":73178,"position":5,"arabic":"ٱلْمُبِينُ","translation":"সুস্পষ্ট","audioUrl":"wbw/037_106_005.mp3","charTypeName":"word"},{"id":73179,"position":6,"arabic":"١٠٦","translation":"(১০৬)","audioUrl":null,"charTypeName":"end"}]},{"number":107,"arabic":"وَفَدَيْنَٰهُ بِذِبْحٍ عَظِيمٍۢ","translation":"And We ransomed him with a tremendous sacrifice,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3895.mp3","surahId":37,"words":[{"id":73420,"position":1,"arabic":"وَفَدَيْنَـٰهُ","translation":"এবং তাকে আমরা ছাড়িয়ে নিই","audioUrl":"wbw/037_107_001.mp3","charTypeName":"word"},{"id":73421,"position":2,"arabic":"بِذِبْحٍ","translation":"জবাই পশুর বিনিময়ে","audioUrl":"wbw/037_107_002.mp3","charTypeName":"word"},{"id":73422,"position":3,"arabic":"عَظِيمٍۢ","translation":"বড়","audioUrl":"wbw/037_107_003.mp3","charTypeName":"word"},{"id":73423,"position":4,"arabic":"١٠٧","translation":"(১০৭)","audioUrl":null,"charTypeName":"end"}]},{"number":108,"arabic":"وَتَرَكْنَا عَلَيْهِ فِى ٱلْءَاخِرِينَ","translation":"and left him thus to be remembered among later generations:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3896.mp3","surahId":37,"words":[{"id":73688,"position":1,"arabic":"وَتَرَكْنَا","translation":"এবং আমরা প্রচলিত রাখলাম","audioUrl":"wbw/037_108_001.mp3","charTypeName":"word"},{"id":73689,"position":2,"arabic":"عَلَيْهِ","translation":"তাঁর উপর","audioUrl":"wbw/037_108_002.mp3","charTypeName":"word"},{"id":73690,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/037_108_003.mp3","charTypeName":"word"},{"id":73691,"position":4,"arabic":"ٱلْـَٔاخِرِينَ","translation":"পরবর্তীদের (তাঁর স্মরণ)","audioUrl":"wbw/037_108_004.mp3","charTypeName":"word"},{"id":73692,"position":5,"arabic":"١٠٨","translation":"(১০৮)","audioUrl":null,"charTypeName":"end"}]},{"number":109,"arabic":"سَلَٰمٌ عَلَىٰٓ إِبْرَٰهِيمَ","translation":"“Peace be upon Abraham!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3897.mp3","surahId":37,"words":[{"id":73984,"position":1,"arabic":"سَلَـٰمٌ","translation":"\"সালাম (বর্ষিত হোক)","audioUrl":"wbw/037_109_001.mp3","charTypeName":"word"},{"id":73985,"position":2,"arabic":"عَلَىٰٓ","translation":"উপর","audioUrl":"wbw/037_109_002.mp3","charTypeName":"word"},{"id":73986,"position":3,"arabic":"إِبْرَٰهِيمَ","translation":"ইবরাহীমের\"","audioUrl":"wbw/037_109_003.mp3","charTypeName":"word"},{"id":73987,"position":4,"arabic":"١٠٩","translation":"(১০৯)","audioUrl":null,"charTypeName":"end"}]},{"number":110,"arabic":"كَذَٰلِكَ نَجْزِى ٱلْمُحْسِنِينَ","translation":"Thus do We reward the doers of good –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3898.mp3","surahId":37,"words":[{"id":74141,"position":1,"arabic":"كَذَٰلِكَ","translation":"এরূপে","audioUrl":"wbw/037_110_001.mp3","charTypeName":"word"},{"id":74142,"position":2,"arabic":"نَجْزِى","translation":"প্রতিফল দিই আমরা","audioUrl":"wbw/037_110_002.mp3","charTypeName":"word"},{"id":74143,"position":3,"arabic":"ٱلْمُحْسِنِينَ","translation":"উত্তম কর্মশীলদেরকে","audioUrl":"wbw/037_110_003.mp3","charTypeName":"word"},{"id":74144,"position":4,"arabic":"١١٠","translation":"(১১০)","audioUrl":null,"charTypeName":"end"}]},{"number":111,"arabic":"إِنَّهُۥ مِنْ عِبَادِنَا ٱلْمُؤْمِنِينَ","translation":"for he was truly one of our believing servants.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3899.mp3","surahId":37,"words":[{"id":74485,"position":1,"arabic":"إِنَّهُۥ","translation":"সে নিশ্চয়ই (ছিলো)","audioUrl":"wbw/037_111_001.mp3","charTypeName":"word"},{"id":74486,"position":2,"arabic":"مِنْ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/037_111_002.mp3","charTypeName":"word"},{"id":74487,"position":3,"arabic":"عِبَادِنَا","translation":"আমাদের দাসদের","audioUrl":"wbw/037_111_003.mp3","charTypeName":"word"},{"id":74488,"position":4,"arabic":"ٱلْمُؤْمِنِينَ","translation":"(যারা ছিলো) মু'মিন","audioUrl":"wbw/037_111_004.mp3","charTypeName":"word"},{"id":74489,"position":5,"arabic":"١١١","translation":"(১১১)","audioUrl":null,"charTypeName":"end"}]},{"number":112,"arabic":"وَبَشَّرْنَٰهُ بِإِسْحَٰقَ نَبِيًّۭا مِّنَ ٱلصَّٰلِحِينَ","translation":"And [in time] We gave him the glad tiding of Isaac, [who, too, would be] a prophet, one of the righteous;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3900.mp3","surahId":37,"words":[{"id":74716,"position":1,"arabic":"وَبَشَّرْنَـٰهُ","translation":"এবং তাকে আমরা সুসংবাদ দিলাম","audioUrl":"wbw/037_112_001.mp3","charTypeName":"word"},{"id":74717,"position":2,"arabic":"بِإِسْحَـٰقَ","translation":"ইসহাক সম্পর্কে","audioUrl":"wbw/037_112_002.mp3","charTypeName":"word"},{"id":74718,"position":3,"arabic":"نَبِيًّۭا","translation":"একজন নাবী হিসেবে","audioUrl":"wbw/037_112_003.mp3","charTypeName":"word"},{"id":74719,"position":4,"arabic":"مِّنَ","translation":"অন্যতম","audioUrl":"wbw/037_112_004.mp3","charTypeName":"word"},{"id":74720,"position":5,"arabic":"ٱلصَّـٰلِحِينَ","translation":"সৎকর্মশীলদের","audioUrl":"wbw/037_112_005.mp3","charTypeName":"word"},{"id":74721,"position":6,"arabic":"١١٢","translation":"(১১২)","audioUrl":null,"charTypeName":"end"}]},{"number":113,"arabic":"وَبَٰرَكْنَا عَلَيْهِ وَعَلَىٰٓ إِسْحَٰقَ ۚ وَمِن ذُرِّيَّتِهِمَا مُحْسِنٌۭ وَظَالِمٌۭ لِّنَفْسِهِۦ مُبِينٌۭ","translation":"and We blessed him and Isaac: but among the offspring of these two there were [des­tined] to be both doers of good and such as would glaringly sin against themselves.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3901.mp3","surahId":37,"words":[{"id":74891,"position":1,"arabic":"وَبَـٰرَكْنَا","translation":"এবং আমরা সমৃদ্ধি দিলাম","audioUrl":"wbw/037_113_001.mp3","charTypeName":"word"},{"id":74892,"position":2,"arabic":"عَلَيْهِ","translation":"তাঁর উপর","audioUrl":"wbw/037_113_002.mp3","charTypeName":"word"},{"id":74893,"position":3,"arabic":"وَعَلَىٰٓ","translation":"ও উপর","audioUrl":"wbw/037_113_003.mp3","charTypeName":"word"},{"id":74894,"position":4,"arabic":"إِسْحَـٰقَ ۚ","translation":"ইসহাকের","audioUrl":"wbw/037_113_004.mp3","charTypeName":"word"},{"id":74896,"position":5,"arabic":"وَمِن","translation":"এবং মধ্য হ'তে","audioUrl":"wbw/037_113_006.mp3","charTypeName":"word"},{"id":74897,"position":6,"arabic":"ذُرِّيَّتِهِمَا","translation":"তাদের দু'জনের বংশধরদের","audioUrl":"wbw/037_113_007.mp3","charTypeName":"word"},{"id":74898,"position":7,"arabic":"مُحْسِنٌۭ","translation":"(কেউ হয়) সৎকর্মপরায়ণ","audioUrl":"wbw/037_113_008.mp3","charTypeName":"word"},{"id":74899,"position":8,"arabic":"وَظَالِمٌۭ","translation":"ও (কেউ হয়) সীমালঙ্ঘনকারী","audioUrl":"wbw/037_113_009.mp3","charTypeName":"word"},{"id":74900,"position":9,"arabic":"لِّنَفْسِهِۦ","translation":"তার নিজের উপর","audioUrl":"wbw/037_113_010.mp3","charTypeName":"word"},{"id":74901,"position":10,"arabic":"مُبِينٌۭ","translation":"সুস্পষ্ট","audioUrl":"wbw/037_113_011.mp3","charTypeName":"word"},{"id":74902,"position":11,"arabic":"١١٣","translation":"(১১৩)","audioUrl":null,"charTypeName":"end"}]},{"number":114,"arabic":"وَلَقَدْ مَنَنَّا عَلَىٰ مُوسَىٰ وَهَٰرُونَ","translation":"THUS, INDEED, did We bestow Our favour upon Moses and Aaron;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3902.mp3","surahId":37,"words":[{"id":75281,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/037_114_001.mp3","charTypeName":"word"},{"id":75282,"position":2,"arabic":"مَنَنَّا","translation":"আমরা অনুগ্রহ করেছি","audioUrl":"wbw/037_114_002.mp3","charTypeName":"word"},{"id":75283,"position":3,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/037_114_003.mp3","charTypeName":"word"},{"id":75284,"position":4,"arabic":"مُوسَىٰ","translation":"মূসার","audioUrl":"wbw/037_114_004.mp3","charTypeName":"word"},{"id":75285,"position":5,"arabic":"وَهَـٰرُونَ","translation":"ও হারূনের","audioUrl":"wbw/037_114_005.mp3","charTypeName":"word"},{"id":75286,"position":6,"arabic":"١١٤","translation":"(১১৪)","audioUrl":null,"charTypeName":"end"}]},{"number":115,"arabic":"وَنَجَّيْنَٰهُمَا وَقَوْمَهُمَا مِنَ ٱلْكَرْبِ ٱلْعَظِيمِ","translation":"and We saved them and their people from the awesome calamity [of bondage],","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3903.mp3","surahId":37,"words":[{"id":75357,"position":1,"arabic":"وَنَجَّيْنَـٰهُمَا","translation":"এবং উদ্ধার করেছি আমরা উভয়কে","audioUrl":"wbw/037_115_001.mp3","charTypeName":"word"},{"id":75358,"position":2,"arabic":"وَقَوْمَهُمَا","translation":"ও উভয়ের জাতিকে","audioUrl":"wbw/037_115_002.mp3","charTypeName":"word"},{"id":75359,"position":3,"arabic":"مِنَ","translation":"হ'তে","audioUrl":"wbw/037_115_003.mp3","charTypeName":"word"},{"id":75360,"position":4,"arabic":"ٱلْكَرْبِ","translation":"সংকট","audioUrl":"wbw/037_115_004.mp3","charTypeName":"word"},{"id":75361,"position":5,"arabic":"ٱلْعَظِيمِ","translation":"মহা","audioUrl":"wbw/037_115_005.mp3","charTypeName":"word"},{"id":75362,"position":6,"arabic":"١١٥","translation":"(১১৫)","audioUrl":null,"charTypeName":"end"}]},{"number":116,"arabic":"وَنَصَرْنَٰهُمْ فَكَانُوا۟ هُمُ ٱلْغَٰلِبِينَ","translation":"and succoured them, so that [in the end] it was they who achieved victory.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3904.mp3","surahId":37,"words":[{"id":75687,"position":1,"arabic":"وَنَصَرْنَـٰهُمْ","translation":"এবং তাদেরকে আমরা সাহায্য করেছি","audioUrl":"wbw/037_116_001.mp3","charTypeName":"word"},{"id":75688,"position":2,"arabic":"فَكَانُوا۟","translation":"অতঃপর তারা হয়েছিলো","audioUrl":"wbw/037_116_002.mp3","charTypeName":"word"},{"id":75689,"position":3,"arabic":"هُمُ","translation":"তারাই","audioUrl":"wbw/037_116_003.mp3","charTypeName":"word"},{"id":75690,"position":4,"arabic":"ٱلْغَـٰلِبِينَ","translation":"বিজয়ী","audioUrl":"wbw/037_116_004.mp3","charTypeName":"word"},{"id":75691,"position":5,"arabic":"١١٦","translation":"(১১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":117,"arabic":"وَءَاتَيْنَٰهُمَا ٱلْكِتَٰبَ ٱلْمُسْتَبِينَ","translation":"And We gave them the divine writ that made [right and wrong] distinct,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3905.mp3","surahId":37,"words":[{"id":75855,"position":1,"arabic":"وَءَاتَيْنَـ