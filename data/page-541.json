l":"wbw/057_026_005.mp3","charTypeName":"word"},{"id":29325,"position":6,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/057_026_006.mp3","charTypeName":"word"},{"id":29326,"position":7,"arabic":"ذُرِّيَّتِهِمَا","translation":"উভয়ের বংশধরদের","audioUrl":"wbw/057_026_007.mp3","charTypeName":"word"},{"id":29327,"position":8,"arabic":"ٱلنُّبُوَّةَ","translation":"নবুয়্যত","audioUrl":"wbw/057_026_008.mp3","charTypeName":"word"},{"id":29328,"position":9,"arabic":"وَٱلْكِتَـٰبَ ۖ","translation":"ও কিতাব","audioUrl":"wbw/057_026_009.mp3","charTypeName":"word"},{"id":29330,"position":10,"arabic":"فَمِنْهُم","translation":"অতঃপর তাদের মধ্য হতে","audioUrl":"wbw/057_026_011.mp3","charTypeName":"word"},{"id":29331,"position":11,"arabic":"مُّهْتَدٍۢ ۖ","translation":"(কিছু হয়েছে) সৎ পথ প্রাপ্ত","audioUrl":"wbw/057_026_012.mp3","charTypeName":"word"},{"id":29333,"position":12,"arabic":"وَكَثِيرٌۭ","translation":"আর অনেকেই","audioUrl":"wbw/057_026_014.mp3","charTypeName":"word"},{"id":29334,"position":13,"arabic":"مِّنْهُمْ","translation":"তাদের মধ্যে হতে","audioUrl":"wbw/057_026_015.mp3","charTypeName":"word"},{"id":29335,"position":14,"arabic":"فَـٰسِقُونَ","translation":"সত্যত্যাগী","audioUrl":"wbw/057_026_016.mp3","charTypeName":"word"},{"id":29336,"position":15,"arabic":"٢٦","translation":"(২৬)","audioUrl":null,"charTypeName":"end"}]},{"number":27,"arabic":"ثُمَّ قَفَّيْنَا عَلَىٰٓ ءَاثَٰرِهِم بِرُسُلِنَا وَقَفَّيْنَا بِعِيسَى ٱبْنِ مَرْيَمَ وَءَاتَيْنَٰهُ ٱلْإِنجِيلَ وَجَعَلْنَا فِى قُلُوبِ ٱلَّذِينَ ٱتَّبَعُوهُ رَأْفَةًۭ وَرَحْمَةًۭ وَرَهْبَانِيَّةً ٱبْتَدَعُوهَا مَا كَتَبْنَٰهَا عَلَيْهِمْ إِلَّا ٱبْتِغَآءَ رِضْوَٰنِ ٱللَّهِ فَمَا رَعَوْهَا حَقَّ رِعَايَتِهَا ۖ فَـَٔاتَيْنَا ٱلَّذِينَ ءَامَنُوا۟ مِنْهُمْ أَجْرَهُمْ ۖ وَكَثِيرٌۭ مِّنْهُمْ فَٰسِقُونَ","translation":"And thereupon We caused [other of] Our apostles to follow in their footsteps; and [in the course of time] We caused them to be followed by Jesus, the son of Mary, upon whom We bestowed the Gospel; and in the hearts of those who [truly] followed him We engendered compassion and mercy. But as for monastic asceticism - We did not enjoin it upon them: they invented it themselves out of a desire for God’s goodly acceptance. But then, they did not [always] observe it as it ought to have been observed: and so We granted their recompense unto such of them as had [truly] attained to faith, whereas many of them became iniquitous.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5102.mp3","surahId":57,"words":[{"id":29697,"position":1,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/057_027_001.mp3","charTypeName":"word"},{"id":29698,"position":2,"arabic":"قَفَّيْنَا","translation":"আমরা অনুগামী করেছি","audioUrl":"wbw/057_027_002.mp3","charTypeName":"word"},{"id":29699,"position":3,"arabic":"عَلَىٰٓ","translation":"উপর","audioUrl":"wbw/057_027_003.mp3","charTypeName":"word"},{"id":29700,"position":4,"arabic":"ءَاثَـٰرِهِم","translation":"তাদের পদচিহ্নের","audioUrl":"wbw/057_027_004.mp3","charTypeName":"word"},{"id":29701,"position":5,"arabic":"بِرُسُلِنَا","translation":"আমাদের  রাসূলদেরকে","audioUrl":"wbw/057_027_005.mp3","charTypeName":"word"},{"id":29702,"position":6,"arabic":"وَقَفَّيْنَا","translation":"এবং আমরা এরপর অনুগামী করেছি","audioUrl":"wbw/057_027_006.mp3","charTypeName":"word"},{"id":29703,"position":7,"arabic":"بِعِيسَى","translation":"ঈসাকে","audioUrl":"wbw/057_027_007.mp3","charTypeName":"word"},{"id":29704,"position":8,"arabic":"ٱبْنِ","translation":"পুত্র","audioUrl":"wbw/057_027_008.mp3","charTypeName":"word"},{"id":29705,"position":9,"arabic":"مَرْيَمَ","translation":"মারইয়ামের","audioUrl":"wbw/057_027_009.mp3","charTypeName":"word"},{"id":29706,"position":10,"arabic":"وَءَاتَيْنَـٰهُ","translation":"এবং আমরা তাকে দিয়েছি","audioUrl":"wbw/057_027_010.mp3","charTypeName":"word"},{"id":29707,"position":11,"arabic":"ٱلْإِنجِيلَ","translation":"ইনজিল","audioUrl":"wbw/057_027_011.mp3","charTypeName":"word"},{"id":29708,"position":12,"arabi