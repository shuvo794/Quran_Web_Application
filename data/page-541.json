{"id":541,"ayahs":[{"number":25,"arabic":"لَقَدْ أَرْسَلْنَا رُسُلَنَا بِٱلْبَيِّنَٰتِ وَأَنزَلْنَا مَعَهُمُ ٱلْكِتَٰبَ وَٱلْمِيزَانَ لِيَقُومَ ٱلنَّاسُ بِٱلْقِسْطِ ۖ وَأَنزَلْنَا ٱلْحَدِيدَ فِيهِ بَأْسٌۭ شَدِيدٌۭ وَمَنَٰفِعُ لِلنَّاسِ وَلِيَعْلَمَ ٱللَّهُ مَن يَنصُرُهُۥ وَرُسُلَهُۥ بِٱلْغَيْبِ ۚ إِنَّ ٱللَّهَ قَوِىٌّ عَزِيزٌۭ","translation":"Indeed, [even aforetime] did We send forth Our apostles with all evidence of [this] truth; and through them We bestowed revelation from on high, and [thus gave you] a balance [wherewith to weigh right and wrong], so that men might behave with equity; and We bestowed [upon you] from on high [the ability to make use of] iron, in which there is awesome power as well as [a source of] benefits for man: and [all this was given to you] so that God might mark out those who would stand up for him and His Apostle, even though He [Himself] is beyond the reach of human perception. Verily, God is powerful, almighty!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5100.mp3","surahId":57,"words":[{"id":27931,"position":1,"arabic":"لَقَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/057_025_001.mp3","charTypeName":"word"},{"id":27932,"position":2,"arabic":"أَرْسَلْنَا","translation":"আমরা পাঠিয়েছি","audioUrl":"wbw/057_025_002.mp3","charTypeName":"word"},{"id":27933,"position":3,"arabic":"رُسُلَنَا","translation":"আমাদের রাসূলদেরকে","audioUrl":"wbw/057_025_003.mp3","charTypeName":"word"},{"id":27934,"position":4,"arabic":"بِٱلْبَيِّنَـٰتِ","translation":"সুস্পষ্ট প্রমাণাদি সহ","audioUrl":"wbw/057_025_004.mp3","charTypeName":"word"},{"id":27935,"position":5,"arabic":"وَأَنزَلْنَا","translation":"এবং আমরা অবতীর্ণ করেছি","audioUrl":"wbw/057_025_005.mp3","charTypeName":"word"},{"id":27936,"position":6,"arabic":"مَعَهُمُ","translation":"তাদের সাথে","audioUrl":"wbw/057_025_006.mp3","charTypeName":"word"},{"id":27937,"position":7,"arabic":"ٱلْكِتَـٰبَ","translation":"কিতাব","audioUrl":"wbw/057_025_007.mp3","charTypeName":"word"},{"id":27938,"position":8,"arabic":"وَٱلْمِيزَانَ","translation":"ও ন্যায়দণ্ড","audioUrl":"wbw/057_025_008.mp3","charTypeName":"word"},{"id":27939,"position":9,"arabic":"لِيَقُومَ","translation":"প্রতিষ্ঠিত হয় যেন","audioUrl":"wbw/057_025_009.mp3","charTypeName":"word"},{"id":27940,"position":10,"arabic":"ٱلنَّاسُ","translation":"মানুষ","audioUrl":"wbw/057_025_010.mp3","charTypeName":"word"},{"id":27941,"position":11,"arabic":"بِٱلْقِسْطِ ۖ","translation":"ন্যায়বিচারের সাথে","audioUrl":"wbw/057_025_011.mp3","charTypeName":"word"},{"id":27943,"position":12,"arabic":"وَأَنزَلْنَا","translation":"ও আমরা অবতীর্ণ করেছি","audioUrl":"wbw/057_025_013.mp3","charTypeName":"word"},{"id":27944,"position":13,"arabic":"ٱلْحَدِيدَ","translation":"লোহা","audioUrl":"wbw/057_025_014.mp3","charTypeName":"word"},{"id":27945,"position":14,"arabic":"فِيهِ","translation":"যার মধ্যে রয়েছে","audioUrl":"wbw/057_025_015.mp3","charTypeName":"word"},{"id":27946,"position":15,"arabic":"بَأْسٌۭ","translation":"শক্তি","audioUrl":"wbw/057_025_016.mp3","charTypeName":"word"},{"id":27947,"position":16,"arabic":"شَدِيدٌۭ","translation":"প্রচণ্ড","audioUrl":"wbw/057_025_017.mp3","charTypeName":"word"},{"id":27948,"position":17,"arabic":"وَمَنَـٰفِعُ","translation":"এবং নানা উপকার","audioUrl":"wbw/057_025_018.mp3","charTypeName":"word"},{"id":27949,"position":18,"arabic":"لِلنَّاسِ","translation":"মানুষের জন্য","audioUrl":"wbw/057_025_019.mp3","charTypeName":"word"},{"id":27950,"position":19,"arabic":"وَلِيَعْلَمَ","translation":"এবং (এ উদ্দেশ্যে ) জানেন যেন","audioUrl":"wbw/057_025_020.mp3","charTypeName":"word"},{"id":27951,"position":20,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌","audioUrl":"wbw/057_025_021.mp3","charTypeName":"word"},{"id":27952,"position":21,"arabic":"مَن","translation":"কে","audioUrl":"wbw/057_025_022.mp3","charTypeName":"word"},{"id":27953,"position":22,"arabic":"يَنصُرُهُۥ","translation":"তাঁকে সাহায্য করে","audioUrl":"wbw/057_025_023.mp3","charTypeName":"word"},{"id":27954,"position":