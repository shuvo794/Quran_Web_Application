bic":"بِهِمْ ۚ","translation":"সম্বন্ধে তাদের\"","audioUrl":"wbw/018_021_026.mp3","charTypeName":"word"},{"id":23524,"position":25,"arabic":"قَالَ","translation":"বললো","audioUrl":"wbw/018_021_028.mp3","charTypeName":"word"},{"id":23525,"position":26,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/018_021_029.mp3","charTypeName":"word"},{"id":23526,"position":27,"arabic":"غَلَبُوا۟","translation":"প্রবল হয়েছিলো","audioUrl":"wbw/018_021_030.mp3","charTypeName":"word"},{"id":23527,"position":28,"arabic":"عَلَىٰٓ","translation":"উপর","audioUrl":"wbw/018_021_031.mp3","charTypeName":"word"},{"id":23528,"position":29,"arabic":"أَمْرِهِمْ","translation":"তাদের মতের","audioUrl":"wbw/018_021_032.mp3","charTypeName":"word"},{"id":23529,"position":30,"arabic":"لَنَتَّخِذَنَّ","translation":"\"অবশ্যই আমরা নির্মাণ করবো","audioUrl":"wbw/018_021_033.mp3","charTypeName":"word"},{"id":23530,"position":31,"arabic":"عَلَيْهِم","translation":"উপর তাদের","audioUrl":"wbw/018_021_034.mp3","charTypeName":"word"},{"id":23531,"position":32,"arabic":"مَّسْجِدًۭا","translation":"মাসজিদ\"","audioUrl":"wbw/018_021_035.mp3","charTypeName":"word"},{"id":23532,"position":33,"arabic":"٢١","translation":"(২১)","audioUrl":null,"charTypeName":"end"}]},{"number":22,"arabic":"سَيَقُولُونَ ثَلَٰثَةٌۭ رَّابِعُهُمْ كَلْبُهُمْ وَيَقُولُونَ خَمْسَةٌۭ سَادِسُهُمْ كَلْبُهُمْ رَجْمًۢا بِٱلْغَيْبِ ۖ وَيَقُولُونَ سَبْعَةٌۭ وَثَامِنُهُمْ كَلْبُهُمْ ۚ قُل رَّبِّىٓ أَعْلَمُ بِعِدَّتِهِم مَّا يَعْلَمُهُمْ إِلَّا قَلِيلٌۭ ۗ فَلَا تُمَارِ فِيهِمْ إِلَّا مِرَآءًۭ ظَٰهِرًۭا وَلَا تَسْتَفْتِ فِيهِم مِّنْهُمْ أَحَدًۭا","translation":"[And in times to come] some will say, \"[They were] three, the fourth of them being their dog,\" while others will say, \"Five, with their dog as the sixth of them\" -idly guessing at something of which they can have no knowledge -and [so on, until] some will say, \"[They were] seven, the eighth of them being their dog.\" Say: \"My Sustainer knows best how many they were. None but a few have any [real] knowledge of them. Hence, do not argue about them otherwise than by way of an obvious argument, and do not ask any of those [story-tellers] to enlighten thee about them.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2162.mp3","surahId":18,"words":[{"id":24531,"position":1,"arabic":"سَيَقُولُونَ","translation":"তারা শীঘ্রই বলবে","audioUrl":"wbw/018_022_001.mp3","charTypeName":"word"},{"id":24532,"position":2,"arabic":"ثَلَـٰثَةٌۭ","translation":"তিন (তাদের সংখ্যা)","audioUrl":"wbw/018_022_002.mp3","charTypeName":"word"},{"id":24533,"position":3,"arabic":"رَّابِعُهُمْ","translation":"চতুর্থটি (ছিলো) তাদের","audioUrl":"wbw/018_022_003.mp3","charTypeName":"word"},{"id":24534,"position":4,"arabic":"كَلْبُهُمْ","translation":"কুকুর তাদের","audioUrl":"wbw/018_022_004.mp3","charTypeName":"word"},{"id":24535,"position":5,"arabic":"وَيَقُولُونَ","translation":"এবং (কিছু লোক) বলবে","audioUrl":"wbw/018_022_005.mp3","charTypeName":"word"},{"id":24536,"position":6,"arabic":"خَمْسَةٌۭ","translation":"পাঁচ (জন)","audioUrl":"wbw/018_022_006.mp3","charTypeName":"word"},{"id":24537,"position":7,"arabic":"سَادِسُهُمْ","translation":"ষষ্ঠটি তাদের","audioUrl":"wbw/018_022_007.mp3","charTypeName":"word"},{"id":24538,"position":8,"arabic":"كَلْبُهُمْ","translation":"কুকুর তাদের","audioUrl":"wbw/018_022_008.mp3","charTypeName":"word"},{"id":24539,"position":9,"arabic":"رَجْمًۢا","translation":"আনুমানিক (কথা)","audioUrl":"wbw/018_022_009.mp3","charTypeName":"word"},{"id":24540,"position":10,"arabic":"بِٱلْغَيْبِ ۖ","translation":"বিষয়ে অজানা","audioUrl":"wbw/018_022_010.mp3","charTypeName":"word"},{"id":24542,"position":11,"arabic":"وَيَقُولُونَ","translation":"এবং (কিছু লোক) বলবে","audioUrl":"wbw/018_022_012.mp3","charTypeName":"word"},{"id":24543,"position":12,"arabic":"سَبْعَةٌۭ","translation":"সাত (তাদের সংখ্যা)","audioUrl":"wbw/018_022_013.mp3","charTypeName":"word"},{"id":24544,"position":13,"arabic":"وَثَامِنُهُمْ","translation":"এবং অষ্টমটি তাদের","audioUrl":"wbw/018_022_014.mp3","charTypeName":"word"},{"id":24545,"position":14,"arabic":"كَلْبُهُمْ ۚ","translation":"কুকুর তাদের","audioUrl":"wbw/018_022_015.mp3","charTypeName":"word"},{"id":24547,"position":15,"arabic":"قُل","translation":"বলো","audioUrl":"wbw/018_022_017.mp3","charTypeName":"word"},{"id":24548,"position":16,"arabic":"رَّبِّىٓ","translation":"\"আমার রব","audioUrl":"wbw/018_022_018.mp3","charTypeName":"word"},{"id":24549,"position":17,"arabic":"أَعْلَمُ","translation":"ভালো জানেন","audioUrl":"wbw/018_022_019.mp3","charTypeName":"word"},{"id":24550,"position":18,"arabic":"بِعِدَّتِهِم","translation":"সম্পর্কে তাদের সংখ্যা","audioUrl":"wbw/018_022_020.mp3","charTypeName":"word"},{"id":24551,"position":19,"arabic":"مَّا","translation":"না","audioUrl":"wbw/018_022_021.mp3","charTypeName":"word"},{"id":24552,"position":20,"arabic":"يَعْلَمُهُمْ","translation":"জানে তাদের","audioUrl":"wbw/018_022_022.mp3","charTypeName":"word"},{"id":24553,"position":21,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/018_022_023.mp3","charTypeName":"word"},{"id":24554,"position":22,"arabic":"قَلِيلٌۭ ۗ","translation":"অল্প (লোক)","audioUrl":"wbw/018_022_024.mp3","charTypeName":"word"},{"id":24556,"position":23,"arabic":"فَلَا","translation":"অতএব","audioUrl":"wbw/018_022_026.mp3","charTypeName":"word"},{"id":24557,"position":24,"arabic":"تُمَارِ","translation":"বিতর্ক করো না","audioUrl":"wbw/018_022_027.mp3","charTypeName":"word"},{"id":24558,"position":25,"arabic":"فِيهِمْ","translation":"বিষয়ে তাদের","audioUrl":"wbw/018_022_028.mp3","charTypeName":"word"},{"id":24559,"position":26,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/018_022_029.mp3","charTypeName":"word"},{"id":24560,"position":27,"arabic":"مِرَآءًۭ","translation":"আলোচনা","audioUrl":"wbw/018_022_030.mp3","charTypeName":"word"},{"id":24561,"position":28,"arabic":"ظَـٰهِرًۭا","translation":"মামুলি","audioUrl":"wbw/018_022_031.mp3","charTypeName":"word"},{"id":24562,"position":29,"arab