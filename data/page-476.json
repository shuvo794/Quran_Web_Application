me":"word"},{"id":63782,"position":5,"arabic":"ٱلْأَنْعَـٰمَ","translation":"গবাদি পশুগুলো","audioUrl":"wbw/040_079_005.mp3","charTypeName":"word"},{"id":63783,"position":6,"arabic":"لِتَرْكَبُوا۟","translation":"তোমরা আরোহণ করতে পারো যেন","audioUrl":"wbw/040_079_006.mp3","charTypeName":"word"},{"id":63784,"position":7,"arabic":"مِنْهَا","translation":"তার মধ্যে হ'তে (কোনটির উপর)","audioUrl":"wbw/040_079_007.mp3","charTypeName":"word"},{"id":63785,"position":8,"arabic":"وَمِنْهَا","translation":"এবং তার মধ্যে হ'তে","audioUrl":"wbw/040_079_008.mp3","charTypeName":"word"},{"id":63786,"position":9,"arabic":"تَأْكُلُونَ","translation":"তোমরা খাও (কোনটির গোশত)","audioUrl":"wbw/040_079_009.mp3","charTypeName":"word"},{"id":63787,"position":10,"arabic":"٧٩","translation":"(৭৯)","audioUrl":null,"charTypeName":"end"}]},{"number":80,"arabic":"وَلَكُمْ فِيهَا مَنَٰفِعُ وَلِتَبْلُغُوا۟ عَلَيْهَا حَاجَةًۭ فِى صُدُورِكُمْ وَعَلَيْهَا وَعَلَى ٱلْفُلْكِ تُحْمَلُونَ","translation":"and find [yet other] benefits in them; and that through them you may attain to the fulfillment of [many] a heartfelt need: for on them, as on ships, you are borne [through life].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4213.mp3","surahId":40,"words":[{"id":64209,"position":1,"arabic":"وَلَكُمْ","translation":"এবং তোমাদের জন্যে","audioUrl":"wbw/040_080_001.mp3","charTypeName":"word"},{"id":64210,"position":2,"arabic":"فِيهَا","translation":"তার মধ্যে (রয়েছে)","audioUrl":"wbw/040_080_002.mp3","charTypeName":"word"},{"id":64211,"position":3,"arabic":"مَنَـٰفِعُ","translation":"(অনেক) উপকার","audioUrl":"wbw/040_080_003.mp3","charTypeName":"word"},{"id":64212,"position":4,"arabic":"وَلِتَبْلُغُوا۟","translation":"এবং তোমরা মেটাতে পারো যেন","audioUrl":"wbw/040_080_004.mp3","charTypeName":"word"},{"id":64213,"position":5,"arabic":"عَلَيْهَا","translation":"তার সাহায্যে","audioUrl":"wbw/040_080_005.mp3","charTypeName":"word"},{"id":64214,"position":6,"arabic":"حَاجَةًۭ","translation":"প্