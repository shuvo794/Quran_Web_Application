:"wbw/040_081_006.mp3","charTypeName":"word"},{"id":64731,"position":7,"arabic":"٨١","translation":"(৮১)","audioUrl":null,"charTypeName":"end"}]},{"number":82,"arabic":"أَفَلَمْ يَسِيرُوا۟ فِى ٱلْأَرْضِ فَيَنظُرُوا۟ كَيْفَ كَانَ عَٰقِبَةُ ٱلَّذِينَ مِن قَبْلِهِمْ ۚ كَانُوٓا۟ أَكْثَرَ مِنْهُمْ وَأَشَدَّ قُوَّةًۭ وَءَاثَارًۭا فِى ٱلْأَرْضِ فَمَآ أَغْنَىٰ عَنْهُم مَّا كَانُوا۟ يَكْسِبُونَ","translation":"HAVE THEY, then, never journeyed about the earth and beheld what happened in the end to those [deniers of the truth] who lived before their time? More numerous were they, and greater in power than they are, and in the impact which they left on earth: but all that they ever achieved was of no avail to them –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4215.mp3","surahId":40,"words":[{"id":65070,"position":1,"arabic":"أَفَلَمْ","translation":"নি তবে কি","audioUrl":"wbw/040_082_001.mp3","charTypeName":"word"},{"id":65071,"position":2,"arabic":"يَسِيرُوا۟","translation":"তারা ভ্রমণ করে","audioUrl":"wbw/040_082_002.mp3","charTypeName":"word"},{"id":65072,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/040_082_003.mp3","charTypeName":"word"},{"id":65073,"position":4,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/040_082_004.mp3","charTypeName":"word"},{"id":65074,"position":5,"arabic":"فَيَنظُرُوا۟","translation":"তারা অতঃপর দেখে (নি কি)","audioUrl":"wbw/040_082_005.mp3","charTypeName":"word"},{"id":65075,"position":6,"arabic":"كَيْفَ","translation":"কেমন","audioUrl":"wbw/040_082_006.mp3","charTypeName":"word"},{"id":65076,"position":7,"arabic":"كَانَ","translation":"ছিলো","audioUrl":"wbw/040_082_007.mp3","charTypeName":"word"},{"id":65077,"position":8,"arabic":"عَـٰقِبَةُ","translation":"পরিণতি","audioUrl":"wbw/040_082_008.mp3","charTypeName":"word"},{"id":65078,"position":9,"arabic":"ٱلَّذِينَ","translation":"(তাদের) যারা","audioUrl":"wbw/040_082_009.mp3","charTypeName":"word"},{"id":65079,"position":10,"arabic":"مِن","translation":"মধ্য হতে","audioUrl":"wbw/040_082_010.mp3","charTypeName":"word"},{"id":65080,"position":11,"arabic":"قَبْلِهِمْ ۚ","translation":"তাদের পূর্বে (ছিলো)","audioUrl":"wbw/040_082_011.mp3","charTypeName":"word"},{"id":65082,"position":12,"arabic":"كَانُوٓا۟","translation":"তারা ছিলো","audioUrl":"wbw/040_082_013.mp3","charTypeName":"word"},{"id":65083,"position":13,"arabic":"أَكْثَرَ","translation":"(সংখ্যায়) বেশী","audioUrl":"wbw/040_082_014.mp3","charTypeName":"word"},{"id":65084,"position":14,"arabic":"مِنْهُمْ","translation":"এদের চেয়েও","audioUrl":"wbw/040_082_015.mp3","charTypeName":"word"},{"id":65085,"position":15,"arabic":"وَأَشَدَّ","translation":"ও প্রবল","audioUrl":"wbw/040_082_016.mp3","charTypeName":"word"},{"id":65086,"position":16,"arabic":"قُوَّةًۭ","translation":"শক্তিতে","audioUrl":"wbw/040_082_017.mp3","charTypeName":"word"},{"id":65087,"position":17,"arabic":"وَءَاثَارًۭا","translation":"ও কীর্তিতে","audioUrl":"wbw/040_082_018.mp3","charTypeName":"word"},{"id":65088,"position":18,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/040_082_019.mp3","charTypeName":"word"},{"id":65089,"position":19,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/040_082_020.mp3","charTypeName":"word"},{"id":65090,"position":20,"arabic":"فَمَآ","translation":"অতঃপর না","audioUrl":"wbw/040_082_021.mp3","charTypeName":"word"},{"id":65091,"position":21,"arabic":"أَغْنَىٰ","translation":"কাজে আসলো","audioUrl":"wbw/040_082_022.mp3","charTypeName":"word"},{"id":65092,"position":22,"arabic":"عَنْهُم","translation":"তাদের জন্যে","audioUrl":"wbw/040_082_023.mp3","charTypeName":"word"},{"id":65093,"position":23,"arabic":"مَّا","translation":"যা","audioUrl":"wbw/040_082_024.mp3","charTypeName":"word"},{"id":65094,"position":24,"arabic":"كَانُوا۟","translation":"তারা","audioUrl":"wbw/040_082_025.mp3","charTypeName":"word"},{"id":65095,"position":25,"arabic":"يَكْسِبُونَ","translation":"অর্জন করেছিলো","audioUrl":"wbw/040_082_026.mp3","charTypeName":"word"},{"id":65096,"position":26,"arabic":"٨٢","translation":"(৮২)","audioUrl":null,"charTypeName":"end"}]},{"number":83,"arabic":"فَلَمَّا جَآءَتْهُمْ رُسُلُهُم بِٱلْبَيِّنَٰتِ فَرِحُوا۟ بِمَا عِندَهُم مِّنَ ٱلْعِلْمِ وَحَاقَ بِهِم مَّا كَانُوا۟ بِهِۦ يَسْتَهْزِءُونَ","translation":"for when their apostles came to them with all evidence of the truth, they arrogantly exulted in whatever knowledge they [already] possessed: and [so, in the end,] they were overwhelmed by the very thing which they were wont to deride.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4216.mp3","surahId":40,"words":[{"id":65337,"position":1,"arabic":"فَلَمَّا","translation":"অতঃপর যখন","audioUrl":"wbw/040_083_001.mp3","charTypeName":"word"},{"id":65338,"position":2,"arabic":"جَآءَتْهُمْ","translation":"তাদের কাছে আসলো","audioUrl":"wbw/040_083_002.mp3","charTypeName":"word"},{"id":65339,"position":3,"arabic":"رُسُلُهُم","translation":"তাদের রাসূলগণ","audioUrl":"wbw/040_083_003.mp3","charTypeName":"word"},{"id":65340,"position":4,"arabic":"بِٱلْبَيِّنَـٰتِ","translation":"সুস্পষ্ট প্রমাণসহ","audioUrl":"wbw/040_083_004.mp3","charTypeName":"word"},{"id":65341,"position":5,"arabic":"فَرِحُوا۟","translation":"তারা খুশীতে মগ্ন রইলো","audioUrl":"wbw/040_083_005.mp3","charTypeName":"word"},{"id":65342,"position":6,"arabic":"بِمَا","translation":"ঐ বিষয়ে যা (ছিলো)","audioUrl":"wbw/040_083_006.mp3","charTypeName":"word"},{"id":65343,"position":7,"arabic":"عِندَهُم","translation":"তাদের কাছে","audioUrl":"wbw/040_083_007.mp3","charTypeName":"word"},{"id":65344,"position":8,"arabic":"مِّنَ","translation":"অংশ বিশেষ","audioUrl":"wbw/040_083_008.mp3","charTypeName":"word"},{"id":65345,"position":9,"arabic":"ٱلْعِلْمِ","translation":"(নিজস্ব) জ্ঞানের","audioUrl":"wbw/040_083_009.mp3","charTypeName":"word"},{"id":65346,"position":10,"arabic":"وَحَاقَ","translation":"এবং ঘিরে ফেললো","audioUrl":"wbw/040_083_010.mp3","charTypeName":"word"},{"id":65347,"position":11,"arabic":"بِهِم","translation":"তাদেরকে","audioUrl":"wbw/040_083_011.mp3","charTypeName":"word"},{"id":65348,"position":12,"arabic":"مَّا","translation":"তাই","audioUrl":"wbw/040_083_012.mp3","charTypeName":"word"},{"id":65349,"position":13,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/040_083_013.mp3","charTypeName":"word"},{"id":65350,"position":14,"arabic":"بِهِۦ","translation":"যে সম্পর্কে","audioUrl":"wbw/040_083_014.mp3","charTypeName":"word"},{"id":65351,"position":15,"arabic":"يَسْتَهْزِءُونَ","translation":"ঠাট্টা-বিদ্রুপ করতো","audioUrl":"wbw/040_083_015.mp3","charTypeName":"word"},{"id":65352,"position":16,"arabic":"٨٣","translation":"(৮৩)","audioUrl":null,"charTypeName":"end"}]},{"number":84,"arabic":"فَلَمَّا رَأَوْا۟ بَأْسَنَا قَالُوٓا۟ ءَامَنَّا بِٱللَّهِ وَحْدَهُۥ وَكَفَرْنَا بِمَا كُنَّا بِهِۦ مُشْرِكِينَ","translation":"And then, when they [clearly] beheld Our punishment, they said: “We have come to believe in the One God, and we have renounced all belief in that to which we were wont to ascribe a share in His divinity!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4217.mp3","surahId":40,"words":[{"id":65621,"position":1,"arabic":"فَلَمَّا","translation":"অতঃপর যখন","audioUrl":"wbw/040_084_001.mp3","charTypeName":"word"},{"id":65622,"position":2,"arabic":"رَأَوْا۟","translation":"তারা দেখলো","audioUrl":"wbw/040_084_002.mp3","charTypeName":"word"},{"id":65623,"position":3,"arabic":"بَأْسَنَا","translation":"আমাদের শাস্তি","audioUrl":"wbw/040_084_003.mp3","charTypeName":"word"},{"id":65624,"position":4,"arabic":"قَالُوٓا۟","translation":"তারা বললো","audioUrl":"wbw/040_084_004.mp3","charTypeName":"word"},{"id":65625,"position":5,"arabic":"ءَامَنَّا","translation":"\"আমরা ঈমান এনেছি","audioUrl":"wbw/040_084_005.mp3","charTypeName":"word"},{"id":65626,"position":6,"arabic":"بِٱللَّهِ","translation":"আল্লাহর উপর","audioUrl":"wbw/040_084_006.mp3","charTypeName":"word"},{"id":65627,"position":7,"arabic":"وَحْدَهُۥ","translation":"তাঁর একারই","audioUrl":"wbw/040_084_007.mp3","charTypeName":"word"},{"id":65628,"position":8,"arabic":"وَكَفَرْنَا","translation":"এবং আমরা অস্বীকার করছি","audioUrl":"wbw/040_084_008.mp3","charTypeName":"word"},{"id":65629,"position":9,"arabic":"بِمَا","translation":"তা সবকে","audioUrl":"wbw/040_084_009.mp3","charTypeName":"word"},{"id":65630,"position":10,"arabic":"كُنَّا","translation":"আমরা ছিলাম","audioUrl":"wbw/040_084_010.mp3","charTypeName":"word"},{"id":65631,"position":11,"arabic":"بِهِۦ","translation":"যার সাথে","audioUrl":"wbw/040_084_011.mp3","charTypeName":"word"},{"id":65632,"position":12,"arabic":"مُشْرِكِينَ","translation":"শরিককারী\"","audioUrl":"wbw/040_084_012.mp3","charTypeName":"word"},{"id":65633,"position":13,"arabic":"٨٤","translation":"(৮৪)","audioUrl":null,"charTypeName":"end"}]},{"number":85,"arabic":"فَلَمْ يَكُ يَنفَعُهُمْ إِيمَٰنُهُمْ لَمَّا رَأَوْا۟ بَأْسَنَا ۖ سُنَّتَ ٱللَّهِ ٱلَّتِى قَدْ خَلَتْ فِى عِبَادِهِۦ ۖ وَخَسِرَ هُنَالِكَ ٱلْكَٰفِرُونَ","translation":"But their attaining to faith after they had beheld Our punishment could not possibly benefit them such being the way of God that has always obtained for His creatures -: and so, then and there, lost were they who had denied the truth.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4218.mp3","surahId":40,"words":[{"id":66101,"position":1,"arabic":"فَلَمْ","translation":"অতঃপর","audioUrl":"wbw/040_085_001.mp3","charTypeName":"word"},{"id":66102,"position":2,"arabic":"يَكُ","translation":"পারে নি","audioUrl":"wbw/040_085_002.mp3","charTypeName":"word"},{"id":66103,"position":3,"arabic":"يَنفَعُهُمْ","translation":"তাদের উপকার করতে","audioUrl":"wbw/040_085_003.mp3","charTypeName":"word"},{"id":66104,"position":4,"arabic":"إِيمَـٰنُهُمْ","translation":"তাদের ঈমান","audioUrl":"wbw/040_085_004.mp3","charTypeName":"word"},{"id":66105,"position":5,"arabic":"لَمَّا","translation":"যখন","audioUrl":"wbw/040_085_005.mp3","charTypeName":"word"},{"id":66106,"position":6,"arabic":"رَأَوْا۟","translation":"তারা দেখলো","audioUrl":"wbw/040_085_006.mp3","charTypeName":"word"},{"id":66107,"position":7,"arabic":"بَأْسَنَا ۖ","translation":"আমাদের শাস্তি","audioUrl":"wbw/040_085_007.mp3","charTypeName":"word"},{"id":66109,"position":8,"arabic":"سُنَّتَ","translation":"বিধান","audioUrl":"wbw/040_085_009.mp3","charTypeName":"word"},{"id":66110,"position":9,"arabic":"ٱللَّهِ","translation":"আল্লাহর (নির্ধারিত)","audioUrl":"wbw/040_085_010.mp3","charTypeName":"word"},{"id":66111,"position":10,"arabic":"ٱلَّتِى","translation":"যা","audioUrl":"wbw/040_085_011.mp3","charTypeName":"word"},{"id":66112,"position":11,"arabic":"قَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/040_085_012.mp3","charTypeName":"word"},{"id":66113,"position":12,"arabic":"خَلَتْ","translation":"(চলে এসেছে)অতীত হয়েছে","audioUrl":"wbw/040_085_013.mp3","charTypeName":"word"},{"id":66114,"position":13,"arabic":"فِى","translation":"ব্যাপারে","audioUrl":"wbw/040_085_014.mp3","charTypeName":"word"},{"id":66115,"position":14,"arabic":"عِبَادِهِۦ ۖ","translation":"তাঁর দাসদের","audioUrl":"wbw/040_085_015.mp3","charTypeName":"word"},{"id":66117,"position":15,"arabic":"وَخَسِرَ","translation":"এবং ক্ষতিগ্রস্ত হয়েছে","audioUrl":"wbw/040_085_017.mp3","charTypeName":"word"},{"id":66118,"position":16,"arabic":"هُنَالِكَ","translation":"এমন অবস্হায়","audioUrl":"wbw/040_085_018.mp3","charTypeName":"word"},{"id":66119,"position":17,"arabic":"ٱلْكَـٰفِرُونَ","translation":"কাফেররা","audioUrl":"wbw/040_085_019.mp3","charTypeName":"word"},{"id":66120,"position":18,"arabic":"٨٥","translation":"(৮৫)","audioUrl":null,"charTypeName":"end"}]}]}