{"id":476,"ayahs":[{"number":78,"arabic":"وَلَقَدْ أَرْسَلْنَا رُسُلًۭا مِّن قَبْلِكَ مِنْهُم مَّن قَصَصْنَا عَلَيْكَ وَمِنْهُم مَّن لَّمْ نَقْصُصْ عَلَيْكَ ۗ وَمَا كَانَ لِرَسُولٍ أَن يَأْتِىَ بِـَٔايَةٍ إِلَّا بِإِذْنِ ٱللَّهِ ۚ فَإِذَا جَآءَ أَمْرُ ٱللَّهِ قُضِىَ بِٱلْحَقِّ وَخَسِرَ هُنَالِكَ ٱلْمُبْطِلُونَ","translation":"And, indeed, [O Muhammad,] We sent forth apostles before thy time; some of them We have mentioned to thee, and some of them We have not mentioned to thee. And it was not given to any apostle to bring forth a miracle other than by God’s leave. Yet when God’s will becomes manifest, judgment will [already] have been passed in all justice, and lost will be, then and there, all who tried to reduce to nothing [whatever they could not understand].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4211.mp3","surahId":40,"words":[{"id":63440,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/040_078_001.mp3","charTypeName":"word"},{"id":63441,"position":2,"arabic":"أَرْسَلْنَا","translation":"আমরা পাঠিয়েছি","audioUrl":"wbw/040_078_002.mp3","charTypeName":"word"},{"id":63442,"position":3,"arabic":"رُسُلًۭا","translation":"(অনেক) রাসূলকে","audioUrl":"wbw/040_078_003.mp3","charTypeName":"word"},{"id":63443,"position":4,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/040_078_004.mp3","charTypeName":"word"},{"id":63444,"position":5,"arabic":"قَبْلِكَ","translation":"তোমার পূর্বে","audioUrl":"wbw/040_078_005.mp3","charTypeName":"word"},{"id":63445,"position":6,"arabic":"مِنْهُم","translation":"তাদের মধ্যে","audioUrl":"wbw/040_078_006.mp3","charTypeName":"word"},{"id":63446,"position":7,"arabic":"مَّن","translation":"কারও (অবস্থা)","audioUrl":"wbw/040_078_007.mp3","charTypeName":"word"},{"id":63447,"position":8,"arabic":"قَصَصْنَا","translation":"আমরা বর্ণনা করেছি","audioUrl":"wbw/040_078_008.mp3","charTypeName":"word"},{"id":63448,"position":9,"arabic":"عَلَيْكَ","translation":"তোমার কাছে","audioUrl":"wbw/040_078_009.mp3","charTypeName":"word"},{"id":63449,"position":10,"arabic":"وَمِنْهُم","translation":"আবার তাদের মধ্যে","audioUrl":"wbw/040_078_010.mp3","charTypeName":"word"},{"id":63450,"position":11,"arabic":"مَّن","translation":"কারও (অবস্থা)","audioUrl":"wbw/040_078_011.mp3","charTypeName":"word"},{"id":63451,"position":12,"arabic":"لَّمْ","translation":"নি","audioUrl":"wbw/040_078_012.mp3","charTypeName":"word"},{"id":63452,"position":13,"arabic":"نَقْصُصْ","translation":"আমরা বর্ণনা করি","audioUrl":"wbw/040_078_013.mp3","charTypeName":"word"},{"id":63453,"position":14,"arabic":"عَلَيْكَ ۗ","translation":"তোমার কাছে","audioUrl":"wbw/040_078_014.mp3","charTypeName":"word"},{"id":63455,"position":15,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/040_078_016.mp3","charTypeName":"word"},{"id":63456,"position":16,"arabic":"كَانَ","translation":"(সম্ভব) ছিলো","audioUrl":"wbw/040_078_017.mp3","charTypeName":"word"},{"id":63457,"position":17,"arabic":"لِرَسُولٍ","translation":"কোনো রাসূলের জন্যে","audioUrl":"wbw/040_078_018.mp3","charTypeName":"word"},{"id":63458,"position":18,"arabic":"أَن","translation":"যে","audioUrl":"wbw/040_078_019.mp3","charTypeName":"word"},{"id":63459,"position":19,"arabic":"يَأْتِىَ","translation":"আসবে","audioUrl":"wbw/040_078_020.mp3","charTypeName":"word"},{"id":63460,"position":20,"arabic":"بِـَٔايَةٍ","translation":"নিয়ে কোন নিদর্শন","audioUrl":"wbw/040_078_021.mp3","charTypeName":"word"},{"id":63461,"position":21,"arabic":"إِلَّا","translation":"ব্যতীত","audioUrl":"wbw/040_078_022.mp3","charTypeName":"word"},{"id":63462,"position":22,"arabic":"بِإِذْنِ","translation":"অনুমতি","audioUrl":"wbw/040_078_023.mp3","charTypeName":"word"},{"id":63463,"position":23,"arabic":"ٱللَّهِ ۚ","translation":"আল্লাহর","audioUrl":"wbw/040_078_024.mp3","charTypeName":"word"},{"id":63465,"position":24,"arabic":"فَإِذَا","translation":"অতঃপর যখন","audioUrl":"wbw/040_078_026.mp3","charTypeName":"word"},{"id":63466,"position":25,"arabic":"جَآءَ","translat