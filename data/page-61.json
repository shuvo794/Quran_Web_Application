{"id":61,"ayahs":[{"number":84,"arabic":"قُلْ ءَامَنَّا بِٱللَّهِ وَمَآ أُنزِلَ عَلَيْنَا وَمَآ أُنزِلَ عَلَىٰٓ إِبْرَٰهِيمَ وَإِسْمَٰعِيلَ وَإِسْحَٰقَ وَيَعْقُوبَ وَٱلْأَسْبَاطِ وَمَآ أُوتِىَ مُوسَىٰ وَعِيسَىٰ وَٱلنَّبِيُّونَ مِن رَّبِّهِمْ لَا نُفَرِّقُ بَيْنَ أَحَدٍۢ مِّنْهُمْ وَنَحْنُ لَهُۥ مُسْلِمُونَ","translation":"Say: \"We believe in God, and in that which has been bestowed from on high upon us, and that which has been bestowed upon Abraham and Ishmael and Isaac and Jacob and their descendants, and that which has been vouchsafed by their Sustainer unto Moses and Jesus and all the [other] prophets: we make no distinction between any of them. And unto Him do we surrender ourselves.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/377.mp3","surahId":3,"words":[{"id":65750,"position":1,"arabic":"قُلْ","translation":"তুমি বল","audioUrl":"wbw/003_084_001.mp3","charTypeName":"word"},{"id":65751,"position":2,"arabic":"ءَامَنَّا","translation":"''আমরা ঈমান এনেছি","audioUrl":"wbw/003_084_002.mp3","charTypeName":"word"},{"id":65752,"position":3,"arabic":"بِٱللَّهِ","translation":"আল্লাহর উপর","audioUrl":"wbw/003_084_003.mp3","charTypeName":"word"},{"id":65753,"position":4,"arabic":"وَمَآ","translation":"ও যা কিছু","audioUrl":"wbw/003_084_004.mp3","charTypeName":"word"},{"id":65754,"position":5,"arabic":"أُنزِلَ","translation":"নাযিল করা হয়েছে","audioUrl":"wbw/003_084_005.mp3","charTypeName":"word"},{"id":65755,"position":6,"arabic":"عَلَيْنَا","translation":"আমাদের উপর","audioUrl":"wbw/003_084_006.mp3","charTypeName":"word"},{"id":65756,"position":7,"arabic":"وَمَآ","translation":"ও যা কিছু","audioUrl":"wbw/003_084_007.mp3","charTypeName":"word"},{"id":65757,"position":8,"arabic":"أُنزِلَ","translation":"নাযিল করা হয়েছে","audioUrl":"wbw/003_084_008.mp3","charTypeName":"word"},{"id":65758,"position":9,"arabic":"عَلَىٰٓ","translation":"উপর","audioUrl":"wbw/003_084_009.mp3","charTypeName":"word"},{"id":65759,"position":10,"arabic":"إِبْرَٰهِيمَ","t