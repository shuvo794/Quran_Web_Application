,"charTypeName":"word"},{"id":65775,"position":26,"arabic":"مِّنْهُمْ","translation":"তাদের মধ্যকার","audioUrl":"wbw/003_084_026.mp3","charTypeName":"word"},{"id":65776,"position":27,"arabic":"وَنَحْنُ","translation":"আর আমরা","audioUrl":"wbw/003_084_027.mp3","charTypeName":"word"},{"id":65777,"position":28,"arabic":"لَهُۥ","translation":"তারই কাছে","audioUrl":"wbw/003_084_028.mp3","charTypeName":"word"},{"id":65778,"position":29,"arabic":"مُسْلِمُونَ","translation":"আত্মসমর্পণকারী (অর্থাৎ মুসলমান)","audioUrl":"wbw/003_084_029.mp3","charTypeName":"word"},{"id":65779,"position":30,"arabic":"٨٤","translation":"(৮৪)","audioUrl":null,"charTypeName":"end"}]},{"number":85,"arabic":"وَمَن يَبْتَغِ غَيْرَ ٱلْإِسْلَٰمِ دِينًۭا فَلَن يُقْبَلَ مِنْهُ وَهُوَ فِى ٱلْءَاخِرَةِ مِنَ ٱلْخَٰسِرِينَ","translation":"For, if one goes in search of a religion other than self-surrender unto God, it will never be accepted from him, and in the life to come he shall be among the lost.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/378.mp3","surahId":3,"words":[{"id":66200,"position":1,"arabic":"وَمَن","translation":"এবং যে কেউ","audioUrl":"wbw/003_085_001.mp3","charTypeName":"word"},{"id":66201,"position":2,"arabic":"يَبْتَغِ","translation":"গ্রহণ করতে চায়","audioUrl":"wbw/003_085_002.mp3","charTypeName":"word"},{"id":66202,"position":3,"arabic":"غَيْرَ","translation":"ব্যতীত","audioUrl":"wbw/003_085_003.mp3","charTypeName":"word"},{"id":66203,"position":4,"arabic":"ٱلْإِسْلَـٰمِ","translation":"ইসলাম","audioUrl":"wbw/003_085_004.mp3","charTypeName":"word"},{"id":66204,"position":5,"arabic":"دِينًۭا","translation":"(অন্যকোন) দ্বীন","audioUrl":"wbw/003_085_005.mp3","charTypeName":"word"},{"id":66205,"position":6,"arabic":"فَلَن","translation":"তা কক্ষণ না","audioUrl":"wbw/003_085_006.mp3","charTypeName":"word"},{"id":66206,"position":7,"arabic":"يُقْبَلَ","translation":"কবুল করা হবে","audioUrl":"wbw/003_085_007.mp3","charTypeName":"word"},{"id":66207,"position":8,"arabic":"مِنْهُ","translation":"তার থেকে","audioUrl":"wbw/003_085_008.mp3","charTypeName":"word"},{"id":66208,"position":9,"arabic":"وَهُوَ","translation":"এবং সে (হবে)","audioUrl":"wbw/003_085_009.mp3","charTypeName":"word"},{"id":66209,"position":10,"arabic":"فِى","translation":"(মধ্যে)","audioUrl":"wbw/003_085_010.mp3","charTypeName":"word"},{"id":66210,"position":11,"arabic":"ٱلْـَٔاخِرَةِ","translation":"আখেরাতে","audioUrl":"wbw/003_085_011.mp3","charTypeName":"word"},{"id":66211,"position":12,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/003_085_012.mp3","charTypeName":"word"},{"id":66212,"position":13,"arabic":"ٱلْخَـٰسِرِينَ","translation":"ক্ষতিগ্রস্থদের","audioUrl":"wbw/003_085_013.mp3","charTypeName":"word"},{"id":66213,"position":14,"arabic":"٨٥","translation":"(৮৫)","audioUrl":null,"charTypeName":"end"}]},{"number":86,"arabic":"كَيْفَ يَهْدِى ٱللَّهُ قَوْمًۭا كَفَرُوا۟ بَعْدَ إِيمَٰنِهِمْ وَشَهِدُوٓا۟ أَنَّ ٱلرَّسُولَ حَقٌّۭ وَجَآءَهُمُ ٱلْبَيِّنَٰتُ ۚ وَٱللَّهُ لَا يَهْدِى ٱلْقَوْمَ ٱلظَّٰلِمِينَ","translation":"How would God bestow His guidance upon people who have resolved to deny the truth after having attained to faith, and having borne witness that this Apostle is true, and [after] all evidence of the truth has come unto them? For, God does not guide such evildoing folk.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/379.mp3","surahId":3,"words":[{"id":66573,"position":1,"arabic":"كَيْفَ","translation":"কিরূপে","audioUrl":"wbw/003_086_001.mp3","charTypeName":"word"},{"id":66574,"position":2,"arabic":"يَهْدِى","translation":"হেদায়াত দিবেন","audioUrl":"wbw/003_086_002.mp3","charTypeName":"word"},{"id":66575,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/003_086_003.mp3","charTypeName":"word"},{"id":66576,"position":4,"arabic":"قَوْمًۭا","translation":"কোন সম্প্রদায়কে","audioUrl":"wbw/003_086_004.mp3","charTypeName":"word"},{"id":66577,"position":5,"arabic":"كَفَرُوا۟","translation":"(যারা) কুফরী করল","a