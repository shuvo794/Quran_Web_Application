,"position":6,"arabic":"ذَٰلِكَ","translation":"এর","audioUrl":"wbw/003_089_006.mp3","charTypeName":"word"},{"id":67731,"position":7,"arabic":"وَأَصْلَحُوا۟","translation":"ও তারা সংশোধন করেছে (নিজেদেরকে)","audioUrl":"wbw/003_089_007.mp3","charTypeName":"word"},{"id":67732,"position":8,"arabic":"فَإِنَّ","translation":"তখন নিশ্চয়","audioUrl":"wbw/003_089_008.mp3","charTypeName":"word"},{"id":67733,"position":9,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/003_089_009.mp3","charTypeName":"word"},{"id":67734,"position":10,"arabic":"غَفُورٌۭ","translation":"বড় ক্ষমাশীল","audioUrl":"wbw/003_089_010.mp3","charTypeName":"word"},{"id":67735,"position":11,"arabic":"رَّحِيمٌ","translation":"মেহেরবান","audioUrl":"wbw/003_089_011.mp3","charTypeName":"word"},{"id":67736,"position":12,"arabic":"٨٩","translation":"(৮৯)","audioUrl":null,"charTypeName":"end"}]},{"number":90,"arabic":"إِنَّ ٱلَّذِينَ كَفَرُوا۟ بَعْدَ إِيمَٰنِهِمْ ثُمَّ ٱزْدَادُوا۟ كُفْرًۭا لَّن تُقْبَلَ تَوْبَتُهُمْ وَأُو۟لَٰٓئِكَ هُمُ ٱلضَّآلُّونَ","translation":"Verily, as for those who are bent on denying the truth after having attained to faith, and then grow [ever more stubborn] in their refusal to acknowledge the truth, their repentance [of other sins] shall not be accepted: for it is they who have truly gone astray.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/383.mp3","surahId":3,"words":[{"id":68042,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়","audioUrl":"wbw/003_090_001.mp3","charTypeName":"word"},{"id":68043,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/003_090_002.mp3","charTypeName":"word"},{"id":68044,"position":3,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/003_090_003.mp3","charTypeName":"word"},{"id":68045,"position":4,"arabic":"بَعْدَ","translation":"পরে","audioUrl":"wbw/003_090_004.mp3","charTypeName":"word"},{"id":68046,"position":5,"arabic":"إِيمَـٰنِهِمْ","translation":"তাদের ঈমানের","audioUrl":"wbw/003_090