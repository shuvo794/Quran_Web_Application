{"id":122,"ayahs":[{"number":83,"arabic":"وَإِذَا سَمِعُوا۟ مَآ أُنزِلَ إِلَى ٱلرَّسُولِ تَرَىٰٓ أَعْيُنَهُمْ تَفِيضُ مِنَ ٱلدَّمْعِ مِمَّا عَرَفُوا۟ مِنَ ٱلْحَقِّ ۖ يَقُولُونَ رَبَّنَآ ءَامَنَّا فَٱكْتُبْنَا مَعَ ٱلشَّٰهِدِينَ","translation":"For, when they come to understand what has been bestowed from on high upon this Apostle, thou canst see their eyes overflow with tears, because they recognize something of its truth; [and] they say: \"O our Sustainer! We do believe; make us one, then, with all who bear witness to the truth.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/752.mp3","surahId":5,"words":[{"id":65447,"position":1,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/005_083_001.mp3","charTypeName":"word"},{"id":65448,"position":2,"arabic":"سَمِعُوا۟","translation":"তারা শুনে","audioUrl":"wbw/005_083_002.mp3","charTypeName":"word"},{"id":65449,"position":3,"arabic":"مَآ","translation":"যা","audioUrl":"wbw/005_083_003.mp3","charTypeName":"word"},{"id":65450,"position":4,"arabic":"أُنزِلَ","translation":"অবতীর্ণ করা হয়েছে","audioUrl":"wbw/005_083_004.mp3","charTypeName":"word"},{"id":65451,"position":5,"arabic":"إِلَى","translation":"প্রতি","audioUrl":"wbw/005_083_005.mp3","charTypeName":"word"},{"id":65452,"position":6,"arabic":"ٱلرَّسُولِ","translation":"রাসূলের","audioUrl":"wbw/005_083_006.mp3","charTypeName":"word"},{"id":65453,"position":7,"arabic":"تَرَىٰٓ","translation":"তুমি দেখবে","audioUrl":"wbw/005_083_007.mp3","charTypeName":"word"},{"id":65454,"position":8,"arabic":"أَعْيُنَهُمْ","translation":"চোখগুলো তাদের","audioUrl":"wbw/005_083_008.mp3","charTypeName":"word"},{"id":65455,"position":9,"arabic":"تَفِيضُ","translation":"বিগলিত হচ্ছে","audioUrl":"wbw/005_083_009.mp3","charTypeName":"word"},{"id":65456,"position":10,"arabic":"مِنَ","translation":"দ্বারা","audioUrl":"wbw/005_083_010.mp3","charTypeName":"word"},{"id":65457,"position":11,"arabic":"ٱلدَّمْعِ","translation":"অশ্রু","audioUrl":"wbw/005_083_011.mp3","charTypeName":"word"},{"id":65458,"position":12,"arabic":"مِمَّا","translation":"এ কারণে (যা)","audioUrl":"wbw/005_083_012.mp3","charTypeName":"word"},{"id":65459,"position":13,"arabic":"عَرَفُوا۟","translation":"তারা উপলব্ধি করেছে","audioUrl":"wbw/005_083_013.mp3","charTypeName":"word"},{"id":65460,"position":14,"arabic":"مِنَ","translation":"বিষয়ে","audioUrl":"wbw/005_083_014.mp3","charTypeName":"word"},{"id":65461,"position":15,"arabic":"ٱلْحَقِّ ۖ","translation":"মহাসত্যের","audioUrl":"wbw/005_083_015.mp3","charTypeName":"word"},{"id":65463,"position":16,"arabic":"يَقُولُونَ","translation":"তারা বলে","audioUrl":"wbw/005_083_017.mp3","charTypeName":"word"},{"id":65464,"position":17,"arabic":"رَبَّنَآ","translation":"\"হে আমাদের রব","audioUrl":"wbw/005_083_018.mp3","charTypeName":"word"},{"id":65465,"position":18,"arabic":"ءَامَنَّا","translation":"আমরা ঈমান এনেছি","audioUrl":"wbw/005_083_019.mp3","charTypeName":"word"},{"id":65466,"position":19,"arabic":"فَٱكْتُبْنَا","translation":"অতএব আমাদেরকে তালিকাভুক্ত করো","audioUrl":"wbw/005_083_020.mp3","charTypeName":"word"},{"id":65467,"position":20,"arabic":"مَعَ","translation":"সাথে","audioUrl":"wbw/005_083_021.mp3","charTypeName":"word"},{"id":65468,"position":21,"arabic":"ٱلشَّـٰهِدِينَ","translation":"সাক্ষীদাতাদের","audioUrl":"wbw/005_083_022.mp3","charTypeName":"word"},{"id":65469,"position":22,"arabic":"٨٣","translation":"(৮৩)","audioUrl":null,"charTypeName":"end"}]},{"number":84,"arabic":"وَمَا لَنَا لَا نُؤْمِنُ بِٱللَّهِ وَمَا جَآءَنَا مِنَ ٱلْحَقِّ وَنَطْمَعُ أَن يُدْخِلَنَا رَبُّنَا مَعَ ٱلْقَوْمِ ٱلصَّٰلِحِينَ","translation":"And how could we fail to believe in God and in whatever truth has come unto us, when we so fervently desire that our Sustainer count us among the righteous?\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/753.mp3","surahId":5,"words":[{"id":65780,"position":1,"arabic":"وَمَا","translation":"এবং কি","audioUrl":"wbw/005_084_001.mp3","charTypeName":"word"},{"id":65781,"position":2,"arabic":"لَنَا","translation":"হয়েছে আমাদের","audioUrl":"wbw/005_084_002.mp3","charTypeName":"word"},{"id":65782,"position":3,"arabic":"لَا","translation":"(যে) না","audioUrl":"wbw/005_084_003.mp3","charTypeName":"word"},{"id":65783,"position":4,"arabic":"نُؤْمِنُ","translation":"ঈমান আনবো আমরা","audioUrl":"wbw/005_084_004.mp3","charTypeName":"word"},{"id":65784,"position":5,"arabic":"بِٱللَّهِ","translation":"উপর আল্লাহর","audioUrl":"wbw/005_084_005.mp3","charTypeName":"word"},{"id":65785,"position":6,"arabic":"وَمَا","translation":"এবং যা","audioUrl":"wbw/005_084_006.mp3","charTypeName":"word"},{"id":65786,"position":7,"arabic":"جَآءَنَا","translation":"কাছে এসেছে আমাদের","audioUrl":"wbw/005_084_007.mp3","charTypeName":"word"},{"id":65787,"position":8,"arabic":"مِنَ","translation":"বিষয়ে","audioUrl":"wbw/005_084_008.mp3","charTypeName":"word"},{"id":65788,"position":9,"arabic":"ٱلْحَقِّ","translation":"মহাসত্যের","audioUrl":"wbw/005_084_009.mp3","charTypeName":"word"},{"id":65789,"position":10,"arabic":"وَنَطْمَعُ","translation":"ও প্রত্যাশা করি আমরা","audioUrl":"wbw/005_084_010.mp3","charTypeName":"word"},{"id":65790,"position":11,"arabic":"أَن","translation":"যে","audioUrl":"wbw/005_084_011.mp3","charTypeName":"word"},{"id":65791,"position":12,"arabic":"يُدْخِلَنَا","translation":"অন্তর্ভুক্ত করবেন আমাদের","audioUrl":"wbw/005_084_012.mp3","charTypeName":"word"},{"id":65792,"position":13,"arabic":"رَبُّنَا","translation":"আমাদের রব","audioUrl":"wbw/005_084_013.mp3","charTypeName":"word"},{"id":65793,"position":14,"arabic":"مَعَ","translation":"সাথে","audioUrl":"wbw/005_084_014.mp3","charTypeName":"word"},{"id":65794,"position":15,"arabic":"ٱلْقَوْمِ","translation":"সম্প্রদায়ের\"","audioUrl":"wbw/005_084_015.mp3","charTypeName":"word"},{"id":65795,"position":16,"arabic":"ٱلصَّـٰلِحِينَ","translation":"সৎকর্মশীল\"","audioUrl":"wbw/005_084_016.mp3","charTypeName":"word"},{"id":65796,"position":17,"arabic":"٨٤","translation":"(৮৪)","audioUrl":null,"charTypeName":"end"}]},{"number":85,"arabic":"فَأَثَٰبَهُمُ ٱللَّهُ بِمَا قَالُوا۟ جَنَّٰتٍۢ تَجْرِى مِن تَحْتِهَا ٱلْأَنْهَٰرُ خَٰلِدِينَ فِيهَا ۚ وَذَٰلِكَ جَزَآءُ ٱلْمُحْسِنِينَ","translation":"And for this their belief God will reward them with gardens through which running waters flow, therein to abide: for such is the requital of the doers of good;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/754.mp3","surahId":5,"words":[{"id":66214,"position":1,"arabic":"فَأَثَـٰبَهُمُ","translation":"তাই প্রতিদান দিলেন তাদের","audioUrl":"wbw/005_085_001.mp3","charTypeName":"word"},{"id":66215,"position":2,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/005_085_002.mp3","charTypeName":"word"},{"id":66216,"position":3,"arabic":"بِمَا","translation":"এ কারণে যা","audioUrl":"wbw/005_085_003.mp3","charTypeName":"word"},{"id":66217,"position":4,"arabic":"قَالُوا۟","translation":"তারা বলেছিলো","audioUrl":"wbw/005_085_004.mp3","charTypeName":"word"},{"id":66218,"position":5,"arabic":"جَنَّـٰتٍۢ","translation":"জান্নাত","audioUrl":"wbw/005_085_005.mp3","charTypeName":"word"},{"id":66219,"position":6,"arabic":"تَجْرِى","translation":"প্রবাহিত হয়","audioUrl":"wbw/005_085_006.mp3","charTypeName":"word"},{"id":66220,"position":7,"arabic":"مِن","translation":"দিয়ে","audioUrl":"wbw/005_085_007.mp3","charTypeName":"word"},{"id":66221,"position":8,"arabic":"تَحْتِهَا","translation":"নিচ তার","audioUrl":"wbw/005_085_008.mp3","charTypeName":"word"},{"id":66222,"position":9,"arabic":"ٱلْأَنْهَـٰرُ","translation":"ঝর্ণাধারাসমূহ","audioUrl":"wbw/005_085_009.mp3","charTypeName":"word"},{"id":66223,"position":10,"arabic":"خَـٰلِدِينَ","translation":"চিরস্থায়ী হবে তারা","audioUrl":"wbw/005_085_010.mp3","charTypeName":"word"},{"id":66224,"position":11,"arabic":"فِيهَا ۚ","translation":"মধ্যে তার","audioUrl":"wbw/005_085_011.mp3","charTypeName":"word"},{"id":66226,"position":12,"arabic":"وَذَٰلِكَ","translation":"এবং এটা","audioUrl":"wbw/005_085_013.mp3","charTypeName":"word"},{"id":66227,"position":13,"arabic":"جَزَآءُ","translation":"প্রতিদান","audioUrl":"wbw/005_085_014.mp3","charTypeName":"word"},{"id":66228,"position":14,"arabic":"ٱلْمُحْسِنِينَ","translation":"সৎকর্মপরায়ণদের","audioUrl":"wbw/005_085_015.mp3","charTypeName":"word"},{"id":66229,"position":15,"arabic":"٨٥","translation":"(৮৫)","audioUrl":null,"charTypeName":"end"}]},{"number":86,"arabic":"وَٱلَّذِينَ كَفَرُوا۟ وَكَذَّبُوا۟ بِـَٔايَٰتِنَآ أُو۟لَٰٓئِكَ أَصْحَٰبُ ٱلْجَحِيمِ","translation":"whereas they who are bent on denying the truth and giving the lie to Our messages - they are destined for the blazing fire.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/755.mp3","surahId":5,"words":[{"id":66565,"position":1,"arabic":"وَٱلَّذِينَ","translation":"কিন্তু যারা","audioUrl":"wbw/005_086_001.mp3","charTypeName":"word"},{"id":66566,"position":2,"arabic":"كَفَرُوا۟","translation":"অবিশ্বাস করেছে","audioUrl":"wbw/005_086_002.mp3","charTypeName":"word"},{"id":66567,"position":3,"arabic":"وَكَذَّبُوا۟","translation":"ও মিথ্যারোপ করেছে","audioUrl":"wbw/005_086_003.mp3","charTypeName":"word"},{"id":66568,"position":4,"arabic":"بِـَٔايَـٰتِنَآ","translation":"প্রতি আয়াতগুলোর আমাদের","audioUrl":"wbw/005_086_004.mp3","charTypeName":"word"},{"id":66569,"position":5,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐ সব লোক","audioUrl":"wbw/005_086_005.mp3","charTypeName":"word"},{"id":66570,"position":6,"arabic":"أَصْحَـٰبُ","translation":"অধিবাসী (হবে)","audioUrl":"wbw/005_086_006.mp3","charTypeName":"word"},{"id":66571,"position":7,"arabic":"ٱلْجَحِيمِ","translation":"জাহান্নামের","audioUrl":"wbw/005_086_007.mp3","charTypeName":"word"},{"id":66572,"position":8,"arabic":"٨٦","translation":"(৮৬)","audioUrl":null,"charTypeName":"end"}]},{"number":87,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ لَا تُحَرِّمُوا۟ طَيِّبَٰتِ مَآ أَحَلَّ ٱللَّهُ لَكُمْ وَلَا تَعْتَدُوٓا۟ ۚ إِنَّ ٱللَّهَ لَا يُحِبُّ ٱلْمُعْتَدِينَ","translation":"O YOU who have attained to faith! Do not d