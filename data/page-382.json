{"id":382,"ayahs":[{"number":56,"arabic":"۞ فَمَا كَانَ جَوَابَ قَوْمِهِۦٓ إِلَّآ أَن قَالُوٓا۟ أَخْرِجُوٓا۟ ءَالَ لُوطٍۢ مِّن قَرْيَتِكُمْ ۖ إِنَّهُمْ أُنَاسٌۭ يَتَطَهَّرُونَ","translation":"But his people’s only answer was this: “Expel [Lot and] Lot’s followers from your township! Verily, they are folk who make themselves out to be pure!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3215.mp3","surahId":27,"words":[{"id":52378,"position":1,"arabic":"۞ فَمَا","translation":"অতঃপর না","audioUrl":"wbw/027_056_002.mp3","charTypeName":"word"},{"id":52379,"position":2,"arabic":"كَانَ","translation":"ছিলো","audioUrl":"wbw/027_056_003.mp3","charTypeName":"word"},{"id":52380,"position":3,"arabic":"جَوَابَ","translation":"উত্তর/জবাব","audioUrl":"wbw/027_056_004.mp3","charTypeName":"word"},{"id":52381,"position":4,"arabic":"قَوْمِهِۦٓ","translation":"জাতির তার","audioUrl":"wbw/027_056_005.mp3","charTypeName":"word"},{"id":52382,"position":5,"arabic":"إِلَّآ","translation":"এ ছাড়া","audioUrl":"wbw/027_056_006.mp3","charTypeName":"word"},{"id":52383,"position":6,"arabic":"أَن","translation":"যে","audioUrl":"wbw/027_056_007.mp3","charTypeName":"word"},{"id":52384,"position":7,"arabic":"قَالُوٓا۟","translation":"তারা বলেছিলো","audioUrl":"wbw/027_056_008.mp3","charTypeName":"word"},{"id":52385,"position":8,"arabic":"أَخْرِجُوٓا۟","translation":"\"তোমরা বের করে দাও","audioUrl":"wbw/027_056_009.mp3","charTypeName":"word"},{"id":52386,"position":9,"arabic":"ءَالَ","translation":"পরিবারকে","audioUrl":"wbw/027_056_010.mp3","charTypeName":"word"},{"id":52387,"position":10,"arabic":"لُوطٍۢ","translation":"লুতের","audioUrl":"wbw/027_056_011.mp3","charTypeName":"word"},{"id":52388,"position":11,"arabic":"مِّن","translation":"হ'তে","audioUrl":"wbw/027_056_012.mp3","charTypeName":"word"},{"id":52389,"position":12,"arabic":"قَرْيَتِكُمْ ۖ","translation":"জনপদ তোমাদের","audioUrl":"wbw/027_056_013.mp3","charTypeName":"word"},{"id":52391,"position":13,"arabic":"إِنَّهُمْ","translation":"নিশ্চয়ই তারা","audioUrl":"wbw/027_056_015.mp3","charTypeName":"word"},{"id":52392,"position":14,"arabic":"أُنَاسٌۭ","translation":"এমন লোক","audioUrl":"wbw/027_056_016.mp3","charTypeName":"word"},{"id":52393,"position":15,"arabic":"يَتَطَهَّرُونَ","translation":"(যারা) তারা পবিত্র থাকতে চায়","audioUrl":"wbw/027_056_017.mp3","charTypeName":"word"},{"id":52394,"position":16,"arabic":"٥٦","translation":"(৫৬)","audioUrl":null,"charTypeName":"end"}]},{"number":57,"arabic":"فَأَنجَيْنَٰهُ وَأَهْلَهُۥٓ إِلَّا ٱمْرَأَتَهُۥ قَدَّرْنَٰهَا مِنَ ٱلْغَٰبِرِينَ","translation":"Thereupon We saved him and his household - all but his wife, whom We willed to be among those that stayed behind -","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3216.mp3","surahId":27,"words":[{"id":52910,"position":1,"arabic":"فَأَنجَيْنَـٰهُ","translation":"অতঃপর আমরা রক্ষা করলাম তাকে","audioUrl":"wbw/027_057_001.mp3","charTypeName":"word"},{"id":52911,"position":2,"arabic":"وَأَهْلَهُۥٓ","translation":"ও পরিবারকে তার","audioUrl":"wbw/027_057_002.mp3","charTypeName":"word"},{"id":52912,"position":3,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/027_057_003.mp3","charTypeName":"word"},{"id":52913,"position":4,"arabic":"ٱمْرَأَتَهُۥ","translation":"স্ত্রীকে তার","audioUrl":"wbw/027_057_004.mp3","charTypeName":"word"},{"id":52914,"position":5,"arabic":"قَدَّرْنَـٰهَا","translation":"আমরা সাব্যস্ত করেছিলাম তাকে","audioUrl":"wbw/027_057_005.mp3","charTypeName":"word"},{"id":52915,"position":6,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/027_057_006.mp3","charTypeName":"word"},{"id":52916,"position":7,"arabic":"ٱلْغَـٰبِرِينَ","translation":"পিছে পড়ে থাকাদের","audioUrl":"wbw/027_057_007.mp3","charTypeName":"word"},{"id":52917,"position":8,"arabic":"٥٧","translation":"(৫৭)","audioUrl":null,"charTypeName":"end"}]},{"number":58,"arabic":"وَأَمْطَرْنَا عَلَيْهِم مَّطَرًۭا ۖ فَسَآءَ مَطَرُ ٱلْمُنذَرِينَ","translation":"the while We rained a rain [of destruction] upon the others: and dire is such rain upon all who let themselves be warned [to no avail]","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3217.mp3","surahId":27,"words":[{"id":53437,"position":1,"arabic":"وَأَمْطَرْنَا","translation":"এবং বর্ষণ করেছিলাম আমরা","audioUrl":"wbw/027_058_001.mp3","charTypeName":"word"},{"id":53438,"position":2,"arabic":"عَلَيْهِم","translation":"উপর তাদের","audioUrl":"wbw/027_058_002.mp3","charTypeName":"word"},{"id":53439,"position":3,"arabic":"مَّطَرًۭا ۖ","translation":"(খুব) বৃষ্টি","audioUrl":"wbw/027_058_003.mp3","charTypeName":"word"},{"id":53441,"position":4,"arabic":"فَسَآءَ","translation":"অতঃপর বড় খারাপ","audioUrl":"wbw/027_058_005.mp3","charTypeName":"word"},{"id":53442,"position":5,"arabic":"مَطَرُ","translation":"বৃষ্টিবর্ষণ (ছিলো)","audioUrl":"wbw/027_058_006.mp3","charTypeName":"word"},{"id":53443,"position":6,"arabic":"ٱلْمُنذَرِينَ","translation":"(তাদের জন্যে) যাদেরকে সতর্ক করা হয়েছিলো","audioUrl":"wbw/027_058_007.mp3","charTypeName":"word"},{"id":53444,"position":7,"arabic":"٥٨","translation":"(৫৮)","audioUrl":null,"charTypeName":"end"}]},{"number":59,"arabic":"قُلِ ٱلْحَمْدُ لِلَّهِ وَسَلَٰمٌ عَلَىٰ عِبَادِهِ ٱلَّذِينَ ٱصْطَفَىٰٓ ۗ ءَآللَّهُ خَيْرٌ أَمَّا يُشْرِكُونَ","translation":"SAY: “All praise is due to God, and peace be upon those servants of His whom He chose [to be His message-bearers]!” Is not God far better than anything to which men [falsely] ascribe a share in His divinity?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3218.mp3","surahId":27,"words":[{"id":53829,"position":1,"arabic":"قُلِ","translation":"(হে নাবী) বলো","audioUrl":"wbw/027_059_001.mp3","charTypeName":"word"},{"id":53830,"position":2,"arabic":"ٱلْحَمْدُ","translation":"\"সব প্রশংসা","audioUrl":"wbw/027_059_002.mp3","charTypeName":"word"},{"id":53831,"position":3,"arabic":"لِلَّهِ","translation":"জন্যে আল্লাহরই","audioUrl":"wbw/027_059_003.mp3","charTypeName":"word"},{"id":53832,"position":4,"arabic":"وَسَلَـٰمٌ","translation":"আর সালাম","audioUrl":"wbw/027_059_004.mp3","charTypeName":"word"},{"id":53833,"position":5,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/027_059_005.mp3","charTypeName":"word"},{"id":53834,"position":6,"arabic":"عِبَادِهِ","translation":"দাসদের তাঁর","audioUrl":"wbw/027_059_006.mp3","charTypeName":"word"},{"id":53835,"position":7,"arabic":"ٱلَّذِينَ","translation":"যাদেরকে","audioUrl":"wbw/027_059_007.mp3","charTypeName":"word"},{"id":53836,"position":8,"arabic":"ٱصْطَفَىٰٓ ۗ","translation":"তিনি মনোনীত করেছেন","audioUrl":"wbw/027_059_008.mp3","charTypeName":"word"},{"id":53838,"position":9,"arabic":"ءَآللَّهُ","translation":"(তাদের জিজ্ঞেস করো)কি আল্লাহ","audioUrl":"wbw/027_059_010.mp3","charTypeName":"word"},{"id":53839,"position":10,"arabic":"خَيْرٌ","translation":"উত্তম","audioUrl":"wbw/027_059_011.mp3","charTypeName":"word"},{"id":53840,"position":11,"arabic":"أَمَّا","translation":"না সেই (মাবুদ)","audioUrl":"wbw/027_059_012.mp3","charTypeName":"word"},{"id":53841,"position":12,"arabic":"يُشْرِكُونَ","translation":"(যাদেরকে) তারা শরিক করছে\"","audioUrl":"wbw/027_059_013.mp3","charTypeName":"word"},{"id":53842,"position":13,"arabic":"٥٩","translation":"(৫৯)","audioUrl":null,"charTypeName":"end"}]},{"number":60,"arabic":"أَمَّنْ خَلَقَ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضَ وَأَنزَلَ لَكُم مِّنَ ٱلسَّمَآءِ مَآءًۭ فَأَنۢبَتْنَا بِهِۦ حَدَآئِقَ ذَاتَ بَهْجَةٍۢ مَّا كَانَ لَكُمْ أَن تُنۢبِتُوا۟ شَجَرَهَآ ۗ أَءِلَٰهٌۭ مَّعَ ٱللَّهِ ۚ بَلْ هُمْ قَوْمٌۭ يَعْدِلُونَ","translation":"Nay - who is it that has created the heavens and the earth, and sends down for you [life-giving] water from the skies? For it is by this means that We cause gardens of shining beauty to grow - [whereas] it is not in your power to cause [even one single of] its trees to grow! Could there be any divine power besides God? Nay, they [who think so] are people who swerve [from the path of reason]","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3219.mp3","surahId":27,"words":[{"id":54585,"position":1,"arabic":"أَمَّنْ","translation":"অথবা কে (এমন আছেন)","audioUrl":"wbw/027_060_001.mp3","charTypeName":"word"},{"id":54586,"position":2,"arabic":"خَلَقَ","translation":"যিনি সৃষ্টি করেছেন","audioUrl":"wbw/027_060_002.mp3","charTypeName":"word"},{"id":54587,"position":3,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশমন্ডলী","audioUrl":"wbw/027_060_003.mp3","charTypeName":"word"},{"id":54588,"position":4,"arabic":"وَٱلْأَرْضَ","translation":"ও পৃথিবীকে","audioUrl":"wbw/027_060_004.mp3","charTypeName":"word"},{"id":54589,"position":5,"arabic":"وَأَنزَلَ","translation":"ও বর্ষণ করেছেন","audioUrl":"wbw/027_060_005.mp3","charTypeName":"word"},{"id":54590,"position":6,"arabic":"لَكُم","translation":"জন্যে তোমাদের","audioUrl":"wbw/027_060_006.mp3","charTypeName":"word"},{"id":54591,"position":7,"arabic":"مِّنَ","translation":"হ'তে","audioUrl":"wbw/027_060_007.mp3","charTypeName":"word"},{"id":54592,"position":8,"arabic":"ٱلسَّمَآءِ","translation":"আকাশ","audioUrl":"wbw/027_060_008.mp3","charTypeName":"word"},{"id":54593,"position":9,"arabic":"مَآءًۭ","translation":"পানি","audioUrl":"wbw/027_060_009.mp3","charTypeName":"word"},{"id":54594,"position":10,"arabic":"فَأَنۢبَتْنَا","translation":"অতঃপর আমরাই  উৎপন্ন করেছি","audioUrl":"wbw/027_060_010.mp3","charTypeName":"word"},{"id":54595,"position":11,"arabic":"بِهِۦ","translation":"দ্বারা তা","audioUrl":"wbw/027_060_011.mp3","charTypeName":"word"},{"id":54596,"position":12,"arabic":"حَدَآئِقَ","translation":"বাগানসমূহ","audioUrl":"wbw/027_060_012.mp3","charTypeName":"word"},{"id":54597,"position":13,"arabic":"ذَاتَ","translation":"মন্ডিত","audioUrl":"wbw/027_060_013.mp3","charTypeName":"word"},{"id":54598,"position":14,"arabic":"بَهْجَةٍۢ","translation":"শোভা","audioUrl":"wbw/027_060_014.mp3","charTypeName":"word"},{"id":54599,"position":15,"arabic":"مَّا","translation":"না","audioUrl":"wbw/027_060_015.mp3","charTypeName":"word"},{"id":54600,"position":16,"arabic":"كَانَ","translation":"(সম্ভব) ছিলো","audioUrl":"wbw/027_060_016.mp3","charTypeName":"word"},{"id":54601,"position":17,"arabic":"لَكُمْ","translation":"জন্যে তোমাদের","audioUrl":"wbw/027_060_017.mp3","charTypeName":"word"},{"id":54602,"position":18,"arabic":"أَن","translation":"যে","audioUrl":"wbw/027_060_018.mp3","charTypeName":"word"},{"id":54603,"position":19,"arabic":"تُنۢبِتُوا۟","translation":"তোমরা উৎপন্ন করবে","audioUrl":"wbw/027_060_019.mp3","charTypeName":"word"},{"id":54604,"position":20,"arabic":"شَجَرَهَآ ۗ","translation":"গাছ-পালা তার","audioUrl":"wbw/027_060_020.mp3","charTypeName":"word"},{"id":54606,"position":21,"arabic":"أَءِلَـٰهٌۭ","translation":"কি তবে (আছে) কোনো ইলাহ","audioUrl":"wbw/027_060_022.mp3","charTypeName":"word"},{"id":54607,"position":22,"arabic":"مَّعَ","translation":"সাথে","audioUrl":"wbw/027_060_023.mp3","charTypeName":"word"},{"id":54608,"position":23,"arabic":"ٱللَّهِ ۚ","translation":"আল্লাহর (এ কাজে)","audioUrl":"wbw/027_060_024.mp3","charTypeName":"word"},{"id":54610,"position":24,"arabic":"بَلْ","translation":"বরং","audioUrl":"wbw/027_060_026.mp3","charTypeName":"word"},{"id":54611,"position":25,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/027_060_027.mp3","charTypeName":"word"},{"id":54612,"position":26,"arabic":"قَوْمٌۭ","translation":"(এমন) সম্প্রদায়","audioUrl":"wbw/027_060_028.mp3","charTypeName":"word"},{"id":54613,"position":27,"arabic":"يَعْدِلُونَ","translation":"যারা সত্যবিচ্যুত হচ্ছে","audioUrl":"wbw/027_060_029.mp3","charTypeName":"word"},{"id":54614,"position":28,"arabic":"٦٠","translation":"(৬০)","audioUrl":null,"charTypeName":"end"}]},{"number":61,"arabic":"أَمَّن جَعَلَ ٱلْأَرْضَ قَرَارًۭا وَجَعَلَ خِلَٰلَهَآ أَنْهَٰرًۭا وَجَعَلَ لَهَا رَوَٰسِىَ وَجَعَلَ بَيْنَ ٱلْبَحْرَيْنِ حَاجِزًا ۗ أَءِلَٰهٌۭ مَّعَ ٱللَّهِ ۚ بَلْ أَكْثَرُهُمْ لَا يَعْلَمُونَ","translation":"Nay - who is it that has made the earth a fitting abode [for living things], and has caused running waters [to flow] in its midst, and has set upon it moun­tains firm, and has placed a barrier between the two great bodies of water? Could there be any divine power besides God? Nay, most of those [who think so] do not know [what they are saying]!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3220.mp3","surahId":27,"words":[{"id":55203,"position":1,"arabic":"أَمَّن","translation":"অথবা কে (এমন আছে)","audioUrl":"wbw/027_061_001.mp3","charTypeName":"word"},{"id":55204,"position":2,"arabic":"جَعَلَ","translation":"যিনি করেছেন","audioUrl":"wbw/027_061_002.mp3","charTypeName":"word"},{"id":55205,"position":3,"arabic":"ٱلْأَرْضَ","translation":"পৃথিবীকে","audioUrl":"wbw/027_061_003.mp3","charTypeName":"word"},{"id":55206,"position":4,"arabic":"قَرَارًۭا","translation":"বাসোপযোগী","audioUrl":"wbw/027_061_004.mp3","charTypeName":"word"},{"id":55207,"position":5,"arabic":"وَجَعَلَ","translation":"ও প্রবাহিত করেছেন","audioUrl":"wbw/027_061_005.mp3","charTypeName":"word"},{"id":55208,"position":6,"arabic":"خِلَـٰلَهَآ","translation":"মাঝে তার","audioUrl":"wbw/027_061_006.mp3","charTypeName":"word"},{"id":55209,"position":7,"arabic":"أَنْهَـٰرًۭا","translation":"নদ-নদীসমূহ","audioUrl":"wbw/027_061_007.mp3","charTypeName":"word"},{"id":55210,"position":8,"arabic":"وَجَعَلَ","translation":"এবং স্থাপন করেছেন","audioUrl":"wbw/027_061_008.mp3","charTypeName":"word"},{"id":55211,"position":9,"arabic":"لَهَا","translation":"তাতে","audioUrl":"wbw/027_061_009.mp3","charTypeName":"word"},{"id":55212,"position":10,"arabic":"رَوَٰسِىَ","translation":"সুদৃঢ় পর্বতসমূহ","audioUrl":"wbw/027_061_010.mp3","charTypeName":"word"},{"id":55213,"position":11,"arabic":"وَجَعَلَ","translation":"এবং সৃষ্টি করেছেন","audioUrl":"wbw/027_061_011.mp3","charTypeName":"word"},{"id":55214,"position":12,"arabic":"بَيْنَ","translation":"মাঝে","audioUrl":"wbw/027_061_012.mp3","charTypeName":"word"},{"id":55215,"position":13,"arabic":"ٱلْبَحْرَيْنِ","translation":"দুই সাগরের","audioUrl":"wbw/027_061_013.mp3","charTypeName":"word"},{"id":55216,"position":14,"arabic":"حَاجِزًا ۗ","translation":"আড়াল","audioUrl":"wbw/027_061_014.mp3","charTypeName":"word"},{"id":55218,"position":15,"arabic":"أَءِلَـٰهٌۭ","translation":"কি তবে (আছে) কোনো ইলাহ","audioUrl":"wbw/027_061_016.mp3","charTypeName":"word"},{"id":55219,"position":16,"arabic":"مَّعَ","translation":"সাথে","audioUrl":"wbw/027_061_017.mp3","charTypeName":"word"},{"id":55220,"position":17,"arabic":"ٱللَّهِ ۚ","translation":"আল্লাহর (এ কাজে)","audioUrl":"wbw/027_061_018.mp3","charTypeName":"word"},{"id":55222,"position":18,"arabic":"بَلْ","translation":"বরং","audioUrl":"wbw/027_061_020.mp3","charTypeName":"word"},{"id":55223,"position":19,"arabic":"أَكْثَرُهُمْ","translation":"অধিকাংশ তাদের","audioUrl":"wbw/027_061_021.mp3","charTypeName":"word"},{"id":55224,"position":20,"arabic":"لَا","translation":"না","audioUrl":"wbw/027_061_022.mp3","charTypeName":"word"},{"id":55225,"position":21,"arabic":"يَعْلَمُونَ","translation":"জানে","audioUrl":"wbw/027_061_023.mp3","charTypeName":"word"},{"id":55226,"position":22,"arabic":"٦١","translation":"(৬১)","audioUrl":null,"charTypeName":"end"}]},{"number":62,"arabic":"أَمَّن يُجِيبُ ٱلْمُضْطَرَّ إِذَا دَعَاهُ وَيَكْشِفُ ٱلسُّوٓءَ وَيَجْعَلُكُمْ خُلَفَآءَ ٱلْأَرْضِ ۗ أَءِلَٰهٌۭ مَّعَ ٱللَّهِ ۚ قَلِيلًۭا مَّا تَذَكَّرُونَ","translation":"Nay - who is it that responds to the distressed when he calls out to Him, and who removes the ill [that caused the distress], and has made you inherit the earth? Could there be any divine power besides God? How seldom do you keep this in mind!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3221.mp3","surahId":27,"words":[{"id":55629,"position":1,"arabic":"أَمَّن","translation":"কে অথবা (এমন আছেন)","audioUrl":"wbw/027_062_001.mp3","charTypeName":"word"},{"id":55630,"position":2,"arabic":"يُجِيبُ","translation":"যিনি সাড়া দেন","audioUrl":"wbw/027_062_002.mp3","charTypeName":"word"},{"id":55631,"position":3,"arabic":"ٱلْمُضْطَرَّ","translation":"আর্তকে","audioUrl":"wbw/027_062_003.mp3","charTypeName":"word"},{"id":55632,"position":4,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/027_062_004.mp3","charTypeName":"word"},{"id":55633,"position":5,"arabic":"دَعَاهُ","translation":"তাকে ডাকে সে","audioUrl":"wbw/027_062_005.mp3","charTypeName":"word"},{"id":55634,"position":6,"arabic":"وَيَكْشِفُ","translation":"ও দূর করেন","audioUrl":"wbw/027_062_006.mp3","charTypeName":"word"},{"id":55635,"position":7,"arabic":"ٱلسُّوٓءَ","translation":"কষ্ট","audioUrl":"wbw/027_062_007.mp3","charTypeName":"word"},{"id":55636,"position":8,"arabic":"وَيَجْعَلُكُمْ","translation":"ও করেন তোমাদেরকে","audioUrl":"wbw/027_062_008.mp3","charTypeName":"word"},{"id":55637,"position":9,"arabic":"خُلَفَآءَ","translation":"প্রতিনিধি","audioUrl":"wbw/027_062_009.mp3","charTypeName":"word"},{"id":55638,"position":10,"arabic":"ٱلْأَرْضِ ۗ","translation":"পৃথিবীর","audioUrl":"wbw/027_062_010.mp3","charTypeName":"word"},{"id":55640,"position":11,"arabic":"أَءِلَـٰهٌۭ","translation":"কি (আছে) কোনো ইলাহ","audioUrl":"wbw/027_062_012.mp3","charTypeName":"word"},{"id":55641,"position":12,"arabic":"مَّعَ","translation":"সাথে","audioUrl":"wbw/027_062_013.mp3","charTypeName":"word"},{"id":55642,"position":13,"arabic":"ٱللَّهِ ۚ","translation":"আল্লাহর (এ কাজে)","audioUrl":"wbw/027_062_014.mp3","charTypeName":"word"},{"id":55644,"position":14,"arabic":"قَلِيلًۭا","translation":"খুব কমই","audioUrl":"wbw/027_062_016.mp3","charTypeName":"word"},{"id":55645,"position":15,"arabic":"مَّا","translation":"যা","audioUrl":"wbw/027_062_017.mp3","charTypeName":"word"},{"id":55646,"position":16,"arabic":"تَذَكَّرُونَ","translation":"তোমরা উপদেশ গ্রহণ করো","audioUrl":"wbw/027_062_018.mp3","charTypeName":"word"},{"id":55647,"position":17,"arabic":"٦٢","translation":"(৬২)","audioUrl":null,"charTypeName":"end"}]},{"number":63,"arabic":"أَمَّن يَهْدِيكُمْ فِى ظُلُمَٰتِ ٱلْبَرِّ وَٱلْبَحْرِ وَمَن يُرْسِلُ ٱلرِّيَٰحَ بُشْرًۢا بَيْنَ يَدَىْ رَحْمَتِهِۦٓ ۗ أَءِلَٰهٌۭ مَّعَ ٱللَّهِ ۚ تَعَٰلَى ٱللَّهُ عَمَّا يُشْرِكُونَ","translation":"Nay - who is it that guides you in the midst of the deep darkness of land and sea, and sends forth the winds as a glad tiding of His coming grace? Could there be any divine power besides God? Sublimely exalted is God above anything to which men may ascribe a share in His divinity!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3222.mp3","surahId":27,"words":[{"id":56272,"position":1,"arabic":"أَمَّن","translation":"কে অথবা (এমন আছেন)","audioUrl":"wbw/027_063_001.mp3","charTypeName":"word"},{"id":56273,"position":2,"arabic":"يَهْدِيكُمْ","translation":"যিনি পথ দেখান তোমাদেরকে","audioUrl":"wbw/027_063_002.mp3","charTypeName":"word"},{"id":56274,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/027_063_003.mp3","charTypeName":"word"},{"id":56275,"position":4,"arabic":"ظُلُمَـٰتِ","translation":"অন্ধকারসমূহের","audioUrl":"wbw/027_063_004.mp3","charTypeName":"word"},{"id":56276,"position":5,"arabic":"ٱلْبَرِّ","translation":"স্থলের","audioUrl":"wbw/027_063_005.mp3","charTypeName":"word"},{"id":56277,"position":6,"arabic":"وَٱلْبَحْرِ","translation":"ও সমুদ্রের","audioUrl":"wbw/027_063_006.mp3","charTypeName":"word"},{"id":56278,"position":7,"arabic":"وَمَن","translation":"আর কে","audioUrl":"wbw/027_063_007.mp3","charTypeName":"word"},{"id":56279,"position":8,"arabic":"يُرْسِلُ","translation":"পাঠান","audioUrl":"wbw/027_063_008.mp3","charTypeName":"word"},{"id":56280,"position":9,"arabic":"ٱلرِّيَـٰحَ","translation":"বাতাসকে","audioUrl":"wbw/027_063_009.mp3","charTypeName":"word"},{"id":56281,"position":10,"arabic":"بُشْرًۢا","translation":"সু-সংবাদ স্বরুপ","audioUrl":"wbw/027_063_010.mp3","charTypeName":"word"},{"id":56282,"position":11,"arabic":"بَيْنَ","translation":"মাঝে","audioUrl":"wbw/027_063_011.mp3","charTypeName":"word"},{"id":56283,"position":12,"arabic":"يَدَىْ","translation":"হাতের (পূর্বে)","audioUrl":"wbw/027_063_012.mp3","charTypeName":"word"},{"id":56284,"position":13,"arabic":