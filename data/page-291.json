{"id":291,"ayahs":[{"number":87,"arabic":"إِلَّا رَحْمَةًۭ مِّن رَّبِّكَ ۚ إِنَّ فَضْلَهُۥ كَانَ عَلَيْكَ كَبِيرًۭا","translation":"[Thou art spared] only by thy Sustainer's grace: behold, His favour towards thee is great indeed!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2116.mp3","surahId":17,"words":[{"id":66728,"position":1,"arabic":"إِلَّا","translation":"কিন্তু","audioUrl":"wbw/017_087_001.mp3","charTypeName":"word"},{"id":66729,"position":2,"arabic":"رَحْمَةًۭ","translation":"(তা না করা) অনুগ্রহ","audioUrl":"wbw/017_087_002.mp3","charTypeName":"word"},{"id":66730,"position":3,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/017_087_003.mp3","charTypeName":"word"},{"id":66731,"position":4,"arabic":"رَّبِّكَ ۚ","translation":"তোমার রব","audioUrl":"wbw/017_087_004.mp3","charTypeName":"word"},{"id":66733,"position":5,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/017_087_006.mp3","charTypeName":"word"},{"id":66734,"position":6,"arabic":"فَضْلَهُۥ","translation":"তাঁর অনুগ্রহ","audioUrl":"wbw/017_087_007.mp3","charTypeName":"word"},{"id":66735,"position":7,"arabic":"كَانَ","translation":"হলো","audioUrl":"wbw/017_087_008.mp3","charTypeName":"word"},{"id":66736,"position":8,"arabic":"عَلَيْكَ","translation":"তোমার উপর","audioUrl":"wbw/017_087_009.mp3","charTypeName":"word"},{"id":66737,"position":9,"arabic":"كَبِيرًۭا","translation":"বিরাট","audioUrl":"wbw/017_087_010.mp3","charTypeName":"word"},{"id":66738,"position":10,"arabic":"٨٧","translation":"(৮৭)","audioUrl":null,"charTypeName":"end"}]},{"number":88,"arabic":"قُل لَّئِنِ ٱجْتَمَعَتِ ٱلْإِنسُ وَٱلْجِنُّ عَلَىٰٓ أَن يَأْتُوا۟ بِمِثْلِ هَٰذَا ٱلْقُرْءَانِ لَا يَأْتُونَ بِمِثْلِهِۦ وَلَوْ كَانَ بَعْضُهُمْ لِبَعْضٍۢ ظَهِيرًۭا","translation":"Say: \"If all mankind and all invisible beings would come together with a view to producing the like of this Qur'an, they could not produce its like even though they were to exert all their strength in aiding one another!\"","audio":"https: