{"id":321,"ayahs":[{"number":126,"arabic":"قَالَ كَذَٰلِكَ أَتَتْكَ ءَايَٰتُنَا فَنَسِيتَهَا ۖ وَكَذَٰلِكَ ٱلْيَوْمَ تُنسَىٰ","translation":"[God] will reply: \"Thus it is: there came unto thee Our messages, but thou wert oblivious of them; and thus shalt thou be today consigned to oblivion!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2474.mp3","surahId":20,"words":[{"id":77323,"position":1,"arabic":"قَالَ","translation":"তিনি বলবেন","audioUrl":"wbw/020_126_001.mp3","charTypeName":"word"},{"id":77324,"position":2,"arabic":"كَذَٰلِكَ","translation":"\"এমনিভাবেই","audioUrl":"wbw/020_126_002.mp3","charTypeName":"word"},{"id":77325,"position":3,"arabic":"أَتَتْكَ","translation":"তোমাদের কাছে এসেছিলো","audioUrl":"wbw/020_126_003.mp3","charTypeName":"word"},{"id":77326,"position":4,"arabic":"ءَايَـٰتُنَا","translation":"আমাদের নিদর্শনাবলী","audioUrl":"wbw/020_126_004.mp3","charTypeName":"word"},{"id":77327,"position":5,"arabic":"فَنَسِيتَهَا ۖ","translation":"তখন তা তুমি ভুলে গিয়েছিলে","audioUrl":"wbw/020_126_005.mp3","charTypeName":"word"},{"id":77329,"position":6,"arabic":"وَكَذَٰلِكَ","translation":"এবং এভাবেই","audioUrl":"wbw/020_126_007.mp3","charTypeName":"word"},{"id":77330,"position":7,"arabic":"ٱلْيَوْمَ","translation":"আজ","audioUrl":"wbw/020_126_008.mp3","charTypeName":"word"},{"id":77331,"position":8,"arabic":"تُنسَىٰ","translation":"বিস্মৃত হয়েছো তুমি\"","audioUrl":"wbw/020_126_009.mp3","charTypeName":"word"},{"id":77332,"position":9,"arabic":"١٢٦","translation":"(১২৬)","audioUrl":null,"charTypeName":"end"}]},{"number":127,"arabic":"وَكَذَٰلِكَ نَجْزِى مَنْ أَسْرَفَ وَلَمْ يُؤْمِنۢ بِـَٔايَٰتِ رَبِّهِۦ ۚ وَلَعَذَابُ ٱلْءَاخِرَةِ أَشَدُّ وَأَبْقَىٰٓ","translation":"For, thus shall We recompense him who wastes his own self and does not believe in his Sustainer's messages: and, indeed, the suffering [of such sinners] in the life to come shall be most severe and most enduring!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2475.mp3","surahId":20,"words":[{"id":77542,"position":1,"arabic":"وَكَذَٰلِكَ","translation":"এবং এরূপেই","audioUrl":"wbw/020_127_001.mp3","charTypeName":"word"},{"id":77543,"position":2,"arabic":"نَجْزِى","translation":"প্রতিফল দিই আমরা","audioUrl":"wbw/020_127_002.mp3","charTypeName":"word"},{"id":77544,"position":3,"arabic":"مَنْ","translation":"(তাকে) যে","audioUrl":"wbw/020_127_003.mp3","charTypeName":"word"},{"id":77545,"position":4,"arabic":"أَسْرَفَ","translation":"বাড়াবাড়ি করে","audioUrl":"wbw/020_127_004.mp3","charTypeName":"word"},{"id":77546,"position":5,"arabic":"وَلَمْ","translation":"এবং না","audioUrl":"wbw/020_127_005.mp3","charTypeName":"word"},{"id":77547,"position":6,"arabic":"يُؤْمِنۢ","translation":"বিশ্বাস করে","audioUrl":"wbw/020_127_006.mp3","charTypeName":"word"},{"id":77548,"position":7,"arabic":"بِـَٔايَـٰتِ","translation":"নিদর্শনাবলীর প্রতি","audioUrl":"wbw/020_127_007.mp3","charTypeName":"word"},{"id":77549,"position":8,"arabic":"رَبِّهِۦ ۚ","translation":"তার রবের","audioUrl":"wbw/020_127_008.mp3","charTypeName":"word"},{"id":77551,"position":9,"arabic":"وَلَعَذَابُ","translation":"এবং অবশ্যই শাস্তি","audioUrl":"wbw/020_127_010.mp3","charTypeName":"word"},{"id":77552,"position":10,"arabic":"ٱلْـَٔاخِرَةِ","translation":"আখিরাতের","audioUrl":"wbw/020_127_011.mp3","charTypeName":"word"},{"id":77553,"position":11,"arabic":"أَشَدُّ","translation":"কঠোরতর","audioUrl":"wbw/020_127_012.mp3","charTypeName":"word"},{"id":77554,"position":12,"arabic":"وَأَبْقَىٰٓ","translation":"ও অধিক স্থায়ী","audioUrl":"wbw/020_127_013.mp3","charTypeName":"word"},{"id":77555,"position":13,"arabic":"١٢٧","translation":"(১২৭)","audioUrl":null,"charTypeName":"end"}]},{"number":128,"arabic":"أَفَلَمْ يَهْدِ لَهُمْ كَمْ أَهْلَكْنَا قَبْلَهُم مِّنَ ٱلْقُرُونِ يَمْشُونَ فِى مَسَٰكِنِهِمْ ۗ إِنَّ فِى ذَٰلِكَ لَءَايَٰتٍۢ لِّأُو۟لِى ٱلنُّهَىٰ","translation":"CAN, THEN, they [who reject the truth] learn no lesson by recalling how many a generation We have destroyed before their time? - [people] in whose dwelling-places they [themselves now] walk about? In this, behold, there are messages indeed for those who are endowed with reason!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2476.mp3","surahId":20,"words":[{"id":77704,"position":1,"arabic":"أَفَلَمْ","translation":"নি তবে কি","audioUrl":"wbw/020_128_001.mp3","charTypeName":"word"},{"id":77705,"position":2,"arabic":"يَهْدِ","translation":"পথ দেখায় (ইতিহাসের এ শিক্ষা)","audioUrl":"wbw/020_128_002.mp3","charTypeName":"word"},{"id":77706,"position":3,"arabic":"لَهُمْ","translation":"তাদের জন্যে","audioUrl":"wbw/020_128_003.mp3","charTypeName":"word"},{"id":77707,"position":4,"arabic":"كَمْ","translation":"কতই (না)","audioUrl":"wbw/020_128_004.mp3","charTypeName":"word"},{"id":77708,"position":5,"arabic":"أَهْلَكْنَا","translation":"আমরা ধ্বংস করেছি (জনপদ)","audioUrl":"wbw/020_128_005.mp3","charTypeName":"word"},{"id":77709,"position":6,"arabic":"قَبْلَهُم","translation":"তাদের পূর্বে","audioUrl":"wbw/020_128_006.mp3","charTypeName":"word"},{"id":77710,"position":7,"arabic":"مِّنَ","translation":"মধ্য হ'তে","audioUrl":"wbw/020_128_007.mp3","charTypeName":"word"},{"id":77711,"position":8,"arabic":"ٱلْقُرُونِ","translation":"মানব গোষ্ঠির","audioUrl":"wbw/020_128_008.mp3","charTypeName":"word"},{"id":77712,"position":9,"arabic":"يَمْشُونَ","translation":"তারা চলছে (আজ)","audioUrl":"wbw/020_128_009.mp3","charTypeName":"word"},{"id":77713,"position":10,"arabic":"فِى","translation":"মধ্য দিয়ে","audioUrl":"wbw/020_128_010.mp3","charTypeName":"word"},{"id":77714,"position":11,"arabic":"مَسَـٰكِنِهِمْ ۗ","translation":"তাদের বাসস্থানসমূহের","audioUrl":"wbw/020_128_011.mp3","charTypeName":"word"},{"id":77716,"position":12,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/020_128_013.mp3","charTypeName":"word"},{"id":77717,"position":13,"arabic":"فِى","translation":"মধ্যে (রয়েছে)","audioUrl":"wbw/020_128_014.mp3","charTypeName":"word"},{"id":77718,"position":14,"arabic":"ذَٰلِكَ","translation":"এর","audioUrl":"wbw/020_128_015.mp3","charTypeName":"word"},{"id":77719,"position":15,"arabic":"لَـَٔايَـٰتٍۢ","translation":"অবশ্যই নিদর্শনাবলী","audioUrl":"wbw/020_128_016.mp3","charTypeName":"word"},{"id":77720,"position":16,"arabic":"لِّأُو۟لِى","translation":"জন্যে অধিকারীদের","audioUrl":"wbw/020_128_017.mp3","charTypeName":"word"},{"id":77721,"position":17,"arabic":"ٱلنُّهَىٰ","translation":"বুদ্ধি-বিবেকের","audioUrl":"wbw/020_128_018.mp3","charTypeName":"word"},{"id":77722,"position":18,"arabic":"١٢٨","translation":"(১২৮)","audioUrl":null,"charTypeName":"end"}]},{"number":129,"arabic":"وَلَوْلَا كَلِمَةٌۭ سَبَقَتْ مِن رَّبِّكَ لَكَانَ لِزَامًۭا وَأَجَلٌۭ مُّسَمًّۭى","translation":"Now were it not for a decree that has already gone forth from thy Sustainer, setting a term [for each sinner's repentance], it would inescapably follow [that all who sin must be doomed at once].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2477.mp3","surahId":20,"words":[{"id":77799,"position":1,"arabic":"وَلَوْلَا","translation":"এবং যদি না","audioUrl":"wbw/020_129_001.mp3","charTypeName":"word"},{"id":77800,"position":2,"arabic":"كَلِمَةٌۭ","translation":"একটি বাণী","audioUrl":"wbw/020_129_002.mp3","charTypeName":"word"},{"id":77801,"position":3,"arabic":"سَبَقَتْ","translation":"পূর্বে নির্দিষ্ট হয়ে থাকতো","audioUrl":"wbw/020_129_003.mp3","charTypeName":"word"},{"id":77802,"position":4,"arabic":"مِن","translation":"পক্ষ হ'তে","audioUrl":"wbw/020_129_004.mp3","charTypeName":"word"},{"id":77803,"position":5,"arabic":"رَّبِّكَ","translation":"তোমার রবের","audioUrl":"wbw/020_129_005.mp3","charTypeName":"word"},{"id":77804,"position":6,"arabic":"لَكَانَ","translation":"অবশ্যই হতো (শাস্তি)","audioUrl":"wbw/020_129_006.mp3","charTypeName":"word"},{"id":77805,"position":7,"arabic":"لِزَامًۭا","translation":"অবশ্যম্ভাবী","audioUrl":"wbw/020_129_007.mp3","charTypeName":"word"},{"id":77806,"position":8,"arabic":"وَأَجَلٌۭ","translation":"ও একটি কাল (যদি না থাকতো)","audioUrl":"wbw/020_129_008.mp3","charTypeName":"word"},{"id":77807,"position":9,"arabic":"مُّسَمًّۭى","translation":"নির্দিষ্ট","audioUrl":"wbw/020_129_009.mp3","charTypeName":"word"},{"id":77808,"position":10,"arabic":"١٢٩","translation":"(১২৯)","audioUrl":null,"charTypeName":"end"}]},{"number":130,"arabic":"فَٱصْبِرْ عَلَىٰ مَا يَقُولُونَ وَسَبِّحْ بِحَمْدِ رَبِّكَ قَبْلَ طُلُوعِ ٱلشَّمْسِ وَقَبْلَ غُرُوبِهَا ۖ وَمِنْ ءَانَآئِ ٱلَّيْلِ فَسَبِّحْ وَأَطْرَافَ ٱلنَّهَارِ لَعَلَّكَ تَرْضَىٰ","translation":"Hence, bear with patience whatever they [who deny the truth] may say, and extol thy Sustainer's limitless glory and praise Him before the rising of the sun and before its setting; and extol His glory, too, during some of the hours of the night as well as during the hours of the day, so that thou might attain to happiness.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2478.mp3","surahId":20,"words":[{"id":78002,"position":1,"arabic":"فَٱصْبِرْ","translation":"সুতরাং ধৈর্য ধরো","audioUrl":"wbw/020_130_001.mp3","charTypeName":"word"},{"id":78003,"position":2,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/020_130_002.mp3","charTypeName":"word"},{"id":78004,"position":3,"arabic":"مَا","translation":"যা","audioUrl":"wbw/020_130_003.mp3","charTypeName":"word"},{"id":78005,"position":4,"arabic":"يَقُولُونَ","translation":"তারা বলে","audioUrl":"wbw/020_130_004.mp3","charTypeName":"word"},{"id":78006,"position":5,"arabic":"وَسَبِّحْ","translation":"ও মহিমা ঘোষণা করো","audioUrl":"wbw/020_130_005.mp3","charTypeName":"word"},{"id":78007,"position":6,"arabic":"بِحَمْدِ","translation":"প্রশংসা সহ","audioUrl":"wbw/020_130_006.mp3","charTypeName":"word"},{"id":78008,"position":7,"arabic":"رَبِّكَ","translation":"তোমার রবের","audioUrl":"wbw/020_130_007.mp3","charTypeName":"word"},{"id":78009,"position":8,"arabic":"قَبْلَ","translation":"পূর্বে","audioUrl":"wbw/020_130_008.mp3","charTypeName":"word"},{"id":78010,"position":9,"arabic":"طُلُوعِ","translation":"উদয়ের","audioUrl":"wbw/020_130_009.mp3","charTypeName":"word"},{"id":78011,"position":10,"arabic":"ٱلشَّمْسِ","translation":"সূর্য","audioUrl":"wbw/020_130_010.mp3","charTypeName":"word"},{"id":78012,"position":11,"arabic":"وَقَبْلَ","translation":"ও পূর্বে","audioUrl":"wbw/020_130_011.mp3","charTypeName":"word"},{"id":78013,"position":12,"arabic":"غُرُوبِهَا ۖ","translation":"তার অস্তের","audioUrl":"wbw/020_130_012.mp3","charTypeName":"word"},{"id":78015,"position":13,"arabic":"وَمِنْ","translation":"এবং","audioUrl":"wbw/020_130_014.mp3","charTypeName":"word"},{"id":78016,"position":14,"arabic":"ءَانَآئِ","translation":"কিছু অংশে","audioUrl":"wbw/020_130_015.mp3","charTypeName":"word"},{"id":78017,"position":15,"arabic":"ٱلَّيْلِ","translation":"রাতের","audioUrl":"wbw/020_130_016.mp3","charTypeName":"word"},{"id":78018,"position":16,"arabic":"فَسَبِّحْ","translation":"অতঃপর মহিমা ঘোষণা করো","audioUrl":"wbw/020_130_017.mp3","charTypeName":"word"},{"id":78019,"position":17,"arabic":"وَأَطْرَافَ","translation":"ও প্রান্ত ভাগে","audioUrl":"wbw/020_130_018.mp3","charTypeName":"word"},{"id":78020,"position":18,"arabic":"ٱلنَّهَارِ","translation":"দিনের","audioUrl":"wbw/020_130_019.mp3","charTypeName":"word"},{"id":78021,"position":19,"arabic":"لَعَلَّكَ","translation":"সম্ভবতঃ তুমি","audioUrl":"wbw/020_130_020.mp3","charTypeName":"word"},{"id":78022,"position":20,"arabic":"تَرْضَىٰ","translation":"সন্তুষ্ট হবে","audioUrl":"wbw/020_130_021.mp3","charTypeName":"word"},{"id":78023,"position":21,"arabic":"١٣٠","translation":"(১৩০)","audioUrl":null,"charTypeName":"end"}]},{"number":131,"arabic":"وَلَا تَمُدَّنَّ عَيْنَيْكَ إِلَىٰ مَا مَتَّعْنَا بِهِۦٓ أَزْوَٰجًۭا مِّنْهُمْ زَهْرَةَ ٱلْحَيَوٰةِ ٱلدُّنْيَا لِنَفْتِنَهُمْ فِيهِ ۚ وَرِزْقُ رَبِّكَ خَيْرٌۭ وَأَبْقَىٰ","translation":"And never turn thine, eyes [with longing] towards whatever splendour of this world's life We may have allowed so many others to enjoy in order that We might test them thereby: for the sustenance which thy Sustainer provides [for thee] is better and more enduring.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2479.mp3","surahId":20,"words":[{"id":78045,"position":1,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/020_131_001.mp3","charTypeName":"word"},{"id":78046,"position":2,"arabic":"تَمُدَّنَّ","translation":"প্রসারিত তুমি করো","audioUrl":"wbw/020_131_002.mp3","charTypeName":"word"},{"id":78047,"position":3,"arabic":"عَيْنَيْكَ","translation":"তোমার দুচোখ","audioUrl":"wbw/020_131_003.mp3","charTypeName":"word"},{"id":78048,"position":4,"arabic":"إِلَىٰ","translation":"প্রতি","audioUrl":"wbw/020_131_004.mp3","charTypeName":"word"},{"id":78049,"position":5,"arabic":"مَا","translation":"যা","audioUrl":"wbw/020_131_005.mp3","charTypeName":"word"},{"id":78050,"position":6,"arabic":"مَتَّعْنَا","translation":"আমরা উপকরণ দিয়েছি","audioUrl":"wbw/020_131_006.mp3","charTypeName":"word"},{"id":78051,"position":7,"arabic":"بِهِۦٓ","translation":"সে সম্পর্কে","audioUrl":"wbw/020_131_007.mp3","charTypeName":"word"},{"id":78052,"position":8,"arabic":"أَزْوَٰجًۭا","translation":"বিভিন্ন শ্রেণীকে","audioUrl":"wbw/020_131_008.mp3","charTypeName":"word"},{"id":78053,"position":9,"arabic":"مِّنْهُمْ","translation":"তাদের মধ্যকার","audioUrl":"wbw/020_131_009.mp3","charTypeName":"word"},{"id":78054,"position":10,"arabic":"زَهْرَةَ","translation":"সৌন্দর্য হিসেবে","audioUrl":"wbw/020_131_010.mp3","charTypeName":"word"},{"id":78055,"position":11,"arabic":"ٱلْحَيَوٰةِ","translation":"জীবনের","audioUrl":"wbw/020_131_011.mp3","charTypeName":"word"},{"id":78056,"position":12,"arabic":"ٱلدُّنْيَا","translation":"পার্থিব","audioUrl":"wbw/020_131_012.mp3","charTypeName":"word"},{"id":78057,"position":13,"arabic":"لِنَفْتِنَهُمْ","translation":"যেন তাদের পরীক্ষা করি আমরা","audioUrl":"wbw/020_131_013.mp3","charTypeName":"word"},{"id":78058,"position":14,"arabic":"فِيهِ ۚ","translation":"তার মধ্যে","audioUrl":"wbw/020_131_014.mp3","charTypeName":"word"},{"id":78060,"position":15,"arabic":"وَرِزْقُ","translation":"আর জীবিকাই","audioUrl":"wbw/020_131_016.mp3","charTypeName":"word"},{"id":78061,"position":16,"arabic":"رَبِّكَ","translation":"তোমার রবের","audioUrl":"wbw/020_131_017.mp3","charTypeName":"word"},{"id":78062,"position":17,"arabic":"خَيْرٌۭ","translation":"উত্তম","audioUrl":"wbw/020_131_018.mp3","charTypeName":"word"},{"id":78063,"position":18,"arabic":"وَأَبْقَىٰ","translation":"ও স্থায়ী","audioUrl":"wbw/020_131_019.mp3","charTypeName":"word"},{"id":78064,"position":19,"arabic":"١٣١","translation":"(১৩১)","audioUrl":null,"charTypeName":"end"}]},{"number":132,"arabic":"وَأْمُرْ أَهْلَكَ بِٱلصَّلَوٰةِ وَٱصْطَبِرْ عَلَيْهَا ۖ لَا نَسْـَٔلُكَ رِزْقًۭا ۖ نَّحْنُ نَرْزُقُكَ ۗ وَٱلْعَٰقِبَةُ لِلتَّقْوَىٰ","translation":"And bid thy people to pray, and persevere therein. [But remember:] We do not ask thee to provide sustenance [for Us]: it is We who provide sustenance for thee. And the future belongs to the God-conscious.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2480.mp3","surahId":20,"words":[{"id":78198,"position":1,"arabic":"وَأْمُرْ","translation":"এবং নির্দেশ দাও","audioUrl":"wbw/020_132_001.mp3","charTypeName":"word"},{"id":78199,"position":2,"arabic":"أَهْلَكَ","translation":"তোমার পরিবারকে","audioUrl":"wbw/020_132_002.mp3","charTypeName":"word"},{"id":78200,"position":3,"arabic":"بِٱلصَّلَوٰةِ","translation":"সালাত সম্পর্কে","audioUrl":"wbw/020_132_003.mp3","charTypeName":"word"},{"id":78201,"position":4,"arabic":"وَٱصْطَبِرْ","translation":"এবং দৃঢ় থাকো","audioUrl":"wbw/020_132_004.mp3","charTypeName":"word"},{"id":78202,"position":5,"arabic":"عَلَيْهَا ۖ","translation":"তার উপর","audioUrl":"wbw/020_132_005.mp3","charTypeName":"word"},{"id":78204,"position":6,"arabic":"لَا","translation":"না","audioUrl":"wbw/020_132_007.mp3","charTypeName":"word"},{"id":78205,"position":7,"arabic":"نَسْـَٔلُكَ","translation":"তোমার কাছে চাই আমরা","audioUrl":"wbw/020_132_008.mp3","charTypeName":"word"},{"id":78206,"position":8,"arabic":"رِزْقًۭا ۖ","translation":"কোন জীবিকা","audioUrl":"wbw/020_132_009.mp3","charTypeName":"word"},{"id":78208,"position":9,"arabic":"نَّحْنُ","translation":"আমরাই","audioUrl":"wbw/020_132_011.mp3","charTypeName":"word"},{"id":78209,"position":10,"arabic":"نَرْزُقُكَ ۗ","translation":"তোমাকে জীবিকা দিই","audioUrl":"wbw/020_132_012.mp3","charTypeName":"word"},{"id":78211,"position":11,"arabic":"وَٱلْعَـٰقِبَةُ","translation":"এবং পরিণাম (শুভ)","audioUrl":"wbw/020_132_014.mp3","charTypeName":"word"},{"id":78212,"position":12,"arabic":"لِلتَّقْوَىٰ","translation":"জন্যে মুত্তাকীদের","audioUrl":"wbw/020_132_015.mp3","charTypeName":"word"},{"id":78213,"position":13,"arabic":"١٣٢","translation":"(১৩২)","audioUrl":null,"charTypeName":"end"}]},{"number":133,"arabic":"وَقَالُوا۟ لَوْلَا يَأْتِينَا بِـَٔايَةٍۢ مِّن رَّبِّهِۦٓ ۚ أَوَلَمْ تَأْتِهِم بَيِّنَةُ مَا فِى ٱلصُّحُفِ ٱلْأُولَىٰ","translation":"NOW THEY [who are blind to the truth] are wont to say, \"If [Muhammad] would but produce for us a miracle from his Sustainer! [But] has there not come unto them a clear evidence [of the truth of this divine writ] in what is [to be found] in the earlier scriptures?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2481.mp3","surahId":20,"words":[{"id":78331,"position":1,"arabic":"وَقَالُوا۟","translation":"এবং তারা বলে","audioUrl":"wbw/020_133_001.mp3","charTypeName":"word"},{"id":78332,"position":2,"arabic":"لَوْلَا","translation":"\"কেন না","audioUrl":"wbw/020_133_002.mp3","charTypeName":"word"},{"id":78333,"position":3,"arabic":"يَأْتِينَا","translation":"আমাদের কাছে আসে","audioUrl":"wbw/020_133_003.mp3","charTypeName":"word"},{"id":78334,"position":4,"arabic":"بِـَٔايَةٍۢ","translation":"একটি নিদর্শন (অর্থাৎ মুজি'যা)","audioUrl":"wbw/020_133_004.mp3","charTypeName":"word"},{"id":78335,"position":5,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/020_133_005.mp3","charTypeName":"word"},{"id":78336,"position":6,"