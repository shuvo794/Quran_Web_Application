3","charTypeName":"word"},{"id":8072,"position":5,"arabic":"بِيَمِينِهِۦ","translation":"তার ডান হাতে","audioUrl":"wbw/084_007_005.mp3","charTypeName":"word"},{"id":8073,"position":6,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"فَسَوْفَ يُحَاسَبُ حِسَابًۭا يَسِيرًۭا","translation":"he will in time be called to account with an easy accounting,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5892.mp3","surahId":84,"words":[{"id":9238,"position":1,"arabic":"فَسَوْفَ","translation":"অতঃপর শীঘ্র","audioUrl":"wbw/084_008_001.mp3","charTypeName":"word"},{"id":9239,"position":2,"arabic":"يُحَاسَبُ","translation":"হিসাব নেয়া হবে (তার)","audioUrl":"wbw/084_008_002.mp3","charTypeName":"word"},{"id":9240,"position":3,"arabic":"حِسَابًۭا","translation":"হিসাব","audioUrl":"wbw/084_008_003.mp3","charTypeName":"word"},{"id":9241,"position":4,"arabic":"يَسِيرًۭا","translation":"সহজ","audioUrl":"wbw/084_008_004.mp3","charTypeName":"word"},{"id":9242,"position":5,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"وَيَنقَلِبُ إِلَىٰٓ أَهْلِهِۦ مَسْرُورًۭا","translation":"and will [be able to] turn joyfully to those of his own kind.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5893.mp3","surahId":84,"words":[{"id":10433,"position":1,"arabic":"وَيَنقَلِبُ","translation":"এবং ফিরবে","audioUrl":"wbw/084_009_001.mp3","charTypeName":"word"},{"id":10434,"position":2,"arabic":"إِلَىٰٓ","translation":"কাছে","audioUrl":"wbw/084_009_002.mp3","charTypeName":"word"},{"id":10435,"position":3,"arabic":"أَهْلِهِۦ","translation":"তার আপনজনের","audioUrl":"wbw/084_009_003.mp3","charTypeName":"word"},{"id":10436,"position":4,"arabic":"مَسْرُورًۭا","translation":"আনন্দচিত্তে","audioUrl":"wbw/084_009_004.mp3","charTypeName":"word"},{"id":10437,"position":5,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"وَأَمَّا مَنْ أُوتِىَ كِتَٰ