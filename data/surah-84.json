{"id":84,"nameArabic":"سُورَةُ الانشِقَاقِ","nameEnglish":"Al-Inshiqaaq","nameTranslation":"The Splitting Open","revelationType":"Meccan","numberOfAyahs":25,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ إِذَا ٱلسَّمَآءُ ٱنشَقَّتْ","translation":"WHEN THE SKY is split asunder,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5885.mp3","surahId":84,"words":[{"id":706,"position":1,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/084_001_001.mp3","charTypeName":"word"},{"id":707,"position":2,"arabic":"ٱلسَّمَآءُ","translation":"আকাশ","audioUrl":"wbw/084_001_002.mp3","charTypeName":"word"},{"id":708,"position":3,"arabic":"ٱنشَقَّتْ","translation":"ফেটে পড়বে","audioUrl":"wbw/084_001_003.mp3","charTypeName":"word"},{"id":709,"position":4,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"وَأَذِنَتْ لِرَبِّهَا وَحُقَّتْ","translation":"obeying its Sustainer, as in truth it must;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5886.mp3","surahId":84,"words":[{"id":1737,"position":1,"arabic":"وَأَذِنَتْ","translation":"এবং সে নির্দেশ পালন করবে","audioUrl":"wbw/084_002_001.mp3","charTypeName":"word"},{"id":1738,"position":2,"arabic":"لِرَبِّهَا","translation":"তার রবের","audioUrl":"wbw/084_002_002.mp3","charTypeName":"word"},{"id":1739,"position":3,"arabic":"وَحُقَّتْ","translation":"ও এটাই তার করণীয়","audioUrl":"wbw/084_002_003.mp3","charTypeName":"word"},{"id":1740,"position":4,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"وَإِذَا ٱلْأَرْضُ مُدَّتْ","translation":"and when the earth is leveled,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5887.mp3","surahId":84,"words":[{"id":2889,"position":1,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/084_003_001.mp3","charTypeName":"word"},{"id":2890,"position":2,"arabic":"ٱلْأَرْضُ","translation":"পৃথিবী","audioUrl":"wbw/084_003_002.mp3","charTypeNam