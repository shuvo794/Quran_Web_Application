3","charTypeName":"word"},{"id":16441,"position":5,"arabic":"يَحُورَ","translation":"ফিরবে","audioUrl":"wbw/084_014_005.mp3","charTypeName":"word"},{"id":16442,"position":6,"arabic":"١٤","translation":"(১৪)","audioUrl":null,"charTypeName":"end"}]},{"number":15,"arabic":"بَلَىٰٓ إِنَّ رَبَّهُۥ كَانَ بِهِۦ بَصِيرًۭا","translation":"Yea indeed! His Sustainer did see all that was in him!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5899.mp3","surahId":84,"words":[{"id":17305,"position":1,"arabic":"بَلَىٰٓ","translation":"হ্যাঁ","audioUrl":"wbw/084_015_001.mp3","charTypeName":"word"},{"id":17306,"position":2,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/084_015_002.mp3","charTypeName":"word"},{"id":17307,"position":3,"arabic":"رَبَّهُۥ","translation":"তার রব","audioUrl":"wbw/084_015_003.mp3","charTypeName":"word"},{"id":17308,"position":4,"arabic":"كَانَ","translation":"ছিলেন","audioUrl":"wbw/084_015_004.mp3","charTypeName":"word"},{"id":17309,"position":5,"arabic":"بِهِۦ","translation":"তার উপর","audioUrl":"wbw/084_015_005.mp3","charTypeName":"word"},{"id":17310,"position":6,"arabic":"بَصِيرًۭا","translation":"দৃষ্টিবান","audioUrl":"wbw/084_015_006.mp3","charTypeName":"word"},{"id":17311,"position":7,"arabic":"١٥","translation":"(১৫)","audioUrl":null,"charTypeName":"end"}]},{"number":16,"arabic":"فَلَآ أُقْسِمُ بِٱلشَّفَقِ","translation":"BUT NAY! I call to witness the sunset's [fleeting] afterglow,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5900.mp3","surahId":84,"words":[{"id":18638,"position":1,"arabic":"فَلَآ","translation":"অতএব না","audioUrl":"wbw/084_016_001.mp3","charTypeName":"word"},{"id":18639,"position":2,"arabic":"أُقْسِمُ","translation":"আমি শপথ করছি","audioUrl":"wbw/084_016_002.mp3","charTypeName":"word"},{"id":18640,"position":3,"arabic":"بِٱلشَّفَقِ","translation":"পশ্চিম দিগন্তের সান্ধ্য লালিমার","audioUrl":"wbw/084_016_003.mp3","charTypeName":"word"},{"id":18641,"position":4,"arabic":"١٦","transl