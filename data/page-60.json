translation":"Do they seek, perchance, a faith other than in God, although it is unto Him that whatever is in the heavens and on earth surrenders itself, willingly or unwillingly, since unto Him all must return?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/376.mp3","surahId":3,"words":[{"id":65432,"position":1,"arabic":"أَفَغَيْرَ","translation":"তাহলে কি ব্যতীত","audioUrl":"wbw/003_083_001.mp3","charTypeName":"word"},{"id":65433,"position":2,"arabic":"دِينِ","translation":"দ্বীন","audioUrl":"wbw/003_083_002.mp3","charTypeName":"word"},{"id":65434,"position":3,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/003_083_003.mp3","charTypeName":"word"},{"id":65435,"position":4,"arabic":"يَبْغُونَ","translation":"তারা চায় (অন্যদ্বীন)","audioUrl":"wbw/003_083_004.mp3","charTypeName":"word"},{"id":65436,"position":5,"arabic":"وَلَهُۥٓ","translation":"তার কাছে","audioUrl":"wbw/003_083_005.mp3","charTypeName":"word"},{"id":65437,"position":6,"arabic":"أَسْلَمَ","translation":"আত্মসমর্পণ করেছে","audioUrl":"wbw/003_083_006.mp3","charTypeName":"word"},{"id":65438,"position":7,"arabic":"مَن","translation":"যা কিছু","audioUrl":"wbw/003_083_007.mp3","charTypeName":"word"},{"id":65439,"position":8,"arabic":"فِى","translation":"মধ্যে আছে","audioUrl":"wbw/003_083_008.mp3","charTypeName":"word"},{"id":65440,"position":9,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আসমান সমূহের","audioUrl":"wbw/003_083_009.mp3","charTypeName":"word"},{"id":65441,"position":10,"arabic":"وَٱلْأَرْضِ","translation":"ও যমীনে","audioUrl":"wbw/003_083_010.mp3","charTypeName":"word"},{"id":65442,"position":11,"arabic":"طَوْعًۭا","translation":"ইচ্ছায়","audioUrl":"wbw/003_083_011.mp3","charTypeName":"word"},{"id":65443,"position":12,"arabic":"وَكَرْهًۭا","translation":"বা অনিচ্ছায়","audioUrl":"wbw/003_083_012.mp3","charTypeName":"word"},{"id":65444,"position":13,"arabic":"وَإِلَيْهِ","translation":"আর তারই দিকে","audioUrl":"wbw/003_083_013.mp3","charTypeName":"word"},{"id":65445,"position":14,"arabic":"يُرْجَعُونَ","translation":"তাদের প্রত্যাবর্তন করা হবে","audioUrl":"wbw/003_083_014.mp3","charTypeName":"word"},{"id":65446,"position":15,"arabic":"٨٣","translation":"(৮৩)","audioUrl":null,"charTypeName":"end"}]}]}