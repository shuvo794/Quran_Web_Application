/003_078_026.mp3","charTypeName":"word"},{"id":63544,"position":27,"arabic":"ٱلْكَذِبَ","translation":"মিথ্যা","audioUrl":"wbw/003_078_027.mp3","charTypeName":"word"},{"id":63545,"position":28,"arabic":"وَهُمْ","translation":"অথচ তারা","audioUrl":"wbw/003_078_028.mp3","charTypeName":"word"},{"id":63546,"position":29,"arabic":"يَعْلَمُونَ","translation":"(ভালভাবে) জানে","audioUrl":"wbw/003_078_029.mp3","charTypeName":"word"},{"id":63547,"position":30,"arabic":"٧٨","translation":"(৭৮)","audioUrl":null,"charTypeName":"end"}]},{"number":79,"arabic":"مَا كَانَ لِبَشَرٍ أَن يُؤْتِيَهُ ٱللَّهُ ٱلْكِتَٰبَ وَٱلْحُكْمَ وَٱلنُّبُوَّةَ ثُمَّ يَقُولَ لِلنَّاسِ كُونُوا۟ عِبَادًۭا لِّى مِن دُونِ ٱللَّهِ وَلَٰكِن كُونُوا۟ رَبَّٰنِيِّۦنَ بِمَا كُنتُمْ تُعَلِّمُونَ ٱلْكِتَٰبَ وَبِمَا كُنتُمْ تَدْرُسُونَ","translation":"It is not conceivable that a human being unto whom God had granted revelation, and sound judgment, and prophethood, should thereafter have said unto people, \"Worship me beside God\"; but rather [did he exhort them], \"Become men of God by spreading the knowledge of the divine writ, and by your own deep study [thereof].\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/372.mp3","surahId":3,"words":[{"id":63949,"position":1,"arabic":"مَا","translation":"নয়","audioUrl":"wbw/003_079_001.mp3","charTypeName":"word"},{"id":63950,"position":2,"arabic":"كَانَ","translation":"শোভনীয়","audioUrl":"wbw/003_079_002.mp3","charTypeName":"word"},{"id":63951,"position":3,"arabic":"لِبَشَرٍ","translation":"কোন মানুষের জন্যে","audioUrl":"wbw/003_079_003.mp3","charTypeName":"word"},{"id":63952,"position":4,"arabic":"أَن","translation":"যে","audioUrl":"wbw/003_079_004.mp3","charTypeName":"word"},{"id":63953,"position":5,"arabic":"يُؤْتِيَهُ","translation":"তাকে দেবেন","audioUrl":"wbw/003_079_005.mp3","charTypeName":"word"},{"id":63954,"position":6,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/003_079_006.mp3","charTypeName":"word"},{"id":63955,"position":7,"arabic":"ٱلْكِتَـٰبَ","translation":"কিতাব","audioUrl":"wbw/003_079_007.mp3","charTypeName":"word"},{"id":63956,"position":8,"arabic":"وَٱلْحُكْمَ","translation":"ও জ্ঞান","audioUrl":"wbw/003_079_008.mp3","charTypeName":"word"},{"id":63957,"position":9,"arabic":"وَٱلنُّبُوَّةَ","translation":"ও নবূয়্যত","audioUrl":"wbw/003_079_009.mp3","charTypeName":"word"},{"id":63958,"position":10,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/003_079_010.mp3","charTypeName":"word"},{"id":63959,"position":11,"arabic":"يَقُولَ","translation":"সে বলবে","audioUrl":"wbw/003_079_011.mp3","charTypeName":"word"},{"id":63960,"position":12,"arabic":"لِلنَّاسِ","translation":"মানুষকে","audioUrl":"wbw/003_079_012.mp3","charTypeName":"word"},{"id":63961,"position":13,"arabic":"كُونُوا۟","translation":"''তোমরা হয়ে যাও","audioUrl":"wbw/003_079_013.mp3","charTypeName":"word"},{"id":63962,"position":14,"arabic":"عِبَادًۭا","translation":"দাস","audioUrl":"wbw/003_079_014.mp3","charTypeName":"word"},{"id":63963,"position":15,"arabic":"لِّى","translation":"আমার","audioUrl":"wbw/003_079_015.mp3","charTypeName":"word"},{"id":63964,"position":16,"arabic":"مِن","translation":"(থেকে)","audioUrl":"wbw/003_079_016.mp3","charTypeName":"word"},{"id":63965,"position":17,"arabic":"دُونِ","translation":"ব্যতীত","audioUrl":"wbw/003_079_017.mp3","charTypeName":"word"},{"id":63966,"position":18,"arabic":"ٱللَّهِ","translation":"আল্লাহ","audioUrl":"wbw/003_079_018.mp3","charTypeName":"word"},{"id":63967,"position":19,"arabic":"وَلَـٰكِن","translation":"কিন্তু (সে বলবে)","audioUrl":"wbw/003_079_019.mp3","charTypeName":"word"},{"id":63968,"position":20,"arabic":"كُونُوا۟","translation":"''তোমরা হও","audioUrl":"wbw/003_079_020.mp3","charTypeName":"word"},{"id":63969,"position":21,"arabic":"رَبَّـٰنِيِّـۧنَ","translation":"আল্লাহওয়ালা","audioUrl":"wbw/003_079_021.mp3","charTypeName":"word"},{"id":63970,"position":22,"arabic":"بِمَا","translation":"যেহেতু","audioUrl":"wbw/003_079_022.mp3","charTypeName":"word"},{"id":63971,"position":23,"arabic":"كُنتُمْ","translation":"তোমরা","audioUrl":"wbw/003_079_023.mp3","charTypeName":"word"},{"id":63972,"position":24,"arabic":"تُعَلِّمُونَ","translation":"শিখিয়ে থাক","audioUrl":"wbw/003_079_024.mp3","charTypeName":"word"},{"id":63973,"position":25,"arabic":"ٱلْكِتَـٰبَ","translation":"কিতাব","audioUrl":"wbw/003_079_025.mp3","charTypeName":"word"},{"id":63974,"position":26,"arabic":"وَبِمَا","translation":"ও যেহেতু","audioUrl":"wbw/003_079_026.mp3","charTypeName":"word"},{"id":63975,"position":27,"arabic":"كُنتُمْ","translation":"(আপনি)","audioUrl":"wbw/003_079_027.mp3","charTypeName":"word"},{"id":63976,"position":28,"arabic":"تَدْرُسُونَ","translation":"তোমরা অধ্যয়ন করে থাক''","audioUrl":"wbw/003_079_028.mp3","charTypeName":"word"},{"id":63977,"position":29,"arabic":"٧٩","translation":"(৭৯)","audioUrl":null,"charTypeName":"end"}]},{"number":80,"arabic":"وَلَا يَأْمُرَكُمْ أَن تَتَّخِذُوا۟ ٱلْمَلَٰٓئِكَةَ وَٱلنَّبِيِّۦنَ أَرْبَابًا ۗ أَيَأْمُرُكُم بِٱلْكُفْرِ بَعْدَ إِذْ أَنتُم مُّسْلِمُونَ","translation":"And neither did he bid you to take the angels and the prophets for your lords: [for] would he bid you to deny the truth after you have surrendered yourselves unto God?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/373.mp3","surahId":3,"words":[{"id":64239,"position":1,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/003_080_001.mp3","charTypeName":"word"},{"id":64240,"position":2,"arabic":"يَأْمُرَكُمْ","translation":"তোমাদেরকে নির্দেশ দিবে সে","audioUrl":"wbw/003_080_002.mp3","charTypeName":"word"},{"id":64241,"position":3,"arabic":"أَن","translation":"যে","audioUrl":"wbw/003_080_003.mp3","charTypeName":"word"},{"id":64242,"position":4,"arabic":"تَتَّخِذُوا۟","translation":"তোমরা গ্রহণ করবে","audioUrl":"wbw/003_080_004.mp3","charTypeName":"word"},{"id":64243,"position":5,"arabic":"ٱلْمَلَـٰٓئِكَةَ","translation":"ফেরেশতাদেরকে","audioUrl":"wbw/003_080_005.mp3","charTypeName":"word"},{"id":64244,"position":6,"arabic":"وَٱلنَّبِيِّـۧنَ","translation":"ও নবীদেরকে","audioUrl":"wbw/003_080_006.mp3","charTypeName":"word"},{"id":64245,"position":7,"arabic":"أَرْبَابًا ۗ","translation":"প্রভু হিসেবে","audioUrl":"wbw/003_080_007.mp3","charTypeName":"word"},{"id":64247,"position":8,"arabic":"أَيَأْمُرُكُم","translation":"তোমাদের নির্দেশ দেবে কি","audioUrl":"wbw/003_080_009.mp3","charTypeName":"word"},{"id":64248,"position":9,"arabic":"بِٱلْكُفْرِ","translation":"কুফরীর","audioUrl":"wbw/003_080_010.mp3","charTypeName":"word"},{"id":64249,"position":10,"arabic":"بَعْدَ","translation":"এরপরেও","audioUrl":"wbw/003_080_011.mp3","charTypeName":"word"},{"id":64250,"position":11,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/003_080_012.mp3","charTypeName":"word"},{"id":64251,"position":12,"arabic":"أَنتُم","translation":"তোমরা","audioUrl":"wbw/003_080_013.mp3","charTypeName":"word"},{"id":64252,"position":13,"arabic":"مُّسْلِمُونَ","translation":"মুসলমান (তা কি সম্ভব?)","audioUrl":"wbw/003_080_014.mp3","charTypeName":"word"},{"id":64253,"position":14,"arabic":"٨٠","translation":"(৮০)","audioUrl":null,"charTypeName":"end"}]},{"number":81,"arabic":"وَإِذْ أَخَذَ ٱللَّهُ مِيثَٰقَ ٱلنَّبِيِّۦنَ لَمَآ ءَاتَيْتُكُم مِّن كِتَٰبٍۢ وَحِكْمَةٍۢ ثُمَّ جَآءَكُمْ رَسُولٌۭ مُّصَدِّقٌۭ لِّمَا مَعَكُمْ لَتُؤْمِنُنَّ بِهِۦ وَلَتَنصُرُنَّهُۥ ۚ قَالَ ءَأَقْرَرْتُمْ وَأَخَذْتُمْ عَلَىٰ ذَٰلِكُمْ إِصْرِى ۖ قَالُوٓا۟ أَقْرَرْنَا ۚ قَالَ فَٱشْهَدُوا۟ وَأَنَا۠ مَعَكُم مِّنَ ٱلشَّٰهِدِينَ","translation":"AND, LO, God accepted, through the prophets, this solemn pledge [from the followers of earlier revelation]: \"If, after all the revelation and the wisdom which I have vouchsafed unto you, there comes to you an apostle confirming the truth already in your possession, you must believe in him and succour him. Do you\" - said He - \"acknowledge and accept My bond on this condition?\" They answered: \"We do acknowledge it.\" Said He: \"Then bear witness [thereto], and I shall be your witness.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/374.mp3","surahId":3,"words":[{"id":64752,"position":1,"arabic":"وَإِذْ","translation":"এবং (স্মরণ কর) যখন","audioUrl":"wbw/003_081_001.mp3","charTypeName":"word"},{"id":64753,"position":2,"arabic":"أَخَذَ","translation":"গ্রহণ করেন","audioUrl":"wbw/003_081_002.mp3","charTypeName":"word"},{"id":64754,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/003_081_003.mp3","charTypeName":"word"},{"id":64755,"position":4,"arabic":"مِيثَـٰقَ","translation":"অঙ্গীকার","audioUrl":"wbw/003_081_004.mp3","charTypeName":"word"},{"id":64756,"position":5,"arabic":"ٱلنَّبِيِّـۧنَ","translation":"নবীদের (থেকে এই বলে যে)","audioUrl":"wbw/003_081_005.mp3","charTypeName":"word"},{"id":64757,"position":6,"arabic":"لَمَآ","translation":"''অবশ্যই যা","audioUrl":"wbw/003_081_006.mp3","charTypeName":"word"},{"id":64758,"position":7,"arabic":"ءَاتَيْتُكُم","translation":"তোমাদের আমি দিয়েছি","audioUrl":"wbw/003_081_007.mp3","charTypeName":"word"},{"id":64759,"position":8,"arabic":"مِّن","translation":"(থেকে)","audioUrl":"wbw/003_081_008.mp3","charTypeName":"word"},{"id":64760,"position":9,"arabic":"كِتَـٰبٍۢ","translation":"কিতাব","audioUrl":"wbw/003_081_009.mp3","charTypeName":"word"},{"id":64761,"position":10,"arabic":"وَحِكْمَةٍۢ","translation":"ও হেকমত","audioUrl":"wbw/003_081_010.mp3","charTypeName":"word"},{"id":64762,"position":11,"arabic":"ثُمَّ","translation":"এরপর (যখন)","audioUrl":"wbw/003_081_011.mp3","charTypeName":"word"},{"id":64763,"position":12,"arabic":"جَآءَكُمْ","translation":"তোমাদের কাছে আসবে","audioUrl":"wbw/003_081_012.mp3","charTypeName":"word"},{"id":64764,"position":13,"arabic":"رَسُولٌۭ","translation":"কোন রসূল","audioUrl":"wbw/003_081_013.mp3","charTypeName":"word"},{"id":64765,"position":14,"arabic":"مُّصَدِّقٌۭ","translation":"সত্যায়নকারী","audioUrl":"wbw/003_081_014.mp3","charTypeName":"word"},{"id":64766,"position":15,"arabic":"لِّمَا","translation":"তার যা","audioUrl":"wbw/003_081_015.mp3","charTypeName":"word"},{"id":64767,"position":16,"arabic":"مَعَكُمْ","translation":"তোমাদের সাথে আছে","audioUrl":"wbw/003_081_016.mp3","charTypeName":"word"},{"id":64768,"position":17,"arabic":"لَتُؤْمِنُنَّ","translation":"তোমরা অবশ্যই বিশ্বাস করবে","audioUrl":"wbw/003_081_017.mp3","charTypeName":"word"},{"id":64769,"position":18,"arabic":"بِهِۦ","translation":"তার উপর","audioUrl":"wbw/003_081_018.mp3","charTypeName":"word"},{"id":64770,"position":19,"arabic":"وَلَتَنصُرُنَّهُۥ ۚ","translation":"ও তাকে তোমরা অবশ্যই সাহায্য করবে''","audioUrl":"wbw/003_081_019.mp3","charTypeName":"word"},{"id":64772,"position":20,"arabic":"قَالَ","translation":"তিনি বললেন","audioUrl":"wbw/003_081_021.mp3","charTypeName":"word"},{"id":64773,"position":21,"arabic":"ءَأَقْرَرْتُمْ","translation":"''তোমরা অঙ্গীকার করলে কি","audioUrl":"wbw/003_081_022.mp3","charTypeName":"word"},{"id":64774,"position":22,"arabic":"وَأَخَذْتُمْ","translation":"ও তোমরা গ্রহণ করলে (কি)","audioUrl":"wbw/003_081_023.mp3","charTypeName":"word"},{"id":64775,"position":23,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/003_081_024.mp3","charTypeName":"word"},{"id":64776,"position":24,"arabic":"ذَٰلِكُمْ","translation":"এসবের","audioUrl":"wbw/003_081_025.mp3","charTypeName":"word"},{"id":64777,"position":25,"arabic":"إِصْرِى ۖ","translation":"দায়িত্বভার","audioUrl":"wbw/003_081_026.mp3","charTypeName":"word"},{"id":64779,"position":26,"arabic":"قَالُوٓا۟","translation":"তারা বলল","audioUrl":"wbw/003_081_028.mp3","charTypeName":"word"},{"id":64780,"position":27,"arabic":"أَقْرَرْنَا ۚ","translation":"''আমরা অঙ্গীকার করলাম''","audioUrl":"wbw/003_081_029.mp3","charTypeName":"word"},{"id":64782,"position":28,"arabic":"قَالَ","translation":"তিনি বললেন","audioUrl":"wbw/003_081_031.mp3","charTypeName":"word"},{"id":64783,"position":29,"arabic":"فَٱشْهَدُوا۟","translation":"''তোমরা সাক্ষী থাকো","audioUrl":"wbw/003_081_032.mp3","charTypeName":"word"},{"id":64784,"position":30,"arabic":"وَأَنَا۠","translation":"এবং আ