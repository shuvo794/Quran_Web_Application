/072_004_002.mp3","charTypeName":"word"},{"id":4028,"position":3,"arabic":"يَقُولُ","translation":"বলত","audioUrl":"wbw/072_004_003.mp3","charTypeName":"word"},{"id":4029,"position":4,"arabic":"سَفِيهُنَا","translation":"আমাদের নির্বোধরা","audioUrl":"wbw/072_004_004.mp3","charTypeName":"word"},{"id":4030,"position":5,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/072_004_005.mp3","charTypeName":"word"},{"id":4031,"position":6,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/072_004_006.mp3","charTypeName":"word"},{"id":4032,"position":7,"arabic":"شَطَطًۭا","translation":"সীমাহীন মিথ্যা","audioUrl":"wbw/072_004_007.mp3","charTypeName":"word"},{"id":4033,"position":8,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"وَأَنَّا ظَنَنَّآ أَن لَّن تَقُولَ ٱلْإِنسُ وَٱلْجِنُّ عَلَى ٱللَّهِ كَذِبًۭا","translation":"and that [we were mistaken when] we thought that neither man nor [any of] the invisible forces would ever tell a lie about God.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5452.mp3","surahId":72,"words":[{"id":5314,"position":1,"arabic":"وَأَنَّا","translation":"এবং আমরা যে","audioUrl":"wbw/072_005_001.mp3","charTypeName":"word"},{"id":5315,"position":2,"arabic":"ظَنَنَّآ","translation":"ভেবেছিলাম","audioUrl":"wbw/072_005_002.mp3","charTypeName":"word"},{"id":5316,"position":3,"arabic":"أَن","translation":"যে","audioUrl":"wbw/072_005_003.mp3","charTypeName":"word"},{"id":5317,"position":4,"arabic":"لَّن","translation":"কখনও না","audioUrl":"wbw/072_005_004.mp3","charTypeName":"word"},{"id":5318,"position":5,"arabic":"تَقُولَ","translation":"বলবে","audioUrl":"wbw/072_005_005.mp3","charTypeName":"word"},{"id":5319,"position":6,"arabic":"ٱلْإِنسُ","translation":"মানুষ","audioUrl":"wbw/072_005_006.mp3","charTypeName":"word"},{"id":5320,"position":7,"arabic":"وَٱلْجِنُّ","translation":"ও জীন্ন","audioUrl":"wbw/072_005_007.mp3","charTypeName":"word"},{"id":5321,"position":8,"arabic":"عَلَى","translation":"সম্পর্কে","audioUrl":"wbw/072_005_008.mp3","charTypeName":"word"},{"id":5322,"position":9,"arabic":"ٱللَّهِ","translation":"আল্লাহ","audioUrl":"wbw/072_005_009.mp3","charTypeName":"word"},{"id":5323,"position":10,"arabic":"كَذِبًۭا","translation":"মিথ্যা","audioUrl":"wbw/072_005_010.mp3","charTypeName":"word"},{"id":5324,"position":11,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"وَأَنَّهُۥ كَانَ رِجَالٌۭ مِّنَ ٱلْإِنسِ يَعُوذُونَ بِرِجَالٍۢ مِّنَ ٱلْجِنِّ فَزَادُوهُمْ رَهَقًۭا","translation":"Yet [it has always happened] that certain kinds of humans would seek refuge with certain kinds of [such] invisible forces: but these only increased their confusion –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5453.mp3","surahId":72,"words":[{"id":6515,"position":1,"arabic":"وَأَنَّهُۥ","translation":"এবং যে","audioUrl":"wbw/072_006_001.mp3","charTypeName":"word"},{"id":6516,"position":2,"arabic":"كَانَ","translation":"ছিল","audioUrl":"wbw/072_006_002.mp3","charTypeName":"word"},{"id":6517,"position":3,"arabic":"رِجَالٌۭ","translation":"কিছু লোক","audioUrl":"wbw/072_006_003.mp3","charTypeName":"word"},{"id":6518,"position":4,"arabic":"مِّنَ","translation":"মধ্যে","audioUrl":"wbw/072_006_004.mp3","charTypeName":"word"},{"id":6519,"position":5,"arabic":"ٱلْإِنسِ","translation":"মানুষের","audioUrl":"wbw/072_006_005.mp3","charTypeName":"word"},{"id":6520,"position":6,"arabic":"يَعُوذُونَ","translation":"আশ্রয় চাইত","audioUrl":"wbw/072_006_006.mp3","charTypeName":"word"},{"id":6521,"position":7,"arabic":"بِرِجَالٍۢ","translation":"কিছু লোকের","audioUrl":"wbw/072_006_007.mp3","charTypeName":"word"},{"id":6522,"position":8,"arabic":"مِّنَ","translation":"মধ্যের","audioUrl":"wbw/072_006_008.mp3","charTypeName":"word"},{"id":6523,"position":9,"arabic":"ٱلْجِنِّ","translation":"জিন্নদের","audioUrl":"wbw/072_006_009.mp3","charTypeName":"word"},{"id":6524,"position":10,"arabic":"فَزَادُوهُمْ","translation":"তাদের বাড়িয়েছিল এভাবে","audioUrl":"wbw/072_006_010.mp3","charTypeName":"word"},{"id":6525,"position":11,"arabic":"رَهَقًۭا","translation":"অহংকার","audioUrl":"wbw/072_006_011.mp3","charTypeName":"word"},{"id":6526,"position":12,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"وَأَنَّهُمْ ظَنُّوا۟ كَمَا ظَنَنتُمْ أَن لَّن يَبْعَثَ ٱللَّهُ أَحَدًۭا","translation":"so much so that they came to think, as you [once] thought, that God would never [again] send forth anyone [as His apostle].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5454.mp3","surahId":72,"words":[{"id":7930,"position":1,"arabic":"وَأَنَّهُمْ","translation":"এবং তারা যে","audioUrl":"wbw/072_007_001.mp3","charTypeName":"word"},{"id":7931,"position":2,"arabic":"ظَنُّوا۟","translation":"ভেবেছিল","audioUrl":"wbw/072_007_002.mp3","charTypeName":"word"},{"id":7932,"position":3,"arabic":"كَمَا","translation":"যেমন","audioUrl":"wbw/072_007_003.mp3","charTypeName":"word"},{"id":7933,"position":4,"arabic":"ظَنَنتُمْ","translation":"তোমরা ভেবেছ","audioUrl":"wbw/072_007_004.mp3","charTypeName":"word"},{"id":7934,"position":5,"arabic":"أَن","translation":"যে","audioUrl":"wbw/072_007_005.mp3","charTypeName":"word"},{"id":7935,"position":6,"arabic":"لَّن","translation":"কখনও না","audioUrl":"wbw/072_007_006.mp3","charTypeName":"word"},{"id":7936,"position":7,"arabic":"يَبْعَثَ","translation":"পাঠাবেন","audioUrl":"wbw/072_007_007.mp3","charTypeName":"word"},{"id":7937,"position":8,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/072_007_008.mp3","charTypeName":"word"},{"id":7938,"position":9,"arabic":"أَحَدًۭا","translation":"কাউকে (রাসূলরূপে)","audioUrl":"wbw/072_007_009.mp3","charTypeName":"word"},{"id":7939,"position":10,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"وَأَنَّا لَمَسْنَا ٱلسَّمَآءَ فَوَجَدْنَٰهَا مُلِئَتْ حَرَسًۭا شَدِيدًۭا وَشُهُبًۭا","translation":"\"'And [so it happened] t