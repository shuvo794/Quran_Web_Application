{"id":72,"nameArabic":"سُورَةُ الجِنِّ","nameEnglish":"Al-Jinn","nameTranslation":"The Jinn","revelationType":"Meccan","numberOfAyahs":28,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ قُلْ أُوحِىَ إِلَىَّ أَنَّهُ ٱسْتَمَعَ نَفَرٌۭ مِّنَ ٱلْجِنِّ فَقَالُوٓا۟ إِنَّا سَمِعْنَا قُرْءَانًا عَجَبًۭا","translation":"SAY: \"It has been revealed to me that some of the unseen beings gave ear [to this divine writ], and thereupon said [unto their fellow-beings]: \"'Verily, we have heard a wondrous discourse,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5448.mp3","surahId":72,"words":[{"id":614,"position":1,"arabic":"قُلْ","translation":"বল (হে নবী)","audioUrl":"wbw/072_001_001.mp3","charTypeName":"word"},{"id":615,"position":2,"arabic":"أُوحِىَ","translation":"\"ওহী করা হয়েছে","audioUrl":"wbw/072_001_002.mp3","charTypeName":"word"},{"id":616,"position":3,"arabic":"إِلَىَّ","translation":"আমার প্রতি","audioUrl":"wbw/072_001_003.mp3","charTypeName":"word"},{"id":617,"position":4,"arabic":"أَنَّهُ","translation":"যে","audioUrl":"wbw/072_001_004.mp3","charTypeName":"word"},{"id":618,"position":5,"arabic":"ٱسْتَمَعَ","translation":"মনযোগসহ শুনেছে","audioUrl":"wbw/072_001_005.mp3","charTypeName":"word"},{"id":619,"position":6,"arabic":"نَفَرٌۭ","translation":"একটি দল","audioUrl":"wbw/072_001_006.mp3","charTypeName":"word"},{"id":620,"position":7,"arabic":"مِّنَ","translation":"মধ্যে","audioUrl":"wbw/072_001_007.mp3","charTypeName":"word"},{"id":621,"position":8,"arabic":"ٱلْجِنِّ","translation":"জ্বীনদের","audioUrl":"wbw/072_001_008.mp3","charTypeName":"word"},{"id":622,"position":9,"arabic":"فَقَالُوٓا۟","translation":"তারা বলেছে অতঃপর","audioUrl":"wbw/072_001_009.mp3","charTypeName":"word"},{"id":623,"position":10,"arabic":"إِنَّا","translation":"\"আমরা নিশ্চয়ই","audioUrl":"wbw/072_001_010.mp3","charTypeName":"word"},{"id":624,"position":11,"arabic":"سَمِعْنَا","translation":"আমরা শুনেছি","audioUrl":"wbw/072_001_011.mp3","charTypeName":"word"},{"id":625,"position":12,"arabic":"قُرْءَانًا","translation":"কুরআন","audioUrl":"wbw/072_001_012.mp3","charTypeName":"word"},{"id":626,"position":13,"arabic":"عَجَبًۭا","translation":"বিস্ময়কর","audioUrl":"wbw/072_001_013.mp3","charTypeName":"word"},{"id":627,"position":14,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"يَهْدِىٓ إِلَى ٱلرُّشْدِ فَـَٔامَنَّا بِهِۦ ۖ وَلَن نُّشْرِكَ بِرَبِّنَآ أَحَدًۭا","translation":"guiding towards consciousness of what is right; and so We have come to believe in it. And we shall never ascribe divinity to anyone beside our Sustainer,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5449.mp3","surahId":72,"words":[{"id":1564,"position":1,"arabic":"يَهْدِىٓ","translation":"পথ দেখায়","audioUrl":"wbw/072_002_001.mp3","charTypeName":"word"},{"id":1565,"position":2,"arabic":"إِلَى","translation":"দিকে","audioUrl":"wbw/072_002_002.mp3","charTypeName":"word"},{"id":1566,"position":3,"arabic":"ٱلرُّشْدِ","translation":"সত্যের","audioUrl":"wbw/072_002_003.mp3","charTypeName":"word"},{"id":1567,"position":4,"arabic":"فَـَٔامَنَّا","translation":"আমরা ঈমান অতঃপর এনেছি","audioUrl":"wbw/072_002_004.mp3","charTypeName":"word"},{"id":1568,"position":5,"arabic":"بِهِۦ ۖ","translation":"তার উপর","audioUrl":"wbw/072_002_005.mp3","charTypeName":"word"},{"id":1570,"position":6,"arabic":"وَلَن","translation":"এবং কক্ষণ না","audioUrl":"wbw/072_002_007.mp3","charTypeName":"word"},{"id":1571,"position":7,"arabic":"نُّشْرِكَ","translation":"শরীক আমরা করবো","audioUrl":"wbw/072_002_008.mp3","charTypeName":"word"},{"id":1572,"position":8,"arabic":"بِرَبِّنَآ","translation":"আমাদের রবের সাথে","audioUrl":"wbw/072_002_009.mp3","charTypeName":"word"},{"id":1573,"position":9,"arabic":"أَحَدًۭا","translation":"কাউকে","audioUrl":"wbw/072_002_010.mp3","charTypeName":"word"},{"id":1574,"position":10,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"وَأَنَّه