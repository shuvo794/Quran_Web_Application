ee with the truth, as a bearer of glad tidings and a warner: for there never was any community but a warner has [lived and] passed away in its midst.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3684.mp3","surahId":35,"words":[{"id":27386,"position":1,"arabic":"إِنَّآ","translation":"নিশ্চযই় আমরা","audioUrl":"wbw/035_024_001.mp3","charTypeName":"word"},{"id":27387,"position":2,"arabic":"أَرْسَلْنَـٰكَ","translation":"তোমাকে আমরা পাঠিয়েছি","audioUrl":"wbw/035_024_002.mp3","charTypeName":"word"},{"id":27388,"position":3,"arabic":"بِٱلْحَقِّ","translation":"সত্যসহ","audioUrl":"wbw/035_024_003.mp3","charTypeName":"word"},{"id":27389,"position":4,"arabic":"بَشِيرًۭا","translation":"সুসংবাদদাতা রূপে","audioUrl":"wbw/035_024_004.mp3","charTypeName":"word"},{"id":27390,"position":5,"arabic":"وَنَذِيرًۭا ۚ","translation":"ও সতর্ককারী হিসেবে","audioUrl":"wbw/035_024_005.mp3","charTypeName":"word"},{"id":27392,"position":6,"arabic":"وَإِن","translation":"এবং নেই","audioUrl":"wbw/035_024_007.mp3","charTypeName":"word"},{"id":27393,"position":7,"arabic":"مِّنْ","translation":"কোনো","audioUrl":"wbw/035_024_008.mp3","charTypeName":"word"},{"id":27394,"position":8,"arabic":"أُمَّةٍ","translation":"(এমন) জাতি","audioUrl":"wbw/035_024_009.mp3","charTypeName":"word"},{"id":27395,"position":9,"arabic":"إِلَّا","translation":"এ ছাড়া যে","audioUrl":"wbw/035_024_010.mp3","charTypeName":"word"},{"id":27396,"position":10,"arabic":"خَلَا","translation":"অতিক্রম করেছে","audioUrl":"wbw/035_024_011.mp3","charTypeName":"word"},{"id":27397,"position":11,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/035_024_012.mp3","charTypeName":"word"},{"id":27398,"position":12,"arabic":"نَذِيرٌۭ","translation":"কোনো সতর্ককারী","audioUrl":"wbw/035_024_013.mp3","charTypeName":"word"},{"id":27399,"position":13,"arabic":"٢٤","translation":"(২৪)","audioUrl":null,"charTypeName":"end"}]},{"number":25,"arabic":"وَإِن يُكَذِّبُوكَ فَقَدْ كَذَّبَ ٱلَّذِينَ مِن قَبْلِهِمْ جَآءَتْهُمْ