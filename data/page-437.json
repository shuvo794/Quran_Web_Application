{"id":437,"ayahs":[{"number":19,"arabic":"وَمَا يَسْتَوِى ٱلْأَعْمَىٰ وَٱلْبَصِيرُ","translation":"For [thus it is:] the blind and the seeing are not equal;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3679.mp3","surahId":35,"words":[{"id":22226,"position":1,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/035_019_001.mp3","charTypeName":"word"},{"id":22227,"position":2,"arabic":"يَسْتَوِى","translation":"সমান হয়","audioUrl":"wbw/035_019_002.mp3","charTypeName":"word"},{"id":22228,"position":3,"arabic":"ٱلْأَعْمَىٰ","translation":"অন্ধ","audioUrl":"wbw/035_019_003.mp3","charTypeName":"word"},{"id":22229,"position":4,"arabic":"وَٱلْبَصِيرُ","translation":"ও চক্ষুষ্মান","audioUrl":"wbw/035_019_004.mp3","charTypeName":"word"},{"id":22230,"position":5,"arabic":"١٩","translation":"(১৯)","audioUrl":null,"charTypeName":"end"}]},{"number":20,"arabic":"وَلَا ٱلظُّلُمَٰتُ وَلَا ٱلنُّورُ","translation":"nor are the depths of darkness and the light;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3680.mp3","surahId":35,"words":[{"id":23239,"position":1,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/035_020_001.mp3","charTypeName":"word"},{"id":23240,"position":2,"arabic":"ٱلظُّلُمَـٰتُ","translation":"অন্ধকারসমূহ","audioUrl":"wbw/035_020_002.mp3","charTypeName":"word"},{"id":23241,"position":3,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/035_020_003.mp3","charTypeName":"word"},{"id":23242,"position":4,"arabic":"ٱلنُّورُ","translation":"আলো","audioUrl":"wbw/035_020_004.mp3","charTypeName":"word"},{"id":23243,"position":5,"arabic":"٢٠","translation":"(২০)","audioUrl":null,"charTypeName":"end"}]},{"number":21,"arabic":"وَلَا ٱلظِّلُّ وَلَا ٱلْحَرُورُ","translation":"nor the [cooling] shade and the scorching heat:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3681.mp3","surahId":35,"words":[{"id":24304,"position":1,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/035_021_001.mp3","charTypeName