},{"id":50302,"position":9,"arabic":"مِن","translation":"হ'তে","audioUrl":"wbw/039_053_010.mp3","charTypeName":"word"},{"id":50303,"position":10,"arabic":"رَّحْمَةِ","translation":"অনুগ্রহ","audioUrl":"wbw/039_053_011.mp3","charTypeName":"word"},{"id":50304,"position":11,"arabic":"ٱللَّهِ ۚ","translation":"আল্লাহর","audioUrl":"wbw/039_053_012.mp3","charTypeName":"word"},{"id":50306,"position":12,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/039_053_014.mp3","charTypeName":"word"},{"id":50307,"position":13,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/039_053_015.mp3","charTypeName":"word"},{"id":50308,"position":14,"arabic":"يَغْفِرُ","translation":"মাফ করেন","audioUrl":"wbw/039_053_016.mp3","charTypeName":"word"},{"id":50309,"position":15,"arabic":"ٱلذُّنُوبَ","translation":"পাপসমূহকে","audioUrl":"wbw/039_053_017.mp3","charTypeName":"word"},{"id":50310,"position":16,"arabic":"جَمِيعًا ۚ","translation":"সমস্তই","audioUrl":"wbw/039_053_018.mp3","charTypeName":"word"},{"id":50312,"position":17,"arabic":"إِنَّهُۥ","translation":"নিশ্চয়ই তিনি","audioUrl":"wbw/039_053_020.mp3","charTypeName":"word"},{"id":50313,"position":18,"arabic":"هُوَ","translation":"তিনিই","audioUrl":"wbw/039_053_021.mp3","charTypeName":"word"},{"id":50314,"position":19,"arabic":"ٱلْغَفُورُ","translation":"ক্ষমাশীল","audioUrl":"wbw/039_053_022.mp3","charTypeName":"word"},{"id":50315,"position":20,"arabic":"ٱلرَّحِيمُ","translation":"পরম দয়ালু","audioUrl":"wbw/039_053_023.mp3","charTypeName":"word"},{"id":50316,"position":21,"arabic":"٥٣","translation":"(৫৩)","audioUrl":null,"charTypeName":"end"}]},{"number":54,"arabic":"وَأَنِيبُوٓا۟ إِلَىٰ رَبِّكُمْ وَأَسْلِمُوا۟ لَهُۥ مِن قَبْلِ أَن يَأْتِيَكُمُ ٱلْعَذَابُ ثُمَّ لَا تُنصَرُونَ","translation":"Hence, turn towards your Sustainer [alone] and surrender yourselves unto Him ere the suffering [of death and resurrection] comes upon you, for then you will not be succoured.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4112.mp3","surahId":39,"words":[{"id":51472,"position":1,"arabic":"وَأَنِيبُوٓا۟","translation":"এবং তোমরা অভিমুখী হও","audioUrl":"wbw/039_054_001.mp3","charTypeName":"word"},{"id":51473,"position":2,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/039_054_002.mp3","charTypeName":"word"},{"id":51474,"position":3,"arabic":"رَبِّكُمْ","translation":"তোমার রবের","audioUrl":"wbw/039_054_003.mp3","charTypeName":"word"},{"id":51475,"position":4,"arabic":"وَأَسْلِمُوا۟","translation":"এবং তোমরা আত্মসমর্পণ করো","audioUrl":"wbw/039_054_004.mp3","charTypeName":"word"},{"id":51476,"position":5,"arabic":"لَهُۥ","translation":"তাঁর কাছে","audioUrl":"wbw/039_054_005.mp3","charTypeName":"word"},{"id":51477,"position":6,"arabic":"مِن","translation":"মধ্য হতে","audioUrl":"wbw/039_054_006.mp3","charTypeName":"word"},{"id":51478,"position":7,"arabic":"قَبْلِ","translation":"(এর) পূর্বে","audioUrl":"wbw/039_054_007.mp3","charTypeName":"word"},{"id":51479,"position":8,"arabic":"أَن","translation":"যে","audioUrl":"wbw/039_054_008.mp3","charTypeName":"word"},{"id":51480,"position":9,"arabic":"يَأْتِيَكُمُ","translation":"তোমাদের উপর আসবে","audioUrl":"wbw/039_054_009.mp3","charTypeName":"word"},{"id":51481,"position":10,"arabic":"ٱلْعَذَابُ","translation":"শাস্তি","audioUrl":"wbw/039_054_010.mp3","charTypeName":"word"},{"id":51482,"position":11,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/039_054_011.mp3","charTypeName":"word"},{"id":51483,"position":12,"arabic":"لَا","translation":"না","audioUrl":"wbw/039_054_012.mp3","charTypeName":"word"},{"id":51484,"position":13,"arabic":"تُنصَرُونَ","translation":"তোমাদের সাহায্য করা হবে","audioUrl":"wbw/039_054_013.mp3","charTypeName":"word"},{"id":51485,"position":14,"arabic":"٥٤","translation":"(৫৪)","audioUrl":null,"charTypeName":"end"}]},{"number":55,"arabic":"وَٱتَّبِعُوٓا۟ أَحْسَنَ مَآ أُنزِلَ إِلَيْكُم مِّن رَّبِّكُم مِّن قَبْلِ أَن يَأْتِيَكُمُ ٱلْعَذَابُ بَغْتَةًۭ وَأَنتُمْ لَا تَشْعُرُونَ","translation":"And ere that