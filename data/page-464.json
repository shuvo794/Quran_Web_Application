{"id":464,"ayahs":[{"number":48,"arabic":"وَبَدَا لَهُمْ سَيِّـَٔاتُ مَا كَسَبُوا۟ وَحَاقَ بِهِم مَّا كَانُوا۟ بِهِۦ يَسْتَهْزِءُونَ","translation":"and obvious to them will have become the evil that they had wrought [in life]: and thus shall they be overwhelmed by the very truth which they were wont to deride.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4106.mp3","surahId":39,"words":[{"id":47016,"position":1,"arabic":"وَبَدَا","translation":"এবং প্রকাশ হয়ে যাবে","audioUrl":"wbw/039_048_001.mp3","charTypeName":"word"},{"id":47017,"position":2,"arabic":"لَهُمْ","translation":"তাদের জন্যে","audioUrl":"wbw/039_048_002.mp3","charTypeName":"word"},{"id":47018,"position":3,"arabic":"سَيِّـَٔاتُ","translation":"মন্দ (ফল) সমূহ","audioUrl":"wbw/039_048_003.mp3","charTypeName":"word"},{"id":47019,"position":4,"arabic":"مَا","translation":"যা","audioUrl":"wbw/039_048_004.mp3","charTypeName":"word"},{"id":47020,"position":5,"arabic":"كَسَبُوا۟","translation":"তারা কামাই করতো","audioUrl":"wbw/039_048_005.mp3","charTypeName":"word"},{"id":47021,"position":6,"arabic":"وَحَاقَ","translation":"এবং ঘিরে রাখবে","audioUrl":"wbw/039_048_006.mp3","charTypeName":"word"},{"id":47022,"position":7,"arabic":"بِهِم","translation":"তাদেরকে","audioUrl":"wbw/039_048_007.mp3","charTypeName":"word"},{"id":47023,"position":8,"arabic":"مَّا","translation":"যা","audioUrl":"wbw/039_048_008.mp3","charTypeName":"word"},{"id":47024,"position":9,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/039_048_009.mp3","charTypeName":"word"},{"id":47025,"position":10,"arabic":"بِهِۦ","translation":"সে সম্পর্কে","audioUrl":"wbw/039_048_010.mp3","charTypeName":"word"},{"id":47026,"position":11,"arabic":"يَسْتَهْزِءُونَ","translation":"ঠাট্রা বিদ্রুপ করতো","audioUrl":"wbw/039_048_011.mp3","charTypeName":"word"},{"id":47027,"position":12,"arabic":"٤٨","translation":"(৪৮)","audioUrl":null,"charTypeName":"end"}]},{"number":49,"arabic":"فَإِذَا مَسَّ ٱلْإِنسَٰنَ ضُرٌّۭ دَعَانَا ثُمَّ إِذَا خَوَّلْنَٰهُ نِعْمَةًۭ مِّنَّا قَالَ إِنَّمَآ أُوتِيتُهُۥ عَلَىٰ عِلْمٍۭ ۚ بَلْ هِىَ فِتْنَةٌۭ وَلَٰكِنَّ أَكْثَرَهُمْ لَا يَعْلَمُونَ","translation":"NOW [thus it is:] when affliction befalls man, he cries out unto Us for help; but when We bestow upon him a boon by Our grace, he says [to himself], “I have been given [all] this by virtue of [my own] wisdom!” Nay, this [bestowal of grace] is a trial: but most of them understand it not!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4107.mp3","surahId":39,"words":[{"id":48161,"position":1,"arabic":"فَإِذَا","translation":"অতঃপর যখন","audioUrl":"wbw/039_049_001.mp3","charTypeName":"word"},{"id":48162,"position":2,"arabic":"مَسَّ","translation":"স্পর্শ করে","audioUrl":"wbw/039_049_002.mp3","charTypeName":"word"},{"id":48163,"position":3,"arabic":"ٱلْإِنسَـٰنَ","translation":"মানুষকে","audioUrl":"wbw/039_049_003.mp3","charTypeName":"word"},{"id":48164,"position":4,"arabic":"ضُرٌّۭ","translation":"কোনো দুঃখদৈন্য","audioUrl":"wbw/039_049_004.mp3","charTypeName":"word"},{"id":48165,"position":5,"arabic":"دَعَانَا","translation":"আমাদেরকে ডাকে","audioUrl":"wbw/039_049_005.mp3","charTypeName":"word"},{"id":48166,"position":6,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/039_049_006.mp3","charTypeName":"word"},{"id":48167,"position":7,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/039_049_007.mp3","charTypeName":"word"},{"id":48168,"position":8,"arabic":"خَوَّلْنَـٰهُ","translation":"তাকে আমরা দিয়েছি","audioUrl":"wbw/039_049_008.mp3","charTypeName":"word"},{"id":48169,"position":9,"arabic":"نِعْمَةًۭ","translation":"অনুগ্রহ","audioUrl":"wbw/039_049_009.mp3","charTypeName":"word"},{"id":48170,"position":10,"arabic":"مِّنَّا","translation":"আমাদের পক্ষ হ'তে","audioUrl":"wbw/039_049_010.mp3","charTypeName":"word"},{"id":48171,"position":11,"arabic":"قَالَ","translation":"সে বলে","audioUrl":"wbw/039_049_011.mp3","charTypeName":"word"},{"id":48172,"position":12,"arabic":"إِنَّمَآ","translation":"\"মূলতঃ","audioUrl":"wbw/039_049_012.mp3","charTypeName":"word"},{"id":48173,"position":13,"arabic":"أُوتِيتُهُۥ","translation":"তা দেওয়া হয়েছিলো আমাকে","audioUrl":"wbw/039_049_013.mp3","charTypeName":"word"},{"id":48174,"position":14,"arabic":"عَلَىٰ","translation":"কারণে","audioUrl":"wbw/039_049_014.mp3","charTypeName":"word"},{"id":48175,"position":15,"arabic":"عِلْمٍۭ ۚ","translation":"জ্ঞানের\"","audioUrl":"wbw/039_049_015.mp3","charTypeName":"word"},{"id":48177,"position":16,"arabic":"بَلْ","translation":"বরং","audioUrl":"wbw/039_049_017.mp3","charTypeName":"word"},{"id":48178,"position":17,"arabic":"هِىَ","translation":"এটা","audioUrl":"wbw/039_049_018.mp3","charTypeName":"word"},{"id":48179,"position":18,"arabic":"فِتْنَةٌۭ","translation":"একটি পরীক্ষা","audioUrl":"wbw/039_049_019.mp3","charTypeName":"word"},{"id":48180,"position":19,"arabic":"وَلَـٰكِنَّ","translation":"কিন্তু","audioUrl":"wbw/039_049_020.mp3","charTypeName":"word"},{"id":48181,"position":20,"arabic":"أَكْثَرَهُمْ","translation":"তারা অধিকাংশই","audioUrl":"wbw/039_049_021.mp3","charTypeName":"word"},{"id":48182,"position":21,"arabic":"لَا","translation":"না","audioUrl":"wbw/039_049_022.mp3","charTypeName":"word"},{"id":48183,"position":22,"arabic":"يَعْلَمُونَ","translation":"জানে","audioUrl":"wbw/039_049_023.mp3","charTypeName":"word"},{"id":48184,"position":23,"arabic":"٤٩","translation":"(৪৯)","audioUrl":null,"charTypeName":"end"}]},{"number":50,"arabic":"قَدْ قَالَهَا ٱلَّذِينَ مِن قَبْلِهِمْ فَمَآ أَغْنَىٰ عَنْهُم مَّا كَانُوا۟ يَكْسِبُونَ","translation":"The same did say [to themselves many of] those who lived before their time; but of no avail to them was all that they had ever achieved:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4108.mp3","surahId":39,"words":[{"id":48342,"position":1,"arabic":"قَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/039_050_001.mp3","charTypeName":"word"},{"id":48343,"position":2,"arabic":"قَالَهَا","translation":"তা বলেছিলো","audioUrl":"wbw/039_050_002.mp3","charTypeName":"word"},{"id":48344,"position":3,"arabic":"ٱلَّذِينَ","translation":"(তারাও) যারা","audioUrl":"wbw/039_050_003.mp3","charTypeName":"word"},{"id":48345,"position":4,"arabic":"مِن","translation":"পূর্বে (ছিলো)","audioUrl":"wbw/039_050_004.mp3","charTypeName":"word"},{"id":48346,"position":5,"arabic":"قَبْلِهِمْ","translation":"তাদের","audioUrl":"wbw/039_050_005.mp3","charTypeName":"word"},{"id":48347,"position":6,"arabic":"فَمَآ","translation":"কিন্তু না","audioUrl":"wbw/039_050_006.mp3","charTypeName":"word"},{"id":48348,"position":7,"arabic":"أَغْنَىٰ","translation":"কাছে এসেছে","audioUrl":"wbw/039_050_007.mp3","charTypeName":"word"},{"id":48349,"position":8,"arabic":"عَنْهُم","translation":"তাদের জন্যে","audioUrl":"wbw/039_050_008.mp3","charTypeName":"word"},{"id":48350,"position":9,"arabic":"مَّا","translation":"যা","audioUrl":"wbw/039_050_009.mp3","charTypeName":"word"},{"id":48351,"position":10,"arabic":"كَانُوا۟","translation":"তারা","audioUrl":"wbw/039_050_010.mp3","charTypeName":"word"},{"id":48352,"position":11,"arabic":"يَكْسِبُونَ","translation":"অর্জন করতেছিলো","audioUrl":"wbw/039_050_011.mp3","charTypeName":"word"},{"id":48353,"position":12,"arabic":"٥٠","translation":"(৫০)","audioUrl":null,"charTypeName":"end"}]},{"number":51,"arabic":"فَأَصَابَهُمْ سَيِّـَٔاتُ مَا كَسَبُوا۟ ۚ وَٱلَّذِينَ ظَلَمُوا۟ مِنْ هَٰٓؤُلَآءِ سَيُصِيبُهُمْ سَيِّـَٔاتُ مَا كَسَبُوا۟ وَمَا هُم بِمُعْجِزِينَ","translation":"for all the evil deeds that they had wrought fell [back] upon them. And [the same will happen to] people of the present time who are bent on wrongdoing: all the evil deeds that they have ever wrought will fall [back] upon them, and never will they be able to elude [God]!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4109.mp3","surahId":39,"words":[{"id":49012,"position":1,"arabic":"فَأَصَابَهُمْ","translation":"তাদের উপর  এরপর আপতিত হয়েছে","audioUrl":"wbw/039_051_001.mp3","charTypeName":"word"},{"id":49013,"position":2,"arabic":"سَيِّـَٔاتُ","translation":"মন্দ ফলসমূহ","audioUrl":"wbw/039_051_002.mp3","charTypeName":"word"},{"id":49014,"position":3,"arabic":"مَا","translation":"যা","audioUrl":"wbw/039_051_003.mp3","charTypeName":"word"},{"id":49015,"position":4,"arabic":"كَسَبُوا۟ ۚ","translation":"তারা কামাই করেছিলো","audioUrl":"wbw/039_051_004.mp3","charTypeName":"word"},{"id":49017,"position":5,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/039_051_006.mp3","charTypeName":"word"},{"id":49018,"position":6,"arabic":"ظَلَمُوا۟","translation":"সীমালঙ্ঘন করেছে","audioUrl":"wbw/039_051_007.mp3","charTypeName":"word"},{"id":49019,"position":7,"arabic":"مِنْ","translation":"মধ্য হ'তে","audioUrl":"wbw/039_051_008.mp3","charTypeName":"word"},{"id":49020,"position":8,"arabic":"هَـٰٓؤُلَآءِ","translation":"এদের","audioUrl":"wbw/039_051_009.mp3","charTypeName":"word"},{"id":49021,"position":9,"arabic":"سَيُصِيبُهُمْ","translation":"তাদের উপর এসে পড়বে শীঘ্রই","audioUrl":"wbw/039_051_010.mp3","charTypeName":"word"},{"id":49022,"position":10,"arabic":"سَيِّـَٔاتُ","translation":"মন্দ ফলসমূহ","audioUrl":"wbw/039_051_011.mp3","charTypeName":"word"},{"id":49023,"position":11,"arabic":"مَا","translation":"যা","audioUrl":"wbw/039_051_012.mp3","charTypeName":"word"},{"id":49024,"position":12,"arabic":"كَسَبُوا۟","translation":"তারা কামাই করেছে","audioUrl":"wbw/039_051_013.mp3","charTypeName":"word"},{"id":49025,"position":13,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/039_051_014.mp3","charTypeName":"word"},{"id":49026,"position":14,"arabic":"هُم","translation":"তারা","audioUrl":"wbw/039_051_015.mp3","charTypeName":"word"},{"id":49027,"position":15,"arabic":"بِمُعْجِزِينَ","translation":"(আমাকে) অক্ষম করতে পারবে","audioUrl":"wbw/039_051_016.mp3","charTypeName":"word"},{"id":49028,"position":16,"arabic":"٥١","translation":"(৫১)","audioUrl":null,"charTypeName":"end"}]},{"number":52,"arabic":"أَوَلَمْ يَعْلَمُوٓا۟ أَنَّ ٱللَّهَ يَبْسُطُ ٱلرِّزْقَ لِمَن يَشَآءُ وَيَقْدِرُ ۚ إِنَّ فِى ذَٰلِكَ لَءَايَٰتٍۢ لِّقَوْمٍۢ يُؤْمِنُونَ","translation":"Are they, then, not aware that it is God who grants abundant sustenance, or gives it in scant measure, unto whomever He wills? In this, behold, there are messages indeed for peo­ple who will believe!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4110.mp3","surahId":39,"words":[{"id":49652,"position":1,"arabic":"أَوَلَمْ","translation":"কি না","audioUrl":"wbw/039_052_001.mp3","charTypeName":"word"},{"id":49653,"position":2,"arabic":"يَعْلَمُوٓا۟","translation":"তারা জানে","audioUrl":"wbw/039_052_002.mp3","charTypeName":"word"},{"id":49654,"position":3,"arabic":"أَنَّ","translation":"যে","audioUrl":"wbw/039_052_003.mp3","charTypeName":"word"},{"id":49655,"position":4,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/039_052_004.mp3","charTypeName":"word"},{"id":49656,"position":5,"arabic":"يَبْسُطُ","translation":"প্রশস্ত করে দেন","audioUrl":"wbw/039_052_005.mp3","charTypeName":"word"},{"id":49657,"position":6,"arabic":"ٱلرِّزْقَ","translation":"জীবনের উপকরণ","audioUrl":"wbw/039_052_006.mp3","charTypeName":"word"},{"id":49658,"position":7,"arabic":"لِمَن","translation":"(তার) জন্যে যাকে","audioUrl":"wbw/039_052_007.mp3","charTypeName":"word"},{"id":49659,"position":8,"arabic":"يَشَآءُ","translation":"ইচ্ছে করেন","audioUrl":"wbw/039_052_008.mp3","charTypeName":"word"},{"id":49660,"position":9,"arabic":"وَيَقْدِرُ ۚ","translation":"এবং সংকীর্ণ করেন (যাকে চান)","audioUrl":"wbw/039_052_009.mp3","charTypeName":"word"},{"id":49662,"position":10,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/039_052_011.mp3","charTypeName":"word"},{"id":49663,"position":11,"arabic":"فِى","translation":"মধ্যে (আছে)","audioUrl":"wbw/039_052_012.mp3","charTypeName":"word"},{"id":49664,"position":12,"arabic":"ذَٰلِكَ","translation":"এর","audioUrl":"wbw/039_052_013.mp3","charTypeName":"word"},{"id":49665,"position":13,"arabic":"لَـَٔايَـٰتٍۢ","translation":"অবশ্যই নি