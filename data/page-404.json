{"id":404,"ayahs":[{"number":64,"arabic":"وَمَا هَٰذِهِ ٱلْحَيَوٰةُ ٱلدُّنْيَآ إِلَّا لَهْوٌۭ وَلَعِبٌۭ ۚ وَإِنَّ ٱلدَّارَ ٱلْءَاخِرَةَ لَهِىَ ٱلْحَيَوَانُ ۚ لَوْ كَانُوا۟ يَعْلَمُونَ","translation":"for, [if they did, they would know that] the life of this world is nothing but a passing delight and a play - whereas, behold, the life in the hereafter is indeed the only [true] life: if they but knew this!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3404.mp3","surahId":29,"words":[{"id":56841,"position":1,"arabic":"وَمَا","translation":"এবং নয় (অন্য কিছু)","audioUrl":"wbw/029_064_001.mp3","charTypeName":"word"},{"id":56842,"position":2,"arabic":"هَـٰذِهِ","translation":"এই","audioUrl":"wbw/029_064_002.mp3","charTypeName":"word"},{"id":56843,"position":3,"arabic":"ٱلْحَيَوٰةُ","translation":"জীবন","audioUrl":"wbw/029_064_003.mp3","charTypeName":"word"},{"id":56844,"position":4,"arabic":"ٱلدُّنْيَآ","translation":"পার্থিব","audioUrl":"wbw/029_064_004.mp3","charTypeName":"word"},{"id":56845,"position":5,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/029_064_005.mp3","charTypeName":"word"},{"id":56846,"position":6,"arabic":"لَهْوٌۭ","translation":"কৌতুক","audioUrl":"wbw/029_064_006.mp3","charTypeName":"word"},{"id":56847,"position":7,"arabic":"وَلَعِبٌۭ ۚ","translation":"ও ক্রীড়া","audioUrl":"wbw/029_064_007.mp3","charTypeName":"word"},{"id":56849,"position":8,"arabic":"وَإِنَّ","translation":"আর নিশ্চয়ই","audioUrl":"wbw/029_064_009.mp3","charTypeName":"word"},{"id":56850,"position":9,"arabic":"ٱلدَّارَ","translation":"ঘর","audioUrl":"wbw/029_064_010.mp3","charTypeName":"word"},{"id":56851,"position":10,"arabic":"ٱلْـَٔاخِرَةَ","translation":"আখেরাতের","audioUrl":"wbw/029_064_011.mp3","charTypeName":"word"},{"id":56852,"position":11,"arabic":"لَهِىَ","translation":"তাই অবশ্যই","audioUrl":"wbw/029_064_012.mp3","charTypeName":"word"},{"id":56853,"position":12,"arabic":"ٱلْحَيَوَانُ ۚ","translation":"প্রকৃত জীবন","audioUrl":"wbw/029_064_013.mp3","charTypeName":"word"},{"id":56855,"position":13,"arabic":"لَوْ","translation":"যদি","audioUrl":"wbw/029_064_015.mp3","charTypeName":"word"},{"id":56856,"position":14,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/029_064_016.mp3","charTypeName":"word"},{"id":56857,"position":15,"arabic":"يَعْلَمُونَ","translation":"তারা জানতো","audioUrl":"wbw/029_064_017.mp3","charTypeName":"word"},{"id":56858,"position":16,"arabic":"٦٤","translation":"(৬৪)","audioUrl":null,"charTypeName":"end"}]},{"number":65,"arabic":"فَإِذَا رَكِبُوا۟ فِى ٱلْفُلْكِ دَعَوُا۟ ٱللَّهَ مُخْلِصِينَ لَهُ ٱلدِّينَ فَلَمَّا نَجَّىٰهُمْ إِلَى ٱلْبَرِّ إِذَا هُمْ يُشْرِكُونَ","translation":"And so, when they embark on a ship [and find themselves in danger], they call unto God, [at that moment] sincere in their faith in Him alone; but as soon as He has brought them safe ashore, they [begin to] ascribe to imaginary powers a share in His divinity:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3405.mp3","surahId":29,"words":[{"id":57329,"position":1,"arabic":"فَإِذَا","translation":"অতঃপর যখন","audioUrl":"wbw/029_065_001.mp3","charTypeName":"word"},{"id":57330,"position":2,"arabic":"رَكِبُوا۟","translation":"তারা আরোহণ করে","audioUrl":"wbw/029_065_002.mp3","charTypeName":"word"},{"id":57331,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/029_065_003.mp3","charTypeName":"word"},{"id":57332,"position":4,"arabic":"ٱلْفُلْكِ","translation":"জলযানের (এবং বিপদে পড়ে)","audioUrl":"wbw/029_065_004.mp3","charTypeName":"word"},{"id":57333,"position":5,"arabic":"دَعَوُا۟","translation":"তারা ডাকে (দোয়া করে)","audioUrl":"wbw/029_065_005.mp3","charTypeName":"word"},{"id":57334,"position":6,"arabic":"ٱللَّهَ","translation":"আল্লাহ্‌কে","audioUrl":"wbw/029_065_006.mp3","charTypeName":"word"},{"id":57335,"position":7,"arabic":"مُخْلِصِينَ","translation":"বিশুদ্ধচিত্তে","audioUrl":"wbw/029_065_007.mp3","charTypeName":"word"},{"id":57336,"position":8,"arabic":"لَهُ","translation":"জন্যে তাঁরই","audioUrl":"wbw/029_065_008.mp3","charTypeName":"word"},{"id":57337,"position":9,"arabic":"ٱلدِّينَ","translation":"অনুগত্যকে (নির্দিষ্ট করে)","audioUrl":"wbw/029_065_009.mp3","charTypeName":"word"},{"id":57338,"position":10,"arabic":"فَلَمَّا","translation":"অতঃপর যখন","audioUrl":"wbw/029_065_010.mp3","charTypeName":"word"},{"id":57339,"position":11,"arabic":"نَجَّىٰهُمْ","translation":"(আল্লাহ্‌)উদ্ধার করে আনেন তাদেরকে","audioUrl":"wbw/029_065_011.mp3","charTypeName":"word"},{"id":57340,"position":12,"arabic":"إِلَى","translation":"দিকে","audioUrl":"wbw/029_065_012.mp3","charTypeName":"word"},{"id":57341,"position":13,"arabic":"ٱلْبَرِّ","translation":"স্থলের","audioUrl":"wbw/029_065_013.mp3","charTypeName":"word"},{"id":57342,"position":14,"arabic":"إِذَا","translation":"তখন","audioUrl":"wbw/029_065_014.mp3","charTypeName":"word"},{"id":57343,"position":15,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/029_065_015.mp3","charTypeName":"word"},{"id":57344,"position":16,"arabic":"يُشْرِكُونَ","translation":"শিরক করে","audioUrl":"wbw/029_065_016.mp3","charTypeName":"word"},{"id":57345,"position":17,"arabic":"٦٥","translation":"(৬৫)","audioUrl":null,"charTypeName":"end"}]},{"number":66,"arabic":"لِيَكْفُرُوا۟ بِمَآ ءَاتَيْنَٰهُمْ وَلِيَتَمَتَّعُوا۟ ۖ فَسَوْفَ يَعْلَمُونَ","translation":"and thus they show utter ingratitude for all that We have vouchsafed them, and go on [thoughtlessly] enjoying their worldly life.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3406.mp3","surahId":29,"words":[{"id":57846,"position":1,"arabic":"لِيَكْفُرُوا۟","translation":"যাতে তারা অস্বীকার করে","audioUrl":"wbw/029_066_001.mp3","charTypeName":"word"},{"id":57847,"position":2,"arabic":"بِمَآ","translation":"প্রতি ঐ বিষয়ের যা","audioUrl":"wbw/029_066_002.mp3","charTypeName":"word"},{"id":57848,"position":3,"arabic":"ءَاتَيْنَـٰهُمْ","translation":"আমরা দান করেছি তাদেরকে","audioUrl":"wbw/029_066_003.mp3","charTypeName":"word"},{"id":57849,"position":4,"arabic":"وَلِيَتَمَتَّعُوا۟ ۖ","translation":"এবং যাতে তারা ভোগবিলাসে মত্ত থাকে","audioUrl":"wbw/029_066_004.mp3","charTypeName":"word"},{"id":57851,"position":5,"arabic":"فَسَوْفَ","translation":"তবে শীঘ্রই","audioUrl":"wbw/029_066_006.mp3","charTypeName":"word"},{"id":57852,"position":6,"arabic":"يَعْلَمُونَ","translation":"তারা জানতে পারবে","audioUrl":"wbw/029_066_007.mp3","charTypeName":"word"},{"id":57853,"position":7,"arabic":"٦٦","translation":"(৬৬)","audioUrl":null,"charTypeName":"end"}]},{"number":67,"arabic":"أَوَلَمْ يَرَوْا۟ أَنَّا جَعَلْنَا حَرَمًا ءَامِنًۭا وَيُتَخَطَّفُ ٱلنَّاسُ مِنْ حَوْلِهِمْ ۚ أَفَبِٱلْبَٰطِلِ يُؤْمِنُونَ وَبِنِعْمَةِ ٱللَّهِ يَكْفُرُونَ","translation":"Are they, then, not aware that We have set up a sanctuary secure [for those who believe in Us], the while all around them men are being carried away [by fear and despair]? Will they, then, [continue to] believe in things false and vain, and thus deny God’s blessings.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3407.mp3","surahId":29,"words":[{"id":57976,"position":1,"arabic":"أَوَلَمْ","translation":"কি   না","audioUrl":"wbw/029_067_001.mp3","charTypeName":"word"},{"id":57977,"position":2,"arabic":"يَرَوْا۟","translation":"তারা দেখে","audioUrl":"wbw/029_067_002.mp3","charTypeName":"word"},{"id":57978,"position":3,"arabic":"أَنَّا","translation":"যে আমরা","audioUrl":"wbw/029_067_003.mp3","charTypeName":"word"},{"id":57979,"position":4,"arabic":"جَعَلْنَا","translation":"আমরা বানিয়েছি","audioUrl":"wbw/029_067_004.mp3","charTypeName":"word"},{"id":57980,"position":5,"arabic":"حَرَمًا","translation":"হারামকে","audioUrl":"wbw/029_067_005.mp3","charTypeName":"word"},{"id":57981,"position":6,"arabic":"ءَامِنًۭا","translation":"নিরাপদ","audioUrl":"wbw/029_067_006.mp3","charTypeName":"word"},{"id":57982,"position":7,"arabic":"وَيُتَخَطَّفُ","translation":"অথচ হামলা করা হয়","audioUrl":"wbw/029_067_007.mp3","charTypeName":"word"},{"id":57983,"position":8,"arabic":"ٱلنَّاسُ","translation":"মানুষদেরকে","audioUrl":"wbw/029_067_008.mp3","charTypeName":"word"},{"id":57984,"position":9,"arabic":"مِنْ","translation":"হ'তে","audioUrl":"wbw/029_067_009.mp3","charTypeName":"word"},{"id":57985,"position":10,"arabic":"حَوْلِهِمْ ۚ","translation":"চারপাশ তার","audioUrl":"wbw/029_067_010.mp3","charTypeName":"word"},{"id":57987,"position":11,"arabic":"أَفَبِٱلْبَـٰطِلِ","translation":"কি তবে উপর অসত্যের","audioUrl":"wbw/029_067_012.mp3","charTypeName":"word"},{"id":57988,"position":12,"arabic":"يُؤْمِنُونَ","translation":"তারা বিশ্বাস করবে","audioUrl":"wbw/029_067_013.mp3","charTypeName":"word"},{"id":57989,"position":13,"arabic":"وَبِنِعْمَةِ","translation":"আর প্রতি  অনুগ্রহের","audioUrl":"wbw/029_067_014.mp3","charTypeName":"word"},{"id":57990,"position":14,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌র","audioUrl":"wbw/029_067_015.mp3","charTypeName":"word"},{"id":57991,"position":15,"arabic":"يَكْفُرُونَ","translation":"তারা অস্বীকার করবে","audioUrl":"wbw/029_067_016.mp3","charTypeName":"word"},{"id":57992,"position":16,"arabic":"٦٧","translation":"(৬৭)","audioUrl":null,"charTypeName":"end"}]},{"number":68,"arabic":"وَمَنْ أَظْلَمُ مِمَّنِ ٱفْتَرَىٰ عَلَى ٱللَّهِ كَذِبًا أَوْ كَذَّبَ بِٱلْحَقِّ لَمَّا جَآءَهُۥٓ ۚ أَلَيْسَ فِى جَهَنَّمَ مَثْوًۭى لِّلْكَٰفِرِينَ","translation":"And who could be more wicked than he who attributes his own lying inventions to God, or gives the lie to the truth when it comes unto him [through revelation]? Is not hell the [proper] abode for all who [thus] deny the truth?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3408.mp3","surahId":29,"words":[{"id":58744,"position":1,"arabic":"وَمَنْ","translation":"এবং কে","audioUrl":"wbw/029_068_001.mp3","charTypeName":"word"},{"id":58745,"position":2,"arabic":"أَظْلَمُ","translation":"বড় সীমালঙ্ঘনকারী (হতে পারে)","audioUrl":"wbw/029_068_002.mp3","charTypeName":"word"},{"id":58746,"position":3,"arabic":"مِمَّنِ","translation":"(তার) চেয়ে যে","audioUrl":"wbw/029_068_003.mp3","charTypeName":"word"},{"id":58747,"position":4,"arabic":"ٱفْتَرَىٰ","translation":"রচনা করে","audioUrl":"wbw/029_068_004.mp3","charTypeName":"word"},{"id":58748,"position":5,"arabic":"عَلَى","translation":"সম্পর্কে","audioUrl":"wbw/029_068_005.mp3","charTypeName":"word"},{"id":58749,"position":6,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌","audioUrl":"wbw/029_068_006.mp3","charTypeName":"word"},{"id":58750,"position":7,"arabic":"كَذِبًا","translation":"মিথ্যা","audioUrl":"wbw/029_068_007.mp3","charTypeName":"word"},{"id":58751,"position":8,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/029_068_008.mp3","charTypeName":"word"},{"id":58752,"position":9,"arabic":"كَذَّبَ","translation":"মিথ্যারোপ করে","audioUrl":"wbw/029_068_009.mp3","charTypeName":"word"},{"id":58753,"position":10,"arabic":"بِٱلْحَقِّ","translation":"উপর সত্যের","audioUrl":"wbw/029_068_010.mp3","charTypeName":"word"},{"id":58754,"position":11,"arabic":"لَمَّا","translation":"যখন","audioUrl":"wbw/029_068_011.mp3","charTypeName":"word"},{"id":58755,"position":12,"arabic":"جَآءَهُۥٓ ۚ","translation":"তার (কাছে) এসে পৌঁছেছে","audioUrl":"wbw/029_068_012.mp3","charTypeName":"word"},{"id":58757,"position":13,"arabic":"أَلَيْسَ","translation":"কি নয়","audioUrl":"wbw/029_068_014.mp3","charTypeName":"word"},{"id":58758,"position":14,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/029_068_015.mp3","charTypeName":"word"},{"id":58759,"position":15,"arabic":"جَهَنَّمَ","translation":"জাহান্নামের","audioUrl":"wbw/029_068_016.mp3","charTypeName":"word"},{"id":58760,"position":16,"arabic":"مَثْوًۭى","translation":"আবাসস্থল","audioUrl":"wbw/029_068_017.mp3","charTypeName":"word"},{"id":58761,"position":17,"arabic":"لِّلْكَـٰفِرِينَ","translation":"জন্যে কাফেরদের","audioUrl":"wbw/029_068_018.mp3","charTypeName":"word"},{"id":58762,"position":18,"arabic":"٦٨","translation":"(৬৮)","audioUrl":null,"charTypeName":"end"}]},{"number":69,"arabic":"وَٱلَّذِينَ جَٰهَدُوا۟ فِينَا لَنَهْدِيَنَّهُمْ سُبُلَنَا ۚ وَإِنَّ ٱللَّهَ لَمَعَ ٱلْمُحْسِنِينَ","translation":"But as for those who strive hard in Our cause -We shall most certainly guide them onto paths that lead unto Us: for, behold, God is indeed with the doers of good.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3409.mp3","surahId":29,"words":[{"id":58930,"position":1,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/029_069_001.mp3","charTypeName":"word"},{"id":58931,"position":2,"arabic":"جَـٰهَدُوا۟","translation":"সংগ্রাম-সাধনা করে","audioUrl":"wbw/029_069_002.mp3","charTypeName":"word"},{"id":58932,"position":3,"arabic":"فِينَا","translation":"জন্যে আমাদের","audioUrl":"wbw/029_069_003.mp3","charTypeName":"word"},{"id":58933,"position":4,"arabic":"لَنَهْدِيَنَّهُمْ","translation":"অবশ্যই আমরা দেখাবে তাদেরকে","audioUrl":"wbw/029_069_004.mp3","charTypeName":"word"},{"id":58934,"position":5,"arabic":"سُبُلَنَا ۚ","translation":"পথ আমাদের","audioUrl":"wbw/029_069_005.mp3","charTypeName":"word"},{"id":58936,"position":6,"arabic":"وَإِنَّ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/029_069_007.mp3","charTypeName":"word"},{"id":58937,"position":7,"arabic":"ٱللَّهَ","translation":"আল্লাহ্‌","audioUrl":"wbw/029_069_008.mp3","charTypeName":"word"},{"id":58938,"position":8,"arabic":"لَمَعَ","translation":"অবশ্যই সাথে আছেন","audioUrl":"wbw/029_069_009.mp3","charTypeName":"word"},{"id":58939,"position":9,"arabic":"ٱلْمُحْسِنِينَ","translation":"সৎকর্মশীলদের","audioUrl":"wbw/029_069_010.mp3","charTypeName":"word"},{"id":58940,"position":10,"arabic":"٦٩","translation":"(৬৯)","audioUrl":null,"charTypeName":"end"}]},{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ الٓمٓ","translation":"Alif. Lam. Mim.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3410.mp3","surahId":30,"words":[{"id":789,"position":1,"arabic":"الٓمٓ","translation":"আলিফ লাম- মীম-","audioUrl":"wbw/030_001_001.mp3","charTypeName":"word"},{"id":790,"position":2,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"غُلِبَتِ ٱلرُّومُ","translation":"Defeated have been the Byzantines","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3411.mp3","surahId":30,"words":[{"id":1843,"position":1,"arabic":"غُلِبَتِ","translation":"পরাজিত হয়েছে","audioUrl":"wbw/030_002_001.mp3","charTypeName":"word"},{"id":1844,"position":2,"arabic":"ٱلرُّومُ","translation":"রোমানরা","audioUrl":"wbw/030_002_002.mp3","charTypeName":"word"},{"id":1845,"position":3,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"فِىٓ أَدْنَى ٱلْأَرْضِ وَهُم مِّنۢ بَعْدِ غَلَبِهِمْ سَيَغْلِبُونَ","translation":"in the lands close-by; yet it is they who, notwithstanding this their defeat, shall be victorious","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3412.mp3","surahId":30,"words":[{"id":3010,"position":1,"arabic":"فِىٓ","translation":"মধ্যে","audioUrl":"wbw/030_003_001.mp3","charTypeName":"word"},{"id":3011,"position":2,"arabic":"أَدْنَى","translation":"নিকটবর্তী","audioUrl":"wbw/030_003_002.mp3","charTypeName":"word"},{"id":3012,"position":3,"arabic":"ٱلْأَرْضِ","translation":"অঞ্চলের","audioUrl":"wbw/030_003_003.mp3","charTypeName":"word"},{"id":3013,"position":4,"arabic":"وَهُم","translation":"কিন্তু তারা","audioUrl":"wbw/030_003_004.mp3","charTypeName":"word"},{"id":3014,"position":5,"arabic":"مِّنۢ","translation":"থেকে","audioUrl":"wbw/030_003_005.mp3","charTypeName":"word"},{"id":3015,"position":6,"arabic":"بَعْدِ","translation":"পর","audioUrl":"wbw/030_003_006.mp3","charTypeName":"word"},{"id":3016,"position":7,"arabic":"غَلَبِهِمْ","translation":"পরাজয়ের তাদের","audioUrl":"wbw/030_003_007.mp3","charTypeName":"word"},{"id":3017,"position":8,"arabic":"سَيَغْلِبُونَ","translation":"শীঘ্রই জয়লাভ করবে","audioUrl":"wbw/030_003_008.mp3","charTypeName":"word"},{"id":3018,"position":9,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"numbe