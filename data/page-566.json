{"id":566,"ayahs":[{"number":43,"arabic":"خَٰشِعَةً أَبْصَٰرُهُمْ تَرْهَقُهُمْ ذِلَّةٌۭ ۖ وَقَدْ كَانُوا۟ يُدْعَوْنَ إِلَى ٱلسُّجُودِ وَهُمْ سَٰلِمُونَ","translation":"downcast will be their eyes, with ignominy overwhelming them - seeing that they had been called upon [in vain] to prostrate themselves [before Him] while they were yet sound [and alive].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5314.mp3","surahId":68,"words":[{"id":43772,"position":1,"arabic":"خَـٰشِعَةً","translation":"অবনত হবে","audioUrl":"wbw/068_043_001.mp3","charTypeName":"word"},{"id":43773,"position":2,"arabic":"أَبْصَـٰرُهُمْ","translation":"তাদের দৃষ্টিগুলো","audioUrl":"wbw/068_043_002.mp3","charTypeName":"word"},{"id":43774,"position":3,"arabic":"تَرْهَقُهُمْ","translation":"তাদের আচ্ছাদিত করবে","audioUrl":"wbw/068_043_003.mp3","charTypeName":"word"},{"id":43775,"position":4,"arabic":"ذِلَّةٌۭ ۖ","translation":"অপমান","audioUrl":"wbw/068_043_004.mp3","charTypeName":"word"},{"id":43777,"position":5,"arabic":"وَقَدْ","translation":"এবং নিশ্চয়","audioUrl":"wbw/068_043_006.mp3","charTypeName":"word"},{"id":43778,"position":6,"arabic":"كَانُوا۟","translation":"তারা ছিল","audioUrl":"wbw/068_043_007.mp3","charTypeName":"word"},{"id":43779,"position":7,"arabic":"يُدْعَوْنَ","translation":"তাদের ডাকা হতো","audioUrl":"wbw/068_043_008.mp3","charTypeName":"word"},{"id":43780,"position":8,"arabic":"إِلَى","translation":"দিকে","audioUrl":"wbw/068_043_009.mp3","charTypeName":"word"},{"id":43781,"position":9,"arabic":"ٱلسُّجُودِ","translation":"সিজদাসমূহের","audioUrl":"wbw/068_043_010.mp3","charTypeName":"word"},{"id":43782,"position":10,"arabic":"وَهُمْ","translation":"অথচ তারা","audioUrl":"wbw/068_043_011.mp3","charTypeName":"word"},{"id":43783,"position":11,"arabic":"سَـٰلِمُونَ","translation":"নিরাপদ ছিল","audioUrl":"wbw/068_043_012.mp3","charTypeName":"word"},{"id":43784,"position":12,"arabic":"٤٣","translation":"(৪৩)","audioUrl":null,"charTypeName":"end"}]},{"number":44,"arabic":"فَذَرْنِى وَمَن يُكَذِّبُ بِهَٰذَا ٱلْحَدِيثِ ۖ سَنَسْتَدْرِجُهُم مِّنْ حَيْثُ لَا يَعْلَمُونَ","translation":"Hence, leave Me alone with such as give the lie to this tiding. We shall bring them low, step by step, without their perceiving how it has come about:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5315.mp3","surahId":68,"words":[{"id":44595,"position":1,"arabic":"فَذَرْنِى","translation":"অতএব আমাকে ছেড়ে দাও","audioUrl":"wbw/068_044_001.mp3","charTypeName":"word"},{"id":44596,"position":2,"arabic":"وَمَن","translation":"এবং যে","audioUrl":"wbw/068_044_002.mp3","charTypeName":"word"},{"id":44597,"position":3,"arabic":"يُكَذِّبُ","translation":"মিথ্যারোপ করে","audioUrl":"wbw/068_044_003.mp3","charTypeName":"word"},{"id":44598,"position":4,"arabic":"بِهَـٰذَا","translation":"এর উপর","audioUrl":"wbw/068_044_004.mp3","charTypeName":"word"},{"id":44599,"position":5,"arabic":"ٱلْحَدِيثِ ۖ","translation":"কথার","audioUrl":"wbw/068_044_005.mp3","charTypeName":"word"},{"id":44601,"position":6,"arabic":"سَنَسْتَدْرِجُهُم","translation":"শীঘ্রয় আমরা তাদের ক্রমে ক্রমে নিয়ে যাব","audioUrl":"wbw/068_044_007.mp3","charTypeName":"word"},{"id":44602,"position":7,"arabic":"مِّنْ","translation":"থেকে","audioUrl":"wbw/068_044_008.mp3","charTypeName":"word"},{"id":44603,"position":8,"arabic":"حَيْثُ","translation":"যেখান","audioUrl":"wbw/068_044_009.mp3","charTypeName":"word"},{"id":44604,"position":9,"arabic":"لَا","translation":"না","audioUrl":"wbw/068_044_010.mp3","charTypeName":"word"},{"id":44605,"position":10,"arabic":"يَعْلَمُونَ","translation":"তারা জানতেও পারবে","audioUrl":"wbw/068_044_011.mp3","charTypeName":"word"},{"id":44606,"position":11,"arabic":"٤٤","translation":"(৪৪)","audioUrl":null,"charTypeName":"end"}]},{"number":45,"arabic":"وَأُمْلِى لَهُمْ ۚ إِنَّ كَيْدِى مَتِينٌ","translation":"for, behold, though I may give them rein for a while, My subtle scheme is exceedingly firm!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5316.mp3","surahId":68,"words":[{"id":45282,"position":1,"arabic":"وَأُمْلِى","translation":"এবং আমি অবকাশ দিচ্ছি","audioUrl":"wbw/068_045_001.mp3","charTypeName":"word"},{"id":45283,"position":2,"arabic":"لَهُمْ ۚ","translation":"তাদের জন্যে","audioUrl":"wbw/068_045_002.mp3","charTypeName":"word"},{"id":45285,"position":3,"arabic":"إِنَّ","translation":"নিশ্চয়","audioUrl":"wbw/068_045_004.mp3","charTypeName":"word"},{"id":45286,"position":4,"arabic":"كَيْدِى","translation":"আমার কাইদা(কোশল)","audioUrl":"wbw/068_045_005.mp3","charTypeName":"word"},{"id":45287,"position":5,"arabic":"مَتِينٌ","translation":"বলিষ্ঠ","audioUrl":"wbw/068_045_006.mp3","charTypeName":"word"},{"id":45288,"position":6,"arabic":"٤٥","translation":"(৪৫)","audioUrl":null,"charTypeName":"end"}]},{"number":46,"arabic":"أَمْ تَسْـَٔلُهُمْ أَجْرًۭا فَهُم مِّن مَّغْرَمٍۢ مُّثْقَلُونَ","translation":"Or is it that [they fear lest] thou ask them for a reward, [O Prophet,] so that they would be burdened with debt [if they listened to thee]?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5317.mp3","surahId":68,"words":[{"id":46017,"position":1,"arabic":"أَمْ","translation":"কি","audioUrl":"wbw/068_046_001.mp3","charTypeName":"word"},{"id":46018,"position":2,"arabic":"تَسْـَٔلُهُمْ","translation":"তাদের কাছে তুমি চাচ্ছ","audioUrl":"wbw/068_046_002.mp3","charTypeName":"word"},{"id":46019,"position":3,"arabic":"أَجْرًۭا","translation":"কোন পারিশ্রমিক","audioUrl":"wbw/068_046_003.mp3","charTypeName":"word"},{"id":46020,"position":4,"arabic":"فَهُم","translation":"অতএব তারা","audioUrl":"wbw/068_046_004.mp3","charTypeName":"word"},{"id":46021,"position":5,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/068_046_005.mp3","charTypeName":"word"},{"id":46022,"position":6,"arabic":"مَّغْرَمٍۢ","translation":"জরিমানা","audioUrl":"wbw/068_046_006.mp3","charTypeName":"word"},{"id":46023,"position":7,"arabic":"مُّثْقَلُونَ","translation":"বোঝাগ্রস্থ","audioUrl":"wbw/068_046_007.mp3","charTypeName":"word"},{"id":46024,"position":8,"arabic":"٤٦","translation":"(৪৬)","audioUrl":null,"charTypeName":"end"}]},{"number":47,"arabic":"أَمْ عِندَهُمُ ٱلْغَيْبُ فَهُمْ يَكْتُبُونَ","translation":"Or [do they think] that the hidden reality [of all that exists] is within their grasp, so that [in time] they can write it down?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5318.mp3","surahId":68,"words":[{"id":46571,"position":1,"arabic":"أَمْ","translation":"কি","audioUrl":"wbw/068_047_001.mp3","charTypeName":"word"},{"id":46572,"position":2,"arabic":"عِندَهُمُ","translation":"তাদের কাছে আছে","audioUrl":"wbw/068_047_002.mp3","charTypeName":"word"},{"id":46573,"position":3,"arabic":"ٱلْغَيْبُ","translation":"গায়েবের(জ্ঞান)","audioUrl":"wbw/068_047_003.mp3","charTypeName":"word"},{"id":46574,"position":4,"arabic":"فَهُمْ","translation":"বা তারা","audioUrl":"wbw/068_047_004.mp3","charTypeName":"word"},{"id":46575,"position":5,"arabic":"يَكْتُبُونَ","translation":"লিখে রাখে","audioUrl":"wbw/068_047_005.mp3","charTypeName":"word"},{"id":46576,"position":6,"arabic":"٤٧","translation":"(৪৭)","audioUrl":null,"charTypeName":"end"}]},{"number":48,"arabic":"فَٱصْبِرْ لِحُكْمِ رَبِّكَ وَلَا تَكُن كَصَاحِبِ ٱلْحُوتِ إِذْ نَادَىٰ وَهُوَ مَكْظُومٌۭ","translation":"BEAR THEN with patience thy Sustainer's will and be not like him of the great fish, who cried out [in distress] after having given in to anger.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5319.mp3","surahId":68,"words":[{"id":47413,"position":1,"arabic":"فَٱصْبِرْ","translation":"অতএব সবর কর","audioUrl":"wbw/068_048_001.mp3","charTypeName":"word"},{"id":47414,"position":2,"arabic":"لِحُكْمِ","translation":"ফয়সালার জন্যে","audioUrl":"wbw/068_048_002.mp3","charTypeName":"word"},{"id":47415,"position":3,"arabic":"رَبِّكَ","translation":"তোমার রবের","audioUrl":"wbw/068_048_003.mp3","charTypeName":"word"},{"id":47416,"position":4,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/068_048_004.mp3","charTypeName":"word"},{"id":47417,"position":5,"arabic":"تَكُن","translation":"হয়ো","audioUrl":"wbw/068_048_005.mp3","charTypeName":"word"},{"id":47418,"position":6,"arabic":"كَصَاحِبِ","translation":"ওঁয়ালার মতো","audioUrl":"wbw/068_048_006.mp3","charTypeName":"word"},{"id":47419,"position":7,"arabic":"ٱلْحُوتِ","translation":"মাছ","audioUrl":"wbw/068_048_007.mp3","charTypeName":"word"},{"id":47420,"position":8,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/068_048_008.mp3","charTypeName":"word"},{"id":47421,"position":9,"arabic":"نَادَىٰ","translation":"শসে ডেকেছিল","audioUrl":"wbw/068_048_009.mp3","charTypeName":"word"},{"id":47422,"position":10,"arabic":"وَهُوَ","translation":"এবং সে","audioUrl":"wbw/068_048_010.mp3","charTypeName":"word"},{"id":47423,"position":11,"arabic":"مَكْظُومٌۭ","translation":"বিষণ্ণ ছিল","audioUrl":"wbw/068_048_011.mp3","charTypeName":"word"},{"id":47424,"position":12,"arabic":"٤٨","translation":"(৪৮)","audioUrl":null,"charTypeName":"end"}]},{"number":49,"arabic":"لَّوْلَآ أَن تَدَٰرَكَهُۥ نِعْمَةٌۭ مِّن رَّبِّهِۦ لَنُبِذَ بِٱلْعَرَآءِ وَهُوَ مَذْمُومٌۭ","translation":"[And remember:] had not grace from his Sustainer reached him, he would indeed have been cast forth upon that barren shore in a state of disgrace:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5320.mp3","surahId":68,"words":[{"id":47917,"position":1,"arabic":"لَّوْلَآ","translation":"যদি না","audioUrl":"wbw/068_049_001.mp3","charTypeName":"word"},{"id":47918,"position":2,"arabic":"أَن","translation":"তাকে","audioUrl":"wbw/068_049_002.mp3","charTypeName":"word"},{"id":47919,"position":3,"arabic":"تَدَٰرَكَهُۥ","translation":"পেতো","audioUrl":"wbw/068_049_003.mp3","charTypeName":"word"},{"id":47920,"position":4,"arabic":"نِعْمَةٌۭ","translation":"অনুগ্রহ","audioUrl":"wbw/068_049_004.mp3","charTypeName":"word"},{"id":47921,"position":5,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/068_049_005.mp3","charTypeName":"word"},{"id":47922,"position":6,"arabic":"رَّبِّهِۦ","translation":"তার রবের","audioUrl":"wbw/068_049_006.mp3","charTypeName":"word"},{"id":47923,"position":7,"arabic":"لَنُبِذَ","translation":"অবশ্যই নিক্ষিপ্ত হতো","audioUrl":"wbw/068_049_007.mp3","charTypeName":"word"},{"id":47924,"position":8,"arabic":"بِٱلْعَرَآءِ","translation":"উন্মুক্ত প্রাস্তরে","audioUrl":"wbw/068_049_008.mp3","charTypeName":"word"},{"id":47925,"position":9,"arabic":"وَهُوَ","translation":"এবং সে","audioUrl":"wbw/068_049_009.mp3","charTypeName":"word"},{"id":47926,"position":10,"arabic":"مَذْمُومٌۭ","translation":"নিন্দিত হতো","audioUrl":"wbw/068_049_010.mp3","charTypeName":"word"},{"id":47927,"position":11,"arabic":"٤٩","translation":"(৪৯)","audioUrl":null,"charTypeName":"end"}]},{"number":50,"arabic":"فَٱجْتَبَٰهُ رَبُّهُۥ فَجَعَلَهُۥ مِنَ ٱلصَّٰلِحِينَ","translation":"but [as it was,] his Sustainer had elected him and placed him among the righteous.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5321.mp3","surahId":68,"words":[{"id":48749,"position":1,"arabic":"فَٱجْتَبَـٰهُ","translation":"অতঃপর তাকে মনোনীত করলেন","audioUrl":"wbw/068_050_001.mp3","charTypeName":"word"},{"id":48750,"position":2,"arabic":"رَبُّهُۥ","translation":"তার রব","audioUrl":"wbw/068_050_002.mp3","charTypeName":"word"},{"id":48751,"position":3,"arabic":"فَجَعَلَهُۥ","translation":"তাই তাকে করলেন","audioUrl":"wbw/068_050_003.mp3","charTypeName":"word"},{"id":48752,"position":4,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/068_050_004.mp3","charTypeName":"word"},{"id":48753,"position":5,"arabic":"ٱلصَّـٰلِحِينَ","translation":"নেক বান্দাদের","audioUrl":"wbw/068_050_005.mp3","charTypeName":"word"},{"id":48754,"position":6,"arabic":"٥٠","translation":"(৫০)","audioUrl":null,"charTypeName":"end"}]},{"number":51,"arabic":"وَإِن يَكَادُ ٱلَّذِينَ كَفَرُوا۟ لَيُزْلِقُونَكَ بِأَبْصَٰرِهِمْ لَمَّا سَمِعُوا۟ ٱلذِّكْرَ وَيَقُولُونَ إِنَّهُۥ لَمَجْنُونٌۭ","translation":"Hence, [be patient,] even though they who are bent on denying the truth would all but kill thee with their eyes whenever they hear this reminder, and [though] they say, \"[As for Muhammad,] behold, most surely he is a madman!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5322.mp3","surahId":68,"words":[{"id":49285,"position":1,"arabic":"وَإِن","translation":"এবং যেন","audioUrl":"wbw/068_051_001.mp3","charTypeName":"word"},{"id":49286,"position":2,"arabic":"يَكَادُ","translation":"মনে হয়","audioUrl":"wbw/068_051_002.mp3","charTypeName":"word"},{"id":49287,"position":3,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/068_051_003.mp3","charTypeName":"word"},{"id":49288,"position":4,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/068_051_004.mp3","charTypeName":"word"},{"id":49289,"position":5,"arabic":"لَيُزْلِقُونَكَ","translation":"অবশ্যই তোমাকে পদংখলন করাবে","audioUrl":"wbw/068_051_005.mp3","charTypeName":"word"},{"id":49290,"position":6,"arabic":"بِأَبْصَـٰرِهِمْ","translation":"তাদের দৃষ্টিগুলো দিয়ে","audioUrl":"wbw/068_051_006.mp3","charTypeName":"word"},{"id":49291,"position":7,"arabic":"لَمَّا","translation":"যখন","audioUrl":"wbw/068_051_007.mp3","charTypeName":"word"},{"id":49292,"position":8,"arabic":"سَمِعُوا۟","translation":"তারা শুনে","audioUrl":"wbw/068_051_008.mp3","charTypeName":"word"},{"id":49293,"position":9,"arabic":"ٱلذِّكْرَ","translation":"উপদেশ(কুরআন)","audioUrl":"wbw/068_051_009.mp3","charTypeName":"word"},{"id":49294,"position":10,"arabic":"وَيَقُولُونَ","translation":"এবং তারা বলে","audioUrl":"wbw/068_051_010.mp3","charTypeName":"word"},{"id":49295,"position":11,"arabic":"إِنَّهُۥ","translation":"\"সেনিশ্চয়","audioUrl":"wbw/068_051_011.mp3","charTypeName":"word"},{"id":49296,"position":12,"arabic":"لَمَجْنُونٌۭ","translation":"অবশ্যই পাগল\"","audioUrl":"wbw/068_051_012.mp3","charTypeName":"word"},{"id":49297,"position":13,"arabic":"٥١","translation":"(৫১)","audioUrl":null,"charTypeName":"end"}]},{"number":52,"arabic":"وَمَا هُوَ إِلَّا 