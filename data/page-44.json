ber":261,"arabic":"مَّثَلُ ٱلَّذِينَ يُنفِقُونَ أَمْوَٰلَهُمْ فِى سَبِيلِ ٱللَّهِ كَمَثَلِ حَبَّةٍ أَنۢبَتَتْ سَبْعَ سَنَابِلَ فِى كُلِّ سُنۢبُلَةٍۢ مِّا۟ئَةُ حَبَّةٍۢ ۗ وَٱللَّهُ يُضَٰعِفُ لِمَن يَشَآءُ ۗ وَٱللَّهُ وَٰسِعٌ عَلِيمٌ","translation":"THE PARABLE of those who spend their possessions for the sake of God is that of a grain out of which grow seven ears, in every ear a hundred grains: for God grants manifold increase unto whom He wills; and God is infinite, all-knowing.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/268.mp3","surahId":2,"words":[{"id":87428,"position":1,"arabic":"مَّثَلُ","translation":"উপমা (তাদের ঐরূপ)","audioUrl":"wbw/002_261_001.mp3","charTypeName":"word"},{"id":87429,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/002_261_002.mp3","charTypeName":"word"},{"id":87430,"position":3,"arabic":"يُنفِقُونَ","translation":"ব্যয় করে","audioUrl":"wbw/002_261_003.mp3","charTypeName":"word"},{"id":87431,"position":4,"arabic":"أَمْوَٰلَهُمْ","translation":"তাদের ধন সম্পদ","audioUrl":"wbw/002_261_004.mp3","charTypeName":"word"},{"id":87432,"position":5,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/002_261_005.mp3","charTypeName":"word"},{"id":87433,"position":6,"arabic":"سَبِيلِ","translation":"পথের","audioUrl":"wbw/002_261_006.mp3","charTypeName":"word"},{"id":87434,"position":7,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/002_261_007.mp3","charTypeName":"word"},{"id":87435,"position":8,"arabic":"كَمَثَلِ","translation":"মতো উপমা","audioUrl":"wbw/002_261_008.mp3","charTypeName":"word"},{"id":87436,"position":9,"arabic":"حَبَّةٍ","translation":"একটা শস্যদানা (বীজের)","audioUrl":"wbw/002_261_009.mp3","charTypeName":"word"},{"id":87437,"position":10,"arabic":"أَنۢبَتَتْ","translation":"তা উৎপন্ন করে","audioUrl":"wbw/002_261_010.mp3","charTypeName":"word"},{"id":87438,"position":11,"arabic":"سَبْعَ","translation":"সাতটি","audioUrl":"wbw/002_261_011.mp3","charTypeName":"word"},{"id":87439,"position":12,"arabic":"سَنَابِلَ","translation":"শীষ","audioUrl":"wbw/002_261_012.mp3","charTypeName":"word"},{"id":87440,"position":13,"arabic":"فِى","translation":"মধ্যে (আছে)","audioUrl":"wbw/002_261_013.mp3","charTypeName":"word"},{"id":87441,"position":14,"arabic":"كُلِّ","translation":"প্রত্যেকটি","audioUrl":"wbw/002_261_014.mp3","charTypeName":"word"},{"id":87442,"position":15,"arabic":"سُنۢبُلَةٍۢ","translation":"শীষে","audioUrl":"wbw/002_261_015.mp3","charTypeName":"word"},{"id":87443,"position":16,"arabic":"مِّا۟ئَةُ","translation":"একশত","audioUrl":"wbw/002_261_016.mp3","charTypeName":"word"},{"id":87444,"position":17,"arabic":"حَبَّةٍۢ ۗ","translation":"শস্যদানা","audioUrl":"wbw/002_261_017.mp3","charTypeName":"word"},{"id":87446,"position":18,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/002_261_019.mp3","charTypeName":"word"},{"id":87447,"position":19,"arabic":"يُضَـٰعِفُ","translation":"বৃদ্ধি করেন বহুগুনে","audioUrl":"wbw/002_261_020.mp3","charTypeName":"word"},{"id":87448,"position":20,"arabic":"لِمَن","translation":"তার জন্য যাকে","audioUrl":"wbw/002_261_021.mp3","charTypeName":"word"},{"id":87449,"position":21,"arabic":"يَشَآءُ ۗ","translation":"তিনি ইচ্ছা করেন","audioUrl":"wbw/002_261_022.mp3","charTypeName":"word"},{"id":87451,"position":22,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/002_261_024.mp3","charTypeName":"word"},{"id":87452,"position":23,"arabic":"وَٰسِعٌ","translation":"প্রাচুর্যময়","audioUrl":"wbw/002_261_025.mp3","charTypeName":"word"},{"id":87453,"position":24,"arabic":"عَلِيمٌ","translation":"সর্বজ্ঞ","audioUrl":"wbw/002_261_026.mp3","charTypeName":"word"},{"id":87454,"position":25,"arabic":"٢٦١","translation":"(২৬১)","audioUrl":null,"charTypeName":"end"}]},{"number":262,"arabic":"ٱلَّذِينَ يُنفِقُونَ أَمْوَٰلَهُمْ فِى سَبِيلِ ٱللَّهِ ثُمَّ لَا يُتْبِعُونَ مَآ أَنفَقُوا۟ مَنًّۭا وَلَآ أَذًۭى ۙ لَّهُمْ أَجْرُهُمْ عِندَ رَبِّهِمْ وَلَا خَوْفٌ عَلَيْهِمْ وَلَا هُمْ يَحْزَنُونَ","translation":"They who spend their possessions for the sake of God and do not thereafter mar their spending by stressing their own benevolence and hurting [the feelings of the needy] shall have their reward with 'their Sustainer, and no fear need they have, and neither shall they grieve.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/269.mp3","surahId":2,"words":[{"id":87455,"position":1,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/002_262_001.mp3","charTypeName":"word"},{"id":87456,"position":2,"arabic":"يُنفِقُونَ","translation":"ব্যয় করে","audioUrl":"wbw/002_262_002.mp3","charTypeName":"word"},{"id":87457,"position":3,"arabic":"أَمْوَٰلَهُمْ","translation":"তাদের ধন সম্পদ","audioUrl":"wbw/002_262_003.mp3","charTypeName":"word"},{"id":87458,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/002_262_004.mp3","charTypeName":"word"},{"id":87459,"position":5,"arabic":"سَبِيلِ","translation":"পথের","audioUrl":"wbw/002_262_005.mp3","charTypeName":"word"},{"id":87460,"position":6,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/002_262_006.mp3","charTypeName":"word"},{"id":87461,"position":7,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/002_262_007.mp3","charTypeName":"word"},{"id":87462,"position":8,"arabic":"لَا","translation":"না","audioUrl":"wbw/002_262_008.mp3","charTypeName":"word"},{"id":87463,"position":9,"arabic":"يُتْبِعُونَ","translation":"তারা পেছনে থাকে","audioUrl":"wbw/002_262_009.mp3","charTypeName":"word"},{"id":87464,"position":10,"arabic":"مَآ","translation":"(তার) যা","audioUrl":"wbw/002_262_010.mp3","charTypeName":"word"},{"id":87465,"position":11,"arabic":"أَنفَقُوا۟","translation":"তারা ব্যয় করেছে","audioUrl":"wbw/002_262_011.mp3","charTypeName":"word"},{"id":87466,"position":12,"arabic":"مَنًّۭا","translation":"(অনুগ্রহ করার) খোটা","audioUrl":"wbw/002_262_012.mp3","charTypeName":"word"},{"id":87467,"position":13,"arabic":"وَلَآ","translation":"আর না","audioUrl":"wbw/002_262_013.mp3","charTypeName":