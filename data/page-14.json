{"id":14,"ayahs":[{"number":89,"arabic":"وَلَمَّا جَآءَهُمْ كِتَٰبٌۭ مِّنْ عِندِ ٱللَّهِ مُصَدِّقٌۭ لِّمَا مَعَهُمْ وَكَانُوا۟ مِن قَبْلُ يَسْتَفْتِحُونَ عَلَى ٱلَّذِينَ كَفَرُوا۟ فَلَمَّا جَآءَهُم مَّا عَرَفُوا۟ كَفَرُوا۟ بِهِۦ ۚ فَلَعْنَةُ ٱللَّهِ عَلَى ٱلْكَٰفِرِينَ","translation":"And whenever there came unto them a [new] revelation from God, confirming the truth already in their possession-and [bear in mind that] aforetime they used to pray for victory over those who were bent on denying the truth -: whenever there came unto them something which they recognized [as the truth], they would deny it. And God's rejection is the due of all who deny the truth.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/96.mp3","surahId":2,"words":[{"id":67761,"position":1,"arabic":"وَلَمَّا","translation":"এবং যখন","audioUrl":"wbw/002_089_001.mp3","charTypeName":"word"},{"id":67762,"position":2,"arabic":"جَآءَهُمْ","translation":"এসেছে তাদের কাছে","audioUrl":"wbw/002_089_002.mp3","charTypeName":"word"},{"id":67763,"position":3,"arabic":"كِتَـٰبٌۭ","translation":"কিতাব","audioUrl":"wbw/002_089_003.mp3","charTypeName":"word"},{"id":67764,"position":4,"arabic":"مِّنْ","translation":"থেকে","audioUrl":"wbw/002_089_004.mp3","charTypeName":"word"},{"id":67765,"position":5,"arabic":"عِندِ","translation":"নিকট","audioUrl":"wbw/002_089_005.mp3","charTypeName":"word"},{"id":67766,"position":6,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌র","audioUrl":"wbw/002_089_006.mp3","charTypeName":"word"},{"id":67767,"position":7,"arabic":"مُصَدِّقٌۭ","translation":"সত্যায়নকারী","audioUrl":"wbw/002_089_007.mp3","charTypeName":"word"},{"id":67768,"position":8,"arabic":"لِّمَا","translation":"তার জন্য যা","audioUrl":"wbw/002_089_008.mp3","charTypeName":"word"},{"id":67769,"position":9,"arabic":"مَعَهُمْ","translation":"তাদের সাথে(আছে)","audioUrl":"wbw/002_089_009.mp3","charTypeName":"word"},{"id":67770,"position":10,"arabic":"وَكَانُوا۟","translation":"এবং তারা ছিল","audioUrl":"wbw/002_089_010.mp3","charTypeName":"word"},{"id":67771,"position":11,"arabic":"مِن","translation":"(থেকে)","audioUrl":"wbw/002_089_011.mp3","charTypeName":"word"},{"id":67772,"position":12,"arabic":"قَبْلُ","translation":"পূর্ব থেকে","audioUrl":"wbw/002_089_012.mp3","charTypeName":"word"},{"id":67773,"position":13,"arabic":"يَسْتَفْتِحُونَ","translation":"বিজয় চাইত","audioUrl":"wbw/002_089_013.mp3","charTypeName":"word"},{"id":67774,"position":14,"arabic":"عَلَى","translation":"উপর(বিরুদ্ধে)","audioUrl":"wbw/002_089_014.mp3","charTypeName":"word"},{"id":67775,"position":15,"arabic":"ٱلَّذِينَ","translation":"(তাদের) যারা","audioUrl":"wbw/002_089_015.mp3","charTypeName":"word"},{"id":67776,"position":16,"arabic":"كَفَرُوا۟","translation":"অবিশ্বাস করেছে","audioUrl":"wbw/002_089_016.mp3","charTypeName":"word"},{"id":67777,"position":17,"arabic":"فَلَمَّا","translation":"অতঃপর যখন","audioUrl":"wbw/002_089_017.mp3","charTypeName":"word"},{"id":67778,"position":18,"arabic":"جَآءَهُم","translation":"আসল তাদের কাছে","audioUrl":"wbw/002_089_018.mp3","charTypeName":"word"},{"id":67779,"position":19,"arabic":"مَّا","translation":"যা","audioUrl":"wbw/002_089_019.mp3","charTypeName":"word"},{"id":67780,"position":20,"arabic":"عَرَفُوا۟","translation":"তারা জানত","audioUrl":"wbw/002_089_020.mp3","charTypeName":"word"},{"id":67781,"position":21,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করল","audioUrl":"wbw/002_089_021.mp3","charTypeName":"word"},{"id":67782,"position":22,"arabic":"بِهِۦ ۚ","translation":"তার প্রতি","audioUrl":"wbw/002_089_022.mp3","charTypeName":"word"},{"id":67784,"position":23,"arabic":"فَلَعْنَةُ","translation":"ফলে অভিশাপ","audioUrl":"wbw/002_089_024.mp3","charTypeName":"word"},{"id":67785,"position":24,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌র","audioUrl":"wbw/002_089_025.mp3","charTypeName":"word"},{"id":67786,"position":25,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/002_089_026.mp3","charTypeName":"word"},{"id":67787,"position":26,"arabic":"ٱلْكَـٰفِرِينَ","translation":"প্রত্যাখ্যানকারীদের","audioUrl":"wbw/002_089_027.mp3","charTypeName":"word"},{"id":67788,"position":27,"arabic":"٨٩","translation":"(৮৯)","audioUrl":null,"charTypeName":"end"}]},{"number":90,"arabic":"بِئْسَمَا ٱشْتَرَوْا۟ بِهِۦٓ أَنفُسَهُمْ أَن يَكْفُرُوا۟ بِمَآ أَنزَلَ ٱللَّهُ بَغْيًا أَن يُنَزِّلَ ٱللَّهُ مِن فَضْلِهِۦ عَلَىٰ مَن يَشَآءُ مِنْ عِبَادِهِۦ ۖ فَبَآءُو بِغَضَبٍ عَلَىٰ غَضَبٍۢ ۚ وَلِلْكَٰفِرِينَ عَذَابٌۭ مُّهِينٌۭ","translation":"Vile is that [false pride] for which they have sold their own selves by denying the truth of what God has bestowed from on high, out of envy that God should bestow aught of His favour upon whomsoever He wills of His servants: and thus have they earned the burden of God's condemnation, over and over. And for those who deny the truth there is shameful suffering in store.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/97.mp3","surahId":2,"words":[{"id":68057,"position":1,"arabic":"بِئْسَمَا","translation":"কতই নিকৃষ্ট তা","audioUrl":"wbw/002_090_001.mp3","charTypeName":"word"},{"id":68058,"position":2,"arabic":"ٱشْتَرَوْا۟","translation":"তারা বিক্রি করেছে","audioUrl":"wbw/002_090_002.mp3","charTypeName":"word"},{"id":68059,"position":3,"arabic":"بِهِۦٓ","translation":"যার বিনিময়ে","audioUrl":"wbw/002_090_003.mp3","charTypeName":"word"},{"id":68060,"position":4,"arabic":"أَنفُسَهُمْ","translation":"তাদের আত্মাকে","audioUrl":"wbw/002_090_004.mp3","charTypeName":"word"},{"id":68061,"position":5,"arabic":"أَن","translation":"(থেকে)","audioUrl":"wbw/002_090_005.mp3","charTypeName":"word"},{"id":68062,"position":6,"arabic":"يَكْفُرُوا۟","translation":"তারা অস্বীকার করে যে","audioUrl":"wbw/002_090_006.mp3","charTypeName":"word"},{"id":68063,"position":7,"arabic":"بِمَآ","translation":"ঐ বিষয় যা","audioUrl":"wbw/002_090_007.mp3","charTypeName":"word"},{"id":68064,"position":8,"arabic":"أَنزَلَ","translation":"অবতীর্ণ করেছেন","audioUrl":"wbw/002_090_008.mp3","charTypeName":"word"},{"id":68065,"position":9,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌","audioUrl":"wbw/002_090_009.mp3","charTypeName":"word"},{"id":68066,"position":10,"arabic":"بَغْيًا","translation":"জিদ বশতঃ","audioUrl":"wbw/002_090_010.mp3","charTypeName":"word"},{"id":68067,"position":11,"arabic":"أَن","translation":"(এজন্য) যে","audioUrl":"wbw/002_090_011.mp3","charTypeName":"word"},{"id":68068,"position":12,"arabic":"يُنَزِّلَ","translation":"অবতীর্ণ করেছেন","audioUrl":"wbw/002_090_012.mp3","charTypeName":"word"},{"id":68069,"position":13,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌","audioUrl":"wbw/002_090_013.mp3","charTypeName":"word"},{"id":68070,"position":14,"arabic":"مِن","translation":"কারণে","audioUrl":"wbw/002_090_014.mp3","charTypeName":"word"},{"id":68071,"position":15,"arabic":"فَضْلِهِۦ","translation":"তাঁর অনুগ্রহের","audioUrl":"wbw/002_090_015.mp3","charTypeName":"word"},{"id":68072,"position":16,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/002_090_016.mp3","charTypeName":"word"},{"id":68073,"position":17,"arabic":"مَن","translation":"যাকে","audioUrl":"wbw/002_090_017.mp3","charTypeName":"word"},{"id":68074,"position":18,"arabic":"يَشَآءُ","translation":"তিনি চান","audioUrl":"wbw/002_090_018.mp3","charTypeName":"word"},{"id":68075,"position":19,"arabic":"مِنْ","translation":"মধ্য হতে","audioUrl":"wbw/002_090_019.mp3","charTypeName":"word"},{"id":68076,"position":20,"arabic":"عِبَادِهِۦ ۖ","translation":"তাঁর বান্দাদের","audioUrl":"wbw/002_090_020.mp3","charTypeName":"word"},{"id":68078,"position":21,"arabic":"فَبَآءُو","translation":"তারা ফলে পরিবেষ্টিত হয়েছে","audioUrl":"wbw/002_090_022.mp3","charTypeName":"word"},{"id":68079,"position":22,"arabic":"بِغَضَبٍ","translation":"রাগ দিয়ে","audioUrl":"wbw/002_090_023.mp3","charTypeName":"word"},{"id":68080,"position":23,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/002_090_024.mp3","charTypeName":"word"},{"id":68081,"position":24,"arabic":"غَضَبٍۢ ۚ","translation":"রাগের","audioUrl":"wbw/002_090_025.mp3","charTypeName":"word"},{"id":68083,"position":25,"arabic":"وَلِلْكَـٰفِرِينَ","translation":"এবং কাফিরদের জন্য(রয়েছে)","audioUrl":"wbw/002_090_027.mp3","charTypeName":"word"},{"id":68084,"position":26,"arabic":"عَذَابٌۭ","translation":"শাস্তি","audioUrl":"wbw/002_090_028.mp3","charTypeName":"word"},{"id":68085,"position":27,"arabic":"مُّهِينٌۭ","translation":"অপমানকর","audioUrl":"wbw/002_090_029.mp3","charTypeName":"word"},{"id":68086,"position":28,"arabic":"٩٠","translation":"(৯০)","audioUrl":null,"charTypeName":"end"}]},{"number":91,"arabic":"وَإِذَا قِيلَ لَهُمْ ءَامِنُوا۟ بِمَآ أَنزَلَ ٱللَّهُ قَالُوا۟ نُؤْمِنُ بِمَآ أُنزِلَ عَلَيْنَا وَيَكْفُرُونَ بِمَا وَرَآءَهُۥ وَهُوَ ٱلْحَقُّ مُصَدِّقًۭا لِّمَا مَعَهُمْ ۗ قُلْ فَلِمَ تَقْتُلُونَ أَنۢبِيَآءَ ٱللَّهِ مِن قَبْلُ إِن كُنتُم مُّؤْمِنِينَ","translation":"For when they are told, \"Believe in what God has bestowed from on high,\" they reply, \"We believe [only] in what has been bestowed on us\"-and they deny the truth of everything else, although it be a truth confirming the one already in their possession. Say \"Why, then, did you slay God's prophets aforetime, if you were (truly] believers?\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/98.mp3","surahId":2,"words":[{"id":68342,"position":1,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/002_091_001.mp3","charTypeName":"word"},{"id":68343,"position":2,"arabic":"قِيلَ","translation":"বলা হয়","audioUrl":"wbw/002_091_002.mp3","charTypeName":"word"},{"id":68344,"position":3,"arabic":"لَهُمْ","translation":"তাদের উদ্দেশে","audioUrl":"wbw/002_091_003.mp3","charTypeName":"word"},{"id":68345,"position":4,"arabic":"ءَامِنُوا۟","translation":"''তোমরা ঈমান আনো","audioUrl":"wbw/002_091_004.mp3","charTypeName":"word"},{"id":68346,"position":5,"arabic":"بِمَآ","translation":"ঐবিষয়ে যা","audioUrl":"wbw/002_091_005.mp3","charTypeName":"word"},{"id":68347,"position":6,"arabic":"أَنزَلَ","translation":"অবতীর্ণ করেছেন","audioUrl":"wbw/002_091_006.mp3","charTypeName":"word"},{"id":68348,"position":7,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌''","audioUrl":"wbw/002_091_007.mp3","charTypeName":"word"},{"id":68349,"position":8,"arabic":"قَالُوا۟","translation":"তারা বলে","audioUrl":"wbw/002_091_008.mp3","charTypeName":"word"},{"id":68350,"position":9,"arabic":"نُؤْمِنُ","translation":"''আমরা ঈমান আনব","audioUrl":"wbw/002_091_009.mp3","charTypeName":"word"},{"id":68351,"position":10,"arabic":"بِمَآ","translation":"ঐবিষয়ে যা","audioUrl":"wbw/002_091_010.mp3","charTypeName":"word"},{"id":68352,"position":11,"arabic":"أُنزِلَ","translation":"অবতীর্ণ করা হয়েছে","audioUrl":"wbw/002_091_011.mp3","charTypeName":"word"},{"id":68353,"position":12,"arabic":"عَلَيْنَا","translation":"আমাদের উপর''","audioUrl":"wbw/002_091_012.mp3","charTypeName":"word"},{"id":68354,"position":13,"arabic":"وَيَكْفُرُونَ","translation":"ও তারা অস্বীকার করে","audioUrl":"wbw/002_091_013.mp3","charTypeName":"word"},{"id":68355,"position":14,"arabic":"بِمَا","translation":"যা(আছে)","audioUrl":"wbw/002_091_014.mp3","charTypeName":"word"},{"id":68356,"position":15,"arabic":"وَرَآءَهُۥ","translation":"তা ছাড়া","audioUrl":"wbw/002_091_015.mp3","charTypeName":"word"},{"id":68357,"position":16,"arabic":"وَهُوَ","translation":"অথচ সেটাই","audioUrl":"wbw/002_091_016.mp3","charTypeName":"word"},{"id":68358,"position":17,"arabic":"ٱلْحَقُّ","translation":"সত্য","audioUrl":"wbw/002_091_017.mp3","charTypeName":"word"},{"id":68359,"position":18,"arabic":"مُصَدِّقًۭا","translation":"সত্যায়নকারী","audioUrl":"wbw/002_091_018.mp3","charTypeName":"word"},{"id":68360,"position":19,"arabic":"لِّمَا","translation":"তার জন্য যা","audioUrl":"wbw/002_091_019.mp3","charTypeName":"word"},{"id":68361,"position":20,"arabic":"مَعَهُمْ ۗ","translation":"তাদের সাথে(আছে)","audioUrl":"wbw/002_091_020.mp3","charTypeName":"word"},{"id":68363,"position":21,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/002_091_022.mp3","charTypeName":"word"},{"id":68364,"position":22,"arabic":"فَلِمَ","translation":"''কেন তাহলে","audioUrl":"wbw/002_091_023.mp3","charTypeName":"word"},{"id":68365,"position":23,"arabic":"تَقْتُلُونَ","translation":"তোমরা হত্যা করেছ","audioUrl":"wbw/002_091_024.mp3","charTypeName":"word"},{"id":68366,"position":24,"arabic":"أَنۢبِيَآءَ","translation":"নবীদেরকে","audioUrl":"wbw/002_091_025.mp3","charTypeName":"word"},{"id":68367,"position":25,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌র","audioUrl":"wbw/002_091_026.mp3","charTypeName":"word"},{"id":68368,"position":26,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/002_091_027.mp3","charTypeName":"word"},{"id":68369,"position":27,"arabic":"قَبْلُ","translation":"পূর্ব","audioUrl":"wbw/002_091_028.mp3","charTypeName":"word"},{"id":68370,"position":28,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/002_091_029.mp3","charTypeName":"word"},{"id":68371,"position":29,"arabic":"كُنتُم","translation":"তোমরা হয়ে থাক","audioUrl":"wbw/002_091_030.mp3","charTypeName":"word"},{"id":68372,"position":30,"arabic":"مُّؤْمِنِينَ","translation":"মুমিন''","audioUrl":"wbw/002_091_031.mp3","charTypeName":"word"},{"id":68373,"position":31,"arabic":"٩١","translation":"(৯১)","audioUrl":null,"charTypeName":"end"}]},{"number":92,"arabic":"۞ وَلَقَدْ جَآءَكُم مُّوسَىٰ بِٱلْبَيِّنَٰتِ ثُمَّ ٱتَّخَذْتُمُ ٱلْعِجْلَ مِنۢ بَعْدِهِۦ وَأَنتُمْ ظَٰلِمُونَ","translation":"And indeed, there came unto you Moses with all evidence of the truth - and thereupon. in his absence, you took to worshipping the (golden] calf, and acted wickedly.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/99.mp3","surahId":2,"words":[{"id":68696,"position":1,"arabic":"۞ وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/002_092_002.mp3","charTypeName":"word"},{"id":68697,"position":2,"arabic":"جَآءَكُم","translation":"তোমাদের কাছে এসেছিল","audioUrl":"wbw/002_092_003.mp3","charTypeName":"word"},{"id":68698,"position":3,"arabic":"مُّوسَىٰ","translation":"মূসা","audioUrl":"wbw/002_092_004.mp3","charTypeName":"word"},{"id":68699,"position":4,"arabic":"بِٱلْبَيِّنَـٰتِ","translation":"সুস্পষ্ট নিদর্শন সমূহ নিয়ে","audioUrl":"wbw/002_092_005.mp3","charTypeName":"word"},{"id":68700,"position":5,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/002_092_006.mp3","charTypeName":"word"},{"id":68701,"position":6,"arabic":"ٱتَّخَذْتُمُ","translation":"গ্রহণ করেছিলে তোমরা","audioUrl":"wbw/002_092_007.mp3","charTypeName":"word"},{"id":68702,"position":7,"arabic":"ٱلْعِجْلَ","translation":"গো বাছুরকে (উপাস্যরূপে)","audioUrl":"wbw/002_092_008.mp3","charTypeName":"word"},{"id":68703,"position":8,"arabic":"مِنۢ","translation":"থেকে","audioUrl":"wbw/002_092_009.mp3","charTypeName":"word"},{"id":68704,"position":9,"arabic":"بَعْدِهِۦ","translation":"তারপর","audioUrl":"wbw/002_092_010.mp3","charTypeName":"word"},{"id":68705,"position":10,"arabic":"وَأَنتُمْ","translation":"এবং তোমরা(ছিলে)","audioUrl":"wbw/002_092_011.mp3","charTypeName":"word"},{"id":68706,"position":11,"arabic":"ظَـٰلِمُونَ","translation":"সীমালঙ্ঘনকারী","audioUrl":"wbw/002_092_012.mp3","charTypeName":"word"},{"id":68707,"position":12,"arabic":"٩٢","translation":"(৯২)","audioUrl":null,"charTypeName":"end"}]},{"number":93,"arabic":"وَإِذْ أَخَذْنَا مِيثَٰقَكُمْ وَرَفَعْنَا فَوْقَكُمُ ٱلطُّورَ خُذُوا۟ مَآ ءَاتَيْنَٰكُم بِقُوَّةٍۢ وَٱسْمَعُوا۟ ۖ قَالُوا۟ سَمِعْنَا وَعَصَيْنَا وَأُشْرِبُوا۟ فِى قُلُوبِهِمُ ٱلْعِجْلَ بِكُفْرِهِمْ ۚ قُلْ بِئْسَمَا يَأْمُرُكُم بِهِۦٓ إِيمَٰنُكُمْ إِن كُنتُم مُّؤْمِنِينَ","translation":"And, lo, We accepted your solemn pledge, raising Mount Sinai high above you, [saying,] \"Hold fast with [all your] strength unto what We have vouchsafed you, and hearken unto it!\" [But] they say, \"We have heard, but we disobey\" - for their hearts are filled to overflowing with love of the [golden] calf because of their refusal to acknowledge the truth. Say: \"Vile is what this [false] belief of yours enjoins upon you-if indeed you are believers!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/100.mp3","surahId":2,"words":[{"id":69081,"position":1,"arabic":"وَإِذْ","translation":"এবং যখন","audioUrl":"wbw/002_093_001.mp3","charTypeName":"word"},{"id":69082,"position":2,"arabic":"أَخَذْنَا","translation":"আমরা গ্রহণ করেছিলাম","audioUrl":"wbw/002_093_002.mp3","charTypeName":"word"},{"id":69083,"position":3,"arabic":"مِيثَـٰقَكُمْ","translation":"তোমাদের প্রতিশ্রুতি","audioUrl":"wbw/002_093_003.mp3","charTypeName":"word"},{"id":69084,"position":4,"arabic":"وَرَفَعْنَا","translation":"এবং উঠিয়েছিলাম","audioUrl":"wbw/002_093_004.mp3","charTypeName":"word"},{"id":69085,"position":5,"arabic":"فَوْقَكُمُ","translation":"তোমাদের উপর","audioUrl":"wbw/002_093_005.mp3","charTypeName":"word"},{"id":69086,"position":6,"arabic":"ٱلطُّورَ","translation":"তুর পাহাড়কে","audioUrl":"wbw/002_093_006.mp3","charTypeName":"word"},{"id":69087,"position":7,"arabic":"خُذُوا۟","translation":"''(বলেছিলাম) তোমরা ধরো","audioUrl":"wbw/002_093_007.mp3","charTypeName":"word"},{"id":69088,"position":8,"arabic":"مَآ","translation":"(তা)যা","audioUrl":"wbw/002_093_008.mp3","charTypeName":"word"},{"id":69089,"position":9,"arabic":"ءَاتَيْنَـٰكُم","translation":"তোমাদেরকে আমরা দিয়েছি","audioUrl":"wbw/002_093_009.mp3","charTypeName":"word"},{"id":69090,"position":10,"arabic":"بِقُوَّةٍۢ","translation":"শক্তভাবে","audioUrl":"wbw/002_093_010.mp3","charTypeName":"word"},{"id":69091,"position":11,"arabic":"وَٱسْمَعُوا۟ ۖ","translation":"ও তোমরা শুনো''","audioUrl":"wbw/002_093_011.mp3","charTypeName":"word"},{"id":69093,"position":12,"arabic":"قَالُوا۟","translation":"তারা বলেছিল","audioUrl":"wbw/002_093_013.mp3","charTypeName":"word"},{"id":69094,"position":13,"arabic":"سَمِعْنَا","translation":"''আমরা শুনলাম","audioUrl":"wbw/002_093_014.mp3","charTypeName":"word"},{"id":69095,"position":14,"arabic":"وَعَصَيْنَا","translation":"কিন্তু আমরা অমান্য করলাম''","audioUrl":"wbw/002_093_015.mp3","charTypeName":"word"},{"id":69096,"position":15,"arabic":"وَأُشْرِبُوا۟","translation":"এবং সিঞ্চিত হয়েছিল","audioUrl":"wbw/002_093_016.mp3","charTypeName":"word"},{"id":69097,"position":16,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/002_093_017.mp3","charTypeName":"word"},{"id":69098,"position":17,"arabic":"قُلُوبِهِمُ","translation":"তাদের অন্তরগুলোর","audioUrl":"wbw/002_093_018.mp3","charTypeName":"word"},{"id":69099,"position":18,"arabic":"ٱلْعِجْلَ","translation":"গোবাছুর (পূজা)","audioUrl":"wbw/002_093_019.mp3","charTypeName":"word"},{"id":69100,"position":19,"arabic":"بِكُفْرِهِمْ ۚ","translation":"অবিশ্বাসের কারণে তাদের","audioUrl":"wbw/002_093_020.mp3","charTypeName":"word"},{"id":69102,"position":20,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/002_093_022.mp3","charTypeName":"word"},{"id":69103,"position":21,"arabic":"بِئْسَمَا","translation":"''কতই না নিকৃষ্ট","audioUrl":"wbw/002_093_023.mp3","charTypeName":"word"},{"id":69104,"position":22,"arabic":"يَأْمُرُكُم","translation":"তোমাদের নির্দেশ দেয়","audioUrl":"wbw/002_093_024.mp3","charTypeName":"word"},{"id":69105,"position":23,"arabic":"بِهِۦٓ","translation":"যার প্রতি","audioUrl":"wbw/002_093_025.mp3","charTypeName":"word"},{"id":69106,"position":24,"arabic":"إِيمَـٰنُكُمْ","translation":"তোমাদের ঈমান","audioUrl":"wbw/002_093_026.mp3","charTypeName":"word"},{"id":69107,"position":25,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/002_093_027.mp3","charTypeName":"word"},{"id":69108,"position":26,"arabic":"كُنتُم","translation":"তোমরা হয়ে থাক","audioUrl":"wbw/002_093_028.mp3","charTypeName":"word"},{"id":69109,"position":27,"arabic":"مُّؤْمِنِينَ","translation":"মুমিন''","audioUrl":"wbw/002_093_029.mp3","charTypeName":"word"},{"id":69110,"position":28,"arabic":"٩٣","translation":"(৯৩)","audioUrl":null,"charTypeName":"end"}]}]}