{"id":453,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ صٓ ۚ وَٱلْقُرْءَانِ ذِى ٱلذِّكْرِ","translation":"Sad. CONSIDER this Qur’an, endowed with all that one ought to remember!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3971.mp3","surahId":38,"words":[{"id":903,"position":1,"arabic":"صٓ ۚ","translation":"সাদ","audioUrl":"wbw/038_001_001.mp3","charTypeName":"word"},{"id":905,"position":2,"arabic":"وَٱلْقُرْءَانِ","translation":"কোরআনের শপথ","audioUrl":"wbw/038_001_003.mp3","charTypeName":"word"},{"id":906,"position":3,"arabic":"ذِى","translation":"পূর্ণ","audioUrl":"wbw/038_001_004.mp3","charTypeName":"word"},{"id":907,"position":4,"arabic":"ٱلذِّكْرِ","translation":"উপদেশ","audioUrl":"wbw/038_001_005.mp3","charTypeName":"word"},{"id":908,"position":5,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"بَلِ ٱلَّذِينَ كَفَرُوا۟ فِى عِزَّةٍۢ وَشِقَاقٍۢ","translation":"But nay - they who are bent on denying the truth are lost in [false] pride, and [hence] deeply in the wrong.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3972.mp3","surahId":38,"words":[{"id":2013,"position":1,"arabic":"بَلِ","translation":"কিন্তু","audioUrl":"wbw/038_002_001.mp3","charTypeName":"word"},{"id":2014,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/038_002_002.mp3","charTypeName":"word"},{"id":2015,"position":3,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/038_002_003.mp3","charTypeName":"word"},{"id":2016,"position":4,"arabic":"فِى","translation":"মধ্যে (লিপ্ত)","audioUrl":"wbw/038_002_004.mp3","charTypeName":"word"},{"id":2017,"position":5,"arabic":"عِزَّةٍۢ","translation":"ঔদ্ধত্যের","audioUrl":"wbw/038_002_005.mp3","charTypeName":"word"},{"id":2018,"position":6,"arabic":"وَشِقَاقٍۢ","translation":"ও বিরোধীতার","audioUrl":"wbw/038_002_006.mp3","charTypeName":"word"},{"id":2019,"position":7,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"كَمْ أَهْلَكْنَا مِن قَبْلِهِم مِّن قَرْنٍۢ فَنَادَوا۟ وَّلَاتَ حِينَ مَنَاصٍۢ","translation":"How many a generation have We destroyed before their time [for this very sin]! And [how] they called [unto Us] when it was too late to escape!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3973.mp3","surahId":38,"words":[{"id":3201,"position":1,"arabic":"كَمْ","translation":"কত (জাতিকেই)","audioUrl":"wbw/038_003_001.mp3","charTypeName":"word"},{"id":3202,"position":2,"arabic":"أَهْلَكْنَا","translation":"আমরা ধ্বংস করেছি","audioUrl":"wbw/038_003_002.mp3","charTypeName":"word"},{"id":3203,"position":3,"arabic":"مِن","translation":"পূর্বে","audioUrl":"wbw/038_003_003.mp3","charTypeName":"word"},{"id":3204,"position":4,"arabic":"قَبْلِهِم","translation":"তাদের","audioUrl":"wbw/038_003_004.mp3","charTypeName":"word"},{"id":3205,"position":5,"arabic":"مِّن","translation":"মধ্যে হতে","audioUrl":"wbw/038_003_005.mp3","charTypeName":"word"},{"id":3206,"position":6,"arabic":"قَرْنٍۢ","translation":"জাতিসমূহের","audioUrl":"wbw/038_003_006.mp3","charTypeName":"word"},{"id":3207,"position":7,"arabic":"فَنَادَوا۟","translation":"তারা তখন চিৎকার করেছে","audioUrl":"wbw/038_003_007.mp3","charTypeName":"word"},{"id":3208,"position":8,"arabic":"وَّلَاتَ","translation":"কিন্তু আর ছিলো না","audioUrl":"wbw/038_003_008.mp3","charTypeName":"word"},{"id":3209,"position":9,"arabic":"حِينَ","translation":"সময়","audioUrl":"wbw/038_003_009.mp3","charTypeName":"word"},{"id":3210,"position":10,"arabic":"مَنَاصٍۢ","translation":"মুক্তি লাভের","audioUrl":"wbw/038_003_010.mp3","charTypeName":"word"},{"id":3211,"position":11,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"وَعَجِبُوٓا۟ أَن جَآءَهُم مُّنذِرٌۭ مِّنْهُمْ ۖ وَقَالَ ٱلْكَٰفِرُونَ هَٰذَا سَٰحِرٌۭ كَذَّابٌ","translation":"Now these [people] deem it strange that a warner should have come unto them from their own midst - and [so] the deniers of the truth are saying: “A [mere] spellbinder is he, a liar!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3974.mp3","surahId":38,"words":[{"id":4543,"position":1,"arabic":"وَعَجِبُوٓا۟","translation":"এবং অবাক হয়েছে তারা","audioUrl":"wbw/038_004_001.mp3","charTypeName":"word"},{"id":4544,"position":2,"arabic":"أَن","translation":"যে","audioUrl":"wbw/038_004_002.mp3","charTypeName":"word"},{"id":4545,"position":3,"arabic":"جَآءَهُم","translation":"তাদের কাছে এসেছে","audioUrl":"wbw/038_004_003.mp3","charTypeName":"word"},{"id":4546,"position":4,"arabic":"مُّنذِرٌۭ","translation":"একজন সতর্ককারী","audioUrl":"wbw/038_004_004.mp3","charTypeName":"word"},{"id":4547,"position":5,"arabic":"مِّنْهُمْ ۖ","translation":"তাদেরই মধ্য হ'তে","audioUrl":"wbw/038_004_005.mp3","charTypeName":"word"},{"id":4549,"position":6,"arabic":"وَقَالَ","translation":"এবং বললো","audioUrl":"wbw/038_004_007.mp3","charTypeName":"word"},{"id":4550,"position":7,"arabic":"ٱلْكَـٰفِرُونَ","translation":"কাফিররা","audioUrl":"wbw/038_004_008.mp3","charTypeName":"word"},{"id":4551,"position":8,"arabic":"هَـٰذَا","translation":"\"এই (ব্যক্তি)","audioUrl":"wbw/038_004_009.mp3","charTypeName":"word"},{"id":4552,"position":9,"arabic":"سَـٰحِرٌۭ","translation":"যাদুকর","audioUrl":"wbw/038_004_010.mp3","charTypeName":"word"},{"id":4553,"position":10,"arabic":"كَذَّابٌ","translation":"বড় মিথ্যাবাদী","audioUrl":"wbw/038_004_011.mp3","charTypeName":"word"},{"id":4554,"position":11,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"أَجَعَلَ ٱلْءَالِهَةَ إِلَٰهًۭا وَٰحِدًا ۖ إِنَّ هَٰذَا لَشَىْءٌ عُجَابٌۭ","translation":"Does he claim that all the deities are [but] one God? Verily, a most strange thing is this!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3975.mp3","surahId":38,"words":[{"id":5821,"position":1,"arabic":"أَجَعَلَ","translation":"সাব্যস্ত করেছে কি সে","audioUrl":"wbw/038_005_001.mp3","charTypeName":"word"},{"id":5822,"position":2,"arabic":"ٱلْـَٔالِهَةَ","translation":"সব উপাস্যকে","audioUrl":"wbw/038_005_002.mp3","charTypeName":"word"},{"id":5823,"position":3,"arabic":"إِلَـٰهًۭا","translation":"ইলাহ","audioUrl":"wbw/038_005_003.mp3","charTypeName":"word"},{"id":5824,"position":4,"arabic":"وَٰحِدًا ۖ","translation":"একই","audioUrl":"wbw/038_005_004.mp3","charTypeName":"word"},{"id":5826,"position":5,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/038_005_006.mp3","charTypeName":"word"},{"id":5827,"position":6,"arabic":"هَـٰذَا","translation":"এটা","audioUrl":"wbw/038_005_007.mp3","charTypeName":"word"},{"id":5828,"position":7,"arabic":"لَشَىْءٌ","translation":"অবশ্যই ব্যাপার","audioUrl":"wbw/038_005_008.mp3","charTypeName":"word"},{"id":5829,"position":8,"arabic":"عُجَابٌۭ","translation":"আজব\"","audioUrl":"wbw/038_005_009.mp3","charTypeName":"word"},{"id":5830,"position":9,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"وَٱنطَلَقَ ٱلْمَلَأُ مِنْهُمْ أَنِ ٱمْشُوا۟ وَٱصْبِرُوا۟ عَلَىٰٓ ءَالِهَتِكُمْ ۖ إِنَّ هَٰذَا لَشَىْءٌۭ يُرَادُ","translation":"And their leaders launch forth [thus]: “Go ahead, and hold steadfastly onto your deities: this, behold, is the only thing to do!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3976.mp3","surahId":38,"words":[{"id":7103,"position":1,"arabic":"وَٱنطَلَقَ","translation":"এবং সরে পড়লো","audioUrl":"wbw/038_006_001.mp3","charTypeName":"word"},{"id":7104,"position":2,"arabic":"ٱلْمَلَأُ","translation":"প্রধানেরা","audioUrl":"wbw/038_006_002.mp3","charTypeName":"word"},{"id":7105,"position":3,"arabic":"مِنْهُمْ","translation":"তাদের মধ্যকার","audioUrl":"wbw/038_006_003.mp3","charTypeName":"word"},{"id":7106,"position":4,"arabic":"أَنِ","translation":"(এই বলে) যে,","audioUrl":"wbw/038_006_004.mp3","charTypeName":"word"},{"id":7107,"position":5,"arabic":"ٱمْشُوا۟","translation":"\"তোমরা চলে যাও","audioUrl":"wbw/038_006_005.mp3","charTypeName":"word"},{"id":7108,