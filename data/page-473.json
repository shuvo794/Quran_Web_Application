{"id":473,"ayahs":[{"number":50,"arabic":"قَالُوٓا۟ أَوَلَمْ تَكُ تَأْتِيكُمْ رُسُلُكُم بِٱلْبَيِّنَٰتِ ۖ قَالُوا۟ بَلَىٰ ۚ قَالُوا۟ فَٱدْعُوا۟ ۗ وَمَا دُعَٰٓؤُا۟ ٱلْكَٰفِرِينَ إِلَّا فِى ضَلَٰلٍ","translation":"[But the keepers of hell] will ask, “Is it not [true] that your apostles came unto you with all evidence of the truth?” Those [in the fire] will reply, “Yea, indeed.” [And the keepers of hell] will say, “Pray, then!” - for the prayer of those who deny the truth cannot lead to aught but delusion.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4183.mp3","surahId":40,"words":[{"id":48963,"position":1,"arabic":"قَالُوٓا۟","translation":"তারা বলবে","audioUrl":"wbw/040_050_001.mp3","charTypeName":"word"},{"id":48964,"position":2,"arabic":"أَوَلَمْ","translation":"\"নি কি","audioUrl":"wbw/040_050_002.mp3","charTypeName":"word"},{"id":48965,"position":3,"arabic":"تَكُ","translation":"\"","audioUrl":"wbw/040_050_003.mp3","charTypeName":"word"},{"id":48966,"position":4,"arabic":"تَأْتِيكُمْ","translation":"তোমাদের কাছে আসে","audioUrl":"wbw/040_050_004.mp3","charTypeName":"word"},{"id":48967,"position":5,"arabic":"رُسُلُكُم","translation":"তোমাদের রাসূলগণ","audioUrl":"wbw/040_050_005.mp3","charTypeName":"word"},{"id":48968,"position":6,"arabic":"بِٱلْبَيِّنَـٰتِ ۖ","translation":"সুস্পষ্ট প্রমাণসহ\"","audioUrl":"wbw/040_050_006.mp3","charTypeName":"word"},{"id":48970,"position":7,"arabic":"قَالُوا۟","translation":"(দোযখীরা) বলবে","audioUrl":"wbw/040_050_008.mp3","charTypeName":"word"},{"id":48971,"position":8,"arabic":"بَلَىٰ ۚ","translation":"\"হ্যাঁ\"","audioUrl":"wbw/040_050_009.mp3","charTypeName":"word"},{"id":48973,"position":9,"arabic":"قَالُوا۟","translation":"(প্রহরীরা) বলবে","audioUrl":"wbw/040_050_011.mp3","charTypeName":"word"},{"id":48974,"position":10,"arabic":"فَٱدْعُوا۟ ۗ","translation":"\"তোমরাই প্রার্থনা করো তাহ'লে","audioUrl":"wbw/040_050_012.mp3","charTypeName":"word"},{"id":48976,"position":11,"arabic":"وَمَا","translation":"এবং নয়","audioUrl":"wbw/040_050_014.mp3","charTypeName":"word"},{"id":48977,"position":12,"arabic":"دُعَـٰٓؤُا۟","translation":"প্রার্থনা","audioUrl":"wbw/040_050_015.mp3","charTypeName":"word"},{"id":48978,"position":13,"arabic":"ٱلْكَـٰفِرِينَ","translation":"কাফেরদের","audioUrl":"wbw/040_050_016.mp3","charTypeName":"word"},{"id":48979,"position":14,"arabic":"إِلَّا","translation":"এ ব্যতীত","audioUrl":"wbw/040_050_017.mp3","charTypeName":"word"},{"id":48980,"position":15,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/040_050_018.mp3","charTypeName":"word"},{"id":48981,"position":16,"arabic":"ضَلَـٰلٍ","translation":"ব্যর্থতার\"","audioUrl":"wbw/040_050_019.mp3","charTypeName":"word"},{"id":48982,"position":17,"arabic":"٥٠","translation":"(৫০)","audioUrl":null,"charTypeName":"end"}]},{"number":51,"arabic":"إِنَّا لَنَنصُرُ رُسُلَنَا وَٱلَّذِينَ ءَامَنُوا۟ فِى ٱلْحَيَوٰةِ ٱلدُّنْيَا وَيَوْمَ يَقُومُ ٱلْأَشْهَٰدُ","translation":"BEHOLD, We shall indeed succour Our apostles and those who have attained to faith, [both] in this world’s life and on the Day when all the witnesses shall stand up","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4184.mp3","surahId":40,"words":[{"id":49576,"position":1,"arabic":"إِنَّا","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/040_051_001.mp3","charTypeName":"word"},{"id":49577,"position":2,"arabic":"لَنَنصُرُ","translation":"অবশ্যই সাহায্য করবো","audioUrl":"wbw/040_051_002.mp3","charTypeName":"word"},{"id":49578,"position":3,"arabic":"رُسُلَنَا","translation":"আমাদের রাসূলগণকে","audioUrl":"wbw/040_051_003.mp3","charTypeName":"word"},{"id":49579,"position":4,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/040_051_004.mp3","charTypeName":"word"},{"id":49580,"position":5,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে (তাদেরকে)","audioUrl":"wbw/040_051_005.mp3","charTypeName":"word"},{"id":49581,"position":6,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/040_051_006.mp3","charTypeName":"word"},{"id":49582,"position":7,"arabic":"ٱلْحَيَوٰةِ","translation":"জীবনের","audioUrl":"wbw/040_051_007.mp3","charTypeName":"word"},{"id":49583,"position":8,"arabic":"ٱلدُّنْيَا","translation":"পার্থিব","audioUrl":"wbw/040_051_008.mp3","charTypeName":"word"},{"id":49584,"position":9,"arabic":"وَيَوْمَ","translation":"এবং যেদিনে","audioUrl":"wbw/040_051_009.mp3","charTypeName":"word"},{"id":49585,"position":10,"arabic":"يَقُومُ","translation":"দাঁড়াবে","audioUrl":"wbw/040_051_010.mp3","charTypeName":"word"},{"id":49586,"position":11,"arabic":"ٱلْأَشْهَـٰدُ","translation":"সাক্ষীরা","audioUrl":"wbw/040_051_011.mp3","charTypeName":"word"},{"id":49587,"position":12,"arabic":"٥١","translation":"(৫১)","audioUrl":null,"charTypeName":"end"}]},{"number":52,"arabic":"يَوْمَ لَا يَنفَعُ ٱلظَّٰلِمِينَ مَعْذِرَتُهُمْ ۖ وَلَهُمُ ٱللَّعْنَةُ وَلَهُمْ سُوٓءُ ٱلدَّارِ","translation":"the Day when their excuses will be of no avail to the evildoers, seeing that their lot will be rejection from all that is good, and a woeful hereafter.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4185.mp3","surahId":40,"words":[{"id":49728,"position":1,"arabic":"يَوْمَ","translation":"সেদিন","audioUrl":"wbw/040_052_001.mp3","charTypeName":"word"},{"id":49729,"position":2,"arabic":"لَا","translation":"না","audioUrl":"wbw/040_052_002.mp3","charTypeName":"word"},{"id":49730,"position":3,"arabic":"يَنفَعُ","translation":"উপকার দিবে","audioUrl":"wbw/040_052_003.mp3","charTypeName":"word"},{"id":49731,"position":4,"arabic":"ٱلظَّـٰلِمِينَ","translation":"সীমালঙ্ঘনকারীদের (জন্য)","audioUrl":"wbw/040_052_004.mp3","charTypeName":"word"},{"id":49732,"position":5,"arabic":"مَعْذِرَتُهُمْ ۖ","translation":"অযুহাত তাদের","audioUrl":"wbw/040_052_005.mp3","charTypeName":"word"},{"id":49734,"position":6,"arabic":"وَلَهُمُ","translation":"আর তাদের জন্যে রয়েছে","audioUrl":"wbw/040_052_007.mp3","charTypeName":"word"},{"id":49735,"position":7,"arabic":"ٱللَّعْنَةُ","translation":"অভিশাপ","audioUrl":"wbw/040_052_008.mp3","charTypeName":"word"},{"id":49736,"position":8,"arabic":"وَلَهُمْ","translation":"এবং তাদের জন্যে","audioUrl":"wbw/040_052_009.mp3","charTypeName":"word"},{"id":49737,"position":9,"arabic":"سُوٓءُ","translation":"নিকৃষ্ট","audioUrl":"wbw/040_052_010.mp3","charTypeName":"word"},{"id":49738,"position":10,"arabic":"ٱلدَّارِ","translation":"আবাস (হবে জাহান্নাম)","audioUrl":"wbw/040_052_011.mp3","charTypeName":"word"},{"id":49739,"position":11,"arabic":"٥٢","translation":"(৫২)","audioUrl":null,"charTypeName":"end"}]},{"number":53,"arabic":"وَلَقَدْ ءَاتَيْنَا مُوسَى ٱلْهُدَىٰ وَأَوْرَثْنَا بَنِىٓ إِسْرَٰٓءِيلَ ٱلْكِتَٰبَ","translation":"And, indeed, We bestowed aforetime [Our] guidance on Moses, and [thus] made the children of Israel heirs to the divine writ [revealed to him]","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4186.mp3","surahId":40,"words":[{"id":50861,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/040_053_001.mp3","charTypeName":"word"},{"id":50862,"position":2,"arabic":"ءَاتَيْنَا","translation":"আমরা দিয়েছি","audioUrl":"wbw/040_053_002.mp3","charTypeName":"word"},{"id":50863,"position":3,"arabic":"مُوسَى","translation":"মূসাকে","audioUrl":"wbw/040_053_003.mp3","charTypeName":"word"},{"id":50864,"position":4,"arabic":"ٱلْهُدَىٰ","translation":"পথের দিশা","audioUrl":"wbw/040_053_004.mp3","charTypeName":"word"},{"id":50865,"position":5,"arabic":"وَأَوْرَثْنَا","translation":"ও আমরা উত্তরাধিকারী করেছিলাম","audioUrl":"wbw/040_053_005.mp3","charTypeName":"word"},{"id":50866,"position":6,"arabic":"بَنِىٓ","translation":"সন্তানদেরকে","audioUrl":"wbw/040_053_006.mp3","charTypeName":"word"},{"id":50867,"position":7,"arabic":"إِسْرَٰٓءِيلَ","translation":"ইসরাঈলের","audioUrl":"wbw/040_053_007.mp3","charTypeName":"word"},{"id":50868,"position":8,"arabic":"ٱلْكِتَـٰبَ","translation":"কিতাবের","audioUrl":"wbw/040_053_008.mp3","charTypeName":"word"},{"id":50869,"position":9,"arabic":"٥٣","translation":"(৫৩)","audioUrl":null,"charTypeName":"end"}]},{"number":54,"arabic":"هُدًۭى وَذِكْرَىٰ لِأُو۟لِى ٱلْأَلْبَٰبِ","translation":"as a [means of] guidance and a reminder for those who were endowed with insight:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4187.mp3","surahId":40,"words":[{"id":50974,"position":1,"arabic":"هُدًۭى","translation":"পথ নির্দেশ","audioUrl":"wbw/040_054_001.mp3","charTypeName":"word"},{"id":50975,"position":2,"arabic":"وَذِكْرَىٰ","translation":"ও উপদেশ স্বরূপ","audioUrl":"wbw/040_054_002.mp3","charTypeName":"word"},{"id":50976,"position":3,"arabic":"لِأُو۟لِى","translation":"সম্পন্নদের জন্যে","audioUrl":"wbw/040_054_003.mp3","charTypeName":"word"},{"id":50977,"position":4,"arabic":"ٱلْأَلْبَـٰبِ","translation":"বুদ্ধি-বিবেক","audioUrl":"wbw/040_054_004.mp3","charTypeName":"word"},{"id":50978,"position":5,"arabic":"٥٤","translation":"(৫৪)","audioUrl":null,"charTypeName":"end"}]},{"number":55,"arabic":"فَٱصْبِرْ إِنَّ وَعْدَ ٱللَّهِ حَقٌّۭ وَٱسْتَغْفِرْ لِذَنۢبِكَ وَسَبِّحْ بِحَمْدِ رَبِّكَ بِٱلْعَشِىِّ وَٱلْإِبْكَٰرِ","translation":"hence, remain thou patient in adversity - for, verily, God’s promise always comes true - and ask forgiveness for thy sins, and extol thy Sustainer’s glory and praise by night and by day.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4188.mp3","surahId":40,"words":[{"id":51823,"position":1,"arabic":"فَٱصْبِرْ","translation":"সুতরাং ধৈর্য্য ধরো","audioUrl":"wbw/040_055_001.mp3","charTypeName":"word"},{"id":51824,"position":2,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/040_055_002.mp3","charTypeName":"word"},{"id":51825,"position":3,"arabic":"وَعْدَ","translation":"প্রতিশ্রুতি","audioUrl":"wbw/040_055_003.mp3","charTypeName":"word"},{"id":51826,"position":4,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/040_055_004.mp3","charTypeName":"word"},{"id":51827,"position":5,"arabic":"حَقٌّۭ","translation":"সত্য","audioUrl":"wbw/040_055_005.mp3","charTypeName":"word"},{"id":51828,"position":6,"arabic":"وَٱسْتَغْفِرْ","translation":"এবং ক্ষমা চাও","audioUrl":"wbw/040_055_006.mp3","charTypeName":"word"},{"id":51829,"position":7,"arabic":"لِذَنۢبِكَ","translation":"তোমার পাপের জন্যে","audioUrl":"wbw/040_055_007.mp3","charTypeName":"word"},{"id":51830,"position":8,"arabic":"وَسَبِّحْ","translation":"ও পবিত্রতা ঘোষণা করো","audioUrl":"wbw/040_055_008.mp3","charTypeName":"word"},{"id":51831,"position":9,"arabic":"بِحَمْدِ","translation":"প্রশংসাসহ","audioUrl":"wbw/040_055_009.mp3","charTypeName":"word"},{"id":51832,"position":10,"arabic":"رَبِّكَ","translation":"তোমার রবের","audioUrl":"wbw/040_055_010.mp3","charTypeName":"word"},{"id":51833,"position":11,"arabic":"بِٱلْعَشِىِّ","translation":"সন্ধ্যাসমূহে","audioUrl":"wbw/040_055_011.mp3","charTypeName":"word"},{"id":51834,"position":12,"arabic":"وَٱلْإِبْكَـٰرِ","translation":"ও সকালসমূহে","audioUrl":"wbw/040_055_012.mp3","charTypeName":"word"},{"id":51835,"position":13,"arabic":"٥٥","translation":"(৫৫)","audioUrl":null,"charTypeName":"end"}]},{"number":56,"arabic":"إِنَّ ٱلَّذِينَ يُجَٰدِلُونَ فِىٓ ءَايَٰتِ ٱللَّهِ بِغَيْرِ سُلْطَٰنٍ أَتَىٰهُمْ ۙ إِن فِى صُدُورِهِمْ إِلَّا كِبْرٌۭ مَّا هُم بِبَٰلِغِيهِ ۚ فَٱسْتَعِذْ بِٱللَّهِ ۖ إِنَّهُۥ هُوَ ٱلسَّمِيعُ ٱلْبَصِيرُ","translation":"Behold, as for those who call God’s messages in question without having any evidence therefore in their hearts is nothing but overweening self-con­ceit, which they will never be able to satisfy: seek thou, then, refuge with God - for, verily, He alone is all-hearing, all-seeing!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4189.mp3","surahId":40,"words":[{"id":52081,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/040_056_001.mp3","charTypeName":"word"},{"id":52082,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/040_056_002.mp3","charTypeName":"word"},{"id":52083,"position":3,"arabic":"يُجَـٰدِلُونَ","translation":"তর্ক করে","audioUrl":"wbw/040_056_003.mp3","charTypeName":"word"},{"id":52084,"position":4,"arabic":"فِىٓ","translation":"আছে","audioUrl":"wbw/040_056_004.mp3","charTypeName":"word"},{"id":52085,"position":5,"arabic":"ءَايَـٰتِ","translation":"আয়াতসমূহে","audioUrl":"wbw/040_056_005.mp3","charTypeName":"word"},{"id":52086,"position":6,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/040_056_006.mp3","charTypeName":"word"},{"id":52087,"position":7,"arabic":"بِغَيْرِ","translation":"ব্যতীত","audioUrl":"wbw/040_056_007.mp3","charTypeName":"word"},{"id":52088,"position":8,"arabic":"سُلْطَـٰنٍ","translation":"কোনো প্রমাণ","audioUrl":"wbw/040_056_008.mp3","charTypeName":"word"},{"id":52089,"position":9,"arabic":"أَتَىٰهُمْ ۙ","translation":"তাদের কাছে (যা) এসেছে","audioUrl":"wbw/040_056_009.mp3","charTypeName":"word"},{"id":52091,"position":10,"arabic":"إِن","translation":"নেই","audioUrl":"wbw/040_056_011.mp3","charTypeName":"word"},{"id":52092,"position":11,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/040_056_012.mp3","charTypeName":"word"},{"id":52093,"position":12,"arabic":"صُدُورِهِمْ","translation":"তাদের অন্তরসমূহের","audioUrl":"wbw/040_056_013.mp3","charTypeName":"word"},{"id":52094,"position":13,"arabic":"إِلَّا","translation":"এ ব্যতীত","audioUrl":"wbw/040_056_014.mp3","charTypeName":"word"},{"id":52095,"position":14,"arabic":"كِبْرٌۭ","translation":"(বড়ত্বের) অহংকার","audioUrl":"wbw/040_056_015.mp3","charTypeName":"word"},{"id":52096,"position":15,"arabic":"مَّا","translation":"(যাতে) না","audioUrl":"wbw/040_056_016.mp3","charTypeName":"word"},{"id":52097,"position":16,"arabic":"هُم","translation":"তারা","audioUrl":"wbw/040_056_017.mp3","charTypeName":"word"},{"id":52098,"position":17,"arabic":"بِبَـٰلِغِيهِ ۚ","translation":"পৌঁছিবে","audioUrl":"wbw/040_056_018.mp3","charTypeName":"word"},{"id":52100,"position":18,"arabic":"فَٱسْتَعِذْ","translation":"সুতরাং আশ্রয় চাও","audioUrl":"wbw/040_056_020.mp3","charTypeName":"word"},{"id":52101,"position":19,"arabic":"بِٱللَّهِ ۖ","translation":"আল্লাহর (কাছে)","audioUrl":"wbw/040_056_021.mp3","charTypeName":"word"},{"id":52103,"position":20,"arabic":"إِنَّهُۥ","translation":"নিশ্চয়ই তিনি","audioUrl":"wbw/040_056_023.mp3","charTypeName":"word"},{"id":52104,"position":21,"arabic":"هُوَ","translation":"তিনিই","audioUrl":"wbw/040_056_024.mp3","charTypeName":"word"},{"id":52105,"position":22,"arabic":"ٱلسَّمِيعُ","translation":"সবকিছু শুনেন","audioUrl":"wbw/040_056_025.mp3","charTypeName":"word"},{"id":52106,"position":23,"arabic":"ٱلْبَصِيرُ","translation":"সবকিছু দেখেন","audioUrl":"wbw/040_056_026.mp3","charTypeName":"word"},{"id":52107,"position":24,"arabic":"٥٦","translation":"(৫৬)","audioUrl":null,"charTypeName":"end"}]},{"number":57,"arabic":"لَخَلْقُ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ أَكْبَرُ مِنْ خَلْقِ ٱلنَّاسِ وَلَٰكِنَّ أَكْثَرَ ٱلنَّاسِ لَا يَعْلَمُونَ","translation":"Greater indeed than the creation of man is the creation of the heavens and the earth: yet most men do not understand [what this implies].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4190.mp3","surahId":40,"words":[{"id":52566,"position":1,"arabic":"لَخَلْقُ","translation":"অবশ্যই সৃষ্টি","audioUrl":"wbw/040_057_001.mp3","charTypeName":"word"},{"id":52567,"position":2,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশের","audioUrl":"wbw/040_057_002.mp3","charTypeName":"word"},{"id":52568,"position":3,"arabic":"وَٱلْأَرْضِ","translation":"ও পৃথিবীর","audioUrl":"wbw/040_057_003.mp3","charTypeName":"word"},{"id":52569,"position":4,"arabic":"أَكْبَرُ","translation":"অনেক কঠিন","audioUrl":"wbw/040_057_004.mp3","charTypeName":"word"},{"id":52570,"position":5,"arabic":"مِنْ","translation":"চেয়েও","audioUrl":"wbw/040_057_005.mp3","charTypeName":"word"},{"id":52571,"position":6,"arabic":"خَلْقِ","translation":"সৃষ্টি","audioUrl":"wbw/040_057_006.mp3","charTypeName":"word"},{"id":52572,"position":7,"arabic":"ٱلنَّاسِ","translation":"মানুষের","audioUrl":"wbw/040_057_007.mp3","charTypeName":"word"},{"id":52573,"position":8,"arabic":"وَلَـٰكِنَّ","translation":"কিন্তু","audioUrl":"wbw/040_057_008.mp3","charTypeName":"word"},{"id":52574,"position":9,"arabic":"أَكْثَرَ","translation":"অধিকাংশ","audioUrl":"wbw/040_057_009.mp3","charTypeName":"word"},{"id":52575,"position":10,"arabic":"ٱلنَّاسِ","translation":"মানুষই","audioUrl":"wbw/040_057_010.mp3","charTypeName":"word"},{"id":52576,"position":11,"arabic":"لَا","translation":"না","audioUrl":"wbw/040_057_011.mp3","charTypeName":"word"},{"id":52577,"position":12,"arabic":"يَعْلَمُونَ","translation":"তারা জানে","audioUrl":"wbw/040_057_012.mp3","charTypeName":"word"},{"id":52578,"position":13,"arabic":"٥٧","translation":"(৫৭)","audioUrl":null,"charTypeName":"end"}]},{"number":58,"arabic":"وَمَا يَسْتَوِى ٱلْأَعْمَىٰ وَٱلْبَصِيرُ وَٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ وَلَا ٱلْمُسِىٓءُ ۚ قَلِيلًۭا مَّا تَتَذَكَّرُونَ","translation":"But [then,] the blind and the seeing are not equal; and neither [can] they who have attained to faith and do good works and the doers of evil [be deemed equal]. How seldom do you keep this in mind!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4191.mp3","surahId":40,"words":[{"id":53292,"position":1,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/040_058_001.mp3","charTypeName":"word"},{"id":53293,"position":2,"arabic":"يَسْتَوِى","translation":"সমান হয়","audioUrl":"wbw/040_058_002.mp3","charTypeName":"word"},{"id":53294,"position":3,"arabic":"ٱلْأَعْمَىٰ","translation":"অন্ধ","audioUrl":"wbw/040_058_003.mp3","charTypeName":"word"},{"id":53295,"position":4,"arabic":"وَٱلْبَصِيرُ","translation":"আর চক্ষুষ্মান","audioUrl":"wbw/040_058_004.mp3","charTypeName":"word"},{"id":53296,"position":5,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/040_058_005.mp3","charTypeName":"word"},{"id":53297,"position":6,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/040_058_006.mp3","charTypeName":"word"},{"id":53298,"position":7,"arabic":"وَعَمِلُوا۟","translation":"ও কাজ করেছে","audioUrl":"wbw/040_058_007.mp3","charTypeName":"word"},{"id":53299,"position":8,"arabic":"ٱلصَّـٰلِحَـٰتِ","translation":"সৎ (তারা)","audioUrl":"wbw/040_058_008.mp3","charTypeName":"word"},{"id":53300,"position":9,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/040_058_009.mp3","charTypeName":"word"},{"id":53301,"position":10,"arabic":"ٱلْمُسِىٓءُ ۚ","translation":"দুষ্কৃতিকারীরা (সমান হয়)","audioUrl":"wbw/040_058_010.mp3","charTypeName":"word"},{"id":53303,"position":11,"arabic":"قَلِيلًۭا","translation":"(খুব) কমই","audioUrl":"wbw/040_058_012.mp3","charTypeName":"word"},{"id":53304,"position":12,"arabic":"مَّا","translation":"যা","audioUrl":"wbw/040_058_013.mp3","charTypeName":"word"},{"id":53305,"position":13,"arabic":"تَتَذَكَّرُونَ","translation":"তোমরা উপদেশ গ্রহণ করো","audioUrl":"wbw/040_058_014.mp3","charTypeName":"word"},{"id":53306,"position":14,"arabic":"٥٨","translation":"(৫৮)","audioUrl":null,"charTypeName":"end"}]}]}