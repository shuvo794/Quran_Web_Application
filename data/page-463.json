{"id":463,"ayahs":[{"number":41,"arabic":"إِنَّآ أَنزَلْنَا عَلَيْكَ ٱلْكِتَٰبَ لِلنَّاسِ بِٱلْحَقِّ ۖ فَمَنِ ٱهْتَدَىٰ فَلِنَفْسِهِۦ ۖ وَمَن ضَلَّ فَإِنَّمَا يَضِلُّ عَلَيْهَا ۖ وَمَآ أَنتَ عَلَيْهِم بِوَكِيلٍ","translation":"BEHOLD, from on high have We bestowed upon thee this divine writ, setting forth the truth for [the benefit of all] mankind. And whoever chooses to be guided [thereby], does so for his own good, and whoever chooses to go astray, goes but astray to his own hurt; and thou hast not the power to determine their fate.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4099.mp3","surahId":39,"words":[{"id":41915,"position":1,"arabic":"إِنَّآ","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/039_041_001.mp3","charTypeName":"word"},{"id":41916,"position":2,"arabic":"أَنزَلْنَا","translation":"আমরা অবতীর্ণ করেছি","audioUrl":"wbw/039_041_002.mp3","charTypeName":"word"},{"id":41917,"position":3,"arabic":"عَلَيْكَ","translation":"তোমার উপর","audioUrl":"wbw/039_041_003.mp3","charTypeName":"word"},{"id":41918,"position":4,"arabic":"ٱلْكِتَـٰبَ","translation":"(এই) কিতাব","audioUrl":"wbw/039_041_004.mp3","charTypeName":"word"},{"id":41919,"position":5,"arabic":"لِلنَّاسِ","translation":"মানুষের জন্যে","audioUrl":"wbw/039_041_005.mp3","charTypeName":"word"},{"id":41920,"position":6,"arabic":"بِٱلْحَقِّ ۖ","translation":"সত্যসহ","audioUrl":"wbw/039_041_006.mp3","charTypeName":"word"},{"id":41922,"position":7,"arabic":"فَمَنِ","translation":"অতঃপর যে","audioUrl":"wbw/039_041_008.mp3","charTypeName":"word"},{"id":41923,"position":8,"arabic":"ٱهْتَدَىٰ","translation":"সৎপথ গ্রহন করে","audioUrl":"wbw/039_041_009.mp3","charTypeName":"word"},{"id":41924,"position":9,"arabic":"فَلِنَفْسِهِۦ ۖ","translation":"তা তার নিজের জন্যে","audioUrl":"wbw/039_041_010.mp3","charTypeName":"word"},{"id":41926,"position":10,"arabic":"وَمَن","translation":"এবং যে","audioUrl":"wbw/039_041_012.mp3","charTypeName":"word"},{"id":41927,"position":11,"arabic":"ضَلَّ","translati