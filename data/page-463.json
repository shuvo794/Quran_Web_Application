َتَوَفَّى","translation":"হরণ করেন","audioUrl":"wbw/039_042_002.mp3","charTypeName":"word"},{"id":42658,"position":3,"arabic":"ٱلْأَنفُسَ","translation":"প্রাণসমূহকে (রূহগুলোকে)","audioUrl":"wbw/039_042_003.mp3","charTypeName":"word"},{"id":42659,"position":4,"arabic":"حِينَ","translation":"সময়","audioUrl":"wbw/039_042_004.mp3","charTypeName":"word"},{"id":42660,"position":5,"arabic":"مَوْتِهَا","translation":"তার মৃত্যুর","audioUrl":"wbw/039_042_005.mp3","charTypeName":"word"},{"id":42661,"position":6,"arabic":"وَٱلَّتِى","translation":"এবং তারও (যে)","audioUrl":"wbw/039_042_006.mp3","charTypeName":"word"},{"id":42662,"position":7,"arabic":"لَمْ","translation":"নাই","audioUrl":"wbw/039_042_007.mp3","charTypeName":"word"},{"id":42663,"position":8,"arabic":"تَمُتْ","translation":"মরে (কিন্তু)","audioUrl":"wbw/039_042_008.mp3","charTypeName":"word"},{"id":42664,"position":9,"arabic":"فِى","translation":"মধ্যে (থাকে)","audioUrl":"wbw/039_042_009.mp3","charTypeName":"word"},{"id":42665,"position":10,"arabic":"مَنَامِهَا ۖ","translation":"তার ঘুমের","audioUrl":"wbw/039_042_010.mp3","charTypeName":"word"},{"id":42667,"position":11,"arabic":"فَيُمْسِكُ","translation":"অতঃপর প্রাণকে ধরে রাখেন","audioUrl":"wbw/039_042_012.mp3","charTypeName":"word"},{"id":42668,"position":12,"arabic":"ٱلَّتِى","translation":"যার","audioUrl":"wbw/039_042_013.mp3","charTypeName":"word"},{"id":42669,"position":13,"arabic":"قَضَىٰ","translation":"অবধারিত হয়েছে","audioUrl":"wbw/039_042_014.mp3","charTypeName":"word"},{"id":42670,"position":14,"arabic":"عَلَيْهَا","translation":"তাদের উপর","audioUrl":"wbw/039_042_015.mp3","charTypeName":"word"},{"id":42671,"position":15,"arabic":"ٱلْمَوْتَ","translation":"মৃত্যু","audioUrl":"wbw/039_042_016.mp3","charTypeName":"word"},{"id":42672,"position":16,"arabic":"وَيُرْسِلُ","translation":"এবং ফিরিয়ে দেন","audioUrl":"wbw/039_042_017.mp3","charTypeName":"word"},{"id":42673,"position":17,"arabic":"ٱلْأُخْرَىٰٓ","translation":"অন্যদের (রূহগুলোকে)","audioUrl":"wbw/039_042_018.mp3","charTypeName":"word"},{"id":42674,"position":18,"arabic":"إِلَىٰٓ","translation":"পর্যন্ত","audioUrl":"wbw/039_042_019.mp3","charTypeName":"word"},{"id":42675,"position":19,"arabic":"أَجَلٍۢ","translation":"একটি মেয়াদ","audioUrl":"wbw/039_042_020.mp3","charTypeName":"word"},{"id":42676,"position":20,"arabic":"مُّسَمًّى ۚ","translation":"নির্দিষ্ট","audioUrl":"wbw/039_042_021.mp3","charTypeName":"word"},{"id":42678,"position":21,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/039_042_023.mp3","charTypeName":"word"},{"id":42679,"position":22,"arabic":"فِى","translation":"মধ্যে আছে","audioUrl":"wbw/039_042_024.mp3","charTypeName":"word"},{"id":42680,"position":23,"arabic":"ذَٰلِكَ","translation":"এর","audioUrl":"wbw/039_042_025.mp3","charTypeName":"word"},{"id":42681,"position":24,"arabic":"لَـَٔايَـٰتٍۢ","translation":"অবশ্যই নিদর্শনাবলী","audioUrl":"wbw/039_042_026.mp3","charTypeName":"word"},{"id":42682,"position":25,"arabic":"لِّقَوْمٍۢ","translation":"লোকদের জন্যে","audioUrl":"wbw/039_042_027.mp3","charTypeName":"word"},{"id":42683,"position":26,"arabic":"يَتَفَكَّرُونَ","translation":"(যারা) চিন্তা ভাবনা করে","audioUrl":"wbw/039_042_028.mp3","charTypeName":"word"},{"id":42684,"position":27,"arabic":"٤٢","translation":"(৪২)","audioUrl":null,"charTypeName":"end"}]},{"number":43,"arabic":"أَمِ ٱتَّخَذُوا۟ مِن دُونِ ٱللَّهِ شُفَعَآءَ ۚ قُلْ أَوَلَوْ كَانُوا۟ لَا يَمْلِكُونَ شَيْـًۭٔا وَلَا يَعْقِلُونَ","translation":"And yet, they choose [to worship], side by side with God, [imaginary] intercessors!” Say: “Why - even though they have no power over anything, and no understanding?”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4101.mp3","surahId":39,"words":[{"id":43364,"position":1,"arabic":"أَمِ","translation":"কি","audioUrl":"wbw/039_043_001.mp3","charTypeName":"word"},{"id":43365,"position":2,"arabic":"ٱتَّخَذُوا۟","translation":"তারা গ্রহণ করেছে","audioUrl":"wbw/039_043_002.mp3","charTypeName":"word"},{"id":4