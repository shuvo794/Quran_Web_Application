uran/audio/128/ar.alafasy/4105.mp3","surahId":39,"words":[{"id":46340,"position":1,"arabic":"وَلَوْ","translation":"এবং (এমন) যে","audioUrl":"wbw/039_047_001.mp3","charTypeName":"word"},{"id":46341,"position":2,"arabic":"أَنَّ","translation":"যে","audioUrl":"wbw/039_047_002.mp3","charTypeName":"word"},{"id":46342,"position":3,"arabic":"لِلَّذِينَ","translation":"(তাদের) জন্যে যারা","audioUrl":"wbw/039_047_003.mp3","charTypeName":"word"},{"id":46343,"position":4,"arabic":"ظَلَمُوا۟","translation":"সীমালঙ্ঘন করেছে","audioUrl":"wbw/039_047_004.mp3","charTypeName":"word"},{"id":46344,"position":5,"arabic":"مَا","translation":"যা কিছু","audioUrl":"wbw/039_047_005.mp3","charTypeName":"word"},{"id":46345,"position":6,"arabic":"فِى","translation":"মধ্যে আছে","audioUrl":"wbw/039_047_006.mp3","charTypeName":"word"},{"id":46346,"position":7,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/039_047_007.mp3","charTypeName":"word"},{"id":46347,"position":8,"arabic":"جَمِيعًۭا","translation":"সবই (তাদের মালিকানায়)","audioUrl":"wbw/039_047_008.mp3","charTypeName":"word"},{"id":46348,"position":9,"arabic":"وَمِثْلَهُۥ","translation":"এবং তারও সমপরিমাণ","audioUrl":"wbw/039_047_009.mp3","charTypeName":"word"},{"id":46349,"position":10,"arabic":"مَعَهُۥ","translation":"তার সাথে","audioUrl":"wbw/039_047_010.mp3","charTypeName":"word"},{"id":46350,"position":11,"arabic":"لَٱفْتَدَوْا۟","translation":"তারা অবশ্যই মুক্তিপণ দিতে চাইতো","audioUrl":"wbw/039_047_011.mp3","charTypeName":"word"},{"id":46351,"position":12,"arabic":"بِهِۦ","translation":"তা দিয়ে","audioUrl":"wbw/039_047_012.mp3","charTypeName":"word"},{"id":46352,"position":13,"arabic":"مِن","translation":"হ'তে","audioUrl":"wbw/039_047_013.mp3","charTypeName":"word"},{"id":46353,"position":14,"arabic":"سُوٓءِ","translation":"কঠিন","audioUrl":"wbw/039_047_014.mp3","charTypeName":"word"},{"id":46354,"position":15,"arabic":"ٱلْعَذَابِ","translation":"শাস্তি (বাঁচতে)","audioUrl":"wbw/039_047_015.mp3","charTypeName":"word"