oUrl":"wbw/038_069_008.mp3","charTypeName":"word"},{"id":59109,"position":9,"arabic":"يَخْتَصِمُونَ","translation":"তারা বাদানুবাদ করছিলো","audioUrl":"wbw/038_069_009.mp3","charTypeName":"word"},{"id":59110,"position":10,"arabic":"٦٩","translation":"(৬৯)","audioUrl":null,"charTypeName":"end"}]},{"number":70,"arabic":"إِن يُوحَىٰٓ إِلَىَّ إِلَّآ أَنَّمَآ أَنَا۠ نَذِيرٌۭ مُّبِينٌ","translation":"had it not been revealed unto me [by God] - to no other end than that I might convey [unto you] a plain warning.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4040.mp3","surahId":38,"words":[{"id":59810,"position":1,"arabic":"إِن","translation":"না","audioUrl":"wbw/038_070_001.mp3","charTypeName":"word"},{"id":59811,"position":2,"arabic":"يُوحَىٰٓ","translation":"ওহী করা হয়","audioUrl":"wbw/038_070_002.mp3","charTypeName":"word"},{"id":59812,"position":3,"arabic":"إِلَىَّ","translation":"আমার প্রতি","audioUrl":"wbw/038_070_003.mp3","charTypeName":"word"},{"id":59813,"position":4,"arabic":"إِلَّآ","translation":"এ ছাড়া","audioUrl":"wbw/038_070_004.mp3","charTypeName":"word"},{"id":59814,"position":5,"arabic":"أَنَّمَآ","translation":"যে মূলতঃ","audioUrl":"wbw/038_070_005.mp3","charTypeName":"word"},{"id":59815,"position":6,"arabic":"أَنَا۠","translation":"আমি","audioUrl":"wbw/038_070_006.mp3","charTypeName":"word"},{"id":59816,"position":7,"arabic":"نَذِيرٌۭ","translation":"একজন সতর্ককারী (মাত্র)","audioUrl":"wbw/038_070_007.mp3","charTypeName":"word"},{"id":59817,"position":8,"arabic":"مُّبِينٌ","translation":"সুস্পষ্ট\"","audioUrl":"wbw/038_070_008.mp3","charTypeName":"word"},{"id":59818,"position":9,"arabic":"٧٠","translation":"(৭০)","audioUrl":null,"charTypeName":"end"}]},{"number":71,"arabic":"إِذْ قَالَ رَبُّكَ لِلْمَلَٰٓئِكَةِ إِنِّى خَٰلِقٌۢ بَشَرًۭا مِّن طِينٍۢ","translation":"[For,] lo, thy Sustainer said unto the angels: “Behold, I am about to create a human being out of clay;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4