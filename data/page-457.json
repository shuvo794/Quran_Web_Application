{"id":457,"ayahs":[{"number":62,"arabic":"وَقَالُوا۟ مَا لَنَا لَا نَرَىٰ رِجَالًۭا كُنَّا نَعُدُّهُم مِّنَ ٱلْأَشْرَارِ","translation":"And they will add: “How is it that we do not see [here any of the] men whom we were wont to count among the wicked,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4032.mp3","surahId":38,"words":[{"id":55921,"position":1,"arabic":"وَقَالُوا۟","translation":"এবং তারা বলবে","audioUrl":"wbw/038_062_001.mp3","charTypeName":"word"},{"id":55922,"position":2,"arabic":"مَا","translation":"\"কি","audioUrl":"wbw/038_062_002.mp3","charTypeName":"word"},{"id":55923,"position":3,"arabic":"لَنَا","translation":"আমাদের হলো (যে)","audioUrl":"wbw/038_062_003.mp3","charTypeName":"word"},{"id":55924,"position":4,"arabic":"لَا","translation":"না","audioUrl":"wbw/038_062_004.mp3","charTypeName":"word"},{"id":55925,"position":5,"arabic":"نَرَىٰ","translation":"আমরা দেখছি","audioUrl":"wbw/038_062_005.mp3","charTypeName":"word"},{"id":55926,"position":6,"arabic":"رِجَالًۭا","translation":"লোকদেরকে","audioUrl":"wbw/038_062_006.mp3","charTypeName":"word"},{"id":55927,"position":7,"arabic":"كُنَّا","translation":"আমরা ছিলাম","audioUrl":"wbw/038_062_007.mp3","charTypeName":"word"},{"id":55928,"position":8,"arabic":"نَعُدُّهُم","translation":"তাদেরকে গণ্য করতাম","audioUrl":"wbw/038_062_008.mp3","charTypeName":"word"},{"id":55929,"position":9,"arabic":"مِّنَ","translation":"মধ্যে","audioUrl":"wbw/038_062_009.mp3","charTypeName":"word"},{"id":55930,"position":10,"arabic":"ٱلْأَشْرَارِ","translation":"খুব খারাপ (লোকদের)","audioUrl":"wbw/038_062_010.mp3","charTypeName":"word"},{"id":55931,"position":11,"arabic":"٦٢","translation":"(৬২)","audioUrl":null,"charTypeName":"end"}]},{"number":63,"arabic":"أَتَّخَذْنَٰهُمْ سِخْرِيًّا أَمْ زَاغَتْ عَنْهُمُ ٱلْأَبْصَٰرُ","translation":"[and] whom we made the target of our derision? Or is it that [they are here, and] our eyes have missed them?”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4033.mp3","surahId":38,"words":[{"id":56436,"position":1,"arabic":"أَتَّخَذْنَـٰهُمْ","translation":"কি তাদেরকে আমরা বানিয়ে নিয়েছিলাম","audioUrl":"wbw/038_063_001.mp3","charTypeName":"word"},{"id":56437,"position":2,"arabic":"سِخْرِيًّا","translation":"বিদ্রুপের (ব্যক্তি হিসেবে)","audioUrl":"wbw/038_063_002.mp3","charTypeName":"word"},{"id":56438,"position":3,"arabic":"أَمْ","translation":"অথবা","audioUrl":"wbw/038_063_003.mp3","charTypeName":"word"},{"id":56439,"position":4,"arabic":"زَاغَتْ","translation":"ভুল করেছে","audioUrl":"wbw/038_063_004.mp3","charTypeName":"word"},{"id":56440,"position":5,"arabic":"عَنْهُمُ","translation":"তাদের থেকে","audioUrl":"wbw/038_063_005.mp3","charTypeName":"word"},{"id":56441,"position":6,"arabic":"ٱلْأَبْصَـٰرُ","translation":"(আমাদের) দৃষ্টিসমূহ\"","audioUrl":"wbw/038_063_006.mp3","charTypeName":"word"},{"id":56442,"position":7,"arabic":"٦٣","translation":"(৬৩)","audioUrl":null,"charTypeName":"end"}]},{"number":64,"arabic":"إِنَّ ذَٰلِكَ لَحَقٌّۭ تَخَاصُمُ أَهْلِ ٱلنَّارِ","translation":"Such, behold, will in truth be the [confusion and] mutual wrangling of the people of the fire!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4034.mp3","surahId":38,"words":[{"id":56961,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/038_064_001.mp3","charTypeName":"word"},{"id":56962,"position":2,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/038_064_002.mp3","charTypeName":"word"},{"id":56963,"position":3,"arabic":"لَحَقٌّۭ","translation":"সত্য অবশ্যই","audioUrl":"wbw/038_064_003.mp3","charTypeName":"word"},{"id":56964,"position":4,"arabic":"تَخَاصُمُ","translation":"পারস্পারিক বিবাদ","audioUrl":"wbw/038_064_004.mp3","charTypeName":"word"},{"id":56965,"position":5,"arabic":"أَهْلِ","translation":"অধিবাসীদের","audioUrl":"wbw/038_064_005.mp3","charTypeName":"word"},{"id":56966,"position":6,"arabic":"ٱلنَّارِ","translation":"জাহান্নামের","audioUrl":"wbw/038_064_006.mp3","charTypeName":"word"},{"id":56967,"position":7,"arabic":"٦٤","translation":"(৬৪)","audioUrl":null,"charTypeName":"end"}]},{"number":65,"arabic":"قُلْ إِنَّمَآ أَنَا۠ مُنذِرٌۭ ۖ وَمَا مِنْ إِلَٰهٍ إِلَّا ٱللَّهُ ٱلْوَٰحِدُ ٱلْقَهَّارُ","translation":"SAY [O Muhammad]: “I am only a warner; and there is no deity whatever save God, the One, who holds absolute sway over all that exists,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4035.mp3","surahId":38,"words":[{"id":57309,"position":1,"arabic":"قُلْ","translation":"(হে নাবী) তুমি বলো","audioUrl":"wbw/038_065_001.mp3","charTypeName":"word"},{"id":57310,"position":2,"arabic":"إِنَّمَآ","translation":"\"মূলতঃ","audioUrl":"wbw/038_065_002.mp3","charTypeName":"word"},{"id":57311,"position":3,"arabic":"أَنَا۠","translation":"আমি","audioUrl":"wbw/038_065_003.mp3","charTypeName":"word"},{"id":57312,"position":4,"arabic":"مُنذِرٌۭ ۖ","translation":"একজন সতর্ককারী (মাত্র)","audioUrl":"wbw/038_065_004.mp3","charTypeName":"word"},{"id":57314,"position":5,"arabic":"وَمَا","translation":"এবং নেই","audioUrl":"wbw/038_065_006.mp3","charTypeName":"word"},{"id":57315,"position":6,"arabic":"مِنْ","translation":"কোনো","audioUrl":"wbw/038_065_007.mp3","charTypeName":"word"},{"id":57316,"position":7,"arabic":"إِلَـٰهٍ","translation":"ইলাহ","audioUrl":"wbw/038_065_008.mp3","charTypeName":"word"},{"id":57317,"position":8,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/038_065_009.mp3","charTypeName":"word"},{"id":57318,"position":9,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/038_065_010.mp3","charTypeName":"word"},{"id":57319,"position":10,"arabic":"ٱلْوَٰحِدُ","translation":"এক","audioUrl":"wbw/038_065_011.mp3","charTypeName":"word"},{"id":57320,"position":11,"arabic":"ٱلْقَهَّارُ","translation":"মহাপ্রতাপশালী","audioUrl":"wbw/038_065_012.mp3","charTypeName":"word"},{"id":57321,"position":12,"arabic":"٦٥","translation":"(৬৫)","audioUrl":null,"charTypeName":"end"}]},{"number":66,"arabic":"رَبُّ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ وَمَا بَيْنَهُمَا ٱلْعَزِيزُ ٱلْغَفَّٰرُ","translation":"the Sustainer of the heavens and the earth and all that is between them, the Almighty, the All-Forgiving!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4036.mp3","surahId":38,"words":[{"id":57932,"position":1,"arabic":"رَبُّ","translation":"রব","audioUrl":"wbw/038_066_001.mp3","charTypeName":"word"},{"id":57933,"position":2,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশের","audioUrl":"wbw/038_066_002.mp3","charTypeName":"word"},{"id":57934,"position":3,"arabic":"وَٱلْأَرْضِ","translation":"ও পৃথিবীর","audioUrl":"wbw/038_066_003.mp3","charTypeName":"word"},{"id":57935,"position":4,"arabic":"وَمَا","translation":"এবং যা","audioUrl":"wbw/038_066_004.mp3","charTypeName":"word"},{"id":57936,"position":5,"arabic":"بَيْنَهُمَا","translation":"উভয়ের মাঝে (আছে)","audioUrl":"wbw/038_066_005.mp3","charTypeName":"word"},{"id":57937,"position":6,"arabic":"ٱلْعَزِيزُ","translation":"(তিনি) মহাপরাক্রমশালী","audioUrl":"wbw/038_066_006.mp3","charTypeName":"word"},{"id":57938,"position":7,"arabic":"ٱلْغَفَّـٰرُ","translation":"পরম ক্ষমাশীল\"","audioUrl":"wbw/038_066_007.mp3","charTypeName":"word"},{"id":57939,"position":8,"arabic":"٦٦","translation":"(৬৬)","audioUrl":null,"charTypeName":"end"}]},{"number":67,"arabic":"قُلْ هُوَ نَبَؤٌا۟ عَظِيمٌ","translation":"Say: “This is a message tremendous:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4037.mp3","surahId":38,"words":[{"id":58398,"position":1,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/038_067_001.mp3","charTypeName":"word"},{"id":58399,"position":2,"arabic":"هُوَ","translation":"\"তা","audioUrl":"wbw/038_067_002.mp3","charTypeName":"word"},{"id":58400,"position":3,"arabic":"نَبَؤٌا۟","translation":"সংবাদ","audioUrl":"wbw/038_067_003.mp3","charTypeName":"word"},{"id":58401,"position":4,"arabic":"عَظِيمٌ","translation":"মহা","audioUrl":"wbw/038_067_004.mp3","charTypeName":"word"},{"id":58402,"position":5,"arabic":"٦٧","translation":