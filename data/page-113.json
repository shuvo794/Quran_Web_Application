ic":"لَمُسْرِفُونَ","translation":"অবশ্যই সীমাতিক্রমকারী হয়","audioUrl":"wbw/005_032_041.mp3","charTypeName":"word"},{"id":34364,"position":41,"arabic":"٣٢","translation":"(৩২)","audioUrl":null,"charTypeName":"end"}]},{"number":33,"arabic":"إِنَّمَا جَزَٰٓؤُا۟ ٱلَّذِينَ يُحَارِبُونَ ٱللَّهَ وَرَسُولَهُۥ وَيَسْعَوْنَ فِى ٱلْأَرْضِ فَسَادًا أَن يُقَتَّلُوٓا۟ أَوْ يُصَلَّبُوٓا۟ أَوْ تُقَطَّعَ أَيْدِيهِمْ وَأَرْجُلُهُم مِّنْ خِلَٰفٍ أَوْ يُنفَوْا۟ مِنَ ٱلْأَرْضِ ۚ ذَٰلِكَ لَهُمْ خِزْىٌۭ فِى ٱلدُّنْيَا ۖ وَلَهُمْ فِى ٱلْءَاخِرَةِ عَذَابٌ عَظِيمٌ","translation":"It is but a just recompense for those who make war on God and His apostle, and endeavour to spread corruption on earth, that they are being slain in great' numbers, or crucified in great numbers, or have, in l' result of their perverseness, their hands and feet cut off in great numbers, or are being [entirely] banished from [the face of] the earth: such is their ignominy in this world. But in the life to come [yet more] awesome suffering awaits them-","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/702.mp3","surahId":5,"words":[{"id":35983,"position":1,"arabic":"إِنَّمَا","translation":"মূলতঃ","audioUrl":"wbw/005_033_001.mp3","charTypeName":"word"},{"id":35984,"position":2,"arabic":"جَزَٰٓؤُا۟","translation":"প্রতিফল (অর্থাৎ শাস্তি)","audioUrl":"wbw/005_033_002.mp3","charTypeName":"word"},{"id":35985,"position":3,"arabic":"ٱلَّذِينَ","translation":"(তাদের) যারা","audioUrl":"wbw/005_033_003.mp3","charTypeName":"word"},{"id":35986,"position":4,"arabic":"يُحَارِبُونَ","translation":"যুদ্ধ করে","audioUrl":"wbw/005_033_004.mp3","charTypeName":"word"},{"id":35987,"position":5,"arabic":"ٱللَّهَ","translation":"আল্লাহর","audioUrl":"wbw/005_033_005.mp3","charTypeName":"word"},{"id":35988,"position":6,"arabic":"وَرَسُولَهُۥ","translation":"ও রাসূলের তাঁর(বিরুদ্ধে)","audioUrl":"wbw/005_033_006.mp3","charTypeName":"word"},{"id":35989,"position":7,"arabic":"وَيَسْعَوْنَ","translation":"এবং সচেষ্ট হয়","audioUrl":"wbw/005_033_007.mp3","charTypeName":"word"},{"id":35990,"position":8,"arabic":"فِى","translation":"উপর","audioUrl":"wbw/005_033_008.mp3","charTypeName":"word"},{"id":35991,"position":9,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/005_033_009.mp3","charTypeName":"word"},{"id":35992,"position":10,"arabic":"فَسَادًا","translation":"বিপর্যয়(সৃষ্টি করতে)","audioUrl":"wbw/005_033_010.mp3","charTypeName":"word"},{"id":35993,"position":11,"arabic":"أَن","translation":"যে","audioUrl":"wbw/005_033_011.mp3","charTypeName":"word"},{"id":35994,"position":12,"arabic":"يُقَتَّلُوٓا۟","translation":"তাদের হত্যা করা হবে","audioUrl":"wbw/005_033_012.mp3","charTypeName":"word"},{"id":35995,"position":13,"arabic":"أَوْ","translation":"বা","audioUrl":"wbw/005_033_013.mp3","charTypeName":"word"},{"id":35996,"position":14,"arabic":"يُصَلَّبُوٓا۟","translation":"তাদের ক্রুশবিদ্ধ করা হবে","audioUrl":"wbw/005_033_014.mp3","charTypeName":"word"},{"id":35997,"position":15,"arabic":"أَوْ","translation":"বা","audioUrl":"wbw/005_033_015.mp3","charTypeName":"word"},{"id":35998,"position":16,"arabic":"تُقَطَّعَ","translation":"কেটে দেওয়া হবে","audioUrl":"wbw/005_033_016.mp3","charTypeName":"word"},{"id":35999,"position":17,"arabic":"أَيْدِيهِمْ","translation":"হাতগুলো তাদের","audioUrl":"wbw/005_033_017.mp3","charTypeName":"word"},{"id":36000,"position":18,"arabic":"وَأَرْجُلُهُم","translation":"ও পাগুলো তাদের","audioUrl":"wbw/005_033_018.mp3","charTypeName":"word"},{"id":36001,"position":19,"arabic":"مِّنْ","translation":"থেকে","audioUrl":"wbw/005_033_019.mp3","charTypeName":"word"},{"id":36002,"position":20,"arabic":"خِلَـٰفٍ","translation":"বিপরীত দিক","audioUrl":"wbw/005_033_020.mp3","charTypeName":"word"},{"id":36003,"position":21,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/005_033_021.mp3","charTypeName":"word"},{"id":36004,"position":22,"arabic":"يُنفَوْا۟","translation":"তাদের নির্বাসিত করা হবে","audioUrl":"wbw/005_033_022.mp3","charTypeName":"word"},{"id":36005