ranslation":"দিনে","audioUrl":"wbw/058_007_043.mp3","charTypeName":"word"},{"id":7661,"position":42,"arabic":"ٱلْقِيَـٰمَةِ ۚ","translation":"কিয়ামতের","audioUrl":"wbw/058_007_044.mp3","charTypeName":"word"},{"id":7663,"position":43,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/058_007_046.mp3","charTypeName":"word"},{"id":7664,"position":44,"arabic":"ٱللَّهَ","translation":"আল্লাহ্‌","audioUrl":"wbw/058_007_047.mp3","charTypeName":"word"},{"id":7665,"position":45,"arabic":"بِكُلِّ","translation":"সব সম্পর্কে","audioUrl":"wbw/058_007_048.mp3","charTypeName":"word"},{"id":7666,"position":46,"arabic":"شَىْءٍ","translation":"কিছুর","audioUrl":"wbw/058_007_049.mp3","charTypeName":"word"},{"id":7667,"position":47,"arabic":"عَلِيمٌ","translation":"খুব অবহিত","audioUrl":"wbw/058_007_050.mp3","charTypeName":"word"},{"id":7668,"position":48,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"أَلَمْ تَرَ إِلَى ٱلَّذِينَ نُهُوا۟ عَنِ ٱلنَّجْوَىٰ ثُمَّ يَعُودُونَ لِمَا نُهُوا۟ عَنْهُ وَيَتَنَٰجَوْنَ بِٱلْإِثْمِ وَٱلْعُدْوَٰنِ وَمَعْصِيَتِ ٱلرَّسُولِ وَإِذَا جَآءُوكَ حَيَّوْكَ بِمَا لَمْ يُحَيِّكَ بِهِ ٱللَّهُ وَيَقُولُونَ فِىٓ أَنفُسِهِمْ لَوْلَا يُعَذِّبُنَا ٱللَّهُ بِمَا نَقُولُ ۚ حَسْبُهُمْ جَهَنَّمُ يَصْلَوْنَهَا ۖ فَبِئْسَ ٱلْمَصِيرُ","translation":"Art thou not aware of such as have been for­bidden [to intrigue through] secret confabulations, and yet [always] revert to that which they have been forbidden, and conspire with one another with a view to sinful doings, and aggressive conduct, and dis­obedience to the Apostle? Now whenever such [people] approach thee, [O Muhammad,] they salute thee with a greeting which God has never countenanced; and they say to themselves, “Why does not God chastise us for what we are saying?” Hell shall be their allotted portion: they shall [in­deed] enter it - and how vile a journey’s end!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5112.mp3","surahId":58,"words":[{"id":8814,"position":1,"arabic":"أَلَمْ","translation":"নি কি","audioUrl":"wbw/058_008_001.mp3","charTypeName":"word"},{"id":8815,"position":2,"arabic":"تَرَ","translation":"তুমি দেখ","audioUrl":"wbw/058_008_002.mp3","charTypeName":"word"},{"id":8816,"position":3,"arabic":"إِلَى","translation":"দিকে","audioUrl":"wbw/058_008_003.mp3","charTypeName":"word"},{"id":8817,"position":4,"arabic":"ٱلَّذِينَ","translation":"(তাদেরকে) যাদের","audioUrl":"wbw/058_008_004.mp3","charTypeName":"word"},{"id":8818,"position":5,"arabic":"نُهُوا۟","translation":"নিষেধ করা হয়েছিল","audioUrl":"wbw/058_008_005.mp3","charTypeName":"word"},{"id":8819,"position":6,"arabic":"عَنِ","translation":"হতে","audioUrl":"wbw/058_008_006.mp3","charTypeName":"word"},{"id":8820,"position":7,"arabic":"ٱلنَّجْوَىٰ","translation":"গোপন পরামর্শ","audioUrl":"wbw/058_008_007.mp3","charTypeName":"word"},{"id":8821,"position":8,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/058_008_008.mp3","charTypeName":"word"},{"id":8822,"position":9,"arabic":"يَعُودُونَ","translation":"তারা পুনরাবৃত্তি করে","audioUrl":"wbw/058_008_009.mp3","charTypeName":"word"},{"id":8823,"position":10,"arabic":"لِمَا","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/058_008_010.mp3","charTypeName":"word"},{"id":8824,"position":11,"arabic":"نُهُوا۟","translation":"নিষেধ করা হয়েছিল","audioUrl":"wbw/058_008_011.mp3","charTypeName":"word"},{"id":8825,"position":12,"arabic":"عَنْهُ","translation":"তা হতে","audioUrl":"wbw/058_008_012.mp3","charTypeName":"word"},{"id":8826,"position":13,"arabic":"وَيَتَنَـٰجَوْنَ","translation":"ও পরস্পর গোপন পরামর্শ করে","audioUrl":"wbw/058_008_013.mp3","charTypeName":"word"},{"id":8827,"position":14,"arabic":"بِٱلْإِثْمِ","translation":"পাপের","audioUrl":"wbw/058_008_014.mp3","charTypeName":"word"},{"id":8828,"position":15,"arabic":"وَٱلْعُدْوَٰنِ","translation":"ও বাড়াবাড়ির","audioUrl":"wbw/058_008_015.mp3","charTypeName":"word"},{"id":8829,"position":16,"arabic":"وَمَعْصِيَتِ","translation":"এবং অবাধ্