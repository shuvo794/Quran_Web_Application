},{"id":8845,"position":32,"arabic":"بِمَا","translation":"একারনে যা","audioUrl":"wbw/058_008_032.mp3","charTypeName":"word"},{"id":8846,"position":33,"arabic":"نَقُولُ ۚ","translation":"বলি আমরা\"","audioUrl":"wbw/058_008_033.mp3","charTypeName":"word"},{"id":8848,"position":34,"arabic":"حَسْبُهُمْ","translation":"তাদের জন্যে যথেষ্ট","audioUrl":"wbw/058_008_035.mp3","charTypeName":"word"},{"id":8849,"position":35,"arabic":"جَهَنَّمُ","translation":"জাহান্নাম","audioUrl":"wbw/058_008_036.mp3","charTypeName":"word"},{"id":8850,"position":36,"arabic":"يَصْلَوْنَهَا ۖ","translation":"তাতে তারা প্রবেশ করবে","audioUrl":"wbw/058_008_037.mp3","charTypeName":"word"},{"id":8852,"position":37,"arabic":"فَبِئْسَ","translation":"অতি নিকৃষ্ট তা","audioUrl":"wbw/058_008_039.mp3","charTypeName":"word"},{"id":8853,"position":38,"arabic":"ٱلْمَصِيرُ","translation":"আবাসস্থল (হিসেবে)","audioUrl":"wbw/058_008_040.mp3","charTypeName":"word"},{"id":8854,"position":39,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوٓا۟ إِذَا تَنَٰجَيْتُمْ فَلَا تَتَنَٰجَوْا۟ بِٱلْإِثْمِ وَٱلْعُدْوَٰنِ وَمَعْصِيَتِ ٱلرَّسُولِ وَتَنَٰجَوْا۟ بِٱلْبِرِّ وَٱلتَّقْوَىٰ ۖ وَٱتَّقُوا۟ ٱللَّهَ ٱلَّذِىٓ إِلَيْهِ تُحْشَرُونَ","translation":"[Hence,] O you who have attained to faith, when you do hold secret confabulations, do not conspire with one another with a view to sinful doings, and aggressive conduct, and disobedience to the Apostle, but [rather] hold counsel in the cause of virtue and God-consciousness: and [always] remain conscious of God, unto whom you all shall be gathered.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5113.mp3","surahId":58,"words":[{"id":10040,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/058_009_001.mp3","charTypeName":"word"},{"id":10041,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/058_009_002.mp3","charTypeName":"word"},{"id":10042,"pos