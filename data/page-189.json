হয়েছে","audioUrl":"wbw/009_017_014.mp3","charTypeName":"word"},{"id":19410,"position":14,"arabic":"أَعْمَـٰلُهُمْ","translation":"কাজকর্ম তাদের","audioUrl":"wbw/009_017_015.mp3","charTypeName":"word"},{"id":19411,"position":15,"arabic":"وَفِى","translation":"ও মধ্যে","audioUrl":"wbw/009_017_016.mp3","charTypeName":"word"},{"id":19412,"position":16,"arabic":"ٱلنَّارِ","translation":"জাহান্নামের","audioUrl":"wbw/009_017_017.mp3","charTypeName":"word"},{"id":19413,"position":17,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/009_017_018.mp3","charTypeName":"word"},{"id":19414,"position":18,"arabic":"خَـٰلِدُونَ","translation":"চিরস্থায়ী হবে","audioUrl":"wbw/009_017_019.mp3","charTypeName":"word"},{"id":19415,"position":19,"arabic":"١٧","translation":"(১৭)","audioUrl":null,"charTypeName":"end"}]},{"number":18,"arabic":"إِنَّمَا يَعْمُرُ مَسَٰجِدَ ٱللَّهِ مَنْ ءَامَنَ بِٱللَّهِ وَٱلْيَوْمِ ٱلْءَاخِرِ وَأَقَامَ ٱلصَّلَوٰةَ وَءَاتَى ٱلزَّكَوٰةَ وَلَمْ يَخْشَ إِلَّا ٱللَّهَ ۖ فَعَسَىٰٓ أُو۟لَٰٓئِكَ أَن يَكُونُوا۟ مِنَ ٱلْمُهْتَدِينَ","translation":"Only he should visit or tend God's houses of worship who believes in God and the Last Day, and is constant in prayer, and spends in charity, and stands in awe of none but God: for [only such as] these may hope to be among the right-guided!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1253.mp3","surahId":9,"words":[{"id":20454,"position":1,"arabic":"إِنَّمَا","translation":"মূলত","audioUrl":"wbw/009_018_001.mp3","charTypeName":"word"},{"id":20455,"position":2,"arabic":"يَعْمُرُ","translation":"রক্ষণাবেক্ষণ করবে","audioUrl":"wbw/009_018_002.mp3","charTypeName":"word"},{"id":20456,"position":3,"arabic":"مَسَـٰجِدَ","translation":"মাসজিদসমূহের","audioUrl":"wbw/009_018_003.mp3","charTypeName":"word"},{"id":20457,"position":4,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/009_018_004.mp3","charTypeName":"word"},{"id":20458,"position":5,"arabic":"مَنْ","translation":"(সেই) যে","audioUrl":"wbw/009_0