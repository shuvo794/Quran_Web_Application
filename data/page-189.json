{"id":189,"ayahs":[{"number":14,"arabic":"قَٰتِلُوهُمْ يُعَذِّبْهُمُ ٱللَّهُ بِأَيْدِيكُمْ وَيُخْزِهِمْ وَيَنصُرْكُمْ عَلَيْهِمْ وَيَشْفِ صُدُورَ قَوْمٍۢ مُّؤْمِنِينَ","translation":"Fight against them! God will chastise them by your hands, and will bring disgrace upon them, and will succour you against them; and He will soothe the bosoms of those who believe,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1249.mp3","surahId":9,"words":[{"id":16070,"position":1,"arabic":"قَـٰتِلُوهُمْ","translation":"তাদের বিরুদ্ধে লড়াই করো","audioUrl":"wbw/009_014_001.mp3","charTypeName":"word"},{"id":16071,"position":2,"arabic":"يُعَذِّبْهُمُ","translation":"শাস্তি দিবেন তাদেরকে","audioUrl":"wbw/009_014_002.mp3","charTypeName":"word"},{"id":16072,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/009_014_003.mp3","charTypeName":"word"},{"id":16073,"position":4,"arabic":"بِأَيْدِيكُمْ","translation":"দিয়ে হাত তোমাদের","audioUrl":"wbw/009_014_004.mp3","charTypeName":"word"},{"id":16074,"position":5,"arabic":"وَيُخْزِهِمْ","translation":"এবং লাঞ্ছিত করবেন তাদেরকে","audioUrl":"wbw/009_014_005.mp3","charTypeName":"word"},{"id":16075,"position":6,"arabic":"وَيَنصُرْكُمْ","translation":"এবং সাহায্য করবেন তোমাদেরকে","audioUrl":"wbw/009_014_006.mp3","charTypeName":"word"},{"id":16076,"position":7,"arabic":"عَلَيْهِمْ","translation":"বিরুদ্ধে তাদের","audioUrl":"wbw/009_014_007.mp3","charTypeName":"word"},{"id":16077,"position":8,"arabic":"وَيَشْفِ","translation":"ও আরোগ্য করবেন","audioUrl":"wbw/009_014_008.mp3","charTypeName":"word"},{"id":16078,"position":9,"arabic":"صُدُورَ","translation":"অন্তরসমুহকে","audioUrl":"wbw/009_014_009.mp3","charTypeName":"word"},{"id":16079,"position":10,"arabic":"قَوْمٍۢ","translation":"সম্প্রদায়ের","audioUrl":"wbw/009_014_010.mp3","charTypeName":"word"},{"id":16080,"position":11,"arabic":"مُّؤْمِنِينَ","translation":"(যারা)মু'মিন","audioUrl":"wbw/009_014_011.mp3","charTypeName":"word"},{"id":16081,"position":12,"arabic":"١٤","translation":"(১৪)","audioUrl":null,"charTypeName":"end"}]},{"number":15,"arabic":"وَيُذْهِبْ غَيْظَ قُلُوبِهِمْ ۗ وَيَتُوبُ ٱللَّهُ عَلَىٰ مَن يَشَآءُ ۗ وَٱللَّهُ عَلِيمٌ حَكِيمٌ","translation":"and will remove the wrath that is in their hearts. And God will turn in His mercy unto whom He wills: for, God is all-knowing, wise.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1250.mp3","surahId":9,"words":[{"id":17312,"position":1,"arabic":"وَيُذْهِبْ","translation":"এবং দূর করবেন তিনি","audioUrl":"wbw/009_015_001.mp3","charTypeName":"word"},{"id":17313,"position":2,"arabic":"غَيْظَ","translation":"ক্ষোভ (জ্বালা)","audioUrl":"wbw/009_015_002.mp3","charTypeName":"word"},{"id":17314,"position":3,"arabic":"قُلُوبِهِمْ ۗ","translation":"অন্তরসমূহের তাদের","audioUrl":"wbw/009_015_003.mp3","charTypeName":"word"},{"id":17316,"position":4,"arabic":"وَيَتُوبُ","translation":"ও তওবা কবুল করবেন","audioUrl":"wbw/009_015_005.mp3","charTypeName":"word"},{"id":17317,"position":5,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/009_015_006.mp3","charTypeName":"word"},{"id":17318,"position":6,"arabic":"عَلَىٰ","translation":"(তাদের) প্রতি","audioUrl":"wbw/009_015_007.mp3","charTypeName":"word"},{"id":17319,"position":7,"arabic":"مَن","translation":"যাদেরকে","audioUrl":"wbw/009_015_008.mp3","charTypeName":"word"},{"id":17320,"position":8,"arabic":"يَشَآءُ ۗ","translation":"তিনি ইচ্ছে করবেন","audioUrl":"wbw/009_015_009.mp3","charTypeName":"word"},{"id":17322,"position":9,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/009_015_011.mp3","charTypeName":"word"},{"id":17323,"position":10,"arabic":"عَلِيمٌ","translation":"সর্বজ্ঞ","audioUrl":"wbw/009_015_012.mp3","charTypeName":"word"},{"id":17324,"position":11,"arabic":"حَكِيمٌ","translation":"সুবিজ্ঞ","audioUrl":"wbw/009_015_013.mp3","charTypeName":"word"},{"id":17325,"position":12,"arabic":"١٥","translation":"(১৫)","audioUrl":null,"charTypeName":"end"}]},{"number":16,"arabic":"أَمْ حَسِبْتُمْ أَن تُتْرَكُوا۟ وَلَمَّا يَعْلَمِ ٱللَّهُ ٱلَّذِينَ جَٰهَدُوا۟ مِنكُمْ وَلَمْ يَتَّخِذُوا۟ مِن دُونِ ٱللَّهِ وَلَا رَسُولِهِۦ وَلَا ٱلْمُؤْمِنِينَ وَلِيجَةًۭ ۚ وَٱللَّهُ خَبِيرٌۢ بِمَا تَعْمَلُونَ","translation":"Do you [O believers] think that you will be spared unless God takes cognizance of your having striven hard [in His cause] without seeking help from any but God and His Apostle and those who believe in Him? For, God is aware of all that you do.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1251.mp3","surahId":9,"words":[{"id":18388,"position":1,"arabic":"أَمْ","translation":"কি","audioUrl":"wbw/009_016_001.mp3","charTypeName":"word"},{"id":18389,"position":2,"arabic":"حَسِبْتُمْ","translation":"মনে করেছো তোমরা","audioUrl":"wbw/009_016_002.mp3","charTypeName":"word"},{"id":18390,"position":3,"arabic":"أَن","translation":"যে","audioUrl":"wbw/009_016_003.mp3","charTypeName":"word"},{"id":18391,"position":4,"arabic":"تُتْرَكُوا۟","translation":"তোমাদেরকে ছেড়ে দেয়া হবে","audioUrl":"wbw/009_016_004.mp3","charTypeName":"word"},{"id":18392,"position":5,"arabic":"وَلَمَّا","translation":"অথচ নি","audioUrl":"wbw/009_016_005.mp3","charTypeName":"word"},{"id":18393,"position":6,"arabic":"يَعْلَمِ","translation":"জানেন(এখন পর্যন্ত)","audioUrl":"wbw/009_016_006.mp3","charTypeName":"word"},{"id":18394,"position":7,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/009_016_007.mp3","charTypeName":"word"},{"id":18395,"position":8,"arabic":"ٱلَّذِينَ","translation":"(তাদেরকে) কারা","audioUrl":"wbw/009_016_008.mp3","charTypeName":"word"},{"id":18396,"position":9,"arabic":"جَـٰهَدُوا۟","translation":"তারা জিহাদ করেছে (তাঁর পথে)","audioUrl":"wbw/009_016_009.mp3","charTypeName":"word"},{"id":18397,"position":10,"arabic":"مِنكُمْ","translation":"মধ্য থেকে তোমাদের","audioUrl":"wbw/009_016_010.mp3","charTypeName":"word"},{"id":18398,"position":11,"arabic":"وَلَمْ","translation":"ও নি","audioUrl":"wbw/009_016_011.mp3","charTypeName":"word"},{"id":1839