র (দিয়ে)","audioUrl":"wbw/009_020_009.mp3","charTypeName":"word"},{"id":22655,"position":10,"arabic":"أَعْظَمُ","translation":"(তারা) অতি বড়","audioUrl":"wbw/009_020_010.mp3","charTypeName":"word"},{"id":22656,"position":11,"arabic":"دَرَجَةً","translation":"মর্যাদায় (অধিষ্ঠিত)","audioUrl":"wbw/009_020_011.mp3","charTypeName":"word"},{"id":22657,"position":12,"arabic":"عِندَ","translation":"কাছে","audioUrl":"wbw/009_020_012.mp3","charTypeName":"word"},{"id":22658,"position":13,"arabic":"ٱللَّهِ ۚ","translation":"আল্লাহর","audioUrl":"wbw/009_020_013.mp3","charTypeName":"word"},{"id":22660,"position":14,"arabic":"وَأُو۟لَـٰٓئِكَ","translation":"এবং ঐসব লোক","audioUrl":"wbw/009_020_015.mp3","charTypeName":"word"},{"id":22661,"position":15,"arabic":"هُمُ","translation":"তারাই","audioUrl":"wbw/009_020_016.mp3","charTypeName":"word"},{"id":22662,"position":16,"arabic":"ٱلْفَآئِزُونَ","translation":"সফলকাম","audioUrl":"wbw/009_020_017.mp3","charTypeName":"word"},{"id":22663,"position":17,"arabic":"٢٠","translation":"(২০)","audioUrl":null,"charTypeName":"end"}]}]}