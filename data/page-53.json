24_003.mp3","charTypeName":"word"},{"id":27005,"position":4,"arabic":"لَن","translation":"''কক্ষনো না","audioUrl":"wbw/003_024_004.mp3","charTypeName":"word"},{"id":27006,"position":5,"arabic":"تَمَسَّنَا","translation":"আমাদের স্পর্শ করবে","audioUrl":"wbw/003_024_005.mp3","charTypeName":"word"},{"id":27007,"position":6,"arabic":"ٱلنَّارُ","translation":"আগুন","audioUrl":"wbw/003_024_006.mp3","charTypeName":"word"},{"id":27008,"position":7,"arabic":"إِلَّآ","translation":"তবে (যদি করেও)","audioUrl":"wbw/003_024_007.mp3","charTypeName":"word"},{"id":27009,"position":8,"arabic":"أَيَّامًۭا","translation":"কয়েকদিন (মাত্র)","audioUrl":"wbw/003_024_008.mp3","charTypeName":"word"},{"id":27010,"position":9,"arabic":"مَّعْدُودَٰتٍۢ ۖ","translation":"সীমিত,''","audioUrl":"wbw/003_024_009.mp3","charTypeName":"word"},{"id":27012,"position":10,"arabic":"وَغَرَّهُمْ","translation":"আর তাদেরকে ধোঁকা দিয়েছে","audioUrl":"wbw/003_024_011.mp3","charTypeName":"word"},{"id":27013,"position":11,"arabic":"فِى","translation":"ব্যাপারে","audioUrl":"wbw/003_024_012.mp3","charTypeName":"word"},{"id":27014,"position":12,"arabic":"دِينِهِم","translation":"তাদের দ্বীনের","audioUrl":"wbw/003_024_013.mp3","charTypeName":"word"},{"id":27015,"position":13,"arabic":"مَّا","translation":"(তাই) যা","audioUrl":"wbw/003_024_014.mp3","charTypeName":"word"},{"id":27016,"position":14,"arabic":"كَانُوا۟","translation":"করছিল","audioUrl":"wbw/003_024_015.mp3","charTypeName":"word"},{"id":27017,"position":15,"arabic":"يَفْتَرُونَ","translation":"তারা উদ্ভাবন","audioUrl":"wbw/003_024_016.mp3","charTypeName":"word"},{"id":27018,"position":16,"arabic":"٢٤","translation":"(২৪)","audioUrl":null,"charTypeName":"end"}]},{"number":25,"arabic":"فَكَيْفَ إِذَا جَمَعْنَٰهُمْ لِيَوْمٍۢ لَّا رَيْبَ فِيهِ وَوُفِّيَتْ كُلُّ نَفْسٍۢ مَّا كَسَبَتْ وَهُمْ لَا يُظْلَمُونَ","translation":"How, then, [will they fare] when We shall gather them all together to witness the Day about [the coming of] which there is no doubt, and every human being shall be repaid in full for what he has done, and none shall be wronged?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/318.mp3","surahId":3,"words":[{"id":27989,"position":1,"arabic":"فَكَيْفَ","translation":"কেমন হবে তখন","audioUrl":"wbw/003_025_001.mp3","charTypeName":"word"},{"id":27990,"position":2,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/003_025_002.mp3","charTypeName":"word"},{"id":27991,"position":3,"arabic":"جَمَعْنَـٰهُمْ","translation":"তাদের আমরা একত্রিত করব","audioUrl":"wbw/003_025_003.mp3","charTypeName":"word"},{"id":27992,"position":4,"arabic":"لِيَوْمٍۢ","translation":"সেদিন","audioUrl":"wbw/003_025_004.mp3","charTypeName":"word"},{"id":27993,"position":5,"arabic":"لَّا","translation":"নাই","audioUrl":"wbw/003_025_005.mp3","charTypeName":"word"},{"id":27994,"position":6,"arabic":"رَيْبَ","translation":"কোন সন্দেহ","audioUrl":"wbw/003_025_006.mp3","charTypeName":"word"},{"id":27995,"position":7,"arabic":"فِيهِ","translation":"যার মধ্যে","audioUrl":"wbw/003_025_007.mp3","charTypeName":"word"},{"id":27996,"position":8,"arabic":"وَوُفِّيَتْ","translation":"এবং পূর্ণ দেয়া হবে","audioUrl":"wbw/003_025_008.mp3","charTypeName":"word"},{"id":27997,"position":9,"arabic":"كُلُّ","translation":"প্রত্যেক","audioUrl":"wbw/003_025_009.mp3","charTypeName":"word"},{"id":27998,"position":10,"arabic":"نَفْسٍۢ","translation":"ব্যক্তিকে","audioUrl":"wbw/003_025_010.mp3","charTypeName":"word"},{"id":27999,"position":11,"arabic":"مَّا","translation":"যা","audioUrl":"wbw/003_025_011.mp3","charTypeName":"word"},{"id":28000,"position":12,"arabic":"كَسَبَتْ","translation":"সে উপার্জন করেছে","audioUrl":"wbw/003_025_012.mp3","charTypeName":"word"},{"id":28001,"position":13,"arabic":"وَهُمْ","translation":"এবং তাদেরকে","audioUrl":"wbw/003_025_013.mp3","charTypeName":"word"},{"id":28002,"position":14,"arabic":"لَا","translation":"না","audioUrl":"wbw/003_025_014.mp3","charTypeName":"word"},{"id":28003,"position":15,"arabic":"يُظْلَمُونَ","translation":"জুলুম করা হবে","audioUrl":"wbw/003_025_015.mp3","charTypeName":"word"},{"id":28004,"position":16,"arabic":"٢٥","translation":"(২৫)","audioUrl":null,"charTypeName":"end"}]},{"number":26,"arabic":"قُلِ ٱللَّهُمَّ مَٰلِكَ ٱلْمُلْكِ تُؤْتِى ٱلْمُلْكَ مَن تَشَآءُ وَتَنزِعُ ٱلْمُلْكَ مِمَّن تَشَآءُ وَتُعِزُّ مَن تَشَآءُ وَتُذِلُّ مَن تَشَآءُ ۖ بِيَدِكَ ٱلْخَيْرُ ۖ إِنَّكَ عَلَىٰ كُلِّ شَىْءٍۢ قَدِيرٌۭ","translation":"SAY: \"O God, Lord of all dominion! Thou grantest dominion unto whom Thou willest, and takest away dominion from whom Thou willest; and Thou exaltest whom Thou willest, and abasest whom Thou willest. In Thy hand is all good. Verily, Thou hast the power to will anything.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/319.mp3","surahId":3,"words":[{"id":28942,"position":1,"arabic":"قُلِ","translation":"তুমি বল","audioUrl":"wbw/003_026_001.mp3","charTypeName":"word"},{"id":28943,"position":2,"arabic":"ٱللَّهُمَّ","translation":"''হে আল্লাহ","audioUrl":"wbw/003_026_002.mp3","charTypeName":"word"},{"id":28944,"position":3,"arabic":"مَـٰلِكَ","translation":"মালিক","audioUrl":"wbw/003_026_003.mp3","charTypeName":"word"},{"id":28945,"position":4,"arabic":"ٱلْمُلْكِ","translation":"রাজত্বের","audioUrl":"wbw/003_026_004.mp3","charTypeName":"word"},{"id":28946,"position":5,"arabic":"تُؤْتِى","translation":"দাও তুমি","audioUrl":"wbw/003_026_005.mp3","charTypeName":"word"},{"id":28947,"position":6,"arabic":"ٱلْمُلْكَ","translation":"শাসন ক্ষমতা","audioUrl":"wbw/003_026_006.mp3","charTypeName":"word"},{"id":28948,"position":7,"arabic":"مَن","translation":"যাকে","audioUrl":"wbw/003_026_007.mp3","charTypeName":"word"},{"id":28949,"position":8,"arabic":"تَشَآءُ","translation":"তুমি ইচ্ছে কর","audioUrl":"wbw/003_026_008.mp3","charTypeName":"word"},{"id":28950,"position":9,"arabic":"وَتَنزِعُ","translation":"আর কেড়ে নাও","audioUrl":"wbw/003_026_009.mp3","charTypeName":"word"},{"id":28951,"position":10,"arabic":"ٱلْمُلْكَ","translation":"শা