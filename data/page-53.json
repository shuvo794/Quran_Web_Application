{"id":53,"ayahs":[{"number":23,"arabic":"أَلَمْ تَرَ إِلَى ٱلَّذِينَ أُوتُوا۟ نَصِيبًۭا مِّنَ ٱلْكِتَٰبِ يُدْعَوْنَ إِلَىٰ كِتَٰبِ ٱللَّهِ لِيَحْكُمَ بَيْنَهُمْ ثُمَّ يَتَوَلَّىٰ فَرِيقٌۭ مِّنْهُمْ وَهُم مُّعْرِضُونَ","translation":"Art thou not aware of those who have been granted their share of revelation [aforetime]? They have been called upon to let God's writ be their law - and yet some of them turn away [from it] in their obstinacy,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/316.mp3","surahId":3,"words":[{"id":25921,"position":1,"arabic":"أَلَمْ","translation":"তুমি কি","audioUrl":"wbw/003_023_001.mp3","charTypeName":"word"},{"id":25922,"position":2,"arabic":"تَرَ","translation":"দেখ নাই","audioUrl":"wbw/003_023_002.mp3","charTypeName":"word"},{"id":25923,"position":3,"arabic":"إِلَى","translation":"প্রতি","audioUrl":"wbw/003_023_003.mp3","charTypeName":"word"},{"id":25924,"position":4,"arabic":"ٱلَّذِينَ","translation":"(ঐ লোকদের) যাদের","audioUrl":"wbw/003_023_004.mp3","charTypeName":"word"},{"id":25925,"position":5,"arabic":"أُوتُوا۟","translation":"দেয়া হয়েছে","audioUrl":"wbw/003_023_005.mp3","charTypeName":"word"},{"id":25926,"position":6,"arabic":"نَصِيبًۭا","translation":"অংশ","audioUrl":"wbw/003_023_006.mp3","charTypeName":"word"},{"id":25927,"position":7,"arabic":"مِّنَ","translation":"কিছু","audioUrl":"wbw/003_023_007.mp3","charTypeName":"word"},{"id":25928,"position":8,"arabic":"ٱلْكِتَـٰبِ","translation":"কিতাবের","audioUrl":"wbw/003_023_008.mp3","charTypeName":"word"},{"id":25929,"position":9,"arabic":"يُدْعَوْنَ","translation":"তাদের ডাকা হয়","audioUrl":"wbw/003_023_009.mp3","charTypeName":"word"},{"id":25930,"position":10,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/003_023_010.mp3","charTypeName":"word"},{"id":25931,"position":11,"arabic":"كِتَـٰبِ","translation":"কিতাবের","audioUrl":"wbw/003_023_011.mp3","charTypeName":"word"},{"id":25932,"position":12,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/0