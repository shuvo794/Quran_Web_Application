6,"arabic":"٢٦","translation":"(২৬)","audioUrl":null,"charTypeName":"end"}]},{"number":27,"arabic":"تُولِجُ ٱلَّيْلَ فِى ٱلنَّهَارِ وَتُولِجُ ٱلنَّهَارَ فِى ٱلَّيْلِ ۖ وَتُخْرِجُ ٱلْحَىَّ مِنَ ٱلْمَيِّتِ وَتُخْرِجُ ٱلْمَيِّتَ مِنَ ٱلْحَىِّ ۖ وَتَرْزُقُ مَن تَشَآءُ بِغَيْرِ حِسَابٍۢ","translation":"\"Thou makest the night grow longer by shortening the day, and Thou makest the day grow longer by shortening the night. And Thou bringest forth the living out of that which is dead, and Thou bringest forth the dead out of that which is alive. And Thou grantest sustenance unto whom `Thou willest, beyond all reckoning.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/320.mp3","surahId":3,"words":[{"id":29628,"position":1,"arabic":"تُولِجُ","translation":"তুমি প্রবেশ করাও","audioUrl":"wbw/003_027_001.mp3","charTypeName":"word"},{"id":29629,"position":2,"arabic":"ٱلَّيْلَ","translation":"রাতকে","audioUrl":"wbw/003_027_002.mp3","charTypeName":"word"},{"id":29630,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/003_027_003.mp3","charTypeName":"word"},{"id":29631,"position":4,"arabic":"ٱلنَّهَارِ","translation":"দিনের","audioUrl":"wbw/003_027_004.mp3","charTypeName":"word"},{"id":29632,"position":5,"arabic":"وَتُولِجُ","translation":"আবার তুমি প্রবেশ করাও","audioUrl":"wbw/003_027_005.mp3","charTypeName":"word"},{"id":29633,"position":6,"arabic":"ٱلنَّهَارَ","translation":"দিনকে","audioUrl":"wbw/003_027_006.mp3","charTypeName":"word"},{"id":29634,"position":7,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/003_027_007.mp3","charTypeName":"word"},{"id":29635,"position":8,"arabic":"ٱلَّيْلِ ۖ","translation":"রাতের","audioUrl":"wbw/003_027_008.mp3","charTypeName":"word"},{"id":29637,"position":9,"arabic":"وَتُخْرِجُ","translation":"এবং তুমি বের কর","audioUrl":"wbw/003_027_010.mp3","charTypeName":"word"},{"id":29638,"position":10,"arabic":"ٱلْحَىَّ","translation":"জীবন্তকে","audioUrl":"wbw/003_027_011.mp3","charTypeName":"word"},{"id":29639,"po