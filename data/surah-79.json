_018_005.mp3","charTypeName":"word"},{"id":20750,"position":6,"arabic":"تَزَكَّىٰ","translation":"তুমি পবিত্র হবে","audioUrl":"wbw/079_018_006.mp3","charTypeName":"word"},{"id":20751,"position":7,"arabic":"١٨","translation":"(১৮)","audioUrl":null,"charTypeName":"end"}]},{"number":19,"arabic":"وَأَهْدِيَكَ إِلَىٰ رَبِّكَ فَتَخْشَىٰ","translation":"[If so,] then I shall guide thee towards [a cognition of] thy Sustainer, so that [henceforth] thou wilt stand in awe [of Him].’\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5731.mp3","surahId":79,"words":[{"id":21721,"position":1,"arabic":"وَأَهْدِيَكَ","translation":"এবং তোমাকে আমি পথ দেখাবো","audioUrl":"wbw/079_019_001.mp3","charTypeName":"word"},{"id":21722,"position":2,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/079_019_002.mp3","charTypeName":"word"},{"id":21723,"position":3,"arabic":"رَبِّكَ","translation":"তোমার রবের","audioUrl":"wbw/079_019_003.mp3","charTypeName":"word"},{"id":21724,"position":4,"arabic":"فَتَخْشَىٰ","translation":"তুমি যেন ভয় করো\"","audioUrl":"wbw/079_019_004.mp3","charTypeName":"word"},{"id":21725,"position":5,"arabic":"١٩","translation":"(১৯)","audioUrl":null,"charTypeName":"end"}]},{"number":20,"arabic":"فَأَرَىٰهُ ٱلْءَايَةَ ٱلْكُبْرَىٰ","translation":"And thereupon he [went to Pharaoh and] made him aware of the great wonder [of God's grace].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5732.mp3","surahId":79,"words":[{"id":22933,"position":1,"arabic":"فَأَرَىٰهُ","translation":"অতঃপর  সে তাকে দেখালো","audioUrl":"wbw/079_020_001.mp3","charTypeName":"word"},{"id":22934,"position":2,"arabic":"ٱلْـَٔايَةَ","translation":"একটি নিদর্শন","audioUrl":"wbw/079_020_002.mp3","charTypeName":"word"},{"id":22935,"position":3,"arabic":"ٱلْكُبْرَىٰ","translation":"বড়","audioUrl":"wbw/079_020_003.mp3","charTypeName":"word"},{"id":22936,"position":4,"arabic":"٢٠","translation":"(২০)","audioUrl":null,"charTypeName":"end"}]},{"number":21,"arabic":"فَكَذَّبَ 