islamic.network/quran/audio/128/ar.alafasy/5722.mp3","surahId":79,"words":[{"id":11628,"position":1,"arabic":"يَقُولُونَ","translation":"তারা বলে","audioUrl":"wbw/079_010_001.mp3","charTypeName":"word"},{"id":11629,"position":2,"arabic":"أَءِنَّا","translation":"\"অবশ্যই কি আমরা","audioUrl":"wbw/079_010_002.mp3","charTypeName":"word"},{"id":11630,"position":3,"arabic":"لَمَرْدُودُونَ","translation":"অবশ্যই প্রত্যাবর্তিত হবো","audioUrl":"wbw/079_010_003.mp3","charTypeName":"word"},{"id":11631,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/079_010_004.mp3","charTypeName":"word"},{"id":11632,"position":5,"arabic":"ٱلْحَافِرَةِ","translation":"পূর্বাবস্থার","audioUrl":"wbw/079_010_005.mp3","charTypeName":"word"},{"id":11633,"position":6,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"أَءِذَا كُنَّا عِظَٰمًۭا نَّخِرَةًۭ","translation":"even though we may have become [a heap of] crumbling bones?\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5723.mp3","surahId":79,"words":[{"id":12979,"position":1,"arabic":"أَءِذَا","translation":"যখন কি","audioUrl":"wbw/079_011_001.mp3","charTypeName":"word"},{"id":12980,"position":2,"arabic":"كُنَّا","translation":"আমরা হবো (পরিণত)","audioUrl":"wbw/079_011_002.mp3","charTypeName":"word"},{"id":12981,"position":3,"arabic":"عِظَـٰمًۭا","translation":"হাড়গুলোয়","audioUrl":"wbw/079_011_003.mp3","charTypeName":"word"},{"id":12982,"position":4,"arabic":"نَّخِرَةًۭ","translation":"গলিত\"","audioUrl":"wbw/079_011_004.mp3","charTypeName":"word"},{"id":12983,"position":5,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]},{"number":12,"arabic":"قَالُوا۟ تِلْكَ إِذًۭا كَرَّةٌ خَاسِرَةٌۭ","translation":"[And] they add, \"That, then, would be a return with loss!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5724.mp3","surahId":79,"words":[{"id":14247,"position":1,"arabic":"قَالُوا۟","translation":"তারা বলল","audioUrl":"wbw/079_012_001.mp3","charTypeName":"word"},{"id":14248,"position":2,"arabic":"تِلْكَ","translation":"\"এটা","audioUrl":"wbw/079_012_002.mp3","charTypeName":"word"},{"id":14249,"position":3,"arabic":"إِذًۭا","translation":"তা হলে","audioUrl":"wbw/079_012_003.mp3","charTypeName":"word"},{"id":14250,"position":4,"arabic":"كَرَّةٌ","translation":"প্রত্যাবর্তন","audioUrl":"wbw/079_012_004.mp3","charTypeName":"word"},{"id":14251,"position":5,"arabic":"خَاسِرَةٌۭ","translation":"বড়ই ক্ষতিকর (হবে)\"","audioUrl":"wbw/079_012_005.mp3","charTypeName":"word"},{"id":14252,"position":6,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]},{"number":13,"arabic":"فَإِنَّمَا هِىَ زَجْرَةٌۭ وَٰحِدَةٌۭ","translation":"[But,] then, that [Last Hour] will be [upon them of a sudden, as if it were] but a single accusing cry -","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5725.mp3","surahId":79,"words":[{"id":15480,"position":1,"arabic":"فَإِنَّمَا","translation":"প্রকৃতপক্ষে","audioUrl":"wbw/079_013_001.mp3","charTypeName":"word"},{"id":15481,"position":2,"arabic":"هِىَ","translation":"তা","audioUrl":"wbw/079_013_002.mp3","charTypeName":"word"},{"id":15482,"position":3,"arabic":"زَجْرَةٌۭ","translation":"বিকট আওয়াজ","audioUrl":"wbw/079_013_003.mp3","charTypeName":"word"},{"id":15483,"position":4,"arabic":"وَٰحِدَةٌۭ","translation":"একটি মাত্র","audioUrl":"wbw/079_013_004.mp3","charTypeName":"word"},{"id":15484,"position":5,"arabic":"١٣","translation":"(১৩)","audioUrl":null,"charTypeName":"end"}]},{"number":14,"arabic":"فَإِذَا هُم بِٱلسَّاهِرَةِ","translation":"and then, lo, they will be fully awakened [to the truth]!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5726.mp3","surahId":79,"words":[{"id":16413,"position":1,"arabic":"فَإِذَا","translation":"অতঃপর তখনই","audioUrl":"wbw/079_014_001.mp3","charTypeName":"word"},{"id":16414,"position":2,"arabic":"هُم","translation":"তারা","audioUrl":"wbw/079_014_002.mp3","charTypeName":"word"},{"id":16415,"position":3,"arabic":"بِٱلسَّاهِرَةِ","translation":"খোলা ময়দানে (হবে)","audioUrl":"wbw/079_014_003.mp3","charTypeName":"word"},{"id":16416,"position":4,"arabic":"١٤","translation":"(১৪)","audioUrl":null,"charTypeName":"end"}]},{"number":15,"arabic":"هَلْ أَتَىٰكَ حَدِيثُ مُوسَىٰٓ","translation":"HAS THE STORY of Moses ever come within thy ken.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5727.mp3","surahId":79,"words":[{"id":17576,"position":1,"arabic":"هَلْ","translation":"কি","audioUrl":"wbw/079_015_001.mp3","charTypeName":"word"},{"id":17577,"position":2,"arabic":"أَتَىٰكَ","translation":"তোমার কাছে এসেছে","audioUrl":"wbw/079_015_002.mp3","charTypeName":"word"},{"id":17578,"position":3,"arabic":"حَدِيثُ","translation":"বৃত্তান্ত","audioUrl":"wbw/079_015_003.mp3","charTypeName":"word"},{"id":17579,"position":4,"arabic":"مُوسَىٰٓ","translation":"মূসার","audioUrl":"wbw/079_015_004.mp3","charTypeName":"word"},{"id":17580,"position":5,"arabic":"١٥","translation":"(১৫)","audioUrl":null,"charTypeName":"end"}]},{"number":16,"arabic":"إِذْ نَادَىٰهُ رَبُّهُۥ بِٱلْوَادِ ٱلْمُقَدَّسِ طُوًى","translation":"Lo! His Sustainer called out to him in the twice-hallowed valley:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5728.mp3","surahId":79,"words":[{"id":18609,"position":1,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/079_016_001.mp3","charTypeName":"word"},{"id":18610,"position":2,"arabic":"نَادَىٰهُ","translation":"তাকে ডেকেছিলেন","audioUrl":"wbw/079_016_002.mp3","charTypeName":"word"},{"id":18611,"position":3,"arabic":"رَبُّهُۥ","translation":"তার রব","audioUrl":"wbw/079_016_003.mp3","charTypeName":"word"},{"id":18612,"position":4,"arabic":"بِٱلْوَادِ","translation":"উপত্যকায়","audioUrl":"wbw/079_016_004.mp3","charTypeName":"word"},{"id":18613,"position":5,"arabic":"ٱلْمُقَدَّسِ","translation":"পবিত্র","audioUrl":"wbw/079_016_005.mp3","charTypeName":"word"},{"id":18614,"position":6,"arabic":"طُوًى","transla