{"id":79,"nameArabic":"سُورَةُ النَّازِعَاتِ","nameEnglish":"An-Naazi'aat","nameTranslation":"Those who drag forth","revelationType":"Meccan","numberOfAyahs":46,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلنَّٰزِعَٰتِ غَرْقًۭا","translation":"CONSIDER those [stars] that rise only to set,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5713.mp3","surahId":79,"words":[{"id":679,"position":1,"arabic":"وَٱلنَّـٰزِعَـٰتِ","translation":"শপথ সজোরে (প্রাণ) নির্গতকারী (ফেরেশতাদের)","audioUrl":"wbw/079_001_001.mp3","charTypeName":"word"},{"id":680,"position":2,"arabic":"غَرْقًۭا","translation":"(যারা নির্গত করে) ডুবে","audioUrl":"wbw/079_001_002.mp3","charTypeName":"word"},{"id":681,"position":3,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"وَٱلنَّٰشِطَٰتِ نَشْطًۭا","translation":"and move [in their orbits] with steady motion,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5714.mp3","surahId":79,"words":[{"id":1695,"position":1,"arabic":"وَٱلنَّـٰشِطَـٰتِ","translation":"শপথ (আত্মার) বাঁধন উন্মুক্তকারী (ফেরেশতাদের)","audioUrl":"wbw/079_002_001.mp3","charTypeName":"word"},{"id":1696,"position":2,"arabic":"نَشْطًۭا","translation":"(যারা মৃদুভাবে) উন্মুক্ত (করে)","audioUrl":"wbw/079_002_002.mp3","charTypeName":"word"},{"id":1697,"position":3,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"وَٱلسَّٰبِحَٰتِ سَبْحًۭا","translation":"and float [through space] with floating serene,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5715.mp3","surahId":79,"words":[{"id":2804,"position":1,"arabic":"وَٱلسَّـٰبِحَـٰتِ","translation":"শপথ সাঁতারকারী (ফেরেশতাদের)","audioUrl":"wbw/079_003_001.mp3","charTypeName":"word"},{"id":2805,"position":2,"arabic":"سَبْحًۭا","translation":"(যারা তীব্র গতিতে) সাঁতরায়","audioUrl":"wbw/079_003_002.mp3","charTypeName":"word"},{"id":2806,"position":3,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"فَٱلسَّٰبِقَٰتِ سَبْقًۭا","translation":"and yet overtake [one another] with swift overtaking:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5716.mp3","surahId":79,"words":[{"id":4178,"position":1,"arabic":"فَٱلسَّـٰبِقَـٰتِ","translation":"অতঃপর (শপথ) অগ্রগামী (ফেরেশতাদের)","audioUrl":"wbw/079_004_001.mp3","charTypeName":"word"},{"id":4179,"position":2,"arabic":"سَبْقًۭا","translation":"দ্রুতবেগে","audioUrl":"wbw/079_004_002.mp3","charTypeName":"word"},{"id":4180,"position":3,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"فَٱلْمُدَبِّرَٰتِ أَمْرًۭا","translation":"and thus they fulfil the [Creator's] behest!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5717.mp3","surahId":79,"words":[{"id":5452,"position":1,"arabic":"فَٱلْمُدَبِّرَٰتِ","translation":"অতঃপর (শপথ) কার্যনির্বাহী (ফেরেশতাদের)","audioUrl":"wbw/079_005_001.mp3","charTypeName":"word"},{"id":5453,"position":2,"arabic":"أَمْرًۭا","translation":"(যারা পরিচালনা করে) কর্ম","audioUrl":"wbw/079_005_002.mp3","charTypeName":"word"},{"id":5454,"position":3,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"يَوْمَ تَرْجُفُ ٱلرَّاجِفَةُ","translation":"[HENCE, think of] the Day when a violent convulsion will convulse [the world],","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5718.mp3","surahId":79,"words":[{"id":6681,"position":1,"arabic":"يَوْمَ","translation":"সেদিন","audioUrl":"wbw/079_006_001.mp3","charTypeName":"word"},{"id":6682,"position":2,"arabic":"تَرْجُفُ","translation":"প্রকম্পিত করবে","audioUrl":"wbw/079_006_002.mp3","charTypeName":"word"},{"id":6683,"position":3,"arabic":"ٱلرَّاجِفَةُ","translation":"প্রথম শিংগাধ্বনি","audioUrl":"wbw/079_006_003.mp3","charTypeName":"word"},{"id":6684,"position":4,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"تَتْبَع