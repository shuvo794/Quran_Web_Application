{"id":47,"ayahs":[{"number":275,"arabic":"ٱلَّذِينَ يَأْكُلُونَ ٱلرِّبَوٰا۟ لَا يَقُومُونَ إِلَّا كَمَا يَقُومُ ٱلَّذِى يَتَخَبَّطُهُ ٱلشَّيْطَٰنُ مِنَ ٱلْمَسِّ ۚ ذَٰلِكَ بِأَنَّهُمْ قَالُوٓا۟ إِنَّمَا ٱلْبَيْعُ مِثْلُ ٱلرِّبَوٰا۟ ۗ وَأَحَلَّ ٱللَّهُ ٱلْبَيْعَ وَحَرَّمَ ٱلرِّبَوٰا۟ ۚ فَمَن جَآءَهُۥ مَوْعِظَةٌۭ مِّن رَّبِّهِۦ فَٱنتَهَىٰ فَلَهُۥ مَا سَلَفَ وَأَمْرُهُۥٓ إِلَى ٱللَّهِ ۖ وَمَنْ عَادَ فَأُو۟لَٰٓئِكَ أَصْحَٰبُ ٱلنَّارِ ۖ هُمْ فِيهَا خَٰلِدُونَ","translation":"THOSE who gorge themselves on usury behave but as he might behave whom Satan has confounded with his touch; for they say, \"Buying and selling is but a kind of usury\" - the while God has made buying and selling lawful and usury unlawful. Hence, whoever becomes aware of his Sustainer's admonition, and thereupon desists [from usury], may keep his past gains, and it will be for God to judge him; but as for those who return to it -they are destined for the fire, therein to abide!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/282.mp3","surahId":2,"words":[{"id":87794,"position":1,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/002_275_001.mp3","charTypeName":"word"},{"id":87795,"position":2,"arabic":"يَأْكُلُونَ","translation":"খায়","audioUrl":"wbw/002_275_002.mp3","charTypeName":"word"},{"id":87796,"position":3,"arabic":"ٱلرِّبَوٰا۟","translation":"সুদ","audioUrl":"wbw/002_275_003.mp3","charTypeName":"word"},{"id":87797,"position":4,"arabic":"لَا","translation":"না","audioUrl":"wbw/002_275_004.mp3","charTypeName":"word"},{"id":87798,"position":5,"arabic":"يَقُومُونَ","translation":"তারা দাঁড়াবে","audioUrl":"wbw/002_275_005.mp3","charTypeName":"word"},{"id":87799,"position":6,"arabic":"إِلَّا","translation":"এছাড়া","audioUrl":"wbw/002_275_006.mp3","charTypeName":"word"},{"id":87800,"position":7,"arabic":"كَمَا","translation":"যেমন","audioUrl":"wbw/002_275_007.mp3","charTypeName":"word"},{"id":87801,"position":8,"arabic":"يَقُومُ","translation":"দাঁড়ায়","audioUrl":"wbw/002_275_008.mp3","charTypeName":"word"},{"id":87802,"position":9,"arabic":"ٱلَّذِى","translation":"সেই (ব্যক্তি)","audioUrl":"wbw/002_275_009.mp3","charTypeName":"word"},{"id":87803,"position":10,"arabic":"يَتَخَبَّطُهُ","translation":"যাকে পাগল করেছে","audioUrl":"wbw/002_275_010.mp3","charTypeName":"word"},{"id":87804,"position":11,"arabic":"ٱلشَّيْطَـٰنُ","translation":"শয়তান","audioUrl":"wbw/002_275_011.mp3","charTypeName":"word"},{"id":87805,"position":12,"arabic":"مِنَ","translation":"দ্বারা","audioUrl":"wbw/002_275_012.mp3","charTypeName":"word"},{"id":87806,"position":13,"arabic":"ٱلْمَسِّ ۚ","translation":"(তার) স্পর্শ","audioUrl":"wbw/002_275_013.mp3","charTypeName":"word"},{"id":87808,"position":14,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/002_275_015.mp3","charTypeName":"word"},{"id":87809,"position":15,"arabic":"بِأَنَّهُمْ","translation":"এ জন্য যে তারা","audioUrl":"wbw/002_275_016.mp3","charTypeName":"word"},{"id":87810,"position":16,"arabic":"قَالُوٓا۟","translation":"বলে","audioUrl":"wbw/002_275_017.mp3","charTypeName":"word"},{"id":87811,"position":17,"arabic":"إِنَّمَا","translation":"মূলতঃ","audioUrl":"wbw/002_275_018.mp3","charTypeName":"word"},{"id":87812,"position":18,"arabic":"ٱلْبَيْعُ","translation":"ব্যবসাও","audioUrl":"wbw/002_275_019.mp3","charTypeName":"word"},{"id":87813,"position":19,"arabic":"مِثْلُ","translation":"মতো","audioUrl":"wbw/002_275_020.mp3","charTypeName":"word"},{"id":87814,"position":20,"arabic":"ٱلرِّبَوٰا۟ ۗ","translation":"সুদেরই","audioUrl":"wbw/002_275_021.mp3","charTypeName":"word"},{"id":87816,"position":21,"arabic":"وَأَحَلَّ","translation":"অথচ বৈধ করেছেন","audioUrl":"wbw/002_275_023.mp3","charTypeName":"word"},{"id":87817,"position":22,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/002_275_024.mp3","charTypeName":"word"},{"id":87818,"position":23,"arabic":"ٱلْبَيْعَ","translation":"ব্যবসাকে","audioUrl":"wbw/002_275_025.mp3","charTypeName":"word"},{"id":87819,"position":24,"arabic":"وَحَرَّمَ","