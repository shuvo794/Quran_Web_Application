_275_043.mp3","charTypeName":"word"},{"id":87837,"position":40,"arabic":"فَأُو۟لَـٰٓئِكَ","translation":"তাহলে ঐসব লোক","audioUrl":"wbw/002_275_044.mp3","charTypeName":"word"},{"id":87838,"position":41,"arabic":"أَصْحَـٰبُ","translation":"অধিবাসী (হবে)","audioUrl":"wbw/002_275_045.mp3","charTypeName":"word"},{"id":87839,"position":42,"arabic":"ٱلنَّارِ ۖ","translation":"আগুনের","audioUrl":"wbw/002_275_046.mp3","charTypeName":"word"},{"id":87841,"position":43,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/002_275_048.mp3","charTypeName":"word"},{"id":87842,"position":44,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/002_275_049.mp3","charTypeName":"word"},{"id":87843,"position":45,"arabic":"خَـٰلِدُونَ","translation":"চিরস্থায়ী হবে","audioUrl":"wbw/002_275_050.mp3","charTypeName":"word"},{"id":87844,"position":46,"arabic":"٢٧٥","translation":"(২৭৫)","audioUrl":null,"charTypeName":"end"}]},{"number":276,"arabic":"يَمْحَقُ ٱللَّهُ ٱلرِّبَوٰا۟ وَيُرْبِى ٱلصَّدَقَٰتِ ۗ وَٱللَّهُ لَا يُحِبُّ كُلَّ كَفَّارٍ أَثِيمٍ","translation":"God deprives usurious gains of all blessing, whereas He blesses charitable deeds with manifold increase. And God does not love anyone who is stubbornly ingrate and persists in sinful ways.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/283.mp3","surahId":2,"words":[{"id":87845,"position":1,"arabic":"يَمْحَقُ","translation":"নিশ্চিহ্ন করেন","audioUrl":"wbw/002_276_001.mp3","charTypeName":"word"},{"id":87846,"position":2,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/002_276_002.mp3","charTypeName":"word"},{"id":87847,"position":3,"arabic":"ٱلرِّبَوٰا۟","translation":"সুদকে","audioUrl":"wbw/002_276_003.mp3","charTypeName":"word"},{"id":87848,"position":4,"arabic":"وَيُرْبِى","translation":"ও বর্ধিত করেন","audioUrl":"wbw/002_276_004.mp3","charTypeName":"word"},{"id":87849,"position":5,"arabic":"ٱلصَّدَقَـٰتِ ۗ","translation":"দানকে","audioUrl":"wbw/002_276_005.mp3","charTypeName":"word"},{"id":87851,"position":6,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/002_276_007.mp3","charTypeName":"word"},{"id":87852,"position":7,"arabic":"لَا","translation":"না","audioUrl":"wbw/002_276_008.mp3","charTypeName":"word"},{"id":87853,"position":8,"arabic":"يُحِبُّ","translation":"ভালোবাসেন","audioUrl":"wbw/002_276_009.mp3","charTypeName":"word"},{"id":87854,"position":9,"arabic":"كُلَّ","translation":"প্রত্যেক","audioUrl":"wbw/002_276_010.mp3","charTypeName":"word"},{"id":87855,"position":10,"arabic":"كَفَّارٍ","translation":"অকৃতজ্ঞ","audioUrl":"wbw/002_276_011.mp3","charTypeName":"word"},{"id":87856,"position":11,"arabic":"أَثِيمٍ","translation":"পাপীকে","audioUrl":"wbw/002_276_012.mp3","charTypeName":"word"},{"id":87857,"position":12,"arabic":"٢٧٦","translation":"(২৭৬)","audioUrl":null,"charTypeName":"end"}]},{"number":277,"arabic":"إِنَّ ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ وَأَقَامُوا۟ ٱلصَّلَوٰةَ وَءَاتَوُا۟ ٱلزَّكَوٰةَ لَهُمْ أَجْرُهُمْ عِندَ رَبِّهِمْ وَلَا خَوْفٌ عَلَيْهِمْ وَلَا هُمْ يَحْزَنُونَ","translation":"Verily, those who have attained to faith and do good works, and are constant in prayer, and dispense charity - they shall have their reward with their Sustainer, and no fear need they have, and neither shall they grieve.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/284.mp3","surahId":2,"words":[{"id":87858,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/002_277_001.mp3","charTypeName":"word"},{"id":87859,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/002_277_002.mp3","charTypeName":"word"},{"id":87860,"position":3,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/002_277_003.mp3","charTypeName":"word"},{"id":87861,"position":4,"arabic":"وَعَمِلُوا۟","translation":"ও কাজ করেছে","audioUrl":"wbw/002_277_004.mp3","charTypeName":"word"},{"id":87862,"position":5,"arabic":"ٱلصَّـٰلِحَـٰتِ","translation":"সৎ","audioUrl":"wbw/002_277_005.mp3","charTypeName":"word"},{"id":87863,"position":6,"arabic":"وَأَقَامُوا۟","translation":"ও প্রতিষ্ঠা করেছে","audioUrl":"wbw/002_277_006.mp3","charTypeName":"word"},{"id":87864,"position":7,"arabic":"ٱلصَّلَوٰةَ","translation":"সালাত","audioUrl":"wbw/002_277_007.mp3","charTypeName":"word"},{"id":87865,"position":8,"arabic":"وَءَاتَوُا۟","translation":"ও দিয়েছে","audioUrl":"wbw/002_277_008.mp3","charTypeName":"word"},{"id":87866,"position":9,"arabic":"ٱلزَّكَوٰةَ","translation":"যাকাত","audioUrl":"wbw/002_277_009.mp3","charTypeName":"word"},{"id":87867,"position":10,"arabic":"لَهُمْ","translation":"তাদের জন্য (রয়েছে)","audioUrl":"wbw/002_277_010.mp3","charTypeName":"word"},{"id":87868,"position":11,"arabic":"أَجْرُهُمْ","translation":"তাদের পুরস্কার","audioUrl":"wbw/002_277_011.mp3","charTypeName":"word"},{"id":87869,"position":12,"arabic":"عِندَ","translation":"কাছে","audioUrl":"wbw/002_277_012.mp3","charTypeName":"word"},{"id":87870,"position":13,"arabic":"رَبِّهِمْ","translation":"তাদের রবের","audioUrl":"wbw/002_277_013.mp3","charTypeName":"word"},{"id":87871,"position":14,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/002_277_014.mp3","charTypeName":"word"},{"id":87872,"position":15,"arabic":"خَوْفٌ","translation":"ভয় (থাকবে)","audioUrl":"wbw/002_277_015.mp3","charTypeName":"word"},{"id":87873,"position":16,"arabic":"عَلَيْهِمْ","translation":"তাদের উপর","audioUrl":"wbw/002_277_016.mp3","charTypeName":"word"},{"id":87874,"position":17,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/002_277_017.mp3","charTypeName":"word"},{"id":87875,"position":18,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/002_277_018.mp3","charTypeName":"word"},{"id":87876,"position":19,"arabic":"يَحْزَنُونَ","translation":"তারা দুঃখিত হবে","audioUrl":"wbw/002_277_019.mp3","charTypeName":"word"},{"id":87877,"position":20,"arabic":"٢٧٧","translation":"(২৭৭)","audioUrl":null,"charTypeName":"end"}]},{"number":278,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ ٱتَّقُوا۟ ٱللَّهَ وَذَرُوا۟ مَا بَقِىَ مِنَ ٱلرِّبَوٰٓا۟ إِن كُنتُم مُّؤْمِنِينَ","translation":"O you who have attained to faith! Remain conscious of God. and give up all outstanding gains from usury, if you are [truly] believers;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/285.mp3","surahId":2,"words":[{"id":87878,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/002_278_001.mp3","charTypeName":"word"},{"id":87879,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/002_278_002.mp3","charTypeName":"word"},{"id":87880,"position":3,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছ","audioUrl":"wbw/002_278_003.mp3","charTypeName":"word"},{"id":87881,"position":4,"arabic":"ٱتَّقُوا۟","translation":"তোমরা ভয় করো","audioUrl":"wbw/002_278_004.mp3","charTypeName":"word"},{"id":87882,"position":5,"arabic":"ٱللَّهَ","translation":"আল্লাহকে","audioUrl":"wbw/002_278_005.mp3","charTypeName":"word"},{"id":87883,"position":6,"arabic":"وَذَرُوا۟","translation":"এবং ছেড়ে দাও","audioUrl":"wbw/002_278_006.mp3","charTypeName":"word"},{"id":87884,"position":7,"arabic":"مَا","translation":"যা","audioUrl":"wbw/002_278_007.mp3","charTypeName":"word"},{"id":87885,"position":8,"arabic":"بَقِىَ","translation":"বকেয়া আছে","audioUrl":"wbw/002_278_008.mp3","charTypeName":"word"},{"id":87886,"position":9,"arabic":"مِنَ","translation":"হতে","audioUrl":"wbw/002_278_009.mp3","charTypeName":"word"},{"id":87887,"position":10,"arabic":"ٱلرِّبَوٰٓا۟","translation":"সুদ","audioUrl":"wbw/002_278_010.mp3","charTypeName":"word"},{"id":87888,"position":11,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/002_278_011.mp3","charTypeName":"word"},{"id":87889,"position":12,"arabic":"كُنتُم","translation":"তোমরা হও","audioUrl":"wbw/002_278_012.mp3","charTypeName":"word"},{"id":87890,"position":13,"arabic":"مُّؤْمِنِينَ","translation":"মু'মিন","audioUrl":"wbw/002_278_013.mp3","charTypeName":"word"},{"id":87891,"position":14,"arabic":"٢٧٨","translation":"(২৭৮)","audioUrl":null,"charTypeName":"end"}]},{"number":279,"arabic":"فَإِن لَّمْ تَفْعَلُوا۟ فَأْذَنُوا۟ بِحَرْبٍۢ مِّنَ ٱللَّهِ وَرَسُولِهِۦ ۖ وَإِن تُبْتُمْ فَلَكُمْ رُءُوسُ أَمْوَٰلِكُمْ لَا تَظْلِمُونَ وَلَا تُظْلَمُونَ","translation":"for if you do it not, then know that you are at war with God and His Apostle. But if you repent, then you shall be entitled to [the return of] your principal: you will do no wrong, and neither will you be wronged.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/286.mp3","surahId":2,"words":[{"id":87892,"position":1,"arabic":"فَإِن","translation":"অতঃপর যদি","audioUrl":"wbw/002_279_001.mp3","charTypeName":"word"},{"id":87893,"position":2,"arabic":"لَّمْ","translation":"না","audioUrl":"wbw/002_279_002.mp3","charTypeName":"word"},{"id":87894,"position":3,"arabic":"تَفْعَلُوا۟","translation":"তোমরা কর","audioUrl":"wbw/002_279_003.mp3","charTypeName":"word"},{"id":87895,"position":4,"arabic":"فَأْذَنُوا۟","translation":"তোমরা তবে ঘোষণা শুনে রাখো","audioUrl":"wbw/002_279_004.mp3","charTypeName":"word"},{"id":87896,"position":5,"arabic":"بِحَرْبٍۢ","translation":"যুদ্ধের (বিষয়ে)","audioUrl":"wbw/002_279_005.mp3","charTypeName":"word"},{"id":87897,"position":6,"arabic":"مِّنَ","translation":"পক্ষ হতে","audioUrl":"wbw/002_279_006.mp3","charTypeName":"word"},{"id":87898,"position":7,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/002_279_007.mp3","charTypeName":"word"},{"id":87899,"position":8,"arabic":"وَرَسُولِهِۦ ۖ","translation":"ও তাঁর রাসূল","audioUrl":"wbw/002_279_008.mp3","charTypeName":"word"},{"id":87901,"position":9,"arabic":"وَإِن","translation":"আর যদি","audioUrl":"wbw/002_279_010.mp3","charTypeName":"word"},{"id":87902,"position":10,"arabic":"تُبْتُمْ","translation":"তোমরা তওবা কর","audioUrl":"wbw/002_279_011.mp3","charTypeName":"word"},{"id":87903,"position":11,"arabic":"فَلَكُمْ","translation":"তবে (থাকবে) তোমাদের জন্য","audioUrl":"wbw/002_279_012.mp3","charTypeName":"word"},{"id":87904,"position":12,"arabic":"رُءُوسُ","translation":"মূলধন","audioUrl":"wbw/002_279_013.mp3","charTypeName":"word"},{"id":87905,"position":13,"arabic":"أَمْوَٰلِكُمْ","translation":"তোমাদের সম্পদের","audioUrl":"wbw/002_279_014.mp3","charTypeName":"word"},{"id":87906,"position":14,"arabic":"لَا","translation":"না","audioUrl":"wbw/002_279_015.mp3","charTypeName":"word"},{"id":87907,"position":15,"arabic":"تَظْلِمُونَ","translation":"তোমরা অবিচার করো","audioUrl":"wbw/002_279_016.mp3","charTypeName":"word"},{"id":87908,"position":16,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/002_279_017.mp3","charTypeName":"word"},{"id":87909,"position":17,"arabic":"تُظْلَمُونَ","translation":"অবিচার করা হবে (তোমাদের উপর)","audioUrl":"wbw/002_279_018.mp3","charTypeName":"word"},{"id":87910,"position":18,"arabic":"٢٧٩","translation":"(২৭৯)","audioUrl":null,"charTypeName":"end"}]},{"number":280,"arabic":"وَإِن كَانَ ذُو عُسْرَةٍۢ فَنَظِرَةٌ إِلَىٰ مَيْسَرَةٍۢ ۚ وَأَن تَصَدَّقُوا۟ خَيْرٌۭ لَّكُمْ ۖ إِن كُنتُمْ تَعْلَمُونَ","translation":"If, however, [the debtor] is in straitened circumstances, [grant him] a delay until a time of ease; and it would be for your own good -if you but knew it -to remit [the debt entirely] by way of charity.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/287.mp3","surahId":2,"words":[{"id":87911,"position":1,"arabic":"وَإِن","translation":"এবং যদি","audioUrl":"wbw/002_280_001.mp3","charTypeName":"word"},{"id":87912,"position":2,"arabic":"كَانَ","translation":"হয় (খাতক)","audioUrl":"wbw/002_280_002.mp3","charTypeName":"word"},{"id":87913,"position":3,"arabic":"ذُو","translation":"(একটি)","audioUrl":"wbw/002_280_003.mp3","charTypeName":"word"},{"id":87914,"position":4,"arabic":"عُسْرَةٍۢ","translation":"অভাবগ্রস্ত","audioUrl":"wbw/002_280_004.mp3","charTypeName":"word"},{"id":87915,"position":5,"arabic":"فَنَظِرَةٌ","translation":"অবসর তবে দেবে","audioUrl":"wbw/002_280_005.mp3","charTypeName":"word"},{"id":87916,"position":6,"arabic":"إِلَىٰ","translation":"পর্যন্ত","audioUrl":"wbw/002_280_006.mp3","charTypeName":"word"},{"id":87917,"position":7,"arabic":"مَيْسَرَةٍۢ ۚ","translation":"সচ্ছলতা","audioUrl":"wbw/002_280_007.mp3","charTypeName":"word"},{"id":87919,"position":8,"arabic":"وَأَن","translation":"এবং যে","audioUrl":"wbw/002_280_009.mp3","charTypeName":"word"},{"id":87920,"position":9,"arabic":"تَصَدَّقُوا۟","translation":"তোমদের সদকা করে দেওয়া","audioUrl":"wbw/002_280_010.mp3","charTypeName":"word"},{"id":87921,"position":10,"arabic":"خَيْرٌۭ","translation":"উত্তম","audioUrl":"wbw/002_280_011.mp3","charTypeName":"word"},{"id":87922,"position":11,"arabic":"لَّكُمْ ۖ","translation":"তোমাদের জন্য","audioUrl":"wbw/002_280_012.mp3","charTypeName":"word"},{"id":87924,"position":12,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/002_280_014.mp3","charTypeName":"word"},{"id":87925,"position":13,"arabic":"كُنتُمْ","translation":"তোমরা ছিলে","audioUrl":"wbw/002_280_015.mp3","charTypeName":"word"},{"id":87926,"position":14,"arabic":"تَعْلَمُونَ","translation":"তোমরা জানতে","audioUrl":"wbw/002_280_016.mp3","charTypeName":"word"},{"id":87927,"position":15,"arabic":"٢٨٠","translation":"(২৮০)","audioUrl":null,"charTypeName":"end"}]},{"number":281,"arabic":"وَٱتَّقُوا۟ يَوْمًۭا تُرْجَعُونَ فِيهِ إِلَى ٱللَّهِ ۖ ثُمَّ تُوَفَّىٰ كُلُّ نَفْسٍۢ مَّا كَسَبَتْ وَهُمْ لَا يُظْلَمُونَ","translation":"And be conscious of the Day on which you shall be brought back unto God, whereupon every human being shall be repaid in full for what he has earned, and none shall be wronged.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/288.mp3","surahId":2,"words":[{"id":87928,"position":1,"arabic":"وَٱتَّقُوا۟","translation":"এবং তোমরা ভয় করো","audioUrl":"wbw/002_281_001.mp3","charTypeName":"word"},{"id":87929,"position":2,"arabic":"يَوْمًۭا","translation":"সে দিনের","audioUrl":"wbw/002_281_002.mp3","charTypeName":"word"},{"id":87930,"position":3,"arabic":"تُرْجَعُونَ","translation":"তোমরা প্রত্যাবর্তিত হবে","audioUrl":"wbw/002_281_003.mp3","charTypeName