d"},{"id":66406,"position":4,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশের","audioUrl":"wbw/023_086_004.mp3","charTypeName":"word"},{"id":66407,"position":5,"arabic":"ٱلسَّبْعِ","translation":"সাত","audioUrl":"wbw/023_086_005.mp3","charTypeName":"word"},{"id":66408,"position":6,"arabic":"وَرَبُّ","translation":"ও রব","audioUrl":"wbw/023_086_006.mp3","charTypeName":"word"},{"id":66409,"position":7,"arabic":"ٱلْعَرْشِ","translation":"আরশের","audioUrl":"wbw/023_086_007.mp3","charTypeName":"word"},{"id":66410,"position":8,"arabic":"ٱلْعَظِيمِ","translation":"মহান\"","audioUrl":"wbw/023_086_008.mp3","charTypeName":"word"},{"id":66411,"position":9,"arabic":"٨٦","translation":"(৮৬)","audioUrl":null,"charTypeName":"end"}]},{"number":87,"arabic":"سَيَقُولُونَ لِلَّهِ ۚ قُلْ أَفَلَا تَتَّقُونَ","translation":"[And] they will reply: “[All this power belongs] to God.” Say: “Will you not, then, remain conscious of Him?”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2760.mp3","surahId":23,"words":[{"id":66739,"position":1,"arabic":"سَيَقُولُونَ","translation":"তারা বলবে","audioUrl":"wbw/023_087_001.mp3","charTypeName":"word"},{"id":66740,"position":2,"arabic":"لِلَّهِ ۚ","translation":"\"জন্যে আল্লাহর (উলুহিয়াত)\"","audioUrl":"wbw/023_087_002.mp3","charTypeName":"word"},{"id":66742,"position":3,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/023_087_004.mp3","charTypeName":"word"},{"id":66743,"position":4,"arabic":"أَفَلَا","translation":"\"কি তবুও না","audioUrl":"wbw/023_087_005.mp3","charTypeName":"word"},{"id":66744,"position":5,"arabic":"تَتَّقُونَ","translation":"তোমরা ভয় করবে\"","audioUrl":"wbw/023_087_006.mp3","charTypeName":"word"},{"id":66745,"position":6,"arabic":"٨٧","translation":"(৮৭)","audioUrl":null,"charTypeName":"end"}]},{"number":88,"arabic":"قُلْ مَنۢ بِيَدِهِۦ مَلَكُوتُ كُلِّ شَىْءٍۢ وَهُوَ يُجِيرُ وَلَا يُجَارُ عَلَيْهِ إِن كُنتُمْ تَعْلَمُونَ","translation":"Say: “In whose hand rests the mighty dominion over all things, and who is it