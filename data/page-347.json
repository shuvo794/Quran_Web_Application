{"id":347,"ayahs":[{"number":75,"arabic":"۞ وَلَوْ رَحِمْنَٰهُمْ وَكَشَفْنَا مَا بِهِم مِّن ضُرٍّۢ لَّلَجُّوا۟ فِى طُغْيَٰنِهِمْ يَعْمَهُونَ","translation":"And even were We to show them mercy and remove whatever distress might befall them [in this life], they would still persist in their overweening arrogance, blindly stumbling to and fro.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2748.mp3","surahId":23,"words":[{"id":62278,"position":1,"arabic":"۞ وَلَوْ","translation":"আর যদি","audioUrl":"wbw/023_075_002.mp3","charTypeName":"word"},{"id":62279,"position":2,"arabic":"رَحِمْنَـٰهُمْ","translation":"তাদেরকে আমরা দয়া করি","audioUrl":"wbw/023_075_003.mp3","charTypeName":"word"},{"id":62280,"position":3,"arabic":"وَكَشَفْنَا","translation":"ও আমরা দূর করে দিই","audioUrl":"wbw/023_075_004.mp3","charTypeName":"word"},{"id":62281,"position":4,"arabic":"مَا","translation":"যা (আছে)","audioUrl":"wbw/023_075_005.mp3","charTypeName":"word"},{"id":62282,"position":5,"arabic":"بِهِم","translation":"উপর তাদের","audioUrl":"wbw/023_075_006.mp3","charTypeName":"word"},{"id":62283,"position":6,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/023_075_007.mp3","charTypeName":"word"},{"id":62284,"position":7,"arabic":"ضُرٍّۢ","translation":"দুঃখ কষ্ট (তবুও)","audioUrl":"wbw/023_075_008.mp3","charTypeName":"word"},{"id":62285,"position":8,"arabic":"لَّلَجُّوا۟","translation":"লেগে থাকবেই তারা","audioUrl":"wbw/023_075_009.mp3","charTypeName":"word"},{"id":62286,"position":9,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/023_075_010.mp3","charTypeName":"word"},{"id":62287,"position":10,"arabic":"طُغْيَـٰنِهِمْ","translation":"তাদের অবাধ্যতার","audioUrl":"wbw/023_075_011.mp3","charTypeName":"word"},{"id":62288,"position":11,"arabic":"يَعْمَهُونَ","translation":"দিশেহারা হয়ে ঘুরবে","audioUrl":"wbw/023_075_012.mp3","charTypeName":"word"},{"id":62289,"position":12,"arabic":"٧٥","translation":"(৭৫)","audioUrl":null,"charTypeName":"end"}]},{"number":76,"arabic":"وَلَقَدْ أَخَذْنَٰهُم بِٱلْعَذَابِ فَمَا ٱسْتَكَانُوا۟ لِرَبِّهِمْ وَمَا يَتَضَرَّعُونَ","translation":"And, indeed, We tested them through suffer­ing, but they did not abase themselves before their Sustainer; and they will never humble them­selves","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2749.mp3","surahId":23,"words":[{"id":62426,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/023_076_001.mp3","charTypeName":"word"},{"id":62427,"position":2,"arabic":"أَخَذْنَـٰهُم","translation":"তাদেরকে আমরা ধরেছি","audioUrl":"wbw/023_076_002.mp3","charTypeName":"word"},{"id":62428,"position":3,"arabic":"بِٱلْعَذَابِ","translation":"দিয়ে শাস্তি","audioUrl":"wbw/023_076_003.mp3","charTypeName":"word"},{"id":62429,"position":4,"arabic":"فَمَا","translation":"কিন্তু না","audioUrl":"wbw/023_076_004.mp3","charTypeName":"word"},{"id":62430,"position":5,"arabic":"ٱسْتَكَانُوا۟","translation":"তারা বিনত হলো","audioUrl":"wbw/023_076_005.mp3","charTypeName":"word"},{"id":62431,"position":6,"arabic":"لِرَبِّهِمْ","translation":"প্রতি তাদের রবের","audioUrl":"wbw/023_076_006.mp3","charTypeName":"word"},{"id":62432,"position":7,"arabic":"وَمَا","translation":"আর না","audioUrl":"wbw/023_076_007.mp3","charTypeName":"word"},{"id":62433,"position":8,"arabic":"يَتَضَرَّعُونَ","translation":"তারা কাতর প্রার্থনা করলো","audioUrl":"wbw/023_076_008.mp3","charTypeName":"word"},{"id":62434,"position":9,"arabic":"٧٦","translation":"(৭৬)","audioUrl":null,"charTypeName":"end"}]},{"number":77,"arabic":"حَتَّىٰٓ إِذَا فَتَحْنَا عَلَيْهِم بَابًۭا ذَا عَذَابٍۢ شَدِيدٍ إِذَا هُمْ فِيهِ مُبْلِسُونَ","translation":"until We open before them a gate of [truly] severe suffering [in the life to come]: and then, lo! they will be broken in spirit.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2750.mp3","surahId":23,"words":[{"id":63184,"position":1,"arabic":"حَتَّىٰٓ","translation":"শেষ পর্যন্ত","audioUrl":"wbw/023_077_001.mp3","charTypeName":"word"},{"id":63185,"position":2,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/023_077_002.mp3","charTypeName":"word"},{"id":63186,"position":3,"arabic":"فَتَحْنَا","translation":"আমরা খুলে দিই","audioUrl":"wbw/023_077_003.mp3","charTypeName":"word"},{"id":63187,"position":4,"arabic":"عَلَيْهِم","translation":"তাদের উপর","audioUrl":"wbw/023_077_004.mp3","charTypeName":"word"},{"id":63188,"position":5,"arabic":"بَابًۭا","translation":"দরজা","audioUrl":"wbw/023_077_005.mp3","charTypeName":"word"},{"id":63189,"position":6,"arabic":"ذَا","translation":"সম্পন্ন","audioUrl":"wbw/023_077_006.mp3","charTypeName":"word"},{"id":63190,"position":7,"arabic":"عَذَابٍۢ","translation":"শাস্তি","audioUrl":"wbw/023_077_007.mp3","charTypeName":"word"},{"id":63191,"position":8,"arabic":"شَدِيدٍ","translation":"কঠিন","audioUrl":"wbw/023_077_008.mp3","charTypeName":"word"},{"id":63192,"position":9,"arabic":"إِذَا","translation":"তখন","audioUrl":"wbw/023_077_009.mp3","charTypeName":"word"},{"id":63193,"position":10,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/023_077_010.mp3","charTypeName":"word"},{"id":63194,"position":11,"arabic":"فِيهِ","translation":"তারা মধ্যে","audioUrl":"wbw/023_077_011.mp3","charTypeName":"word"},{"id":63195,"position":12,"arabic":"مُبْلِسُونَ","translation":"হতাশ হয়ে পড়বে","audioUrl":"wbw/023_077_012.mp3","charTypeName":"word"},{"id":63196,"position":13,"arabic":"٧٧","translation":"(৭৭)","audioUrl":null,"charTypeName":"end"}]},{"number":78,"arabic":"وَهُوَ ٱلَّذِىٓ أَنشَأَ لَكُمُ ٱلسَّمْعَ وَٱلْأَبْصَٰرَ وَٱلْأَفْـِٔدَةَ ۚ قَلِيلًۭا مَّا تَشْكُرُونَ","translation":"[O MEN! Pay heed to God’s messages,] for it is He who has endowed you with hearing, and sight, and minds: [yet] how seldom are you grateful!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2751.mp3","surahId":23,"words":[{"id":63428,"position":1,"arabic":"وَهُوَ","translation":"এবং তিনিই (আল্লাহ)","audioUrl":"wbw/023_078_001.mp3","charTypeName":"word"},{"id":63429,"position":2,"arabic":"ٱلَّذِىٓ","translation":"যিনি","audioUrl":"wbw/023_078_002.mp3","charTypeName":"word"},{"id":63430,"position":3,"arabic":"أَنشَأَ","translation":"সৃষ্টি করেছেন","audioUrl":"wbw/023_078_003.mp3","charTypeName":"word"},{"id":63431,"position":4,"arabic":"لَكُمُ","translation":"জন্যে তোমাদের","audioUrl":"wbw/023_078_004.mp3","charTypeName":"word"},{"id":63432,"position":5,"arabic":"ٱلسَّمْعَ","translation":"(শ্রবণশক্তির) কান","audioUrl":"wbw/023_078_005.mp3","charTypeName":"word"},{"id":63433,"position":6,"arabic":"وَٱلْأَبْصَـٰرَ","translation":"ও (দর্শনশক্তির) চোখ","audioUrl":"wbw/023_078_006.mp3","charTypeName":"word"},{"id":63434,"position":7,"arabic":"وَٱلْأَفْـِٔدَةَ ۚ","translation":"হৃদয়","audioUrl":"wbw/023_078_007.mp3","charTypeName":"word"},{"id":63436,"position":8,"arabic":"قَلِيلًۭا","translation":"কমই","audioUrl":"wbw/023_078_009.mp3","charTypeName":"word"},{"id":63437,"position":9,"arabic":"مَّا","translation":"যা","audioUrl":"wbw/023_078_010.mp3","charTypeName":"word"},{"id":63438,"position":10,"arabic":"تَشْكُرُونَ","translation":"তোমরা কৃতজ্ঞতা প্রকাশ করো","audioUrl":"wbw/023_078_011.mp3","charTypeName":"word"},{"id":63439,"position":11,"arabic":"٧٨","translation":"(৭৮)","audioUrl":null,"charTypeName":"end"}]},{"number":79,"arabic":"وَهُوَ ٱلَّذِى ذَرَأَكُمْ فِى ٱلْأَرْضِ وَإِلَيْهِ تُحْشَرُونَ","translation":"And He it is who has caused you to multiply on earth; and unto Him you shall be gathered.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2752.mp3","surahId":23,"words":[{"id":63770,"position":1,"arabic":"وَهُوَ","translation":"এবং তিনিই (আল্লাহ)","audioUrl":"wbw/023_079_001.mp3","charTypeName":"word"},{"id":63771,"position":2,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/023_079_002.mp3","charTypeName":"word"},{"id":63772,"position":3,"arabic":"ذَرَأَكُمْ","translation":"তোমাদেরকে ছড়িয়ে দিয়েছেন","audioUrl":"wbw/023_079_003.mp3","charTypeName":"word"},{"id":63773,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/023_079_004.mp3","charTypeName":"word"},{"id":63774,"position":5,"arabic":"ٱلْأَرْضِ","translation":"জমিনের","audioUrl":"wbw/023_079_005.mp3","charTypeName":"word"},{"id":63775,"position":6,"arabic":"وَإِلَيْهِ","translation":"আর তাঁরই দিকে","audioUrl":"wbw/023_079_006.mp3","charTypeName":"word"},{"id":63776,"position":7,"arabic":"تُحْشَرُونَ","translation":"তোমাদেরকে একত্র করা হবে","audioUrl":"wbw/023_079_007.mp3","charTypeName":"word"},{"id":63777,"position":8,"arabic":"٧٩","translation":"(৭৯)","audioUrl":null,"charTypeName":"end"}]},{"number":80,"arabic":"وَهُوَ ٱلَّذِى يُحْىِۦ وَيُمِيتُ وَلَهُ ٱخْتِلَٰفُ ٱلَّيْلِ وَٱلنَّهَارِ ۚ أَفَلَا تَعْقِلُونَ","translation":"And He it is who grants life and deals death; and to Him is due the alternation of night and day. Will you not, then, use your reason?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2753.mp3","surahId":23,"words":[{"id":64378,"position":1,"arabic":"وَهُوَ","translation":"এবং তিনিই (আল্লাহ)","audioUrl":"wbw/023_080_001.mp3","charTypeName":"word"},{"id":64379,"position":2,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/023_080_002.mp3","charTypeName":"word"},{"id":64380,"position":3,"arabic":"يُحْىِۦ","translation":"জীবনদান করেন","audioUrl":"wbw/023_080_003.mp3","charTypeName":"word"},{"id":64381,"position":4,"arabic":"وَيُمِيتُ","translation":"ও মৃত্যু দেন","audioUrl":"wbw/023_080_004.mp3","charTypeName":"word"},{"id":64382,"position":5,"arabic":"وَلَهُ","translation":"আর  রয়েছে তাঁরই (কর্তৃত্ব)","audioUrl":"wbw/023_080_005.mp3","charTypeName":"word"},{"id":64383,"position":6,"arabic":"ٱخْتِلَـٰفُ","translation":"আবর্তন","audioUrl":"wbw/023_080_006.mp3","charTypeName":"word"},{"id":64384,"position":7,"arabic":"ٱلَّيْلِ","translation":"রাতের","audioUrl":"wbw/023_080_007.mp3","charTypeName":"word"},{"id":64385,"position":8,"arabic":"وَٱلنَّهَارِ ۚ","translation":"ও দিনের","audioUrl":"wbw/023_080_008.mp3","charTypeName":"word"},{"id":64387,"position":9,"arabic":"أَفَلَا","translation":"কি তবুও না","audioUrl":"wbw/023_080_010.mp3","charTypeName":"word"},{"id":64388,"position":10,"arabic":"تَعْقِلُونَ","translation":"তোমরা বুঝবে","audioUrl":"wbw/023_080_011.mp3","charTypeName":"word"},{"id":64389,"position":11,"arabic":"٨٠","translation":"(৮০)","audioUrl":null,"charTypeName":"end"}]},{"number":81,"arabic":"بَلْ قَالُوا۟ مِثْلَ مَا قَالَ ٱلْأَوَّلُونَ","translation":"But nay, they speak as the people of olden times did speak:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2754.mp3","surahId":23,"words":[{"id":64860,"position":1,"arabic":"بَلْ","translation":"বরং","audioUrl":"wbw/023_081_001.mp3","charTypeName":"word"},{"id":64861,"position":2,"arabic":"قَالُوا۟","translation":"তারা বলে","audioUrl":"wbw/023_081_002.mp3","charTypeName":"word"},{"id":64862,"position":3,"arabic":"مِثْلَ","translation":"তেমনই","audioUrl":"wbw/023_081_003.mp3","charTypeName":"word"},{"id":64863,"position":4,"arabic":"مَا","translation":"যা","audioUrl":"wbw/023_081_004.mp3","charTypeName":"word"},{"id":64864,"position":5,"arabic":"قَالَ","translation":"বলেছিলো","audioUrl":"wbw/023_081_005.mp3","charTypeName":"word"},{"id":64865,"position":6,"arabic":"ٱلْأَوَّلُونَ","translation":"পূর্ববর্তীরা","audioUrl":"wbw/023_081_006.mp3","charTypeName":"word"},{"id":64866,"position":7,"arabic":"٨١","translation":"(৮১)","audioUrl":null,"charTypeName":"end"}]},{"number":82,"arabic":"قَالُوٓا۟ أَءِذَا مِتْنَا وَكُنَّا تُرَابًۭا وَعِظَٰمًا أَءِنَّا لَمَبْعُوثُونَ","translation":"they say: “What! After we have died and become mere dust and bones, shall we, forsooth, be raised from the dead?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2755.mp3","surahId":23,"words":[{"id":65052,"position":1,"arabic":"قَالُوٓا۟","translation":"তারা বলে","audioUrl":"wbw/023_082_001.mp3","charTypeName":"word"},{"id":65053,"position":2,"arabic":"أَءِذَا","translation":"\"কি যখন","audioUrl":"wbw/023_082_002.mp3","charTypeName":"word"},{"id":65054,"position":3,"arabic":"مِتْنَا","translation":"আমরা মরে যাবো","audioUrl":"wbw/023_082_003.mp3","charTypeName":"word"},{"id":65055,"position":4,"arabic":"وَكُنَّا","translation":"ও আমরা হয়ে যাবো","audioUrl":"wbw/023_082_004.mp3","charTypeName":"word"},{"id":65056,"position":5,"arabic":"تُرَابًۭا","translation":"মাটি","audioUrl":"wbw/023_082_005.mp3","charTypeName":"word"},{"id":65057,"position":6,"arabic":"وَعِظَـٰمًا","translation":"ও হাড়","audioUrl":"wbw/023_082_006.mp3","charTypeName":"word"},{"id":65058,"position":7,"arabic":"أَءِنَّا","translation":"কি নিশ্চয়ই আমরা","audioUrl":"wbw/023_082_007.mp3","charTypeName":"word"},{"id":65059,"position":8,"arabic":"لَمَبْعُوثُونَ","translation":"অবশ্যই উত্থিত হবো","audioUrl":"wbw/023_082_008.mp3","charTypeName":"word"},{"id":65060,"position":9,"arabic":"٨٢","translation":"(৮২)","audioUrl":null,"charTypeName":"end"}]},{"number":83,"arabic":"لَقَدْ وُعِدْنَا نَحْنُ وَءَابَآؤُنَا هَٰذَا مِن قَبْلُ إِنْ هَٰذَآ إِلَّآ أَسَٰطِيرُ ٱلْأَوَّلِينَ","translation":"Indeed, this [very thing] we have been promised - we and our forefathers - long ago! This is nothing but fables of ancient times!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2756.mp3","surahId":23,"words":[{"id":65507,"position":1,"arabic":"لَقَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/023_083_001.mp3","charTypeName":"word"},{"id":65508,"position":2,"arabic":"وُعِدْنَا","translation":"প্রতিশ্রুতি দেয়া হয়েছে","audioUrl":"wbw/023_083_002.mp3","charTypeName":"word"},{"id":65509,"position":3,"arabic":"نَحْنُ","translation":"আমরা (আমাদেরকে)","audioUrl":"wbw/023_083_003.mp3","charTypeName":"word"},{"id":65510,"position":4,"arabic":"وَءَابَآؤُنَا","translation":"ও আমাদের পূর্ব পুরুষদেরকে","audioUrl":"wbw/023_083_004.mp3","charTypeName":"word"},{"id":65511,"position":5,"arabic":"هَـٰذَا","translation":"এটা","audioUrl":"wbw/023_083_005.mp3","charTypeName":"word"},{"id":65512,"position":6,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/023_083_006.mp3","charTypeName":"word"},{"id":65513,"position":7,"arabic":"قَبْلُ","translation":"ইতিপূর্ব","audioUrl":"wbw/023_083_007.mp3","charTypeName":"word"},{"id":65514,"position":8,"arabic":"إِنْ","translation":"নয়","audioUrl":"wbw/023_083_008.mp3","charTypeName":"word"},{"id":65515,"position":9,"arabic":"هَـٰذَآ","translation":"এটা","audioUrl":"wbw/023_083_009.mp3","charTypeName":"word"},{"id":65516,"position":10,"arabic":"إِلَّآ","translation":"এ ছাড়া","audioUrl":"wbw/023_083_010.mp3","charTypeName":"word"},{"id":65517,"position":11,"arabic":"أَسَـٰطِيرُ","translation":"উপকথা","audioUrl":"wbw/023_083_011.mp3","charTypeName":"word"},{"id":65518,"position":12,"arabic":"ٱلْأَوَّلِينَ","translation":"পূর্ববর্তীদের\"","audioUrl":"wbw/023_083_012.mp3","charTypeName":"word"},{"id":65519,"position":13,"arabic":"٨٣","translation":"(৮৩)","audioUrl":null,"charTypeName":"end"}]},{"number":84,"arabic":"قُل لِّمَنِ ٱلْأَرْضُ وَمَن فِيهَآ إِن كُنتُمْ تَعْلَمُونَ","translation":"Say: “Unto whom belongs the earth and all that lives there on? [Tell me this] if you happen to know [the answer]!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2757.mp3","surahId":23,"words":[{"id":65891,"position":1,"arabic":"قُل","translation":"বলো","audioUrl":"wbw/023_084_001.mp3","charTypeName":"word"},{"id":65892,"position":2,"arabic":"لِّمَنِ","translation":"\"জন্যে কার (মালিকানায়)","audioUrl":"wbw/023_084_002.mp3","charTypeName":"word"},{"id":65893,"position":3,"arabic":"ٱلْأَرْضُ","translation":"(এই) পৃথিবী","audioUrl":"wbw/023_084_003.mp3","charTypeName":"word"},{"id":65894,"position":4,"arabic":"وَمَن","translation":"ও যা কিছু (আছে)","audioUrl":"wbw/023_084_004.mp3","charTypeName":"word"},{"id":65895,"position":5,"arabic":"فِيهَآ","translation":"তার মধ্যে","audioUrl":"wbw/023_084_005.mp3","charTypeName":"word"},{"id":65896,"position":6,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/023_084_006.mp3","charTypeName":"word"},{"id":65897,"position":7,"arabic":"كُنتُمْ","transl