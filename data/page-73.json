{"id":73,"ayahs":[{"number":174,"arabic":"فَٱنقَلَبُوا۟ بِنِعْمَةٍۢ مِّنَ ٱللَّهِ وَفَضْلٍۢ لَّمْ يَمْسَسْهُمْ سُوٓءٌۭ وَٱتَّبَعُوا۟ رِضْوَٰنَ ٱللَّهِ ۗ وَٱللَّهُ ذُو فَضْلٍ عَظِيمٍ","translation":"- and returned [from the battle] with God's blessings and bounty, without having been touched by evil: for they had been striving after God's goodly acceptance - and God is limitless in His great bounty.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/467.mp3","surahId":3,"words":[{"id":83269,"position":1,"arabic":"فَٱنقَلَبُوا۟","translation":"তারা ফলে ফিরে এল","audioUrl":"wbw/003_174_001.mp3","charTypeName":"word"},{"id":83270,"position":2,"arabic":"بِنِعْمَةٍۢ","translation":"অবদানে","audioUrl":"wbw/003_174_002.mp3","charTypeName":"word"},{"id":83271,"position":3,"arabic":"مِّنَ","translation":"(থেকে)","audioUrl":"wbw/003_174_003.mp3","charTypeName":"word"},{"id":83272,"position":4,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/003_174_004.mp3","charTypeName":"word"},{"id":83273,"position":5,"arabic":"وَفَضْلٍۢ","translation":"ও (তাঁর) অনুগ্রহে","audioUrl":"wbw/003_174_005.mp3","charTypeName":"word"},{"id":83274,"position":6,"arabic":"لَّمْ","translation":"নাই","audioUrl":"wbw/003_174_006.mp3","charTypeName":"word"},{"id":83275,"position":7,"arabic":"يَمْسَسْهُمْ","translation":"তাদের স্পর্শ করে","audioUrl":"wbw/003_174_007.mp3","charTypeName":"word"},{"id":83276,"position":8,"arabic":"سُوٓءٌۭ","translation":"কোন অকল্যাণ","audioUrl":"wbw/003_174_008.mp3","charTypeName":"word"},{"id":83277,"position":9,"arabic":"وَٱتَّبَعُوا۟","translation":"এবং তারা অনুসরণ করেছিল","audioUrl":"wbw/003_174_009.mp3","charTypeName":"word"},{"id":83278,"position":10,"arabic":"رِضْوَٰنَ","translation":"সন্তুষ্টির","audioUrl":"wbw/003_174_010.mp3","charTypeName":"word"},{"id":83279,"position":11,"arabic":"ٱللَّهِ ۗ","translation":"আল্লাহর","audioUrl":"wbw/003_174_011.mp3","charTypeName":"word"},{"id":83281,"position":12,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/003_174_013.mp3","charTypeName":"word"},{"id":83282,"position":13,"arabic":"ذُو","translation":"(একটি)","audioUrl":"wbw/003_174_014.mp3","charTypeName":"word"},{"id":83283,"position":14,"arabic":"فَضْلٍ","translation":"অনুগ্রহশীল","audioUrl":"wbw/003_174_015.mp3","charTypeName":"word"},{"id":83284,"position":15,"arabic":"عَظِيمٍ","translation":"মহান","audioUrl":"wbw/003_174_016.mp3","charTypeName":"word"},{"id":83285,"position":16,"arabic":"١٧٤","translation":"(১৭৪)","audioUrl":null,"charTypeName":"end"}]},{"number":175,"arabic":"إِنَّمَا ذَٰلِكُمُ ٱلشَّيْطَٰنُ يُخَوِّفُ أَوْلِيَآءَهُۥ فَلَا تَخَافُوهُمْ وَخَافُونِ إِن كُنتُم مُّؤْمِنِينَ","translation":"It is but Satan who instils [into you] fear of his allies: so fear them not, but fear Me, if you are [truly] believers!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/468.mp3","surahId":3,"words":[{"id":83311,"position":1,"arabic":"إِنَّمَا","translation":"মূলত","audioUrl":"wbw/003_175_001.mp3","charTypeName":"word"},{"id":83312,"position":2,"arabic":"ذَٰلِكُمُ","translation":"তোমাদের এই","audioUrl":"wbw/003_175_002.mp3","charTypeName":"word"},{"id":83313,"position":3,"arabic":"ٱلشَّيْطَـٰنُ","translation":"শয়তানই","audioUrl":"wbw/003_175_003.mp3","charTypeName":"word"},{"id":83314,"position":4,"arabic":"يُخَوِّفُ","translation":"ভয় দেখায়","audioUrl":"wbw/003_175_004.mp3","charTypeName":"word"},{"id":83315,"position":5,"arabic":"أَوْلِيَآءَهُۥ","translation":"তার বন্ধুদেরকে","audioUrl":"wbw/003_175_005.mp3","charTypeName":"word"},{"id":83316,"position":6,"arabic":"فَلَا","translation":"অতএব না","audioUrl":"wbw/003_175_006.mp3","charTypeName":"word"},{"id":83317,"position":7,"arabic":"تَخَافُوهُمْ","translation":"তোমরা ভয় কর তাদেরকে","audioUrl":"wbw/003_175_007.mp3","charTypeName":"word"},{"id":83318,"position":8,"arabic":"وَخَافُونِ","translation":"বরং আমাকেই তোমরা ভয় কর","audioUrl":"wbw/003_175_008.mp3","charTypeName":"word"},{"id":83319,"position":9,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/003_175_009.mp3","charTypeName":"word"},{"id":83320,"position":10,"arabic":"كُنتُم","translation":"তোমরা হও","audioUrl":"wbw/003_175_010.mp3","charTypeName":"word"},{"id":83321,"position":11,"arabic":"مُّؤْمِنِينَ","translation":"মু'মিন","audioUrl":"wbw/003_175_011.mp3","charTypeName":"word"},{"id":83322,"position":12,"arabic":"١٧٥","translation":"(১৭৫)","audioUrl":null,"charTypeName":"end"}]},{"number":176,"arabic":"وَلَا يَحْزُنكَ ٱلَّذِينَ يُسَٰرِعُونَ فِى ٱلْكُفْرِ ۚ إِنَّهُمْ لَن يَضُرُّوا۟ ٱللَّهَ شَيْـًۭٔا ۗ يُرِيدُ ٱللَّهُ أَلَّا يَجْعَلَ لَهُمْ حَظًّۭا فِى ٱلْءَاخِرَةِ ۖ وَلَهُمْ عَذَابٌ عَظِيمٌ","translation":"And be not grieved by those who vie with one another in denying the truth: verily, they can in no wise harm God. It is God's will that they shall have no share in the [blessings of the] life to come; and tremendous suffering awaits them.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/469.mp3","surahId":3,"words":[{"id":83476,"position":1,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/003_176_001.mp3","charTypeName":"word"},{"id":83477,"position":2,"arabic":"يَحْزُنكَ","translation":"তোমাকে (যেন) চিন্তিত করে","audioUrl":"wbw/003_176_002.mp3","charTypeName":"word"},{"id":83478,"position":3,"arabic":"ٱلَّذِينَ","translation":"(তারা) যারা","audioUrl":"wbw/003_176_003.mp3","charTypeName":"word"},{"id":83479,"position":4,"arabic":"يُسَـٰرِعُونَ","translation":"তৎপর হয়েছে","audioUrl":"wbw/003_176_004.mp3","charTypeName":"word"},{"id":83480,"position":5,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/003_176_005.mp3","charTypeName":"word"},{"id":83481,"position":6,"arabic":"ٱلْكُفْرِ ۚ","translation":"কুফরীর","audioUrl":"wbw/003_176_006.mp3","charTypeName":"word"},{"id":83483,"position":7,"arabic":"إِنَّهُمْ","translation":"তারা নিশ্চয়","audioUrl":"wbw/003_176_008.mp3","charTypeName":"word"},{"id":83484,"position":8,"arabic":"لَن","translation":"কক্ষনো না","audioUrl":"wbw/003_176_009.mp3","charTypeName":"word"},{"id":83485,"position":9,"arabic":"يَضُرُّوا۟","translation":"ক্ষতি করতে পারবে","audioUrl":"wbw/003_176_010.mp3","charTypeName":"word"},{"id":83486,"position":10,"arabic":"ٱللَّهَ","translation":"আল্লাহর","audioUrl":"wbw/003_176_011.mp3","charTypeName":"word"},{"id":83487,"position":11,"arabic":"شَيْـًۭٔا ۗ","translation":"কিছুমাত্রও","audioUrl":"wbw/003_176_012.mp3","charTypeName":"word"},{"id":83489,"position":12,"arabic":"يُرِيدُ","translation":"চান","audioUrl":"wbw/003_176_014.mp3","charTypeName":"word"},{"id":83490,"position":13,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/003_176_015.mp3","charTypeName":"word"},{"id":83491,"position":14,"arabic":"أَلَّا","translation":"যে না","audioUrl":"wbw/003_176_016.mp3","charTypeName":"word"},{"id":83492,"position":15,"arabic":"يَجْعَلَ","translation":"রাখবেন","audioUrl":"wbw/003_176_017.mp3","charTypeName":"word"},{"id":83493,"position":16,"arabic":"لَهُمْ","translation":"তাদের জন্য","audioUrl":"wbw/003_176_018.mp3","charTypeName":"word"},{"id":83494,"position":17,"arabic":"حَظًّۭا","translation":"কোন অংশ","audioUrl":"wbw/003_176_019.mp3","charTypeName":"word"},{"id":83495,"position":18,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/003_176_020.mp3","charTypeName":"word"},{"id":83496,"position":19,"arabic":"ٱلْـَٔاخِرَةِ ۖ","translation":"আখিরাতের","audioUrl":"wbw/003_176_021.mp3","charTypeName":"word"},{"id":83498,"position":20,"arabic":"وَلَهُمْ","translation":"এবং তাদের জন্য রয়েছে","audioUrl":"wbw/003_176_023.mp3","charTypeName":"word"},{"id":83499,"position":21,"arabic":"عَذَابٌ","translation":"শাস্তি","audioUrl":"wbw/003_176_024.mp3","charTypeName":"word"},{"id":83500,"position":22,"arabic":"عَظِيمٌ","translation":"বড় কঠিন","audioUrl":"wbw/003_176_025.mp3","charTypeName":"word"},{"id":83501,"position":23,"arabic":"١٧٦","translation":"(১৭৬)","audioUrl":null,"charTypeName":"end"}]},{"number":177,"arabic":"إِنَّ ٱلَّذِينَ ٱشْتَرَوُا۟ ٱلْكُفْرَ بِٱلْإِيمَٰنِ لَن يَضُرُّوا۟ ٱللَّهَ شَيْـًۭٔا وَلَهُمْ عَذَابٌ أَلِيمٌۭ","translation":"Verily, they who have bought a denial of the truth at the price of faith can in no wise harm God, whereas grievous suffering awaits them.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/470.mp3","surahId":3,"words":[{"id":83570,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়","audioUrl":"wbw/003_177_001.mp3","charTypeName":"word"},{"id":83571,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/003_177_002.mp3","charTypeName":"word"},{"id":83572,"position":3,"arabic":"ٱشْتَرَوُا۟","translation":"ক্রয় করেছে","audioUrl":"wbw/003_177_003.mp3","charTypeName":"word"},{"id":83573,"position":4,"arabic":"ٱلْكُفْرَ","translation":"কুফরীকে","audioUrl":"wbw/003_177_004.mp3","charTypeName":"word"},{"id":83574,"position":5,"arabic":"بِٱلْإِيمَـٰنِ","translation":"ঈমানের বদলে","audioUrl":"wbw/003_177_005.mp3","charTypeName":"word"},{"id":83575,"position":6,"arabic":"لَن","translation":"কক্ষনো না","audioUrl":"wbw/003_177_006.mp3","charTypeName":"word"},{"id":83576,"position":7,"arabic":"يَضُرُّوا۟","translation":"ক্ষতি করতে পারবে","audioUrl":"wbw/003_177_007.mp3","charTypeName":"word"},{"id":83577,"position":8,"arabic":"ٱللَّهَ","translation":"আল্লাহকে","audioUrl":"wbw/003_177_008.mp3","charTypeName":"word"},{"id":83578,"position":9,"arabic":"شَيْـًۭٔا","translation":"কিছুমাত্রও","audioUrl":"wbw/003_177_009.mp3","charTypeName":"word"},{"id":83579,"position":10,"arabic":"وَلَهُمْ","translation":"এবং তাদের জন্য রয়েছে","audioUrl":"wbw/003_177_010.mp3","charTypeName":"word"},{"id":83580,"position":11,"arabic":"عَذَابٌ","translation":"শাস্তি","audioUrl":"wbw/003_177_011.mp3","charTypeName":"word"},{"id":83581,"position":12,"arabic":"أَلِيمٌۭ","translation":"বড়ই কষ্টদায়ক","audioUrl":"wbw/003_177_012.mp3","charTypeName":"word"},{"id":83582,"position":13,"arabic":"١٧٧","translation":"(১৭৭)","audioUrl":null,"charTypeName":"end"}]},{"number":178,"arabic":"وَلَا يَحْسَبَنَّ ٱلَّذِينَ كَفَرُوٓا۟ أَنَّمَا نُمْلِى لَهُمْ خَيْرٌۭ لِّأَنفُسِهِمْ ۚ إِنَّمَا نُمْلِى لَهُمْ لِيَزْدَادُوٓا۟ إِثْمًۭا ۚ وَلَهُمْ عَذَابٌۭ مُّهِينٌۭ","translation":"And they should not think - they who are bent on denying the truth - that Our giving them rein is good for them: We give them rein only to let them grow in sinfulness; and shameful suffering awaits them.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/471.mp3","surahId":3,"words":[{"id":83664,"position":1,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/003_178_001.mp3","charTypeName":"word"},{"id":83665,"position":2,"arabic":"يَحْسَبَنَّ","translation":"(যেন) তারা মনে করে","audioUrl":"wbw/003_178_002.mp3","charTypeName":"word"},{"id":83666,"position":3,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/003_178_003.mp3","charTypeName":"word"},{"id":83667,"position":4,"arabic":"كَفَرُوٓا۟","translation":"কুফরী করেছে","audioUrl":"wbw/003_178_004.mp3","charTypeName":"word"},{"id":83668,"position":5,"arabic":"أَنَّمَا","translation":"এই যে","audioUrl":"wbw/003_178_005.mp3","charTypeName":"word"},{"id":83669,"position":6,"arabic":"نُمْلِى","translation":"আমরা ঢিল দিই","audioUrl":"wbw/003_178_006.mp3","charTypeName":"word"},{"id":83670,"position":7,"arabic":"لَهُمْ","translation":"তাদেরকে","audioUrl":"wbw/003_178_007.mp3","charTypeName":"word"},{"id":83671,"position":8,"arabic":"خَيْرٌۭ","translation":"উত্তম","audioUrl":"wbw/003_178_008.mp3","charTypeName":"word"},{"id":83672,"position":9,"arabic":"لِّأَنفُسِهِمْ ۚ","translation":"তাদের নিজেদের জন্য","audioUrl":"wbw/003_178_009.mp3","charTypeName":"word"},{"id":83674,"position":10,"arabic":"إِنَّمَا","translation":"মূলত","audioUrl":"wbw/003_178_011.mp3","charTypeName":"word"},{"id":83675,"position":11,"arabic":"نُمْلِى","translation":"আমরা ঢিল দিই","audioUrl":"wbw/003_178_012.mp3","charTypeName":"word"},{"id":83676,"position":12,"arabic":"لَهُمْ","translation":"তাদেরকে","audioUrl":"wbw/003_178_013.mp3","charTypeName":"word"},{"id":83677,"position":13,"arabic":"لِيَزْدَادُوٓا۟","translation":"তারা বৃদ্ধি করে যেন","audioUrl":"wbw/003_178_014.mp3","charTypeName":"word"},{"id":83678,"position":14,"arabic":"إِثْمًۭا ۚ","translation":"পাপ","audioUrl":"wbw/003_178_015.mp3","charTypeName":"word"},{"id":83680,"position":15,"arabic":"وَلَهُمْ","translation":"এবং তাদের জন্য (রয়েছে)","audioUrl":"wbw/003_178_017.mp3","charTypeName":"word"},{"id":83681,"position":16,"arabic":"عَذَابٌۭ","translation":"শাস্তি","audioUrl":"wbw/003_178_018.mp3","charTypeName":"word"},{"id":83682,"position":17,"arabic":"مُّهِينٌۭ","translation":"বড় অপমানকর","audioUrl":"wbw/003_178_019.mp3","charTypeName":"word"},{"id":83683,"position":18,"arabic":"١٧٨","translation":"(১৭৮)","audioUrl":null,"charTypeName":"end"}]},{"number":179,"arabic":"مَّا كَانَ ٱللَّهُ لِيَذَرَ ٱلْمُؤْمِنِينَ عَلَىٰ مَآ أَنتُمْ عَلَيْهِ حَتَّىٰ يَمِيزَ ٱلْخَبِيثَ مِنَ ٱلطَّيِّبِ ۗ وَمَا كَانَ ٱللَّهُ لِيُطْلِعَكُمْ عَلَى ٱلْغَيْبِ وَلَٰكِنَّ ٱللَّهَ يَجْتَبِى مِن رُّسُلِهِۦ مَن يَشَآءُ ۖ فَـَٔامِنُوا۟ بِٱللَّهِ وَرُسُلِهِۦ ۚ وَإِن تُؤْمِنُوا۟ وَتَتَّقُوا۟ فَلَكُمْ أَجْرٌ عَظِيمٌۭ","translation":"It is not God's will [O you who deny the truth] to abandon the believers to your way of life: [and] to that end He will set apart the bad from the good. And it is not God's will to give you insight into that which is beyond the reach of human perception: but [to that end] God elects whomsoever He wills from among His apostles. Believe, then, in God and His apostles; for if you believe and are conscious of Him, a magnificent requital awaits you.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/472.mp3","surahId":3,"words":[{"id":83684,"position":1,"arabic":"مَّا","translation":"নয়","audioUrl":"wbw/003_179_001.mp3","charTypeName":"word"},{"id":83685,"position":2,"arabic":"كَانَ","translation":"(পদ্ধতি)","audioUrl":"wbw/003_179_002.mp3","charTypeName":"word"},{"id":83686,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহর","audioUrl":"wbw/003_179_003.mp3","charTypeName":"word"},{"id"