rd"},{"id":83721,"position":35,"arabic":"أَجْرٌ","translation":"পুরস্কার (রয়েছে)","audioUrl":"wbw/003_179_038.mp3","charTypeName":"word"},{"id":83722,"position":36,"arabic":"عَظِيمٌۭ","translation":"বিরাট","audioUrl":"wbw/003_179_039.mp3","charTypeName":"word"},{"id":83723,"position":37,"arabic":"١٧٩","translation":"(১৭৯)","audioUrl":null,"charTypeName":"end"}]},{"number":180,"arabic":"وَلَا يَحْسَبَنَّ ٱلَّذِينَ يَبْخَلُونَ بِمَآ ءَاتَىٰهُمُ ٱللَّهُ مِن فَضْلِهِۦ هُوَ خَيْرًۭا لَّهُم ۖ بَلْ هُوَ شَرٌّۭ لَّهُمْ ۖ سَيُطَوَّقُونَ مَا بَخِلُوا۟ بِهِۦ يَوْمَ ٱلْقِيَٰمَةِ ۗ وَلِلَّهِ مِيرَٰثُ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ ۗ وَٱللَّهُ بِمَا تَعْمَلُونَ خَبِيرٌۭ","translation":"AND THEY should not think - they who niggardly cling to all that God has granted them out of His bounty - that this is good for them: nay, it is bad for them. That to which they [so] niggardly cling will, on the Day of Resurrection, be hung about their necks: for unto God [alone] belongs the heritage of the heavens and of the earth; and God is aware of all that you do.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/473.mp3","surahId":3,"words":[{"id":83830,"position":1,"arabic":"وَلَا","translation":"এবং না (যেন)","audioUrl":"wbw/003_180_001.mp3","charTypeName":"word"},{"id":83831,"position":2,"arabic":"يَحْسَبَنَّ","translation":"তারা মনে করে","audioUrl":"wbw/003_180_002.mp3","charTypeName":"word"},{"id":83832,"position":3,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/003_180_003.mp3","charTypeName":"word"},{"id":83833,"position":4,"arabic":"يَبْخَلُونَ","translation":"কৃপণতা করে","audioUrl":"wbw/003_180_004.mp3","charTypeName":"word"},{"id":83834,"position":5,"arabic":"بِمَآ","translation":"যা","audioUrl":"wbw/003_180_005.mp3","charTypeName":"word"},{"id":83835,"position":6,"arabic":"ءَاتَىٰهُمُ","translation":"তাদের দিয়েছেন","audioUrl":"wbw/003_180_006.mp3","charTypeName":"word"},{"id":83836,"position":7,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/003_180