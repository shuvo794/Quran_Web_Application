{"id":313,"ayahs":[{"number":13,"arabic":"وَأَنَا ٱخْتَرْتُكَ فَٱسْتَمِعْ لِمَا يُوحَىٰٓ","translation":"and I have chosen thee [to be My apostle]: listen, then, to what is being revealed [unto thee].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2361.mp3","surahId":20,"words":[{"id":14938,"position":1,"arabic":"وَأَنَا","translation":"এবং আমি","audioUrl":"wbw/020_013_001.mp3","charTypeName":"word"},{"id":14939,"position":2,"arabic":"ٱخْتَرْتُكَ","translation":"তোমাকে বেছে নিয়েছি","audioUrl":"wbw/020_013_002.mp3","charTypeName":"word"},{"id":14940,"position":3,"arabic":"فَٱسْتَمِعْ","translation":"সুতরাং তুমি মনোযোগসহ শুনো","audioUrl":"wbw/020_013_003.mp3","charTypeName":"word"},{"id":14941,"position":4,"arabic":"لِمَا","translation":"তাই যা কিছু","audioUrl":"wbw/020_013_004.mp3","charTypeName":"word"},{"id":14942,"position":5,"arabic":"يُوحَىٰٓ","translation":"ওহী করা হয়","audioUrl":"wbw/020_013_005.mp3","charTypeName":"word"},{"id":14943,"position":6,"arabic":"١٣","translation":"(১৩)","audioUrl":null,"charTypeName":"end"}]},{"number":14,"arabic":"إِنَّنِىٓ أَنَا ٱللَّهُ لَآ إِلَٰهَ إِلَّآ أَنَا۠ فَٱعْبُدْنِى وَأَقِمِ ٱلصَّلَوٰةَ لِذِكْرِىٓ","translation":"\"Verily, I - I alone - am God; there is no deity save Me. Hence, worship Me alone, and be constant in prayer, so as to remember Me!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2362.mp3","surahId":20,"words":[{"id":16004,"position":1,"arabic":"إِنَّنِىٓ","translation":"আমি নিশ্চয়ই","audioUrl":"wbw/020_014_001.mp3","charTypeName":"word"},{"id":16005,"position":2,"arabic":"أَنَا","translation":"আমিই","audioUrl":"wbw/020_014_002.mp3","charTypeName":"word"},{"id":16006,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/020_014_003.mp3","charTypeName":"word"},{"id":16007,"position":4,"arabic":"لَآ","translation":"নেই","audioUrl":"wbw/020_014_004.mp3","charTypeName":"word"},{"id":16008,"position":5,"arabic":"إِلَـٰهَ","translation":"কোন ইলাহ","audioUrl":"wbw/020_014_005.mp3","charTypeName":"word"},{"id":16009,"position":6,"arabic":"إِلَّآ","translation":"ছাড়া","audioUrl":"wbw/020_014_006.mp3","charTypeName":"word"},{"id":16010,"position":7,"arabic":"أَنَا۠","translation":"আমি","audioUrl":"wbw/020_014_007.mp3","charTypeName":"word"},{"id":16011,"position":8,"arabic":"فَٱعْبُدْنِى","translation":"সুতরাং আমারই  ইবাদত করো","audioUrl":"wbw/020_014_008.mp3","charTypeName":"word"},{"id":16012,"position":9,"arabic":"وَأَقِمِ","translation":"এবং প্রতিষ্ঠিত করো","audioUrl":"wbw/020_014_009.mp3","charTypeName":"word"},{"id":16013,"position":10,"arabic":"ٱلصَّلَوٰةَ","translation":"সালাত","audioUrl":"wbw/020_014_010.mp3","charTypeName":"word"},{"id":16014,"position":11,"arabic":"لِذِكْرِىٓ","translation":"আমার স্মরণের জন্যে","audioUrl":"wbw/020_014_011.mp3","charTypeName":"word"},{"id":16015,"position":12,"arabic":"١٤","translation":"(১৪)","audioUrl":null,"charTypeName":"end"}]},{"number":15,"arabic":"إِنَّ ٱلسَّاعَةَ ءَاتِيَةٌ أَكَادُ أُخْفِيهَا لِتُجْزَىٰ كُلُّ نَفْسٍۭ بِمَا تَسْعَىٰ","translation":"\"Behold, [although] I have willed to keep it hidden, the Last Hour is bound to come, so that every human being may be recompensed in accordance with what he strove for [in life].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2363.mp3","surahId":20,"words":[{"id":17234,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/020_015_001.mp3","charTypeName":"word"},{"id":17235,"position":2,"arabic":"ٱلسَّاعَةَ","translation":"ক্বিয়ামাত","audioUrl":"wbw/020_015_002.mp3","charTypeName":"word"},{"id":17236,"position":3,"arabic":"ءَاتِيَةٌ","translation":"আসবেই","audioUrl":"wbw/020_015_003.mp3","charTypeName":"word"},{"id":17237,"position":4,"arabic":"أَكَادُ","translation":"রাখতে চাই আমি","audioUrl":"wbw/020_015_004.mp3","charTypeName":"word"},{"id":17238,"position":5,"arabic":"أُخْفِيهَا","translation":"তা গোপন","audioUrl":"wbw/020_015_005.mp3","charTypeName":"word"},{"id":17239,"position":6,"arabic":"لِتُجْزَىٰ","translation":"যেন প্রতিফল পায়","audioUrl":"wbw/020_015_006.mp3","charTypeName":"word"},{"id":17240,"position":7,"arabic":"كُلُّ","translation":"প্রত্যেক","audioUrl":"wbw/020_015_007.mp3","charTypeName":"word"},{"id":17241,"position":8,"arabic":"نَفْسٍۭ","translation":"ব্যক্তি","audioUrl":"wbw/020_015_008.mp3","charTypeName":"word"},{"id":17242,"position":9,"arabic":"بِمَا","translation":"ঐ বিষয়ের যা","audioUrl":"wbw/020_015_009.mp3","charTypeName":"word"},{"id":17243,"position":10,"arabic":"تَسْعَىٰ","translation":"সে চেষ্টা সাধনা করে","audioUrl":"wbw/020_015_010.mp3","charTypeName":"word"},{"id":17244,"position":11,"arabic":"١٥","translation":"(১৫)","audioUrl":null,"charTypeName":"end"}]},{"number":16,"arabic":"فَلَا يَصُدَّنَّكَ عَنْهَا مَن لَّا يُؤْمِنُ بِهَا وَٱتَّبَعَ هَوَىٰهُ فَتَرْدَىٰ","translation":"Hence, let not anyone who does not believe in its coming and follows [but] his own desires divert thee from [belief in] it, lest thou perish!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2364.mp3","surahId":20,"words":[{"id":18281,"position":1,"arabic":"فَلَا","translation":"সুতরাং না","audioUrl":"wbw/020_016_001.mp3","charTypeName":"word"},{"id":18282,"position":2,"arabic":"يَصُدَّنَّكَ","translation":"তোমাকে নিবৃত্ত করে ( যেন )","audioUrl":"wbw/020_016_002.mp3","charTypeName":"word"},{"id":18283,"position":3,"arabic":"عَنْهَا","translation":"তা থেকে","audioUrl":"wbw/020_016_003.mp3","charTypeName":"word"},{"id":18284,"position":4,"arabic":"مَن","translation":"সেই ব্যক্তি (যে )","audioUrl":"wbw/020_016_004.mp3","charTypeName":"word"},{"id":18285,"position":5,"arabic":"لَّا","translation":"না","audioUrl":"wbw/020_016_005.mp3","charTypeName":"word"},{"id":18286,"position":6,"arabic":"يُؤْمِنُ","translation":"ঈমান আনে","audioUrl":"wbw/020_016_006.mp3","charTypeName":"word"},{"id":18287,"position":7,"arabic":"بِهَا","translation":"তার উপর","audioUrl":"wbw/020_016_007.mp3","charTypeName":"word"},{"id":18288,"position":8,"arabic":"وَٱتَّبَعَ","translation":"এবং অনুসরণ করেছে","audioUrl":"wbw/020_016_008.mp3","charTypeName":"word"},{"id":18289,"position":9,"arabic":"هَوَىٰهُ","translation":"তার প্রবৃত্তির","audioUrl":"wbw/020_016_009.mp3","charTypeName":"word"},{"id":18290,"position":10,"arabic":"فَتَرْدَىٰ","translation":"তাহ'লে তুমি ধ্বংস হবে","audioUrl":"wbw/020_016_010.mp3","charTypeName":"word"},{"id":18291,"position":11,"arabic":"١٦","translation":"(১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":17,"arabic":"وَمَا تِلْكَ بِيَمِينِكَ يَٰمُوسَىٰ","translation":"\"Now, what is this in thy right hand, O Moses?\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2365.mp3","surahId":20,"words":[{"id":19305,"position":1,"arabic":"وَمَا","translation":"এবং ( আল্লাহ বললেন ) কি","audioUrl":"wbw/020_017_001.mp3","charTypeName":"word"},{"id":19306,"position":2,"arabic":"تِلْكَ","translation":"ওটা","audioUrl":"wbw/020_017_002.mp3","charTypeName":"word"},{"id":19307,"position":3,"arabic":"بِيَمِينِكَ","translation":"তোমার ডান হাতের মধ্যে","audioUrl":"wbw/020_017_003.mp3","charTypeName":"word"},{"id":19308,"position":4,"arabic":"يَـٰمُوسَىٰ","translation":"হে মূসা\"","audioUrl":"wbw/020_017_004.mp3","charTypeName":"word"},{"id":19309,"position":5,"arabic":"١٧","translation":"(১৭)","audioUrl":null,"charTypeName":"end"}]},{"number":18,"arabic":"قَالَ هِىَ عَصَاىَ أَتَوَكَّؤُا۟ عَلَيْهَا وَأَهُشُّ بِهَا عَلَىٰ غَنَمِى وَلِىَ فِيهَا مَـَٔارِبُ أُخْرَىٰ","translation":"He answered: \"It is my staff; I lean on it; and with it I beat down leaves for my sheep; and [many] other uses have I for it.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2366.mp3","surahId":20,"words":[{"id":20375,"position":1,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/020_018_001.mp3","charTypeName":"word"},{"id":20376,"position":2,"arabic":"هِىَ","translation":"\"তা","audioUrl":"wbw/020_018_002.mp3","charTypeName":"word"},{"id":20377,"position":3,"arabic":"عَصَاىَ","translation":"আমা