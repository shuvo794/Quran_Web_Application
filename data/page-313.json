w/020_022_010.mp3","charTypeName":"word"},{"id":24680,"position":11,"arabic":"أُخْرَىٰ","translation":"অপর ( একটি )","audioUrl":"wbw/020_022_011.mp3","charTypeName":"word"},{"id":24681,"position":12,"arabic":"٢٢","translation":"(২২)","audioUrl":null,"charTypeName":"end"}]},{"number":23,"arabic":"لِنُرِيَكَ مِنْ ءَايَٰتِنَا ٱلْكُبْرَى","translation":"so that We might make thee aware of some of Our greatest wonders.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2371.mp3","surahId":20,"words":[{"id":25750,"position":1,"arabic":"لِنُرِيَكَ","translation":"তোমাকে যেন আমরা দেখাই","audioUrl":"wbw/020_023_001.mp3","charTypeName":"word"},{"id":25751,"position":2,"arabic":"مِنْ","translation":"মধ্য হ'তে","audioUrl":"wbw/020_023_002.mp3","charTypeName":"word"},{"id":25752,"position":3,"arabic":"ءَايَـٰتِنَا","translation":"আমাদের নিদর্শনাবলীর","audioUrl":"wbw/020_023_003.mp3","charTypeName":"word"},{"id":25753,"position":4,"arabic":"ٱلْكُبْرَى","translation":"বড় বড় ( কয়েকটি )","audioUrl":"wbw/020_023_004.mp3","charTypeName":"word"},{"id":25754,"position":5,"arabic":"٢٣","translation":"(২৩)","audioUrl":null,"charTypeName":"end"}]},{"number":24,"arabic":"ٱذْهَبْ إِلَىٰ فِرْعَوْنَ إِنَّهُۥ طَغَىٰ","translation":"\"[And now] go thou unto Pharaoh: for, verily, he has transgressed all bounds of equity.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2372.mp3","surahId":20,"words":[{"id":26820,"position":1,"arabic":"ٱذْهَبْ","translation":"তুমি যাও","audioUrl":"wbw/020_024_001.mp3","charTypeName":"word"},{"id":26821,"position":2,"arabic":"إِلَىٰ","translation":"কাছে","audioUrl":"wbw/020_024_002.mp3","charTypeName":"word"},{"id":26822,"position":3,"arabic":"فِرْعَوْنَ","translation":"ফিরআউনের","audioUrl":"wbw/020_024_003.mp3","charTypeName":"word"},{"id":26823,"position":4,"arabic":"إِنَّهُۥ","translation":"সে নিশ্চয়ই","audioUrl":"wbw/020_024_004.mp3","charTypeName":"word"},{"id":26824,"position":5,"arabic":"طَغَىٰ","translation":"সীমালঙ্ঘন করেছে\""