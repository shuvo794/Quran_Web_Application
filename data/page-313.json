dioUrl":"wbw/020_019_003.mp3","charTypeName":"word"},{"id":21465,"position":4,"arabic":"١٩","translation":"(১৯)","audioUrl":null,"charTypeName":"end"}]},{"number":20,"arabic":"فَأَلْقَىٰهَا فَإِذَا هِىَ حَيَّةٌۭ تَسْعَىٰ","translation":"So he threw it - and lo! it was a snake, moving rapidly.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2368.mp3","surahId":20,"words":[{"id":22548,"position":1,"arabic":"فَأَلْقَىٰهَا","translation":"অতঃপর তা সে নিক্ষেপ করলো","audioUrl":"wbw/020_020_001.mp3","charTypeName":"word"},{"id":22549,"position":2,"arabic":"فَإِذَا","translation":"সঙ্গে সঙ্গে","audioUrl":"wbw/020_020_002.mp3","charTypeName":"word"},{"id":22550,"position":3,"arabic":"هِىَ","translation":"তা ( হলো )","audioUrl":"wbw/020_020_003.mp3","charTypeName":"word"},{"id":22551,"position":4,"arabic":"حَيَّةٌۭ","translation":"সাপ","audioUrl":"wbw/020_020_004.mp3","charTypeName":"word"},{"id":22552,"position":5,"arabic":"تَسْعَىٰ","translation":"( যা ) ছুটোছুটি করতে লাগলো","audioUrl":"wbw/020_020_005.mp3","charTypeName":"word"},{"id":22553,"position":6,"arabic":"٢٠","translation":"(২০)","audioUrl":null,"charTypeName":"end"}]},{"number":21,"arabic":"قَالَ خُذْهَا وَلَا تَخَفْ ۖ سَنُعِيدُهَا سِيرَتَهَا ٱلْأُولَىٰ","translation":"Said He: \"Take hold of it, and fear not: We shall restore it to its former state.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2369.mp3","surahId":20,"words":[{"id":23711,"position":1,"arabic":"قَالَ","translation":"তিনি বললেন","audioUrl":"wbw/020_021_001.mp3","charTypeName":"word"},{"id":23712,"position":2,"arabic":"خُذْهَا","translation":"\"তা ধরো","audioUrl":"wbw/020_021_002.mp3","charTypeName":"word"},{"id":23713,"position":3,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/020_021_003.mp3","charTypeName":"word"},{"id":23714,"position":4,"arabic":"تَخَفْ ۖ","translation":"ভয় করো তুমি","audioUrl":"wbw/020_021_004.mp3","charTypeName":"word"},{"id":23716,"position":5,"arabic":"سَنُعِيدُهَا","translatio