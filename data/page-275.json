{"id":275,"ayahs":[{"number":73,"arabic":"وَيَعْبُدُونَ مِن دُونِ ٱللَّهِ مَا لَا يَمْلِكُ لَهُمْ رِزْقًۭا مِّنَ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ شَيْـًۭٔا وَلَا يَسْتَطِيعُونَ","translation":"and will they [continue to] worship, instead of God, something that has it not within its power to provide for them any sustenance whatever from the heavens or the earth, and can do nothing at all?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1974.mp3","surahId":16,"words":[{"id":60951,"position":1,"arabic":"وَيَعْبُدُونَ","translation":"এবং তারা উপাসনা করবে (কি)","audioUrl":"wbw/016_073_001.mp3","charTypeName":"word"},{"id":60952,"position":2,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/016_073_002.mp3","charTypeName":"word"},{"id":60953,"position":3,"arabic":"دُونِ","translation":"ছাড়া","audioUrl":"wbw/016_073_003.mp3","charTypeName":"word"},{"id":60954,"position":4,"arabic":"ٱللَّهِ","translation":"আল্লাহর (অন্য কিছুকে)","audioUrl":"wbw/016_073_004.mp3","charTypeName":"word"},{"id":60955,"position":5,"arabic":"مَا","translation":"যা","audioUrl":"wbw/016_073_005.mp3","charTypeName":"word"},{"id":60956,"position":6,"arabic":"لَا","translation":"না","audioUrl":"wbw/016_073_006.mp3","charTypeName":"word"},{"id":60957,"position":7,"arabic":"يَمْلِكُ","translation":"ক্ষমতা রাখে","audioUrl":"wbw/016_073_007.mp3","charTypeName":"word"},{"id":60958,"position":8,"arabic":"لَهُمْ","translation":"জন্যে তাদেন","audioUrl":"wbw/016_073_008.mp3","charTypeName":"word"},{"id":60959,"position":9,"arabic":"رِزْقًۭا","translation":"জীবিকার","audioUrl":"wbw/016_073_009.mp3","charTypeName":"word"},{"id":60960,"position":10,"arabic":"مِّنَ","translation":"থেকে","audioUrl":"wbw/016_073_010.mp3","charTypeName":"word"},{"id":60961,"position":11,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশমন্ডলী","audioUrl":"wbw/016_073_011.mp3","charTypeName":"word"},{"id":60962,"position":12,"arabic":"وَٱلْأَرْضِ","translation":"অথবা পৃথিবী (থেকে)","audioUrl":"wbw/016_073_012.mp3","charTypeName"