n":"(৭৭)","audioUrl":null,"charTypeName":"end"}]},{"number":78,"arabic":"وَٱللَّهُ أَخْرَجَكُم مِّنۢ بُطُونِ أُمَّهَٰتِكُمْ لَا تَعْلَمُونَ شَيْـًۭٔا وَجَعَلَ لَكُمُ ٱلسَّمْعَ وَٱلْأَبْصَٰرَ وَٱلْأَفْـِٔدَةَ ۙ لَعَلَّكُمْ تَشْكُرُونَ","translation":"And God has brought you forth from your mothers' wombs knowing nothing-but He has endowed you with hearing, and sight, and minds, so that you might have cause to be grateful.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1979.mp3","surahId":16,"words":[{"id":63382,"position":1,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ্‌","audioUrl":"wbw/016_078_001.mp3","charTypeName":"word"},{"id":63383,"position":2,"arabic":"أَخْرَجَكُم","translation":"বের করেন তোমাদের","audioUrl":"wbw/016_078_002.mp3","charTypeName":"word"},{"id":63384,"position":3,"arabic":"مِّنۢ","translation":"থেকে","audioUrl":"wbw/016_078_003.mp3","charTypeName":"word"},{"id":63385,"position":4,"arabic":"بُطُونِ","translation":"পেটসমূহ","audioUrl":"wbw/016_078_004.mp3","charTypeName":"word"},{"id":63386,"position":5,"arabic":"أُمَّهَـٰتِكُمْ","translation":"তোমাদের মায়ের (এ অবস্থায় যে)","audioUrl":"wbw/016_078_005.mp3","charTypeName":"word"},{"id":63387,"position":6,"arabic":"لَا","translation":"না","audioUrl":"wbw/016_078_006.mp3","charTypeName":"word"},{"id":63388,"position":7,"arabic":"تَعْلَمُونَ","translation":"তোমরা জানো","audioUrl":"wbw/016_078_007.mp3","charTypeName":"word"},{"id":63389,"position":8,"arabic":"شَيْـًۭٔا","translation":"কিছুই","audioUrl":"wbw/016_078_008.mp3","charTypeName":"word"},{"id":63390,"position":9,"arabic":"وَجَعَلَ","translation":"এবং দিয়েছেন","audioUrl":"wbw/016_078_009.mp3","charTypeName":"word"},{"id":63391,"position":10,"arabic":"لَكُمُ","translation":"জন্যে তোমাদের","audioUrl":"wbw/016_078_010.mp3","charTypeName":"word"},{"id":63392,"position":11,"arabic":"ٱلسَّمْعَ","translation":"শ্রবণশক্তিসমূহ","audioUrl":"wbw/016_078_011.mp3","charTypeName":"word"},{"id":63393,"position":12,"arabic":"وَٱلْأَبْصَـٰرَ