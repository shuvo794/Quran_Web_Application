ion":10,"arabic":"تَعْلَمُونَ","translation":"জানো","audioUrl":"wbw/016_074_011.mp3","charTypeName":"word"},{"id":61393,"position":11,"arabic":"٧٤","translation":"(৭৪)","audioUrl":null,"charTypeName":"end"}]},{"number":75,"arabic":"۞ ضَرَبَ ٱللَّهُ مَثَلًا عَبْدًۭا مَّمْلُوكًۭا لَّا يَقْدِرُ عَلَىٰ شَىْءٍۢ وَمَن رَّزَقْنَٰهُ مِنَّا رِزْقًا حَسَنًۭا فَهُوَ يُنفِقُ مِنْهُ سِرًّۭا وَجَهْرًا ۖ هَلْ يَسْتَوُۥنَ ۚ ٱلْحَمْدُ لِلَّهِ ۚ بَلْ أَكْثَرُهُمْ لَا يَعْلَمُونَ","translation":"God propounds [to you] the parable of [two men-] a man enslaved, unable to do anything of his own accord, and a [free] man upon whom We have bestowed goodly sustenance [as a gift] from Ourselves, so that he can spend thereof [at will, both] secretly and openly. Can these [two] be deemed equal? All praise is due to God [alone]: but most of them do not understand it.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1976.mp3","surahId":16,"words":[{"id":61920,"position":1,"arabic":"۞ ضَرَبَ","translation":"বর্ণনা করছেন","audioUrl":"wbw/016_075_002.mp3","charTypeName":"word"},{"id":61921,"position":2,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌","audioUrl":"wbw/016_075_003.mp3","charTypeName":"word"},{"id":61922,"position":3,"arabic":"مَثَلًا","translation":"উপমা","audioUrl":"wbw/016_075_004.mp3","charTypeName":"word"},{"id":61923,"position":4,"arabic":"عَبْدًۭا","translation":"একজন দাসের","audioUrl":"wbw/016_075_005.mp3","charTypeName":"word"},{"id":61924,"position":5,"arabic":"مَّمْلُوكًۭا","translation":"অপরের অধিকারভুক্ত","audioUrl":"wbw/016_075_006.mp3","charTypeName":"word"},{"id":61925,"position":6,"arabic":"لَّا","translation":"না","audioUrl":"wbw/016_075_007.mp3","charTypeName":"word"},{"id":61926,"position":7,"arabic":"يَقْدِرُ","translation":"সে ক্ষমতা রাখে","audioUrl":"wbw/016_075_008.mp3","charTypeName":"word"},{"id":61927,"position":8,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/016_075_009.mp3","charTypeName":"word"},{"id":61928,"position":9,"arabic":"شَىْءٍۢ"