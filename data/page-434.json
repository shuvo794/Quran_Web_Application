{"id":434,"ayahs":[{"number":49,"arabic":"قُلْ جَآءَ ٱلْحَقُّ وَمَا يُبْدِئُ ٱلْبَٰطِلُ وَمَا يُعِيدُ","translation":"Say: “The truth has now come [to light, and falsehood is bound to wither away]: for, falsehood cannot bring forth anything new, nor can it bring back [what has passed away].”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3655.mp3","surahId":34,"words":[{"id":48281,"position":1,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/034_049_001.mp3","charTypeName":"word"},{"id":48282,"position":2,"arabic":"جَآءَ","translation":"\"এসেছে","audioUrl":"wbw/034_049_002.mp3","charTypeName":"word"},{"id":48283,"position":3,"arabic":"ٱلْحَقُّ","translation":"সত্য","audioUrl":"wbw/034_049_003.mp3","charTypeName":"word"},{"id":48284,"position":4,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/034_049_004.mp3","charTypeName":"word"},{"id":48285,"position":5,"arabic":"يُبْدِئُ","translation":"নতুন সৃষ্টি করতে পারে","audioUrl":"wbw/034_049_005.mp3","charTypeName":"word"},{"id":48286,"position":6,"arabic":"ٱلْبَـٰطِلُ","translation":"অসত্য","audioUrl":"wbw/034_049_006.mp3","charTypeName":"word"},{"id":48287,"position":7,"arabic":"وَمَا","translation":"আর না","audioUrl":"wbw/034_049_007.mp3","charTypeName":"word"},{"id":48288,"position":8,"arabic":"يُعِيدُ","translation":"পুনরাবৃত্তি করতে (অর্থাৎ কিছুই পারে না)\"","audioUrl":"wbw/034_049_008.mp3","charTypeName":"word"},{"id":48289,"position":9,"arabic":"٤٩","translation":"(৪৯)","audioUrl":null,"charTypeName":"end"}]},{"number":50,"arabic":"قُلْ إِن ضَلَلْتُ فَإِنَّمَآ أَضِلُّ عَلَىٰ نَفْسِى ۖ وَإِنِ ٱهْتَدَيْتُ فَبِمَا يُوحِىٓ إِلَىَّ رَبِّىٓ ۚ إِنَّهُۥ سَمِيعٌۭ قَرِيبٌۭ","translation":"Say: “Were I to go astray, I would but go astray [due to my own self, and] to the hurt of myself; but if I am on the right path, it is but by virtue of what my Sustainer reveals unto me: for, verily, He is all-hearing, ever-near!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3656.mp3","surahId":34,"words":[{"id":48476,"position":1,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/034_050_001.mp3","charTypeName":"word"},{"id":48477,"position":2,"arabic":"إِن","translation":"\"যদি","audioUrl":"wbw/034_050_002.mp3","charTypeName":"word"},{"id":48478,"position":3,"arabic":"ضَلَلْتُ","translation":"আমি পথভ্রষ্ট হয়ে থাকি","audioUrl":"wbw/034_050_003.mp3","charTypeName":"word"},{"id":48479,"position":4,"arabic":"فَإِنَّمَآ","translation":"তবে মূলতঃ","audioUrl":"wbw/034_050_004.mp3","charTypeName":"word"},{"id":48480,"position":5,"arabic":"أَضِلُّ","translation":"আমি পথভ্রষ্ট হবো","audioUrl":"wbw/034_050_005.mp3","charTypeName":"word"},{"id":48481,"position":6,"arabic":"عَلَىٰ","translation":"জন্যে","audioUrl":"wbw/034_050_006.mp3","charTypeName":"word"},{"id":48482,"position":7,"arabic":"نَفْسِى ۖ","translation":"আমার নিজের","audioUrl":"wbw/034_050_007.mp3","charTypeName":"word"},{"id":48484,"position":8,"arabic":"وَإِنِ","translation":"আর যদি","audioUrl":"wbw/034_050_009.mp3","charTypeName":"word"},{"id":48485,"position":9,"arabic":"ٱهْتَدَيْتُ","translation":"আমি সঠিক পথ পেয়ে থাকি","audioUrl":"wbw/034_050_010.mp3","charTypeName":"word"},{"id":48486,"position":10,"arabic":"فَبِمَا","translation":"তবে এ কারণে যা","audioUrl":"wbw/034_050_011.mp3","charTypeName":"word"},{"id":48487,"position":11,"arabic":"يُوحِىٓ","translation":"ওহী করেন","audioUrl":"wbw/034_050_012.mp3","charTypeName":"word"},{"id":48488,"position":12,"arabic":"إِلَىَّ","translation":"আমার প্রতি","audioUrl":"wbw/034_050_013.mp3","charTypeName":"word"},{"id":48489,"position":13,"arabic":"رَبِّىٓ ۚ","translation":"আমার রব","audioUrl":"wbw/034_050_014.mp3","charTypeName":"word"},{"id":48491,"position":14,"arabic":"إِنَّهُۥ","translation":"নিশ্চয়ই তিনি","audioUrl":"wbw/034_050_016.mp3","charTypeName":"word"},{"id":48492,"position":15,"arabic":"سَمِيعٌۭ","translation":"খুব শুনেন","audioUrl":"wbw/034_050_017.mp3","charTypeName":"word"},{"id":48493,"position":16,"arabic":"قَرِيبٌۭ","translation":"নিকট (আছেন)\"","audioUrl":"wbw/034_050_018.mp3","charTypeName":"word"},{"id":48494,"position":17,"arabic":"٥٠","translation":"(৫০)","audioUrl":null,"charTypeName":"end"}]},{"number":51,"arabic":"وَلَوْ تَرَىٰٓ إِذْ فَزِعُوا۟ فَلَا فَوْتَ وَأُخِذُوا۟ مِن مَّكَانٍۢ قَرِيبٍۢ","translation":"IF THOU couldst but see [how the deniers of the truth will fare on Resurrection Day,] when they will shrink in terror, with nowhere to escape - since they will have been seized from so close nearby","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3657.mp3","surahId":34,"words":[{"id":49553,"position":1,"arabic":"وَلَوْ","translation":"এবং যদি","audioUrl":"wbw/034_051_001.mp3","charTypeName":"word"},{"id":49554,"position":2,"arabic":"تَرَىٰٓ","translation":"তুমি দেখতে","audioUrl":"wbw/034_051_002.mp3","charTypeName":"word"},{"id":49555,"position":3,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/034_051_003.mp3","charTypeName":"word"},{"id":49556,"position":4,"arabic":"فَزِعُوا۟","translation":"তারা ভয়ে বিহ্বল হবে","audioUrl":"wbw/034_051_004.mp3","charTypeName":"word"},{"id":49557,"position":5,"arabic":"فَلَا","translation":"কিন্তু না","audioUrl":"wbw/034_051_005.mp3","charTypeName":"word"},{"id":49558,"position":6,"arabic":"فَوْتَ","translation":"পালাতে পারবে","audioUrl":"wbw/034_051_006.mp3","charTypeName":"word"},{"id":49559,"position":7,"arabic":"وَأُخِذُوا۟","translation":"এবং তারা ধরা পড়বে","audioUrl":"wbw/034_051_007.mp3","charTypeName":"word"},{"id":49560,"position":8,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/034_051_008.mp3","charTypeName":"word"},{"id":49561,"position":9,"arabic":"مَّكَانٍۢ","translation":"স্হান","audioUrl":"wbw/034_051_009.mp3","charTypeName":"word"},{"id":49562,"position":10,"arabic":"قَرِيبٍۢ","translation":"নিকটবর্তী","audioUrl":"wbw/034_051_010.mp3","charTypeName":"word"},{"id":49563,"position":11,"arabic":"٥١","translation":"(৫১)","audioUrl":null,"charTypeName":"end"}]},{"number":52,"arabic":"وَقَالُوٓا۟ ءَامَنَّا بِهِۦ وَأَنَّىٰ لَهُمُ ٱلتَّنَاوُشُ مِن مَّكَانٍۭ بَعِيدٍۢ","translation":"and will cry, “We do [now] believe in it!” But how can they [hope to] attain [to salvation] from so far away,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3658.mp3","surahId":34,"words":[{"id":49798,"position":1,"arabic":"وَقَالُوٓا۟","translation":"এবং তারা বলবে","audioUrl":"wbw/034_052_001.mp3","charTypeName":"word"},{"id":49799,"position":2,"arabic":"ءَامَنَّا","translation":"\"আমরা ঈমান এনেছি","audioUrl":"wbw/034_052_002.mp3","charTypeName":"word"},{"id":49800,"position":3,"arabic":"بِهِۦ","translation":"প্রতি তাঁর\"","audioUrl":"wbw/034_052_003.mp3","charTypeName":"word"},{"id":49801,"position":4,"arabic":"وَأَنَّىٰ","translation":"কিন্তু কোথায়","audioUrl":"wbw/034_052_004.mp3","charTypeName":"word"},{"id":49802,"position":5,"arabic":"لَهُمُ","translation":"জন্যে তাদের (সম্ভব হবে)","audioUrl":"wbw/034_052_005.mp3","charTypeName":"word"},{"id":49803,"position":6,"arabic":"ٱلتَّنَاوُشُ","translation":"(ঈমানের) নাগাল পাওয়া","audioUrl":"wbw/034_052_006.mp3","charTypeName":"word"},{"id":49804,"position":7,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/034_052_007.mp3","charTypeName":"word"},{"id":49805,"position":8,"arabic":"مَّكَانٍۭ","translation":"স্হান","audioUrl":"wbw/034_052_008.mp3","charTypeName":"word"},{"id":49806,"position":9,"arabic":"بَعِيدٍۢ","translation":"দূরবর্তী","audioUrl":"wbw/034_052_009.mp3","charTypeName":"word"},{"id":49807,"position":10,"arabic":"٥٢","translation":"(৫২)","audioUrl":null,"charTypeName":"end"}]},{"number":53,"arabic":"وَقَدْ كَفَرُوا۟ بِهِۦ مِن قَبْلُ ۖ وَيَقْذِفُونَ بِٱلْغَيْبِ مِن مَّكَانٍۭ بَعِيدٍۢ","translation":"seeing that aforetime they had been bent on denying the truth, and had been wont to cast scorn, from far away, on something that was beyond the reach of human perception?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3659.mp3","surahId":34,"words":[{"id":50841,"position":1,"arabic":"وَقَدْ","translation":"অথচ নিশ্চয়ই","audioUrl":"wbw/034_053_001.mp3","charTypeName":"word"},{"id":50842,"position":2,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করেছিলো","audioUrl":"wbw/034_053_002.mp3","charTypeName":"word"},{"id":50843,"position":3,"arabic":"بِهِۦ","translation":"প্রতি তার","audioUrl":"wbw/034_053_003.mp3","charTypeName":"word"},{"id":50844,"position":4,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/034_053_004.mp3","charTypeName":"word"},{"id":50845,"position":5,"arabic":"قَبْلُ ۖ","translation":"পূর্ব","audioUrl":"wbw/034_053_005.mp3","charTypeName":"word"},{"id":50847,"position":6,"arabic":"وَيَقْذِفُونَ","translation":"এবং তারা (আনুমানিক কথা)ছুঁড়ে মারতো","audioUrl":"wbw/034_053_007.mp3","charTypeName":"word"},{"id":50848,"position":7,"arabic":"بِٱلْغَيْبِ","translation":"বিষয়ে অদৃশ্য","audioUrl":"wbw/034_053_008.mp3","charTypeName":"word"},{"id":50849,"position":8,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/034_053_009.mp3","charTypeName":"word"},{"id":50850,"position":9,"arabic":"مَّكَانٍۭ","translation":"স্হান","audioUrl":"wbw/034_053_010.mp3","charTypeName":"word"},{"id":50851,"position":10,"arabic":"بَعِيدٍۢ","translation":"দূরবর্তী","audioUrl":"wbw/034_053_011.mp3","charTypeName":"word"},{"id":50852,"position":11,"arabic":"٥٣","translation":"(৫৩)","audioUrl":null,"charTypeName":"end"}]},{"number":54,"arabic":"وَحِيلَ بَيْنَهُمْ وَبَيْنَ مَا يَشْتَهُونَ كَمَا فُعِلَ بِأَشْيَاعِهِم مِّن قَبْلُ ۚ إِنَّهُمْ كَانُوا۟ فِى شَكٍّۢ مُّرِيبٍۭ","translation":"And so, a barrier will be set between them and all that they had [ever] desired, as will be done to such of their kind as lived before their time: for, behold, they [too] were lost in doubt amounting to suspicion.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3660.mp3","surahId":34,"words":[{"id":51035,"position":1,"arabic":"وَحِيلَ","translation":"এবং অন্তরাল করা হবে","audioUrl":"wbw/034_054_001.mp3","charTypeName":"word"},{"id":51036,"position":2,"arabic":"بَيْنَهُمْ","translation":"মাঝে তাদের","audioUrl":"wbw/034_054_002.mp3","charTypeName":"word"},{"id":51037,"position":3,"arabic":"وَبَيْنَ","translation":"ও মাঝে (ঐসব জিনিসের)","audioUrl":"wbw/034_054_003.mp3","charTypeName":"word"},{"id":51038,"position":4,"arabic":"مَا","translation":"যা","audioUrl":"wbw/034_054_004.mp3","charTypeName":"word"},{"id":51039,"position":5,"arabic":"يَشْتَهُونَ","translation":"তারা বাসনা করবে (অর্থাৎ তা হ'তে বঞ্চিত করা হবে)","audioUrl":"wbw/034_054_005.mp3","charTypeName":"word"},{"id":51040,"position":6,"arabic":"كَمَا","translation":"যেমন","audioUrl":"wbw/034_054_006.mp3","charTypeName":"word"},{"id":51041,"position":7,"arabic":"فُعِلَ","translation":"করা হয়েছিলো","audioUrl":"wbw/034_054_007.mp3","charTypeName":"word"},{"id":51042,"position":8,"arabic":"بِأَشْيَاعِهِم","translation":"সাথে তাদের (একমনা) দলগুলোর (ক্ষেত্রে)","audioUrl":"wbw/034_054_008.mp3","charTypeName":"word"},{"id":51043,"position":9,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/034_054_009.mp3","charTypeName":"word"},{"id":51044,"position":10,"arabic":"قَبْلُ ۚ","translation":"পূর্ব","audioUrl":"wbw/034_054_010.mp3","charTypeName":"word"},{"id":51046,"position":11,"arabic":"إِنَّهُمْ","translation":"নিশ্চয়ই তারা","audioUrl":"wbw/034_054_012.mp3","charTypeName":"word"},{"id":51047,"position":12,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/034_054_013.mp3","charTypeName":"word"},{"id":51048,"position":13,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/034_054_014.mp3","charTypeName":"word"},{"id":51049,"position":14,"arabic":"شَكٍّۢ","translation":"সন্দেহের","audioUrl":"wbw/034_054_015.mp3","charTypeName":"word"},{"id":51050,"position":15,"arabic":"مُّرِيبٍۭ","translation":"বিভ্রান্তিকর","audioUrl":"wbw/034_054_016.mp3","charTypeName":"word"},{"id":51051,"position":16,"arabic":"٥٤","translation":"(৫৪)","audioUrl":null,"charTypeName":"end"}]},{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ ٱلْحَمْدُ لِلَّهِ فَاطِرِ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ جَاعِلِ ٱلْمَلَٰٓئِكَةِ رُسُلًا أُو۟لِىٓ أَجْنِحَةٍۢ مَّثْنَىٰ وَثُلَٰثَ وَرُبَٰعَ ۚ يَزِيدُ فِى ٱلْخَلْقِ مَا يَشَآءُ ۚ إِنَّ ٱللَّهَ عَلَىٰ كُلِّ شَىْءٍۢ قَدِيرٌۭ","translation":"ALL PRAISE is due to God, Originator of the heavens and the earth, who causes the angels to be (His) message-bearers, endowed with wings, two, or three, or four. [Unceasingly] He adds to His creation whatever He wills: for, verily, God has the power to will anything.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3661.mp3","surahId":35,"words":[{"id":860,"position":1,"arabic":"ٱلْحَمْدُ","translation":"সকল প্রশংসা","audioUrl":"wbw/035_001_001.mp3","charTypeName":"word"},{"id":861,"position":2,"arabic":"لِلَّهِ","translation":"আল্লাহরই জন্যে","audioUrl":"wbw/035_001_002.mp3","charTypeName":"word"},{"id":862,"position":3,"arabic":"فَاطِرِ","translation":"(যিনি) স্রষ্টা","audioUrl":"wbw/035_001_003.mp3","charTypeName":"word"},{"id":863,"position":4,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশের","audioUrl":"wbw/035_001_004.mp3","charTypeName":"word"},{"id":864,"position":5,"arabic":"وَٱلْأَرْضِ","translation":"ও পৃথিবীর","audioUrl":"wbw/035_001_005.mp3","charTypeName":"word"},{"id":865,"position":6,"arabic":"جَاعِلِ","translation":"(তিনিই) নিয়োগকারী","audioUrl":"wbw/035_001_006.mp3","charTypeName":"word"},{"id":866,"position":7,"arabic":"ٱلْمَلَـٰٓئِكَةِ","translation":"ফেরেশতাদেরকে","audioUrl":"wbw/035_001_007.mp3","charTypeName":"word"},{"id":867,"position":8,"arabic":"رُسُلًا","translation":"বাণীবাহক রূপে","audioUrl":"wbw/035_001_008.mp3","charTypeName":"word"},{"id":868,"position":9,"arabic":"أُو۟لِىٓ","translation":"বিশিষ্ট","audioUrl":"wbw/035_001_009.mp3","charTypeName":"word"},{"id":869,"position":10,"arabic":"أَجْنِحَةٍۢ","translation":"(বহু) ডানা","audioUrl":"wbw/035_001_010.mp3","charTypeName":"word"},{"id":870,"position":11,"arabic":"مَّثْنَىٰ","translation":"দু'টি","audioUrl":"wbw/035_001_011.mp3","charTypeName":"word"},{"id":871,"position":12,"arabic":"وَثُلَـٰثَ","translation":"ও তিনটি","audioUrl":"wbw/035_001_012.mp3","charTypeName":"word"},{"id":872,"position":13,"arabic":"وَرُبَـٰعَ ۚ","translation":"ও চারটি (করে)","audioUrl":"wbw/035_001_013.mp3","charTypeName":"word"},{"id":874,"position":14,"arabic":"يَزِيدُ","translation":"বৃদ্ধি করেন","audioUrl":"wbw/035_001_015.mp3","charTypeName":"word"},{"id":875,"position":15,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/035_001_016.mp3","charTypeName":"word"},{"id":876,"position":16,"arabic":"ٱلْخَلْقِ","translation":"সৃষ্টি (কাঠামোর)","audioUrl":"wbw/035_001_017.mp3","charTypeName":"word"},{"id":877,"position":17,"arabic":"مَا","translation":"যেমন","audioUrl":"wbw/035_001_018.mp3","charTypeName":"word"},{"id":878,"position":18,"arabic":"يَشَآءُ ۚ","translation":"ইচ্ছে করেন তিনি","audioUrl":"wbw/035_001_019.mp3","charTypeName":"word"},{"id":880,"position":19,"arabic":"إِنَّ","translation":"নিশ্চয়","audioUrl":"wbw/035_001_021.mp3","charTypeName":"word"},{"id":881,"position":20,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/035_001_022.mp3","charTypeName":"word"},{"id":882,"position":21,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/035_001_023.mp3","charTypeName":"word"},{"id":883,"position":22,"arabic":"كُلِّ","translation":"সব","audioUrl":"wbw/035_001_024.mp3","charTypeName":"word"},{"id":884,"position":23,"arabic":"شَىْءٍۢ","translation":"কিছুরই","audioUrl":"wbw/035_001_025.mp3","charTypeName":"word"},{"id":885,"position":24,"arabic":"قَدِيرٌۭ","translation":"সর্বশক্তিমান","audioUrl":"wbw/035_001_026.mp3","charTypeName":"word"},{"id":886,"position":25,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"مَّا يَفْتَحِ ٱللَّهُ لِلنَّاسِ مِن رَّحْمَةٍۢ فَلَا مُمْسِكَ لَهَا ۖ وَمَا يُمْسِكْ فَلَا مُرْسِلَ لَهُۥ مِنۢ بَعْدِهِۦ ۚ وَهُوَ ٱلْعَزِيزُ ٱلْحَكِيمُ","translation":"Whatever grace God opens up to man, none can withhold it; and whatever He withholds, none can henceforth release: for He alone is 