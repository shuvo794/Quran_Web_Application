.mp3","charTypeName":"word"},{"id":15258,"position":5,"arabic":"أَلِيمًۭا","translation":"কষ্টকর","audioUrl":"wbw/073_013_005.mp3","charTypeName":"word"},{"id":15259,"position":6,"arabic":"١٣","translation":"(১৩)","audioUrl":null,"charTypeName":"end"}]},{"number":14,"arabic":"يَوْمَ تَرْجُفُ ٱلْأَرْضُ وَٱلْجِبَالُ وَكَانَتِ ٱلْجِبَالُ كَثِيبًۭا مَّهِيلًا","translation":"on the Day when the earth and the mountains will be convulsed and the mountains will [crumble and] become like a sand-dune on the move!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5489.mp3","surahId":73,"words":[{"id":16751,"position":1,"arabic":"يَوْمَ","translation":"সেদিন","audioUrl":"wbw/073_014_001.mp3","charTypeName":"word"},{"id":16752,"position":2,"arabic":"تَرْجُفُ","translation":"কাঁপবে","audioUrl":"wbw/073_014_002.mp3","charTypeName":"word"},{"id":16753,"position":3,"arabic":"ٱلْأَرْضُ","translation":"জমিন","audioUrl":"wbw/073_014_003.mp3","charTypeName":"word"},{"id":16754,"position":4,"arabic":"وَٱلْجِبَالُ","translation":"ও পাহাড়সমূহ","audioUrl":"wbw/073_014_004.mp3","charTypeName":"word"},{"id":16755,"position":5,"arabic":"وَكَانَتِ","translation":"এবং হবে","audioUrl":"wbw/073_014_005.mp3","charTypeName":"word"},{"id":16756,"position":6,"arabic":"ٱلْجِبَالُ","translation":"পাহাড়গুলো","audioUrl":"wbw/073_014_006.mp3","charTypeName":"word"},{"id":16757,"position":7,"arabic":"كَثِيبًۭا","translation":"ধুলার স্তূপ","audioUrl":"wbw/073_014_007.mp3","charTypeName":"word"},{"id":16758,"position":8,"arabic":"مَّهِيلًا","translation":"বিক্ষিপ্ত হয়ে পড়া","audioUrl":"wbw/073_014_008.mp3","charTypeName":"word"},{"id":16759,"position":9,"arabic":"١٤","translation":"(১৪)","audioUrl":null,"charTypeName":"end"}]},{"number":15,"arabic":"إِنَّآ أَرْسَلْنَآ إِلَيْكُمْ رَسُولًۭا شَٰهِدًا عَلَيْكُمْ كَمَآ أَرْسَلْنَآ إِلَىٰ فِرْعَوْنَ رَسُولًۭا","translation":"BEHOLD, [O men,] We have sent unto you an apostle who shall bear witness to the truth before you, even as We sent an apostl