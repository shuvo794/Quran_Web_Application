{"id":117,"ayahs":[{"number":51,"arabic":"۞ يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ لَا تَتَّخِذُوا۟ ٱلْيَهُودَ وَٱلنَّصَٰرَىٰٓ أَوْلِيَآءَ ۘ بَعْضُهُمْ أَوْلِيَآءُ بَعْضٍۢ ۚ وَمَن يَتَوَلَّهُم مِّنكُمْ فَإِنَّهُۥ مِنْهُمْ ۗ إِنَّ ٱللَّهَ لَا يَهْدِى ٱلْقَوْمَ ٱلظَّٰلِمِينَ","translation":"O YOU who have attained to faith! Do not take the Jews and the Christians for your allies: they are but allies of one another and whoever of you allies himself with them becomes, verily, one of them; behold, God does not guide such evildoers.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/720.mp3","surahId":5,"words":[{"id":49325,"position":1,"arabic":"۞ يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/005_051_002.mp3","charTypeName":"word"},{"id":49326,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/005_051_003.mp3","charTypeName":"word"},{"id":49327,"position":3,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছো","audioUrl":"wbw/005_051_004.mp3","charTypeName":"word"},{"id":49328,"position":4,"arabic":"لَا","translation":"না","audioUrl":"wbw/005_051_005.mp3","charTypeName":"word"},{"id":49329,"position":5,"arabic":"تَتَّخِذُوا۟","translation":"তোমরা গ্রহণ করো","audioUrl":"wbw/005_051_006.mp3","charTypeName":"word"},{"id":49330,"position":6,"arabic":"ٱلْيَهُودَ","translation":"ইয়াহুদীদেরকে","audioUrl":"wbw/005_051_007.mp3","charTypeName":"word"},{"id":49331,"position":7,"arabic":"وَٱلنَّصَـٰرَىٰٓ","translation":"এবং খ্রিষ্টানদেরকে","audioUrl":"wbw/005_051_008.mp3","charTypeName":"word"},{"id":49332,"position":8,"arabic":"أَوْلِيَآءَ ۘ","translation":"বন্ধুরূপে","audioUrl":"wbw/005_051_009.mp3","charTypeName":"word"},{"id":49334,"position":9,"arabic":"بَعْضُهُمْ","translation":"একে তাদের","audioUrl":"wbw/005_051_011.mp3","charTypeName":"word"},{"id":49335,"position":10,"arabic":"أَوْلِيَآءُ","translation":"বন্ধু","audioUrl":"wbw/005_051_012.mp3","charTypeName":"word"},{"id":49336,"position":11,"arabic":"بَعْضٍۢ ۚ","translation":"অপরের (অর্থাৎ পরস্পরে বন্ধু)","audioUrl":"wbw/005_051_013.mp3","charTypeName":"word"},{"id":49338,"position":12,"arabic":"وَمَن","translation":"এবং যে","audioUrl":"wbw/005_051_015.mp3","charTypeName":"word"},{"id":49339,"position":13,"arabic":"يَتَوَلَّهُم","translation":"বন্ধু বানাবে তাদেরকে","audioUrl":"wbw/005_051_016.mp3","charTypeName":"word"},{"id":49340,"position":14,"arabic":"مِّنكُمْ","translation":"মধ্য হতে তোমাদের","audioUrl":"wbw/005_051_017.mp3","charTypeName":"word"},{"id":49341,"position":15,"arabic":"فَإِنَّهُۥ","translation":"তবে নিশ্চয়ই সে","audioUrl":"wbw/005_051_018.mp3","charTypeName":"word"},{"id":49342,"position":16,"arabic":"مِنْهُمْ ۗ","translation":"মধ্যকার তাদের(গণ্য হবে)","audioUrl":"wbw/005_051_019.mp3","charTypeName":"word"},{"id":49344,"position":17,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/005_051_021.mp3","charTypeName":"word"},{"id":49345,"position":18,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/005_051_022.mp3","charTypeName":"word"},{"id":49346,"position":19,"arabic":"لَا","translation":"না","audioUrl":"wbw/005_051_023.mp3","charTypeName":"word"},{"id":49347,"position":20,"arabic":"يَهْدِى","translation":"সতপথ দেখান","audioUrl":"wbw/005_051_024.mp3","charTypeName":"word"},{"id":49348,"position":21,"arabic":"ٱلْقَوْمَ","translation":"(ঐসব)সম্প্রদায়ের","audioUrl":"wbw/005_051_025.mp3","charTypeName":"word"},{"id":49349,"position":22,"arabic":"ٱلظَّـٰلِمِينَ","translation":"(যারা)সীমালঙ্ঘনকারী","audioUrl":"wbw/005_051_026.mp3","charTypeName":"word"},{"id":49350,"position":23,"arabic":"٥١","translation":"(৫১)","audioUrl":null,"charTypeName":"end"}]},{"number":52,"arabic":"فَتَرَى ٱلَّذِينَ فِى قُلُوبِهِم مَّرَضٌۭ يُسَٰرِعُونَ فِيهِمْ يَقُولُونَ نَخْشَىٰٓ أَن تُصِيبَنَا دَآئِرَةٌۭ ۚ فَعَسَى ٱللَّهُ أَن يَأْتِىَ بِٱلْفَتْحِ أَوْ أَمْرٍۢ مِّنْ عِندِهِۦ فَيُصْبِحُوا۟ عَلَىٰ مَآ أَسَرُّوا۟ فِىٓ أَنفُسِهِمْ نَٰدِمِينَ","translation":"And yet thou canst see how those in whose hearts there is disease vie with one another for their good will, saying [to themselves], \"We fear lest fortune turn against us.\" But God may well bring about good fortune [for the believers] or any [other] event of His own devising, whereupon those [waverers] will be smitten with remorse for the thoughts which they had secretly harboured within themselves-","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/721.mp3","surahId":5,"words":[{"id":50021,"position":1,"arabic":"فَتَرَى","translation":"তাই তুমি দেখবে","audioUrl":"wbw/005_052_001.mp3","charTypeName":"word"},{"id":50022,"position":2,"arabic":"ٱلَّذِينَ","translation":"যাদের","audioUrl":"wbw/005_052_002.mp3","charTypeName":"word"},{"id":50023,"position":3,"arabic":"فِى","translation":"মধ্যে (আছে)","audioUrl":"wbw/005_052_003.mp3","charTypeName":"word"},{"id":50024,"position":4,"arabic":"قُلُوبِهِم","translation":"অন্তরগুলোতে তাদের","audioUrl":"wbw/005_052_004.mp3","charTypeName":"word"},{"id":50025,"position":5,"arabic":"مَّرَضٌۭ","translation":"(মুনাফেকীর)রোগ","audioUrl":"wbw/005_052_005.mp3","charTypeName":"word"},{"id":50026,"position":6,"arabic":"يُسَـٰرِعُونَ","translation":"তারা দ্রুত ধাবিত হয়","audioUrl":"wbw/005_052_006.mp3","charTypeName":"word"},{"id":50027,"position":7,"arabic":"فِيهِمْ","translation":"মধ্যে তাদের","audioUrl":"wbw/005_052_007.mp3","charTypeName":"word"},{"id":50028,"position":8,"arabic":"يَقُولُونَ","translation":"তারা বলে","audioUrl":"wbw/005_052_008.mp3","charTypeName":"word"},{"id":50029,"position":9,"arabic":"نَخْشَىٰٓ","translation":"\"ভয় করি আমরা","audioUrl":"wbw/005_052_009.mp3","charTypeName":"word"},{"id":50030,"position":10,"arabic":"أَن","translation":"যে","audioUrl":"wbw/005_052_010.mp3","charTypeName":"word"},{"id":50031,"position":11,"arabic":"تُصِيبَنَا","translation":"আমাদের উপর পড়বে","audioUrl":"wbw/005_052_011.mp3","charTypeName":"word"},{"id":50032,"position":12,"arabic":"دَآئِرَ ةٌۭ ۚ","translation":"কোনো ভাগ্য বিপর্যয়\"","audioUrl":"wbw/005_052_012.mp3","charTypeName":"word"},{"id":50034,"position":13,"arabic":"فَعَسَى","translation":"অতঃপর হয়তো (যখন)","audioUrl":"wbw/005_052_014.mp3","charTypeName":"word"},{"id":50035,"position":14,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/005_052_015.mp3","charTypeName":"word"},{"id":50036,"position":15,"arabic":"أَن","translation":"যে","audioUrl":"wbw/005_052_016.mp3","charTypeName":"word"},{"id":50037,"position":16,"arabic":"يَأْتِىَ","translation":"আসবেন","audioUrl":"wbw/005_052_017.mp3","charTypeName":"word"},{"id":50038,"position":17,"arabic":"بِٱلْفَتْحِ","translation":"নিয়ে বিজয় (তোমাদেরকে)","audioUrl":"wbw/005_052_018.mp3","charTypeName":"word"},{"id":50039,"position":18,"arabic":"أَوْ","translation":"বা","audioUrl":"wbw/005_052_019.mp3","charTypeName":"word"},{"id":50040,"position":19,"arabic":"أَمْرٍۢ","translation":"(অন্য কিছু) বিষয়","audioUrl":"wbw/005_052_020.mp3","charTypeName":"word"},{"id":50041,"position":20,"arabic":"مِّنْ","translation":"থেকে","audioUrl":"wbw/005_052_021.mp3","charTypeName":"word"},{"id":50042,"position":21,"arabic":"عِندِهِۦ","translation":"নিকট তাঁর","audioUrl":"wbw/005_052_022.mp3","charTypeName":"word"},{"id":50043,"position":22,"arabic":"فَيُصْبِحُوا۟","translation":"তখন তারা হবে","audioUrl":"wbw/005_052_023.mp3","charTypeName":"word"},{"id":50044,"position":23,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/005_052_024.mp3","charTypeName":"word"},{"id":50045,"position":24,"arabic":"مَآ","translation":"যা","audioUrl":"wbw/005_052_025.mp3","charTypeName":"word"},{"id":50046,"position":25,"arabic":"أَسَرُّوا۟","translation":"তারা গোপন করতো (অর্থাৎ মুনাফেকী)","audioUrl":"wbw/005_052_026.mp3","charTypeName":"word"},{"id":50047,"position":26,"arabic":"فِىٓ","translation":"মধ্যে","audioUrl":"wbw/005_052_027.mp3","charTypeName":"word"},{"id":50048,"position":27,"arabic":"أَنفُسِهِمْ","translation":"নিজেদের তাদের (মনের)","audioUrl":"wbw/005_052_028.mp3","charTypeName":"word"},{"id":50049,"position":28,"arabic":"نَـٰدِمِينَ","translation":"অনুতাপকারী (হবে)","audioUrl":"wbw/005_052_029.mp3","charTypeName":"word"},{"id":50050,"position":29,"arabic":"٥٢","translation":"(৫২)","audioUrl":null,"charTypeName":"end"}]},{"number":53,"arabic":"وَيَقُولُ ٱلَّذِينَ ءَامَنُوٓا۟ أَهَٰٓؤُلَآءِ ٱلَّذِينَ أَقْسَمُوا۟ بِٱللَّهِ جَهْدَ أَيْمَٰنِهِمْ ۙ إِنَّهُمْ لَمَعَكُمْ ۚ حَبِطَتْ أَعْمَٰلُهُمْ فَأَصْبَحُوا۟ خَٰسِرِينَ","translation":"while those who have attained to faith will say [to one another], \"Are these the selfsame people who swore by God with their most solemn oaths that they were indeed with you? In vain are all their works, for now they are lost!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/722.mp3","surahId":5,"words":[{"id":50637,"position":1,"arabic":"وَيَقُولُ","translation":"এবং তারা বলবে","audioUrl":"wbw/005_053_001.mp3","charTypeName":"word"},{"id":50638,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/005_053_002.mp3","charTypeName":"word"},{"id":50639,"position":3,"arabic":"ءَامَنُوٓا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/005_053_003.mp3","charTypeName":"word"},{"id":50640,"position":4,"arabic":"أَهَـٰٓؤُلَآءِ","translation":"\"কি এইসব লোকেরা","audioUrl":"wbw/005_053_004.mp3","charTypeName":"word"},{"id":50641,"position":5,"arabic":"ٱلَّذِينَ","translation":"(তারাই) যারা","audioUrl":"wbw/005_053_005.mp3","charTypeName":"word"},{"id":50642,"position":6,"arabic":"أَقْسَمُوا۟","translation":"শপথ করেছিলো (বিশ্বাস করাতো)","audioUrl":"wbw/005_053_006.mp3","charTypeName":"word"},{"id":50643,"position":7,"arabic":"بِٱللَّهِ","translation":"নামে আল্লাহর","audioUrl":"wbw/005_053_007.mp3","charTypeName":"word"},{"id":50644,"position":8,"arabic":"جَهْدَ","translation":"দৃঢ়ভাবে","audioUrl":"wbw/005_053_008.mp3","charTypeName":"word"},{"id":50645,"position":9,"arabic":"أَيْمَـٰنِهِمْ ۙ","translation":"শপথগুলোকে তাদের","audioUrl":"wbw/005_053_009.mp3","charTypeName":"word"},{"id":50647,"position":10,"arabic":"إِنَّهُمْ","translation":"নিশ্চয়ই তারা","audioUrl":"wbw/005_053_011.mp3","charTypeName":"word"},{"id":50648,"position":11,"arabic":"لَمَعَكُمْ ۚ","translation":"অবশ্যই সাথে তোমাদের\"","audioUrl":"wbw/005_053_012.mp3","charTypeName":"word"},{"id":50650,"position":12,"arabic":"حَبِطَتْ","translation":"বিনষ্ট হয়েছে","audioUrl":"wbw/005_053_014.mp3","charTypeName":"word"},{"id":50651,"position":13,"arabic":"أَعْمَـٰلُهُمْ","translation":"কাজগুলো তাদের","audioUrl":"wbw/005_053_015.mp3","charTypeName":"word"},{"id":50652,"position":14,"arabic":"فَأَصْبَحُوا۟","translation":"অতএব তারা হয়েছে","audioUrl":"wbw/005_053_016.mp3","charTypeName":"word"},{"id":50653,"position":15,"arabic":"خَـٰسِرِينَ","translation":"ক্ষতিগ্রস্ত","audioUrl":"wbw/005_053_017.mp3","charTypeName":"word"},{"id":50654,"position":16,"arabic":"٥٣","translation":"(৫৩)","audioUrl":null,"charTypeName":"end"}]},{"number":54,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ مَن يَرْتَدَّ مِنكُمْ عَن دِينِهِۦ فَسَوْفَ يَأْتِى ٱللَّهُ بِقَوْمٍۢ يُحِبُّهُمْ وَيُحِبُّونَهُۥٓ أَذِلَّةٍ عَلَى ٱلْمُؤْمِنِينَ أَعِزَّةٍ عَلَى ٱلْكَٰفِرِينَ يُجَٰهِدُونَ فِى سَبِيلِ ٱللَّهِ وَلَا يَخَافُونَ لَوْمَةَ لَآئِمٍۢ ۚ ذَٰلِكَ فَضْلُ ٱللَّهِ يُؤْتِيهِ مَن يَشَآءُ ۚ وَٱللَّهُ وَٰسِعٌ عَلِيمٌ","translation":"O you who have attained to faith! If you ever abandon your faith,\" God will in time bring forth [in your stead] people whom He loves and who love Him - humble towards the believers, proud towards all who deny the truth: [people] who strive hard in God's cause, and do not fear to be censured by anyone who might censure them: such is God's favour, which He grants unto whom He wills. And God is infinite, all-knowing.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/723.mp3","surahId":5,"words":[{"id":51420,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/005_054_001.mp3","charTypeName":"word"},{"id":51421,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/005_054_002.mp3","charTypeName":"word"},{"id":51422,"position":3,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছো","audioUrl":"wbw/005_054_003.mp3","charTypeName":"word"},{"id":51423,"position":4,"arabic":"مَن","translation":"যে কেউ","audioUrl":"wbw/005_054_004.mp3","charTypeName":"word"},{"id":51424,"position":5,"arabic":"يَرْتَدَّ","translation":"ফিরে যাবে","audioUrl":"wbw/005_054_005.mp3","charTypeName":"word"},{"id":51425,"position":6,"arabic":"مِنكُمْ","translation":"মধ্য হতে তোমাদের","audioUrl":"wbw/005_054_006.mp3","charTypeName":"word"},{"id":51426,"position":7,"arabic":"عَن","translation":"থেকে","audioUrl":"wbw/005_054_007.mp3","charTypeName":"word"},{"id":51427,"position":8,"arabic":"دِينِهِۦ","translation":"তার দীন (যাক না)","audioUrl":"wbw/005_054_008.mp3","charTypeName":"word"},{"id":51428,"position":9,"arabic":"فَسَوْفَ","translation":"এরপর শীঘ্রই","audioUrl":"wbw/005_054_009.mp3","charTypeName":"word"},{"id":51429,"position":10,"arabic":"يَأْتِى","translation":"আসবেন (অর্থাৎ সৃষ্টি করবেন)","audioUrl":"wbw/005_054_010.mp3","charTypeName":"word"},{"id":51430,"position":11,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/005_054_011.mp3","charTypeName":"word"},{"id":51431,"position":12,"arabic":"بِقَوْمٍۢ","translation":"নিয়ে (এমন)সম্প্রদায়","audioUrl":"wbw/005_054_012.mp3","charTypeName":"word"},{"id":51432,"position":13,"arabic":"يُحِبُّهُمْ","translation":"ভালোবাসবেন তিনি যাদেরকে","audioUrl":"wbw/005_054_013.mp3","charTypeName":"word"},{"id":51433,"position":14,"arabic":"وَيُحِبُّونَهُۥٓ","translation":"এবং তারা ভালোবাসবে তাঁকে","audioUrl":"wbw/005_054_014.mp3","charTypeName":"word"},{"id":51434,"position":15,"arabic":"أَذِلَّةٍ","translation":"(তারা)কোমল","audioUrl":"wbw/005_054_015.mp3","charTypeName":"word"},{"id":51435,"position":16,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/005_054_016.mp3","charTypeName":"word"},{"id":51436,"position":17,"arabic":"ٱلْمُؤْمِنِينَ","translation":"মু’মিনদের","audioUrl":"wbw/005_054_017.mp3","charTypeName":"word"},{"id":51437,"position":18,"arabic":"أَعِزَّةٍ","translation":"কঠো