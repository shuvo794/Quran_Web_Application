":38539,"position":5,"arabic":"حِسَابًۭا","translation":"যথোচিত","audioUrl":"wbw/078_036_005.mp3","charTypeName":"word"},{"id":38540,"position":6,"arabic":"٣٦","translation":"(৩৬)","audioUrl":null,"charTypeName":"end"}]},{"number":37,"arabic":"رَّبِّ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ وَمَا بَيْنَهُمَا ٱلرَّحْمَٰنِ ۖ لَا يَمْلِكُونَ مِنْهُ خِطَابًۭا","translation":"[a reward from] the Sustainer of the heavens and the earth and all that is between them, the Most Gracious! [And] none shall have it in their power to raise their voices unto Him","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5709.mp3","surahId":78,"words":[{"id":39402,"position":1,"arabic":"رَّبِّ","translation":"(পক্ষ হতে) রবের","audioUrl":"wbw/078_037_001.mp3","charTypeName":"word"},{"id":39403,"position":2,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশসমূহের","audioUrl":"wbw/078_037_002.mp3","charTypeName":"word"},{"id":39404,"position":3,"arabic":"وَٱلْأَرْضِ","translation":"এবং পৃথিবীর","audioUrl":"wbw/078_037_003.mp3","charTypeName":"word"},{"id":39405,"position":4,"arabic":"وَمَا","translation":"এবং যা কিছু","audioUrl":"wbw/078_037_004.mp3","charTypeName":"word"},{"id":39406,"position":5,"arabic":"بَيْنَهُمَا","translation":"তাদের দু'য়ের মাঝে আছে","audioUrl":"wbw/078_037_005.mp3","charTypeName":"word"},{"id":39407,"position":6,"arabic":"ٱلرَّحْمَـٰنِ ۖ","translation":"অশেষ দয়াবানের (পক্ষ হতে)","audioUrl":"wbw/078_037_006.mp3","charTypeName":"word"},{"id":39409,"position":7,"arabic":"لَا","translation":"না","audioUrl":"wbw/078_037_008.mp3","charTypeName":"word"},{"id":39410,"position":8,"arabic":"يَمْلِكُونَ","translation":"তারা সক্ষম হবে","audioUrl":"wbw/078_037_009.mp3","charTypeName":"word"},{"id":39411,"position":9,"arabic":"مِنْهُ","translation":"তাঁর সাথে","audioUrl":"wbw/078_037_010.mp3","charTypeName":"word"},{"id":39412,"position":10,"arabic":"خِطَابًۭا","translation":"কথা বলতে","audioUrl":"wbw/078_037_011.mp3","charTypeName":"word"},{"id":39413,"position":11,"arabic":"٣٧","translation":"(৩৭)","audioUrl":null,"charTypeName":"end"}]},{"number":38,"arabic":"يَوْمَ يَقُومُ ٱلرُّوحُ وَٱلْمَلَٰٓئِكَةُ صَفًّۭا ۖ لَّا يَتَكَلَّمُونَ إِلَّا مَنْ أَذِنَ لَهُ ٱلرَّحْمَٰنُ وَقَالَ صَوَابًۭا","translation":"on the Day when all [human] souls and all the angels will stand up in ranks: none will speak but he to whom the Most Gracious will have given leave; and [everyone] will say [only] what is right.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5710.mp3","surahId":78,"words":[{"id":40124,"position":1,"arabic":"يَوْمَ","translation":"সেদিন","audioUrl":"wbw/078_038_001.mp3","charTypeName":"word"},{"id":40125,"position":2,"arabic":"يَقُومُ","translation":"দাঁড়াবে","audioUrl":"wbw/078_038_002.mp3","charTypeName":"word"},{"id":40126,"position":3,"arabic":"ٱلرُّوحُ","translation":"রূহ (জিবরাইল)","audioUrl":"wbw/078_038_003.mp3","charTypeName":"word"},{"id":40127,"position":4,"arabic":"وَٱلْمَلَـٰٓئِكَةُ","translation":"ও ফেরেশতারা","audioUrl":"wbw/078_038_004.mp3","charTypeName":"word"},{"id":40128,"position":5,"arabic":"صَفًّۭا ۖ","translation":"সারিবদ্ধ ভাবে","audioUrl":"wbw/078_038_005.mp3","charTypeName":"word"},{"id":40130,"position":6,"arabic":"لَّا","translation":"না","audioUrl":"wbw/078_038_007.mp3","charTypeName":"word"},{"id":40131,"position":7,"arabic":"يَتَكَلَّمُونَ","translation":"তারা কথা বলবে","audioUrl":"wbw/078_038_008.mp3","charTypeName":"word"},{"id":40132,"position":8,"arabic":"إِلَّا","translation":"(সে) ছাড়া","audioUrl":"wbw/078_038_009.mp3","charTypeName":"word"},{"id":40133,"position":9,"arabic":"مَنْ","translation":"যাকে","audioUrl":"wbw/078_038_010.mp3","charTypeName":"word"},{"id":40134,"position":10,"arabic":"أَذِنَ","translation":"অনুমতি দেবেন","audioUrl":"wbw/078_038_011.mp3","charTypeName":"word"},{"id":40135,"position":11,"arabic":"لَهُ","translation":"তার জন্যে","audioUrl":"wbw/078_038_012.mp3","charTypeName":"word"},{"id":40136,"position":12,"arabic":"ٱلرَّحْمَـٰنُ","translation":"দয়াময়","audioUrl":"wbw/078_038_013.mp3","charTypeName":"word"},{"id":40137,"position":13,"arabic":"وَقَالَ","translation":"এবং বলবে","audioUrl":"wbw/078_038_014.mp3","charTypeName":"word"},{"id":40138,"position":14,"arabic":"صَوَابًۭا","translation":"যথাযথ","audioUrl":"wbw/078_038_015.mp3","charTypeName":"word"},{"id":40139,"position":15,"arabic":"٣٨","translation":"(৩৮)","audioUrl":null,"charTypeName":"end"}]},{"number":39,"arabic":"ذَٰلِكَ ٱلْيَوْمُ ٱلْحَقُّ ۖ فَمَن شَآءَ ٱتَّخَذَ إِلَىٰ رَبِّهِۦ مَـَٔابًا","translation":"That will be the Day of Ultimate Truth: whoever wills, then, let him take the path that leads towards his Sustainer!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5711.mp3","surahId":78,"words":[{"id":40931,"position":1,"arabic":"ذَٰلِكَ","translation":"সে-ই","audioUrl":"wbw/078_039_001.mp3","charTypeName":"word"},{"id":40932,"position":2,"arabic":"ٱلْيَوْمُ","translation":"দিন","audioUrl":"wbw/078_039_002.mp3","charTypeName":"word"},{"id":40933,"position":3,"arabic":"ٱلْحَقُّ ۖ","translation":"সুনিশ্চিত","audioUrl":"wbw/078_039_003.mp3","charTypeName":"word"},{"id":40935,"position":4,"arabic":"فَمَن","translation":"অতএব যে","audioUrl":"wbw/078_039_005.mp3","charTypeName":"word"},{"id":40936,"position":5,"arabic":"شَآءَ","translation":"চায়","audioUrl":"wbw/078_039_006.mp3","charTypeName":"word"},{"id":40937,"position":6,"arabic":"ٱتَّخَذَ","translation":"গ্রহণ করুক (আজ)","audioUrl":"wbw/078_039_007.mp3","charTypeName":"word"},{"id":40938,"position":7,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/078_039_008.mp3","charTypeName":"word"},{"id":40939,"position":8,"arabic":"رَبِّهِۦ","translation":"তার রবের","audioUrl":"wbw/078_039_009.mp3","charTypeName":"word"},{"id":40940,"position":9,"arabic":"مَـَٔابًا","translation":"প্রত্যাবর্তনের (পথ)","audioUrl":"wbw/078_039_010.mp3","charTypeName":"word"},{"id":40941,"position":10,"arabic":"٣٩","translation":"(৩৯)","audioUrl":null,"charTypeName":"end"}]},{"number":40,"arabic":"إِنَّآ أَنذَرْنَٰكُمْ عَذَابًۭا قَرِيبًۭا يَوْمَ يَنظُرُ ٱلْمَرْءُ مَا قَدَّمَتْ يَدَاهُ وَيَقُولُ ٱلْكَافِرُ يَٰلَيْتَنِى كُنتُ تُرَٰبًۢا","translation":"Verily, We have warned you of suffering near at hand - [suffering] on the Day when man shall [clearly] see what his hands have sent ahead, and when he who has denied the truth shall say, \"Oh, would that I were mere dust...!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5712.mp3","surahId":78,"words":[{"id":41863,"position":1,"arabic":"إِنَّآ","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/078_040_001.mp3","charTypeName":"word"},{"id":41864,"position":2,"arabic":"أَنذَرْنَـٰكُمْ","translation":"তোমাদেরকে আমরা সতর্ক করছি","audioUrl":"wbw/078_040_002.mp3","charTypeName":"word"},{"id":41865,"position":3,"arabic":"عَذَابًۭا","translation":"শাস্তির","audioUrl":"wbw/078_040_003.mp3","charTypeName":"word"},{"id":41866,"position":4,"arabic":"قَرِيبًۭا","translation":"আসন্ন","audioUrl":"wbw/078_040_004.mp3","charTypeName":"word"},{"id":41867,"position":5,"arabic":"يَوْمَ","translation":"সেদিন","audioUrl":"wbw/078_040_005.mp3","charTypeName":"word"},{"id":41868,"position":6,"arabic":"يَنظُرُ","translation":"দেখবে","audioUrl":"wbw/078_040_006.mp3","charTypeName":"word"},{"id":41869,"position":7,"arabic":"ٱلْمَرْءُ","translation":"মানুষ","audioUrl":"wbw/078_040_007.mp3","charTypeName":"word"},{"id":41870,"position":8,"arabic":"مَا","translation":"যা","audioUrl":"wbw/078_040_008.mp3","charTypeName":"word"},{"id":41871,"position":9,"arabic":"قَدَّمَتْ","translation":"আগে পাঠিয়েছে","audioUrl":"wbw/078_040_009.mp3","charTypeName":"word"},{"id":41872,"position":10,"arabic":"يَدَاهُ","translation":"তার দু'হাত","audioUrl":"wbw/078_040_010.mp3","charTypeName":"word"},{"id":41873,"position":11,"arabic":"وَيَقُولُ","translation":"এবং বলবে","audioUrl":"wbw/078_040_011.mp3","charTypeName":"word"},{"id":41874,"position":12,"arabic":"ٱلْكَافِرُ","translation":"কাফের","audioUrl":"wbw/078_040_012.mp3","charTypeName":"word"},{"id":41875,"position":13,"arabic":"يَـٰلَيْتَنِى","translation":"\"হায় আমার আফসোস","audioUrl":"wbw/078_040_013.mp3","charTypeName":"word"},{"id":41876,"position":14,"arabic":"كُنتُ","translation":"যদি আমি হতাম","audioUrl":"wbw/078_040_014.mp3","charTypeName":"word"},{"id":41877,"position":15,"arabic":"تُرَٰبًۢا","translation":"মাটি\"","audioUrl":"wbw/078_040_015.mp3","charTypeName":"word"},{"id":41878,"position":16,"arabic":"٤٠","translation":"(৪০)","audioUrl":null,"charTypeName":"end"}]}]}