{"id":390,"ayahs":[{"number":36,"arabic":"فَلَمَّا جَآءَهُم مُّوسَىٰ بِـَٔايَٰتِنَا بَيِّنَٰتٍۢ قَالُوا۟ مَا هَٰذَآ إِلَّا سِحْرٌۭ مُّفْتَرًۭى وَمَا سَمِعْنَا بِهَٰذَا فِىٓ ءَابَآئِنَا ٱلْأَوَّلِينَ","translation":"But as soon as Moses came unto them with Our clear messages [Pharaoh and his great ones] said: “All this is nothing but spellbinding eloquence devised [by man]: and never did we hear [the like of] this, [nor has it ever been heard of] in the time of our forebears of old!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3288.mp3","surahId":28,"words":[{"id":38318,"position":1,"arabic":"فَلَمَّا","translation":"অতঃপর যখন","audioUrl":"wbw/028_036_001.mp3","charTypeName":"word"},{"id":38319,"position":2,"arabic":"جَآءَهُم","translation":"আসলো তাদের কাছে","audioUrl":"wbw/028_036_002.mp3","charTypeName":"word"},{"id":38320,"position":3,"arabic":"مُّوسَىٰ","translation":"মূসা","audioUrl":"wbw/028_036_003.mp3","charTypeName":"word"},{"id":38321,"position":4,"arabic":"بِـَٔايَـٰتِنَا","translation":"নিয়ে আমাদের নিদর্শনাবলী","audioUrl":"wbw/028_036_004.mp3","charTypeName":"word"},{"id":38322,"position":5,"arabic":"بَيِّنَـٰتٍۢ","translation":"সুস্পষ্ট","audioUrl":"wbw/028_036_005.mp3","charTypeName":"word"},{"id":38323,"position":6,"arabic":"قَالُوا۟","translation":"তারা বললো","audioUrl":"wbw/028_036_006.mp3","charTypeName":"word"},{"id":38324,"position":7,"arabic":"مَا","translation":"\"নয়","audioUrl":"wbw/028_036_007.mp3","charTypeName":"word"},{"id":38325,"position":8,"arabic":"هَـٰذَآ","translation":"এটা","audioUrl":"wbw/028_036_008.mp3","charTypeName":"word"},{"id":38326,"position":9,"arabic":"إِلَّا","translation":"এ ছাড়া যে","audioUrl":"wbw/028_036_009.mp3","charTypeName":"word"},{"id":38327,"position":10,"arabic":"سِحْرٌۭ","translation":"জাদু","audioUrl":"wbw/028_036_010.mp3","charTypeName":"word"},{"id":38328,"position":11,"arabic":"مُّفْتَرًۭى","translation":"অলীক","audioUrl":"wbw/028_036_011.mp3","charTypeName":"word"},{"id":38329,"position":12,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/028_036_012.mp3","charTypeName":"word"},{"id":38330,"position":13,"arabic":"سَمِعْنَا","translation":"শুনেছি আমরা","audioUrl":"wbw/028_036_013.mp3","charTypeName":"word"},{"id":38331,"position":14,"arabic":"بِهَـٰذَا","translation":"সম্পর্কে এটা","audioUrl":"wbw/028_036_014.mp3","charTypeName":"word"},{"id":38332,"position":15,"arabic":"فِىٓ","translation":"মধ্যে (নিকট)","audioUrl":"wbw/028_036_015.mp3","charTypeName":"word"},{"id":38333,"position":16,"arabic":"ءَابَآئِنَا","translation":"আমাদের পিতৃপুরুষদের\"","audioUrl":"wbw/028_036_016.mp3","charTypeName":"word"},{"id":38334,"position":17,"arabic":"ٱلْأَوَّلِينَ","translation":"পূর্বেকার\"","audioUrl":"wbw/028_036_017.mp3","charTypeName":"word"},{"id":38335,"position":18,"arabic":"٣٦","translation":"(৩৬)","audioUrl":null,"charTypeName":"end"}]},{"number":37,"arabic":"وَقَالَ مُوسَىٰ رَبِّىٓ أَعْلَمُ بِمَن جَآءَ بِٱلْهُدَىٰ مِنْ عِندِهِۦ وَمَن تَكُونُ لَهُۥ عَٰقِبَةُ ٱلدَّارِ ۖ إِنَّهُۥ لَا يُفْلِحُ ٱلظَّٰلِمُونَ","translation":"And Moses replied: “My Sustainer knows best as to who comes with guidance from Him, and to whom the future belongs! Verily, never will evil­doers attain to a happy state!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3289.mp3","surahId":28,"words":[{"id":39170,"position":1,"arabic":"وَقَالَ","translation":"এবং বললো","audioUrl":"wbw/028_037_001.mp3","charTypeName":"word"},{"id":39171,"position":2,"arabic":"مُوسَىٰ","translation":"মূসা","audioUrl":"wbw/028_037_002.mp3","charTypeName":"word"},{"id":39172,"position":3,"arabic":"رَبِّىٓ","translation":"\"আমার রব","audioUrl":"wbw/028_037_003.mp3","charTypeName":"word"},{"id":39173,"position":4,"arabic":"أَعْلَمُ","translation":"খুব ভাল জানেন","audioUrl":"wbw/028_037_004.mp3","charTypeName":"word"},{"id":39174,"position":5,"arabic":"بِمَن","translation":"(তার) সম্পর্কে যে","audioUrl":"wbw/028_037_005.mp3","charTypeName":"word"},{"id":39175,"position":6,"arabic":"جَآءَ","translation":"এসেছে","audioUrl":"wbw/028_037_006.mp3","charTypeName":"word"},{"id":39176,"position":7,"arabic":"بِٱلْهُدَىٰ","translation":"নিয়ে পথ নির্দেশ","audioUrl":"wbw/028_037_007.mp3","charTypeName":"word"},{"id":39177,"position":8,"arabic":"مِنْ","translation":"হ'তে","audioUrl":"wbw/028_037_008.mp3","charTypeName":"word"},{"id":39178,"position":9,"arabic":"عِندِهِۦ","translation":"নিকট তাঁর","audioUrl":"wbw/028_037_009.mp3","charTypeName":"word"},{"id":39179,"position":10,"arabic":"وَمَن","translation":"এবং কে","audioUrl":"wbw/028_037_010.mp3","charTypeName":"word"},{"id":39180,"position":11,"arabic":"تَكُونُ","translation":"(শুভ) হবে","audioUrl":"wbw/028_037_011.mp3","charTypeName":"word"},{"id":39181,"position":12,"arabic":"لَهُۥ","translation":"জন্যে তাঁর","audioUrl":"wbw/028_037_012.mp3","charTypeName":"word"},{"id":39182,"position":13,"arabic":"عَـٰقِبَةُ","translation":"পরিণাম","audioUrl":"wbw/028_037_013.mp3","charTypeName":"word"},{"id":39183,"position":14,"arabic":"ٱلدَّارِ ۖ","translation":"আখিরাতের","audioUrl":"wbw/028_037_014.mp3","charTypeName":"word"},{"id":39185,"position":15,"arabic":"إِنَّهُۥ","translation":"নিশ্চয়ই তা(এমন যে)","audioUrl":"wbw/028_037_016.mp3","charTypeName":"word"},{"id":39186,"position":16,"arabic":"لَا","translation":"না","audioUrl":"wbw/028_037_017.mp3","charTypeName":"word"},{"id":39187,"position":17,"arabic":"يُفْلِحُ","translation":"সফলকাম হয়","audioUrl":"wbw/028_037_018.mp3","charTypeName":"word"},{"id":39188,"position":18,"arabic":"ٱلظَّـٰلِمُونَ","translation":"সীমালঙ্ঘনকারীরা\"","audioUrl":"wbw/028_037_019.mp3","charTypeName":"word"},{"id":39189,"position":19,"arabic":"٣٧","translation":"(৩৭)","audioUrl":null,"charTypeName":"end"}]},{"number":38,"arabic":"وَقَالَ فِرْعَوْنُ يَٰٓأَيُّهَا ٱلْمَلَأُ مَا عَلِمْتُ لَكُم مِّنْ إِلَٰهٍ غَيْرِى فَأَوْقِدْ لِى يَٰهَٰمَٰنُ عَلَى ٱلطِّينِ فَٱجْعَل لِّى صَرْحًۭا لَّعَلِّىٓ أَطَّلِعُ إِلَىٰٓ إِلَٰهِ مُوسَىٰ وَإِنِّى لَأَظُنُّهُۥ مِنَ ٱلْكَٰذِبِينَ","translation":"Whereupon Pharaoh said: “O you nobles! I did not know that you could have any deity other than myself Well, then, O Haman, kindle me a fire for [baking bricks of] clay, and then build me a lofty tower, that haply I may have a look at the god of Moses although, behold, I am convinced that he is of those who [always] tell lies!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3290.mp3","surahId":28,"words":[{"id":39971,"position":1,"arabic":"وَقَالَ","translation":"এবং বললো","audioUrl":"wbw/028_038_001.mp3","charTypeName":"word"},{"id":39972,"position":2,"arabic":"فِرْعَوْنُ","translation":"ফেরআউন","audioUrl":"wbw/028_038_002.mp3","charTypeName":"word"},{"id":39973,"position":3,"arabic":"يَـٰٓأَيُّهَا","translation":"\"হে","audioUrl":"wbw/028_038_003.mp3","charTypeName":"word"},{"id":39974,"position":4,"arabic":"ٱلْمَلَأُ","translation":"\"সভাষদবৃন্দ","audioUrl":"wbw/028_038_004.mp3","charTypeName":"word"},{"id":39975,"position":5,"arabic":"مَا","translation":"না","audioUrl":"wbw/028_038_005.mp3","charTypeName":"word"},{"id":39976,"position":6,"arabic":"عَلِمْتُ","translation":"আমি জানি","audioUrl":"wbw/028_038_006.mp3","charTypeName":"word"},{"id":39977,"position":7,"arabic":"لَكُم","translation":"জন্যে তোমাদের","audioUrl":"wbw/028_038_007.mp3","charTypeName":"word"},{"id":39978,"position":8,"arabic":"مِّنْ","translation":"কোনো","audioUrl":"wbw/028_038_008.mp3","charTypeName":"word"},{"id":39979,"position":9,"arabic":"إِلَـٰهٍ","translation":"ইলাহ","audioUrl":"wbw/028_038_009.mp3","charTypeName":"word"},{"id":39980,"position":10,"arabic":"غَيْرِى","translation":"আমি ছাড়া","audioUrl":"wbw/028_038_010.mp3","charTypeName":"word"},{"id":39981,"position":11,"arabic":"فَأَوْقِدْ","translation":"সুতরাং জ্বালাও আগুন","audioUrl":"wbw/028_038_011.mp3","charTypeName":"word"},{"id":39982,"position":12,"arabic":"لِى","translation":"জন্যে আমার","audioUrl":"wbw/028_038_012.mp3","charTypeName":"word"},{"id":39983,"position":13,"arabic":"يَـٰهَـٰمَـٰنُ","translation":"হে হামান","audioUrl":"wbw/028_038_013.mp3","charTypeName":"word"},{"id":39984,"position":14,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/028_038_014.mp3","charTypeName":"word"},{"id":39985,"position":15,"arabic":"ٱلطِّينِ","translation":"মাটির (অর্থাৎ ইট তৈরী করো)","audioUrl":"wbw/028_038_015.mp3","charTypeName":"word"},{"id":39986,"position":16,"arabic":"فَٱجْعَل","translation":"অতঃপর বানাও","audioUrl":"wbw/028_038_016.mp3","charTypeName":"word"},{"id":39987,"position":17,"arabic":"لِّى","translation":"জন্যে আমার","audioUrl":"wbw/028_038_017.mp3","charTypeName":"word"},{"id":39988,"position":18,"arabic":"صَرْحًۭا","translation":"সুউচ্চ প্রাসাদ","audioUrl":"wbw/028_038_018.mp3","charTypeName":"word"},{"id":39989,"position":19,"arabic":"لَّعَلِّىٓ","translation":"যাতে আমি","audioUrl":"wbw/028_038_019.mp3","charTypeName":"word"},{"id":39990,"position":20,"arabic":"أَطَّلِعُ","translation":"আমি চড়ে দেখতে পারি","audioUrl":"wbw/028_038_020.mp3","charTypeName":"word"},{"id":39991,"position":21,"arabic":"إِلَىٰٓ","translation":"প্রতি","audioUrl":"wbw/028_038_021.mp3","charTypeName":"word"},{"id":39992,"position":22,"arabic":"إِلَـٰهِ","translation":"ইলাহর","audioUrl":"wbw/028_038_022.mp3","charTypeName":"word"},{"id":39993,"position":23,"arabic":"مُوسَىٰ","translation":"মূসার","audioUrl":"wbw/028_038_023.mp3","charTypeName":"word"},{"id":39994,"position":24,"arabic":"وَإِنِّى","translation":"এবং নিশ্চয়ই আমি","audioUrl":"wbw/028_038_024.mp3","charTypeName":"word"},{"id":39995,"position":25,"arabic":"لَأَظُنُّهُۥ","translation":"অবশ্যই আমি মনে করি তাকে","audioUrl":"wbw/028_038_025.mp3","charTypeName":"word"},{"id":39996,"position":26,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/028_038_026.mp3","charTypeName":"word"},{"id":39997,"position":27,"arabic":"ٱلْكَـٰذِبِينَ","translation":"মিথ্যাবাদীদের\"","audioUrl":"wbw/028_038_027.mp3","charTypeName":"word"},{"id":39998,"position":28,"arabic":"٣٨","translation":"(৩৮)","audioUrl":null,"charTypeName":"end"}]},{"number":39,"arabic":"وَٱسْتَكْبَرَ هُوَ وَجُنُودُهُۥ فِى ٱلْأَرْضِ بِغَيْرِ ٱلْحَقِّ وَظَنُّوٓا۟ أَنَّهُمْ إِلَيْنَا لَا يُرْجَعُونَ","translation":"Thus arrogantly, without the least good sense, did he and his hosts behave on earth - just as if they thought that they would never have to appear before Us [for judgment]!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3291.mp3","surahId":28,"words":[{"id":40791,"position":1,"arabic":"وَٱسْتَكْبَرَ","translation":"এবং সে অহংকার করলো","audioUrl":"wbw/028_039_001.mp3","charTypeName":"word"},{"id":40792,"position":2,"arabic":"هُوَ","translation":"সে","audioUrl":"wbw/028_039_002.mp3","charTypeName":"word"},{"id":40793,"position":3,"arabic":"وَجُنُودُهُۥ","translation":"ও তার সৈন্য বাহিনী","audioUrl":"wbw/028_039_003.mp3","charTypeName":"word"},{"id":40794,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/028_039_004.mp3","charTypeName":"word"},{"id":40795,"position":5,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/028_039_005.mp3","charTypeName":"word"},{"id":40796,"position":6,"arabic":"بِغَيْرِ","translation":"ছাড়া","audioUrl":"wbw/028_039_006.mp3","charTypeName":"word"},{"id":40797,"position":7,"arabic":"ٱلْحَقِّ","translation":"কোনো অধিকার","audioUrl":"wbw/028_039_007.mp3","charTypeName":"word"},{"id":40798,"position":8,"arabic":"وَظَنُّوٓا۟","translation":"এবং তারা মনে করেছিলো","audioUrl":"wbw/028_039_008.mp3","charTypeName":"word"},{"id":40799,"position":9,"arabic":"أَنَّهُمْ","translation":"যে তারা","audioUrl":"wbw/028_039_009.mp3","charTypeName":"word"},{"id":40800,"position":10,"arabic":"إِلَيْنَا","translation":"দিকে আমাদের","audioUrl":"wbw/028_039_010.mp3","charTypeName":"word"},{"id":40801,"position":11,"arabic":"لَا","translation":"না","audioUrl":"wbw/028_039_011.mp3","charTypeName":"word"},{"id":40802,"position":12,"arabic":"يُرْجَعُونَ","translation":"তারা প্রত্যাবর্তিত হবে","audioUrl":"wbw/028_039_012.mp3","charTypeName":"word"},{"id":40803,"position":13,"arabic":"٣٩","translation":"(৩৯)","audioUrl":null,"charTypeName":"end"}]},{"number":40,"arabic":"فَأَخَذْنَٰهُ وَجُنُودَهُۥ فَنَبَذْنَٰهُمْ فِى ٱلْيَمِّ ۖ فَٱنظُرْ كَيْفَ كَانَ عَٰقِبَةُ ٱلظَّٰلِمِينَ","translation":"And so We seized him and his hosts and cast them into the sea: and behold what happened in the end to those evildoers:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3292.mp3","surahId":28,"words":[{"id":41651,"position":1,"arabic":"فَأَخَذْنَـٰهُ","translation":"অতঃপর আমরা ধরলাম তাকে","audioUrl":"wbw/028_040_001.mp3","charTypeName":"word"},{"id":41652,"position":2,"arabic":"وَجُنُودَهُۥ","translation":"ও তার সৈন্যবাহিনীকেও","audioUrl":"wbw/028_040_002.mp3","charTypeName":"word"},{"id":41653,"position":3,"arabic":"فَنَبَذْنَـٰهُمْ","translation":"অতঃপর আমরা নিক্ষেপ করলাম তাদেরকে","audioUrl":"wbw/028_040_003.mp3","charTypeName":"word"},{"id":41654,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/028_040_004.mp3","charTypeName":"word"},{"id":41655,"position":5,"arabic":"ٱلْيَمِّ ۖ","translation":"সমুদ্রের","audioUrl":"wbw/028_040_005.mp3","charTypeName":"word"},{"id":41657,"position":6,"arabic":"فَٱنظُرْ","translation":"এখন দেখো","audioUrl":"wbw/028_040_007.mp3","charTypeName":"word"},{"id":41658,"position":7,"arabic":"كَيْفَ","translation":"কেমন","audioUrl":"wbw/028_040_008.mp3","charTypeName":"word"},{"id":41659,"position":8,"arabic":"كَانَ","translation":"হয়েছিলো","audioUrl":"wbw/028_040_009.mp3","charTypeName":"word"},{"id":41660,"position":9,"arabic":"عَـٰقِبَةُ","translation":"পরিণাম","audioUrl":"wbw/028_040_010.mp3","charTypeName":"word"},{"id":41661,"position":10,"arabic":"ٱلظَّـٰلِمِينَ","translation":"সীমালঙ্ঘনকারীদের","audioUrl":"wbw/028_040_011.mp3","charTypeName":"word"},{"id":41662,"position":11,"arabic":"٤٠","translation":"(৪০)","audioUrl":null,"charTypeName":"end"}]},{"number":41,"arabic":"وَجَعَلْنَٰهُمْ أَئِمَّةًۭ يَدْعُونَ إِلَى ٱلنَّارِ ۖ وَيَوْمَ ٱلْقِيَٰمَةِ لَا يُنصَرُونَ","translation":"[We destroyed them,] and We set them up as archetypes [of evil] that show the way to the fire [of hell]; and [whereas] no succour will come to them on Resurrection Day,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3293.mp3","surahId":28,"words":[{"id":42471,"position":1,"arabic":"وَجَعَلْنَـٰهُمْ","translation":"আমরা বানিয়েছিলাম তাদেরকে","audioUrl":"wbw/028_041_001.mp3","charTypeName":"word"},{"id":42472,"position":2,"arabic":"أَئِمَّةًۭ","translation":"নেতৃবৃন্দ (অথচ)","audioUrl":"wbw/028_041_002.mp3","charTypeName":"word"},{"id":42473,"position":3,"arabic":"يَدْعُونَ","translation":"তারা ডাকে (লোকদেরকে)","audioUrl":"wbw/028_041_003.mp3","charTypeName":"word"},{"id":42474,"position":4,"arabic":"إِلَى","translation":"দিকে","audioUrl":"wbw/028_041_004.mp3","charTypeName":"word"},{"id":42475,"position":5,"arabic":"ٱلنَّارِ ۖ","translation":"জাহান্নামের","audioUrl":"wbw/028_041_005.mp3","charTypeName":"word"},{"id":42477,"position":6,"arabic":"وَيَوْمَ","translation":"এবং দিনে","audioUrl":"wbw/028_041_007.mp3","charTypeName":"word"},{"id":42478,"position":7,"arabic":"ٱلْقِيَـٰمَةِ","translation":"ক্বিয়ামাতের","audioUrl":"wbw/028_041_008.mp3","charTypeName":"word"},{"id":42479,"position":8,"arabic":"لَا","translation":"না","audioUrl":"wbw/028_041_009.mp3","charTypeName":"word"},{"id":42480,"position":9,"arabic":"يُنصَرُونَ","translation":"তাদের সাহায্য করা হবে","audioUrl":"wbw/028_041_010.mp3","charTypeName":"word"},{"id":42481,"position":10,"arabic":"٤١","translation":"(৪১)","audioUrl":null,"charTypeName":"end"}]},{"number":42,"arabic":"وَأَتْبَعْنَٰهُمْ فِى هَٰذِهِ ٱلدُّنْيَا لَعْنَةًۭ ۖ وَيَوْمَ ٱلْقِيَٰمَةِ هُم مِّنَ ٱلْمَقْبُوحِينَ","translation":"We have caused a curse to follow them in this world as well; and on Resurrection Day they will find themselves among those who are bereft of all good.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3294.mp3","surahId":28,"words":[{"id":43159,"position":1,"arabic":"وَأَتْبَعْنَـٰهُمْ","translation":"এবং আমরা লাগিয়ে দিয়েছি পিছনে তাদের","audioUrl":"wbw/028_042_001.mp3","charTypeName":"word"},{"id":43160,"position":2,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/028_042_002.mp3","charTypeName":"word"},{"id":43161,"position":3,"arabic":"هَـٰذِهِ","translation":"এই","audioUrl":"wbw/028_042_003.mp3","charTypeName":"word"},{"id":43162,"position":4,"arabic":"ٱلدُّنْيَا","translation":"দুনিয়ার","audioUrl":"wbw/028_042_004.mp3","charTypeName":"word"},{"id":43163,"position":5,"arabic":"لَعْنَةًۭ ۖ","translation":"অভিশাপ","audioUrl":"wbw/028_042_005.mp3","charTypeName":"word"},{"id":43165,"position":6,"arabic":"وَيَوْمَ","translation":"এবং দিনে","audioUrl":"wbw/028_042_007.mp3","charTypeName":"word"},{"id":43166,"position":7,"arabic":"ٱلْقِيَـٰمَةِ","translation":"ক্বিয়ামাতের","audioUrl":"wbw/028_042_008.mp3","charTypeName":"word"},{"id":43167,"position":8,"arabic":"هُم","translation":"তারা (হবে)","audioUrl":"wbw/028_042_009.mp3","charTypeName":"word"},{"id":43168,"position":9,"arabic":"مِّنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/028_042_010.mp3","charTypeName":"word"},{"id":43169,"position":10,"arabic":"ٱلْمَقْبُوحِينَ","translation":"ঘৃণিতদের","audioUrl":"wbw/028_042_011.mp3","charTypeName":"word"},{"id":43170,"position":11,"arabic":"٤٢","translation":"(৪২)","audioUrl":null,"charTypeName":"end"}]},{"number":43,"arabic":"وَلَقَدْ ءَاتَيْنَا مُوسَى ٱلْكِتَٰبَ مِنۢ بَعْدِ مَآ أَهْلَكْنَا ٱلْقُرُونَ ٱلْأُولَىٰ بَصَآئِرَ لِلنَّاسِ وَهُدًۭى وَرَحْمَةًۭ لَّعَلَّهُمْ يَتَذَكَّرُونَ","translation":"And [then,] indeed, after We had destroyed those earlier generations [of sinners], We vouchsafed unto Moses [Our] revelation as a means of insight for men, and as a guidance and grace, so that they might bethink themselves [of Us].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3295.mp3","surahId":28,"words":[{"id":43859,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/028_043_001.mp3","charTypeName":"word"},{"id":43860,"position":2,"arabic":"ءَاتَيْنَا","translation":"আমরা দিয়েছি","audioUrl":"wbw/028_043_002.mp3","charTypeName":"word"},{"id":43861,"position":3,"arabic":"مُوسَى","translation":"মূসাকে","audioUrl":"wbw/028_043_003.mp3","charTypeName":"word"},{"id":43862,"position":4,"arabic":"ٱلْكِتَـٰبَ","translation":"কিতাব","audioUrl":"wbw/028_043_004.mp3","charTypeName":"word"},{"id":43863,"position":5,"arabic":"مِنۢ","translation":"থেকে","audioUrl":"wbw/028_043_005.mp3","charTypeName":"word"},{"id":43864,"position":6,"arabic":"بَعْدِ","translation":"পর","audioUrl":"wbw/028_043_006.mp3","charTypeName":"word"},{"id":43865,"position":7,"arabic":"مَآ","translation":"যখন","audioUrl":"wbw/028_043_007.mp3","charTypeName":"word"},{"id":43866,"position":8,"arabic":"أَهْلَكْنَا","translation":"ধ্বংস করে দিয়েছি আমরা","audioUrl":"wbw/028_043_008.mp3","charTypeName":"word"},{"id":43867,"position":9,"arabic":"ٱلْقُرُونَ","translation":"বহুমানবগোষ্ঠীকে","audioUrl":"wbw/028_043_009.mp3","charTypeName":"word"},{"id":43868,"position":10,"arabic":"ٱلْأُولَىٰ","translation":"পুর্ববর্তী","audioUrl":"wbw/028_043_010.mp3","charTypeName":"word"},{"id":43869,"position":11,"arabic":"بَصَآئِرَ","translation":"জ্ঞান-বর্তিকাস্বরুপ","audioUrl":"wbw/028_043_011.mp3","charTypeName":"word"},{"id":43870,"position":12,"arabic":"لِلنَّاسِ","translation":"জন্যে মানুষের","audioUrl":"wbw/028_043_012.mp3","charTypeName":"word"},{"id":43871,"position":13,"arabic":"وَهُدًۭى","translation":"এবং পথ নির্দেশ","audioUrl":"wbw/028_043_013.mp3","charTypeName":"word"},{"id":43872,"position":14,"arabic":"وَرَحْمَةًۭ","translation":"ও দয়া হিসেবে","audioUrl":"wbw/028_043_014.mp3","charTypeName":"word"},{"id":43873,"position":15,"arabic":"لَّعَلَّهُمْ","translation":"যাতে তারা","audioUrl":"wbw/028_043_015.mp3","charTypeName":"word"},{"id":43874,"position":16,"arabic":"يَتَذَكَّرُونَ","translation":"শিক্ষাগ্রহণ করে","audioUrl":"wbw/028_043_016.mp3","charTypeName":"word"},{"id":43875,"position":17,"arabic":"٤٣","translation":"(৪৩)","audioUrl":null,"charTypeName":"end"}]}]}