eName":"word"},{"id":30157,"position":15,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/029_027_016.mp3","charTypeName":"word"},{"id":30158,"position":16,"arabic":"ٱلْـَٔاخِرَةِ","translation":"আখেরাতের","audioUrl":"wbw/029_027_017.mp3","charTypeName":"word"},{"id":30159,"position":17,"arabic":"لَمِنَ","translation":"অবশ্যই অন্তর্ভুক্ত","audioUrl":"wbw/029_027_018.mp3","charTypeName":"word"},{"id":30160,"position":18,"arabic":"ٱلصَّـٰلِحِينَ","translation":"সৎকর্মশীলদের","audioUrl":"wbw/029_027_019.mp3","charTypeName":"word"},{"id":30161,"position":19,"arabic":"٢٧","translation":"(২৭)","audioUrl":null,"charTypeName":"end"}]},{"number":28,"arabic":"وَلُوطًا إِذْ قَالَ لِقَوْمِهِۦٓ إِنَّكُمْ لَتَأْتُونَ ٱلْفَٰحِشَةَ مَا سَبَقَكُم بِهَا مِنْ أَحَدٍۢ مِّنَ ٱلْعَٰلَمِينَ","translation":"And Lot, [too, was inspired by Us] when he said unto his people: “Verily, you commit abominations such as none in all the world has ever committed before you!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3368.mp3","surahId":29,"words":[{"id":31203,"position":1,"arabic":"وَلُوطًا","translation":"এবং (স্মরণ করো) লূতের (ঘটনা হলো)","audioUrl":"wbw/029_028_001.mp3","charTypeName":"word"},{"id":31204,"position":2,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/029_028_002.mp3","charTypeName":"word"},{"id":31205,"position":3,"arabic":"قَالَ","translation":"বলেছিলো","audioUrl":"wbw/029_028_003.mp3","charTypeName":"word"},{"id":31206,"position":4,"arabic":"لِقَوْمِهِۦٓ","translation":"উদ্দেশ্যে তার জাতির","audioUrl":"wbw/029_028_004.mp3","charTypeName":"word"},{"id":31207,"position":5,"arabic":"إِنَّكُمْ","translation":"\"নিশ্চয়ই তোমরা","audioUrl":"wbw/029_028_005.mp3","charTypeName":"word"},{"id":31208,"position":6,"arabic":"لَتَأْتُونَ","translation":"অবশ্যই তোমরা আছো (করছো)","audioUrl":"wbw/029_028_006.mp3","charTypeName":"word"},{"id":31209,"position":7,"arabic":"ٱلْفَـٰحِشَةَ","translation":"(এমন)অশ্লীলকর্মে","audioUrl":"wbw/029_028_007.mp3","charTypeName":"word