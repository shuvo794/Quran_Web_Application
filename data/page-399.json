{"id":399,"ayahs":[{"number":24,"arabic":"فَمَا كَانَ جَوَابَ قَوْمِهِۦٓ إِلَّآ أَن قَالُوا۟ ٱقْتُلُوهُ أَوْ حَرِّقُوهُ فَأَنجَىٰهُ ٱللَّهُ مِنَ ٱلنَّارِ ۚ إِنَّ فِى ذَٰلِكَ لَءَايَٰتٍۢ لِّقَوْمٍۢ يُؤْمِنُونَ","translation":"Now [as for Abraham,] his people’s only answer was, “Slay him, or burn him!” – but God saved him from the fire. Behold, in this [story] there are messages indeed for people who will believe!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3364.mp3","surahId":29,"words":[{"id":27247,"position":1,"arabic":"فَمَا","translation":"অতঃপর না","audioUrl":"wbw/029_024_001.mp3","charTypeName":"word"},{"id":27248,"position":2,"arabic":"كَانَ","translation":"ছিলো","audioUrl":"wbw/029_024_002.mp3","charTypeName":"word"},{"id":27249,"position":3,"arabic":"جَوَابَ","translation":"জবাব","audioUrl":"wbw/029_024_003.mp3","charTypeName":"word"},{"id":27250,"position":4,"arabic":"قَوْمِهِۦٓ","translation":"জাতির তার","audioUrl":"wbw/029_024_004.mp3","charTypeName":"word"},{"id":27251,"position":5,"arabic":"إِلَّآ","translation":"এ ছাড়া","audioUrl":"wbw/029_024_005.mp3","charTypeName":"word"},{"id":27252,"position":6,"arabic":"أَن","translation":"যে","audioUrl":"wbw/029_024_006.mp3","charTypeName":"word"},{"id":27253,"position":7,"arabic":"قَالُوا۟","translation":"তারা বললো","audioUrl":"wbw/029_024_007.mp3","charTypeName":"word"},{"id":27254,"position":8,"arabic":"ٱقْتُلُوهُ","translation":"\"তোমরা তাকে হত্যা করো","audioUrl":"wbw/029_024_008.mp3","charTypeName":"word"},{"id":27255,"position":9,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/029_024_009.mp3","charTypeName":"word"},{"id":27256,"position":10,"arabic":"حَرِّقُوهُ","translation":"তাকে অাগুনে পোড়াও\"","audioUrl":"wbw/029_024_010.mp3","charTypeName":"word"},{"id":27257,"position":11,"arabic":"فَأَنجَىٰهُ","translation":"অতঃপর রক্ষা করলেন তাকে","audioUrl":"wbw/029_024_011.mp3","charTypeName":"word"},{"id":27258,"position":12,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌","audioUrl":"wbw/029_024_012.mp3","charTypeName":"word"},{"id":27259,"position":13,"arabic":"مِنَ","translation":"হ'তে","audioUrl":"wbw/029_024_013.mp3","charTypeName":"word"},{"id":27260,"position":14,"arabic":"ٱلنَّارِ ۚ","translation":"আগুন","audioUrl":"wbw/029_024_014.mp3","charTypeName":"word"},{"id":27262,"position":15,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/029_024_016.mp3","charTypeName":"word"},{"id":27263,"position":16,"arabic":"فِى","translation":"মধ্যে (আছে)","audioUrl":"wbw/029_024_017.mp3","charTypeName":"word"},{"id":27264,"position":17,"arabic":"ذَٰلِكَ","translation":"এর","audioUrl":"wbw/029_024_018.mp3","charTypeName":"word"},{"id":27265,"position":18,"arabic":"لَـَٔايَـٰتٍۢ","translation":"অবশ্যই নিদর্শনাবলী","audioUrl":"wbw/029_024_019.mp3","charTypeName":"word"},{"id":27266,"position":19,"arabic":"لِّقَوْمٍۢ","translation":"জন্যে সম্প্রদায়ের","audioUrl":"wbw/029_024_020.mp3","charTypeName":"word"},{"id":27267,"position":20,"arabic":"يُؤْمِنُونَ","translation":"(যারা) ঈমান আনে","audioUrl":"wbw/029_024_021.mp3","charTypeName":"word"},{"id":27268,"position":21,"arabic":"٢٤","translation":"(২৪)","audioUrl":null,"charTypeName":"end"}]},{"number":25,"arabic":"وَقَالَ إِنَّمَا ٱتَّخَذْتُم مِّن دُونِ ٱللَّهِ أَوْثَٰنًۭا مَّوَدَّةَ بَيْنِكُمْ فِى ٱلْحَيَوٰةِ ٱلدُّنْيَا ۖ ثُمَّ يَوْمَ ٱلْقِيَٰمَةِ يَكْفُرُ بَعْضُكُم بِبَعْضٍۢ وَيَلْعَنُ بَعْضُكُم بَعْضًۭا وَمَأْوَىٰكُمُ ٱلنَّارُ وَمَا لَكُم مِّن نَّٰصِرِينَ","translation":"And [Abraham] said: “You have chosen to worship idols instead of God for no other reason than to have a bond of love in the life of this world, between yourselves [and your forebears]: but then, on Resurrection Day, you shall disown one another and curse one another - for the goal of you all will be the fire, and you will have none to succour you.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3365.mp3","surahId":29,"words":[{"id":28300,"position":1,"arabic":"وَقَالَ","translation":"এবং সে বলেছিলো","audioUrl":"wbw/029_025_001.mp3","charTypeName":"word"},{"id":28301,"position":2,"arabic":"إِنَّمَا","translation":"\"মূলতঃ","audioUrl":"wbw/029_025_002.mp3","charTypeName":"word"},{"id":28302,"position":3,"arabic":"ٱتَّخَذْتُم","translation":"তোমরা গ্রহণ করেছো","audioUrl":"wbw/029_025_003.mp3","charTypeName":"word"},{"id":28303,"position":4,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/029_025_004.mp3","charTypeName":"word"},{"id":28304,"position":5,"arabic":"دُونِ","translation":"ছাড়া","audioUrl":"wbw/029_025_005.mp3","charTypeName":"word"},{"id":28305,"position":6,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌","audioUrl":"wbw/029_025_006.mp3","charTypeName":"word"},{"id":28306,"position":7,"arabic":"أَوْثَـٰنًۭا","translation":"মূর্তিগুলোকে","audioUrl":"wbw/029_025_007.mp3","charTypeName":"word"},{"id":28307,"position":8,"arabic":"مَّوَدَّةَ","translation":"বন্ধুত্ব রক্ষার (উপায় হিসাবে)","audioUrl":"wbw/029_025_008.mp3","charTypeName":"word"},{"id":28308,"position":9,"arabic":"بَيْنِكُمْ","translation":"মাঝে তোমাদের","audioUrl":"wbw/029_025_009.mp3","charTypeName":"word"},{"id":28309,"position":10,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/029_025_010.mp3","charTypeName":"word"},{"id":28310,"position":11,"arabic":"ٱلْحَيَوٰةِ","translation":"জীবনের","audioUrl":"wbw/029_025_011.mp3","charTypeName":"word"},{"id":28311,"position":12,"arabic":"ٱلدُّنْيَا ۖ","translation":"পার্থিব","audioUrl":"wbw/029_025_012.mp3","charTypeName":"word"},{"id":28313,"position":13,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/029_025_014.mp3","charTypeName":"word"},{"id":28314,"position":14,"arabic":"يَوْمَ","translation":"দিনে","audioUrl":"wbw/029_025_015.mp3","charTypeName":"word"},{"id":28315,"position":15,"arabic":"ٱلْقِيَـٰمَةِ","translation":"ক্বিয়ামাতের","audioUrl":"wbw/029_025_016.mp3","charTypeName":"word"},{"id":28316,"position":16,"arabic":"يَكْفُرُ","translation":"অস্বীকার করবে","audioUrl":"wbw/029_025_017.mp3","charTypeName":"word"},{"id":28317,"position":17,"arabic":"بَعْضُكُم","translation":"একে তোমাদের","audioUrl":"wbw/029_025_018.mp3","charTypeName":"word"},{"id":28318,"position":18,"arabic":"بِبَعْضٍۢ","translation":"প্রতি অপরের","audioUrl":"wbw/029_025_019.mp3","charTypeName":"word"},{"id":28319,"position":19,"arabic":"وَيَلْعَنُ","translation":"ও অভিশাপ দিবে","audioUrl":"wbw/029_025_020.mp3","charTypeName":"word"},{"id":28320,"position":20,"arabic":"بَعْضُكُم","translation":"একে তোমাদের","audioUrl":"wbw/029_025_021.mp3","charTypeName":"word"},{"id":28321,"position":21,"arabic":"بَعْضًۭا","translation":"অপরকে","audioUrl":"wbw/029_025_022.mp3","charTypeName":"word"},{"id":28322,"position":22,"arabic":"وَمَأْوَىٰكُمُ","translation":"এবং তোমাদের আবাস (হবে)","audioUrl":"wbw/029_025_023.mp3","charTypeName":"word"},{"id":28323,"position":23,"arabic":"ٱلنَّارُ","translation":"আগুন","audioUrl":"wbw/029_025_024.mp3","charTypeName":"word"},{"id":28324,"position":24,"arabic":"وَمَا","translation":"ও না","audioUrl":"wbw/029_025_025.mp3","charTypeName":"word"},{"id":28325,"position":25,"arabic":"لَكُم","translation":"জন্যে (থাকবে)তোমাদের","audioUrl":"wbw/029_025_026.mp3","charTypeName":"word"},{"id":28326,"position":26,"arabic":"مِّن","translation":"কোনো","audioUrl":"wbw/029_025_027.mp3","charTypeName":"word"},{"id":28327,"position":27,"arabic":"نَّـٰصِرِينَ","translation":"সাহায্যকারী\"","audioUrl":"wbw/029_025_028.mp3","charTypeName":"word"},{"id":28328,"position":28,"arabic":"٢٥","translation":"(২৫)","audioUrl":null,"charTypeName":"end"}]},{"number":26,"arabic":"۞ فَـَٔامَنَ لَهُۥ لُوطٌۭ ۘ وَقَالَ إِنِّى مُهَاجِرٌ إِلَىٰ رَبِّىٓ ۖ إِنَّهُۥ هُوَ ٱلْعَزِيزُ ٱلْحَكِيمُ","translation":"Thereupon [his brother’s son] Lot came to believe in him and said: “Verily, I [too] shall forsake the domain of evil [and turn] to my Sustainer: for, verily, He alone is almighty, truly wise!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3366.mp3","surahId":29,"words":[{"id":29227,"position":1,"arabic":"۞ فَـَٔامَنَ","translation":"তখন