{"id":551,"ayahs":[{"number":12,"arabic":"يَٰٓأَيُّهَا ٱلنَّبِىُّ إِذَا جَآءَكَ ٱلْمُؤْمِنَٰتُ يُبَايِعْنَكَ عَلَىٰٓ أَن لَّا يُشْرِكْنَ بِٱللَّهِ شَيْـًۭٔا وَلَا يَسْرِقْنَ وَلَا يَزْنِينَ وَلَا يَقْتُلْنَ أَوْلَٰدَهُنَّ وَلَا يَأْتِينَ بِبُهْتَٰنٍۢ يَفْتَرِينَهُۥ بَيْنَ أَيْدِيهِنَّ وَأَرْجُلِهِنَّ وَلَا يَعْصِينَكَ فِى مَعْرُوفٍۢ ۙ فَبَايِعْهُنَّ وَٱسْتَغْفِرْ لَهُنَّ ٱللَّهَ ۖ إِنَّ ٱللَّهَ غَفُورٌۭ رَّحِيمٌۭ","translation":"O Prophet! Whenever believing women come unto thee to pledge their allegiance to thee, [pledging] that [henceforth] they would not ascribe divinity, in any way, to aught but God, and would not steal, and would not commit adultery, and would not kill their children, and would not indulge in slander, falsely devising it out of nothingness: and would not disobey thee in anything [that thou declarest to be] right - then accept their pledge of allegiance, and pray to God to forgive them their [past] sins: for, behold, God is much-forgiving, a dispenser of grace.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5162.mp3","surahId":60,"words":[{"id":13949,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/060_012_001.mp3","charTypeName":"word"},{"id":13950,"position":2,"arabic":"ٱلنَّبِىُّ","translation":"নবী","audioUrl":"wbw/060_012_002.mp3","charTypeName":"word"},{"id":13951,"position":3,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/060_012_003.mp3","charTypeName":"word"},{"id":13952,"position":4,"arabic":"جَآءَكَ","translation":"তোমার কাছে আসবে","audioUrl":"wbw/060_012_004.mp3","charTypeName":"word"},{"id":13953,"position":5,"arabic":"ٱلْمُؤْمِنَـٰتُ","translation":"মুমিন নারীরা","audioUrl":"wbw/060_012_005.mp3","charTypeName":"word"},{"id":13954,"position":6,"arabic":"يُبَايِعْنَكَ","translation":"তোমার কাছে বয়াত করবে","audioUrl":"wbw/060_012_006.mp3","charTypeName":"word"},{"id":13955,"position":7,"arabic":"عَلَىٰٓ","translation":"(এ কথার) উপর","audioUrl":"wbw/060_012_007.mp3","charTypeName":"word"},{"id":13956,"position":8,"arabic":"أَن","translation":"যে","audioUrl":"wbw/060_012_008.mp3","charTypeName":"word"},{"id":13957,"position":9,"arabic":"لَّا","translation":"না","audioUrl":"wbw/060_012_009.mp3","charTypeName":"word"},{"id":13958,"position":10,"arabic":"يُشْرِكْنَ","translation":"তারা শিরক করবে","audioUrl":"wbw/060_012_010.mp3","charTypeName":"word"},{"id":13959,"position":11,"arabic":"بِٱللَّهِ","translation":"আল্লাহর সাথে","audioUrl":"wbw/060_012_011.mp3","charTypeName":"word"},{"id":13960,"position":12,"arabic":"شَيْـًۭٔا","translation":"কোনকিছু","audioUrl":"wbw/060_012_012.mp3","charTypeName":"word"},{"id":13961,"position":13,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/060_012_013.mp3","charTypeName":"word"},{"id":13962,"position":14,"arabic":"يَسْرِقْنَ","translation":"তারা চুরি করবে","audioUrl":"wbw/060_012_014.mp3","charTypeName":"word"},{"id":13963,"position":15,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/060_012_015.mp3","charTypeName":"word"},{"id":13964,"position":16,"arabic":"يَزْنِينَ","translation":"তারা জিনা করবে না","audioUrl":"wbw/060_012_016.mp3","charTypeName":"word"},{"id":13965,"position":17,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/060_012_017.mp3","charTypeName":"word"},{"id":13966,"position":18,"arabic":"يَقْتُلْنَ","translation":"তারা হত্যা করবে","audioUrl":"wbw/060_012_018.mp3","charTypeName":"word"},{"id":13967,"position":19,"arabic":"أَوْلَـٰدَهُنَّ","translation":"তাআদের সন্তানদের","audioUrl":"wbw/060_012_019.mp3","charTypeName":"word"},{"id":13968,"position":20,"arabic":"وَلَا","translation":"ও না","audioUrl":"wbw/060_012_020.mp3","charTypeName":"word"},{"id":13969,"position":21,"arabic":"يَأْتِينَ","translation":"তারা আনবে","audioUrl":"wbw/060_012_021.mp3","charTypeName":"word"},{"id":13970,"position":22,"arabic":"بِبُهْتَـٰنٍۢ","translation":"অপমান","audioUrl":"wbw/060_012_022.mp3","charTypeName":"word"},{"id":13971,"position":23,"arabic":"يَفْتَرِينَهُۥ","translation":"তা তারা রচনা