mp3","charTypeName":"word"},{"id":13989,"position":39,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]},{"number":13,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ لَا تَتَوَلَّوْا۟ قَوْمًا غَضِبَ ٱللَّهُ عَلَيْهِمْ قَدْ يَئِسُوا۟ مِنَ ٱلْءَاخِرَةِ كَمَا يَئِسَ ٱلْكُفَّارُ مِنْ أَصْحَٰبِ ٱلْقُبُورِ","translation":"O YOU who have attained to faith! Be not friends with people whom God has condemned! They [who would befriend them] are indeed bereft of all hope of a life to come - just as those deniers of the truth are bereft of all hope of [ever again seeing] those who are [now] in their graves.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5163.mp3","surahId":60,"words":[{"id":15093,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"ওহে","audioUrl":"wbw/060_013_001.mp3","charTypeName":"word"},{"id":15094,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/060_013_002.mp3","charTypeName":"word"},{"id":15095,"position":3,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছ","audioUrl":"wbw/060_013_003.mp3","charTypeName":"word"},{"id":15096,"position":4,"arabic":"لَا","translation":"না","audioUrl":"wbw/060_013_004.mp3","charTypeName":"word"},{"id":15097,"position":5,"arabic":"تَتَوَلَّوْا۟","translation":"তোমতা বন্ধুত্ব করো","audioUrl":"wbw/060_013_005.mp3","charTypeName":"word"},{"id":15098,"position":6,"arabic":"قَوْمًا","translation":"লোকদের (সংগে)","audioUrl":"wbw/060_013_006.mp3","charTypeName":"word"},{"id":15099,"position":7,"arabic":"غَضِبَ","translation":"গযব দিয়েছেন","audioUrl":"wbw/060_013_007.mp3","charTypeName":"word"},{"id":15100,"position":8,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/060_013_008.mp3","charTypeName":"word"},{"id":15101,"position":9,"arabic":"عَلَيْهِمْ","translation":"যাদের উপর","audioUrl":"wbw/060_013_009.mp3","charTypeName":"word"},{"id":15102,"position":10,"arabic":"قَدْ","translation":"নিশ্চই","audioUrl":"wbw/060_013_010.mp3","charTypeName":"word"},{"id":15103,"posi