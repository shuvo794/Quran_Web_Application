nslation":"যা","audioUrl":"wbw/061_002_006.mp3","charTypeName":"word"},{"id":1358,"position":7,"arabic":"لَا","translation":"না","audioUrl":"wbw/061_002_007.mp3","charTypeName":"word"},{"id":1359,"position":8,"arabic":"تَفْعَلُونَ","translation":"তোমরা করো","audioUrl":"wbw/061_002_008.mp3","charTypeName":"word"},{"id":1360,"position":9,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"كَبُرَ مَقْتًا عِندَ ٱللَّهِ أَن تَقُولُوا۟ مَا لَا تَفْعَلُونَ","translation":"Most loathsome is it in the sight of God that you say what you do not do!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5166.mp3","surahId":61,"words":[{"id":2398,"position":1,"arabic":"كَبُرَ","translation":"অতিশয়","audioUrl":"wbw/061_003_001.mp3","charTypeName":"word"},{"id":2399,"position":2,"arabic":"مَقْتًا","translation":"ক্রোধজনক","audioUrl":"wbw/061_003_002.mp3","charTypeName":"word"},{"id":2400,"position":3,"arabic":"عِندَ","translation":"কাছে","audioUrl":"wbw/061_003_003.mp3","charTypeName":"word"},{"id":2401,"position":4,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/061_003_004.mp3","charTypeName":"word"},{"id":2402,"position":5,"arabic":"أَن","translation":"যে","audioUrl":"wbw/061_003_005.mp3","charTypeName":"word"},{"id":2403,"position":6,"arabic":"تَقُولُوا۟","translation":"তোমরা বলো","audioUrl":"wbw/061_003_006.mp3","charTypeName":"word"},{"id":2404,"position":7,"arabic":"مَا","translation":"যা","audioUrl":"wbw/061_003_007.mp3","charTypeName":"word"},{"id":2405,"position":8,"arabic":"لَا","translation":"না","audioUrl":"wbw/061_003_008.mp3","charTypeName":"word"},{"id":2406,"position":9,"arabic":"تَفْعَلُونَ","translation":"তোমরা করো","audioUrl":"wbw/061_003_009.mp3","charTypeName":"word"},{"id":2407,"position":10,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"إِنَّ ٱللَّهَ يُحِبُّ ٱلَّذِينَ يُقَٰتِلُونَ فِى سَبِيلِهِۦ صَفًّۭا كَأَنَّهُم بُنْيَٰنٌۭ مَّرْصُوصٌۭ","translation":"Verily, God loves [only] those who fight in His cause in [solid] ranks, as though they were a building firm and compact.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5167.mp3","surahId":61,"words":[{"id":3793,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়","audioUrl":"wbw/061_004_001.mp3","charTypeName":"word"},{"id":3794,"position":2,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/061_004_002.mp3","charTypeName":"word"},{"id":3795,"position":3,"arabic":"يُحِبُّ","translation":"পছন্দ করেন","audioUrl":"wbw/061_004_003.mp3","charTypeName":"word"},{"id":3796,"position":4,"arabic":"ٱلَّذِينَ","translation":"(তাদের) যারা","audioUrl":"wbw/061_004_004.mp3","charTypeName":"word"},{"id":3797,"position":5,"arabic":"يُقَـٰتِلُونَ","translation":"লড়াই করে","audioUrl":"wbw/061_004_005.mp3","charTypeName":"word"},{"id":3798,"position":6,"arabic":"فِى","translation":"(পথে)","audioUrl":"wbw/061_004_006.mp3","charTypeName":"word"},{"id":3799,"position":7,"arabic":"سَبِيلِهِۦ","translation":"তাঁর পথে","audioUrl":"wbw/061_004_007.mp3","charTypeName":"word"},{"id":3800,"position":8,"arabic":"صَفًّۭا","translation":"সারিবদ্ধ হয়ে","audioUrl":"wbw/061_004_008.mp3","charTypeName":"word"},{"id":3801,"position":9,"arabic":"كَأَنَّهُم","translation":"তারা যেন","audioUrl":"wbw/061_004_009.mp3","charTypeName":"word"},{"id":3802,"position":10,"arabic":"بُنْيَـٰنٌۭ","translation":"প্রাচীর","audioUrl":"wbw/061_004_010.mp3","charTypeName":"word"},{"id":3803,"position":11,"arabic":"مَّرْصُوصٌۭ","translation":"সুদৃঢ়","audioUrl":"wbw/061_004_011.mp3","charTypeName":"word"},{"id":3804,"position":12,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"وَإِذْ قَالَ مُوسَىٰ لِقَوْمِهِۦ يَٰقَوْمِ لِمَ تُؤْذُونَنِى وَقَد تَّعْلَمُونَ أَنِّى رَسُولُ ٱللَّهِ إِلَيْكُمْ ۖ فَلَمَّا زَاغُوٓا۟ أَزَاغَ ٱللَّهُ قُلُوبَهُمْ ۚ وَٱللَّهُ لَا يَهْدِى ٱلْقَوْمَ ٱلْفَٰسِقِينَ","translation":"Now when Moses spoke to his people, [it was this same truth that he had in mind:] \"O my people! Why do you cause me grief, the while you know that I am an apostle of God sent unto you?\" And so, when they swerved from the right way, God let their hearts swerve from the truth: for God does not bestow His guidance upon iniquitous folk.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5168.mp3","surahId":61,"words":[{"id":5040,"position":1,"arabic":"وَإِذْ","translation":"এবং যখন","audioUrl":"wbw/061_005_001.mp3","charTypeName":"word"},{"id":5041,"position":2,"arabic":"قَالَ","translation":"বলেছিল","audioUrl":"wbw/061_005_002.mp3","charTypeName":"word"},{"id":5042,"position":3,"arabic":"مُوسَىٰ","translation":"মূসা","audioUrl":"wbw/061_005_003.mp3","charTypeName":"word"},{"id":5043,"position":4,"arabic":"لِقَوْمِهِۦ","translation":"তার জাতিকে","audioUrl":"wbw/061_005_004.mp3","charTypeName":"word"},{"id":5044,"position":5,"arabic":"يَـٰقَوْمِ","translation":"\"হে আমার জাতি","audioUrl":"wbw/061_005_005.mp3","charTypeName":"word"},{"id":5045,"position":6,"arabic":"لِمَ","translation":"কেন","audioUrl":"wbw/061_005_006.mp3","charTypeName":"word"},{"id":5046,"position":7,"arabic":"تُؤْذُونَنِى","translation":"তোমরা আমাকে কষ্ট দাও","audioUrl":"wbw/061_005_007.mp3","charTypeName":"word"},{"id":5047,"position":8,"arabic":"وَقَد","translation":"অথচ নিশ্চয়","audioUrl":"wbw/061_005_008.mp3","charTypeName":"word"},{"id":5048,"position":9,"arabic":"تَّعْلَمُونَ","translation":"তোমরা জানো","audioUrl":"wbw/061_005_009.mp3","charTypeName":"word"},{"id":5049,"position":10,"arabic":"أَنِّى","translation":"যে আমি","audioUrl":"wbw/061_005_010.mp3","charTypeName":"word"},{"id":5050,"position":11,"arabic":"رَسُولُ","translation":"রাসূল","audioUrl":"wbw/061_005_011.mp3","charTypeName":"word"},{"id":5051,"position":12,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/061_005_012.mp3","charTypeName":"word"},{"id":5052,"position":13,"arabic":"إِلَيْكُمْ ۖ","translation":"তোমাদের প্রতি\"","audioUrl":"wbw/061_005_013.mp3","charTypeName":"word"},{"id":5054,"position":14,"arabic":"فَلَمَّا","translation":"অতঃপর যখন","audioUrl":"wbw/061_005_015.mp3","charTypeName":"word"},{"id":5055,"position":15,"arabic":"زَاغُوٓا۟","translation":"তারা বক্রতা অবলম্বন করল","audioUrl":"wbw/061_005_016.mp3","charTypeName":"word"},{"id":5056,"position":16,"arabic":"أَزَاغَ","translation":"বক্র করে দিলেন","audioUrl":"wbw/061_005_017.mp3","charTypeName":"word"},{"id":5057,"position":17,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/061_005_018.mp3","charTypeName":"word"},{"id":5058,"position":18,"arabic":"قُلُوبَهُمْ ۚ","translation":"তাদের অন্তরসমূহকে","audioUrl":"wbw/061_005_019.mp3","charTypeName":"word"},{"id":5060,"position":19,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/061_005_021.mp3","charTypeName":"word"},{"id":5061,"position":20,"arabic":"لَا","translation":"না","audioUrl":"wbw/061_005_022.mp3","charTypeName":"word"},{"id":5062,"position":21,"arabic":"يَهْدِى","translation":"পথ দেখান","audioUrl":"wbw/061_005_023.mp3","charTypeName":"word"},{"id":5063,"position":22,"arabic":"ٱلْقَوْمَ","translation":"জাতিকে","audioUrl":"wbw/061_005_024.mp3","charTypeName":"word"},{"id":5064,"position":23,"arabic":"ٱلْفَـٰسِقِينَ","translation":"ফাসেক","audioUrl":"wbw/061_005_025.mp3","charTypeName":"word"},{"id":5065,"position":24,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]}]}