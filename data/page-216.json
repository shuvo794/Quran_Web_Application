{"id":216,"ayahs":[{"number":62,"arabic":"أَلَآ إِنَّ أَوْلِيَآءَ ٱللَّهِ لَا خَوْفٌ عَلَيْهِمْ وَلَا هُمْ يَحْزَنُونَ","translation":"Oh, verily, they who are close to God - no fear need they have, and neither shall they grieve:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1426.mp3","surahId":10,"words":[{"id":55690,"position":1,"arabic":"أَلَآ","translation":"সাবধান (জেনে রাখো)","audioUrl":"wbw/010_062_001.mp3","charTypeName":"word"},{"id":55691,"position":2,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/010_062_002.mp3","charTypeName":"word"},{"id":55692,"position":3,"arabic":"أَوْلِيَآءَ","translation":"বন্ধুদের","audioUrl":"wbw/010_062_003.mp3","charTypeName":"word"},{"id":55693,"position":4,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/010_062_004.mp3","charTypeName":"word"},{"id":55694,"position":5,"arabic":"لَا","translation":"নেই","audioUrl":"wbw/010_062_005.mp3","charTypeName":"word"},{"id":55695,"position":6,"arabic":"خَوْفٌ","translation":"কোনো ভয়","audioUrl":"wbw/010_062_006.mp3","charTypeName":"word"},{"id":55696,"position":7,"arabic":"عَلَيْهِمْ","translation":"উপর তাদের","audioUrl":"wbw/010_062_007.mp3","charTypeName":"word"},{"id":55697,"position":8,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/010_062_008.mp3","charTypeName":"word"},{"id":55698,"position":9,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/010_062_009.mp3","charTypeName":"word"},{"id":55699,"position":10,"arabic":"يَحْزَنُونَ","translation":"দুঃখিত হবে","audioUrl":"wbw/010_062_010.mp3","charTypeName":"word"},{"id":55700,"position":11,"arabic":"٦٢","translation":"(৬২)","audioUrl":null,"charTypeName":"end"}]},{"number":63,"arabic":"ٱلَّذِينَ ءَامَنُوا۟ وَكَانُوا۟ يَتَّقُونَ","translation":"they who have attained to faith and have always been conscious of Him.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1427.mp3","surahId":10,"words":[{"id":56205,"position":1,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/010_063_001.mp3","charTypeName":"word"},{"id":56206,"position":2,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/010_063_002.mp3","charTypeName":"word"},{"id":56207,"position":3,"arabic":"وَكَانُوا۟","translation":"ও তারা ছিলো","audioUrl":"wbw/010_063_003.mp3","charTypeName":"word"},{"id":56208,"position":4,"arabic":"يَتَّقُونَ","translation":"তাকওয়া অবলম্বন করেছে","audioUrl":"wbw/010_063_004.mp3","charTypeName":"word"},{"id":56209,"position":5,"arabic":"٦٣","translation":"(৬৩)","audioUrl":null,"charTypeName":"end"}]},{"number":64,"arabic":"لَهُمُ ٱلْبُشْرَىٰ فِى ٱلْحَيَوٰةِ ٱلدُّنْيَا وَفِى ٱلْءَاخِرَةِ ۚ لَا تَبْدِيلَ لِكَلِمَٰتِ ٱللَّهِ ۚ ذَٰلِكَ هُوَ ٱلْفَوْزُ ٱلْعَظِيمُ","translation":"For them there is the glad tiding [of happiness] in the life of this world and in the life to come; [and since] nothing could ever alter [the outcome of] God's promises, this, this is the triumph supreme!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1428.mp3","surahId":10,"words":[{"id":56658,"position":1,"arabic":"لَهُمُ","translation":"জন্যে তাদের (রয়েছে)","audioUrl":"wbw/010_064_001.mp3","charTypeName":"word"},{"id":56659,"position":2,"arabic":"ٱلْبُشْرَىٰ","translation":"সুসংবাদ","audioUrl":"wbw/010_064_002.mp3","charTypeName":"word"},{"id":56660,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/010_064_003.mp3","charTypeName":"word"},{"id":56661,"position":4,"arabic":"ٱلْحَيَوٰةِ","translation":"জীবনের","audioUrl":"wbw/010_064_004.mp3","charTypeName":"word"},{"id":56662,"position":5,"arabic":"ٱلدُّنْيَا","translation":"পার্থিব","audioUrl":"wbw/010_064_005.mp3","charTypeName":"word"},{"id":56663,"position":6,"arabic":"وَفِى","translation":"এবং মধ্যে","audioUrl":"wbw/010_064_006.mp3","charTypeName":"word"},{"id":56664,"position":7,"arabic":"ٱلْـَٔاخِرَةِ ۚ","translation":"আখিরাতের","audioUrl":"wbw/010_064_007.mp3","charTypeName":"word"},{"id":56666,"position":8,"arabic":"لَا","translation":"নেই","audioUrl":"wbw/0