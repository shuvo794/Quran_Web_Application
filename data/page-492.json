{"id":492,"ayahs":[{"number":34,"arabic":"وَلِبُيُوتِهِمْ أَبْوَٰبًۭا وَسُرُرًا عَلَيْهَا يَتَّكِـُٔونَ","translation":"and [silver] doors for their houses, and [silver] couches whereon to recline,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4359.mp3","surahId":43,"words":[{"id":36509,"position":1,"arabic":"وَلِبُيُوتِهِمْ","translation":"ও জন্যে তাদের ঘরগুলোর","audioUrl":"wbw/043_034_001.mp3","charTypeName":"word"},{"id":36510,"position":2,"arabic":"أَبْوَٰبًۭا","translation":"দরজাসমূহকে","audioUrl":"wbw/043_034_002.mp3","charTypeName":"word"},{"id":36511,"position":3,"arabic":"وَسُرُرًا","translation":"ও পালঙ্কসমূহকে","audioUrl":"wbw/043_034_003.mp3","charTypeName":"word"},{"id":36512,"position":4,"arabic":"عَلَيْهَا","translation":"যার উপর","audioUrl":"wbw/043_034_004.mp3","charTypeName":"word"},{"id":36513,"position":5,"arabic":"يَتَّكِـُٔونَ","translation":"তারা হেলান দেয়","audioUrl":"wbw/043_034_005.mp3","charTypeName":"word"},{"id":36514,"position":6,"arabic":"٣٤","translation":"(৩৪)","audioUrl":null,"charTypeName":"end"}]},{"number":35,"arabic":"وَزُخْرُفًۭا ۚ وَإِن كُلُّ ذَٰلِكَ لَمَّا مَتَٰعُ ٱلْحَيَوٰةِ ٱلدُّنْيَا ۚ وَٱلْءَاخِرَةُ عِندَ رَبِّكَ لِلْمُتَّقِينَ","translation":"and gold [beyond count]. Yet all this would have been nothing but a [brief] enjoyment of life in this world - whereas [happiness in] the life to come awaits the God-conscious with thy Sustainer.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4360.mp3","surahId":43,"words":[{"id":36961,"position":1,"arabic":"وَزُخْرُفًۭا ۚ","translation":"ও সোনার (বানাতাম)","audioUrl":"wbw/043_035_001.mp3","charTypeName":"word"},{"id":36963,"position":2,"arabic":"وَإِن","translation":"এবং নয়","audioUrl":"wbw/043_035_003.mp3","charTypeName":"word"},{"id":36964,"position":3,"arabic":"كُلُّ","translation":"প্রতি","audioUrl":"wbw/043_035_004.mp3","charTypeName":"word"},{"id":36965,"position":4,"arabic":"ذَٰلِكَ","translation":"এসব","audioUrl":"wbw/043_035_005.mp3","charTypeName":"word"},{"id":36966,"position":5,"arabic":"لَمَّا","translation":"এ ব্যতীত","audioUrl":"wbw/043_035_006.mp3","charTypeName":"word"},{"id":36967,"position":6,"arabic":"مَتَـٰعُ","translation":"ভোগসম্ভার","audioUrl":"wbw/043_035_007.mp3","charTypeName":"word"},{"id":36968,"position":7,"arabic":"ٱلْحَيَوٰةِ","translation":"জীবনের","audioUrl":"wbw/043_035_008.mp3","charTypeName":"word"},{"id":36969,"position":8,"arabic":"ٱلدُّنْيَا ۚ","translation":"পার্থিব","audioUrl":"wbw/043_035_009.mp3","charTypeName":"word"},{"id":36971,"position":9,"arabic":"وَٱلْـَٔاخِرَةُ","translation":"আর পরকালই","audioUrl":"wbw/043_035_011.mp3","charTypeName":"word"},{"id":36972,"position":10,"arabic":"عِندَ","translation":"কাছে","audioUrl":"wbw/043_035_012.mp3","charTypeName":"word"},{"id":36973,"position":11,"arabic":"رَبِّكَ","translation":"তোমার রবের","audioUrl":"wbw/043_035_013.mp3","charTypeName":"word"},{"id":36974,"position":12,"arabic":"لِلْمُتَّقِينَ","translation":"মুত্তাকীদের জন্য (নির্দিষ্ট)","audioUrl":"wbw/043_035_014.mp3","charTypeName":"word"},{"id":36975,"position":13,"arabic":"٣٥","translation":"(৩৫)","audioUrl":null,"charTypeName":"end"}]},{"number":36,"arabic":"وَمَن يَعْشُ عَن ذِكْرِ ٱلرَّحْمَٰنِ نُقَيِّضْ لَهُۥ شَيْطَٰنًۭا فَهُوَ لَهُۥ قَرِينٌۭ","translation":"But as for anyone who chooses to remain blind to the remembrance of the Most Gracious, to him We assign an [enduring] evil impulse, to become his other self:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4361.mp3","surahId":43,"words":[{"id":37835,"position":1,"arabic":"وَمَن","translation":"এবং যে","audioUrl":"wbw/043_036_001.mp3","charTypeName":"word"},{"id":37836,"position":2,"arabic":"يَعْشُ","translation":"বিমুখ হয়","audioUrl":"wbw/043_036_002.mp3","charTypeName":"word"},{"id":37837,"position":3,"arabic":"عَن","translation":"হ'তে","audioUrl":"wbw/043_036_003.mp3","charTypeName":"word"},{"id":37838,"position":4,"arabic":"ذِكْرِ","translation":"স্মরণ","audioUrl":"wbw/043_036_004.mp3","charTypeName":"word"},{"id":37839,"position":5,"arabic":"ٱلرَّحْمَـٰنِ","translation":"দয়াময়ের","audioUrl":"wbw/043_036_005.mp3","charTypeName":"word"},{"id":37840,"position":6,"arabic":"نُقَيِّضْ","translation":"নিয়োজিত করি আমরা","audioUrl":"wbw/043_036_006.mp3","charTypeName":"word"},{"id":37841,"position":7,"arabic":"لَهُۥ","translation":"তার জন্যে","audioUrl":"wbw/043_036_007.mp3","charTypeName":"word"},{"id":37842,"position":8,"arabic":"شَيْطَـٰنًۭا","translation":"শয়তানকে","audioUrl":"wbw/043_036_008.mp3","charTypeName":"word"},{"id":37843,"position":9,"arabic":"فَهُوَ","translation":"তখন সে","audioUrl":"wbw/043_036_009.mp3","charTypeName":"word"},{"id":37844,"position":10,"arabic":"لَهُۥ","translation":"তার জন্যে হয়","audioUrl":"wbw/043_036_010.mp3","charTypeName":"word"},{"id":37845,"position":11,"arabic":"قَرِينٌۭ","translation":"সঙ্গী","audioUrl":"wbw/043_036_011.mp3","charTypeName":"word"},{"id":37846,"position":12,"arabic":"٣٦","translation":"(৩৬)","audioUrl":null,"charTypeName":"end"}]},{"number":37,"arabic":"وَإِنَّهُمْ لَيَصُدُّونَهُمْ عَنِ ٱلسَّبِيلِ وَيَحْسَبُونَ أَنَّهُم مُّهْتَدُونَ","translation":"whereupon, behold, these [evil impulses] bar all such from the path [of truth], making them think that they are guided aright!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4362.mp3","surahId":43,"words":[{"id":38685,"position":1,"arabic":"وَإِنَّهُمْ","translation":"এবং নিশ্চয়ই তারা","audioUrl":"wbw/043_037_001.mp3","charTypeName":"word"},{"id":38686,"position":2,"arabic":"لَيَصُدُّونَهُمْ","translation":"তাদেরকে বাধা দেয় অবশ্যই","audioUrl":"wbw/043_037_002.mp3","charTypeName":"word"},{"id":38687,"position":3,"arabic":"عَنِ","translation":"হ'তে","audioUrl":"wbw/043_037_003.mp3","charTypeName":"word"},{"id":38688,"position":4,"arabic":"ٱلسَّبِيلِ","translation":"(হেদায়াতের) পথ","audioUrl":"wbw/043_037_004.mp3","charTypeName":"word"},{"id":38689,"position":5,"arabic":"وَيَحْسَبُونَ","translation":"ও তারা মনে করে","audioUrl":"wbw/043_037_005.mp3","charTypeName":"word"},{"id":38690,"position":6,"arabic":"أَنَّهُم","translation":"যে তারা","audioUrl":"wbw/043_037_006.mp3","charTypeName":"word"},{"id":38691,"position":7,"arabic":"مُّهْتَدُونَ","translation":"সঠিক পথপ্রাপ্ত","audioUrl":"wbw/043_037_007.mp3","charTypeName":"word"},{"id":38692,"position":8,"arabic":"٣٧","translation":"(৩৭)","audioUrl":null,"charTypeName":"end"}]},{"number":38,"arabic":"حَتَّىٰٓ إِذَا جَآءَنَا قَالَ يَٰلَيْتَ بَيْنِى وَبَيْنَكَ بُعْدَ ٱلْمَشْرِقَيْنِ فَبِئْسَ ٱلْقَرِينُ","translation":"But in the end, when he [who has thus sinned] appears before us [on Judgment Day], he will say [to his other self], “Would that between me and thee there had been the distance of east and west!” for, evil indeed [has proved] that other self!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4363.mp3","surahId":43,"words":[{"id":39863,"position":1,"arabic":"حَتَّىٰٓ","translation":"শেষপর্যন্ত","audioUrl":"wbw/043_038_001.mp3","charTypeName":"word"},{"id":39864,"position":2,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/043_038_002.mp3","charTypeName":"word"},{"id":39865,"position":3,"arabic":"جَآءَنَا","translation":"আমাদের কাছে আসবে","audioUrl":"wbw/043_038_003.mp3","charTypeName":"word"},{"id":39866,"position":4,"arabic":"قَالَ","translation":"বলবে (শয়তানকে)","audioUrl":"wbw/043_038_004.mp3","charTypeName":"word"},{"id":39867,"position":5,"arabic":"يَـٰلَيْتَ","translation":"\"হায়","audioUrl":"wbw/043_038_005.mp3","charTypeName":"word"},{"id":39868,"position":6,"arabic":"بَيْنِى","translation":"আমার মাঝে","audioUrl":"wbw/043_038_006.mp3","charTypeName":"word"},{"id":39869,"position":7,"arabic":"وَبَيْنَكَ","translation":"ও তোমার মাঝে (থাকতো)","audioUrl":"wbw/043_038_007.mp3","charTypeName":"word"},{"id":39870,"position":8,"arabic":"بُعْدَ","translation":"দুরত্ব","audioUrl":"wbw/043_038_008.mp3","charTypeName":"word"},{"id":39871,"position":9,"arabic":"ٱلْمَشْرِقَيْنِ","translation":"পূর্ব ও পশ্চিমের\"","audioUrl":"wbw/043_038_009.mp3","charTypeName":"word"},{"id":39872,"position":10,"arabic":"فَبِئْسَ","translation":"অতএব কত নিকৃষ্ট","audioUrl":"wbw/043_038_010.mp3","charTypeName":"word"},{"id":39873,"position":11,"arabic":"ٱلْقَرِينُ","translation":"সঙ্গী (শয়তান)","audioUrl":"wbw/043_038_011.mp3","charTypeName":"word"},{"id":39874,"position":12,"arabic":"٣٨","translation":"(৩৮)","audioUrl":null,"charTypeName":"end"}]},{"number":39,"arabic":"وَلَن يَنفَعَكُمُ ٱلْيَوْمَ إِذ ظَّلَمْتُمْ أَنَّكُمْ فِى ٱلْعَذَابِ مُشْتَرِكُونَ","translation":"On that Day it will not profit you in the least [to know] that, since you have sinned [together], you are now to share your suffering [as well].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4364.mp3","surahId":43,"words":[{"id":40371,"position":1,"arabic":"وَلَن","translation":"এবং (বলা হবে) কখনও না","audioUrl":"wbw/043_039_001.mp3","charTypeName":"word"},{"id":40372,"position":2,"arabic":"يَنفَعَكُمُ","translation":"তোমাদের কল্যাণ দিবে","audioUrl":"wbw/043_039_002.mp3","charTypeName":"word"},{"id":40373,"position":3,"arabic":"ٱلْيَوْمَ","translation":"আজ (তোমাদের অনুতাপ)","audioUrl":"wbw/043_039_003.mp3","charTypeName":"word"},{"id":40374,"position":4,"arabic":"إِذ","translation":"যখন","audioUrl":"wbw/043_039_004.mp3","charTypeName":"word"},{"id":40375,"position":5,"arabic":"ظَّلَمْتُمْ","translation":"তোমরা সীমালঙ্ঘন করেছো","audioUrl":"wbw/043_039_005.mp3","charTypeName":"word"},{"id":40376,"position":6,"arabic":"أَنَّكُمْ","translation":"(এও) যে তোমরা","audioUrl":"wbw/043_039_006.mp3","charTypeName":"word"},{"id":40377,"position":7,"arabic":"فِى","translation":"মধ্যে হবে","audioUrl":"wbw/043_039_007.mp3","charTypeName":"word"},{"id":40378,"position":8,"arabic":"ٱلْعَذَابِ","translation":"শাস্তির","audioUrl":"wbw/043_039_008.mp3","charTypeName":"word"},{"id":40379,"position":9,"arabic":"مُشْتَرِكُونَ","translation":"(তোমরা ও শয়তান) সমঅংশ গ্রহণকারী","audioUrl":"wbw/043_039_009.mp3","charTypeName":"word"},{"id":40380,"position":10,"arabic":"٣٩","translation":"(৩৯)","audioUrl":null,"charTypeName":"end"}]},{"number":40,"arabic":"أَفَأَنتَ تُسْمِعُ ٱلصُّمَّ أَوْ تَهْدِى ٱلْعُمْىَ وَمَن كَانَ فِى ضَلَٰلٍۢ مُّبِينٍۢ","translation":"CANST THOU, perchance, [O Muhammad,] make the deaf hear, or show the right way to the blind or to such as are obviously lost in error?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4365.mp3","surahId":43,"words":[{"id":41103,"position":1,"arabic":"أَفَأَنتَ","translation":"(হে নাবী) তুমি তবে কি","audioUrl":"wbw/043_040_001.mp3","charTypeName":"word"},{"id":41104,"position":2,"arabic":"تُسْمِعُ","translation":"শুনাবে","audioUrl":"wbw/043_040_002.mp3","charTypeName":"word"},{"id":41105,"position":3,"arabic":"ٱلصُّمَّ","translation":"বধিরকে","audioUrl":"wbw/043_040_003.mp3","charTypeName":"word"},{"id":41106,"position":4,"arabic":"أَوْ","translation":"বা","audioUrl":"wbw/043_040_004.mp3","charTypeName":"word"},{"id":41107,"position":5,"arabic":"تَهْدِى","translation":"পথ দেখাবে","audioUrl":"wbw/043_040_005.mp3","charTypeName":"word"},{"id":41108,"position":6,"arabic":"ٱلْعُمْىَ","translation":"অন্ধকে","audioUrl":"wbw/043_040_006.mp3","charTypeName":"word"},{"id":41109,"position":7,"arabic":"وَمَن","translation":"এবং (তাকে) যে","audioUrl":"wbw/043_040_007.mp3","charTypeName":"word"},{"id":41110,"position":8,"arabic":"كَانَ","translation":"আছে","audioUrl":"wbw/043_040_008.mp3","charTypeName":"word"},{"id":41111,"position":9,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/043_040_009.mp3","charTypeName":"word"},{"id":41112,"position":10,"arabic":"ضَلَـٰلٍۢ","translation":"বিভ্রান্তির","audioUrl":"wbw/043_040_010.mp3","charTypeName":"word"},{"id":41113,"position":11,"arabic":"مُّبِينٍۢ","translation":"সুস্পষ্ট","audioUrl":"wbw/043_040_011.mp3","charTypeName":"word"},{"id":41114,"position":12,"arabic":"٤٠","translation":"(৪০)","audioUrl":null,"charTypeName":"end"}]},{"number":41,"arabic":"فَإِمَّا نَذْهَبَنَّ بِكَ فَإِنَّا مِنْهُم مُّنتَقِمُونَ","translation":"But whether We do [or do not] take thee away [ere thy message prevails] - verily, We shall inflict Our retribution on them;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4366.mp3","surahId":43,"words":[{"id":41988,"position":1,"arabic":"فَإِمَّا","translation":"সুতরাং যদি","audioUrl":"wbw/043_041_001.mp3","charTypeName":"word"},{"id":41989,"position":2,"arabic":"نَذْهَبَنَّ","translation":"আমরা উঠিয়ে নিই","audioUrl":"wbw/043_041_002.mp3","charTypeName":"word"},{"id":41990,"position":3,"arabic":"بِكَ","translation":"তোমাকে","audioUrl":"wbw/043_041_003.mp3","charTypeName":"word"},{"id":41991,"position":4,"arabic":"فَإِنَّا","translation":"নিশ্চয় তবুও আমরা","audioUrl":"wbw/043_041_004.mp3","charTypeName":"word"},{"id":41992,"position":5,"arabic":"مِنْهُم","translation":"তাদের হাতে","audioUrl":"wbw/043_041_005.mp3","charTypeName":"word"},{"id":41993,"position":6,"arabic":"مُّنتَقِمُونَ","translation":"প্রতিশোধ গ্রহণকারী (অর্থাৎ শাস্তি দিবো)","audioUrl":"wbw/043_041_006.mp3","charTypeName":"word"},{"id":41994,"position":7,"arabic":"٤١","translation":"(৪১)","audioUrl":null,"charTypeName":"end"}]},{"number":42,"arabic":"أَوْ نُرِيَنَّكَ ٱلَّذِى وَعَدْنَٰهُمْ فَإِنَّا عَلَيْهِم مُّقْتَدِرُونَ","translation":"and whether We show thee [or do not show thee in this world] the fulfillment of what We have promised them - verily, We have full power over them!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4367.mp3","surahId":43,"words":[{"id":43026,"position":1,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/043_042_001.mp3","charTypeName":"word"},{"id":43027,"position":2,"arabic":"نُرِيَنَّكَ","translation":"তোমাকে দেখাই আমরা","audioUrl":"wbw/043_042_002.mp3","charTypeName":"word"},{"id":43028,"position":3,"arabic":"ٱلَّذِى","translation":"যা","audioUrl":"wbw/043_042_003.mp3","charTypeName":"word"},{"id":43029,"position":4,"arabic":"وَعَدْنَـٰهُمْ","translation":"তাদেরকে আমরা প্রতিশ্রুতি দিয়েছি","audioUrl":"wbw/043_042_004.mp3","charTypeName":"word"},{"id":43030,"position":5,"arabic":"فَإِنَّا","translation":"তবুও আমরা নিশ্চয়ই","audioUrl":"wbw/043_042_005.mp3","charTypeName":"word"},{"id":43031,"position":6,"arabic":"عَلَيْهِم","translation":"তাদের উপর","audioUrl":"wbw/043_042_006.mp3","charTypeName":"word"},{"id":43032,"position":7,"arabic":"مُّقْتَدِرُونَ","translation":"পূর্ণ ক্ষমতাবান","audioUrl":"wbw/043_042_007.mp3","charTypeName":"word"},{"id":43033,"position":8,"arabic":"٤٢","translation":"(৪২)","audioUrl":null,"charTypeName":"end"}]},{"number":43,"arabic":"فَٱسْتَمْسِكْ بِٱلَّذِىٓ أُوحِىَ إِلَيْكَ ۖ إِنَّكَ عَلَىٰ صِرَٰطٍۢ مُّسْتَقِيمٍۢ","translation":"So hold fast to all that has been revealed to thee: for, behold, thou art on a straight way;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4368.mp3","surahId":43,"words":[{"id":43495,"position":1,"arabic":"فَٱسْتَمْسِكْ","translation":"তুমি অতএব দৃঢ়ভাবে ধারণ করো","audioUrl":"wbw/043_043_001.mp3","charTypeName":"word"},{"id":43496,"position":2,"arabic":"بِٱلَّذِىٓ","translation":"তার ওপর যা","audioUrl":"wbw/043_043_002.mp3","charTypeName":"word"},{"id":43497,"position":3,"arabic":"أُوحِىَ","translation":"ওহী করা হয়েছে","audioUrl":"wbw/043_043_003.mp3","charTypeName":"word"},{"id":43498,"position":4,"arabic":"إِلَيْكَ ۖ","translation":"তোমার প্রতি","audioUrl":"wbw/043_043_004.mp3","charTypeName":"word"},{"id":43500,"position":5,"arabic":"إِنَّكَ","translation":"তুমি নিশ্চয়ই (আছো)","audioUrl":"wbw/043_043_006.mp3","charTypeName":"word"},{"id":43501,"position":6,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/043_043_007.mp3","charTypeName":"word"},{"id":43502,"position":7,"arabic":"صِرَٰطٍۢ","translation":"পথের","audioUrl":"wbw/043_043_008.mp3","charTypeName":"word"},{"id":43503,"position":8,"arabic":"مُّسْتَقِيمٍۢ","translation":"সরল সঠিক","audioUrl":"wbw/043_043_009.mp3","charTypeName":"word"},{"id":43504,"position":9,"arabic":"٤٣","translation":"(৪৩)","audioUrl":null,"charTypeName":"end"}]},{"number":44,"arabic":"وَإِنَّهُۥ لَذِكْرٌۭ لَّكَ وَلِقَوْمِكَ ۖ وَسَوْفَ تُسْـَٔلُونَ","translation":"and, verily, this [revelation] shall indeed become [a source of] eminence for thee and thy people: but in time you all will be called to account [for what you have done with it].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4369.mp3","surahId":43,"words":[{"id":44273,"position":1,"arabic":"وَإِنَّهُۥ","translation":"এবং তা নিশ্চয়ই","audioUrl":"wbw/043_044_001.mp3","charTypeName":"word"},{"id":44274,"position":2,"arabic":"لَذِكْرٌۭ","translation":"অবশ্যই সম্মানের বিষয়","audioUrl":"wbw/043_044_002.mp3","charTypeName":"word"},{"id":44275,"position":3,"arabic":"لَّكَ","translation":"তোমার জন্যে","audioUrl":"wbw/043_044_003.mp3","charTypeName":"word"},{"id":44276,"position":4,"arabic":"وَلِقَوْمِكَ ۖ","translation":"এবং তোমার জাতির জন্যে","audioUrl":"wbw/043_044_004.mp3","charTypeName":"word"},{"id":44278,"position":5,"arabic":"وَسَوْفَ","translation":"এবং শীঘ্রই","audioUrl":"wbw/043_044_006.mp3","charTypeName":"word"},{"id":44279,"position":6,"arabic":"تُسْـَٔلُونَ","translation":"তোমরা জিজ্ঞাসিত হবে","audioUrl":"wbw/043_044_007.mp3","charTypeName":"word"},{"id":44280,"position":7,"arabic":"٤٤","translation":"(৪৪)","audioUrl":null,"charTypeName":"end"}]},{"number":45,"arabic":"وَسْـَٔلْ مَنْ أَرْسَلْنَا مِن قَبْلِكَ مِن رُّسُلِنَآ أَجَعَلْنَا مِن دُونِ ٱلرَّحْمَٰنِ ءَالِهَةًۭ يُعْبَدُونَ","translation":"Yet [above all else,] ask any of Our apostles whom We sent forth before thy time whether We have ever allowed that deities other than the Most Gracious be worshipped!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4370.mp3","surahId":43,"words":[{"id":45027,"position":1,"arabic":"وَسْـَٔلْ","translation":"এবং জিজ্ঞেস করো","audioUrl":"wbw/043_045_001.mp3","charTypeName":"word"},{"id":45028,"position":2,"arabic":"مَنْ","translation":"যাদেরকে","audioUrl":"wbw/043_045_002.mp3","charTypeName":"word"},{"id":45029,"position":3,"arabic":"أَرْسَلْنَا","translation":"আমরা পাঠিয়েছি","audioUrl":"wbw/043_045_003.mp3","charTypeName":"word"},{"id":45030,"position":4,"arabic":"مِن","translation":"মধ্য হতে","audioUrl":"wbw/043_045_004.mp3","charTypeName":"word"},{"id":45031,"position":5,"arabic":"قَبْلِكَ","translation":"তোমার পূর্বে","audioUrl":"wbw/043_045_005.mp3","charTypeName":"word"},{"id":45032,"position":6,"arabic":"مِن","translation":"মধ্য হ'তে","audioUrl":"wbw/043_045_006.mp3","charTypeName":"word"},{"id":45033,"position":7,"arabic":"رُّسُلِنَآ","translation":"আমাদের রাসূলগণের","audioUrl":"wbw/043_045_007.mp3","charTypeName":"word"},{"id":45034,"position":8,"arabic":"أَجَعَلْنَا","translation":"আমরা  নির্দিষ্ট করেছি কি","audioUrl":"wbw/043_045_008.mp3","charTypeName":"word"},{"id":45035,"position":9,"arabic":"مِن","translation":"মধ্য হতে","audioUrl":"wbw/043_045_009.mp3","charTypeName":"word"},{"id":45036,"position":10,"arabic":"دُونِ","translation":"ব্যতীত","audioUrl":"wbw/043_045_010.mp3","charTypeName":"word"},{"id":45037,"position":11,"arabic":"ٱلرَّحْمَـٰنِ","translation":"দয়াময়","audioUrl":"wbw/043_045_011.mp3","charTypeName":"word"},{"id":45038,"position":12,"arabic":"ءَالِهَةًۭ","translation":"(অন্য কোন) উপাস্যকে","audioUrl":"wbw/043_045_012.mp3","charTypeName":"word"},{"id":45039,"position":13,"arabic":"يُعْبَدُونَ","translation":"উপাসনা করা হবে (যার)","audioUrl":"wbw/043_045_013.mp3","charTypeName":"word"},{"id":45040,"position":14,"arabic":"٤٥","translation":"(৪৫)","audioUrl":null,"charTypeName":"end"}]},{"number":46,"arabic":"وَلَقَدْ أَرْسَلْنَا مُوسَىٰ بِـَٔايَٰتِنَآ إِلَىٰ فِرْعَوْنَ وَمَلَإِي۟هِۦ فَقَالَ إِنِّى رَسُولُ رَبِّ ٱلْعَٰلَمِينَ","translation":"THUS, INDEED, have We sent Moses with Our messages unto Pharaoh and his great ones; and he said: “Behold, I am an apostle of the Sustainer of all the worlds!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4371.mp3","surahId":43,"words":[{"id":45970,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/043_046_001.mp3","charTypeName":"word"},{"id":45971,"position":2,"arabic":"أَرْسَلْنَا","translation":"আমরা পাঠিয়েছি","audioUrl":"wbw/043_046_002.mp3","charTypeName":"word"},{"id":45972,"position":3,"arabic":"مُوسَىٰ","translation":"মূসাকে","audioUrl":"wbw/043_046_003.mp3","charTypeName":"word"},{"id":45973,"position":4,"arabic":"بِـَٔايَـٰتِنَآ","translation":"আমাদের নির্দেশনাবলীসহ","audioUrl":"wbw/043_046_004.mp3","charTypeName":"word"},{"id":45974,"position":5,"arabic":"إِلَىٰ","translation":"প্রতি","audioUrl":"wbw/043_046_005.mp3","charTypeName":"word"},{"id":45975,"position":6,"arabic":"فِرْعَوْنَ","translation":"ফিরআউনের","audioUrl":"wbw/043_046_006.mp3","charTypeName":"word"},{"id":45976,"position":7,"arabic":"وَمَلَإِي۟هِۦ","translation":"ও তার পারিষদবর্গের","audioUrl":"wbw/043_046_007.mp3","charTypeName":"word"},{"id":45977,"position":8,"arabic":"فَقَالَ","translation":"তখন সে বললো","audioUrl":"wbw/043_046_008.mp3","charTypeName":"word"},{"id":45978,"position":9,"arabic":"إِنِّى","translation":"\"আমি নিশ্চয়ই","audioUrl":"wbw/043_046_009.mp3","charTypeName":"word"},{"id":45979,"position":10,"arabic":"رَسُولُ","translation":"রাসূল","audioUrl":"wbw/043_046_010.mp3","charTypeName":"word"},{"id":45980,"position":11,"arabic":"رَبِّ","translation":"রবের","audioUrl":"wbw/043_046_011.mp3","charTypeName":"word"},{"id":45981,"position":12,"arabic":"ٱلْعَـٰلَمِينَ","translation":"বিশ্ব জগতের\"","audioUrl":"wbw/043_046_012.mp3","charTypeName":"word"},{"id":45982,"position":13,"arabic":"٤٦","translation":"(৪৬)","audioUrl":null,"charTypeName":"end"}]},{"number":47,"arabic":"فَلَمَّا جَآءَهُم بِـَٔايَٰتِنَآ إِذَا هُم مِّنْهَا يَضْحَكُونَ","translation":"But as soon as he came before them with Our [miraculous] signs, lo! they derided them,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4372.mp3","surahId":43,"words":[{"id":46419,"position":1,"arabic":"فَلَمَّا","translation":"অতঃপর যখন","audioUrl":"wbw/043_047_001.mp3","c