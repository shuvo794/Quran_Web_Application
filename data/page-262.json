{"id":262,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ الٓر ۚ تِلْكَ ءَايَٰتُ ٱلْكِتَٰبِ وَقُرْءَانٍۢ مُّبِينٍۢ","translation":"Alif. Lam. Ra. THESE ARE MESSAGES of revelation -of a discourse clear in itself and clearly showing the truth.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1803.mp3","surahId":15,"words":[{"id":833,"position":1,"arabic":"الٓر ۚ","translation":"আলিফ লা-ম রা-","audioUrl":"wbw/015_001_001.mp3","charTypeName":"word"},{"id":835,"position":2,"arabic":"تِلْكَ","translation":"এগুলো","audioUrl":"wbw/015_001_003.mp3","charTypeName":"word"},{"id":836,"position":3,"arabic":"ءَايَـٰتُ","translation":"আয়াত","audioUrl":"wbw/015_001_004.mp3","charTypeName":"word"},{"id":837,"position":4,"arabic":"ٱلْكِتَـٰبِ","translation":"কিতাবের","audioUrl":"wbw/015_001_005.mp3","charTypeName":"word"},{"id":838,"position":5,"arabic":"وَقُرْءَانٍۢ","translation":"এবং কুরআনের","audioUrl":"wbw/015_001_006.mp3","charTypeName":"word"},{"id":839,"position":6,"arabic":"مُّبِينٍۢ","translation":"(যা) সুষ্পষ্ট","audioUrl":"wbw/015_001_007.mp3","charTypeName":"word"},{"id":840,"position":7,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"رُّبَمَا يَوَدُّ ٱلَّذِينَ كَفَرُوا۟ لَوْ كَانُوا۟ مُسْلِمِينَ","translation":"And it will come to pass that those who are [now] bent on denying this truth will wish that they had surrendered themselves to God [in their life time].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1804.mp3","surahId":15,"words":[{"id":1944,"position":1,"arabic":"رُّبَمَا","translation":"কখনও কখনও","audioUrl":"wbw/015_002_001.mp3","charTypeName":"word"},{"id":1945,"position":2,"arabic":"يَوَدُّ","translation":"আকাঙ্ক্ষা করবে","audioUrl":"wbw/015_002_002.mp3","charTypeName":"word"},{"id":1946,"position":3,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/015_002_003.mp3","charTypeName":"word"},{"id":1947,"position":4,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/015_002_004.mp3","charTypeName":"word"},{"id":1948,"position":5,"arabic":"لَوْ","translation":"যদি","audioUrl":"wbw/015_002_005.mp3","charTypeName":"word"},{"id":1949,"position":6,"arabic":"كَانُوا۟","translation":"তারা হতো","audioUrl":"wbw/015_002_006.mp3","charTypeName":"word"},{"id":1950,"position":7,"arabic":"مُسْلِمِينَ","translation":"(আত্মসমর্পণকারী) মুসলমান","audioUrl":"wbw/015_002_007.mp3","charTypeName":"word"},{"id":1951,"position":8,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"ذَرْهُمْ يَأْكُلُوا۟ وَيَتَمَتَّعُوا۟ وَيُلْهِهِمُ ٱلْأَمَلُ ۖ فَسَوْفَ يَعْلَمُونَ","translation":"Leave them alone; let them eat and enjoy themselves the while the hope [of vain delights] be guiles them: for in time they will come to know [the truth].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1805.mp3","surahId":15,"words":[{"id":3132,"position":1,"arabic":"ذَرْهُمْ","translation":"তাদেরকে ছেড়ে দাও","audioUrl":"wbw/015_003_001.mp3","charTypeName":"word"},{"id":3133,"position":2,"arabic":"يَأْكُلُوا۟","translation":"তারা খেতে থাকুক","audioUrl":"wbw/015_003_002.mp3","charTypeName":"word"},{"id":3134,"position":3,"arabic":"وَيَتَمَتَّعُوا۟","translation":"ও তারা ভোগ করুক","audioUrl":"wbw/015_003_003.mp3","charTypeName":"word"},{"id":3135,"position":4,"arabic":"وَيُلْهِهِمُ","translation":"এবং তাদেরকে মোহাচ্ছন্ন রাখুক","audioUrl":"wbw/015_003_004.mp3","charTypeName":"word"},{"id":3136,"position":5,"arabic":"ٱلْأَمَلُ ۖ","translation":"আশা আকাঙ্ক্ষা","audioUrl":"wbw/015_003_005.mp3","charTypeName":"word"},{"id":3138,"position":6,"arabic":"فَسَوْفَ","translation":"অতঃপর শীঘ্রই","audioUrl":"wbw/015_003_007.mp3","charTypeName":"word"},{"id":3139,"position":7,"arabic":"يَعْلَمُونَ","translation":"তারা জানবে","audioUrl":"wbw/015_003_008.mp3","charTypeName":"word"},{"id":3140,"position":8,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"وَمَآ أَهْلَكْنَا مِن قَرْيَةٍ إِلَّا وَلَهَا كِتَابٌۭ مَّعْلُومٌۭ","translation":"And never have We destroyed any community [for its wrongdoing] unless a divine writ had (previously] been made known to it;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1806.mp3","surahId":15,"words":[{"id":3605,"position":1,"arabic":"وَمَآ","translation":"এবং না","audioUrl":"wbw/015_004_001.mp3","charTypeName":"word"},{"id":3606,"position":2,"arabic":"أَهْلَكْنَا","translation":"আমরা ধ্বংস করি","audioUrl":"wbw/015_004_002.mp3","charTypeName":"word"},{"id":3607,"position":3,"arabic":"مِن","translation":"কোনো","audioUrl":"wbw/015_004_003.mp3","charTypeName":"word"},{"id":3608,"position":4,"arabic":"قَرْيَةٍ","translation":"জনবসতিকে","audioUrl":"wbw/015_004_004.mp3","charTypeName":"word"},{"id":3609,"position":5,"arabic":"إِلَّا","translation":"এ ছাড়া যে","audioUrl":"wbw/015_004_005.mp3","charTypeName":"word"},{"id":3610,"position":6,"arabic":"وَلَهَا","translation":"এবং তার জন্যে ছিলো","audioUrl":"wbw/015_004_006.mp3","charTypeName":"word"},{"id":3611,"position":7,"arabic":"كِتَابٌۭ","translation":"লিখিত মেয়াদ","audioUrl":"wbw/015_004_007.mp3","charTypeName":"word"},{"id":3612,"position":8,"arabic":"مَّعْلُومٌۭ","translation":"নির্দিষ্ট","audioUrl":"wbw/015_004_008.mp3","charTypeName":"word"},{"id":3613,"position":9,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"مَّا تَسْبِقُ مِنْ أُمَّةٍ أَجَلَهَا وَمَا يَسْتَـْٔخِرُونَ","translation":"[but remember that] no community can ever forestall [the end of] its term - and neither can they delay [it].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1807.mp3","surahId":15,"words":[{"id":5180,"position":1,"arabic":"مَّا","translation":"না","audioUrl":"wbw/015_005_001.mp3","charTypeName":"word"},{"id":5181,"position":2,"arabic":"تَسْبِقُ","translation":"এগিয়ে আনতে পারে","audioUrl":"wbw/015_005_002.mp3","charTypeName":"word"},{"id":5182,"position":3,"arabic":"مِنْ","translation":"কোনো","audioUrl":"wbw/015_005_003.mp3","charTypeName":"word"},{"id":5183,"position":4,"arabic":"أُمَّةٍ","translation":"জাতি","audioUrl":"wbw/015_005_004.mp3","charTypeName":"word"},{"id":5184,"position":5,"arabic":"أَجَلَهَا","translation":"তার কালকে","audioUrl":"wbw/015_005_005.mp3","charTypeName":"word"},{"id":5185,"position":6,"arabic":"وَمَا","translation":"আর না","audioUrl":"wbw/015_005_006.mp3","charTypeName":"word"},{"id":5186,"position":7,"arabic":"يَسْتَـْٔخِرُونَ","translation":"দেরি করতে পারে","audioUrl":"wbw/015_005_007.mp3","charTypeName":"word"},{"id":5187,"position":8,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"وَقَالُوا۟ يَٰٓأَيُّهَا ٱلَّذِى نُزِّلَ عَلَيْهِ ٱلذِّكْرُ إِنَّكَ لَمَجْنُونٌۭ","translation":"And yet, they [who deny the truth] say: \"O thou unto whom this reminder has [allegedly] been bestowed from on high: verily, thou art mad!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1808.mp3","surahId":15,"words":[{"id":6937,"position":1,"arabic":"وَقَالُوا۟","translation":"এবং তারা বলে","audioUrl":"wbw/015_006_001.mp3","charTypeName":"word"},{"id":6938,"position":2,"arabic":"يَـٰٓأَيُّهَا","translation":"\"হে","audioUrl":"wbw/015_006_002.mp3","charTypeName":"word"},{"id":6939,"position":3,"arabic":"ٱلَّذِى","translation":"যে","audioUrl":"wbw/015_006_003.mp3","charTypeName":"word"},{"id":6940,"position":4,"arabic":"نُزِّلَ","translation":"অবতীর্ণ হয়েছে","audioUrl":"wbw/015_006_004.mp3","charTypeName":"word"},{"id":6941,"position":5,"arabic":"عَلَيْهِ","translation":"তার উপর","audioUrl":"wbw/015_006_005.mp3","charTypeName":"word"},{"id":6942,"position":6,"arabic":"ٱلذِّكْرُ","translation":"উপদেশ বাণী(কুরআন)","audioUrl":"wbw/015_006_006.mp3","charTypeName":"word"},{"id":6943,"position":7,"arabic":"إِنَّكَ","translation":"নিশ্চয়ই তুমি","audioUrl":"wbw/015_006_007.mp3","charTypeName":"word"},{"id":6944,"position":8,"arabic":"لَمَجْنُونٌۭ","translation":"অবশ্যই পাগল","audioUrl":"wbw/015_006_008.mp3","charTypeName":"word"},{"id":6945,"position":9,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"لَّوْ مَا تَأْتِينَا بِٱلْمَلَٰٓئِكَةِ إِن كُنتَ مِنَ ٱلصَّٰدِقِينَ","translation":"Why dost thou not bring before us angels, if thou art a man of truth?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1809.mp3","surahId":15,"words":[{"id":8233,"position":1,"arabic":"لَّوْ","translation":"কেন","audioUrl":"wbw/015_007_001.mp3","charTypeName":"word"},{"id":8234,"position":2,"arabic":"مَا","translation":"না","audioUrl":"wbw/015_007_002.mp3","charTypeName":"word"},{"id":8235,"position":3,"arabic":"تَأْتِينَا","translation":"আমাদের কাছে আসো","audioUrl":"wbw/015_007_003.mp3","charTypeName":"word"},{"id":8236,"position":4,"arabic":"بِٱلْمَلَـٰٓئِكَةِ","translation":"নিয়ে ফেরেশতাদের","audioUrl":"wbw/015_007_004.mp3","charTypeName":"word"},{"id":8237,"position":5,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/015_007_005.mp3","charTypeName":"word"},{"id":8238,"position":6,"arabic":"كُنتَ","translation":"তুমি হয়ে থাকো","audioUrl":"wbw/015_007_006.mp3","charTypeName":"word"},{"id":8239,"position":7,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/015_007_007.mp3","charTypeName":"word"},{"id":8240,"position":8,"arabic":"ٱلصَّـٰدِقِينَ","translation":"সত্যবাদীদের\"","audioUrl":"wbw/015_007_008.mp3","charTypeName":"word"},{"id":8241,"position":9,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"مَا نُنَزِّلُ ٱلْمَلَٰٓئِكَةَ إِلَّا بِٱلْحَقِّ وَمَا كَانُوٓا۟ إِذًۭا مُّنظَرِينَ","translation":"[Yet] We never send down angels otherwise than in accordance with the [demands of] truth; and [were the angels to appear now,] lo! they [who reject this divine writ] would have no further respite!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1810.mp3","surahId":15,"words":[{"id":9493,"position":1,"arabic":"مَا","translation":"না","audioUrl":"wbw/015_008_001.mp3","charTypeName":"word"},{"id":9494,"position":2,"arabic":"نُنَزِّلُ","translation":"আমরা অবতীর্ণ করি","audioUrl":"wbw/015_008_002.mp3","charTypeName":"word"},{"id":9495,"position":3,"arabic":"ٱلْمَلَـٰٓئِكَةَ","translation":"ফেরেশতাদেরকে","audioUrl":"wbw/015_008_003.mp3","charTypeName":"word"},{"id":9496,"position":4,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/015_008_004.mp3","charTypeName":"word"},{"id":9497,"position":5,"arabic":"بِٱلْحَقِّ","translation":"দিয়ে সত্য","audioUrl":"wbw/015_008_005.mp3","charTypeName":"word"},{"id":9498,"position":6,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/015_008_006.mp3","charTypeName":"word"},{"id":9499,"position":7,"arabic":"كَانُوٓا۟","translation":"তারা হবে","audioUrl":"wbw/015_008_007.mp3","charTypeName":"word"},{"id":9500,"position":8,"arabic":"إِذًۭا","translation":"তখন","audioUrl":"wbw/015_008_008.mp3","charTypeName":"word"},{"id":9501,"position":9,"arabic":"مُّنظَرِينَ","translation":"অবকাশপ্রাপ্ত","audioUrl":"wbw/015_008_009.mp3","charTypeName":"word"},{"id":9502,"position":10,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"إِنَّا نَحْنُ نَزَّلْنَا ٱلذِّكْرَ وَإِنَّا لَهُۥ لَحَٰفِظُونَ","translation":"Behold, it is We Ourselves who have bestowed from on high, step by step, this reminder? and, behold, it is We who shall truly guard it [from all corruption].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1811.mp3","surahId":15,"words":[{"id":10575,"position":1,"arabic":"إِنَّا","translation":"নিশ্চয়ই","audioUrl":"wbw/015_009_001.mp3","charTypeName":"word"},{"id":10576,"position":2,"arabic":"نَحْنُ","translation":"আমরা","audioUrl":"wbw/015_009_002.mp3","charTypeName":"word"},{"id":10577,"position":3,"arabic":"نَزَّلْنَا","translation":"আমরা অবতীর্ণ করেছি","audioUrl":"wbw/015_009_003.mp3","charTypeName":"word"},{"id":10578,"position":4,"arabic":"ٱلذِّكْرَ","translation":"উপদেশ বাণী (কুরআন)","audioUrl":"wbw/015_009_004.mp3","charTypeName":"word"},{"id":10579,"position":5,"arabic":"وَإِنَّا","translation":"এবং নিশ্চয়ই আমরা","audioUrl":"wbw/015_009_005.mp3","charTypeName":"word"},{"id":10580,"position":6,"arabic":"لَهُۥ","translation":"জন্যে তার","audioUrl":"wbw/015_009_006.mp3","charTypeName":"word"},{"id":10581,"position":7,"arabic":"لَحَـٰفِظُونَ","translation":"অবশ্যই সংরক্ষক","audioUrl":"wbw/015_009_007.mp3","charTypeName":"word"},{"id":10582,"position":8,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"وَلَقَدْ أَرْسَلْنَا مِن قَبْلِكَ فِى شِيَعِ ٱلْأَوَّلِينَ","translation":"AND, INDEED, [O Prophet,] even before thy time did We send [Our apostles] unto communities of old -","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1812.mp3","surahId":15,"words":[{"id":11721,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/015_010_001.mp3","charTypeName":"word"},{"id":11722,"position":2,"arabic":"أَرْسَلْنَا","translation":"আমরা পাঠিয়েছি","audioUrl":"wbw/015_010_002.mp3","charTypeName":"word"},{"id":11723,"position":3,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/015_010_003.mp3","charTypeName":"word"},{"id":11724,"position":4,"arabic":"قَبْلِكَ","translation":"তোমার পূর্ব","audioUrl":"wbw/015_010_004.mp3","charTypeName":"word"},{"id":11725,"position":5,"arabic":"فِى","translation":"কাছে (রাসূলদেরকে)","audioUrl":"wbw/015_010_005.mp3","charTypeName":"word"},{"id":11726,"position":6,"arabic":"شِيَعِ","translation":"জাতিগুলোর","audioUrl":"wbw/015_010_006.mp3","charTypeName":"word"},{"id":11727,"position":7,"arabic":"ٱلْأَوَّلِينَ","translation":"পূর্ববর্তী","audioUrl":"wbw/015_010_007.mp3","charTypeName":"word"},{"id":11728,"position":8,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"وَمَا يَأْتِيهِم مِّن رَّسُولٍ إِلَّا كَانُوا۟ بِهِۦ يَسْتَهْزِءُونَ","translation":"and never yet came an apostle to them without their deriding him.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1813.mp3","surahId":15,"words":[{"id":13206,"position":1,"arabic":"وَمَا","translation":"এবং নি","audioUrl":"wbw/015_011_001.mp3","charTypeName":"word"},{"id":13207,"position":2,"arabic":"يَأْتِيهِم","translation":"তাদের কাছে আসে","audioUrl":"wbw/015_011_002.mp3","charTypeName":"word"},{"id":13208,"position":3,"arabic":"مِّن","translation":"কোনো","audioUrl":"wbw/015_011_003.mp3","charTypeName":"word"},{"id":13209,"position":4,"arabic":"رَّسُولٍ","translation":"রাসূল","audioUrl":"wbw/015_011_004.mp3","charTypeName":"word"},{"id":13210,"position":5,"arabic":"إِلَّا","translation":"এ ছাড়া যে","audioUrl":"wbw/015_011_005.mp3","charTypeName":"word"},{"id":13211,"position":6,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/015_011_006.mp3","charTypeName":"word"},{"id":13212,"position":7,"arabic":"بِهِۦ","translation":"সাথে তার","audioUrl":"wbw/015_011_007.mp3","charTypeName":"word"},{"id":13213,"position":8,"arabic":"يَسْتَهْزِءُونَ","translation":"তারা বিদ্রুপ করতো","audioUrl":"wbw/015_011_008.mp3","charTypeName":"word"},{"id":13214,"position":9,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]},{"number":12,"arabic":"كَذَٰلِكَ نَسْلُكُهُۥ فِى قُلُوبِ ٱلْمُجْرِمِينَ","translation":"Even so do We [now] cause this [scorn of Our message] to pervade the hearts of those who are lost in sin,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1814.mp3","surahId":15,"words":[{"id":13537,"position":1,"arabic":"كَذَٰلِكَ","translation":"এভাবে","audioUrl":"wbw/015_012_001.mp3","charTypeName":"word"},{"id":13538,"position":2,"arabic":"نَسْلُكُهُۥ","translation":"তা প্রবেশ করাই আমরা","audioUrl":"wbw/015_012_002.mp3","charTypeName":"word"},{"id":13539,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/015_012_003.mp3","charTypeName":"word"},{"id":13540,"position":4,"arabic":"قُلُوبِ","translation":"অন্তরসমূহের","audioUrl":"wbw/015_012_004.mp3","ch