{"id":7,"ayahs":[{"number":38,"arabic":"قُلْنَا ٱهْبِطُوا۟ مِنْهَا جَمِيعًۭا ۖ فَإِمَّا يَأْتِيَنَّكُم مِّنِّى هُدًۭى فَمَن تَبِعَ هُدَاىَ فَلَا خَوْفٌ عَلَيْهِمْ وَلَا هُمْ يَحْزَنُونَ","translation":"[For although] We did say, \"Down with you all from this [state],\" there shall, none the less, most certainly come unto you guidance from Me: and those who follow My guidance need have no fear, and neither shall they grieve;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/45.mp3","surahId":2,"words":[{"id":39920,"position":1,"arabic":"قُلْنَا","translation":"আমরা বললাম,","audioUrl":"wbw/002_038_001.mp3","charTypeName":"word"},{"id":39921,"position":2,"arabic":"ٱهْبِطُوا۟","translation":"''তোমরা নামো","audioUrl":"wbw/002_038_002.mp3","charTypeName":"word"},{"id":39922,"position":3,"arabic":"مِنْهَا","translation":"এখান থেকে","audioUrl":"wbw/002_038_003.mp3","charTypeName":"word"},{"id":39923,"position":4,"arabic":"جَمِيعًۭا ۖ","translation":"সবাই","audioUrl":"wbw/002_038_004.mp3","charTypeName":"word"},{"id":39925,"position":5,"arabic":"فَإِمَّا","translation":"অতঃপর যখন","audioUrl":"wbw/002_038_006.mp3","charTypeName":"word"},{"id":39926,"position":6,"arabic":"يَأْتِيَنَّكُم","translation":"তোমাদের কাছে আসবে অবশ্যই","audioUrl":"wbw/002_038_007.mp3","charTypeName":"word"},{"id":39927,"position":7,"arabic":"مِّنِّى","translation":"আমার পক্ষ হতে","audioUrl":"wbw/002_038_008.mp3","charTypeName":"word"},{"id":39928,"position":8,"arabic":"هُدًۭى","translation":"পথনির্দেশনা","audioUrl":"wbw/002_038_009.mp3","charTypeName":"word"},{"id":39929,"position":9,"arabic":"فَمَن","translation":"তখন যে","audioUrl":"wbw/002_038_010.mp3","charTypeName":"word"},{"id":39930,"position":10,"arabic":"تَبِعَ","translation":"অনুসরণ করবে","audioUrl":"wbw/002_038_011.mp3","charTypeName":"word"},{"id":39931,"position":11,"arabic":"هُدَاىَ","translation":"আমার পথনির্দেশনা","audioUrl":"wbw/002_038_012.mp3","charTypeName":"word"},{"id":39932,"position":12,"arabic":"فَلَا","translation":"অতঃপর নেই","audioUrl":"wbw/002_038_013.mp3","charTypeName":"word"},{"id":39933,"position":13,"arabic":"خَوْفٌ","translation":"কোনো ভয়","audioUrl":"wbw/002_038_014.mp3","charTypeName":"word"},{"id":39934,"position":14,"arabic":"عَلَيْهِمْ","translation":"তাদের জন্যে","audioUrl":"wbw/002_038_015.mp3","charTypeName":"word"},{"id":39935,"position":15,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/002_038_016.mp3","charTypeName":"word"},{"id":39936,"position":16,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/002_038_017.mp3","charTypeName":"word"},{"id":39937,"position":17,"arabic":"يَحْزَنُونَ","translation":"দুঃখিত হবে","audioUrl":"wbw/002_038_018.mp3","charTypeName":"word"},{"id":39938,"position":18,"arabic":"٣٨","translation":"(৩৮)","audioUrl":null,"charTypeName":"end"}]},{"number":39,"arabic":"وَٱلَّذِينَ كَفَرُوا۟ وَكَذَّبُوا۟ بِـَٔايَٰتِنَآ أُو۟لَٰٓئِكَ أَصْحَٰبُ ٱلنَّارِ ۖ هُمْ فِيهَا خَٰلِدُونَ","translation":"but those who are bent on denying the truth and giving the lie to Our messages - they are destined for the fire, and therein shall they abide.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/46.mp3","surahId":2,"words":[{"id":40738,"position":1,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/002_039_001.mp3","charTypeName":"word"},{"id":40739,"position":2,"arabic":"كَفَرُوا۟","translation":"অবিশ্বাস করবে","audioUrl":"wbw/002_039_002.mp3","charTypeName":"word"},{"id":40740,"position":3,"arabic":"وَكَذَّبُوا۟","translation":"ও মিথ্যা মনে করবে","audioUrl":"wbw/002_039_003.mp3","charTypeName":"word"},{"id":40741,"position":4,"arabic":"بِـَٔايَـٰتِنَآ","translation":"আমার নিদর্শনসমূহকে","audioUrl":"wbw/002_039_004.mp3","charTypeName":"word"},{"id":40742,"position":5,"arabic":"أُو۟لَـٰٓئِكَ","translation":"তারা","audioUrl":"wbw/002_039_005.mp3","charTypeName":"word"},{"id":40743,"position":6,"arabic":"أَصْحَـٰبُ","translation":"অধিবাসী (হবে)","audioUrl":"wbw/002_039_006.mp3","charTypeName":"word"},{"id":40744,"position":7,"arabic":"ٱلنَّارِ ۖ","translation":"(জাহান্নামের) আগুনের","audioUrl":"wbw/002_039_007.mp3","charTypeName":"word"},{"id":40746,"position":8,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/002_039_009.mp3","charTypeName":"word"},{"id":40747,"position":9,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/002_039_010.mp3","charTypeName":"word"},{"id":40748,"position":10,"arabic":"خَـٰلِدُونَ","translation":"চিরস্থায়ী হবে''","audioUrl":"wbw/002_039_011.mp3","charTypeName":"word"},{"id":40749,"position":11,"arabic":"٣٩","translation":"(৩৯)","audioUrl":null,"charTypeName":"end"}]},{"number":40,"arabic":"يَٰبَنِىٓ إِسْرَٰٓءِيلَ ٱذْكُرُوا۟ نِعْمَتِىَ ٱلَّتِىٓ أَنْعَمْتُ عَلَيْكُمْ وَأَوْفُوا۟ بِعَهْدِىٓ أُوفِ بِعَهْدِكُمْ وَإِيَّٰىَ فَٱرْهَبُونِ","translation":"O CHILDREN of Israel! Remember those blessings of Mine with which I graced you, and fulfil your promise unto Me, [whereupon] I shall fulfil My promise unto you; and of Me, of Me stand in awe!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/47.mp3","surahId":2,"words":[{"id":41595,"position":1,"arabic":"يَـٰبَنِىٓ","translation":"হে সন্তান","audioUrl":"wbw/002_040_001.mp3","charTypeName":"word"},{"id":41596,"position":2,"arabic":"إِسْرَٰٓءِيلَ","translation":"ইসরাঈলের","audioUrl":"wbw/002_040_002.mp3","charTypeName":"word"},{"id":41597,"position":3,"arabic":"ٱذْكُرُوا۟","translation":"তোমরা স্মরণ করো","audioUrl":"wbw/002_040_003.mp3","charTypeName":"word"},{"id":41598,"position":4,"arabic":"نِعْمَتِىَ","translation":"আমার নেয়ামতের","audioUrl":"wbw/002_040_004.mp3","charTypeName":"word"},{"id":41599,"position":5,"arabic":"ٱلَّتِىٓ","translation":"যা","audioUrl":"wbw/002_040_005.mp3","charTypeName":"word"},{"id":41600,"position":6,"arabic":"أَنْعَمْتُ","translation":"আমি নেয়ামত দিয়েছি","audioUrl":"wbw/002_040_006.mp3","charTypeName":"word"},{"id":41601,"position":7,"arabic":"عَلَيْكُمْ","translation":"তোমাদের উপর","audioUrl":"wbw/002_040_007.mp3","charTypeName":"word"},{"id":41602,"position":8,"arabic":"وَأَوْفُوا۟","translation":"এবং তোমরা পূর্ণ করো","audioUrl":"wbw/002_040_008.mp3","charTypeName":"word"},{"id":41603,"position":9,"arabic":"بِعَهْدِىٓ","translation":"আমার (কাছে কৃত) প্রতিশ্রুতি","audioUrl":"wbw/002_040_009.mp3","charTypeName":"word"},{"id":41604,"position":10,"arabic":"أُوفِ","translation":"আমি পূর্ণ কর","audioUrl":"wbw/002_040_010.mp3","charTypeName":"word"},{"id":41605,"position":11,"arabic":"بِعَهْدِكُمْ","translation":"তোমাদের (কাছে কৃত) প্রতিশ্রুতি;","audioUrl":"wbw/002_040_011.mp3","charTypeName":"word"},{"id":41606,"position":12,"arabic":"وَإِيَّـٰىَ","translation":"এবং শুধু আমাকেই","audioUrl":"wbw/002_040_012.mp3","charTypeName":"word"},{"id":41607,"position":13,"arabic":"فَٱرْهَبُونِ","translation":"তোমরা ভয় করো","audioUrl":"wbw/002_040_013.mp3","charTypeName":"word"},{"id":41608,"position":14,"arabic":"٤٠","translation":"(৪০)","audioUrl":null,"charTypeName":"end"}]},{"number":41,"arabic":"وَءَامِنُوا۟ بِمَآ أَنزَلْتُ مُصَدِّقًۭا لِّمَا مَعَكُمْ وَلَا تَكُونُوٓا۟ أَوَّلَ كَافِرٍۭ بِهِۦ ۖ وَلَا تَشْتَرُوا۟ بِـَٔايَٰتِى ثَمَنًۭا قَلِيلًۭا وَإِيَّٰىَ فَٱتَّقُونِ","translation":"Believe in that which I have [now] bestowed from on high, confirming the truth already in your possession, and be not foremost among those who deny its truth; and do not barter away My messages for a trifling gain; and of Me, of Me be conscious","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/48.mp3","surahId":2,"words":[{"id":42438,"position":1,"arabic":"وَءَامِنُوا۟","translation":"এবং তোমরা ঈমান আনো","audioUrl":"wbw/002_041_001.mp3","charTypeName":"word"},{"id":42439,"position":2,"arabic":"بِمَآ","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/002_041_002.mp3","charTypeName":"word"},{"id":42440,"position":3,"arabic":"أَنزَلْتُ","translation":"আমি অবতীর্ণ করেছি","audioUrl":"wbw/002_041_003.mp3","charTypeName":"word"},{"id":42441,"position":4,"arabic":"مُصَدِّقًۭا","translation":"সমর্থনকারী","audioUrl":"wbw/002_041_004.mp3",