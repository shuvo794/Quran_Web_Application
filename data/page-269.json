{"id":269,"ayahs":[{"number":15,"arabic":"وَأَلْقَىٰ فِى ٱلْأَرْضِ رَوَٰسِىَ أَن تَمِيدَ بِكُمْ وَأَنْهَٰرًۭا وَسُبُلًۭا لَّعَلَّكُمْ تَهْتَدُونَ","translation":"And he has placed firm mountains on earth, lest it sway with you, and rivers and paths, so that you might find your way,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1916.mp3","surahId":16,"words":[{"id":17930,"position":1,"arabic":"وَأَلْقَىٰ","translation":"এবং তিনি স্থাপন করেছেন","audioUrl":"wbw/016_015_001.mp3","charTypeName":"word"},{"id":17931,"position":2,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/016_015_002.mp3","charTypeName":"word"},{"id":17932,"position":3,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/016_015_003.mp3","charTypeName":"word"},{"id":17933,"position":4,"arabic":"رَوَٰسِىَ","translation":"পর্বতসমূহকে","audioUrl":"wbw/016_015_004.mp3","charTypeName":"word"},{"id":17934,"position":5,"arabic":"أَن","translation":"(এমন না হয়) যে","audioUrl":"wbw/016_015_005.mp3","charTypeName":"word"},{"id":17935,"position":6,"arabic":"تَمِيدَ","translation":"হেলে যায়","audioUrl":"wbw/016_015_006.mp3","charTypeName":"word"},{"id":17936,"position":7,"arabic":"بِكُمْ","translation":"তোমাদের নিয়ে","audioUrl":"wbw/016_015_007.mp3","charTypeName":"word"},{"id":17937,"position":8,"arabic":"وَأَنْهَـٰرًۭا","translation":"ও নদীসমূহ","audioUrl":"wbw/016_015_008.mp3","charTypeName":"word"},{"id":17938,"position":9,"arabic":"وَسُبُلًۭا","translation":"এবং রাস্তাসমূহ","audioUrl":"wbw/016_015_009.mp3","charTypeName":"word"},{"id":17939,"position":10,"arabic":"لَّعَلَّكُمْ","translation":"যাতে তোমরা","audioUrl":"wbw/016_015_010.mp3","charTypeName":"word"},{"id":17940,"position":11,"arabic":"تَهْتَدُونَ","translation":"পথের সন্ধান পাও","audioUrl":"wbw/016_015_011.mp3","charTypeName":"word"},{"id":17941,"position":12,"arabic":"١٥","translation":"(১৫)","audioUrl":null,"charTypeName":"end"}]},{"number":16,"arabic":"وَعَلَٰمَٰتٍۢ ۚ وَبِٱلنَّجْمِ هُمْ يَهْتَدُونَ","translation":"as well as [various other] means of orientation: for [it is] by the stars that men find their way.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1917.mp3","surahId":16,"words":[{"id":18945,"position":1,"arabic":"وَعَلَـٰمَـٰتٍۢ ۚ","translation":"ও (যমীনে) পথনির্ণায়ক চিহ্নসমূহ","audioUrl":"wbw/016_016_001.mp3","charTypeName":"word"},{"id":18947,"position":2,"arabic":"وَبِٱلنَّجْمِ","translation":"এবং সাহায্যে নক্ষত্রের","audioUrl":"wbw/016_016_003.mp3","charTypeName":"word"},{"id":18948,"position":3,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/016_016_004.mp3","charTypeName":"word"},{"id":18949,"position":4,"arabic":"يَهْتَدُونَ","translation":"পথ নির্দেশ পায়","audioUrl":"wbw/016_016_005.mp3","charTypeName":"word"},{"id":18950,"position":5,"arabic":"١٦","translation":"(১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":17,"arabic":"أَفَمَن يَخْلُقُ كَمَن لَّا يَخْلُقُ ۗ أَفَلَا تَذَكَّرُونَ","translation":"IS, THEN, HE who creates comparable to any [being] that cannot create? Will you not, then, bethink yourselves?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1918.mp3","surahId":16,"words":[{"id":20046,"position":1,"arabic":"أَفَمَن","translation":"তবে কি যিনি","audioUrl":"wbw/016_017_001.mp3","charTypeName":"word"},{"id":20047,"position":2,"arabic":"يَخْلُقُ","translation":"সৃষ্টি করেছেন","audioUrl":"wbw/016_017_002.mp3","charTypeName":"word"},{"id":20048,"position":3,"arabic":"كَمَن","translation":"(তার) মতো যে","audioUrl":"wbw/016_017_003.mp3","charTypeName":"word"},{"id":20049,"position":4,"arabic":"لَّا","translation":"না","audioUrl":"wbw/016_017_004.mp3","charTypeName":"word"},{"id":20050,"position":5,"arabic":"يَخْلُقُ ۗ","translation":"সৃষ্টি করে (কোন কিছুই)","audioUrl":"wbw/016_017_005.mp3","charTypeName":"word"},{"id":20052,"position":6,"arabic":"أَفَلَا","translation":"তবুও কি না","audioUrl":"wbw/016_017_007.mp3","charTypeName":"word"},{"id":20053,"position":7,"arabic":"تَذَكَّرُونَ","translation":"তোমরা শিক্ষা গ্রহণ করবে","audioUrl":"wbw/016_017_008.mp3","charTypeName":"word"},{"id":20054,"position":8,"arabic":"١٧","translation":"(১৭)","audioUrl":null,"charTypeName":"end"}]},{"number":18,"arabic":"وَإِن تَعُدُّوا۟ نِعْمَةَ ٱللَّهِ لَا تُحْصُوهَآ ۗ إِنَّ ٱللَّهَ لَغَفُورٌۭ رَّحِيمٌۭ","translation":"For, should you try to count God's blessings, you could never compute them! Behold, God is indeed much-forgiving, a dispenser of grace;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1919.mp3","surahId":16,"words":[{"id":21135,"position":1,"arabic":"وَإِن","translation":"এবং যদি","audioUrl":"wbw/016_018_001.mp3","charTypeName":"word"},{"id":21136,"position":2,"arabic":"تَعُدُّوا۟","translation":"তোমরা গণনা করো","audioUrl":"wbw/016_018_002.mp3","charTypeName":"word"},{"id":21137,"position":3,"arabic":"نِعْمَةَ","translation":"অনুগ্রহকে","audioUrl":"wbw/016_018_003.mp3","charTypeName":"word"},{"id":21138,"position":4,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/016_018_004.mp3","charTypeName":"word"},{"id":21139,"position":5,"arabic":"لَا","translation":"না","audioUrl":"wbw/016_018_005.mp3","charTypeName":"word"},{"id":21140,"position":6,"arabic":"تُحْصُوهَآ ۗ","translation":"তার সংখ্যা নির্ণয় করতে পারবে","audioUrl":"wbw/016_018_006.mp3","charTypeName":"word"},{"id":21142,"position":7,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/016_018_008.mp3","charTypeName":"word"},{"id":21143,"position":8,"arabic":"ٱللَّهَ","translation":"আল্লাহ্‌","audioUrl":"wbw/016_018_009.mp3","charTypeName":"word"},{"id":21144,"position":9,"arabic":"لَغَفُورٌۭ","translation":"অবশ্যই ক্ষমাশীল","audioUrl":"wbw/016_018_010.mp3","charTypeName":"word"},{"id":21145,"position":10,"arabic":"رَّحِيمٌۭ","translation":"পরম দয়ালু","audioUrl":"wbw/016_018_011.mp3","charTypeName":"word"},{"id":21146,"position":11,"arabic":"١٨","translation":"(১৮)","audioUrl":null,"charTypeName":"end"}]},{"number":19,"arabic":"وَٱللَّهُ يَعْلَمُ مَا تُسِرُّونَ وَمَا تُعْلِنُونَ","translation":"and God knows all that you keep secret as well as all that you bring into the open.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1920.mp3","surahId":16,"words":[{"id":22251,"position":1,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ্‌","audioUrl":"wbw/016_019_001.mp3","charTypeName":"word"},{"id":22252,"position":2,"arabic":"يَعْلَمُ","translation":"জানেন","audioUrl":"wbw/016_019_002.mp3","charTypeName":"word"},{"id":22253,"position":3,"arabic":"مَا","translation":"যা","audioUrl":"wbw/016_019_003.mp3","charTypeName":"word"},{"id":22254,"position":4,"arabic":"تُسِرُّونَ","translation":"তোমরা গোপন রাখো","audioUrl":"wbw/016_019_004.mp3","charTypeName":"word"},{"id":22255,"position":5,"arabic":"وَمَا","translation":"এবং যা","audioUrl":"wbw/016_019_005.mp3","charTypeName":"word"},{"id":22256,"position":6,"arabic":"تُعْلِنُونَ","translation":"তোমরা প্রকাশ করো","audioUrl":"wbw/016_019_006.mp3","charTypeName":"word"},{"id":22257,"position":7,"arabic":"١٩","translation":"(১৯)","audioUrl":null,"charTypeName":"end"}]},{"number":20,"arabic":"وَٱلَّذِينَ يَدْعُونَ مِن دُونِ ٱللَّهِ لَا يَخْلُقُونَ شَيْـًۭٔا وَهُمْ يُخْلَقُونَ","translation":"Now those beings that some people invoke beside God cannot create anything, since they themselves are but created:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1921.mp3","surahId":16,"words":[{"id":23270,"position":1,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/016_020_001.mp3","charTypeName":"word"},{"id":23271,"position":2,"arabic":"يَدْعُونَ","translation":"ডাকে","audioUrl":"wbw/016_020_002.mp3","charTypeName":"word"},{"id":23272,"position":3,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/016_020_003.mp3","charTypeName":"word"},{"id":23273,"position":4,"arabic":"دُونِ","translation":"ছাড়া","audioUrl":"wbw/016_020_004.mp3","charTypeName":"word"},{"id":23274,"position":5,"arabic":"ٱللَّهِ","translation":"আল্লাহকে","audioUrl":"wbw/016_020_005.mp3","charTypeName":"word"},{"id":23275,"position":6,"arabic":"لَا","translation":"না","audioUrl":"wbw/016_020_006.mp3","charTypeName":"word"},{"id":23276,"position":7,"arabic":"يَخْلُقُونَ","translation":"তারা সৃষ্টি করে","audioUrl":"wbw/016_020_007.mp3","charTypeName":"word"},{"id":23277,"position":8,"arabic":"شَيْـًۭٔا","translation":"কোনো কিছু","audioUrl":"wbw/016_020_008.mp3","charTypeName":"word"},{"id":23278,"position":9,"arabic":"وَهُمْ","translation":"বরং তাদেরকে","audioUrl":"wbw/016_020_009.mp3","charTypeName":"word"},{"id":23279,"position":10,"arabic":"يُخْلَقُونَ","translation":"সৃষ্টি করা হয়েছে","audioUrl":"wbw/016_020_010.mp3","charTypeName":"word"},{"id":23280,"position":11,"arabic":"٢٠","translation":"(২০)","audioUrl":null,"charTypeName":"end"}]},{"number":21,"arabic":"أَمْوَٰتٌ غَيْرُ أَحْيَآءٍۢ ۖ وَمَا يَشْعُرُونَ أَيَّانَ يُبْعَثُونَ","translation":"they are dead, not living, and they do not [even] know when they will be raised from the dead!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1922.mp3","surahId":16,"words":[{"id":24337,"position":1,"arabic":"أَمْوَٰتٌ","translation":"(তারা) মৃত","audioUrl":"wbw/016_021_001.mp3","charTypeName":"word"},{"id":24338,"position":2,"arabic":"غَيْرُ","translation":"নয়","audioUrl":"wbw/016_021_002.mp3","charTypeName":"word"},{"id":24339,"position":3,"arabic":"أَحْيَآءٍۢ ۖ","translation":"জীবিত","audioUrl":"wbw/016_021_003.mp3","charTypeName":"word"},{"id":24341,"position":4,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/016_021_005.mp3","charTypeName":"word"},{"id":24342,"position":5,"arabic":"يَشْعُرُونَ","translation":"চেতনা রাখে","audioUrl":"wbw/016_021_006.mp3","charTypeName":"word"},{"id":24343,"position":6,"arabic":"أَيَّانَ","translation":"কবে","audioUrl":"wbw/016_021_007.mp3","charTypeName":"word"},{"id":24344,"position":7,"arabic":"يُبْعَثُونَ","translation":"উঠানো হবে তাদের","audioUrl":"wbw/016_021_008.mp3","charTypeName":"word"},{"id":24345,"position":8,"arabic":"٢١","translation":"(২১)","audioUrl":null,"charTypeName":"end"}]},{"number":22,"arabic":"إِلَٰهُكُمْ إِلَٰهٌۭ وَٰحِدٌۭ ۚ فَٱلَّذِينَ لَا يُؤْمِنُونَ بِٱلْءَاخِرَةِ قُلُوبُهُم مُّنكِرَةٌۭ وَهُم مُّسْتَكْبِرُونَ","translation":"Your God is the One God: but because of their false pride, the hearts of those who do not believe in the life to come refuse to admit this [truth].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1923.mp3","surahId":16,"words":[{"id":25364,"position":1,"arabic":"إِلَـٰهُكُمْ","translation":"তোমাদের ইলাহ","audioUrl":"wbw/016_022_001.mp3","charTypeName":"word"},{"id":25365,"position":2,"arabic":"إِلَـٰهٌۭ","translation":"ইলাহ","audioUrl":"wbw/016_022_002.mp3","charTypeName":"word"},{"id":25366,"position":3,"arabic":"وَٰحِدٌۭ ۚ","translation":"একই","audioUrl":"wbw/016_022_003.mp3","charTypeName":"word"},{"id":25368,"position":4,"arabic":"فَٱلَّذِينَ","translation":"সুতরাং যারা","audioUrl":"wbw/016_022_005.mp3","charTypeName":"word"},{"id":25369,"position":5,"arabic":"لَا","translation":"না","audioUrl":"wbw/016_022_006.mp3","charTypeName":"word"},{"id":25370,"position":6,"arabic":"يُؤْمِنُونَ","translation":"বিশ্বাস করে","audioUrl":"wbw/016_022_007.mp3","charTypeName":"word"},{"id":25371,"position":7,"arabic":"بِٱلْـَٔاخِرَةِ","translation":"প্রতি আখেরাতের","audioUrl":"wbw/016_022_008.mp3","charTypeName":"word"},{"id":25372,"position":8,"arabic":"قُلُوبُهُم","translation":"তাদের অন্তরসমূহ","audioUrl":"wbw/016_022_009.mp3","charTypeName":"word"},{"id":25373,"position":9,"arabic":"مُّنكِرَةٌۭ","translation":"সত্যবিমুখ","audioUrl":"wbw/016_022_010.mp3","charTypeName":"word"},{"id":25374,"position":10,"arabic":"وَهُم","translation":"এবং তারা","audioUrl":"wbw/016_022_011.mp3","charTypeName":"word"},{"id":25375,"position":11,"arabic":"مُّسْتَكْبِرُونَ","translation":"অহংকারী","audioUrl":"wbw/016_022_012.mp3","charTypeName":"word"},{"id":25376,"position":12,"arabic":"٢٢","translation":"(২২)","audioUrl":null,"charTypeName":"end"}]},{"number":23,"arabic":"لَا جَرَمَ أَنَّ ٱللَّهَ يَعْلَمُ مَا يُسِرُّونَ وَمَا يُعْلِنُونَ ۚ إِنَّهُۥ لَا يُحِبُّ ٱلْمُسْتَكْبِرِينَ","translation":"Truly, God knows all that they keep secret as well as all that they bring into the open -[and,] behold, He does not love those who are given to arrogance,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1924.mp3","surahId":16,"words":[{"id":26411,"position":1,"arabic":"لَا","translation":"নেই","audioUrl":"wbw/016_023_001.mp3","charTypeName":"word"},{"id":26412,"position":2,"arabic":"جَرَمَ","translation":"সন্দেহ","audioUrl":"wbw/016_023_002.mp3","charTypeName":"word"},{"id":26413,"position":3,"arabic":"أَنَّ","translation":"যে","audioUrl":"wbw/016_023_003.mp3","charTypeName":"word"},{"id":26414,"position":4,"arabic":"ٱللَّهَ","translation":"আল্লাহ্‌","audioUrl":"wbw/016_023_004.mp3","charTypeName":"word"},{"id":26415,"position":5,"arabic":"يَعْلَمُ","translation":"জানেন","audioUrl":"wbw/016_023_005.mp3","charTypeName":"word"},{"id":26416,"position":6,"arabic":"مَا","translation":"যা","audioUrl":"wbw/016_023_006.mp3","charTypeName":"word"},{"id":26417,"position":7,"arabic":"يُسِرُّونَ","translation":"তারা গোপন রাখে","audioUrl":"wbw/016_023_007.mp3","charTypeName":"word"},{"id":26418,"position":8,"arabic":"وَمَا","translation":"এবং যা","audioUrl":"wbw/016_023_008.mp3","charTypeName":"word"},{"id":26419,"position":9,"arabic":"يُعْلِنُونَ ۚ","translation":"তারা প্রকাশ করে","audioUrl":"wbw/016_023_009.mp3","charTypeName":"word"},{"id":26421,"position":10,"arabic":"إِنَّهُۥ","translation":"নিশ্চয়ই তিনি","audioUrl":"wbw/016_023_011.mp3","charTypeName":"word"},{"id":26422,"position":11,"arabic":"لَا","translation":"না","audioUrl":"wbw/016_023_012.mp3","charTypeName":"word"},{"id":26423,"position":12,"arabic":"يُحِبُّ","translation":"ভালোবাসেন","audioUrl":"wbw/016_023_013.mp3","charTypeName":"word"},{"id":26424,"position":13,"arabic":"ٱلْمُسْتَكْبِرِينَ","translation":"অহংকারীদেরকে","audioUrl":"wbw/016_023_014.mp3","charTypeName":"word"},{"id":26425,"position":14,"arabic":"٢٣","translation":"(২৩)","audioUrl":null,"charTypeName":"end"}]},{"number":24,"arabic":"وَإِذَا قِيلَ لَهُم مَّاذَآ أَنزَلَ رَبُّكُمْ ۙ قَالُوٓا۟ أَسَٰطِيرُ ٱلْأَوَّلِينَ","translation":"and [who], whenever they are asked, \"What is it that your Sustainer has bestowed from on high?\"-are wont to answer, \"Fables of ancient times!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1925.mp3","surahId":16,"words":[{"id":27423,"position":1,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/016_024_001.mp3","charTypeName":"word"},{"id":27424,"position":2,"arabic":"قِيلَ","translation":"বলা হয়","audioUrl":"wbw/016_024_002.mp3","charTypeName":"word"},{"id":27425,"position":3,"arabic":"لَهُم","translation":"তাদেরকে","audioUrl":"wbw/016_024_003.mp3","charTypeName":"word"},{"id":27426,"position":4,"arabic":"مَّاذَآ","translation":"\"কি","audioUrl":"wbw/016_024_004.mp3","charTypeName":"word"},{"id":27427,"position":5,"arabic":"أَنزَلَ","translation":"অবতীর্ণ করেছেন","audioUrl":"wbw/016_024_005.mp3","charTypeName":"word"},{"id":27428,"position":6,"arabic":"رَبُّكُمْ ۙ","translation":"তোমাদের রব","audioUrl":"wbw/016_024_006.mp3","charTypeName":"word"},{"id":27430,"position":7,"arabic":"قَالُوٓا۟","translation":"তারা বলে","audioUrl":"wbw/016_024_008.mp3","charTypeName":"word"},{"id":27431,"position":8,"arabic":"أَسَـٰطِيرُ","translation":"\"উপকথাসমূহ","audioUrl":"wbw/016_024_009.mp3","charTypeName":"word"},{"id":27432,"position":9,"arabic":"ٱلْأَوَّلِينَ","translation":"পূর্ববর্তীদের\"","audioUrl":"wbw/016_024_010.mp3","charTypeName":"word"},{"id":27433,"position":10,"arabic":"٢٤","translation":"(২৪)","audioUrl":null,"charTypeName":"end"}]},{"number":25,"arabic":"لِيَحْمِلُوٓا۟ أَوْزَارَهُمْ كَامِلَةًۭ يَوْمَ ٱلْقِيَٰمَةِ ۙ وَمِنْ أَوْزَارِ ٱلَّذِينَ يُضِلُّونَهُم بِغَيْرِ عِلْمٍ ۗ أَلَا سَآءَ مَا يَزِرُونَ","translation":"Hence, on Resurrection Day they shall bear the full weight of their own burdens, as well as some of the burdens