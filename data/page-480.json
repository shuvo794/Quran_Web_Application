{"id":480,"ayahs":[{"number":30,"arabic":"إِنَّ ٱلَّذِينَ قَالُوا۟ رَبُّنَا ٱللَّهُ ثُمَّ ٱسْتَقَٰمُوا۟ تَتَنَزَّلُ عَلَيْهِمُ ٱلْمَلَٰٓئِكَةُ أَلَّا تَخَافُوا۟ وَلَا تَحْزَنُوا۟ وَأَبْشِرُوا۟ بِٱلْجَنَّةِ ٱلَّتِى كُنتُمْ تُوعَدُونَ","translation":"[But,] behold, as for those who say, “Our Sustainer is God,” and then steadfastly pursue the right way - upon them do angels often descend, [say­ing:] “Fear not and grieve not, but receive the glad tiding of that paradise which has been promised to you!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4248.mp3","surahId":41,"words":[{"id":32455,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/041_030_001.mp3","charTypeName":"word"},{"id":32456,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/041_030_002.mp3","charTypeName":"word"},{"id":32457,"position":3,"arabic":"قَالُوا۟","translation":"বলে","audioUrl":"wbw/041_030_003.mp3","charTypeName":"word"},{"id":32458,"position":4,"arabic":"رَبُّنَا","translation":"\"আমাদের রব","audioUrl":"wbw/041_030_004.mp3","charTypeName":"word"},{"id":32459,"position":5,"arabic":"ٱللَّهُ","translation":"আল্লাহ-ই\"","audioUrl":"wbw/041_030_005.mp3","charTypeName":"word"},{"id":32460,"position":6,"arabic":"ثُمَّ","translation":"অতঃপর","audioUrl":"wbw/041_030_006.mp3","charTypeName":"word"},{"id":32461,"position":7,"arabic":"ٱسْتَقَـٰمُوا۟","translation":"তারা অবিচল থাকে","audioUrl":"wbw/041_030_007.mp3","charTypeName":"word"},{"id":32462,"position":8,"arabic":"تَتَنَزَّلُ","translation":"অবতীর্ণ হয়","audioUrl":"wbw/041_030_008.mp3","charTypeName":"word"},{"id":32463,"position":9,"arabic":"عَلَيْهِمُ","translation":"তাদের উপর","audioUrl":"wbw/041_030_009.mp3","charTypeName":"word"},{"id":32464,"position":10,"arabic":"ٱلْمَلَـٰٓئِكَةُ","translation":"ফেরেশতারা (আর বলে)","audioUrl":"wbw/041_030_010.mp3","charTypeName":"word"},{"id":32465,"position":11,"arabic":"أَلَّا","translation":"\"যে না","audioUrl":"wbw/041_030_011.mp3","charTypeNa