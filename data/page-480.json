মধ্যে","audioUrl":"wbw/041_031_003.mp3","charTypeName":"word"},{"id":33308,"position":4,"arabic":"ٱلْحَيَوٰةِ","translation":"জীবনের","audioUrl":"wbw/041_031_004.mp3","charTypeName":"word"},{"id":33309,"position":5,"arabic":"ٱلدُّنْيَا","translation":"দুনিয়ার","audioUrl":"wbw/041_031_005.mp3","charTypeName":"word"},{"id":33310,"position":6,"arabic":"وَفِى","translation":"এবং মধ্যে","audioUrl":"wbw/041_031_006.mp3","charTypeName":"word"},{"id":33311,"position":7,"arabic":"ٱلْـَٔاخِرَةِ ۖ","translation":"পরকালের","audioUrl":"wbw/041_031_007.mp3","charTypeName":"word"},{"id":33313,"position":8,"arabic":"وَلَكُمْ","translation":"এবং তোমাদের জন্যে (রয়েছে)","audioUrl":"wbw/041_031_009.mp3","charTypeName":"word"},{"id":33314,"position":9,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/041_031_010.mp3","charTypeName":"word"},{"id":33315,"position":10,"arabic":"مَا","translation":"যা","audioUrl":"wbw/041_031_011.mp3","charTypeName":"word"},{"id":33316,"position":11,"arabic":"تَشْتَهِىٓ","translation":"চায়","audioUrl":"wbw/041_031_012.mp3","charTypeName":"word"},{"id":33317,"position":12,"arabic":"أَنفُسُكُمْ","translation":"তোমাদের মন","audioUrl":"wbw/041_031_013.mp3","charTypeName":"word"},{"id":33318,"position":13,"arabic":"وَلَكُمْ","translation":"এবং তোমাদের জন্যে","audioUrl":"wbw/041_031_014.mp3","charTypeName":"word"},{"id":33319,"position":14,"arabic":"فِيهَا","translation":"তার মধ্যে (রয়েছে)","audioUrl":"wbw/041_031_015.mp3","charTypeName":"word"},{"id":33320,"position":15,"arabic":"مَا","translation":"যা","audioUrl":"wbw/041_031_016.mp3","charTypeName":"word"},{"id":33321,"position":16,"arabic":"تَدَّعُونَ","translation":"তোমরা দাবি করবে","audioUrl":"wbw/041_031_017.mp3","charTypeName":"word"},{"id":33322,"position":17,"arabic":"٣١","translation":"(৩১)","audioUrl":null,"charTypeName":"end"}]},{"number":32,"arabic":"نُزُلًۭا مِّنْ غَفُورٍۢ رَّحِيمٍۢ","translation":"as a ready welcome from Him who is much-forgiving, a dispenser of grace!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4250.mp3","surahId":41,"words":[{"id":34365,"position":1,"arabic":"نُزُلًۭا","translation":"আপ্যায়ন","audioUrl":"wbw/041_032_001.mp3","charTypeName":"word"},{"id":34366,"position":2,"arabic":"مِّنْ","translation":"(আল্লাহর) পক্ষ থেকে","audioUrl":"wbw/041_032_002.mp3","charTypeName":"word"},{"id":34367,"position":3,"arabic":"غَفُورٍۢ","translation":"(যিনি) ক্ষমাশীল","audioUrl":"wbw/041_032_003.mp3","charTypeName":"word"},{"id":34368,"position":4,"arabic":"رَّحِيمٍۢ","translation":"পরম দয়ালু\"","audioUrl":"wbw/041_032_004.mp3","charTypeName":"word"},{"id":34369,"position":5,"arabic":"٣٢","translation":"(৩২)","audioUrl":null,"charTypeName":"end"}]},{"number":33,"arabic":"وَمَنْ أَحْسَنُ قَوْلًۭا مِّمَّن دَعَآ إِلَى ٱللَّهِ وَعَمِلَ صَٰلِحًۭا وَقَالَ إِنَّنِى مِنَ ٱلْمُسْلِمِينَ","translation":"And who could be better of speech than he who calls [his fellow-men] unto God, and does what is just and right, and says, “Verily, I am of those who have surrendered themselves to God”?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4251.mp3","surahId":41,"words":[{"id":35244,"position":1,"arabic":"وَمَنْ","translation":"এবং কার","audioUrl":"wbw/041_033_001.mp3","charTypeName":"word"},{"id":35245,"position":2,"arabic":"أَحْسَنُ","translation":"উত্তম","audioUrl":"wbw/041_033_002.mp3","charTypeName":"word"},{"id":35246,"position":3,"arabic":"قَوْلًۭا","translation":"কথা (হতে পারে)","audioUrl":"wbw/041_033_003.mp3","charTypeName":"word"},{"id":35247,"position":4,"arabic":"مِّمَّن","translation":"তার চেয়ে যে","audioUrl":"wbw/041_033_004.mp3","charTypeName":"word"},{"id":35248,"position":5,"arabic":"دَعَآ","translation":"ডাকে","audioUrl":"wbw/041_033_005.mp3","charTypeName":"word"},{"id":35249,"position":6,"arabic":"إِلَى","translation":"দিকে","audioUrl":"wbw/041_033_006.mp3","charTypeName":"word"},{"id":35250,"position":7,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/041_033_007.mp3","charTypeName":"word"},{"id":35251,"position":8,"arabic":"وَعَمِلَ","translation":"ও কাজ করে","audioUrl":"wbw/041_033_008.mp3","charTypeName":"word"},{"id":35252,"position":9,"arabic":"صَـٰلِحًۭا","translation":"সৎ","audioUrl":"wbw/041_033_009.mp3","charTypeName":"word"},{"id":35253,"position":10,"arabic":"وَقَالَ","translation":"এবং বলে","audioUrl":"wbw/041_033_010.mp3","charTypeName":"word"},{"id":35254,"position":11,"arabic":"إِنَّنِى","translation":"\"নিশ্চয়ই আমি","audioUrl":"wbw/041_033_011.mp3","charTypeName":"word"},{"id":35255,"position":12,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/041_033_012.mp3","charTypeName":"word"},{"id":35256,"position":13,"arabic":"ٱلْمُسْلِمِينَ","translation":"আত্মসমর্পণকারীদের (অর্থাৎ মুসলমানদের)\"","audioUrl":"wbw/041_033_013.mp3","charTypeName":"word"},{"id":35257,"position":14,"arabic":"٣٣","translation":"(৩৩)","audioUrl":null,"charTypeName":"end"}]},{"number":34,"arabic":"وَلَا تَسْتَوِى ٱلْحَسَنَةُ وَلَا ٱلسَّيِّئَةُ ۚ ٱدْفَعْ بِٱلَّتِى هِىَ أَحْسَنُ فَإِذَا ٱلَّذِى بَيْنَكَ وَبَيْنَهُۥ عَدَٰوَةٌۭ كَأَنَّهُۥ وَلِىٌّ حَمِيمٌۭ","translation":"But [since] good and evil cannot be equal, repel thou [evil] with something that is better and lo! he between whom and thyself was enmity [may then become] as though he had [always] been close [unto thee], a true friend!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4252.mp3","surahId":41,"words":[{"id":36131,"position":1,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/041_034_001.mp3","charTypeName":"word"},{"id":36132,"position":2,"arabic":"تَسْتَوِى","translation":"সমান হয়","audioUrl":"wbw/041_034_002.mp3","charTypeName":"word"},{"id":36133,"position":3,"arabic":"ٱلْحَسَنَةُ","translation":"ভালো","audioUrl":"wbw/041_034_003.mp3","charTypeName":"word"},{"id":36134,"position":4,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/041_034_004.mp3","charTypeName":"word"},{"id":36135,"position":5,"arabic":"ٱلسَّيِّئَةُ ۚ","translation":"মন্দ","audioUrl":"wbw/041_034_005.mp3","charTypeName":"word"},{"id":36137,"position":6,"arabic":"ٱدْفَعْ","translation":"প্রতিহত করো","audioUrl":"wbw/041_034_007.mp3","charTypeName":"word"},{"id":36138,"position":7,"arabic":"بِٱلَّتِى","translation":"সেই (জ্ঞান) দ্বারা","audioUrl":"wbw/041_034_008.mp3","charTypeName":"word"},{"id":36139,"position":8,"arabic":"هِىَ","translation":"যা","audioUrl":"wbw/041_034_009.mp3","charTypeName":"word"},{"id":36140,"position":9,"arabic":"أَحْسَنُ","translation":"উত্তম","audioUrl":"wbw/041_034_010.mp3","charTypeName":"word"},{"id":36141,"position":10,"arabic":"فَإِذَا","translation":"ফলে (দেখবে) তখন","audioUrl":"wbw/041_034_011.mp3","charTypeName":"word"},{"id":36142,"position":11,"arabic":"ٱلَّذِى","translation":"যে","audioUrl":"wbw/041_034_012.mp3","charTypeName":"word"},{"id":36143,"position":12,"arabic":"بَيْنَكَ","translation":"তোমার মাঝে","audioUrl":"wbw/041_034_013.mp3","charTypeName":"word"},{"id":36144,"position":13,"arabic":"وَبَيْنَهُۥ","translation":"ও তার মাঝে","audioUrl":"wbw/041_034_014.mp3","charTypeName":"word"},{"id":36145,"position":14,"arabic":"عَدَٰوَةٌۭ","translation":"শত্রুতা (আছে)","audioUrl":"wbw/041_034_015.mp3","charTypeName":"word"},{"id":36146,"position":15,"arabic":"كَأَنَّهُۥ","translation":"সে যেন (হয়ে যাবে)","audioUrl":"wbw/041_034_016.mp3","charTypeName":"word"},{"id":36147,"position":16,"arabic":"وَلِىٌّ","translation":"বন্ধু","audioUrl":"wbw/041_034_017.mp3","charTypeName":"word"},{"id":36148,"position":17,"arabic":"حَمِيمٌۭ","translation":"অন্তরঙ্গ","audioUrl":"wbw/041_034_018.mp3","charTypeName":"word"},{"id":36149,"position":18,"arabic":"٣٤","translation":"(৩৪)","audioUrl":null,"charTypeName":"end"}]},{"number":35,"arabic":"وَمَا يُلَقَّىٰهَآ إِلَّا ٱلَّذِينَ صَبَرُوا۟ وَمَا يُلَقَّىٰهَآ إِلَّا ذُو حَظٍّ عَظِيمٍۢ","translation":"Yet [to achieve] this is not given to any but those who are wont to be patient in adversity: it is not given to any but those endowed with the greatest good fortune!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4253.mp3","surahId":41,"words":[{"id":36933,"position":1,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/041_035_001.mp3","charTypeName":"word"},{"id":36934,"position":2,"arabic":"يُلَقَّىٰهَآ","translation":"তা (জুটে) লাভ করে","audioUrl":"wbw/041_035_002.mp3","charTypeName":"word"},{"id":36935,"position":3,"arabic":"إِلَّا","translation":"এ ব্যতীত","audioUrl":"wbw/041_035_003.mp3","charTypeName":"word"},{"id":36936,"position":4,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/041_035_004.mp3","charTypeName":"word"},{"id":36937,"position":5,"arabic":"صَبَرُوا۟","translation":"ধৈর্য্য ধরে","audioUrl":"wbw/041_035_005.mp3","charTypeName":"word"},{"id":36938,"position":6,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/041_035_006.mp3","charTypeName":"word"},{"id":36939,"position":7,"arabic":"يُلَقَّىٰهَآ","translation":"তা (জুটে) লাভ করে","audioUrl":"wbw/041_035_007.mp3","charTypeName":"word"},{"id":36940,"position":8,"arabic":"إِلَّا","translation":"এ ব্যতীত","audioUrl":"wbw/041_035_008.mp3","charTypeName":"word"},{"id":36941,"position":9,"arabic":"ذُو","translation":"অধিকারী","audioUrl":"wbw/041_035_009.mp3","charTypeName":"word"},{"id":36942,"position":10,"arabic":"حَظٍّ","translation":"ভাগ্যের","audioUrl":"wbw/041_035_010.mp3","charTypeName":"word"},{"id":36943,"position":11,"arabic":"عَظِيمٍۢ","translation":"মহা","audioUrl":"wbw/041_035_011.mp3","charTypeName":"word"},{"id":36944,"position":12,"arabic":"٣٥","translation":"(৩৫)","audioUrl":null,"charTypeName":"end"}]},{"number":36,"arabic":"وَإِمَّا يَنزَغَنَّكَ مِنَ ٱلشَّيْطَٰنِ نَزْغٌۭ فَٱسْتَعِذْ بِٱللَّهِ ۖ إِنَّهُۥ هُوَ ٱلسَّمِيعُ ٱلْعَلِيمُ","translation":"Hence, if it should happen that a prompting from Satan stirs thee up [to blind anger], seek refuge with God: behold, He alone is all-hearing, all-knowing!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4254.mp3","surahId":41,"words":[{"id":38572,"position":1,"arabic":"وَإِمَّا","translation":"আর যদি","audioUrl":"wbw/041_036_001.mp3","charTypeName":"word"},{"id":38573,"position":2,"arabic":"يَنزَغَنَّكَ","translation":"তোমাকে উস্কানি দেয়","audioUrl":"wbw/041_036_002.mp3","charTypeName":"word"},{"id":38574,"position":3,"arabic":"مِنَ","translation":"পক্ষ হতে","audioUrl":"wbw/041_036_003.mp3","charTypeName":"word"},{"id":38575,"position":4,"arabic":"ٱلشَّيْطَـٰنِ","translation":"শয়তানের","audioUrl":"wbw/041_036_004.mp3","charTypeName":"word"},{"id":38576,"position":5,"arabic":"نَزْغٌۭ","translation":"(যে কোন) কুমন্ত্রণা","audioUrl":"wbw/041_036_005.mp3","charTypeName":"word"},{"id":38577,"position":6,"arabic":"فَٱسْتَعِذْ","translation":"তবে  আশ্রয় চাও","audioUrl":"wbw/041_036_006.mp3","charTypeName":"word"},{"id":38578,"position":7,"arabic":"بِٱللَّهِ ۖ","translation":"আল্লাহর","audioUrl":"wbw/041_036_007.mp3","charTypeName":"word"},{"id":38580,"position":8,"arabic":"إِنَّهُۥ","translation":"তিনি নিশ্চয়ই","audioUrl":"wbw/041_036_009.mp3","charTypeName":"word"},{"id":38581,"position":9,"arabic":"هُوَ","translation":"তিনিই","audioUrl":"wbw/041_036_010.mp3","charTypeName":"word"},{"id":38582,"position":10,"arabic":"ٱلسَّمِيعُ","translation":"সবকিছু শুনেন","audioUrl":"wbw/041_036_011.mp3","charTypeName":"word"},{"id":38583,"position":11,"arabic":"ٱلْعَلِيمُ","translation":"সবকিছুু জানেন","audioUrl":"wbw/041_036_012.mp3","charTypeName":"word"},{"id":38584,"position":12,"arabic":"٣٦","translation":"(৩৬)","audioUrl":null,"charTypeName":"end"}]},{"number":37,"arabic":"وَمِنْ ءَايَٰتِهِ ٱلَّيْلُ وَٱلنَّهَارُ وَٱلشَّمْسُ وَٱلْقَمَرُ ۚ لَا تَسْجُدُوا۟ لِلشَّمْسِ وَلَا لِلْقَمَرِ وَٱسْجُدُوا۟ لِلَّهِ ٱلَّذِى خَلَقَهُنَّ إِن كُنتُمْ إِيَّاهُ تَعْبُدُونَ","translation":"Now among His signs are the night and the day, as well as the sun and the moon: [hence,] adore not the sun or the moon, but prostrate yourselves in adoration before God, who has created them - if it is Him whom you [really] worship.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4255.mp3","surahId":41,"words":[{"id":38653,"position":1,"arabic":"وَمِنْ","translation":"এবং মধ্যে হ'তে","audioUrl":"wbw/041_037_001.mp3","charTypeName":"word"},{"id":38654,"position":2,"arabic":"ءَايَـٰتِهِ","translation":"তাঁর নিদর্শনাবলীর","audioUrl":"wbw/041_037_002.mp3","charTypeName":"word"},{"id":38655,"position":3,"arabic":"ٱلَّيْلُ","translation":"(রয়েছে) রাত","audioUrl":"wbw/041_037_003.mp3","charTypeName":"word"},{"id":38656,"position":4,"arabic":"وَٱلنَّهَارُ","translation":"ও দিন","audioUrl":"wbw/041_037_004.mp3","charTypeName":"word"},{"id":38657,"position":5,"arabic":"وَٱلشَّمْسُ","translation":"এবং সূর্য","audioUrl":"wbw/041_037_005.mp3","charTypeName":"word"},{"id":38658,"position":6,"arabic":"وَٱلْقَمَرُ ۚ","translation":"ও চাঁদ","audioUrl":"wbw/041_037_006.mp3","charTypeName":"word"},{"id":38660,"position":7,"arabic":"لَا","translation":"না","audioUrl":"wbw/041_037_008.mp3","charTypeName":"word"},{"id":38661,"position":8,"arabic":"تَسْجُدُوا۟","translation":"তোমরা সিজদা করো","audioUrl":"wbw/041_037_009.mp3","charTypeName":"word"},{"id":38662,"position":9,"arabic":"لِلشَّمْسِ","translation":"সূর্যকে","audioUrl":"wbw/041_037_010.mp3","charTypeName":"word"},{"id":38663,"position":10,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/041_037_011.mp3","charTypeName":"word"},{"id":38664,"position":11,"arabic":"لِلْقَمَرِ","translation":"চাঁদকে","audioUrl":"wbw/041_037_012.mp3","charTypeName":"word"},{"id":38665,"position":12,"arabic":"وَٱسْجُدُوا۟","translation":"এবং তোমরা সিজদা করো","audioUrl":"wbw/041_037_013.mp3","charTypeName":"word"},{"id":38666,"position":13,"arabic":"لِلَّهِ","translation":"আল্লাহর-ই","audioUrl":"wbw/041_037_014.mp3","charTypeName":"word"},{"id":38667,"position":14,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/041_037_015.mp3","charTypeName":"word"},{"id":38668,"position":15,"arabic":"خَلَقَهُنَّ","translation":"তাদেরকে সৃষ্টি করেছেন","audioUrl":"wbw/041_037_016.mp3","charTypeName":"word"},{"id":38669,"position":16,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/041_037_017.mp3","charTypeName":"word"},{"id":38670,"position":17,"arabic":"كُنتُمْ","translation":"তোমরা হও (বাস্তবিকই)","audioUrl":"wbw/041_037_018.mp3","charTypeName":"word"},{"id":38671,"position":18,"arabic":"إِيَّاهُ","translation":"তাঁরই শুধু","audioUrl":"wbw/041_037_019.mp3","charTypeName":"word"},{"id":38672,"position":19,"arabic":"تَعْبُدُونَ","translation":"তোমরা ইবাদত করো","audioUrl":"wbw/041_037_020.mp3","charTypeName":"word"},{"id":38673,"position":20,"arabic":"٣٧","translation":"(৩৭)","audioUrl":null,"charTypeName":"end"}]},{"number":38,"arabic":"فَإِنِ ٱسْتَكْبَرُوا۟ فَٱلَّذِينَ عِندَ رَبِّكَ يُسَبِّحُونَ لَهُۥ بِٱلَّيْلِ وَٱلنَّهَارِ وَهُمْ لَا يَسْـَٔمُونَ ۩","translation":"And though some be too proud [to listen to this call], they who [in their hearts] are with thy Sustainer extol His limitless glory by night and by day, and never grow weary [thereof].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4256.mp3","surahId":41,"words":[{"id":39540,"position":1,"arabic":"فَإِنِ","translation":"অতঃপর যদি","audioUrl":"wbw/041_038_001.mp3","charTypeName":"word"},{"id":39541,"position":2,"arabic":"ٱسْتَكْبَرُوا۟","translation":"তোমরা অহংকার করো (তবে কোন পরোয়া নেই)","audioUrl":"wbw/041_038_002.mp3","charTypeName":"word"},{"id":39542,"position":3,"arabic":"فَٱلَّذِينَ","translation":"কারণ যারা (আছে)","audioUrl":"wbw/041_038_003.mp3","charTypeName":"word"},{"id":39543,"position":4,"arabic":"عِندَ","translation":"কাছে","audioUrl":"wbw/041_038_004.mp3","charTypeName":"word"},{"id":39544,"position":5,"arabic":"رَبِّكَ","translation":"তোমার রবের","audioUrl":"wbw/041_038_005.mp3","charTypeName":"word"},{"id":39545,"position":6,"arabic":"يُسَبِّحُونَ","translation":"তারা মহিমা ঘোষণা করছে","audioUrl":"wbw/041_038_006.mp3","charTypeName":"word"},{"id":39546,"position":7,"arabic":"لَهُۥ","translation":"তাঁরই","audioUrl":"wbw/041_038_007.mp3","charTypeName":"word"},{"id":39547,