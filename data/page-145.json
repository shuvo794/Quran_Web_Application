{"id":145,"ayahs":[{"number":132,"arabic":"وَلِكُلٍّۢ دَرَجَٰتٌۭ مِّمَّا عَمِلُوا۟ ۚ وَمَا رَبُّكَ بِغَٰفِلٍ عَمَّا يَعْمَلُونَ","translation":"for all shall be judged according to their [conscious] deeds - and thy Sustainer is not unaware of what they do.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/921.mp3","surahId":6,"words":[{"id":78147,"position":1,"arabic":"وَلِكُلٍّۢ","translation":"এবং সবার জন্য (রয়েছে)","audioUrl":"wbw/006_132_001.mp3","charTypeName":"word"},{"id":78148,"position":2,"arabic":"دَرَجَـٰتٌۭ","translation":"মর্যাদাসমূহ","audioUrl":"wbw/006_132_002.mp3","charTypeName":"word"},{"id":78149,"position":3,"arabic":"مِّمَّا","translation":"সে অনুসারে যা","audioUrl":"wbw/006_132_003.mp3","charTypeName":"word"},{"id":78150,"position":4,"arabic":"عَمِلُوا۟ ۚ","translation":"তারা কাজ করেছে","audioUrl":"wbw/006_132_004.mp3","charTypeName":"word"},{"id":78152,"position":5,"arabic":"وَمَا","translation":"এবং নন","audioUrl":"wbw/006_132_006.mp3","charTypeName":"word"},{"id":78153,"position":6,"arabic":"رَبُّكَ","translation":"তোমার রব","audioUrl":"wbw/006_132_007.mp3","charTypeName":"word"},{"id":78154,"position":7,"arabic":"بِغَـٰفِلٍ","translation":"অনবহিত","audioUrl":"wbw/006_132_008.mp3","charTypeName":"word"},{"id":78155,"position":8,"arabic":"عَمَّا","translation":"তা হতে যা","audioUrl":"wbw/006_132_009.mp3","charTypeName":"word"},{"id":78156,"position":9,"arabic":"يَعْمَلُونَ","translation":"তারা কাজ করে","audioUrl":"wbw/006_132_010.mp3","charTypeName":"word"},{"id":78157,"position":10,"arabic":"١٣٢","translation":"(১৩২)","audioUrl":null,"charTypeName":"end"}]},{"number":133,"arabic":"وَرَبُّكَ ٱلْغَنِىُّ ذُو ٱلرَّحْمَةِ ۚ إِن يَشَأْ يُذْهِبْكُمْ وَيَسْتَخْلِفْ مِنۢ بَعْدِكُم مَّا يَشَآءُ كَمَآ أَنشَأَكُم مِّن ذُرِّيَّةِ قَوْمٍ ءَاخَرِينَ","translation":"And thy Sustainer alone is self-sufficient, limitless in His grace. If He so wills, He may put an end to you and thereafter cause whom He wills to succeed you - even as He has brought you into being out of other people's seed.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/922.mp3","surahId":6,"words":[{"id":78297,"position":1,"arabic":"وَرَبُّكَ","translation":"এবং তোমার রব","audioUrl":"wbw/006_133_001.mp3","charTypeName":"word"},{"id":78298,"position":2,"arabic":"ٱلْغَنِىُّ","translation":"অভাবমুক্ত","audioUrl":"wbw/006_133_002.mp3","charTypeName":"word"},{"id":78299,"position":3,"arabic":"ذُو","translation":"অধিকারী","audioUrl":"wbw/006_133_003.mp3","charTypeName":"word"},{"id":78300,"position":4,"arabic":"ٱلرَّحْمَةِ ۚ","translation":"দয়ার","audioUrl":"wbw/006_133_004.mp3","charTypeName":"word"},{"id":78302,"position":5,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/006_133_006.mp3","charTypeName":"word"},{"id":78303,"position":6,"arabic":"يَشَأْ","translation":"ইচ্ছে করেন তিনি","audioUrl":"wbw/006_133_007.mp3","charTypeName":"word"},{"id":78304,"position":7,"arabic":"يُذْهِبْكُمْ","translation":"অপসারিত করতে পারেন তোমাদের","audioUrl":"wbw/006_133_008.mp3","charTypeName":"word"},{"id":78305,"position":8,"arabic":"وَيَسْتَخْلِفْ","translation":"ও স্থলাভিষিক্ত করতে পারেন","audioUrl":"wbw/006_133_009.mp3","charTypeName":"word"},{"id":78306,"position":9,"arabic":"مِنۢ","translation":"থেকে","audioUrl":"wbw/006_133_010.mp3","charTypeName":"word"},{"id":78307,"position":10,"arabic":"بَعْدِكُم","translation":"পর তোমাদের","audioUrl":"wbw/006_133_011.mp3","charTypeName":"word"},{"id":78308,"position":11,"arabic":"مَّا","translation":"যাকে","audioUrl":"wbw/006_133_012.mp3","charTypeName":"word"},{"id":78309,"position":12,"arabic":"يَشَآءُ","translation":"ইচ্ছে করবেন তিনি","audioUrl":"wbw/006_133_013.mp3","charTypeName":"word"},{"id":78310,"position":13,"arabic":"كَمَآ","translation":"যেমন","audioUrl":"wbw/006_133_014.mp3","charTypeName":"word"},{"id":78311,"position":14,"arabic":"أَنشَأَكُم","translation":"সৃষ্টি করেছেন তোমাদের","audioUrl":"wbw/006_133_015.mp3","charTypeName":"word"},{"id":78312,"position":15,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/006_133_016.mp3","charTypeName":"word"},{"id":78313,"position":16,"arabic":"ذُرِّيَّةِ","translation":"বংশধরদের","audioUrl":"wbw/006_133_017.mp3","charTypeName":"word"},{"id":78314,"position":17,"arabic":"قَوْمٍ","translation":"সম্প্রদায়ের","audioUrl":"wbw/006_133_018.mp3","charTypeName":"word"},{"id":78315,"position":18,"arabic":"ءَاخَرِينَ","translation":"অন্যান্য","audioUrl":"wbw/006_133_019.mp3","charTypeName":"word"},{"id":78316,"position":19,"arabic":"١٣٣","translation":"(১৩৩)","audioUrl":null,"charTypeName":"end"}]},{"number":134,"arabic":"إِنَّ مَا تُوعَدُونَ لَءَاتٍۢ ۖ وَمَآ أَنتُم بِمُعْجِزِينَ","translation":"Verily, that [reckoning] which you are promised is bound to come, and you cannot elude it!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/923.mp3","surahId":6,"words":[{"id":78346,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/006_134_001.mp3","charTypeName":"word"},{"id":78347,"position":2,"arabic":"مَا","translation":"যা","audioUrl":"wbw/006_134_002.mp3","charTypeName":"word"},{"id":78348,"position":3,"arabic":"تُوعَدُونَ","translation":"তোমাদের প্রতিশ্রুতি দেয়া হচ্ছে","audioUrl":"wbw/006_134_003.mp3","charTypeName":"word"},{"id":78349,"position":4,"arabic":"لَـَٔاتٍۢ ۖ","translation":"অবশ্যই আসবে","audioUrl":"wbw/006_134_004.mp3","charTypeName":"word"},{"id":78351,"position":5,"arabic":"وَمَآ","translation":"এবং না","audioUrl":"wbw/006_134_006.mp3","charTypeName":"word"},{"id":78352,"position":6,"arabic":"أَنتُم","translation":"তোমরা (সমর্থ হবে)","audioUrl":"wbw/006_134_007.mp3","charTypeName":"word"},{"id":78353,"position":7,"arabic":"بِمُعْجِزِينَ","translation":"অক্ষম করতে (আল্লাহ্‌কে)","audioUrl":"wbw/006_134_008.mp3","charTypeName":"word"},{"id":78354,"position":8,"arabic":"١٣٤","translation":"(১৩৪)","audioUrl":null,"charTypeName":"end"}]},{"number":135,"arabic":"قُلْ يَٰقَوْمِ ٱعْمَلُوا۟ عَلَىٰ مَكَانَتِكُمْ إِنِّى عَامِلٌۭ ۖ فَسَوْفَ تَعْلَمُونَ مَن تَكُونُ لَهُۥ عَٰقِبَةُ ٱلدَّارِ ۗ إِنَّهُۥ لَا يُفْلِحُ ٱلظَّٰلِمُونَ","translation":"Say: \"O my [unbelieving] people! Do yet all that may be within your power, [while] I, behold, shall labour [in God's way]; and in time you will come to know to whom the future belongs. Verily, never will evildoers attain to a happy state!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/924.mp3","surahId":6,"words":[{"id":78480,"position":1,"arabic":"قُلْ","translation":"(হে নাবী) বলো","audioUrl":"wbw/006_135_001.mp3","charTypeName":"word"},{"id":78481,"position":2,"arabic":"يَـٰقَوْمِ","translation":"\"হে আমার জাতি","audioUrl":"wbw/006_135_002.mp3","charTypeName":"word"},{"id":78482,"position":3,"arabic":"ٱعْمَلُوا۟","translation":"তোমরা কাজ করো","audioUrl":"wbw/006_135_003.mp3","charTypeName":"word"},{"id":78483,"position":4,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/006_135_004.mp3","charTypeName":"word"},{"id":78484,"position":5,"arabic":"مَكَانَتِكُمْ","translation":"তোমাদের জায়গায়","audioUrl":"wbw/006_135_005.mp3","charTypeName":"word"},{"id":78485,"position":6,"arabic":"إِنِّى","translation":"নিশ্চয়ই আমি","audioUrl":"wbw/006_135_006.mp3","charTypeName":"word"},{"id":78486,"position":7,"arabic":"عَامِلٌۭ ۖ","translation":"কর্মসম্পাদনকারী (নিজের স্হানে)","audioUrl":"wbw/006_135_007.mp3","charTypeName":"word"},{"id":78488,"position":8,"arabic":"فَسَوْفَ","translation":"অতঃপর শীঘ্রই","audioUrl":"wbw/006_135_009.mp3","charTypeName":"word"},{"id":78489,"position":9,"arabic":"تَعْلَمُونَ","translation":"তোমরা জানবে","audioUrl":"wbw/006_135_010.mp3","charTypeName":"word"},{"id":78490,"position":10,"arabic":"مَن","translation":"কে","audioUrl":"wbw/006_135_011.mp3","charTypeName":"word"},{"id":78491,"position":11,"arabic":"تَكُونُ","translation":"হবে (এমন যে)","audioUrl":"wbw/006_135_012.mp3","charTypeName":"word"},{"id":78492,"position":12,"arabic":"لَهُۥ","translation":"জন্যে তার (থাকবে)","audioUrl":"wbw/006_135_013.mp3","charTypeName":"word"},{"id":78493,"position":13,"arabic":"عَـٰقِبَةُ","translation":"পরিণামে","audioUrl":"wbw/006_135_014.mp3","charTypeName":"word"},{"id":78494,"position":14,"arabic":"ٱلدَّارِ ۗ","translation":"(কল্যাণকর) আবাসস্থল","audioUrl":"wbw/006_135_015.mp3","charTypeName":"word"},{"id":78496,"position":15,"arabic":"إِنَّهُۥ","translation":"নিশ্চয়ই তা (এমন সত্য যে)","audioUrl":"wbw/006_135_017.mp3","charTypeName":"word"},{"id":78497,"position":16,"arabic":"لَا","translation":"না","audioUrl":"wbw/006_135_018.mp3","charTypeName":"word"},{"id":78498,"position":17,"arabic":"يُفْلِحُ","translation":"সফল হয়","audioUrl":"wbw/006_135_019.mp3","charTypeName":"word"},{"id":78499,"position":18,"arabic":"ٱلظَّـٰلِمُونَ","translation":"সীমালঙ্ঘনকারীরা\"","audioUrl":"wbw/006_135_020.mp3","charTypeName":"word"},{"id":78500,"position":19,"arabic":"١٣٥","translation":"(১৩৫)","audioUrl":null,"charTypeName":"end"}]},{"number":136,"arabic":"وَجَعَلُوا۟ لِلَّهِ مِمَّا ذَرَأَ مِنَ ٱلْحَرْثِ وَٱلْأَنْعَٰمِ نَصِيبًۭا فَقَالُوا۟ هَٰذَا لِلَّهِ بِزَعْمِهِمْ وَهَٰذَا لِشُرَكَآئِنَا ۖ فَمَا كَانَ لِشُرَكَآئِهِمْ فَلَا يَصِلُ إِلَى ٱللَّهِ ۖ وَمَا كَانَ لِلَّهِ فَهُوَ يَصِلُ إِلَىٰ شُرَكَآئِهِمْ ۗ سَآءَ مَا يَحْكُمُونَ","translation":"AND OUT OF whatever He has created of the fruits of the field and the cattle, they assign unto God a portion, saying, \"This belongs to God\"-or so they [falsely] claim - \"and this is for those beings who, we are convinced, have a share in God's divinity.\" But that which is assigned to the beings associated in their minds with God does not bring [them] closer to God - whereas that which is assigned to God brings [them but] closer to those beings to whom they ascribe a share in His divinity. Bad, indeed, is their judgment!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/925.mp3","surahId":6,"words":[{"id":78703,"position":1,"arabic":"وَجَعَلُوا۟","translation":"এবং তারা নির্দিষ্ট করেছে","audioUrl":"wbw/006_136_001.mp3","charTypeName":"word"},{"id":78704,"position":2,"arabic":"لِلَّهِ","translation":"জন্যে আল্লাহ্‌র","audioUrl":"wbw/006_136_002.mp3","charTypeName":"word"},{"id":78705,"position":3,"arabic":"مِمَّا","translation":"তা হতে যা","audioUrl":"wbw/006_136_003.mp3","charTypeName":"word"},{"id":78706,"position":4,"arabic":"ذَرَأَ","translation":"তিনি সৃষ্টি করেছেন","audioUrl":"wbw/006_136_004.mp3","charTypeName":"word"},{"id":78707,"position":5,"arabic":"مِنَ","translation":"মধ্য হতে","audioUrl":"wbw/006_136_005.mp3","charTypeName":"word"},{"id":78708,"position":6,"arabic":"ٱلْحَرْثِ","translation":"ক্ষেত ফসলের","audioUrl":"wbw/006_136_006.mp3","charTypeName":"word"},{"id":78709,"position":7,"arabic":"وَٱلْأَنْعَـٰمِ","translation":"ও গবাদি পশুর","audioUrl":"wbw/006_136_007.mp3","charTypeName":"word"},{"id":78710,"position":8,"arabic":"نَصِيبًۭا","translation":"এক অংশ","audioUrl":"wbw/006_136_008.mp3","charTypeName":"word"},{"id":78711,"position":9,"arabic":"فَقَالُوا۟","translation":"অতঃপর তারা বলে","audioUrl":"wbw/006_136_009.mp3","charTypeName":"word"},{"id":78712,"position":10,"arabic":"هَـٰذَا","translation":"\"এটা","audioUrl":"wbw/006_136_010.mp3","charTypeName":"word"},{"id":78713,"position":11,"arabic":"لِلَّهِ","translation":"জন্যে আল্লাহ্‌র\"","audioUrl":"wbw/006_136_011.mp3","charTypeName":"word"},{"id":78714,"position":12,"arabic":"بِزَعْمِهِمْ","translation":"অনুযায়ী ধারণা তাদের","audioUrl":"wbw/006_136_012.mp3","charTypeName":"word"},{"id":78715,"position":13,"arabic":"وَهَـٰذَا","translation":"\"এবং (বল) এই (অন্য অংশটা)","audioUrl":"wbw/006_136_013.mp3","charTypeName":"word"},{"id":78716,"position":14,"arabic":"لِشُرَكَآئِنَا ۖ","translation":"জন্যে আমাদের শরিকদের\"","audioUrl":"wbw/006_136_014.mp3","charTypeName":"word"},{"id":78718,"position":15,"arabic":"فَمَا","translation":"অতঃপর যা","audioUrl":"wbw/006_136_016.mp3","charTypeName":"word"},{"id":78719,"position":16,"arabic":"كَانَ","translation":"হয়","audioUrl":"wbw/006_136_017.mp3","charTypeName":"word"},{"id":78720,"position":17,"arabic":"لِشُرَكَا