{"id":30,"ayahs":[{"number":191,"arabic":"وَٱقْتُلُوهُمْ حَيْثُ ثَقِفْتُمُوهُمْ وَأَخْرِجُوهُم مِّنْ حَيْثُ أَخْرَجُوكُمْ ۚ وَٱلْفِتْنَةُ أَشَدُّ مِنَ ٱلْقَتْلِ ۚ وَلَا تُقَٰتِلُوهُمْ عِندَ ٱلْمَسْجِدِ ٱلْحَرَامِ حَتَّىٰ يُقَٰتِلُوكُمْ فِيهِ ۖ فَإِن قَٰتَلُوكُمْ فَٱقْتُلُوهُمْ ۗ كَذَٰلِكَ جَزَآءُ ٱلْكَٰفِرِينَ","translation":"And slay them wherever you may come upon them, and drive them away from wherever they drove you away - for oppression is even worse than killing. And fight not against them near the Inviolable House of Worship unless they fight against you there first; but if they fight against you, slay them: such shall be the recompense of those who deny the truth.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/198.mp3","surahId":2,"words":[{"id":84646,"position":1,"arabic":"وَٱقْتُلُوهُمْ","translation":"এবং তাদেরকে হত্যা করো","audioUrl":"wbw/002_191_001.mp3","charTypeName":"word"},{"id":84647,"position":2,"arabic":"حَيْثُ","translation":"যেখানেই","audioUrl":"wbw/002_191_002.mp3","charTypeName":"word"},{"id":84648,"position":3,"arabic":"ثَقِفْتُمُوهُمْ","translation":"তাদেরকে তোমরা পাও","audioUrl":"wbw/002_191_003.mp3","charTypeName":"word"},{"id":84649,"position":4,"arabic":"وَأَخْرِجُوهُم","translation":"ও তাদেরকে বের করে দাও","audioUrl":"wbw/002_191_004.mp3","charTypeName":"word"},{"id":84650,"position":5,"arabic":"مِّنْ","translation":"থেকে","audioUrl":"wbw/002_191_005.mp3","charTypeName":"word"},{"id":84651,"position":6,"arabic":"حَيْثُ","translation":"যেখান","audioUrl":"wbw/002_191_006.mp3","charTypeName":"word"},{"id":84652,"position":7,"arabic":"أَخْرَجُوكُمْ ۚ","translation":"তোমাদের বের করেছে তারা","audioUrl":"wbw/002_191_007.mp3","charTypeName":"word"},{"id":84654,"position":8,"arabic":"وَٱلْفِتْنَةُ","translation":"এবং বিপর্যয়","audioUrl":"wbw/002_191_009.mp3","charTypeName":"word"},{"id":84655,"position":9,"arabic":"أَشَدُّ","translation":"গুরুতর","audioUrl":"wbw/002_191_010.mp3","charTypeName":"word"},{"id":84656,"position":10,"arabic":"مِنَ","translation":"চেয়ে","audioUrl":"wbw/002_191_011.mp3","charTypeName":"word"},{"id":84657,"position":11,"arabic":"ٱلْقَتْلِ ۚ","translation":"হত্যার","audioUrl":"wbw/002_191_012.mp3","charTypeName":"word"},{"id":84659,"position":12,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/002_191_014.mp3","charTypeName":"word"},{"id":84660,"position":13,"arabic":"تُقَـٰتِلُوهُمْ","translation":"তাদের সাথে যুদ্ধ কর","audioUrl":"wbw/002_191_015.mp3","charTypeName":"word"},{"id":84661,"position":14,"arabic":"عِندَ","translation":"কাছে","audioUrl":"wbw/002_191_016.mp3","charTypeName":"word"},{"id":84662,"position":15,"arabic":"ٱلْمَسْجِدِ","translation":"মসজিদে","audioUrl":"wbw/002_191_017.mp3","charTypeName":"word"},{"id":84663,"position":16,"arabic":"ٱلْحَرَامِ","translation":"হারামের","audioUrl":"wbw/002_191_018.mp3","charTypeName":"word"},{"id":84664,"position":17,"arabic":"حَتَّىٰ","translation":"যতক্ষণ না","audioUrl":"wbw/002_191_019.mp3","charTypeName":"word"},{"id":84665,"position":18,"arabic":"يُقَـٰتِلُوكُمْ","translation":"তোমাদের সাথে যুদ্ধ করে তারা","audioUrl":"wbw/002_191_020.mp3","charTypeName":"word"},{"id":84666,"position":19,"arabic":"فِيهِ ۖ","translation":"তার মধ্যে","audioUrl":"wbw/002_191_021.mp3","charTypeName":"word"},{"id":84668,"position":20,"arabic":"فَإِن","translation":"তবে যদি","audioUrl":"wbw/002_191_023.mp3","charTypeName":"word"},{"id":84669,"position":21,"arabic":"قَـٰتَلُوكُمْ","translation":"তোমাদের সাথে যুদ্ধ করে তারা","audioUrl":"wbw/002_191_024.mp3","charTypeName":"word"},{"id":84670,"position":22,"arabic":"فَٱقْتُلُوهُمْ ۗ","translation":"তাহলে তোমরা হত্যা করো","audioUrl":"wbw/002_191_025.mp3","charTypeName":"word"},{"id":84672,"position":23,"arabic":"كَذَٰلِكَ","translation":"এরূপই","audioUrl":"wbw/002_191_027.mp3","charTypeName":"word"},{"id":84673,"position":24,"arabic":"جَزَآءُ","translation":"শাস্তি","audioUrl":"wbw/002_191_028.mp3","charTypeName":"word"},{"id":84674,"position":25,"arabic":"ٱلْكَـٰفِرِينَ","translation":"কাফেরদের","audioUrl":"wbw/002_191_029.mp3","charTypeName":"word"},{"id":84675,"position":26,"arabic":"١٩١","translation":"(১৯১)","audioUrl":null,"charTypeName":"end"}]},{"number":192,"arabic":"فَإِنِ ٱنتَهَوْا۟ فَإِنَّ ٱللَّهَ غَفُورٌۭ رَّحِيمٌۭ","translation":"But if they desist-behold, God is much-forgiving, a dispenser of grace.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/199.mp3","surahId":2,"words":[{"id":84725,"position":1,"arabic":"فَإِنِ","translation":"অতঃপর যদি","audioUrl":"wbw/002_192_001.mp3","charTypeName":"word"},{"id":84726,"position":2,"arabic":"ٱنتَهَوْا۟","translation":"তারা বিরত হয়","audioUrl":"wbw/002_192_002.mp3","charTypeName":"word"},{"id":84727,"position":3,"arabic":"فَإِنَّ","translation":"তবে নিশ্চয়ই","audioUrl":"wbw/002_192_003.mp3","charTypeName":"word"},{"id":84728,"position":4,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/002_192_004.mp3","charTypeName":"word"},{"id":84729,"position":5,"arabic":"غَفُورٌۭ","translation":"ক্ষমাশীল","audioUrl":"wbw/002_192_005.mp3","charTypeName":"word"},{"id":84730,"position":6,"arabic":"رَّحِيمٌۭ","translation":"পরম দয়ালু","audioUrl":"wbw/002_192_006.mp3","charTypeName":"word"},{"id":84731,"position":7,"arabic":"١٩٢","translation":"(১৯২)","audioUrl":null,"charTypeName":"end"}]},{"number":193,"arabic":"وَقَٰتِلُوهُمْ حَتَّىٰ لَا تَكُونَ فِتْنَةٌۭ وَيَكُونَ ٱلدِّينُ لِلَّهِ ۖ فَإِنِ ٱنتَهَوْا۟ فَلَا عُدْوَٰنَ إِلَّا عَلَى ٱلظَّٰلِمِينَ","translation":"Hence, fight against them until there is no more oppression and all worship is devoted to God alone; but if they desist, then all hostility shall cease, save against those who [wilfully] do wrong.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/200.mp3","surahId":2,"words":[{"id":84750,"position":1,"arabic":"وَقَـٰتِلُوهُمْ","translation":"এবং তোমরা যুদ্ধ করতে থাকো তাদেরকে","audioUrl":"wbw/002_193_001.mp3","charTypeName":"word"},{"id":84751,"position":2,"arabic":"حَتَّىٰ","translation":"যতক্ষণ","audioUrl":"wbw/002_193_002.mp3","charTypeName":"word"},{"id":84752,"position":3,"arabic":"لَا","translation":"না","audioUrl":"wbw/002_193_003.mp3","charTypeName":"word"},{"id":84753,"position":4,"arabic":"تَكُونَ","translation":"থাকে","audioUrl":"wbw/002_193_004.mp3","charTypeName":"word"},{"id":84754,"position":5,"arabic":"فِتْنَةٌۭ","translation":"বিপর্যয়","audioUrl":"wbw/002_193_005.mp3","charTypeName":"word"},{"id":84755,"position":6,"arabic":"وَيَكُونَ","translation":"ও হয়","audioUrl":"wbw/002_193_006.mp3","charTypeName":"word"},{"id":84756,"position":7,"arabic":"ٱلدِّينُ","translation":"দ্বীন","audioUrl":"wbw/002_193_007.mp3","charTypeName":"word"},{"id":84757,"position":8,"arabic":"لِلَّهِ ۖ","translation":"আল্লাহর জন্যে (নির্দিষ্ট)","audioUrl":"wbw/002_193_008.mp3","charTypeName":"word"},{"id":84759,"position":9,"arabic":"فَإِنِ","translation":"যদি অতঃপর","audioUrl":"wbw/002_193_010.mp3","charTypeName":"word"},{"id":84760,"position":10,"arabic":"ٱنتَهَوْا۟","translation":"তারা বিরত হয়","audioUrl":"wbw/002_193_011.mp3","charTypeName":"word"},{"id":84761,"position":11,"arabic":"فَلَا","translation":"নেই তবে","audioUrl":"wbw/002_193_012.mp3","charTypeName":"word"},{"id":84762,"position":12,"arabic":"عُدْوَٰنَ","translation":"আক্রমণের (সুযোগ)","audioUrl":"wbw/002_193_013.mp3","charTypeName":"word"},{"id":84763,"position":13,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/002_193_014.mp3","charTypeName":"word"},{"id":84764,"position":14,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/002_193_015.mp3","charTypeName":"word"},{"id":84765,"position":15,"arabic":"ٱلظَّـٰلِمِينَ","translation":"সীমালঙ্ঘনকারীদের","audioUrl":"wbw/002_193_016.mp3","charTypeName":"word"},{"id":84766,"position":16,"arabic":"١٩٣","translation":"(১৯৩)","audioUrl":null,"charTypeName":"end"}]},{"number":194,"arabic":"ٱلشَّهْرُ ٱلْحَرَامُ بِٱلشَّهْرِ ٱلْحَرَامِ وَٱلْحُرُمَٰتُ قِصَاصٌۭ ۚ فَمَنِ ٱعْتَدَىٰ عَلَيْكُمْ فَٱعْتَدُوا۟ عَلَيْهِ بِمِثْلِ مَا ٱعْتَدَىٰ عَلَيْكُمْ ۚ وَٱتَّقُوا۟ ٱللَّهَ وَٱعْلَمُوٓا۟ أَنَّ ٱللَّهَ مَعَ ٱلْمُتَّقِينَ","translation":"Fight during the sacred months if you are attacked: for a violation of sanctity is [subject to the law of] just retribution. Thus, if anyone commits aggression against you, attack him just as he has attacked you - but remain conscious of God, and know that God is with those who are conscious of Him.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/201.mp3","surahId":2,"words":[{"id":84841,"position":1,"arabic":"ٱلشَّهْرُ","translation":"মাস","audioUrl":"wbw/002_194_001.mp3","charTypeName":"word"},{"id":84842,"position":2,"arabic":"ٱلْحَرَامُ","translation":"পবিত্র","audioUrl":"wbw/002_194_002.mp3","charTypeName":"word"},{"id":84843,"position":3,"arabic":"بِٱلشَّهْرِ","translation":"মাস বিনিময়ে","audioUrl":"wbw/002_194_003.mp3","charTypeName":"word"},{"id":84844,"position":4,"arabic":"ٱلْحَرَامِ","translation":"পবিত্র","audioUrl":"wbw/002_194_004.mp3","charTypeName":"word"},{"id":84845,"position":5,"arabic":"وَٱلْحُرُمَـٰتُ","translation":"এবং সমস্ত পবিত্র বিষয় (লংঘনের)","audioUrl":"wbw/002_194_005.mp3","charTypeName":"word"},{"id":84846,"position":6,"arabic":"قِصَاصٌۭ ۚ","translation":"বদলা (রয়েছে)","audioUrl":"wbw/002_194_006.mp3","charTypeName":"word"},{"id":84848,"position":7,"arabic":"فَمَنِ","translation":"যে তাই","audioUrl":"wbw/002_194_008.mp3","charTypeName":"word"},{"id":84849,"position":8,"arabic":"ٱعْتَدَىٰ","translation":"বাড়াবাড়ি করবে","audioUrl":"wbw/002_194_009.mp3","charTypeName":"word"},{"id":84850,"position":9,"arabic":"عَلَيْكُمْ","translation":"তোমাদের উপর","audioUrl":"wbw/002_194_010.mp3","charTypeName":"word"},{"id":84851,"position":10,"arabic":"فَٱعْتَدُوا۟","translation":"তোমরাও তখন বাড়াবাড়ির বদলা নাও","audioUrl":"wbw/002_194_011.mp3","charTypeName":"word"},{"id":84852,"position":11,"arabic":"عَلَيْهِ","translation":"তার উপর","audioUrl":"wbw/002_194_012.mp3","charTypeName":"word"},{"id":84853,"position":12,"arabic":"بِمِثْلِ","translation":"অনুরূপ","audioUrl"