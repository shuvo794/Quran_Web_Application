eName":"word"},{"id":84867,"position":2,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/002_195_002.mp3","charTypeName":"word"},{"id":84868,"position":3,"arabic":"سَبِيلِ","translation":"পথের","audioUrl":"wbw/002_195_003.mp3","charTypeName":"word"},{"id":84869,"position":4,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/002_195_004.mp3","charTypeName":"word"},{"id":84870,"position":5,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/002_195_005.mp3","charTypeName":"word"},{"id":84871,"position":6,"arabic":"تُلْقُوا۟","translation":"তোমরা নিক্ষেপ করো","audioUrl":"wbw/002_195_006.mp3","charTypeName":"word"},{"id":84872,"position":7,"arabic":"بِأَيْدِيكُمْ","translation":"তোমাদের হাতে (নিজেদেরকে)","audioUrl":"wbw/002_195_007.mp3","charTypeName":"word"},{"id":84873,"position":8,"arabic":"إِلَى","translation":"দিকে","audioUrl":"wbw/002_195_008.mp3","charTypeName":"word"},{"id":84874,"position":9,"arabic":"ٱلتَّهْلُكَةِ ۛ","translation":"ধ্বংসের","audioUrl":"wbw/002_195_009.mp3","charTypeName":"word"},{"id":84876,"position":10,"arabic":"وَأَحْسِنُوٓا۟ ۛ","translation":"এবং তোমরা অনুগ্রহ করো","audioUrl":"wbw/002_195_011.mp3","charTypeName":"word"},{"id":84878,"position":11,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/002_195_013.mp3","charTypeName":"word"},{"id":84879,"position":12,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/002_195_014.mp3","charTypeName":"word"},{"id":84880,"position":13,"arabic":"يُحِبُّ","translation":"ভালবাসেন","audioUrl":"wbw/002_195_015.mp3","charTypeName":"word"},{"id":84881,"position":14,"arabic":"ٱلْمُحْسِنِينَ","translation":"অনুগ্রহকারীদেরকে","audioUrl":"wbw/002_195_016.mp3","charTypeName":"word"},{"id":84882,"position":15,"arabic":"١٩٥","translation":"(১৯৫)","audioUrl":null,"charTypeName":"end"}]},{"number":196,"arabic":"وَأَتِمُّوا۟ ٱلْحَجَّ وَٱلْعُمْرَةَ لِلَّهِ ۚ فَإِنْ أُحْصِرْتُمْ فَمَا ٱسْتَيْسَرَ مِنَ ٱلْهَدْىِ ۖ وَلَا تَحْلِقُوا۟ رُءُوسَكُمْ حَتَّىٰ يَبْلُغَ ٱلْهَدْىُ مَحِلَّهُۥ ۚ فَمَن كَانَ مِنكُم مَّرِيضًا أَوْ بِهِۦٓ أَذًۭى مِّن رَّأْسِهِۦ فَفِدْيَةٌۭ مِّن صِيَامٍ أَوْ صَدَقَةٍ أَوْ نُسُكٍۢ ۚ فَإِذَآ أَمِنتُمْ فَمَن تَمَتَّعَ بِٱلْعُمْرَةِ إِلَى ٱلْحَجِّ فَمَا ٱسْتَيْسَرَ مِنَ ٱلْهَدْىِ ۚ فَمَن لَّمْ يَجِدْ فَصِيَامُ ثَلَٰثَةِ أَيَّامٍۢ فِى ٱلْحَجِّ وَسَبْعَةٍ إِذَا رَجَعْتُمْ ۗ تِلْكَ عَشَرَةٌۭ كَامِلَةٌۭ ۗ ذَٰلِكَ لِمَن لَّمْ يَكُنْ أَهْلُهُۥ حَاضِرِى ٱلْمَسْجِدِ ٱلْحَرَامِ ۚ وَٱتَّقُوا۟ ٱللَّهَ وَٱعْلَمُوٓا۟ أَنَّ ٱللَّهَ شَدِيدُ ٱلْعِقَابِ","translation":"AND PERFORM the pilgrimage and the pious visit [to Mecca] in honour of God; and if you are held back, give instead whatever offering you can easily afford. And do not shave your heads until the offering has been sacrificed; but he from among you who is ill or suffers from an ailment of the head shall redeem himself by fasting, or alms, or [any other] act of worship. And if you are hale and secure, then he who takes advantage of a pious visit before the [time of] pilgrimage shall give whatever offering he can easily afford; whereas he who cannot afford it shall fast for three days during the pilgrimage and for seven days after your return: that is, ten full [days]. All this relates to him who does not live near the Inviolable House of Worship. And remain conscious of God, and know that God is severe in retribution.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/203.mp3","surahId":2,"words":[{"id":84989,"position":1,"arabic":"وَأَتِمُّوا۟","translation":"এবং তোমরা পূর্ণ করো","audioUrl":"wbw/002_196_001.mp3","charTypeName":"word"},{"id":84990,"position":2,"arabic":"ٱلْحَجَّ","translation":"হজ্জ","audioUrl":"wbw/002_196_002.mp3","charTypeName":"word"},{"id":84991,"position":3,"arabic":"وَٱلْعُمْرَةَ","translation":"ও ওমরাহ","audioUrl":"wbw/002_196_003.mp3","charTypeName":"word"},{"id":84992,"position":4,"arabic":"لِلَّهِ ۚ","translation":"আল্লাহরই জন্যে","audioUrl":"wbw/002_196_004.mp3","charTypeName":"word"},{"id":84994,"position":5,"arabic":"فَإِنْ","translation":"অতঃপর যদি