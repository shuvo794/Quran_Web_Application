Url":"wbw/007_135_001.mp3","charTypeName":"word"},{"id":78562,"position":2,"arabic":"كَشَفْنَا","translation":"সরিয়ে দিলাম আমরা","audioUrl":"wbw/007_135_002.mp3","charTypeName":"word"},{"id":78563,"position":3,"arabic":"عَنْهُمُ","translation":"থেকে তাদের","audioUrl":"wbw/007_135_003.mp3","charTypeName":"word"},{"id":78564,"position":4,"arabic":"ٱلرِّجْزَ","translation":"শাস্তি","audioUrl":"wbw/007_135_004.mp3","charTypeName":"word"},{"id":78565,"position":5,"arabic":"إِلَىٰٓ","translation":"পর্যন্ত","audioUrl":"wbw/007_135_005.mp3","charTypeName":"word"},{"id":78566,"position":6,"arabic":"أَجَلٍ","translation":"একটি নির্দিষ্ট সময়","audioUrl":"wbw/007_135_006.mp3","charTypeName":"word"},{"id":78567,"position":7,"arabic":"هُم","translation":"তারা","audioUrl":"wbw/007_135_007.mp3","charTypeName":"word"},{"id":78568,"position":8,"arabic":"بَـٰلِغُوهُ","translation":"যাতে পৌঁছানো নির্ধারিত ছিলো","audioUrl":"wbw/007_135_008.mp3","charTypeName":"word"},{"id":78569,"position":9,"arabic":"إِذَا","translation":"তখন","audioUrl":"wbw/007_135_009.mp3","charTypeName":"word"},{"id":78570,"position":10,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/007_135_010.mp3","charTypeName":"word"},{"id":78571,"position":11,"arabic":"يَنكُثُونَ","translation":"অঙ্গীকার ভঙ্গ করে","audioUrl":"wbw/007_135_011.mp3","charTypeName":"word"},{"id":78572,"position":12,"arabic":"١٣٥","translation":"(১৩৫)","audioUrl":null,"charTypeName":"end"}]},{"number":136,"arabic":"فَٱنتَقَمْنَا مِنْهُمْ فَأَغْرَقْنَٰهُمْ فِى ٱلْيَمِّ بِأَنَّهُمْ كَذَّبُوا۟ بِـَٔايَٰتِنَا وَكَانُوا۟ عَنْهَا غَٰفِلِينَ","translation":"And so We inflicted Our retribution on them, and caused them to drown in the sea, because they had given the lie to Our messages and had been heedless of them;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1090.mp3","surahId":7,"words":[{"id":78647,"position":1,"arabic":"فَٱنتَقَمْنَا","translation":"অতঃপর প্রতিশোধ নিলাম আমরা","audioUrl":"wbw/007_136_001.mp3","charTypeName":"