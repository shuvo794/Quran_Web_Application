{"id":329,"ayahs":[{"number":82,"arabic":"وَمِنَ ٱلشَّيَٰطِينِ مَن يَغُوصُونَ لَهُۥ وَيَعْمَلُونَ عَمَلًۭا دُونَ ذَٰلِكَ ۖ وَكُنَّا لَهُمْ حَٰفِظِينَ","translation":"And among the rebel­lious forces [which We made subservient to him] there were some that dived for him [into the sea] and performed other works, besides: but it was We who kept watch over them.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2565.mp3","surahId":21,"words":[{"id":64950,"position":1,"arabic":"وَمِنَ","translation":"এবং মধ্য হ'তে","audioUrl":"wbw/021_082_001.mp3","charTypeName":"word"},{"id":64951,"position":2,"arabic":"ٱلشَّيَـٰطِينِ","translation":"(জ্বিন) শয়তানদের","audioUrl":"wbw/021_082_002.mp3","charTypeName":"word"},{"id":64952,"position":3,"arabic":"مَن","translation":"যারা","audioUrl":"wbw/021_082_003.mp3","charTypeName":"word"},{"id":64953,"position":4,"arabic":"يَغُوصُونَ","translation":"ডুবুরির কাজ করতো","audioUrl":"wbw/021_082_004.mp3","charTypeName":"word"},{"id":64954,"position":5,"arabic":"لَهُۥ","translation":"জন্যে তার","audioUrl":"wbw/021_082_005.mp3","charTypeName":"word"},{"id":64955,"position":6,"arabic":"وَيَعْمَلُونَ","translation":"ও তারা করতো","audioUrl":"wbw/021_082_006.mp3","charTypeName":"word"},{"id":64956,"position":7,"arabic":"عَمَلًۭا","translation":"কাজ","audioUrl":"wbw/021_082_007.mp3","charTypeName":"word"},{"id":64957,"position":8,"arabic":"دُونَ","translation":"ছাড়াও","audioUrl":"wbw/021_082_008.mp3","charTypeName":"word"},{"id":64958,"position":9,"arabic":"ذَٰلِكَ ۖ","translation":"এটা","audioUrl":"wbw/021_082_009.mp3","charTypeName":"word"},{"id":64960,"position":10,"arabic":"وَكُنَّا","translation":"আমরা ছিলাম","audioUrl":"wbw/021_082_011.mp3","charTypeName":"word"},{"id":64961,"position":11,"arabic":"لَهُمْ","translation":"উপর তাদের","audioUrl":"wbw/021_082_012.mp3","charTypeName":"word"},{"id":64962,"position":12,"arabic":"حَـٰفِظِينَ","translation":"সংরক্ষণকারী","audioUrl":"wbw/021_082_013.mp3","charTypeName":"word"},{"id":64963,"position":13,"arabic":"٨٢","translation":"(৮২)","audioUrl":null,"charTypeName":"end"}]},{"number":83,"arabic":"۞ وَأَيُّوبَ إِذْ نَادَىٰ رَبَّهُۥٓ أَنِّى مَسَّنِىَ ٱلضُّرُّ وَأَنتَ أَرْحَمُ ٱلرَّٰحِمِينَ","translation":"AND [remember] Job, when he cried out to his Sus­tainer, “Affliction has befallen me: but Thou art the most merciful of the merciful!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2566.mp3","surahId":21,"words":[{"id":65521,"position":1,"arabic":"۞ وَأَيُّوبَ","translation":"এবং আইয়ূবকে (স্মরণ করো)","audioUrl":"wbw/021_083_002.mp3","charTypeName":"word"},{"id":65522,"position":2,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/021_083_003.mp3","charTypeName":"word"},{"id":65523,"position":3,"arabic":"نَادَىٰ","translation":"সে ডেকেছিলো","audioUrl":"wbw/021_083_004.mp3","charTypeName":"word"},{"id":65524,"position":4,"arabic":"رَبَّهُۥٓ","translation":"তার রবকে","audioUrl":"wbw/021_083_005.mp3","charTypeName":"word"},{"id":65525,"position":5,"arabic":"أَنِّى","translation":"\"নিশ্চয়ই আমি","audioUrl":"wbw/021_083_006.mp3","charTypeName":"word"},{"id":65526,"position":6,"arabic":"مَسَّنِىَ","translation":"ধরেছে আমাকে","audioUrl":"wbw/021_083_007.mp3","charTypeName":"word"},{"id":65527,"position":7,"arabic":"ٱلضُّرُّ","translation":"দুঃখ কষ্টে (অসুখে)","audioUrl":"wbw/021_083_008.mp3","charTypeName":"word"},{"id":65528,"position":8,"arabic":"وَأَنتَ","translation":"আর তুমি","audioUrl":"wbw/021_083_009.mp3","charTypeName":"word"},{"id":65529,"position":9,"arabic":"أَرْحَمُ","translation":"সর্বশ্রেষ্ঠ দয়ালু","audioUrl":"wbw/021_083_010.mp3","charTypeName":"word"},{"id":65530,"position":10,"arabic":"ٱلرَّٰحِمِينَ","translation":"সব দয়ালুদের\"","audioUrl":"wbw/021_083_011.mp3","charTypeName":"word"},{"id":65531,"position":11,"arabic":"٨٣","translation":"(৮৩)","audioUrl":null,"charTypeName":"end"}]},{"number":84,"arabic":"فَٱسْتَجَبْنَا لَهُۥ فَكَشَفْنَا مَا بِهِۦ مِن ضُرٍّۢ ۖ وَءَاتَيْنَٰهُ أَهْلَهُۥ وَمِثْلَهُم مَّعَهُمْ رَحْمَةًۭ مِّنْ عِندِنَا وَذِكْرَىٰ لِلْعَٰبِدِينَ","translation":"whereupon We responded unto him and removed all the affliction from which he suffered; and We gave him new offspring, doubling their number as an act of grace from Us, and as a reminder unto all who worship Us.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2567.mp3","surahId":21,"words":[{"id":65972,"position":1,"arabic":"فَٱسْتَجَبْنَا","translation":"তখন আমরা সাড়া দিলাম","audioUrl":"wbw/021_084_001.mp3","charTypeName":"word"},{"id":65973,"position":2,"arabic":"لَهُۥ","translation":"তার ডাকে","audioUrl":"wbw/021_084_002.mp3","charTypeName":"word"},{"id":65974,"position":3,"arabic":"فَكَشَفْنَا","translation":"অতঃপর আমরা দূর করে দিলাম","audioUrl":"wbw/021_084_003.mp3","charTypeName":"word"},{"id":65975,"position":4,"arabic":"مَا","translation":"যা","audioUrl":"wbw/021_084_004.mp3","charTypeName":"word"},{"id":65976,"position":5,"arabic":"بِهِۦ","translation":"তার সাথে (হয়েছিলো)","audioUrl":"wbw/021_084_005.mp3","charTypeName":"word"},{"id":65977,"position":6,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/021_084_006.mp3","charTypeName":"word"},{"id":65978,"position":7,"arabic":"ضُرٍّۢ ۖ","translation":"দুঃখ কষ্ট","audioUrl":"wbw/021_084_007.mp3","charTypeName":"word"},{"id":65980,"position":8,"arabic":"وَءَاتَيْنَـٰهُ","translation":"ও তাকে আমরা ফেরত দিলাম","audioUrl":"wbw/021_084_009.mp3","charTypeName":"word"},{"id":65981,"position":9,"arabic":"أَهْلَهُۥ","translation":"তার পরিবারকে","audioUrl":"wbw/021_084_010.mp3","charTypeName":"word"},{"id":65982,"position":10,"arabic":"وَمِثْلَهُم","translation":"এবং তাদের অনুরূপ","audioUrl":"wbw/021_084_011.mp3","charTypeName":"word"},{"id":65983,"position":11,"arabic":"مَّعَهُمْ","translation":"তাদের সাথে","audioUrl":"wbw/021_084_012.mp3","charTypeName":"word"},{"id":65984,"position":12,"arabic":"رَحْمَةًۭ","translation":"অনুগ্রহ হিসেবে","audioUrl":"wbw/021_084_013.mp3","charTypeName":"word"},{"id":65985,"position":13,"arabic":"مِّنْ","translation":"হ'তে","audioUrl":"wbw/021_084_014.mp3","charTypeName":"word"},{"id":65986,"position":14,"arabic":"عِندِنَا","translation":"আমাদের পক্ষ","audioUrl":"wbw/021_084_015.mp3","charTypeName":"word"},{"id":65987,"position":15,"arabic":"وَذِكْرَىٰ","translation":"এবং উপদেশস্বরূপ","audioUrl":"wbw/021_084_016.mp3","charTypeName":"word"},{"id":65988,"position":16,"arabic":"لِلْعَـٰبِدِينَ","translation":"ইবাদাতকারীদের জন্যে","audioUrl":"wbw/021_084_017.mp3","charTypeName":"word"},{"id":65989,"position":17,"arabic":"٨٤","translation":"(৮৪)","audioUrl":null,"charTypeName":"end"}]},{"number":85,"arabic":"وَإِسْمَٰعِيلَ وَإِدْرِيسَ وَذَا ٱلْكِفْلِ ۖ كُلٌّۭ مِّنَ ٱلصَّٰبِرِينَ","translation":"AND [remember] Ishmael and Idris and every one who [like them] has pledged himself [unto God]: they all were among those who are patient in adver­sity,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2568.mp3","surahId":21,"words":[{"id":66360,"position":1,"arabic":"وَإِسْمَـٰعِيلَ","translation":"এবং (স্মরণ করো) ইসমাইলকে","audioUrl":"wbw/021_085_001.mp3","charTypeName":"word"},{"id":66361,"position":2,"arabic":"وَإِدْرِيسَ","translation":"ও ইদরীসকে","audioUrl":"wbw/021_085_002.mp3","charTypeName":"word"},{"id":66362,"position":3,"arabic":"وَذَا","translation":"ও","audioUrl":"wbw/021_085_003.mp3","charTypeName":"word"},{"id":66363,"position":4,"arabic":"ٱلْكِفْلِ ۖ","translation":"যুলকিফ্‌লকে","audioUrl":"wbw/021_085_004.mp3","charTypeName":"word"},{"id":66365,"position":5,"arabic":"كُلٌّۭ","translation":"প্রত্যেকে (ছিলো)","audioUrl":"wbw/021_085_006.mp3","charTypeName":"word"},{"id":66366,"position":6,"arabic":"مِّنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/021_085_007.mp3","charTypeName":"word"},{"id":66367,"position":7,"arabic":"ٱلصَّـٰبِرِينَ","translation":"ধৈর্যশীলদের","audioUrl":"wbw/021_085_008.mp3","charTypeName":"word"},{"id":66368,"position":8,"arabic":"٨٥","translation":"(৮৫)","audioUrl":null,"charTypeName":"end"}]},{"number":86,"arabic":"وَأَدْخَلْنَٰهُمْ فِى رَحْمَتِنَآ ۖ إِنَّهُم مِّنَ ٱلصَّٰلِحِينَ","translation":"and so We admitted them unto Our grace: behold, they were among the righteous!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2569.mp3","surahId":21,"words":[{"id":66458,"position":1,"arabic":"وَأَدْخَلْنَـٰهُمْ","translation":"এবং তাদেরকে আমরা প্রবেশ করিয়েছি","audioUrl":"wbw/021_086_001.mp3","charTypeName":"word"},{"id":66459,"position":2,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/021_086_002.mp3","charTypeName":"word"},{"id":66460,"position":3,"arabic":"رَحْمَتِنَآ ۖ","translation":"আমাদের অনুগ্রহের","audioUrl":"wbw/021_086_003.mp3","charTypeName":"word"},{"id":66462,"position":4,"arabic":"إِنَّهُم","translation":"নিশ্চয়ই তারা (ছিলো)","audioUrl":"wbw/021_086_005.mp3","charTypeName":"word"},{"id":66463,"position":5,"arabic":"مِّنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/021_086_006.mp3","charTypeName":"word"},{"id":66464,"position":6,"arabic":"ٱلصَّـٰلِحِينَ","translation":"সৎকর্মশীলদের","audioUrl":"wbw/021_086_007.mp3","charTypeName":"word"},{"id":66465,"position":7,"arabic":"٨٦","translation":"(৮৬)","audioUrl":null,"charTypeName":"end"}]},{"number":87,"arabic":"وَذَا ٱلنُّونِ إِذ ذَّهَبَ مُغَٰضِبًۭا فَظَنَّ أَن لَّن نَّقْدِرَ عَلَيْهِ فَنَادَىٰ فِى ٱلظُّلُمَٰتِ أَن لَّآ إِلَٰهَ إِلَّآ أَنتَ سُبْحَٰنَكَ إِنِّى كُنتُ مِنَ ٱلظَّٰلِمِينَ","translation":"AND [remember] him of the great fish when he went off in wrath, thinking that We had no power over him! But then heeded out in the deep darkness [of his distress]: “There is no deity save Thee! Limit­less art Thou in Thy glory! Verily, I have done wrong!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2570.mp3","surahId":21,"words":[{"id":66783,"position":1,"arabic":"وَذَا","translation":"আর অধিকারী","audioUrl":"wbw/021_087_001.mp3","charTypeName":"word"},{"id":66784,"position":2,"arabic":"ٱلنُّونِ","translation":"মাছের (স্মরণ করো)","audioUrl":"wbw/021_087_002.mp3","charTypeName":"word"},{"id"