":66801,"position":19,"arabic":"سُبْحَـٰنَكَ","translation":"তুমি পবিত্র মহান","audioUrl":"wbw/021_087_019.mp3","charTypeName":"word"},{"id":66802,"position":20,"arabic":"إِنِّى","translation":"নিশ্চয়ই আমি","audioUrl":"wbw/021_087_020.mp3","charTypeName":"word"},{"id":66803,"position":21,"arabic":"كُنتُ","translation":"ছিলাম","audioUrl":"wbw/021_087_021.mp3","charTypeName":"word"},{"id":66804,"position":22,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/021_087_022.mp3","charTypeName":"word"},{"id":66805,"position":23,"arabic":"ٱلظَّـٰلِمِينَ","translation":"সীমালঙ্ঘনকারীদের\"","audioUrl":"wbw/021_087_023.mp3","charTypeName":"word"},{"id":66806,"position":24,"arabic":"٨٧","translation":"(৮৭)","audioUrl":null,"charTypeName":"end"}]},{"number":88,"arabic":"فَٱسْتَجَبْنَا لَهُۥ وَنَجَّيْنَٰهُ مِنَ ٱلْغَمِّ ۚ وَكَذَٰلِكَ نُۨجِى ٱلْمُؤْمِنِينَ","translation":"And so We responded unto him and delivered him from [his] distress: for thus do We deliver all who have faith.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2571.mp3","surahId":21,"words":[{"id":67474,"position":1,"arabic":"فَٱسْتَجَبْنَا","translation":"তখন আমরা সাড়া দিলাম","audioUrl":"wbw/021_088_001.mp3","charTypeName":"word"},{"id":67475,"position":2,"arabic":"لَهُۥ","translation":"তার ডাকে","audioUrl":"wbw/021_088_002.mp3","charTypeName":"word"},{"id":67476,"position":3,"arabic":"وَنَجَّيْنَـٰهُ","translation":"এবং তাকে আমরা উদ্ধার করেছিলাম","audioUrl":"wbw/021_088_003.mp3","charTypeName":"word"},{"id":67477,"position":4,"arabic":"مِنَ","translation":"হ'তে","audioUrl":"wbw/021_088_004.mp3","charTypeName":"word"},{"id":67478,"position":5,"arabic":"ٱلْغَمِّ ۚ","translation":"দুশ্চিন্তা","audioUrl":"wbw/021_088_005.mp3","charTypeName":"word"},{"id":67480,"position":6,"arabic":"وَكَذَٰلِكَ","translation":"এরূপেই","audioUrl":"wbw/021_088_007.mp3","charTypeName":"word"},{"id":67481,"position":7,"arabic":"نُـۨجِى","translation":"উদ্ধার করি আমরা","audioUrl":"wbw/021_088_008.mp3","charTypeName":"word"},{"id":67482,"position":8,"arabic":"ٱلْمُؤْمِنِينَ","translation":"মু'মিনদেরকে","audioUrl":"wbw/021_088_009.mp3","charTypeName":"word"},{"id":67483,"position":9,"arabic":"٨٨","translation":"(৮৮)","audioUrl":null,"charTypeName":"end"}]},{"number":89,"arabic":"وَزَكَرِيَّآ إِذْ نَادَىٰ رَبَّهُۥ رَبِّ لَا تَذَرْنِى فَرْدًۭا وَأَنتَ خَيْرُ ٱلْوَٰرِثِينَ","translation":"AND [thus did We deliver] Zachariah when he cried out unto his Sustainer: “O my Sustainer! Leave me not childless! But [even if Thou grant me no bodily heir, I know that] Thou wilt remain when all else has ceased to be!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2572.mp3","surahId":21,"words":[{"id":67823,"position":1,"arabic":"وَزَكَرِيَّآ","translation":"এবং যাকারিয়াকে (স্মরণ করো)","audioUrl":"wbw/021_089_001.mp3","charTypeName":"word"},{"id":67824,"position":2,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/021_089_002.mp3","charTypeName":"word"},{"id":67825,"position":3,"arabic":"نَادَىٰ","translation":"সে ডেকেছিলো","audioUrl":"wbw/021_089_003.mp3","charTypeName":"word"},{"id":67826,"position":4,"arabic":"رَبَّهُۥ","translation":"তার রবকে","audioUrl":"wbw/021_089_004.mp3","charTypeName":"word"},{"id":67827,"position":5,"arabic":"رَبِّ","translation":"\"হে আমার রব","audioUrl":"wbw/021_089_005.mp3","charTypeName":"word"},{"id":67828,"position":6,"arabic":"لَا","translation":"না","audioUrl":"wbw/021_089_006.mp3","charTypeName":"word"},{"id":67829,"position":7,"arabic":"تَذَرْنِى","translation":"আমাকে ছেড়ো","audioUrl":"wbw/021_089_007.mp3","charTypeName":"word"},{"id":67830,"position":8,"arabic":"فَرْدًۭا","translation":"একাকী","audioUrl":"wbw/021_089_008.mp3","charTypeName":"word"},{"id":67831,"position":9,"arabic":"وَأَنتَ","translation":"এবং তুমি","audioUrl":"wbw/021_089_009.mp3","charTypeName":"word"},{"id":67832,"position":10,"arabic":"خَيْرُ","translation":"উত্তম","audioUrl":"wbw/021_089_010.mp3","charTypeName":"word"},{"id":67833,"position":11,"arabic":"ٱلْوَٰرِثِينَ","translation":"উত্তরাধিকারীদের\"","audioUrl":"wbw/021_089_011.mp3","charTypeName":"word"},{"id":67834,"position":12,"arabic":"٨٩","translation":"(৮৯)","audioUrl":null,"charTypeName":"end"}]},{"number":90,"arabic":"فَٱسْتَجَبْنَا لَهُۥ وَوَهَبْنَا لَهُۥ يَحْيَىٰ وَأَصْلَحْنَا لَهُۥ زَوْجَهُۥٓ ۚ إِنَّهُمْ كَانُوا۟ يُسَٰرِعُونَ فِى ٱلْخَيْرَٰتِ وَيَدْعُونَنَا رَغَبًۭا وَرَهَبًۭا ۖ وَكَانُوا۟ لَنَا خَٰشِعِينَ","translation":"And so We responded unto him, and bestowed upon him the gift of John, having made his wife fit to bear him a child: [and,] verily, these [three] would vie with one another in doing good works, and would call unto Us in yearning and awe; and they were always humble before Us.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2573.mp3","surahId":21,"words":[{"id":67860,"position":1,"arabic":"فَٱسْتَجَبْنَا","translation":"তখন আমরা সাড়া দিয়েছিলাম","audioUrl":"wbw/021_090_001.mp3","charTypeName":"word"},{"id":67861,"position":2,"arabic":"لَهُۥ","translation":"তার ডাকে","audioUrl":"wbw/021_090_002.mp3","charTypeName":"word"},{"id":67862,"position":3,"arabic":"وَوَهَبْنَا","translation":"ও আমরা দিয়েছিলাম","audioUrl":"wbw/021_090_003.mp3","charTypeName":"word"},{"id":67863,"position":4,"arabic":"لَهُۥ","translation":"তার জন্যে","audioUrl":"wbw/021_090_004.mp3","charTypeName":"word"},{"id":67864,"position":5,"arabic":"يَحْيَىٰ","translation":"ইয়াহইয়াকে","audioUrl":"wbw/021_090_005.mp3","charTypeName":"word"},{"id":67865,"position":6,"arabic":"وَأَصْلَحْنَا","translation":"আমরা উপযোগী করে দিয়েছিলাম","audioUrl":"wbw/021_090_006.mp3","charTypeName":"word"},{"id":67866,"position":7,"arabic":"لَهُۥ","translation":"জন্যে তা","audioUrl":"wbw/021_090_007.mp3","charTypeName":"word"},{"id":67867,"position":8,"arabic":"زَوْجَهُۥٓ ۚ","translation":"তার স্ত্রীকে","audioUrl":"wbw/021_090_008.mp3","charTypeName":"word"},{"id":67869,"position":9,"arabic":"إِنَّهُمْ","translation":"নিশ্চয়ই তারা","audioUrl":"wbw/021_090_010.mp3","charTy