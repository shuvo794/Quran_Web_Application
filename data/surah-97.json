{"id":97,"nameArabic":"سُورَةُ القَدۡرِ","nameEnglish":"Al-Qadr","nameTranslation":"The Power, Fate","revelationType":"Meccan","numberOfAyahs":5,"ayahs":[{"number":1,"arabic":"بِّسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ إِنَّآ أَنزَلْنَٰهُ فِى لَيْلَةِ ٱلْقَدْرِ","translation":"BEHOLD, from on high have We bestowed this [divine writ] on Night of Destiny.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6126.mp3","surahId":97,"words":[{"id":169,"position":1,"arabic":"إِنَّآ","translation":"নিশ্চয়ই","audioUrl":"wbw/097_001_001.mp3","charTypeName":"word"},{"id":170,"position":2,"arabic":"أَنزَلْنَـٰهُ","translation":"তা আমরা অবতীর্ণ করেছি","audioUrl":"wbw/097_001_002.mp3","charTypeName":"word"},{"id":171,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/097_001_003.mp3","charTypeName":"word"},{"id":172,"position":4,"arabic":"لَيْلَةِ","translation":"রাতের","audioUrl":"wbw/097_001_004.mp3","charTypeName":"word"},{"id":173,"position":5,"arabic":"ٱلْقَدْرِ","translation":"কদরের/ মহিমার","audioUrl":"wbw/097_001_005.mp3","charTypeName":"word"},{"id":174,"position":6,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"وَمَآ أَدْرَىٰكَ مَا لَيْلَةُ ٱلْقَدْرِ","translation":"And what could make thee conceive what it is, that Night of Destiny?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6127.mp3","surahId":97,"words":[{"id":1789,"position":1,"arabic":"وَمَآ","translation":"এবং কিসে","audioUrl":"wbw/097_002_001.mp3","charTypeName":"word"},{"id":1790,"position":2,"arabic":"أَدْرَىٰكَ","translation":"তোমাকে জানাবে","audioUrl":"wbw/097_002_002.mp3","charTypeName":"word"},{"id":1791,"position":3,"arabic":"مَا","translation":"কি সেই","audioUrl":"wbw/097_002_003.mp3","charTypeName":"word"},{"id":1792,"position":4,"arabic":"لَيْلَةُ","translation":"রাত","audioUrl":"wbw/097_002_004.mp3","charTypeName":"word"},{"id":1793,"position":5,"arabic":"ٱلْقَدْرِ","translation":"কদরের","audioUrl":"wbw/0