{"id":52,"ayahs":[{"number":16,"arabic":"ٱلَّذِينَ يَقُولُونَ رَبَّنَآ إِنَّنَآ ءَامَنَّا فَٱغْفِرْ لَنَا ذُنُوبَنَا وَقِنَا عَذَابَ ٱلنَّارِ","translation":"those who say, \"O our Sustainer! Behold, we believe [in Thee]; forgive us, then, our sins, and keep us safe from suffering through the fire\" -:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/309.mp3","surahId":3,"words":[{"id":18449,"position":1,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/003_016_001.mp3","charTypeName":"word"},{"id":18450,"position":2,"arabic":"يَقُولُونَ","translation":"বলে","audioUrl":"wbw/003_016_002.mp3","charTypeName":"word"},{"id":18451,"position":3,"arabic":"رَبَّنَآ","translation":"''হে আমাদের রব","audioUrl":"wbw/003_016_003.mp3","charTypeName":"word"},{"id":18452,"position":4,"arabic":"إِنَّنَآ","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/003_016_004.mp3","charTypeName":"word"},{"id":18453,"position":5,"arabic":"ءَامَنَّا","translation":"আমরা ঈমান এনেছি","audioUrl":"wbw/003_016_005.mp3","charTypeName":"word"},{"id":18454,"position":6,"arabic":"فَٱغْفِرْ","translation":"অতএব ক্ষমা কর","audioUrl":"wbw/003_016_006.mp3","charTypeName":"word"},{"id":18455,"position":7,"arabic":"لَنَا","translation":"আমাদের","audioUrl":"wbw/003_016_007.mp3","charTypeName":"word"},{"id":18456,"position":8,"arabic":"ذُنُوبَنَا","translation":"আমাদের গুনাহগুলোকে","audioUrl":"wbw/003_016_008.mp3","charTypeName":"word"},{"id":18457,"position":9,"arabic":"وَقِنَا","translation":"এবং বাঁচাও আমাদের","audioUrl":"wbw/003_016_009.mp3","charTypeName":"word"},{"id":18458,"position":10,"arabic":"عَذَابَ","translation":"শাস্তি (হতে)","audioUrl":"wbw/003_016_010.mp3","charTypeName":"word"},{"id":18459,"position":11,"arabic":"ٱلنَّارِ","translation":"জাহান্নামের''","audioUrl":"wbw/003_016_011.mp3","charTypeName":"word"},{"id":18460,"position":12,"arabic":"١٦","translation":"(১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":17,"arabic":"ٱلصَّٰبِرِينَ وَٱلصَّٰدِقِينَ وَٱلْقَٰنِتِينَ وَٱلْمُنفِقِينَ وَٱلْمُسْتَغْفِرِينَ بِٱلْأَسْحَارِ","translation":"those who are patient in adversity, and true to their word, and truly devout, and who spend [in God's way], and pray for forgiveness from their innermost hearts.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/310.mp3","surahId":3,"words":[{"id":19434,"position":1,"arabic":"ٱلصَّـٰبِرِينَ","translation":"(তারা হবে) ধৈর্য্যশীল","audioUrl":"wbw/003_017_001.mp3","charTypeName":"word"},{"id":19435,"position":2,"arabic":"وَٱلصَّـٰدِقِينَ","translation":"ও সত্যবাদী-সত্যপন্থী","audioUrl":"wbw/003_017_002.mp3","charTypeName":"word"},{"id":19436,"position":3,"arabic":"وَٱلْقَـٰنِتِينَ","translation":"ও বিনীত-অনুগত","audioUrl":"wbw/003_017_003.mp3","charTypeName":"word"},{"id":19437,"position":4,"arabic":"وَٱلْمُنفِقِينَ","translation":"ও দাতা","audioUrl":"wbw/003_017_004.mp3","charTypeName":"word"},{"id":19438,"position":5,"arabic":"وَٱلْمُسْتَغْفِرِينَ","translation":"এবং ক্ষমাপ্রার্থী","audioUrl":"wbw/003_017_005.mp3","charTypeName":"word"},{"id":19439,"position":6,"arabic":"بِٱلْأَسْحَارِ","translation":"রাতের শেষপ্রান্তে","audioUrl":"wbw/003_017_006.mp3","charTypeName":"word"},{"id":19440,"position":7,"arabic":"١٧","translation":"(১৭)","audioUrl":null,"charTypeName":"end"}]},{"number":18,"arabic":"شَهِدَ ٱللَّهُ أَنَّهُۥ لَآ إِلَٰهَ إِلَّا هُوَ وَٱلْمَلَٰٓئِكَةُ وَأُو۟لُوا۟ ٱلْعِلْمِ قَآئِمًۢا بِٱلْقِسْطِ ۚ لَآ إِلَٰهَ إِلَّا هُوَ ٱلْعَزِيزُ ٱلْحَكِيمُ","translation":"GOD [Himself] proffers evidence - and [so do] the angels and all who are endowed with knowledge - that there is no deity save Him, the Upholder of Equity: there is no deity save Him, the Almighty, the Truly Wise.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/311.mp3","surahId":3,"words":[{"id":20519,"position":1,"arabic":"شَهِدَ","translation":"সাক্ষী দিচ্ছেন","audioUrl":"wbw/003_018_001.mp3","charTypeName":"word"},{"id":20520,"position":2,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/003_018_002.mp3","charTypeName":"word"},{"id":20521,"position":3,"arabic":"أَنَّهُۥ","translation":"তিনি নিশ্চয় (এমন যে)","audioUrl":"wbw/003_018_003.mp3","charTypeName":"word"},{"id":20522,"position":4,"arabic":"لَآ","translation":"নাই","audioUrl":"wbw/003_018_004.mp3","charTypeName":"word"},{"id":20523,"position":5,"arabic":"إِلَـٰهَ","translation":"কোন ইলাহ","audioUrl":"wbw/003_018_005.mp3","charTypeName":"word"},{"id":20524,"position":6,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/003_018_006.mp3","charTypeName":"word"},{"id":20525,"position":7,"arabic":"هُوَ","translation":"তিনি","audioUrl":"wbw/003_018_007.mp3","charTypeName":"word"},{"id":20526,"position":8,"arabic":"وَٱلْمَلَـٰٓئِكَةُ","translation":"এবং ফেরেশতারা (সাক্ষ্য দিচ্ছে)","audioUrl":"wbw/003_018_008.mp3","charTypeName":"word"},{"id":20527,"position":9,"arabic":"وَأُو۟لُوا۟","translation":"এবং","audioUrl":"wbw/003_018_009.mp3","charTypeName":"word"},{"id":20528,"position":10,"arabic":"ٱلْعِلْمِ","translation":"জ্ঞানীগণও","audioUrl":"wbw/003_018_010.mp3","charTypeName":"word"},{"id":20529,"position":11,"arabic":"قَآئِمًۢا","translation":"(যারা) প্রতিষ্ঠিত","audioUrl":"wbw/003_018_011.mp3","charTypeName":"word"},{"id":20530,"position":12,"arabic":"بِٱلْقِسْطِ ۚ","translation":"ন্যায়নীতিতে","audioUrl":"wbw/003_018_012.mp3","charTypeName":"word"},{"id":20532,"position":13,"arabic":"لَآ","translation":"নাই","audioUrl":"wbw/003_018_014.mp3","charTypeName":"word"},{"id":20533,"position":14,"arabic":"إِلَـٰهَ","translation":"কোন ইলাহ","audioUrl":"wbw/003_018_015.mp3","charTypeName":"word"},{"id":20534,"position":15,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/003_018_016.mp3","charTypeName":"word"},{"id":20535,"position":16,"arabic":"هُوَ","translation":"তিনি","audioUrl":"wbw/003_018_017.mp3","charTypeName":"word"},{"id":20536,"position":17,"arabic":"ٱلْعَزِيزُ","translation":"পরাক্রমশালী","audioUrl":"wbw/003_018_018.mp3","charTypeName":"word"},{"id":20537,"position":18,"arabic":"ٱلْحَكِيمُ","translation":"মহাবিজ্ঞ","audioUrl":"wbw/003_018_019.mp3","charTypeName":"word"},{"id":20538,"position":19,"arabic":"١٨","translation":"(১৮)","audioUrl":null,"charTypeName":"end"}]},{"number":19,"arabic":"إِنَّ ٱلدِّينَ عِندَ ٱللَّهِ ٱلْإِسْلَٰمُ ۗ وَمَا ٱخْتَلَفَ ٱلَّذِينَ أُوتُوا۟ ٱلْكِتَٰبَ إِلَّا مِنۢ بَعْدِ مَا جَآءَهُمُ ٱلْعِلْمُ بَغْيًۢا بَيْنَهُمْ ۗ وَمَن يَكْفُرْ بِـَٔايَٰتِ ٱللَّهِ فَإِنَّ ٱللَّهَ سَرِيعُ ٱلْحِسَابِ","translation":"Behold, the only [true] religion in the sight of God is [man's] self-surrender unto Him; and those who were vouchsafed revelation aforetime took, out of mutual jealousy, to divergent views [on this point] only after knowledge [thereof] had come unto them. But as for him who denies the truth of God's messages - behold, God is swift in reckoning!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/312.mp3","surahId":3,"words":[{"id":21588,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়","audioUrl":"wbw/003_019_001.mp3","charTypeName":"word"},{"id":21589,"position":2,"arabic":"ٱلدِّينَ","translation":"জীবন ব্যবস্থা","audioUrl":"wbw/003_019_002.mp3","charTypeName":"word"},{"id":21590,"position":3,"arabic":"عِندَ","translation":"কাছে","audioUrl":"wbw/003_019_003.mp3","charTypeName":"word"},{"id":21591,"position":4,"arabic":"ٱللَّهِ","translation":"আল্লাহর (গ্রহণযোগ্য)","audioUrl":"wbw/003_019_004.mp3","charTypeName":"word"},{"id":21592,"position":5,"arabic":"ٱلْإِسْلَـٰمُ ۗ","translation":"(একমাত্র) ইসলাম","audioUrl":"wbw/003_019_005.mp3","charTypeName":"word"},{"id":21594,"position":6,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/003_019_007.mp3","charTypeName":"word"},{"id":21595,"position":7,"arabic":"ٱخْتَلَفَ","translation":"মতানৈক্য করেছে","audioUrl":"wbw/003_019_008.mp3","charTypeName":"word"},{"id":21596,"position":8,"arabic":"ٱلَّذِينَ","translation":"যাদের","audioUrl":"wbw/003_019_009.mp3","charTypeName":"word"},{"id":21597,"position":9,"arabic":"أُوتُوا۟","translation":"দেওয়া হয়েছিল","audioUrl":"wbw/003_019_010.mp3","charTypeName":"word"},{"id":21598,"position":10,"arabic":"ٱلْكِتَـٰبَ","translation":"কিতাব","audioUrl":"wbw/003_019_011.mp3","charTypeName":"word"},{"id":21599,"position":11,"arabic":"إِلَّا","translation":"এছাড়া","audioUrl":"wbw/003_019_012.mp3","charTypeName":"word"},{"id":21600,"position":12,"arabic":"مِنۢ","translation":"(থেকে)","audioUrl":"wbw/003_019_013.mp3","charTypeName":"word"},{"id":21601,"position":13,"arabic":"بَعْدِ","translation":"পরে","audioUrl":"wbw/003_019_014.mp3","charTypeName":"word"},{"id":21602,"position":14,"arabic":"مَا","translation":"যা","audioUrl":"wbw/003_019_015.mp3","charTypeName":"word"},{"id":21603,"position":15,"arabic":"جَآءَهُمُ","translation":"তাদের কাছে এসেছে","audioUrl":"wbw/003_019_016.mp3","charTypeName":"word"},{"id":21604,"position":16,"arabic":"ٱلْعِلْمُ","translation":"জ্ঞান","audioUrl":"wbw/003_019_017.mp3","charTypeName":"word"},{"id":21605,"position":17,"arabic":"بَغْيًۢا","translation":"বিদ্বেষের কারণে","audioUrl":"wbw/003_019_018.mp3","charTypeName":"word"},{"id":21606,"position":18,"arabic":"بَيْنَهُمْ ۗ","translation":"তাদের মাঝে","audioUrl":"wbw/003_019_019.mp3","charTypeName":"word"},{"id":21608,"position":19,"arabic":"وَمَن","translation":"এবং যে কেউ","audioUrl":"wbw/003_019_021.mp3","charTypeName":"word"},{"id":21609,"position":20,"arabic":"يَكْفُرْ","translation":"অস্বীকার করবে","audioUrl":"wbw/003_019_022.mp3","charTypeName":"word"},{"id":21610,"position":21,"arabic":"بِـَٔايَـٰتِ","translation":"নিদর্শনগুলোকে","audioUrl":"wbw/003_019_023.mp3","charTypeName":"word"},{"id":21611,"position":22,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/003_019_024.mp3","charTypeName":"word"},{"id":21612,"position":23,"arabic":"فَإِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/003_019_025.mp3","charTypeName":"word"},{"id":21613,"position":24,"arabic":"ٱللَّهَ","translation":"আল্লাহ (তাদের হতে)","audioUrl":"wbw/003_019_026.mp3","charTypeName":"word"},{"id":21614,"position":25,"arabic":"سَرِيعُ","translation":"তৎপর","audioUrl":"wbw/003_019_027.mp3","charTypeName":"word"},{"id":21615,"position":26,"arabic":"ٱلْحِسَابِ","translation":"হিসাব (নিতে)","audioUrl":"wbw/003_019_028.mp3","charTypeName":"word"},{"id":21616,"position":27,"arabic":"١٩","translation":"(১৯)","audioUrl":null,"charTypeName":"end"}]},{"number":20,"arabic":"فَإِنْ حَآجُّوكَ فَقُلْ أَسْلَمْتُ وَجْهِىَ لِلَّهِ وَمَنِ ٱتَّبَعَنِ ۗ وَقُل لِّلَّذِينَ أُوتُوا۟ ٱلْكِتَٰبَ وَٱلْأُمِّيِّۦنَ ءَأَسْلَمْتُمْ ۚ فَإِنْ أَسْلَمُوا۟ فَقَدِ ٱهْتَدَوا۟ ۖ وَّإِن تَوَلَّوْا۟ فَإِنَّمَا عَلَيْكَ ٱلْبَلَٰغُ ۗ وَٱللَّهُ بَصِيرٌۢ بِٱلْعِبَادِ","translation":"Thus, [O Prophet,] if they argue with thee, say, \"I have surrendered my whole being unto God, and [so have] all who follow me!\" - and ask those who have been vouchsafed revelation aforetime, as well as all unlettered people, \"Have you [too] surrendered yourselves unto Him?\" And if they surrender themselves unto Him, they are on the right path; but if they turn away - behold, thy duty is no more than to deliver the message: for God sees all that is in [the hearts of] His creatures.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/313.mp3","surahId":3,"words":[{"id":22702,"position":1,"arabic":"فَإِنْ","translation":"যদি এখন","audioUrl":"wbw/003_020_001.mp3","charTypeName":"word"},{"id":22703,"position":2,"arabic":"حَآجُّوكَ","translation":"তোমাদের সাথে বিতর্ক করে","audioUrl":"wbw/003_020_002.mp3","charTypeName":"word"},{"id":22704,"position":3,"arabic":"فَقُلْ","translation":"বল তবে","audioUrl":"wbw/003_020_003.mp3","charTypeName":"word"},{"id":22705,"position":4,"arabic":"أَسْلَمْتُ","translation":"''আমি সমর্পণ করেছি","audioUrl":"wbw/003_020_004.mp3","charTypeName":"word"},{"id":22706,"position":5,"arabic":"وَجْهِىَ","translation":"আমার মুখ","audioUrl":"wbw/003_020_005.mp3","charTypeName":"word"},{"id":22707,"position":6,"arabic":"لِلَّهِ","translation":"আল্লাহর কাছে","audioUrl":"wbw/003_020_006.mp3","charTypeName":"word"},{"id":22708,"position":7,"arabic":"وَمَنِ","translation":"ও যারা","audioUrl":"wbw/003_020_007.mp3","charTypeName":"word"},{"id":22709,"position":8,"arabic":"ٱتَّبَعَنِ ۗ","translation":"আমার অনুসরণ করেছে (তারাও)''","audioUrl":"wbw/003_020_008.mp3","charTypeName":"word"},{"id":22711,"position":9,"arabic":"وَقُل","translation":"এবং তুমি বল","audioUrl":"wbw/003_020_010.mp3","charTypeName":"word"},{"id":22712,"position":10,"arabic":"لِّلَّذِينَ","translation":"তাদেরকে (যাদের)","audioUrl":"wbw/003_020_011.mp3","charTypeName":"word"},{"id":22713,"position":11,"arabic":"أُوتُوا۟","translation":"দেয়া হয়েছিল","audioUrl":"wbw/003_020_012.mp3","charTypeName":"word"},{"id":22714,"position":12,"arabic":"ٱلْكِتَـٰبَ","translation":"কিতাব","audioUrl":"wbw/003_020_013.mp3","charTypeName":"word"},{"id":22715,"position":13,"arabic":"وَٱلْأُمِّيِّـۧنَ","translation":"এবং নিরক্ষরদেরকেও","audioUrl":"wbw/003_020_014.mp3","charTypeName":"word"},{"id":22716,"position":14,"arabic":"ءَأَسْلَمْتُمْ ۚ","translation":"''কি তোমরা আত্মসমর্পণ করেছ''","audioUrl":"wbw/003_020_015.mp3","charTypeName":"word"},{"id":22718,"position":15,"arabic":"فَإِنْ","translation":"অতএব যদি","audioUrl":"wbw/003_020_017.mp3","charTypeName":"word"},{"id":22719,"position":16,"arabic":"أَسْلَمُوا۟","translation":"তারা আত্মসমর্পণ করে থাকে","audioUrl":"wbw/003_020_018.mp3","charTypeName":"word"},{"id":22720,"position":17,"arabic":"فَقَدِ","translation":"নিশ্চয়ই তবে","audioUrl":"wbw/003_020_019.mp3","charTypeName":"word"},{"id":22721,"position":18,"arabic":"ٱهْتَدَوا۟ ۖ","translation":"তারা সঠিক পথ পেয়েছে","audioUrl":"wbw/003_020_020.mp3","charTypeName":"word"},{"id":22723,"position":19,"arabic":"وَّإِن","translation":"আর যদি","audioUrl":"wbw/003_020_022.mp3","charTypeName":"word"},{"id":22724,"position":20,"arabic":"تَوَلَّوْا۟","translation":"তারা মুখ ফিরায়","audioUrl":"wbw/003_020_023.mp3","charTypeName":"word"},{"id":22725,"position":21,"arabic":"فَإِنَّمَا","translation":"তবে মূলত","audioUrl":"wbw/003_020_024.mp3","charTypeName":"word"},{"id":22726,"position":22,"arabic":"عَلَيْكَ","translation":"তোমার (দায়িত্ব)","audioUrl":"wbw/003_020_025.mp3","charTypeName":"word"},{"id":22727,"position":23,"arabic":"ٱلْبَلَـٰغُ ۗ","translation":"(দাওয়াত) পৌঁছান","audioUrl":"wbw/003_020_026.mp3","charTypeName":"word"},{"id":22729,"position":24,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/003_020_028.mp3","charTypeName":"word"},{"id":22730,"position":25,"arabic":"بَصِيرٌۢ","translation":"খুব দৃষ্টি রাখছেন","audioUrl":"wbw/003_020_029.mp3","charTypeName":"word"},{"id":22731,"position":26,"arabic":"بِٱلْعِبَادِ","translation":"বান্দাদের উপর","audioUrl":"wbw/003_020_030.mp3","charTypeName":"word"},{"id":22732,"position":27,"arabic":"٢٠","translation":"(২০)","audioUrl":null,"charTypeName":"end"}]},{"number":21,"arabic":"إِنَّ ٱلَّذِينَ يَكْفُرُونَ بِـَٔايَٰتِ ٱللَّهِ وَيَقْتُلُونَ ٱلنَّبِيِّۦنَ بِغَيْرِ حَقٍّۢ وَيَقْتُلُونَ ٱلَّذِينَ يَأْمُرُونَ بِٱلْقِسْطِ مِنَ ٱلنَّاسِ فَبَشِّرْهُم بِعَذَابٍ أَلِيمٍ","translation":"Verily, as for those who deny the truth of God's messages, and slay the prophets against all right, and slay people who enjoin equity - announce unto them a grievous chastisement.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/314.mp3","surahId":3,"words":[{"id":23839,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/003_021_001.mp3","charTypeName":"word"},{"id":23840,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/003_021_002.mp3","charTypeName":"word"},{"id":23841,"position":3,"arabic":"يَكْفُرُونَ","translation":"অস্বীকার করে","audioUrl":"wbw/003_021_003.mp3","charTypeName":"word"},{"id":23842,"position":4,"arabic":"بِـَٔايَـٰتِ","translation":"নিদর্শনাবলীকে","audioUrl":"wbw/003_021_004.mp3","charTypeName":"word"},{"id":23843,"position":5,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/003_021_005.mp3","charTypeName":"word"},{"id":23844,"position":6,"arabic":"وَيَقْتُلُونَ","translation":"ও হত্যা করে","audioUrl":"wbw/003_021_006.mp3","charTypeName":"word"},{"id":23845,"position":7,"arabic":"ٱلنَّبِيِّـۧنَ","translation":"নবীদেরকে","audioUrl":"wbw/003_021_007.mp3","charTypeName":"word"},{"id":23846,"position":8,"arabic":"بِغَيْرِ","translation":"ব্যাতিত","audioUrl":"wbw/003_021_008.mp3","charTypeName":"word"},{"id":23847,"position":9,"arabic":"حَقٍّۢ","translation":"ন্যায়ভাবে","audioUrl":"wbw/003_021_009.mp3","charTypeName":"word"},{"id":23848,"position":10,"arabic":"وَيَقْتُلُونَ","translation":"এবং হত্যা করে","audioUrl":"wbw/003_021_010.mp3","charTypeName":"word"},{"id":23849,"position":11,"arabic":"ٱلَّذِينَ","translation":"(তাদেরকেও) যারা","audioUrl":"wbw/003_021_011.mp3","charTypeName":"word"},{"id":23850,"position":12,"arabic":"يَأْمُرُونَ","translation":"নির্দেশ দেয়","audioUrl":"wbw/003_021_012.mp3","charTypeName":"word"},{"id":23851,"position":13,"arabic":"بِٱلْقِسْطِ","translation":"ন্যায়পরায়ণতার","audioUrl":"wbw/003_021_013.mp3","charTypeName":"word"},{"id":23852,"position":14,"arabic":"مِنَ","translation":"মধ্যে হতে","audioUrl":"wbw/003_021_014.mp3","charTypeName":"word"},{"id":23853,"position":15,"arabic":"ٱلنَّاسِ","translation":"লোকদের","audioUrl":"wbw/003_021_015.mp3","charTypeName":"word"},{"id":23854,"position":16,"arabic":"فَبَشِّرْهُم","translation":"তাই সুসংবাদ দাও তাদেরকে","audioUrl":"wbw/003_021_016.mp3","charTypeName":"word"},{"id":23855,"position":17,"arabic":"بِعَذَابٍ","translation":"আজাবের","audioUrl":"wbw/003_021_017.mp3","charTypeName":"word"},{"id":23856,"position":18,"arabic":"أَلِيمٍ","translation":"বড় যন্ত্রণাদায়ক","audioUrl":"wbw/003_021_018.mp3","charTypeName":"word"},{"id":23857,"position":19,"arabic":"٢١","translation":"(২১)","audioUrl":null,"charTypeName":"end"}]},{"number":22,"arabic":"أُو۟لَٰٓئِكَ ٱلَّذِينَ حَبِطَتْ أَعْمَٰلُهُمْ فِى ٱلدُّنْيَا وَٱلْءَاخِرَةِ وَمَا لَهُم مِّن نَّٰصِرِينَ","translation":"It is they whose works shall come to nought both in this world and in the life to come; and they shall have none to suc