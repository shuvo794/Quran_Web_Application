{"id":417,"ayahs":[{"number":21,"arabic":"وَلَنُذِيقَنَّهُم مِّنَ ٱلْعَذَابِ ٱلْأَدْنَىٰ دُونَ ٱلْعَذَابِ ٱلْأَكْبَرِ لَعَلَّهُمْ يَرْجِعُونَ","translation":"However, ere [We condemn them to] that supreme suffering, We shall most certainly let them taste of a suffering closer at hand, so that they might [repent and] mend their ways.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3524.mp3","surahId":32,"words":[{"id":24204,"position":1,"arabic":"وَلَنُذِيقَنَّهُم","translation":"এবং অবশ্যই আস্বাদন করাবোই আমরা তাদের","audioUrl":"wbw/032_021_001.mp3","charTypeName":"word"},{"id":24205,"position":2,"arabic":"مِّنَ","translation":"কিছু","audioUrl":"wbw/032_021_002.mp3","charTypeName":"word"},{"id":24206,"position":3,"arabic":"ٱلْعَذَابِ","translation":"শাস্তি (দ্বারা)","audioUrl":"wbw/032_021_003.mp3","charTypeName":"word"},{"id":24207,"position":4,"arabic":"ٱلْأَدْنَىٰ","translation":"হালকা (দুনিয়ার)","audioUrl":"wbw/032_021_004.mp3","charTypeName":"word"},{"id":24208,"position":5,"arabic":"دُونَ","translation":"ছাড়াও","audioUrl":"wbw/032_021_005.mp3","charTypeName":"word"},{"id":24209,"position":6,"arabic":"ٱلْعَذَابِ","translation":"শাস্তি (আখেরাতের)","audioUrl":"wbw/032_021_006.mp3","charTypeName":"word"},{"id":24210,"position":7,"arabic":"ٱلْأَكْبَرِ","translation":"বড়","audioUrl":"wbw/032_021_007.mp3","charTypeName":"word"},{"id":24211,"position":8,"arabic":"لَعَلَّهُمْ","translation":"সম্ভবত তারা","audioUrl":"wbw/032_021_008.mp3","charTypeName":"word"},{"id":24212,"position":9,"arabic":"يَرْجِعُونَ","translation":"ফিরে আসবে","audioUrl":"wbw/032_021_009.mp3","charTypeName":"word"},{"id":24213,"position":10,"arabic":"٢١","translation":"(২১)","audioUrl":null,"charTypeName":"end"}]},{"number":22,"arabic":"وَمَنْ أَظْلَمُ مِمَّن ذُكِّرَ بِـَٔايَٰتِ رَبِّهِۦ ثُمَّ أَعْرَضَ عَنْهَآ ۚ إِنَّا مِنَ ٱلْمُجْرِمِينَ مُنتَقِمُونَ","translation":"And who could be more wicked than he to whom his Sustainer’s messages are conveyed and who thereupon turns away from them? Verily, We shall inflict Our retribution on those who are [thus] lost in sin!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3525.mp3","surahId":32,"words":[{"id":25176,"position":1,"arabic":"وَمَنْ","translation":"এবং কে","audioUrl":"wbw/032_022_001.mp3","charTypeName":"word"},{"id":25177,"position":2,"arabic":"أَظْلَمُ","translation":"বড় সীমালঙ্ঘনকারী","audioUrl":"wbw/032_022_002.mp3","charTypeName":"word"},{"id":25178,"position":3,"arabic":"مِمَّن","translation":"(তার) চেয়ে যাকে","audioUrl":"wbw/032_022_003.mp3","charTypeName":"word"},{"id":25179,"position":4,"arabic":"ذُكِّرَ","translation":"উপদেশ দেওয়া হয়","audioUrl":"wbw/032_022_004.mp3","charTypeName":"word"},{"id":25180,"position":5,"arabic":"بِـَٔايَـٰتِ","translation":"দিয়ে নিদর্শন সমূহ","audioUrl":"wbw/032_022_005.mp3","charTypeName":"word"},{"id":25181,"position":6,"arabic":"رَبِّهِۦ","translation":"রবের তার","audioUrl":"wbw/032_022_006.mp3","charTypeName":"word"},{"id":25182,"position":7,"arabic":"ثُمَّ","translation":"এরপরও","audioUrl":"wbw/032_022_007.mp3","charTypeName":"word"},{"id":25183,"position":8,"arabic":"أَعْرَضَ","translation":"সে মুখ ফিরিয়ে নেয়","audioUrl":"wbw/032_022_008.mp3","charTypeName":"word"},{"id":25184,"position":9,"arabic":"عَنْهَآ ۚ","translation":"থেকে তা","audioUrl":"wbw/032_022_009.mp3","charTypeName":"word"},{"id":25186,"position":10,"arabic":"إِنَّا","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/032_022_011.mp3","charTypeName":"word"},{"id":25187,"position":11,"arabic":"مِنَ","translation":"থেকে","audioUrl":"wbw/032_022_012.mp3","charTypeName":"word"},{"id":25188,"position":12,"arabic":"ٱلْمُجْرِمِينَ","translation":"অপরাধীদের","audioUrl":"wbw/032_022_013.mp3","charTypeName":"word"},{"id":25189,"position":13,"arabic":"مُنتَقِمُونَ","translation":"প্রতিশোধ গ্রহণকারী","audioUrl":"wbw/032_022_014.mp3","charTypeName":"word"},{"id":25190,"position":14,"arabic":"٢٢","translation":"(২২)","audioUrl":null,"charTypeName":"end"}]},{"number":23,"arabic":"وَلَقَدْ ءَاتَيْنَا مُوسَى ٱلْكِتَٰبَ فَلَا تَكُن فِى مِرْيَةٍۢ مِّن لِّقَآئِهِۦ ۖ وَجَعَلْنَٰهُ هُدًۭى لِّبَنِىٓ إِسْرَٰٓءِيلَ","translation":"AND, INDEED, [O Muhammad,] We did vouchsafe revelation unto Moses [as well]: so be not in doubt of [thy] having met with the same [truth in the revelation vouchsafed to thee]. And [just as] We caused that [earlier revelation] to be a guidance for the children of Israel,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3526.mp3","surahId":32,"words":[{"id":26281,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/032_023_001.mp3","charTypeName":"word"},{"id":26282,"position":2,"arabic":"ءَاتَيْنَا","translation":"দিয়েছি আমরা","audioUrl":"wbw/032_023_002.mp3","charTypeName":"word"},{"id":26283,"position":3,"arabic":"مُوسَى","translation":"মূসাকে","audioUrl":"wbw/032_023_003.mp3","charTypeName":"word"},{"id":26284,"position":4,"arabic":"ٱلْكِتَـٰبَ","translation":"কিতাব","audioUrl":"wbw/032_023_004.mp3","charTypeName":"word"},{"id":26285,"position":5,"arabic":"فَلَا","translation":"সুতরাং না (যেন)","audioUrl":"wbw/032_023_005.mp3","charTypeName":"word"},{"id":26286,"position":6,"arabic":"تَكُن","translation":"তুমি হয়ো (থাকো)","audioUrl":"wbw/032_023_006.mp3","charTypeName":"word"},{"id":26287,"position":7,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/032_023_007.mp3","charTypeName":"word"},{"id":26288,"position":8,"arabic":"مِرْيَةٍۢ","translation":"সন্দেহের","audioUrl":"wbw/032_023_008.mp3","charTypeName":"word"},{"id":26289,"position":9,"arabic":"مِّن","translation":"ব্যাপারে","audioUrl":"wbw/032_023_009.mp3","charTypeName":"word"},{"id":26290,"position":10,"arabic":"لِّقَآئِهِۦ ۖ","translation":"পাওয়ার তা","audioUrl":"wbw/032_023_010.mp3","charTypeName":"word"},{"id":26292,"position":11,"arabic":"وَجَعَلْنَـٰهُ","translation":"এবং আমরা বানিয়েছিলাম তাকে","audioUrl":"wbw/032_023_012.mp3","charTypeName":"word"},{"id":26293,"position":12,"arabic":"هُدًۭى","translation":"পথনির্দেশনা","audioUrl":"wbw/032_023_013.mp3","charTypeName":"word"},{"id":26294,"position":13,"arabic":"لِّبَنِىٓ","translation":"জন্যে সন্তানদের","audioUrl":"wbw/032_023_014.mp3","charTypeName":"word"},{"id":26295,"position":14,"arabic":"إِسْرَٰٓءِيلَ","translation":"ইসরাঈলের","audioUrl":"wbw/032_023_015.mp3","charTypeName":"word"},{"id":26296,"position":15,"arabic":"٢٣","translation":"(২৩)","audioUrl":null,"charTypeName":"end"}]},{"number":24,"arabic":"وَجَعَلْنَا مِنْهُمْ أَئِمَّةًۭ يَهْدُونَ بِأَمْرِنَا لَمَّا صَبَرُوا۟ ۖ وَكَانُوا۟ بِـَٔايَٰتِنَا يُوقِنُونَ","translation":"and [as] We raised among them leaders who, so long as they bore themselves with patience and had sure faith in Our messages, guided [their people] in accordance with Our behest [so, too, shall it be with the divine writ revealed unto thee, O Muhammad.]","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3527.mp3","surahId":32,"words":[{"id":27319,"position":1,"arabic":"وَجَعَلْنَا","translation":"এবং মনোনীত করেছিলাম আমরা","audioUrl":"wbw/032_024_001.mp3","charTypeName":"word"},{"id":27320,"position":2,"arabic":"مِنْهُمْ","translation":"মধ্যে থেকে তাদের","audioUrl":"wbw/032_024_002.mp3","charTypeName":"word"},{"id":27321,"position":3,"arabic":"أَئِمَّةًۭ","translation":"(অনেক) নেতা","audioUrl":"wbw/032_024_003.mp3","charTypeName":"word"},{"id":27322,"position":4,"arabic":"يَهْدُونَ","translation":"(যারা) পথ দেখাতো","audioUrl":"wbw/032_024_004.mp3","charTypeName":"word"},{"id":27323,"position":5,"arabic":"بِأَمْرِنَا","translation":"অনুসারে আমাদের নির্দেশ","audioUrl":"wbw/032_024_005.mp3","charTypeName":"word"},{"id":27324,"position":6,"arabic":"لَمَّا","translation":"যখন","audioUrl":"wbw/032_024_006.mp3","charTypeName":"word"},{"id":27325,"position":7,"arabic":"صَبَرُوا۟ ۖ","translation":"তারা ধৈর্য ধরেছিলো","audioUrl":"wbw/032_024_007.mp3","charTypeName":"word"},{"id":27327,"position":8,"arabic":"وَكَانُوا۟","translation":"এবং তারা ছিলো","audioUrl":"wbw/032_024_009.mp3","charTypeName":"word"},{"id":27328,"position":9,"arabic":"بِـَٔايَـٰتِنَا","translation":"প্রতি আমাদের নিদর্শনগুলোর","audioUrl":"wbw/032_024_010.mp3","charTypeName":"word"},{"id":27329,"position":10,"arabic":"يُوقِنُونَ","translation":"দৃঢ়বিশ্বাস করতো","audioUrl":"wbw/032_024_011.mp3","charTypeName":"word"},{"id":27330,"position":11,"arabic":"٢٤","translation":"(২৪)","audioUrl":null,"charTypeName":"end"}]},{"number":25,"arabic":"إِنَّ رَبَّكَ هُوَ يَفْصِلُ بَيْنَهُمْ يَوْمَ ٱلْقِيَٰمَةِ فِيمَا كَانُوا۟ فِيهِ يَخْتَلِفُونَ","translation":"VERILY, it is God alone who will decide between men on Resurrection Day with regard to all on which they were wont to differ.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3528.mp3","surahId":32,"words":[{"id":28365,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/032_025_001.mp3","charTypeName":"word"},{"id":28366,"position":2,"arabic":"رَبَّكَ","translation":"তোমার রব","audioUrl":"wbw/032_025_002.mp3","charTypeName":"word"},{"id":28367,"position":3,"arabic":"هُوَ","translation":"তিনিই","audioUrl":"wbw/032_025_003.mp3","charTypeName":"word"},{"id":28368,"position":4,"arabic":"يَفْصِلُ","translation":"মীমাংসা করে দিবেন","audioUrl":"wbw/032_025_004.mp3","charTypeName":"word"},{"id":28369,"position":5,"arabic":"بَيْنَهُمْ","translation":"মাঝে তাদের","audioUrl":"wbw/032_025_005.mp3","charTypeName":"word"},{"id":28370,"position":6,"arabic":"يَوْمَ","translation":"দিনে","audioUrl":"wbw/032_025_006.mp3","charTypeName":"word"},{"id":28371,"position":7,"arabic":"ٱلْقِيَـٰمَةِ","translation":"ক্বিয়ামাতের","audioUrl":"wbw/032_025_007.mp3","charTypeName":"word"},{"id":28372,"position":8,"arabic":"فِيمَا","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/032_025_008.mp3","charTypeName":"word"},{"id":28373,"position":9,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/032_025_009.mp3","charTypeName":"word"},{"id":28374,"position":10,"arabic":"فِيهِ","translation":"বিষয়ে সে","audioUrl":"wbw/032_025_010.mp3","charTypeName":"word"},{"id":28375,"position":11,"arabic":"يَخْتَلِفُونَ","translation":"তারা মত-বিরোধ করতো","audioUrl":"wbw/032_025_011.mp3","charTypeName":"word"},{"id":28376,"position":12,"arabic":"٢٥","translation":"(২৫)","audioUrl":null,"charTypeName":"end"}]},{"number":26,"arabic":"أَوَلَمْ يَهْدِ لَهُمْ كَمْ أَهْلَكْنَا مِن قَبْلِهِم مِّنَ ٱلْقُرُونِ يَمْشُونَ فِى مَسَٰكِنِهِمْ ۚ إِنَّ فِى ذَٰلِكَ لَءَايَٰتٍ ۖ أَفَلَا يَسْمَعُونَ","translation":"[But] can, then, they [who deny the truth] learn no lesson by recalling how many a generation We have destroyed before their time? [people] in whose dwelling-places they [themselves now] walk about? In this, behold, there are messages indeed: will they not, then, listen?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3529.mp3","surahId":32,"words":[{"id":29282,"position":1,"arabic":"أَوَلَمْ","translation":"(এটাও) কি না","audioUrl":"wbw/032_026_001.mp3","charTypeName":"word"},{"id":29283,"position":2,"arabic":"يَهْدِ","translation":"পথপ্রদর্শন করে","audioUrl":"wbw/032_026_002.mp3","charTypeName":"word"},{"id":29284,"position":3,"arabic":"لَهُمْ","translation":"জন্যে তাদের","audioUrl":"wbw/032_026_003.mp3","charTypeName":"word"},{"id":29285,"position":4,"arabic":"كَمْ","translation":"কতই (না)","audioUrl":"wbw/032_026_004.mp3","charTypeName":"word"},{"id":29286,"position":5,"arabic":"أَهْلَكْنَا","translation":"ধ্বংস করেছি আমরা","audioUrl":"wbw/032_026_005.mp3","charTypeName":"word"},{"id":29287,"position":6,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/032_026_006.mp3","charTypeName":"word"},{"id":29288,"position":7,"arabic":"قَبْلِهِم","translation":"পূর্ব তাদের","audioUrl":"wbw/032_026_007.mp3","charTypeName":"word"},{"id":29289,"position":8,"arabic":"مِّنَ","translation":"মধ্য হ'তে","audioUrl":"wbw/032_026_008.mp3","charTypeName":"word"},{"id":29290,"position":9,"arabic":"ٱلْقُرُونِ","translation":"মানবগোষ্ঠীর","audioUrl":"wbw/032_026_009.mp3","charTypeName":"word"},{"id":29291,"position":10,"arabic":"يَمْشُونَ","translation":"তারা বিচরণ করে","audioUrl":"wbw/032_026_010.mp3","charTypeName":"word"},{"id":29292,"position":11,"arabic":"فِى","translation":"মধ্য দিয়ে","audioUrl":"wbw/032_026_011.mp3","charTypeName":"word"},{"id":29293,"position":12,"arabic":"مَسَـٰكِنِهِمْ ۚ","translation":"বাসভূমির তাদের","audioUrl":"wbw/032_026_012.mp3","charTypeName":"word"},{"id":29295,"position":13,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/032_026_014.mp3","charTypeName":"word"},{"id":29296,"position":14,"arabic":"فِى","translation":"মধ্যে (রয়েছে)","audioUrl":"wbw/032_026_015.mp3","charTypeName":"word"},{"id":29297,"position":15,"arabic":"ذَٰلِكَ","translation":"এর","audioUrl":"wbw/032_026_016.mp3","charTypeName":"word"},{"id":29298,"position":16,"arabic":"لَـَٔايَـٰتٍ ۖ","translation":"অবশ্যই নিদর্শনাবলী","audioUrl":"wbw/032_026_017.mp3","charTypeName":"word"},{"id":29300,"position":17,"arabic":"أَفَلَا","translation":"কি তবুও না","audioUrl":"wbw/032_026_019.mp3","charTypeName":"word"},{"id":29301,"position":18,"arabic":"يَسْمَعُونَ","translation":"তারা শুনবে","audioUrl":"wbw/032_026_020.mp3","charTypeName":"word"},{"id":29302,"position":19,"arabic":"٢٦","translation":"(২৬)","audioUrl":null,"charTypeName":"end"}]},{"number":27,"arabic":"أَوَلَمْ يَرَوْا۟ أَنَّا نَسُوقُ ٱلْمَآءَ إِلَى ٱلْأَرْضِ ٱلْجُرُزِ فَنُخْرِجُ بِهِۦ زَرْعًۭا تَأْكُلُ مِنْهُ أَنْعَٰمُهُمْ وَأَنفُسُهُمْ ۖ أَفَلَا يُبْصِرُونَ","translation":"Are they not aware that it is We who drive the rain onto dry land devoid of herbage, and thereby bring forth herbage of which their cattle and they themselves do eat? Can they not, then, see [the truth of resurrection]?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3530.mp3","surahId":32,"words":[{"id":30249,"position":1,"arabic":"أَوَلَمْ","translation":"কি না","audioUrl":"wbw/032_027_001.mp3","charTypeName":"word"},{"id":30250,"position":2,"arabic":"يَرَوْا۟","translation":"তারা দেখে","audioUrl":"wbw/032_027_002.mp3","charTypeName":"word"},{"id":30251,"position":3,"arabic":"أَنَّا","translation":"যে আমরা","audioUrl":"wbw/032_027_003.mp3","charTypeName":"word"},{"id":30252,"position":4,"arabic":"نَسُوقُ","translation":"প্রবাহিত করি","audioUrl":"wbw/032_027_004.mp3","charTypeName":"word"},{"id":30253,"position":5,"arabic":"ٱلْمَآءَ","translation":"পানি","audioUrl":"wbw/032_027_005.mp3","charTypeName":"word"},{"id":30254,"position":6,"arabic":"إِلَى","translation":"দিকে","audioUrl":"wbw/032_027_006.mp3","charTypeName":"word"},{"id":30255,"position":7,"arabic":"ٱلْأَرْضِ","translation":"ভূমির","audioUrl":"wbw/032_027_007.mp3","charTypeName":"word"},{"id":30256,"position":8,"arabic":"ٱلْجُرُزِ","translation":"(তৃণ পানিবিহীন) ঊষর","audioUrl":"wbw/032_027_008.mp3","charTypeName":"word"},{"id":30257,"position":9,"arabic":"فَنُخْرِجُ","translation":"এরপর বের করি আমরা","audioUrl":"wbw/032_027_009.mp3","charTypeName":"word"},{"id":30258,"position":10,"arabic":"بِهِۦ","translation":"দিয়ে তা","audioUrl":"wbw/032_027_010.mp3","charTypeName":"word"},{"id":30259,"position":11,"arabic":"زَرْعًۭا","translation":"শস্য","audioUrl":"wbw/032_027_011.mp3","charTypeName":"word"},{"id":30260,"position":12,"arabic":"تَأْكُلُ","translation":"খায়","audioUrl":"wbw/032_027_012.mp3","charTypeName":"word"},{"id":30261,"position":13,"arabic":"مِنْهُ","translation":"থেকে তা","audioUrl":"wbw/032_027_013.mp3","charTypeName":"word"},{"id":30262,"position":14,"arabic":"أَنْعَـٰمُهُمْ","translation":"গবাদি পশু তাদের","audioUrl":"wbw/032_027_014.mp3","charTypeName":"word"},{"id":30263,"position":15,"arabic":"وَأَنفُسُهُمْ ۖ","translation":"এবং নিজেরাও তারা","audioUrl":"wbw/032_027_015.mp3","charTypeName":"word"},{"id":30265,"position":16,"arabic":"أَفَلَا","translation":"কি তবুুও  না","audioUrl":"wbw/032_027_017.mp3","charTypeName":"word"},{"id":30266,"position":17,"arabic":"يُبْصِرُونَ","translation":"তারা লক্ষ্য করবে (বা বুঝবে)","audioUrl":"wbw/032_027_018.mp3","charTypeName":"word"},{"id":30267,"position":18,"arabic":"٢٧","translation":"(২৭)","audioUrl":null,"charTypeName":"end"}]},{"number":28,"arabic":"وَيَقُولُونَ مَتَىٰ هَٰذَا ٱلْفَتْحُ إِن كُنتُمْ صَٰدِقِينَ","translation":"But they answer: “When will that final decision take place, if what you [believers] say is true?”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3531.mp3","surahId":32,"words":[{"id":31274,"position":1,"arabic":"وَيَقُولُونَ","translation":"এবং তারা বলে","audioUrl":"wbw/032_028_001.mp3","charTypeName":"word"},{"id":31275,"position":2,"arabic":"مَتَىٰ","translation":"\"কখন (আসবে)","audioUrl":"wbw/032_028_002.mp3","charTypeName":"word"},{"id":31276,"position":3,"arabic":"هَـٰذَا","translation":"এই","audioUrl":"wbw/032_028_003.mp3","charTypeName":"word"},{"id":31277,"position":4,"arabic":"ٱلْفَتْحُ","translation":"মীমাংসা","audioUrl":"wbw/032_028_004.mp3","charTypeName":"word"},{"id":31278,"position":5,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/032_028_005.mp3","charTypeName":"word"},{"id":31279,"position":6,"arabic":"كُنتُمْ","translation":"তোমরা হও","audioUrl":"wbw/032_028_006.mp3","charTypeName":"word"},{"id":31280,"position":7,"arabic":"صَـٰدِقِينَ","translation":"সত্যবাদী\"","audioUrl":"wbw/032_028_007.mp3","charTypeName":"word"},{"id":31281,"position":8,"arabic":"٢٨","translation":"(২৮)","audioUrl":null,"charTypeName":"end"}]},{"number":29,"arabic":"قُلْ يَوْمَ ٱلْفَتْحِ لَا يَنفَعُ ٱلَّذِينَ كَفَرُوٓا۟ إِيمَٰنُهُمْ وَلَا هُمْ يُنظَرُونَ","translation":"Say: “On the Day of the Final Decision, their [newly-found] faith will be of no use to those who [in their lifetime] were bent on denying the truth, nor will they be granted respite!” –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3532.mp3","surahId":32,"words":[{"id":32259,"position":1,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/032_029_001.mp3","charTypeName":"word"},{"id":32260,"position":2,"arabic":"يَوْمَ","translation":"\"দিন","audioUrl":"wbw/032_029_002.mp3","charTypeName":"word"},{"id":32261,"position":3,"arabic":"ٱلْفَتْحِ","translation":"মীমাংসার","audioUrl":"wbw/032_029_003.mp3","charTypeName":"word"},{"id":32262,"position":4,"arabic":"لَا","translation":"না","audioUrl":"wbw/032_029_004.mp3","charTypeName":"word"},{"id":32263,"position":5,"arabic":"يَنفَعُ","translation":"উপকার দিবে","audioUrl":"wbw/032_029_005.mp3","charTypeName":"word"},{"id":32264,"position":6,"arabic":"ٱلَّذِينَ","translation":"(তাদের) যারা","audioUrl":"wbw/032_029_006.mp3","charTypeName":"word"},{"id":32265,"position":7,"arabic":"كَفَرُوٓا۟","translation":"অবিশ্বাস করেছে","audioUrl":"wbw/032_029_007.mp3","charTypeName":"word"},{"id":32266,"position":8,"arabic":"إِيمَـٰنُهُمْ","translation":"ঈমান তাদের","audioUrl":"wbw/032_029_008.mp3","charTypeName":"word"},{"id":32267,"position":9,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/032_029_009.mp3","charTypeName":"word"},{"id":32268,"position":10,"arabic":"هُمْ","translation":"তাদের","audioUrl":"wbw/032_029_010.mp3","charTypeName":"word"},{"id":32269,"position":11,"arabic":"يُنظَرُونَ","translation":"অবকাশ দেওয়া হবে\"","audioUrl":"wbw/032_029_011.mp3","charTypeName":"word"},{"id":32270,"position":12,"arabic":"٢٩","translation":"(২৯)","audioUrl":null,"charTypeName":"end"}]},{"number":30,"arabic":"فَأَعْرِضْ عَنْهُمْ وَٱنتَظِرْ إِنَّهُم مُّنتَظِرُونَ","translation":"and then leave them alone, and wait [for the truth to unfold as] they, behold, are waiting.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3533.mp3","surahId":32,"words":[{"id":33108,"position":1,"arabic":"فَأَعْرِضْ","translation":"সুতরাং (এ অবস্থায়) ছেড়ে দাও","audioUrl":"wbw/032_030_001.mp3","charTypeName":"word"},{"id":33109,"position":2,"arabic":"عَنْهُمْ","translation":"ব্যাপারে তাদের","audioUrl":"wbw/032_030_002.mp3","charTypeName":"word"},{"id":33110,"position":3,"arabic":"وَٱنتَظِرْ","translation":"ও অপেক্ষা করো","audioUrl":"wbw/032_030_003.mp3","charTypeName":"word"},{"id":33111,"position":4,"arabic":"إِنَّهُم","translation":"নিশ্চয়ই তারাও","audioUrl":"wbw/032_030_004.mp3","charTypeName":"word"},{"id":33112,"position":5,"arabic":"مُّنتَظِرُونَ","translation":"অপেক্ষাকারী","audioUrl":"wbw/032_030_005.mp3","charTypeName":"word"},{"id":33113,"position":6,"arabic":"٣٠","translation":"(৩০)","audioUrl":null,"charTypeName":"end"}]}]}