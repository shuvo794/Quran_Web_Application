{"id":436,"ayahs":[{"number":12,"arabic":"وَمَا يَسْتَوِى ٱلْبَحْرَانِ هَٰذَا عَذْبٌۭ فُرَاتٌۭ سَآئِغٌۭ شَرَابُهُۥ وَهَٰذَا مِلْحٌ أُجَاجٌۭ ۖ وَمِن كُلٍّۢ تَأْكُلُونَ لَحْمًۭا طَرِيًّۭا وَتَسْتَخْرِجُونَ حِلْيَةًۭ تَلْبَسُونَهَا ۖ وَتَرَى ٱلْفُلْكَ فِيهِ مَوَاخِرَ لِتَبْتَغُوا۟ مِن فَضْلِهِۦ وَلَعَلَّكُمْ تَشْكُرُونَ","translation":"[Easy is it for Him to create likeness and variety:] thus, the two great bodies of water [on earth] are not alike the one sweet, thirst-allaying, pleasant to drink, and the other salty and bitter: and yet, from either of them do you eat fresh meat, and [from either] you take gems which you may wear; and on either thou canst see ships ploughing through the waves, so that you might [be able to] go forth in quest of some of His bounty, and thus have cause to be grateful.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3672.mp3","surahId":35,"words":[{"id":14560,"position":1,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/035_012_001.mp3","charTypeName":"word"},{"id":14561,"position":2,"arabic":"يَسْتَوِى","translation":"সমান হয়","audioUrl":"wbw/035_012_002.mp3","charTypeName":"word"},{"id":14562,"position":3,"arabic":"ٱلْبَحْرَانِ","translation":"দুই সাগর","audioUrl":"wbw/035_012_003.mp3","charTypeName":"word"},{"id":14563,"position":4,"arabic":"هَـٰذَا","translation":"যেমন (এটা)","audioUrl":"wbw/035_012_004.mp3","charTypeName":"word"},{"id":14564,"position":5,"arabic":"عَذْبٌۭ","translation":"সুমিষ্ট","audioUrl":"wbw/035_012_005.mp3","charTypeName":"word"},{"id":14565,"position":6,"arabic":"فُرَاتٌۭ","translation":"সুপেয়","audioUrl":"wbw/035_012_006.mp3","charTypeName":"word"},{"id":14566,"position":7,"arabic":"سَآئِغٌۭ","translation":"সহজ পেয়","audioUrl":"wbw/035_012_007.mp3","charTypeName":"word"},{"id":14567,"position":8,"arabic":"شَرَابُهُۥ","translation":"তার পানীয়","audioUrl":"wbw/035_012_008.mp3","charTypeName":"word"},{"id":14568,"position":9,"arabic":"وَهَـٰذَا","translation":"আর ওটা","audioUrl":"wbw/035_012_009.mp3","charTypeName":"word"},{"id":14569,"position":10,"arabic":"مِلْحٌ","translation":"লোনা","audioUrl":"wbw/035_012_010.mp3","charTypeName":"word"},{"id":14570,"position":11,"arabic":"أُجَاجٌۭ ۖ","translation":"বিস্বাদ","audioUrl":"wbw/035_012_011.mp3","charTypeName":"word"},{"id":14572,"position":12,"arabic":"وَمِن","translation":"কিন্তু থেকে","audioUrl":"wbw/035_012_013.mp3","charTypeName":"word"},{"id":14573,"position":13,"arabic":"كُلٍّۢ","translation":"প্রত্যেকটা","audioUrl":"wbw/035_012_014.mp3","charTypeName":"word"},{"id":14574,"position":14,"arabic":"تَأْكُلُونَ","translation":"তোমরা খাও","audioUrl":"wbw/035_012_015.mp3","charTypeName":"word"},{"id":14575,"position":15,"arabic":"لَحْمًۭا","translation":"গোশত (মাছ)","audioUrl":"wbw/035_012_016.mp3","charTypeName":"word"},{"id":14576,"position":16,"arabic":"طَرِيًّۭا","translation":"তাজা","audioUrl":"wbw/035_012_017.mp3","charTypeName":"word"},{"id":14577,"position":17,"arabic":"وَتَسْتَخْرِجُونَ","translation":"ও তোমরা বের করো","audioUrl":"wbw/035_012_018.mp3","charTypeName":"word"},{"id":14578,"position":18,"arabic":"حِلْيَةًۭ","translation":"অলংকার (অর্থাৎ মনি-মুক্তা)","audioUrl":"wbw/035_012_019.mp3","charTypeName":"word"},{"id":14579,"position":19,"arabic":"تَلْبَسُونَهَا ۖ","translation":"তা তোমরা পরিধান করো","audioUrl":"wbw/035_012_020.mp3","charTypeName":"word"},{"id":14581,"position":20,"arabic":"وَتَرَى","translation":"এবং তোমরা দেখো","audioUrl":"wbw/035_012_022.mp3","charTypeName":"word"},{"id":14582,"position":21,"arabic":"ٱلْفُلْكَ","translation":"নৌকাগুলো","audioUrl":"wbw/035_012_023.mp3","charTypeName":"word"},{"id":14583,"position":22,"arabic":"فِيهِ","translation":"তার মধ্যে","audioUrl":"wbw/035_012_024.mp3","charTypeName":"word"},{"id":14584,"position":23,"arabic":"مَوَاخِرَ","translation":"পানিবিদীর্ণ করে চলে","audioUrl":"wbw/035_012_025.mp3","charTypeName":"word"},{"id":14585,"position":24,"arabic":"لِتَبْتَغُوا۟","translation":"তোমরা খোঁজ করতে পারো যেন","audioUrl":"wbw/035_012_026.mp3","charTypeName":"word"},{"id":14586,"position":25,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/035_012_027.mp3","charTypeName":"word"},{"id":14587,"position":26,"arabic":"فَضْلِهِۦ","translation":"তাঁর অনুগ্রহ","audioUrl":"wbw/035_012_028.mp3","charTypeName":"word"},{"id":14588,"position":27,"arabic":"وَلَعَلَّكُمْ","translation":"এবং তোমরা যাতে","audioUrl":"wbw/035_012_029.mp3","charTypeName":"word"},{"id":14589,"position":28,"arabic":"تَشْكُرُونَ","translation":"কৃতজ্ঞতা প্রকাশ করো","audioUrl":"wbw/035_012_030.mp3","charTypeName":"word"},{"id":14590,"position":29,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]},{"number":13,"arabic":"يُولِجُ ٱلَّيْلَ فِى ٱلنَّهَارِ وَيُولِجُ ٱلنَّهَارَ فِى ٱلَّيْلِ وَسَخَّرَ ٱلشَّمْسَ وَٱلْقَمَرَ كُلٌّۭ يَجْرِى لِأَجَلٍۢ مُّسَمًّۭى ۚ ذَٰلِكُمُ ٱللَّهُ رَبُّكُمْ لَهُ ٱلْمُلْكُ ۚ وَٱلَّذِينَ تَدْعُونَ مِن دُونِهِۦ مَا يَمْلِكُونَ مِن قِطْمِيرٍ","translation":"He makes the night grow longer by shortening the day, and He makes the day grow longer by shortening the night; and He has made the sun and the moon subservient [to His laws], each running its course for a term set [by Him]. Thus is God, your Sustainer: unto Him belongs all dominion - whereas those whom you invoke instead of Him do not own so much as the husk of a date-stone!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3673.mp3","surahId":35,"words":[{"id":15655,"position":1,"arabic":"يُولِجُ","translation":"তিনি প্রবেশ করান","audioUrl":"wbw/035_013_001.mp3","charTypeName":"word"},{"id":15656,"position":2,"arabic":"ٱلَّيْلَ","translation":"রাতকে","audioUrl":"wbw/035_013_002.mp3","charTypeName":"word"},{"id":15657,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/035_013_003.mp3","charTypeName":"word"},{"id":15658,"position":4,"arabic":"ٱلنَّهَارِ","translation":"দিনের","audioUrl":"wbw/035_013_004.mp3","charTypeName":"word"},{"id":15659,"position":5,"arabic":"وَيُولِجُ","translation":"এবং প্রবেশ করান","audioUrl":"wbw/035_013_005.mp3","charTypeName":"word"},{"id":15660,"position":6,"arabic":"ٱلنَّهَارَ","translation":"দিনকে","audioUrl":"wbw/035_013_006.mp3","charTypeName":"word"},{"id":15661,"position":7,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/035_013_007.mp3","charTypeName":"word"},{"id":15662,"position":8,"arabic":"ٱلَّيْلِ","translation":"রাতের","audioUrl":"wbw/035_013_008.mp3","charTypeName":"word"},{"id":15663,"position":9,"arabic":"وَسَخَّرَ","translation":"এবং নিয়ন্ত্রিত করেছেন","audioUrl":"wbw/035_013_009.mp3","charTypeName":"word"},{"id":15664,"position":10,"arabic":"ٱلشَّمْسَ","translation":"সূর্যকে","audioUrl":"wbw/035_013_010.mp3","charTypeName":"word"},{"id":15665,"position":11,"arabic":"وَٱلْقَمَرَ","translation":"ও চাঁদকে","audioUrl":"wbw/035_013_011.mp3","charTypeName":"word"},{"id":15666,"position":12,"arabic":"كُلٌّۭ","translation":"প্রত্যেকেই","audioUrl":"wbw/035_013_012.mp3","charTypeName":"word"},{"id":15667,"position":13,"arabic":"يَجْرِى","translation":"(পরিভ্রমণ করে) আবর্তন করে","audioUrl":"wbw/035_013_013.mp3","charTypeName":"word"},{"id":15668,"position":14,"arabic":"لِأَجَلٍۢ","translation":"একটি সময়ের জন্যে","audioUrl":"wbw/035_013_014.mp3","charTypeName":"word"},{"id":15669,"position":15,"arabic":"مُّسَمًّۭى ۚ","translation":"নির্দিষ্ট","audioUrl":"wbw/035_013_015.mp3","charTypeName":"word"},{"id":15671,"position":16,"arabic":"ذَٰلِكُمُ","translation":"তোমাদের সেই","audioUrl":"wbw/035_013_017.mp3","charTypeName":"word"},{"id":15672,"position":17,"arabic":"ٱللَّهُ","translation":"আল্লাহ-ই","audioUrl":"wbw/035_013_018.mp3","charTypeName":"word"},{"id":15673,"position":18,"arabic":"رَبُّكُمْ","translation":"তোমাদের রব","audioUrl":"wbw/035_013_019.mp3","charTypeName":"word"},{"id":15674,"position":19,"arabic":"لَهُ","translation":"তাঁরই","audioUrl":"wbw/035_013_020.mp3","charTypeName":"word"},{"id":15675,"position":20,"arabic":"ٱلْمُلْكُ ۚ","translation":"সার্বভৌমত্ব","audioUrl":"wbw/035_013_021.mp3","charTypeName":"word"},{"id":15677,"position":21,"arabic":"وَٱلَّذِينَ","translation":"এবং যাদেরকে","audioUrl":"wbw/035_013_023.mp3","charTypeName":"word"},{"id":15678,"position":22,"arabic":"تَدْعُونَ","translation":"তোমরা ডাকো","audioUrl":"wbw/035_013_024.mp3","charTypeName":"word"},{"id":15679,"position":23,"arabic":"مِن","translation":"ছাড়া","audioUrl":"wbw/035_013_025.mp3","charTypeName":"word"},{"id":15680,"position":24,"arabic":"دُونِهِۦ","translation":"তাঁকে","audioUrl":"wbw/035_013_026.mp3","charTypeName":"word"},{"id":15681,"position":25,"arabic":"مَا","translation":"না","audioUrl":"wbw/035_013_027.mp3","charTypeName":"word"},{"id":15682,"position":26,"arabic":"يَمْلِكُونَ","translation":"(তারা অধিকারী) অধিকার রাখে","audioUrl":"wbw/035_013_028.mp3","charTypeName":"word"},{"id":15683,"position":27,"arabic":"مِن","translation":"কোনো","audioUrl":"wbw/035_013_029.mp3","charTypeName":"word"},{"id":15684,"position":28,"arabic":"قِطْمِيرٍ","translation":"(তুচ্ছাতিতুচ্ছ বস্তুর) খেজুরের আঁটির পর্দা","audioUrl":"wbw/035_013_030.mp3","charTypeName":"word"},{"id":15685,"position":29,"arabic":"١٣","translation":"(১৩)","audioUrl":null,"charTypeName":"end"}]},{"number":14,"arabic":"إِن تَدْعُوهُمْ لَا يَسْمَعُوا۟ دُعَآءَكُمْ وَلَوْ سَمِعُوا۟ مَا ٱسْتَجَابُوا۟ لَكُمْ ۖ وَيَوْمَ ٱلْقِيَٰمَةِ يَكْفُرُونَ بِشِرْكِكُمْ ۚ وَلَا يُنَبِّئُكَ مِثْلُ خَبِيرٍۢ","translation":"If you invoke them, they do not hear your call; and even if they could hear, they would not [be able to] respond to you. And [withal,] on the Day of Resurrection they will utterly disown your having associated them with God. And none can make thee understand [the truth] like the One who is all-aware.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3674.mp3","surahId":35,"words":[{"id":16713,"position":1,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/035_014_001.mp3","charTypeName":"word"},{"id":16714,"position":2,"arabic":"تَدْعُوهُمْ","translation":"তোমরা তাদেরকে ডাকো","audioUrl":"wbw/035_014_002.mp3","charTypeName":"word"},{"id":16715,"position":3,"arabic":"لَا","translation":"না","audioUrl":"wbw/035_014_003.mp3","charTypeName":"word"},{"id":16716,"position":4,"arabic":"يَسْمَعُوا۟","translation":"তারা শুনতে পায়","audioUrl":"wbw/035_014_004.mp3","charTypeName":"word"},{"id":16717,"position":5,"arabic":"دُعَآءَكُمْ","translation":"তোমাদের ডাক","audioUrl":"wbw/035_014_005.mp3","charTypeName":"word"},{"id":16718,"position":6,"arabic":"وَلَوْ","translation":"আর যদি","audioUrl":"wbw/035_014_006.mp3","charTypeName":"word"},{"id":16719,"position":7,"arabic":"سَمِعُوا۟","translation":"তারা শুনেও","audioUrl":"wbw/035_014_007.mp3","charTypeName":"word"},{"id":16720,"position":8,"arabic":"مَا","translation":"না","audioUrl":"wbw/035_014_008.mp3","charTypeName":"word"},{"id":16721,"position":9,"arabic":"ٱسْتَجَابُوا۟","translation":"তারা সাড়া দিতে পারে","audioUrl":"wbw/035_014_009.mp3","charTypeName":"word"},{"id":16722,"position":10,"arabic":"لَكُمْ ۖ","translation":"তোমাদেরকে","audioUrl":"wbw/035_014_010.mp3","charTypeName":"word"},{"id":16724,"position":11,"arabic":"وَيَوْمَ","translation":"এবং দিনে","audioUrl":"wbw/035_014_012.mp3","charTypeName":"word"},{"id":16725,"position":12,"arabic":"ٱلْقِيَـٰمَةِ","translation":"ক্বিয়ামাতের","audioUrl":"wbw/035_014_013.mp3","charTypeName":"word"},{"id":16726,"position":13,"arabic":"يَكْفُرُونَ","translation":"তারা অস্বীকার করবে","audioUrl":"wbw/035_014_014.mp3","charTypeName":"word"},{"id":16727,"position":14,"arabic":"بِشِرْكِكُمْ ۚ","translation":"তোমাদের শিরককে","audioUrl":"wbw/035_014_015.mp3","charTypeName":"word"},{"id":16729,"position":15,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/035_014_017.mp3","charTypeName":"word"},{"id":16730,"position":16,"arabic":"يُنَبِّئُكَ","translation":"তোমাকে জানাতে পারে কেউ","audioUrl":"wbw/035_014_018.mp3","charTypeName":"word"},{"id":16731,"position":17,"arabic":"مِثْلُ","translation":"মতো","audioUrl":"wbw/035_014_019.mp3","charTypeName":"word"},{"id":16732,"position":18,"arabic":"خَبِيرٍۢ","translation":"সর্বজ্ঞ আল্লাহর","audioUrl":"wbw/035_014_020.mp3","charTypeName":"word"},{"id":16733,"position":19,"arabic":"١٤","translation":"(১৪)","audioUrl":null,"charTypeName":"end"}]},{"number":15,"arabic":"۞ يَٰٓأَيُّهَا ٱلنَّاسُ أَنتُمُ ٱلْفُقَرَآءُ إِلَى ٱللَّهِ ۖ وَٱللَّهُ هُوَ ٱلْغَنِىُّ ٱلْحَمِيدُ","translation":"O men! It is you, who stand in need of God, whereas He alone is self-sufficient, the One to whom all praise is due.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3675.mp3","surahId":35,"words":[{"id":17895,"position":1,"arabic":"۞ يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/035_015_002.mp3","charTypeName":"word"},{"id":17896,"position":2,"arabic":"ٱلنَّاسُ","translation":"মানব সম্প্রদায়","audioUrl":"wbw/035_015_003.mp3","charTypeName":"word"},{"id":17897,"position":3,"arabic":"أَنتُمُ","translation":"তোমরা","audioUrl":"wbw/035_015_004.mp3","charTypeName":"word"},{"id":17898,"position":4,"arabic":"ٱلْفُقَرَآءُ","translation":"মুখাপেক্ষী","audioUrl":"wbw/035_015_005.mp3","charTypeName":"word"},{"id":17899,"position":5,"arabic":"إِلَى","translation":"কাছে","audioUrl":"wbw/035_015_006.mp3","charTypeName":"word"},{"id":17900,"position":6,"arabic":"ٱللَّهِ ۖ","translation":"আল্লাহর","audioUrl":"wbw/035_015_007.mp3","charTypeName":"word"},{"id":17902,"position":7,"arabic":"وَٱللَّهُ","translation":"কিন্তু আল্লাহ (এমন যে)","audioUrl":"wbw/035_015_009.mp3","charTypeName":"word"},{"id":17903,"position":8,"arabic":"هُوَ","translation":"তিনিই","audioUrl":"wbw/035_015_010.mp3","charTypeName":"word"},{"id":17904,"position":9,"arabic":"ٱلْغَنِىُّ","translation":"অভাবমুক্ত","audioUrl":"wbw/035_015_011.mp3","charTypeName":"word"},{"id":17905,"position":10,"arabic":"ٱلْحَمِيدُ","translation":"প্রশংসিত","audioUrl":"wbw/035_015_012.mp3","charTypeName":"word"},{"id":17906,"position":11,"arabic":"١٥","translation":"(১৫)","audioUrl":null,"charTypeName":"end"}]},{"number":16,"arabic":"إِن يَشَأْ يُذْهِبْكُمْ وَيَأْتِ بِخَلْقٍۢ جَدِيدٍۢ","translation":"If He so wills, He can do away with you and bring forth a new mankind [in your stead]:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3676.mp3","surahId":35,"words":[{"id":18915,"position":1,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/035_016_001.mp3","charTypeName":"word"},{"id":18916,"position":2,"arabic":"يَشَأْ","translation":"তিনি ইচ্ছে করেন","audioUrl":"wbw/035_016_002.mp3","charTypeName":"word"},{"id":18917,"position":3,"arabic":"يُذْهِبْكُمْ","translation":"তোমাদেরকে বিলোপ করতে পারেন","audioUrl":"wbw/035_016_003.mp3","charTypeName":"word"},{"id":18918,"position":4,"arabic":"وَيَأْتِ","translation":"এবং আনতে পারেন (তোমাদের স্থানে)","audioUrl":"wbw/035_016_004.mp3","charTypeName":"word"},{"id":18919,"position":5,"arabic":"بِخَلْقٍۢ","translation":"সৃষ্টিকে","audioUrl":"wbw/035_016_005.mp3","charTypeName":"word"},{"id":18920,"position":6,"arabic":"جَدِيدٍۢ","translation":"নতুন","audioUrl":"wbw/035_016_006.mp3","charTypeName":"word"},{"id":18921,"position":7,"arabic":"١٦","translation":"(১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":17,"arabic":"وَمَا ذَٰلِكَ عَلَى ٱللَّهِ بِعَزِيزٍۢ","translation":"nor is this difficult for God.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3677.mp3","surahId":35,"words":[{"id":20025,"position":1,"arabic":"وَمَا","translation":"আর নয়","audioUrl":"wbw/035_017_001.mp3","charTypeName":"word"},{"id":20026,"position":2,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/035_017_002.mp3","charTypeName":"word"},{"id":20027,"position":3,"arabic":"عَلَى","translation":"জন্যে","audioUrl":"wbw/035_017_003.mp3","charTypeName":"word"},{"id":20028,"position":4,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/035_017_004.mp3","charTypeName":"word"},{"id":20029,"position":5,"arabic":"بِعَزِيزٍۢ","translation":"কোনো কঠিন (কিছু)","audioUrl":"wbw/035_017_005.mp3","charTypeName":"word"},{"id":20030,"position":6,"arabic":"١٧","translation":"(১৭)","audioUrl":null,"charTypeName":"end"}]},{"number":18,"arabic":"وَلَا تَزِرُ وَازِرَةٌۭ وِزْرَ أُخْرَىٰ ۚ وَإِن تَدْعُ مُثْقَلَةٌ إِلَىٰ حِمْلِهَا لَا يُحْمَلْ مِنْهُ شَىْءٌۭ وَلَوْ كَانَ ذَا قُرْبَىٰٓ ۗ إِنَّمَا تُنذِرُ ٱلَّذِينَ يَخْشَوْنَ رَبَّهُم بِٱلْغَيْبِ وَأَقَامُوا۟ ٱلصَّلَوٰةَ ۚ وَمَن تَزَكَّىٰ فَإِنَّمَا يَتَزَكَّىٰ لِنَفْسِهِۦ ۚ وَإِلَى ٱللَّهِ ٱلْمَصِيرُ","translation":"AND NO BEARER of burdens shall be made to bear another’s burden; and if one weighed down by his load calls upon [another] to help him carry it, nothing thereof may be carried [by that other], even if it be one’s near of kin. Hence, thou canst [truly] warn only those who stand in awe of their Sustainer although He is beyond the reach of their perception, and are constant in prayer, and [know that] whoever grows in purity, attains to purity but for the good of his own self, and [that] with God is all journeys’ end.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3678.mp3","surahId":35,"words":[{"id":21061,"position":1,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/035_018_001.mp3","charTypeName":"word"},{"id":21062,"position":2,"arabic":"تَزِرُ","translation":"বহন করবে","audioUrl":"wbw/035_018_002.mp3","charTypeName":"word"},{"id":21063,"position":3,"arabic":"وَازِرَةٌۭ","translation":"কোনো বহনকারী","audioUrl":"wbw/035_018_003.mp3","charTypeName":"word"},{"id":21064,"position":4,"arabic":"وِزْرَ","translation":"ভার","audioUrl":"wbw/035_018_004.mp3","charTypeName":"word"},{"id":21065,"position":5,"arabic":"أُخْرَىٰ ۚ","translation":"অন্যের","audioUrl":"wbw/035_018_005.mp3","charTypeName":"word"},{"id":21067,"position":6,"arabic":"وَإِن","translation":"এবং যদি","audioUrl":"wbw/035_018_007.mp3","charTypeName":"word"},{"id":21068,"position":7,"arabic":"تَدْعُ","translation":"ডাকে","audioUrl":"wbw/035_018_008.mp3","charTypeName":"word"},{"id":21069,"position":8,"arabic":"مُثْقَلَةٌ","translation":"কোনো বোঝাভারাক্রান্ত ব্যক্তি","audioUrl":"wbw/035_018_009.mp3","charTypeName":"word"},{"id":21070,"position":9,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/035_018_010.mp3","charTypeName":"word"},{"id":21071,"position":10,"arabic":"حِمْلِهَا","translation":"তার বোঝার (তা বইতে)","audioUrl":"wbw/035_018_011.mp3","charTypeName":"word"},{"id":21072,"position":11,"arabic":"لَا","translation":"না","audioUrl":"wbw/035_018_012.mp3","charTypeName":"word"},{"id":21073,"position":12,"arabic":"يُحْمَلْ","translation":"বহন করা হবে","audioUrl":"wbw/035_018_013.mp3","charTypeName":"word"},{"id":21074,"position":13,"arabic":"مِنْهُ","translation":"তার থেকে","audioUrl":"wbw/035_018_014.mp3","charTypeName":"word"},{"id":21075,"position":14,"arabic":"شَىْءٌۭ","translation":"(সামান্য) কিছুও","audioUrl":"wbw/035_018_015.mp3","charTypeName":"word"},{"id":21076,"position":15,"arabic":"وَلَوْ","translation":"এবং যদি","audioUrl":"wbw/035_018_016.mp3","charTypeName":"word"},{"id":21077,"position":16,"arabic":"كَانَ","translation":"সে হয়ও","audioUrl":"wbw/035_018_017.mp3","charTypeName":"word"},{"id":21078,"position":17,"arabic":"ذَا","translation":"আছে","audioUrl":"wbw/035_018_018.mp3","charTypeName":"word"},{"id":21079,"position":18,"arabic":"قُرْبَىٰٓ ۗ","translation":"কোন নিকট আত্মীয়","audioUrl":"wbw/035_018_019.mp3","charTypeName":"word"},{"id":21081,"position":19,"arabic":"إِنَّمَا","translation":"(তাই হে নাবী) কেবল","audioUrl":"wbw/035_018_021.mp3","charTypeName":"word"},{"id":21082,"position":20,"arabic":"تُنذِرُ","translation":"তুমি সতর্ক করো","audioUrl":"wbw/035_018_022.mp3","charTypeName":"word"},{"id":21083,"position":21,"arabic":"ٱلَّذِينَ","translation":"(তাদেরকে) যারা","audioUrl":"wbw/035_018_023.mp3","charTypeName":"word"},{"id":21084,"position":22,"arabic":"يَخْشَوْنَ","translation":"ভয় করে","audioUrl":"wbw/035_018_024.mp3","charTypeName":"word"},{"id":21085,"position":23,"arabic":"رَبَّهُم","translation":"তাদের রবকে","audioUrl":"wbw/035_018_025.mp3","charTypeName":"word"},{"id":21086,"position":24,"arabic":"بِٱلْغَيْبِ","translation":"না দেখা অবস্