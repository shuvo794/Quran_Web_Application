{"id":194,"ayahs":[{"number":41,"arabic":"ٱنفِرُوا۟ خِفَافًۭا وَثِقَالًۭا وَجَٰهِدُوا۟ بِأَمْوَٰلِكُمْ وَأَنفُسِكُمْ فِى سَبِيلِ ٱللَّهِ ۚ ذَٰلِكُمْ خَيْرٌۭ لَّكُمْ إِن كُنتُمْ تَعْلَمُونَ","translation":"Go forth to war, whether it be easy or difficult [for you], and strive hard in God's cause with your possessions and your lives: this is for your own good -if you but knew it!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1276.mp3","surahId":9,"words":[{"id":42135,"position":1,"arabic":"ٱنفِرُوا۟","translation":"তোমরা বের হও","audioUrl":"wbw/009_041_001.mp3","charTypeName":"word"},{"id":42136,"position":2,"arabic":"خِفَافًۭا","translation":"হালকা অবস্থায় (থাকো)","audioUrl":"wbw/009_041_002.mp3","charTypeName":"word"},{"id":42137,"position":3,"arabic":"وَثِقَالًۭا","translation":"কিংবা ভারী অবস্থায়","audioUrl":"wbw/009_041_003.mp3","charTypeName":"word"},{"id":42138,"position":4,"arabic":"وَجَـٰهِدُوا۟","translation":"এবং তোমরা জিহাদ করো","audioUrl":"wbw/009_041_004.mp3","charTypeName":"word"},{"id":42139,"position":5,"arabic":"بِأَمْوَٰلِكُمْ","translation":"দিয়ে ধনসম্পদ তোমাদের","audioUrl":"wbw/009_041_005.mp3","charTypeName":"word"},{"id":42140,"position":6,"arabic":"وَأَنفُسِكُمْ","translation":"ও জান-প্রাণ (দিয়ে) তোমাদের","audioUrl":"wbw/009_041_006.mp3","charTypeName":"word"},{"id":42141,"position":7,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/009_041_007.mp3","charTypeName":"word"},{"id":42142,"position":8,"arabic":"سَبِيلِ","translation":"পথের","audioUrl":"wbw/009_041_008.mp3","charTypeName":"word"},{"id":42143,"position":9,"arabic":"ٱللَّهِ ۚ","translation":"আল্লাহর","audioUrl":"wbw/009_041_009.mp3","charTypeName":"word"},{"id":42145,"position":10,"arabic":"ذَٰلِكُمْ","translation":"(তোমাদের) সেটাই","audioUrl":"wbw/009_041_011.mp3","charTypeName":"word"},{"id":42146,"position":11,"arabic":"خَيْرٌۭ","translation":"উত্তম","audioUrl":"wbw/009_041_012.mp3","charTypeName":"word"},{"id":42147,"position":12,"arabic":"لَّكُمْ","translation":"জন্যে তোমাদের","audioUrl":"wbw/009_041_013.mp3","charTypeName":"word"},{"id":42148,"position":13,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/009_041_014.mp3","charTypeName":"word"},{"id":42149,"position":14,"arabic":"كُنتُمْ","translation":"তোমরা ছিলে","audioUrl":"wbw/009_041_015.mp3","charTypeName":"word"},{"id":42150,"position":15,"arabic":"تَعْلَمُونَ","translation":"জানতে","audioUrl":"wbw/009_041_016.mp3","charTypeName":"word"},{"id":42151,"position":16,"arabic":"٤١","translation":"(৪১)","audioUrl":null,"charTypeName":"end"}]},{"number":42,"arabic":"لَوْ كَانَ عَرَضًۭا قَرِيبًۭا وَسَفَرًۭا قَاصِدًۭا لَّٱتَّبَعُوكَ وَلَٰكِنۢ بَعُدَتْ عَلَيْهِمُ ٱلشُّقَّةُ ۚ وَسَيَحْلِفُونَ بِٱللَّهِ لَوِ ٱسْتَطَعْنَا لَخَرَجْنَا مَعَكُمْ يُهْلِكُونَ أَنفُسَهُمْ وَٱللَّهُ يَعْلَمُ إِنَّهُمْ لَكَٰذِبُونَ","translation":"Had there been [a prospect of] immediate gain, and an easy journey, they would certainly have followed thee, [O Prophet:] but the distance was too great for them. And yet, [after your return, O believers,] they will swear by God, \"Had we been able to do so, we would certainly have set out with you!\" - [and by thus falsely swearing] they will be destroying their own selves: for God knows indeed that they are lying!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1277.mp3","surahId":9,"words":[{"id":43081,"position":1,"arabic":"لَوْ","translation":"যদি","audioUrl":"wbw/009_042_001.mp3","charTypeName":"word"},{"id":43082,"position":2,"arabic":"كَانَ","translation":"হতো","audioUrl":"wbw/009_042_002.mp3","charTypeName":"word"},{"id":43083,"position":3,"arabic":"عَرَضًۭا","translation":"সম্পদ লাভের আশা","audioUrl":"wbw/009_042_003.mp3","charTypeName":"word"},{"id":43084,"position":4,"arabic":"قَرِيبًۭا","translation":"নিকটবর্তী (সহজলভ্য)","audioUrl":"wbw/009_042_004.mp3","charTypeName":"word"},{"id":43085,"position":5,"arabic":"وَسَفَرًۭا","translation":"ও ভ্রমণ","audioUrl":"wbw/009_042_005.mp3","charTypeName":"word"},{"id":43086,"position":6,"arabic":"قَاصِدًۭا","translation":"সুগম","audioUrl":"wbw/009_042_006.mp3","charTypeName":"word"},{"id":43087,"position":7,"arabic":"لَّٱتَّبَعُوكَ","translation":"অবশ্যই তোমাকে তারা অনুসরণ করতো","audioUrl":"wbw/009_042_007.mp3","charTypeName":"word"},{"id":43088,"position":8,"arabic":"وَلَـٰكِنۢ","translation":"কিন্তু","audioUrl":"wbw/009_042_008.mp3","charTypeName":"word"},{"id":43089,"position":9,"arabic":"بَعُدَتْ","translation":"দীর্ঘ লাগলো","audioUrl":"wbw/009_042_009.mp3","charTypeName":"word"},{"id":43090,"position":10,"arabic":"عَلَيْهِمُ","translation":"কাছে তাদের","audioUrl":"wbw/009_042_010.mp3","charTypeName":"word"},{"id":43091,"position":11,"arabic":"ٱلشُّقَّةُ ۚ","translation":"কষ্টসাধ্য যাত্রাপথ","audioUrl":"wbw/009_042_011.mp3","charTypeName":"word"},{"id":43093,"position":12,"arabic":"وَسَيَحْلِفُونَ","translation":"ও (এখন)অচিরেই তারা শপথ করে বলবে","audioUrl":"wbw/009_042_013.mp3","charTypeName":"word"},{"id":43094,"position":13,"arabic":"بِٱللَّهِ","translation":"নামে আল্লাহর","audioUrl":"wbw/009_042_014.mp3","charTypeName":"word"},{"id":43095,"position":14,"arabic":"لَوِ","translation":"\"যদি","audioUrl":"wbw/009_042_015.mp3","charTypeName":"word"},{"id":43096,"position":15,"arabic":"ٱسْتَطَعْنَا","translation":"পারতাম আমরা","audioUrl":"wbw/009_042_016.mp3","charTypeName":"word"},{"id":43097,"position":16,"arabic":"لَخَرَجْنَا","translation":"অবশ্যই বের হতাম আমরা","audioUrl":"wbw/009_042_017.mp3","charTypeName":"word"},{"id":43098,"position":17,"arabic":"مَعَكُمْ","translation":"সাথে তোমাদের\"","audioUrl":"wbw/009_042_018.mp3","charTypeName":"word"},{"id":43099,"position":18,"arabic":"يُهْلِكُونَ","translation":"(আসলে) তারা ধ্বংস করছে","audioUrl":"wbw/009_042_019.mp3","charTypeName":"word"},{"id":43100,"position":19,"arabic":"أَنفُسَهُمْ","translation":"নিজেদেরকে তাদের","audioUrl":"wbw/009_042_020.mp3","charTypeName":"word"},{"id":43101,"position":20,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/009_042_021.mp3","charTypeName":"word"},{"id":43102,"position":21,"arabic":"يَعْلَمُ","translation":"জানেন","audioUrl":"wbw/009_042_022.mp3","charTypeName":"word"},{"id":43103,"position":22,"arabic":"إِنَّهُمْ","translation":"নিশ্চয়ই তারা","audioUrl":"wbw/009_042_023.mp3","charTypeName":"word"},{"id":43104,"position":23,"arabic":"لَكَـٰذِبُونَ","translation":"অবশ্যই মিথ্যাবাদী","audioUrl":"wbw/009_042_024.mp3","charTypeName":"word"},{"id":43105,"position":24,"arabic":"٤٢","translation":"(৪২)","audioUrl":null,"charTypeName":"end"}]},{"number":43,"arabic":"عَفَا ٱللَّهُ عَنكَ لِمَ أَذِنتَ لَهُمْ حَتَّىٰ يَتَبَيَّنَ لَكَ ٱلَّذِينَ صَدَقُوا۟ وَتَعْلَمَ ٱلْكَٰذِبِينَ","translation":"May God pardon thee [O Prophet]! Why didst thou grant them permission [to stay at home] ere it had become obvious to thee as to who was speaking the truth, and [ere] thou camest to know. [who were] the liars?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1278.mp3","surahId":9,"words":[{"id":43664,"position":1,"arabic":"عَفَا","translation":"ক্ষমা করেছেন","audioUrl":"wbw/009_043_001.mp3","charTypeName":"word"},{"id":43665,"position":2,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/009_043_002.mp3","charTypeName":"word"},{"id":43666,"position":3,"arabic":"عَنكَ","translation":"বিষয়কে তোমার","audioUrl":"wbw/009_043_003.mp3","charTypeName":"word"},{"id":43667,"position":4,"arabic":"لِمَ","translation":"কেন","audioUrl":"wbw/009_043_004.mp3","charTypeName":"word"},{"id":43668,"position":5,"arabic":"أَذِنتَ","translation":"অব্যহতি দিলে","audioUrl":"wbw/009_043_005.mp3","charTypeName":"word"},{"id":43669,"position":6,"arabic":"لَهُمْ","translation":"তাদেরকে","audioUrl":"wbw/009_043_006.mp3","charTypeName":"word"},{"id":43670,"position":7,"arabic":"حَتَّىٰ","translation":"যতক্ষণ না","audioUrl":"wbw/009_043_007.mp3","charTypeName":"word"},{"id":43671,"position":8,"arabic":"يَتَبَيَّنَ","translation":"সুস্পষ্ট হয়ে যায়","audioUrl":"wbw/009_043_008.mp3","charTypeName":"word"},{"id":43672,"position":9,"arabic":"لَكَ","translation":"কাছে তোমার","audioUrl":"wbw/009_043_009.mp3","charTypeName":"word"},{"id":43673,"position":10,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/009_043_010.mp3","charTypeName":"word"},{"id":43674,"position":11,"arabic":"صَدَقُوا۟","translation":"সত্য বলেছে","audioUrl":"wbw/009_043_011.mp3","charTypeName":"word"},{"id":43675,"position":12,"arabic":"وَتَعْلَمَ","translation":"ও তুমি জানতে পারো","audioUrl":"wbw/009_043_012.mp3","charTypeName":"word"},{"id":43676,"position":13,"arabic":"ٱلْكَـٰذِبِينَ","translation":"মিথ্যাবাদীদেরকে","audioUrl":"wbw/009_043_013.mp3","charTypeName":"word"},{"id":43677,"position":14,"arabic":"٤٣","translation":"(৪৩)","audioUrl":null,"charTypeName":"end"}]},{"number":44,"arabic":"لَا يَسْتَـْٔذِنُكَ ٱلَّذِينَ يُؤْمِنُونَ بِٱللَّهِ وَٱلْيَوْمِ ٱلْءَاخِرِ أَن يُجَٰهِدُوا۟ بِأَمْوَٰلِهِمْ وَأَنفُسِهِمْ ۗ وَٱللَّهُ عَلِيمٌۢ بِٱلْمُتَّقِينَ","translation":"Those who [truly] believe in God and the Last Day do not ask thee for exemption from struggling with their possessions and their lives [in God's cause]-and God has full knowledge as to who is conscious of Him-:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1279.mp3","surahId":9,"words":[{"id":44426,"position":1,"arabic":"لَا","translation":"না","audioUrl":"wbw/009_044_001.mp3","charTypeName":"word"},{"id":44427,"position":2,"arabic":"يَسْتَـْٔذِنُكَ","translation":"তোমার কাছে অব্যহতি চায়","audioUrl":"wbw/009_044_002.mp3","charTypeName":"word"},{"id":44428,"position":3,"arabic":"ٱلَّذِينَ","translation":"(তারা) যারা","audioUrl":"wbw/009_044_003.mp3","charTypeName":"word"},{"id":44429,"position":4,"arabic":"يُؤْمِنُونَ","translation":"ঈমান আনে","audioUrl":"wbw/009_044_004.mp3","charTypeName":"word"},{"id":44430,"position":5,"arabic":"بِٱللَّهِ","translation":"উপর আল্লাহর","audioUrl":"wbw/009_044_005.mp3","charTypeName":"word"},{"id":44431,"position":6,"arabic":"وَٱلْيَوْمِ","translation":"ও দিনে","audioUrl":"wbw/009_044_006.mp3","charTypeName":"word"},{"id":44432,"position":7,"arabic":"ٱلْـَٔاخِرِ","translation":"আখেরাতের (উপর)","audioUrl":"wbw/009_044_007.mp3","charTypeName":"word"},{"id":44433,"position":8,"arabic":"أَن","translation":"যে","audioUrl":"wbw/009_044_008.mp3","charTypeName":"word"},{"id":44434,"position":9,"arabic":"يُجَـٰهِدُوا۟","translation":"তারা জিহাদ করবে (না)","audioUrl":"wbw/009_044_009.mp3","charTypeName":"word"},{"id":44435,"position":10,"arabic":"بِأَمْوَٰلِهِمْ","translation":"দিয়ে ধনসম্পদ তাদের","audioUrl":"wbw/009_044_010.mp3","charTypeName":"word"},{"id":44436,"position":11,"arabic":"وَأَنفُسِهِمْ ۗ","translation":"ও জান-প্রাণ তাদের (দিয়ে)","audioUrl":"wbw/009_044_011.mp3","charTypeName":"word"},{"id":44438,"position":12,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/009_044_013.mp3","charTypeName":"word"},{"id":44439,"position":13,"arabic":"عَلِيمٌۢ","translation":"খুব জানেন","audioUrl":"wbw/009_044_014.mp3","charTypeName":"word"},{"id":44440,"position":14,"arabic":"بِٱلْمُتَّقِينَ","translation":"সম্পর্কে মুত্তাকীদের","audioUrl":"wbw/009_044_015.mp3","charTypeName":"word"},{"id":44441,"position":15,"arabic":"٤٤","translation":"(৪৪)","audioUrl":null,"charTypeName":"end"}]},{"number":45,"arabic":"إِنَّمَا يَسْتَـْٔذِنُكَ ٱلَّذِينَ لَا يُؤْمِنُونَ بِٱللَّهِ وَٱلْيَوْمِ ٱلْءَاخِرِ وَٱرْتَابَتْ قُلُوبُهُمْ فَهُمْ فِى رَيْبِهِمْ يَتَرَدَّدُونَ","translation":"only those ask thee for exemption who do not [truly] believe in God and the Last Day and whose hearts have become a prey to doubt, so that in their doubting they waver between one thing and another.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1280.mp3","surahId":9,"words":[{"id":45212,"position":1,"arabic":"إِنَّمَا","translation":"প্রকৃতপক্ষে","audioUrl":"wbw/009_045_001.mp3","charTypeName":"word"},{"id":45213,"position":2,"arabic":"يَسْتَـْٔذِنُكَ","translation":"তোমার কাছে অব্যহতি চায়","audioUrl":"wbw/009_045_002.mp3","charTypeName":"word"},{"id":45214,"position":3,"arabic":"ٱلَّذِينَ","translation":"(তারাই) যারা","audioUrl":"wbw/009_045_003.mp3","charTypeName":"word"},{"id":45215,"position":4,"arabic":"لَا","translation":"না","audioUrl":"wbw/009_045_004.mp3","charTypeName":"word"},{"id":45216,"position":5,"arabic":"يُؤْمِنُونَ","translation":"ঈমান আনে","audioUrl":"wbw/009_045_005.mp3","charTypeName":"word"},{"id":45217,"position":6,"arabic":"بِٱللَّهِ","translation":"উপর আল্লাহর","audioUrl":"wbw/009_045_006.mp3","charTypeName":"word"},{"id":45218,"position":7,"arabic":"وَٱلْيَوْمِ","translation":"ও দিনে","audioUrl":"wbw/009_045_007.mp3","charTypeName":"word"},{"id":45219,"position":8,"arabic":"ٱلْـَٔاخِرِ","translation":"আখেরাতের (উপর)","audioUrl":"wbw/009_045_008.mp3","charTypeName":"word"},{"id":45220,"position":9,"arabic":"وَٱرْتَابَتْ","translation":"এবং সন্দেহে পড়েছে","audioUrl":"wbw/009_045_009.mp3","charTypeName":"word"},{"id":45221,"position":10,"arabic":"قُلُوبُهُمْ","translation":"অন্তর তাদের","audioUrl":"wbw/009_045_010.mp3","charTypeName":"word"},{"id":45222,"position":11,"arabic":"فَهُمْ","translation":"তাই তারা","audioUrl":"wbw/009_045_011.mp3","charTypeName":"word"},{"id":45223,"position":12,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/009_045_012.mp3","charTypeName":"word"},{"id":45224,"position":13,"arabic":"رَيْبِهِمْ","translation":"সন্দেহের তাদের","audioUrl":"wbw/009_045_013.mp3","charTypeName":"word"},{"id":45225,"position":14,"arabic":"يَتَرَدَّدُونَ","translation":"তারা দ্বিধাগ্রস্ত হচ্ছে","audioUrl":"wbw/009_045_014.mp3","charTypeName":"word"},{"id":45226,"position":15,"arabic":"٤٥","translation":"(৪৫)","audioUrl":null,"charTypeName":"end"}]},{"number":46,"arabic":"۞ وَلَوْ أَرَادُوا۟ ٱلْخُرُوجَ لَأَعَدُّوا۟ لَهُۥ عُدَّةًۭ وَلَٰكِن كَرِهَ ٱللَّهُ ٱنۢبِعَاثَهُمْ فَثَبَّطَهُمْ وَقِيلَ ٱقْعُدُوا۟ مَعَ ٱلْقَٰعِدِينَ","translation":"For, had they been [truly] desirous of setting out [with thee], they would surely have made some preparation therefor: but God was averse to their taking the field, and so He caused them to hold back when it was said, \"[You may] stay at home with all [the others] who stay at home.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1281.mp3","surahId":9,"words":[{"id":45906,"position":1,"arabic":"۞ وَلَوْ","translation":"এবং যদি","audioUrl":"wbw/009_046_002.mp3","charTypeName":"word"},{"id":45907,"position":2,"arabic":"أَرَادُوا۟","translation":"তারা ইচ্ছা করতো","audioUrl":"wbw/009_046_003.mp3","charTypeName":"word"},{"id":45908,"position":3,"arabic":"ٱلْخُرُوجَ","translation":"বের হওয়ার","audioUrl":"wbw/009_046_004.mp3","charTypeName":"word"},{"id":45909,"position":4,"arabic":"لَأَعَدُّوا۟","translation":"তারা অবশ্যই প্রস্তুতি নিতো","audioUrl":"wbw/009_046_005.mp3","charTypeName":"word"},{"id":45910,"position":5,"arabic":"لَهُۥ","translation":"জন্যে তার","audioUrl":"wbw/009_046_006.mp3","charTypeName":"word"},{"id":45911,"position":6,"arabic":"عُدَّةًۭ","translation":"প্রস্তুতি (যথাযথ)","audioUrl":"wbw/009_046_007.mp3","charTypeName":"word"},{"id":45912,"position":7,"arabic":"وَلَـٰكِن","translation":"কিন্তু","audioUrl":"wbw/009_046_008.mp3","charTypeName":"word"},{"id":45913,"position":8,"arabic":"كَرِهَ","translation":"অপছন্দ করেছেন","audioUrl":"wbw/009_046_009.mp3","charTypeName":"word"},{"id":45914,"position":9,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/009_046_010.mp3","charTypeName":"word"},{"id":45915,"position":10,"arabic":"ٱنۢبِعَاثَهُمْ","translation":"অভিযাত্রা তাদের","audioUrl":"wbw/009_046_011.mp3","charTypeName":"word"},{"id":45916,"position":11,"arabic":"فَثَبَّطَهُمْ","translation":"অতঃপর বিরত রাখলেন তাদেরকে","audioUrl":"wbw/009_046_012.mp3","charTypeName":"word"},{"id":45917,"position":12,"arabic":"وَقِيلَ","translation":"এবং বলা হলো","audioUrl":"wbw/009_046_013.mp3","charTypeName":"word"},{"id":45918,"position":13,"arabic":"ٱقْعُدُوا۟","translation":"\"তোমরা বসে থাকো","audioUrl":"wbw/009_046_014.mp3","charTypeName":"word"},{"id":45919,"position":14,"arabic":"مَعَ","translation":"সাথে","audioUrl":"wbw/009_046_015.mp3","charTypeName":"word"},{"id":45920,"position":15,"arabic":"ٱلْقَـٰعِدِينَ","translation":"বসে থাকা লোকদের\"","audioUrl":"wbw/009_046_016.mp3","charTypeName":"word"},{"id":45921,"position":16,"arabic":"٤٦","translation":"(৪৬)","audioUrl":null,"charTypeName":"end"}]},{"number":47,"arabic":"لَوْ خَرَجُوا۟ فِيكُم مَّا زَادُوكُمْ إِلَّا خَبَالًۭا وَلَأَوْضَعُوا۟ خِلَٰلَكُمْ يَبْغُونَكُمُ ٱلْفِتْنَةَ وَفِيكُمْ سَمَّٰعُونَ لَهُمْ ۗ وَٱللَّهُ عَلِيمٌۢ بِٱلظَّٰلِمِينَ","translation":"Had these [hypocrites] set out with_ you, [O believers,] they would have added nothing to you save the evil of corruption, and would surely have scurried to and fro in your midst, seeking to stir up discord among you, seeing that there are in your midst such as would have lent them ear: but God has full knowledge of the evildoers.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1282.mp3","surahId":9,"words":[{"id":46552,"position":1,"arabic":"لَوْ","translation":"যদি","audioUrl":"wbw/009_047_001.mp3","charTypeName":"word"},{"id":46553,"position":2,"arabic":"خَرَجُوا۟","translation":"তারা বের হতো","audioUrl":"wbw/009_047_002.mp3","charTypeName":"word"},{"id":46554,"position":3,"arabic":"فِيكُم","translation":"মধ্যে তোমাদের","audioUrl":"wbw/009_047_003.mp3","charTypeName":"word"},{"id":46555,"position":4,"arabic":"مَّا","translation":"না","audioUrl":"wbw/009_047_004.mp3","charTypeName":"word"},{"id":46556,"position":5,"arabic":"زَادُوكُمْ","translation":"তোমাদের মধ্যে বাড়াতো (আর কিছু)","audioUrl":"wbw/009_047_005.mp3","charTypeName":"word"},{"id":46557,"position":6,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/009_047_006.mp3","charTypeName":"word"},{"id":46558,"position":7,"arabic":"خَبَالًۭا","translation":"বিভ্রান্তি","audioUrl":"wbw/009_047_007.mp3","charTypeName":"word"},{"id":46559,"position":8,"arabic":"وَلَأَوْضَعُوا۟","translation":"এবং অবশ্যই তারা ঘোড়া দৌড়াতো (ছুটাছুটি করতো)","audioUrl":"wbw/009_047_008.mp3","charTypeName":"word"},{"id":46560,"position":9,"arabic":"خِلَـٰلَكُمْ","translation":"মাঝে তোমাদের","audioUrl":"wbw/009_047_009.mp3","charTypeName":"word"},{"id":46561,"position":10,"arabic":"يَبْغُونَكُمُ","translation":"তোমাদের মধ্যে তারা চাইতো","audioUrl":"wbw/009_047_010.mp3","charTypeName":"word"},{"id":46562,"position":11,"arabic":"ٱلْفِتْنَةَ","translation":"বিপর্যয় (সৃষ্টি করতে)","audioUrl":"wbw/009_047_011.mp3","charTypeName":"word"},{"id":46563,"position":12,"arabic":"وَفِيكُمْ","translation":"এবং মধ্যে তোমাদের (আছে)","audioUrl":"wbw/009_047_012.mp3","charTypeName":"word"},{"id":46564,"position":13,"arabic":"سَمَّـٰعُونَ","translation":"গুপ্তচর (কান দেয়ার লোক)","audioUrl":"wbw/009_047_013.mp3","charTypeName":"word"},{"id":46565,"position":14,"arabic":"لَهُمْ ۗ","translation":"জন্যে তাদের","audioUrl":"wbw/009_047_014.mp3","charTypeName":"word"},{"id":46567,"position":15,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/009_047_016.mp3","charTypeName":"word"},{"id":46568,"position":16,"arabic":"عَلِيمٌۢ","translation":"খুব জানেন","audioUrl":"wbw/009_047_017.mp3","charTypeName":"word"},{"id":46569,"position":17,"arabic":"بِٱلظَّـٰلِمِينَ","translation":"সম্পর্কে সীমালঙ্ঘনকারীদের","audioUrl":"wbw/009_047_018.mp3","charTypeName":"word"},{"id":46570,"position":18,"arabic":"٤٧","translation":"(৪৭)","audioUrl":null,"charTypeName":"end"}]}]}