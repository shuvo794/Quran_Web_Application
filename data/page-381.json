{"id":381,"ayahs":[{"number":45,"arabic":"وَلَقَدْ أَرْسَلْنَآ إِلَىٰ ثَمُودَ أَخَاهُمْ صَٰلِحًا أَنِ ٱعْبُدُوا۟ ٱللَّهَ فَإِذَا هُمْ فَرِيقَانِ يَخْتَصِمُونَ","translation":"AND [likewise], indeed, We sent unto [the tribe of] Thamud their brother Salih [with this message]: “Worship God alone!” and, behold, they were [split into] two factions contending with one another.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3204.mp3","surahId":27,"words":[{"id":45320,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/027_045_001.mp3","charTypeName":"word"},{"id":45321,"position":2,"arabic":"أَرْسَلْنَآ","translation":"প্রেরণ করেছিলাম আমরা","audioUrl":"wbw/027_045_002.mp3","charTypeName":"word"},{"id":45322,"position":3,"arabic":"إِلَىٰ","translation":"প্রতি","audioUrl":"wbw/027_045_003.mp3","charTypeName":"word"},{"id":45323,"position":4,"arabic":"ثَمُودَ","translation":"সামূদের","audioUrl":"wbw/027_045_004.mp3","charTypeName":"word"},{"id":45324,"position":5,"arabic":"أَخَاهُمْ","translation":"ভাই তাদেরই","audioUrl":"wbw/027_045_005.mp3","charTypeName":"word"},{"id":45325,"position":6,"arabic":"صَـٰلِحًا","translation":"সালেহকে","audioUrl":"wbw/027_045_006.mp3","charTypeName":"word"},{"id":45326,"position":7,"arabic":"أَنِ","translation":"(এ বার্তাসহ) যে","audioUrl":"wbw/027_045_007.mp3","charTypeName":"word"},{"id":45327,"position":8,"arabic":"ٱعْبُدُوا۟","translation":"\"তোমরা ইবাদত করো","audioUrl":"wbw/027_045_008.mp3","charTypeName":"word"},{"id":45328,"position":9,"arabic":"ٱللَّهَ","translation":"আল্লাহর\"","audioUrl":"wbw/027_045_009.mp3","charTypeName":"word"},{"id":45329,"position":10,"arabic":"فَإِذَا","translation":"অতঃপর তখন","audioUrl":"wbw/027_045_010.mp3","charTypeName":"word"},{"id":45330,"position":11,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/027_045_011.mp3","charTypeName":"word"},{"id":45331,"position":12,"arabic":"فَرِيقَانِ","translation":"দু'দলে","audioUrl":"wbw/027_045_012.mp3","charTypeName":"word"},{"id":45332,"position":13,"arabic":"يَخْتَصِمُونَ","translation":"তর্কে মেতে উঠলো","audioUrl":"wbw/027_045_013.mp3","charTypeName":"word"},{"id":45333,"position":14,"arabic":"٤٥","translation":"(৪৫)","audioUrl":null,"charTypeName":"end"}]},{"number":46,"arabic":"قَالَ يَٰقَوْمِ لِمَ تَسْتَعْجِلُونَ بِٱلسَّيِّئَةِ قَبْلَ ٱلْحَسَنَةِ ۖ لَوْلَا تَسْتَغْفِرُونَ ٱللَّهَ لَعَلَّكُمْ تُرْحَمُونَ","translation":"Said [Salih to the erring ones]: Why do you seek to hasten the coming upon you of evil instead of hoping for the good?” Why do you not, rather, ask God to forgive you your sins, so that you might be graced with His mercy?”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3205.mp3","surahId":27,"words":[{"id":46056,"position":1,"arabic":"قَالَ","translation":"(সালেহ) বললো","audioUrl":"wbw/027_046_001.mp3","charTypeName":"word"},{"id":46057,"position":2,"arabic":"يَـٰقَوْمِ","translation":"\"হে আমার জাতি","audioUrl":"wbw/027_046_002.mp3","charTypeName":"word"},{"id":46058,"position":3,"arabic":"لِمَ","translation":"কেন","audioUrl":"wbw/027_046_003.mp3","charTypeName":"word"},{"id":46059,"position":4,"arabic":"تَسْتَعْجِلُونَ","translation":"তোমরা তাড়াতাড়ি করতে চাচ্ছো","audioUrl":"wbw/027_046_004.mp3","charTypeName":"word"},{"id":46060,"position":5,"arabic":"بِٱلسَّيِّئَةِ","translation":"অকল্যাণকে","audioUrl":"wbw/027_046_005.mp3","charTypeName":"word"},{"id":46061,"position":6,"arabic":"قَبْلَ","translation":"পূর্বে","audioUrl":"wbw/027_046_006.mp3","charTypeName":"word"},{"id":46062,"position":7,"arabic":"ٱلْحَسَنَةِ ۖ","translation":"কল্যাণের","audioUrl":"wbw/027_046_007.mp3","charTypeName":"word"},{"id":46064,"position":8,"arabic":"لَوْلَا","translation":"কেন না","audioUrl":"wbw/027_046_009.mp3","charTypeName":"word"},{"id":46065,"position":9,"arabic":"تَسْتَغْفِرُونَ","translation":"তোমরা ক্ষমা চাচ্ছো","audioUrl":"wbw/027_046_010.mp3","charTypeName":"word"},{"id":46066,"position":10,"arabic":"ٱللَّهَ","translation":"আল্লাহর (নিকট)","audioUrl":"wbw/027_046_011.mp3","charTypeName":"word"},{"id":46067,"position":11,"arabic":"لَعَلَّكُمْ","translation":"হয়তো তোমাদের (প্রতি)","audioUrl":"wbw/027_046_012.mp3","charTypeName":"word"},{"id":46068,"position":12,"arabic":"تُرْحَمُونَ","translation":"করুণা করা হবে\"","audioUrl":"wbw/027_046_013.mp3","charTypeName":"word"},{"id":46069,"position":13,"arabic":"٤٦","translation":"(৪৬)","audioUrl":null,"charTypeName":"end"}]},{"number":47,"arabic":"قَالُوا۟ ٱطَّيَّرْنَا بِكَ وَبِمَن مَّعَكَ ۚ قَالَ طَٰٓئِرُكُمْ عِندَ ٱللَّهِ ۖ بَلْ أَنتُمْ قَوْمٌۭ تُفْتَنُونَ","translation":"They answered: “We augur evil from thee and those that follow thee!” Said he: “Your destiny, good or evil, rests with God yea, you are people undergoing a test!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3206.mp3","surahId":27,"words":[{"id":46650,"position":1,"arabic":"قَالُوا۟","translation":"তারা বললো","audioUrl":"wbw/027_047_001.mp3","charTypeName":"word"},{"id":46651,"position":2,"arabic":"ٱطَّيَّرْنَا","translation":"\"আমরা অমঙ্গল ভাবছি","audioUrl":"wbw/027_047_002.mp3","charTypeName":"word"},{"id":46652,"position":3,"arabic":"بِكَ","translation":"\"বিষয়টি তোমার","audioUrl":"wbw/027_047_003.mp3","charTypeName":"word"},{"id":46653,"position":4,"arabic":"وَبِمَن","translation":"ও বিষয়টি তাদের (যারা)","audioUrl":"wbw/027_047_004.mp3","charTypeName":"word"},{"id":46654,"position":5,"arabic":"مَّعَكَ ۚ","translation":"তোমার সাথে (আছে)\"","audioUrl":"wbw/027_047_005.mp3","charTypeName":"word"},{"id":46656,"position":6,"arabic":"قَالَ","translation":"(সালেহ) বললো","audioUrl":"wbw/027_047_007.mp3","charTypeName":"word"},{"id":46657,"position":7,"arabic":"طَـٰٓئِرُكُمْ","translation":"\"তোমাদের শুভাশুভ","audioUrl":"wbw/027_047_008.mp3","charTypeName":"word"},{"id":46658,"position":8,"arabic":"عِندَ","translation":"নিকট","audioUrl":"wbw/027_047_009.mp3","charTypeName":"word"},{"id":46659,"position":9,"arabic":"ٱللَّهِ ۖ","translation":"আল্লাহর","audioUrl":"wbw/027_047_010.mp3","charTypeName":"word"},{"id":46661,"position":10,"arabic":"بَلْ","translation":"বরং","audioUrl":"wbw/027_047_012.mp3","charTypeName":"word"},{"id":46662,"position":11,"arabic":"أَنتُمْ","translation":"তোমরা","audioUrl":"wbw/027_047_013.mp3","charTypeName":"word"},{"id":46663,"position":12,"arabic":"قَوْمٌۭ","translation":"(এমন) লোক","audioUrl":"wbw/027_047_014.mp3","charTypeName":"word"},{"id":46664,"position":13,"arabic":"تُفْتَنُونَ","translation":"পরীক্ষা করা হচ্ছে (যাদেরকে)\"","audioUrl":"wbw/027_047_015.mp3","charTypeName":"word"},{"id":46665,"position":14,"arabic":"٤٧","translation":"(৪৭)","audioUrl":null,"charTypeName":"end"}]},{"number":48,"arabic":"وَكَانَ فِى ٱلْمَدِينَةِ تِسْعَةُ رَهْطٍۢ يُفْسِدُونَ فِى ٱلْأَرْضِ وَلَا يُصْلِحُونَ","translation":"Now there were in the city nine men who were wont to commit deeds of depravity all over the land, and would not reform;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3207.mp3","surahId":27,"words":[{"id":47466,"position":1,"arabic":"وَكَانَ","translation":"এবং ছিলো","audioUrl":"wbw/027_048_001.mp3","charTypeName":"word"},{"id":47467,"position":2,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/027_048_002.mp3","charTypeName":"word"},{"id":47468,"position":3,"arabic":"ٱلْمَدِينَةِ","translation":"শহরের","audioUrl":"wbw/027_048_003.mp3","charTypeName":"word"},{"id":47469,"position":4,"arabic":"تِسْعَةُ","translation":"নয় (জনের)","audioUrl":"wbw/027_048_004.mp3","charTypeName":"word"},{"id":47470,"position":5,"arabic":"رَهْطٍۢ","translation":"একটি দল","audioUrl":"wbw/027_048_005.mp3","charTypeName":"word"},{"id":47471,"position":6,"arabic":"يُفْسِدُونَ","translation":"তারা বিপর্যয় সৃষ্টি করতো","audioUrl":"wbw/027_048_006.mp3","charTypeName":"word"},{"id":47472,"position":7,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/027_048_007.mp3","charTypeName":"word"},{"id":47473,"position":8,"arabic":"ٱلْأَرْضِ","translation":"দেশের","audioUrl":"wbw/027_048_008.mp3","charTypeName":"word"},{"id":47474,"position":9,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/027_048_009.mp3","charTypeName":"word"},{"id":47475,"position":10,"arabic":"يُصْلِحُونَ","translation":"তারা সংশোধনমূলক কাজ করতো","audioUrl":"wbw/027_048_010.mp3","charTypeName":"word"},{"id":47476,"position":11,"arabic":"٤٨","translation":"(৪৮)","audioUrl":null,"charTypeName":"end"}]},{"number":49,"arabic":"قَالُوا۟ تَقَاسَمُوا۟ بِٱللَّهِ لَنُبَيِّتَنَّهُۥ وَأَهْلَهُۥ ثُمَّ لَنَقُولَنَّ لِوَلِيِّهِۦ مَا شَهِدْنَا مَهْلِكَ أَهْلِهِۦ وَإِنَّا لَصَٰدِقُونَ","translation":"[and] after having bound one another by an oath in God’s name, they said: “Indeed, we shall suddenly fall upon him and his household by night [and slay them all]; and then we shall boldly say to his next of kin, ‘We did not witness the destruction of his household - and, behold, we are indeed men of truth!’”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3208.mp3","surahId":27,"words":[{"id":48142,"position":1,"arabic":"قَالُوا۟","translation":"তারা বললো","audioUrl":"wbw/027_049_001.mp3","charTypeName":"word"},{"id":48143,"position":2,"arabic":"تَقَاسَمُوا۟","translation":"\"তোমরা শপথ করো পরস্পরে","audioUrl":"wbw/027_049_002.mp3","charTypeName":"word"},{"id":48144,"position":3,"arabic":"بِٱللَّهِ","translation":"নামে আল্লাহর","audioUrl":"wbw/027_049_003.mp3","charTypeName":"word"},{"id":48145,"position":4,"arabic":"لَنُبَيِّتَنَّهُۥ","translation":"অবশ্যই আমরা তাকে রাতে আক্রমণ করবোই","audioUrl":"wbw/027_049_004.mp3","charTypeName":"word"},{"id":48146,"position":5,"arabic":"وَأَهْلَهُۥ","translation":"ও তার পরিবারকে","audioUrl":"wbw/027_049_005.mp3","charTypeName":"word"},{"id":48147,"position":6,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/027_049_006.mp3","charTypeName":"word"},{"id":48148,"position":7,"arabic":"لَنَقُولَنَّ","translation":"অবশ্যই বলবো আমরা","audioUrl":"wbw/027_049_007.mp3","charTypeName":"word"},{"id":48149,"position":8,"arabic":"لِوَلِيِّهِۦ","translation":"প্রতি তার অভিভাবকের","audioUrl":"wbw/027_049_008.mp3","charTypeName":"word"},{"id":48150,"position":9,"arabic":"مَا","translation":"\"না","audioUrl":"wbw/027_049_009.mp3","charTypeName":"word"},{"id":48151,"position":10,"arabic":"شَهِدْنَا","translation":"উপস্থিত ছিলাম আমরা","audioUrl":"wbw/027_049_010.mp3","charTypeName":"word"},{"id":48152,"position":11,"arabic":"مَهْلِكَ","translation":"ধ্বংসের সময়","audioUrl":"wbw/027_049_011.mp3","charTypeName":"word"},{"id":48153,"position":12,"arabic":"أَهْلِهِۦ","translation":"তার পরিবারের","audioUrl":"wbw/027_049_012.mp3","charTypeName":"word"},{"id":48154,"position":13,"arabic":"وَإِنَّا","translation":"আর নিশ্চয়ই আমরা","audioUrl":"wbw/027_049_013.mp3","charTypeName":"word"},{"id":48155,"position":14,"arabic":"لَصَـٰدِقُونَ","translation":"অবশ্যই সত্যবাদী\"","audioUrl":"wbw/027_049_014.mp3","charTypeName":"word"},{"id":48156,"position":15,"arabic":"٤٩","translation":"(৪৯)","audioUrl":null,"charTypeName":"end"}]},{"number":50,"arabic":"وَمَكَرُوا۟ مَكْرًۭا وَمَكَرْنَا مَكْرًۭا وَهُمْ لَا يَشْعُرُونَ","translation":"And so they devised an evil scheme; but We devised a subtle scheme (of Our own), and they perceived it not.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3209.mp3","surahId":27,"words":[{"id":48826,"position":1,"arabic":"وَمَكَرُوا۟","translation":"এবং তারা ষড়যন্ত্র করলো","audioUrl":"wbw/027_050_001.mp3","charTypeName":"word"},{"id":48827,"position":2,"arabic":"مَكْرًۭا","translation":"এক ষড়যন্ত্র","audioUrl":"wbw/027_050_002.mp3","charTypeName":"word"},{"id":48828,"position":3,"arabic":"وَمَكَرْنَا","translation":"আর আমরা কৌশল করলাম","audioUrl":"wbw/027_050_003.mp3","charTypeName":"word"},{"id":48829,"position":4,"arabic":"مَكْرًۭا","translation":"এক কৌশল","audioUrl":"wbw/027_050_004.mp3","charTypeName":"word"},{"id":48830,"position":5,"arabic":"وَهُمْ","translation":"অথচ তারা","audioUrl":"wbw/027_050_005.mp3","charTypeName":"word"},{"id":48831,"position":6,"arabic":"لَا","translation":"না","audioUrl":"wbw/027_050_006.mp3","charTypeName":"word"},{"id":48832,"position":7,"arabic":"يَشْعُرُونَ","translation":"অনুভব করলো","audioUrl":"wbw/027_050_007.mp3","charTypeName":"word"},{"id":48833,"position":8,"arabic":"٥٠","translation":"(৫০)","audioUrl":null,"charTypeName":"end"}]},{"number":51,"arabic":"فَٱنظُرْ كَيْفَ كَانَ عَٰقِبَةُ مَكْرِهِمْ أَنَّا دَمَّرْنَٰهُمْ وَقَوْمَهُمْ أَجْمَعِينَ","translation":"Behold, then, what all their scheming came to in the end: We utterly destroyed them and their people, all of them;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3210.mp3","surahId":27,"words":[{"id":49298,"position":1,"arabic":"فَٱنظُرْ","translation":"অতঃপর লক্ষ্য করো","audioUrl":"wbw/027_051_001.mp3","charTypeName":"word"},{"id":49299,"position":2,"arabic":"كَيْفَ","translation":"কেমন","audioUrl":"wbw/027_051_002.mp3","charTypeName":"word"},{"id":49300,"position":3,"arabic":"كَانَ","translation":"হয়েছিলো","audioUrl":"wbw/027_051_003.mp3","charTypeName":"word"},{"id":49301,"position":4,"arabic":"عَـٰقِبَةُ","translation":"পরিণাম","audioUrl":"wbw/027_051_004.mp3","charTypeName":"word"},{"id":49302,"position":5,"arabic":"مَكْرِهِمْ","translation":"ষড়যন্ত্রের তাদের","audioUrl":"wbw/027_051_005.mp3","charTypeName":"word"},{"id":49303,"position":6,"arabic":"أَنَّا","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/027_051_006.mp3","charTypeName":"word"},{"id":49304,"position":7,"arabic":"دَمَّرْنَـٰهُمْ","translation":"আমরা ধ্বংস করেছি তাদেরকে","audioUrl":"wbw/027_051_007.mp3","charTypeName":"word"},{"id":49305,"position":8,"arabic":"وَقَوْمَهُمْ","translation":"ও জাতির তাদের","audioUrl":"wbw/027_051_008.mp3","charTypeName":"word"},{"id":49306,"position":9,"arabic":"أَجْمَعِينَ","translation":"সবাইকে","audioUrl":"wbw/027_051_009.mp3","charTypeName":"word"},{"id":49307,"position":10,"arabic":"٥١","translation":"(৫১)","audioUrl":null,"charTypeName":"end"}]},{"number":52,"arabic":"فَتِلْكَ بُيُوتُهُمْ خَاوِيَةًۢ بِمَا ظَلَمُوٓا۟ ۗ إِنَّ فِى ذَٰلِكَ لَءَايَةًۭ لِّقَوْم