{"id":207,"ayahs":[{"number":123,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ قَٰتِلُوا۟ ٱلَّذِينَ يَلُونَكُم مِّنَ ٱلْكُفَّارِ وَلْيَجِدُوا۟ فِيكُمْ غِلْظَةًۭ ۚ وَٱعْلَمُوٓا۟ أَنَّ ٱللَّهَ مَعَ ٱلْمُتَّقِينَ","translation":"O you who have attained to faith! Fight against those deniers of the truth who are near you, and let them find you adamant; and know that. God is with those who are conscious of Him.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1358.mp3","surahId":9,"words":[{"id":76884,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/009_123_001.mp3","charTypeName":"word"},{"id":76885,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/009_123_002.mp3","charTypeName":"word"},{"id":76886,"position":3,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছো","audioUrl":"wbw/009_123_003.mp3","charTypeName":"word"},{"id":76887,"position":4,"arabic":"قَـٰتِلُوا۟","translation":"তোমরা যুদ্ধ করো","audioUrl":"wbw/009_123_004.mp3","charTypeName":"word"},{"id":76888,"position":5,"arabic":"ٱلَّذِينَ","translation":"(তাদের বিরুদ্ধে) যারা","audioUrl":"wbw/009_123_005.mp3","charTypeName":"word"},{"id":76889,"position":6,"arabic":"يَلُونَكُم","translation":"কাছাকাছি আছে তোমাদের","audioUrl":"wbw/009_123_006.mp3","charTypeName":"word"},{"id":76890,"position":7,"arabic":"مِّنَ","translation":"মধ্যে হতে","audioUrl":"wbw/009_123_007.mp3","charTypeName":"word"},{"id":76891,"position":8,"arabic":"ٱلْكُفَّارِ","translation":"কাফেরদের","audioUrl":"wbw/009_123_008.mp3","charTypeName":"word"},{"id":76892,"position":9,"arabic":"وَلْيَجِدُوا۟","translation":"ও যেন তারা পায়","audioUrl":"wbw/009_123_009.mp3","charTypeName":"word"},{"id":76893,"position":10,"arabic":"فِيكُمْ","translation":"মধ্যে তোমাদের","audioUrl":"wbw/009_123_010.mp3","charTypeName":"word"},{"id":76894,"position":11,"arabic":"غِلْظَةًۭ ۚ","translation":"কঠোরতা","audioUrl":"wbw/009_123_011.mp3","charTypeName":"word"},{"id":76896,"position":12,"arabic":"وَٱعْلَمُوٓا۟","translation":"এবং তোমরা জেনে রাখো","audioUrl":"wbw/009_123_013.mp3","charTypeName":"word"},{"id":76897,"position":13,"arabic":"أَنَّ","translation":"যে","audioUrl":"wbw/009_123_014.mp3","charTypeName":"word"},{"id":76898,"position":14,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/009_123_015.mp3","charTypeName":"word"},{"id":76899,"position":15,"arabic":"مَعَ","translation":"সাথে (আছেন)","audioUrl":"wbw/009_123_016.mp3","charTypeName":"word"},{"id":76900,"position":16,"arabic":"ٱلْمُتَّقِينَ","translation":"মুত্তাকীদের","audioUrl":"wbw/009_123_017.mp3","charTypeName":"word"},{"id":76901,"position":17,"arabic":"١٢٣","translation":"(১২৩)","audioUrl":null,"charTypeName":"end"}]},{"number":124,"arabic":"وَإِذَا مَآ أُنزِلَتْ سُورَةٌۭ فَمِنْهُم مَّن يَقُولُ أَيُّكُمْ زَادَتْهُ هَٰذِهِۦٓ إِيمَٰنًۭا ۚ فَأَمَّا ٱلَّذِينَ ءَامَنُوا۟ فَزَادَتْهُمْ إِيمَٰنًۭا وَهُمْ يَسْتَبْشِرُونَ","translation":"YET WHENEVER a surah [of this divine writ] is bestowed from on high, some of the deniers of the truth are prone to ask, \"Which of you has this [message] strengthened in his faith?\" Now as for those who have attained to faith, it does strengthen them in their faith, and they rejoice in the glad tiding [which God has given them].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1359.mp3","surahId":9,"words":[{"id":77101,"position":1,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/009_124_001.mp3","charTypeName":"word"},{"id":77102,"position":2,"arabic":"مَآ","translation":"যা","audioUrl":"wbw/009_124_002.mp3","charTypeName":"word"},{"id":77103,"position":3,"arabic":"أُنزِلَتْ","translation":"অবতীর্ণ করা হয়","audioUrl":"wbw/009_124_003.mp3","charTypeName":"word"},{"id":77104,"position":4,"arabic":"سُورَةٌۭ","translation":"কোনো সূরাহ","audioUrl":"wbw/009_124_004.mp3","charTypeName":"word"},{"id":77105,"position":5,"arabic":"فَمِنْهُم","translation":"তখন মধ্যে তাদের","audioUrl":"wbw/009_124_005.mp3","charTypeName":"word"},{"id":77106,"position":6,"arabic":"مَّن","translation":"কেউ কেউ","audioUrl":"wbw/009_124_006.mp3","charTypeName":"word"},{"id":77107,"position":7,"arabic":"يَقُولُ","translation":"বলে","audioUrl":"wbw/009_124_007.mp3","charTypeName":"word"},{"id":77108,"position":8,"arabic":"أَيُّكُمْ","translation":"\"মধ্যে কার তোমাদের","audioUrl":"wbw/009_124_008.mp3","charTypeName":"word"},{"id":77109,"position":9,"arabic":"زَادَتْهُ","translation":"বৃদ্ধি করেছে তার","audioUrl":"wbw/009_124_009.mp3","charTypeName":"word"},{"id":77110,"position":10,"arabic":"هَـٰذِهِۦٓ","translation":"এটা (দিয়ে)","audioUrl":"wbw/009_124_010.mp3","charTypeName":"word"},{"id":77111,"position":11,"arabic":"إِيمَـٰنًۭا ۚ","translation":"ঈমান\"","audioUrl":"wbw/009_124_011.mp3","charTypeName":"word"},{"id":77113,"position":12,"arabic":"فَأَمَّا","translation":"অতঃপর আর বাস্তবিকই","audioUrl":"wbw/009_124_013.mp3","charTypeName":"word"},{"id":77114,"position":13,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/009_124_014.mp3","charTypeName":"word"},{"id":77115,"position":14,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/009_124_015.mp3","charTypeName":"word"},{"id":77116,"position":15,"arabic":"فَزَادَتْهُمْ","translation":"তখন তা তাদের বৃদ্ধি করেছে","audioUrl":"wbw/009_124_016.mp3","charTypeName":"word"},{"id":77117,"position":16,"arabic":"إِيمَـٰنًۭا","translation":"ঈমান","audioUrl":"wbw/009_124_017.mp3","charTypeName":"word"},{"id":77118,"position":17,"arabic":"وَهُمْ","translation":"এবং তারা","audioUrl":"wbw/009_124_018.mp3","charTypeName":"word"},{"id":77119,"position":18,"arabic":"يَسْتَبْشِرُونَ","translation":"আনন্দিত হয়","audioUrl":"wbw/009_124_019.mp3","charTypeName":"word"},{"id":77120,"position":19,"arabic":"١٢٤","translation":"(১২৪)","audioUrl":null,"charTypeName":"end"}]},{"number":125,"arabic":"وَأَمَّا ٱلَّذِينَ فِى قُلُوبِهِم مَّرَضٌۭ فَزَادَتْهُمْ رِجْسًا إِلَىٰ رِجْسِهِمْ وَمَاتُوا۟ وَهُمْ كَٰفِرُونَ","translation":"But as for those in whose hearts is disease, each new message but adds another [element of] disbelief to the disbelief which they already harbour, and they die while [still] refusing to acknowledge the truth.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1360.mp3","surahId":9,"words":[{"id":77232,"position":1,"arabic":"وَأَمَّا","translation":"আর পক্ষান্তরে","audioUrl":"wbw/009_125_001.mp3","charTypeName":"word"},{"id":77233,"position":2,"arabic":"ٱلَّذِينَ","translation":"যাদের","audioUrl":"wbw/009_125_002.mp3","charTypeName":"word"},{"id":77234,"position":3,"arabic":"فِى","translation":"মধ্যে (আছে)","audioUrl":"wbw/009_125_003.mp3","charTypeName":"word"},{"id":77235,"position":4,"arabic":"قُلُوبِهِم","translation":"অন্তরসমূহে তাদের","audioUrl":"wbw/009_125_004.mp3","charTypeName":"word"},{"id":77236,"position":5,"arabic":"مَّرَضٌۭ","translation":"রোগ","audioUrl":"wbw/009_125_005.mp3","charTypeName":"word"},{"id":77237,"position":6,"arabic":"فَزَادَتْهُمْ","translation":"তখন তা তাদের বৃদ্ধি করেছে","audioUrl":"wbw/009_125_006.mp3","charTypeName":"word"},{"id":77238,"position":7,"arabic":"رِجْسًا","translation":"কলুষতার","audioUrl":"wbw/009_125_007.mp3","charTypeName":"word"},{"id":77239,"position":8,"arabic":"إِلَىٰ","translation":"সাথে","audioUrl":"wbw/009_125_008.mp3","charTypeName":"word"},{"id":77240,"position":9,"arabic":"رِجْسِهِمْ","translation":"কলুষতা তাদের","audioUrl":"wbw/009_125_009.mp3","charTypeName":"word"},{"id":77241,"position":10,"arabic":"وَمَاتُوا۟","translation":"এবং তারা মারা গিয়েছে","audioUrl":"wbw/009_125_010.mp3","charTypeName":"word"},{"id":77242,"position":11,"arabic":"وَهُمْ","translation":"এ অবস্থায় যে তারা","audioUrl":"wbw/009_125_011.mp3","charTypeName":"word"},{"id":77243,"position":12,"arabic":"كَـٰفِرُونَ","translation":"কাফের (থাকবে)","audioUrl":"wbw/009_125_012.mp3","charTypeName":"word"},{"id":77244,"position":13,"arabic":"١٢٥","translation":"(১২৫)","audioUrl":null,"charTypeName":"end"}]},{"number":126,"arabic":"أَوَلَا يَرَوْنَ أَنَّهُمْ يُفْتَنُونَ فِى كُلِّ عَامٍۢ مَّرَّةً أَوْ مَرَّتَيْنِ ثُمَّ لَا يَتُوبُونَ وَلَا هُمْ يَذَّكَّرُونَ","translation":"Are they, then, not aware that they are being tested year-in, year-out? And yet, they do not repent and do not bethink themselves [of God];","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1361.mp3","surahId":9,"words":[{"id":77295,"position":1,"arabic":"أَوَلَا","translation":"কি না","audioUrl":"wbw/009_126_001.mp3","charTypeName":"word"},{"id":77296,"position":2,"arabic":"يَرَوْنَ","translation":"তারা দেখে","audioUrl":"wbw/009_126_002.mp3","charTypeName":"word"},{"id":77297,"position":3,"arabic":"أَنَّهُمْ","translation":"যে তারা","audioUrl":"wbw/009_126_003.mp3","charTypeName":"word"},{"id":77298,"position":4,"arabic":"يُفْتَنُونَ","translation":"পরীক্ষায় নিক্ষিপ্ত হয়","audioUrl":"wbw/009_126_004.mp3","charTypeName":"word"},{"id":77299,"position":5,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/009_126_005.mp3","charTypeName":"word"},{"id":77300,"position":6,"arabic":"كُلِّ","translation":"প্রত্যেক","audioUrl":"wbw/009_126_006.mp3","charTypeName":"word"},{"id":77301,"position":7,"arabic":"عَامٍۢ","translation":"বছরে","audioUrl":"wbw/009_126_007.mp3","charTypeName":"word"},{"id":77302,"position":8,"arabic":"مَّرَّةً","translation":"একবার","audioUrl":"wbw/009_126_008.mp3","charTypeName":"word"},{"id":77303,"position":9,"arabic":"أَوْ","translation":"বা","audioUrl":"wbw/009_126_009.mp3","charTypeName":"word"},{"id":77304,"position":10,"arabic":"مَرَّتَيْنِ","translation":"দু'বার","audioUrl":"wbw/009_126_010.mp3","charTypeName":"word"},{"id":77305,"position":11,"arabic":"ثُمَّ","translation":"এরপরও","audioUrl":"wbw/009_126_011.mp3","charTypeName":"word"},{"id":77306,"position":12,"arabic":"لَا","translation":"না","audioUrl":"wbw/009_126_012.mp3","charTypeName":"word"},{"id":77307,"position":13,"arabic":"يَتُوبُونَ","translation":"তারা তওবা করে","audioUrl":"wbw/009_126_013.mp3","charTypeName":"word"},{"id":77308,"position":14,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/009_126_014.mp3","charTypeName":"word"},{"id":77309,"position":15,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/009_126_015.mp3","charTypeName":"word"},{"id":77310,"position":16,"arabic":"يَذَّكَّرُونَ","translation":"শিক্ষা নেয়","audioUrl":"wbw/009_126_016.mp3","charTypeName":"word"},{"id":77311,"position":17,"arabic":"١٢٦","translation":"(১২৬)","audioUrl":null,"charTypeName":"end"}]},{"number":127,"arabic":"وَإِذَا مَآ أُنزِلَتْ سُورَةٌۭ نَّظَرَ بَعْضُهُمْ إِلَىٰ بَعْضٍ هَلْ يَرَىٰكُم مِّنْ أَحَدٍۢ ثُمَّ ٱنصَرَفُوا۟ ۚ صَرَفَ ٱللَّهُ قُلُوبَهُم بِأَنَّهُمْ قَوْمٌۭ لَّا يَفْقَهُونَ","translation":"and whenever a surah is bestowed from on high, they look at one another [and say, as it were], \"Is there anyone who can see what is in your hearts?\" -and then they turn away. God has turned their hearts away [from the truth] - for they are people who will not grasp it.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1362.mp3","surahId":9,"words":[{"id":77433,"position":1,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/009_127_001.mp3","charTypeName":"word"},{"id":77434,"position":2,"arabic":"مَآ","translation":"যা","audioUrl":"wbw/009_127_002.mp3","charTypeName":"word"},{"id":77435,"position":3,"arabic":"أُنزِلَتْ","translation":"অবতীর্ণ হয়","audioUrl":"wbw/009_127_003.mp3","charTypeName":"word"},{"id":77436,"position":4,"arabic":"سُورَةٌۭ","translation":"কোনো সূরাহ","audioUrl":"wbw/009_127_004.mp3","charTypeName":"word"},{"id":77437,"position":5,"arabic":"نَّظَرَ","translation":"দেখে","audioUrl":"wbw/009_127_005.mp3","charTypeName":"word"},{"id":77438,"position":6,"arabic":"بَعْضُهُمْ","translation":"একে তাদের","audioUrl":"wbw/009_127_006.mp3","charTypeName":"word"},{"id":77439,"position":7,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/009_127_007.mp3","charTypeName":"word"},{"id":77440,"position":8,"arabic":"بَعْضٍ","translation":"অন্যের","audioUrl":"wbw/009_127_008.mp3","charTypeName":"word"},{"id":7744