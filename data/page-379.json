hId":27,"words":[{"id":32119,"position":1,"arabic":"قَالَتْ","translation":"(রানী) বললো","audioUrl":"wbw/027_029_001.mp3","charTypeName":"word"},{"id":32120,"position":2,"arabic":"يَـٰٓأَيُّهَا","translation":"\"হে","audioUrl":"wbw/027_029_002.mp3","charTypeName":"word"},{"id":32121,"position":3,"arabic":"ٱلْمَلَؤُا۟","translation":"সভাসদবৃন্দ","audioUrl":"wbw/027_029_003.mp3","charTypeName":"word"},{"id":32122,"position":4,"arabic":"إِنِّىٓ","translation":"নিশ্চয়ই আমাকে","audioUrl":"wbw/027_029_004.mp3","charTypeName":"word"},{"id":32123,"position":5,"arabic":"أُلْقِىَ","translation":"অর্পণ করা হয়েছে","audioUrl":"wbw/027_029_005.mp3","charTypeName":"word"},{"id":32124,"position":6,"arabic":"إِلَىَّ","translation":"আমার প্রতি","audioUrl":"wbw/027_029_006.mp3","charTypeName":"word"},{"id":32125,"position":7,"arabic":"كِتَـٰبٌۭ","translation":"একটি চিঠি","audioUrl":"wbw/027_029_007.mp3","charTypeName":"word"},{"id":32126,"position":8,"arabic":"كَرِيمٌ","translation":"সম্মানিত","audioUrl":"wbw/027_029_008.mp3","charTypeName":"word"},{"id":32127,"position":9,"arabic":"٢٩","translation":"(২৯)","audioUrl":null,"charTypeName":"end"}]},{"number":30,"arabic":"إِنَّهُۥ مِن سُلَيْمَٰنَ وَإِنَّهُۥ بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ","translation":"Behold, it is from Solomon, and it says, ‘In the name of God, the Most Gracious, the Dispenser of Grace:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3189.mp3","surahId":27,"words":[{"id":32954,"position":1,"arabic":"إِنَّهُۥ","translation":"নিশ্চয় তা (এসেছে)","audioUrl":"wbw/027_030_001.mp3","charTypeName":"word"},{"id":32955,"position":2,"arabic":"مِن","translation":"হ'তে","audioUrl":"wbw/027_030_002.mp3","charTypeName":"word"},{"id":32956,"position":3,"arabic":"سُلَيْمَـٰنَ","translation":"সুলায়মান","audioUrl":"wbw/027_030_003.mp3","charTypeName":"word"},{"id":32957,"position":4,"arabic":"وَإِنَّهُۥ","translation":"এবং নিশ্চয় তা (শুরু হয়েছে)","audioUrl":"wbw/027_030_004.mp3","charTypeName":"word"},{"id":32958,"position":5,"arabic":"بِسْمِ","translation":"\"দিয়ে নাম","audioUrl":"wbw/027_030_005.mp3","charTypeName":"word"},{"id":32959,"position":6,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/027_030_006.mp3","charTypeName":"word"},{"id":32960,"position":7,"arabic":"ٱلرَّحْمَـٰنِ","translation":"দয়াময়","audioUrl":"wbw/027_030_007.mp3","charTypeName":"word"},{"id":32961,"position":8,"arabic":"ٱلرَّحِيمِ","translation":"পরম দয়ালু","audioUrl":"wbw/027_030_008.mp3","charTypeName":"word"},{"id":32962,"position":9,"arabic":"٣٠","translation":"(৩০)","audioUrl":null,"charTypeName":"end"}]},{"number":31,"arabic":"أَلَّا تَعْلُوا۟ عَلَىَّ وَأْتُونِى مُسْلِمِينَ","translation":"[God says:] Exalt not yourselves against Me, but come unto Me in willing surrender!’”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3190.mp3","surahId":27,"words":[{"id":33866,"position":1,"arabic":"أَلَّا","translation":"(তা এই) যে না","audioUrl":"wbw/027_031_001.mp3","charTypeName":"word"},{"id":33867,"position":2,"arabic":"تَعْلُوا۟","translation":"তোমরা বিদ্রোহ করো","audioUrl":"wbw/027_031_002.mp3","charTypeName":"word"},{"id":33868,"position":3,"arabic":"عَلَىَّ","translation":"আমার বিরুদ্ধে","audioUrl":"wbw/027_031_003.mp3","charTypeName":"word"},{"id":33869,"position":4,"arabic":"وَأْتُونِى","translation":"এবং আমার (নিকট) চলে এসো","audioUrl":"wbw/027_031_004.mp3","charTypeName":"word"},{"id":33870,"position":5,"arabic":"مُسْلِمِينَ","translation":"আত্মসমর্পণকারী হয়ে\"","audioUrl":"wbw/027_031_005.mp3","charTypeName":"word"},{"id":33871,"position":6,"arabic":"٣١","translation":"(৩১)","audioUrl":null,"charTypeName":"end"}]},{"number":32,"arabic":"قَالَتْ يَٰٓأَيُّهَا ٱلْمَلَؤُا۟ أَفْتُونِى فِىٓ أَمْرِى مَا كُنتُ قَاطِعَةً أَمْرًا حَتَّىٰ تَشْهَدُونِ","translation":"She added: “O you nobles! Give me your opinion on the problem with which I am now faced; I would never make a [weighty] decision unless you are present with me.”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3191.mp3","surahId":27,"words":[{"id":34809,"position":1,"arabic":"قَالَتْ","translation":"(রাণী) বললো","audioUrl":"wbw/027_032_001.mp3","charTypeName":"word"},{"id":34810,"position":2,"arabic":"يَـٰٓأَيُّهَا","translation":"\"হে","audioUrl":"wbw/027_032_002.mp3","charTypeName":"word"},{"id":34811,"position":3,"arabic":"ٱلْمَلَؤُا۟","translation":"সভাসদবৃন্দ","audioUrl":"wbw/027_032_003.mp3","charTypeName":"word"},{"id":34812,"position":4,"arabic":"أَفْتُونِى","translation":"তোমরা আমাকে অভিমত দাও","audioUrl":"wbw/027_032_004.mp3","charTypeName":"word"},{"id":34813,"position":5,"arabic":"فِىٓ","translation":"ব্যাপারে","audioUrl":"wbw/027_032_005.mp3","charTypeName":"word"},{"id":34814,"position":6,"arabic":"أَمْرِى","translation":"আমার কাজের","audioUrl":"wbw/027_032_006.mp3","charTypeName":"word"},{"id":34815,"position":7,"arabic":"مَا","translation":"না","audioUrl":"wbw/027_032_007.mp3","charTypeName":"word"},{"id":34816,"position":8,"arabic":"كُنتُ","translation":"আমি ছিলাম","audioUrl":"wbw/027_032_008.mp3","charTypeName":"word"},{"id":34817,"position":9,"arabic":"قَاطِعَةً","translation":"চূড়ান্ত মীমাংসাকারী","audioUrl":"wbw/027_032_009.mp3","charTypeName":"word"},{"id":34818,"position":10,"arabic":"أَمْرًا","translation":"কোনো কাজে","audioUrl":"wbw/027_032_010.mp3","charTypeName":"word"},{"id":34819,"position":11,"arabic":"حَتَّىٰ","translation":"যতক্ষণ না","audioUrl":"wbw/027_032_011.mp3","charTypeName":"word"},{"id":34820,"position":12,"arabic":"تَشْهَدُونِ","translation":"তোমরা আমার সামনে উপস্থিত থাকো (পরামর্শে)\"","audioUrl":"wbw/027_032_012.mp3","charTypeName":"word"},{"id":34821,"position":13,"arabic":"٣٢","translation":"(৩২)","audioUrl":null,"charTypeName":"end"}]},{"number":33,"arabic":"قَالُوا۟ نَحْنُ أُو۟لُوا۟ قُوَّةٍۢ وَأُو۟لُوا۟ بَأْسٍۢ شَدِيدٍۢ وَٱلْأَمْرُ إِلَيْكِ فَٱنظُرِى مَاذَا تَأْمُرِينَ","translation":"They answered: “We are endowed with power and with mighty prowess in war - but the command is thine; consider, then, what thou wouldst command.”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3192.mp3","surahId":27,"words":[{"id":35626,"position":1,"arabic":"قَالُوا۟","translation":"(সভাসদবৃন্দ) বললো","audioUrl":"wbw/027_033_001.mp3","charTypeName":"word"},{"id":35627,"position":2,"arabic":"نَحْنُ","translation":"\"আমরা","audioUrl":"wbw/027_033_002.mp3","charTypeName":"word"},{"id":35628,"position":3,"arabic":"أُو۟لُوا۟","translation":"অধিকারী","audioUrl":"wbw/027_033_003.mp3","charTypeName":"word"},{"id":35629,"position":4,"arabic":"قُوَّةٍۢ","translation":"শক্তির (অর্থাৎ বড় শক্তিশালী)","audioUrl":"wbw/027_033_004.mp3","charTypeName":"word"},{"id":35630,"position":5,"arabic":"وَأُو۟لُوا۟","translation":"ও (দক্ষতার) অধিকারী","audioUrl":"wbw/027_033_005.mp3","charTypeName":"word"},{"id":35631,"position":6,"arabic":"بَأْسٍۢ","translation":"যুদ্ধ বিগ্রহে","audioUrl":"wbw/027_033_006.mp3","charTypeName":"word"},{"id":35632,"position":7,"arabic":"شَدِيدٍۢ","translation":"কঠোর","audioUrl":"wbw/027_033_007.mp3","charTypeName":"word"},{"id":35633,"position":8,"arabic":"وَٱلْأَمْرُ","translation":"তবে (সিদ্ধান্তের) কাজ","audioUrl":"wbw/027_033_008.mp3","charTypeName":"word"},{"id":35634,"position":9,"arabic":"إِلَيْكِ","translation":"কাছে আপনারই","audioUrl":"wbw/027_033_009.mp3","charTypeName":"word"},{"id":35635,"position":10,"arabic":"فَٱنظُرِى","translation":"তাই ভেবে দেখুন","audioUrl":"wbw/027_033_010.mp3","charTypeName":"word"},{"id":35636,"position":11,"arabic":"مَاذَا","translation":"কি","audioUrl":"wbw/027_033_011.mp3","charTypeName":"word"},{"id":35637,"position":12,"arabic":"تَأْمُرِينَ","translation":"নির্দেশ দিবেন\"","audioUrl":"wbw/027_033_012.mp3","charTypeName":"word"},{"id":35638,"position":13,"arabic":"٣٣","translation":"(৩৩)","audioUrl":null,"charTypeName":"end"}]},{"number":34,"arabic":"قَالَتْ إِنَّ ٱلْمُلُوكَ إِذَا دَخَلُوا۟ قَرْيَةً أَفْسَدُوهَا وَجَعَلُوٓا۟ أَعِزَّةَ أَهْلِهَآ أَذِلَّةًۭ ۖ وَكَذَٰلِكَ يَفْعَلُونَ","translation":"Said she: “Verily, whenever kings enter a country they corrupt it, and turn the noblest of its people into the most abject. And this is the way they [always] behave?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3193.mp3","surahId":27,"words":[{"id":36574,"position":1,"arabic":"قَالَتْ","translation":"(রানী) বললো","audioUrl":"wbw/027_034_001.mp3","charTypeName":"word"},{"id":36575,"position":2,"arabic":"إِنَّ","translation":"\"নিশ্চয়ই","audioUrl":"wbw/027_034_002.mp3","charTypeName":"word"},{"id":36576,"position":3,"arabic":"ٱلْمُلُوكَ","translation":"রাজারা","audioUrl":"wbw/027_034_003.mp3","charTypeName":"word"},{"id":36577,"position":4,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/027_034_004.mp3","charTypeName":"word"},{"id":36578,"position":5,"arabic":"دَخَلُوا۟","translation":"তারা প্রবেশ করে","audioUrl":"wbw/027_034_005.mp3","charTypeName":"word"},{"id":36579,"position":6,"arabic":"قَرْيَةً","translation":"কোনো জনপদে","audioUrl":"wbw/027_034_006.mp3","charTypeName":"word"},{"id":36580,"position":7,"arabic":"أَفْسَدُوهَا","translation":"তা বিপর্যস্ত করে তারা","audioUrl":"wbw/027_034_007.mp3","charTypeName":"word"},{"id":36581,"position":8,"arabic":"وَجَعَلُوٓا۟","translation":"ও তারা বানিয়ে দেয়","audioUrl":"wbw/027_034_008.mp3","charTypeName":"word"},{"id":36582,"position":9,"arabic":"أَعِزَّةَ","translation":"মর্যাদাবানদেরকে","audioUrl":"wbw/027_034_009.mp3","charTypeName":"word"},{"id":36583,"position":10,"arabic":"أَهْلِهَآ","translation":"অধিবাসীদের তার","audioUrl":"wbw/027_034_010.mp3","charTypeName":"word"},{"id":36584,"position":11,"arabic":"أَذِلَّةًۭ ۖ","translation":"অপদস্হ","audioUrl":"wbw/027_034_011.mp3","charTypeName":"word"},{"id":36586,"position":12,"arabic":"وَكَذَٰلِكَ","translation":"আর এরূপই","audioUrl":"wbw/027_034_013.mp3","charTypeName":"word"},{"id":36587,"position":13,"arabic":"يَفْعَلُونَ","translation":"তারা করবে","audioUrl":"wbw/027_034_014.mp3","charTypeName":"word"},{"id":36588,"position":14,"arabic":"٣٤","translation":"(৩৪)","audioUrl":null,"charTypeName":"end"}]},{"number":35,"arabic":"وَإِنِّى مُرْسِلَةٌ إِلَيْهِم بِهَدِيَّةٍۢ فَنَاظِرَةٌۢ بِمَ يَرْجِعُ ٱلْمُرْسَلُونَ","translation":"Hence, behold, I am going to send a gift to those [people], and await whatever [answer] the envoys bring back.”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3194.mp3","surahId":27,"words":[{"id":37425,"position":1,"arabic":"وَإِنِّى","translation":"এবং নিশ্চয়ই আমি","audioUrl":"wbw/027_035_001.mp3","charTypeName":"word"},{"id":37426,"position":2,"arabic":"مُرْسِلَةٌ","translation":"প্রেরণকারী","audioUrl":"wbw/027_035_002.mp3","charTypeName":"word"},{"id":37427,"position":3,"arabic":"إِلَيْهِم","translation":"প্রতি তাদের","audioUrl":"wbw/027_035_003.mp3","charTypeName":"word"},{"id":37428,"position":4,"arabic":"بِهَدِيَّةٍۢ","translation":"সহ উপঢৌকন","audioUrl":"wbw/027_035_004.mp3","charTypeName":"word"},{"id":37429,"position":5,"arabic":"فَنَاظِرَةٌۢ","translation":"অতঃপর লক্ষ্য করবো","audioUrl":"wbw/027_035_005.mp3","charTypeName":"word"},{"id":37430,"position":6,"arabic":"بِمَ","translation":"নিয়ে কি","audioUrl":"wbw/027_035_006.mp3","charTypeName":"word"},{"id":37431,"position":7,"arabic":"يَرْجِعُ","translation":"ফিরে আসে","audioUrl":"wbw/027_035_007.mp3","charTypeName":"word"},{"id":37432,"position":8,"arabic":"ٱلْمُرْسَلُونَ","translation":"দূতেরা\"","audioUrl":"wbw/027_035_008.mp3","charTypeName":"word"},{"id":37433,"position":9,"arabic":"٣٥","translation":"(৩৫)","audioUrl":null,"charTypeName":"end"}]}]}