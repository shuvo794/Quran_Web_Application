"word"},{"id":27190,"position":13,"arabic":"عَنِ","translation":"হ'তে","audioUrl":"wbw/027_024_013.mp3","charTypeName":"word"},{"id":27191,"position":14,"arabic":"ٱلسَّبِيلِ","translation":"(সৎ) পথ","audioUrl":"wbw/027_024_014.mp3","charTypeName":"word"},{"id":27192,"position":15,"arabic":"فَهُمْ","translation":"তাই তারা","audioUrl":"wbw/027_024_015.mp3","charTypeName":"word"},{"id":27193,"position":16,"arabic":"لَا","translation":"না","audioUrl":"wbw/027_024_016.mp3","charTypeName":"word"},{"id":27194,"position":17,"arabic":"يَهْتَدُونَ","translation":"(সৎ) পথ পায়","audioUrl":"wbw/027_024_017.mp3","charTypeName":"word"},{"id":27195,"position":18,"arabic":"٢٤","translation":"(২৪)","audioUrl":null,"charTypeName":"end"}]},{"number":25,"arabic":"أَلَّا يَسْجُدُوا۟ لِلَّهِ ٱلَّذِى يُخْرِجُ ٱلْخَبْءَ فِى ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ وَيَعْلَمُ مَا تُخْفُونَ وَمَا تُعْلِنُونَ","translation":"[for they have come to believe] that they ought not to adore God [although it is He] who brings forth all that is hidden in the heavens and on earth, and knows all that you would conceal as well as all that you bring into the open:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3184.mp3","surahId":27,"words":[{"id":28195,"position":1,"arabic":"أَلَّا","translation":"(বিরত করেছে) যেন না","audioUrl":"wbw/027_025_001.mp3","charTypeName":"word"},{"id":28196,"position":2,"arabic":"يَسْجُدُوا۟","translation":"তারা সিজদা করে","audioUrl":"wbw/027_025_002.mp3","charTypeName":"word"},{"id":28197,"position":3,"arabic":"لِلَّهِ","translation":"উদ্দেশ্যে আল্লাহর","audioUrl":"wbw/027_025_003.mp3","charTypeName":"word"},{"id":28198,"position":4,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/027_025_004.mp3","charTypeName":"word"},{"id":28199,"position":5,"arabic":"يُخْرِجُ","translation":"বের করেন","audioUrl":"wbw/027_025_005.mp3","charTypeName":"word"},{"id":28200,"position":6,"arabic":"ٱلْخَبْءَ","translation":"লুকায়িত বস্তুকে","audioUrl":"wbw/027_025_006.mp3","charTypeName":"word"},{"id":28201,"position":7,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/027_025_007.mp3","charTypeName":"word"},{"id":28202,"position":8,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশমন্ডলীর","audioUrl":"wbw/027_025_008.mp3","charTypeName":"word"},{"id":28203,"position":9,"arabic":"وَٱلْأَرْضِ","translation":"ও পৃথিবীর","audioUrl":"wbw/027_025_009.mp3","charTypeName":"word"},{"id":28204,"position":10,"arabic":"وَيَعْلَمُ","translation":"আর তিনি জানেন","audioUrl":"wbw/027_025_010.mp3","charTypeName":"word"},{"id":28205,"position":11,"arabic":"مَا","translation":"যা কিছু","audioUrl":"wbw/027_025_011.mp3","charTypeName":"word"},{"id":28206,"position":12,"arabic":"تُخْفُونَ","translation":"তোমরা গোপন করো","audioUrl":"wbw/027_025_012.mp3","charTypeName":"word"},{"id":28207,"position":13,"arabic":"وَمَا","translation":"এবং যা কিছু","audioUrl":"wbw/027_025_013.mp3","charTypeName":"word"},{"id":28208,"position":14,"arabic":"تُعْلِنُونَ","translation":"তোমরা প্রকাশ করো","audioUrl":"wbw/027_025_014.mp3","charTypeName":"word"},{"id":28209,"position":15,"arabic":"٢٥","translation":"(২৫)","audioUrl":null,"charTypeName":"end"}]},{"number":26,"arabic":"ٱللَّهُ لَآ إِلَٰهَ إِلَّا هُوَ رَبُّ ٱلْعَرْشِ ٱلْعَظِيمِ ۩","translation":"God, save whom there is no deity - the Sustainer, in awesome almightiness enthroned!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3185.mp3","surahId":27,"words":[{"id":29170,"position":1,"arabic":"ٱللَّهُ","translation":"আল্লাহ (এমন যে)","audioUrl":"wbw/027_026_001.mp3","charTypeName":"word"},{"id":29171,"position":2,"arabic":"لَآ","translation":"নেই","audioUrl":"wbw/027_026_002.mp3","charTypeName":"word"},{"id":29172,"position":3,"arabic":"إِلَـٰهَ","translation":"কোনো ইলাহ","audioUrl":"wbw/027_026_003.mp3","charTypeName":"word"},{"id":29173,"position":4,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/027_026_004.mp3","charTypeName":"word"},{"id":29174,"position":5,"arabic":"هُوَ","translation":"তিনি","audioUr