{"id":379,"ayahs":[{"number":23,"arabic":"إِنِّى وَجَدتُّ ٱمْرَأَةًۭ تَمْلِكُهُمْ وَأُوتِيَتْ مِن كُلِّ شَىْءٍۢ وَلَهَا عَرْشٌ عَظِيمٌۭ","translation":"“Behold, I found there a woman ruling over them; and she has been given [abundance] of all [good] things, and hers is a mighty throne,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3182.mp3","surahId":27,"words":[{"id":26124,"position":1,"arabic":"إِنِّى","translation":"নিশ্চয়ই আমি","audioUrl":"wbw/027_023_001.mp3","charTypeName":"word"},{"id":26125,"position":2,"arabic":"وَجَدتُّ","translation":"আমি (দেখতে) পেয়েছি","audioUrl":"wbw/027_023_002.mp3","charTypeName":"word"},{"id":26126,"position":3,"arabic":"ٱمْرَأَةًۭ","translation":"একজন মহিলা","audioUrl":"wbw/027_023_003.mp3","charTypeName":"word"},{"id":26127,"position":4,"arabic":"تَمْلِكُهُمْ","translation":"শাসন করে সে তাদেরকে","audioUrl":"wbw/027_023_004.mp3","charTypeName":"word"},{"id":26128,"position":5,"arabic":"وَأُوتِيَتْ","translation":"এবং তাকে দেওয়া হয়েছে","audioUrl":"wbw/027_023_005.mp3","charTypeName":"word"},{"id":26129,"position":6,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/027_023_006.mp3","charTypeName":"word"},{"id":26130,"position":7,"arabic":"كُلِّ","translation":"সব","audioUrl":"wbw/027_023_007.mp3","charTypeName":"word"},{"id":26131,"position":8,"arabic":"شَىْءٍۢ","translation":"কিছুই","audioUrl":"wbw/027_023_008.mp3","charTypeName":"word"},{"id":26132,"position":9,"arabic":"وَلَهَا","translation":"আর আছে তার","audioUrl":"wbw/027_023_009.mp3","charTypeName":"word"},{"id":26133,"position":10,"arabic":"عَرْشٌ","translation":"একটি সিংহাসন","audioUrl":"wbw/027_023_010.mp3","charTypeName":"word"},{"id":26134,"position":11,"arabic":"عَظِيمٌۭ","translation":"বিরাট","audioUrl":"wbw/027_023_011.mp3","charTypeName":"word"},{"id":26135,"position":12,"arabic":"٢٣","translation":"(২৩)","audioUrl":null,"charTypeName":"end"}]},{"number":24,"arabic":"وَجَدتُّهَا وَقَوْمَهَا يَسْجُدُونَ لِلشَّمْسِ مِن دُونِ ٱللَّهِ وَزَيَّنَ لَ