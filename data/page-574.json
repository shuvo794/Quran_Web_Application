d"},{"id":2619,"position":4,"arabic":"مِنْهُ","translation":"তা থেকে","audioUrl":"wbw/073_003_004.mp3","charTypeName":"word"},{"id":2620,"position":5,"arabic":"قَلِيلًا","translation":"সামান্য","audioUrl":"wbw/073_003_005.mp3","charTypeName":"word"},{"id":2621,"position":6,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"أَوْ زِدْ عَلَيْهِ وَرَتِّلِ ٱلْقُرْءَانَ تَرْتِيلًا","translation":"or add to it [at will]; and [during that time] recite the Qur’an calmly and distinctly, with thy mind attuned to its meaning.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5479.mp3","surahId":73,"words":[{"id":4034,"position":1,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/073_004_001.mp3","charTypeName":"word"},{"id":4035,"position":2,"arabic":"زِدْ","translation":"বাড়াও","audioUrl":"wbw/073_004_002.mp3","charTypeName":"word"},{"id":4036,"position":3,"arabic":"عَلَيْهِ","translation":"তার উপর","audioUrl":"wbw/073_004_003.mp3","charTypeName":"word"},{"id":4037,"position":4,"arabic":"وَرَتِّلِ","translation":"এবং আবৃতি করো ধীরে ধীরে","audioUrl":"wbw/073_004_004.mp3","charTypeName":"word"},{"id":4038,"position":5,"arabic":"ٱلْقُرْءَانَ","translation":"কুরআন","audioUrl":"wbw/073_004_005.mp3","charTypeName":"word"},{"id":4039,"position":6,"arabic":"تَرْتِيلًا","translation":"তারতিলসহ","audioUrl":"wbw/073_004_006.mp3","charTypeName":"word"},{"id":4040,"position":7,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"إِنَّا سَنُلْقِى عَلَيْكَ قَوْلًۭا ثَقِيلًا","translation":"Behold, We shall bestow upon thee a weighty message –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5480.mp3","surahId":73,"words":[{"id":5325,"position":1,"arabic":"إِنَّا","translation":"আমরা নিশ্চয়","audioUrl":"wbw/073_005_001.mp3","charTypeName":"word"},{"id":5326,"position":2,"arabic":"سَنُلْقِى","translation":"অর্পণ আমরা শিঘ্রই করবো","audioUrl":"wbw/073_005_002.mp3","charTypeName":"word"},{"id":5327,"position":3,"arabic":"عَلَيْكَ","translation":"তোমার উপর","audioUrl":"wbw/073_005_003.mp3","charTypeName":"word"},{"id":5328,"position":4,"arabic":"قَوْلًۭا","translation":"বাণী","audioUrl":"wbw/073_005_004.mp3","charTypeName":"word"},{"id":5329,"position":5,"arabic":"ثَقِيلًا","translation":"ভারী","audioUrl":"wbw/073_005_005.mp3","charTypeName":"word"},{"id":5330,"position":6,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"إِنَّ نَاشِئَةَ ٱلَّيْلِ هِىَ أَشَدُّ وَطْـًۭٔا وَأَقْوَمُ قِيلًا","translation":"[and,] verily, the hours of night the mind most strongly and speak with the clearest voice,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5481.mp3","surahId":73,"words":[{"id":6527,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়","audioUrl":"wbw/073_006_001.mp3","charTypeName":"word"},{"id":6528,"position":2,"arabic":"نَاشِئَةَ","translation":"উথান (শয্যা ত্যাগ)","audioUrl":"wbw/073_006_002.mp3","charTypeName":"word"},{"id":6529,"position":3,"arabic":"ٱلَّيْلِ","translation":"রাত্রি কালের","audioUrl":"wbw/073_006_003.mp3","charTypeName":"word"},{"id":6530,"position":4,"arabic":"هِىَ","translation":"তা","audioUrl":"wbw/073_006_004.mp3","charTypeName":"word"},{"id":6531,"position":5,"arabic":"أَشَدُّ","translation":"প্রবলতর","audioUrl":"wbw/073_006_005.mp3","charTypeName":"word"},{"id":6532,"position":6,"arabic":"وَطْـًۭٔا","translation":"দলনে (প্রবৃত্তি)","audioUrl":"wbw/073_006_006.mp3","charTypeName":"word"},{"id":6533,"position":7,"arabic":"وَأَقْوَمُ","translation":"এবং সঠিকতর","audioUrl":"wbw/073_006_007.mp3","charTypeName":"word"},{"id":6534,"position":8,"arabic":"قِيلًا","translation":"বাক্য স্ফুরণে","audioUrl":"wbw/073_006_008.mp3","charTypeName":"word"},{"id":6535,"position":9,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"إِنَّ لَكَ فِى ٱلنَّهَارِ سَبْحًۭا طَوِيلًۭا","translation":"whereas by day a long chain of doings is thy portion.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5482.mp3","surahId":73,"words":[{"id":7940,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়","audioUrl":"wbw/073_007_001.mp3","charTypeName":"word"},{"id":7941,"position":2,"arabic":"لَكَ","translation":"তোমার জন্যে","audioUrl":"wbw/073_007_002.mp3","charTypeName":"word"},{"id":7942,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/073_007_003.mp3","charTypeName":"word"},{"id":7943,"position":4,"arabic":"ٱلنَّهَارِ","translation":"দিনে","audioUrl":"wbw/073_007_004.mp3","charTypeName":"word"},{"id":7944,"position":5,"arabic":"سَبْحًۭا","translation":"ব্যস্ততা","audioUrl":"wbw/073_007_005.mp3","charTypeName":"word"},{"id":7945,"position":6,"arabic":"طَوِيلًۭا","translation":"দীর্ঘ","audioUrl":"wbw/073_007_006.mp3","charTypeName":"word"},{"id":7946,"position":7,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"وَٱذْكُرِ ٱسْمَ رَبِّكَ وَتَبَتَّلْ إِلَيْهِ تَبْتِيلًۭا","translation":"But [whether by night or by day,] remember thy Sustainer's name, and devote thyself unto Him with utter devotion.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5483.mp3","surahId":73,"words":[{"id":9106,"position":1,"arabic":"وَٱذْكُرِ","translation":"এবং তুমি স্মরণ করো","audioUrl":"wbw/073_008_001.mp3","charTypeName":"word"},{"id":9107,"position":2,"arabic":"ٱسْمَ","translation":"নাম","audioUrl":"wbw/073_008_002.mp3","charTypeName":"word"},{"id":9108,"position":3,"arabic":"رَبِّكَ","translation":"তোমার রবের","audioUrl":"wbw/073_008_003.mp3","charTypeName":"word"},{"id":9109,"position":4,"arabic":"وَتَبَتَّلْ","translation":"এবং নিমগ্ন হও","audioUrl":"wbw/073_008_004.mp3","charTypeName":"word"},{"id":9110,"position":5,"arabic":"إِلَيْهِ","translation":"তার দিকে","audioUrl":"wbw/073_008_005.mp3","charTypeName":"word"},{"id":9111,"position":6,"arabic":"تَبْتِيلًۭا","translation":"খুব নিমগ্ন হয়ে","audioUrl":"wbw/073_008_006.mp3","charTypeName":"word"},{"id":9112,"position":7,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"رَّبُّ ٱلْمَشْرِقِ وَٱلْمَغْرِبِ لَآ إِلَٰهَ إِلَّا هُوَ فَٱتَّخِذْهُ وَكِيلًۭا","translation":"The Sustainer of the east and the west [is He]: there is no deity save Him: hence, ascribe to Him alone the power to determine thy fate,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5484.mp3","surahId":73,"words":[{"id":10328,"position":1,"arabic":"رَّبُّ","translation":"রব","audioUrl":"wbw/073_009_001.mp3","charTypeName":"word"},{"id":10329,"position":2,"arabic":"ٱلْمَشْرِقِ","translation":"পূর্ব","audioUrl":"wbw/073_009_002.mp3","charTypeName":"word"},{"id":10330,"position":3,"arabic":"وَٱلْمَغْرِبِ","translation":"ও পশ্চিমের","audioUrl":"wbw/073_009_003.mp3","charTypeName":"word"},{"id":10331,"position":4,"arabic":"لَآ","translation":"নেই","audioUrl":"wbw/073_009_004.mp3","charTypeName":"word"},{"id":10332,"position":5,"arabic":"إِلَـٰهَ","translation":"(কোন) ইলাহ","audioUrl":"wbw/073_009_005.mp3","charTypeName":"word"},{"id":10333,"position":6,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/073_009_006.mp3","charTypeName":"word"},{"id":10334,"position":7,"arabic":"هُوَ","translation":"তিনি","audioUrl":"wbw/073_009_007.mp3","charTypeName":"word"},{"id":10335,"position":8,"arabic":"فَٱتَّخِذْهُ","translation":"তাকেই গ্রহণ সুতরাং করো","audioUrl":"wbw/073_009_008.mp3","charTypeName":"word"},{"id":10336,"position":9,"arabic":"وَكِيلًۭا","translation":"কর্ম বিধায়ক রূপে","audioUrl":"wbw/073_009_009.mp3","charTypeName":"word"},{"id":10337,"position":10,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"وَٱصْبِرْ عَلَىٰ مَا يَقُولُونَ وَٱهْجُرْهُمْ هَجْرًۭا جَمِيلًۭا","translation":"and endure with patience whatever people may say [against thee], and avoid them with a comely avoidance.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5485.mp3","surahId":73,"words":[{"id":11562,"position":1,"arabic":"وَٱصْبِرْ","translation":"এবং সবর করো","audioUrl":"wbw/073_010_001.mp3","charTypeName":"word"},{"id":11563,"position":2,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/073_010_002.mp3","charTypeName":"word"},{"id":11564,"position":3,"arabic":"مَا","translation":"যা","audioUrl":"wbw/073_010_003.mp3","charTypeName":"word"},{"id":11565,"position":4,"arabic":"يَقُولُونَ","translation":"তারা বলেছে","audioUrl":"wbw/073_010_004.mp3","charTypeName":"word"},{"id":11566,"position":5,"arabic":"وَٱهْجُرْهُمْ","translation":"এবং তাদের পরিহার করো","audioUrl":"wbw/073_010_005.mp3","charTypeName":"word"},{"id":11567,"position":6,"arabic":"هَجْرًۭا","translation":"পরিহার","audioUrl":"wbw/073_010_006.mp3","charTypeName":"word"},{"id":11568,"position":7,"arabic":"جَمِيلًۭا","translation":"উত্তম","audioUrl":"wbw/073_010_007.mp3","charTypeName":"word"},{"id":11569,"position":8,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"وَذَرْنِى وَٱلْمُكَذِّبِينَ أُو۟لِى ٱلنَّعْمَةِ وَمَهِّلْهُمْ قَلِيلًا","translation":"And leave Me alone [to deal] with those who give the lie to the truth - those who enjoy the blessings of life [without any thought of God] - and bear thou with them for a little while:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5486.mp3","surahId":73,"words":[{"id":12870,"position":1,"arabic":"وَذَرْنِى","translation":"এবং আমাকে ছাড়","audioUrl":"wbw/073_011_001.mp3","charTypeName":"word"},{"id":12871,"position":2,"arabic":"وَٱلْمُكَذِّبِينَ","translation":"ও মিথারপকারীদের","audioUrl":"wbw/073_011_002.mp3","charTypeName":"word"},{"id":12872,"position":3,"arabic":"أُو۟لِى","translation":"অধিকারী","audioUrl":"wbw/073_011_003.mp3","charTypeName":"word"},{"id":12873,"position":4,"arabic":"ٱلنَّعْمَةِ","translation":"নেয়ামতের","audioUrl":"wbw/073_011_004.mp3","charTypeName":"word"},{"id":12874,"position":5,"arabic":"وَمَهِّلْهُمْ","translation":"এবং তাদে্র অবকাশ দ