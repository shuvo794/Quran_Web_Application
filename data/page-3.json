,"audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/16.mp3","surahId":2,"words":[{"id":9694,"position":1,"arabic":"يُخَـٰدِعُونَ","translation":"তারা প্রতারিত করতে চায়","audioUrl":"wbw/002_009_001.mp3","charTypeName":"word"},{"id":9695,"position":2,"arabic":"ٱللَّهَ","translation":"আল্লাহকে","audioUrl":"wbw/002_009_002.mp3","charTypeName":"word"},{"id":9696,"position":3,"arabic":"وَٱلَّذِينَ","translation":"ও (তাদেরকে) যারা","audioUrl":"wbw/002_009_003.mp3","charTypeName":"word"},{"id":9697,"position":4,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/002_009_004.mp3","charTypeName":"word"},{"id":9698,"position":5,"arabic":"وَمَا","translation":"কিন্তু না","audioUrl":"wbw/002_009_005.mp3","charTypeName":"word"},{"id":9699,"position":6,"arabic":"يَخْدَعُونَ","translation":"তারা প্রতারিত করে","audioUrl":"wbw/002_009_006.mp3","charTypeName":"word"},{"id":9700,"position":7,"arabic":"إِلَّآ","translation":"ছাড়া","audioUrl":"wbw/002_009_007.mp3","charTypeName":"word"},{"id":9701,"position":8,"arabic":"أَنفُسَهُمْ","translation":"তাদের নিজেদেরকে","audioUrl":"wbw/002_009_008.mp3","charTypeName":"word"},{"id":9702,"position":9,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/002_009_009.mp3","charTypeName":"word"},{"id":9703,"position":10,"arabic":"يَشْعُرُونَ","translation":"তারা অনুভব করে","audioUrl":"wbw/002_009_010.mp3","charTypeName":"word"},{"id":9704,"position":11,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"فِى قُلُوبِهِم مَّرَضٌۭ فَزَادَهُمُ ٱللَّهُ مَرَضًۭا ۖ وَلَهُمْ عَذَابٌ أَلِيمٌۢ بِمَا كَانُوا۟ يَكْذِبُونَ","translation":"In their hearts is disease, and so God lets their disease increase; and grievous suffering awaits them because of their persistent lying.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/17.mp3","surahId":2,"words":[{"id":10915,"position":1,"arabic":"فِى","translation":"মধ্যে আছে","audioUrl":"wbw/002_010_001.mp3","charTypeName":"word"},{"id":10916,"position":2,"arabic":"قُلُوبِهِم","translation":"তাদের অন্তর সমূহের","audioUrl":"wbw/002_010_002.mp3","charTypeName":"word"},{"id":10917,"position":3,"arabic":"مَّرَضٌۭ","translation":"রোগ (আছে)","audioUrl":"wbw/002_010_003.mp3","charTypeName":"word"},{"id":10918,"position":4,"arabic":"فَزَادَهُمُ","translation":"বৃদ্ধি করলেন তাই (আরও) তাদেরকে","audioUrl":"wbw/002_010_004.mp3","charTypeName":"word"},{"id":10919,"position":5,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌","audioUrl":"wbw/002_010_005.mp3","charTypeName":"word"},{"id":10920,"position":6,"arabic":"مَرَضًۭا ۖ","translation":"(তাদের) রোগ","audioUrl":"wbw/002_010_006.mp3","charTypeName":"word"},{"id":10922,"position":7,"arabic":"وَلَهُمْ","translation":"এবং তাদের জন্য (রয়েছে)","audioUrl":"wbw/002_010_008.mp3","charTypeName":"word"},{"id":10923,"position":8,"arabic":"عَذَابٌ","translation":"শাস্তি","audioUrl":"wbw/002_010_009.mp3","charTypeName":"word"},{"id":10924,"position":9,"arabic":"أَلِيمٌۢ","translation":"কষ্টদায়ক","audioUrl":"wbw/002_010_010.mp3","charTypeName":"word"},{"id":10925,"position":10,"arabic":"بِمَا","translation":"এজন্যে যে","audioUrl":"wbw/002_010_011.mp3","charTypeName":"word"},{"id":10926,"position":11,"arabic":"كَانُوا۟","translation":"তারা ছিল","audioUrl":"wbw/002_010_012.mp3","charTypeName":"word"},{"id":10927,"position":12,"arabic":"يَكْذِبُونَ","translation":"তারা মিথ্যা বলতো","audioUrl":"wbw/002_010_013.mp3","charTypeName":"word"},{"id":10928,"position":13,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"وَإِذَا قِيلَ لَهُمْ لَا تُفْسِدُوا۟ فِى ٱلْأَرْضِ قَالُوٓا۟ إِنَّمَا نَحْنُ مُصْلِحُونَ","translation":"And when they are told, \"Do not spread corruption on earth,\" they answer, \"We are but improving things!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/18.mp3","surahId":2,"words":[{"id":12330,"position":1,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/002_011_001.mp3","charTypeName":"word