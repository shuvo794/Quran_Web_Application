{"id":3,"ayahs":[{"number":6,"arabic":"إِنَّ ٱلَّذِينَ كَفَرُوا۟ سَوَآءٌ عَلَيْهِمْ ءَأَنذَرْتَهُمْ أَمْ لَمْ تُنذِرْهُمْ لَا يُؤْمِنُونَ","translation":"BEHOLD, as for those who are bent on denying the truth - it is all one to them whether thou warnest them or dost not warn them: they will not believe.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/13.mp3","surahId":2,"words":[{"id":6905,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/002_006_001.mp3","charTypeName":"word"},{"id":6906,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/002_006_002.mp3","charTypeName":"word"},{"id":6907,"position":3,"arabic":"كَفَرُوا۟","translation":"অবিশ্বাস করেছে","audioUrl":"wbw/002_006_003.mp3","charTypeName":"word"},{"id":6908,"position":4,"arabic":"سَوَآءٌ","translation":"সমান","audioUrl":"wbw/002_006_004.mp3","charTypeName":"word"},{"id":6909,"position":5,"arabic":"عَلَيْهِمْ","translation":"তাদের জন্যে","audioUrl":"wbw/002_006_005.mp3","charTypeName":"word"},{"id":6910,"position":6,"arabic":"ءَأَنذَرْتَهُمْ","translation":"তাদের তুমি সতর্ক কর কি","audioUrl":"wbw/002_006_006.mp3","charTypeName":"word"},{"id":6911,"position":7,"arabic":"أَمْ","translation":"অথবা","audioUrl":"wbw/002_006_007.mp3","charTypeName":"word"},{"id":6912,"position":8,"arabic":"لَمْ","translation":"না","audioUrl":"wbw/002_006_008.mp3","charTypeName":"word"},{"id":6913,"position":9,"arabic":"تُنذِرْهُمْ","translation":"সতর্ক কর তুমি তাদেরকে","audioUrl":"wbw/002_006_009.mp3","charTypeName":"word"},{"id":6914,"position":10,"arabic":"لَا","translation":"না","audioUrl":"wbw/002_006_010.mp3","charTypeName":"word"},{"id":6915,"position":11,"arabic":"يُؤْمِنُونَ","translation":"তারা ঈমান আনবে","audioUrl":"wbw/002_006_011.mp3","charTypeName":"word"},{"id":6916,"position":12,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"خَتَمَ ٱللَّهُ عَلَىٰ قُلُوبِهِمْ وَعَلَىٰ سَمْعِهِمْ ۖ وَعَلَىٰٓ أَبْصَٰرِهِمْ غِشَٰوَةٌۭ ۖ وَلَهُمْ عَذَابٌ عَظِيمٌۭ","translation":"God; has sealed their hearts and their hearing, and over their eyes is a veil; and awesome suffering awaits them.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/14.mp3","surahId":2,"words":[{"id":8309,"position":1,"arabic":"خَتَمَ","translation":"সিল মেরে দিয়েছেন","audioUrl":"wbw/002_007_001.mp3","charTypeName":"word"},{"id":8310,"position":2,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/002_007_002.mp3","charTypeName":"word"},{"id":8311,"position":3,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/002_007_003.mp3","charTypeName":"word"},{"id":8312,"position":4,"arabic":"قُلُوبِهِمْ","translation":"তাদের অন্তরের","audioUrl":"wbw/002_007_004.mp3","charTypeName":"word"},{"id":8313,"position":5,"arabic":"وَعَلَىٰ","translation":"এবং উপর","audioUrl":"wbw/002_007_005.mp3","charTypeName":"word"},{"id":8314,"position":6,"arabic":"سَمْعِهِمْ ۖ","translation":"তাদের শ্রবণশক্তির","audioUrl":"wbw/002_007_006.mp3","charTypeName":"word"},{"id":8316,"position":7,"arabic":"وَعَلَىٰٓ","translation":"এবং উপর","audioUrl":"wbw/002_007_008.mp3","charTypeName":"word"},{"id":8317,"position":8,"arabic":"أَبْصَـٰرِهِمْ","translation":"তাদের দৃষ্টিশক্তির","audioUrl":"wbw/002_007_009.mp3","charTypeName":"word"},{"id":8318,"position":9,"arabic":"غِشَـٰوَةٌۭ ۖ","translation":"আবরণ (দিয়েছেন)","audioUrl":"wbw/002_007_010.mp3","charTypeName":"word"},{"id":8320,"position":10,"arabic":"وَلَهُمْ","translation":"এবং তাদেরজন্যে (রয়েছে)","audioUrl":"wbw/002_007_012.mp3","charTypeName":"word"},{"id":8321,"position":11,"arabic":"عَذَابٌ","translation":"শাস্তি","audioUrl":"wbw/002_007_013.mp3","charTypeName":"word"},{"id":8322,"position":12,"arabic":"عَظِيمٌۭ","translation":"কঠিন","audioUrl":"wbw/002_007_014.mp3","charTypeName":"word"},{"id":8323,"position":13,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"وَمِنَ ٱلنَّاسِ مَن يَقُولُ ءَامَنَّا بِٱللَّهِ وَبِٱلْيَوْمِ ٱلْءَاخ