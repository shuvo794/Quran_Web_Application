{"id":239,"ayahs":[{"number":31,"arabic":"فَلَمَّا سَمِعَتْ بِمَكْرِهِنَّ أَرْسَلَتْ إِلَيْهِنَّ وَأَعْتَدَتْ لَهُنَّ مُتَّكَـًۭٔا وَءَاتَتْ كُلَّ وَٰحِدَةٍۢ مِّنْهُنَّ سِكِّينًۭا وَقَالَتِ ٱخْرُجْ عَلَيْهِنَّ ۖ فَلَمَّا رَأَيْنَهُۥٓ أَكْبَرْنَهُۥ وَقَطَّعْنَ أَيْدِيَهُنَّ وَقُلْنَ حَٰشَ لِلَّهِ مَا هَٰذَا بَشَرًا إِنْ هَٰذَآ إِلَّا مَلَكٌۭ كَرِيمٌۭ","translation":"Thereupon, when she heard of their malicious talk, she sent for them, and prepared for them a sumptuous repast, and handed each of them a knife and said [to Joseph]: \"Come out and show thyself to them!\" And when the women saw him, they were greatly amazed at his beauty, and [so flustered were they that] they cut their hands [with their knives], exclaiming, \"God save us! This is no mortal man! This is nought but a noble angel!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1627.mp3","surahId":12,"words":[{"id":33895,"position":1,"arabic":"فَلَمَّا","translation":"অতঃপর যখন","audioUrl":"wbw/012_031_001.mp3","charTypeName":"word"},{"id":33896,"position":2,"arabic":"سَمِعَتْ","translation":"(মহিলা) শুনলো","audioUrl":"wbw/012_031_002.mp3","charTypeName":"word"},{"id":33897,"position":3,"arabic":"بِمَكْرِهِنَّ","translation":"সম্বন্ধে তাদের ষড়যন্ত্রেরর কথা","audioUrl":"wbw/012_031_003.mp3","charTypeName":"word"},{"id":33898,"position":4,"arabic":"أَرْسَلَتْ","translation":"মহিলা (লোক) প্রেরণ করলো","audioUrl":"wbw/012_031_004.mp3","charTypeName":"word"},{"id":33899,"position":5,"arabic":"إِلَيْهِنَّ","translation":"তাদের কাছে","audioUrl":"wbw/012_031_005.mp3","charTypeName":"word"},{"id":33900,"position":6,"arabic":"وَأَعْتَدَتْ","translation":"ও প্রস্তুত করলো","audioUrl":"wbw/012_031_006.mp3","charTypeName":"word"},{"id":33901,"position":7,"arabic":"لَهُنَّ","translation":"তাদের জন্যে","audioUrl":"wbw/012_031_007.mp3","charTypeName":"word"},{"id":33902,"position":8,"arabic":"مُتَّكَـًۭٔا","translation":"(হেলান দিয়ে) বসার আসন","audioUrl":"wbw/012_031_008.mp3","charTypeName":"word"},{"id":33903,"position":9,"arabic":"وَءَاتَتْ","translation":"ও দিলো","audioUrl":"wbw/012_031_009.mp3","charTypeName":"word"},{"id":33904,"position":10,"arabic":"كُلَّ","translation":"ব্যক্তিকে","audioUrl":"wbw/012_031_010.mp3","charTypeName":"word"},{"id":33905,"position":11,"arabic":"وَٰحِدَةٍۢ","translation":"প্রত্যেক","audioUrl":"wbw/012_031_011.mp3","charTypeName":"word"},{"id":33906,"position":12,"arabic":"مِّنْهُنَّ","translation":"তাদের মধ্যকার","audioUrl":"wbw/012_031_012.mp3","charTypeName":"word"},{"id":33907,"position":13,"arabic":"سِكِّينًۭا","translation":"একটি করে ছুরি (ফল কেটে খেতে)","audioUrl":"wbw/012_031_013.mp3","charTypeName":"word"},{"id":33908,"position":14,"arabic":"وَقَالَتِ","translation":"এবং বললো (ইউসুফকে)","audioUrl":"wbw/012_031_014.mp3","charTypeName":"word"},{"id":33909,"position":15,"arabic":"ٱخْرُجْ","translation":"\"বের হও","audioUrl":"wbw/012_031_015.mp3","charTypeName":"word"},{"id":33910,"position":16,"arabic":"عَلَيْهِنَّ ۖ","translation":"সামনে তাদের\"","audioUrl":"wbw/012_031_016.mp3","charTypeName":"word"},{"id":33912,"position":17,"arabic":"فَلَمَّا","translation":"অতঃপর যখন","audioUrl":"wbw/012_031_018.mp3","charTypeName":"word"},{"id":33913,"position":18,"arabic":"رَأَيْنَهُۥٓ","translation":"তাকে তারা দেখলো","audioUrl":"wbw/012_031_019.mp3","charTypeName":"word"},{"id":33914,"position":19,"arabic":"أَكْبَرْنَهُۥ","translation":"তারা অভিভূত হলো","audioUrl":"wbw/012_031_020.mp3","charTypeName":"word"},{"id":33915,"position":20,"arabic":"وَقَطَّعْنَ","translation":"ও তারা কেটে ফেললো","audioUrl":"wbw/012_031_021.mp3","charTypeName":"word"},{"id":33916,"position":21,"arabic":"أَيْدِيَهُنَّ","translation":"(ফলের পরিবর্তে) তাদের হাত","audioUrl":"wbw/012_031_022.mp3","charTypeName":"word"},{"id":33917,"position":22,"arabic":"وَقُلْنَ","translation":"ও তারা বললো","audioUrl":"wbw/012_031_023.mp3","charTypeName":"word"},{"id":33918,"position":23,"arabic":"حَـٰشَ","translation":"\"মহিমা","audioUrl":"wbw/012_031_024.mp3","charTypeName":"word"},{"id":33919,"position":24,"arabic":"لِلَّهِ","translation":"জন্যে আল্লাহর","audioUrl":"wbw/012_031_025.mp3","charTypeName":"word"},{"id":33920,"position":25,"arabic":"مَا","translation":"নয়","audioUrl":"wbw/012_031_026.mp3","charTypeName":"word"},{"id":33921,"position":26,"arabic":"هَـٰذَا","translation":"এতো","audioUrl":"wbw/012_031_027.mp3","charTypeName":"word"},{"id":33922,"position":27,"arabic":"بَشَرًا","translation":"মানুষ","audioUrl":"wbw/012_031_028.mp3","charTypeName":"word"},{"id":33923,"position":28,"arabic":"إِنْ","translation":"নয়","audioUrl":"wbw/012_031_029.mp3","charTypeName":"word"},{"id":33924,"position":29,"arabic":"هَـٰذَآ","translation":"এতো","audioUrl":"wbw/012_031_030.mp3","charTypeName":"word"},{"id":33925,"position":30,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/012_031_031.mp3","charTypeName":"word"},{"id":33926,"position":31,"arabic":"مَلَكٌۭ","translation":"ফেরেশতা","audioUrl":"wbw/012_031_032.mp3","charTypeName":"word"},{"id":33927,"position":32,"arabic":"كَرِيمٌۭ","translation":"সম্মানিত\"","audioUrl":"wbw/012_031_033.mp3","charTypeName":"word"},{"id":33928,"position":33,"arabic":"٣١","translation":"(৩১)","audioUrl":null,"charTypeName":"end"}]},{"number":32,"arabic":"قَالَتْ فَذَٰلِكُنَّ ٱلَّذِى لُمْتُنَّنِى فِيهِ ۖ وَلَقَدْ رَٰوَدتُّهُۥ عَن نَّفْسِهِۦ فَٱسْتَعْصَمَ ۖ وَلَئِن لَّمْ يَفْعَلْ مَآ ءَامُرُهُۥ لَيُسْجَنَنَّ وَلَيَكُونًۭا مِّنَ ٱلصَّٰغِرِينَ","translation":"Said she: \"This, then, is he about whom you have been blaming me! And, indeed, I did try to make him yield himself unto me, but he remained chaste. Now, however, if he does not do what I bid him, he shall most certainly be imprisoned, and shall most certainly find himself among the despised!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1628.mp3","surahId":12,"words":[{"id":34850,"position":1,"arabic":"قَالَتْ","translation":"সে বললো","audioUrl":"wbw/012_032_001.mp3","charTypeName":"word"},{"id":34851,"position":2,"arabic":"فَذَٰلِكُنَّ","translation":"\"অতঃপর এ-ই সে","audioUrl":"wbw/012_032_002.mp3","charTypeName":"word"},{"id":34852,"position":3,"arabic":"ٱلَّذِى","translation":"যার (যুবক)","audioUrl":"wbw/012_032_003.mp3","charTypeName":"word"},{"id":34853,"position":4,"arabic":"لُمْتُنَّنِى","translation":"আমাকে তোমরা নিন্দা করেছো","audioUrl":"wbw/012_032_004.mp3","charTypeName":"word"},{"id":34854,"position":5,"arabic":"فِيهِ ۖ","translation":"ব্যাপারে","audioUrl":"wbw/012_032_005.mp3","charTypeName":"word"},{"id":34856,"position":6,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/012_032_007.mp3","charTypeName":"word"},{"id":34857,"position":7,"arabic":"رَٰوَدتُّهُۥ","translation":"তাকে আমি ফুসলিয়েছি","audioUrl":"wbw/012_032_008.mp3","charTypeName":"word"},{"id":34858,"position":8,"arabic":"عَن","translation":"হ'তে","audioUrl":"wbw/012_032_009.mp3","charTypeName":"word"},{"id":34859,"position":9,"arabic":"نَّفْسِهِۦ","translation":"তার নিজের (আত্মসংবরণ)","audioUrl":"wbw/012_032_010.mp3","charTypeName":"word"},{"id":34860,"position":10,"arabic":"فَٱسْتَعْصَمَ ۖ","translation":"তবুও সে নিজেকে পবিত্র রেখেছে","audioUrl":"wbw/012_032_011.mp3","charTypeName":"word"},{"id":34862,"position":11,"arabic":"وَلَئِن","translation":"এবং অবশ্যই যদি","audioUrl":"wbw/012_032_013.mp3","charTypeName":"word"},{"id":34863,"position":12,"arabic":"لَّمْ","translation":"না","audioUrl":"wbw/012_032_014.mp3","charTypeName":"word"},{"id":34864,"position":13,"arabic":"يَفْعَلْ","translation":"সে করে","audioUrl":"wbw/012_032_015.mp3","charTypeName":"word"},{"id":34865,"position":14,"arabic":"مَآ","translation":"তা যা","audioUrl":"wbw/012_032_016.mp3","charTypeName":"word"},{"id":34866,"position":15,"arabic":"ءَامُرُهُۥ","translation":"তাকে নির্দেশ দিই আমি","audioUrl":"wbw/012_032_017.mp3","charTypeName":"word"},{"id":34867,"position":16,"arabic":"لَيُسْجَنَنَّ","translation":"অবশ্যই সে কারারুদ্ধ হবে","audioUrl":"wbw/012_032_018.mp3","charTypeName":"word"},{"id":34868,"position":17,"arabic":"وَلَيَكُونًۭا","translation":"এবং অবশ্যই সে হবে","audioUrl":"wbw/012_032_019.mp3","charTypeName":"word"},{"id":34869,"position":18,"arabic":"مِّنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/012_032_020.mp3","charTypeName":"word"},{"id":34870,"position":19,"arabic":"ٱلصَّـٰغِرِينَ","translation":"লাঞ্ছিতদের","audioUrl":"wbw/012_032_021.mp3","charTypeName":"word"},{"id":34871,"position":20,"arabic":"٣٢","translation":"(৩২)","audioUrl":null,"charTypeName":"end"}]},{"number":33,"arabic":"قَالَ رَبِّ ٱلسِّجْنُ أَحَبُّ إِلَىَّ مِمَّا يَدْعُونَنِىٓ إِلَيْهِ ۖ وَإِلَّا تَصْرِفْ عَنِّى كَيْدَهُنَّ أَصْبُ إِلَيْهِنَّ وَأَكُن مِّنَ ٱلْجَٰهِلِينَ","translation":"Said he: \"O my Sustainer! Prison is more desirable to me than [compliance with] what these women invite me to: for, unless Thou turn away their guile from me, I might yet yield to their allure and become one of those who are unaware [of right and wrong].\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1629.mp3","surahId":12,"words":[{"id":35649,"position":1,"arabic":"قَالَ","translation":"(ইউসুফ) বললো","audioUrl":"wbw/012_033_001.mp3","charTypeName":"word"},{"id":35650,"position":2,"arabic":"رَبِّ","translation":"\"হে আমার রব","audioUrl":"wbw/012_033_002.mp3","charTypeName":"word"},{"id":35651,"position":3,"arabic":"ٱلسِّجْنُ","translation":"কারাগারই","audioUrl":"wbw/012_033_003.mp3","charTypeName":"word"},{"id":35652,"position":4,"arabic":"أَحَبُّ","translation":"অধিক প্রিয়","audioUrl":"wbw/012_033_004.mp3","charTypeName":"word"},{"id":35653,"position":5,"arabic":"إِلَىَّ","translation":"আমার কাছে","audioUrl":"wbw/012_033_005.mp3","charTypeName":"word"},{"id":35654,"position":6,"arabic":"مِمَّا","translation":"তা হ'তে","audioUrl":"wbw/012_033_006.mp3","charTypeName":"word"},{"id":35655,"position":7,"arabic":"يَدْعُونَنِىٓ","translation":"আমাকে তারা ডাকছে","audioUrl":"wbw/012_033_007.mp3","charTypeName":"word"},{"id":35656,"position":8,"arabic":"إِلَيْهِ ۖ","translation":"যার দিকে","audioUrl":"wbw/012_033_