{"id":191,"ayahs":[{"number":27,"arabic":"ثُمَّ يَتُوبُ ٱللَّهُ مِنۢ بَعْدِ ذَٰلِكَ عَلَىٰ مَن يَشَآءُ ۗ وَٱللَّهُ غَفُورٌۭ رَّحِيمٌۭ","translation":"But with all this, God will turn in His mercy unto whom He wills: for God is much-forgiving, a dispenser of grace.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1262.mp3","surahId":9,"words":[{"id":29745,"position":1,"arabic":"ثُمَّ","translation":"অতঃপর","audioUrl":"wbw/009_027_001.mp3","charTypeName":"word"},{"id":29746,"position":2,"arabic":"يَتُوبُ","translation":"ক্ষমাপরায়ণ হলেন","audioUrl":"wbw/009_027_002.mp3","charTypeName":"word"},{"id":29747,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/009_027_003.mp3","charTypeName":"word"},{"id":29748,"position":4,"arabic":"مِنۢ","translation":"থেকেও","audioUrl":"wbw/009_027_004.mp3","charTypeName":"word"},{"id":29749,"position":5,"arabic":"بَعْدِ","translation":"পর","audioUrl":"wbw/009_027_005.mp3","charTypeName":"word"},{"id":29750,"position":6,"arabic":"ذَٰلِكَ","translation":"এর","audioUrl":"wbw/009_027_006.mp3","charTypeName":"word"},{"id":29751,"position":7,"arabic":"عَلَىٰ","translation":"(তারা) প্রতি","audioUrl":"wbw/009_027_007.mp3","charTypeName":"word"},{"id":29752,"position":8,"arabic":"مَن","translation":"যাকে","audioUrl":"wbw/009_027_008.mp3","charTypeName":"word"},{"id":29753,"position":9,"arabic":"يَشَآءُ ۗ","translation":"তিনি ইচ্ছে করেন","audioUrl":"wbw/009_027_009.mp3","charTypeName":"word"},{"id":29755,"position":10,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/009_027_011.mp3","charTypeName":"word"},{"id":29756,"position":11,"arabic":"غَفُورٌۭ","translation":"ক্ষমাশীল","audioUrl":"wbw/009_027_012.mp3","charTypeName":"word"},{"id":29757,"position":12,"arabic":"رَّحِيمٌۭ","translation":"পরম দয়ালু","audioUrl":"wbw/009_027_013.mp3","charTypeName":"word"},{"id":29758,"position":13,"arabic":"٢٧","translation":"(২৭)","audioUrl":null,"charTypeName":"end"}]},{"number":28,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوٓا۟ إِنَّمَا ٱلْمُشْرِكُونَ نَجَسٌۭ فَلَا يَقْرَبُوا۟ ٱلْمَسْجِدَ ٱلْحَرَامَ بَعْدَ عَامِهِمْ هَٰذَا ۚ وَإِنْ خِفْتُمْ عَيْلَةًۭ فَسَوْفَ يُغْنِيكُمُ ٱللَّهُ مِن فَضْلِهِۦٓ إِن شَآءَ ۚ إِنَّ ٱللَّهَ عَلِيمٌ حَكِيمٌۭ","translation":"O YOU who have attained to faith! Those who ascribe divinity to aught beside God are nothing but impure: and so they shall not approach the Inviolable House of Worship from this year onwards And should you fear poverty, then [know that] in time God will enrich you out of His bounty, if He so wills: for, verily, God is all-knowing, wise!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1263.mp3","surahId":9,"words":[{"id":30819,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/009_028_001.mp3","charTypeName":"word"},{"id":30820,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/009_028_002.mp3","charTypeName":"word"},{"id":30821,"position":3,"arabic":"ءَامَنُوٓا۟","translation":"ঈমান এনেছো","audioUrl":"wbw/009_028_003.mp3","charTypeName":"word"},{"id":30822,"position":4,"arabic":"إِنَّمَا","translation":"মূলতঃ","audioUrl":"wbw/009_028_004.mp3","charTypeName":"word"},{"id":30823,"position":5,"arabic":"ٱلْمُشْرِكُونَ","translation":"মুশরিকরা","audioUrl":"wbw/009_028_005.mp3","charTypeName":"word"},{"id":30824,"position":6,"arabic":"نَجَسٌۭ","translation":"অপবিত্র","audioUrl":"wbw/009_028_006.mp3","charTypeName":"word"},{"id":30825,"position":7,"arabic":"فَلَا","translation":"অতএব না","audioUrl":"wbw/009_028_007.mp3","charTypeName":"word"},{"id":30826,"position":8,"arabic":"يَقْرَبُوا۟","translation":"তারা নিকটবর্তী হবে","audioUrl":"wbw/009_028_008.mp3","charTypeName":"word"},{"id":30827,"position":9,"arabic":"ٱلْمَسْجِدَ","translation":"মাসজিদে","audioUrl":"wbw/009_028_009.mp3","charTypeName":"word"},{"id":30828,"position":10,"arabic":"ٱلْحَرَامَ","translation":"হারামের","audioUrl":"wbw/009_028_010.mp3","charTypeName":"word"},{"id":30829,"position":11,"arabic":"بَعْدَ