47,"position":27,"arabic":"حَكِيمٌۭ","translation":"মহাবিজ্ঞ","audioUrl":"wbw/009_028_029.mp3","charTypeName":"word"},{"id":30848,"position":28,"arabic":"٢٨","translation":"(২৮)","audioUrl":null,"charTypeName":"end"}]},{"number":29,"arabic":"قَٰتِلُوا۟ ٱلَّذِينَ لَا يُؤْمِنُونَ بِٱللَّهِ وَلَا بِٱلْيَوْمِ ٱلْءَاخِرِ وَلَا يُحَرِّمُونَ مَا حَرَّمَ ٱللَّهُ وَرَسُولُهُۥ وَلَا يَدِينُونَ دِينَ ٱلْحَقِّ مِنَ ٱلَّذِينَ أُوتُوا۟ ٱلْكِتَٰبَ حَتَّىٰ يُعْطُوا۟ ٱلْجِزْيَةَ عَن يَدٍۢ وَهُمْ صَٰغِرُونَ","translation":"[And] fight against those who - despite having been vouchsafed revelation [aforetime] -do not [truly] believe either in God or the Last Day, and do not consider forbidden that which God and His Apostle have forbidden, and do not follow the religion of truth [which God has enjoined upon them] till they [agree to] pay the exemption tax with a willing hand, after having been humbled [in war].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1264.mp3","surahId":9,"words":[{"id":31875,"position":1,"arabic":"قَـٰتِلُوا۟","translation":"তোমরা যুদ্ধ করো","audioUrl":"wbw/009_029_001.mp3","charTypeName":"word"},{"id":31876,"position":2,"arabic":"ٱلَّذِينَ","translation":"(তাদের বিরুদ্ধে) যারা","audioUrl":"wbw/009_029_002.mp3","charTypeName":"word"},{"id":31877,"position":3,"arabic":"لَا","translation":"না","audioUrl":"wbw/009_029_003.mp3","charTypeName":"word"},{"id":31878,"position":4,"arabic":"يُؤْمِنُونَ","translation":"ঈমান আনে","audioUrl":"wbw/009_029_004.mp3","charTypeName":"word"},{"id":31879,"position":5,"arabic":"بِٱللَّهِ","translation":"উপর আল্লাহর","audioUrl":"wbw/009_029_005.mp3","charTypeName":"word"},{"id":31880,"position":6,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/009_029_006.mp3","charTypeName":"word"},{"id":31881,"position":7,"arabic":"بِٱلْيَوْمِ","translation":"উপর দিনের","audioUrl":"wbw/009_029_007.mp3","charTypeName":"word"},{"id":31882,"position":8,"arabic":"ٱلْـَٔاخِرِ","translation":"আখেরাতের","audioUrl":"wbw/009_029_008.mp3","charTypeName":"word"},{"id":31883,"position":9,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/009_029_009.mp3","charTypeName":"word"},{"id":31884,"position":10,"arabic":"يُحَرِّمُونَ","translation":"নিষিদ্ধ করে","audioUrl":"wbw/009_029_010.mp3","charTypeName":"word"},{"id":31885,"position":11,"arabic":"مَا","translation":"যা কিছু","audioUrl":"wbw/009_029_011.mp3","charTypeName":"word"},{"id":31886,"position":12,"arabic":"حَرَّمَ","translation":"নিষিদ্ধ করেছেন","audioUrl":"wbw/009_029_012.mp3","charTypeName":"word"},{"id":31887,"position":13,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/009_029_013.mp3","charTypeName":"word"},{"id":31888,"position":14,"arabic":"وَرَسُولُهُۥ","translation":"ও তাঁর রাসূল","audioUrl":"wbw/009_029_014.mp3","charTypeName":"word"},{"id":31889,"position":15,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/009_029_015.mp3","charTypeName":"word"},{"id":31890,"position":16,"arabic":"يَدِينُونَ","translation":"আনুগত্য করে","audioUrl":"wbw/009_029_016.mp3","charTypeName":"word"},{"id":31891,"position":17,"arabic":"دِينَ","translation":"দ্বীনের","audioUrl":"wbw/009_029_017.mp3","charTypeName":"word"},{"id":31892,"position":18,"arabic":"ٱلْحَقِّ","translation":"সত্যকে","audioUrl":"wbw/009_029_018.mp3","charTypeName":"word"},{"id":31893,"position":19,"arabic":"مِنَ","translation":"মধ্য হতে","audioUrl":"wbw/009_029_019.mp3","charTypeName":"word"},{"id":31894,"position":20,"arabic":"ٱلَّذِينَ","translation":"যাদেরকে","audioUrl":"wbw/009_029_020.mp3","charTypeName":"word"},{"id":31895,"position":21,"arabic":"أُوتُوا۟","translation":"দেয়া হয়েছে","audioUrl":"wbw/009_029_021.mp3","charTypeName":"word"},{"id":31896,"position":22,"arabic":"ٱلْكِتَـٰبَ","translation":"কিতাব","audioUrl":"wbw/009_029_022.mp3","charTypeName":"word"},{"id":31897,"position":23,"arabic":"حَتَّىٰ","translation":"যতক্ষণ না","audioUrl":"wbw/009_029_023.mp3","charTypeName":"word"},{"id":31898,"position":24,"arabic":"يُعْطُوا۟","translation":"তারা