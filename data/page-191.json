lation":"ধ্বংস করুন তাদের","audioUrl":"wbw/009_030_023.mp3","charTypeName":"word"},{"id":32774,"position":21,"arabic":"ٱللَّهُ ۚ","translation":"আল্লাহ","audioUrl":"wbw/009_030_024.mp3","charTypeName":"word"},{"id":32776,"position":22,"arabic":"أَنَّىٰ","translation":"কেমন করে","audioUrl":"wbw/009_030_026.mp3","charTypeName":"word"},{"id":32777,"position":23,"arabic":"يُؤْفَكُونَ","translation":"তাদের ফিরিয়ে নেয়া হচ্ছে","audioUrl":"wbw/009_030_027.mp3","charTypeName":"word"},{"id":32778,"position":24,"arabic":"٣٠","translation":"(৩০)","audioUrl":null,"charTypeName":"end"}]},{"number":31,"arabic":"ٱتَّخَذُوٓا۟ أَحْبَارَهُمْ وَرُهْبَٰنَهُمْ أَرْبَابًۭا مِّن دُونِ ٱللَّهِ وَٱلْمَسِيحَ ٱبْنَ مَرْيَمَ وَمَآ أُمِرُوٓا۟ إِلَّا لِيَعْبُدُوٓا۟ إِلَٰهًۭا وَٰحِدًۭا ۖ لَّآ إِلَٰهَ إِلَّا هُوَ ۚ سُبْحَٰنَهُۥ عَمَّا يُشْرِكُونَ","translation":"They have taken their rabbis and their monks-as well as the Christ, son of Mary-for their lords beside God, although they had been bidden to worship none but the One God, save whom there is no deity: the One who is utterly remote, in His limitless glory, from anything to which they may ascribe a share in His divinity!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1266.mp3","surahId":9,"words":[{"id":33569,"position":1,"arabic":"ٱتَّخَذُوٓا۟","translation":"তারা গ্রহণ করেছে","audioUrl":"wbw/009_031_001.mp3","charTypeName":"word"},{"id":33570,"position":2,"arabic":"أَحْبَارَهُمْ","translation":"পন্ডিতদেরকে তাদের","audioUrl":"wbw/009_031_002.mp3","charTypeName":"word"},{"id":33571,"position":3,"arabic":"وَرُهْبَـٰنَهُمْ","translation":"ও সংসার-বিরাগীদেরকে তাদের","audioUrl":"wbw/009_031_003.mp3","charTypeName":"word"},{"id":33572,"position":4,"arabic":"أَرْبَابًۭا","translation":"রব হিসেবে (অর্থাৎ হুকুম দেয়ার মালিক)","audioUrl":"wbw/009_031_004.mp3","charTypeName":"word"},{"id":33573,"position":5,"arabic":"مِّن","translation":"বাদ","audioUrl":"wbw/009_031_005.mp3","charTypeName":"word"},{"id":33574,"position":6,"arabic":