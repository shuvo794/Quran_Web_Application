ll who are gifted with [innate] knowledge and none could knowingly reject Our messages unless it be such as would do wrong [to themselves].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3389.mp3","surahId":29,"words":[{"id":48211,"position":1,"arabic":"بَلْ","translation":"বরং","audioUrl":"wbw/029_049_001.mp3","charTypeName":"word"},{"id":48212,"position":2,"arabic":"هُوَ","translation":"তা","audioUrl":"wbw/029_049_002.mp3","charTypeName":"word"},{"id":48213,"position":3,"arabic":"ءَايَـٰتٌۢ","translation":"নিদর্শন","audioUrl":"wbw/029_049_003.mp3","charTypeName":"word"},{"id":48214,"position":4,"arabic":"بَيِّنَـٰتٌۭ","translation":"সুস্পষ্ট","audioUrl":"wbw/029_049_004.mp3","charTypeName":"word"},{"id":48215,"position":5,"arabic":"فِى","translation":"মধ্যে রয়েছে","audioUrl":"wbw/029_049_005.mp3","charTypeName":"word"},{"id":48216,"position":6,"arabic":"صُدُورِ","translation":"অন্তরসমূহের","audioUrl":"wbw/029_049_006.mp3","charTypeName":"word"},{"id":48217,"position":7,"arabic":"ٱلَّذِينَ","translation":"যাদেরকে","audioUrl":"wbw/029_049_007.mp3","charTypeName":"word"},{"id":48218,"position":8,"arabic":"أُوتُوا۟","translation":"দেয়া হয়েছে","audioUrl":"wbw/029_049_008.mp3","charTypeName":"word"},{"id":48219,"position":9,"arabic":"ٱلْعِلْمَ ۚ","translation":"জ্ঞান","audioUrl":"wbw/029_049_009.mp3","charTypeName":"word"},{"id":48221,"position":10,"arabic":"وَمَا","translation":"আর না","audioUrl":"wbw/029_049_011.mp3","charTypeName":"word"},{"id":48222,"position":11,"arabic":"يَجْحَدُ","translation":"অস্বীকার করে (অন্য কেউ)","audioUrl":"wbw/029_049_012.mp3","charTypeName":"word"},{"id":48223,"position":12,"arabic":"بِـَٔايَـٰتِنَآ","translation":"প্রতি নিদর্শনাবলীর আমাদের","audioUrl":"wbw/029_049_013.mp3","charTypeName":"word"},{"id":48224,"position":13,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/029_049_014.mp3","charTypeName":"word"},{"id":48225,"position":14,"arabic":"ٱلظَّـٰلِمُونَ","translation":"সীমালঙ্ঘনকারীরা","audioUrl":"wbw/02