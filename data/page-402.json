ypeName":"word"},{"id":48903,"position":12,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌র","audioUrl":"wbw/029_050_013.mp3","charTypeName":"word"},{"id":48904,"position":13,"arabic":"وَإِنَّمَآ","translation":"আর শুধুমাত্র","audioUrl":"wbw/029_050_014.mp3","charTypeName":"word"},{"id":48905,"position":14,"arabic":"أَنَا۠","translation":"আমি","audioUrl":"wbw/029_050_015.mp3","charTypeName":"word"},{"id":48906,"position":15,"arabic":"نَذِيرٌۭ","translation":"একজন সতর্ককারী","audioUrl":"wbw/029_050_016.mp3","charTypeName":"word"},{"id":48907,"position":16,"arabic":"مُّبِينٌ","translation":"সুস্পষ্ট\"","audioUrl":"wbw/029_050_017.mp3","charTypeName":"word"},{"id":48908,"position":17,"arabic":"٥٠","translation":"(৫০)","audioUrl":null,"charTypeName":"end"}]},{"number":51,"arabic":"أَوَلَمْ يَكْفِهِمْ أَنَّآ أَنزَلْنَا عَلَيْكَ ٱلْكِتَٰبَ يُتْلَىٰ عَلَيْهِمْ ۚ إِنَّ فِى ذَٰلِكَ لَرَحْمَةًۭ وَذِكْرَىٰ لِقَوْمٍۢ يُؤْمِنُونَ","translation":"Why - is it not enough for them that We have bestowed this divine writ on thee from on high, to be conveyed [by thee] to them? For, verily, in it is [manifested Our] grace, and a reminder to people who will believe.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3391.mp3","surahId":29,"words":[{"id":49411,"position":1,"arabic":"أَوَلَمْ","translation":"কি নয়","audioUrl":"wbw/029_051_001.mp3","charTypeName":"word"},{"id":49412,"position":2,"arabic":"يَكْفِهِمْ","translation":"জন্যে যথেষ্ট তাদের","audioUrl":"wbw/029_051_002.mp3","charTypeName":"word"},{"id":49413,"position":3,"arabic":"أَنَّآ","translation":"যে আমরা","audioUrl":"wbw/029_051_003.mp3","charTypeName":"word"},{"id":49414,"position":4,"arabic":"أَنزَلْنَا","translation":"অবতীর্ণ করেছি আমরা","audioUrl":"wbw/029_051_004.mp3","charTypeName":"word"},{"id":49415,"position":5,"arabic":"عَلَيْكَ","translation":"উপর তোমার","audioUrl":"wbw/029_051_005.mp3","charTypeName":"word"},{"id":49416,"position":6,"arabic":"ٱلْكِتَـٰبَ","translation":"কিতাব","audioUrl":"wbw/029_051_006.mp3","charTypeName":"word"},{"id":49417,"position":7,"arabic":"يُتْلَىٰ","translation":"তিলাওয়াত করে শোনানো হয়","audioUrl":"wbw/029_051_007.mp3","charTypeName":"word"},{"id":49418,"position":8,"arabic":"عَلَيْهِمْ ۚ","translation":"কাছে তাদের","audioUrl":"wbw/029_051_008.mp3","charTypeName":"word"},{"id":49420,"position":9,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/029_051_010.mp3","charTypeName":"word"},{"id":49421,"position":10,"arabic":"فِى","translation":"মধ্যে রয়েছে","audioUrl":"wbw/029_051_011.mp3","charTypeName":"word"},{"id":49422,"position":11,"arabic":"ذَٰلِكَ","translation":"এর","audioUrl":"wbw/029_051_012.mp3","charTypeName":"word"},{"id":49423,"position":12,"arabic":"لَرَحْمَةًۭ","translation":"অবশ্যই অনুগ্রহ","audioUrl":"wbw/029_051_013.mp3","charTypeName":"word"},{"id":49424,"position":13,"arabic":"وَذِكْرَىٰ","translation":"ও উপদেশ","audioUrl":"wbw/029_051_014.mp3","charTypeName":"word"},{"id":49425,"position":14,"arabic":"لِقَوْمٍۢ","translation":"জন্যে সম্প্রদায়ের","audioUrl":"wbw/029_051_015.mp3","charTypeName":"word"},{"id":49426,"position":15,"arabic":"يُؤْمِنُونَ","translation":"(যারা) ঈমান আনে","audioUrl":"wbw/029_051_016.mp3","charTypeName":"word"},{"id":49427,"position":16,"arabic":"٥١","translation":"(৫১)","audioUrl":null,"charTypeName":"end"}]},{"number":52,"arabic":"قُلْ كَفَىٰ بِٱللَّهِ بَيْنِى وَبَيْنَكُمْ شَهِيدًۭا ۖ يَعْلَمُ مَا فِى ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ ۗ وَٱلَّذِينَ ءَامَنُوا۟ بِٱلْبَٰطِلِ وَكَفَرُوا۟ بِٱللَّهِ أُو۟لَٰٓئِكَ هُمُ ٱلْخَٰسِرُونَ","translation":"Say [unto those who will not believe]: “God is witness enough between me and you! He knows all that is in the heavens and on earth; and they who are bent on believing in what is false and vain, and thus on denying God - it is they, they who shall be the losers!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3392.mp3","surahId":29,"words":[{"id":49951,"position":1,"arabic":"قُلْ","translation":"(হে নাবী) বলো","audioUrl":"wbw/029_052_001.mp3","charTypeName":"word"},{"id":49952,"position":2,"arabic":"كَفَىٰ","translation":"\"যথেষ্ট","audioUrl":"wbw/029_052_002.mp3","charTypeName":"word"},{"id":49953,"position":3,"arabic":"بِٱللَّهِ","translation":"আল্লাহ্ই","audioUrl":"wbw/029_052_003.mp3","charTypeName":"word"},{"id":49954,"position":4,"arabic":"بَيْنِى","translation":"মাঝে আমার","audioUrl":"wbw/029_052_004.mp3","charTypeName":"word"},{"id":49955,"position":5,"arabic":"وَبَيْنَكُمْ","translation":"ও মাঝে তোমাদের","audioUrl":"wbw/029_052_005.mp3","charTypeName":"word"},{"id":49956,"position":6,"arabic":"شَهِيدًۭا ۖ","translation":"সাক্ষী হিসেবে","audioUrl":"wbw/029_052_006.mp3","charTypeName":"word"},{"id":49958,"position":7,"arabic":"يَعْلَمُ","translation":"তিনি জানেন","audioUrl":"wbw/029_052_008.mp3","charTypeName":"word"},{"id":49959,"position":8,"arabic":"مَا","translation":"যা কিছু","audioUrl":"wbw/029_052_009.mp3","charTypeName":"word"},{"id":49960,"position":9,"arabic":"فِى","translation":"মধ্যে (আছে)","audioUrl":"wbw/029_052_010.mp3","charTypeName":"word"},{"id":49961,"position":10,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশমন্ডলীতে","audioUrl":"wbw/029_052_011.mp3","charTypeName":"word"},{"id":49962,"position":11,"arabic":"وَٱلْأَرْضِ ۗ","translation":"ও পৃথিবীতে","audioUrl":"wbw/029_052_012.mp3","charTypeName":"word"},{"id":49964,"position":12,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/029_052_014.mp3","charTypeName":"word"},{"id":49965,"position":13,"arabic":"ءَامَنُوا۟","translation":"বিশ্বাস করে","audioUrl":"wbw/029_052_015.mp3","charTypeName":"word"},{"id":49966,"position":14,"arabic":"بِٱلْبَـٰطِلِ","translation":"উপর অসত্যের","audioUrl":"wbw/029_052_016.mp3","charTypeName":"word"},{"id":49967,"position":15,"arabic":"وَكَفَرُوا۟","translation":"এবং অস্বীকার করে","audioUrl":"wbw/029_052_017.mp3","charTypeName":"word"},{"id":49968,"position":16,"arabic":"بِٱللَّهِ","translation":"প্রতি আল্লাহর","audioUrl":"wbw/029_052_018.mp3","charTypeName":"word"},{"id":49969,"position":17,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐসব লোক","audioUrl":"wbw/029_052_019.mp3","charTypeName":"word"},{"id":49970,"position":18,"arabic":"هُمُ","translation":"তারাই","audioUrl":"wbw/029_052_020.mp3","charTypeName":"word"},{"id":49971,"position":19,"arabic":"ٱلْخَـٰسِرُونَ","translation":"ক্ষতিগ্রস্ত\"","audioUrl":"wbw/029_052_021.mp3","charTypeName":"word"},{"id":49972,"position":20,"arabic":"٥٢","translation":"(৫২)","audioUrl":null,"charTypeName":"end"}]}]}