,"charTypeName":"word"},{"id":61158,"position":10,"arabic":"مِنْ","translation":"কোনো","audioUrl":"wbw/005_073_011.mp3","charTypeName":"word"},{"id":61159,"position":11,"arabic":"إِلَـٰهٍ","translation":"ইলাহ","audioUrl":"wbw/005_073_012.mp3","charTypeName":"word"},{"id":61160,"position":12,"arabic":"إِلَّآ","translation":"ছাড়া","audioUrl":"wbw/005_073_013.mp3","charTypeName":"word"},{"id":61161,"position":13,"arabic":"إِلَـٰهٌۭ","translation":"ইলাহ","audioUrl":"wbw/005_073_014.mp3","charTypeName":"word"},{"id":61162,"position":14,"arabic":"وَٰحِدٌۭ ۚ","translation":"একজন (অর্থাৎ আল্লাহ)","audioUrl":"wbw/005_073_015.mp3","charTypeName":"word"},{"id":61164,"position":15,"arabic":"وَإِن","translation":"এবং যদি","audioUrl":"wbw/005_073_017.mp3","charTypeName":"word"},{"id":61165,"position":16,"arabic":"لَّمْ","translation":"না","audioUrl":"wbw/005_073_018.mp3","charTypeName":"word"},{"id":61166,"position":17,"arabic":"يَنتَهُوا۟","translation":"তারা নিবৃত্ত হয়","audioUrl":"wbw/005_073_019.mp3","charTypeName":"word"},{"id":61167,"position":18,"arabic":"عَمَّا","translation":"(তা) হতে যা","audioUrl":"wbw/005_073_020.mp3","charTypeName":"word"},{"id":61168,"position":19,"arabic":"يَقُولُونَ","translation":"তারা বলে","audioUrl":"wbw/005_073_021.mp3","charTypeName":"word"},{"id":61169,"position":20,"arabic":"لَيَمَسَّنَّ","translation":"অবশ্যই ধরবে","audioUrl":"wbw/005_073_022.mp3","charTypeName":"word"},{"id":61170,"position":21,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/005_073_023.mp3","charTypeName":"word"},{"id":61171,"position":22,"arabic":"كَفَرُوا۟","translation":"অবিশ্বাস করেছে","audioUrl":"wbw/005_073_024.mp3","charTypeName":"word"},{"id":61172,"position":23,"arabic":"مِنْهُمْ","translation":"মধ্যে হতে তাদের","audioUrl":"wbw/005_073_025.mp3","charTypeName":"word"},{"id":61173,"position":24,"arabic":"عَذَابٌ","translation":"শাস্তি","audioUrl":"wbw/005_073_026.mp3","charTypeName":"word"},{"id":61174,"position":25,"arabic":"أَلِيمٌ","translation":"নিদারুণ","audioUrl":"wbw/005_073_027.mp3","charTypeName":"word"},{"id":61175,"position":26,"arabic":"٧٣","translation":"(৭৩)","audioUrl":null,"charTypeName":"end"}]},{"number":74,"arabic":"أَفَلَا يَتُوبُونَ إِلَى ٱللَّهِ وَيَسْتَغْفِرُونَهُۥ ۚ وَٱللَّهُ غَفُورٌۭ رَّحِيمٌۭ","translation":"Will they not, then, turn towards God in repentance, and ask His forgiveness? For God is much-forgiving, a dispenser of grace.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/743.mp3","surahId":5,"words":[{"id":61613,"position":1,"arabic":"أَفَلَا","translation":"কি তবে না","audioUrl":"wbw/005_074_001.mp3","charTypeName":"word"},{"id":61614,"position":2,"arabic":"يَتُوبُونَ","translation":"তারা ফিরে আসবে","audioUrl":"wbw/005_074_002.mp3","charTypeName":"word"},{"id":61615,"position":3,"arabic":"إِلَى","translation":"দিকে","audioUrl":"wbw/005_074_003.mp3","charTypeName":"word"},{"id":61616,"position":4,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/005_074_004.mp3","charTypeName":"word"},{"id":61617,"position":5,"arabic":"وَيَسْتَغْفِرُونَهُۥ ۚ","translation":"ও তাঁর কাছে ক্ষমা চাইবে (না)","audioUrl":"wbw/005_074_005.mp3","charTypeName":"word"},{"id":61619,"position":6,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/005_074_007.mp3","charTypeName":"word"},{"id":61620,"position":7,"arabic":"غَفُورٌۭ","translation":"ক্ষমাশীল","audioUrl":"wbw/005_074_008.mp3","charTypeName":"word"},{"id":61621,"position":8,"arabic":"رَّحِيمٌۭ","translation":"পরম দয়ালু","audioUrl":"wbw/005_074_009.mp3","charTypeName":"word"},{"id":61622,"position":9,"arabic":"٧٤","translation":"(৭৪)","audioUrl":null,"charTypeName":"end"}]},{"number":75,"arabic":"مَّا ٱلْمَسِيحُ ٱبْنُ مَرْيَمَ إِلَّا رَسُولٌۭ قَدْ خَلَتْ مِن قَبْلِهِ ٱلرُّسُلُ وَأُمُّهُۥ صِدِّيقَةٌۭ ۖ كَانَا يَأْكُلَانِ ٱلطَّعَامَ ۗ ٱنظُرْ كَيْفَ نُبَيِّنُ لَهُمُ ٱلْءَايَٰتِ ثُمَّ ٱنظُرْ أَنَّىٰ يُؤْفَكُونَ","translation":"The Christ, son of Mary, was but an apostle: all [other] apostles had passed away before 