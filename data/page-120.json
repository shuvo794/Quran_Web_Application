005_072_001.mp3","charTypeName":"word"},{"id":60697,"position":2,"arabic":"كَفَرَ","translation":"অবিশ্বাস করেছে","audioUrl":"wbw/005_072_002.mp3","charTypeName":"word"},{"id":60698,"position":3,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/005_072_003.mp3","charTypeName":"word"},{"id":60699,"position":4,"arabic":"قَالُوٓا۟","translation":"বলেছে","audioUrl":"wbw/005_072_004.mp3","charTypeName":"word"},{"id":60700,"position":5,"arabic":"إِنَّ","translation":"\"নিশ্চয়ই","audioUrl":"wbw/005_072_005.mp3","charTypeName":"word"},{"id":60701,"position":6,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/005_072_006.mp3","charTypeName":"word"},{"id":60702,"position":7,"arabic":"هُوَ","translation":"তিনি","audioUrl":"wbw/005_072_007.mp3","charTypeName":"word"},{"id":60703,"position":8,"arabic":"ٱلْمَسِيحُ","translation":"মসীহই","audioUrl":"wbw/005_072_008.mp3","charTypeName":"word"},{"id":60704,"position":9,"arabic":"ٱبْنُ","translation":"পুত্র","audioUrl":"wbw/005_072_009.mp3","charTypeName":"word"},{"id":60705,"position":10,"arabic":"مَرْيَمَ ۖ","translation":"মারইয়ামের\"","audioUrl":"wbw/005_072_010.mp3","charTypeName":"word"},{"id":60707,"position":11,"arabic":"وَقَالَ","translation":"অথচ বলেছিলো","audioUrl":"wbw/005_072_012.mp3","charTypeName":"word"},{"id":60708,"position":12,"arabic":"ٱلْمَسِيحُ","translation":"মসীহ","audioUrl":"wbw/005_072_013.mp3","charTypeName":"word"},{"id":60709,"position":13,"arabic":"يَـٰبَنِىٓ","translation":"\"হে বনী","audioUrl":"wbw/005_072_014.mp3","charTypeName":"word"},{"id":60710,"position":14,"arabic":"إِسْرَٰٓءِيلَ","translation":"ইসরাঈল","audioUrl":"wbw/005_072_015.mp3","charTypeName":"word"},{"id":60711,"position":15,"arabic":"ٱعْبُدُوا۟","translation":"তোমরা ইবাদত করো","audioUrl":"wbw/005_072_016.mp3","charTypeName":"word"},{"id":60712,"position":16,"arabic":"ٱللَّهَ","translation":"আল্লাহর","audioUrl":"wbw/005_072_017.mp3","charTypeName":"word"},{"id":60713,"position":17,"arabic":"رَبِّى","translation":"(যিনি)