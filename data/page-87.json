 who attain to faith and do righteous deeds We shall bring into gardens through which running waters flow, therein to abide beyond the count of time; there shall they have spouses pure: and [thus] We shall bring them unto happiness abounding.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/550.mp3","surahId":4,"words":[{"id":52811,"position":1,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/004_057_001.mp3","charTypeName":"word"},{"id":52812,"position":2,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/004_057_002.mp3","charTypeName":"word"},{"id":52813,"position":3,"arabic":"وَعَمِلُوا۟","translation":"ও কাজ করেছে","audioUrl":"wbw/004_057_003.mp3","charTypeName":"word"},{"id":52814,"position":4,"arabic":"ٱلصَّـٰلِحَـٰتِ","translation":"নেকীর","audioUrl":"wbw/004_057_004.mp3","charTypeName":"word"},{"id":52815,"position":5,"arabic":"سَنُدْخِلُهُمْ","translation":"তাদের প্রবেশ করাব আমরা","audioUrl":"wbw/004_057_005.mp3","charTypeName":"word"},{"id":52816,"position":6,"arabic":"جَنَّـٰتٍۢ","translation":"জান্নাতে","audioUrl":"wbw/004_057_006.mp3","charTypeName":"word"},{"id":52817,"position":7,"arabic":"تَجْرِى","translation":"প্রবাহিত হয়","audioUrl":"wbw/004_057_007.mp3","charTypeName":"word"},{"id":52818,"position":8,"arabic":"مِن","translation":"(থেকে)","audioUrl":"wbw/004_057_008.mp3","charTypeName":"word"},{"id":52819,"position":9,"arabic":"تَحْتِهَا","translation":"তার পাদদেশে","audioUrl":"wbw/004_057_009.mp3","charTypeName":"word"},{"id":52820,"position":10,"arabic":"ٱلْأَنْهَـٰرُ","translation":"ঝর্ণাধারা","audioUrl":"wbw/004_057_010.mp3","charTypeName":"word"},{"id":52821,"position":11,"arabic":"خَـٰلِدِينَ","translation":"চিরস্থায়ী হবে তারা","audioUrl":"wbw/004_057_011.mp3","charTypeName":"word"},{"id":52822,"position":12,"arabic":"فِيهَآ","translation":"তার মধ্যে","audioUrl":"wbw/004_057_012.mp3","charTypeName":"word"},{"id":52823,"position":13,"arabic":"أَبَدًۭا ۖ","translation":"অনন্তকাল ধরে","audioUrl":