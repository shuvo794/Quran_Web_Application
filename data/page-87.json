{"id":87,"ayahs":[{"number":52,"arabic":"أُو۟لَٰٓئِكَ ٱلَّذِينَ لَعَنَهُمُ ٱللَّهُ ۖ وَمَن يَلْعَنِ ٱللَّهُ فَلَن تَجِدَ لَهُۥ نَصِيرًا","translation":"It is they whom God has rejected: and he whom God rejects shall find none to succour him.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/545.mp3","surahId":4,"words":[{"id":50183,"position":1,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐ সব লোক","audioUrl":"wbw/004_052_001.mp3","charTypeName":"word"},{"id":50184,"position":2,"arabic":"ٱلَّذِينَ","translation":"(তারাই) যাদের","audioUrl":"wbw/004_052_002.mp3","charTypeName":"word"},{"id":50185,"position":3,"arabic":"لَعَنَهُمُ","translation":"তাদেরকে অভিশাপ দিয়েছেন","audioUrl":"wbw/004_052_003.mp3","charTypeName":"word"},{"id":50186,"position":4,"arabic":"ٱللَّهُ ۖ","translation":"আল্লাহ","audioUrl":"wbw/004_052_004.mp3","charTypeName":"word"},{"id":50188,"position":5,"arabic":"وَمَن","translation":"এবং যাকে","audioUrl":"wbw/004_052_006.mp3","charTypeName":"word"},{"id":50189,"position":6,"arabic":"يَلْعَنِ","translation":"অভিশাপ দেন","audioUrl":"wbw/004_052_007.mp3","charTypeName":"word"},{"id":50190,"position":7,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/004_052_008.mp3","charTypeName":"word"},{"id":50191,"position":8,"arabic":"فَلَن","translation":"এরপর কক্ষনো না","audioUrl":"wbw/004_052_009.mp3","charTypeName":"word"},{"id":50192,"position":9,"arabic":"تَجِدَ","translation":"তুমি পাবে","audioUrl":"wbw/004_052_010.mp3","charTypeName":"word"},{"id":50193,"position":10,"arabic":"لَهُۥ","translation":"তাঁর জন্য","audioUrl":"wbw/004_052_011.mp3","charTypeName":"word"},{"id":50194,"position":11,"arabic":"نَصِيرًا","translation":"কোন সাহায্যকারী","audioUrl":"wbw/004_052_012.mp3","charTypeName":"word"},{"id":50195,"position":12,"arabic":"٥٢","translation":"(৫২)","audioUrl":null,"charTypeName":"end"}]},{"number":53,"arabic":"أَمْ لَهُمْ نَصِيبٌۭ مِّنَ ٱلْمُلْكِ فَإِذًۭا لَّا يُؤْتُونَ ٱلنَّاسَ نَقِيرًا","translation":"Have they, perchance, a share in [God's] dominion? But [if they had], lo, they would not give to other people as much as [would fill] the groove of a date-stone!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/546.mp3","surahId":4,"words":[{"id":50427,"position":1,"arabic":"أَمْ","translation":"কি","audioUrl":"wbw/004_053_001.mp3","charTypeName":"word"},{"id":50428,"position":2,"arabic":"لَهُمْ","translation":"তাদের জন্য আছে","audioUrl":"wbw/004_053_002.mp3","charTypeName":"word"},{"id":50429,"position":3,"arabic":"نَصِيبٌۭ","translation":"কোন অংশ","audioUrl":"wbw/004_053_003.mp3","charTypeName":"word"},{"id":50430,"position":4,"arabic":"مِّنَ","translation":"(থেকে)","audioUrl":"wbw/004_053_004.mp3","charTypeName":"word"},{"id":50431,"position":5,"arabic":"ٱلْمُلْكِ","translation":"রাজশক্তিতে","audioUrl":"wbw/004_053_005.mp3","charTypeName":"word"},{"id":50432,"position":6,"arabic":"فَإِذًۭا","translation":"অতঃপর যদি (থাকত)","audioUrl":"wbw/004_053_006.mp3","charTypeName":"word"},{"id":50433,"position":7,"arabic":"لَّا","translation":"না","audioUrl":"wbw/004_053_007.mp3","charTypeName":"word"},{"id":50434,"position":8,"arabic":"يُؤْتُونَ","translation":"তারা দিত","audioUrl":"wbw/004_053_008.mp3","charTypeName":"word"},{"id":50435,"position":9,"arabic":"ٱلنَّاسَ","translation":"মানুষকে","audioUrl":"wbw/004_053_009.mp3","charTypeName":"word"},{"id":50436,"position":10,"arabic":"نَقِيرًا","translation":"এক কপর্দকও","audioUrl":"wbw/004_053_010.mp3","charTypeName":"word"},{"id":50437,"position":11,"arabic":"٥٣","translation":"(৫৩)","audioUrl":null,"charTypeName":"end"}]},{"number":54,"arabic":"أَمْ يَحْسُدُونَ ٱلنَّاسَ عَلَىٰ مَآ ءَاتَىٰهُمُ ٱللَّهُ مِن فَضْلِهِۦ ۖ فَقَدْ ءَاتَيْنَآ ءَالَ إِبْرَٰهِيمَ ٱلْكِتَٰبَ وَٱلْحِكْمَةَ وَءَاتَيْنَٰهُم مُّلْكًا عَظِيمًۭا","translation":"Do they, perchance, envy other people for what God has granted them out of His bounty? But then, We did grant revelation and wisdom unto the House of Abraham, and We did bestow on them a mighty dominion:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/547.mp3","surahId":4,"words":[{"id":51065,"position":1,"arabic":"أَمْ","translation":"(তাহলে) কি","audioUrl":"wbw/004_054_001.mp3","charTypeName":"word"},{"id":51066,"position":2,"arabic":"يَحْسُدُونَ","translation":"তারা হিংসা করে","audioUrl":"wbw/004_054_002.mp3","charTypeName":"word"},{"id":51067,"position":3,"arabic":"ٱلنَّاسَ","translation":"লোকদের","audioUrl":"wbw/004_054_003.mp3","charTypeName":"word"},{"id":51068,"position":4,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/004_054_004.mp3","charTypeName":"word"},{"id":51069,"position":5,"arabic":"مَآ","translation":"(এজন্য) যা","audioUrl":"wbw/004_054_005.mp3","charTypeName":"word"},{"id":51070,"position":6,"arabic":"ءَاتَىٰهُمُ","translation":"তাদের দিয়েছেন","audioUrl":"wbw/004_054_006.mp3","charTypeName":"word"},{"id":51071,"position":7,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/004_054_007.mp3","charTypeName":"word"},{"id":51072,"position":8,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/004_054_008.mp3","charTypeName":"word"},{"id":51073,"position":9,"arabic":"فَضْلِهِۦ ۖ","translation":"তাঁর অনুগ্রহ","audioUrl":"wbw/004_054_009.mp3","charTypeName":"word"},{"id":51075,"position":10,"arabic":"فَقَدْ","translation":"(যদি তাই হয়) নিশ্চয় তবে","audioUrl":"wbw/004_054_011.mp3","charTypeName":"word"},{"id":51076,"position":11,"arabic":"ءَاتَيْنَآ","translation":"আমরা দিয়েছি","audioUrl":"wbw/004_054_012.mp3","charTypeName":"word"},{"id":51077,"position":12,"arabic":"ءَالَ","translation":"বংশধরদের","audioUrl":"wbw/004_054_013.mp3","charTypeName":"word"},{"id":51078,"position":13,"arabic":"إِبْرَٰهِيمَ","translation":"ইবরাহিমের","audioUrl":"wbw/004_054_014.mp3","charTypeName":"word"},{"id":51079,"position":14,"arabic":"ٱلْكِتَـٰبَ","translation":"কিতাব","audioUrl":"wbw/004_054_015.mp3","charTypeName":"word"},{"id":51080,"position":15,"arabic":"وَٱلْحِكْمَةَ","translation":"ও হিকমত","audioUrl":"wbw/004_054_016.mp3","charTypeName":"word"},{"id":51081,"position":16,"arabic":"وَءَاتَيْنَـٰهُم","translation":"ও তাদেরকে আমরা দিয়েছি","audioUrl":"wbw/004_054_017.mp3","charTypeName":"word"},{"id":51082,"position":17,"arabic":"مُّلْكًا","translation":"রাজ্য","audioUrl":"wbw/004_054_018.mp3","charTypeName":"word"},{"id":51083,"position":18,"arabic":"عَظِيمًۭا","translation":"বিশাল","audioUrl":"wbw/004_054_019.mp3","charTypeName":"word"},{"id":51084,"position":19,"arabic":"٥٤","translation":"(৫৪)","audioUrl":null,"charTypeName":"end"}]},{"number":55,"arabic":"فَمِنْهُم مَّنْ ءَامَنَ بِهِۦ وَمِنْهُم مَّن صَدَّ عَنْهُ ۚ وَكَفَىٰ بِجَهَنَّمَ سَعِيرًا","translation":"and among them are such as [truly] believe in him, and among them are such as have turned away from him. And nothing could be as burning as [the fire of] hell:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/548.mp3","surahId":4,"words":[{"id":51634,"position":1,"arabic":"فَمِنْهُم","translation":"অতঃপর তাদের মধ্যে","audioUrl":"wbw/004_055_001.mp3","charTypeName":"word"},{"id":51635,"position":2,"arabic":"مَّنْ","translation":"কেউ কেউ","audioUrl":"wbw/004_055_002.mp3","charTypeName":"word"},{"id":51636,"position":3,"arabic":"ءَامَنَ","translation":"ঈমান এনেছে","audioUrl":"wbw/004_055_003.mp3","charTypeName":"word"},{"id":51637,"position":4,"arabic":"بِهِۦ","translation":"তাঁর উপর","audioUrl":"wbw/004_055_004.mp3","charTypeName":"word"},{"id":51638,"position":5,"arabic":"وَمِنْهُم","translation":"আর তাদের মধ্য হতে","audioUrl":"wbw/004_055_005.mp3","charTypeName":"word"},{"id":51639,"position":6,"arabic":"مَّن","translation":"কেউ কেউ","audioUrl":"wbw/004_055_006.mp3","charTypeName":"word"},{"id":51640,"position":7,"arabic":"صَدَّ","translation":"বিরত রয়েছে","audioUrl":"wbw/004_055_007.mp3","charTypeName":"word"},{"id":51641,"position":8,"arabic":"عَنْهُ ۚ","translation":"তা থেকে","audioUrl":"wbw/004_055_008.mp3","charTypeName":"word"},{"id":51643,"position":9,"arabic":"وَكَفَىٰ","translation":"এবং যথেষ্ট","audioUrl":"wbw/004_055_010.mp3","charTypeName":"word"},{"id":51644,"position":10,"arabic":"بِجَهَنَّمَ","translation":"জাহান্নামের","audioUrl":"wbw/004_055_011.mp3","charTypeName":"word"},{"id":51645,"position":11,"arabic":"سَعِيرًا","translation":"অগ্নিশিখা (তাদের জন্য)","audioUrl":"wbw/004_055_012.mp3","charTypeName":"word"},{"id":51646,"position":12,"arabic":"٥٥","translation":"(৫৫)","audioUrl":null,"charTypeName":"end"}]},{"number":56,"arabic":"إِنَّ ٱلَّذِينَ كَفَرُوا۟ بِـَٔايَٰتِنَا سَوْفَ نُصْلِيهِمْ نَارًۭا كُلَّمَا نَضِجَتْ جُلُودُهُم بَدَّلْنَٰهُمْ جُلُودًا غَيْرَهَا لِيَذُوقُوا۟ ٱلْعَذَابَ ۗ إِنَّ ٱللَّهَ كَانَ عَزِيزًا حَكِيمًۭا","translation":"for, verily, those who are bent on denying the truth of Our messages We shall, in time, cause to endure fire: [and] every time their skins are burnt off, We shall replace them with new skins, so that they may taste suffering [in full] Verily, God is almighty, wise.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/549.mp3","surahId":4,"words":[{"id":52476,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/004_056_001.mp3","charTypeName":"word"},{"id":52477,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/004_056_002.mp3","charTypeName":"word"},{"id":52478,"position":3,"arabic":"كَفَرُوا۟","translation":"প্রত্যাখ্যান করেছে","audioUrl":"wbw/004_056_003.mp3","charTypeName":"word"},{"id":52479,"position":4,"arabic":"بِـَٔايَـٰتِنَا","translation":"আমাদের নিদর্শনাদির","audioUrl":"wbw/004_056_004.mp3","charTypeName":"word"},{"id":52480,"position":5,"arabic":"سَوْفَ","translation":"শীঘ্রই","audioUrl":"wbw/004_056_005.mp3","charTypeName":"word"},{"id":52481,"position":6,"arabic":"نُصْلِيهِمْ","translation":"তাদের জ্বালাবো আমরা","audioUrl":"wbw/004_056_006.mp3","charTypeName":"word"},{"id":52482,"position":7,"arabic":"نَارًۭا","translation":"(দোজখের) আগুনে","audioUrl":"wbw/004_056_007.mp3","charTypeName":"word"},{"id":52483,"position":8,"arabic":"كُلَّمَا","translation":"যখনই"