{"id":85,"ayahs":[{"number":38,"arabic":"وَٱلَّذِينَ يُنفِقُونَ أَمْوَٰلَهُمْ رِئَآءَ ٱلنَّاسِ وَلَا يُؤْمِنُونَ بِٱللَّهِ وَلَا بِٱلْيَوْمِ ٱلْءَاخِرِ ۗ وَمَن يَكُنِ ٱلشَّيْطَٰنُ لَهُۥ قَرِينًۭا فَسَآءَ قَرِينًۭا","translation":"And [God does not love] those who spend their possessions on others [only] to be seen and praised by men, the while they believe neither in God nor in the Last Day; and he who has Satan for a soul-mate, how evil a soul-mate has he!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/531.mp3","surahId":4,"words":[{"id":39566,"position":1,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/004_038_001.mp3","charTypeName":"word"},{"id":39567,"position":2,"arabic":"يُنفِقُونَ","translation":"খুরচ করে","audioUrl":"wbw/004_038_002.mp3","charTypeName":"word"},{"id":39568,"position":3,"arabic":"أَمْوَٰلَهُمْ","translation":"তাদের সম্পদ গুলো","audioUrl":"wbw/004_038_003.mp3","charTypeName":"word"},{"id":39569,"position":4,"arabic":"رِئَآءَ","translation":"দেখানোর জন্য","audioUrl":"wbw/004_038_004.mp3","charTypeName":"word"},{"id":39570,"position":5,"arabic":"ٱلنَّاسِ","translation":"লোকদেরকে","audioUrl":"wbw/004_038_005.mp3","charTypeName":"word"},{"id":39571,"position":6,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/004_038_006.mp3","charTypeName":"word"},{"id":39572,"position":7,"arabic":"يُؤْمِنُونَ","translation":"ঈমান আনে","audioUrl":"wbw/004_038_007.mp3","charTypeName":"word"},{"id":39573,"position":8,"arabic":"بِٱللَّهِ","translation":"আল্লাহর উপর","audioUrl":"wbw/004_038_008.mp3","charTypeName":"word"},{"id":39574,"position":9,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/004_038_009.mp3","charTypeName":"word"},{"id":39575,"position":10,"arabic":"بِٱلْيَوْمِ","translation":"দিনের উপর","audioUrl":"wbw/004_038_010.mp3","charTypeName":"word"},{"id":39576,"position":11,"arabic":"ٱلْـَٔاخِرِ ۗ","translation":"আখিরাতের","audioUrl":"wbw/004_038_011.mp3","charTypeName":"word"},{"id":39578,"position":12