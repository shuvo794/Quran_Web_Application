{"id":435,"ayahs":[{"number":4,"arabic":"وَإِن يُكَذِّبُوكَ فَقَدْ كُذِّبَتْ رُسُلٌۭ مِّن قَبْلِكَ ۚ وَإِلَى ٱللَّهِ تُرْجَعُ ٱلْأُمُورُ","translation":"But if they [whose minds are perverted] give thee the lie, [O Prophet, remember that] even so, before thy time, have [other] apostles been given the lie: for [the unbelievers always refuse to admit that] all things go back to God [as their source].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3664.mp3","surahId":35,"words":[{"id":4511,"position":1,"arabic":"وَإِن","translation":"এবং (হে নাবী) যদি","audioUrl":"wbw/035_004_001.mp3","charTypeName":"word"},{"id":4512,"position":2,"arabic":"يُكَذِّبُوكَ","translation":"তোমাকে তারা মিথ্যারোপ করে","audioUrl":"wbw/035_004_002.mp3","charTypeName":"word"},{"id":4513,"position":3,"arabic":"فَقَدْ","translation":"নিশ্চয়ই তবে","audioUrl":"wbw/035_004_003.mp3","charTypeName":"word"},{"id":4514,"position":4,"arabic":"كُذِّبَتْ","translation":"মিথ্যারোপ করা হয়েছে","audioUrl":"wbw/035_004_004.mp3","charTypeName":"word"},{"id":4515,"position":5,"arabic":"رُسُلٌۭ","translation":"রাসূলদেরকে","audioUrl":"wbw/035_004_005.mp3","charTypeName":"word"},{"id":4516,"position":6,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/035_004_006.mp3","charTypeName":"word"},{"id":4517,"position":7,"arabic":"قَبْلِكَ ۚ","translation":"তোমার পূর্বেও","audioUrl":"wbw/035_004_007.mp3","charTypeName":"word"},{"id":4519,"position":8,"arabic":"وَإِلَى","translation":"এবং দিকে","audioUrl":"wbw/035_004_009.mp3","charTypeName":"word"},{"id":4520,"position":9,"arabic":"ٱللَّهِ","translation":"আল্লাহরই","audioUrl":"wbw/035_004_010.mp3","charTypeName":"word"},{"id":4521,"position":10,"arabic":"تُرْجَعُ","translation":"ফিরিয়ে আনা হয়","audioUrl":"wbw/035_004_011.mp3","charTypeName":"word"},{"id":4522,"position":11,"arabic":"ٱلْأُمُورُ","translation":"(সব) বিষয়","audioUrl":"wbw/035_004_012.mp3","charTypeName":"word"},{"id":4523,"position":12,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"يَٰٓأَيُّهَا ٱلنَّاسُ إِنَّ وَعْدَ ٱللَّهِ حَقٌّۭ ۖ فَلَا تَغُرَّنَّكُمُ ٱلْحَيَوٰةُ ٱلدُّنْيَا ۖ وَلَا يَغُرَّنَّكُم بِٱللَّهِ ٱلْغَرُورُ","translation":"O men! Verily, God’s promise [of resurrection] is true indeed: let not, then, the life of this world delude you, and let not [your own] deceptive thoughts about God delude you!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3665.mp3","surahId":35,"words":[{"id":5765,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/035_005_001.mp3","charTypeName":"word"},{"id":5766,"position":2,"arabic":"ٱلنَّاسُ","translation":"মানব সম্প্রদায়","audioUrl":"wbw/035_005_002.mp3","charTypeName":"word"},{"id":5767,"position":3,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/035_005_003.mp3","charTypeName":"word"},{"id":5768,"position":4,"arabic":"وَعْدَ","translation":"প্রতিশ্রুতি","audioUrl":"wbw/035_005_004.mp3","charTypeName":"word"},{"id":5769,"position":5,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/035_005_005.mp3","charTypeName":"word"},{"id":5770,"position":6,"arabic":"حَقٌّۭ ۖ","translation":"সত্য","audioUrl":"wbw/035_005_006.mp3","charTypeName":"word"},{"id":5772,"position":7,"arabic":"فَلَا","translation":"সুতরাং না","audioUrl":"wbw/035_005_008.mp3","charTypeName":"word"},{"id":5773,"position":8,"arabic":"تَغُرَّنَّكُمُ","translation":"তোমাদেরকে ধোঁকা দেয় (যেন)","audioUrl":"wbw/035_005_009.mp3","charTypeName":"word"},{"id":5774,"position":9,"arabic":"ٱلْحَيَوٰةُ","translation":"জীবন","audioUrl":"wbw/035_005_010.mp3","charTypeName":"word"},{"id":5775,"position":10,"arabic":"ٱلدُّنْيَا ۖ","translation":"পার্থিব","audioUrl":"wbw/035_005_011.mp3","charTypeName":"word"},{"id":5777,"position":11,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/035_005_013.mp3","charTypeName":"word"},{"id":5778,"position":12,"arabic":"يَغُرَّنَّكُم","translation":"তোমাদের ধোঁকা দেয় (যেন)","audioUrl":"wbw/035_005_014.mp3","charTypeName":"word"},{"id":5779,"position":13,"arabic":"بِٱللَّهِ","translation":"আল্লাহর ব্যাপারে","audioUrl":"wbw/035_005_015.mp3","charTypeName":"word"},{"id":5780,"position":14,"arabic":"ٱلْغَرُورُ","translation":"কোনো বড় ধোঁকাবাজ (অর্থাৎ শয়তান)","audioUrl":"wbw/035_005_016.mp3","charTypeName":"word"},{"id":5781,"position":15,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"إِنَّ ٱلشَّيْطَٰنَ لَكُمْ عَدُوٌّۭ فَٱتَّخِذُوهُ عَدُوًّا ۚ إِنَّمَا يَدْعُوا۟ حِزْبَهُۥ لِيَكُونُوا۟ مِنْ أَصْحَٰبِ ٱلسَّعِيرِ","translation":"Behold, Satan is a foe unto you: so treat him as a foe. He but calls on his followers to the end that they might find themselves among such as are des­tined for the blazing flame –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3666.mp3","surahId":35,"words":[{"id":7054,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/035_006_001.mp3","charTypeName":"word"},{"id":7055,"position":2,"arabic":"ٱلشَّيْطَـٰنَ","translation":"শয়তান","audioUrl":"wbw/035_006_002.mp3","charTypeName":"word"},{"id":7056,"position":3,"arabic":"لَكُمْ","translation":"তোমাদের জন্যে","audioUrl":"wbw/035_006_003.mp3","charTypeName":"word"},{"id":7057,"position":4,"arabic":"عَدُوٌّۭ","translation":"শত্রু","audioUrl":"wbw/035_006_004.mp3","charTypeName":"word"},{"id":7058,"position":5,"arabic":"فَٱتَّخِذُوهُ","translation":"সুতরাং তোমরা তাকে  গ্রহণ করো","audioUrl":"wbw/035_006_005.mp3","charTypeName":"word"},{"id":7059,"position":6,"arabic":"عَدُوًّا ۚ","translation":"শত্রু হিসেবে","audioUrl":"wbw/035_006_006.mp3","charTypeName":"word"},{"id":7061,"position":7,"arabic":"إِنَّمَا","translation":"মূলতঃ","audioUrl":"wbw/035_006_008.mp3","charTypeName":"word"},{"id":7062,"position":8,"arabic":"يَدْعُوا۟","translation":"সে ডাকে","audioUrl":"wbw/035_006_009.mp3","charTypeName":"word"},{"id":7063,"position":9,"arabic":"حِزْبَهُۥ","translation":"তার দলবলকে","audioUrl":"wbw/035_006_010.mp3","charTypeName":"word"},{"id":7064,"position":10,"arabic":"لِيَكُونُوا۟","translation":"তারা হয় যেন","audioUrl":"wbw/035_006_011.mp3","charTypeName":"word"},{"id":7065,"position":11,"arabic":"مِنْ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/035_006_012.mp3","charTypeName":"word"},{"id":7066,"position":12,"arabic":"أَصْحَـٰبِ","translation":"অধিবাসীদের","audioUrl":"wbw/035_006_013.mp3","charTypeName":"word"},{"id":7067,"position":13,"arabic":"ٱلسَّعِيرِ","translation":"জাহান্নামের","audioUrl":"wbw/035_006_014.mp3","charTypeName":"word"},{"id":7068,"position":14,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"ٱلَّذِينَ كَفَرُوا۟ لَهُمْ عَذَابٌۭ شَدِيدٌۭ ۖ وَٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ لَهُم مَّغْفِرَةٌۭ وَأَجْرٌۭ كَبِيرٌ","translation":"[seeing that] for those who are bent on denying the truth there is suffering severe in store, just as for those who have attained to faith and do righteous deeds there is forgiveness of sins, and a great reward.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3667.mp3","surahId":35,"words":[{"id":8361,"position":1,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/035_007_001.mp3","charTypeName":"word"},{"id":8362,"position":2,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/035_007_002.mp3","charTypeName":"word"},{"id":8363,"position":3,"arabic":"لَهُمْ","translation":"তাদের জন্যে (রয়েছে)","audioUrl":"wbw/035_007_003.mp3","charTypeName":"word"},{"id":8364,"position":4,"arabic":"عَذَابٌۭ","translation":"শাস্তি","audioUrl":"wbw/035_007_004.mp3","charTypeName":"word"},{"id":8365,"position":5,"arabic":"شَدِيدٌۭ ۖ","translation":"কঠোর","audioUrl":"wbw/035_007_005.mp3","charTypeName":"word"},{"id":8367,"position":6,"arabic":"وَٱلَّذِينَ","translation":"আর যারা","audioUrl":"wbw/035_007_007.mp3","charTypeName":"word"},{"id":8368,"position":7,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/035_007_008.mp3","charTypeName":"word"},{"id":8369,"position":8,"arabic":"وَعَمِلُوا۟","translation":"ও কাজ করেছে","audioUrl":"wbw/035_007_009.mp3","charTypeName":"word"},{"id":8370,"position":9,"arabic":"ٱلصَّـٰلِحَـٰتِ","translation":"সৎকাজ","audioUrl":"wbw/035_007_010.mp3","charTypeName":"word"},{"id":8371,"position":10,"arabic":"لَهُم","translation":"তাদের জন্যে (রয়েছে)","audioUrl":"wbw/035_007_011.mp3","charTypeName":"word"},{"id":8372,"position":11,"arabic":"مَّغْفِرَةٌۭ","translation":"ক্ষমা","audioUrl":"wbw/035_007_012.mp3","charTypeName":"word"},{"id":8373,"position":12,"arabic":"وَأَجْرٌۭ","translation":"ও পুরস্কার","audioUrl":"wbw/035_007_013.mp3","charTypeName":"word"},{"id":8374,"position":13,"arabic":"كَبِيرٌ","translation":"বড়","audioUrl":"wbw/035_007_014.mp3","charTypeName":"word"},{"id":8375,"position":14,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"أَفَمَن زُيِّنَ لَهُۥ سُوٓءُ عَمَلِهِۦ فَرَءَاهُ حَسَنًۭا ۖ فَإِنَّ ٱللَّهَ يُضِلُّ مَن يَشَآءُ وَيَهْدِى مَن يَشَآءُ ۖ فَلَا تَذْهَبْ نَفْسُكَ عَلَيْهِمْ حَسَرَٰتٍ ۚ إِنَّ ٱللَّهَ عَلِيمٌۢ بِمَا يَصْنَعُونَ","translation":"Is, then, he to whom the evil of his own doings is [so] alluring that [in the end] he regards it as good [anything but a follower of Satan]? For, verily, God lets go astray him that wills [to go astray], just as He guides him that wills [to be guided]. Hence, [O believer,] do not waste thyself in sorrowing over them: verily, God has full knowledge of all that they do!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3668.mp3","surahId":35,"words":[{"id":9532,"position":1,"arabic":"أَفَمَن","translation":"তবে কি যে","audioUrl":"wbw/035_008_001.mp3","charTypeName":"word"},{"id":9533,"position":2,"arabic":"زُيِّنَ","translation":"শোভন করে দেখানো হয়েছে","audioUrl":"wbw/035_008_002.mp3","charTypeName":"word"},{"id":9534,"position":3,"arabic":"لَهُۥ","translation":"তার কাছে","audioUrl":"wbw/035_008_003.mp3","charTypeName":"word"},{"id":9535,"position":4,"arabic":"سُوٓء