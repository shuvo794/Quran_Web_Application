َ هُوَ يَبُورُ","translation":"He who desires might and glory [ought to know that] all might and glory belong to God [alone]. Unto Him ascend all good words, and the righteous deed does He exalt. But as for those who cunningly devise evil deeds - suffering severe awaits them; and all their devising is bound to come to nought.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3670.mp3","surahId":35,"words":[{"id":11966,"position":1,"arabic":"مَن","translation":"যে","audioUrl":"wbw/035_010_001.mp3","charTypeName":"word"},{"id":11967,"position":2,"arabic":"كَانَ","translation":"ছিল","audioUrl":"wbw/035_010_002.mp3","charTypeName":"word"},{"id":11968,"position":3,"arabic":"يُرِيدُ","translation":"চায়","audioUrl":"wbw/035_010_003.mp3","charTypeName":"word"},{"id":11969,"position":4,"arabic":"ٱلْعِزَّةَ","translation":"সম্মান","audioUrl":"wbw/035_010_004.mp3","charTypeName":"word"},{"id":11970,"position":5,"arabic":"فَلِلَّهِ","translation":"তবে (জেনে রাখুক) আল্লাহর জন্যে","audioUrl":"wbw/035_010_005.mp3","charTypeName":"word"},{"id":11971,"position":6,"arabic":"ٱلْعِزَّةُ","translation":"সম্মান","audioUrl":"wbw/035_010_006.mp3","charTypeName":"word"},{"id":11972,"position":7,"arabic":"جَمِيعًا ۚ","translation":"সবই","audioUrl":"wbw/035_010_007.mp3","charTypeName":"word"},{"id":11974,"position":8,"arabic":"إِلَيْهِ","translation":"তাঁরই দিকে","audioUrl":"wbw/035_010_009.mp3","charTypeName":"word"},{"id":11975,"position":9,"arabic":"يَصْعَدُ","translation":"উঠে","audioUrl":"wbw/035_010_010.mp3","charTypeName":"word"},{"id":11976,"position":10,"arabic":"ٱلْكَلِمُ","translation":"কথা","audioUrl":"wbw/035_010_011.mp3","charTypeName":"word"},{"id":11977,"position":11,"arabic":"ٱلطَّيِّبُ","translation":"ভালো","audioUrl":"wbw/035_010_012.mp3","charTypeName":"word"},{"id":11978,"position":12,"arabic":"وَٱلْعَمَلُ","translation":"এবং কাজ","audioUrl":"wbw/035_010_013.mp3","charTypeName":"word"},{"id":11979,"position":13,"arabic":"ٱلصَّـٰلِحُ","translation":"সত","au