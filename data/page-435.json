ou into either of the two sexes. And no female conceives or gives birth unless it be with His knowledge; and none that is long-lived has his days lengthened - and neither is aught lessened of his days - unless it be thus laid down in [God’s] decree: for, behold, all this is easy for God.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3671.mp3","surahId":35,"words":[{"id":13262,"position":1,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহই","audioUrl":"wbw/035_011_001.mp3","charTypeName":"word"},{"id":13263,"position":2,"arabic":"خَلَقَكُم","translation":"তোমাদের সৃষ্টি করেছেন","audioUrl":"wbw/035_011_002.mp3","charTypeName":"word"},{"id":13264,"position":3,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/035_011_003.mp3","charTypeName":"word"},{"id":13265,"position":4,"arabic":"تُرَابٍۢ","translation":"মাটি","audioUrl":"wbw/035_011_004.mp3","charTypeName":"word"},{"id":13266,"position":5,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/035_011_005.mp3","charTypeName":"word"},{"id":13267,"position":6,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/035_011_006.mp3","charTypeName":"word"},{"id":13268,"position":7,"arabic":"نُّطْفَةٍۢ","translation":"শুক্রবিন্দু","audioUrl":"wbw/035_011_007.mp3","charTypeName":"word"},{"id":13269,"position":8,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/035_011_008.mp3","charTypeName":"word"},{"id":13270,"position":9,"arabic":"جَعَلَكُمْ","translation":"তোমাদেরকে বানিয়েছেন","audioUrl":"wbw/035_011_009.mp3","charTypeName":"word"},{"id":13271,"position":10,"arabic":"أَزْوَٰجًۭا ۚ","translation":"জোড়া জোড়া","audioUrl":"wbw/035_011_010.mp3","charTypeName":"word"},{"id":13273,"position":11,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/035_011_012.mp3","charTypeName":"word"},{"id":13274,"position":12,"arabic":"تَحْمِلُ","translation":"গর্ভধারণ করে","audioUrl":"wbw/035_011_013.mp3","charTypeName":"word"},{"id":13275,"position":13,"arabic":"مِنْ","translation":"কোনো","audioUrl":"wbw/035_011_014