{"id":525,"ayahs":[{"number":32,"arabic":"أَمْ تَأْمُرُهُمْ أَحْلَٰمُهُم بِهَٰذَآ ۚ أَمْ هُمْ قَوْمٌۭ طَاغُونَ","translation":"Is it their minds that bid them [to take] this [attitude] - or are they [simply] people filled with overweening arrogance?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4767.mp3","surahId":52,"words":[{"id":34596,"position":1,"arabic":"أَمْ","translation":"(তবে) কি","audioUrl":"wbw/052_032_001.mp3","charTypeName":"word"},{"id":34597,"position":2,"arabic":"تَأْمُرُهُمْ","translation":"নির্দেশ দেয় তাদেরকে","audioUrl":"wbw/052_032_002.mp3","charTypeName":"word"},{"id":34598,"position":3,"arabic":"أَحْلَـٰمُهُم","translation":"তাদের বিবেকবুদ্ধি","audioUrl":"wbw/052_032_003.mp3","charTypeName":"word"},{"id":34599,"position":4,"arabic":"بِهَـٰذَآ ۚ","translation":"এটা সম্বন্ধে","audioUrl":"wbw/052_032_004.mp3","charTypeName":"word"},{"id":34601,"position":5,"arabic":"أَمْ","translation":"না কি (প্রকৃতপক্ষে)","audioUrl":"wbw/052_032_006.mp3","charTypeName":"word"},{"id":34602,"position":6,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/052_032_007.mp3","charTypeName":"word"},{"id":34603,"position":7,"arabic":"قَوْمٌۭ","translation":"জাতি","audioUrl":"wbw/052_032_008.mp3","charTypeName":"word"},{"id":34604,"position":8,"arabic":"طَاغُونَ","translation":"সীমালঙ্ঘনকারী","audioUrl":"wbw/052_032_009.mp3","charTypeName":"word"},{"id":34605,"position":9,"arabic":"٣٢","translation":"(৩২)","audioUrl":null,"charTypeName":"end"}]},{"number":33,"arabic":"أَمْ يَقُولُونَ تَقَوَّلَهُۥ ۚ بَل لَّا يُؤْمِنُونَ","translation":"Or do they say, “He himself has composed this [message]”? Nay, but they are not willing to believe!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4768.mp3","surahId":52,"words":[{"id":35409,"position":1,"arabic":"أَمْ","translation":"কি","audioUrl":"wbw/052_033_001.mp3","charTypeName":"word"},{"id":35410,"position":2,"arabic":"يَقُولُونَ","translation":"তারা বলে","audioUrl":"wbw/052_033_002.mp3","charTypeName":"word"},{"id":35411,"position":3,"arabic":"تَقَوَّلَهُۥ ۚ","translation":"\"তা সে রচনা করেছে\"","audioUrl":"wbw/052_033_003.mp3","charTypeName":"word"},{"id":35413,"position":4,"arabic":"بَل","translation":"আসল কথা হল","audioUrl":"wbw/052_033_005.mp3","charTypeName":"word"},{"id":35414,"position":5,"arabic":"لَّا","translation":"না","audioUrl":"wbw/052_033_006.mp3","charTypeName":"word"},{"id":35415,"position":6,"arabic":"يُؤْمِنُونَ","translation":"তারা ঈমান আনতে চায়","audioUrl":"wbw/052_033_007.mp3","charTypeName":"word"},{"id":35416,"position":7,"arabic":"٣٣","translation":"(৩৩)","audioUrl":null,"charTypeName":"end"}]},{"number":34,"arabic":"فَلْيَأْتُوا۟ بِحَدِيثٍۢ مِّثْلِهِۦٓ إِن كَانُوا۟ صَٰدِقِينَ","translation":"But then, [if they deem it the work of a mere mortal,] let them produce another discourse like it - if what they say be true!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4769.mp3","surahId":52,"words":[{"id":36335,"position":1,"arabic":"فَلْيَأْتُوا۟","translation":"তারা আনুক তাহলে  (রচনা করে)","audioUrl":"wbw/052_034_001.mp3","charTypeName":"word"},{"id":36336,"position":2,"arabic":"بِحَدِيثٍۢ","translation":"নিয়ে কোনো বাণী","audioUrl":"wbw/052_034_002.mp3","charTypeName":"word"},{"id":36337,"position":3,"arabic":"مِّثْلِهِۦٓ","translation":"তার মতো (মর্যাদাবান)","audioUrl":"wbw/052_034_003.mp3","charTypeName":"word"},{"id":36338,"position":4,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/052_034_004.mp3","charTypeName":"word"},{"id":36339,"position":5,"arabic":"كَانُوا۟","translation":"তারা হয়","audioUrl":"wbw/052_034_005.mp3","charTypeName":"word"},{"id":36340,"position":6,"arabic":"صَـٰدِقِينَ","translation":"সত্যবাদী","audioUrl":"wbw/052_034_006.mp3","charTypeName":"word"},{"id":36341,"position":7,"arabic":"٣٤","translation":"(৩৪)","audioUrl":null,"charTypeName":"end"}]},{"number":35,"arabic":"أَمْ خُلِقُوا۟ مِنْ غَيْرِ شَىْءٍ أَمْ هُمُ ٱلْخَٰلِقُونَ","translation":"[Or do they deny the existence of God?] Have they themselves been created without anything [that might have caused their creation]? or were they, perchance, their own creators?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4770.mp3","surahId":52,"words":[{"id":37205,"position":1,"arabic":"أَمْ","translation":"কি","audioUrl":"wbw/052_035_001.mp3","charTypeName":"word"},{"id":37206,"position":2,"arabic":"خُلِقُوا۟","translation":"তারা সৃষ্টি হয়েছে","audioUrl":"wbw/052_035_002.mp3","charTypeName":"word"},{"id":37207,"position":3,"arabic":"مِنْ","translation":"কোনো","audioUrl":"wbw/052_035_003.mp3","charTypeName":"word"},{"id":37208,"position":4,"arabic":"غَيْرِ","translation":"ব্যতীতই","audioUrl":"wbw/052_035_004.mp3","charTypeName":"word"},{"id":37209,"position":5,"arabic":"شَىْءٍ","translation":"কিছু (কোনো স্রষ্টা)","audioUrl":"wbw/052_035_005.mp3","charTypeName":"word"},{"id":37210,"position":6,"arabic":"أَمْ","translation":"অথবা","audioUrl":"wbw/052_035_006.mp3","charTypeName":"word"},{"id":37211,"position":7,"arabic":"هُمُ","translation":"তারা (নিজেরাই)","audioUrl":"wbw/052_035_007.mp3","charTypeName":"word"},{"id":37212,"position":8,"arabic":"ٱلْخَـٰلِقُونَ","translation":"(নিজেদের) সৃষ্টিকারী","audioUrl":"wbw/052_035_008.mp3","charTypeName":"word"},{"id":37213,"position":9,"arabic":"٣٥","translation":"(৩৫)","audioUrl":null,"charTypeName":"end"}]},{"number":36,"arabic":"أَمْ خَلَقُوا۟ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضَ ۚ بَل لَّا يُوقِنُونَ","translation":"[And] have they created the heavens and the earth? Nay, but they have no certainty of anything!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4771.mp3","surahId":52,"words":[{"id":37957,"position":1,"arabic":"أَمْ","translation":"অথবা","audioUrl":"wbw/052_036_001.mp3","charTypeName":"word"},{"id":37958,"position":2,"arabic":"خَلَقُوا۟","translation":"তারা সৃষ্টি করেছে","audioUrl":"wbw/052_036_002.mp3","charTypeName":"word"},{"id":37959,"position":3,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশ","audioUrl":"wbw/052_036_003.mp3","charTypeName":"word"},{"id":37960,"position":4,"arabic":"وَٱلْأَرْضَ ۚ","translation":"ও পৃথিবী","audioUrl":"wbw/052_036_004.mp3","charTypeName":"word"},{"id":37962,"position":5,"arabic":"بَل","translation":"বরং","audioUrl":"wbw/052_036_006.mp3","charTypeName":"word"},{"id":37963,"position":6,"arabic":"لَّا","translation":"না","audioUrl":"wbw/052_036_007.mp3","charTypeName":"word"},{"id":37964,"position":7,"arabic":"يُوقِنُونَ","translation":"(কোনো কথায়) তারা বিশ্বাস করে","audioUrl":"wbw/052_036_008.mp3","charTypeName":"word"},{"id":37965,"position":8,"arabic":"٣٦","translation":"(৩৬)","audioUrl":null,"charTypeName":"end"}]},{"number":37,"arabic":"أَمْ عِندَهُمْ خَزَآئِنُ رَبِّكَ أَمْ هُمُ ٱلْمُصَۣيْطِرُونَ","translation":"[How could they?] Are thy Sustainer’s treasures with them? Or are they in charge [of destiny]?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4772.mp3","surahId":52,"words":[{"id":38791,"position":1,"arabic":"أَمْ","translation":"তবে কি","audioUrl":"wbw/052_037_001.mp3","charTypeName":"word"},{"id":38792,"position":2,"arabic":"عِندَهُمْ","translation":"তাদের আছে","audioUrl":"wbw/052_037_002.mp3","charTypeName":"word"},{"id":38793,"position":3,"arabic":"خَزَآئِنُ","translation":"ধনভাণ্ডারসমূহ","audioUrl":"wbw/052_037_003.mp3","charTypeName":"word"},{"id":38794,"position":4,"arabic":"رَبِّكَ","translation":"তোমার রবের","audioUrl":"wbw/052_037_004.mp3","charTypeName":"word"},{"id":38795,"position":5,"arabic":"أَمْ","translation":"নাকি","audioUrl":"wbw/052_037_005.mp3","charTypeName":"word"},{"id":38796,"position":6,"arabic":"هُمُ","translation":"তারা","audioUrl":"wbw/052_037_006.mp3","charTypeName":"word"},{"id":38797,"position":7,"arabic":"ٱلْمُصَۣيْطِرُونَ","translation":"(তার উপর) নিয়ন্তা","audioUrl":"wbw/052_037_007.mp3","charTypeName":"word"},{"id":38798,"position":8,"arabic":"٣٧","translation":"(৩৭)","audioUrl":null,"charTypeName":"end"}]},{"number":38,"arabic":"أَمْ لَهُمْ سُلَّمٌۭ يَسْتَمِعُونَ فِيهِ ۖ فَلْيَأْتِ مُسْتَمِعُهُم بِسُلْطَٰنٍۢ مُّبِينٍ","translation":"Or have they a ladder by which they could [ascend to ultimate truths and] listen [to what is beyond the reach of human perception]? Let, then, any of them who have listened [to it] produce a manifest proof [of his knowledge]!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4773.mp3","surahId":52,"words":[{"id":39681,"position":1,"arabic":"أَمْ","translation":"তবে কি","audioUrl":"wbw/052_038_001.mp3","charTypeName":"word"},{"id":39682,"position":2,"arabic":"لَهُمْ","translation":"তাদের আছে","audioUrl":"wbw/052_038_002.mp3","charTypeName":"word"},{"id":39683,"position":3,"arabic":"سُلَّمٌۭ","translation":"কোনো সিঁড়ি","audioUrl":"wbw/052_038_003.mp3","charTypeName":"word"},{"id":39684,"position":4,"arabic":"يَسْتَمِعُونَ","translation":"(তা চড়ে গোপন খবর) তারা শুনে নেয়","audioUrl":"wbw/052_038_004.mp3","charTypeName":"word"},{"id":39685,"position":5,"arabic":"فِيهِ ۖ","translation":"সেখানকার","audioUrl":"wbw/052_038_005.mp3","charTypeName":"word"},{"id":39687,"position":6,"arabic":"فَلْيَأْتِ","translation":"আসুক তাহলে","audioUrl":"wbw/052_038_007.mp3","charTypeName":"word"},{"id":39688,"position":7,"arabic":"مُسْتَمِعُهُم","translation":"তাদের কোনো শ্রোতা","audioUrl":"wbw/052_038_008.mp3","charTypeName":"word"},{"id":39689,"position":8,"arabic":"بِسُلْطَـٰنٍۢ","translation":"নিয়ে প্রমাণসহ","audioUrl":"wbw/052_038_009.mp3","charTypeName":"word"},{"id":39690,"position":9,"arabic":"مُّبِينٍ","translation":"সুস্পষ্ট","audioUrl":"wbw/052_038_010.mp3","charTypeName":"word"},{"id":39691,"position":10,"arabic":"٣٨","translation":"(৩৮)","audioUrl":null,"charTypeName":"end"}]},{"number":39,"arabic":"أَمْ لَهُ ٱلْبَنَٰتُ وَلَكُمُ ٱلْبَنُونَ","translation":"Or, [if you believe in God, how can you believe that] He has [chosen to have] daughters, whereas you yourselves would have [only] sons?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4774.mp3","surahId":52,"words":[{"id":40719,"position":1,"arabic":"أَمْ","translation":"না কি","audioUrl":"wbw/052_039_001.mp3","charTypeName":"word"},{"id":40720,"position":2,"arabic":"لَهُ","translation":"তাঁর জন্যে (নির্ধারণ করে)","audioUrl":"wbw/052_039_002.mp3","charTypeName":"word"},{"id":40721,"position":3,"arabic":"ٱلْبَنَـٰتُ","translation":"কন্যাসমূহ","audioUrl":"wbw/052_039_003.mp3","charTypeName":"word"},{"id":40722,"position":4,"arabic":"وَلَكُمُ","translation":"ও তোমাদের জন্যে (চাও)","audioUrl":"wbw/052_039_004.mp3","charTypeName":"word"},{"id":40723,"position":5,"arabic":"ٱلْبَنُونَ","translation":"পুত্রসমূহ","audioUrl":"wbw/052_039_005.mp3","charTypeName":"word"},{"id":40724,"position":6,"arabic":"٣٩","translation":"(৩৯)","audioUrl":null,"charTypeName":"end"}]},{"number":40,"arabic":"أَمْ تَسْـَٔلُهُمْ أَجْرًۭا فَهُم مِّن مَّغْرَمٍۢ مُّثْقَلُونَ","translation":"Or is it that [they who reject thy message, O Muhammad, fear lest] thou ask of them a reward, so that they would be burdened with debt [if they should listen to thee]?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4775.mp3","surahId":52,"words":[{"id":41171,"position":1,"arabic":"أَمْ","translation":"তবে কি","audioUrl":"wbw/052_040_001.mp3","charTypeName":"word"},{"id":41172,"position":2,"arabic":"تَسْـَٔلُهُمْ","translation":"তাদের কাছে চাচ্ছ তুমি","audioUrl":"wbw/052_040_002.mp3","charTypeName":"word"},{"id":41173,"position":3,"arabic":"أَجْرًۭا","translation":"কোনো পারিশ্রমিক","audioUrl":"wbw/052_040_003.mp3","charTypeName":"word"},{"id":41174,"position":4,"arabic":"فَهُم","translation":"তারা তাই","audioUrl":"wbw/052_040_004.mp3","charTypeName":"word"},{"id":41175,"position":5,"arabic":"مِّن","translation":"কারণে","audioUrl":"wbw/052_040_005.mp3","charTypeName":"word"},{"id":41176,"position":6,"arabic":"مَّغْرَمٍۢ","translation":"জরিমানার","audioUrl":"wbw/052_040_006.mp3","charTypeName":"word"},{"id":41177,"position":7,"arabic":"مُّثْقَلُونَ","translation":"ভারগ্রস্ত হয়ে আছে","audioUrl":"wbw/052_040_007.mp3","charTypeName":"word"},{"id":41178,"position":8,"arabic":"٤٠","translation":"(৪০)","audioUrl":null,"charTypeName":"end"}]},{"number":41,"arabic":"أَمْ عِندَهُمُ ٱلْغَيْبُ فَهُمْ يَكْتُبُونَ","translation":"Or [do they think] that the hidden reality [of all that exists] is almost within their grasp, so that [in time] they can write it down?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4776.mp3","surahId":52,"words":[{"id":42071,"position":1,"arabic":"أَمْ","translation":"নাকি","audioUrl":"wbw/052_041_001.mp3","charTypeName":"word"},{"id":42072,"position":2,"arabic":"عِندَهُمُ","translation":"আছে তাদের কাছে","audioUrl":"wbw/052_041_002.mp3","charTypeName":"word"},{"id":42073,"position":3,"arabic":"ٱلْغَيْبُ","translation":"অদৃশ্যের জ্ঞান","audioUrl":"wbw/052_041_003.mp3","charTypeName":"word"},{"id":42074,"position":4,"arabic":"فَهُمْ","translation":"তারা ফলে","audioUrl":"wbw/052_041_004.mp3","charTypeName":"word"},{"id":42075,"position":5,"arabic":"يَكْتُبُونَ","translation":"লিখে দিতে পারে","audioUrl":"wbw/052_041_005.mp3","charTypeName":"word"},{"id":42076,"position":6,"arabic":"٤١","translation":"(৪১)","audioUrl":null,"charTypeName":"end"}]},{"number":42,"arabic":"أَمْ يُرِيدُونَ كَيْدًۭا ۖ فَٱلَّذِينَ كَفَرُوا۟ هُمُ ٱلْمَكِيدُونَ","translation":"Or do they want to entrap [thee in contradic­tions]? But they who are bent on denying the truth - it is they who are truly entrapped!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4777.mp3","surahId":52,"words":[{"id":42835,"position":1,"arabic":"أَمْ","translation":"তবে কি","audioUrl":"wbw/052_042_001.mp3","charTypeName":"word"},{"id":42836,"position":2,"arabic":"يُرِيدُونَ","translation":"তারা চাচ্ছে","audioUrl":"wbw/052_042_002.mp3","charTypeName":"word"},{"id":42837,"position":3,"arabic":"كَيْدًۭا ۖ","translation":"কোনো ষড়যন্ত্র (করতে)","audioUrl":"wbw/052_042_003.mp3","charTypeName":"word"},{"id":42839,"position":4,"arabic":"فَٱلَّذِينَ","translation":"যারা তাহলে","audioUrl":"wbw/052_042_005.mp3","charTypeName":"word"},{"id":42840,"position":5,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/052_042_006.mp3","charTypeName":"word"},{"id":42841,"position":6,"arabic":"هُمُ","translation":"তারাই","audioUrl":"wbw/052_042_007.mp3","charTypeName":"word"},{"id":42842,"position":7,"arabic":"ٱلْمَكِيدُونَ","translation":"ষড়যন্ত্রের শিকার হবে","audioUrl":"wbw/052_042_008.mp3","charTypeName":"word"},{"id":42843,"position":8,"arabic":"٤٢","translation":"(৪২)","audioUrl":null,"charTypeName":"end"}]},{"number":43,"arabic":"أَمْ لَهُمْ إِلَٰهٌ غَيْرُ ٱللَّهِ ۚ سُبْحَٰنَ ٱللَّهِ عَمَّا يُشْرِكُونَ","translation":"Have they, then, any deity other than God? Utterly remote is God, in His limitless glory, from anything to which men may ascribe a share in His divinity!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4778.mp3","surahId":52,"words":[{"id":43744,"position":1,"arabic":"أَمْ","translation":"নাকি","audioUrl":"wbw/052_043_001.mp3","charTypeName":"word"},{"id":43745,"position":2,"arabic":"لَهُمْ","translation":"তাদের আছে","audioUrl":"wbw/052_043_002.mp3","charTypeName":"word"},{"id":43746,"position":3,"arabic":"إِلَـٰهٌ","translation":"কোনো উপাস্য","audioUrl":"wbw/052_043_003.mp3","charTypeName":"word"},{"id":43747,"position":4,"arabic":"غَيْرُ","translation":"ব্যতীত","audioUrl":"wbw/052_043_004.mp3","charTypeName":"word"},{"id":43748,"position":5,"arabic":"ٱللَّهِ ۚ","translation":"আল্লাহ","audioUrl":"wbw/052_043_005.mp3","charTypeName":"word"},{"id":43750,"position":6,"arabic":"سُبْحَـٰنَ","translation":"মহান পবিত্র","audioUrl":"wbw/052_043_007.mp3","charTypeName":"word"},{"id":43751,"position":7,"arabic":"ٱللَّهِ","translation":"আল্লাহ","audioUrl":"wbw/052_043_008.mp3","charTypeName":"word"},{"id":43752,"position":8,"arabic":"عَمَّا","translation":"তা হতে যার","audioUrl":"wbw/052_043_009.mp3","charTypeName":"word"},{"id":43753,"position":9,"arabic":"يُشْرِكُونَ","translation":"তারা শরিক করছে","audioUrl":"wbw/052_043_010.mp3","charTypeName":"word"},{"id":43754,"position":10,"arabic":"٤٣","translation":"(৪৩)","audioUrl":null,"charTypeName":"end"}]},{"number":44,"arabic":"وَإِن يَرَوْا۟ كِسْفًۭا مِّنَ ٱلسَّمَآءِ سَاقِطًۭا يَقُولُوا۟ سَحَابٌۭ مَّرْكُومٌۭ","translation":"AND YET, if they [who refuse to see the truth] were to see part of the sky falling down, they would [only] say, “[It is but] a mass of clouds!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4779.mp3","surahId":52,"words":[{"id":44374,"position":1,"arabic":"وَإِن","translation":"এবং যদি","audioUrl":"wbw/052_044_001.mp3","charTypeName":"word"},{"id":44375,"position":2,"arabic":"يَرَوْا۟","translation":"তারা দেখে","audioUrl":"wbw/052_044_002.mp3","charTypeName":"word"},{"id":44376,"position":3,"arabic":"كِسْفًۭا","translation":"এক অংশ","audioUrl":"wbw/052_044_003.mp3","charTypeName":"word"},{"id":44377,"position":4,"arabic":"مِّنَ","translation":"হতে","audioUrl":"wbw/052_044_004.mp3","charTypeName":"word"},{"id":44378,"position":5,"arabic":"ٱلسَّمَآءِ","translation":"আকাশ","audioUrl":"wbw/052_044_005.mp3","charTypeName":"word"},{"id":44379,"position":6,"arabic":"سَاقِطًۭا","translation":"ভেঙে পড়তে","audioUrl":"wbw/052_044_006.mp3","charTypeName":"word"},{"id":44380,"position":7,"arabic":"يَقُولُوا۟","translation":"(তবুও) তারা বলবে","audioUrl":"wbw/052_044_007.mp3","charTypeName":"word"},{"id":44381,"position":8,"arabic":"سَحَابٌۭ","translation":"\"(সেটা) মেঘ","audioUrl":"wbw/052_044_008.mp3","charTypeName":"word"},{"id":44382,"position":9,"arabic":"مَّرْكُومٌۭ","translation":"পুঞ্জীভূত\"","audioUrl":"wbw/052_044_009.mp3","charTypeName":"word"},{"id":44383,"position":10,"arabic":"٤٤","translation":"(৪৪)","audioUrl":null,"charTypeName":"end"}]},{"number":45,"arabic":"فَذَرْهُمْ حَتَّىٰ يُلَٰقُوا۟ يَوْمَهُمُ ٱلَّذِى فِيهِ يُصْعَقُونَ","translation":"Hence, leave them alone until they face that [Judgment] Day of theirs, when they will be stricken with terror:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4780.mp3","surahId":52,"words":[{"id":45113,"position":1,"arabic":"فَذَرْهُمْ","translation":"(হে নবী) অতএব তাদেরকে ছেড়ে দাও","audioUrl":"wbw/052_045_001.mp3","charTypeName":"word"},{"id":45114,"position":2,"arabic":"حَتَّىٰ","translation":"যতক্ষণ না","audioUrl":"wbw/052_045_002.mp3","charTypeName":"word"},{"id":45115,"position":3,"arabic":"يُلَـٰقُوا۟","translation":"তারা সাক্ষাৎ করবে","audioUrl":"wbw/052_045_003.mp3","charTypeName":"word"},{"id":45116,"position":4,"arabic":"يَوْمَهُمُ","translation":"তাদের সেই দিনের","audioUrl":"wbw/052_045_004.mp3","charTypeName":"word"},{"id":45117,"position":5,"arabic":"ٱلَّذِى","translation":"যা (এমন যে)","audioUrl":"wbw/052_045_005.mp3","charTypeName":"word"},{"id":45118,"position":6,"arabic":"فِيهِ","translation":"তার মধ্যে","audioUrl":"wbw/052_045_006.mp3","charTypeName":"word"},{"id":45119,"position":7,"arabic":"يُصْعَقُونَ","translation":"তাদেরকে শাস্তির মধ্যে নিক্ষেপ করা হবে","audioUrl":"wbw/052_045_007.mp3","charTypeName":"word"},{"id":45120,"position":8,"arabic":"٤٥","translation":"(৪৫)","audioUrl":null,"charTypeName":"end"}]},{"number":46,"arabic":"يَوْمَ لَا يُغْنِى عَنْهُمْ كَيْدُهُمْ شَيْـًۭٔا وَلَا هُمْ يُنصَرُونَ","translation":"the Day when none of their scheming will be of the least avail to them, and they will receive no succour.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4781.mp3","surahId":52,"words":[{"id":45849,"position":1,"arabic":"يَوْمَ","translation":"সেদিন","audioUrl":"wbw/052_046_001.mp3","charTypeName":"word"},{"id":45850,"position":2,"arabic":"لَا","translation":"না","audioUrl":"wbw/052_046_002.mp3","charTypeName":"word"},{"id":45851,"position":3,"arabic":"يُغْنِى","translation":"কাজে আসবে","audioUrl":"wbw/052_046_003.mp3","charTypeName":"word"},{"id":45852,"position":4,"arabic":"عَنْهُمْ","translation":"তাদের জন্যে","audioUrl":"wbw/052_046_004.mp3","charTypeName":"word"},{"id":45853,"position":5,"arabic":"كَيْدُهُمْ","translation":"তাদের ষড়যন্ত্র","audioUrl":"wbw/052_046_005.mp3","charTypeName":"word"},{"id":45854,"position":6,"arabic":"شَيْـًۭٔا","translation":"কিছুমাত্রও","audioUrl":"wbw/052_046_006.mp3","charTypeName":"word"},{"id":45855,"position":7,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/052_046_007.mp3","charTypeName":"word"},{"id":45856,"position":8,"arabic":"هُمْ","translation":"তাদের","audioUrl":"wbw/052_046_008.mp3","charTypeName":"word"},{"id":45857,"position":9,"arabic":"يُنصَرُونَ","translation":"সাহায্য করা হবে","audioUrl":"wbw/052_046_009.mp3","charTypeName":"word"},{"id":45858,"position":10,"arabic":"٤٦","translation":"(৪৬)","audioUrl":null,"charTypeName":"end"}]},{"number":47,"arabic":"وَإِنَّ لِلَّذِينَ ظَلَمُوا۟ عَذَابًۭا دُونَ ذَٰلِكَ وَلَٰكِنَّ أَكْثَرَهُمْ لَا يَعْلَمُونَ","translation":"But, verily, for those who are bent on doing evil, there is suffering in store [even] closer at hand than that [supreme suffering in the hereafter]: but most of them are not aware of it.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4782.mp3","surahId":52,"words":[{"id":46604,"position":1,"arabic":"وَإِنَّ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/052_047_001.mp3","charTypeName":"word"},{"id":46605,"position":2,"arabic":"لِلَّذِينَ","translation":"(তাদের) জন্যে যারা","audioUrl":"wbw/052_047_002.mp3","charTypeName":"word"},{"id":46606,"position":3,"arabic":"ظَلَمُوا۟","translation":"সীমালঙ্ঘন করেছে","audioUrl":"wbw/052_047_003.mp3","charTypeName":"word"},{"id":46607,"position":4,"arabic":"عَذَابًۭا","translation":"শাস্তি (রয়েছে)","audioUrl":"wbw/052_047_004.mp3","charTypeName":"word"},{"id":46608,"position":5,"arabic":"دُونَ","translation":"ছাড়াও","audioUrl":"wbw/052_047_005.mp3","charTypeName":"word"},{"id":46609,"position":6,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/052_047_006.mp3","charTypeName":"word"},{"id":46610,"position":7,"arabic":"وَلَـٰكِنَّ","translation":"কিন্তু","audioUrl":"wbw/052_047_007.mp3","charTypeName":"word"},{"id":46611,"position":8,"arabic":"أَكْثَرَهُمْ","translation":"তাদের অধিকাংশই","audioUrl":"wbw/052_047_008.mp3","charTypeName":"word"},{"id":46612,"position":9,"arabic":"لَا","translation":"না","audioUrl":"wbw/052_047_009.mp3","charTypeName":"word"},{"id":46613,"position":10,"arabic":"يَعْلَمُونَ","translation":"তারা জানে","audioUrl":"wbw/052_047_010.mp3","charTypeName":"word"},{"id":46614,"position":11,"arabic":"٤٧","translation":"(৪৭)","audioUrl":null,"charTypeName":"end"}]},{"number":48,"arabic":"وَٱصْبِرْ لِحُكْمِ رَبِّكَ فَإِنَّكَ بِأَعْيُنِنَا ۖ وَسَبِّحْ بِحَمْدِ رَبِّكَ حِينَ تَقُومُ","translation":"And so, await in patience thy Sustainer’s judgment, for thou art well within Our sight. And extol thy Sustainer’s limitless glory and praise whenever thou risest up,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4783.mp3","surahId":52,"words":[{"id":47215,"position":1,"arabic":"وَٱصْبِرْ","translation":"এবং (হে নবী) ধৈর্য ধর","audioUrl":"wbw/052_048_001.mp3","charTypeName":"word"},{"id":47216,"position":2,"arabic":"لِحُكْمِ","translation":"সিদ্ধান্তের জন্যে","audioUrl":"wbw/052_048_002.mp3","charTypeName":"word"},{"id":47217,"position":3,"arabic":"رَبِّكَ","translation":"তোমার রবের","audioUrl":"wbw/052_048_003.mp3","charTypeName":"word"},{"id":47218,"position":4,"arabic":"فَإِنَّكَ","translation":"অতঃপর তুমি নিশ্চয়ই","audioUrl":"wbw/052_048_004.mp3","charTypeName":"word"},{"id":47219,"position":5,"arabic":"بِأَعْيُنِنَا ۖ","translation":"আমাদের চোখে (আছ)","audioUrl":"wbw/052_048_005.mp3","charTypeName":"word"},{"id":47221,"position":6,"arabic":"وَسَبِّحْ","translation":"এবং পবিত্রতা ঘোষণা করো","audioUrl":"wbw/052_048_007.mp3","charTypeName":"word"},{"id":47222,"position":7,"arabic":"بِحَمْدِ","translation":"প্রশংসার সাথে","audioUrl":"wbw/052_048_008.mp3","charTypeName":"word"},{"id":47223,"position":8,"arabic":"رَبِّكَ","translation":"তোমার রবের","audioUrl":"wbw/052_048_009.mp3","charTypeName":"word"},{"id":47224,"position":9,"arabic":"حِينَ","translation":"যখন","audioUrl":"wbw/052_048_010.mp3","charTypeName":"word"},{"id":47225,"position":10,"arabic":"تَقُومُ","translation":"তুমি উঠবে","audioUrl":"wbw/052_048_011.mp3","charTypeName":"word"},{"id":47226,"position":11,"arabic":"٤٨","translation":"(৪৮)","audioUrl":null,"charTypeName":"end"}]},{"number":49,"arabic":"وَمِنَ ٱلَّيْلِ فَسَبِّحْهُ وَإِدْبَٰرَ ٱلنُّجُومِ","translation":"and extol His glory at night, and at the time when the stars retreat.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4784.mp3","surahId":52,"words":[{"id":48042,"position":1,"arabic":"وَمِنَ","translation":"এবং কিছু অংশে","audioUrl":"wbw/052_049_001.mp3","charTypeName":"word"},{"id":48043,"position":2,"arabic":"ٱلَّيْلِ","translation":"রাতের","audioUrl":"wbw/052_049_002.mp3","charTypeName":"word"},{"id":48044,"position":3,"arabic":"فَسَبِّحْهُ","translation":"অতঃপর তার পবিত্র মহিমা ঘোষণা করো","audioUrl":"wbw/052_049_003.mp3","charTypeName":"word"},{"id":48045,"position":4,"arabic":"وَإِدْبَـٰرَ","translation":"এবং অস্তগমনেও","audioUrl":"wbw/052_049_004.mp3","charTypeName":"word"},{"id":48046,"position":5,"arabic":"ٱلنُّجُومِ","translation":"তারাদের","audioUrl":"wbw/052_049_005.mp3","charTypeName":"word"},{"id":48047,"position":6,"arabic":"٤٩","translation":"(৪৯)","audioUrl":null,"charTypeName":"end"}]}]}