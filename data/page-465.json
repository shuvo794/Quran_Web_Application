{"id":465,"ayahs":[{"number":57,"arabic":"أَوْ تَقُولَ لَوْ أَنَّ ٱللَّهَ هَدَىٰنِى لَكُنتُ مِنَ ٱلْمُتَّقِينَ","translation":"or lest he should say, “If God had but guided me, I would surely have been among those who are conscious of Him!”-","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4115.mp3","surahId":39,"words":[{"id":52556,"position":1,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/039_057_001.mp3","charTypeName":"word"},{"id":52557,"position":2,"arabic":"تَقُولَ","translation":"কেউ বলে","audioUrl":"wbw/039_057_002.mp3","charTypeName":"word"},{"id":52558,"position":3,"arabic":"لَوْ","translation":"\"যদি (এমন হতো)","audioUrl":"wbw/039_057_003.mp3","charTypeName":"word"},{"id":52559,"position":4,"arabic":"أَنَّ","translation":"\"যে","audioUrl":"wbw/039_057_004.mp3","charTypeName":"word"},{"id":52560,"position":5,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/039_057_005.mp3","charTypeName":"word"},{"id":52561,"position":6,"arabic":"هَدَىٰنِى","translation":"আমাকে পথপ্রদর্শন করতেন","audioUrl":"wbw/039_057_006.mp3","charTypeName":"word"},{"id":52562,"position":7,"arabic":"لَكُنتُ","translation":"অবশ্যই আমি হতাম","audioUrl":"wbw/039_057_007.mp3","charTypeName":"word"},{"id":52563,"position":8,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/039_057_008.mp3","charTypeName":"word"},{"id":52564,"position":9,"arabic":"ٱلْمُتَّقِينَ","translation":"মুত্তাকীদের\"","audioUrl":"wbw/039_057_009.mp3","charTypeName":"word"},{"id":52565,"position":10,"arabic":"٥٧","translation":"(৫৭)","audioUrl":null,"charTypeName":"end"}]},{"number":58,"arabic":"أَوْ تَقُولَ حِينَ تَرَى ٱلْعَذَابَ لَوْ أَنَّ لِى كَرَّةًۭ فَأَكُونَ مِنَ ٱلْمُحْسِنِينَ","translation":"or lest he should say, when he becomes aware of the suffering [that awaits him], “Would that I had a second chance [in life], so that I could be among the doers of good!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4116.mp3","surahId":39,"words":[{"id":53380,"position":1,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/039_058_001.mp3","charTypeName":"word"},{"id":53381,"position":2,"arabic":"تَقُولَ","translation":"কেউ বলে","audioUrl":"wbw/039_058_002.mp3","charTypeName":"word"},{"id":53382,"position":3,"arabic":"حِينَ","translation":"যখন","audioUrl":"wbw/039_058_003.mp3","charTypeName":"word"},{"id":53383,"position":4,"arabic":"تَرَى","translation":"দেখবে","audioUrl":"wbw/039_058_004.mp3","charTypeName":"word"},{"id":53384,"position":5,"arabic":"ٱلْعَذَابَ","translation":"শাস্তি","audioUrl":"wbw/039_058_005.mp3","charTypeName":"word"},{"id":53385,"position":6,"arabic":"لَوْ","translation":"\"যদি (সম্ভব হতো)","audioUrl":"wbw/039_058_006.mp3","charTypeName":"word"},{"id":53386,"position":7,"arabic":"أَنَّ","translation":"যে","audioUrl":"wbw/039_058_007.mp3","charTypeName":"word"},{"id":53387,"position":8,"arabic":"لِى","translation":"আমার জন্যে","audioUrl":"wbw/039_058_008.mp3","charTypeName":"word"},{"id":53388,"position":9,"arabic":"كَرَّةًۭ","translation":"একবার প্রত্যাবর্তন","audioUrl":"wbw/039_058_009.mp3","charTypeName":"word"},{"id":53389,"position":10,"arabic":"فَأَكُونَ","translation":"হতাম আমি তবে","audioUrl":"wbw/039_058_010.mp3","charTypeName":"word"},{"id":53390,"position":11,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/039_058_011.mp3","charTypeName":"word"},{"id":53391,"position":12,"arabic":"ٱلْمُحْسِنِينَ","translation":"সৎকর্মপরায়ণদের\"","audioUrl":"wbw/039_058_012.mp3","charTypeName":"word"},{"id":53392,"position":13,"arabic":"٥٨","translation":"(৫৮)","audioUrl":null,"charTypeName":"end"}]},{"number":59,"arabic":"بَلَىٰ قَدْ جَآءَتْكَ ءَايَٰتِى فَكَذَّبْتَ بِهَا وَٱسْتَكْبَرْتَ وَكُنتَ مِنَ ٱلْكَٰفِرِينَ","translation":"[But God will reply:] “Yea, indeed! My mes­sages did come unto thee; but thou gavest them the lie, and wert filled with false pride, and wert among those who deny the truth!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4117.mp3","surahId":39,"words":[{"id":53624,"position":1,"arabic":"بَلَىٰ","translation":"\"(বলা হবে) কেন নয়","audioUrl":"wbw/039_059_001.mp3","charTypeName":"word"},{"id":53625,"position":2,"arabic":"قَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/039_059_002.mp3","charTypeName":"word"},{"id":53626,"position":3,"arabic":"جَآءَتْكَ","translation":"তোমার কাছে এসেছিলো","audioUrl":"wbw/039_059_003.mp3","charTypeName":"word"},{"id":53627,"position":4,"arabic":"ءَايَـٰتِى","translation":"আমার নিদর্শনাবলী","audioUrl":"wbw/039_059_004.mp3","charTypeName":"word"},{"id":53628,"position":5,"arabic":"فَكَذَّبْتَ","translation":"তুমি তখন মিথ্যা বলেছিলে","audioUrl":"wbw/039_059_005.mp3","charTypeName":"word"},{"id":53629,"position":6,"arabic":"بِهَا","translation":"তা","audioUrl":"wbw/039_059_006.mp3","charTypeName":"word"},{"id":53630,"position":7,"arabic":"وَٱسْتَكْبَرْتَ","translation":"এবং তুমি অহংকার করেছিলে","audioUrl":"wbw/039_059_007.mp3","charTypeName":"word"},{"id":53631,"position":8,"arabic":"وَكُنتَ","translation":"এবং তুমি হয়েছিলে","audioUrl":"wbw/039_059_008.mp3","charTypeName":"word"},{"id":53632,"position":9,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/039_059_009.mp3","charTypeName":"word"},{"id":53633,"position":10,"arabic":"ٱلْكَـٰفِرِينَ","translation":"কাফেরদের","audioUrl":"wbw/039_059_010.mp3","charTypeName":"word"},{"id":53634,"position":11,"arabic":"٥٩","translation":"(৫৯)","audioUrl":null,"charTypeName":"end"}]},{"number":60,"arabic":"وَيَوْمَ ٱلْقِيَٰمَةِ تَرَى ٱلَّذِينَ كَذَبُوا۟ عَلَى ٱللَّهِ وُجُوهُهُم مُّسْوَدَّةٌ ۚ أَلَيْسَ فِى جَهَنَّمَ مَثْوًۭى لِّلْمُتَكَبِّرِينَ","translation":"And [so,] on the Day of Resurrection thou wilt see all who invented lies about God [with] their faces darkened [by grief and ignominy]. Is not hell the [proper] abode for all who are given to false pride?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4118.mp3","surahId":39,"words":[{"id":54186,"position":1,"arabic":"وَيَوْمَ","translation":"এবং দিনে","audioUrl":"wbw/039_060_001.mp3","charTypeName":"word"},{"id":54187,"position":2,"arabic":"ٱلْقِيَـٰمَةِ","translation":"ক্বিয়ামাতের","audioUrl":"wbw/039_060_002.mp3","charTypeName":"word"},{"id":54188,"position":3,"arabic":"تَرَى","translation":"তুমি দেখবে","audioUrl":"wbw/039_060_003.mp3","charTypeName":"word"},{"id":54189,"position":4,"arabic":"ٱلَّذِينَ","translation":"(তাদেরকে) যারা","audioUrl":"wbw/039_060_004.mp3","charTypeName":"word"},{"id":54190,"position":5,"arabic":"كَذَبُوا۟","translation":"মিথ্যারোপ করেছে","audioUrl":"wbw/039_060_005.mp3","charTypeName":"word"},{"id":54191,"position":6,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/039_060_006.mp3","charTypeName":"word"},{"id":54192,"position":7,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/039_060_007.mp3","charTypeName":"word"},{"id":54193,"position":8,"arabic":"وُجُوهُهُم","translation":"তাদের মুখগুলো","audioUrl":"wbw/039_060_008.mp3","charTypeName":"word"},{"id":54194,"position":9,"arabic":"مُّسْوَدَّةٌ ۚ","translation":"কালো (হয়ে গিয়েছে)","audioUrl":"wbw/039_060_009.mp3","charTypeName":"word"},{"id":54196,"position":10,"arabic":"أَلَيْسَ","translation":"নয় কি","audioUrl":"wbw/039_060_011.mp3","charTypeName":"word"},{"id":54197,"position":11,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/039_060_012.mp3","charTypeName":"word"},{"id":54198,"position":12,"arabic":"جَهَنَّمَ","translation":"জাহান্নামের","audioUrl":"wbw/039_060_013.mp3","charTypeName":"word"},{"id":54199,"position":13,"arabic":"مَثْوًۭى","translation":"আবাসস্থল (যথেষ্ঠ)","audioUrl":"wbw/039_060_014.mp3","charTypeName":"word"},{"id":54200,"position":14,"arabic":"لِّلْمُتَكَبِّرِينَ","translation":"অহংকারকারীদের জন্যে","audioUrl":"wbw/039_060_015.mp3","charTypeName":"word"},{"id":54201,"position":15,"arabic":"٦٠","translation":"(৬০)","audioUrl":null,"charTypeName":"end"}]},{"number":61,"arabic":"وَيُنَجِّى ٱللَّهُ ٱلَّذِينَ ٱتَّقَوْا۟ بِمَفَازَتِهِمْ لَا يَمَسُّهُمُ ٱلسُّوٓءُ وَلَا هُمْ يَحْزَنُونَ","translation":"But God will safeguard all who were conscious of Him, [and will grant them happiness] by virtue of their [inner] triumphs; no evil shall ever touch them, and neither shall they grieve.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4119.mp3","surahId":39,"words":[{"id":54793,"position":1,"arabic":"وَيُنَجِّى","translation":"এবং উদ্ধার করবেন","audioUrl":"wbw/039_061_001.mp3","charTypeName":"word"},{"id":54794,"position":2,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/039_061_002.mp3","charTypeName":"word"},{"id":54795,"position":3,"arabic":"ٱلَّذِينَ","translation":"(তাদেরকে) যারা","audioUrl":"wbw/039_061_003.mp3","charTypeName":"word"},{"id":54796,"position":4,"arabic":"ٱتَّقَوْا۟","translation":"আত্মরক্ষা করেছিলো","audioUrl":"wbw/039_061_004.mp3","charTypeName":"word"},{"id":54797,"position":5,"arabic":"بِمَفَازَتِهِمْ","translation":"তাদের সাফল্যসহ","audioUrl":"wbw/039_061_005.mp3","charTypeName":"word"},{"id":54798,"position":6,"arabic":"لَا","translation":"না","audioUrl":"wbw/039_061_006.mp3","charTypeName":"word"},{"id":54799,"position":7,"arabic":"يَمَسُّهُمُ","translation":"তাদেরকে স্পর্শ করবে","audioUrl":"wbw/039_061_007.mp3","charTypeName":"word"},{"id":54800,"position":8,"arabic":"ٱلسُّوٓءُ","translation":"অমঙ্গল","audioUrl":"wbw/039_061_008.mp3","charTypeName":"word"},{"id":54801,"position":9,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/039_061_009.mp3","charTypeName":"word"},{"id":54802,"position":10,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/039_061_010.mp3","charTypeName":"word"},{"id":54803,"position":11,"arabic":"يَحْزَنُونَ","translation":"চিন্তিত হবে","audioUrl":"wbw/039_061_011.mp3","charTypeName":"word"},{"id":54804,"position":12,"arabic":"٦١","translation":"(৬১)","audioUrl":null,"charTypeName":"end"}]},{"number":62,"arabic":"ٱللَّهُ خَٰلِقُ كُلِّ شَىْءٍۢ ۖ وَهُوَ عَلَىٰ كُلِّ شَىْءٍۢ وَكِيلٌۭ","translation":"GOD is the Creator of all things, and He alone has the power to determine the fate of all things.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4120.mp3","surahId":39,"words":[{"id":55842,"position":1,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/039_062_001.mp3","charTypeName":"word"},{"id":55843,"position":2,"arabic":"خَـٰلِقُ","translation":"স্রষ্টা","audioUrl":"wbw/039_062_002.mp3","charTypeName":"word"},{"id":55844,"position":3,"arabic":"كُلِّ","translation":"প্রত্যেক","audioUrl":"wbw/039_062_003.mp3","charTypeName":"word"},{"id":55845,"position":4,"arabic":"شَىْءٍۢ ۖ","translation":"জিনিসের","audioUrl":"wbw/039_062_004.mp3","charTypeName":"word"},{"id":55847,"position":5,"arabic":"وَهُوَ","translation":"এবং তিনি","audioUrl":"wbw/039_062_006.mp3","charTypeName":"word"},{"id":55848,"position":6,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/039_062_007.mp3","charTypeName":"word"},{"id":55849,"position":7,"arabic":"كُلِّ","translation":"সব","audioUrl":"wbw/039_062_008.mp3","charTypeName":"word"},{"id":55850,"position":8,"arabic":"شَىْءٍۢ","translation":"জিনিসের","audioUrl":"wbw/039_062_009.mp3","charTypeName":"word"},{"id":55851,"position":9,"arabic":"وَكِيلٌۭ","translation":"কর্মবিধায়ক","audioUrl":"wbw/039_062_010.mp3","charTypeName":"word"},{"id":55852,"position":10,"arabic":"٦٢","translation":"(৬২)","audioUrl":null,"charTypeName":"end"}]},{"number":63,"arabic":"لَّهُۥ مَقَالِيدُ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ ۗ وَٱلَّذِينَ كَفَرُوا۟ بِـَٔايَٰتِ ٱللَّهِ أُو۟لَٰٓئِكَ هُمُ ٱلْخَٰسِرُونَ","translation":"His are the keys [to the mysteries] of the heavens and the earth: and they who are bent on denying the truth of God’s messages - it is they, they, who are the losers!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4121.mp3","surahId":39,"words":[{"id":56295,"position":1,"arabic":"لَّهُۥ","translation":"তাঁরই (কাছে রক্ষিত)","audioUrl":"wbw/039_063_001.mp3","charTypeName":"word"},{"id":56296,"position":2,"arabic":"مَقَالِيدُ","translation":"চাবিসমূহ","audioUrl":"wbw/039_063_002.mp3","charTypeName":"word"},{"id":56297,"position":3,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশের","audioUrl":"wbw/039_063_003.mp3","charTypeName":"word"},{"id":56298,"position":4,"arabic":"وَٱلْأَرْضِ ۗ","translation":"ও পৃথিবীর","audioUrl":"wbw/039_063_004.mp3","charTypeName":"word"},{"id":56300,"position":5,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/039_063_006.mp3","charTypeName":"word"},{"id":56301,"position":6,"arabic":"كَفَرُوا۟","translation":"অমান্য করেছে","audioUrl":"wbw/039_063_007.mp3","charTypeName":"word"},{"id":56302,"position":7,"arabic":"بِـَٔايَـٰتِ","translation":"আয়াতগুলোকে","audioUrl":"wbw/039_063_008.mp3","charTypeName":"word"},{"id":56303,"position":8,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/039_063_009.mp3","charTypeName":"word"},{"id":56304,"position":9,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐসব লোক","audioUrl":"wbw/039_063_010.mp3","charTypeName":"word"},{"id":56305,"position":10,"arabic":"هُمُ","translation":"তারাই","audioUrl":"wbw/039_063_011.mp3","charTypeName":"word"},{"id":56306,"position":11,"arabic":"ٱلْخَـٰسِرُونَ","translation":"ক্ষতিগ্রস্ত","audioUrl":"wbw/039_063_012.mp3","charTypeName":"word"},{"id":56307,"position":12,"arabic":"٦٣","translation":"(৬৩)","audioUrl":null,"charTypeName":"end"}]},{"number":64,"arabic":"قُلْ أَفَغَيْرَ ٱللَّهِ تَأْمُرُوٓنِّىٓ أَعْبُدُ أَيُّهَا ٱلْجَٰهِلُونَ","translation":"Say: “Is it, then, something other than God that you bid me to worship, O you who are unaware [of right and wrong]?”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4122.mp3","surahId":39,"words":[{"id":56895,"position":1,"arabic":"قُلْ","translation":"(হে নাবী) বলো","audioUrl":"wbw/039_064_001.mp3","charTypeName":"word"},{"id":56896,"position":2,"arabic":"أَفَغَيْرَ","translation":"\"তবে কি ব্যতীত","audioUrl":"wbw/039_064_002.mp3","charTypeName":"word"},{"id":56897,"position":3,"arabic":"ٱللَّهِ","translation":"আল্লাহ","audioUrl":"wbw/039_064_003.mp3","charTypeName":"word"},{"id":56898,"position":4,"arabic":"تَأْمُرُوٓنِّىٓ","translation":"আমাকে তোমরা নির্দেশ দিচ্ছো (যে)","audioUrl":"wbw/039_064_004.mp3","charTypeName":"word"},{"id":56899,"position":5,"arabic":"أَعْبُدُ","translation":"ইবাদাত করবো আমি (অন্যকে)","audioUrl":"wbw/039_064_005.mp3","charTypeName":"word"},{"id":56900,"position":6,"arabic":"أَيُّهَا","translation":"ও হে","audioUrl":"wbw/039_064_006.mp3","charTypeName":"word"},{"id":56901,"position":7,"arabic":"ٱلْجَـٰهِلُونَ","translation":"অজ্ঞ লোকেরা\"","audioUrl":"wbw/039_064_007.mp3","charTypeName":"word"},{"id":56902,"position":8,"arabic":"٦٤","translation":"(৬৪)","audioUrl":null,"charTypeName":"end"}]},{"number":65,"arabic":"وَلَقَدْ أُوحِىَ إِلَيْكَ وَإِلَى ٱلَّذِينَ مِن قَبْلِكَ لَئِنْ أَشْرَكْتَ لَيَحْبَطَنَّ عَمَلُكَ وَلَتَكُونَنَّ مِنَ ٱلْخَٰسِرِينَ","translation":"And yet, it has already been revealed to thee [O man,] as well as to those who lived before thee, that if thou ever ascribe divine powers to aught but God, all thy works shall most certainly have been in vain: for [in the life to come] thou shalt most certainly be among the lost.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4123.mp3","surahId":39,"words":[{"id":56968,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/039_065_001.mp3","charTypeName":"word"},{"id":56969,"position":2,"arabic":"أُوحِىَ","translation":"ওহী করা হয়েছে","audioUrl":"wbw/039_065_002.mp3","charTypeName":"word"},{"id":56970,"position":3,"arabic":"إِلَيْكَ","translation":"তোমার প্রতি","audioUrl":"wbw/039_065_003.mp3","charTypeName":"word"},{"id":56971,"position":4,"arabic":"وَإِلَى","translation":"এবং প্রতি","audioUrl":"wbw/039_065_004.mp3","charTypeName":"word"},{"id":56972,"position":5,"arabic":"ٱلَّذِينَ","translation":"(তাদের) যারা","audioUrl":"wbw/039_065_005.mp3","charTypeName":"word"},{"id":56973,"position":6,"arabic":"مِن","translation":"মধ্য হতে","audioUrl":"wbw/039_065_006.mp3","charTypeName":"word"},{"id":56974,"position":7,"arabic":"قَبْلِكَ","translation":"তোমার পূর্বে (ছিলো)","audioUrl":"wbw/039_065_007.mp3","charTypeName":"word"},{"id":56975,"position":8,"arabic":"لَئِنْ","translation":"অবশ্য যদি","audioUrl":"wbw/039_065_008.mp3","charTypeName":"word"},{"id":56976,"position":9,"arabic":"أَشْرَكْتَ","translation":"তুমি শরিক করো","audioUrl":"wbw/039_065_009.mp3","charTypeName":"word"},{"id":56977,"position":10,"arabic":"لَيَحْبَطَنَّ","translation":"বিনষ্ট হবে যাবেই","audioUrl":"wbw/039_065_010.mp3","charTypeName":"word"},{"id":56978,"position":11,"arabic":"عَمَلُكَ","translation":"তোমার কৃতকর্ম","audioUrl":"wbw/039_065_011.mp3","charTypeName":"word"},{"id":56979,"position":12,"arabic":"وَلَتَكُونَنَّ","translation":"এবং তুমি অবশ্যই হয়ে যাবে","audioUrl":"wbw/039_065_012.mp3","charTypeName":"word"},{"id":56980,"position":13,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/039_065_013.mp3","charTypeName":"word"},{"id":56981,"position":14,"arabic":"ٱلْخَـٰسِرِينَ","translation":"ক্ষতিগ্রস্তদের","audioUrl":"wbw/039_065_014.mp3","charTypeName":"word"},{"id":56982,"position":15,"arabic":"٦٥","translation":"(৬৫)","audioUrl":null,"charTypeName":"end"}]},{"number":66,"arabic":"بَلِ ٱللَّهَ فَٱعْبُدْ وَكُن مِّنَ ٱلشَّٰكِرِينَ","translation":"Nay, but thou shalt worship God [alone], and be among those who are grateful [to Him]!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4124.mp3","surahId":39,"words":[{"id":57865,"position":1,"arabic":"بَلِ","translation":"বরং","audioUrl":"wbw/039_066_001.mp3","charTypeName":"word"},{"id":57866,"position":2,"arabic":"ٱللَّهَ","translation":"আল্লাহরই","audioUrl":"wbw/039_066_002.mp3","charTypeName":"word"},{"id":57867,"position":3,"arabic":"فَٱعْبُدْ","translation":"তুমি তাই  ইবাদাত করো","audioUrl":"wbw/039_066_003.mp3","charTypeName":"word"},{"id":57868,"position":4,"arabic":"وَكُن","translation":"এবং হয়ে যাও","audioUrl":"wbw/039_066_004.mp3","charTypeName":"word"},{"id":57869,"position":5,"arabic":"مِّنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/039_066_005.mp3","charTypeName":"word"},{"id":57870,"position":6,"arabic":"ٱلشَّـٰكِرِينَ","translation":"কৃতজ্ঞদের","audioUrl":"wbw/039_066_006.mp3","charTypeName":"word"},{"id":57871,"position":7,"arabic":"٦٦","translation":"(৬৬)","audioUrl":null,"charTypeName":"end"}]},{"number":67,"arabic":"وَمَا قَدَرُوا۟ ٱللَّهَ حَقَّ قَدْرِهِۦ وَٱلْأَرْضُ جَمِيعًۭا قَبْضَتُهُۥ يَوْمَ ٱلْقِيَٰمَةِ وَٱلسَّمَٰوَٰتُ مَطْوِيَّٰتٌۢ بِيَمِينِهِۦ ۚ سُبْحَٰنَهُۥ وَتَعَٰلَىٰ عَمَّا يُشْرِكُونَ","translation":"And no true understanding of God have they [who worship aught beside Him], inasmuch as the whole of the earth will be as a [mere] handful to Him on Resurrection Day, and the heavens will be rolled up in His right hand: limitless is He in His glory, and sublimely exalted above anything to which they may ascribe a share in His divinity!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4125.mp3","surahId":39,"words":[{"id":58025,"position":1,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/039_067_001.mp3","charTypeName":"word"},{"id":58026,"position":2,"arabic":"قَدَرُوا۟","translation":"তারা সম্মান করে","audioUrl":"wbw/039_067_002.mp3","charTypeName":"word"},{"id":58027,"position":3,"arabic":"ٱللَّهَ","translation":"আল্লাহর","audioUrl":"wbw/039_067_003.mp3","charTypeName":"word"},{"id":58028,"position":4,"arabic":"حَقَّ","translation":"যথোচিত","audioUrl":"wbw/039_067_004.mp3","charTypeName":"word"},{"id":58029,"position":5,"arabic":"قَدْرِهِۦ","translation":"তাঁর সম্মান","audioUrl":"wbw/039_067_005.mp3","charTypeName":"word"},{"id":58030,"position":6,"arabic":"وَٱلْأَرْضُ","translation":"অথচ পৃথিবী","audioUrl":"wbw/039_067_006.mp3","charTypeName":"word"},{"id":58031,"position":7,"arabic":"جَمِيعًۭا","translation":"সবটাই","audioUrl":"wbw/039_067_007.mp3","charTypeName":"word"},{"id":58032,"position":8,"arabic":"قَبْضَتُهُۥ","translation":"তাঁরই মুঠিতে হবে","audioUrl":"wbw/039_067_008.mp3","charTypeName":"word"},{"id":58033,"position":9,"arabic":"يَوْمَ","translation":"দিনে","audioUrl":"wbw/039_067_009.mp3","charTypeName":"word"},{"id":58034,"position":10,"arabic":"ٱلْقِيَـٰمَةِ","translation":"ক্বিয়ামাতের","audioUrl":"wbw/039_067_010.mp3","charTypeName":"word"},{"id":58035,"position":11,"arabic":"وَٱلسَّمَـٰوَٰتُ","translation":"ও আকাশ (থাকবে)","audioUrl":"wbw/039_067_011.mp3","charTypeName":"word"},{"id":58036,"position":12,"arabic":"مَطْوِيَّـٰتٌۢ","translation":"গুটানো অবস্থায়","audioUrl":"wbw/039_067_012.mp3","charTypeName":"word"},{"id":58037,"position":13,"arabic":"بِيَمِينِهِۦ ۚ","translation":"তাঁর ডান হাতের মধ্যে","audioUrl":"wbw/039_067_013.mp3","charTypeName":"word"},{"id":58039,"position":14,"arabic":"سُبْحَـٰنَهُۥ","translation":"তিনি মহান পবিত্র","audioUrl":"wbw/039_067_015.mp3","charTypeName":"word"},{"id":58040,"position":15,"arabic":"وَتَعَـٰلَىٰ","translation":"ও বহু ঊর্ধ্বে","audioUrl":"wbw/039_067_016.mp3","charTypeName":"word"},{"id":58041,"position":16,"arabic":"عَمَّا","translation":"তা হ'তে যা","audioUrl":"wbw/039_067_017.mp3","charTypeName":"word"},{"id":58042,"position":17,"arabic":"يُشْرِكُونَ","translation":"তারা শরিক করে","audioUrl":"wbw/039_067_018.mp3","charTypeName":"word"},{"id":58043,"position":18,"arabic":"٦٧","translation":"(৬৭)","audioUrl":null,"charTypeName":"end"}]}]}