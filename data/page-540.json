ition":4,"arabic":"مَا","translation":"যা","audioUrl":"wbw/057_023_004.mp3","charTypeName":"word"},{"id":25816,"position":5,"arabic":"فَاتَكُمْ","translation":"তোমরা হারাও","audioUrl":"wbw/057_023_005.mp3","charTypeName":"word"},{"id":25817,"position":6,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/057_023_006.mp3","charTypeName":"word"},{"id":25818,"position":7,"arabic":"تَفْرَحُوا۟","translation":"উল্লাসিত হও তোমরা","audioUrl":"wbw/057_023_007.mp3","charTypeName":"word"},{"id":25819,"position":8,"arabic":"بِمَآ","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/057_023_008.mp3","charTypeName":"word"},{"id":25820,"position":9,"arabic":"ءَاتَىٰكُمْ ۗ","translation":"তোমাদের দান করেন তিনি","audioUrl":"wbw/057_023_009.mp3","charTypeName":"word"},{"id":25822,"position":10,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ্‌‌","audioUrl":"wbw/057_023_011.mp3","charTypeName":"word"},{"id":25823,"position":11,"arabic":"لَا","translation":"না","audioUrl":"wbw/057_023_012.mp3","charTypeName":"word"},{"id":25824,"position":12,"arabic":"يُحِبُّ","translation":"ভালবাসেন","audioUrl":"wbw/057_023_013.mp3","charTypeName":"word"},{"id":25825,"position":13,"arabic":"كُلَّ","translation":"প্রত্যেক","audioUrl":"wbw/057_023_014.mp3","charTypeName":"word"},{"id":25826,"position":14,"arabic":"مُخْتَالٍۢ","translation":"উদ্ধত","audioUrl":"wbw/057_023_015.mp3","charTypeName":"word"},{"id":25827,"position":15,"arabic":"فَخُورٍ","translation":"অহংকারীকে","audioUrl":"wbw/057_023_016.mp3","charTypeName":"word"},{"id":25828,"position":16,"arabic":"٢٣","translation":"(২৩)","audioUrl":null,"charTypeName":"end"}]},{"number":24,"arabic":"ٱلَّذِينَ يَبْخَلُونَ وَيَأْمُرُونَ ٱلنَّاسَ بِٱلْبُخْلِ ۗ وَمَن يَتَوَلَّ فَإِنَّ ٱللَّهَ هُوَ ٱلْغَنِىُّ ٱلْحَمِيدُ","translation":"those who are niggardly [with God’s bounty] and bid others to be niggardly! And he who turns his back [on this truth ought to know that], verily, God alone is self-sufficient, the One to whom all praise is due!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5099.mp3","surahId":57,"words":[{"id":26541,"position":1,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/057_024_001.mp3","charTypeName":"word"},{"id":26542,"position":2,"arabic":"يَبْخَلُونَ","translation":"কৃপণতা করে","audioUrl":"wbw/057_024_002.mp3","charTypeName":"word"},{"id":26543,"position":3,"arabic":"وَيَأْمُرُونَ","translation":"ও নির্দেশ দেয়","audioUrl":"wbw/057_024_003.mp3","charTypeName":"word"},{"id":26544,"position":4,"arabic":"ٱلنَّاسَ","translation":"লোকদেরকে","audioUrl":"wbw/057_024_004.mp3","charTypeName":"word"},{"id":26545,"position":5,"arabic":"بِٱلْبُخْلِ ۗ","translation":"কৃপণতার ব্যাপারে","audioUrl":"wbw/057_024_005.mp3","charTypeName":"word"},{"id":26547,"position":6,"arabic":"وَمَن","translation":"এবং যে","audioUrl":"wbw/057_024_007.mp3","charTypeName":"word"},{"id":26548,"position":7,"arabic":"يَتَوَلَّ","translation":"মুখ ফিরিয়ে নেয় (সে জেনে রাখুক)","audioUrl":"wbw/057_024_008.mp3","charTypeName":"word"},{"id":26549,"position":8,"arabic":"فَإِنَّ","translation":"তবে নিশ্চয়ই","audioUrl":"wbw/057_024_009.mp3","charTypeName":"word"},{"id":26550,"position":9,"arabic":"ٱللَّهَ","translation":"আল্লাহ্‌","audioUrl":"wbw/057_024_010.mp3","charTypeName":"word"},{"id":26551,"position":10,"arabic":"هُوَ","translation":"তিনিই","audioUrl":"wbw/057_024_011.mp3","charTypeName":"word"},{"id":26552,"position":11,"arabic":"ٱلْغَنِىُّ","translation":"অভাবমুক্ত","audioUrl":"wbw/057_024_012.mp3","charTypeName":"word"},{"id":26553,"position":12,"arabic":"ٱلْحَمِيدُ","translation":"প্রশংসিত","audioUrl":"wbw/057_024_013.mp3","charTypeName":"word"},{"id":26554,"position":13,"arabic":"٢٤","translation":"(২৪)","audioUrl":null,"charTypeName":"end"}]}]}