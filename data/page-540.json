{"id":540,"ayahs":[{"number":19,"arabic":"وَٱلَّذِينَ ءَامَنُوا۟ بِٱللَّهِ وَرُسُلِهِۦٓ أُو۟لَٰٓئِكَ هُمُ ٱلصِّدِّيقُونَ ۖ وَٱلشُّهَدَآءُ عِندَ رَبِّهِمْ لَهُمْ أَجْرُهُمْ وَنُورُهُمْ ۖ وَٱلَّذِينَ كَفَرُوا۟ وَكَذَّبُوا۟ بِـَٔايَٰتِنَآ أُو۟لَٰٓئِكَ أَصْحَٰبُ ٱلْجَحِيمِ","translation":"For, they who have attained to faith in God and His Apostle - it is they, they who uphold the truth, and they who bear witness [thereto] before God: [and so] they shall have their reward and their light! But as for those who are bent on denying the truth and on giving the lie to Our messages - it is they who are destined for the blazing fire!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5094.mp3","surahId":57,"words":[{"id":21282,"position":1,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/057_019_001.mp3","charTypeName":"word"},{"id":21283,"position":2,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/057_019_002.mp3","charTypeName":"word"},{"id":21284,"position":3,"arabic":"بِٱللَّهِ","translation":"আল্লাহ্‌র উপর","audioUrl":"wbw/057_019_003.mp3","charTypeName":"word"},{"id":21285,"position":4,"arabic":"وَرُسُلِهِۦٓ","translation":"এবং তঁর রাসূলদের (উপর)","audioUrl":"wbw/057_019_004.mp3","charTypeName":"word"},{"id":21286,"position":5,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐসব লোক","audioUrl":"wbw/057_019_005.mp3","charTypeName":"word"},{"id":21287,"position":6,"arabic":"هُمُ","translation":"তারাই","audioUrl":"wbw/057_019_006.mp3","charTypeName":"word"},{"id":21288,"position":7,"arabic":"ٱلصِّدِّيقُونَ ۖ","translation":"সিদ্দিক (সত্যনিষ্ঠ)","audioUrl":"wbw/057_019_007.mp3","charTypeName":"word"},{"id":21290,"position":8,"arabic":"وَٱلشُّهَدَآءُ","translation":"এবং (তারাই) শহীদ","audioUrl":"wbw/057_019_009.mp3","charTypeName":"word"},{"id":21291,"position":9,"arabic":"عِندَ","translation":"কাছে","audioUrl":"wbw/057_019_010.mp3","charTypeName":"word"},{"id":21292,"position":10,"arabic":"رَبِّهِمْ","translation":"তাদের রবের","audioUrl":"wbw/057_019_011.mp3","charTypeName":"word"},{"id":21293,"position":11,"arabic":"لَهُمْ","translation":"তাদের জন্যে রয়েছে","audioUrl":"wbw/057_019_012.mp3","charTypeName":"word"},{"id":21294,"position":12,"arabic":"أَجْرُهُمْ","translation":"তাদের পুরস্কার","audioUrl":"wbw/057_019_013.mp3","charTypeName":"word"},{"id":21295,"position":13,"arabic":"وَنُورُهُمْ ۖ","translation":"ও তাদের জ্যোতি","audioUrl":"wbw/057_019_014.mp3","charTypeName":"word"},{"id":21297,"position":14,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/057_019_016.mp3","charTypeName":"word"},{"id":21298,"position":15,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/057_019_017.mp3","charTypeName":"word"},{"id":21299,"position":16,"arabic":"وَكَذَّبُوا۟","translation":"ও মিথ্যা মনে করেছে","audioUrl":"wbw/057_019_018.mp3","charTypeName":"word"},{"id":21300,"position":17,"arabic":"بِـَٔايَـٰتِنَآ","translation":"আমাদের আয়াত গুলোকে","audioUrl":"wbw/057_019_019.mp3","charTypeName":"word"},{"id":21301,"position":18,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐসব লোক","audioUrl":"wbw/057_019_020.mp3","charTypeName":"word"},{"id":21302,"position":19,"arabic":"أَصْحَـٰبُ","translation":"অধিবাসী (হবে)","audioUrl":"wbw/057_019_021.mp3","charTypeName":"word"},{"id":21303,"position":20,"arabic":"ٱلْجَحِيمِ","translation":"জাহান্নামের","audioUrl":"wbw/057_019_022.mp3","charTypeName":"word"},{"id":21304,"position":21,"arabic":"١٩","translation":"(১৯)","audioUrl":null,"charTypeName":"end"}]},{"number":20,"arabic":"ٱعْلَمُوٓا۟ أَنَّمَا ٱلْحَيَوٰةُ ٱلدُّنْيَا لَعِبٌۭ وَلَهْوٌۭ وَزِينَةٌۭ وَتَفَاخُرٌۢ بَيْنَكُمْ وَتَكَاثُرٌۭ فِى ٱلْأَمْوَٰلِ وَٱلْأَوْلَٰدِ ۖ كَمَثَلِ غَيْثٍ أَعْجَبَ ٱلْكُفَّارَ نَبَاتُهُۥ ثُمَّ يَهِيجُ فَتَرَىٰهُ مُصْفَرًّۭا ثُمَّ يَكُونُ حُطَٰمًۭا ۖ وَفِى ٱلْءَاخِرَةِ عَذَابٌۭ شَدِيدٌۭ وَمَغْفِرَةٌۭ مِّنَ ٱللَّهِ وَرِضْوَٰنٌۭ ۚ وَمَا ٱلْحَيَوٰةُ ٱلدُّنْيَآ إِلَّا مَتَٰعُ ٱلْغُرُورِ","translation":"KNOW [O men] that the life of this world is but a play and a passing delight, and a beautiful show, and [the cause of] your boastful vying with one another, and [of your] greed for more and more riches and children. Its parable is that of [life-giving] rain: the herbage which it causes to grow delights the tillers of the soil; but then it withers, and thou canst see it turn yellow; and in the end it crumbles into dust. But [the abiding truth of man’s condition will become fully apparent] in the life to come: [either] suffering severe, or God’s forgiveness and His goodly acceptance: for the life of this world is nothing but an enjoyment of self-delusion.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5095.mp3","surahId":57,"words":[{"id":22603,"position":1,"arabic":"ٱعْلَمُوٓا۟","translation":"তোমরা জেনে রাখ","audioUrl":"wbw/057_020_001.mp3","charTypeName":"word"},{"id":22604,"position":2,"arabic":"أَنَّمَا","translation":"প্রকৃতপক্ষে","audioUrl":"wbw/057_020_002.mp3","charTypeName":"word"},{"id":22605,"position":3,"arabic":"ٱلْحَيَوٰةُ","translation":"জীবন","audioUrl":"wbw/057_020_003.mp3","charTypeName":"word"},{"id":22606,"position":4,"arabic":"ٱلدُّنْيَا","translation":"(এই) দুনিয়ার","audioUrl":"wbw/057_020_004.mp3","charTypeName":"word"},{"id":22607,"position":5,"arabic":"لَعِبٌۭ","translation":"ক্রীড়া","audioUrl":"wbw/057_020_005.mp3","charTypeName":"word"},{"id":22608,"position":6,"arabic":"وَلَهْوٌۭ","translation":"ও কৌতুক (মাত্র)","audioUrl":"wbw/057_020_006.mp3","charTypeName":"word"},{"id":22609,"position":7,"arabic":"وَزِينَةٌۭ","translation":"এবং জাঁকজমক","audioUrl":"wbw/057_020_007.mp3","charTypeName":"word"},{"id":22610,"position":8,"arabic":"وَتَفَاخُرٌۢ","translation":"ও পারস্পরিক গৌরব অহংকার","audioUrl":"wbw/057_020_008.mp3","charTypeName":"word"},{"id":22611,"position":9,"arabic":"بَيْنَكُمْ","translation":"তোমাদের মাঝে","audioUrl":"wbw/057_020_009.mp3","charTypeName":"word"},{"id":22612,"position":10,"arabic":"وَتَكَاثُرٌۭ","translation":"ও পারস্পরিক প্রাচুর্য লাভের প্রতিযোগিতা","audioUrl":"wbw/057_020_010.mp3","charTypeName":"word"},{"id":22613,"position":11,"arabic":"فِى","translation":"ক্ষেত্রে","audioUrl":"wbw/057_020_011.mp3","charTypeName":"word"},{"id":22614,"position":12,"arabic":"ٱلْأَمْوَٰلِ","translation":"সম্পদ সমুহের","audioUrl":"wbw/057_020_012.mp3","charTypeName":"word"},{"id":22615,"position":13,"arabic":"وَٱلْأَوْلَـٰدِ ۖ","translation":"ও সন্তানসন্ততিতে","audioUrl":"wbw/057_020_013.mp3","charTypeName":"word"},{"id":22617,"position":14,"arabic":"كَمَثَلِ","translation":"(এর) উপমা যেমন","audioUrl":"wbw/057_020_015.mp3","charTypeName":"word"},{"id":22618,"position":15,"arabic":"غَيْثٍ","translation":"বৃষ্টি (হলে)","audioUrl":"wbw/057_020_016.mp3","charTypeName":"word"},{"id":22619,"position":16,"arabic":"أَعْجَبَ","translation":"চমৎকৃত করে","audioUrl":"wbw/057_020_017.mp3","charTypeName":"word"},{"id":22620,"position":17,"arabic":"ٱلْكُفَّارَ","translation":"কৃষককে","audioUrl":"wbw/057_020_018.mp3","charTypeName":"word"},{"id":22621,"position":18,"arabic":"نَبَاتُهُۥ","translation":"তার উদ্ভিদ সম্ভার","audioUrl":"wbw/057_020_019.mp3","charTypeName":"word"},{"id":22622,"position":19,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/057_020_020.mp3","charTypeName":"word"},{"id":22623,"position":20,"arabic":"يَهِيجُ","translation":"শুকিয়ে  যায়","audioUrl":"wbw/057_020_021.mp3","charTypeName":"word"},{"id":22624,"position":21,"arabic":"فَتَرَىٰهُ","translation":"অতঃপর তুমি তা দেখ","audioUrl":"wbw/057_020_022.mp3","charTypeName":"word"},{"id":22625,"position":22,"arabic":"مُصْفَرًّۭا","translation":"হলুদবর্ণ (হতে)","audioUrl":"wbw/057_020_023.mp3","charTypeName":"word"},{"id":22626,"position":23,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/057_020_024.mp3","charTypeName":"word"},{"id":22627,"position":24,"arabic":"يَكُونُ","translation":"সেটা হয়ে যায়","audioUrl":"wbw/057_020_025.mp3","charTypeName":"word"},{"id":22628,"position":25,"arabic":"حُطَـٰمًۭا ۖ","translation":"খড়কুটা","audioUrl":"wbw/057_020_026.mp3","charTypeName":"word"},{"id":22630,"position":26,"arabic":"وَفِى","translation":"আর মধ্যে আছে","audioUrl":"wbw/057_020_028.mp3","charTypeName":"word"},{"id":22631,"position":27,"arabic":"ٱلْـَٔاخِرَةِ","translation":"আখেরাতের","audioUrl":"wbw/057_020_029.mp3","charTypeName":"word"},{"id":22632,"position":28,"arabic":"عَذَابٌۭ","translation":"শাস্তি","audioUrl":"wbw/057_020_030.mp3","charTypeName":"word"},{"id":22633,"position":29,"arabic":"شَدِيدٌۭ","translation":"কঠোর","audioUrl":"wbw/057_020_031.mp3","charTypeName":"word"},{"id":22634,"position":30,"arabic":"وَمَغْفِرَةٌۭ","translation":"আর (আছে) ক্ষমা","audioUrl":"wbw/057_020_032.mp3","charTypeName":"word"},{"id":22635,"position":31,"arabic":"مِّنَ","translation":"পক্ষ হতে","audioUrl":"wbw/057_020_033.mp3","charTypeName":"word"},{"id":22636,"position":32,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌র","audioUrl":"wbw/057_020_034.mp3","charTypeName":"word"},{"id":22637,"position":33,"arabic":"وَرِضْوَٰنٌۭ ۚ","translation":"এবং সন্তুষ্টিও","audioUrl":"wbw/057_020_035.mp3","charTypeName":"word"},{"id":22639,"position":34,"arabic":"وَمَا","translation":"এবং নয়","audioUrl":"wbw/057_020_037.mp3","charTypeName":"word"},{"id":22640,"position":35,"arabic":"ٱلْحَيَوٰةُ","translation":"জীবন","audioUrl":"wbw/057_020_038.mp3","charTypeName":"word"},{"id":22641,"position":36,"arabic":"ٱلدُّنْيَآ","translation":"দুনিয়ার","audioUrl":"wbw/057_020_039.mp3","charTypeName":"word"},{"id":22642,"position":37,"arabic":"إِلَّا","translation":"এছাড়া","audioUrl":"wbw/057_020_040.mp3","charTypeName":"word"},{"id":22643,"position":38,"arabic":"مَتَـٰعُ","translation":"সামগ্রী","audioUrl":"wbw/057_020_041.mp3","charTypeName":"word"},{"id":22644,"position":39,"arabic":"ٱلْغُرُورِ","translation":"ছলনার","audioUrl":"wbw/057_020_042.mp3","charTypeName":"word"},{"id":22645,"position":40,"arabic":"٢٠","translation":"(২০)","audioUrl":null,"charTypeName":"end"}]},{"number":21,"arabic":"سَابِقُوٓا۟ إِلَىٰ مَغْفِرَةٍۢ مِّن رَّبِّكُمْ وَجَنَّةٍ عَرْضُهَا كَعَرْضِ ٱلسَّمَآءِ وَٱلْأَرْضِ أُعِدَّتْ لِلَّذِينَ ءَامَنُوا۟ بِٱللَّهِ وَرُسُلِهِۦ ۚ ذَٰلِكَ فَضْلُ ٱللَّهِ يُؤْتِيهِ مَن يَشَآءُ ۚ وَٱللَّهُ ذُو ٱلْفَضْلِ ٱلْعَظِيمِ","translation":"[Hence,] vie with one another in seeking to attain to your Sustainer’s forgiveness, and [thus] to a paradise as vast as the heavens and the earth, which has been readied for those who have attained to faith in God and His Apostle: such is the bounty of God which He grants unto whomever He wills - for God is limitless in His great bounty.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5096.mp3","surahId":57,"words":[{"id":23785,"position":1,"arabic":"سَابِقُوٓا۟","translation":"তোমরা এগিয়ে যাও","audioUrl":"wbw/057_021_001.mp3","charTypeName":"word"},{"id":23786,"position":2,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/057_021_002.mp3","charTypeName":"word"},{"id":23787,"position":3,"arabic":"مَغْفِرَةٍۢ","translation":"ক্ষমার","audioUrl":"wbw/057_021_003.mp3","charTypeName":"word"},{"id":23788,"position":4,"arabic":"مِّن","translation":"পক্ষ হতে","audioUrl":"wbw/057_021_004.mp3","charTypeName":"word"},{"id":23789,"position":5,"arabic":"رَّبِّكُمْ","translation":"তোমাদের রবের","audioUrl":"wbw/057_021_005.mp3","charTypeName":"word"},{"id":23790,"position":6,"arabic":"وَجَنَّةٍ","translation":"ও (এমন) জান্নাতের","audioUrl":"wbw/057_021_006.mp3","charTypeName":"word"},{"id":23791,"position":7,"arabic":"عَرْضُهَا","translation":"যার প্রশস্ততা","audioUrl":"wbw/057_021_007.mp3","charTypeName":"word"},{"id":23792,"position":8,"arabic":"كَعَرْضِ","translation":"প্রশস্ততার মতো","audioUrl":"wbw/057_021_008.mp3","charTypeName":"word"},{"id":23793,"position":9,"arabic":"ٱلسَّمَآءِ","translation":"আকাশের","audioUrl":"wbw/057_021_009.mp3","charTypeName":"word"},{"id":23794,"position":10,"arabic":"وَٱلْأَرْضِ","translation":"ও পৃথিবীর","audioUrl":"wbw/057_021_010.mp3","charTypeName":"word"},{"id":23795,"position":11,"arabic":"أُعِدَّتْ","translation":"প্রস্তুত করা হয়েছে","audioUrl":"wbw/057_021_011.mp3","charTypeName":"word"},{"id":23796,"position":12,"arabic":"لِلَّذِينَ","translation":"(তাদের) জন্যে যারা","audioUrl":"wbw/057_021_012.mp3","charTypeName":"word"},{"id":23797,"position":13,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/057_021_013.mp3","charTypeName":"word"},{"id":23798,"position":14,"arabic":"بِٱللَّهِ","translation":"আল্লাহ্‌র উপর","audioUrl":"wbw/057_021_014.mp3","charTypeName":"word"},{"id":23799,"position":15,"arabic":"وَرُسُلِهِۦ ۚ","translation":"ও তাঁর রাসূলদের (উপর)","audioUrl":"wbw/057_021_015.mp3","charTypeName":"word"},{"id":23801,"position":16,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/057_021_017.mp3","charTypeName":"word"},{"id":23802,"position":17,"arabic":"فَضْلُ","translation":"অনুগ্রহ","audioUrl":"wbw/057_021_018.mp3","charTypeName":"word"},{"id":23803,"position":18,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/057_021_019.mp3","charTypeName":"word"},{"id":23804,"position":19,"arabic":"يُؤْتِيهِ","translation":"তা দান করবেন","audioUrl":"wbw/057_021_020.mp3","charTypeName":"word"},{"id":23805,"position":20,"arabic":"مَن","translation":"যাকে","audioUrl":"wbw/057_021_021.mp3","charTypeName":"word"},{"id":23806,"position":21,"arabic":"يَشَآءُ ۚ","translation":"তিনি চান","audioUrl":"wbw/057_021_022.mp3","charTypeName":"word"},{"id":23808,"position":22,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/057_021_024.mp3","charTypeName":"word"},{"id":23809,"position":23,"arabic":"ذُو","translation":"অধিকারী","audioUrl":"wbw/057_021_025.mp3","charTypeName":"word"},{"id":23810,"position":24,"arabic":"ٱلْفَضْلِ","translation":"অনুগ্রহের","audioUrl":"wbw/057_021_026.mp3","charTypeName":"word"},{"id":23811,"position":25,"arabic":"ٱلْعَظِيمِ","translation":"মহা","audioUrl":"wbw/057_021_027.mp3","charTypeName":"word"},{"id":23812,"position":26,"arabic":"٢١","translation":"(২১)","audioUrl":null,"charTypeName":"end"}]},{"number":22,"arabic":"مَآ أَصَابَ مِن مُّصِيبَةٍ