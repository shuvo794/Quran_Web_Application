{"id":601,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلْعَصْرِ","translation":"CONSIDER the flight of time!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6177.mp3","surahId":103,"words":[{"id":177,"position":1,"arabic":"وَٱلْعَصْرِ","translation":"শপথ মহাকালের","audioUrl":"wbw/103_001_001.mp3","charTypeName":"word"},{"id":178,"position":2,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"إِنَّ ٱلْإِنسَٰنَ لَفِى خُسْرٍ","translation":"Verily, man is bound to lose himself","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6178.mp3","surahId":103,"words":[{"id":1056,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/103_002_001.mp3","charTypeName":"word"},{"id":1057,"position":2,"arabic":"ٱلْإِنسَـٰنَ","translation":"মানুষ","audioUrl":"wbw/103_002_002.mp3","charTypeName":"word"},{"id":1058,"position":3,"arabic":"لَفِى","translation":"অবশ্যই মধ্যে","audioUrl":"wbw/103_002_003.mp3","charTypeName":"word"},{"id":1059,"position":4,"arabic":"خُسْرٍ","translation":"ক্ষতির","audioUrl":"wbw/103_002_004.mp3","charTypeName":"word"},{"id":1060,"position":5,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"إِلَّا ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ وَتَوَاصَوْا۟ بِٱلْحَقِّ وَتَوَاصَوْا۟ بِٱلصَّبْرِ","translation":"unless he be of those who attain to faith, and do good works, and enjoin upon one another the keeping to truth, and enjoin upon one another patience in adversity.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6179.mp3","surahId":103,"words":[{"id":2213,"position":1,"arabic":"إِلَّا","translation":"(তাদের) ছাড়া","audioUrl":"wbw/103_003_001.mp3","charTypeName":"word"},{"id":2214,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/103_003_002.mp3","charTypeName":"word"},{"id":2215,"position":3,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/103_003_003.mp3","charTypeName":"word"},{"id":2216,"position":4,"arabic":"وَعَمِلُوا۟","translation":"এবং করেছে","audioUrl":"wbw/103_003_004.mp3","charTypeName":"word"},{"id":2217,"position":5,"arabic":"ٱلصَّـٰلِحَـٰتِ","translation":"সৎকর্মের","audioUrl":"wbw/103_003_005.mp3","charTypeName":"word"},{"id":2218,"position":6,"arabic":"وَتَوَاصَوْا۟","translation":"এবং পরস্পরকে উপদেশ দিয়েছে","audioUrl":"wbw/103_003_006.mp3","charTypeName":"word"},{"id":2219,"position":7,"arabic":"بِٱلْحَقِّ","translation":"সত্যের","audioUrl":"wbw/103_003_007.mp3","charTypeName":"word"},{"id":2220,"position":8,"arabic":"وَتَوَاصَوْا۟","translation":"ও পরস্পরকে উপদেশ দিয়েছে","audioUrl":"wbw/103_003_008.mp3","charTypeName":"word"},{"id":2221,"position":9,"arabic":"بِٱلصَّبْرِ","translation":"ধৈর্যের","audioUrl":"wbw/103_003_009.mp3","charTypeName":"word"},{"id":2222,"position":10,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَيْلٌۭ لِّكُلِّ هُمَزَةٍۢ لُّمَزَةٍ","translation":"WOE unto every slanderer, fault-finder!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6180.mp3","surahId":104,"words":[{"id":108,"position":1,"arabic":"وَيْلٌۭ","translation":"দুর্ভোগ","audioUrl":"wbw/104_001_001.mp3","charTypeName":"word"},{"id":109,"position":2,"arabic":"لِّكُلِّ","translation":"প্রত্যেকের","audioUrl":"wbw/104_001_002.mp3","charTypeName":"word"},{"id":110,"position":3,"arabic":"هُمَزَةٍۢ","translation":"সামনে নিন্দাকারীর","audioUrl":"wbw/104_001_003.mp3","charTypeName":"word"},{"id":111,"position":4,"arabic":"لُّمَزَةٍ","translation":"পিছনে দোষ প্রচারকারীর","audioUrl":"wbw/104_001_004.mp3","charTypeName":"word"},{"id":112,"position":5,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"ٱلَّذِى جَمَعَ مَالًۭا وَعَدَّدَهُۥ","translation":"[Woe unto him who amasses wealth and counts it a safeguard,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6181.mp3","surahId":104,"words":[{"id":1031,"position":1,"arabic":"ٱلَّذِى","translation":"যে","audioUrl":"wbw/104_002_001.mp3","charTypeName":"word"},{"id":1032,"position":2,"arabic":"جَمَعَ","translation":"জমা করেছে","audioUrl":"wbw/104_002_002.mp3","charTypeName":"word"},{"id":1033,"position":3,"arabic":"مَالًۭا","translation":"অর্থ","audioUrl":"wbw/104_002_003.mp3","charTypeName":"word"},{"id":1034,"position":4,"arabic":"وَعَدَّدَهُۥ","translation":"এবং তা বারবার গণনা করে রেখেছে","audioUrl":"wbw/104_002_004.mp3","charTypeName":"word"},{"id":1035,"position":5,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"يَحْسَبُ أَنَّ مَالَهُۥٓ أَخْلَدَهُۥ","translation":"thinking that his wealth will make him live forever!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6182.mp3","surahId":104,"words":[{"id":2234,"position":1,"arabic":"يَحْسَبُ","translation":"সে ধারণা করে","audioUrl":"wbw/104_003_001.mp3","charTypeName":"word"},{"id":2235,"position":2,"arabic":"أَنَّ","translation":"যে","audioUrl":"wbw/104_003_002.mp3","charTypeName":"word"},{"id":2236,"position":3,"arabic":"مَالَهُۥٓ","translation":"তার অর্থ","audioUrl":"wbw/104_003_003.mp3","charTypeName":"word"},{"id":2237,"position":4,"arabic":"أَخْلَدَهُۥ","translation":"তাকে অমর করবে","audioUrl":"wbw/104_003_004.mp3","charTypeName":"word"},{"id":2238,"position":5,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"كَلَّا ۖ لَيُنۢبَذَنَّ فِى ٱلْحُطَمَةِ","translation":"Nay, but [in the life to come such as] he shall indeed be abandoned to crushing torment!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6183.mp3","surahId":104,"words":[{"id":3599,"position":1,"arabic":"كَلَّا ۖ","translation":"কখনও না","audioUrl":"wbw/104_004_001.mp3","charTypeName":"word"},{"id":3601,"position":2,"arabic":"لَيُنۢبَذَنَّ","translation":"সে নিক্ষিপ্ত হবে অবশ্যই","audioUrl":"wbw/104_004_003.mp3","charTypeName":"word"},{"id":3602,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/104_004_004.mp3","charTypeName":"word"},{"id":3603,"position":4,"arabic":"ٱلْحُطَمَةِ","translation":"বিচূর্ণকারী স্থানের","audioUrl":"wbw/104_004_005.mp3","charTypeName":"word"},{"id":3604,"position":5,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"وَمَآ أَدْرَىٰكَ مَا ٱلْحُطَمَةُ","translation":"And what could make thee conceive what that crushing torment will be?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6184.mp3","surahId":104,"words":[{"id":4913,"position":1,"arabic":"وَمَآ","translation":"এবং কি","audioUrl":"wbw/104_005_001.mp3","charTypeName":"word"},{"id":4914,"position":2,"arabic":"أَدْرَىٰكَ","translation":"তোমাকে জানাবে","audioUrl":"wbw/104_005_002.mp3","charTypeName":"word"},{"id":4915,"position":3,"arabic":"مَا","translation":"কি","audioUrl":"wbw/104_005_003.mp3","charTypeName":"word"},{"id":4916,"position":4,"arabic":"ٱلْحُطَمَةُ","translation":"বিচূর্ণকারী স্থান","audioUrl":"wbw/104_005_004.mp3","charTypeName":"word"},{"id":4917,"position":5,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"نَارُ ٱللَّهِ ٱلْمُوقَدَةُ","translation":"A fire kindled by God,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6185.mp3","surahId":104,"words":[{"id":6148,"position":1,"arabic":"نَارُ","translation":"আগুন","audioUrl":"wbw/104_006_001.mp3","charTypeName":"word"},{"id":6149,"position":2,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/104_006_002.mp3","charTypeName":"word"},{"id":6150,"position":3,"arabic":"ٱلْمُوقَدَةُ","translation":"প্রজ্জ্বলিত","audioUrl":"wbw/104_006_003.mp3","charTypeName":"word"},{"id":6151,"position":4,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"ٱلَّتِى تَطَّلِعُ عَلَى ٱلْأَفْـِٔدَةِ","translation":"which will rise over the [guilty] hearts:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6186.mp3","surahId":104,"words":[{"id":7378,"position":1,"arabic":"ٱلَّتِى","translation":"যা","audioUrl":"wbw/104_007_001.mp3","charTypeName":"word"},{"id":7379,"position":2,"arabic":"تَطَّلِعُ","translation":"পৌঁছে যাবে","audioUrl":"wbw/104_007_002.mp3","charTypeName":"word"},{"id":7380,"position":3,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/104_007_003.mp3","charTypeName":"word"},{"id":7381,"position":4,"arabic":"ٱلْأَفْـِٔدَةِ","translation":"অন্তরসমূহের","audioUrl":"wbw/104_007_004.mp3","charTypeName":"word"},{"id":7382,"position":5,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"إِنَّهَا عَلَيْهِم مُّؤْصَدَةٌۭ","translation":"verily, it will close in upon them","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6187.mp3","surahId":104,"words":[{"id":8482,"position":1,"arabic":"إِنَّهَا","translation":"নিশ্চয়ই তা","audioUrl":"wbw/104_008_001.mp3","charTypeName":"word"},{"id":8483,"position":2,"arabic":"عَلَيْهِم","translation":"তাদের উপর","audioUrl":"wbw/104_008_002.mp3","charTypeName":"word"},{"id":8484,"position":3,"arabic":"مُّؤْصَدَةٌۭ","translation":"অবরুদ্ধ করে দেয়া হবে","audioUrl":"wbw/104_008_003.mp3","charTypeName":"word"},{"id":8485,"position":4,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"فِى عَمَدٍۢ مُّمَدَّدَةٍۭ","translation":"in endless columns!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6188.mp3","surahId":104,"words":[{"id":10159,"position":1,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/104_009_001.mp3","charTypeName":"word"},{"id":10160,"position":2,"arabic":"عَمَدٍۢ","translation":"স্তম্ভসমূহের","audioUrl":"wbw/104_009_002.mp3","charTypeName":"word"},{"id":10161,"position":3,"arabic":"مُّمَدَّدَةٍۭ","translation":"দীর্ঘায়িত","audioUrl":"wbw/104_009_003.mp3","charTypeName":"word"},{"id":10162,"position":4,"arabic":"٩","translation":"(৯)","audioU