charTypeName":"word"},{"id":1023,"position":5,"arabic":"تَضْلِيلٍۢ","translation":"নিষ্ফলতার","audioUrl":"wbw/105_002_005.mp3","charTypeName":"word"},{"id":1024,"position":6,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"وَأَرْسَلَ عَلَيْهِمْ طَيْرًا أَبَابِيلَ","translation":"Thus, He let loose upon them great swarms of flying creatures","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6191.mp3","surahId":105,"words":[{"id":2361,"position":1,"arabic":"وَأَرْسَلَ","translation":"এবং পাঠিয়েছেন","audioUrl":"wbw/105_003_001.mp3","charTypeName":"word"},{"id":2362,"position":2,"arabic":"عَلَيْهِمْ","translation":"তাদের বিরুদ্ধে","audioUrl":"wbw/105_003_002.mp3","charTypeName":"word"},{"id":2363,"position":3,"arabic":"طَيْرًا","translation":"পাখি","audioUrl":"wbw/105_003_003.mp3","charTypeName":"word"},{"id":2364,"position":4,"arabic":"أَبَابِيلَ","translation":"ঝাঁকে ঝাঁকে","audioUrl":"wbw/105_003_004.mp3","charTypeName":"word"},{"id":2365,"position":5,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"تَرْمِيهِم بِحِجَارَةٍۢ مِّن سِجِّيلٍۢ","translation":"which smote them with stone-hard blows of chastisement pre-ordained,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6192.mp3","surahId":105,"words":[{"id":3867,"position":1,"arabic":"تَرْمِيهِم","translation":"তাদের উপর নিক্ষেপ করে","audioUrl":"wbw/105_004_001.mp3","charTypeName":"word"},{"id":3868,"position":2,"arabic":"بِحِجَارَةٍۢ","translation":"পাথরসমূহকে","audioUrl":"wbw/105_004_002.mp3","charTypeName":"word"},{"id":3869,"position":3,"arabic":"مِّن","translation":"হতে","audioUrl":"wbw/105_004_003.mp3","charTypeName":"word"},{"id":3870,"position":4,"arabic":"سِجِّيلٍۢ","translation":"কংকরের","audioUrl":"wbw/105_004_004.mp3","charTypeName":"word"},{"id":3871,"position":5,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"فَجَعَلَهُمْ كَعَصْفٍۢ مَّأْكُولٍۭ","translation":"and caused them to become like a field of grain that has been eaten down to stubble","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6193.mp3","surahId":105,"words":[{"id":5092,"position":1,"arabic":"فَجَعَلَهُمْ","translation":"অতঃপর তিনি তাদের করে দেন","audioUrl":"wbw/105_005_001.mp3","charTypeName":"word"},{"id":5093,"position":2,"arabic":"كَعَصْفٍۢ","translation":"ভুসির মতো","audioUrl":"wbw/105_005_002.mp3","charTypeName":"word"},{"id":5094,"position":3,"arabic":"مَّأْكُولٍۭ","translation":"খাওয়া/ভক্ষিত","audioUrl":"wbw/105_005_003.mp3","charTypeName":"word"},{"id":5095,"position":4,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]}]}