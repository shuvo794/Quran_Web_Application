{"id":75,"ayahs":[{"number":187,"arabic":"وَإِذْ أَخَذَ ٱللَّهُ مِيثَٰقَ ٱلَّذِينَ أُوتُوا۟ ٱلْكِتَٰبَ لَتُبَيِّنُنَّهُۥ لِلنَّاسِ وَلَا تَكْتُمُونَهُۥ فَنَبَذُوهُ وَرَآءَ ظُهُورِهِمْ وَٱشْتَرَوْا۟ بِهِۦ ثَمَنًۭا قَلِيلًۭا ۖ فَبِئْسَ مَا يَشْتَرُونَ","translation":"AND LO, God accepted a solemn pledge from those who were granted earlier revelation [when He bade them]: \"Make it known unto mankind, and do not conceal it!\" But they cast this [pledge] behind their backs, and bartered it away for a trifling gain: and how evil was their bargain!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/480.mp3","surahId":3,"words":[{"id":84288,"position":1,"arabic":"وَإِذْ","translation":"এবং (স্মরণ কর) যখন","audioUrl":"wbw/003_187_001.mp3","charTypeName":"word"},{"id":84289,"position":2,"arabic":"أَخَذَ","translation":"নিয়েছিলেন","audioUrl":"wbw/003_187_002.mp3","charTypeName":"word"},{"id":84290,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/003_187_003.mp3","charTypeName":"word"},{"id":84291,"position":4,"arabic":"مِيثَـٰقَ","translation":"প্রতিশ্রুতি","audioUrl":"wbw/003_187_004.mp3","charTypeName":"word"},{"id":84292,"position":5,"arabic":"ٱلَّذِينَ","translation":"(তাদের থেকে) যাদেরকে","audioUrl":"wbw/003_187_005.mp3","charTypeName":"word"},{"id":84293,"position":6,"arabic":"أُوتُوا۟","translation":"দেয়া হয়েছিল","audioUrl":"wbw/003_187_006.mp3","charTypeName":"word"},{"id":84294,"position":7,"arabic":"ٱلْكِتَـٰبَ","translation":"কিতাব","audioUrl":"wbw/003_187_007.mp3","charTypeName":"word"},{"id":84295,"position":8,"arabic":"لَتُبَيِّنُنَّهُۥ","translation":"''তা অবশ্যই তোমরা প্রচার করবে","audioUrl":"wbw/003_187_008.mp3","charTypeName":"word"},{"id":84296,"position":9,"arabic":"لِلنَّاسِ","translation":"লোকদের জন্য","audioUrl":"wbw/003_187_009.mp3","charTypeName":"word"},{"id":84297,"position":10,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/003_187_010.mp3","charTypeName":"word"},{"id":84298,"position":11,"arabic":"تَكْتُ