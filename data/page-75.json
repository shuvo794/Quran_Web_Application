:"https://cdn.islamic.network/quran/audio/128/ar.alafasy/481.mp3","surahId":3,"words":[{"id":84447,"position":1,"arabic":"لَا","translation":"না","audioUrl":"wbw/003_188_001.mp3","charTypeName":"word"},{"id":84448,"position":2,"arabic":"تَحْسَبَنَّ","translation":"তারা (যেন) মনে করে","audioUrl":"wbw/003_188_002.mp3","charTypeName":"word"},{"id":84449,"position":3,"arabic":"ٱلَّذِينَ","translation":"মনে করে","audioUrl":"wbw/003_188_003.mp3","charTypeName":"word"},{"id":84450,"position":4,"arabic":"يَفْرَحُونَ","translation":"যারা আনুন্দ করে","audioUrl":"wbw/003_188_004.mp3","charTypeName":"word"},{"id":84451,"position":5,"arabic":"بِمَآ","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/003_188_005.mp3","charTypeName":"word"},{"id":84452,"position":6,"arabic":"أَتَوا۟","translation":"তারা করেছে","audioUrl":"wbw/003_188_006.mp3","charTypeName":"word"},{"id":84453,"position":7,"arabic":"وَّيُحِبُّونَ","translation":"তারা পছন্দ করে","audioUrl":"wbw/003_188_007.mp3","charTypeName":"word"},{"id":84454,"position":8,"arabic":"أَن","translation":"যে","audioUrl":"wbw/003_188_008.mp3","charTypeName":"word"},{"id":84455,"position":9,"arabic":"يُحْمَدُوا۟","translation":"তাদের প্রশংসা করা হোক","audioUrl":"wbw/003_188_009.mp3","charTypeName":"word"},{"id":84456,"position":10,"arabic":"بِمَا","translation":"ঐবিষয়ে যা","audioUrl":"wbw/003_188_010.mp3","charTypeName":"word"},{"id":84457,"position":11,"arabic":"لَمْ","translation":"নাই","audioUrl":"wbw/003_188_011.mp3","charTypeName":"word"},{"id":84458,"position":12,"arabic":"يَفْعَلُوا۟","translation":"তারা করেও","audioUrl":"wbw/003_188_012.mp3","charTypeName":"word"},{"id":84459,"position":13,"arabic":"فَلَا","translation":"অতএব না","audioUrl":"wbw/003_188_013.mp3","charTypeName":"word"},{"id":84460,"position":14,"arabic":"تَحْسَبَنَّهُم","translation":"তাদের মনে করবে","audioUrl":"wbw/003_188_014.mp3","charTypeName":"word"},{"id":84461,"position":15,"arabic":"بِمَفَازَةٍۢ","translation":"নিরাপদ স্থানে","audioUrl":"wbw/003_188_015.mp3","charTypeName":"word"},{"id":84462,"position":16,"arabic":"مِّنَ","translation":"হতে","audioUrl":"wbw/003_188_016.mp3","charTypeName":"word"},{"id":84463,"position":17,"arabic":"ٱلْعَذَابِ ۖ","translation":"আজাব","audioUrl":"wbw/003_188_017.mp3","charTypeName":"word"},{"id":84465,"position":18,"arabic":"وَلَهُمْ","translation":"এবং তাদের জন্য রয়েছে","audioUrl":"wbw/003_188_019.mp3","charTypeName":"word"},{"id":84466,"position":19,"arabic":"عَذَابٌ","translation":"শাস্তি","audioUrl":"wbw/003_188_020.mp3","charTypeName":"word"},{"id":84467,"position":20,"arabic":"أَلِيمٌۭ","translation":"কষ্টদায়ক","audioUrl":"wbw/003_188_021.mp3","charTypeName":"word"},{"id":84468,"position":21,"arabic":"١٨٨","translation":"(১৮৮)","audioUrl":null,"charTypeName":"end"}]},{"number":189,"arabic":"وَلِلَّهِ مُلْكُ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ ۗ وَٱللَّهُ عَلَىٰ كُلِّ شَىْءٍۢ قَدِيرٌ","translation":"AND UNTO GOD belongs the dominion over the heavens and the earth: and God has the power to will anything.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/482.mp3","surahId":3,"words":[{"id":84539,"position":1,"arabic":"وَلِلَّهِ","translation":"এবং আল্লাহর জন্য","audioUrl":"wbw/003_189_001.mp3","charTypeName":"word"},{"id":84540,"position":2,"arabic":"مُلْكُ","translation":"রাজত্ব","audioUrl":"wbw/003_189_002.mp3","charTypeName":"word"},{"id":84541,"position":3,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশমন্ডলীর","audioUrl":"wbw/003_189_003.mp3","charTypeName":"word"},{"id":84542,"position":4,"arabic":"وَٱلْأَرْضِ ۗ","translation":"ও পৃথিবীর","audioUrl":"wbw/003_189_004.mp3","charTypeName":"word"},{"id":84544,"position":5,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/003_189_006.mp3","charTypeName":"word"},{"id":84545,"position":6,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/003_189_007.mp3","charTypeName":"word"},{"id":84546,"position":7,"arabic":"كُلِّ","translation":"সব","audioUrl":"wbw/003_189_008.mp3","charTypeName":"word"},{"id":84547,"position":8,"arabic":"شَىْءٍۢ","translation":"কিছুর","audioUrl":"wbw/003_189_009.mp3","charTypeName":"word"},{"id":84548,"position":9,"arabic":"قَدِيرٌ","translation":"ক্ষমতাবান","audioUrl":"wbw/003_189_010.mp3","charTypeName":"word"},{"id":84549,"position":10,"arabic":"١٨٩","translation":"(১৮৯)","audioUrl":null,"charTypeName":"end"}]},{"number":190,"arabic":"إِنَّ فِى خَلْقِ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ وَٱخْتِلَٰفِ ٱلَّيْلِ وَٱلنَّهَارِ لَءَايَٰتٍۢ لِّأُو۟لِى ٱلْأَلْبَٰبِ","translation":"Verily, in the creation of the heavens and the earth, and in the succession of night and day, there are indeed messages for all who are endowed with insight,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/483.mp3","surahId":3,"words":[{"id":84609,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়","audioUrl":"wbw/003_190_001.mp3","charTypeName":"word"},{"id":84610,"position":2,"arabic":"فِى","translation":"মধ্যে রয়েছে","audioUrl":"wbw/003_190_002.mp3","charTypeName":"word"},{"id":84611,"position":3,"arabic":"خَلْقِ","translation":"সৃষ্টির","audioUrl":"wbw/003_190_003.mp3","charTypeName":"word"},{"id":84612,"position":4,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশ সমূহের","audioUrl":"wbw/003_190_004.mp3","charTypeName":"word"},{"id":84613,"position":5,"arabic":"وَٱلْأَرْضِ","translation":"ও পৃথিবীর","audioUrl":"wbw/003_190_005.mp3","charTypeName":"word"},{"id":84614,"position":6,"arabic":"وَٱخْتِلَـٰفِ","translation":"ও আবর্তনে","audioUrl":"wbw/003_190_006.mp3","charTypeName":"word"},{"id":84615,"position":7,"arabic":"ٱلَّيْلِ","translation":"রাতের","audioUrl":"wbw/003_190_007.mp3","charTypeName":"word"},{"id":84616,"position":8,"arabic":"وَٱلنَّهَارِ","translation":"এবং দিনের","audioUrl":"wbw/003_190_008.mp3","charTypeName":"word"},{"id":84617,"position":9,"arabic":"لَـَٔايَـٰتٍۢ","translation":"অবশ্যই নিদর্শন সমূহ","audioUrl":"wbw/003_190_009.mp3","charTypeName":"word"},{"id":84618,"position":10,"arabic":"لِّأُو۟لِى","translation":"জন্য","audioUrl":"wbw/003_190_010.mp3","charTypeName":"word"},{"id":84619,"position":11,"arabic":"ٱلْأَلْبَـٰبِ","translation":"বুদ্ধিমানদের","audioUrl":"wbw/003_190_011.mp3","charTypeName":"word"},{"id":84620,"position":12,"arabic":"١٩٠","translation":"(১৯০)","audioUrl":null,"charTypeName":"end"}]},{"number":191,"arabic":"ٱلَّذِينَ يَذْكُرُونَ ٱللَّهَ قِيَٰمًۭا وَقُعُودًۭا وَعَلَىٰ جُنُوبِهِمْ وَيَتَفَكَّرُونَ فِى خَلْقِ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ رَبَّنَا مَا خَلَقْتَ هَٰذَا بَٰطِلًۭا سُبْحَٰنَكَ فَقِنَا عَذَابَ ٱلنَّارِ","translation":"[and] who remember God when they stand, and when they sit, and when they lie down to sleep, and [thus] reflect on the creation of the heavens and the earth: \"O our Sustainer! Thou hast not created [aught of] this without meaning and purpose. Limitless art Thou in Thy glory! Keep us safe, then, from suffering through fire!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/484.mp3","surahId":3,"words":[{"id":84676,"position":1,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/003_191_001.mp3","charTypeName":"word"},{"id":84677,"position":2,"arabic":"يَذْكُرُونَ","translation":"স্মরণ করে","audioUrl":"wbw/003_191_002.mp3","charTypeName":"word"},{"id":84678,"position":3,"arabic":"ٱللَّهَ","translation":"আল্লাহ্‌কে","audioUrl":"wbw/003_191_003.mp3","charTypeName":"word"},{"id":84679,"position":4,"arabic":"قِيَـٰمًۭا","translation":"দাঁড়িয়ে","audioUrl":"wbw/003_191_004.mp3","charTypeName":"word"},{"id":84680,"position":5,"arabic":"وَقُعُودًۭا","translation":"ও বসে","audioUrl":"wbw/003_191_005.mp3","charTypeName":"word"},{"id":84681,"position":6,"arabic":"وَعَلَىٰ","translation":"এবং উপর","audioUrl":"wbw/003_191_006.mp3","charTypeName":"word"},{"id":84682,"position":7,"arabic":"جُنُوبِهِمْ","translation":"তাদের পার্শ্ব সমূহের (শুয়ে)","audioUrl":"wbw/003_191_007.mp3","charTypeName":"word"},{"id":84683,"position":8,"arabic":"وَيَتَفَكَّرُونَ","translation":"আর তারা চিন্তা গবেষণা করে","audioUrl":"wbw/003_191_008.mp3","charTypeName":"word"},{"id":84684,"position"