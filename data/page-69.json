{"id":69,"ayahs":[{"number":149,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوٓا۟ إِن تُطِيعُوا۟ ٱلَّذِينَ كَفَرُوا۟ يَرُدُّوكُمْ عَلَىٰٓ أَعْقَٰبِكُمْ فَتَنقَلِبُوا۟ خَٰسِرِينَ","translation":"O YOU who have attained to faith! If you pay heed to those who are bent on denying the truth, they will cause you to turn back on your heels, and you will be the losers.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/442.mp3","surahId":3,"words":[{"id":80270,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"ওহে","audioUrl":"wbw/003_149_001.mp3","charTypeName":"word"},{"id":80271,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/003_149_002.mp3","charTypeName":"word"},{"id":80272,"position":3,"arabic":"ءَامَنُوٓا۟","translation":"ঈমান এনেছ","audioUrl":"wbw/003_149_003.mp3","charTypeName":"word"},{"id":80273,"position":4,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/003_149_004.mp3","charTypeName":"word"},{"id":80274,"position":5,"arabic":"تُطِيعُوا۟","translation":"তোমরা আনুগত্য কর","audioUrl":"wbw/003_149_005.mp3","charTypeName":"word"},{"id":80275,"position":6,"arabic":"ٱلَّذِينَ","translation":"(তাদেরকে) যারা","audioUrl":"wbw/003_149_006.mp3","charTypeName":"word"},{"id":80276,"position":7,"arabic":"كَفَرُوا۟","translation":"কুফরী করেছে","audioUrl":"wbw/003_149_007.mp3","charTypeName":"word"},{"id":80277,"position":8,"arabic":"يَرُدُّوكُمْ","translation":"তোমাদের তারা ফিরিয়ে দিবে","audioUrl":"wbw/003_149_008.mp3","charTypeName":"word"},{"id":80278,"position":9,"arabic":"عَلَىٰٓ","translation":"উপর","audioUrl":"wbw/003_149_009.mp3","charTypeName":"word"},{"id":80279,"position":10,"arabic":"أَعْقَـٰبِكُمْ","translation":"তোমাদের গোড়ালির (অর্থাৎ পিছন দিকে)","audioUrl":"wbw/003_149_010.mp3","charTypeName":"word"},{"id":80280,"position":11,"arabic":"فَتَنقَلِبُوا۟","translation":"ফলে তোমরা ফিরবে","audioUrl":"wbw/003_149_011.mp3","charTypeName":"word"},{"id":80281,"position":12,"arabic":"خَـٰسِرِينَ","translation":"ক্ষতিগ্রস্ত হয়ে","audioUrl":"wbw/003_149_012.mp3","charTypeName":"word"},{"id":80282,"position":13,"arabic":"١٤٩","translation":"(১৪৯)","audioUrl":null,"charTypeName":"end"}]},{"number":150,"arabic":"بَلِ ٱللَّهُ مَوْلَىٰكُمْ ۖ وَهُوَ خَيْرُ ٱلنَّٰصِرِينَ","translation":"Nay, but God alone is your Lord Supreme, and His is the best succour.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/443.mp3","surahId":3,"words":[{"id":80426,"position":1,"arabic":"بَلِ","translation":"বরং","audioUrl":"wbw/003_150_001.mp3","charTypeName":"word"},{"id":80427,"position":2,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/003_150_002.mp3","charTypeName":"word"},{"id":80428,"position":3,"arabic":"مَوْلَىٰكُمْ ۖ","translation":"তোমাদের অভিভাবক","audioUrl":"wbw/003_150_003.mp3","charTypeName":"word"},{"id":80430,"position":4,"arabic":"وَهُوَ","translation":"এবং তিনিই","audioUrl":"wbw/003_150_005.mp3","charTypeName":"word"},{"id":80431,"position":5,"arabic":"خَيْرُ","translation":"উত্তম","audioUrl":"wbw/003_150_006.mp3","charTypeName":"word"},{"id":80432,"position":6,"arabic":"ٱلنَّـٰصِرِينَ","translation":"সাহায্যকারীদের (মধ্যে)","audioUrl":"wbw/003_150_007.mp3","charTypeName":"word"},{"id":80433,"position":7,"arabic":"١٥٠","translation":"(১৫০)","audioUrl":null,"charTypeName":"end"}]},{"number":151,"arabic":"سَنُلْقِى فِى قُلُوبِ ٱلَّذِينَ كَفَرُوا۟ ٱلرُّعْبَ بِمَآ أَشْرَكُوا۟ بِٱللَّهِ مَا لَمْ يُنَزِّلْ بِهِۦ سُلْطَٰنًۭا ۖ وَمَأْوَىٰهُمُ ٱلنَّارُ ۚ وَبِئْسَ مَثْوَى ٱلظَّٰلِمِينَ","translation":"Into the hearts of those who are bent on denying the truth We shall cast dread in return for their ascribing divinity, side by side with God, to other beings - [something] for which He has never bestowed any warrant from on high; and their goal is the fire - and how evil that abode of evildoers!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/444.mp3","surahId":3,"words":[{"id":80582,"position":1,"arabic":"سَنُلْقِى","translation":"আমরা শীঘ্রই সঞ্চার করব","audioUrl":"wbw/003_151_001.mp3","charTypeName":"word"},{"id":80583,"position":2,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/003_151_002.mp3","charTypeName":"word"},{"id":80584,"position":3,"arabic":"قُلُوبِ","translation":"অন্তরগুলোর","audioUrl":"wbw/003_151_003.mp3","charTypeName":"word"},{"id":80585,"position":4,"arabic":"ٱلَّذِينَ","translation":"(তাদের) যারা","audioUrl":"wbw/003_151_004.mp3","charTypeName":"word"},{"id":80586,"position":5,"arabic":"كَفَرُوا۟","translation":"কুফরী করেছে","audioUrl":"wbw/003_151_005.mp3","charTypeName":"word"},{"id":80587,"position":6,"arabic":"ٱلرُّعْبَ","translation":"ভীতি","audioUrl":"wbw/003_151_006.mp3","charTypeName":"word"},{"id":80588,"position":7,"arabic":"بِمَآ","translation":"এ কারণে যে","audioUrl":"wbw/003_151_007.mp3","charTypeName":"word"},{"id":80589,"position":8,"arabic":"أَشْرَكُوا۟","translation":"তারা শিরক করেছে","audioUrl":"wbw/003_151_008.mp3","charTypeName":"word"},{"id":80590,"position":9,"arabic":"بِٱللَّهِ","translation":"আল্লাহর সাথে","audioUrl":"wbw/003_151_009.mp3","charTypeName":"word"},{"id":80591,"position":10,"arabic":"مَا","translation":"যার","audioUrl":"wbw/003_151_010.mp3","charTypeName":"word"},{"id":80592,"position":11,"arabic":"لَمْ","translation":"না","audioUrl":"wbw/003_151_011.mp3","charTypeName":"word"},{"id":80593,"position":12,"arabic":"يُنَزِّلْ","translation":"তিনি অবতীর্ণ করেছেন","audioUrl":"wbw/003_151_012.mp3","charTypeName":"word"},{"id":80594,"position":13,"arabic":"بِهِۦ","translation":"সে ব্যাপারে","audioUrl":"wbw/003_151_013.mp3","charTypeName":"word"},{"id":80595,"position":14,"arabic":"سُلْطَـٰنًۭا ۖ","translation":"কোনো প্রমাণ","audioUrl":"wbw/003_151_014.mp3","charTypeName":"word"},{"id":80597,"position":15,"arabic":"وَمَأْوَىٰهُمُ","translation":"এবং তাদের ঠিকানা (হবে)","audioUrl":"wbw/003_151_016.mp3","charTypeName":"word"},{"id":80598,"position":16,"arabic":"ٱلنَّارُ ۚ","translation":"(জাহান্নামের) আগুন","audioUrl":"wbw/003_151_017.mp3","charTypeName":"word"},{"id":80600,"position":17,"arabic":"وَبِئْسَ","translation":"এবং অতি নিকৃষ্ট","audioUrl":"wbw/003_151_019.mp3","charTypeName":"word"},{"id":80601,"position":18,"arabic":"مَثْوَى","translation":"আবাসস্থল","audioUrl":"wbw/003_151_020.mp3","charTypeName":"word"},{"id":80602,"position":19,"arabic":"ٱلظَّـٰلِمِينَ","translation":"জালিমদের (জন্য)","audioUrl":"wbw/003_151_021.mp3","charTypeName":"word"},{"id":80603,"position":20,"arabic":"١٥١","translation":"(১৫১)","audioUrl":null,"charTypeName":"end"}]},{"number":152,"arabic":"وَلَقَدْ صَدَقَكُمُ ٱللَّهُ وَعْدَهُۥٓ إِذْ تَحُسُّونَهُم بِإِذْنِهِۦ ۖ حَتَّىٰٓ إِذَا فَشِلْتُمْ وَتَنَٰزَعْتُمْ فِى ٱلْأَمْرِ وَعَصَيْتُم مِّنۢ بَعْدِ مَآ أَرَىٰكُم مَّا تُحِبُّونَ ۚ مِنكُم مَّن يُرِيدُ ٱلدُّنْيَا وَمِنكُم مَّن يُرِيدُ ٱلْءَاخِرَةَ ۚ ثُمَّ صَرَفَكُمْ عَنْهُمْ لِيَبْتَلِيَكُمْ ۖ وَلَقَدْ عَفَا عَنكُمْ ۗ وَٱللَّهُ ذُو فَضْلٍ عَلَى ٱلْمُؤْمِنِينَ","translation":"AND, INDEED, God made good His promise unto you when, by His leave, you were about to destroy your foes - until the moment when you lost heart and acted contrary to the [Prophet's] command, and disobeyed after He had brought you within view of that [victory] for which you were longing. There were among you such as cared for this world [alone], just as there were among you such as cared for the life to come: whereupon, in order that He might put you to a test, He prevented you from defeating your foes. But now He has effaced your sin: for God is limitless in His bounty unto the believers.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/445.mp3","surahId":3,"words":[{"id":80670,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়","audioUrl":"wbw/003_152_001.mp3","charTypeName":"word"},{"id":80671,"position":2,"arabic":"صَدَقَكُمُ","translation":"তোমাদেরকে সত্য করে দেখিয়েছেন","audioUrl":"wbw/003_152_002.mp3","charTypeName":"word"},{"id":80672,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/003_152_003.mp3","charTypeName":"word"},{"id":80673,"position":4,"arabic":"وَعْدَهُۥٓ","translation":"তাঁর ওয়াদা","audioUrl":"wbw/003_152_004.mp3","charTypeName":"word"},{"id":80674,"position":5,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/003_152_005.mp3","charTypeName":"word"},{"id":80675,"position":6,"arabic":"تَحُسُّونَهُم","translation":"তাদেরকে তোমরা হত্যা করছিলে","audioUrl":"wbw/003_152_006.mp3","charTypeName":"word"},{"id":80676,"position":7,"arabic":"بِإِذْنِهِۦ ۖ","translation":"তাঁর নির্দেশে","audioUrl":"wbw/003_152_007.mp3","charTypeName":"word"},{"id":80678,"position":8,"arabic":"حَتَّىٰٓ","translation":"এমনকি","audioUrl":"wbw/003_152_009.mp3","charTypeName":"word"},{"id":80679,"position":9,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/003_152_010.mp3","charTypeName":"word"},{"id":80680,"position":10,"arabic":"فَشِلْتُمْ","translation":"তোমরা দূর্বলতা দেখালে","audioUrl":"wbw/003_152_011.mp3","charTypeName":"word"},{"id":80681,"position":11,"arabic":"وَتَنَـٰزَعْتُمْ","translation":"এবং তোমরা মতবিরোধ করলে","audioUrl":"wbw/003_152_012.mp3","charTypeName":"word"},{"id":80682,"position":12,"arabic":"فِى","translation":"ক্ষেত্রে","audioUrl":"wbw/003_152_013.mp3","charTypeName":"word"},{"id":80683,"position":13,"arabic":"ٱلْأَمْرِ","translation":"কাজের","audioUrl":"wbw/003_152_014.mp3","charTypeName":"word"},{"id":80684,"position":14,"arabic":"وَعَصَيْتُم","translation":"ও তোমরা অবাধ্য হলে","audioUrl":"wbw/003_152_015.mp3","charTypeName":"word"},{"id":80685,"position":15,"arabic":"مِّنۢ","translation":"(থেকে)","audioUrl":"wbw/003_152_016.mp3","charTypeName":"word"},{"id":80686,"position":16,"arabic":"بَعْدِ","translation":"এরপরও","audioUrl":"wbw/003_152_017.mp3","charTypeName":"word"},{"id":80687,"position":17,"arabic":"مَآ","translation":"যা","audioUrl":"wbw/003_152_018.mp3","charTypeName":"word"},{"id":80688,"position":18,"arabic":"أَرَىٰكُم","translation":"তোমাদের তিনি দেখালেন","audioUrl":"wbw/003_152_019.mp3","charTypeName":"word"},{"id":80689,"position":19,"arabic":"مَّا","translation":"যা","audioUr