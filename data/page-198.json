َيِّبَةًۭ","translation":"পবিত্র","audioUrl":"wbw/009_072_013.mp3","charTypeName":"word"},{"id":60548,"position":14,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/009_072_014.mp3","charTypeName":"word"},{"id":60549,"position":15,"arabic":"جَنَّـٰتِ","translation":"জান্নাতের","audioUrl":"wbw/009_072_015.mp3","charTypeName":"word"},{"id":60550,"position":16,"arabic":"عَدْنٍۢ ۚ","translation":"চিরস্থায়ী","audioUrl":"wbw/009_072_016.mp3","charTypeName":"word"},{"id":60552,"position":17,"arabic":"وَرِضْوَٰنٌۭ","translation":"ও সন্তুষ্টি","audioUrl":"wbw/009_072_018.mp3","charTypeName":"word"},{"id":60553,"position":18,"arabic":"مِّنَ","translation":"পক্ষ থেকে","audioUrl":"wbw/009_072_019.mp3","charTypeName":"word"},{"id":60554,"position":19,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/009_072_020.mp3","charTypeName":"word"},{"id":60555,"position":20,"arabic":"أَكْبَرُ ۚ","translation":"সবচেয়ে বড়","audioUrl":"wbw/009_072_021.mp3","charTypeName":"word"},{"id":60557,"position":21,"arabic":"ذَٰلِكَ","translation":"এটাই","audioUrl":"wbw/009_072_023.mp3","charTypeName":"word"},{"id":60558,"position":22,"arabic":"هُوَ","translation":"সেই","audioUrl":"wbw/009_072_024.mp3","charTypeName":"word"},{"id":60559,"position":23,"arabic":"ٱلْفَوْزُ","translation":"সাফল্য","audioUrl":"wbw/009_072_025.mp3","charTypeName":"word"},{"id":60560,"position":24,"arabic":"ٱلْعَظِيمُ","translation":"মহা","audioUrl":"wbw/009_072_026.mp3","charTypeName":"word"},{"id":60561,"position":25,"arabic":"٧٢","translation":"(৭২)","audioUrl":null,"charTypeName":"end"}]}]}