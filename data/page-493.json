{"id":493,"ayahs":[{"number":48,"arabic":"وَمَا نُرِيهِم مِّنْ ءَايَةٍ إِلَّا هِىَ أَكْبَرُ مِنْ أُخْتِهَا ۖ وَأَخَذْنَٰهُم بِٱلْعَذَابِ لَعَلَّهُمْ يَرْجِعُونَ","translation":"although each sign that We showed them was weigh­tier than the preceding one: and [each time] We took them to task through suffering, so that they might return [to Us].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4373.mp3","surahId":43,"words":[{"id":47073,"position":1,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/043_048_001.mp3","charTypeName":"word"},{"id":47074,"position":2,"arabic":"نُرِيهِم","translation":"তাদের দেখাই আমরা","audioUrl":"wbw/043_048_002.mp3","charTypeName":"word"},{"id":47075,"position":3,"arabic":"مِّنْ","translation":"কোনো","audioUrl":"wbw/043_048_003.mp3","charTypeName":"word"},{"id":47076,"position":4,"arabic":"ءَايَةٍ","translation":"নিদর্শন","audioUrl":"wbw/043_048_004.mp3","charTypeName":"word"},{"id":47077,"position":5,"arabic":"إِلَّا","translation":"এছাড়া যে","audioUrl":"wbw/043_048_005.mp3","charTypeName":"word"},{"id":47078,"position":6,"arabic":"هِىَ","translation":"তা ছিলো","audioUrl":"wbw/043_048_006.mp3","charTypeName":"word"},{"id":47079,"position":7,"arabic":"أَكْبَرُ","translation":"উৎকৃষ্ট","audioUrl":"wbw/043_048_007.mp3","charTypeName":"word"},{"id":47080,"position":8,"arabic":"مِنْ","translation":"চেয়ে","audioUrl":"wbw/043_048_008.mp3","charTypeName":"word"},{"id":47081,"position":9,"arabic":"أُخْتِهَا ۖ","translation":"তার (পূর্বেকার) অনুরূপ","audioUrl":"wbw/043_048_009.mp3","charTypeName":"word"},{"id":47083,"position":10,"arabic":"وَأَخَذْنَـٰهُم","translation":"এবং তাদেরকে আমরা ধরেছিলাম","audioUrl":"wbw/043_048_011.mp3","charTypeName":"word"},{"id":47084,"position":11,"arabic":"بِٱلْعَذَابِ","translation":"শাস্তি দিয়ে","audioUrl":"wbw/043_048_012.mp3","charTypeName":"word"},{"id":47085,"position":12,"arabic":"لَعَلَّهُمْ","translation":"তারা যাতে","audioUrl":"wbw/043_048_013.mp3","charTypeName":"word"},{"id":4708