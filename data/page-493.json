097,"position":17,"arabic":"تُبْصِرُونَ","translation":"তোমরা দেখতে পাও","audioUrl":"wbw/043_051_018.mp3","charTypeName":"word"},{"id":49098,"position":18,"arabic":"٥١","translation":"(৫১)","audioUrl":null,"charTypeName":"end"}]},{"number":52,"arabic":"أَمْ أَنَا۠ خَيْرٌۭ مِّنْ هَٰذَا ٱلَّذِى هُوَ مَهِينٌۭ وَلَا يَكَادُ يُبِينُ","translation":"Am I not better than this contemptible man who can hardly make his meaning clear?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4377.mp3","surahId":43,"words":[{"id":49808,"position":1,"arabic":"أَمْ","translation":"অথবা","audioUrl":"wbw/043_052_001.mp3","charTypeName":"word"},{"id":49809,"position":2,"arabic":"أَنَا۠","translation":"আমি (নই কি)","audioUrl":"wbw/043_052_002.mp3","charTypeName":"word"},{"id":49810,"position":3,"arabic":"خَيْرٌۭ","translation":"উত্তম","audioUrl":"wbw/043_052_003.mp3","charTypeName":"word"},{"id":49811,"position":4,"arabic":"مِّنْ","translation":"চেয়ে","audioUrl":"wbw/043_052_004.mp3","charTypeName":"word"},{"id":49812,"position":5,"arabic":"هَـٰذَا","translation":"এই (মুসার)","audioUrl":"wbw/043_052_005.mp3","charTypeName":"word"},{"id":49813,"position":6,"arabic":"ٱلَّذِى","translation":"(এমন) যে","audioUrl":"wbw/043_052_006.mp3","charTypeName":"word"},{"id":49814,"position":7,"arabic":"هُوَ","translation":"সে","audioUrl":"wbw/043_052_007.mp3","charTypeName":"word"},{"id":49815,"position":8,"arabic":"مَهِينٌۭ","translation":"হীন","audioUrl":"wbw/043_052_008.mp3","charTypeName":"word"},{"id":49816,"position":9,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/043_052_009.mp3","charTypeName":"word"},{"id":49817,"position":10,"arabic":"يَكَادُ","translation":"প্রায়","audioUrl":"wbw/043_052_010.mp3","charTypeName":"word"},{"id":49818,"position":11,"arabic":"يُبِينُ","translation":"স্পষ্ট বর্ণনা করতে পারে (কথা)","audioUrl":"wbw/043_052_011.mp3","charTypeName":"word"},{"id":49819,"position":12,"arabic":"٥٢","translation":"(৫২)","audioUrl":null,"charTypeName":"end"}]},{"numbe