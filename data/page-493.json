sition":4,"arabic":"عَبْدٌ","translation":"এক দাস","audioUrl":"wbw/043_059_004.mp3","charTypeName":"word"},{"id":53703,"position":5,"arabic":"أَنْعَمْنَا","translation":"আমরা অনুগ্রহ করেছিলাম","audioUrl":"wbw/043_059_005.mp3","charTypeName":"word"},{"id":53704,"position":6,"arabic":"عَلَيْهِ","translation":"তার উপর","audioUrl":"wbw/043_059_006.mp3","charTypeName":"word"},{"id":53705,"position":7,"arabic":"وَجَعَلْنَـٰهُ","translation":"এবং তাকে আমরা করেছিলাম","audioUrl":"wbw/043_059_007.mp3","charTypeName":"word"},{"id":53706,"position":8,"arabic":"مَثَلًۭا","translation":"আদর্শস্বরূপ","audioUrl":"wbw/043_059_008.mp3","charTypeName":"word"},{"id":53707,"position":9,"arabic":"لِّبَنِىٓ","translation":"সন্তানদের জন্যে","audioUrl":"wbw/043_059_009.mp3","charTypeName":"word"},{"id":53708,"position":10,"arabic":"إِسْرَٰٓءِيلَ","translation":"ইসরাঈলের","audioUrl":"wbw/043_059_010.mp3","charTypeName":"word"},{"id":53709,"position":11,"arabic":"٥٩","translation":"(৫৯)","audioUrl":null,"charTypeName":"end"}]},{"number":60,"arabic":"وَلَوْ نَشَآءُ لَجَعَلْنَا مِنكُم مَّلَٰٓئِكَةًۭ فِى ٱلْأَرْضِ يَخْلُفُونَ","translation":"And had We so willed, [O you who worship angels,] We could indeed have made you into angels succeeding one another on earth!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4385.mp3","surahId":43,"words":[{"id":54430,"position":1,"arabic":"وَلَوْ","translation":"এবং যদি","audioUrl":"wbw/043_060_001.mp3","charTypeName":"word"},{"id":54431,"position":2,"arabic":"نَشَآءُ","translation":"আমরা চাইতাম","audioUrl":"wbw/043_060_002.mp3","charTypeName":"word"},{"id":54432,"position":3,"arabic":"لَجَعَلْنَا","translation":"আমরা অবশ্যই সৃষ্টি করতাম","audioUrl":"wbw/043_060_003.mp3","charTypeName":"word"},{"id":54433,"position":4,"arabic":"مِنكُم","translation":"তোমাদের মধ্য থেকে","audioUrl":"wbw/043_060_004.mp3","charTypeName":"word"},{"id":54434,"position":5,"arabic":"مَّلَـٰٓئِكَةًۭ","translation":"ফেরেশতা","audioUrl":"wbw/043_060_005.mp3","charTypeName":"word"},{"id":54435,"position":6,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/043_060_006.mp3","charTypeName":"word"},{"id":54436,"position":7,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/043_060_007.mp3","charTypeName":"word"},{"id":54437,"position":8,"arabic":"يَخْلُفُونَ","translation":"তারা স্থলাভিষিক্ত হতো (তোমাদের)","audioUrl":"wbw/043_060_008.mp3","charTypeName":"word"},{"id":54438,"position":9,"arabic":"٦٠","translation":"(৬০)","audioUrl":null,"charTypeName":"end"}]}]}