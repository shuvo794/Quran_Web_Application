{"id":252,"ayahs":[{"number":19,"arabic":"۞ أَفَمَن يَعْلَمُ أَنَّمَآ أُنزِلَ إِلَيْكَ مِن رَّبِّكَ ٱلْحَقُّ كَمَنْ هُوَ أَعْمَىٰٓ ۚ إِنَّمَا يَتَذَكَّرُ أُو۟لُوا۟ ٱلْأَلْبَٰبِ","translation":"CAN, THEN, he who knows that whatever has been bestowed from on high upon thee by thy Sustainer is the truth be deemed equal to one who is blind? Only they who are endowed with insight keep this in mind:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1726.mp3","surahId":13,"words":[{"id":22085,"position":1,"arabic":"۞ أَفَمَن","translation":"তবে কি যে ব্যক্তি","audioUrl":"wbw/013_019_002.mp3","charTypeName":"word"},{"id":22086,"position":2,"arabic":"يَعْلَمُ","translation":"জানে","audioUrl":"wbw/013_019_003.mp3","charTypeName":"word"},{"id":22087,"position":3,"arabic":"أَنَّمَآ","translation":"যে যা কিছু","audioUrl":"wbw/013_019_004.mp3","charTypeName":"word"},{"id":22088,"position":4,"arabic":"أُنزِلَ","translation":"অবতীর্ণ হয়েছে","audioUrl":"wbw/013_019_005.mp3","charTypeName":"word"},{"id":22089,"position":5,"arabic":"إِلَيْكَ","translation":"তোমার প্রতি","audioUrl":"wbw/013_019_006.mp3","charTypeName":"word"},{"id":22090,"position":6,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/013_019_007.mp3","charTypeName":"word"},{"id":22091,"position":7,"arabic":"رَّبِّكَ","translation":"তোমার রবের","audioUrl":"wbw/013_019_008.mp3","charTypeName":"word"},{"id":22092,"position":8,"arabic":"ٱلْحَقُّ","translation":"সত্য","audioUrl":"wbw/013_019_009.mp3","charTypeName":"word"},{"id":22093,"position":9,"arabic":"كَمَنْ","translation":"(ঐ ব্যক্তির) মতো যে","audioUrl":"wbw/013_019_010.mp3","charTypeName":"word"},{"id":22094,"position":10,"arabic":"هُوَ","translation":"সে","audioUrl":"wbw/013_019_011.mp3","charTypeName":"word"},{"id":22095,"position":11,"arabic":"أَعْمَىٰٓ ۚ","translation":"অন্ধ","audioUrl":"wbw/013_019_012.mp3","charTypeName":"word"},{"id":22097,"position":12,"arabic":"إِنَّمَا","translation":"প্রকৃতপক্ষে","audioUrl":"wbw/013_019_014.mp3","charTypeName":"word"},{"id":22098,"position":13,"arabic":"يَتَذَكَّرُ","translation":"শিক্ষা গ্রহণ করে (তা থেকে)","audioUrl":"wbw/013_019_015.mp3","charTypeName":"word"},{"id":22099,"position":14,"arabic":"أُو۟لُوا۟","translation":"সম্পন্নরাই","audioUrl":"wbw/013_019_016.mp3","charTypeName":"word"},{"id":22100,"position":15,"arabic":"ٱلْأَلْبَـٰبِ","translation":"বিবেক","audioUrl":"wbw/013_019_017.mp3","charTypeName":"word"},{"id":22101,"position":16,"arabic":"١٩","translation":"(১৯)","audioUrl":null,"charTypeName":"end"}]},{"number":20,"arabic":"ٱلَّذِينَ يُوفُونَ بِعَهْدِ ٱللَّهِ وَلَا يَنقُضُونَ ٱلْمِيثَٰقَ","translation":"they who are true to their bond with God and never break their covenant;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1727.mp3","surahId":13,"words":[{"id":23158,"position":1,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/013_020_001.mp3","charTypeName":"word"},{"id":23159,"position":2,"arabic":"يُوفُونَ","translation":"পূর্ণ করে সাথে","audioUrl":"wbw/013_020_002.mp3","charTypeName":"word"},{"id":23160,"position":3,"arabic":"بِعَهْدِ","translation":"অঙ্গীকার","audioUrl":"wbw/013_020_003.mp3","charTypeName":"word"},{"id":23161,"position":4,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/013_020_004.mp3","charTypeName":"word"},{"id":23162,"position":5,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/013_020_005.mp3","charTypeName":"word"},{"id":23163,"position":6,"arabic":"يَنقُضُونَ","translation":"তারা ভঙ্গ করে","audioUrl":"wbw/013_020_006.mp3","charTypeName":"word"},{"id":23164,"position":7,"arabic":"ٱلْمِيثَـٰقَ","translation":"প্রতিজ্ঞা","audioUrl":"wbw/013_020_007.mp3","charTypeName":"word"},{"id":23165,"position":8,"arabic":"٢٠","translation":"(২০)","audioUrl":null,"charTypeName":"end"}]},{"number":21,"arabic":"وَٱلَّذِينَ يَصِلُونَ مَآ أَمَرَ ٱللَّهُ بِهِۦٓ أَن يُوصَلَ وَيَخْشَوْنَ رَبَّهُمْ وَيَخَافُونَ سُوٓءَ ٱلْحِسَابِ","translation":"and who keep together what God has bidden to be joined, and stand in awe of their Sustainer and fear the most evil reckoning [which awaits such as do not respond to Him];","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1728.mp3","surahId":13,"words":[{"id":24168,"position":1,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/013_021_001.mp3","charTypeName":"word"},{"id":24169,"position":2,"arabic":"يَصِلُونَ","translation":"অক্ষুন্ন রাখে","audioUrl":"wbw/013_021_002.mp3","charTypeName":"word"},{"id":24170,"position":3,"arabic":"مَآ","translation":"যা","audioUrl":"wbw/013_021_003.mp3","charTypeName":"word"},{"id":24171,"position":4,"arabic":"أَمَرَ","translation":"নির্দেশ দিয়েছেন","audioUrl":"wbw/013_021_004.mp3","charTypeName":"word"},{"id":24172,"position":5,"arabic":"ٱللَّهُ","translation":"আল্লাহ তা'লা","audioUrl":"wbw/013_021_005.mp3","charTypeName":"word"},{"id":24173,"position":6,"arabic":"بِهِۦٓ","translation":"তা সম্বন্ধে","audioUrl":"wbw/013_021_006.mp3","charTypeName":"word"},{"id":24174,"position":7,"arabic":"أَن","translation":"যে","audioUrl":"wbw/013_021_007.mp3","charTypeName":"word"},{"id":24175,"position":8,"arabic":"يُوصَلَ","translation":"অক্ষুন্ন রাখতে","audioUrl":"wbw/013_021_008.mp3","charTypeName":"word"},{"id":24176,"position":9,"arabic":"وَيَخْشَوْنَ","translation":"ও তারা ভয় করে","audioUrl":"wbw/013_021_009.mp3","charTypeName":"word"},{"id":24177,"position":10,"arabic":"رَبَّهُمْ","translation":"তাদের রবকে","audioUrl":"wbw/013_021_010.mp3","charTypeName":"word"},{"id":24178,"position":11,"arabic":"وَيَخَافُونَ","translation":"এবং তারা আশঙ্কা করে","audioUrl":"wbw/013_021_011.mp3","charTypeName":"word"},{"id":24179,"position":12,"arabic":"سُوٓءَ","translation":"মন্দ","audioUrl":"wbw/013_021_012.mp3","charTypeName":"word"},{"id":24180,"position":13,"arabic":"ٱلْحِسَابِ","translation":"হিসাবের","audioUrl":"wbw/013_021_013.mp3","charTypeName":"word"},{"id":24181,"position":14,"arabic":"٢١","translation":"(২১)","audioUrl":null,"charTypeName":"end"}]},{"number":22,"arabic":"وَٱلَّذِينَ صَبَرُوا۟ ٱبْتِغَآءَ وَجْهِ رَبِّهِمْ وَأَقَامُوا۟ ٱلصَّلَوٰةَ وَأَنفَقُوا۟ مِمَّا رَزَقْنَٰهُمْ سِرًّۭا وَعَلَانِيَةًۭ وَيَدْرَءُونَ بِٱلْحَسَنَةِ ٱلسَّيِّئَةَ أُو۟لَٰٓئِكَ لَهُمْ عُقْبَى ٱلدَّارِ","translation":"and who are patient in adversity out of a longing for their Sustainer's countenance, and are constant in prayer, and spend on others, secretly and openly, out of what We provide for them as sustenance, and [who] repel evil with good. It is these that shall find their fulfilment in the hereafter:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1729.mp3","surahId":13,"words":[{"id":25156,"position":1,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/013_022_001.mp3","charTypeName":"word"},{"id":25157,"position":2,"arabic":"صَبَرُوا۟","translation":"ধৈর্য ধরে","audioUrl":"wbw/013_022_002.mp3","charTypeName":"word"},{"id":25158,"position":3,"arabic":"ٱبْتِغَآءَ","translation":"লাভের জন্যে","audioUrl":"wbw/013_022_003.mp3","charTypeName":"word"},{"id":25159,"position":4,"arabic":"وَجْهِ","translation":"সন্তুষ্টি","audioUrl":"wbw/013_022_004.mp3","charTypeName":"word"},{"id":25160,"position":5,"arabic":"رَبِّهِمْ","translation":"তাদের রবের","audioUrl":"wbw/013_022_005.mp3","charTypeName":"word"},{"id":25161,"position":6,"arabic":"وَأَقَامُوا۟","translation":"এবং তারা প্রতিষ্ঠা করে","audioUrl":"wbw/013_022_006.mp3","charTypeName":"word"},{"id":25162,"position":7,"arabic":"ٱلصَّلَوٰةَ","translation":"সালাত","audioUrl":"wbw/013_022_007.mp3","charTypeName":"word"},{"id":25163,"position":8,"arabic":"وَأَنفَقُوا۟","translation":"ও তারা ব্যয় করে","audioUrl":"wbw/013_022_008.mp3","charTypeName":"word"},{"id":25164,"position":9,"arabic":"مِمَّا","translation":"(তা) থেকে যা","audioUrl":"wbw/013_022_009.mp3","charTypeName":"word"},{"id":25165,"position":10,"arabic":"رَزَقْنَـٰهُمْ","translation":"আমরা জীবিকা দিয়েছি তাদের","audioUrl":"wbw/013_022_010.mp3","charTypeName":"word"},{"id":25166,"position":11,"arabic":"سِرًّۭا","translation":"গোপনে","audioUrl":"wbw/013_022_011.mp3","charTypeName":"word"},{"id":25167,"position":12,"arabic":"وَعَلَانِيَةًۭ","translation":"ও প্রকাশ্যে","audioUrl":"wbw/013_022_012.mp3","charTypeName":"word"},{"id":25168,"position":13,"arabic":"وَيَدْرَءُونَ","translation":"এবং তারা প্রতিরোধ করে","audioUrl":"wbw/013_022_013.mp3","charTypeName":"word"},{"id":25169,"position":14,"arabic":"بِٱلْحَسَنَةِ","translation":"দিয়ে ভালো","audioUrl":"wbw/013_022_014.mp3","charTypeName":"word"},{"id":25170,"position":15,"arabic":"ٱلسَّيِّئَةَ","translation":"মন্দকে","audioUrl":"wbw/013_022_015.mp3","charTypeName":"word"},{"id":25171,"position":16,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐসব লোক","audioUrl":"wbw/013_022_016.mp3","charTypeName":"word"},{"id":25172,"position":17,"arabic":"لَهُمْ","translation":"তাদের জন্যে (রয়েছে)","audioUrl":"wbw/013_022_017.mp3","charTypeName":"word"},{"id":25173,"position":18,"arabic":"عُقْبَى","translation":"পরকালের","audioUrl":"wbw/013_022_018.mp3","charTypeName":"word"},{"id":25174,"position":19,"arabic":"ٱلدَّارِ","translation":"ঘর","audioUrl":"wbw/013_022_019.mp3","charTypeName":"word"},{"id":25175,"position":20,"arabic":"٢٢","translation":"(২২)","audioUrl":null,"charTypeName":"end"}]},{"number":23,"arabic":"جَنَّٰتُ عَدْنٍۢ يَدْخُلُونَهَا وَمَن صَلَحَ مِنْ ءَابَآئِهِمْ وَأَزْوَٰجِهِمْ وَذُرِّيَّٰتِهِمْ ۖ وَٱلْمَلَٰٓئِكَةُ يَدْخُلُونَ عَلَيْهِم مِّن كُلِّ بَابٍۢ","translation":"gardens of perpetual bliss, which they shall enter together with the righteous from among their parents, their spouses, and their offspring; and the angels will come unto them from every gate [and will say]:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1730.mp3","surahId":13,"words":[{"id":26264,"position":1,"arabic":"جَنَّـٰتُ","translation":"জান্নাত","audioUrl":"wbw/013_023_001.mp3","charTypeName":"word"},{"id":26265,"position":2,"arabic":"عَدْنٍۢ","translation":"স্হায়ী","audioUrl":"wbw/013_023_002.mp3","charTypeName":"word"},{"id":26266,"position":3,"arabic":"يَدْخُلُونَهَا","translation":"তাতে তারা প্রবেশ করবে","audioUrl":"wbw/013_023_003.mp3","charTypeName":"word"},{"id":26267,"position":4,"arabic":"وَمَن","translation":"এবং যে","audioUrl":"wbw/013_023_004.mp3","charTypeName":"word"},{"id":26268,"position":5,"arabic":"صَلَحَ","translation":"সৎকাজ করেছে","audioUrl":"wbw/013_023_005.mp3","charTypeName":"word"},{"id":26269,"position":6,"arabic":"مِنْ","translation":"মধ্য হ'তে","audioUrl":"wbw/013_023_006.mp3","charTypeName":"word"},{"id":26270,"position":7,"arabic":"ءَابَآئِهِمْ","translation":"তাদের পূর্ব-পুরুষদের","audioUrl":"wbw/013_023_007.mp3","charTypeName":"word"},{"id":26271,"position":8,"arabic":"وَأَزْوَٰجِهِمْ","translation":"ও তাদের পতি-পত্নীদের","audioUrl":"wbw/013_023_008.mp3","charTypeName":"word"},{"id":26272,"position":9,"arabic":"وَذُرِّيَّـٰتِهِمْ ۖ","translation":"ও তাদের সন্তান-সন্ততিদের","audioUrl":"wbw/013_023_009.mp3","charTypeName":"word"},{"id":26274,"position":10,"arabic":"وَٱلْمَلَـٰٓئِكَةُ","translation":"এবং ফেরেশতারা","audioUrl":"wbw/013_023_011.mp3","charTypeName":"word"},{"id":26275,"position":11,"arabic":"يَدْخُلُونَ","translation":"প্রবেশ করবে (উপস্হিত হবে)","audioUrl":"wbw/013_023_012.mp3","charTypeName":"word"},{"id":26276,"position":12,"arabic":"عَلَيْهِم","translation":"কাছে তাদের","audioUrl":"wbw/013_023_013.mp3","charTypeName":"word"},{"id":26277,"position":13,"arabic":"مِّن","translation":"দিয়ে","audioUrl":"wbw/013_023_014.mp3","charTypeName":"word"},{"id":26278,"position":14,"arabic":"كُلِّ","translation":"প্রত্যেক","audioUrl":"wbw/013_023_015.mp3","charTypeName":"word"},{"id":26279,"position":15,"arabic":"بَابٍۢ","translation":"দরজা","audioUrl":"wbw/013_023_016.mp3","charTypeName":"word"},{"id":26280,"position":16,"arabic":"٢٣","translation":"(২৩)","audioUrl":null,"charTypeName":"end"}]},{"number":24,"arabic":"سَلَٰمٌ عَلَيْكُم بِمَا صَبَرْتُمْ ۚ فَنِعْمَ عُقْبَى ٱلدَّارِ","translation":"\"Peace be upon you, because you have persevered!\" How excellent, then, this fulfilment in the hereafter!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1731.mp3","surahId":13,"words":[{"id":27310,"position":1,"arabic":"سَلَـٰمٌ","translation":"শান্তি (বর্ষিত হোক)","audioUrl":"wbw/013_024_001.mp3","charTypeName":"word"},{"id":27311,"position":2,"arabic":"عَلَيْكُم","translation":"তোমাদের উপর","audioUrl":"wbw/013_024_002.mp3","charTypeName":"word"},{"id":27312,"position":3,"arabic":"بِمَا","translation":"এ কারণে যা","audioUrl":"wbw/013_024_003.mp3","charTypeName":"word"},{"id":27313,"position":4,"arabic":"صَبَرْتُمْ ۚ","translation":"তোমরা ধৈর্য ধরেছো","audioUrl":"wbw/013_024_004.mp3","charTypeName":"word"},{"id":27315,"position":5,"arabic":"فَنِعْمَ","translation":"অতএব কতই উত্তম","audioUrl":"wbw/013_024_006.mp3","charTypeName":"word"},{"id":27316,"position":6,"arabic":"عُقْبَى","translation":"পরকালের","audioUrl":"wbw/013_024_007.mp3","charTypeName":"word"},{"id":27317,"position":7,"arabic":"ٱلدَّارِ","translation":"ঘর\"","audioUrl":"wbw/013_024_008.mp3","charTypeName":"word"},{"id":27318,"position":8,"arabic":"٢٤","translation":"(২৪)","audioUrl":null,"charTypeName":"end"}]},{"number":25,"arabic":"وَٱلَّذِينَ يَنقُضُونَ عَهْدَ ٱللَّهِ مِنۢ بَعْدِ مِيثَٰقِهِۦ وَيَقْطَعُونَ مَآ أَمَرَ ٱللَّهُ بِهِۦٓ أَن يُوصَلَ وَيُفْسِدُونَ فِى ٱلْأَرْضِ ۙ أُو۟لَٰٓئِكَ لَهُمُ ٱللَّعْنَةُ وَلَهُمْ سُوٓءُ ٱلدَّارِ","translation":"But as for those who break their bond with God after it has been established [in their nature], and cut asunder what God has bidden to be joined, and spread corruption on earth -their due is rejection [by God], and theirs is a most evil fate [in the life to come].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1732.mp3","surahId":13,"words":[{"id":28377,"position":1,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/013_025_001.mp3","charTypeName":"word"},{"id":28378,"position":2,"arabic":"يَنقُضُونَ","translation":"ভঙ্গ করে","audioUrl":"wbw/013_025_002.mp3","charTypeName":"word"},{"id":28379,"position":3,"arabic":"عَهْدَ","translation":"অঙ্গীকার","audioUrl":"wbw/013_025_003.mp3","charTypeName":"word"},{"id":28380,"position":4,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/013_025_004.mp3","charTypeName":"word"},{"id":28381,"position":5,"arabic":"مِنۢ","translation":"থেকে","audioUrl":"wbw/013_025_005.mp3","charTypeName":"word"},{"id":28382,"position":6,"arabic":"بَعْدِ","translation":"পর","audioUrl":"wbw/013_025_006.mp3","charTypeName":"word"},{"id":28383,"position":7,"arabic":"مِيثَـٰقِهِۦ","translation":"তা (দৃঢ়ভাবে) বেঁধে নেয়ার","audioUrl":"wbw/013_025_007.mp3","charTypeName":"word"},{"id":28384,"position":8,"arabic":"وَيَقْطَعُونَ","translation":"ও তারা ছিন্ন করে","audioUrl":"wbw/013_025_008.mp3","charTypeName":"word"},{"id":28385,"position":9,"arabic":"مَآ","translation":"যা","audioUrl":"wbw/013_025_009.mp3","charTypeName":"word"},{"id":28386,"position":10,"arabic":"أَمَرَ","translation":"নির্দেশ দিয়েছেন","audioUrl":"wbw/013_025_010.mp3","charTypeName":"word"},{"id":28387,"position":11,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/013_025_011.mp3","charTypeName":"word"},{"id":28388,"position":12,"arabic":"بِهِۦٓ","translation":"সম্পর্কে তা","audioUrl":"wbw/013_025_012.mp3","charTypeName":"word"},{"id":28389,"position":13,"arabic":"أَن","translation":"যে","audioUrl":"wbw/013_025_013.mp3","charTypeName":"word"},{"id":28390,"position":14,"arabic":"يُوصَلَ","translation":"জুড়ে দিতে","audioUrl":"wbw/013_025_014.mp3","charTypeName":"word"},{"id":28391,"position":15,"arabic":"وَيُفْسِدُونَ","translation":"এবং তারা অশান্তি করে বেড়ায়","audioUrl":"wbw/013_025_015.mp3","charTypeName":"word"},{"id":28392,"position":16,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/013_025_016.mp3","charTypeName":"word"},{"id":28393,"position":17,"arabic":"ٱلْأَرْضِ ۙ","translation":"জমিনের","audioUrl":"wbw/013_025_017.mp3","charTypeName":"word"},{"id":28395,"position":18,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐসব লোক","audioUrl":"wbw/013_025_019.mp3","charTypeName":"word"},{"id":28396,"position":19,"arabic":"لَهُمُ","translation":"তাদের জন্যে","audioUrl":"wbw/013_025_020.mp3","charTypeName":"word"},{"id":28397,"position":20,"arabic":"ٱللَّعْنَةُ","translation":"অভিশাপ","audioUrl":"wbw/013_025_021.mp3","charTypeName":"word"},{"id":28398,"position":21,"arabic":"وَلَهُمْ","translation":"এবং তাদের জন্যে","audioUrl":"wbw/013_025_022.mp3","charTypeName":"word"},{"id":28399,"position":22,"arabic":"سُوٓءُ","translation":"নিকৃষ্ট","audioUrl":"wbw/013_025_023.mp3","charTypeName":"word"},{"id":28400,"position":23,"arabic":"ٱلدَّارِ","translation":"ঘর","audioUrl":"wbw/013_025_024.mp3","charTypeName":"word"},{"id":28401,"position":24,"arabic":"٢٥","translation":"(২৫)","audioUrl":null,"charTypeName":"end"}]},{"number":26,"arabic":"ٱللَّهُ يَبْسُطُ ٱلرِّزْقَ لِمَن يَشَآءُ وَيَقْدِرُ ۚ وَفَرِحُوا۟ بِٱلْحَيَوٰةِ ٱلدُّنْيَا وَمَا ٱلْحَيَوٰةُ ٱلدُّنْيَا فِى ٱلْءَاخِرَةِ إِلَّا مَتَٰعٌۭ","translation":"GOD GRANTS abundant sustenance, or gives it in scant measure, unto whomever He wills; and they [who are given abundance] rejoice in the life of this world - even though, as compared with the life to come, the life of this world is nought but -a fleeting pleasure.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1733.mp3","surahId":13,"words":[{"id":29264,"position":1,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/013_026_001.mp3","charTypeName":"word"},{"id":29265,"position":2,"arabic":"يَبْسُطُ","translation":"প্রশস্ত করে দেন","audioUrl":"wbw/013_026_002.mp3","charTypeName":"word"},{"id":29266,"position":3,"arabic":"ٱلرِّزْقَ","translation":"জীবনের উপকরণ","audioUrl":"wbw/013_026_003.mp3","charTypeName":"word"},{"id":29267,"position":4,"arabic":"لِمَن","translation":"জন্যে যার","audioUrl":"wbw/013_026_004.mp3","charTypeName":"word"},{"id":29268,"position":5,"arabic":"يَشَآءُ","translation":"তিনি ইচ্ছে করেন","audioUrl":"wbw/013_026_005.mp3","charTypeName":"word"},{"id":29269,"position":6,"arab