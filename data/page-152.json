":"word"},{"id":18957,"position":7,"arabic":"ٱلْمُسْتَقِيمَ","translation":"(যা) সরল সঠিক","audioUrl":"wbw/007_016_007.mp3","charTypeName":"word"},{"id":18958,"position":8,"arabic":"١٦","translation":"(১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":17,"arabic":"ثُمَّ لَءَاتِيَنَّهُم مِّنۢ بَيْنِ أَيْدِيهِمْ وَمِنْ خَلْفِهِمْ وَعَنْ أَيْمَٰنِهِمْ وَعَن شَمَآئِلِهِمْ ۖ وَلَا تَجِدُ أَكْثَرَهُمْ شَٰكِرِينَ","translation":"and shall most certainly fall upon them openly as well as in a manner beyond their ken, and from their right and from their left: and most of them Thou wilt find ungrateful.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/971.mp3","surahId":7,"words":[{"id":20055,"position":1,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/007_017_001.mp3","charTypeName":"word"},{"id":20056,"position":2,"arabic":"لَـَٔاتِيَنَّهُم","translation":"অবশ্যই আমি আসবোই কাছে তাদের","audioUrl":"wbw/007_017_002.mp3","charTypeName":"word"},{"id":20057,"position":3,"arabic":"مِّنۢ","translation":"হতে","audioUrl":"wbw/007_017_003.mp3","charTypeName":"word"},{"id":20058,"position":4,"arabic":"بَيْنِ","translation":"মাঝে","audioUrl":"wbw/007_017_004.mp3","charTypeName":"word"},{"id":20059,"position":5,"arabic":"أَيْدِيهِمْ","translation":"হাতের তাদের","audioUrl":"wbw/007_017_005.mp3","charTypeName":"word"},{"id":20060,"position":6,"arabic":"وَمِنْ","translation":"ও হতে","audioUrl":"wbw/007_017_006.mp3","charTypeName":"word"},{"id":20061,"position":7,"arabic":"خَلْفِهِمْ","translation":"পিছন তাদের","audioUrl":"wbw/007_017_007.mp3","charTypeName":"word"},{"id":20062,"position":8,"arabic":"وَعَنْ","translation":"ও হতে","audioUrl":"wbw/007_017_008.mp3","charTypeName":"word"},{"id":20063,"position":9,"arabic":"أَيْمَـٰنِهِمْ","translation":"ডানদিক তাদের","audioUrl":"wbw/007_017_009.mp3","charTypeName":"word"},{"id":20064,"position":10,"arabic":"وَعَن","translation":"ও হতে","audioUrl":"wbw/007_017_010.mp3","charTypeName":"word"},{"id":20065,"position":11,