rl":"wbw/007_018_008.mp3","charTypeName":"word"},{"id":21155,"position":8,"arabic":"مِنْهُمْ","translation":"মধ্য হতে তাদের","audioUrl":"wbw/007_018_009.mp3","charTypeName":"word"},{"id":21156,"position":9,"arabic":"لَأَمْلَأَنَّ","translation":"অবশ্যই পূর্ণ করব আমি","audioUrl":"wbw/007_018_010.mp3","charTypeName":"word"},{"id":21157,"position":10,"arabic":"جَهَنَّمَ","translation":"জাহান্নামকে","audioUrl":"wbw/007_018_011.mp3","charTypeName":"word"},{"id":21158,"position":11,"arabic":"مِنكُمْ","translation":"দিয়ে তোমাদের","audioUrl":"wbw/007_018_012.mp3","charTypeName":"word"},{"id":21159,"position":12,"arabic":"أَجْمَعِينَ","translation":"সবাইকে","audioUrl":"wbw/007_018_013.mp3","charTypeName":"word"},{"id":21160,"position":13,"arabic":"١٨","translation":"(১৮)","audioUrl":null,"charTypeName":"end"}]},{"number":19,"arabic":"وَيَٰٓـَٔادَمُ ٱسْكُنْ أَنتَ وَزَوْجُكَ ٱلْجَنَّةَ فَكُلَا مِنْ حَيْثُ شِئْتُمَا وَلَا تَقْرَبَا هَٰذِهِ ٱلشَّجَرَةَ فَتَكُونَا مِنَ ٱلظَّٰلِمِينَ","translation":"And [as for thee], O Adam', dwell thou and thy wife in this garden, and eat, both of you, whatever you may wish; but do not approach this one tree, lest you become evildoers!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/973.mp3","surahId":7,"words":[{"id":22258,"position":1,"arabic":"وَيَـٰٓـَٔادَمُ","translation":"এবং হে আদম","audioUrl":"wbw/007_019_001.mp3","charTypeName":"word"},{"id":22259,"position":2,"arabic":"ٱسْكُنْ","translation":"বসবাস করো","audioUrl":"wbw/007_019_002.mp3","charTypeName":"word"},{"id":22260,"position":3,"arabic":"أَنتَ","translation":"তুমি","audioUrl":"wbw/007_019_003.mp3","charTypeName":"word"},{"id":22261,"position":4,"arabic":"وَزَوْجُكَ","translation":"ও তোমার স্ত্রী","audioUrl":"wbw/007_019_004.mp3","charTypeName":"word"},{"id":22262,"position":5,"arabic":"ٱلْجَنَّةَ","translation":"জান্নাতে","audioUrl":"wbw/007_019_005.mp3","charTypeName":"word"},{"id":22263,"position":6,"arabic":"فَكُلَا","translation":"অতঃপর দু'জনে খাও","audioUrl":"wbw/007_019_006.mp3","charTypeName":"word"},{"id":22264,"position":7,"arabic":"مِنْ","translation":"থেকে","audioUrl":"wbw/007_019_007.mp3","charTypeName":"word"},{"id":22265,"position":8,"arabic":"حَيْثُ","translation":"যেখান","audioUrl":"wbw/007_019_008.mp3","charTypeName":"word"},{"id":22266,"position":9,"arabic":"شِئْتُمَا","translation":"তোমরা দু'জনে চাও","audioUrl":"wbw/007_019_009.mp3","charTypeName":"word"},{"id":22267,"position":10,"arabic":"وَلَا","translation":"তবে না","audioUrl":"wbw/007_019_010.mp3","charTypeName":"word"},{"id":22268,"position":11,"arabic":"تَقْرَبَا","translation":"দু'জনে নিকটে হবে","audioUrl":"wbw/007_019_011.mp3","charTypeName":"word"},{"id":22269,"position":12,"arabic":"هَـٰذِهِ","translation":"এই","audioUrl":"wbw/007_019_012.mp3","charTypeName":"word"},{"id":22270,"position":13,"arabic":"ٱلشَّجَرَةَ","translation":"গাছের","audioUrl":"wbw/007_019_013.mp3","charTypeName":"word"},{"id":22271,"position":14,"arabic":"فَتَكُونَا","translation":"তাহ'লে দু'জনে হবে","audioUrl":"wbw/007_019_014.mp3","charTypeName":"word"},{"id":22272,"position":15,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/007_019_015.mp3","charTypeName":"word"},{"id":22273,"position":16,"arabic":"ٱلظَّـٰلِمِينَ","translation":"সীমালঙ্ঘনকারীদের\"","audioUrl":"wbw/007_019_016.mp3","charTypeName":"word"},{"id":22274,"position":17,"arabic":"١٩","translation":"(১৯)","audioUrl":null,"charTypeName":"end"}]},{"number":20,"arabic":"فَوَسْوَسَ لَهُمَا ٱلشَّيْطَٰنُ لِيُبْدِىَ لَهُمَا مَا وُۥرِىَ عَنْهُمَا مِن سَوْءَٰتِهِمَا وَقَالَ مَا نَهَىٰكُمَا رَبُّكُمَا عَنْ هَٰذِهِ ٱلشَّجَرَةِ إِلَّآ أَن تَكُونَا مَلَكَيْنِ أَوْ تَكُونَا مِنَ ٱلْخَٰلِدِينَ","translation":"Thereupon Satan whispered unto the two with a view to making them conscious of their nakedness, of which [hitherto] they had been unaware; and he said: \"Your Sustainer has but forbidden you this tree lest you two become [as] angels, or lest you live forever.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/974.mp3","surahId":7,"words":[{"id":23303,"position":1,"arabic":"فَوَسْوَسَ","translation":"অতঃপর কুমন্ত্রণা দিলো","audioUrl":"wbw/007_020_001.mp3","charTypeName":"word"},{"id":23304,"position":2,"arabic":"لَهُمَا","translation":"প্রতি তাদের দুজনের","audioUrl":"wbw/007_020_002.mp3","charTypeName":"word"},{"id":23305,"position":3,"arabic":"ٱلشَّيْطَـٰنُ","translation":"শয়তান","audioUrl":"wbw/007_020_003.mp3","charTypeName":"word"},{"id":23306,"position":4,"arabic":"لِيُبْدِىَ","translation":"যেন প্রকাশ করে দেয়","audioUrl":"wbw/007_020_004.mp3","charTypeName":"word"},{"id":23307,"position":5,"arabic":"لَهُمَا","translation":"কাছে তাদের দু'জনের","audioUrl":"wbw/007_020_005.mp3","charTypeName":"word"},{"id":23308,"position":6,"arabic":"مَا","translation":"যা","audioUrl":"wbw/007_020_006.mp3","charTypeName":"word"},{"id":23309,"position":7,"arabic":"وُۥرِىَ","translation":"গোপন রাখা হয়েছিলো","audioUrl":"wbw/007_020_007.mp3","charTypeName":"word"},{"id":23310,"position":8,"arabic":"عَنْهُمَا","translation":"নিকট তাদের দুজন","audioUrl":"wbw/007_020_008.mp3","charTypeName":"word"},{"id":23311,"position":9,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/007_020_009.mp3","charTypeName":"word"},{"id":23312,"position":10,"arabic":"سَوْءَٰتِهِمَا","translation":"দুজনের লজ্জাস্থানগুলো তাদের","audioUrl":"wbw/007_020_010.mp3","charTypeName":"word"},{"id":23313,"position":11,"arabic":"وَقَالَ","translation":"এবং (শয়তান) বললো","audioUrl":"wbw/007_020_011.mp3","charTypeName":"word"},{"id":23314,"position":12,"arabic":"مَا","translation":"\"না","audioUrl":"wbw/007_020_012.mp3","charTypeName":"word"},{"id":23315,"position":13,"arabic":"نَهَىٰكُمَا","translation":"তোমাদের দুজনকে নিষেধ করেছেন","audioUrl":"wbw/007_020_013.mp3","charTypeName":"word"},{"id":23316,"position":14,"arabic":"رَبُّكُمَا","translation":"তোমাদের দুজনের রব","audioUrl":"wbw/007_020_014.mp3","charTypeName":"word"},{"id":23317,"position":15,"arabic":"عَنْ","translation":"হতে","audioUrl":"wbw/007