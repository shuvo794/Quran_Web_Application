{"id":152,"ayahs":[{"number":12,"arabic":"قَالَ مَا مَنَعَكَ أَلَّا تَسْجُدَ إِذْ أَمَرْتُكَ ۖ قَالَ أَنَا۠ خَيْرٌۭ مِّنْهُ خَلَقْتَنِى مِن نَّارٍۢ وَخَلَقْتَهُۥ مِن طِينٍۢ","translation":"[And God] said: \"What has kept thee from prostrating thyself when I commanded thee?\" Answered [Iblis]: \"I am better than he: Thou hast created me out of fire, whereas him Thou hast created out of clay.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/966.mp3","surahId":7,"words":[{"id":14629,"position":1,"arabic":"قَالَ","translation":"(আল্লাহ) বললেন","audioUrl":"wbw/007_012_001.mp3","charTypeName":"word"},{"id":14630,"position":2,"arabic":"مَا","translation":"\"কিসে","audioUrl":"wbw/007_012_002.mp3","charTypeName":"word"},{"id":14631,"position":3,"arabic":"مَنَعَكَ","translation":"তোমাকে বাধা দিলো","audioUrl":"wbw/007_012_003.mp3","charTypeName":"word"},{"id":14632,"position":4,"arabic":"أَلَّا","translation":"যে না","audioUrl":"wbw/007_012_004.mp3","charTypeName":"word"},{"id":14633,"position":5,"arabic":"تَسْجُدَ","translation":"তুমি সিজদা করলে (আদমকে)","audioUrl":"wbw/007_012_005.mp3","charTypeName":"word"},{"id":14634,"position":6,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/007_012_006.mp3","charTypeName":"word"},{"id":14635,"position":7,"arabic":"أَمَرْتُكَ ۖ","translation":"তোমাকে আমি নির্দেশ দিয়েছি\"","audioUrl":"wbw/007_012_007.mp3","charTypeName":"word"},{"id":14637,"position":8,"arabic":"قَالَ","translation":"(ইবলীস) বললো","audioUrl":"wbw/007_012_009.mp3","charTypeName":"word"},{"id":14638,"position":9,"arabic":"أَنَا۠","translation":"\"আমি","audioUrl":"wbw/007_012_010.mp3","charTypeName":"word"},{"id":14639,"position":10,"arabic":"خَيْرٌۭ","translation":"উত্তম","audioUrl":"wbw/007_012_011.mp3","charTypeName":"word"},{"id":14640,"position":11,"arabic":"مِّنْهُ","translation":"চেয়েও তার","audioUrl":"wbw/007_012_012.mp3","charTypeName":"word"},{"id":14641,"position":12,"arabic":"خَلَقْتَنِى","translation":"আপনি সৃষ্টি করেছেন আমাকে","audioUrl":"wbw/007_012_013.mp3","charTypeName":"word"},{"id":14642,"position":13,"arabic":"مِن","translation":"হতে","audioUrl":"wbw/007_012_014.mp3","charTypeName":"word"},{"id":14643,"position":14,"arabic":"نَّارٍۢ","translation":"আগুন","audioUrl":"wbw/007_012_015.mp3","charTypeName":"word"},{"id":14644,"position":15,"arabic":"وَخَلَقْتَهُۥ","translation":"এবং আপনি সৃষ্টি করেছেন তাকে","audioUrl":"wbw/007_012_016.mp3","charTypeName":"word"},{"id":14645,"position":16,"arabic":"مِن","translation":"দিয়ে","audioUrl":"wbw/007_012_017.mp3","charTypeName":"word"},{"id":14646,"position":17,"arabic":"طِينٍۢ","translation":"কাদা মাটি\"","audioUrl":"wbw/007_012_018.mp3","charTypeName":"word"},{"id":14647,"position":18,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]},{"number":13,"arabic":"قَالَ فَٱهْبِطْ مِنْهَا فَمَا يَكُونُ لَكَ أَن تَتَكَبَّرَ فِيهَا فَٱخْرُجْ إِنَّكَ مِنَ ٱلصَّٰغِرِينَ","translation":"[God] said: \"Down with thee, then, from this [state] -for it is not meet for thee to show arrogance here! Go forth, then: verily, among the humiliated shalt thou be!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/967.mp3","surahId":7,"words":[{"id":15719,"position":1,"arabic":"قَالَ","translation":"(আল্লা্হ) বললেন","audioUrl":"wbw/007_013_001.mp3","charTypeName":"word"},{"id":15720,"position":2,"arabic":"فَٱهْبِطْ","translation":"\"তাহ'লে তুমি নেমে যাও","audioUrl":"wbw/007_013_002.mp3","charTypeName":"word"},{"id":15721,"position":3,"arabic":"مِنْهَا","translation":"থেকে এখান","audioUrl":"wbw/007_013_003.mp3","charTypeName":"word"},{"id":15722,"position":4,"arabic":"فَمَا","translation":"কারণ না","audioUrl":"wbw/007_013_004.mp3","charTypeName":"word"},{"id":15723,"position":5,"arabic":"يَكُونُ","translation":"হতে পারে","audioUrl":"wbw/007_013_005.mp3","charTypeName":"word"},{"id":15724,"position":6,"arabic":"لَكَ","translation":"জন্যে তোমার","audioUrl":"wbw/007_013_006.mp3","charTypeName":"word"},{"id":15725,"position":7,"arabic":"أَن","