tion":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"أَمِ ٱتَّخَذُوا۟ مِن دُونِهِۦٓ أَوْلِيَآءَ ۖ فَٱللَّهُ هُوَ ٱلْوَلِىُّ وَهُوَ يُحْىِ ٱلْمَوْتَىٰ وَهُوَ عَلَىٰ كُلِّ شَىْءٍۢ قَدِيرٌۭ","translation":"Did they, perchance, [think that they could] choose protectors other than Him? But God alone is the Protector [of all that exists], since it is He alone who brings the dead to life, and He alone who has the power to will anything.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4281.mp3","surahId":42,"words":[{"id":9753,"position":1,"arabic":"أَمِ","translation":"তবে কি","audioUrl":"wbw/042_009_001.mp3","charTypeName":"word"},{"id":9754,"position":2,"arabic":"ٱتَّخَذُوا۟","translation":"তারা গ্রহণ করেছে","audioUrl":"wbw/042_009_002.mp3","charTypeName":"word"},{"id":9755,"position":3,"arabic":"مِن","translation":"মধ্য হতে","audioUrl":"wbw/042_009_003.mp3","charTypeName":"word"},{"id":9756,"position":4,"arabic":"دُونِهِۦٓ","translation":"তাঁকে ছাড়া","audioUrl":"wbw/042_009_004.mp3","charTypeName":"word"},{"id":9757,"position":5,"arabic":"أَوْلِيَآءَ ۖ","translation":"অভিভাবকরূপে (অন্যান্যদেরকে)","audioUrl":"wbw/042_009_005.mp3","charTypeName":"word"},{"id":9759,"position":6,"arabic":"فَٱللَّهُ","translation":"অথচ আল্লাহ","audioUrl":"wbw/042_009_007.mp3","charTypeName":"word"},{"id":9760,"position":7,"arabic":"هُوَ","translation":"তিনিই","audioUrl":"wbw/042_009_008.mp3","charTypeName":"word"},{"id":9761,"position":8,"arabic":"ٱلْوَلِىُّ","translation":"অভিভাবক","audioUrl":"wbw/042_009_009.mp3","charTypeName":"word"},{"id":9762,"position":9,"arabic":"وَهُوَ","translation":"এবং তিনিই","audioUrl":"wbw/042_009_010.mp3","charTypeName":"word"},{"id":9763,"position":10,"arabic":"يُحْىِ","translation":"জীবিত করেন","audioUrl":"wbw/042_009_011.mp3","charTypeName":"word"},{"id":9764,"position":11,"arabic":"ٱلْمَوْتَىٰ","translation":"মৃতদেরকে","audioUrl":"wbw/042_009_012.mp3","charTypeName":"word"},{"id":9765,"position":12,"arabic":"وَهُوَ"