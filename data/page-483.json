ation":"ছাড়া","audioUrl":"wbw/042_006_003.mp3","charTypeName":"word"},{"id":5958,"position":4,"arabic":"دُونِهِۦٓ","translation":"তাঁকে","audioUrl":"wbw/042_006_004.mp3","charTypeName":"word"},{"id":5959,"position":5,"arabic":"أَوْلِيَآءَ","translation":"অভিভাবকরূপে","audioUrl":"wbw/042_006_005.mp3","charTypeName":"word"},{"id":5960,"position":6,"arabic":"ٱللَّهُ","translation":"আল্লাহ-ই","audioUrl":"wbw/042_006_006.mp3","charTypeName":"word"},{"id":5961,"position":7,"arabic":"حَفِيظٌ","translation":"সংরক্ষক","audioUrl":"wbw/042_006_007.mp3","charTypeName":"word"},{"id":5962,"position":8,"arabic":"عَلَيْهِمْ","translation":"তাদের উপর","audioUrl":"wbw/042_006_008.mp3","charTypeName":"word"},{"id":5963,"position":9,"arabic":"وَمَآ","translation":"এবং নও","audioUrl":"wbw/042_006_009.mp3","charTypeName":"word"},{"id":5964,"position":10,"arabic":"أَنتَ","translation":"তুমি","audioUrl":"wbw/042_006_010.mp3","charTypeName":"word"},{"id":5965,"position":11,"arabic":"عَلَيْهِم","translation":"তাদের উপর (নিযুক্ত হয়েছে)","audioUrl":"wbw/042_006_011.mp3","charTypeName":"word"},{"id":5966,"position":12,"arabic":"بِوَكِيلٍۢ","translation":"কর্ম বিধায়ক","audioUrl":"wbw/042_006_012.mp3","charTypeName":"word"},{"id":5967,"position":13,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"وَكَذَٰلِكَ أَوْحَيْنَآ إِلَيْكَ قُرْءَانًا عَرَبِيًّۭا لِّتُنذِرَ أُمَّ ٱلْقُرَىٰ وَمَنْ حَوْلَهَا وَتُنذِرَ يَوْمَ ٱلْجَمْعِ لَا رَيْبَ فِيهِ ۚ فَرِيقٌۭ فِى ٱلْجَنَّةِ وَفَرِيقٌۭ فِى ٱلسَّعِيرِ","translation":"[Thou art but entrusted with Our message:] and so We have revealed unto thee a discourse in the Arabic tongue in order that thou mayest warn the foremost of all cities and all who dwell around it to wit, warn [them] of the Day of the Gathering, [the coming of] which is beyond all doubt: [the Day when] some shall find themselves in paradise, and some in the blazing flame.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4279.mp3",