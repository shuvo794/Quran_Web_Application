{"id":483,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ حمٓ","translation":"Ha. Mim.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4273.mp3","surahId":42,"words":[{"id":113,"position":1,"arabic":"حمٓ","translation":"হা-মীম","audioUrl":"wbw/042_001_001.mp3","charTypeName":"word"},{"id":114,"position":2,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"عٓسٓقٓ","translation":"Ayn. Sin. Qaf.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4274.mp3","surahId":42,"words":[{"id":947,"position":1,"arabic":"عٓسٓقٓ","translation":"আইন - সীন-ক্কাফ","audioUrl":"wbw/042_002_001.mp3","charTypeName":"word"},{"id":948,"position":2,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"كَذَٰلِكَ يُوحِىٓ إِلَيْكَ وَإِلَى ٱلَّذِينَ مِن قَبْلِكَ ٱللَّهُ ٱلْعَزِيزُ ٱلْحَكِيمُ","translation":"THUS has God, the Almighty, the Wise, revealed [the truth] unto thee, [O Muhammad,] and unto those who preceded thee:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4275.mp3","surahId":42,"words":[{"id":2048,"position":1,"arabic":"كَذَٰلِكَ","translation":"এভাবে","audioUrl":"wbw/042_003_001.mp3","charTypeName":"word"},{"id":2049,"position":2,"arabic":"يُوحِىٓ","translation":"ওহী পাঠান (আল্লাহ)","audioUrl":"wbw/042_003_002.mp3","charTypeName":"word"},{"id":2050,"position":3,"arabic":"إِلَيْكَ","translation":"তোমার প্রতি","audioUrl":"wbw/042_003_003.mp3","charTypeName":"word"},{"id":2051,"position":4,"arabic":"وَإِلَى","translation":"এবং প্রতি","audioUrl":"wbw/042_003_004.mp3","charTypeName":"word"},{"id":2052,"position":5,"arabic":"ٱلَّذِينَ","translation":"(তাদের) যারা","audioUrl":"wbw/042_003_005.mp3","charTypeName":"word"},{"id":2053,"position":6,"arabic":"مِن","translation":"মধ্য হতে","audioUrl":"wbw/042_003_006.mp3","charTypeName":"word"},{"id":2054,"position":7,"arabic":"قَبْلِكَ","translation":"তোমার পূর্বে (নাবী-রাসূল ছিলো)","audioUrl":"wbw/042_003_007.mp3","charTypeName":"word"},{"id":2055,"position":8,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/042_003_008.mp3","charTypeName":"word"},{"id":2056,"position":9,"arabic":"ٱلْعَزِيزُ","translation":"পরাক্রমশালী","audioUrl":"wbw/042_003_009.mp3","charTypeName":"word"},{"id":2057,"position":10,"arabic":"ٱلْحَكِيمُ","translation":"প্রজ্ঞাময়","audioUrl":"wbw/042_003_010.mp3","charTypeName":"word"},{"id":2058,"position":11,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"لَهُۥ مَا فِى ٱلسَّمَٰوَٰتِ وَمَا فِى ٱلْأَرْضِ ۖ وَهُوَ ٱلْعَلِىُّ ٱلْعَظِيمُ","translation":"His is all that is in the heavens and all that is on earth; and most exalted, tremendous is He.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4276.mp3","surahId":42,"words":[{"id":3320,"position":1,"arabic":"لَهُۥ","translation":"তাঁরই","audioUrl":"wbw/042_004_001.mp3","charTypeName":"word"},{"id":3321,"position":2,"arabic":"مَا","translation":"যা কিছু","audioUrl":"wbw/042_004_002.mp3","charTypeName":"word"},{"id":3322,"position":3,"arabic":"فِى","translation":"মধ্যে (আছে)","audioUrl":"wbw/042_004_003.mp3","charTypeName":"word"},{"id":3323,"position":4,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশের","audioUrl":"wbw/042_004_004.mp3","charTypeName":"word"},{"id":3324,"position":5,"arabic":"وَمَا","translation":"এবং যা কিছু","audioUrl":"wbw/042_004_005.mp3","charTypeName":"word"},{"id":3325,"position":6,"arabic":"فِى","translation":"মধ্যে আছে","audioUrl":"wbw/042_004_006.mp3","charTypeName":"word"},{"id":3326,"position":7,"arabic":"ٱلْأَرْضِ ۖ","translation":"পৃথিবীর","audioUrl":"wbw/042_004_007.mp3","charTypeName":"word"},{"id":3328,"position":8,"arabic":"وَهُوَ","translation":"এবং তিনিই","audioUrl":"wbw/042_004_009.mp3","charTypeName":"word"},{"id":3329,"position":9,"arabic":"ٱلْعَلِىُّ","translation":"সমুন্নত","audioUrl":"wbw/042_004_010.mp3","charTypeName":"word"},{"id":3330,"position":10,"arabic":"ٱلْعَظِيمُ","translation":"সুমহান","audioUrl":"wbw/042_004_011.mp3","charTypeName":"word"},{"id":3331,"position":11,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"تَكَادُ ٱلسَّمَٰوَٰتُ يَتَفَطَّرْنَ مِن فَوْقِهِنَّ ۚ وَٱلْمَلَٰٓئِكَةُ يُسَبِّحُونَ بِحَمْدِ رَبِّهِمْ وَيَسْتَغْفِرُونَ لِمَن فِى ٱلْأَرْضِ ۗ أَلَآ إِنَّ ٱللَّهَ هُوَ ٱلْغَفُورُ ٱلرَّحِيمُ","translation":"The uppermost heavens are well-nigh rent asunder [for awe of Him]; and the angels extol their Sustainer’s limitless glory and praise, and ask for­giveness for all who are on earth. Oh, verily, God alone is truly-forgiving, a dispenser of grace!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4277.mp3","surahId":42,"words":[{"id":4676,"position":1,"arabic":"تَكَادُ","translation":"(তাঁর সাথে শরিক করায়) উপক্রম হয়","audioUrl":"wbw/042_005_001.mp3","charTypeName":"word"},{"id":4677,"position":2,"arabic":"ٱلسَّمَـٰوَٰتُ","translation":"আকাশ","audioUrl":"wbw/042_005_002.mp3","charTypeName":"word"},{"id":4678,"position":3,"arabic":"يَتَفَطَّرْنَ","translation":"ভেঙে পড়ার","audioUrl":"wbw/042_005_003.mp3","charTypeName":"word"},{"id":4679,"position":4,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/042_005_004.mp3","charTypeName":"word"},{"id":4680,"position":5,"arabic":"فَوْقِهِنَّ ۚ","translation":"তাদের উপর","audioUrl":"wbw/042_005_005.mp3","charTypeName":"word"},{"id":4682,"position":6,"arabic":"وَٱلْمَلَـٰٓئِكَةُ","translation":"এবং ফেরেশতারা","audioUrl":"wbw/042_005_007.mp3","charTypeName":"word"},{"id":4683,"position":7,"arabic":"يُسَبِّحُونَ","translation":"পবিত্রতা ঘোষণা করে","audioUrl":"wbw/042_005_008.mp3","charTypeName":"word"},{"id":4684,"position":8,"arabic":"بِحَمْدِ","translation":"প্রশংসাসহ","audioUrl":"wbw/042_005_009.mp3","charTypeName":"word"},{"id":4685,"position":9,"arabic":"رَبِّهِمْ","translation":"তাদের রবের","audioUrl":"wbw/042_005_010.mp3","charTypeName":"word"},{"id":4686,"position":10,"arabic":"وَيَسْتَغْفِرُونَ","translati