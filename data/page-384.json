e":"word"},{"id":65200,"position":13,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/027_082_014.mp3","charTypeName":"word"},{"id":65201,"position":14,"arabic":"بِـَٔايَـٰتِنَا","translation":"প্রতি আয়াতগুলোর আমাদের","audioUrl":"wbw/027_082_015.mp3","charTypeName":"word"},{"id":65202,"position":15,"arabic":"لَا","translation":"না","audioUrl":"wbw/027_082_016.mp3","charTypeName":"word"},{"id":65203,"position":16,"arabic":"يُوقِنُونَ","translation":"দৃঢ় বিশ্বাস করতো","audioUrl":"wbw/027_082_017.mp3","charTypeName":"word"},{"id":65204,"position":17,"arabic":"٨٢","translation":"(৮২)","audioUrl":null,"charTypeName":"end"}]},{"number":83,"arabic":"وَيَوْمَ نَحْشُرُ مِن كُلِّ أُمَّةٍۢ فَوْجًۭا مِّمَّن يُكَذِّبُ بِـَٔايَٰتِنَا فَهُمْ يُوزَعُونَ","translation":"And on that Day We shall gather from within every community a host of those who gave the lie to Our messages; and they will be grouped [according to the gravity of their sins]","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3242.mp3","surahId":27,"words":[{"id":65603,"position":1,"arabic":"وَيَوْمَ","translation":"এবং(স্মরণ করো) সেদিন","audioUrl":"wbw/027_083_001.mp3","charTypeName":"word"},{"id":65604,"position":2,"arabic":"نَحْشُرُ","translation":"আমরা সমবেত করবো","audioUrl":"wbw/027_083_002.mp3","charTypeName":"word"},{"id":65605,"position":3,"arabic":"مِن","translation":"হ'তে","audioUrl":"wbw/027_083_003.mp3","charTypeName":"word"},{"id":65606,"position":4,"arabic":"كُلِّ","translation":"প্রত্যেক","audioUrl":"wbw/027_083_004.mp3","charTypeName":"word"},{"id":65607,"position":5,"arabic":"أُمَّةٍۢ","translation":"সম্প্রদায়","audioUrl":"wbw/027_083_005.mp3","charTypeName":"word"},{"id":65608,"position":6,"arabic":"فَوْجًۭا","translation":"একেক দলকে","audioUrl":"wbw/027_083_006.mp3","charTypeName":"word"},{"id":65609,"position":7,"arabic":"مِّمَّن","translation":"তাদের হ'তে যারা","audioUrl":"wbw/027_083_007.mp3","charTypeName":"word"},{"id":65610,"position":8,"arabic":"يُكَذِّبُ","tran