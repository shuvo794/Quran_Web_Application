{"id":384,"ayahs":[{"number":77,"arabic":"وَإِنَّهُۥ لَهُدًۭى وَرَحْمَةٌۭ لِّلْمُؤْمِنِينَ","translation":"and, verily, it is a guidance and a grace unto all who believe [in it].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3236.mp3","surahId":27,"words":[{"id":63122,"position":1,"arabic":"وَإِنَّهُۥ","translation":"এবং নিশ্চয়ই তা","audioUrl":"wbw/027_077_001.mp3","charTypeName":"word"},{"id":63123,"position":2,"arabic":"لَهُدًۭى","translation":"অবশ্যই পথনির্দেশ","audioUrl":"wbw/027_077_002.mp3","charTypeName":"word"},{"id":63124,"position":3,"arabic":"وَرَحْمَةٌۭ","translation":"এবং দয়া","audioUrl":"wbw/027_077_003.mp3","charTypeName":"word"},{"id":63125,"position":4,"arabic":"لِّلْمُؤْمِنِينَ","translation":"জন্যে মু'মিনদের","audioUrl":"wbw/027_077_004.mp3","charTypeName":"word"},{"id":63126,"position":5,"arabic":"٧٧","translation":"(৭৭)","audioUrl":null,"charTypeName":"end"}]},{"number":78,"arabic":"إِنَّ رَبَّكَ يَقْضِى بَيْنَهُم بِحُكْمِهِۦ ۚ وَهُوَ ٱلْعَزِيزُ ٱلْعَلِيمُ","translation":"Verily, [O believer,] thy Sustainer will judge between them in His wisdom - for He alone is almighty, all-knowing.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3237.mp3","surahId":27,"words":[{"id":63578,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/027_078_001.mp3","charTypeName":"word"},{"id":63579,"position":2,"arabic":"رَبَّكَ","translation":"তোমার রব","audioUrl":"wbw/027_078_002.mp3","charTypeName":"word"},{"id":63580,"position":3,"arabic":"يَقْضِى","translation":"মীমাংসা করে দিবেন","audioUrl":"wbw/027_078_003.mp3","charTypeName":"word"},{"id":63581,"position":4,"arabic":"بَيْنَهُم","translation":"মাঝে তাদের","audioUrl":"wbw/027_078_004.mp3","charTypeName":"word"},{"id":63582,"position":5,"arabic":"بِحُكْمِهِۦ ۚ","translation":"অনুযায়ী নির্দেশ তাঁর","audioUrl":"wbw/027_078_005.mp3","charTypeName":"word"},{"id":63584,"position":6,"arabic":"وَهُوَ","translation":"আর তিনি (হলেন)","audioUrl":"wbw/027_078_007.mp3","charTypeName":"word"},{"id":63585,"position":7,"arabic":"ٱلْعَزِيزُ","translation":"পরাক্রমশালী","audioUrl":"wbw/027_078_008.mp3","charTypeName":"word"},{"id":63586,"position":8,"arabic":"ٱلْعَلِيمُ","translation":"মহাবিজ্ঞ","audioUrl":"wbw/027_078_009.mp3","charTypeName":"word"},{"id":63587,"position":9,"arabic":"٧٨","translation":"(৭৮)","audioUrl":null,"charTypeName":"end"}]},{"number":79,"arabic":"فَتَوَكَّلْ عَلَى ٱللَّهِ ۖ إِنَّكَ عَلَى ٱلْحَقِّ ٱلْمُبِينِ","translation":"Hence, place thy trust in God [alone] - for, behold, that in which thou believest is truth self-evident.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3238.mp3","surahId":27,"words":[{"id":64036,"position":1,"arabic":"فَتَوَكَّلْ","translation":"অতএব (হে নাবী) নির্ভর করো","audioUrl":"wbw/027_079_001.mp3","charTypeName":"word"},{"id":64037,"position":2,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/027_079_002.mp3","charTypeName":"word"},{"id":64038,"position":3,"arabic":"ٱللَّهِ ۖ","translation":"আল্লাহর","audioUrl":"wbw/027_079_003.mp3","charTypeName":"word"},{"id":64040,"position":4,"arabic":"إِنَّكَ","translation":"তুমি নিশ্চয়ই (প্রতিষ্ঠিত)","audioUrl":"wbw/027_079_005.mp3","charTypeName":"word"},{"id":64041,"position":5,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/027_079_006.mp3","charTypeName":"word"},{"id":64042,"position":6,"arabic":"ٱلْحَقِّ","translation":"সত্যের","audioUrl":"wbw/027_079_007.mp3","charTypeName":"word"},{"id":64043,"position":7,"arabic":"ٱلْمُبِينِ","translation":"সুস্পষ্ট","audioUrl":"wbw/027_079_008.mp3","charTypeName":"word"},{"id":64044,"position":8,"arabic":"٧٩","translation":"(৭৯)","audioUrl":null,"charTypeName":"end"}]},{"number":80,"arabic":"إِنَّكَ لَا تُسْمِعُ ٱلْمَوْتَىٰ وَلَا تُسْمِعُ ٱلصُّمَّ ٱلدُّعَآءَ إِذَا وَلَّوْا۟ مُدْبِرِينَ","translation":"[But,] verily, thou canst not make the dead hear: and [so, too,] thou canst not make the deaf [of heart] hear this call when they turn their backs [on thee] and go away,","au