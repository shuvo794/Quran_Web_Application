3240.mp3","surahId":27,"words":[{"id":64844,"position":1,"arabic":"وَمَآ","translation":"এবং না","audioUrl":"wbw/027_081_001.mp3","charTypeName":"word"},{"id":64845,"position":2,"arabic":"أَنتَ","translation":"তুমি","audioUrl":"wbw/027_081_002.mp3","charTypeName":"word"},{"id":64846,"position":3,"arabic":"بِهَـٰدِى","translation":"পথপ্রদর্শনকারী (হ'তে পারো)","audioUrl":"wbw/027_081_003.mp3","charTypeName":"word"},{"id":64847,"position":4,"arabic":"ٱلْعُمْىِ","translation":"অন্ধদেরকে","audioUrl":"wbw/027_081_004.mp3","charTypeName":"word"},{"id":64848,"position":5,"arabic":"عَن","translation":"হ'তে","audioUrl":"wbw/027_081_005.mp3","charTypeName":"word"},{"id":64849,"position":6,"arabic":"ضَلَـٰلَتِهِمْ ۖ","translation":"পথভ্রষ্টতা তাদের","audioUrl":"wbw/027_081_006.mp3","charTypeName":"word"},{"id":64851,"position":7,"arabic":"إِن","translation":"(আর) না","audioUrl":"wbw/027_081_008.mp3","charTypeName":"word"},{"id":64852,"position":8,"arabic":"تُسْمِعُ","translation":"তুমি শুনাতে পারো","audioUrl":"wbw/027_081_009.mp3","charTypeName":"word"},{"id":64853,"position":9,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/027_081_010.mp3","charTypeName":"word"},{"id":64854,"position":10,"arabic":"مَن","translation":"যারা","audioUrl":"wbw/027_081_011.mp3","charTypeName":"word"},{"id":64855,"position":11,"arabic":"يُؤْمِنُ","translation":"ঈমান আনে","audioUrl":"wbw/027_081_012.mp3","charTypeName":"word"},{"id":64856,"position":12,"arabic":"بِـَٔايَـٰتِنَا","translation":"প্রতি আয়াতগুলোর আমাদের","audioUrl":"wbw/027_081_013.mp3","charTypeName":"word"},{"id":64857,"position":13,"arabic":"فَهُم","translation":"অতঃপর তারাই","audioUrl":"wbw/027_081_014.mp3","charTypeName":"word"},{"id":64858,"position":14,"arabic":"مُّسْلِمُونَ","translation":"মুসলমান বা আত্মসমর্পণকারী","audioUrl":"wbw/027_081_015.mp3","charTypeName":"word"},{"id":64859,"position":15,"arabic":"٨١","translation":"(৮১)","audioUrl":null,"charTypeName":"end"}]},{"number":82,"arabic":"۞ وَإِذَا وَقَعَ ٱلْقَوْلُ