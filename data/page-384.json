rTypeName":"word"},{"id":65840,"position":8,"arabic":"تُحِيطُوا۟","translation":"আয়ত্বে নিতে পারো","audioUrl":"wbw/027_084_008.mp3","charTypeName":"word"},{"id":65841,"position":9,"arabic":"بِهَا","translation":"সম্পর্কে সেগুলো","audioUrl":"wbw/027_084_009.mp3","charTypeName":"word"},{"id":65842,"position":10,"arabic":"عِلْمًا","translation":"কোনো জ্ঞান","audioUrl":"wbw/027_084_010.mp3","charTypeName":"word"},{"id":65843,"position":11,"arabic":"أَمَّاذَا","translation":"কি (তবে) আর","audioUrl":"wbw/027_084_011.mp3","charTypeName":"word"},{"id":65844,"position":12,"arabic":"كُنتُمْ","translation":"তোমরা ছিলে","audioUrl":"wbw/027_084_012.mp3","charTypeName":"word"},{"id":65845,"position":13,"arabic":"تَعْمَلُونَ","translation":"তোমরা করো\"","audioUrl":"wbw/027_084_013.mp3","charTypeName":"word"},{"id":65846,"position":14,"arabic":"٨٤","translation":"(৮৪)","audioUrl":null,"charTypeName":"end"}]},{"number":85,"arabic":"وَوَقَعَ ٱلْقَوْلُ عَلَيْهِم بِمَا ظَلَمُوا۟ فَهُمْ لَا يَنطِقُونَ","translation":"And the word [of truth] will stand revealed against them in the face of all the wrong which they had committed, and they will not [be able to] utter a single word [of excuse]:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3244.mp3","surahId":27,"words":[{"id":66230,"position":1,"arabic":"وَوَقَعَ","translation":"আর এসে পড়বে","audioUrl":"wbw/027_085_001.mp3","charTypeName":"word"},{"id":66231,"position":2,"arabic":"ٱلْقَوْلُ","translation":"(ঘোষিত শাস্তির) কথা","audioUrl":"wbw/027_085_002.mp3","charTypeName":"word"},{"id":66232,"position":3,"arabic":"عَلَيْهِم","translation":"উপর তাদের","audioUrl":"wbw/027_085_003.mp3","charTypeName":"word"},{"id":66233,"position":4,"arabic":"بِمَا","translation":"এ কারণে যা","audioUrl":"wbw/027_085_004.mp3","charTypeName":"word"},{"id":66234,"position":5,"arabic":"ظَلَمُوا۟","translation":"তারা সীমালঙ্ঘন করেছিলো","audioUrl":"wbw/027_085_005.mp3","charTypeName":"word"},{"id":66235,"position":6,"arabic":"فَهُمْ","translati