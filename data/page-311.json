":"wbw/019_087_002.mp3","charTypeName":"word"},{"id":66775,"position":3,"arabic":"ٱلشَّفَـٰعَةَ","translation":"সুপারিশ করার","audioUrl":"wbw/019_087_003.mp3","charTypeName":"word"},{"id":66776,"position":4,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/019_087_004.mp3","charTypeName":"word"},{"id":66777,"position":5,"arabic":"مَنِ","translation":"(সে)  যে","audioUrl":"wbw/019_087_005.mp3","charTypeName":"word"},{"id":66778,"position":6,"arabic":"ٱتَّخَذَ","translation":"গ্রহণ করেছে","audioUrl":"wbw/019_087_006.mp3","charTypeName":"word"},{"id":66779,"position":7,"arabic":"عِندَ","translation":"নিকট হ'তে","audioUrl":"wbw/019_087_007.mp3","charTypeName":"word"},{"id":66780,"position":8,"arabic":"ٱلرَّحْمَـٰنِ","translation":"দয়াময়ের","audioUrl":"wbw/019_087_008.mp3","charTypeName":"word"},{"id":66781,"position":9,"arabic":"عَهْدًۭا","translation":"প্রতিশ্রুতি","audioUrl":"wbw/019_087_009.mp3","charTypeName":"word"},{"id":66782,"position":10,"arabic":"٨٧","translation":"(৮৭)","audioUrl":null,"charTypeName":"end"}]},{"number":88,"arabic":"وَقَالُوا۟ ٱتَّخَذَ ٱلرَّحْمَٰنُ وَلَدًۭا","translation":"As it is, some assert, \"The Most Gracious has taken unto Himself a son„!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2338.mp3","surahId":19,"words":[{"id":67156,"position":1,"arabic":"وَقَالُوا۟","translation":"এবং তারা বলে","audioUrl":"wbw/019_088_001.mp3","charTypeName":"word"},{"id":67157,"position":2,"arabic":"ٱتَّخَذَ","translation":"\"গ্রহণ করেছেন","audioUrl":"wbw/019_088_002.mp3","charTypeName":"word"},{"id":67158,"position":3,"arabic":"ٱلرَّحْمَـٰنُ","translation":"দয়াময়","audioUrl":"wbw/019_088_003.mp3","charTypeName":"word"},{"id":67159,"position":4,"arabic":"وَلَدًۭا","translation":"পুত্র\"","audioUrl":"wbw/019_088_004.mp3","charTypeName":"word"},{"id":67160,"position":5,"arabic":"٨٨","translation":"(৮৮)","audioUrl":null,"charTypeName":"end"}]},{"number":89,"arabic":"لَّقَدْ جِئْتُمْ شَيْـًٔا إِدًّۭا","translation":"Indeed, [by this asse