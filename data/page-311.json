3","charTypeName":"word"},{"id":67889,"position":8,"arabic":"ٱلْجِبَالُ","translation":"পাহাড়সমূহ","audioUrl":"wbw/019_090_008.mp3","charTypeName":"word"},{"id":67890,"position":9,"arabic":"هَدًّا","translation":"চূর্ণ-বিচূর্ণ হয়ে","audioUrl":"wbw/019_090_009.mp3","charTypeName":"word"},{"id":67891,"position":10,"arabic":"٩٠","translation":"(৯০)","audioUrl":null,"charTypeName":"end"}]},{"number":91,"arabic":"أَن دَعَوْا۟ لِلرَّحْمَٰنِ وَلَدًۭا","translation":"That men. should ascribe a son to the Most Gracious,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2341.mp3","surahId":19,"words":[{"id":68587,"position":1,"arabic":"أَن","translation":"(এ কারণে) যে","audioUrl":"wbw/019_091_001.mp3","charTypeName":"word"},{"id":68588,"position":2,"arabic":"دَعَوْا۟","translation":"দাবী করছে","audioUrl":"wbw/019_091_002.mp3","charTypeName":"word"},{"id":68589,"position":3,"arabic":"لِلرَّحْمَـٰنِ","translation":"দয়াময়ের জন্যে","audioUrl":"wbw/019_091_003.mp3","charTypeName":"word"},{"id":68590,"position":4,"arabic":"وَلَدًۭا","translation":"পুত্র","audioUrl":"wbw/019_091_004.mp3","charTypeName":"word"},{"id":68591,"position":5,"arabic":"٩١","translation":"(৯১)","audioUrl":null,"charTypeName":"end"}]},{"number":92,"arabic":"وَمَا يَنۢبَغِى لِلرَّحْمَٰنِ أَن يَتَّخِذَ وَلَدًا","translation":"although it is inconceivable that the Most Gracious should take unto Himself a son!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2342.mp3","surahId":19,"words":[{"id":68647,"position":1,"arabic":"وَمَا","translation":"অথচ না","audioUrl":"wbw/019_092_001.mp3","charTypeName":"word"},{"id":68648,"position":2,"arabic":"يَنۢبَغِى","translation":"শোভা পায়","audioUrl":"wbw/019_092_002.mp3","charTypeName":"word"},{"id":68649,"position":3,"arabic":"لِلرَّحْمَـٰنِ","translation":"দয়াময়ের জন্য","audioUrl":"wbw/019_092_003.mp3","charTypeName":"word"},{"id":68650,"position":4,"arabic":"أَن","translation":"যে","audioUrl":"wbw/019_092_004.mp3","charTypeName":"word"},{"i