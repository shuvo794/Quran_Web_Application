bw/019_082_006.mp3","charTypeName":"word"},{"id":65172,"position":6,"arabic":"ضِدًّا","translation":"(তাদের দাবীর) বিরোধী","audioUrl":"wbw/019_082_007.mp3","charTypeName":"word"},{"id":65173,"position":7,"arabic":"٨٢","translation":"(৮২)","audioUrl":null,"charTypeName":"end"}]},{"number":83,"arabic":"أَلَمْ تَرَ أَنَّآ أَرْسَلْنَا ٱلشَّيَٰطِينَ عَلَى ٱلْكَٰفِرِينَ تَؤُزُّهُمْ أَزًّۭا","translation":"ART THOU NOT aware that We have let loose all [manner of] satanic forces upon those who deny the truth - [forces] that impel them [towards sin] with strong impulsion?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2333.mp3","surahId":19,"words":[{"id":65359,"position":1,"arabic":"أَلَمْ","translation":"নি কি","audioUrl":"wbw/019_083_001.mp3","charTypeName":"word"},{"id":65360,"position":2,"arabic":"تَرَ","translation":"তুমি লক্ষ্য করো","audioUrl":"wbw/019_083_002.mp3","charTypeName":"word"},{"id":65361,"position":3,"arabic":"أَنَّآ","translation":"যে আমরা","audioUrl":"wbw/019_083_003.mp3","charTypeName":"word"},{"id":65362,"position":4,"arabic":"أَرْسَلْنَا","translation":"আমরা পাঠিয়েছি","audioUrl":"wbw/019_083_004.mp3","charTypeName":"word"},{"id":65363,"position":5,"arabic":"ٱلشَّيَـٰطِينَ","translation":"শয়তানদেরকে","audioUrl":"wbw/019_083_005.mp3","charTypeName":"word"},{"id":65364,"position":6,"arabic":"عَلَى","translation":"কাছে","audioUrl":"wbw/019_083_006.mp3","charTypeName":"word"},{"id":65365,"position":7,"arabic":"ٱلْكَـٰفِرِينَ","translation":"কাফিরদের","audioUrl":"wbw/019_083_007.mp3","charTypeName":"word"},{"id":65366,"position":8,"arabic":"تَؤُزُّهُمْ","translation":"তাদেরকে উদ্বুদ্ধ করে","audioUrl":"wbw/019_083_008.mp3","charTypeName":"word"},{"id":65367,"position":9,"arabic":"أَزًّۭا","translation":"(বেশী বেশী) উদ্বুদ্ধ","audioUrl":"wbw/019_083_009.mp3","charTypeName":"word"},{"id":65368,"position":10,"arabic":"٨٣","translation":"(৮৩)","audioUrl":null,"charTypeName":"end"}]},{"number":84,"arabic":"فَلَا تَعْجَلْ عَلَيْهِمْ ۖ إِنَّمَا 