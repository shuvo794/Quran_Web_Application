tion":7,"arabic":"مِنَ","translation":"থেকে","audioUrl":"wbw/019_079_008.mp3","charTypeName":"word"},{"id":63741,"position":8,"arabic":"ٱلْعَذَابِ","translation":"শাস্তি","audioUrl":"wbw/019_079_009.mp3","charTypeName":"word"},{"id":63742,"position":9,"arabic":"مَدًّۭا","translation":"(অধিক মাত্রায়) বাড়ান","audioUrl":"wbw/019_079_010.mp3","charTypeName":"word"},{"id":63743,"position":10,"arabic":"٧٩","translation":"(৭৯)","audioUrl":null,"charTypeName":"end"}]},{"number":80,"arabic":"وَنَرِثُهُۥ مَا يَقُولُ وَيَأْتِينَا فَرْدًۭا","translation":"and divest him of all that he is [now] speaking of: for [on Judgment Day] he will appear before Us in a lonely state.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2330.mp3","surahId":19,"words":[{"id":64299,"position":1,"arabic":"وَنَرِثُهُۥ","translation":"এবং আমরা তার অধিকারী হবো","audioUrl":"wbw/019_080_001.mp3","charTypeName":"word"},{"id":64300,"position":2,"arabic":"مَا","translation":"যা কিছু","audioUrl":"wbw/019_080_002.mp3","charTypeName":"word"},{"id":64301,"position":3,"arabic":"يَقُولُ","translation":"সে বলছে","audioUrl":"wbw/019_080_003.mp3","charTypeName":"word"},{"id":64302,"position":4,"arabic":"وَيَأْتِينَا","translation":"এবং আমার কাছে সে আসবে","audioUrl":"wbw/019_080_004.mp3","charTypeName":"word"},{"id":64303,"position":5,"arabic":"فَرْدًۭا","translation":"একাকী","audioUrl":"wbw/019_080_005.mp3","charTypeName":"word"},{"id":64304,"position":6,"arabic":"٨٠","translation":"(৮০)","audioUrl":null,"charTypeName":"end"}]},{"number":81,"arabic":"وَٱتَّخَذُوا۟ مِن دُونِ ٱللَّهِ ءَالِهَةًۭ لِّيَكُونُوا۟ لَهُمْ عِزًّۭا","translation":"For [such as] these have taken to worshipping deities other than God, hoping that they would be a [source of] strength for them.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2331.mp3","surahId":19,"words":[{"id":64541,"position":1,"arabic":"وَٱتَّخَذُوا۟","translation":"এবং তারা গ্রহণ করেছে","audioUrl":"wbw/019_081_001.mp3","charTypeName":"word"},