{"id":149,"ayahs":[{"number":152,"arabic":"وَلَا تَقْرَبُوا۟ مَالَ ٱلْيَتِيمِ إِلَّا بِٱلَّتِى هِىَ أَحْسَنُ حَتَّىٰ يَبْلُغَ أَشُدَّهُۥ ۖ وَأَوْفُوا۟ ٱلْكَيْلَ وَٱلْمِيزَانَ بِٱلْقِسْطِ ۖ لَا نُكَلِّفُ نَفْسًا إِلَّا وُسْعَهَا ۖ وَإِذَا قُلْتُمْ فَٱعْدِلُوا۟ وَلَوْ كَانَ ذَا قُرْبَىٰ ۖ وَبِعَهْدِ ٱللَّهِ أَوْفُوا۟ ۚ ذَٰلِكُمْ وَصَّىٰكُم بِهِۦ لَعَلَّكُمْ تَذَكَّرُونَ","translation":"and do not touch the substance of an orphan - save to improve it-before he comes of age.\" And [in all your dealings] give full measure and weight, with equity: [however,] We do not burden any human being with more than he is well able to bear; and when you voice an opinion, be just, even though it be [against] one near of kin. And [always] observe your bond with God: this has He enjoined upon you, so that you might keep it in mind.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/941.mp3","surahId":6,"words":[{"id":80716,"position":1,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/006_152_001.mp3","charTypeName":"word"},{"id":80717,"position":2,"arabic":"تَقْرَبُوا۟","translation":"তোমরা নিকটেও যেও","audioUrl":"wbw/006_152_002.mp3","charTypeName":"word"},{"id":80718,"position":3,"arabic":"مَالَ","translation":"সম্পদের","audioUrl":"wbw/006_152_003.mp3","charTypeName":"word"},{"id":80719,"position":4,"arabic":"ٱلْيَتِيمِ","translation":"ইয়াতীমের","audioUrl":"wbw/006_152_004.mp3","charTypeName":"word"},{"id":80720,"position":5,"arabic":"إِلَّا","translation":"তবে","audioUrl":"wbw/006_152_005.mp3","charTypeName":"word"},{"id":80721,"position":6,"arabic":"بِٱلَّتِى","translation":"এমনভাবে","audioUrl":"wbw/006_152_006.mp3","charTypeName":"word"},{"id":80722,"position":7,"arabic":"هِىَ","translation":"যা","audioUrl":"wbw/006_152_007.mp3","charTypeName":"word"},{"id":80723,"position":8,"arabic":"أَحْسَنُ","translation":"অতি উত্তম (যেমন তাদের ভরণ পোষণ)","audioUrl":"wbw/006_152_008.mp3","charTypeName":"word"},{"id":80724,"position":9,"arabic":"حَتَّىٰ","translation":"যতক্ষণ না","audioUrl":"wbw/006_152_009.mp3","charTypeName":"word"},{"id":80725,"position":10,"arabic":"يَبْلُغَ","translation":"সে পৌঁছে","audioUrl":"wbw/006_152_010.mp3","charTypeName":"word"},{"id":80726,"position":11,"arabic":"أَشُدَّهُۥ ۖ","translation":"বয়ঃপ্রাপ্ততায় তার","audioUrl":"wbw/006_152_011.mp3","charTypeName":"word"},{"id":80728,"position":12,"arabic":"وَأَوْفُوا۟","translation":"এবং তোমরা পূর্ণ দিবে","audioUrl":"wbw/006_152_013.mp3","charTypeName":"word"},{"id":80729,"position":13,"arabic":"ٱلْكَيْلَ","translation":"পরিমাপ","audioUrl":"wbw/006_152_014.mp3","charTypeName":"word"},{"id":80730,"position":14,"arabic":"وَٱلْمِيزَانَ","translation":"ও ওজন","audioUrl":"wbw/006_152_015.mp3","charTypeName":"word"},{"id":80731,"position":15,"arabic":"بِٱلْقِسْطِ ۖ","translation":"ভাবে ন্যায্য","audioUrl":"wbw/006_152_016.mp3","charTypeName":"word"},{"id":80733,"position":16,"arabic":"لَا","translation":"না","audioUrl":"wbw/006_152_018.mp3","charTypeName":"word"},{"id":80734,"position":17,"arabic":"نُكَلِّفُ","translation":"ভার অর্পণ করি আমরা","audioUrl":"wbw/006_152_019.mp3","charTypeName":"word"},{"id":80735,"position":18,"arabic":"نَفْسًا","translation":"কোনো ব্যক্তিকে","audioUrl":"wbw/006_152_020.mp3","charTypeName":"word"},{"id":80736,"position":19,"arabic":"إِلَّا","translation":"এ ছাড়া (যা)","audioUrl":"wbw/006_152_021.mp3","charTypeName":"word"},{"id":80737,"position":20,"arabic":"وُسْعَهَا ۖ","translation":"তার সামর্থ্য (আছে)","audioUrl":"wbw/006_152_022.mp3","charTypeName":"word"},{"id":80739,"position":21,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/006_152_024.mp3","charTypeName":"word"},{"id":80740,"position":22,"arabic":"قُلْتُمْ","translation":"কথা বলো তোমরা","audioUrl":"wbw/006_152_025.mp3","charTypeName":"word"},{"id":80741,"position":23,"arabic":"فَٱعْدِلُوا۟","translation":"তখন তোমরা সুবিচার করো","audioUrl":"wbw/006_152_026.mp3","charTypeName":"word"},{"id":80742,"position":24,"arabic":"وَلَوْ","translation":"এবং যদি","audioUrl":"wbw/006_152_027.mp3","charTypeName":"word"},{"id":80743,"position":25,"arabic":"كَانَ","translation":"সে হয়","audioUrl":"wbw/006_152_028.mp3","charTypeName":"word"},{"id":80744,"position":26,"arabic":"ذَا","translation":"সম্পন্ন","audioUrl":"wbw/006_152_029.mp3","charTypeName":"word"},{"id":80745,"position":27,"arabic":"قُرْبَىٰ ۖ","translation":"নৈকট্য","audioUrl":"wbw/006_152_030.mp3","charTypeName":"word"},{"id":80747,"position":28,"arabic":"وَبِعَهْدِ","translation":"এবং অঙ্গীকারকে","audioUrl":"wbw/006_152_032.mp3","charTypeName":"word"},{"id":80748,"position":29,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌র","audioUrl":"wbw/006_152_033.mp3","charTypeName":"word"},{"id":80749,"position":30,"arabic":"أَوْفُوا۟ ۚ","translation":"তোমরা পূর্ণ করো","audioUrl":"wbw/006_152_034.mp3","charTypeName":"word"},{"id":80751,"position":31,"arabic":"ذَٰلِكُمْ","translation":"এটা","audioUrl":"wbw/006_152_036.mp3","charTypeName":"word"},{"id":80752,"position":32,"arabic":"وَصَّىٰكُم","translation":"নির্দেশ দিচ্ছেন তোমাদের","audioUrl":"wbw/006_152_037.mp3","charTypeName":"word"},{"id":80753,"position":33,"arabic":"بِهِۦ","translation":"সম্পর্কে সে","audioUrl":"wbw/006_152_038.mp3","charTypeName":"word"},{"id":80754,"position":34,"arabic":"لَعَلَّكُمْ","translation":"সম্ভবতঃ তোমরা","audioUrl":"wbw/006_152_039.mp3","charTypeName":"word"},{"id":80755,"position":35,"arabic":"تَذَكَّرُونَ","translation":"উপদেশ গ্রহণ করবে","audioUrl":"wbw/006_152_040.mp3","charTypeName":"word"},{"id":80756,"position":36,"arabic":"١٥٢","translation":"(১৫২)","audioUrl":null,"charTypeName":"end"}]},{"number":153,"arabic":"وَأَنَّ هَٰذَا صِرَٰطِى مُسْتَقِيمًۭا فَٱتَّبِعُوهُ ۖ وَلَا تَتَّبِعُوا۟ ٱلسُّبُلَ فَتَفَرَّقَ بِكُمْ عَن سَبِيلِهِۦ ۚ ذَٰلِكُمْ وَصَّىٰكُم بِهِۦ لَعَلَّكُمْ تَتَّقُونَ","translation":"And [know] that this is the way leading straight unto Me: follow it, then, and follow not other ways, lest they cause you to deviate from His way. [All] this has He enjoined upon you, so that you might remain conscious of Him.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/942.mp3","surahId":6,"words":[{"id":80774,"position":1,"arabic":"وَأَنَّ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/006_153_001.mp3","charTypeName":"word"},{"id":80775,"position":2,"arabic":"هَـٰذَا","translation":"এটাই","audioUrl":"wbw/006_153_002.mp3","charTypeName":"word"},{"id":80776,"position":3,"arabic":"صِرَٰطِى","translation":"আমার পথ","audioUrl":"wbw/006_153_003.mp3","charTypeName":"word"},{"id":80777,"position":4,"arabic":"مُسْتَقِيمًۭا","translation":"সরল-সঠিক","audioUrl":"wbw/006_153_004.mp3","charTypeName":"word"},{"id":80778,"position":5,"arabic":"فَٱتَّبِعُوهُ ۖ","translation":"অতএব তোমরা অনুসরণ করো তা","audioUrl":"wbw/006_153_005.mp3","charTypeName":"word"},{"id":80780,"position":6,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/006_153_007.mp3","charTypeName":"word"},{"id":80781,"position":7,"arabic":"تَتَّبِعُوا۟","translation":"তোমরা অনুসরণ করো","audioUrl":"wbw/006_153_008.mp3","charTypeName":"word"},{"id":80782,"position":8,"arabic":"ٱلسُّبُلَ","translation":"(শয়তানের) পথগুলোর","audioUrl":"wbw/006_153_009.mp3","charTypeName":"word"},{"id":80783,"position":9,"arabic":"فَتَفَرَّقَ","translation":"তাহলে বিচ্ছিন্ন করবে","audioUrl":"wbw/006_153_010.mp3","charTypeName":"word"},{"id":80784,"position":10,"arabic":"بِكُمْ","translation":"তোমাদেরকে","audioUrl":"wbw/006_153_011.mp3","charTypeName":"word"},{"id":80785,"position":11,"arabic":"عَن","translation":"হতে","audioUrl":"wbw/006_153_012.mp3","charTypeName":"word"},{"id":80786,"position":12,"arabic":"سَبِيلِهِۦ ۚ","translation":"পথ তাঁর","audioUrl":"wbw/006_153_013.mp3","charTypeName":"word"},{"id":80788,"position":13,"arabic":"ذَٰلِكُمْ","translation":"এটা","audioUrl":"wbw/006_153_015.mp3","charTypeName":"word"},{"id":80789,"position":14,"arabic":"وَصَّىٰكُم","translation":"(আল্লাহ্‌) জোর নির্দেশ দেন তোমাদেরকে","audioUrl":"wbw/006_153_016.mp3","charTypeName":"word"},{"id":80790,"position":15,"arabic":"بِهِۦ","translation":"সম্পর্কে সে","audioUrl":"wbw/006_153_017.mp3","charTypeName":"word"},{"id":80791,"position":16,"arabic":"لَعَلَّكُمْ","translation":"সম্ভবতঃ তোমরা","audioUrl":"wbw/006_153_018.mp3","charTypeName":"word"},{"id":80792,"position":17,"arabic":"تَتَّقُونَ","translation":"সংযত হবে","audioUrl":"wbw/006_153_019.mp3","charTypeName":"word"},{"id":80793,"position":18,"arabic":"١٥٣","translation":"(১৫৩)","audioUrl":null,"charTypeName":"end"}]},{"number":154,"arabic":"ثُمَّ ءَاتَيْنَا مُوسَى ٱلْكِتَٰبَ تَمَامًا عَلَى ٱلَّذِىٓ أَحْسَنَ وَتَفْصِيلًۭا لِّكُلِّ شَىْءٍۢ وَهُدًۭى وَرَحْمَةًۭ لَّعَلَّهُم بِلِقَآءِ رَبِّهِمْ يُؤْمِنُونَ","translation":"AND ONCE AGAIN: We vouchsafed the divine writ unto Moses in fulfilment [of Our favour] upon those who persevered in doing good, clearly spelling out everything, and [thus providing] guidance and grace, so that they might have faith in the [final] meeting with their Sustainer.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/943.mp3","surahId":6,"words":[{"id":80901,"position":1,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/006_154_001.mp3","charTypeName":"word"},{"id":80902,"position":2,"arabic":"ءَاتَيْنَا","translation":"আমরা দিয়েছি","audioUrl":"wbw/006_154_002.mp3","charTypeName":"word"},{"id":80903,"position":3,"arabic":"مُوسَى","translation":"মূসাকে","audioUrl":"wbw/006_154_003.mp3","charTypeName":"word"},{"id":80904,"position":4,"arabic":"ٱلْكِتَـٰبَ","translation":"কিতাব","audioUrl":"wbw/006_154_004.mp3","charTypeName":"word"},{"id":80905,"position":5,"arabic":"تَمَامًا","translation":"সম্পূর্ণ (নিয়ামাত)","audioUrl":"wbw/006_154_005.mp3","charTypeName":"word"},{"id":80906,"position":6,"arabic":"عَلَى","translation":"(তার) জন্যে","audioUrl":"wbw/006_154_006.mp3","charTypeName":"word"},{"id":80907,"position":7,"arabic":"ٱلَّذِىٓ","translation":"যে","audioUrl":"wbw/006_154_007.mp3","charTypeName":"word"},{"id":80908,"position":8,"arabic":"أَحْسَنَ","translation":"সৎ কাজ করে","audioUrl":"wbw/006_154_008.mp3","charTypeName":"word"},{"id":80909,"position":9,"arabic":"وَتَفْصِيلًۭا","translation":"ও (তা ছিলো) বিস্তারিত বিবরণ","audioUrl":"wbw/006_154_009.mp3","charTypeName":"word"},{"id":80910,"position":10,"arabic":"لِّكُلِّ","translation":"জন্যে সব","audioUrl":"wbw/006_154_010.mp3","charTypeName":"word"},{"id":80911,"position":11,"arabic":"شَىْءٍۢ","translation":"(জরুরী) জিনিসের","audioUrl":"wbw/006_154_011.mp3","charTypeName":"word"},{"id":80912,"position":12,"arabic":"وَهُدًۭى","translation":"ও পথ-নির্দেশ","audioUrl":"wbw/006_154_012.mp3","charTypeName":"word"},{"id":80913,"position":13,"arabic":"وَرَحْمَةًۭ","translation":"ও দয়াস্বরূপ","audioUrl":"wbw/006_154_013.mp3","charTypeName":"word"},{"id":80914,"position":14,"arabic":"لَّعَلَّهُم","translation":"যাতে তারা","audioUrl":"wbw/006_154_014.mp3","charTypeName":"word"},{"id":80915,"position":15,"arabic":"بِلِقَآءِ","translation":"প্রতি সাক্ষাতের","audioUrl":"wbw/006_154_015.mp3","charTypeName":"word"},{"id":80916,"position":16,"arabic":"رَبِّهِمْ","translation":"রবের তাদের","audioUrl":"wbw/006_154_016.mp3","charTypeName":"word"},{"id":80917,"position":17,"arabic":"يُؤْمِنُونَ","translation":"তারা বিশ্বাস করে","audioUrl":"wbw/006_154_017.mp3","charTypeName":"word"},{"id":80918,"position":18,"arabic":"١٥٤","translation":"(১৫৪)","audioUrl":null,"charTypeName":"end"}]},{"number":155,"arabic":"وَهَٰذَا كِتَٰبٌ أَنزَلْنَٰهُ مُبَارَكٌۭ فَٱتَّبِعُوهُ وَٱتَّقُوا۟ لَعَلَّكُمْ تُرْحَمُونَ","translation":"And this, too, is a divine writ which We have bestowed from on high, a blessed one: follow it, then, and be conscious of God, so that you might be graced with His mercy.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/944.mp3","surahId":6,"words":[{"id":81086,"position":1,"arabic":"وَهَـٰذَا","translation":"এবং এই","audioUrl":"wbw/006_155_001.mp3","charTypeName":"word"},{"id":81087,"position":2,"arabic":"كِتَـٰبٌ","translation":"কিতাব","audioUrl":"wbw/006_155_002.mp3","charTypeName":"word"},{