:"wbw/006_156_005.mp3","charTypeName":"word"},{"id":81274,"position":6,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/006_156_006.mp3","charTypeName":"word"},{"id":81275,"position":7,"arabic":"طَآئِفَتَيْنِ","translation":"দুই দলের (ইয়াহুদী ও খ্রিষ্টান)","audioUrl":"wbw/006_156_007.mp3","charTypeName":"word"},{"id":81276,"position":8,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/006_156_008.mp3","charTypeName":"word"},{"id":81277,"position":9,"arabic":"قَبْلِنَا","translation":"পূর্ব আমাদের","audioUrl":"wbw/006_156_009.mp3","charTypeName":"word"},{"id":81278,"position":10,"arabic":"وَإِن","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/006_156_010.mp3","charTypeName":"word"},{"id":81279,"position":11,"arabic":"كُنَّا","translation":"আমরা ছিলাম","audioUrl":"wbw/006_156_011.mp3","charTypeName":"word"},{"id":81280,"position":12,"arabic":"عَن","translation":"সম্বন্ধে","audioUrl":"wbw/006_156_012.mp3","charTypeName":"word"},{"id":81281,"position":13,"arabic":"دِرَاسَتِهِمْ","translation":"অধ্যয়ন তাদের","audioUrl":"wbw/006_156_013.mp3","charTypeName":"word"},{"id":81282,"position":14,"arabic":"لَغَـٰفِلِينَ","translation":"অবশ্যই অনবহিত\"","audioUrl":"wbw/006_156_014.mp3","charTypeName":"word"},{"id":81283,"position":15,"arabic":"١٥٦","translation":"(১৫৬)","audioUrl":null,"charTypeName":"end"}]},{"number":157,"arabic":"أَوْ تَقُولُوا۟ لَوْ أَنَّآ أُنزِلَ عَلَيْنَا ٱلْكِتَٰبُ لَكُنَّآ أَهْدَىٰ مِنْهُمْ ۚ فَقَدْ جَآءَكُم بَيِّنَةٌۭ مِّن رَّبِّكُمْ وَهُدًۭى وَرَحْمَةٌۭ ۚ فَمَنْ أَظْلَمُ مِمَّن كَذَّبَ بِـَٔايَٰتِ ٱللَّهِ وَصَدَفَ عَنْهَا ۗ سَنَجْزِى ٱلَّذِينَ يَصْدِفُونَ عَنْ ءَايَٰتِنَا سُوٓءَ ٱلْعَذَابِ بِمَا كَانُوا۟ يَصْدِفُونَ","translation":"or lest you say, \"If a divine writ had been bestowed from on high upon us, we would surely have followed its guidance better than they did.\" And so, a clear evidence of the truth has now come unto you from your Sustainer, and guidance, and grace. Who, then, could be more wicked than he who gives the lie to God's messages, and turns away from them in disdain? We shall requite those who turn away from Our messages in disdain with evil suffering for having thus turned away!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/946.mp3","surahId":6,"words":[{"id":81349,"position":1,"arabic":"أَوْ","translation":"বা","audioUrl":"wbw/006_157_001.mp3","charTypeName":"word"},{"id":81350,"position":2,"arabic":"تَقُولُوا۟","translation":"তোমরা বলো","audioUrl":"wbw/006_157_002.mp3","charTypeName":"word"},{"id":81351,"position":3,"arabic":"لَوْ","translation":"\"যদি","audioUrl":"wbw/006_157_003.mp3","charTypeName":"word"},{"id":81352,"position":4,"arabic":"أَنَّآ","translation":"বাস্তবিক আমরা","audioUrl":"wbw/006_157_004.mp3","charTypeName":"word"},{"id":81353,"position":5,"arabic":"أُنزِلَ","translation":"অবতীর্ণ করা হতো","audioUrl":"wbw/006_157_005.mp3","charTypeName":"word"},{"id":81354,"position":6,"arabic":"عَلَيْنَا","translation":"উপর আমাদের","audioUrl":"wbw/006_157_006.mp3","charTypeName":"word"},{"id":81355,"position":7,"arabic":"ٱلْكِتَـٰبُ","translation":"কিতাব","audioUrl":"wbw/006_157_007.mp3","charTypeName":"word"},{"id":81356,"position":8,"arabic":"لَكُنَّآ","translation":"অবশ্যই হতাম আমরা","audioUrl":"wbw/006_157_008.mp3","charTypeName":"word"},{"id":81357,"position":9,"arabic":"أَهْدَىٰ","translation":"অধিক সৎপথপ্রাপ্ত","audioUrl":"wbw/006_157_009.mp3","charTypeName":"word"},{"id":81358,"position":10,"arabic":"مِنْهُمْ ۚ","translation":"অপেক্ষা তাদের","audioUrl":"wbw/006_157_010.mp3","charTypeName":"word"},{"id":81360,"position":11,"arabic":"فَقَدْ","translation":"এখন নিশ্চয়ই","audioUrl":"wbw/006_157_012.mp3","charTypeName":"word"},{"id":81361,"position":12,"arabic":"جَآءَكُم","translation":"কাছে এসেছে তোমাদের","audioUrl":"wbw/006_157_013.mp3","charTypeName":"word"},{"id":81362,"position":13,"arabic":"بَيِّنَةٌۭ","translation":"স্পষ্ট প্রমাণ","audioUrl":"wbw/006_157_014.mp3","charTypeName":"word"},{"id":81363,"position":14,"arabic":"مِّن","translation":"পক্ষ হতে","audioUrl":"wbw/006_157_015.mp3","charTypeName":"word"},{"id":81364,"position":15,"arabic":"رَّبِّكُمْ","translation":"রবের তোমাদের","audioUrl":"wbw/006_157_016.mp3","charTypeName":"word"},{"id":81365,"position":16,"arabic":"وَهُدًۭى","translation":"ও পথ-নির্দেশনা","audioUrl":"wbw/006_157_017.mp3","charTypeName":"word"},{"id":81366,"position":17,"arabic":"وَرَحْمَةٌۭ ۚ","translation":"ও দয়া","audioUrl":"wbw/006_157_018.mp3","charTypeName":"word"},{"id":81368,"position":18,"arabic":"فَمَنْ","translation":"অতএব কে","audioUrl":"wbw/006_157_020.mp3","charTypeName":"word"},{"id":81369,"position":19,"arabic":"أَظْلَمُ","translation":"বড় সীমালঙ্ঘনকারী (হতে পারে)","audioUrl":"wbw/006_157_021.mp3","charTypeName":"word"},{"id":81370,"position":20,"arabic":"مِمَّن","translation":"তার চেয়ে যে","audioUrl":"wbw/006_157_022.mp3","charTypeName":"word"},{"id":81371,"position":21,"arabic":"كَذَّبَ","translation":"মিথ্যারোপ করে","audioUrl":"wbw/006_157_023.mp3","charTypeName":"word"},{"id":81372,"position":22,"arabic":"بِـَٔايَـٰتِ","translation":"প্রতি নিদর্শনাবলীর","audioUrl":"wbw/006_157_024.mp3","charTypeName":"word"},{"id":81373,"position":23,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌র","audioUrl":"wbw/006_157_025.mp3","charTypeName":"word"},{"id":81374,"position":24,"arabic":"وَصَدَفَ","translation":"ও মুখ ফিরিয়ে নেয়","audioUrl":"wbw/006_157_026.mp3","charTypeName":"word"},{"id":81375,"position":25,"arabic":"عَنْهَا ۗ","translation":"থেকে তা","audioUrl":"wbw/006_157_027.mp3","charTypeName":"word"},{"id":81377,"position":26,"arabic":"سَنَجْزِى","translation":"শীঘ্রই প্রতিফল দিবো আমরা","audioUrl":"wbw/006_157_029.mp3","charTypeName":"word"},{"id":81378,"position":27,"arabic":"ٱلَّذِينَ","translation":"(তাদেরকে) যারা","audioUrl":"wbw/006_157_030.mp3","charTypeName":"word"},{"id":81379,"position":28,"arabic":"يَصْدِفُونَ","translation":"মুখ ফিরিয়ে নিয়েছে","audioUrl":"wbw/006_157_031.mp3","charTypeName":"word"},{"id":81380,"position":29,"arabic":"عَنْ","translation":"হতে","