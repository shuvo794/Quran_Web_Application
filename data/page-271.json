_039_006.mp3","charTypeName":"word"},{"id":40972,"position":7,"arabic":"ٱلَّذِينَ","translation":"(তারা) যারা","audioUrl":"wbw/016_039_007.mp3","charTypeName":"word"},{"id":40973,"position":8,"arabic":"كَفَرُوٓا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/016_039_008.mp3","charTypeName":"word"},{"id":40974,"position":9,"arabic":"أَنَّهُمْ","translation":"যে তারা","audioUrl":"wbw/016_039_009.mp3","charTypeName":"word"},{"id":40975,"position":10,"arabic":"كَانُوا۟","translation":"(তারা) ছিলো","audioUrl":"wbw/016_039_010.mp3","charTypeName":"word"},{"id":40976,"position":11,"arabic":"كَـٰذِبِينَ","translation":"মিথ্যাবাদী","audioUrl":"wbw/016_039_011.mp3","charTypeName":"word"},{"id":40977,"position":12,"arabic":"٣٩","translation":"(৩৯)","audioUrl":null,"charTypeName":"end"}]},{"number":40,"arabic":"إِنَّمَا قَوْلُنَا لِشَىْءٍ إِذَآ أَرَدْنَٰهُ أَن نَّقُولَ لَهُۥ كُن فَيَكُونُ","translation":"Whenever We will anything to be, We but say unto it Our word \"Be\" -and it is.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1941.mp3","surahId":16,"words":[{"id":41879,"position":1,"arabic":"إِنَّمَا","translation":"শুধু এতটুকুই","audioUrl":"wbw/016_040_001.mp3","charTypeName":"word"},{"id":41880,"position":2,"arabic":"قَوْلُنَا","translation":"আমাদের কথা","audioUrl":"wbw/016_040_002.mp3","charTypeName":"word"},{"id":41881,"position":3,"arabic":"لِشَىْءٍ","translation":"জন্যে কোন কিছুর","audioUrl":"wbw/016_040_003.mp3","charTypeName":"word"},{"id":41882,"position":4,"arabic":"إِذَآ","translation":"যখন","audioUrl":"wbw/016_040_004.mp3","charTypeName":"word"},{"id":41883,"position":5,"arabic":"أَرَدْنَـٰهُ","translation":"আমরা তা করতে চাই","audioUrl":"wbw/016_040_005.mp3","charTypeName":"word"},{"id":41884,"position":6,"arabic":"أَن","translation":"যে","audioUrl":"wbw/016_040_006.mp3","charTypeName":"word"},{"id":41885,"position":7,"arabic":"نَّقُولَ","translation":"আমরা বলি","audioUrl":"wbw/016_040_007.mp3","charTypeName":"word"},{"id":41886,"position":8