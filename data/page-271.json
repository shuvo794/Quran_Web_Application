ِنَّ أَكْثَرَ ٱلنَّاسِ لَا يَعْلَمُونَ","translation":"As it is, they swear by God with their most solemn oaths, \"Never will God raise from the dead anyone who has died!\" Yea indeed! [This very thing has God promised] by a promise which He has willed upon Himself; but most people know it not.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1939.mp3","surahId":16,"words":[{"id":40226,"position":1,"arabic":"وَأَقْسَمُوا۟","translation":"এবং তারা শপথ করে","audioUrl":"wbw/016_038_001.mp3","charTypeName":"word"},{"id":40227,"position":2,"arabic":"بِٱللَّهِ","translation":"নামে আল্লাহর","audioUrl":"wbw/016_038_002.mp3","charTypeName":"word"},{"id":40228,"position":3,"arabic":"جَهْدَ","translation":"সাধ্য অনুসারে","audioUrl":"wbw/016_038_003.mp3","charTypeName":"word"},{"id":40229,"position":4,"arabic":"أَيْمَـٰنِهِمْ ۙ","translation":"তাদের শপথের","audioUrl":"wbw/016_038_004.mp3","charTypeName":"word"},{"id":40231,"position":5,"arabic":"لَا","translation":"না","audioUrl":"wbw/016_038_006.mp3","charTypeName":"word"},{"id":40232,"position":6,"arabic":"يَبْعَثُ","translation":"উঠাবেন","audioUrl":"wbw/016_038_007.mp3","charTypeName":"word"},{"id":40233,"position":7,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌","audioUrl":"wbw/016_038_008.mp3","charTypeName":"word"},{"id":40234,"position":8,"arabic":"مَن","translation":"(তাকে) যে","audioUrl":"wbw/016_038_009.mp3","charTypeName":"word"},{"id":40235,"position":9,"arabic":"يَمُوتُ ۚ","translation":"মারা যায়","audioUrl":"wbw/016_038_010.mp3","charTypeName":"word"},{"id":40237,"position":10,"arabic":"بَلَىٰ","translation":"হ্যাঁ (নিশ্চয়ই)","audioUrl":"wbw/016_038_012.mp3","charTypeName":"word"},{"id":40238,"position":11,"arabic":"وَعْدًا","translation":"প্রতিশ্রুতি","audioUrl":"wbw/016_038_013.mp3","charTypeName":"word"},{"id":40239,"position":12,"arabic":"عَلَيْهِ","translation":"তার উপর","audioUrl":"wbw/016_038_014.mp3","charTypeName":"word"},{"id":40240,"position":13,"arabic":"حَقًّۭا","translation":"অবধারিত","a