n":"তাদের পূর্ব","audioUrl":"wbw/016_035_027.mp3","charTypeName":"word"},{"id":37688,"position":27,"arabic":"فَهَلْ","translation":"সুতরাং কি","audioUrl":"wbw/016_035_029.mp3","charTypeName":"word"},{"id":37689,"position":28,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/016_035_030.mp3","charTypeName":"word"},{"id":37690,"position":29,"arabic":"ٱلرُّسُلِ","translation":"(দায়িত্ব আছে) রাসূলদের","audioUrl":"wbw/016_035_031.mp3","charTypeName":"word"},{"id":37691,"position":30,"arabic":"إِلَّا","translation":"এ ছাড়া যে","audioUrl":"wbw/016_035_032.mp3","charTypeName":"word"},{"id":37692,"position":31,"arabic":"ٱلْبَلَـٰغُ","translation":"পৌঁছানো (দীনের দাওয়াত)","audioUrl":"wbw/016_035_033.mp3","charTypeName":"word"},{"id":37693,"position":32,"arabic":"ٱلْمُبِينُ","translation":"সুস্পষ্ট ভাবে","audioUrl":"wbw/016_035_034.mp3","charTypeName":"word"},{"id":37694,"position":33,"arabic":"٣٥","translation":"(৩৫)","audioUrl":null,"charTypeName":"end"}]},{"number":36,"arabic":"وَلَقَدْ بَعَثْنَا فِى كُلِّ أُمَّةٍۢ رَّسُولًا أَنِ ٱعْبُدُوا۟ ٱللَّهَ وَٱجْتَنِبُوا۟ ٱلطَّٰغُوتَ ۖ فَمِنْهُم مَّنْ هَدَى ٱللَّهُ وَمِنْهُم مَّنْ حَقَّتْ عَلَيْهِ ٱلضَّلَٰلَةُ ۚ فَسِيرُوا۟ فِى ٱلْأَرْضِ فَٱنظُرُوا۟ كَيْفَ كَانَ عَٰقِبَةُ ٱلْمُكَذِّبِينَ","translation":"And indeed, within every community have We raised up an apostle [entrusted with this message]: \"Worship God, and shun the powers of evil!\" And among those [past generations] were people whom God graced with His guidance, just as there was among them [many a one] who inevitably fell prey to grievous error: go, then, about the earth and behold what happened in the end to those who gave the lie to the truth!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1937.mp3","surahId":16,"words":[{"id":38541,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/016_036_001.mp3","charTypeName":"word"},{"id":38542,"position":2,"arabic":"بَعَثْنَا","translation":"আমরা পাঠিয়েছি","audioUrl":"wbw/016_036_002.mp3","charTypeName":"word"},{"id":38543,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/016_036_003.mp3","charTypeName":"word"},{"id":38544,"position":4,"arabic":"كُلِّ","translation":"প্রত্যেক","audioUrl":"wbw/016_036_004.mp3","charTypeName":"word"},{"id":38545,"position":5,"arabic":"أُمَّةٍۢ","translation":"জাতির","audioUrl":"wbw/016_036_005.mp3","charTypeName":"word"},{"id":38546,"position":6,"arabic":"رَّسُولًا","translation":"রাসূল","audioUrl":"wbw/016_036_006.mp3","charTypeName":"word"},{"id":38547,"position":7,"arabic":"أَنِ","translation":"যে","audioUrl":"wbw/016_036_007.mp3","charTypeName":"word"},{"id":38548,"position":8,"arabic":"ٱعْبُدُوا۟","translation":"\"তোমরা ইবাদাত করো","audioUrl":"wbw/016_036_008.mp3","charTypeName":"word"},{"id":38549,"position":9,"arabic":"ٱللَّهَ","translation":"আল্লাহর","audioUrl":"wbw/016_036_009.mp3","charTypeName":"word"},{"id":38550,"position":10,"arabic":"وَٱجْتَنِبُوا۟","translation":"ও দূরে থাকো","audioUrl":"wbw/016_036_010.mp3","charTypeName":"word"},{"id":38551,"position":11,"arabic":"ٱلطَّـٰغُوتَ ۖ","translation":"তাগুত (হ'তে)\"","audioUrl":"wbw/016_036_011.mp3","charTypeName":"word"},{"id":38553,"position":12,"arabic":"فَمِنْهُم","translation":"অতঃপর তাদের মধ্য থেকে","audioUrl":"wbw/016_036_013.mp3","charTypeName":"word"},{"id":38554,"position":13,"arabic":"مَّنْ","translation":"কাউকে","audioUrl":"wbw/016_036_014.mp3","charTypeName":"word"},{"id":38555,"position":14,"arabic":"هَدَى","translation":"সৎপথে পরিচালনা করেন","audioUrl":"wbw/016_036_015.mp3","charTypeName":"word"},{"id":38556,"position":15,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌","audioUrl":"wbw/016_036_016.mp3","charTypeName":"word"},{"id":38557,"position":16,"arabic":"وَمِنْهُم","translation":"আর তাদের মধ্য থেকে","audioUrl":"wbw/016_036_017.mp3","charTypeName":"word"},{"id":38558,"position":17,"arabic":"مَّنْ","translation":"কারো","audioUrl":"wbw/016_036_018.mp3","charTypeName":"word"},{"id":38559,"position":18,"arabic":"حَقَّتْ","tran