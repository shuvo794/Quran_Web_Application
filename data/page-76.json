_199_019.mp3","charTypeName":"word"},{"id":85248,"position":20,"arabic":"ثَمَنًۭا","translation":"মূল্যের (জিনিস)","audioUrl":"wbw/003_199_020.mp3","charTypeName":"word"},{"id":85249,"position":21,"arabic":"قَلِيلًا ۗ","translation":"সামান্য","audioUrl":"wbw/003_199_021.mp3","charTypeName":"word"},{"id":85251,"position":22,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐসব লোক","audioUrl":"wbw/003_199_023.mp3","charTypeName":"word"},{"id":85252,"position":23,"arabic":"لَهُمْ","translation":"তাদের জন্য (রয়েছে)","audioUrl":"wbw/003_199_024.mp3","charTypeName":"word"},{"id":85253,"position":24,"arabic":"أَجْرُهُمْ","translation":"তাদের প্রতিফল","audioUrl":"wbw/003_199_025.mp3","charTypeName":"word"},{"id":85254,"position":25,"arabic":"عِندَ","translation":"কাছে","audioUrl":"wbw/003_199_026.mp3","charTypeName":"word"},{"id":85255,"position":26,"arabic":"رَبِّهِمْ ۗ","translation":"তাদের রবের","audioUrl":"wbw/003_199_027.mp3","charTypeName":"word"},{"id":85257,"position":27,"arabic":"إِنَّ","translation":"নিশ্চয়","audioUrl":"wbw/003_199_029.mp3","charTypeName":"word"},{"id":85258,"position":28,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/003_199_030.mp3","charTypeName":"word"},{"id":85259,"position":29,"arabic":"سَرِيعُ","translation":"ত্বরিত","audioUrl":"wbw/003_199_031.mp3","charTypeName":"word"},{"id":85260,"position":30,"arabic":"ٱلْحِسَابِ","translation":"হিসাব গ্রহণকারী","audioUrl":"wbw/003_199_032.mp3","charTypeName":"word"},{"id":85261,"position":31,"arabic":"١٩٩","translation":"(১৯৯)","audioUrl":null,"charTypeName":"end"}]},{"number":200,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ ٱصْبِرُوا۟ وَصَابِرُوا۟ وَرَابِطُوا۟ وَٱتَّقُوا۟ ٱللَّهَ لَعَلَّكُمْ تُفْلِحُونَ","translation":"O you who have attained to faith! Be patient in adversity, and vie in patience with one another, and be ever ready [to do what is right], and remain conscious of God, so that you might attain to a happy state!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/493.mp3","