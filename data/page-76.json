{"id":76,"ayahs":[{"number":195,"arabic":"فَٱسْتَجَابَ لَهُمْ رَبُّهُمْ أَنِّى لَآ أُضِيعُ عَمَلَ عَٰمِلٍۢ مِّنكُم مِّن ذَكَرٍ أَوْ أُنثَىٰ ۖ بَعْضُكُم مِّنۢ بَعْضٍۢ ۖ فَٱلَّذِينَ هَاجَرُوا۟ وَأُخْرِجُوا۟ مِن دِيَٰرِهِمْ وَأُوذُوا۟ فِى سَبِيلِى وَقَٰتَلُوا۟ وَقُتِلُوا۟ لَأُكَفِّرَنَّ عَنْهُمْ سَيِّـَٔاتِهِمْ وَلَأُدْخِلَنَّهُمْ جَنَّٰتٍۢ تَجْرِى مِن تَحْتِهَا ٱلْأَنْهَٰرُ ثَوَابًۭا مِّنْ عِندِ ٱللَّهِ ۗ وَٱللَّهُ عِندَهُۥ حُسْنُ ٱلثَّوَابِ","translation":"And thus does their Sustainer answer their prayer: \"I shall not lose sight of the labour of any of you who labours [in My way], be it man or woman: each of you is an issue of the other. Hence, as for those who forsake the domain of evil, and are driven from their homelands, and suffer hurt in My cause, and fight [for it], and are slain - I shall most certainly efface their bad deeds, and shall most certainly bring them into gardens through which running waters flow, as a reward from God: for with God is the most beauteous of rewards.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/488.mp3","surahId":3,"words":[{"id":84914,"position":1,"arabic":"فَٱسْتَجَابَ","translation":"তাই সাড়া দিলেন","audioUrl":"wbw/003_195_001.mp3","charTypeName":"word"},{"id":84915,"position":2,"arabic":"لَهُمْ","translation":"তাদেরকে","audioUrl":"wbw/003_195_002.mp3","charTypeName":"word"},{"id":84916,"position":3,"arabic":"رَبُّهُمْ","translation":"তাদের রব","audioUrl":"wbw/003_195_003.mp3","charTypeName":"word"},{"id":84917,"position":4,"arabic":"أَنِّى","translation":"''(এ বলে) যে আমি","audioUrl":"wbw/003_195_004.mp3","charTypeName":"word"},{"id":84918,"position":5,"arabic":"لَآ","translation":"না","audioUrl":"wbw/003_195_005.mp3","charTypeName":"word"},{"id":84919,"position":6,"arabic":"أُضِيعُ","translation":"নষ্ট করব","audioUrl":"wbw/003_195_006.mp3","charTypeName":"word"},{"id":84920,"position":7,"arabic":"عَمَلَ","translation":"আমল","audioUrl":"wbw/003_195_007.mp3","charTypeName":"word"},{"id":84921,"position":8,"arabic":"عَـٰمِلٍۢ","translation":"কোনো আমলকারীর","audioUrl":"wbw/003_195_008.mp3","charTypeName":"word"},{"id":84922,"position":9,"arabic":"مِّنكُم","translation":"তোমাদের মধ্যকার","audioUrl":"wbw/003_195_009.mp3","charTypeName":"word"},{"id":84923,"position":10,"arabic":"مِّن","translation":"মধ্য হতে","audioUrl":"wbw/003_195_010.mp3","charTypeName":"word"},{"id":84924,"position":11,"arabic":"ذَكَرٍ","translation":"পুরুষ (লোকদের)","audioUrl":"wbw/003_195_011.mp3","charTypeName":"word"},{"id":84925,"position":12,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/003_195_012.mp3","charTypeName":"word"},{"id":84926,"position":13,"arabic":"أُنثَىٰ ۖ","translation":"স্ত্রী (লোকদের)","audioUrl":"wbw/003_195_013.mp3","charTypeName":"word"},{"id":84928,"position":14,"arabic":"بَعْضُكُم","translation":"তোমাদের একে","audioUrl":"wbw/003_195_015.mp3","charTypeName":"word"},{"id":84929,"position":15,"arabic":"مِّنۢ","translation":"হতে","audioUrl":"wbw/003_195_016.mp3","charTypeName":"word"},{"id":84930,"position":16,"arabic":"بَعْضٍۢ ۖ","translation":"অন্যের (অর্থাত্‌ সমশ্রেণী ভুক্ত)","audioUrl":"wbw/003_195_017.mp3","charTypeName":"word"},{"id":84932,"position":17,"arabic":"فَٱلَّذِينَ","translation":"কাজেই যারা","audioUrl":"wbw/003_195_019.mp3","charTypeName":"word"},{"id":84933,"position":18,"arabic":"هَاجَرُوا۟","translation":"হিজরত করেছে","audioUrl":"wbw/003_195_020.mp3","charTypeName":"word"},{"id":84934,"position":19,"arabic":"وَأُخْرِجُوا۟","translation":"ও বহিস্কৃত হয়েছে","audioUrl":"wbw/003_195_021.mp3","charTypeName":"word"},{"id":84935,"position":20,"arabic":"مِن","translation":"হতে","audioUrl":"wbw/003_195_022.mp3","charTypeName":"word"},{"id":84936,"position":21,"arabic":"دِيَـٰرِهِمْ","translation":"তাদের ঘরবাড়ি","audioUrl":"wbw/003_195_023.mp3","charTypeName":"word"},{"id":84937,"position":22,"arabic":"وَأُوذُوا۟","translation":"এবং নির্যাতিত হয়েছে","audioUrl":"wbw/003_195_024.mp3","charTypeName":"word"},{"id":84938,"position":23,"arabic":"فِى","translation":"(মধ্যে)","audioUrl":"wbw/003_195_025.mp3","charTypeName":"word"},{"id":84939,"position":24,"arabic":"سَبِيلِى","translation":"আমার পথে","audioUrl":"wbw/003_195_026.mp3","charTypeName":"word"},{"id":84940,"position":25,"arabic":"وَقَـٰتَلُوا۟","translation":"এবং তারা যুদ্ধ করেছে","audioUrl":"wbw/003_195_027.mp3","charTypeName":"word"},{"id":84941,"position":26,"arabic":"وَقُتِلُوا۟","translation":"ও নিহত হয়েছে","audioUrl":"wbw/003_195_028.mp3","charTypeName":"word"},{"id":84942,"position":27,"arabic":"لَأُكَفِّرَنَّ","translation":"আমি অবশ্যই দূর করে দিবই","audioUrl":"wbw/003_195_029.mp3","charTypeName":"word"},{"id":84943,"position":28,"arabic":"عَنْهُمْ","translation":"তাদের থেকে","audioUrl":"wbw/003_195_030.mp3","charTypeName":"word"},{"id":84944,"position":29,"arabic":"سَيِّـَٔاتِهِمْ","translation":"তাদের দোষত্রুটি","audioUrl":"wbw/003_195_031.mp3","charTypeName":"word"},{"id":84945,"position":30,"arabic":"وَلَأُدْخِلَنَّهُمْ","translation":"এবং তাদেরকে অবশ্যই আমি প্রবেশ করাবই","audioUrl":"wbw/003_195_032.mp3","charTypeName":"word"},{"id":84946,"position":31,"arabic":"جَنَّـٰتٍۢ","translation":"জান্নাতে","audioUrl":"wbw/003_195_033.mp3","charTypeName":"word"},{"id":84947,"position":32,"arabic":"تَجْرِى","translation":"প্রবাহিত হয়","audioUrl":"wbw/003_195_034.mp3","charTypeName":"word"},{"id":84948,"position":33,"arabic":"مِن","translation":"(থেকে)","audioUrl":"wbw/003_195_035.mp3","charTypeName":"word"},{"id":84949,"position":34,"arabic":"تَحْتِهَا","translation":"তার পাদদেশে","audioUrl":"wbw/003_195_036.mp3","charTypeName":"word"},{"id":84950,"position":35,"arabic":"ٱلْأَنْهَـٰرُ","translation":"ঝর্নাধারা","audioUrl":"wbw/003_195_037.mp3","charTypeName":"word"},{"id":84951,"position":36,"arabic":"ثَوَابًۭا","translation":"প্রতিফল","audioUrl":"wbw/003_195_038.mp3","charTypeName":"word"},{"id":84952,"position":37,"arabic":"مِّنْ","translation":"থেকে","audioUrl":"wbw/003_195_039.mp3","charTypeName":"word"},{"id":84953,"position":38,"arabic":"عِندِ","translation":"নিকট","audioUrl":"wbw/003_195_040.mp3","charTypeName":"word"},{"id":84954,"position":39,"arabic":"ٱللَّهِ ۗ","translation":"আল্লাহ্‌র","audioUrl":"wbw/003_195_041.mp3","charTypeName":"word"},{"id":84956,"position":40,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ (এমন যে)","audioUrl":"wbw/003_195_043.mp3","charTypeName":"word"},{"id":84957,"position":41,"arabic":"عِندَهُۥ","translation":"তাঁরই কাছে (আছে)","audioUrl":"wbw/003_195_044.mp3","charTypeName":"word"},{"id":84958,"position":42,"arabic":"حُسْنُ","translation":"উত্তম","audioUrl":"wbw/003_195_045.mp3","charTypeName":"word"},{"id":84959,"position":43,"arabic":"ٱلثَّوَابِ","translation":"প্রতিফল''","audioUrl":"wbw/003_195_046.mp3","charTypeName":"word"},{"id":84960,"position":44,"arabic":"١٩٥","translation":"(১৯৫)","audioUrl":null,"charTypeName":"end"}]},{"number":196,"arabic":"لَا يَغُرَّنَّكَ تَقَلُّبُ ٱلَّذِينَ كَفَرُوا۟ فِى ٱلْبِلَٰدِ","translation":"LET IT NOT deceive thee that those who are bent on denying the truth seem to be able to do as they please on earth:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/489.mp3","surahId":3,"words":[{"id":84981,"position":1,"arabic":"لَا","translation":"না  (যেন)","audioUrl":"wbw/003_196_001.mp3","charTypeName":"word"},{"id":84982,"position":2,"arabic":"يَغُرَّنَّكَ","translation":"তোমাকে ধোঁকা দেয়","audioUrl":"wbw/003_196_002.mp3","charTypeName":"word"},{"id":84983,"position":3,"arabic":"تَقَلُّبُ","translation":"(দম্ভপূর্ণ) চলাফেরা","audioUrl":"wbw/003_196_003.mp3","charTypeName":"word"},{"id":84984,"position":4,"arabic":"ٱلَّذِينَ","translation":"(তাদের) যারা","audioUrl":"wbw/003_196_004.mp3","charTypeName":"word"},{"id":84985,"position":5,"arabic":"كَفَرُوا۟","translation":"কুফরী করেছে","audioUrl":"wbw/003_196_005.mp3","charTypeName":"word"},{"id":84986,"position":6,"arabic":"فِى","translation":"(মধ্যে)","audioUrl":"wbw/003_196_006.mp3","charTypeName":"word"},{"id":84987,"position":7,"arabic":"ٱلْبِلَـٰدِ","translation":"দেশ দেশে","audioUrl":"