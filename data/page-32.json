{"id":32,"ayahs":[{"number":203,"arabic":"۞ وَٱذْكُرُوا۟ ٱللَّهَ فِىٓ أَيَّامٍۢ مَّعْدُودَٰتٍۢ ۚ فَمَن تَعَجَّلَ فِى يَوْمَيْنِ فَلَآ إِثْمَ عَلَيْهِ وَمَن تَأَخَّرَ فَلَآ إِثْمَ عَلَيْهِ ۚ لِمَنِ ٱتَّقَىٰ ۗ وَٱتَّقُوا۟ ٱللَّهَ وَٱعْلَمُوٓا۟ أَنَّكُمْ إِلَيْهِ تُحْشَرُونَ","translation":"And bear God in mind during the appointed days; but he who hurries away within two days shall incur no sin, and he who tarries longer shall incur no sin, provided that he is conscious of God. Hence, remain conscious of God, and know that unto Him you shall be gathered.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/210.mp3","surahId":2,"words":[{"id":85385,"position":1,"arabic":"۞ وَٱذْكُرُوا۟","translation":"এবং তোমরা স্মরণ করো","audioUrl":"wbw/002_203_002.mp3","charTypeName":"word"},{"id":85386,"position":2,"arabic":"ٱللَّهَ","translation":"আল্লাহকে","audioUrl":"wbw/002_203_003.mp3","charTypeName":"word"},{"id":85387,"position":3,"arabic":"فِىٓ","translation":"মধ্যে","audioUrl":"wbw/002_203_004.mp3","charTypeName":"word"},{"id":85388,"position":4,"arabic":"أَيَّامٍۢ","translation":"দিনগুলোর","audioUrl":"wbw/002_203_005.mp3","charTypeName":"word"},{"id":85389,"position":5,"arabic":"مَّعْدُودَٰتٍۢ ۚ","translation":"নির্দিষ্ট সংখ্যক","audioUrl":"wbw/002_203_006.mp3","charTypeName":"word"},{"id":85391,"position":6,"arabic":"فَمَن","translation":"যে অতঃপর","audioUrl":"wbw/002_203_008.mp3","charTypeName":"word"},{"id":85392,"position":7,"arabic":"تَعَجَّلَ","translation":"তাড়াতাড়ি করে","audioUrl":"wbw/002_203_009.mp3","charTypeName":"word"},{"id":85393,"position":8,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/002_203_010.mp3","charTypeName":"word"},{"id":85394,"position":9,"arabic":"يَوْمَيْنِ","translation":"দুইদিনের (চলে আসে)","audioUrl":"wbw/002_203_011.mp3","charTypeName":"word"},{"id":85395,"position":10,"arabic":"فَلَآ","translation":"নেই তবে","audioUrl":"wbw/002_203_012.mp3","charTypeName":"word"},{"id":85396,"position":11,"arabic":"إِثْمَ","translation":"কোন পাপ","audioUrl":"wbw/002_203_013.mp3","charTypeName":"word"},{"id":85397,"position":12,"arabic":"عَلَيْهِ","translation":"তার উপর","audioUrl":"wbw/002_203_014.mp3","charTypeName":"word"},{"id":85398,"position":13,"arabic":"وَمَن","translation":"আর যে","audioUrl":"wbw/002_203_015.mp3","charTypeName":"word"},{"id":85399,"position":14,"arabic":"تَأَخَّرَ","translation":"বিলম্ব করে (ফিরে)","audioUrl":"wbw/002_203_016.mp3","charTypeName":"word"},{"id":85400,"position":15,"arabic":"فَلَآ","translation":"তাতেও নাই","audioUrl":"wbw/002_203_017.mp3","charTypeName":"word"},{"id":85401,"position":16,"arabic":"إِثْمَ","translation":"কোন পাপ","audioUrl":"wbw/002_203_018.mp3","charTypeName":"word"},{"id":85402,"position":17,"arabic":"عَلَيْهِ ۚ","translation":"তার উপর","audioUrl":"wbw/002_203_019.mp3","charTypeName":"word"},{"id":85404,"position":18,"arabic":"لِمَنِ","translation":"তার জন্য যে","audioUrl":"wbw/002_203_021.mp3","charTypeName":"word"},{"id":85405,"position":19,"arabic":"ٱتَّقَىٰ ۗ","translation":"তাকওয়া অবলম্বন করে","audioUrl":"wbw/002_203_022.mp3","charTypeName":"word"},{"id":85407,"position":20,"arabic":"وَٱتَّقُوا۟","translation":"এবং তোমরা ভয় করো","audioUrl":"wbw/002_203_024.mp3","charTypeName":"word"},{"id":85408,"position":21,"arabic":"ٱللَّهَ","translation":"আল্লাহকে","audioUrl":"wbw/002_203_025.mp3","charTypeName":"word"},{"id":85409,"position":22,"arabic":"وَٱعْلَمُوٓا۟","translation":"এবং তোমরা জেনে রাখো","audioUrl":"wbw/002_203_026.mp3","charTypeName":"word"},{"id":85410,"position":23,"arabic":"أَنَّكُمْ","translation":"যে তোমাদেরকে","audioUrl":"wbw/002_203_027.mp3","charTypeName":"word"},{"id":85411,"position":24,"arabic":"إِلَيْهِ","translation":"তারই দিকে","audioUrl":"wbw/002_203_028.mp3","charTypeName":"word"},{"id":85412,"position":25,"arabic":"تُحْشَرُونَ","translation":"একত্র করা হবে","audioUrl":"wbw/002_203_029.mp3","charTypeName":"word"},{"id":85413,"position":26,"arabic":"٢٠٣","translation":"(২০৩)","audioUrl":null,"charTypeName":"end"}]},{"number":204,"arabic":"وَمِنَ ٱلنَّاسِ مَن يُعْجِبُكَ قَوْلُهُۥ فِى ٱلْحَيَوٰةِ ٱلدُّنْيَا وَيُشْهِدُ ٱللَّهَ عَلَىٰ مَا فِى قَلْبِهِۦ وَهُوَ أَلَدُّ ٱلْخِصَامِ","translation":"NOW THERE IS a kind of man whose views on the life of this world may please thee greatly, and [the more so as] he cites God as witness to what is in his heart and is, moreover, exceedingly skillful in argument.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/211.mp3","surahId":2,"words":[{"id":85445,"position":1,"arabic":"وَمِنَ","translation":"এবং মধ্যে(কেউ কেউ)","audioUrl":"wbw/002_204_001.mp3","charTypeName":"word"},{"id":85446,"position":2,"arabic":"ٱلنَّاسِ","translation":"লোকদের (এমনও আছে)","audioUrl":"wbw/002_204_002.mp3","charTypeName":"word"},{"id":85447,"position":3,"arabic":"مَن","translation":"যে","audioUrl":"wbw/002_204_003.mp3","charTypeName":"word"},{"id":85448,"position":4,"arabic":"يُعْجِبُكَ","translation":"তোমাকে মুগ্ধ করে","audioUrl":"wbw/002_204_004.mp3","charTypeName":"word"},{"id":85449,"position":5,"arabic":"قَوْلُهُۥ","translation":"তার কথাবার্তা","audioUrl":"wbw/002_204_005.mp3","charTypeName":"word"},{"id":85450,"position":6,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/002_204_006.mp3","charTypeName":"word"},{"id":85451,"position":7,"arabic":"ٱلْحَيَوٰةِ","translation":"জীবনের","audioUrl":"wbw/002_204_007.mp3","charTypeName":"word"},{"id":85452,"position":8,"arabic":"ٱلدُّنْيَا","translation":"পার্থিব","audioUrl":"wbw/002_204_008.mp3","charTypeName":"word"},{"id":85453,"position":9,"arabic":"وَيُشْهِدُ","translation":"ও সে সাক্ষী রাখে","audioUrl":"wbw/002_204_009.mp3","charTypeName":"word"},{"id":85454,"position":10,"arabic":"ٱللَّهَ","translation":"আল্লাহকে","audioUrl":"wbw/002_204_010.mp3","charTypeName":"word"},{"id":85455,"position":11,"arabic":"عَلَىٰ","translation":"(এর) উপর","audioUrl":"wbw/002_204_011.mp3","charTypeName":"word"},{"id":85456,"position":12,"arabic":"مَا","translation":"যা","audioUrl":"wbw/002_204_012.mp3","charTypeName":"word"},{"id":85457,"position":13,"arabic":"فِى","translation":"মধ্যে(আছে)","audioUrl":"wbw/002_204_013.mp3","charTypeName":"word"},{"id":85458,"position":14,"arabic":"قَلْبِهِۦ","translation":"তার অন্তরের","audioUrl":"wbw/002_204_014.mp3","charTypeName":"word"},{"id":85459,"position":15,"arabic":"وَهُوَ","translation":"এবং সে","audioUrl":"wbw/002_204_015.mp3","charTypeName":"word"},{"id":85460,"position":16,"arabic":"أَلَدُّ","translation":"সাংঘাতিক","audioUrl":"wbw/002_204_016.mp3","charTypeName":"word"},{"id":85461,"position":17,"arabic":"ٱلْخِصَامِ","translation":"ঝগড়াটে","audioUrl":"wbw/002_204_017.mp3","charTypeName":"word"},{"id":85462,"position":18,"arabic":"٢٠٤","translation":"(২০৪)","audioUrl":null,"charTypeName":"end"}]},{"number":205,"arabic":"وَإِذَا تَوَلَّىٰ سَعَىٰ فِى ٱلْأَرْضِ لِيُفْسِدَ فِيهَا وَيُهْلِكَ ٱلْحَرْثَ وَٱلنَّسْلَ ۗ وَٱللَّهُ لَا يُحِبُّ ٱلْفَسَادَ","translation":"But whenever he prevails, he goes about the earth spreading corruption and destroying [man's] tilth and progeny: and God does not love corruption.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/212.mp3","surahId":2,"words":[{"id":85480,"position":1,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/002_205_001.mp3","charTypeName":"word"},{"id":85481,"position":2,"arabic":"تَوَلَّىٰ","translation":"সে কর্তৃত্ব পায়","audioUrl":"wbw/002_205_002.mp3","charTypeName":"word"},{"id":85482,"position":3,"arabic":"سَعَىٰ","translation":"সে চেষ্টা করে","audioUrl":"wbw/002_205_003.mp3","charTypeName":"word"},{"id":85483,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/002_205_004.mp3","charTypeName":"word"},{"id":85484,"position":5,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/002_205_005.mp3","charTypeName":"word"},{"id":85485,"position":6,"arabic":"لِيُفْسِدَ","translation":"বিপর্যয় সৃষ্টির জন্যে","audioUrl":"wbw/002_205_006.mp3","charTypeName":"word"},{"id":85486,"position":7,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/002_205_007.mp3","charTypeName":"word"},{"id":85487,"position":8,"arabic":"وَيُهْلِكَ","translation":"ও ধ্বংস করতে","audioUrl":"wbw/002_205_008.mp3","charTypeName":"word"},{"id":85488,"position":9,"arabic":"ٱلْحَرْثَ","translation":"শস্যক্ষেত","audioUrl":"wbw/002_205_009.mp3","charTypeName":"word"},{"id":85489,"position":10,"arabic":"وَٱلنَّسْلَ ۗ","translation":"ও জীব-জন্তুর বংশ","audioUrl":"wbw/002_205_010.mp3","charTypeName":"word"},{"id":85491,"position":11,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/002_205_012.mp3","charTypeName":"word"},{"id":85492,"position":12,"arabic":"لَا","translation":"না","audioUrl":"wbw/002_205_013.mp3","charTypeName":"word"},{"id":85493,"position":13,"arabic":"يُحِبُّ","translation":"পছন্দ করনে","audioUrl":"wbw/002_205_014.mp3","charTypeName":"word"},{"id":85494,"position":14,"arabic":"ٱلْفَسَادَ","translation":"বিপর্যয়","audioUrl":"wbw/002_205_015.mp3","charTypeName":"word"},{"id":85495,"position":15,"arabic":"٢٠٥","translation":"(২০৫)","audioUrl":null,"charTypeName":"end"}]},{"number":206,"arabic":"وَإِذَا قِيلَ لَهُ ٱتَّقِ ٱللَّهَ أَخَذَتْهُ ٱلْعِزَّةُ بِٱلْإِثْمِ ۚ فَحَسْبُهُۥ جَهَنَّمُ ۚ وَلَبِئْسَ ٱلْمِهَادُ","translation":"And whenever he is told, \"Be conscious of God,\" his false pride drives him into sin: wherefore hell will be his allotted portion-and how vile a resting-place!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/213.mp3","surahId":2,"words":[{"id":85519,"position":1,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/002_206_001.mp3","charTypeName":"word"},{"id":85520,"position":2,"arabic":"قِيلَ","translation":"বলা হয়","audioUrl":"wbw/002_206_002.mp3","charTypeName":"word"},{"id":85521,"position":3,"arabic":"لَهُ","translation":"তার উদ্দেশে","audioUrl":"wbw/002_206_003.mp3","charTypeName":"word"},{"id":85522,"position":4,"arabic":"ٱتَّقِ","translation":"ভয় করো","audioUrl":"wbw/002_206_004.mp3","charTypeName":"word"},{"id":85523,"position":5,"arabic":"ٱللَّهَ","translation":"আল্লাহকে","audioUrl":"wbw/002_206_005.mp3","charTypeName":"word"},{"id":85524,"position":6,"arabic":"أَخَذَتْهُ","translation":"তাকে ধরে","audioUrl":"wbw/002_206_006.mp3","charTypeName":"word"},{"id":85525,"position":7,"arabic":"ٱلْعِزَّةُ","translation":"(তার) মর্যাদা সম্মান","audioUrl":"wbw/002_206_007.mp3","charTypeName":"word"},{"id":85526,"position":8,"arabic":"بِٱلْإِثْمِ ۚ","translation":"পাপের (পথে)","audioUrl":"wbw/002_206_008.mp3","charTypeName":"word"},{"id":85528,"position":9,"arabic":"فَحَسْبُهُۥ","translation":"তার জন্যে তাই যথেষ্ট","audioUrl":"wbw/002_206_010.mp3","charTypeName":"word"},{"id":85529,"position":10,"arabic":"جَهَنَّمُ ۚ","translation":"জাহান্নাম","audioUrl":"wbw/002_206_011.mp3","charTypeName":"word"},{"id":85531,"position":11,"arabic":"وَلَبِئْسَ","translation":"এবং (তা) অবশ্যই অতি নিকৃষ্ট","audioUrl":"wbw/002_206_013.mp3","charTypeName":"word"},{"id":85532,"position":12,"arabic":"ٱلْمِهَادُ","translation":"আবাস","audioUrl":"wbw/002_206_014.mp3","charTypeName":"word"},{"id":85533,"position":13,"arabic":"٢٠٦","translation":"(২০৬)","audioUrl":null,"charTypeName":"end"}]},{"number":207,"arabic":"وَمِنَ ٱلنَّاسِ مَن يَشْرِى نَفْسَهُ ٱبْتِغَآءَ مَرْضَاتِ ٱللَّهِ ۗ وَٱللَّهُ رَءُوفٌۢ بِٱلْعِبَادِ","translation":"But there is [also] a kind of man who would willingly sell his own self in order to please God: and God is most compassionate towards His servants.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/214.mp3","surahId":2,"words":[{"id":85554,"position":1,"arabic":"وَمِنَ","translation":"এবং মধ্য হতে","audioUrl":"wbw/002_207_001.mp3","charTypeName":"word"},{"id":85555,"position":2,"arabic":"ٱلنَّاسِ","translation":"লোকদের (এমনও আছে)","audioUrl":"wbw/002_207_002.mp3","charTypeName":"word"},{"id":85556,"position":3,"arabic":"مَن","translation":"যে","audioUrl":"wbw/002_207_003.mp3","charTypeName":"word"},{"id":85557,"position":4,"arabic":"يَشْرِى","translation":"বিক্রি করে","audioUrl":"wbw/002_207_004.mp3","charTypeName":"word"},{"id":85558,"position":5,"arabic":"نَفْسَهُ","translation":"তার প্রাণ","audioUrl":"wbw/002_207_005.mp3","charTypeName":"word"},{"id":85559,"position":6,"arabic":"ٱبْتِغَآءَ","translation":"উদ্দেশ্যে","audioUrl":"wbw/002_207_006.mp3","charTypeName":"word"},{"id":85560,"position":7,"arabic":"مَرْضَاتِ","translation":"সন্তুষ্টির","audioUrl":"wbw/002_207_007.mp3","charTypeName":"word"},{"id":85561,"position":8,"arabic":"ٱللَّهِ ۗ","translation":"আল্লাহর","audioUrl":"wbw/002_207_008.mp3","charTypeName":"word"},{"id":85563,"position":9,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/002_207_010.mp3","charTypeName":"word"},{"id":85564,"position":10,"arabic":"رَءُوفٌۢ","translation":"খুব দয়ালু","audioUrl":"wbw/002_207_011.mp3","charTypeName":"word"},{"id":85565,"position":11,"arabic":"بِٱلْعِبَادِ","translation":"এ ধরনের দাসদের সাথে","audioUrl":"wbw/002_207_012.mp3","charTypeName":"word"},{"id":85566,"position":12,"arabic":"٢٠٧","translation":"(২০৭)","audioUrl":null,"charTypeName":"end"}]},{"number":208,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ ٱدْخُلُوا۟ فِى ٱلسِّلْمِ كَآفَّةًۭ وَلَا تَتَّبِعُوا۟ خُطُوَٰتِ ٱلشَّيْطَٰنِ ۚ إِنَّهُۥ لَكُمْ عَدُوٌّۭ مُّبِينٌۭ","translation":"O you who have attained to faith! Surrender yourselves wholly unto God, and follow not Satan's footsteps, for, verily, he is your open foe.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/215.mp3","surahId":2,"words":[{"id":85567,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"ওহে","audioUrl":"wbw/002_208_001.mp3","charTypeName":"word"},{"id":85568,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/002_208_002.mp3","charTypeName":"word"},{"id":85569,"position":3,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছো","audioUrl":"wbw/002_208_003.mp3","charTypeName":"word"},{"id":85570,"position":4,"arabic":"ٱدْخُلُوا۟","translation":"তোমরা প্রবেশ করো","audioUrl":"wbw/002_208_004.mp3","charTypeName":"word"},{"id":85571,"position