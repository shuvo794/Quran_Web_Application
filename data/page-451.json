{"id":451,"ayahs":[{"number":127,"arabic":"فَكَذَّبُوهُ فَإِنَّهُمْ لَمُحْضَرُونَ","translation":"But they gave him the lie: and therefore they will most surely be arraigned [on Judgment Day],","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3915.mp3","surahId":37,"words":[{"id":77515,"position":1,"arabic":"فَكَذَّبُوهُ","translation":"তাকে তারা তখন অমান্য করলো","audioUrl":"wbw/037_127_001.mp3","charTypeName":"word"},{"id":77516,"position":2,"arabic":"فَإِنَّهُمْ","translation":"নিশ্চয় তাই তাদের","audioUrl":"wbw/037_127_002.mp3","charTypeName":"word"},{"id":77517,"position":3,"arabic":"لَمُحْضَرُونَ","translation":"উপস্থিত করা হবে অবশ্যই (শাস্তির জন্যে)","audioUrl":"wbw/037_127_003.mp3","charTypeName":"word"},{"id":77518,"position":4,"arabic":"١٢٧","translation":"(১২৭)","audioUrl":null,"charTypeName":"end"}]},{"number":128,"arabic":"إِلَّا عِبَادَ ٱللَّهِ ٱلْمُخْلَصِينَ","translation":"excepting only [those who were] God’s true servants;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3916.mp3","surahId":37,"words":[{"id":77669,"position":1,"arabic":"إِلَّا","translation":"তবে (ব্যতিক্রম)","audioUrl":"wbw/037_128_001.mp3","charTypeName":"word"},{"id":77670,"position":2,"arabic":"عِبَادَ","translation":"দাসরা","audioUrl":"wbw/037_128_002.mp3","charTypeName":"word"},{"id":77671,"position":3,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/037_128_003.mp3","charTypeName":"word"},{"id":77672,"position":4,"arabic":"ٱلْمُخْلَصِينَ","translation":"(যারা) একনিষ্ঠ","audioUrl":"wbw/037_128_004.mp3","charTypeName":"word"},{"id":77673,"position":5,"arabic":"١٢٨","translation":"(১২৮)","audioUrl":null,"charTypeName":"end"}]},{"number":129,"arabic":"وَتَرَكْنَا عَلَيْهِ فِى ٱلْءَاخِرِينَ","translation":"and him We left thus to be remem­bered among later generations:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3917.mp3","surahId":37,"words":[{"id":77903,"position":1,"arabic":"وَتَرَكْنَا","translation":"এবং আমরা রেখেছি","audioUrl":"wbw/037_129_001.mp3","charTypeName":"word"},{"id":77904,"position":2,"arabic":"عَلَيْهِ","translation":"তার সমন্ধে","audioUrl":"wbw/037_129_002.mp3","charTypeName":"word"},{"id":77905,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/037_129_003.mp3","charTypeName":"word"},{"id":77906,"position":4,"arabic":"ٱلْـَٔاخِرِينَ","translation":"পরবর্তীদের (উত্তম স্মরণ)","audioUrl":"wbw/037_129_004.mp3","charTypeName":"word"},{"id":77907,"position":5,"arabic":"١٢٩","translation":"(১২৯)","audioUrl":null,"charTypeName":"end"}]},{"number":130,"arabic":"سَلَٰمٌ عَلَىٰٓ إِلْ يَاسِينَ","translation":"“Peace be upon Elijah and his followers!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3918.mp3","surahId":37,"words":[{"id":77952,"position":1,"arabic":"سَلَـٰمٌ","translation":"\"সালাম (বর্ষিত হোক)","audioUrl":"wbw/037_130_001.mp3","charTypeName":"word"},{"id":77953,"position":2,"arabic":"عَلَىٰٓ","translation":"উপর","audioUrl":"wbw/037_130_002.mp3","charTypeName":"word"},{"id":77954,"position":3,"arabic":"إِلْ يَاسِينَ","translation":"ইলিয়াসের\"","audioUrl":"wbw/037_130_003.mp3","charTypeName":"word"},{"id":77956,"position":4,"arabic":"١٣٠","translation":"(১৩০)","audioUrl":null,"charTypeName":"end"}]},{"number":131,"arabic":"إِنَّا كَذَٰلِكَ نَجْزِى ٱلْمُحْسِنِينَ","translation":"Verily, thus do We reward the doers of good –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3919.mp3","surahId":37,"words":[{"id":78029,"position":1,"arabic":"إِنَّا","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/037_131_001.mp3","charTypeName":"word"},{"id":78030,"position":2,"arabic":"كَذَٰلِكَ","translation":"এরূপে","audioUrl":"wbw/037_131_002.mp3","charTypeName":"word"},{"id":78031,"position":3,"arabic":"نَجْزِى","translation":"প্রতিফল দিই আমরা","audioUrl":"wbw/037_131_003.mp3","charTypeName":"word"},{"id":78032,"position":4,"arabic":"ٱلْمُحْسِنِينَ","translation":"সৎকর্মশীলদের","audioUrl":"wbw/037_131_004.mp3","charTypeName":"word"},{"id":78033,"position":5,"arabic":"١٣١","translation":"(১৩১)","audioUrl":null,"charTypeName":"end"}]},{"number":132,"arabic":"إِنَّهُۥ مِنْ عِبَادِنَا ٱلْمُؤْمِنِينَ","translation":"for he was truly one of Our believing servants!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3920.mp3","surahId":37,"words":[{"id":78164,"position":1,"arabic":"إِنَّهُۥ","translation":"সে নিশ্চয়ই","audioUrl":"wbw/037_132_001.mp3","charTypeName":"word"},{"id":78165,"position":2,"arabic":"مِنْ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/037_132_002.mp3","charTypeName":"word"},{"id":78166,"position":3,"arabic":"عِبَادِنَا","translation":"আমাদের দাসদের","audioUrl":"wbw/037_132_003.mp3","charTypeName":"word"},{"id":78167,"position":4,"arabic":"ٱلْمُؤْمِنِينَ","translation":"(যারা) মু'মিন","audioUrl":"wbw/037_132_004.mp3","charTypeName":"word"},{"id":78168,"position":5,"arabic":"١٣٢","translation":"(১৩২)","audioUrl":null,"charTypeName":"end"}]},{"number":133,"arabic":"وَإِنَّ لُوطًۭا لَّمِنَ ٱلْمُرْسَلِينَ","translation":"AND, BEHOLD, Lot was indeed one of Our mes­sage-bearers;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3921.mp3","surahId":37,"words":[{"id":78233,"position":1,"arabic":"وَإِنَّ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/037_133_001.mp3","charTypeName":"word"},{"id":78234,"position":2,"arabic":"لُوطًۭا","translation":"লুতও (ছিলো)","audioUrl":"wbw/037_133_002.mp3","charTypeName":"word"},{"id":78235,"position":3,"arabic":"لَّمِنَ","translation":"অন্যতম অবশ্যই","audioUrl":"wbw/037_133_003.mp3","charTypeName":"word"},{"id":78236,"position":4,"arabic":"ٱلْمُرْسَلِينَ","translation":"রাসূলদের","audioUrl":"wbw/037_133_004.mp3","charTypeName":"word"},{"id":78237,"position":5,"arabic":"١٣٣","translation":"(১৩৩)","audioUrl":null,"charTypeName":"end"}]},{"number":134,"arabic":"إِذْ نَجَّيْنَٰهُ وَأَهْلَهُۥٓ أَجْمَعِينَ","translation":"[and so,] when [We decreed the doom of his sinful town,] We saved him and his household,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3922.mp3","surahId":37,"words":[{"id":78355,"position":1,"arabic":"إِذْ","translation":"(স্মরণ করো) যখন","audioUrl":"wbw/037_134_001.mp3","charTypeName":"word"},{"id":78356,"position":2,"arabic":"نَجَّيْنَـٰهُ","translation":"তাকে আমরা উদ্ধার করেছিলাম","audioUrl":"wbw/037_134_002.mp3","charTypeName":"word"},{"id":78357,"position":3,"arabic":"وَأَهْلَهُۥٓ","translation":"এবং তারা পরিবারের","audioUrl":"wbw/037_134_003.mp3","charTypeName":"word"},{"id":78358,"position":4,"arabic":"أَجْمَعِينَ","translation":"সকলকে","audioUrl":"wbw/037_134_004.mp3","charTypeName":"word"},{"id":78359,"position":5,"arabic":"١٣٤","translation":"(১৩৪)","audioUrl":null,"charTypeName":"end"}]},{"number":135,"arabic":"إِلَّا عَجُوزًۭا فِى ٱلْغَٰبِرِينَ","translation":"except an old woman who was among those that stayed behind;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3923.mp3","surahId":37,"words":[{"id":78543,"position":1,"arabic":"إِلَّا","translation":"ব্যতীত","audioUrl":"wbw/037_135_001.mp3","charTypeName":"word"},{"id":78544,"position":2,"arabic":"عَجُوزًۭا","translation":"এক বৃদ্ধাকে (অর্থাৎ তার স্ত্রীকে)","audioUrl":"wbw/037_135_002.mp3","charTypeName":"word"},{"id":78545,"position":3,"arabic":"فِى","translation":"(সে ছিলো) অন্তর্ভুক্ত","audioUrl":"wbw/037_135_003.mp3","charTypeName":"word"},{"id":78546,"position":4,"arabic":"ٱلْغَـٰبِرِينَ","translation":"পিছনে অবস্থানকারীদের","audioUrl":"wbw/037_135_004.mp3","charTypeName":"word"},{"id":78547,"position":5,"arabic":"١٣٥","translation":"(১৩৫)","audioUrl":null,"charTypeName":"end"}]},{"number":136,"arabic":"ثُمَّ دَمَّرْنَا ٱلْءَاخَرِينَ","translation":"and then We utterly destroyed the others:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3924.mp3","surahId":37,"words":[{"id":78689,"position":1,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/037_136_001.mp3","charTypeName":"word"},{"id":78690,"position":2,"arabic":"دَمَّرْنَا","translation":"আমরা ধ্বংস করেছিলাম","audioUrl":"wbw/037_136_002.mp3","charTypeName":"word"},{"id":78691,"position":3,"arabic":"ٱلْـَٔاخَرِينَ","translation":"বাকিদেরকে","audioUrl":"wbw/037_136_003.mp3","charTypeName":"word"},{"id":78692,"position":4,"arabic":"١٣٦","translation":"(১৩৬)","audioUrl":null,"charTypeName":"end"}]},{"number":137,"arabic":"وَإِنَّكُمْ لَتَمُرُّونَ عَلَيْهِم مُّصْبِحِينَ","translation":"and, verily, [to this day] you pass by the remnants of their dwellings at morning-time","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3925.mp3","surahId":37,"words":[{"id":78799,"position":1,"arabic":"وَإِنَّكُمْ","translation":"এবং নিশ্চয়ই তোমরা","audioUrl":"wbw/037_137_001.mp3","charTypeName":"word"},{"id":78800,"position":2,"arabic":"لَتَمُرُّونَ","translation":"অবশ্যই আসা-যাওয়া করে থাকো","audioUrl":"wbw/037_137_002.mp3","charTypeName":"word"},{"id":78801,"position":3,"arabic":"عَلَيْهِم","translation":"তাদের (ধ্বংসপ্রাপ্ত এলাকার) উপর দিয়ে","audioUrl":"wbw/037_137_003.mp3","charTypeName":"word"},{"id":78802,"position":4,"arabic":"مُّصْبِحِينَ","translation":"সকালে","audioUrl":"wbw/037_137_004.mp3","charTypeName":"word"},{"id":78803,"position":5,"arabic":"١٣٧","translation":"(১৩৭)","audioUrl":null,"charTypeName":"end"}]},{"number":138,"arabic":"وَبِٱلَّيْلِ ۗ أَفَلَا تَعْقِلُونَ","translation":"and by night. Will you not, then, use your reason?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3926.mp3","surahId":37,"words":[{"id":78920,"position":1,"arabic":"وَبِٱلَّيْلِ ۗ","translation":"ও সন্ধ্যায়","audioUrl":"wbw/037_138_001.mp3","charTypeName":"word"},{"id":78922,"position":2,"arabic":"أَفَلَا","translation":"তবুও কিনা","audioUrl":"wbw/037_138_003.mp3","charTypeName":"word"},{"id":78923,"position":3,"arabic":"تَعْقِلُونَ","translation":"তোমরা জ্ঞান কাজে লাগাও","audioUrl":"wbw/037_138_004.mp3","charTypeName":"word"},{"id":78924,"position":4,"arabic":"١٣٨","translation":"(১৩৮)","audioUrl":null,"charTypeName":"end"}]},{"number":139,"arabic":"وَإِنَّ يُونُسَ لَمِنَ ٱلْمُرْسَلِينَ","translation":"AND, BEHOLD, Jonah was indeed one of Our mes­sage-bearers","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3927.mp3","surahId":37,"words":[{"id":79018,"position":1,"arabic":"وَإِنَّ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/037_139_001.mp3","charTypeName":"word"},{"id":79019,"position":2,"arabic":"يُونُسَ","translation":"ইউনূসও (ছিলো)","audioUrl":"wbw/037_139_002.mp3","charTypeName":"word"},{"id":79020,"position":3,"arabic":"لَمِنَ","translation":"অবশ্যই অন্যতম","audioUrl":"wbw/037_139_003.mp3","charTypeName":"word"},{"id":79021,"position":4,"arabic":"ٱلْمُرْسَلِينَ","translation":"রাসূলদের","audioUrl":"wbw/037_139_004.mp3","charTypeName":"word"},{"id":79022,"position":5,"arabic":"١٣٩","translation":"(১৩৯)","audioUrl":null,"charTypeName":"end"}]},{"number":140,"arabic":"إِذْ أَبَقَ إِلَى ٱلْفُلْكِ ٱلْمَشْحُونِ","translation":"when he fled like a runaway slave onto a laden ship.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3928.mp3","surahId":37,"words":[{"id":79088,"position":1,"arabic":"إِذْ","translation":"(স্মরণ করো) যখন","audioUrl":"wbw/037_140_001.mp3","charTypeName":"word"},{"id":79089,"position":2,"arabic":"أَبَقَ","translation":"সে পালিয়েছিলো","audioUrl":"wbw/037_140_002.mp3","charTypeName":"word"},{"id":79090,"position":3,"arabic":"إِلَى","translation":"দিকে","audioUrl":"wbw/037_140_003.mp3","charTypeName":"word"},{"id":79091,"position":4,"arabic":"ٱلْفُلْكِ","translation":"নৌকার","audioUrl":"wbw/037_140_004.mp3","charTypeName":"word"},{"id":79092,"position":5,"arabic":"ٱلْمَشْحُونِ","translation":"বোঝাই","audioUrl":"wbw/037_140_005.mp3","charTypeName":"word"},{"id":79093,"position":6,"arabic":"١٤٠","translation":"(১৪০)","audioUrl":null,"charTypeName":"end"}]},{"number":141,"arabic":"فَسَاهَمَ فَكَانَ مِنَ ٱلْمُدْحَضِينَ","translation":"And then they cast lots, and he was the one who lost;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3929.mp3","surahId":37,"words":[{"id":79193,"position":1,"arabic":"فَسَاهَمَ","translation":"অতঃপর সে লটারীতে অংশ নিলো","audioUrl":"wbw/037_141_001.mp3","charTypeName":"word"},{"id":79194,"position":2,"arabic":"فَكَانَ","translation":"তখন সে হলো","audioUrl":"wbw/037_141_002.mp3","charTypeName":"word"},{"id":79195,"position":3,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/037_141_003.mp3","charTypeName":"word"},{"id":79196,"position":4,"arabic":"ٱلْمُدْحَضِينَ","translation":"পরাস্তদের (আর পানিতে নিক্ষিপ্ত হলো)","audioUrl":"wbw/037_141_004.mp3","charTypeName":"word"},{"id":79197,"position":5,"arabic":"١٤١","translation":"(১৪১)","audioUrl":null,"charTypeName":"end"}]},{"number":142,"arabic":"فَٱلْتَقَمَهُ ٱلْحُوتُ وَهُوَ مُلِيمٌۭ","translation":"[and they cast him into the sea,] whereupon the great fish swallowed him, for he had been blameworthy.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3930.mp3","surahId":37,"words":[{"id":79431,"position":1,"arabic":"فَٱلْتَقَمَهُ","translation":"তাকে অতঃপর গিলে ফেললো","audioUrl":"wbw/037_142_001.mp3","charTypeName":"word"},{"id":79432,"position":2,"arabic":"ٱلْحُوتُ","translation":"মাছ","audioUrl":"wbw/037_142_002.mp3","charTypeName":"word"},{"id":79433,"position":3,"arabic":"وَهُوَ","translation":"এবং সে","audioUrl":"wbw/037_142_003.mp3","charTypeName":"word"},{"id":79434,"position":4,"arabic":"مُلِيمٌۭ","translation":"নিজেকে ধিক্কারকারী হলো","audioUrl":"wbw/037_142_004.mp3","charTypeName":"word"},{"id":79435,"position":5,"arabic":"١٤٢","translation":"(১৪২)","audioUrl":null,"charTypeName":"end"}]},{"number":143,"arabic":"فَلَوْلَآ أَنَّهُۥ كَانَ مِنَ ٱلْمُسَبِّحِينَ","translation":"And had he not been of those who [even in the deep darkness of their distress are able to] extol God’s limitless glory,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3931.mp3","surahId":37,"words":[{"id":79509,"position":1,"arabic":"فَلَوْلَآ","translation":"তখন যদি না","audioUrl":"wbw/037_143_001.mp3","charTypeName":"word"},{"id":79510,"position":2,"arabic":"أَنَّهُۥ","translation":"সে","audioUrl":"wbw/037_143_002.mp3","charTypeName":"word"},{"id":79511,"position":3,"arabic":"كَانَ","translation":"হতো","audioUrl":"wbw/037_143_003.mp3","charTypeName":"word"},{"id":79512,"position":4,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/037_143_004.mp3","charTypeName":"word"},{"id":79513,"position":5,"arabic":"ٱلْمُسَبِّحِينَ","translation":"মহিমা ঘোষণাকারীদের","audioUrl":"wbw/037_143_005.mp3","charTypeName":"word"},{"id":79514,"position":6,"arabic":"١٤٣","translation":"(১৪৩)","audioUrl":null,"charTypeName":"end"}]},{"number":144,"arabic":"لَلَبِثَ فِى بَطْنِهِۦٓ إِلَىٰ يَوْمِ يُبْعَثُونَ","translation":"he would indeed have remained in its belly till the Day when all shall be raised from the dead:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3932.mp3","surahId":37,"words":[{"id":79695,"position":1,"arabic":"لَلَبِثَ","translation":"অবশ্যই সে থাকতো","audioUrl":"wbw/037_144_001.mp3","charTypeName":"word"},{"id":79696,"position":2,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/037_144_002.mp3","charTypeName":"word"},{"id":79697,"position":3,"arabic":"بَطْنِهِۦٓ","translation":"তার পেটের","audioUrl":"wbw/037_144_003.mp3","charTypeName":"word"},{"id":79698,"position":4,"arabic":"إِلَىٰ","translation":"পর্যন্ত","audioUrl":"wbw/037_144_004.mp3","charTypeName":"word"},{"id":79699,"position":5,"arabic":"يَوْمِ","translation":"দিন","audioUrl":"wbw/037_144_005.mp3","charTypeName":"word"},{"id":79700,"position":6,"arabic":"يُبْعَثُونَ","translation":"উত্থানের","audioUrl":"wbw/037_144_006.mp3","charTypeName":"word"},{"id":79701,"position":7,"arabic":"١٤٤","translation":"(১৪৪)","audioUrl":null,"charTypeName":"end"}]},{"number":145,"arabic":"۞ فَنَبَذْنَٰهُ بِٱلْعَرَآءِ وَهُوَ سَقِيمٌۭ","translation":"but We caused him to be cast forth on a desert shore, sick [at heart] as he was,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3933.mp3","surahId":37,"words":[{"id":79762,"position":1,"arabic":"۞ فَنَبَذْنَـٰهُ","translation":"তাকে আমরা এরপর নিক্ষেপ করলাম","audioUrl":"wbw/037_145_002.mp3","charTypeName":"word"},{"id":79763,"position":2,"arabic":"بِٱلْعَرَآءِ","translation":"তৃণহীন প্রান্তরে","audioUrl":"wbw/037_145_003.mp3","charTypeName":"word"},{"id":79764,"position":3,"arabic":"وَهُوَ","translation":"এমনাবস্হায় যে সে","audioUrl":"wbw/037_145_004.mp3","charTypeName":"word"},{"id":79765,"position":4,"arabic":"سَقِيمٌۭ","translation":"(ছিলো) অসুস্থ","audioUrl":"wbw/037_145_005.mp3","charTypeName":"word"},{"id":79766,"position":5,"arabic":"١٤٥","translation":"(১৪৫)","audioUrl":null,"charTypeName":"end"}]},{"number":146,"arabic":"وَأَنۢبَتْنَا عَلَيْهِ شَجَرَةًۭ مِّن يَقْطِينٍۢ","translation":"and caused a creeping plant to grow over him [out of the barren soil].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3934.mp3","surahId":37,"words":[{"id":79925,"position":1,"arabic":"وَأَنۢبَتْنَا","translation":"এবং আমরা উৎপন্ন করলাম","audioUrl":"wbw/037_146_001.mp3","charTypeName":"word"},{"id":79926,"position":2,"arabic":"عَلَيْهِ","translation":"তার জন্যে","audioUrl":"wbw/037_146_002.mp3","charTypeName":"word"},{"id":79927,"position":3,"arabic":"شَجَرَةًۭ","translation":"গাছ","audioUrl":"wbw/037_146_003.mp3","charTypeName":"word"},{"id":79928,"position":4,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/037_146_004.mp3","charTypeName":"word"},{"id":79929,"position":5,"arabic":"يَقْطِينٍۢ","translation":"লাউগাছ","audioUrl":"wbw/037_146_005.mp3","charTypeName":"word"},{"id":79930,"position":6,"arabic":"١٤٦","translation":"(১৪৬)","audioUrl":null,"charTypeName":"end"}]},{"number":147,"arabic":"وَأَرْسَلْنَٰهُ إِلَىٰ مِا۟ئَةِ أَلْفٍ أَوْ يَزِيدُونَ","translation":"And [then] We sent him [once again] to [his people,] a hundred thousand [souls] or more:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3935.mp3","surahId":37,"words":[{"id":80135,"position":1,"a