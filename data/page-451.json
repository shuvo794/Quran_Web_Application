uld have [only] sons?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3937.mp3","surahId":37,"words":[{"id":80312,"position":1,"arabic":"فَٱسْتَفْتِهِمْ","translation":"তাদেরকে অতঃপর জিজ্ঞাসা করো","audioUrl":"wbw/037_149_001.mp3","charTypeName":"word"},{"id":80313,"position":2,"arabic":"أَلِرَبِّكَ","translation":"\"তোমার রবের জন্যে কি","audioUrl":"wbw/037_149_002.mp3","charTypeName":"word"},{"id":80314,"position":3,"arabic":"ٱلْبَنَاتُ","translation":"কন্যাসমূহ (আছে)","audioUrl":"wbw/037_149_003.mp3","charTypeName":"word"},{"id":80315,"position":4,"arabic":"وَلَهُمُ","translation":"এবং তাদের জন্যে (আছে)","audioUrl":"wbw/037_149_004.mp3","charTypeName":"word"},{"id":80316,"position":5,"arabic":"ٱلْبَنُونَ","translation":"পুত্রসমূহ\"","audioUrl":"wbw/037_149_005.mp3","charTypeName":"word"},{"id":80317,"position":6,"arabic":"١٤٩","translation":"(১৪৯)","audioUrl":null,"charTypeName":"end"}]},{"number":150,"arabic":"أَمْ خَلَقْنَا ٱلْمَلَٰٓئِكَةَ إِنَٰثًۭا وَهُمْ شَٰهِدُونَ","translation":"- or is it that We have created the angels female, and they [who believe them to be divine] have witnessed [that act of creation]?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3938.mp3","surahId":37,"words":[{"id":80419,"position":1,"arabic":"أَمْ","translation":"অথবা","audioUrl":"wbw/037_150_001.mp3","charTypeName":"word"},{"id":80420,"position":2,"arabic":"خَلَقْنَا","translation":"আমরা সৃষ্টি করেছি","audioUrl":"wbw/037_150_002.mp3","charTypeName":"word"},{"id":80421,"position":3,"arabic":"ٱلْمَلَـٰٓئِكَةَ","translation":"ফেরেশতাদেরকে","audioUrl":"wbw/037_150_003.mp3","charTypeName":"word"},{"id":80422,"position":4,"arabic":"إِنَـٰثًۭا","translation":"নারীরূপে","audioUrl":"wbw/037_150_004.mp3","charTypeName":"word"},{"id":80423,"position":5,"arabic":"وَهُمْ","translation":"আর তারা","audioUrl":"wbw/037_150_005.mp3","charTypeName":"word"},{"id":80424,"position":6,"arabic":"شَـٰهِدُونَ","translation":"দেখেছে","audioUrl":"wbw/037_150_006.mp3","charTypeName":"word"},{"id":80425,"position":7,"arabic":"١٥٠","translation":"(১৫০)","audioUrl":null,"charTypeName":"end"}]},{"number":151,"arabic":"أَلَآ إِنَّهُم مِّنْ إِفْكِهِمْ لَيَقُولُونَ","translation":"Oh, verily, it is out of their own [inclination to] falsehood that some people assert,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3939.mp3","surahId":37,"words":[{"id":80507,"position":1,"arabic":"أَلَآ","translation":"সাবধান","audioUrl":"wbw/037_151_001.mp3","charTypeName":"word"},{"id":80508,"position":2,"arabic":"إِنَّهُم","translation":"তারা নিশ্চয়ই","audioUrl":"wbw/037_151_002.mp3","charTypeName":"word"},{"id":80509,"position":3,"arabic":"مِّنْ","translation":"হ'তে","audioUrl":"wbw/037_151_003.mp3","charTypeName":"word"},{"id":80510,"position":4,"arabic":"إِفْكِهِمْ","translation":"তাদের মনগড়া কথা","audioUrl":"wbw/037_151_004.mp3","charTypeName":"word"},{"id":80511,"position":5,"arabic":"لَيَقُولُونَ","translation":"বলছে অবশ্যই (যে)","audioUrl":"wbw/037_151_005.mp3","charTypeName":"word"},{"id":80512,"position":6,"arabic":"١٥١","translation":"(১৫১)","audioUrl":null,"charTypeName":"end"}]},{"number":152,"arabic":"وَلَدَ ٱللَّهُ وَإِنَّهُمْ لَكَٰذِبُونَ","translation":"“God has begotten [a son]”; and, verily, they are lying [too, when they say],","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3940.mp3","surahId":37,"words":[{"id":80658,"position":1,"arabic":"وَلَدَ","translation":"\"সন্তান জন্ম দিয়েছেন\"","audioUrl":"wbw/037_152_001.mp3","charTypeName":"word"},{"id":80659,"position":2,"arabic":"ٱللَّهُ","translation":"\"আল্লাহ\"","audioUrl":"wbw/037_152_002.mp3","charTypeName":"word"},{"id":80660,"position":3,"arabic":"وَإِنَّهُمْ","translation":"এবং তারা নিশ্চয়ই","audioUrl":"wbw/037_152_003.mp3","charTypeName":"word"},{"id":80661,"position":4,"arabic":"لَكَـٰذِبُونَ","translation":"মিথ্যাবাদী অবশ্যই","audioUrl":"wbw/037_152_004.mp3","charTypeName":"word"},{"id":80662,"position":5,"arabic":"١٥٢","translation":"(১৫২)","audi