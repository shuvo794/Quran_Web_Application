:31503,"position":18,"arabic":"أُرِيكُمْ","translation":"তোমাদেরকে মতামত দিচ্ছি","audioUrl":"wbw/040_029_019.mp3","charTypeName":"word"},{"id":31504,"position":19,"arabic":"إِلَّا","translation":"এ ব্যতীত","audioUrl":"wbw/040_029_020.mp3","charTypeName":"word"},{"id":31505,"position":20,"arabic":"مَآ","translation":"যা","audioUrl":"wbw/040_029_021.mp3","charTypeName":"word"},{"id":31506,"position":21,"arabic":"أَرَىٰ","translation":"আমি ভালো মনে করি","audioUrl":"wbw/040_029_022.mp3","charTypeName":"word"},{"id":31507,"position":22,"arabic":"وَمَآ","translation":"আর না","audioUrl":"wbw/040_029_023.mp3","charTypeName":"word"},{"id":31508,"position":23,"arabic":"أَهْدِيكُمْ","translation":"তোমাদেরকে আমি পরিচালনা করছি","audioUrl":"wbw/040_029_024.mp3","charTypeName":"word"},{"id":31509,"position":24,"arabic":"إِلَّا","translation":"এ ব্যতীত","audioUrl":"wbw/040_029_025.mp3","charTypeName":"word"},{"id":31510,"position":25,"arabic":"سَبِيلَ","translation":"পথে","audioUrl":"wbw/040_029_026.mp3","charTypeName":"word"},{"id":31511,"position":26,"arabic":"ٱلرَّشَادِ","translation":"সঠিক\"","audioUrl":"wbw/040_029_027.mp3","charTypeName":"word"},{"id":31512,"position":27,"arabic":"٢٩","translation":"(২৯)","audioUrl":null,"charTypeName":"end"}]},{"number":30,"arabic":"وَقَالَ ٱلَّذِىٓ ءَامَنَ يَٰقَوْمِ إِنِّىٓ أَخَافُ عَلَيْكُم مِّثْلَ يَوْمِ ٱلْأَحْزَابِ","translation":"Thereupon exclaimed he who had attained to faith: “O my people! Verily, I fear for you the like of what one day befell those others who were leagued together [against God’s truth] –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4163.mp3","surahId":40,"words":[{"id":32430,"position":1,"arabic":"وَقَالَ","translation":"এবং বললো","audioUrl":"wbw/040_030_001.mp3","charTypeName":"word"},{"id":32431,"position":2,"arabic":"ٱلَّذِىٓ","translation":"যে","audioUrl":"wbw/040_030_002.mp3","charTypeName":"word"},{"id":32432,"position":3,"arabic":"ءَامَنَ","translation":"ঈমান এনেছিলো","audioUrl":"wbw/04