{"id":470,"ayahs":[{"number":26,"arabic":"وَقَالَ فِرْعَوْنُ ذَرُونِىٓ أَقْتُلْ مُوسَىٰ وَلْيَدْعُ رَبَّهُۥٓ ۖ إِنِّىٓ أَخَافُ أَن يُبَدِّلَ دِينَكُمْ أَوْ أَن يُظْهِرَ فِى ٱلْأَرْضِ ٱلْفَسَادَ","translation":"And Pharaoh said: “Leave it to me to slay Moses - and let him invoke his [alleged] sustainer! Behold, I fear lest he cause you to change your religion, or lest he cause corruption to prevail in the land!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4159.mp3","surahId":40,"words":[{"id":28538,"position":1,"arabic":"وَقَالَ","translation":"এবং বললো","audioUrl":"wbw/040_026_001.mp3","charTypeName":"word"},{"id":28539,"position":2,"arabic":"فِرْعَوْنُ","translation":"ফিরআউন","audioUrl":"wbw/040_026_002.mp3","charTypeName":"word"},{"id":28540,"position":3,"arabic":"ذَرُونِىٓ","translation":"\"আমাকে ছাড়ো","audioUrl":"wbw/040_026_003.mp3","charTypeName":"word"},{"id":28541,"position":4,"arabic":"أَقْتُلْ","translation":"আমি হত্যা করে ফেলি","audioUrl":"wbw/040_026_004.mp3","charTypeName":"word"},{"id":28542,"position":5,"arabic":"مُوسَىٰ","translation":"মূসাকে","audioUrl":"wbw/040_026_005.mp3","charTypeName":"word"},{"id":28543,"position":6,"arabic":"وَلْيَدْعُ","translation":"এবং সে ডাকে যেন","audioUrl":"wbw/040_026_006.mp3","charTypeName":"word"},{"id":28544,"position":7,"arabic":"رَبَّهُۥٓ ۖ","translation":"তাঁর রবকে","audioUrl":"wbw/040_026_007.mp3","charTypeName":"word"},{"id":28546,"position":8,"arabic":"إِنِّىٓ","translation":"নিশ্চয়ই আমি","audioUrl":"wbw/040_026_009.mp3","charTypeName":"word"},{"id":28547,"position":9,"arabic":"أَخَافُ","translation":"আমি আশংকা করি","audioUrl":"wbw/040_026_010.mp3","charTypeName":"word"},{"id":28548,"position":10,"arabic":"أَن","translation":"যে","audioUrl":"wbw/040_026_011.mp3","charTypeName":"word"},{"id":28549,"position":11,"arabic":"يُبَدِّلَ","translation":"সে পাল্টে দিবে","audioUrl":"wbw/040_026_012.mp3","charTypeName":"word"},{"id":28550,"position":12,"arabic":"دِينَكُمْ","translation":"তোমাদের ধর্মকে","audioUrl":"wbw/040_026_013.mp3","charTypeName":"word"},{"id":28551,"position":13,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/040_026_014.mp3","charTypeName":"word"},{"id":28552,"position":14,"arabic":"أَن","translation":"যে","audioUrl":"wbw/040_026_015.mp3","charTypeName":"word"},{"id":28553,"position":15,"arabic":"يُظْهِرَ","translation":"সৃষ্টি করবে","audioUrl":"wbw/040_026_016.mp3","charTypeName":"word"},{"id":28554,"position":16,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/040_026_017.mp3","charTypeName":"word"},{"id":28555,"position":17,"arabic":"ٱلْأَرْضِ","translation":"দেশের","audioUrl":"wbw/040_026_018.mp3","charTypeName":"word"},{"id":28556,"position":18,"arabic":"ٱلْفَسَادَ","translation":"বিপর্যয়\"","audioUrl":"wbw/040_026_019.mp3","charTypeName":"word"},{"id":28557,"position":19,"arabic":"٢٦","translation":"(২৬)","audioUrl":null,"charTypeName":"end"}]},{"number":27,"arabic":"وَقَالَ مُوسَىٰٓ إِنِّى عُذْتُ بِرَبِّى وَرَبِّكُم مِّن كُلِّ مُتَكَبِّرٍۢ لَّا يُؤْمِنُ بِيَوْمِ ٱلْحِسَابِ","translation":"But Moses said: “With [Him who is] my Sus­tainer as well as your Sustainer have I indeed found refuge from everyone who, immersed in false pride, will not believe in [the coming of] the Day of Reckon­ing!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4160.mp3","surahId":40,"words":[{"id":29483,"position":1,"arabic":"وَقَالَ","translation":"এবং বললো","audioUrl":"wbw/040_027_001.mp3","charTypeName":"word"},{"id":29484,"position":2,"arabic":"مُوسَىٰٓ","translation":"মূসা","audioUrl":"wbw/040_027_002.mp3","charTypeName":"word"},{"id":29485,"position":3,"arabic":"إِنِّى","translation":"\"নিশ্চয়ই আমি","audioUrl":"wbw/040_027_003.mp3","charTypeName":"word"},{"id":29486,"position":4,"arabic":"عُذْتُ","translation":"আমি আশ্রয় চাই","audioUrl":"wbw/040_027_004.mp3","charTypeName":"word"},{"id":29487,"position":5,"arabic":"بِرَبِّى","translation":"আমার রবের কাছে","audioUrl":"wbw/040_027_005.mp3","charTypeName":"word"},{"id":29488,"position":6,"arabic":"وَرَبِّكُم","translation":"ও তোমাদের রবের (কাছে)","audioUrl":"wbw/040_027_006.mp3","charTypeName":"word"},{"id":29489,"position":7,"arabic":"مِّن","translation":"হ'তে","audioUrl":"wbw/040_027_007.mp3","charTypeName":"word"},{"id":29490,"position":8,"arabic":"كُلِّ","translation":"প্রত্যেক","audioUrl":"wbw/040_027_008.mp3","charTypeName":"word"},{"id":29491,"position":9,"arabic":"مُتَكَبِّرٍۢ","translation":"অহংকারী ব্যক্তি","audioUrl":"wbw/040_027_009.mp3","charTypeName":"word"},{"id":29492,"position":10,"arabic":"لَّا","translation":"(যে) না","audioUrl":"wbw/040_027_010.mp3","charTypeName":"word"},{"id":29493,"position":11,"arabic":"يُؤْمِنُ","translation":"বিশ্বাস করে","audioUrl":"wbw/040_027_011.mp3","charTypeName":"word"},{"id":29494,"position":12,"arabic":"بِيَوْمِ","translation":"দিনের প্রতি","audioUrl":"wbw/040_027_012.mp3","charTypeName":"word"},{"id":29495,"position":13,"arabic":"ٱلْحِسَابِ","translation":"বিচারের\"","audioUrl":"wbw/040_027_013.mp3","charTypeName":"word"},{"id":29496,"position":14,"arabic":"٢٧","translation":"(২৭)","audioUrl":null,"charTypeName":"end"}]},{"number":28,"arabic":"وَقَالَ رَجُلٌۭ مُّؤْمِنٌۭ مِّنْ ءَالِ فِرْعَوْنَ يَكْتُمُ إِيمَٰنَهُۥٓ أَتَقْتُلُونَ رَجُلًا أَن يَقُولَ رَبِّىَ ٱللَّهُ وَقَدْ جَآءَكُم بِٱلْبَيِّنَٰتِ مِن رَّبِّكُمْ ۖ وَإِن يَكُ كَٰذِبًۭا فَعَلَيْهِ كَذِبُهُۥ ۖ وَإِن يَكُ صَادِقًۭا يُصِبْكُم بَعْضُ ٱلَّذِى يَعِدُكُمْ ۖ إِنَّ ٱللَّهَ لَا يَهْدِى مَنْ هُوَ مُسْرِفٌۭ كَذَّابٌۭ","translation":"At that, a believing man of Pharaoh’s family, who [until then] had concealed his faith, exclaimed: “Would you slay a man because he says, ‘God is my Sustainer’ - seeing, withal, that he has brought you all evidence of this truth from your Sustainer? Now if he be a liar, his lie will fall back on him; but if he is a man of truth, something [of the punishment] whereof he warns you is bound to befall you: for, verily, God would not grace with His guidance one who has wasted his own self by lying [about Him].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4161.mp3","surahId":40,"words":[{"id":30484,"position":1,"arabic":"وَقَالَ","translation":"এবং বললো","audioUrl":"wbw/040_028_001.mp3","charTypeName":"word"},{"id":30485,"position":2,"arabic":"رَجُلٌۭ","translation":"এক ব্যক্তি","audioUrl":"wbw/040_028_002.mp3","charTypeName":"word"},{"id":30486,"position":3,"arabic":"مُّؤْمِنٌۭ","translation":"মু'মিন","audioUrl":"wbw/040_028_003.mp3","charTypeName":"word"},{"id":30487,"position":4,"arabic":"مِّنْ","translation":"মধ্যে হ'তে","audioUrl":"wbw/040_028_004.mp3","charTypeName":"word"},{"id":30488,"position":5,"arabic":"ءَالِ","translation":"সম্প্রদায়ের","audioUrl":"wbw/040_028_005.mp3","charTypeName":"word"},{"id":30489,"position":6,"arabic":"فِرْعَوْنَ","translation":"ফিরআউনের","audioUrl":"wbw/040_028_006.mp3","charTypeName":"word"},{"id":30490,"position":7,"arabic":"يَكْتُمُ","translation":"যে গোপন রেখেছিলো","audioUrl":"wbw/040_028_007.mp3","charTypeName":"word"},{"id":30491,"position":8,"arabic":"إِيمَـٰنَهُۥٓ","translation":"তার ঈমান","audioUrl":"wbw/040_028_008.mp3","charTypeName":"word"},{"id":30492,"position":9,"arabic":"أَتَقْتُلُونَ","translation":"\"তোমরা হত্যা করবে কি","audioUrl":"wbw/040_028_009.mp3","charTypeName":"word"},{"id":30493,"position":10,"arabic":"رَجُلًا","translation":"এক ব্যক্তিকে","audioUrl":"wbw/040_028_010.mp3","charTypeName":"word"},{"id":30494,"position":11,"arabic":"أَن","translation":"(এ কারণে) যে","audioUrl":"wbw/040_028_011.mp3","charTypeName":"word"},{"id":30495,"position":12,"arabic":"يَقُولَ","translation":"সে বলে","audioUrl":"wbw/040_028_012.mp3","charTypeName":"word"},{"id":30496,"position":13,"arabic":"رَبِّىَ","translation":"\"আমার রব","audioUrl":"wbw/040_028_013.mp3","charTypeName":"word"},{"id":30497,"position":14,"arabic":"ٱللَّهُ","translation":"আল্লাহ\"","audioUrl":"wbw/040_028_014.mp3","charTypeName":"word"},{"id":30498,"position":15,"arabic":"وَقَدْ","translation":"অথচ নিশ্চয়ই","audioUrl":"wbw/040_028_015.mp3","charTypeName":"word"},{"id":30499,"position":16,"arabic":"جَآءَكُم","translation":"তোমাদের কাছে এসেছে","audioUrl":"wbw/040_028_016.mp3","charTypeName":"word"},{"id":30500,"position":17,"arabic":"بِٱلْبَيِّنَـٰتِ","translation":"সুস্পষ্ট প্রমাণ নিয়ে","audioUrl":"wbw/040_028_017.mp3","charTypeName":"word"},{"id":30501,"position":18,"arabic":"مِن","translation":"পক্ষ হ'তে","audioUrl":"wbw/040_028_018.mp3","charTypeName":"word"},{"id":30502,"position":19,"arabic":"رَّبِّكُمْ ۖ","translation":"তোমাদের রবের","audioUrl":"wbw/040_028_019.mp3","charTypeName":"word"},{"id":30504,"position":20,"arabic":"وَإِن","translation":"এবং যদি","audioUrl":"wbw/040_028_021.mp3","charTypeName":"word"},{"id":30505,"position":21,"arabic":"يَكُ","translation":"সে হয়","audioUrl":"wbw/040_028_022.mp3","charTypeName":"word"},{"id":30506,"position":22,"arabic":"كَـٰذِبًۭا","translation":"মিথ্যাবাদী","audioUrl":"wbw/040_028_023.mp3","charTypeName":"word"},{"id":30507,"position":23,"arabic":"فَعَلَيْهِ","translation":"তবে তার উপর (বর্তিবে)","audioUrl":"wbw/040_028_024.mp3","charTypeName":"word"},{"id":30508,"position":24,"arabic":"كَذِبُهُۥ ۖ","translation":"তার মিথ্যার দায়","audioUrl":"wbw/040_028_025.mp3","charTypeName":"word"},{"id":30510,"position":25,"arabic":"وَإِن","translation":"কিন্তু যদি","audioUrl":"wbw/040_028_027.mp3","charTypeName":"word"},{"id":30511,"position":26,"arabic":"يَكُ","translation":"সে হয়","audioUrl":"wbw/040_028_028.mp3","charTypeName":"word"},{"id":30512,"position":27,"arabic":"صَادِقًۭا","translation":"সত্যবাদী","audioUrl":"wbw/040_028_029.mp3","charTypeName":"word"},{"id":30513,"position":28,"arabic":"يُصِبْكُم","translation":"তোমাদের উপর আপতিত হবে","audioUrl":"wbw/040_028_030.mp3","charTypeName":"word"},{"id":30514,"position":29,"arabic":"بَعْضُ","translation":"(তার) কিছু","audioUrl":"wbw/040_028_031.mp3","charTypeName":"word"},{"id":30515,"position":30,"arabic":"ٱلَّذِى","translation":"যা","audioUrl":"wbw/040_028_032.mp3","charTypeName":"word"},{"id":30516,"position":31,"arabic":"يَعِدُكُمْ ۖ","translation":"তোমাদেরকে সে ভয় দেখাচ্ছে","audioUrl":"wbw/040_028_033.mp3","charTypeName":"word"},{"id":30518,"position":32,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/040_028_035.mp3","charTypeName":"word"},{"id":30519,"position":33,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/040_028_036.mp3","charTypeName":"word"},{"id":30520,"position":34,"arabic":"لَا","translation":"না","audioUrl":"wbw/040_028_037.mp3","charTypeName":"word"},{"id":30521,"position":35,"arabic":"يَهْدِى","translation":"পথ দেখান","audioUrl":"wbw/040_028_038.mp3","charTypeName":"word"},{"id":30522,"position":36,"arabic":"مَنْ","translation":"(এমন) কাউকে","audioUrl":"wbw/040_028_039.mp3","charTypeName":"word"},{"id":30523,"position":37,"arabic":"هُوَ","translation":"যে","audioUrl":"wbw/040_028_040.mp3","charTypeName":"word"},{"id":30524,"position":38,"arabic":"مُسْرِفٌۭ","translation":"সীমালংঘনকারী","audioUrl":"wbw/040_028_041.mp3","charTypeName":"word"},{"id":30525,"position":39,"arabic":"كَذَّابٌۭ","translation":"ডাহা মিথ্যাবাদী","audioUrl":"wbw/040_028_042.mp3","charTypeName":"word"},{"id":30526,"position":40,"arabic":"٢٨","translation":"(২৮)","audioUrl":null,"charTypeName":"end"}]},{"number":29,"arabic":"يَٰقَوْمِ لَكُمُ ٱلْمُلْكُ ٱلْيَوْمَ ظَٰهِرِينَ فِى ٱلْأَرْضِ فَمَن يَنصُرُنَا مِنۢ بَأْسِ ٱللَّهِ إِن جَآءَنَا ۚ قَالَ فِرْعَوْنُ مَآ أُرِيكُمْ إِلَّا مَآ أَرَىٰ وَمَآ أَهْدِيكُمْ إِلَّا سَبِيلَ ٱلرَّشَادِ","translation":"“O my people! Yours is the dominion today, [and] most eminent are you on earth: but who will rescue us from God’s punishment, once it befalls us?” Said Pharaoh: “I but want to make you see what I see myself; and I would never make you follow any path but that of rectitude!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4162.mp3","surahId":40,"words":[{"id":31485,"position":1,"arabic":"يَـٰقَوْمِ","translation":"হে আমার জাতি","audioUrl":"wbw/040_029_001.mp3","charTypeName":"word"},{"id":31