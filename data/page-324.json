{"id":324,"ayahs":[{"number":25,"arabic":"وَمَآ أَرْسَلْنَا مِن قَبْلِكَ مِن رَّسُولٍ إِلَّا نُوحِىٓ إِلَيْهِ أَنَّهُۥ لَآ إِلَٰهَ إِلَّآ أَنَا۠ فَٱعْبُدُونِ","translation":"and [this despite the fact that even] before thy time We never sent any apostle without having revealed to him that there is no deity save Me, - [and that,] therefore, you shall worship Me [alone]!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2508.mp3","surahId":21,"words":[{"id":27915,"position":1,"arabic":"وَمَآ","translation":"এবং না","audioUrl":"wbw/021_025_001.mp3","charTypeName":"word"},{"id":27916,"position":2,"arabic":"أَرْسَلْنَا","translation":"আমরা পাঠিয়েছি","audioUrl":"wbw/021_025_002.mp3","charTypeName":"word"},{"id":27917,"position":3,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/021_025_003.mp3","charTypeName":"word"},{"id":27918,"position":4,"arabic":"قَبْلِكَ","translation":"পূর্ব তোমার","audioUrl":"wbw/021_025_004.mp3","charTypeName":"word"},{"id":27919,"position":5,"arabic":"مِن","translation":"কোন","audioUrl":"wbw/021_025_005.mp3","charTypeName":"word"},{"id":27920,"position":6,"arabic":"رَّسُولٍ","translation":"রাসূলকে","audioUrl":"wbw/021_025_006.mp3","charTypeName":"word"},{"id":27921,"position":7,"arabic":"إِلَّا","translation":"এ ছাড়া যে","audioUrl":"wbw/021_025_007.mp3","charTypeName":"word"},{"id":27922,"position":8,"arabic":"نُوحِىٓ","translation":"ওহী করেছি আমরা","audioUrl":"wbw/021_025_008.mp3","charTypeName":"word"},{"id":27923,"position":9,"arabic":"إِلَيْهِ","translation":"তার কাছে","audioUrl":"wbw/021_025_009.mp3","charTypeName":"word"},{"id":27924,"position":10,"arabic":"أَنَّهُۥ","translation":"এই যে","audioUrl":"wbw/021_025_010.mp3","charTypeName":"word"},{"id":27925,"position":11,"arabic":"لَآ","translation":"\"নেই","audioUrl":"wbw/021_025_011.mp3","charTypeName":"word"},{"id":27926,"position":12,"arabic":"إِلَـٰهَ","translation":"কোন ইলাহ","audioUrl":"wbw/021_025_012.mp3","charTypeName":"word"},{"id":27927,"position":13,"arabic":"إِلَّآ","translation":"ছাড়া","audioUrl":"wbw/021_025_013.mp3","charTypeName":"word"},{"id":27928,"position":14,"arabic":"أَنَا۠","translation":"আমি","audioUrl":"wbw/021_025_014.mp3","charTypeName":"word"},{"id":27929,"position":15,"arabic":"فَٱعْبُدُونِ","translation":"সুতরাং তোমরা আমারই ইবাদাত করো\"","audioUrl":"wbw/021_025_015.mp3","charTypeName":"word"},{"id":27930,"position":16,"arabic":"٢٥","translation":"(২৫)","audioUrl":null,"charTypeName":"end"}]},{"number":26,"arabic":"وَقَالُوا۟ ٱتَّخَذَ ٱلرَّحْمَٰنُ وَلَدًۭا ۗ سُبْحَٰنَهُۥ ۚ بَلْ عِبَادٌۭ مُّكْرَمُونَ","translation":"And [yet,] some say, “The Most Gracious has taken unto Himself a son”! Limitless is He in His glory! Nay, [those whom they regard as God’s “offspring” are but His] honoured servants:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2509.mp3","surahId":21,"words":[{"id":28885,"position":1,"arabic":"وَقَالُوا۟","translation":"এবং তারা বলে","audioUrl":"wbw/021_026_001.mp3","charTypeName":"word"},{"id":28886,"position":2,"arabic":"ٱتَّخَذَ","translation":"\"গ্রহণ করেছেন","audioUrl":"wbw/021_026_002.mp3","charTypeName":"word"},{"id":28887,"position":3,"arabic":"ٱلرَّحْمَـٰنُ","translation":"দয়াময়","audioUrl":"wbw/021_026_003.mp3","charTypeName":"word"},{"id":28888,"position":4,"arabic":"وَلَدًۭا ۗ","translation":"সন্তান\"","audioUrl":"wbw/021_026_004.mp3","charTypeName":"word"},{"id":28890,"position":5,"arabic":"سُبْحَـٰنَهُۥ ۚ","translation":"তিনি মহান পবিত্র","audioUrl":"wbw/021_026_006.mp3","charTypeName":"word"},{"id":28892,"position":6,"arabic":"بَلْ","translation":"বরং","audioUrl":"wbw/021_026_008.mp3","charTypeName":"word"},{"id":28893,"position":7,"arabic":"عِبَادٌۭ","translation":"(ফিরিশতারা) দাস","audioUrl":"wbw/021_026_009.mp3","charTypeName":"word"},{"id":28894,"position":8,"arabic":"مُّكْرَمُونَ","translation":"সম্মানিত","audioUrl":"wbw/021_026_010.mp3","charTypeName":"word"},{"id":28895,"position":9,"arabic":"٢٦","translation":"(২৬)","audioUrl":null,"charTypeName":"end"}]},{"number":27,"arabic":"لَا يَسْبِقُونَهُۥ بِٱلْقَوْلِ وَهُم بِأَمْرِهِۦ يَعْمَلُونَ","translation":"they speak not until He has spoken unto them, and [whenever they act,] they act at His behest.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2510.mp3","surahId":21,"words":[{"id":29690,"position":1,"arabic":"لَا","translation":"না","audioUrl":"wbw/021_027_001.mp3","charTypeName":"word"},{"id":29691,"position":2,"arabic":"يَسْبِقُونَهُۥ","translation":"তাঁর আগে বাড়ে তারা","audioUrl":"wbw/021_027_002.mp3","charTypeName":"word"},{"id":29692,"position":3,"arabic":"بِٱلْقَوْلِ","translation":"কথার মাধ্যমে","audioUrl":"wbw/021_027_003.mp3","charTypeName":"word"},{"id":29693,"position":4,"arabic":"وَهُم","translation":"এবং তারা","audioUrl":"wbw/021_027_004.mp3","charTypeName":"word"},{"id":29694,"position":5,"arabic":"بِأَمْرِهِۦ","translation":"তাঁর হুকুম অনুসারে","audioUrl":"wbw/021_027_005.mp3","charTypeName":"word"},{"id":29695,"position":6,"arabic":"يَعْمَلُونَ","translation":"কাজ করে","audioUrl":"wbw/021_027_006.mp3","charTypeName":"word"},{"id":29696,"position":7,"arabic":"٢٧","translation":"(২৭)","audioUrl":null,"charTypeName":"end"}]},{"number":28,"arabic":"يَعْلَمُ مَا بَيْنَ أَيْدِيهِمْ وَمَا خَلْفَهُمْ وَلَا يَشْفَعُونَ إِلَّا لِمَنِ ٱرْتَضَىٰ وَهُم مِّنْ خَشْيَتِهِۦ مُشْفِقُونَ","translation":"He knows all that lies open before them and all that is hidden from them: hence, they cannot intercede for any but those whom He has [already] graced with His goodly acceptance, since they themselves stand in reverent awe of Him.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2511.mp3","surahId":21,"words":[{"id":30768,"position":1,"arabic":"يَعْلَمُ","translation":"তিনি জানেন","audioUrl":"wbw/021_028_001.mp3","charTypeName":"word"},{"id":30769,"position":2,"arabic":"مَا","translation":"যা (আছে)","audioUrl":"wbw/021_028_002.mp3","charTypeName":"word"},{"id":30770,"position":3,"arabic":"بَيْنَ","translation":"মাঝে","audioUrl":"wbw/021_028_003.mp3","charTypeName":"word"},{"id":30771,"position":4,"arabic":"أَيْدِيهِمْ","translation":"তাদের হাতের (সামনে)","audioUrl":"wbw/021_028_004.mp3","charTypeName":"word"},{"id":30772,"position":5,"arabic":"وَمَا","translation":"এবং যা (আছে)","audioUrl":"wbw/021_028_005.mp3","charTypeName":"word"},{"id":30773,"position":6,"arabic":"خَلْفَهُمْ","translation":"তাদের পিছনে","audioUrl":"wbw/021_028_006.mp3","charTypeName":"word"},{"id":30774,"position":7,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/021_028_007.mp3","charTypeName":"word"},{"id":30775,"position":8,"arabic":"يَشْفَعُونَ","translation":"তারা সুপারিশ করে","audioUrl":"wbw/021_028_008.mp3","charTypeName":"word"},{"id":30776,"position":9,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/021_028_009.mp3","charTypeName":"word"},{"id":30777,"position":10,"arabic":"لِمَنِ","translation":"জন্যে তাদের (যাদের প্রতি)","audioUrl":"wbw/021_028_010.mp3","charTypeName":"word"},{"id":30778,"position":11,"arabic":"ٱرْتَضَىٰ","translation":"(আল্লাহ্‌) সন্তুষ্ট হন","audioUrl":"wbw/021_028_011.mp3","charTypeName":"word"},{"id":30779,"position":12,"arabic":"وَهُم","translation":"এবং তারা","audioUrl":"wbw/021_028_012.mp3","charTypeName":"word"},{"id":30780,"position":13,"arabic":"مِّنْ","translation":"কারণে","audioUrl":"wbw/021_028_013.mp3","charTypeName":"word"},{"id":30781,"position":14,"arabic":"خَشْيَتِهِۦ","translation":"তাঁর ভয়ের","audioUrl":"wbw/021_028_014.mp3","charTypeName":"word"},{"id":30782,"position":15,"arabic":"مُشْفِقُونَ","translation":"ভীত সন্ত্রস্ত","audioUrl":"wbw/021_028_015.mp3","charTypeName":"word"},{"id":30783,"position":16,"arabic":"٢٨","translation":"(২৮)","audioUrl":null,"charTypeName":"end"}]},{"number":29,"arabic":"۞ وَمَن يَقُلْ مِنْهُمْ إِنِّىٓ إِلَٰهٌۭ مِّن دُونِهِۦ فَذَٰلِكَ نَجْزِيهِ جَهَنَّمَ ۚ كَذَٰلِكَ نَجْزِى ٱلظَّٰلِمِينَ","translation":"And if any of them were to say, “Behold, I am deity beside Him” - that one We should requite with hell: thus do We requite all [such] evildoers.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2512.mp3","surahId":21,"words":[{"id":31860,"position":1,"arabic":"۞ وَمَن","translation":"এবং কেউ","audioUrl":"wbw/021_029_002.mp3","charTypeName":"word"},{"id":31861,"position":2,"arabic":"يَقُلْ","translation":"(যদি) বলে","audioUrl":"wbw/021_029_003.mp3","charTypeName":"word"},{"id":31862,"position":3,"arabic":"مِنْهُمْ","translation":"তাদের মধ্য হ'তে","audioUrl":"wbw/021_029_004.mp3","charTypeName":"word"},{"id":31863,"position":4,"arabic":"إِنِّىٓ","translation":"\"আমিও নিশ্চয়ই","audioUrl":"wbw/021_029_005.mp3","charTypeName":"word"},{"id":31864,"position":5,"arabic":"إِلَـٰهٌۭ","translation":"একজন ইলাহ","audioUrl":"wbw/021_029_006.mp3","charTypeName":"word"},{"id":31865,"position":6,"arabic":"مِّن","translation":"ছাড়া\"","audioUrl":"wbw/021_029_007.mp3","charTypeName":"word"},{"id":31866,"position":7,"arabic":"دُونِهِۦ","translation":"তিনি\"","audioUrl":"wbw/021_029_008.mp3","charTypeName":"word"},{"id":31867,"position":8,"arabic":"فَذَٰلِكَ","translation":"তবে এ কারণে","audioUrl":"wbw/021_029_009.mp3","charTypeName":"word"},{"id":31868,"position":9,"arabic":"نَجْزِيهِ","translation":"তাকে শাস্তি দিবো আমরা","audioUrl":"wbw/021_029_010.mp3","charTypeName":"word"},{"id":31869,"position":10,"arabic":"جَهَنَّمَ ۚ","translation":"জাহান্নামে","audioUrl":"wbw/021_029_011.mp3","charTypeName":"word"},{"id":31871,"position":11,"arabic":"كَذَٰلِكَ","translation":"এরূপে","audioUrl":"wbw/021_029_013.mp3","charTypeName":"word"},{"id":31872,"position":12,"arabic":"نَجْزِى","translation":"শাস্তি দিই আমরা","audioUrl":"wbw/021_029_014.mp3","charTypeName":"word"},{"id":31873,"position":13,"arabic":"ٱلظَّـٰلِمِينَ","translation":"সীমালঙ্ঘনকারীদেরকে","audioUrl":"wbw/021_029_015.mp3","charTypeName":"word"},{"id":31874,"position":14,"arabic":"٢٩","translation":"(২৯)","audioUrl":null,"charTypeName":"end"}]},{"number":30,"arabic":"أَوَلَمْ يَرَ ٱلَّذِينَ كَفَرُوٓا۟ أَنَّ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضَ كَانَتَا رَتْقًۭا فَفَتَقْنَٰهُمَا ۖ وَجَعَلْنَا مِنَ ٱلْمَآءِ كُلَّ شَىْءٍ حَىٍّ ۖ أَفَلَا يُؤْمِنُونَ","translation":"ARE, THEN, they who are bent on denying the truth not aware that the heavens and the earth were [once] one single entity, which We then parted asunder? – and [that] We made out of water every living thing? Will they not, then, [begin to] believe?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2513.mp3","surahId":21,"words":[{"id":32725,"position":1,"arabic":"أَوَلَمْ","translation":"কি নি","audioUrl":"wbw/021_030_001.mp3","charTypeName":"word"},{"id":32726,"position":2,"arabic":"يَرَ","translation":"ভেবে দেখে","audioUrl":"wbw/021_030_002.mp3","charTypeName":"word"},{"id":32727,"position":3,"arabic":"ٱلَّذِينَ","translation":"(তারা) যারা","audioUrl":"wbw/021_030_003.mp3","charTypeName":"word"},{"id":32728,"position":4,"arabic":"كَفَرُوٓا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/021_030_004.mp3","charTypeName":"word"},{"id":32729,"position":5,"arabic":"أَنَّ","translation":"যে","audioUrl":"wbw/021_030_005.mp3","charTypeName":"word"},{"id":32730,"position":6,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশমন্ডলী","audioUrl":"wbw/021_030_006.mp3","charTypeName":"word"},{"id":32731,"position":7,"arabic":"وَٱلْأَرْضَ","translation":"ও পৃথিবী","audioUrl":"wbw/021_030_007.mp3","charTypeName":"word"},{"id":32732,"position":8,"arabic":"كَانَتَا","translation":"উভয়ে ছিলো","audioUrl":"wbw/021_030_008.mp3","charTypeName":"word"},{"id":32733,"position":9,"arabic":"رَتْقًۭا","translation":"মিলিত অবস্থায়","audioUrl":"wbw/021_030_009.mp3","charTypeName":"word"},{"id":32734,"position":10,"arabic":"فَفَتَقْنَـٰهُمَا ۖ","translation":"অতঃপর উভয়কে আমরা পৃথক করে দিয়েছি","audioUrl":"wbw/021_030_010.mp3","charTypeName":"word"},{"id":32736,"position":11,"arabic":"وَجَعَلْنَا","translation":"এবং আমরা বানিয়েছি","audioUrl":"wbw/021_030_012.mp3","charTypeName":"word"},{"id":32737,"position":12,"arabic":"مِنَ","translation":"থেকে","audioUrl":"wbw/