ُۥ حَثِيثًۭا وَٱلشَّمْسَ وَٱلْقَمَرَ وَٱلنُّجُومَ مُسَخَّرَٰتٍۭ بِأَمْرِهِۦٓ ۗ أَلَا لَهُ ٱلْخَلْقُ وَٱلْأَمْرُ ۗ تَبَارَكَ ٱللَّهُ رَبُّ ٱلْعَٰلَمِينَ","translation":"VERILY, your Sustainer is God, who has created the heavens and the earth in six aeons, and is established on the throne of His almightiness. He covers the day with the night in swift pursuit, with the sun and the moon and the stars subservient to His command: oh, verily, His is all creation and all command. Hallowed is God, the Sustainer of all the worlds!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1008.mp3","surahId":7,"words":[{"id":50928,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/007_054_001.mp3","charTypeName":"word"},{"id":50929,"position":2,"arabic":"رَبَّكُمُ","translation":"রব তোমাদের","audioUrl":"wbw/007_054_002.mp3","charTypeName":"word"},{"id":50930,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ-ই","audioUrl":"wbw/007_054_003.mp3","charTypeName":"word"},{"id":50931,"position":4,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/007_054_004.mp3","charTypeName":"word"},{"id":50932,"position":5,"arabic":"خَلَقَ","translation":"সৃষ্টি করেছেন","audioUrl":"wbw/007_054_005.mp3","charTypeName":"word"},{"id":50933,"position":6,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশসমূহকে","audioUrl":"wbw/007_054_006.mp3","charTypeName":"word"},{"id":50934,"position":7,"arabic":"وَٱلْأَرْضَ","translation":"ও পৃথিবীকে","audioUrl":"wbw/007_054_007.mp3","charTypeName":"word"},{"id":50935,"position":8,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/007_054_008.mp3","charTypeName":"word"},{"id":50936,"position":9,"arabic":"سِتَّةِ","translation":"ছয়","audioUrl":"wbw/007_054_009.mp3","charTypeName":"word"},{"id":50937,"position":10,"arabic":"أَيَّامٍۢ","translation":"দিনের","audioUrl":"wbw/007_054_010.mp3","charTypeName":"word"},{"id":50938,"position":11,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/007_054_011.mp3","charTypeName":"word"},{"