3","charTypeName":"word"},{"id":72459,"position":3,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছ","audioUrl":"wbw/002_104_003.mp3","charTypeName":"word"},{"id":72460,"position":4,"arabic":"لَا","translation":"''না","audioUrl":"wbw/002_104_004.mp3","charTypeName":"word"},{"id":72461,"position":5,"arabic":"تَقُولُوا۟","translation":"তোমরা বলো","audioUrl":"wbw/002_104_005.mp3","charTypeName":"word"},{"id":72462,"position":6,"arabic":"رَٰعِنَا","translation":"''রায়িনা''","audioUrl":"wbw/002_104_006.mp3","charTypeName":"word"},{"id":72463,"position":7,"arabic":"وَقُولُوا۟","translation":"বরং তোমরা বলো","audioUrl":"wbw/002_104_007.mp3","charTypeName":"word"},{"id":72464,"position":8,"arabic":"ٱنظُرْنَا","translation":"''উনজুরনা''","audioUrl":"wbw/002_104_008.mp3","charTypeName":"word"},{"id":72465,"position":9,"arabic":"وَٱسْمَعُوا۟ ۗ","translation":"এবং তোমরা শুনো","audioUrl":"wbw/002_104_009.mp3","charTypeName":"word"},{"id":72467,"position":10,"arabic":"وَلِلْكَـٰفِرِينَ","translation":"এবং কাফিরদের জন্য (রয়েছে)","audioUrl":"wbw/002_104_011.mp3","charTypeName":"word"},{"id":72468,"position":11,"arabic":"عَذَابٌ","translation":"শাস্তি","audioUrl":"wbw/002_104_012.mp3","charTypeName":"word"},{"id":72469,"position":12,"arabic":"أَلِيمٌۭ","translation":"নিদারুণ","audioUrl":"wbw/002_104_013.mp3","charTypeName":"word"},{"id":72470,"position":13,"arabic":"١٠٤","translation":"(১০৪)","audioUrl":null,"charTypeName":"end"}]},{"number":105,"arabic":"مَّا يَوَدُّ ٱلَّذِينَ كَفَرُوا۟ مِنْ أَهْلِ ٱلْكِتَٰبِ وَلَا ٱلْمُشْرِكِينَ أَن يُنَزَّلَ عَلَيْكُم مِّنْ خَيْرٍۢ مِّن رَّبِّكُمْ ۗ وَٱللَّهُ يَخْتَصُّ بِرَحْمَتِهِۦ مَن يَشَآءُ ۚ وَٱللَّهُ ذُو ٱلْفَضْلِ ٱلْعَظِيمِ","translation":"Neither those from among the followers of earlier revelation who are bent on denying the truth, nor those who ascribe divinity to other beings beside God, would like to see any good ever bestowed upon you from on high by your Sustainer; but God singles out for His grace whom He wills-for God is limitless i