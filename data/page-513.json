"charTypeName":"end"}]},{"number":19,"arabic":"وَمَغَانِمَ كَثِيرَةًۭ يَأْخُذُونَهَا ۗ وَكَانَ ٱللَّهُ عَزِيزًا حَكِيمًۭا","translation":"and [of] many war-gains which they would achieve: for God is indeed almighty, wise.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4602.mp3","surahId":48,"words":[{"id":21413,"position":1,"arabic":"وَمَغَانِمَ","translation":"এবং যুদ্ধলব্ধ সম্পদসমূহ","audioUrl":"wbw/048_019_001.mp3","charTypeName":"word"},{"id":21414,"position":2,"arabic":"كَثِيرَةًۭ","translation":"বিপুল পরিমাণে","audioUrl":"wbw/048_019_002.mp3","charTypeName":"word"},{"id":21415,"position":3,"arabic":"يَأْخُذُونَهَا ۗ","translation":"তা তারা গ্রহণ করবে","audioUrl":"wbw/048_019_003.mp3","charTypeName":"word"},{"id":21417,"position":4,"arabic":"وَكَانَ","translation":"এবং হলেন","audioUrl":"wbw/048_019_005.mp3","charTypeName":"word"},{"id":21418,"position":5,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌","audioUrl":"wbw/048_019_006.mp3","charTypeName":"word"},{"id":21419,"position":6,"arabic":"عَزِيزًا","translation":"পরাক্রমশালী","audioUrl":"wbw/048_019_007.mp3","charTypeName":"word"},{"id":21420,"position":7,"arabic":"حَكِيمًۭا","translation":"মহাবিজ্ঞ","audioUrl":"wbw/048_019_008.mp3","charTypeName":"word"},{"id":21421,"position":8,"arabic":"١٩","translation":"(১৯)","audioUrl":null,"charTypeName":"end"}]},{"number":20,"arabic":"وَعَدَكُمُ ٱللَّهُ مَغَانِمَ كَثِيرَةًۭ تَأْخُذُونَهَا فَعَجَّلَ لَكُمْ هَٰذِهِۦ وَكَفَّ أَيْدِىَ ٱلنَّاسِ عَنكُمْ وَلِتَكُونَ ءَايَةًۭ لِّلْمُؤْمِنِينَ وَيَهْدِيَكُمْ صِرَٰطًۭا مُّسْتَقِيمًۭا","translation":"[O you who believe!] God has promised you many war-gains which you shall yet achieve; and He has vouchsafed you these [worldly gains] well in advance, and has stayed from you the hands of [hostile] people, so that this [your inner strength] may become a symbol to the believers [who will come after you], and that He may guide you all on a straight way.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4603.mp3","surahId":48,"words":[{"id":22507,"position":1,"arabic":"وَعَدَكُمُ","translation":"তোমাদেরকে প্রতিশ্রুতি দিয়েছেন","audioUrl":"wbw/048_020_001.mp3","charTypeName":"word"},{"id":22508,"position":2,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌","audioUrl":"wbw/048_020_002.mp3","charTypeName":"word"},{"id":22509,"position":3,"arabic":"مَغَانِمَ","translation":"যুদ্ধলব্ধ সম্পদ সমুহের","audioUrl":"wbw/048_020_003.mp3","charTypeName":"word"},{"id":22510,"position":4,"arabic":"كَثِيرَةًۭ","translation":"বিপুল পরিমাণ","audioUrl":"wbw/048_020_004.mp3","charTypeName":"word"},{"id":22511,"position":5,"arabic":"تَأْخُذُونَهَا","translation":"তা তোমরা গ্রহণ করবে","audioUrl":"wbw/048_020_005.mp3","charTypeName":"word"},{"id":22512,"position":6,"arabic":"فَعَجَّلَ","translation":"এখন তিনি ত্বরান্বিত করেছেন","audioUrl":"wbw/048_020_006.mp3","charTypeName":"word"},{"id":22513,"position":7,"arabic":"لَكُمْ","translation":"তোমাদের জন্য","audioUrl":"wbw/048_020_007.mp3","charTypeName":"word"},{"id":22514,"position":8,"arabic":"هَـٰذِهِۦ","translation":"এটা","audioUrl":"wbw/048_020_008.mp3","charTypeName":"word"},{"id":22515,"position":9,"arabic":"وَكَفَّ","translation":"এবং বিরত রাখলেন","audioUrl":"wbw/048_020_009.mp3","charTypeName":"word"},{"id":22516,"position":10,"arabic":"أَيْدِىَ","translation":"হাতগুলোকে","audioUrl":"wbw/048_020_010.mp3","charTypeName":"word"},{"id":22517,"position":11,"arabic":"ٱلنَّاسِ","translation":"লোকদের","audioUrl":"wbw/048_020_011.mp3","charTypeName":"word"},{"id":22518,"position":12,"arabic":"عَنكُمْ","translation":"তোমাদের থেকে","audioUrl":"wbw/048_020_012.mp3","charTypeName":"word"},{"id":22519,"position":13,"arabic":"وَلِتَكُونَ","translation":"এবং এটা হয় যেন","audioUrl":"wbw/048_020_013.mp3","charTypeName":"word"},{"id":22520,"position":14,"arabic":"ءَايَةًۭ","translation":"একটি নিদর্শন","audioUrl":"wbw/048_020_014.mp3","charTypeName":"word"},{"id":22521,"position":15,"arabic":"لِّلْمُؤْمِنِينَ","translation":"মু'মিনদের জন্যে","audioUrl":"wbw/04