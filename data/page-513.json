{"id":513,"ayahs":[{"number":16,"arabic":"قُل لِّلْمُخَلَّفِينَ مِنَ ٱلْأَعْرَابِ سَتُدْعَوْنَ إِلَىٰ قَوْمٍ أُو۟لِى بَأْسٍۢ شَدِيدٍۢ تُقَٰتِلُونَهُمْ أَوْ يُسْلِمُونَ ۖ فَإِن تُطِيعُوا۟ يُؤْتِكُمُ ٱللَّهُ أَجْرًا حَسَنًۭا ۖ وَإِن تَتَوَلَّوْا۟ كَمَا تَوَلَّيْتُم مِّن قَبْلُ يُعَذِّبْكُمْ عَذَابًا أَلِيمًۭا","translation":"Say unto those bedouin who stayed behind: “In time you will be called upon [to fight] against people of great prowess in war: you will have to fight against them [until you die] or they surrender. And then, if you heed [that call], God will bestow on you a goodly reward; but if you turn away as you turned away this time, He will chastise you with grievous chastisement.”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4599.mp3","surahId":48,"words":[{"id":18184,"position":1,"arabic":"قُل","translation":"বলো","audioUrl":"wbw/048_016_001.mp3","charTypeName":"word"},{"id":18185,"position":2,"arabic":"لِّلْمُخَلَّفِينَ","translation":"পিছে থেকে যাওয়া লোকদেরকে","audioUrl":"wbw/048_016_002.mp3","charTypeName":"word"},{"id":18186,"position":3,"arabic":"مِنَ","translation":"মধ্য হতে","audioUrl":"wbw/048_016_003.mp3","charTypeName":"word"},{"id":18187,"position":4,"arabic":"ٱلْأَعْرَابِ","translation":"মরুবাসীদের","audioUrl":"wbw/048_016_004.mp3","charTypeName":"word"},{"id":18188,"position":5,"arabic":"سَتُدْعَوْنَ","translation":"\"তোমাদের ডাকা হবে শীঘ্রই (যুদ্ধ করতে)","audioUrl":"wbw/048_016_005.mp3","charTypeName":"word"},{"id":18189,"position":6,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/048_016_006.mp3","charTypeName":"word"},{"id":18190,"position":7,"arabic":"قَوْمٍ","translation":"এক জাতির","audioUrl":"wbw/048_016_007.mp3","charTypeName":"word"},{"id":18191,"position":8,"arabic":"أُو۟لِى","translation":"সম্পন্ন","audioUrl":"wbw/048_016_008.mp3","charTypeName":"word"},{"id":18192,"position":9,"arabic":"بَأْسٍۢ","translation":"শক্তি","audioUrl":"wbw/048_016_009.mp3","charTypeName":"word"},{"id":18193,"position":10,"arabic"