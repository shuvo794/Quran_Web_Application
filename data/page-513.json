Url":"wbw/048_017_006.mp3","charTypeName":"word"},{"id":19227,"position":7,"arabic":"ٱلْأَعْرَجِ","translation":"পঙ্গুর","audioUrl":"wbw/048_017_007.mp3","charTypeName":"word"},{"id":19228,"position":8,"arabic":"حَرَجٌۭ","translation":"কোনো অপরাধ","audioUrl":"wbw/048_017_008.mp3","charTypeName":"word"},{"id":19229,"position":9,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/048_017_009.mp3","charTypeName":"word"},{"id":19230,"position":10,"arabic":"عَلَى","translation":"জন্যে","audioUrl":"wbw/048_017_010.mp3","charTypeName":"word"},{"id":19231,"position":11,"arabic":"ٱلْمَرِيضِ","translation":"রোগীর","audioUrl":"wbw/048_017_011.mp3","charTypeName":"word"},{"id":19232,"position":12,"arabic":"حَرَجٌۭ ۗ","translation":"কোনো অপরাধ","audioUrl":"wbw/048_017_012.mp3","charTypeName":"word"},{"id":19234,"position":13,"arabic":"وَمَن","translation":"এবং যে","audioUrl":"wbw/048_017_014.mp3","charTypeName":"word"},{"id":19235,"position":14,"arabic":"يُطِعِ","translation":"আনুগত্য করে","audioUrl":"wbw/048_017_015.mp3","charTypeName":"word"},{"id":19236,"position":15,"arabic":"ٱللَّهَ","translation":"আল্লাহ্‌র","audioUrl":"wbw/048_017_016.mp3","charTypeName":"word"},{"id":19237,"position":16,"arabic":"وَرَسُولَهُۥ","translation":"ও তাঁর রাসুলের","audioUrl":"wbw/048_017_017.mp3","charTypeName":"word"},{"id":19238,"position":17,"arabic":"يُدْخِلْهُ","translation":"তাকে প্রবেশ করাবেন তিনি","audioUrl":"wbw/048_017_018.mp3","charTypeName":"word"},{"id":19239,"position":18,"arabic":"جَنَّـٰتٍۢ","translation":"জান্নাতে","audioUrl":"wbw/048_017_019.mp3","charTypeName":"word"},{"id":19240,"position":19,"arabic":"تَجْرِى","translation":"প্রবাহিত হয়","audioUrl":"wbw/048_017_020.mp3","charTypeName":"word"},{"id":19241,"position":20,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/048_017_021.mp3","charTypeName":"word"},{"id":19242,"position":21,"arabic":"تَحْتِهَا","translation":"তার নিচ","audioUrl":"wbw/048_017_022.mp3","charTypeName":"word"},{"id":19243,"position":22,"arabic":"ٱ