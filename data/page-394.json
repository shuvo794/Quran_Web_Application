{"id":394,"ayahs":[{"number":71,"arabic":"قُلْ أَرَءَيْتُمْ إِن جَعَلَ ٱللَّهُ عَلَيْكُمُ ٱلَّيْلَ سَرْمَدًا إِلَىٰ يَوْمِ ٱلْقِيَٰمَةِ مَنْ إِلَٰهٌ غَيْرُ ٱللَّهِ يَأْتِيكُم بِضِيَآءٍ ۖ أَفَلَا تَسْمَعُونَ","translation":"Say: “Have you ever considered [this]: If God had willed that there should always be night about you, without break, until the Day of Resurrection - is there any deity other than God that could bring you light? Will you not, then, listen [to the truth]?”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3323.mp3","surahId":28,"words":[{"id":59977,"position":1,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/028_071_001.mp3","charTypeName":"word"},{"id":59978,"position":2,"arabic":"أَرَءَيْتُمْ","translation":"\"কি ভেবে দেখেছো তোমরা","audioUrl":"wbw/028_071_002.mp3","charTypeName":"word"},{"id":59979,"position":3,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/028_071_003.mp3","charTypeName":"word"},{"id":59980,"position":4,"arabic":"جَعَلَ","translation":"করে দেন","audioUrl":"wbw/028_071_004.mp3","charTypeName":"word"},{"id":59981,"position":5,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/028_071_005.mp3","charTypeName":"word"},{"id":59982,"position":6,"arabic":"عَلَيْكُمُ","translation":"উপর তোমাদের","audioUrl":"wbw/028_071_006.mp3","charTypeName":"word"},{"id":59983,"position":7,"arabic":"ٱلَّيْلَ","translation":"রাতকে","audioUrl":"wbw/028_071_007.mp3","charTypeName":"word"},{"id":59984,"position":8,"arabic":"سَرْمَدًا","translation":"সুদীর্ঘ","audioUrl":"wbw/028_071_008.mp3","charTypeName":"word"},{"id":59985,"position":9,"arabic":"إِلَىٰ","translation":"পর্যন্ত","audioUrl":"wbw/028_071_009.mp3","charTypeName":"word"},{"id":59986,"position":10,"arabic":"يَوْمِ","translation":"দিন","audioUrl":"wbw/028_071_010.mp3","charTypeName":"word"},{"id":59987,"position":11,"arabic":"ٱلْقِيَـٰمَةِ","translation":"ক্বিয়ামাতের","audioUrl":"wbw/028_071_011.mp3","charTypeName":"word"},{"id":59988,"position":12,"arabic":"مَنْ","translation":"কে (এমন আছে)","audioUrl":"wbw/028_071_012.mp3","charTypeName":"word"},{"id":59989,"position":13,"arabic":"إِلَـٰهٌ","translation":"ইলাহ","audioUrl":"wbw/028_071_013.mp3","charTypeName":"word"},{"id":59990,"position":14,"arabic":"غَيْرُ","translation":"ছাড়া","audioUrl":"wbw/028_071_014.mp3","charTypeName":"word"},{"id":59991,"position":15,"arabic":"ٱللَّهِ","translation":"আল্লাহ (যে)","audioUrl":"wbw/028_071_015.mp3","charTypeName":"word"},{"id":59992,"position":16,"arabic":"يَأْتِيكُم","translation":"কাছে আসবে তোমাদের","audioUrl":"wbw/028_071_016.mp3","charTypeName":"word"},{"id":59993,"position":17,"arabic":"بِضِيَآءٍ ۖ","translation":"নিয়ে আলো","audioUrl":"wbw/028_071_017.mp3","charTypeName":"word"},{"id":59995,"position":18,"arabic":"أَفَلَا","translation":"কি তবুও না","audioUrl":"wbw/028_071_019.mp3","charTypeName":"word"},{"id":59996,"position":19,"arabic":"تَسْمَعُونَ","translation":"তোমরা শুনবে\"","audioUrl":"wbw/028_071_020.mp3","charTypeName":"word"},{"id":59997,"position":20,"arabic":"٧١","translation":"(৭১)","audioUrl":null,"charTypeName":"end"}]},{"number":72,"arabic":"قُلْ أَرَءَيْتُمْ إِن جَعَلَ ٱللَّهُ عَلَيْكُمُ ٱلنَّهَارَ سَرْمَدًا إِلَىٰ يَوْمِ ٱلْقِيَٰمَةِ مَنْ إِلَٰهٌ غَيْرُ ٱللَّهِ يَأْتِيكُم بِلَيْلٍۢ تَسْكُنُونَ فِيهِ ۖ أَفَلَا تُبْصِرُونَ","translation":"Say: “Have you ever considered [this]: If God had willed that there should always be daylight about you, without break, until the Day of Resurrection - is there any deity other than God that could bring you [the darkness of] night, wherein you might rest? Will you not, then, see [the truth]?”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3324.mp3","surahId":28,"words":[{"id":60772,"position":1,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/028_072_001.mp3","charTypeName":"word"},{"id":60773,"position":2,"arabic":"أَرَءَيْتُمْ","translation":"\"কি ভেবে দেখেছো তোমরা","audioUrl":"wbw/028_072_002.mp3","charTypeName":"word"},{"id":60774,"position":3,"arabic":