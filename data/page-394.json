Exult not [in thy wealth], for, verily, God does not love those who exult [in things vain]!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3328.mp3","surahId":28,"words":[{"id":62615,"position":1,"arabic":"۞ إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/028_076_002.mp3","charTypeName":"word"},{"id":62616,"position":2,"arabic":"قَـٰرُونَ","translation":"ক্বারুণ","audioUrl":"wbw/028_076_003.mp3","charTypeName":"word"},{"id":62617,"position":3,"arabic":"كَانَ","translation":"ছিলো","audioUrl":"wbw/028_076_004.mp3","charTypeName":"word"},{"id":62618,"position":4,"arabic":"مِن","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/028_076_005.mp3","charTypeName":"word"},{"id":62619,"position":5,"arabic":"قَوْمِ","translation":"জাতির","audioUrl":"wbw/028_076_006.mp3","charTypeName":"word"},{"id":62620,"position":6,"arabic":"مُوسَىٰ","translation":"মূসার","audioUrl":"wbw/028_076_007.mp3","charTypeName":"word"},{"id":62621,"position":7,"arabic":"فَبَغَىٰ","translation":"কিন্তু সে উদ্ধত্য প্রকাশ করলো","audioUrl":"wbw/028_076_008.mp3","charTypeName":"word"},{"id":62622,"position":8,"arabic":"عَلَيْهِمْ ۖ","translation":"বিরুদ্ধে তাদেরই (জাতির)","audioUrl":"wbw/028_076_009.mp3","charTypeName":"word"},{"id":62624,"position":9,"arabic":"وَءَاتَيْنَـٰهُ","translation":"আর আমরা দিয়েছিলাম তাকে","audioUrl":"wbw/028_076_011.mp3","charTypeName":"word"},{"id":62625,"position":10,"arabic":"مِنَ","translation":"থেকে","audioUrl":"wbw/028_076_012.mp3","charTypeName":"word"},{"id":62626,"position":11,"arabic":"ٱلْكُنُوزِ","translation":"ধনভান্ডারসমূহ","audioUrl":"wbw/028_076_013.mp3","charTypeName":"word"},{"id":62627,"position":12,"arabic":"مَآ","translation":"যা (এমন ছিলো যে)","audioUrl":"wbw/028_076_014.mp3","charTypeName":"word"},{"id":62628,"position":13,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/028_076_015.mp3","charTypeName":"word"},{"id":62629,"position":14,"arabic":"مَفَاتِحَهُۥ","translation":"চাবিগুলো তার","audioUrl":"wbw/028_076_016.mp3","charTypeName"