"id":60790,"position":19,"arabic":"فِيهِ ۖ","translation":"মধ্যে তার","audioUrl":"wbw/028_072_019.mp3","charTypeName":"word"},{"id":60792,"position":20,"arabic":"أَفَلَا","translation":"কি তবুও না","audioUrl":"wbw/028_072_021.mp3","charTypeName":"word"},{"id":60793,"position":21,"arabic":"تُبْصِرُونَ","translation":"তোমরা ভেবে দেখবে\"","audioUrl":"wbw/028_072_022.mp3","charTypeName":"word"},{"id":60794,"position":22,"arabic":"٧٢","translation":"(৭২)","audioUrl":null,"charTypeName":"end"}]},{"number":73,"arabic":"وَمِن رَّحْمَتِهِۦ جَعَلَ لَكُمُ ٱلَّيْلَ وَٱلنَّهَارَ لِتَسْكُنُوا۟ فِيهِ وَلِتَبْتَغُوا۟ مِن فَضْلِهِۦ وَلَعَلَّكُمْ تَشْكُرُونَ","translation":"For it is out of His grace that He has made for you the night and the day, so that you might rest therein as well as seek to obtain [what you need] of His bounty: and [He gave you all this] so that you might have cause to be grateful.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3325.mp3","surahId":28,"words":[{"id":61067,"position":1,"arabic":"وَمِن","translation":"আর হ'তে","audioUrl":"wbw/028_073_001.mp3","charTypeName":"word"},{"id":61068,"position":2,"arabic":"رَّحْمَتِهِۦ","translation":"তাঁর দয়া","audioUrl":"wbw/028_073_002.mp3","charTypeName":"word"},{"id":61069,"position":3,"arabic":"جَعَلَ","translation":"তিনি সৃষ্টি করেছেন","audioUrl":"wbw/028_073_003.mp3","charTypeName":"word"},{"id":61070,"position":4,"arabic":"لَكُمُ","translation":"জন্যে তোমাদের","audioUrl":"wbw/028_073_004.mp3","charTypeName":"word"},{"id":61071,"position":5,"arabic":"ٱلَّيْلَ","translation":"রাতকে","audioUrl":"wbw/028_073_005.mp3","charTypeName":"word"},{"id":61072,"position":6,"arabic":"وَٱلنَّهَارَ","translation":"ও দিনকে","audioUrl":"wbw/028_073_006.mp3","charTypeName":"word"},{"id":61073,"position":7,"arabic":"لِتَسْكُنُوا۟","translation":"যেন তোমরা শান্তি পাও","audioUrl":"wbw/028_073_007.mp3","charTypeName":"word"},{"id":61074,"position":8,"arabic":"فِيهِ","translation":"মধ্যে তার","audioUrl":"wbw/028_073_008.mp3","charTypeName":"word"},{"id":61075,"position":9,"arabic":"وَلِتَبْتَغُوا۟","translation":"এবং যেন তোমরা সন্ধান করো","audioUrl":"wbw/028_073_009.mp3","charTypeName":"word"},{"id":61076,"position":10,"arabic":"مِن","translation":"হ'তে","audioUrl":"wbw/028_073_010.mp3","charTypeName":"word"},{"id":61077,"position":11,"arabic":"فَضْلِهِۦ","translation":"তাঁর অনুগ্রহ","audioUrl":"wbw/028_073_011.mp3","charTypeName":"word"},{"id":61078,"position":12,"arabic":"وَلَعَلَّكُمْ","translation":"আর( এভাবেই) হয়তো তোমরা","audioUrl":"wbw/028_073_012.mp3","charTypeName":"word"},{"id":61079,"position":13,"arabic":"تَشْكُرُونَ","translation":"তোমরা কৃতজ্ঞতা প্রকাশ করবে","audioUrl":"wbw/028_073_013.mp3","charTypeName":"word"},{"id":61080,"position":14,"arabic":"٧٣","translation":"(৭৩)","audioUrl":null,"charTypeName":"end"}]},{"number":74,"arabic":"وَيَوْمَ يُنَادِيهِمْ فَيَقُولُ أَيْنَ شُرَكَآءِىَ ٱلَّذِينَ كُنتُمْ تَزْعُمُونَ","translation":"AND ON THAT DAY He will call unto those [that shall have been arraigned before His judgment seat], and will ask: “Where, now, are those [beings or powers] whom you imagined to have a share in My divinity?”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3326.mp3","surahId":28,"words":[{"id":61488,"position":1,"arabic":"وَيَوْمَ","translation":"আর সেদিন (কেমন হবে যখন)","audioUrl":"wbw/028_074_001.mp3","charTypeName":"word"},{"id":61489,"position":2,"arabic":"يُنَادِيهِمْ","translation":"তিনি ডাকবেন তাদেরকে","audioUrl":"wbw/028_074_002.mp3","charTypeName":"word"},{"id":61490,"position":3,"arabic":"فَيَقُولُ","translation":"অতঃপর বলবেন","audioUrl":"wbw/028_074_003.mp3","charTypeName":"word"},{"id":61491,"position":4,"arabic":"أَيْنَ","translation":"\"কোথায়","audioUrl":"wbw/028_074_004.mp3","charTypeName":"word"},{"id":61492,"position":5,"arabic":"شُرَكَآءِىَ","translation":"(তোমাদের বানানো) আমার শরিকরা","audioUrl":"wbw/028_074_005.mp3","charTypeName":"word"},{"id":61493,"position":6,"arabic":"ٱلَّذِينَ","translation":"যাদেরকে","audioUrl":"wbw/028_074_006.mp3","charTypeName":"word"},{"id":61494,"position":7,"arabic":"كُنتُمْ","translation":"তোমরা ছিলে তোমরা ধারণা করতে শরিক হিসেবে","audioUrl":"wbw/028_074_007.mp3","charTypeName":"word"},{"id":61495,"position":8,"arabic":"تَزْعُمُونَ","translation":"\"","audioUrl":"wbw/028_074_008.mp3","charTypeName":"word"},{"id":61496,"position":9,"arabic":"٧٤","translation":"(৭৪)","audioUrl":null,"charTypeName":"end"}]},{"number":75,"arabic":"وَنَزَعْنَا مِن كُلِّ أُمَّةٍۢ شَهِيدًۭا فَقُلْنَا هَاتُوا۟ بُرْهَٰنَكُمْ فَعَلِمُوٓا۟ أَنَّ ٱلْحَقَّ لِلَّهِ وَضَلَّ عَنْهُم مَّا كَانُوا۟ يَفْتَرُونَ","translation":"And [they will remain silent: for by then] We will have called forth witnesses from within every community, and will have said [unto the sinners]: “Produce an evidence for what you have been claim­ing!” And so they will come to understand that all truth is God’s [alone]; and all their false imagery will have forsaken them.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3327.mp3","surahId":28,"words":[{"id":62072,"position":1,"arabic":"وَنَزَعْنَا","translation":"বের করে আনবো আমরা","audioUrl":"wbw/028_075_001.mp3","charTypeName":"word"},{"id":62073,"position":2,"arabic":"مِن","translation":"হ'তে","audioUrl":"wbw/028_075_002.mp3","charTypeName":"word"},{"id":62074,"position":3,"arabic":"كُلِّ","translation":"প্রত্যেক","audioUrl":"wbw/028_075_003.mp3","charTypeName":"word"},{"id":62075,"position":4,"arabic":"أُمَّةٍۢ","translation":"জাতি","audioUrl":"wbw/028_075_004.mp3","charTypeName":"word"},{"id":62076,"position":5,"arabic":"شَهِيدًۭا","translation":"একজন সাক্ষী","audioUrl":"wbw/028_075_005.mp3","charTypeName":"word"},{"id":62077,"position":6,"arabic":"فَقُلْنَا","translation":"অতঃপর আমরা বলবো","audioUrl":"wbw/028_075_006.mp3","charTypeName":"word"},{"id":62078,"position":7,"arabic":"هَاتُوا۟","translation":"\"তোমরা উপস্হিত করো","audioUrl":"wbw/028_075_007.mp3","charTypeName":"word"},{"id":62079,"position":8,"arabic":"بُرْهَـٰ