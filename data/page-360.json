{"id":360,"ayahs":[{"number":3,"arabic":"وَٱتَّخَذُوا۟ مِن دُونِهِۦٓ ءَالِهَةًۭ لَّا يَخْلُقُونَ شَيْـًۭٔا وَهُمْ يُخْلَقُونَ وَلَا يَمْلِكُونَ لِأَنفُسِهِمْ ضَرًّۭا وَلَا نَفْعًۭا وَلَا يَمْلِكُونَ مَوْتًۭا وَلَا حَيَوٰةًۭ وَلَا نُشُورًۭا","translation":"And yet, some choose to worship, instead of Him, imaginary deities that cannot create anything but are themselves created, and have it not within their power to avert harm from, or bring benefit to, themselves, and have no power over death, nor over life, nor over resurrection!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2858.mp3","surahId":25,"words":[{"id":2822,"position":1,"arabic":"وَٱتَّخَذُوا۟","translation":"আর (কিছু লোক) তারা গ্রহণ করেছে","audioUrl":"wbw/025_003_001.mp3","charTypeName":"word"},{"id":2823,"position":2,"arabic":"مِن","translation":"মধ্য হতে","audioUrl":"wbw/025_003_002.mp3","charTypeName":"word"},{"id":2824,"position":3,"arabic":"دُونِهِۦٓ","translation":"তাঁর পরিবর্তে","audioUrl":"wbw/025_003_003.mp3","charTypeName":"word"},{"id":2825,"position":4,"arabic":"ءَالِهَةًۭ","translation":"ইলাহরূপে (অন্যদেরকে)","audioUrl":"wbw/025_003_004.mp3","charTypeName":"word"},{"id":2826,"position":5,"arabic":"لَّا","translation":"না","audioUrl":"wbw/025_003_005.mp3","charTypeName":"word"},{"id":2827,"position":6,"arabic":"يَخْلُقُونَ","translation":"( সেই ইলাহরা) সৃষ্টি করে","audioUrl":"wbw/025_003_006.mp3","charTypeName":"word"},{"id":2828,"position":7,"arabic":"شَيْـًۭٔا","translation":"কোন কিছু","audioUrl":"wbw/025_003_007.mp3","charTypeName":"word"},{"id":2829,"position":8,"arabic":"وَهُمْ","translation":"অথচ তাদেরকেই","audioUrl":"wbw/025_003_008.mp3","charTypeName":"word"},{"id":2830,"position":9,"arabic":"يُخْلَقُونَ","translation":"সৃষ্টি করা হয়েছে","audioUrl":"wbw/025_003_009.mp3","charTypeName":"word"},{"id":2831,"position":10,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/025_003_010.mp3","charTypeName":"word"},{"id":2832,"position":11,"arabic":"يَمْلِكُونَ","translation":"তারা ক্ষমতা রাখে","audioUrl":"wbw/025_003_011.mp3","charTypeName":"word"},{"id":2833,"position":12,"arabic":"لِأَنفُسِهِمْ","translation":"জন্যেও তাদের নিজেদের","audioUrl":"wbw/025_003_012.mp3","charTypeName":"word"},{"id":2834,"position":13,"arabic":"ضَرًّۭا","translation":"কোন ক্ষতির","audioUrl":"wbw/025_003_013.mp3","charTypeName":"word"},{"id":2835,"position":14,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/025_003_014.mp3","charTypeName":"word"},{"id":2836,"position":15,"arabic":"نَفْعًۭا","translation":"উপকারের","audioUrl":"wbw/025_003_015.mp3","charTypeName":"word"},{"id":2837,"position":16,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/025_003_016.mp3","charTypeName":"word"},{"id":2838,"position":17,"arabic":"يَمْلِكُونَ","translation":"তারা ক্ষমতা রাখে","audioUrl":"wbw/025_003_017.mp3","charTypeName":"word"},{"id":2839,"position":18,"arabic":"مَوْتًۭا","translation":"মৃত্যুর","audioUrl":"wbw/025_003_018.mp3","charTypeName":"word"},{"id":2840,"position":19,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/025_003_019.mp3","charTypeName":"word"},{"id":2841,"position":20,"arabic":"حَيَوٰةًۭ","translation":"জীবনের","audioUrl":"wbw/025_003_020.mp3","charTypeName":"word"},{"id":2842,"position":21,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/025_003_021.mp3","charTypeName":"word"},{"id":2843,"position":22,"arabic":"نُشُورًۭا","translation":"উত্থানের","audioUrl":"wbw/025_003_022.mp3","charTypeName":"word"},{"id":2844,"position":23,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"وَقَالَ ٱلَّذِينَ كَفَرُوٓا۟ إِنْ هَٰذَآ إِلَّآ إِفْكٌ ٱفْتَرَىٰهُ وَأَعَانَهُۥ عَلَيْهِ قَوْمٌ ءَاخَرُونَ ۖ فَقَدْ جَآءُو ظُلْمًۭا وَزُورًۭا","translation":"Moreover, those who are bent on denying the truth are wont to say, “This [Qur’an] is nothing but a lie, which he [himself] has devised with the help of other people, who thereupon have perverted the truth and brought a falsehood into being.”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2859.mp3","surahId":25,"words":[{"id":4192,"position":1,"arabic":"وَقَالَ","translation":"এবং বলে","audioUrl":"wbw/025_004_001.mp3","charTypeName":"word"},{"id":4193,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/025_004_002.mp3","charTypeName":"word"},{"id":4194,"position":3,"arabic":"كَفَرُوٓا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/025_004_003.mp3","charTypeName":"word"},{"id":4195,"position":4,"arabic":"إِنْ","translation":"\"নয়","audioUrl":"wbw/025_004_004.mp3","charTypeName":"word"},{"id":4196,"position":5,"arabic":"هَـٰذَآ","translation":"এই (কুরআন)","audioUrl":"wbw/025_004_005.mp3","charTypeName":"word"},{"id":4197,"position":6,"arabic":"إِلَّآ","translation":"এ ছাড়া","audioUrl":"wbw/025_004_006.mp3","charTypeName":"word"},{"id":4198,"position":7,"arabic":"إِفْكٌ","translation":"মনগড়া জিনিস","audioUrl":"wbw/025_004_007.mp3","charTypeName":"word"},{"id":4199,"position":8,"arabic":"ٱفْتَرَىٰهُ","translation":"তা (মুহাম্মাদ সাল্লাল্লাহু 'অালাইহি ওয়া সাল্লাম) রচনা করেছে","audioUrl":"wbw/025_004_008.mp3","charTypeName":"word"},{"id":4200,"position":9,"arabic":"وَأَعَانَهُۥ","translation":"ও তাকে সাহায্য করেছে","audioUrl":"wbw/025_004_009.mp3","charTypeName":"word"},{"id":4201,"position":10,"arabic":"عَلَيْهِ","translation":"এক্ষেত্রে","audioUrl":"wbw/025_004_010.mp3","charTypeName":"word"},{"id":4202,"position":11,"arabic":"قَوْمٌ","translation":"লোকেরা","audioUrl":"wbw/025_004_011.mp3","charTypeName":"word"},{"id":4203,"position":12,"arabic":"ءَاخَرُونَ ۖ","translation":"অন্য সব\"","audioUrl":"wbw/025_004_012.mp3","charTypeName":"word"},{"id":4205,"position":13,"arabic":"فَقَدْ","translation":"এভাবে নিশ্চয়ই","audioUrl":"wbw/025_004_014.mp3","charTypeName":"word"},{"id":4206,"position":14,"arabic":"جَآءُو","translation":"তারা এসেছে","audioUrl":"wbw/025_004_015.mp3","charTypeName":"word"},{"id":4207,"position":15,"arabic":"ظُلْمًۭا","translation":"সীমালঙ্ঘনে","audioUrl":"wbw/025_004_016.mp3","charTypeName":"word"},{"id":4208,"position":16,"arabic":"وَزُورًۭا","translation":"ও মিথ্যায়","audioUrl":"wbw/025_004_017.mp3","charTypeName":"word"},{"id":4209,"position":17,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"وَقَالُوٓا۟ أَسَٰطِيرُ ٱلْأَوَّلِينَ ٱكْتَتَبَهَا فَهِىَ تُمْلَىٰ عَلَيْهِ بُكْرَةًۭ وَأَصِيلًۭا","translation":"And they say, “Fables of ancient times which he has caused to be written down, so that they might be read out to him at morn and evening!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2860.mp3","surahId":25,"words":[{"id":5459,"position":1,"arabic":"وَقَالُوٓا۟","translation":"এবং তারা বলে","audioUrl":"wbw/025_005_001.mp3","charTypeName":"word"},{"id":5460,"position":2,"arabic":"أَسَـٰطِيرُ","translation":"\"(এই কুরআন) উপকথার সমাহার","audioUrl":"wbw/025_005_002.mp3","charTypeName":"word"},{"id":5461,"position":3,"arabic":"ٱلْأَوَّلِينَ","translation":"পূর্বকালের","audioUrl":"wbw/025_005_003.mp3","charTypeName":"word"},{"id":5462,"position":4,"arabic":"ٱكْتَتَبَهَا","translation":"তা সে লিখিয়ে নিয়েছে","audioUrl":"wbw/025_005_004.mp3","charTypeName":"word"},{"id":5463,"position":5,"arabic":"فَهِىَ","translation":"অতঃপর তা","audioUrl":"wbw/025_005_005.mp3","charTypeName":"word"},{"id":5464,"position":6,"arabic":"تُمْلَىٰ","translation":"তিলাওয়াত করা হয়","audioUrl":"wbw/025_005_006.mp3","charTypeName":"word"},{"id":5465,"position":7,"arabic":"عَلَيْهِ","translation":"তার নিকট","audioUrl":"wbw/025_005_007.mp3","charTypeName":"word"},{"id":5466,"position":8,"arabic":"بُكْرَةًۭ","translation":"সকালে","audioUrl":"wbw/025_005_008.mp3","charTypeName":"word"},{"id":5467,"position":9,"arabic":"وَأَصِيلًۭا","translation":"ও সন্ধ্যায়\"","audioUrl":"wbw/025_005_009.mp3","charTypeName":"word"},{"id":5468,"position":10,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"قُلْ أَنزَلَهُ ٱلَّذِى يَعْلَمُ ٱلسِّرَّ فِى ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ ۚ إِنَّهُۥ كَانَ غَفُورًۭا رَّحِيمًۭا","translation":"Say [O Muhammad]: “He who knows all the mysteries of the heavens and the earth has bestowed from on high this [Qur’an upon me]! Verily, He is much-forgiving, a dispenser of grace!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2861.mp3","surahId":25,"words":[{"id":6693,"position":1,"arabic":"قُلْ","translation":"বলো (হে নাবী)","audioUrl":"wbw/025_006_001.mp3","charTypeName":"word"},{"id":6694,"position":2,"arabic":"أَنزَلَهُ","translation":"\"তা অবতীর্ণ করেছেন","audioUrl":"wbw/025_006_002.mp3","charTypeName":"word"},{"id":6695,"position":3,"arabic":"ٱلَّذِى","translation":"(এমন সত্ত্বা) যিনি","audioUrl":"wbw/025_006_003.mp3","charTypeName":"word"},{"id":6696,"position":4,"arabic":"يَعْلَمُ","translation":"জানেন","audioUrl":"wbw/025_006_004.mp3","charTypeName":"word"},{"id":6697,"position":5,"arabic":"ٱلسِّرَّ","translation":"(সমুদয়) রহস্য (গোপন)","audioUrl":"wbw/025_006_005.mp3","charTypeName":"word"},{"id":6698,"position":6,"arabic":"فِى","translation":"মধ্যকার","audioUrl":"wbw/025_006_006.mp3","charTypeName":"word"},{"id":6699,"position":7,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশমন্ডলীর","audioUrl":"wbw/025_006_007.mp3","charTypeName":"word"},{"id":6700,"position":8,"arabic":"وَٱلْأَرْضِ ۚ","translation":"ও পৃথিবীর","audioUrl":"wbw/025_006_008.mp3","charTypeName":"word"},{"id":6702,"position":9,"arabic":"إِنَّهُۥ","translation":"নিশ্চয়ই তিনি","audioUrl":"wbw/025_006_010.mp3","charTypeName":"word"},{"id":6703,"position":10,"arabic":"كَانَ","translation":"হলেন","audioUrl":"wbw/025_006_011.mp3","charTypeName":"word"},{"id":6704,"position":11,"arabic":"غَفُورًۭا","translation":"ক্ষমাশীল","audioUrl":"wbw/025_006_012.mp3","charTypeName":"word"},{"id":6705,"position":12,"arabic":"رَّحِيمًۭا","translation":"পরম দয়ালু\"","audioUrl":"wbw/025_006_013.mp3","charTypeName":"word"},{"id":6706,"position":13,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"وَقَالُوا۟ مَالِ هَٰذَا ٱلرَّسُولِ يَأْكُلُ ٱلطَّعَامَ وَيَمْشِى فِى ٱلْأَسْوَاقِ ۙ لَوْلَآ أُنزِلَ إِلَيْهِ مَلَكٌۭ فَيَكُونَ مَعَهُۥ نَذِيرًا","translation":"Yet they say: What sort of apostle is this [man] who eats food [like all other mortals] and goes about in the market places? Why has not an angel [visibly] been sent down unto him, to act as a warner together with him?”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2862.mp3","surahId":25,"words":[{"id":8034,"position":1,"arabic":"وَقَالُوا۟","translation":"এবং তারা বলে","audioUrl":"wbw/025_007_001.mp3","charTypeName":"word"},{"id":8035,"position":2,"arabic":"مَالِ","translation":"\"কেমন","audioUrl":"wbw/025_007_002.mp3","charTypeName":"word"},{"id":8036,"position":3,"arabic":"هَـٰذَا","translation":"এই","audioUrl":"wbw/025_007_003.mp3","charTypeName":"word"},{"id":8037,"position":4,"arabic":"ٱلرَّسُولِ","translation":"রাসূল","audioUrl":"wbw/025_007_004.mp3","charTypeName":"word"},{"id":8038,"position":5,"arabic":"يَأْكُلُ","translation":"সে খায়","audioUrl":"wbw/025_007_005.mp3","charTypeName":"word"},{"id":8039,"position":6,"arabic":"ٱلطَّعَامَ","translation":"খাবার","audioUrl":"wbw/025_007_006.mp3","charTypeName":"word"},{"id":8040,"position":7,"arabic":"وَيَمْشِى","translation":"ও চলাফেরা করে","audioUrl":"wbw/025_007_007.mp3","charTypeName":"word"},{"id":8041,"position":8,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/025_007_008.mp3","charTypeName":"word"},{"id":8042,"position":9,"arabic":"ٱلْأَسْوَاقِ ۙ","translation":"হাট বাজারসমূহে","audioUrl":"wbw/025_007_009.mp3","charTypeName":"word"},{"id":8044,"position":10,"arabic":"لَوْلَآ","translation":"কেন না","audioUrl":"wbw/025_007_011.mp3","charTypeName":"word"},{"id":8045,"position":11,"arabic":"أُنزِلَ","translation":"অবতীর্ণ করা হলো","audioUrl":"wbw/025_007_012.mp3","charTypeName":"word"},{"id":8046,"position":12,"arabic":"إِلَيْهِ","translation":"তার কাছে","audioUrl":"wbw/025_007_013.mp3","charTypeName":"word"},{"id":8047,"position":13,"arabic":"مَلَكٌۭ","translation":"কোন ফেরেশতা","audioUrl":"wbw/025_007_014.mp3","charTypeName":"word"},{"id":8048,"position":14,"arabic":"فَيَكُونَ","translation":"অতঃপর সে হতো","audioUrl":"wbw/025_007_015.mp3","charTypeName":"word"},{"id":8049,"position":15,"arabic":"مَعَهُۥ","translation":"তার সাথে","audioUrl":"wbw/025_007_016.mp3","charTypeName":"word"},{"id":8050,"position":16,"arabic":"نَذِيرًا","translation":"ভীতি প্রদর্শনকারী","audioUrl":"wbw/025_007_017.mp3","charTypeName":"word"},{"id":8051,"position":17,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"أَوْ يُلْقَىٰٓ إِلَيْهِ كَنزٌ أَوْ تَكُونُ لَهُۥ جَنَّةٌۭ يَأْكُلُ مِنْهَا ۚ وَقَالَ ٱلظَّٰلِمُونَ إِن تَتَّبِعُونَ إِلَّا رَجُلًۭا مَّسْحُورًا","translation":"Or: “[Why has not] a treasure been granted to him [by God]?” Or: “He should [at least] have a [bountiful] garden, so that he could eat thereof [without effort]!” And so these evildoers say [unto one another], “If you were to follow [Muhammad, you would follow] but a man bewitched!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2863.mp3","surahId":25,"words":[{"id":9207,"position":1,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/025_008_001.mp3","charTypeName":"word"},{"id":9208,"position":2,"arabic":"يُلْقَىٰٓ","translation":"নিক্ষেপ করা হতো","audioUrl":"wbw/025_008_002.mp3","charTypeName":"word"},{"id":9209,"position":3,"arabic":"إِلَيْهِ","translation":"তার কাছে","audioUrl":"wbw/025_008_003.mp3","charTypeName":"word"},{"id":9210,"position":4,"arabic":"كَنزٌ","translation":"কোন ধনভান্ডার","audioUrl":"wbw/025_008_004.mp3","charTypeName":"word"},{"id":9211,"position":5,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/025_008_005.mp3","charTypeName":"word"},{"id":9212,"position":6,"arabic":"تَكُونُ","translation":"হতো","audioUrl":"wbw/025_008_006.mp3","charTypeName":"word"},{"id":9213,"position":7,"arabic":"لَهُۥ","translation":"জন্যে তার","audioUrl":"wbw/0