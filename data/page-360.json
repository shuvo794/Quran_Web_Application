3","charTypeName":"word"},{"id":11642,"position":5,"arabic":"جَعَلَ","translation":"দিতে পারেন","audioUrl":"wbw/025_010_005.mp3","charTypeName":"word"},{"id":11643,"position":6,"arabic":"لَكَ","translation":"জন্যে তোমার","audioUrl":"wbw/025_010_006.mp3","charTypeName":"word"},{"id":11644,"position":7,"arabic":"خَيْرًۭا","translation":"(আরও) উত্তম","audioUrl":"wbw/025_010_007.mp3","charTypeName":"word"},{"id":11645,"position":8,"arabic":"مِّن","translation":"চেয়েও","audioUrl":"wbw/025_010_008.mp3","charTypeName":"word"},{"id":11646,"position":9,"arabic":"ذَٰلِكَ","translation":"এর","audioUrl":"wbw/025_010_009.mp3","charTypeName":"word"},{"id":11647,"position":10,"arabic":"جَنَّـٰتٍۢ","translation":"(অনেক) বাগান","audioUrl":"wbw/025_010_010.mp3","charTypeName":"word"},{"id":11648,"position":11,"arabic":"تَجْرِى","translation":"প্রবাহিত হয়","audioUrl":"wbw/025_010_011.mp3","charTypeName":"word"},{"id":11649,"position":12,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/025_010_012.mp3","charTypeName":"word"},{"id":11650,"position":13,"arabic":"تَحْتِهَا","translation":"তার নিচ","audioUrl":"wbw/025_010_013.mp3","charTypeName":"word"},{"id":11651,"position":14,"arabic":"ٱلْأَنْهَـٰرُ","translation":"ঝর্ণাধারাসমূহ","audioUrl":"wbw/025_010_014.mp3","charTypeName":"word"},{"id":11652,"position":15,"arabic":"وَيَجْعَل","translation":"এবং দিতে পারেন","audioUrl":"wbw/025_010_015.mp3","charTypeName":"word"},{"id":11653,"position":16,"arabic":"لَّكَ","translation":"জন্যে তোমার","audioUrl":"wbw/025_010_016.mp3","charTypeName":"word"},{"id":11654,"position":17,"arabic":"قُصُورًۢا","translation":"(অনেক) প্রাসাদ","audioUrl":"wbw/025_010_017.mp3","charTypeName":"word"},{"id":11655,"position":18,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"بَلْ كَذَّبُوا۟ بِٱلسَّاعَةِ ۖ وَأَعْتَدْنَا لِمَن كَذَّبَ بِٱلسَّاعَةِ سَعِيرًا","translation":"But nay! It is [the very coming of] the Last Hour to which they give the lie! However, for such 