,"arabic":"قَيِّمَةٌۭ","translation":"সঠিক","audioUrl":"wbw/098_003_003.mp3","charTypeName":"word"},{"id":2910,"position":4,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"وَمَا تَفَرَّقَ ٱلَّذِينَ أُوتُوا۟ ٱلْكِتَٰبَ إِلَّا مِنۢ بَعْدِ مَا جَآءَتْهُمُ ٱلْبَيِّنَةُ","translation":"Now those who have been vouchsafed revelation aforetime did break up their unity [of faith] after such an evidence of the truth had come to them.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6134.mp3","surahId":98,"words":[{"id":3300,"position":1,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/098_004_001.mp3","charTypeName":"word"},{"id":3301,"position":2,"arabic":"تَفَرَّقَ","translation":"বিভেদে লিপ্ত হয়েছে","audioUrl":"wbw/098_004_002.mp3","charTypeName":"word"},{"id":3302,"position":3,"arabic":"ٱلَّذِينَ","translation":"(তারা) যাদের","audioUrl":"wbw/098_004_003.mp3","charTypeName":"word"},{"id":3303,"position":4,"arabic":"أُوتُوا۟","translation":"দেয়া হয়েছিল","audioUrl":"wbw/098_004_004.mp3","charTypeName":"word"},{"id":3304,"position":5,"arabic":"ٱلْكِتَـٰبَ","translation":"কিতাব","audioUrl":"wbw/098_004_005.mp3","charTypeName":"word"},{"id":3305,"position":6,"arabic":"إِلَّا","translation":"তবে","audioUrl":"wbw/098_004_006.mp3","charTypeName":"word"},{"id":3306,"position":7,"arabic":"مِنۢ","translation":"থেকে","audioUrl":"wbw/098_004_007.mp3","charTypeName":"word"},{"id":3307,"position":8,"arabic":"بَعْدِ","translation":"পরে","audioUrl":"wbw/098_004_008.mp3","charTypeName":"word"},{"id":3308,"position":9,"arabic":"مَا","translation":"যা","audioUrl":"wbw/098_004_009.mp3","charTypeName":"word"},{"id":3309,"position":10,"arabic":"جَآءَتْهُمُ","translation":"তাদের কাছে এসেছিল","audioUrl":"wbw/098_004_010.mp3","charTypeName":"word"},{"id":3310,"position":11,"arabic":"ٱلْبَيِّنَةُ","translation":"সুস্পষ্ট প্রমাণ","audioUrl":"wbw/098_004_011.mp3","charTypeName":"word"},{"id":3311,"position":12,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"وَمَآ أُمِرُوٓا۟ إِلَّا لِيَعْبُدُوا۟ ٱللَّهَ مُخْلِصِينَ لَهُ ٱلدِّينَ حُنَفَآءَ وَيُقِيمُوا۟ ٱلصَّلَوٰةَ وَيُؤْتُوا۟ ٱلزَّكَوٰةَ ۚ وَذَٰلِكَ دِينُ ٱلْقَيِّمَةِ","translation":"And withal, they were not enjoined aught but that they should worship God, sincere in their faith in Him alone, turning away from all that is false; and that they should be constant in prayer; and that they should spend in charity: for this is a moral law endowed with ever-true soundness and clarity.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6135.mp3","surahId":98,"words":[{"id":4610,"position":1,"arabic":"وَمَآ","translation":"এবং না","audioUrl":"wbw/098_005_001.mp3","charTypeName":"word"},{"id":4611,"position":2,"arabic":"أُمِرُوٓا۟","translation":"তারা আদিষ্ট হয়েছে","audioUrl":"wbw/098_005_002.mp3","charTypeName":"word"},{"id":4612,"position":3,"arabic":"إِلَّا","translation":"এ ছাড়া যে","audioUrl":"wbw/098_005_003.mp3","charTypeName":"word"},{"id":4613,"position":4,"arabic":"لِيَعْبُدُوا۟","translation":"তারা ইবাদত করুক","audioUrl":"wbw/098_005_004.mp3","charTypeName":"word"},{"id":4614,"position":5,"arabic":"ٱللَّهَ","translation":"আল্লাহর","audioUrl":"wbw/098_005_005.mp3","charTypeName":"word"},{"id":4615,"position":6,"arabic":"مُخْلِصِينَ","translation":"একনিষ্ঠভাবে","audioUrl":"wbw/098_005_006.mp3","charTypeName":"word"},{"id":4616,"position":7,"arabic":"لَهُ","translation":"তাঁরই জন্যে","audioUrl":"wbw/098_005_007.mp3","charTypeName":"word"},{"id":4617,"position":8,"arabic":"ٱلدِّينَ","translation":"আনুগত্যকে","audioUrl":"wbw/098_005_008.mp3","charTypeName":"word"},{"id":4618,"position":9,"arabic":"حُنَفَآءَ","translation":"খাঁটি মনে","audioUrl":"wbw/098_005_009.mp3","charTypeName":"word"},{"id":4619,"position":10,"arabic":"وَيُقِيمُوا۟","translation":"এবং তারা কায়েম করবে","audioUrl":"wbw/098_005_010.mp3","charTypeName":"word"},{"id":4620,"position":11,"arabic":"ٱلصَّلَوٰةَ","