{"id":98,"nameArabic":"سُورَةُ البَيِّنَةِ","nameEnglish":"Al-Bayyina","nameTranslation":"The Evidence","revelationType":"Medinan","numberOfAyahs":8,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ لَمْ يَكُنِ ٱلَّذِينَ كَفَرُوا۟ مِنْ أَهْلِ ٱلْكِتَٰبِ وَٱلْمُشْرِكِينَ مُنفَكِّينَ حَتَّىٰ تَأْتِيَهُمُ ٱلْبَيِّنَةُ","translation":"IT IS NOT [conceivable] that such as are bent on denying the truth - [be they] from among the followers of earlier revelation or from among those who ascribe divinity to aught beside God should ever be abandoned [by Him] ere there comes unto them the [full] evidence of the truth:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6131.mp3","surahId":98,"words":[{"id":122,"position":1,"arabic":"لَمْ","translation":"না","audioUrl":"wbw/098_001_001.mp3","charTypeName":"word"},{"id":123,"position":2,"arabic":"يَكُنِ","translation":"ছিল (প্রস্তুত)","audioUrl":"wbw/098_001_002.mp3","charTypeName":"word"},{"id":124,"position":3,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/098_001_003.mp3","charTypeName":"word"},{"id":125,"position":4,"arabic":"كَفَرُوا۟","translation":"কুফরি করেছে","audioUrl":"wbw/098_001_004.mp3","charTypeName":"word"},{"id":126,"position":5,"arabic":"مِنْ","translation":"মধ্য হতে","audioUrl":"wbw/098_001_005.mp3","charTypeName":"word"},{"id":127,"position":6,"arabic":"أَهْلِ","translation":"অধিকারী","audioUrl":"wbw/098_001_006.mp3","charTypeName":"word"},{"id":128,"position":7,"arabic":"ٱلْكِتَـٰبِ","translation":"কিতাবের","audioUrl":"wbw/098_001_007.mp3","charTypeName":"word"},{"id":129,"position":8,"arabic":"وَٱلْمُشْرِكِينَ","translation":"এবং মুশরিকদের (মধ্য হতে)","audioUrl":"wbw/098_001_008.mp3","charTypeName":"word"},{"id":130,"position":9,"arabic":"مُنفَكِّينَ","translation":"(কুফরী হতে) বিরত","audioUrl":"wbw/098_001_009.mp3","charTypeName":"word"},{"id":131,"position":10,"arabic":"حَتَّىٰ","translation":"যতক্ষণ না","audioUrl":"wbw/098_001_010.mp3","charTypeName":"word"},{"i