{"id":391,"ayahs":[{"number":44,"arabic":"وَمَا كُنتَ بِجَانِبِ ٱلْغَرْبِىِّ إِذْ قَضَيْنَآ إِلَىٰ مُوسَى ٱلْأَمْرَ وَمَا كُنتَ مِنَ ٱلشَّٰهِدِينَ","translation":"NOW [as for thee, O Muhammad,] thou wert not present on the sunset slope [of Mount Sinai] when We imposed the Law upon Moses, nor wert thou among those who witnessed [his times]:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3296.mp3","surahId":28,"words":[{"id":44658,"position":1,"arabic":"وَمَا","translation":"আর (হে নাবী) না","audioUrl":"wbw/028_044_001.mp3","charTypeName":"word"},{"id":44659,"position":2,"arabic":"كُنتَ","translation":"তুমি ছিলে","audioUrl":"wbw/028_044_002.mp3","charTypeName":"word"},{"id":44660,"position":3,"arabic":"بِجَانِبِ","translation":"পাশে","audioUrl":"wbw/028_044_003.mp3","charTypeName":"word"},{"id":44661,"position":4,"arabic":"ٱلْغَرْبِىِّ","translation":"(তুর পাহাড়ের)পশ্চিম","audioUrl":"wbw/028_044_004.mp3","charTypeName":"word"},{"id":44662,"position":5,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/028_044_005.mp3","charTypeName":"word"},{"id":44663,"position":6,"arabic":"قَضَيْنَآ","translation":"দান করেছিলাম আমরা","audioUrl":"wbw/028_044_006.mp3","charTypeName":"word"},{"id":44664,"position":7,"arabic":"إِلَىٰ","translation":"প্রতি","audioUrl":"wbw/028_044_007.mp3","charTypeName":"word"},{"id":44665,"position":8,"arabic":"مُوسَى","translation":"মূসার","audioUrl":"wbw/028_044_008.mp3","charTypeName":"word"},{"id":44666,"position":9,"arabic":"ٱلْأَمْرَ","translation":"বিধান","audioUrl":"wbw/028_044_009.mp3","charTypeName":"word"},{"id":44667,"position":10,"arabic":"وَمَا","translation":"আর না","audioUrl":"wbw/028_044_010.mp3","charTypeName":"word"},{"id":44668,"position":11,"arabic":"كُنتَ","translation":"তুমি ছিলে","audioUrl":"wbw/028_044_011.mp3","charTypeName":"word"},{"id":44669,"position":12,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/028_044_012.mp3","charTypeName":"word"},{"id":44670,"position":13,"arabic":"ٱلشَّـٰهِدِينَ","translation":"প্রত্যক্ষদর্শীদের","audioUrl":"wbw/028_044_013.mp3","charTypeName":"word"},{"id":44671,"position":14,"arabic":"٤٤","translation":"(৪৪)","audioUrl":null,"charTypeName":"end"}]},{"number":45,"arabic":"وَلَٰكِنَّآ أَنشَأْنَا قُرُونًۭا فَتَطَاوَلَ عَلَيْهِمُ ٱلْعُمُرُ ۚ وَمَا كُنتَ ثَاوِيًۭا فِىٓ أَهْلِ مَدْيَنَ تَتْلُوا۟ عَلَيْهِمْ ءَايَٰتِنَا وَلَٰكِنَّا كُنَّا مُرْسِلِينَ","translation":"nay, but [between them and thee] We brought into being [many] generations, and long was their span of life. And neither didst thou dwell among the people of Madyan, conveying Our messages unto them: nay, but We have [always] been sending [Our message-bearers unto man].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3297.mp3","surahId":28,"words":[{"id":45334,"position":1,"arabic":"وَلَـٰكِنَّآ","translation":"কিন্তু আমরা","audioUrl":"wbw/028_045_001.mp3","charTypeName":"word"},{"id":45335,"position":2,"arabic":"أَنشَأْنَا","translation":"সৃষ্টি করেছি আমরা","audioUrl":"wbw/028_045_002.mp3","charTypeName":"word"},{"id":45336,"position":3,"arabic":"قُرُونًۭا","translation":"বহু মানবগোষ্ঠী","audioUrl":"wbw/028_045_003.mp3","charTypeName":"word"},{"id":45337,"position":4,"arabic":"فَتَطَاوَلَ","translation":"অতঃপর দীর্ঘায়িত হয়েছে","audioUrl":"wbw/028_045_004.mp3","charTypeName":"word"},{"id":45338,"position":5,"arabic":"عَلَيْهِمُ","translation":"উপর তাদের","audioUrl":"wbw/028_045_005.mp3","charTypeName":"word"},{"id":45339,"position":6,"arabic":"ٱلْعُمُرُ ۚ","translation":"(বহু) যুগ","audioUrl":"wbw/028_045_006.mp3","charTypeName":"word"},{"id":45341,"position":7,"arabic":"وَمَا","translation":"আর না","audioUrl":"wbw/028_045_008.mp3","charTypeName":"word"},{"id":45342,"position":8,"arabic":"كُنتَ","translation":"তুমি ছিলে","audioUrl":"wbw/028_045_009.mp3","charTypeName":"word"},{"id":45343,"position":9,"arabic":"ثَاوِيًۭا","translation":"বিদ্যমান","audioUrl":"wbw/028_045_010.mp3","charTypeName":"word"},{"id":45344,"position":10,"arabic":"فِىٓ","translation":"মধ্যে","audioUrl":"wbw/028_045_011.mp3","charTypeName":"word"},{"id":45345,"position":11,"arabic":"أَهْلِ","translation":"বাসীদের","audioUrl":"wbw/028_045_012.mp3","charTypeName":"word"},{"id":45346,"position":12,"arabic":"مَدْيَنَ","translation":"মাদয়ান","audioUrl":"wbw/028_045_013.mp3","charTypeName":"word"},{"id":45347,"position":13,"arabic":"تَتْلُوا۟","translation":"তুমি তিলাওয়াত করো (যেন)","audioUrl":"wbw/028_045_014.mp3","charTypeName":"word"},{"id":45348,"position":14,"arabic":"عَلَيْهِمْ","translation":"কাছে তাদের","audioUrl":"wbw/028_045_015.mp3","charTypeName":"word"},{"id":45349,"position":15,"arabic":"ءَايَـٰتِنَا","translation":"আয়াতসমূহ আমাদের","audioUrl":"wbw/028_045_016.mp3","charTypeName":"word"},{"id":45350,"position":16,"arabic":"وَلَـٰكِنَّا","translation":"কিন্তু আমরা","audioUrl":"wbw/028_045_017.mp3","charTypeName":"word"},{"id":45351,"position":17,"arabic":"كُنَّا","translation":"আমরা ছিলাম","audioUrl":"wbw/028_045_018.mp3","charTypeName":"word"},{"id":45352,"position":18,"arabic":"مُرْسِلِينَ","translation":"(রাসূল) প্রেরণকারী","audioUrl":"wbw/028_045_019.mp3","charTypeName":"word"},{"id":45353,"position":19,"arabic":"٤٥","translation":"(৪৫)","audioUrl":null,"charTypeName":"end"}]},{"number":46,"arabic":"وَمَا كُنتَ بِجَانِبِ ٱلطُّورِ إِذْ نَادَيْنَا وَلَٰكِن رَّحْمَةًۭ مِّن رَّبِّكَ لِتُنذِرَ قَوْمًۭا مَّآ أَتَىٰهُم مِّن نَّذِيرٍۢ مِّن قَبْلِكَ لَعَلَّهُمْ يَتَذَكَّرُونَ","translation":"And neither wert thou present on the slope of Mount Sinai when We called out [to Moses]: but [thou, too, art sent] as an act of thy Sustainer’s grace, to warn people to whom no warner has come before thee, so that they might bethink themselves [of Us];","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3298.mp3","surahId":28,"words":[{"id":46074,"position":1,"arabic":"وَمَا","translation":"আর না","audioUrl":"wbw/028_046_001.mp3","charTypeName":"word"},{"id":46075,"position":2,"arabic":"كُنتَ","translation":"তুমি ছিলে","audioUrl":"wbw/028_046_002.mp3","charTypeName":"word"},{"id":46076,"position":3,"arabic":"بِجَانِبِ","translation":"পাশে","audioUrl":"wbw/028_046_003.mp3","charTypeName":"word"},{"id":46077,"position":4,"arabic":"ٱلطُّورِ","translation":"তুর পাহাড়ের","audioUrl":"wbw/028_046_004.mp3","charTypeName":"word"},{"id":46078,"position":5,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/028_046_005.mp3","charTypeName":"word"},{"id":46079,"position":6,"arabic":"نَادَيْنَا","translation":"ডেকে ছিলাম আমরা","audioUrl":"wbw/028_046_006.mp3","charTypeName":"word"},{"id":46080,"position":7,"arabic":"وَلَـٰكِن","translation":"কিন্তু","audioUrl":"wbw/028_046_007.mp3","charTypeName":"word"},{"id":46081,"position":8,"arabic":"رَّحْمَةًۭ","translation":"এটা (অনুগ্রহ)","audioUrl":"wbw/028_046_008.mp3","charTypeName":"word"},{"id":46082,"position":9,"arabic":"مِّن","translation":"পক্ষ হতে","audioUrl":"wbw/028_046_009.mp3","charTypeName":"word"},{"id":46083,"position":10,"arabic":"رَّبِّكَ","translation":"তোমার রবের","audioUrl":"wbw/028_046_010.mp3","charTypeName":"word"},{"id":46084,"position":11,"arabic":"لِتُنذِرَ","translation":"যেন তুমি সতর্ক করো","audioUrl":"wbw/028_046_011.mp3","charTypeName":"word"},{"id":46085,"position":12,"arabic":"قَوْمًۭا","translation":"সম্প্রদায়কে","audioUrl":"wbw/028_046_012.mp3","charTypeName":"word"},{"id":46086,"position":13,"arabic":"مَّآ","translation":"না","audioUrl":"wbw/028_046_013.mp3","charTypeName":"word"},{"id":46087,"position":14,"arabic":"أَتَىٰهُم","translation":"যাদের (নিকট) এসেছে","audioUrl":"wbw/028_046_014.mp3","charTypeName":"word"},{"id":46088,"position":15,"arabic":"مِّن","translation":"কোনো","audioUrl":"wbw/028_046_015.mp3","charTypeName":"word"},{"id":46089,"position":16,"arabic":"نَّذِيرٍۢ","translation":"সতর্ককারী","audioUrl":"wbw/028_046_016.mp3","charTypeName":"word"},{"id":46090,"position":17,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/028_046_017.mp3","charTypeName":"word"},{"id":46091,"position":18,"arabic":"قَبْلِكَ","translation":"তোমার পূর্ব","audioUrl":"wbw/028_046_018.mp3","charTypeName":"word"},{"id":46092,"position":19,"arabic":"لَعَلَّهُمْ","translation":"যাতে তারা","audioUrl":"wbw/028_046_019.mp3","charTypeName":"word"},{"id":46093,"position":20,"arabic":"يَتَذَكَّرُونَ","translation":"উপদেশ গ্রহণ করে","audioUrl":"wbw/028_046_020.mp3","charTypeName":"word"},{"id":46094,"position":21,"arabic":"٤٦","translation":"(৪৬)","audioUrl":null,"charTypeName":"end"}]},{"number":47,"arabic":"وَلَوْلَآ أَن تُصِيبَهُم مُّصِيبَةٌۢ بِمَا قَدَّمَتْ أَيْدِيهِمْ فَيَقُولُوا۟ رَبَّنَا لَوْلَآ أَرْسَلْتَ إِلَيْنَا رَسُولًۭا فَنَتَّبِعَ ءَايَٰتِكَ وَنَكُونَ مِنَ ٱلْمُؤْمِنِينَ","translation":"and [We have sent thee] lest they say [on Judg­ment Day], when disaster befalls them as an outcome of what their own hands have wrought, “O our Sus­tainer, if only Thou had sent an apostle unto us, we would have followed Thy messages, and would have been among those who believe!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3299.mp3","surahId":28,"words":[{"id":46976,"position":1,"arabic":"وَلَوْلَآ","translation":"আর যদি না","audioUrl":"wbw/028_047_001.mp3","charTypeName":"word"},{"id":46977,"position":2,"arabic":"أَن","translation":"(হতো) যে","audioUrl":"wbw/028_047_002.mp3","charTypeName":"word"},{"id":46978,"position":3,"arabic":"تُصِيبَهُم","translation":"তাদের (উপর) পড়তো","audioUrl":"wbw/028_047_003.mp3","charTypeName":"word"},{"id":46979,"position":4,"arabic":"مُّصِيبَةٌۢ","translation":"কোনো বিপদ","audioUrl":"wbw/028_047_004.mp3","charTypeName":"word"},{"id":46980,"position":5,"arabic":"بِمَا","translation":"এ কারণে যা","audioUrl":"wbw/028_047_005.mp3","charTypeName":"word"},{"id":46981,"position":6,"arabic":"قَدَّمَتْ","translation":"আগে পাঠিয়েছে","audioUrl":"wbw/028_047_006.mp3","charTypeName":"word"},{"id":46982,"position":7,"arabic":"أَيْدِيهِمْ","translation":"হাতগুলো তাদের","audioUrl":"wbw/028_047_007.mp3","charTypeName":"word"},{"id":46983,"position":8,"arabic":"فَيَقُولُ