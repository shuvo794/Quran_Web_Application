uchsafed? [For] they do say, “Two examples of delusion, [seemingly] supporting each other!” And they add, “Behold, we refuse to accept either of them as true!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3300.mp3","surahId":28,"words":[{"id":47482,"position":1,"arabic":"فَلَمَّا","translation":"অতঃপর যখন","audioUrl":"wbw/028_048_001.mp3","charTypeName":"word"},{"id":47483,"position":2,"arabic":"جَآءَهُمُ","translation":"আসলো তাদের (কাছে)","audioUrl":"wbw/028_048_002.mp3","charTypeName":"word"},{"id":47484,"position":3,"arabic":"ٱلْحَقُّ","translation":"সত্য","audioUrl":"wbw/028_048_003.mp3","charTypeName":"word"},{"id":47485,"position":4,"arabic":"مِنْ","translation":"হ'তে","audioUrl":"wbw/028_048_004.mp3","charTypeName":"word"},{"id":47486,"position":5,"arabic":"عِندِنَا","translation":"নিকট আমাদের","audioUrl":"wbw/028_048_005.mp3","charTypeName":"word"},{"id":47487,"position":6,"arabic":"قَالُوا۟","translation":"তারা বলে","audioUrl":"wbw/028_048_006.mp3","charTypeName":"word"},{"id":47488,"position":7,"arabic":"لَوْلَآ","translation":"\"কেন না","audioUrl":"wbw/028_048_007.mp3","charTypeName":"word"},{"id":47489,"position":8,"arabic":"أُوتِىَ","translation":"তাকে দেয়া হয়েছে","audioUrl":"wbw/028_048_008.mp3","charTypeName":"word"},{"id":47490,"position":9,"arabic":"مِثْلَ","translation":"(তার) মতো","audioUrl":"wbw/028_048_009.mp3","charTypeName":"word"},{"id":47491,"position":10,"arabic":"مَآ","translation":"যেমন","audioUrl":"wbw/028_048_010.mp3","charTypeName":"word"},{"id":47492,"position":11,"arabic":"أُوتِىَ","translation":"দেয়া হয়েছে","audioUrl":"wbw/028_048_011.mp3","charTypeName":"word"},{"id":47493,"position":12,"arabic":"مُوسَىٰٓ ۚ","translation":"মূসাকে\"","audioUrl":"wbw/028_048_012.mp3","charTypeName":"word"},{"id":47495,"position":13,"arabic":"أَوَلَمْ","translation":"কি নি","audioUrl":"wbw/028_048_014.mp3","charTypeName":"word"},{"id":47496,"position":14,"arabic":"يَكْفُرُوا۟","translation":"তারা অস্বীকার করে","audioUrl":"wbw/028_048_015.mp3","charTypeName":"word"},{"id":47497,"position":15,"arabic":"بِمَآ","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/028_048_016.mp3","charTypeName":"word"},{"id":47498,"position":16,"arabic":"أُوتِىَ","translation":"দেয়া হয়েছিলো","audioUrl":"wbw/028_048_017.mp3","charTypeName":"word"},{"id":47499,"position":17,"arabic":"مُوسَىٰ","translation":"মূসাকে","audioUrl":"wbw/028_048_018.mp3","charTypeName":"word"},{"id":47500,"position":18,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/028_048_019.mp3","charTypeName":"word"},{"id":47501,"position":19,"arabic":"قَبْلُ ۖ","translation":"পূর্ব","audioUrl":"wbw/028_048_020.mp3","charTypeName":"word"},{"id":47503,"position":20,"arabic":"قَالُوا۟","translation":"তারা বললো","audioUrl":"wbw/028_048_022.mp3","charTypeName":"word"},{"id":47504,"position":21,"arabic":"سِحْرَانِ","translation":"\"(ক্বুর'আন ও তাওরাত) এ দু'টিই জ্দু","audioUrl":"wbw/028_048_023.mp3","charTypeName":"word"},{"id":47505,"position":22,"arabic":"تَظَـٰهَرَا","translation":"পরস্পরে সমর্থন করে\"","audioUrl":"wbw/028_048_024.mp3","charTypeName":"word"},{"id":47506,"position":23,"arabic":"وَقَالُوٓا۟","translation":"আরও তারা বললো","audioUrl":"wbw/028_048_025.mp3","charTypeName":"word"},{"id":47507,"position":24,"arabic":"إِنَّا","translation":"\"নিশ্চয়ই আমরা","audioUrl":"wbw/028_048_026.mp3","charTypeName":"word"},{"id":47508,"position":25,"arabic":"بِكُلٍّۢ","translation":"প্রতি প্রত্যেকটির","audioUrl":"wbw/028_048_027.mp3","charTypeName":"word"},{"id":47509,"position":26,"arabic":"كَـٰفِرُونَ","translation":"অস্বীকারকারী\"","audioUrl":"wbw/028_048_028.mp3","charTypeName":"word"},{"id":47510,"position":27,"arabic":"٤٨","translation":"(৪৮)","audioUrl":null,"charTypeName":"end"}]},{"number":49,"arabic":"قُلْ فَأْتُوا۟ بِكِتَٰبٍۢ مِّنْ عِندِ ٱللَّهِ هُوَ أَهْدَىٰ مِنْهُمَآ أَتَّبِعْهُ إِن كُنتُمْ صَٰدِقِينَ","translation":"Say: “Produce, then, [another] revelation from God which would offer better guidance than either of these two [and] I shall