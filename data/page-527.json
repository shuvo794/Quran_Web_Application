{"id":527,"ayahs":[{"number":27,"arabic":"إِنَّ ٱلَّذِينَ لَا يُؤْمِنُونَ بِٱلْءَاخِرَةِ لَيُسَمُّونَ ٱلْمَلَٰٓئِكَةَ تَسْمِيَةَ ٱلْأُنثَىٰ","translation":"Behold, it is [only] such as do not [really] believe in the life to come that regard the angels as female beings;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4811.mp3","surahId":53,"words":[{"id":29618,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/053_027_001.mp3","charTypeName":"word"},{"id":29619,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/053_027_002.mp3","charTypeName":"word"},{"id":29620,"position":3,"arabic":"لَا","translation":"না","audioUrl":"wbw/053_027_003.mp3","charTypeName":"word"},{"id":29621,"position":4,"arabic":"يُؤْمِنُونَ","translation":"ঈমান আনে","audioUrl":"wbw/053_027_004.mp3","charTypeName":"word"},{"id":29622,"position":5,"arabic":"بِٱلْـَٔاخِرَةِ","translation":"আখিরাতের উপর","audioUrl":"wbw/053_027_005.mp3","charTypeName":"word"},{"id":29623,"position":6,"arabic":"لَيُسَمُّونَ","translation":"তারা অবশ্য নাম রাখে","audioUrl":"wbw/053_027_006.mp3","charTypeName":"word"},{"id":29624,"position":7,"arabic":"ٱلْمَلَـٰٓئِكَةَ","translation":"ফেরেশতাদের","audioUrl":"wbw/053_027_007.mp3","charTypeName":"word"},{"id":29625,"position":8,"arabic":"تَسْمِيَةَ","translation":"নামকরণ","audioUrl":"wbw/053_027_008.mp3","charTypeName":"word"},{"id":29626,"position":9,"arabic":"ٱلْأُنثَىٰ","translation":"নারীবাচক","audioUrl":"wbw/053_027_009.mp3","charTypeName":"word"},{"id":29627,"position":10,"arabic":"٢٧","translation":"(২৭)","audioUrl":null,"charTypeName":"end"}]},{"number":28,"arabic":"وَمَا لَهُم بِهِۦ مِنْ عِلْمٍ ۖ إِن يَتَّبِعُونَ إِلَّا ٱلظَّنَّ ۖ وَإِنَّ ٱلظَّنَّ لَا يُغْنِى مِنَ ٱلْحَقِّ شَيْـًۭٔا","translation":"and [since] they have no knowledge whatever thereof, they follow nothing but surmise: yet, behold, never can surmise take the place of truth.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4812.mp3"