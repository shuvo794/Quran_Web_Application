arTypeName":"word"},{"id":30737,"position":17,"arabic":"٢٨","translation":"(২৮)","audioUrl":null,"charTypeName":"end"}]},{"number":29,"arabic":"فَأَعْرِضْ عَن مَّن تَوَلَّىٰ عَن ذِكْرِنَا وَلَمْ يُرِدْ إِلَّا ٱلْحَيَوٰةَ ٱلدُّنْيَا","translation":"Avoid thou, therefore, those who turn away from all remembrance of Us and care for no more than the life of this world,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4813.mp3","surahId":53,"words":[{"id":31783,"position":1,"arabic":"فَأَعْرِضْ","translation":"(হে নবী) অতএব উপেক্ষা করো","audioUrl":"wbw/053_029_001.mp3","charTypeName":"word"},{"id":31784,"position":2,"arabic":"عَن","translation":"থেকে","audioUrl":"wbw/053_029_002.mp3","charTypeName":"word"},{"id":31785,"position":3,"arabic":"مَّن","translation":"তার (তাকে) যে","audioUrl":"wbw/053_029_003.mp3","charTypeName":"word"},{"id":31786,"position":4,"arabic":"تَوَلَّىٰ","translation":"মুখ ফিরায়","audioUrl":"wbw/053_029_004.mp3","charTypeName":"word"},{"id":31787,"position":5,"arabic":"عَن","translation":"হতে","audioUrl":"wbw/053_029_005.mp3","charTypeName":"word"},{"id":31788,"position":6,"arabic":"ذِكْرِنَا","translation":"আমাদের স্মরণ","audioUrl":"wbw/053_029_006.mp3","charTypeName":"word"},{"id":31789,"position":7,"arabic":"وَلَمْ","translation":"এবং না","audioUrl":"wbw/053_029_007.mp3","charTypeName":"word"},{"id":31790,"position":8,"arabic":"يُرِدْ","translation":"চায়","audioUrl":"wbw/053_029_008.mp3","charTypeName":"word"},{"id":31791,"position":9,"arabic":"إِلَّا","translation":"এছাড়া","audioUrl":"wbw/053_029_009.mp3","charTypeName":"word"},{"id":31792,"position":10,"arabic":"ٱلْحَيَوٰةَ","translation":"জীবন","audioUrl":"wbw/053_029_010.mp3","charTypeName":"word"},{"id":31793,"position":11,"arabic":"ٱلدُّنْيَا","translation":"পার্থিব","audioUrl":"wbw/053_029_011.mp3","charTypeName":"word"},{"id":31794,"position":12,"arabic":"٢٩","translation":"(২৯)","audioUrl":null,"charTypeName":"end"}]},{"number":30,"arabic":"ذَٰلِكَ مَبْلَغُهُم مِّنَ ٱلْعِ