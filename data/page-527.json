"word"},{"id":32658,"position":14,"arabic":"أَعْلَمُ","translation":"খুব জানেন","audioUrl":"wbw/053_030_015.mp3","charTypeName":"word"},{"id":32659,"position":15,"arabic":"بِمَنِ","translation":"(তার সম্বন্ধে) কে","audioUrl":"wbw/053_030_016.mp3","charTypeName":"word"},{"id":32660,"position":16,"arabic":"ٱهْتَدَىٰ","translation":"সৎপথ পেয়েছে","audioUrl":"wbw/053_030_017.mp3","charTypeName":"word"},{"id":32661,"position":17,"arabic":"٣٠","translation":"(৩০)","audioUrl":null,"charTypeName":"end"}]},{"number":31,"arabic":"وَلِلَّهِ مَا فِى ٱلسَّمَٰوَٰتِ وَمَا فِى ٱلْأَرْضِ لِيَجْزِىَ ٱلَّذِينَ أَسَٰٓـُٔوا۟ بِمَا عَمِلُوا۟ وَيَجْزِىَ ٱلَّذِينَ أَحْسَنُوا۟ بِٱلْحُسْنَى","translation":"Indeed, unto God belongs all that is in the heavens and all that is on earth: and so He will reward those who do evil in accordance with what they did, and will reward those who do good with ultimate good.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4815.mp3","surahId":53,"words":[{"id":33479,"position":1,"arabic":"وَلِلَّهِ","translation":"এবং আল্লাহরই মালিকানায়","audioUrl":"wbw/053_031_001.mp3","charTypeName":"word"},{"id":33480,"position":2,"arabic":"مَا","translation":"যা কিছু","audioUrl":"wbw/053_031_002.mp3","charTypeName":"word"},{"id":33481,"position":3,"arabic":"فِى","translation":"মধ্যে আছে","audioUrl":"wbw/053_031_003.mp3","charTypeName":"word"},{"id":33482,"position":4,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশের","audioUrl":"wbw/053_031_004.mp3","charTypeName":"word"},{"id":33483,"position":5,"arabic":"وَمَا","translation":"এবং যা কিছু","audioUrl":"wbw/053_031_005.mp3","charTypeName":"word"},{"id":33484,"position":6,"arabic":"فِى","translation":"মধ্যে আছে","audioUrl":"wbw/053_031_006.mp3","charTypeName":"word"},{"id":33485,"position":7,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/053_031_007.mp3","charTypeName":"word"},{"id":33486,"position":8,"arabic":"لِيَجْزِىَ","translation":"প্রতিফল যেন দেন","audioUrl":"wbw/053_031_008.mp3","charTypeName":"word"},{"id":33487,"position":9,"arabic":"ٱلَّذِينَ","translation":"(তাদেরকে) যারা","audioUrl":"wbw/053_031_009.mp3","charTypeName":"word"},{"id":33488,"position":10,"arabic":"أَسَـٰٓـُٔوا۟","translation":"মন্দ করেছে","audioUrl":"wbw/053_031_010.mp3","charTypeName":"word"},{"id":33489,"position":11,"arabic":"بِمَا","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/053_031_011.mp3","charTypeName":"word"},{"id":33490,"position":12,"arabic":"عَمِلُوا۟","translation":"তারা কাজ করেছে","audioUrl":"wbw/053_031_012.mp3","charTypeName":"word"},{"id":33491,"position":13,"arabic":"وَيَجْزِىَ","translation":"এবং প্রতিফল দেন (যেন)","audioUrl":"wbw/053_031_013.mp3","charTypeName":"word"},{"id":33492,"position":14,"arabic":"ٱلَّذِينَ","translation":"(তাদেরকে) যারা","audioUrl":"wbw/053_031_014.mp3","charTypeName":"word"},{"id":33493,"position":15,"arabic":"أَحْسَنُوا۟","translation":"সৎকর্ম করেছে","audioUrl":"wbw/053_031_015.mp3","charTypeName":"word"},{"id":33494,"position":16,"arabic":"بِٱلْحُسْنَى","translation":"উত্তমভাবে (প্রতিফল)","audioUrl":"wbw/053_031_016.mp3","charTypeName":"word"},{"id":33495,"position":17,"arabic":"٣١","translation":"(৩১)","audioUrl":null,"charTypeName":"end"}]},{"number":32,"arabic":"ٱلَّذِينَ يَجْتَنِبُونَ كَبَٰٓئِرَ ٱلْإِثْمِ وَٱلْفَوَٰحِشَ إِلَّا ٱللَّمَمَ ۚ إِنَّ رَبَّكَ وَٰسِعُ ٱلْمَغْفِرَةِ ۚ هُوَ أَعْلَمُ بِكُمْ إِذْ أَنشَأَكُم مِّنَ ٱلْأَرْضِ وَإِذْ أَنتُمْ أَجِنَّةٌۭ فِى بُطُونِ أُمَّهَٰتِكُمْ ۖ فَلَا تُزَكُّوٓا۟ أَنفُسَكُمْ ۖ هُوَ أَعْلَمُ بِمَنِ ٱتَّقَىٰٓ","translation":"As for those who avoid the [truly] grave sins and shameful deeds - even though they may some­times stumble behold, thy Sustainer is abounding in forgiveness. He is fully aware of you when He brings you into being out of dust, and when you are still hidden in your mothers’ wombs: do not, then, consider your­selves pure - [for] He knows best as to who is conscious of Him.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4816.mp3","surahId":53,"words":[{"id":345