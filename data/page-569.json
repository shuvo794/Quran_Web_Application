{"id":569,"ayahs":[{"number":11,"arabic":"يُبَصَّرُونَهُمْ ۚ يَوَدُّ ٱلْمُجْرِمُ لَوْ يَفْتَدِى مِنْ عَذَابِ يَوْمِئِذٍۭ بِبَنِيهِ","translation":"though they may be in one another's sight: [for,] everyone who was lost in sin will on that Day but desire to ransom himself from suffering at the price of his own children,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5386.mp3","surahId":70,"words":[{"id":12843,"position":1,"arabic":"يُبَصَّرُونَهُمْ ۚ","translation":"তাদেরকে দেখানো হবে","audioUrl":"wbw/070_011_001.mp3","charTypeName":"word"},{"id":12845,"position":2,"arabic":"يَوَدُّ","translation":"ইচ্ছা করবে","audioUrl":"wbw/070_011_003.mp3","charTypeName":"word"},{"id":12846,"position":3,"arabic":"ٱلْمُجْرِمُ","translation":"অপরাধী","audioUrl":"wbw/070_011_004.mp3","charTypeName":"word"},{"id":12847,"position":4,"arabic":"لَوْ","translation":"যদি","audioUrl":"wbw/070_011_005.mp3","charTypeName":"word"},{"id":12848,"position":5,"arabic":"يَفْتَدِى","translation":"মুক্তিপন দিতে পারত","audioUrl":"wbw/070_011_006.mp3","charTypeName":"word"},{"id":12849,"position":6,"arabic":"مِنْ","translation":"থেকে","audioUrl":"wbw/070_011_007.mp3","charTypeName":"word"},{"id":12850,"position":7,"arabic":"عَذَابِ","translation":"আযাব","audioUrl":"wbw/070_011_008.mp3","charTypeName":"word"},{"id":12851,"position":8,"arabic":"يَوْمِئِذٍۭ","translation":"সেদিন","audioUrl":"wbw/070_011_009.mp3","charTypeName":"word"},{"id":12852,"position":9,"arabic":"بِبَنِيهِ","translation":"তার সন্তানদের দ্বারা","audioUrl":"wbw/070_011_010.mp3","charTypeName":"word"},{"id":12853,"position":10,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]},{"number":12,"arabic":"وَصَٰحِبَتِهِۦ وَأَخِيهِ","translation":"and of his spouse, and of his brother,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5387.mp3","surahId":70,"words":[{"id":14101,"position":1,"arabic":"وَصَـٰحِبَتِهِۦ","translation":"এবং তার স্ত্রী","audioUrl":"wbw/070_012_001.mp3","charTypeName":"word"},{"id":14102,"position":2,"arabic":"وَأَخِيهِ","translation":"এবং তার ভাই,","audioUrl":"wbw/070_012_002.mp3","charTypeName":"word"},{"id":14103,"position":3,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]},{"number":13,"arabic":"وَفَصِيلَتِهِ ٱلَّتِى تُـْٔوِيهِ","translation":"and of all the kinsfolk who ever sheltered him,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5388.mp3","surahId":70,"words":[{"id":15220,"position":1,"arabic":"وَفَصِيلَتِهِ","translation":"আর তার জ্ঞাতি-গোষ্ঠীকে","audioUrl":"wbw/070_013_001.mp3","charTypeName":"word"},{"id":15221,"position":2,"arabic":"ٱلَّتِى","translation":"যা","audioUrl":"wbw/070_013_002.mp3","charTypeName":"word"},{"id":15222,"position":3,"arabic":"تُـْٔوِيهِ","translation":"তাকে আশ্রয় দেয়","audioUrl":"wbw/070_013_003.mp3","charTypeName":"word"},{"id":15223,"position":4,"arabic":"١٣","translation":"(১৩)","audioUrl":null,"charTypeName":"end"}]},{"number":14,"arabic":"وَمَن فِى ٱلْأَرْضِ جَمِيعًۭا ثُمَّ يُنجِيهِ","translation":"and of whoever [else] lives on earth, all of them - so that he could but save himself.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5389.mp3","surahId":70,"words":[{"id":16256,"position":1,"arabic":"وَمَن","translation":"এবং যা","audioUrl":"wbw/070_014_001.mp3","charTypeName":"word"},{"id":16257,"position":2,"arabic":"فِى","translation":"মধ্যে্","audioUrl":"wbw/070_014_002.mp3","charTypeName":"word"},{"id":16258,"position":3,"arabic":"ٱلْأَرْضِ","translation":"যমীনের","audioUrl":"wbw/070_014_003.mp3","charTypeName":"word"},{"id":16259,"position":4,"arabic":"جَمِيعًۭا","translation":"সবকিছুই","audioUrl":"wbw/070_014_004.mp3","charTypeName":"word"},{"id":16260,"position":5,"arabic":"ثُمَّ","translation":"তারপর","audioUrl":"wbw/070_014_005.mp3","charTypeName":"word"},{"id":16261,"position":6,"arabic":"يُنجِيهِ","translation":"তাকে মুক্তি দিত","audioUrl":"wbw/070_014_006.mp3","charTypeName":"word"},{"id":16262,"position":7,"arabic":"١٤","translation":"(১৪)","audioUrl":null,"charTypeName":"end"}]},{"number":15,"arabic":"كَلَّآ ۖ إِنَّهَا لَظَىٰ","translation":"But nay! Verily, all [that awaits him] is a raging flame,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5390.mp3","surahId":70,"words":[{"id":17440,"position":1,"arabic":"كَلَّآ ۖ","translation":"অবশ্যই নহে!","audioUrl":"wbw/070_015_001.mp3","charTypeName":"word"},{"id":17442,"position":2,"arabic":"إِنَّهَا","translation":"নিশ্চয় তা","audioUrl":"wbw/070_015_003.mp3","charTypeName":"word"},{"id":17443,"position":3,"arabic":"لَظَىٰ","translation":"লেলিহান আগুন","audioUrl":"wbw/070_015_004.mp3","charTypeName":"word"},{"id":17444,"position":4,"arabic":"١٥","translation":"(১৫)","audioUrl":null,"charTypeName":"end"}]},{"number":16,"arabic":"نَزَّاعَةًۭ لِّلشَّوَىٰ","translation":"tearing away his skin!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5391.mp3","surahId":70,"words":[{"id":18505,"position":1,"arabic":"نَزَّاعَةًۭ","translation":"লেহনকারী","audioUrl":"wbw/070_016_001.mp3","charTypeName":"word"},{"id":18506,"position":2,"arabic":"لِّلشَّوَىٰ","translation":"চামড়াকে","audioUrl":"wbw/070_016_002.mp3","charTypeName":"word"},{"id":18507,"position":3,"arabic":"١٦","translation":"(১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":17,"arabic":"تَدْعُوا۟ مَنْ أَدْبَرَ وَتَوَلَّىٰ","translation":"It will claim all such as turn their backs [on what is right], and turn away [from the truth],","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5392.mp3","surahId":70,"words":[{"id":19511,"position":1,"arabic":"تَدْعُوا۟","translation":"আহবান করে","audioUrl":"wbw/070_017_001.mp3","charTypeName":"word"},{"id":19512,"position":2,"arabic":"مَنْ","translation":"যে","audioUrl":"wbw/070_017_002.mp3","charTypeName":"word"},{"id":19513,"position":3,"arabic":"أَدْبَرَ","translation":"পিঠ প্রদর্শন করে","audioUrl":"wbw/070_017_003.mp3","charTypeName":"word"},{"id":19514,"position":4,"arabic":"