","audioUrl":"wbw/070_027_004.mp3","charTypeName":"word"},{"id":30272,"position":5,"arabic":"رَبِّهِم","translation":"তাদের রবের","audioUrl":"wbw/070_027_005.mp3","charTypeName":"word"},{"id":30273,"position":6,"arabic":"مُّشْفِقُونَ","translation":"ভয়কারী","audioUrl":"wbw/070_027_006.mp3","charTypeName":"word"},{"id":30274,"position":7,"arabic":"٢٧","translation":"(২৭)","audioUrl":null,"charTypeName":"end"}]},{"number":28,"arabic":"إِنَّ عَذَابَ رَبِّهِمْ غَيْرُ مَأْمُونٍۢ","translation":"for, behold, of their Sustainer's chastisement none may ever feel [wholly] secure;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5403.mp3","surahId":70,"words":[{"id":30935,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়","audioUrl":"wbw/070_028_001.mp3","charTypeName":"word"},{"id":30936,"position":2,"arabic":"عَذَابَ","translation":"আযাব","audioUrl":"wbw/070_028_002.mp3","charTypeName":"word"},{"id":30937,"position":3,"arabic":"رَبِّهِمْ","translation":"তাদের রবের","audioUrl":"wbw/070_028_003.mp3","charTypeName":"word"},{"id":30938,"position":4,"arabic":"غَيْرُ","translation":"নয়","audioUrl":"wbw/070_028_004.mp3","charTypeName":"word"},{"id":30939,"position":5,"arabic":"مَأْمُونٍۢ","translation":"নিরাপদ","audioUrl":"wbw/070_028_005.mp3","charTypeName":"word"},{"id":30940,"position":6,"arabic":"٢٨","translation":"(২৮)","audioUrl":null,"charTypeName":"end"}]},{"number":29,"arabic":"وَٱلَّذِينَ هُمْ لِفُرُوجِهِمْ حَٰفِظُونَ","translation":"and who are mindful of their chastity,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5404.mp3","surahId":70,"words":[{"id":31958,"position":1,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/070_029_001.mp3","charTypeName":"word"},{"id":31959,"position":2,"arabic":"هُمْ","translation":"[তারা]","audioUrl":"wbw/070_029_002.mp3","charTypeName":"word"},{"id":31960,"position":3,"arabic":"لِفُرُوجِهِمْ","translation":"তাদের যৌনাংগসমূহের","audioUrl":"wbw/070_029_003.mp3","charTypeName":"word"},{"i