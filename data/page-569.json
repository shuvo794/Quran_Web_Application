2747,"position":2,"arabic":"مَسَّهُ","translation":"তাকে স্পর্শ করে","audioUrl":"wbw/070_020_002.mp3","charTypeName":"word"},{"id":22748,"position":3,"arabic":"ٱلشَّرُّ","translation":"মন্দ,","audioUrl":"wbw/070_020_003.mp3","charTypeName":"word"},{"id":22749,"position":4,"arabic":"جَزُوعًۭا","translation":"দুর্দশাগ্রস্ত.","audioUrl":"wbw/070_020_004.mp3","charTypeName":"word"},{"id":22750,"position":5,"arabic":"٢٠","translation":"(২০)","audioUrl":null,"charTypeName":"end"}]},{"number":21,"arabic":"وَإِذَا مَسَّهُ ٱلْخَيْرُ مَنُوعًا","translation":"and whenever good fortune comes to him, he selfishly withholds it [from others].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5396.mp3","surahId":70,"words":[{"id":23903,"position":1,"arabic":"وَإِذَا","translation":"এবং কখন","audioUrl":"wbw/070_021_001.mp3","charTypeName":"word"},{"id":23904,"position":2,"arabic":"مَسَّهُ","translation":"তাকে স্পর্শ করে","audioUrl":"wbw/070_021_002.mp3","charTypeName":"word"},{"id":23905,"position":3,"arabic":"ٱلْخَيْرُ","translation":"কল্যাণ","audioUrl":"wbw/070_021_003.mp3","charTypeName":"word"},{"id":23906,"position":4,"arabic":"مَنُوعًا","translation":"কৃপণ হয়","audioUrl":"wbw/070_021_004.mp3","charTypeName":"word"},{"id":23907,"position":5,"arabic":"٢١","translation":"(২১)","audioUrl":null,"charTypeName":"end"}]},{"number":22,"arabic":"إِلَّا ٱلْمُصَلِّينَ","translation":"Not so, however, those who consciously turn towards God in prayer.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5397.mp3","surahId":70,"words":[{"id":24909,"position":1,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/070_022_001.mp3","charTypeName":"word"},{"id":24910,"position":2,"arabic":"ٱلْمُصَلِّينَ","translation":"নামাযিরা","audioUrl":"wbw/070_022_002.mp3","charTypeName":"word"},{"id":24911,"position":3,"arabic":"٢٢","translation":"(২২)","audioUrl":null,"charTypeName":"end"}]},{"number":23,"arabic":"ٱلَّذِينَ هُمْ عَلَىٰ صَلَاتِهِمْ دَآئِمُونَ","translation":"[and] who incessantly persevere in their prayer","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5398.mp3","surahId":70,"words":[{"id":26118,"position":1,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/070_023_001.mp3","charTypeName":"word"},{"id":26119,"position":2,"arabic":"هُمْ","translation":"[তারা]","audioUrl":"wbw/070_023_002.mp3","charTypeName":"word"},{"id":26120,"position":3,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/070_023_003.mp3","charTypeName":"word"},{"id":26121,"position":4,"arabic":"صَلَاتِهِمْ","translation":"তাদের নামযের","audioUrl":"wbw/070_023_004.mp3","charTypeName":"word"},{"id":26122,"position":5,"arabic":"دَآئِمُونَ","translation":"নিয়মিত","audioUrl":"wbw/070_023_005.mp3","charTypeName":"word"},{"id":26123,"position":6,"arabic":"٢٣","translation":"(২৩)","audioUrl":null,"charTypeName":"end"}]},{"number":24,"arabic":"وَٱلَّذِينَ فِىٓ أَمْوَٰلِهِمْ حَقٌّۭ مَّعْلُومٌۭ","translation":"and in whose possessions there is a due share, acknowledged [by them],","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5399.mp3","surahId":70,"words":[{"id":27029,"position":1,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/070_024_001.mp3","charTypeName":"word"},{"id":27030,"position":2,"arabic":"فِىٓ","translation":"মধ্যে","audioUrl":"wbw/070_024_002.mp3","charTypeName":"word"},{"id":27031,"position":3,"arabic":"أَمْوَٰلِهِمْ","translation":"তাদের সম্পদ","audioUrl":"wbw/070_024_003.mp3","charTypeName":"word"},{"id":27032,"position":4,"arabic":"حَقٌّۭ","translation":"অধিকার","audioUrl":"wbw/070_024_004.mp3","charTypeName":"word"},{"id":27033,"position":5,"arabic":"مَّعْلُومٌۭ","translation":"অবগত","audioUrl":"wbw/070_024_005.mp3","charTypeName":"word"},{"id":27034,"position":6,"arabic":"٢٤","translation":"(২৪)","audioUrl":null,"charTypeName":"end"}]},{"number":25,"arabic":"لِّلسَّآئِلِ وَٱلْمَحْرُومِ","translation":"for such as ask [for help] and such as are deprived [of what is good in life];"