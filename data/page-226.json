{"id":226,"ayahs":[{"number":38,"arabic":"وَيَصْنَعُ ٱلْفُلْكَ وَكُلَّمَا مَرَّ عَلَيْهِ مَلَأٌۭ مِّن قَوْمِهِۦ سَخِرُوا۟ مِنْهُ ۚ قَالَ إِن تَسْخَرُوا۟ مِنَّا فَإِنَّا نَسْخَرُ مِنكُمْ كَمَا تَسْخَرُونَ","translation":"And [so Noah] set himself to building the ark; and every time the great ones of his people passed by him, they scoffed at him. [Thereupon] he said: \"If you are scoffing at us-behold, we are scoffing at you [and your ignorance], just as you are scoffing at us.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1511.mp3","surahId":11,"words":[{"id":39939,"position":1,"arabic":"وَيَصْنَعُ","translation":"এবং সে নির্মাণ করতে লাগলো","audioUrl":"wbw/011_038_001.mp3","charTypeName":"word"},{"id":39940,"position":2,"arabic":"ٱلْفُلْكَ","translation":"একটি নৌযান","audioUrl":"wbw/011_038_002.mp3","charTypeName":"word"},{"id":39941,"position":3,"arabic":"وَكُلَّمَا","translation":"এবং যখনই","audioUrl":"wbw/011_038_003.mp3","charTypeName":"word"},{"id":39942,"position":4,"arabic":"مَرَّ","translation":"অতিক্রম করতো","audioUrl":"wbw/011_038_004.mp3","charTypeName":"word"},{"id":39943,"position":5,"arabic":"عَلَيْهِ","translation":"তার পাশ দিয়ে","audioUrl":"wbw/011_038_005.mp3","charTypeName":"word"},{"id":39944,"position":6,"arabic":"مَلَأٌۭ","translation":"প্রধানেরা","audioUrl":"wbw/011_038_006.mp3","charTypeName":"word"},{"id":39945,"position":7,"arabic":"مِّن","translation":"মধ্যকার","audioUrl":"wbw/011_038_007.mp3","charTypeName":"word"},{"id":39946,"position":8,"arabic":"قَوْمِهِۦ","translation":"তার জাতির","audioUrl":"wbw/011_038_008.mp3","charTypeName":"word"},{"id":39947,"position":9,"arabic":"سَخِرُوا۟","translation":"ঠাট্টা করতো","audioUrl":"wbw/011_038_009.mp3","charTypeName":"word"},{"id":39948,"position":10,"arabic":"مِنْهُ ۚ","translation":"তার সাথে","audioUrl":"wbw/011_038_010.mp3","charTypeName":"word"},{"id":39950,"position":11,"arabic":"قَالَ","translation":"সে বলতো","audioUrl":"wbw/011_038_012.mp3","charTypeName":"word"},{"id":39951,"position":12,"arabic":"إِن","translation":"\"যদি","audioUrl":"wbw/011_038_013.mp3","charTypeName":"word"},{"id":39952,"position":13,"arabic":"تَسْخَرُوا۟","translation":"তোমরা ঠাট্টা করো","audioUrl":"wbw/011_038_014.mp3","charTypeName":"word"},{"id":39953,"position":14,"arabic":"مِنَّا","translation":"আমাদেরকে","audioUrl":"wbw/011_038_015.mp3","charTypeName":"word"},{"id":39954,"position":15,"arabic":"فَإِنَّا","translation":"তবে নিশ্চয়ই আমরাও","audioUrl":"wbw/011_038_016.mp3","charTypeName":"word"},{"id":39955,"position":16,"arabic":"نَسْخَرُ","translation":"আমরা ঠাট্টা করবো","audioUrl":"wbw/011_038_017.mp3","charTypeName":"word"},{"id":39956,"position":17,"arabic":"مِنكُمْ","translation":"তোমাদেরকে","audioUrl":"wbw/011_038_018.mp3","charTypeName":"word"},{"id":39957,"position":18,"arabic":"كَمَا","translation":"যেমন","audioUrl":"wbw/011_038_019.mp3","charTypeName":"word"},{"id":39958,"position":19,"arabic":"تَسْخَرُونَ","translation":"ঠাট্টা করছো তোমরা","audioUrl":"wbw/011_038_020.mp3","charTypeName":"word"},{"id":39959,"position":20,"arabic":"٣٨","translation":"(৩৮)","audioUrl":null,"charTypeName":"end"}]},{"number":39,"arabic":"فَسَوْفَ تَعْلَمُونَ مَن يَأْتِيهِ عَذَابٌۭ يُخْزِيهِ وَيَحِلُّ عَلَيْهِ عَذَابٌۭ مُّقِيمٌ","translation":"But in time you will come to know who it is that [in this world] shall be visited by suffering which will cover him with ignominy, and upon whom long lasting suffering shall alight [in the life to come]!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1512.mp3","surahId":11,"words":[{"id":40419,"position":1,"arabic":"فَسَوْفَ","translation":"অতঃপর শীঘ্রই","audioUrl":"wbw/011_039_001.mp3","charTypeName":"word"},{"id":40420,"position":2,"arabic":"تَعْلَمُونَ","translation":"তোমরা জানবে","audioUrl":"wbw/011_039_002.mp3","charTypeName":"word"},{"id":40421,"position":3,"arabic":"مَن","translation":"কে (সেই)","audioUrl":"wbw/011_039_003.mp3","charTypeName":"word"},{"id":40422,"position":4,"arabic":"يَأْتِيهِ","translation":"তার উপর আসবে","audioUrl":"wbw/011_039_004.mp3","charTypeName":"word"},{"id":40423,"position":5,"arabic":"عَذَابٌۭ","translation":"শাস্তি","audioUrl":"wbw/011_039_005.mp3","charTypeName":"word"},{"id":40424,"position":6,"arabic":"يُخْزِيهِ","translation":"যা তাকে লাঞ্ছিত করবে","audioUrl":"wbw/011_039_006.mp3","charTypeName":"word"},{"id":40425,"position":7,"arabic":"وَيَحِلُّ","translation":"ও অবশ্যম্ভাবী","audioUrl":"wbw/011_039_007.mp3","charTypeName":"word"},{"id":40426,"position":8,"arabic":"عَلَيْهِ","translation":"তার উপর","audioUrl":"wbw/011_039_008.mp3","charTypeName":"word"},{"id":40427,"position":9,"arabic":"عَذَابٌۭ","translation":"শাস্তি","audioUrl":"wbw/011_039_009.mp3","charTypeName":"word"},{"id":40428,"position":10,"arabic":"مُّقِيمٌ","translation":"স্থায়ী\"","audioUrl":"wbw/011_039_010.mp3","charTypeName":"word"},{"id":40429,"position":11,"arabic":"٣٩","translation":"(৩৯)","audioUrl":null,"charTypeName":"end"}]},{"number":40,"arabic":"حَتَّىٰٓ إِذَا جَآءَ أَمْرُنَا وَفَارَ ٱلتَّنُّورُ قُلْنَا ٱحْمِلْ فِيهَا مِن كُلٍّۢ زَوْجَيْنِ ٱثْنَيْنِ وَأَهْلَكَ إِلَّا مَن سَبَقَ عَلَيْهِ ٱلْقَوْلُ وَمَنْ ءَامَنَ ۚ وَمَآ ءَامَنَ مَعَهُۥٓ إِلَّا قَلِيلٌۭ","translation":"[And so it went on] till, when Our judgment came to pass, and waters gushed forth in torrents over the face of the earth, We said [unto Noah]: \"Place on board of this [ark] one pair of each [kind of animal] of either sex, as well as thy family -except those on whom [Our] sentence has already been passed -and all [others] who have attained to faith!\"-for, only a few [of Noah's people] shared his faith.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1513.mp3","surahId":11,"words":[{"id":41567,"position":1,"arabic":"حَتَّىٰٓ","translation":"অবশেষে","audioUrl":"wbw/011_040_001.mp3","charTypeName":"word"},{"id":41568,"position":2,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/011_040_002.mp3","charTypeName":"word"},{"id":41569,"position":3,"arabic":"جَآءَ","translation":"আসলো","audioUrl":"wbw/011_040_003.mp3","charTypeName":"word"},{"id":41570,"position":4,"arabic":"أَمْرُنَا","translation":"আমাদের নির্দেশ","audioUrl":"wbw/011_040_004.mp3","charTypeName":"word"},{"id":41571,"position":5,"arabic":"وَفَارَ","translation":"এবং উথলে উঠলো","audioUrl":"wbw/011_040_005.mp3","charTypeName":"word"},{"id":41572,"position":6,"arabic":"ٱلتَّنُّورُ","translation":"চুলা","audioUrl":"wbw/011_040_006.mp3","charTypeName":"word"},{"id":41573,"position":7,"arabic":"قُلْنَا","translation":"আমরা বললাম","audioUrl":"wbw/011_040_007.mp3","charTypeName":"word"},{"id":41574,"position":8,"arabic":"ٱحْمِلْ","translation":"\"তুলে নাও","audioUrl":"wbw/011_040_008.mp3","charTypeName":"word"},{"id":41575,"position":9,"arabic":"فِيهَا","translation":"তার মধ্যে (নৌযানে)","audioUrl":"wbw/011_040_009.mp3","charTypeName":"word"},{"id":41576,"position":10,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/011_040_010.mp3","charTypeName":"word"},{"id":41577,"position":11,"arabic":"كُلٍّۢ","translation":"প্রত্যেক","audioUrl":"wbw/011_040_011.mp3","charTypeName":"word"},{"id":41578,"position":12,"arabic":"زَوْجَيْنِ","translation":"প্রকারের (জীব-জন্তু)","audioUrl":"wbw/011_040_012.mp3","charTypeName":"word"},{"id":41579,"position":13,"arabic":"ٱثْنَيْنِ","translation":"দুইটি (অর্থাৎ নর ও নারী)","audioUrl":"wbw/011_040_013.mp3","charTypeName":"word"},{"id":41580,"position":14,"arabic":"وَأَهْلَكَ","translation":"এবং তোমার পরিবারকে","audioUrl":"wbw/011_040_014.mp3","charTypeName":"word"},{"id":41581,"position":15,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/011_040_015.mp3","charTypeName":"word"},{"id":41582,"position":16,"arabic":"مَن","translation":"যার (সম্পর্কে)","audioUrl":"wbw/011_040_016.mp3","charTypeName":"word"},{"id":41583,"position":17,"arabic":"سَبَقَ","translation":"পূর্বে হয়েছে","audioUrl":"wbw/011_040_017.mp3","charTypeName":"word"},{"id":41584,"position":18,"arabic":"عَلَيْهِ","translation":"তার বিরুদ্ধে","audioUrl":"wbw/011_040_018.mp3","ch