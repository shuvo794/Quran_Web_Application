/011_042_019.mp3","charTypeName":"word"},{"id":43132,"position":20,"arabic":"٤٢","translation":"(৪২)","audioUrl":null,"charTypeName":"end"}]},{"number":43,"arabic":"قَالَ سَـَٔاوِىٓ إِلَىٰ جَبَلٍۢ يَعْصِمُنِى مِنَ ٱلْمَآءِ ۚ قَالَ لَا عَاصِمَ ٱلْيَوْمَ مِنْ أَمْرِ ٱللَّهِ إِلَّا مَن رَّحِمَ ۚ وَحَالَ بَيْنَهُمَا ٱلْمَوْجُ فَكَانَ مِنَ ٱلْمُغْرَقِينَ","translation":"[But the son] answered: \"I shall betake myself to a mountain that will protect me from the waters.\" Said [Noah]: \"Today there is no protection [for anyone] from God's judgment, save [for] those who have earned [His] mercy!\" And a wave rose up between them, and [the son] was among those who were drowned.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1516.mp3","surahId":11,"words":[{"id":43793,"position":1,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/011_043_001.mp3","charTypeName":"word"},{"id":43794,"position":2,"arabic":"سَـَٔاوِىٓ","translation":"\"আমি শীঘ্রই আশ্রয় নিবো","audioUrl":"wbw/011_043_002.mp3","charTypeName":"word"},{"id":43795,"position":3,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/011_043_003.mp3","charTypeName":"word"},{"id":43796,"position":4,"arabic":"جَبَلٍۢ","translation":"এমন এক পাহাড়ের","audioUrl":"wbw/011_043_004.mp3","charTypeName":"word"},{"id":43797,"position":5,"arabic":"يَعْصِمُنِى","translation":"যা আমাকে রক্ষা করবে","audioUrl":"wbw/011_043_005.mp3","charTypeName":"word"},{"id":43798,"position":6,"arabic":"مِنَ","translation":"থেকে","audioUrl":"wbw/011_043_006.mp3","charTypeName":"word"},{"id":43799,"position":7,"arabic":"ٱلْمَآءِ ۚ","translation":"প্লাবন\"","audioUrl":"wbw/011_043_007.mp3","charTypeName":"word"},{"id":43801,"position":8,"arabic":"قَالَ","translation":"(নূহ) বললো","audioUrl":"wbw/011_043_009.mp3","charTypeName":"word"},{"id":43802,"position":9,"arabic":"لَا","translation":"\"নেই","audioUrl":"wbw/011_043_010.mp3","charTypeName":"word"},{"id":43803,"position":10,"arabic":"عَاصِمَ","translation":"কোন রক্ষাকারী","au