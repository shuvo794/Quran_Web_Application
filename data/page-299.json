{"id":299,"ayahs":[{"number":46,"arabic":"ٱلْمَالُ وَٱلْبَنُونَ زِينَةُ ٱلْحَيَوٰةِ ٱلدُّنْيَا ۖ وَٱلْبَٰقِيَٰتُ ٱلصَّٰلِحَٰتُ خَيْرٌ عِندَ رَبِّكَ ثَوَابًۭا وَخَيْرٌ أَمَلًۭا","translation":"Wealth and children are an adornment of this, world's life: but good deeds, the fruit whereof endures forever, are of far greater merit in thy Sustainer's sight, and a far better source of hope.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2186.mp3","surahId":18,"words":[{"id":45748,"position":1,"arabic":"ٱلْمَالُ","translation":"ধনসম্পদ","audioUrl":"wbw/018_046_001.mp3","charTypeName":"word"},{"id":45749,"position":2,"arabic":"وَٱلْبَنُونَ","translation":"ও সন্তান-সন্ততি","audioUrl":"wbw/018_046_002.mp3","charTypeName":"word"},{"id":45750,"position":3,"arabic":"زِينَةُ","translation":"শোভা","audioUrl":"wbw/018_046_003.mp3","charTypeName":"word"},{"id":45751,"position":4,"arabic":"ٱلْحَيَوٰةِ","translation":"জীবনের","audioUrl":"wbw/018_046_004.mp3","charTypeName":"word"},{"id":45752,"position":5,"arabic":"ٱلدُّنْيَا ۖ","translation":"পার্থিব","audioUrl":"wbw/018_046_005.mp3","charTypeName":"word"},{"id":45754,"position":6,"arabic":"وَٱلْبَـٰقِيَـٰتُ","translation":"স্থায়ী","audioUrl":"wbw/018_046_007.mp3","charTypeName":"word"},{"id":45755,"position":7,"arabic":"ٱلصَّـٰلِحَـٰتُ","translation":"সৎ কাজসমূহ","audioUrl":"wbw/018_046_008.mp3","charTypeName":"word"},{"id":45756,"position":8,"arabic":"خَيْرٌ","translation":"উত্তম","audioUrl":"wbw/018_046_009.mp3","charTypeName":"word"},{"id":45757,"position":9,"arabic":"عِندَ","translation":"কাছে","audioUrl":"wbw/018_046_010.mp3","charTypeName":"word"},{"id":45758,"position":10,"arabic":"رَبِّكَ","translation":"তোমার রবের","audioUrl":"wbw/018_046_011.mp3","charTypeName":"word"},{"id":45759,"position":11,"arabic":"ثَوَابًۭا","translation":"প্রতিফল হিসেবে","audioUrl":"wbw/018_046_012.mp3","charTypeName":"word"},{"id":45760,"position":12,"arabic":"وَخَيْرٌ","translation":"ও উত্তম","audioUrl":"wbw/018_046_013.mp3","charTypeName":"word"},{"id":45761,"position":13,"arabic":"أَمَلًۭا","translation":"আকাঙ্ক্ষা হিসেবে","audioUrl":"wbw/018_046_014.mp3","charTypeName":"word"},{"id":45762,"position":14,"arabic":"٤٦","translation":"(৪৬)","audioUrl":null,"charTypeName":"end"}]},{"number":47,"arabic":"وَيَوْمَ نُسَيِّرُ ٱلْجِبَالَ وَتَرَى ٱلْأَرْضَ بَارِزَةًۭ وَحَشَرْنَٰهُمْ فَلَمْ نُغَادِرْ مِنْهُمْ أَحَدًۭا","translation":"Hence, [bear in mind] the Day, on which We shall cause the mountains to disappear and thou shalt behold the earth void and bare: for [on that Day] We will [resurrect the dead and] gather them all together, leaving out none of them.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2187.mp3","surahId":18,"words":[{"id":46427,"position":1,"arabic":"وَيَوْمَ","translation":"এবং যেদিন","audioUrl":"wbw/018_047_001.mp3","charTypeName":"word"},{"id":46428,"position":2,"arabic":"نُسَيِّرُ","translation":"আমরা চালাবো","audioUrl":"wbw/018_047_002.mp3","charTypeName":"word"},{"id":46429,"position":3,"arabic":"ٱلْجِبَالَ","translation":"পর্বতসমূহকে","audioUrl":"wbw/018_047_003.mp3","charTypeName":"word"},{"id":46430,"position":4,"arabic":"وَتَرَى","translation":"এবং তুমি দেখবে","audioUrl":"wbw/018_047_004.mp3","charTypeName":"word"},{"id":46431,"position":5,"arabic":"ٱلْأَرْضَ","translation":"পৃথিবীকে","audioUrl":"wbw/018_047_005.mp3","charTypeName":"word"},{"id":46432,"position":6,"arabic":"بَارِزَةًۭ","translation":"খোলা মাঠ","audioUrl":"wbw/018_047_006.mp3","charTypeName":"word"},{"id":46433,"position":7,"arabic":"وَحَشَرْنَـٰهُمْ","translation":"এবং আমরা একত্র করবো তাদের","audioUrl":"wbw/018_047_007.mp3","charTypeName":"word"},{"id":46434,"position":8,"arabic":"فَلَمْ","translation":"অতঃপর না","audioUrl":"wbw/018_047_008.mp3","charTypeName":"word"},{"id":46435,"position":9,"arabic":"نُغَادِرْ","translation":"আমরা  ছাড়বো","audioUrl":"wbw/018_047_009.mp3","charTypeName":"word"},{"id":46436,"position":10,"arabic":"مِنْهُمْ","translation":"মধ্য হ'তে তাদের","audioUrl":"wbw/018_047_010.mp3","charTypeName":"word"},{"id":46437,"position":11,"arabic":"أَحَدًۭا","translation":"কাউকে","audioUrl":"wbw/018_047_011.mp3","charTypeName":"word"},{"id":46438,"position":12,"arabic":"٤٧","translation":"(৪৭)","audioUrl":null,"charTypeName":"end"}]},{"number":48,"arabic":"وَعُرِضُوا۟ عَلَىٰ رَبِّكَ صَفًّۭا لَّقَدْ جِئْتُمُونَا كَمَا خَلَقْنَٰكُمْ أَوَّلَ مَرَّةٍۭ ۚ بَلْ زَعَمْتُمْ أَلَّن نَّجْعَلَ لَكُم مَّوْعِدًۭا","translation":"And they will be lined up before thy Sustainer, [and He will say:] \"Now, indeed, you have come unto Us [in a lonely state], even as We created you in the first instances - although you were wont to assert that We would never 'appoint for you a meeting [with Us]!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2188.mp3","surahId":18,"words":[{"id":47395,"position":1,"arabic":"وَعُرِضُوا۟","translation":"এবং তাদের পেশ করা হবে","audioUrl":"wbw/018_048_001.mp3","charTypeName":"word"},{"id":47396,"position":2,"arabic":"عَلَىٰ","translation":"কাছে","audioUrl":"wbw/018_048_002.mp3","charTypeName":"word"},{"id":47397,"position":3,"arabic":"رَبِّكَ","translation":"তোমার রবের","audioUrl":"wbw/018_048_003.mp3","charTypeName":"word"},{"id":47398,"position":4,"arabic":"صَفًّۭا","translation":"সারিবদ্ধভাবে","audioUrl":"wbw/018_048_004.mp3","charTypeName":"word"},{"id":47399,"position":5,"arabic":"لَّقَدْ","translation":"\"নিশ্চয়ই","audioUrl":"wbw/018_048_005.mp3","charTypeName":"word"},{"id":47400,"position":6,"arabic":"جِئْتُمُونَا","translation":"আমাদের কাছে তোমরা এসেছো","audioUrl":"wbw/018_048_006.mp3","charTypeName":"word"},{"id":47401,"position":7,"arabic":"كَمَا","translation":"যেমন","audioUrl":"wbw/018_048_007.mp3","charTypeName":"word"},{"id":47402,"position":8,"arabic":"خَلَقْنَـٰكُمْ","translation":"আমরা সৃষ্টি করেছিলাম তোমাদেরকে","audioUrl":"wbw/018_048_008.mp3","charTypeName":"word"},{"id":47403,"position":9,"arabic":"أَوَّلَ","translation":"প্রথম","audioUrl":"wbw/018_048_009.mp3","charTypeName":"word"},{"id":47404,"position":10,"arabic":"مَرَّةٍۭ ۚ","translation":"বার","audioUrl":"wbw/018_048_010.mp3","charTypeName":"word"},{"id":47406,"position":11,"arabic":"بَلْ","translation":"বরং","audioUrl":"wbw/018_048_012.mp3","charTypeName":"word"},{"id":47407,"position":12,"arabic":"زَعَمْتُمْ","translation":"তোমরা ভেবেছিলে","audioUrl":"wbw/018_048_013.mp3","charTypeName":"word"},{"id":47408,"position":13,"arabic":"أَلَّن","translation":"যে কখনও না","audioUrl":"wbw/018_048_014.mp3","charTypeName":"word"},{"id":47409,"position":14,"arabic":"نَّجْعَلَ","translation":"আমরা উপস্থিত করবো","audioUrl":"wbw/018_048_015.mp3","charTypeName":"word"},{"id":47410,"position":15,"arabic":"لَكُم","translation":"জন্যে তোমাদের","audioUrl":"wbw/018_048_016.mp3","charTypeName":"word"},{"id":47411,"position":16,"arabic":"مَّوْعِدًۭا","translation":"প্রতিশ্রুত সময়\"","audioUrl":"wbw/018_048_017.mp3","charTypeName":"word"},{"id":47412,"position":17,"arabic":"٤٨","translation":"(৪৮)","audioUrl":null,"charTypeName":"end"}]},{"number":49,"arabic":"وَوُضِعَ ٱلْكِتَٰبُ فَتَرَى ٱلْمُجْرِمِينَ مُشْفِقِينَ مِمَّا فِيهِ وَيَقُولُونَ يَٰوَيْلَتَنَا مَالِ هَٰذَا ٱلْكِتَٰبِ لَا يُغَادِرُ صَغِيرَةًۭ وَلَا كَبِيرَةً إِلَّآ أَحْصَىٰهَا ۚ وَوَجَدُوا۟ مَا عَمِلُوا۟ حَاضِرًۭا ۗ وَلَا يَظْلِمُ رَبُّكَ أَحَدًۭا","translation":"And the record [of everyone's deeds] will be laid open; and thou wilt behold the guilty filled with dread at what [they see] therein; and they will exclaim: \"Oh, woe unto us! What a record is this! It leaves out nothing, be it small or great, but takes everything into account!\" For they will find all that they ever wrought [now] facing them, and [will know that] thy Sustainer does not wrong anyone.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2189.mp3","surahId":18,"words":[{"id":48012,"position":1,"arabic":"وَوُضِعَ","translation":"এবং রাখা হবে","audioUrl":"wbw/018_049_001.mp3","charTypeName":"word"},{"id":48013,"position":2,"arabic":"ٱلْكِتَـٰبُ","translation":"(হিসেবের) কিতাব","audioUrl":"wbw/018_049_002.mp3","charTypeName":"word"},{"id":48014,"position":3,"arabic":"فَتَرَى","translation":"অতঃপর তুমি দেখবে","audioUrl":"wbw/018_049_003.mp3","charTypeName":"word"},{"id":48015,"position":4,"arabic":"ٱلْمُجْرِمِينَ","translation":"অপরাধীদেরকে","audioUrl":"wbw/018_049_004.mp3","charTypeName":"word"},{"id":48016,"position":5,"arabic":"مُشْفِقِينَ","translation":"আতঙ্কগ্রস্ত","audioUrl":"wbw/018_049_005.mp3","charTypeName":"word"},{"id":48017,"position":6,"arabic":"مِمَّا","translation":"তা থেকে যা","audioUrl":"wbw/018_049_006.mp3","charTypeName":"word"},{"id":48018,"position":7,"arabic":"فِيهِ","translation":"মধ্যে আছে তার","audioUrl":"wbw/018_049_007.mp3","charTypeName":"word"},{"id":48019,"position":8,"arabic":"وَيَقُولُونَ","translation":"এবং তারা বলবে","audioUrl":"wbw/018_049_008.mp3","charTypeName":"word"},{"id":48020,"position":9,"arabic":"يَـٰوَيْلَتَنَا","translation":"\"দুর্ভাগ্য হায়! আমাদের","audioUrl":"wbw/018_049_009.mp3","charTypeName":"word"},{"id":48021,"position":10,"arabic":"مَالِ","translation":"কেমন","audioUrl":"wbw/018_049_010.mp3","charTypeName":"word"},{"id":48022,"position":11,"arabic":"هَـٰذَا","translation":"এই","audioUrl":"wbw/018_049_011.mp3","charTypeName":"word"},{"id":48023,"position":12,"arabic":"ٱلْكِتَـٰبِ","translation":"(হিসেবের) কিতাব","audioUrl":"wbw/018_049_012.mp3","charTypeName":"word"},{"id":48024,"position":13,"arabic":"لَا","translation":"না","audioUrl":"wbw/018_049_013.mp3","charTypeName":"word"},{"id":48025,"position":14,"arabic":"يُغَادِرُ","translation":"ছাড়ে","audioUrl":"wbw/018_049_014.mp3","charTypeName":"word"},{"id":48026,"position":15,"arabic":"صَغِيرَةًۭ","translation":"ছোট","audioUrl":"wbw/018_049_015.mp3","charTypeName":"word"},{"id":48027,"position":16,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/018_049_016.mp3","charTypeName":"word"},{"id":48028,"position":17,"arabic":"كَبِيرَةً","translation":"বড়","audioUrl":"wbw/018_049_017.mp3","charTypeName":"word"},{"id":48029,"position":18,"arabic":"إِلَّآ","translation":"কিন্তু","audioUrl":"wbw/018_049_018.mp3","charTypeName":"word"},{"id":48030,"position":19,"arabic":"أَحْصَىٰهَا ۚ","translation":"তা গুনে রেখেছে\"","audioUrl":"wbw/018_049_019.mp3","charTypeName":"word"},{"id":48032,"position":20,"arabic":"وَوَجَدُوا۟","translation":"তারা পাবে","audioUrl":"wbw/018_049_021.mp3","charTypeName":"word"},{"id":48033,"position":21,"arabic":"مَا","translation":"যা","audioUrl":"wbw/018_049_022.mp3","charTypeName":"word"},{"id":48034,"position":22,"arabic":"عَمِلُوا۟","translation":"তারা কাজ করছে","audioUrl":"wbw/018_049_023.mp3","charTypeName":"word"},{"id":48035,"position":23,"arabic":"حَاضِرًۭا ۗ","translation":"উপস্থিত","audioUrl":"wbw/018_049_024.mp3","charTypeName":"word"},{"id":48037,"position":24,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/018_049_026.mp3","charTypeName":"word"},{"id":48038,"position":25,"arabic":"يَظْلِمُ","translation":"অন্যায় করবেন","audioUrl":"wbw/018_049_027.mp3","charTypeName":"word"},{"id":48039,"position":26,"arabic":"رَبُّكَ","translation":"তোমার রব","audioUrl":"wbw/018_049_028.mp3","charTypeName":"word"},{"id":48040,"position":27,"arabic":"أَحَدًۭا","translation":"কাউকে","audioUrl":"wbw/018_049_029.mp3","charTypeName":"word"},{"id":48041,"position":28,"arabic":"٤٩","translation":"(৪৯)","audioUrl":null,"charTypeName":"end"}]},{"number":50,"arabic":"وَإِذْ قُلْنَا لِلْمَلَٰٓئِكَةِ ٱسْجُدُوا۟ لِءَادَمَ فَسَجَدُوٓا۟ إِلَّآ إِبْلِيسَ كَانَ مِنَ ٱلْجِنِّ فَفَسَقَ عَنْ أَمْرِ رَبِّهِۦٓ ۗ أَفَتَتَّخِذُونَهُۥ وَذُرِّيَّتَهُۥٓ أَوْلِيَآءَ مِن دُونِى وَهُمْ لَكُمْ عَدُوٌّۢ ۚ بِئْسَ لِلظَّٰلِمِينَ بَدَلًۭا","translation":"AND [remember that] when We told the angels, \"Prostrate yourselves before Adam,\" they all prostrated themselves, save Iblis: he [too] was one of those invisible beings, but then he turned away from his Sustainer's command. Will you, then, take him and his cohorts for (your], masters instead of Me, although they are your foe? How vile an exchange on the evildoers' part!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2190.mp3","surahId":18,"words":[{"id":48720,"position":1,"arabic":"وَإِذْ","translation":"এবং (স্মরণ করো) যখন","audioUrl":"wbw/018_050_001.mp3","charTypeName":"word"},{"id":48721,"position":2,"arabic":"قُلْنَا","translation":"আমরা বলেছিলাম","audioUrl":"wbw/018_050_002.mp3","charTypeName":"word"},{"id":48722,"position":3,"arabic":"لِلْمَلَـٰٓئِكَةِ","translation":"ফেরেশতাদেরকে","audioUrl":"wbw/018_050_003.mp3","charTypeName":"word"},{"id":48723,"position":4,"arabic":"ٱسْجُدُوا۟","translation":"\"তোমরা সিজদা করো","audioUrl":"wbw/018_050_004.mp3","charTypeName":"word"},{"id":48724,"position":5,"arabic":"لِـَٔادَمَ","translation":"আদমকে\"","audioUrl":"wbw/018_050_005.mp3","charTypeName":"word"},{"id":48725,"position":6,"arabic":"فَسَجَدُوٓا۟","translation":"তখন তারা সিজদা করেছিলো","audioUrl":"wbw/018_050_006.mp3","charTypeName":"word"},{"id":48726,"position":7,"arabic":"إِلَّآ","translation":"ছাড়া","audioUrl":"wbw/018_050_007.mp3","charTypeName":"word"},{"id":48727,"position":8,"arabic":"إِبْلِيسَ","translation":"ইবলীশ","audioUrl":"wbw/018_050_008.mp3","charTypeName":"word"},{"id":48728,"position":9,"arabic":"كَانَ","translation":"সে ছিলো","audioUrl":"wbw/018_050_009.mp3","charTypeName":"word"},{"id":48729,"position":10,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/018_050_010.mp3","charTypeName":"word"},{"id":48730,"position":11,"arabic":"ٱلْجِنِّ","translation":"জিনদের","audioUrl":"wbw/018_050_011.mp3","charTypeName":"word"},{"id":48731,"position":12,"arabic":"فَفَسَقَ","translation":"তাই সে অমান্য করলো","audioUrl":"wbw/018_050_012.mp3","charTypeName":"word"},{"id":48732,"position":13,"arabic":"عَنْ","translation":"থেকে","audioUrl":"wbw/018_050_013.mp3","charTypeName":"word"},{"id":48733,"position":14,"arabic":"أَمْرِ","translation":"নির্দেশ","audioUrl":"wbw/018_050_014.mp3","charTypeName":"word"},{"id":48734,"position":15,"arabic":"رَبِّهِۦٓ ۗ","transl