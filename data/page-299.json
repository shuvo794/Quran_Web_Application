stray.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2191.mp3","surahId":18,"words":[{"id":49244,"position":1,"arabic":"۞ مَّآ","translation":"নি","audioUrl":"wbw/018_051_002.mp3","charTypeName":"word"},{"id":49245,"position":2,"arabic":"أَشْهَدتُّهُمْ","translation":"তাদেরকে আমি সাক্ষী করি","audioUrl":"wbw/018_051_003.mp3","charTypeName":"word"},{"id":49246,"position":3,"arabic":"خَلْقَ","translation":"সৃষ্টিতে","audioUrl":"wbw/018_051_004.mp3","charTypeName":"word"},{"id":49247,"position":4,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশসমূহের","audioUrl":"wbw/018_051_005.mp3","charTypeName":"word"},{"id":49248,"position":5,"arabic":"وَٱلْأَرْضِ","translation":"ও পৃথিবীর","audioUrl":"wbw/018_051_006.mp3","charTypeName":"word"},{"id":49249,"position":6,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/018_051_007.mp3","charTypeName":"word"},{"id":49250,"position":7,"arabic":"خَلْقَ","translation":"সৃষ্টিতে","audioUrl":"wbw/018_051_008.mp3","charTypeName":"word"},{"id":49251,"position":8,"arabic":"أَنفُسِهِمْ","translation":"নিজেদের তাদের","audioUrl":"wbw/018_051_009.mp3","charTypeName":"word"},{"id":49252,"position":9,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/018_051_010.mp3","charTypeName":"word"},{"id":49253,"position":10,"arabic":"كُنتُ","translation":"আমি ছিলাম","audioUrl":"wbw/018_051_011.mp3","charTypeName":"word"},{"id":49254,"position":11,"arabic":"مُتَّخِذَ","translation":"গ্রহণকারী","audioUrl":"wbw/018_051_012.mp3","charTypeName":"word"},{"id":49255,"position":12,"arabic":"ٱلْمُضِلِّينَ","translation":"বিভ্রান্তকারীদেরকে","audioUrl":"wbw/018_051_013.mp3","charTypeName":"word"},{"id":49256,"position":13,"arabic":"عَضُدًۭا","translation":"সাহায্যকারীরূপে","audioUrl":"wbw/018_051_014.mp3","charTypeName":"word"},{"id":49257,"position":14,"arabic":"٥١","translation":"(৫১)","audioUrl":null,"charTypeName":"end"}]},{"number":52,"arabic":"وَيَوْمَ يَقُولُ نَادُوا۟ شُرَكَآءِىَ ٱلَّذِينَ زَعَمْتُمْ فَدَعَوْهُمْ فَلَمْ يَسْتَجِيب