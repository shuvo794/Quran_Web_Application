","charTypeName":"word"},{"id":50001,"position":13,"arabic":"مَّوْبِقًۭا","translation":"ধ্বংসের স্থান","audioUrl":"wbw/018_052_013.mp3","charTypeName":"word"},{"id":50002,"position":14,"arabic":"٥٢","translation":"(৫২)","audioUrl":null,"charTypeName":"end"}]},{"number":53,"arabic":"وَرَءَا ٱلْمُجْرِمُونَ ٱلنَّارَ فَظَنُّوٓا۟ أَنَّهُم مُّوَاقِعُوهَا وَلَمْ يَجِدُوا۟ عَنْهَا مَصْرِفًۭا","translation":"And those who were lost in sin will behold the fire, and will know that they are bound to fall into it, and will find no way of escape therefrom.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2193.mp3","surahId":18,"words":[{"id":50565,"position":1,"arabic":"وَرَءَا","translation":"এবং দেখবে","audioUrl":"wbw/018_053_001.mp3","charTypeName":"word"},{"id":50566,"position":2,"arabic":"ٱلْمُجْرِمُونَ","translation":"অপরাধীরা","audioUrl":"wbw/018_053_002.mp3","charTypeName":"word"},{"id":50567,"position":3,"arabic":"ٱلنَّارَ","translation":"আগুন","audioUrl":"wbw/018_053_003.mp3","charTypeName":"word"},{"id":50568,"position":4,"arabic":"فَظَنُّوٓا۟","translation":"তখন তারা ভাববে","audioUrl":"wbw/018_053_004.mp3","charTypeName":"word"},{"id":50569,"position":5,"arabic":"أَنَّهُم","translation":"যে তারা","audioUrl":"wbw/018_053_005.mp3","charTypeName":"word"},{"id":50570,"position":6,"arabic":"مُّوَاقِعُوهَا","translation":"তাতে ফেলা হবে","audioUrl":"wbw/018_053_006.mp3","charTypeName":"word"},{"id":50571,"position":7,"arabic":"وَلَمْ","translation":"এবং না","audioUrl":"wbw/018_053_007.mp3","charTypeName":"word"},{"id":50572,"position":8,"arabic":"يَجِدُوا۟","translation":"তারা পাবে","audioUrl":"wbw/018_053_008.mp3","charTypeName":"word"},{"id":50573,"position":9,"arabic":"عَنْهَا","translation":"থেকে তা","audioUrl":"wbw/018_053_009.mp3","charTypeName":"word"},{"id":50574,"position":10,"arabic":"مَصْرِفًۭا","translation":"ফিরার স্থান","audioUrl":"wbw/018_053_010.mp3","charTypeName":"word"},{"id":50575,"position":11,"arabic":"٥٣","translation":"(৫৩)","audioUrl