{"id":338,"ayahs":[{"number":47,"arabic":"وَيَسْتَعْجِلُونَكَ بِٱلْعَذَابِ وَلَن يُخْلِفَ ٱللَّهُ وَعْدَهُۥ ۚ وَإِنَّ يَوْمًا عِندَ رَبِّكَ كَأَلْفِ سَنَةٍۢ مِّمَّا تَعُدُّونَ","translation":"And [so, O Muhammad,] they challenge thee to hasten the coming upon them of [God’s] chastisement: but God never fails to fulfill His promise - and, behold, in thy Sustainer’s sight a day is like a thousand years of your reckoning.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2642.mp3","surahId":22,"words":[{"id":46577,"position":1,"arabic":"وَيَسْتَعْجِلُونَكَ","translation":"আর তোমাকে তাড়াতাড়ি করতে বলে","audioUrl":"wbw/022_047_001.mp3","charTypeName":"word"},{"id":46578,"position":2,"arabic":"بِٱلْعَذَابِ","translation":"ব্যাপারে শাস্তির","audioUrl":"wbw/022_047_002.mp3","charTypeName":"word"},{"id":46579,"position":3,"arabic":"وَلَن","translation":"অথচ কখনও না","audioUrl":"wbw/022_047_003.mp3","charTypeName":"word"},{"id":46580,"position":4,"arabic":"يُخْلِفَ","translation":"ভঙ্গ করবেন","audioUrl":"wbw/022_047_004.mp3","charTypeName":"word"},{"id":46581,"position":5,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/022_047_005.mp3","charTypeName":"word"},{"id":46582,"position":6,"arabic":"وَعْدَهُۥ ۚ","translation":"তাঁর প্রতিজ্ঞা","audioUrl":"wbw/022_047_006.mp3","charTypeName":"word"},{"id":46584,"position":7,"arabic":"وَإِنَّ","translation":"আর নিশ্চয়ই","audioUrl":"wbw/022_047_008.mp3","charTypeName":"word"},{"id":46585,"position":8,"arabic":"يَوْمًا","translation":"সেদিন (হবে)","audioUrl":"wbw/022_047_009.mp3","charTypeName":"word"},{"id":46586,"position":9,"arabic":"عِندَ","translation":"নিকট","audioUrl":"wbw/022_047_010.mp3","charTypeName":"word"},{"id":46587,"position":10,"arabic":"رَبِّكَ","translation":"তোমার রবের","audioUrl":"wbw/022_047_011.mp3","charTypeName":"word"},{"id":46588,"position":11,"arabic":"كَأَلْفِ","translation":"মতো এক হাজার","audioUrl":"wbw/022_047_012.mp3","charTypeName":"word"},{"id":46589,"position":12,"arabic":"سَنَةٍۢ","translation":"বছর","audioUrl":"wbw/022_047_013.mp3","charTypeName":"word"},{"id":46590,"position":13,"arabic":"مِّمَّا","translation":"তা হ'তে যা","audioUrl":"wbw/022_047_014.mp3","charTypeName":"word"},{"id":46591,"position":14,"arabic":"تَعُدُّونَ","translation":"তোমরা গণনা করো","audioUrl":"wbw/022_047_015.mp3","charTypeName":"word"},{"id":46592,"position":15,"arabic":"٤٧","translation":"(৪৭)","audioUrl":null,"charTypeName":"end"}]},{"number":48,"arabic":"وَكَأَيِّن مِّن قَرْيَةٍ أَمْلَيْتُ لَهَا وَهِىَ ظَالِمَةٌۭ ثُمَّ أَخَذْتُهَا وَإِلَىَّ ٱلْمَصِيرُ","translation":"And to how many a community that was im­mersed in evildoing have I given rein for a while! But then I took it to task: for with Me is all journeys’ end!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2643.mp3","surahId":22,"words":[{"id":47345,"position":1,"arabic":"وَكَأَيِّن","translation":"আর কত","audioUrl":"wbw/022_048_001.mp3","charTypeName":"word"},{"id":47346,"position":2,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/022_048_002.mp3","charTypeName":"word"},{"id":47347,"position":3,"arabic":"قَرْيَةٍ","translation":"জনবসতির (এমন ছিলো)","audioUrl":"wbw/022_048_003.mp3","charTypeName":"word"},{"id":47348,"position":4,"arabic":"أَمْلَيْتُ","translation":"আমি অবকাশ দিয়েছি","audioUrl":"wbw/022_048_004.mp3","charTypeName":"word"},{"id":47349,"position":5,"arabic":"لَهَا","translation":"জন্যে তাদের","audioUrl":"wbw/022_048_005.mp3","charTypeName":"word"},{"id":47350,"position":6,"arabic":"وَهِىَ","translation":"যখন তা","audioUrl":"wbw/022_048_006.mp3","charTypeName":"word"},{"id":47351,"position":7,"arabic":"ظَالِمَةٌۭ","translation":"সীমালঙ্ঘনকারী (ছিলো)","audioUrl":"wbw/022_048_007.mp3","charTypeName":"word"},{"id":47352,"position":8,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/022_048_008.mp3","charTypeName":"word"},{"id":47353,"position":9,"arabic":"أَخَذْتُهَا","translation":"তাদেরকে আমি পাকড়াও করেছি","audioUrl":"wbw/022_048_009.mp3","charTypeName":"word"},{"id":47354,"position":10,"arabic":"وَإِلَىَّ","translation":"আর নিকট আমারই","audioUrl":"wbw/022_048_010.mp3","charTypeName":"word"},{"id":47355,"position":11,"arabic":"ٱلْمَصِيرُ","translation":"প্রত্যাবর্তন (সকলেরই)","audioUrl":"wbw/022_048_011.mp3","charTypeName":"word"},{"id":47356,"position":12,"arabic":"٤٨","translation":"(৪৮)","audioUrl":null,"charTypeName":"end"}]},{"number":49,"arabic":"قُلْ يَٰٓأَيُّهَا ٱلنَّاسُ إِنَّمَآ أَنَا۠ لَكُمْ نَذِيرٌۭ مُّبِينٌۭ","translation":"SAY [O Muhammad]: “O men! I am but a plain warner [sent by God] unto you!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2644.mp3","surahId":22,"words":[{"id":47890,"position":1,"arabic":"قُلْ","translation":"(হে নাবী) বলো","audioUrl":"wbw/022_049_001.mp3","charTypeName":"word"},{"id":47891,"position":2,"arabic":"يَـٰٓأَيُّهَا","translation":"\"হে","audioUrl":"wbw/022_049_002.mp3","charTypeName":"word"},{"id":47892,"position":3,"arabic":"ٱلنَّاسُ","translation":"\"মানবজাতি","audioUrl":"wbw/022_049_003.mp3","charTypeName":"word"},{"id":47893,"position":4,"arabic":"إِنَّمَآ","translation":"মূলতঃ","audioUrl":"wbw/022_049_004.mp3","charTypeName":"word"},{"id":47894,"position":5,"arabic":"أَنَا۠","translation":"আমি","audioUrl":"wbw/022_049_005.mp3","charTypeName":"word"},{"id":47895,"position":6,"arabic":"لَكُمْ","translation":"জন্যে তোমাদের","audioUrl":"wbw/022_049_006.mp3","charTypeName":"word"},{"id":47896,"position":7,"arabic":"نَذِيرٌۭ","translation":"একজন সতর্ককারী","audioUrl":"wbw/022_049_007.mp3","charTypeName":"word"},{"id":47897,"position":8,"arabic":"مُّبِينٌۭ","translation":"সুস্পষ্ট\"","audioUrl":"wbw/022_049_008.mp3","charTypeName":"word"},{"id":47898,"position":9,"arabic":"٤٩","translation":"(৪৯)","audioUrl":null,"charTypeName":"end"}]},{"number":50,"arabic":"فَٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ لَهُم مَّغْفِرَةٌۭ وَرِزْقٌۭ كَرِيمٌۭ","translation":"And [know that] those who attain to faith and do righteous deeds shall be granted forgiveness of sins and a most excellent sustenance;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2645.mp3","surahId":22,"words":[{"id":48376,"position":1,"arabic":"فَٱلَّذِينَ","translation":"অতঃপর যারা","audioUrl":"wbw/022_050_001.mp3","charTypeName":"word"},{"id":48377,"position":2,"arabic":"ءَامَنُوا۟","translation":"ঈমান আনে","audioUrl":"wbw/022_050_002.mp3","charTypeName":"word"},{"id":48378,"position":3,"arabic":"وَعَمِلُوا۟","translation":"ও কাজ করে","audioUrl":"wbw/022_050_003.mp3","charTypeName":"word"},{"id":48379,"position":4,"arabic":"ٱلصَّـٰلِحَـٰتِ","translation":"সৎকাজসমূহের","audioUrl":"wbw/022_050_004.mp3","charTypeName":"word"},{"id":48380,"position":5,"arabic":"لَهُم","translation":"জন্যে তাদের (রয়েছে)","audioUrl":"wbw/022_050_005.mp3","charTypeName":"word"},{"id":48381,"position":6,"arabic":"مَّغْفِرَةٌۭ","translation":"ক্ষমা","audioUrl":"wbw/022_050_006.mp3","charTypeName":"word"},{"id":48382,"position":7,"arabic":"وَرِزْقٌۭ","translation":"ও জীবিকা","audioUrl":"wbw/022_050_007.mp3","charTypeName":"word"},{"id":48383,"position":8,"arabic":"كَرِيمٌۭ","translation":"সম্মানজনক","audioUrl":"wbw/022_050_008.mp3","charTypeName":"word"},{"id":48384,"position":9,"arabic":"٥٠","translation":"(৫০)","audioUrl":null,"charTypeName":"end"}]},{"number":51,"arabic":"وَٱلَّذِينَ سَعَوْا۟ فِىٓ ءَايَٰتِنَا مُعَٰجِزِينَ أُو۟لَٰٓئِكَ أَصْحَٰبُ ٱلْجَحِيمِ","translation":"whereas those who strive against Our messages, seeking to defeat their purpose - they are destined for the blazing fire.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2646.mp3","surahId":22,"words":[{"id":49230,"position":1,"arabic":"وَٱلَّذِينَ","translation":"আর যারা","audioUrl":"wbw/022_051_001.mp3","charTypeName":"word"},{"id":49231,"position":2,"arabic":"سَعَوْا۟","translation":"চেষ্টা করে","audioUrl":"wbw/022_051_002.mp3","charTypeName":"word"},{"id":49232,"position":3,"arabic":"فِىٓ","translation":"মধ্যে","audioUrl":"wbw/022_051_003.mp3","charTypeName":"word"},{"id":49233,"position":4,"arabic":"ءَايَـٰتِنَا","translation":"আমাদের আয়াত সমূহের","audioUrl":"wbw/022_051_004.mp3","charTypeName":"word"},{"id":49234,"position":5,"arabic":"مُعَـٰجِزِينَ","translation":"ব্যর্থ করে দেখাতে","audioUrl":"wbw/022_051_005.mp3","charTypeName":"word"},{"id":49235,"position":6,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐসবলোক","audioUrl":"wbw/022_051_006.mp3","charTypeName":"word"},{"id":49236,"position":7,"arabic":"أَصْحَـٰبُ","translation":"অধিবাসী","audioUrl":"wbw/022_051_007.mp3","charTypeName":"word"},{"id":49237,"position":8,"arabic":"ٱلْجَحِيمِ","translation":"জাহান্নামের","audioUrl":"wbw/022_051_008.mp3","charTypeName":"word"},{"id":49238,"position":9,"arabic":"٥١","translation":"(৫১)","audioUrl":null,"charTypeName":"end"}]},{"number":52,"arabic":"وَمَآ أَرْسَلْنَا مِن قَبْلِكَ مِن رَّسُولٍۢ وَلَا نَبِىٍّ إِلَّآ إِذَا تَمَنَّىٰٓ أَلْقَى ٱلشَّيْطَٰنُ فِىٓ أُمْنِيَّتِهِۦ فَيَنسَخُ ٱللَّهُ مَا يُلْقِى ٱلشَّيْطَٰنُ ثُمَّ يُحْكِمُ ٱللَّهُ ءَايَٰتِهِۦ ۗ وَٱللَّهُ عَلِيمٌ حَكِيمٌۭ","translation":"Yet whenever We sent forth any apostle or prophet before thee, and he was hoping [that his warnings would be heeded], Satan would cast an asper­sion on his innermost aims: but God renders null and void whatever aspersion Satan may cast; and God makes His messages clear in and by themselves for God is all-knowing, wise.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2647.mp3","surahId":22,"words":[{"id":49904,"position":1,"arabic":"وَمَآ","translation":"এবং না","audioUrl":"wbw/022_052_001.mp3","charTypeName":"word"},{"id":49905,"position":2,"arabic":"أَرْسَلْنَا","translation":"আমরা পাঠিয়েছি","audioUrl":"wbw/022_052_002.mp3","charTypeName":"word"},{"id":49906,"position":3,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/022_052_003.mp3","charTypeName":"word"},{"id":49907,"position":4,"arabic":"قَبْلِكَ","translation":"তোমার পূর্ব","audioUrl":"wbw/022_052_004.mp3","charTypeName":"word"},{"id":49908,"position":5,"arabic":"مِن","transl