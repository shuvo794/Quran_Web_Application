َاسَ وَٱللَّهُ أَحَقُّ أَن تَخْشَىٰهُ ۖ فَلَمَّا قَضَىٰ زَيْدٌۭ مِّنْهَا وَطَرًۭا زَوَّجْنَٰكَهَا لِكَىْ لَا يَكُونَ عَلَى ٱلْمُؤْمِنِينَ حَرَجٌۭ فِىٓ أَزْوَٰجِ أَدْعِيَآئِهِمْ إِذَا قَضَوْا۟ مِنْهُنَّ وَطَرًۭا ۚ وَكَانَ أَمْرُ ٱللَّهِ مَفْعُولًۭا","translation":"AND LO, [O Muhammad,] thou didst say unto the one to whom God had shown favour and to whom thou hadst shown favour, “Hold on to thy wife, and remain conscious of God!” And [thus] wouldst thou hide within thyself something that God was about to bring to light for thou didst stand in awe of [what] people [might think], whereas it was God alone of whom thou shouldst have stood in awe! [But] then, when Zayd had come to the end of his union with her, We gave her to thee in marriage, so that [in future] no blame should attach to the be­lievers for [marrying] the spouses of their adopted children when the latter have come to the end of their union with them. And [thus] God’s will was done.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3570.mp3","surahId":33,"words":[{"id":38904,"position":1,"arabic":"وَإِذْ","translation":"এবং (স্মরণ কর) যখন","audioUrl":"wbw/033_037_001.mp3","charTypeName":"word"},{"id":38905,"position":2,"arabic":"تَقُولُ","translation":"তুমি বলেছিলে","audioUrl":"wbw/033_037_002.mp3","charTypeName":"word"},{"id":38906,"position":3,"arabic":"لِلَّذِىٓ","translation":"উদ্দেশ্যে সেই(ব্যক্তির)","audioUrl":"wbw/033_037_003.mp3","charTypeName":"word"},{"id":38907,"position":4,"arabic":"أَنْعَمَ","translation":"অনুগ্রহ করেছেন (যাকে)","audioUrl":"wbw/033_037_004.mp3","charTypeName":"word"},{"id":38908,"position":5,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/033_037_005.mp3","charTypeName":"word"},{"id":38909,"position":6,"arabic":"عَلَيْهِ","translation":"উপর তার","audioUrl":"wbw/033_037_006.mp3","charTypeName":"word"},{"id":38910,"position":7,"arabic":"وَأَنْعَمْتَ","translation":"ও তুমি অনুগ্রহ করেছো","audioUrl":"wbw/033_037_007.mp3","charTypeName":"word"},{"id":38911,