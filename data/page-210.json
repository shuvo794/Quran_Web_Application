كَلِمَةٌۭ سَبَقَتْ مِن رَّبِّكَ لَقُضِىَ بَيْنَهُمْ فِيمَا فِيهِ يَخْتَلِفُونَ","translation":"AND [know that] all mankind were once but one single community, and only later did they begin to hold divergent views. And had it not been for a decree- that had already gone forth from thy Sustainer, all their differences would indeed have been settled [from the outset].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1383.mp3","surahId":10,"words":[{"id":21726,"position":1,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/010_019_001.mp3","charTypeName":"word"},{"id":21727,"position":2,"arabic":"كَانَ","translation":"ছিলো","audioUrl":"wbw/010_019_002.mp3","charTypeName":"word"},{"id":21728,"position":3,"arabic":"ٱلنَّاسُ","translation":"মানুষ","audioUrl":"wbw/010_019_003.mp3","charTypeName":"word"},{"id":21729,"position":4,"arabic":"إِلَّآ","translation":"এ ছাড়া","audioUrl":"wbw/010_019_004.mp3","charTypeName":"word"},{"id":21730,"position":5,"arabic":"أُمَّةًۭ","translation":"উম্মত","audioUrl":"wbw/010_019_005.mp3","charTypeName":"word"},{"id":21731,"position":6,"arabic":"وَٰحِدَةًۭ","translation":"একই","audioUrl":"wbw/010_019_006.mp3","charTypeName":"word"},{"id":21732,"position":7,"arabic":"فَٱخْتَلَفُوا۟ ۚ","translation":"এরপর তারা মতভেদ করে","audioUrl":"wbw/010_019_007.mp3","charTypeName":"word"},{"id":21734,"position":8,"arabic":"وَلَوْلَا","translation":"এবং যদি না","audioUrl":"wbw/010_019_009.mp3","charTypeName":"word"},{"id":21735,"position":9,"arabic":"كَلِمَةٌۭ","translation":"একটি কথা","audioUrl":"wbw/010_019_010.mp3","charTypeName":"word"},{"id":21736,"position":10,"arabic":"سَبَقَتْ","translation":"পূর্ব ঘোষিত হতে","audioUrl":"wbw/010_019_011.mp3","charTypeName":"word"},{"id":21737,"position":11,"arabic":"مِن","translation":"পক্ষ হতে","audioUrl":"wbw/010_019_012.mp3","charTypeName":"word"},{"id":21738,"position":12,"arabic":"رَّبِّكَ","translation":"তোমার রবের","audioUrl":"wbw/010_019_013.mp3","charTypeName":"word"},{"id":21739,"posi