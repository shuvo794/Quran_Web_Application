{"id":210,"ayahs":[{"number":15,"arabic":"وَإِذَا تُتْلَىٰ عَلَيْهِمْ ءَايَاتُنَا بَيِّنَٰتٍۢ ۙ قَالَ ٱلَّذِينَ لَا يَرْجُونَ لِقَآءَنَا ٱئْتِ بِقُرْءَانٍ غَيْرِ هَٰذَآ أَوْ بَدِّلْهُ ۚ قُلْ مَا يَكُونُ لِىٓ أَنْ أُبَدِّلَهُۥ مِن تِلْقَآئِ نَفْسِىٓ ۖ إِنْ أَتَّبِعُ إِلَّا مَا يُوحَىٰٓ إِلَىَّ ۖ إِنِّىٓ أَخَافُ إِنْ عَصَيْتُ رَبِّى عَذَابَ يَوْمٍ عَظِيمٍۢ","translation":"AND [thus it is:] whenever Our messages are conveyed unto them in all their clarity, those who do not believe that they are destined to meet Us [are wont to] say, \"Bring us a discourse other than this, or alter this one.” Say [O Prophet]: \"It is not conceivable that I should alter it of my own volition; I only follow what is revealed to me. Behold, I would dread, were I [thus] to rebel against my Sustainer, the suffering [which would befall me] on that awesome Day [of Judgment]!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1379.mp3","surahId":10,"words":[{"id":17502,"position":1,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/010_015_001.mp3","charTypeName":"word"},{"id":17503,"position":2,"arabic":"تُتْلَىٰ","translation":"তিলাওয়াত করা হয়","audioUrl":"wbw/010_015_002.mp3","charTypeName":"word"},{"id":17504,"position":3,"arabic":"عَلَيْهِمْ","translation":"নিকট তাদের","audioUrl":"wbw/010_015_003.mp3","charTypeName":"word"},{"id":17505,"position":4,"arabic":"ءَايَاتُنَا","translation":"আয়াতগুলোকে আমাদের","audioUrl":"wbw/010_015_004.mp3","charTypeName":"word"},{"id":17506,"position":5,"arabic":"بَيِّنَـٰتٍۢ ۙ","translation":"সুস্পষ্ট","audioUrl":"wbw/010_015_005.mp3","charTypeName":"word"},{"id":17508,"position":6,"arabic":"قَالَ","translation":"বলে","audioUrl":"wbw/010_015_007.mp3","charTypeName":"word"},{"id":17509,"position":7,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/010_015_008.mp3","charTypeName":"word"},{"id":17510,"position":8,"arabic":"لَا","translation":"না","audioUrl":"wbw/010_015_009.mp3","charTypeName":"word"},{"id":17511,"position":9,"arabic":"يَرْجُونَ","translation":"আশা রাখে","audioUrl":"wbw/010_015_010.mp3","charTypeName":"word"},{"id":17512,"position":10,"arabic":"لِقَآءَنَا","translation":"সাক্ষাতের আমাদের","audioUrl":"wbw/010_015_011.mp3","charTypeName":"word"},{"id":17513,"position":11,"arabic":"ٱئْتِ","translation":"\"আসো","audioUrl":"wbw/010_015_012.mp3","charTypeName":"word"},{"id":17514,"position":12,"arabic":"بِقُرْءَانٍ","translation":"নিয়ে কুরআন","audioUrl":"wbw/010_015_013.mp3","charTypeName":"word"},{"id":17515,"position":13,"arabic":"غَيْرِ","translation":"ছাড়া","audioUrl":"wbw/010_015_014.mp3","charTypeName":"word"},{"id":17516,"position":14,"arabic":"هَـٰذَآ","translation":"এটা (অন্য একটি)","audioUrl":"wbw/010_015_015.mp3","charTypeName":"word"},{"id":17517,"position":15,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/010_015_016.mp3","charTypeName":"word"},{"id":17518,"position":16,"arabic":"بَدِّلْهُ ۚ","translation":"পরিবর্তন করো তা\"","audioUrl":"wbw/010_015_017.mp3","charTypeName":"word"},{"id":17520,"position":17,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/010_015_019.mp3","charTypeName":"word"},{"id":17521,"position":18,"arabic":"مَا","translation":"\"নয়","audioUrl":"wbw/010_015_020.mp3","charTypeName":"word"},{"id":17522,"position":19,"arabic":"يَكُونُ","translation":"সঙ্গত","audioUrl":"wbw/010_015_021.mp3","charTypeName":"word"},{"id":17523,"position":20,"arabic":"لِىٓ","translation":"জন্যে আমার","audioUrl":"wbw/010_015_022.mp3","charTypeName":"word"},{"id":17524,"position":21,"arabic":"أَنْ","translation":"যে","audioUrl":"wbw/010_015_023.mp3","charTypeName":"word"},{"id":17525,"position":22,"arabic":"أُبَدِّلَهُۥ","translation":"পরিবর্তন করবো আমি তা","audioUrl":"wbw/010_015_024.mp3","charTypeName":"word"},{"id":17526,"position":23,"arabic":"مِن","translation":"হতে","audioUrl":"wbw/010_015_025.mp3","charTypeName":"word"},{"id":17527,"position":24,"arabic":"تِلْقَآئِ","translation":"পক্ষ","audioUrl":"wbw/010_015_026.mp3","charTypeName":"word"},{"id":17528,"position":25,"arabic":"نَفْسِىٓ ۖ","translation":"নিজের আমার","audioUrl":"wbw/010_015_027.mp3","charTypeName":"word"},{"id":17530,"position":26,"arabic":"إِنْ","translation":"না","audioUrl":"wbw/010_015_029.mp3","charTypeName":"word"},{"id":17531,"position":27,"arabic":"أَتَّبِعُ","translation":"আমি অনুসরণ করি","audioUrl":"wbw/010_015_030.mp3","charTypeName":"word"},{"id":17532,"position":28,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/010_015_031.mp3","charTypeName":"word"},{"id":17533,"position":29,"arabic":"مَا","translation":"যা","audioUrl":"wbw/010_015_032.mp3","charTypeName":"word"},{"id":17534,"position":30,"arabic":"يُوحَىٰٓ","translation":"ওহী করা হয়","audioUrl":"wbw/010_015_033.mp3","charTypeName":"word"},{"id":17535,"position":31,"arabic":"إِلَىَّ ۖ","translation":"প্রতি আমার","audioUrl":"wbw/010_015_034.mp3","charTypeName":"word"},{"id":17537,"position":32,"arabic":"إِنِّىٓ","translation":"নিশ্চয়ই আমি","audioUrl":"wbw/010_015_036.mp3","charTypeName":"word"},{"id":17538,"position":33,"arabic":"أَخَافُ","translation":"ভয় করি","audioUrl":"wbw/010_015_037.mp3","charTypeName":"word"},{"id":17539,"position":34,"arabic":"إِنْ","translation":"যদি","audioUrl":"wbw/010_015_038.mp3","charTypeName":"word"},{"id":17540,"position":35,"arabic":"عَصَيْتُ","translation":"আমি অবাধ্যতা করি","audioUrl":"wbw/010_015_039.mp3","charTypeName":"word"},{"id":17541,"position":36,"arabic":"رَبِّى","translation":"আমার রবের","audioUrl":"wbw/010_015_040.mp3","charTypeName":"word"},{"id":17542,"position":37,"arabic":"عَذَابَ","translation":"শাস্তির","audioUrl":"wbw/010_015_041.mp3","charTypeName":"word"},{"id":17543,"position":38,"arabic":"يَوْمٍ","translation":"দিনের\"","audioUrl":"wbw/010_015_042.mp3","charTypeName":"word"},{"id":17544,"position":39,"arabic":"عَظِيمٍۢ","translation":"মহা\"","audioUrl":"wbw/010_015_043.mp3","charTypeName":"word"},{"id":17545,"position":40,"arabic":"١٥","translation":"(১৫)","audioUrl":null,"charTypeName":"end"}]},{"number":16,"arabic":"قُل لَّوْ شَآءَ ٱللَّهُ مَا تَلَوْتُهُۥ عَلَيْكُمْ وَلَآ أَدْرَىٰكُم بِهِۦ ۖ فَقَدْ لَبِثْتُ فِيكُمْ عُمُرًۭا مِّن قَبْلِهِۦٓ ۚ أَفَلَا تَعْقِلُونَ","translation":"Say: \"Had God willed it [otherwise], I would not have conveyed this [divine writ] unto you, nor would He have brought it to your knowledge. Indeed. a whole lifetime have I dwelt among you ere this [revelation came unto me]: will you not, then, use your reason?”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1380.mp3","surahId":10,"words":[{"id":18566,"position":1,"arabic":"قُل","translation":"বলো","audioUrl":"wbw/010_016_001.mp3","charTypeName":"word"},{"id":18567,"position":2,"arabic":"لَّوْ","translation":"\"যদি","audioUrl":"wbw/010_016_002.mp3","charTypeName":"word"},{"id":18568,"position":3,"arabic":"شَآءَ","translation":"চাইতেন","audioUrl":"wbw/010_016_003.mp3","charTypeName":"word"},{"id":18569,"position":4,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/010_016_004.mp3","charTypeName":"word"},{"id":18570,"position":5,"arabic":"مَا","translation":"না","audioUrl":"wbw/010_016_005.mp3","charTypeName":"word"},{"id":18571,"position":6,"arabic":"تَلَوْتُهُۥ","translation":"আমি তিলাওয়াত করতাম তা","audioUrl":"wbw/010_016_006.mp3","charTypeName":"word"},{"id":18572,"position":7,"arabic":"عَلَيْكُمْ","translation":"কাছে তোমাদের","audioUrl":"wbw/010_016_007.mp3","charTypeName":"word"},{"id":18573,"position":8,"arabic":"وَلَآ","translation":"এবং না","audioUrl":"wbw/010_016_008.mp3","charTypeName":"word"},{"id":18574,"position":9,"arabic":"أَدْرَىٰكُم","translation":"তিনি জানাতেন তোমাদের","audioUrl":"wbw/010_016_009.mp3","charTypeName":"word"},{"id":18575,"position":10,"arabic":"بِهِۦ ۖ","translation":"সম্বন্ধে তা","audioUrl":"wbw/010_016_010.mp3","charTypeName":"word"},{"id":18577,"position":11,"arabic":"فَقَدْ","translation":"অতঃপর নিশ্চয়ই","audioUrl":"wbw/010_016_012.mp3","charTypeName":"word"},{"id":18578,"position":12,"arabic":"لَبِثْتُ","translation":"আমি অবস্থান করেছি","audioUrl":"wbw/010_016_013.mp3","charTypeName":"word"},{"id":18579,"position":13,"arabic":"فِيكُمْ","translation":"মাঝে তোমাদের","audioUrl":"wbw/010_016_014.mp3","charTypeName":"word"},{"id":18580,"position":14,"arabic":"عُمُرًۭا","translation":"এক বয়স","audioUrl":"wbw/010_016_015.mp3","charTypeName":"word"},{"id":18581,"position":15,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/010_016_016.mp3","charTypeName":"word"},{"id":18582,"position":16,"arabic":"قَبْلِهِۦٓ ۚ","translation":"পূর্ব এর","audioUrl":"wbw/010_016_017.mp3","charTypeName":"word"},{"id":18584,"position":17,"arabic":"أَفَلَا","translation":"কি তবুও না","audioUrl":"wbw/010_016_019.mp3","charTypeName":"word"},{"id":18585,"position":18,"arabic":"تَعْقِلُونَ","translation":"তোমরা বুঝবে\"","audioUrl":"wbw/010_016_020.mp3","charTypeName":"word"},{"id":18586,"position":19,"arabic":"١٦","translation":"(১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":17,"arabic":"فَمَنْ أَظْلَمُ مِمَّنِ ٱفْتَرَىٰ عَلَى ٱللَّهِ كَذِبًا أَوْ كَذَّبَ بِـَٔايَٰتِهِۦٓ ۚ إِنَّهُۥ لَا يُفْلِحُ ٱلْمُجْرِمُونَ","translation":"And who could be more wicked than they who attribute their own lying inventions to God or give the lie to His messages? Verily, those who are lost in sin will never attain to a happy state -","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1381.mp3","surahId":10,"words":[{"id":19581,"position":1,"arabic":"فَمَنْ","translation":"অতএব কে","audioUrl":"wbw/010_017_001.mp3","charTypeName":"word"},{"id":19582,"position":2,"arabic":"أَظْلَمُ","translation":"অধিক সীমালঙ্ঘনকারী (হতে পারে)","audioUrl":"wbw/010_017_002.mp3","charTypeName":"word"},{"id":19583,"position":3,"arabic":"مِمَّنِ","translation":"(তার) চেয়ে যে","audioUrl":"wbw/010_017_003.mp3","charTypeName":"word"},{"id":19584,"position":4,"arabic":"ٱفْتَرَىٰ","translation":"রচনা করে","audioUrl":"wbw/010_017_004.mp3","charTypeName":"word"},{"id":19585,"position":5,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/010_017_005.mp3","charTypeName":"word"},{"id":19586,"position":6,"arabic":"ٱللَّهِ","translation":"আল্লাহ","audioUrl":"wbw/010_017_006.mp3","charTypeName":"word"},{"id":19587,"position":7,"arabic":"كَذِبًا","translation":"মিথ্যা","audioUrl":"wbw/010_017_007.mp3","charTypeName":"word"},{"id":19588,"position":8,"arabic":"أَوْ","translation":"বা","audioUrl":"wbw/010_017_008.mp3","charTypeName":"word"},{"id":19589,"position":9,"arabic":"كَذَّبَ","translation":"মিথ্যারোপ করে","audioUrl":"wbw/010_017_009.mp3","charTypeName":"word"},{"id":19590,"position":10,"arabic":"بِـَٔايَـٰتِهِۦٓ ۚ","translation":"সম্পর্কে তাঁর নিদর্শনগুলো","audioUrl":"wbw/010_017_010.mp3","charTypeName":"word"},{"id":19592,"position":11,"arabic":"إِنَّهُۥ","translation":"নিশ্চয়ই তা","audioUrl":"wbw/010_017_012.mp3","charTypeName":"word"},{"id":19593,"position":12,"arabic":"لَا","translation":"না","audioUrl":"wbw/010_017_013.mp3","charTypeName":"word"},{"id":19594,"position":13,"arabic":"يُفْلِحُ","translation":"সফলকাম হয়","audioUrl":"wbw/010_017_014.mp3","charTypeName":"word"},{"id":19595,"position":14,"arabic":"ٱلْمُجْرِمُونَ","translation":"অপরাধীরা","audioUrl":"wbw/010_017_015.mp3","charTypeName":"word"},{"id":19596,"position":15,"arabic":"١٧","translation":"(১৭)","audioUrl":null,"charTypeName":"end"}]},{"number":18,"arabic":"وَيَعْبُدُونَ مِن دُونِ ٱللَّهِ مَا لَا يَضُرُّهُمْ وَلَا يَنفَعُهُمْ وَيَقُولُونَ هَٰٓؤُلَآءِ شُفَعَٰٓؤُنَا عِندَ ٱللَّهِ ۚ قُلْ أَتُنَبِّـُٔونَ ٱللَّهَ بِمَا لَا يَعْلَمُ فِى ٱلسَّمَٰوَٰتِ وَلَا فِى ٱلْأَرْضِ ۚ سُبْحَٰنَهُۥ وَتَعَٰلَىٰ عَمَّا يُشْرِكُونَ","translation":"and [neither will] they [who] worship, side by side with God, things or beings that can neither harm nor benefit them, saying [to themselves], \"These are our intercessors with God!\" Say: \"Do you [think that you could] inform God of anything in the heavens or on earth that He does not know? Limitless is He in His glory, and sublimely exalted above anything to which men may ascribe a share in His divinity!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1382.mp3","surahId":10,"words":[{"id":20664,"position":1,"arabic":"وَيَعْبُدُونَ","translation":"এবং তারা ইবাদত করে","audioUrl":"wbw/010_018_001.mp3","charTypeName":"word"},{"id":20665,"position":2,"arabic":"مِن","translation":"দিয়ে","audioUrl":"wbw/010_018_002.mp3","charTypeName":"word"},{"id":20666,"position":3,"arabic":"دُونِ","translation":"ছেড়ে","audioUrl":"wbw/010_018_003.mp3","charTypeName":"word"},{"id":20667,"position":4,"arabic":"ٱللَّهِ","translation":"আল্লাহকে","audioUrl":"wbw/010_018_004.mp3","charTypeName":"word"},{"id":20668,"position":5,"arabic":"مَا","translation":"যা","audioUrl":"wbw/010_018_005.mp3","charTypeName":"word"},{"id":20669,"position":6,"arabic":"لَا","translation":"না","audioUrl":"wbw/010_018_006.mp3","charTypeName":"word"},{"id":20670,"position":7,"arabic":"يَضُرُّهُمْ","translation":"ক্ষতি করতে পারে তাদের","audioUrl":"wbw/010_018_007.mp3","charTypeName":"word"},{"id":20671,"position":8,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/010_018_008.mp3","charTypeName":"word"},{"id":20672,"position":9,"arabic":"يَنفَعُهُمْ","translation":"উপকার করতে পারে তাদের","audioUrl":"wbw/010_018_009.mp3","charTypeName":"word"},{"id":20673,"position":10,"arabic":"وَيَقُولُونَ","translation":"এবং তারা বলে","audioUrl":"wbw/010_018_010.mp3","charTypeName":"word"},{"id":20674,"position":11,"arabic":"هَـٰٓؤُلَآءِ","translation":"\"এসব","audioUrl":"wbw/010_018_011.mp3","charTypeName":"word"},{"id":20675,"position":12,"arabic":"شُفَعَـٰٓؤُنَا","translation":"সুপারিশকারী আমাদের","audioUrl":"wbw/010_018_012.mp3","charTypeName":"word"},{"id":20676,"position":13,"arabic":"عِندَ","translation":"কাছে","audioUrl":"wbw/010_018_013.mp3","charTypeName":"word"},{"id":20677,"position":14,"arabic":"ٱللَّهِ ۚ","translation":"আল্লাহর\"","audioUrl":"wbw/010_018_014.mp3","charTypeName":"word"},{"id":20679,"position":15,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/010_018_016.mp3","charTypeName":"word"},{"id":20680