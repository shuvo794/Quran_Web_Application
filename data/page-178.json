{"id":178,"ayahs":[{"number":9,"arabic":"إِذْ تَسْتَغِيثُونَ رَبَّكُمْ فَٱسْتَجَابَ لَكُمْ أَنِّى مُمِدُّكُم بِأَلْفٍۢ مِّنَ ٱلْمَلَٰٓئِكَةِ مُرْدِفِينَ","translation":"Lo! You were praying unto your Sustainer for aid, whereupon He thus responded to you: \"I shall, verily, aid you with a thousand angels following one upon' another!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1169.mp3","surahId":8,"words":[{"id":9940,"position":1,"arabic":"إِذْ","translation":"(স্মরণ করো) যখন","audioUrl":"wbw/008_009_001.mp3","charTypeName":"word"},{"id":9941,"position":2,"arabic":"تَسْتَغِيثُونَ","translation":"তোমরা সাহায্য চেয়েছিলে","audioUrl":"wbw/008_009_002.mp3","charTypeName":"word"},{"id":9942,"position":3,"arabic":"رَبَّكُمْ","translation":"তোমাদের রবের কাছে","audioUrl":"wbw/008_009_003.mp3","charTypeName":"word"},{"id":9943,"position":4,"arabic":"فَٱسْتَجَابَ","translation":"তখন তিনি ডাকে সাড়া দিলেন","audioUrl":"wbw/008_009_004.mp3","charTypeName":"word"},{"id":9944,"position":5,"arabic":"لَكُمْ","translation":"প্রতি তোমাদের","audioUrl":"wbw/008_009_005.mp3","charTypeName":"word"},{"id":9945,"position":6,"arabic":"أَنِّى","translation":"\"(এভাবে) যে আমি","audioUrl":"wbw/008_009_006.mp3","charTypeName":"word"},{"id":9946,"position":7,"arabic":"مُمِدُّكُم","translation":"সাহায্য করছি তোমাদের","audioUrl":"wbw/008_009_007.mp3","charTypeName":"word"},{"id":9947,"position":8,"arabic":"بِأَلْفٍۢ","translation":"দিয়ে এক হাজার","audioUrl":"wbw/008_009_008.mp3","charTypeName":"word"},{"id":9948,"position":9,"arabic":"مِّنَ","translation":"মধ্য হতে","audioUrl":"wbw/008_009_009.mp3","charTypeName":"word"},{"id":9949,"position":10,"arabic":"ٱلْمَلَـٰٓئِكَةِ","translation":"ফেরেশতাদের","audioUrl":"wbw/008_009_010.mp3","charTypeName":"word"},{"id":9950,"position":11,"arabic":"مُرْدِفِينَ","translation":"ধারাবাহিকভাবে আগত\"","audioUrl":"wbw/008_009_011.mp3","charTypeName":"word"},{"id":9951,"position":12,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"وَمَا جَعَلَهُ ٱللَّهُ إِلَّا بُشْرَىٰ وَلِتَطْمَئِنَّ بِهِۦ قُلُوبُكُمْ ۚ وَمَا ٱلنَّصْرُ إِلَّا مِنْ عِندِ ٱللَّهِ ۚ إِنَّ ٱللَّهَ عَزِيزٌ حَكِيمٌ","translation":"And God ordained this only as a glad tiding, and that your hearts should thereby be set at rest-since no succour can come from any save God: verily, God is almighty, wise!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1170.mp3","surahId":8,"words":[{"id":11134,"position":1,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/008_010_001.mp3","charTypeName":"word"},{"id":11135,"position":2,"arabic":"جَعَلَهُ","translation":"করেছিলেন তা","audioUrl":"wbw/008_010_002.mp3","charTypeName":"word"},{"id":11136,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/008_010_003.mp3","charTypeName":"word"},{"id":11137,"position":4,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/008_010_004.mp3","charTypeName":"word"},{"id":11138,"position":5,"arabic":"بُشْرَىٰ","translation":"সুসংবাদ হিসেবে","audioUrl":"wbw/008_010_005.mp3","charTypeName":"word"},{"id":11139,"position":6,"arabic":"وَلِتَطْمَئِنَّ","translation":"এবং যেন প্রশান্ত হয়","audioUrl":"wbw/008_010_006.mp3","charTypeName":"word"},{"id":11140,"position":7,"arabic":"بِهِۦ","translation":"দিয়ে তা","audioUrl":"wbw/008_010_007.mp3","charTypeName":"word"},{"id":11141,"position":8,"arabic":"قُلُوبُكُمْ ۚ","translation":"অন্তরসমূহ তোমাদের","audioUrl":"wbw/008_010_008.mp3","charTypeName":"word"},{"id":11143,"position":9,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/008_010_010.mp3","charTypeName":"word"},{"id":11144,"position":10,"arabic":"ٱلنَّصْرُ","translation":"সাহায্য(আসে)","audioUrl":"wbw/008_010_011.mp3","charTypeName":"word"},{"id":11145,"position":11,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/008_010_012.mp3","charTypeName":"word"},{"id":11146,"position":12,"arabic":"مِنْ","translation":"হতে","audioUrl":"wbw/008_010_013.mp3","charTypeName":"word"},{