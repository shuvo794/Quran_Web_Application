,"charTypeName":"word"},{"id":12462,"position":5,"arabic":"مِّنْهُ","translation":"পক্ষ হতে তাঁর","audioUrl":"wbw/008_011_005.mp3","charTypeName":"word"},{"id":12463,"position":6,"arabic":"وَيُنَزِّلُ","translation":"ও অবতীর্ণ করেন","audioUrl":"wbw/008_011_006.mp3","charTypeName":"word"},{"id":12464,"position":7,"arabic":"عَلَيْكُم","translation":"উপর তোমাদের","audioUrl":"wbw/008_011_007.mp3","charTypeName":"word"},{"id":12465,"position":8,"arabic":"مِّنَ","translation":"হতে","audioUrl":"wbw/008_011_008.mp3","charTypeName":"word"},{"id":12466,"position":9,"arabic":"ٱلسَّمَآءِ","translation":"আকাশ","audioUrl":"wbw/008_011_009.mp3","charTypeName":"word"},{"id":12467,"position":10,"arabic":"مَآءًۭ","translation":"পানি","audioUrl":"wbw/008_011_010.mp3","charTypeName":"word"},{"id":12468,"position":11,"arabic":"لِّيُطَهِّرَكُم","translation":"জন্যে পবিত্র করার তোমাদেরকে","audioUrl":"wbw/008_011_011.mp3","charTypeName":"word"},{"id":12469,"position":12,"arabic":"بِهِۦ","translation":"দিয়ে তা","audioUrl":"wbw/008_011_012.mp3","charTypeName":"word"},{"id":12470,"position":13,"arabic":"وَيُذْهِبَ","translation":"এবং দূর করার(জন্যে)","audioUrl":"wbw/008_011_013.mp3","charTypeName":"word"},{"id":12471,"position":14,"arabic":"عَنكُمْ","translation":"হতে তোমাদের","audioUrl":"wbw/008_011_014.mp3","charTypeName":"word"},{"id":12472,"position":15,"arabic":"رِجْزَ","translation":"অপবিত্রতা","audioUrl":"wbw/008_011_015.mp3","charTypeName":"word"},{"id":12473,"position":16,"arabic":"ٱلشَّيْطَـٰنِ","translation":"শয়তানের","audioUrl":"wbw/008_011_016.mp3","charTypeName":"word"},{"id":12474,"position":17,"arabic":"وَلِيَرْبِطَ","translation":"এবং জন্যে  দূঢ় করার","audioUrl":"wbw/008_011_017.mp3","charTypeName":"word"},{"id":12475,"position":18,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/008_011_018.mp3","charTypeName":"word"},{"id":12476,"position":19,"arabic":"قُلُوبِكُمْ","translation":"অন্তরসমূহের তোমাদের","audioUrl":"wbw/008_011_019.mp3","charTypeName":"word"},{"id":12477,"position":20,"arabic":"وَيُثَبِّتَ","translation":"ও স্থির করার (জন্যে)","audioUrl":"wbw/008_011_020.mp3","charTypeName":"word"},{"id":12478,"position":21,"arabic":"بِهِ","translation":"দিয়ে তা","audioUrl":"wbw/008_011_021.mp3","charTypeName":"word"},{"id":12479,"position":22,"arabic":"ٱلْأَقْدَامَ","translation":"(তোমাদের) পাগুলোকে","audioUrl":"wbw/008_011_022.mp3","charTypeName":"word"},{"id":12480,"position":23,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]},{"number":12,"arabic":"إِذْ يُوحِى رَبُّكَ إِلَى ٱلْمَلَٰٓئِكَةِ أَنِّى مَعَكُمْ فَثَبِّتُوا۟ ٱلَّذِينَ ءَامَنُوا۟ ۚ سَأُلْقِى فِى قُلُوبِ ٱلَّذِينَ كَفَرُوا۟ ٱلرُّعْبَ فَٱضْرِبُوا۟ فَوْقَ ٱلْأَعْنَاقِ وَٱضْرِبُوا۟ مِنْهُمْ كُلَّ بَنَانٍۢ","translation":"Lo! Thy Sustainer inspired the angels [to convey this His message to the believers]: \"I am with you!\" [And He commanded the angels:] \"And, give firmness unto those who have attained to faith [with these words from Me]: `I shall cast terror into the hearts of those who are bent on denying the truth; strike, then, their necks, [O believers,] and strike off every one of their finger-tips!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1172.mp3","surahId":8,"words":[{"id":13772,"position":1,"arabic":"إِذْ","translation":"(স্মরণ করো) যখন","audioUrl":"wbw/008_012_001.mp3","charTypeName":"word"},{"id":13773,"position":2,"arabic":"يُوحِى","translation":"ওহী করেন","audioUrl":"wbw/008_012_002.mp3","charTypeName":"word"},{"id":13774,"position":3,"arabic":"رَبُّكَ","translation":"তোমার রব","audioUrl":"wbw/008_012_003.mp3","charTypeName":"word"},{"id":13775,"position":4,"arabic":"إِلَى","translation":"প্রতি","audioUrl":"wbw/008_012_004.mp3","charTypeName":"word"},{"id":13776,"position":5,"arabic":"ٱلْمَلَـٰٓئِكَةِ","translation":"ফেরেশতাদের","audioUrl":"wbw/008_012_005.mp3","charTypeName":"word"},{"id":13777,"position":6,"arabic":"أَنِّى","translation":"\"যে আমি","audioUrl":"wbw/008_012_006.mp3","charTypeName":"word"