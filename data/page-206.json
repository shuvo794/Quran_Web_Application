Name":"word"},{"id":76282,"position":6,"arabic":"وَكُونُوا۟","translation":"ও তোমরা হও","audioUrl":"wbw/009_119_006.mp3","charTypeName":"word"},{"id":76283,"position":7,"arabic":"مَعَ","translation":"(অন্তর্ভুক্ত)সাথে থাকো","audioUrl":"wbw/009_119_007.mp3","charTypeName":"word"},{"id":76284,"position":8,"arabic":"ٱلصَّـٰدِقِينَ","translation":"সত্যবাদীদের","audioUrl":"wbw/009_119_008.mp3","charTypeName":"word"},{"id":76285,"position":9,"arabic":"١١٩","translation":"(১১৯)","audioUrl":null,"charTypeName":"end"}]},{"number":120,"arabic":"مَا كَانَ لِأَهْلِ ٱلْمَدِينَةِ وَمَنْ حَوْلَهُم مِّنَ ٱلْأَعْرَابِ أَن يَتَخَلَّفُوا۟ عَن رَّسُولِ ٱللَّهِ وَلَا يَرْغَبُوا۟ بِأَنفُسِهِمْ عَن نَّفْسِهِۦ ۚ ذَٰلِكَ بِأَنَّهُمْ لَا يُصِيبُهُمْ ظَمَأٌۭ وَلَا نَصَبٌۭ وَلَا مَخْمَصَةٌۭ فِى سَبِيلِ ٱللَّهِ وَلَا يَطَـُٔونَ مَوْطِئًۭا يَغِيظُ ٱلْكُفَّارَ وَلَا يَنَالُونَ مِنْ عَدُوٍّۢ نَّيْلًا إِلَّا كُتِبَ لَهُم بِهِۦ عَمَلٌۭ صَٰلِحٌ ۚ إِنَّ ٱللَّهَ لَا يُضِيعُ أَجْرَ ٱلْمُحْسِنِينَ","translation":"It does not behove the people of the [Prophet's] City and the bedouin [who live] around them to hold back from following God's Apostle, or to care for their own selves more than for him -for, whenever they suffer from thirst or weariness or hunger in God's cause, and whenever they take any step which confounds those who deny the truth, and whenever there comes to them from the enemy whatever may be destined for them -[whenever anything thereof comes to pass,,] a good deed is recorded in their favour. Verily, God does not fail to requite the doers of good!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1355.mp3","surahId":9,"words":[{"id":76431,"position":1,"arabic":"مَا","translation":"না","audioUrl":"wbw/009_120_001.mp3","charTypeName":"word"},{"id":76432,"position":2,"arabic":"كَانَ","translation":"শোভা পায়","audioUrl":"wbw/009_120_002.mp3","charTypeName":"word"},{"id":76433,"position":3,"arabic":"لِأَهْلِ","translation":"জন্যে অধিবাসীদের","audioUrl":"wbw/009_120_003.mp3","charTypeName":"word"},{"id":76434,"position":4,"arabic":"ٱلْمَدِينَةِ","translation":"মাদীনার","audioUrl":"wbw/009_120_004.mp3","charTypeName":"word"},{"id":76435,"position":5,"arabic":"وَمَنْ","translation":"ও যারা","audioUrl":"wbw/009_120_005.mp3","charTypeName":"word"},{"id":76436,"position":6,"arabic":"حَوْلَهُم","translation":"তাদের চার পাশে (থাকে)","audioUrl":"wbw/009_120_006.mp3","charTypeName":"word"},{"id":76437,"position":7,"arabic":"مِّنَ","translation":"মধ্য হতে","audioUrl":"wbw/009_120_007.mp3","charTypeName":"word"},{"id":76438,"position":8,"arabic":"ٱلْأَعْرَابِ","translation":"বেদুঈনদের","audioUrl":"wbw/009_120_008.mp3","charTypeName":"word"},{"id":76439,"position":9,"arabic":"أَن","translation":"যে","audioUrl":"wbw/009_120_009.mp3","charTypeName":"word"},{"id":76440,"position":10,"arabic":"يَتَخَلَّفُوا۟","translation":"তারা পিছনে রয়ে যাবে","audioUrl":"wbw/009_120_010.mp3","charTypeName":"word"},{"id":76441,"position":11,"arabic":"عَن","translation":"(সহগামী হওয়া) থেকে","audioUrl":"wbw/009_120_011.mp3","charTypeName":"word"},{"id":76442,"position":12,"arabic":"رَّسُولِ","translation":"রাসূলের","audioUrl":"wbw/009_120_012.mp3","charTypeName":"word"},{"id":76443,"position":13,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/009_120_013.mp3","charTypeName":"word"},{"id":76444,"position":14,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/009_120_014.mp3","charTypeName":"word"},{"id":76445,"position":15,"arabic":"يَرْغَبُوا۟","translation":"তারা প্রিয় মনে করবে","audioUrl":"wbw/009_120_015.mp3","charTypeName":"word"},{"id":76446,"position":16,"arabic":"بِأَنفُسِهِمْ","translation":"ব্যাপারে জীবনের তাদের","audioUrl":"wbw/009_120_016.mp3","charTypeName":"word"},{"id":76447,"position":17,"arabic":"عَن","translation":"চেয়ে","audioUrl":"wbw/009_120_017.mp3","charTypeName":"word"},{"id":76448,"position":18,"arabic":"نَّفْسِهِۦ ۚ","translation":"প্রাণের তার","audioUrl":"wbw/009_120_018.mp3","charTypeName":"word"},{"id":76450,"position":19,"ar