ioUrl":"wbw/009_121_009.mp3","charTypeName":"word"},{"id":76639,"position":10,"arabic":"إِلَّا","translation":"এ ছাড়া যে","audioUrl":"wbw/009_121_010.mp3","charTypeName":"word"},{"id":76640,"position":11,"arabic":"كُتِبَ","translation":"লেখা হয়","audioUrl":"wbw/009_121_011.mp3","charTypeName":"word"},{"id":76641,"position":12,"arabic":"لَهُمْ","translation":"জন্যে তাদের","audioUrl":"wbw/009_121_012.mp3","charTypeName":"word"},{"id":76642,"position":13,"arabic":"لِيَجْزِيَهُمُ","translation":"যেন প্রতিফল দেন তাদেরকে","audioUrl":"wbw/009_121_013.mp3","charTypeName":"word"},{"id":76643,"position":14,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/009_121_014.mp3","charTypeName":"word"},{"id":76644,"position":15,"arabic":"أَحْسَنَ","translation":"অতি উত্তম","audioUrl":"wbw/009_121_015.mp3","charTypeName":"word"},{"id":76645,"position":16,"arabic":"مَا","translation":"যা","audioUrl":"wbw/009_121_016.mp3","charTypeName":"word"},{"id":76646,"position":17,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/009_121_017.mp3","charTypeName":"word"},{"id":76647,"position":18,"arabic":"يَعْمَلُونَ","translation":"তারা কাজ করতে","audioUrl":"wbw/009_121_018.mp3","charTypeName":"word"},{"id":76648,"position":19,"arabic":"١٢١","translation":"(১২১)","audioUrl":null,"charTypeName":"end"}]},{"number":122,"arabic":"۞ وَمَا كَانَ ٱلْمُؤْمِنُونَ لِيَنفِرُوا۟ كَآفَّةًۭ ۚ فَلَوْلَا نَفَرَ مِن كُلِّ فِرْقَةٍۢ مِّنْهُمْ طَآئِفَةٌۭ لِّيَتَفَقَّهُوا۟ فِى ٱلدِّينِ وَلِيُنذِرُوا۟ قَوْمَهُمْ إِذَا رَجَعُوٓا۟ إِلَيْهِمْ لَعَلَّهُمْ يَحْذَرُونَ","translation":"With all this, it is not desirable that all of the believers take the field [in time of war]. From within every group in their midst, some shall refrain from going forth to war, and shall devote themselves [instead] to acquiring a deeper knowledge of the Faith. and [thus be able to] teach their home-coming brethren, so that these [too] might guard themselves against evil.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1357.mp3","surahId":9,"words":[{"id":76733,"position":1,"arabic":"۞ وَمَا","translation":"এবং না","audioUrl":"wbw/009_122_002.mp3","charTypeName":"word"},{"id":76734,"position":2,"arabic":"كَانَ","translation":"সঙ্গত (ছিলো)","audioUrl":"wbw/009_122_003.mp3","charTypeName":"word"},{"id":76735,"position":3,"arabic":"ٱلْمُؤْمِنُونَ","translation":"মু'মিনদের (জন্যে যে)","audioUrl":"wbw/009_122_004.mp3","charTypeName":"word"},{"id":76736,"position":4,"arabic":"لِيَنفِرُوا۟","translation":"যেন তারা বের হবে","audioUrl":"wbw/009_122_005.mp3","charTypeName":"word"},{"id":76737,"position":5,"arabic":"كَآفَّةًۭ ۚ","translation":"সবাই (একযোগে)","audioUrl":"wbw/009_122_006.mp3","charTypeName":"word"},{"id":76739,"position":6,"arabic":"فَلَوْلَا","translation":"আর কেন না","audioUrl":"wbw/009_122_008.mp3","charTypeName":"word"},{"id":76740,"position":7,"arabic":"نَفَرَ","translation":"বের হলো","audioUrl":"wbw/009_122_009.mp3","charTypeName":"word"},{"id":76741,"position":8,"arabic":"مِن","translation":"হতে","audioUrl":"wbw/009_122_010.mp3","charTypeName":"word"},{"id":76742,"position":9,"arabic":"كُلِّ","translation":"প্রত্যেক","audioUrl":"wbw/009_122_011.mp3","charTypeName":"word"},{"id":76743,"position":10,"arabic":"فِرْقَةٍۢ","translation":"দলের","audioUrl":"wbw/009_122_012.mp3","charTypeName":"word"},{"id":76744,"position":11,"arabic":"مِّنْهُمْ","translation":"মধ্য থেকে তাদের","audioUrl":"wbw/009_122_013.mp3","charTypeName":"word"},{"id":76745,"position":12,"arabic":"طَآئِفَةٌۭ","translation":"একটি অংশ","audioUrl":"wbw/009_122_014.mp3","charTypeName":"word"},{"id":76746,"position":13,"arabic":"لِّيَتَفَقَّهُوا۟","translation":"যেন তারা গভীর জ্ঞান অনুশীলন করতো","audioUrl":"wbw/009_122_015.mp3","charTypeName":"word"},{"id":76747,"position":14,"arabic":"فِى","translation":"ব্যাপারে","audioUrl":"wbw/009_122_016.mp3","charTypeName":"word"},{"id":76748,"position":15,"arabic":"ٱلدِّينِ","translation":"দীনের","audioUrl":"wbw/009_122_017.mp3","charTypeName":"word"},{"id":76749,"position":16,"arabic":"وَلِيُنذِرُوا۟","translation":"এবং যেন তারা সতর্ক করে","audioUrl":"wbw/009_122_018.mp3","charTypeName":"word"},{"id":76750,"position":17,"arabic":"قَوْمَهُمْ","translation":"সম্প্রদায়কে তাদের","audioUrl":"wbw/009_122_019.mp3","charTypeName":"word"},{"id":76751,"position":18,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/009_122_020.mp3","charTypeName":"word"},{"id":76752,"position":19,"arabic":"رَجَعُوٓا۟","translation":"তারা ফিরে যায়","audioUrl":"wbw/009_122_021.mp3","charTypeName":"word"},{"id":76753,"position":20,"arabic":"إِلَيْهِمْ","translation":"দিকে তাদের","audioUrl":"wbw/009_122_022.mp3","charTypeName":"word"},{"id":76754,"position":21,"arabic":"لَعَلَّهُمْ","translation":"যাতে তারা(এভাবে)","audioUrl":"wbw/009_122_023.mp3","charTypeName":"word"},{"id":76755,"position":22,"arabic":"يَحْذَرُونَ","translation":"(ইসলাম বিরোধী কাজ থেকে) সতর্ক থাকে","audioUrl":"wbw/009_122_024.mp3","charTypeName":"word"},{"id":76756,"position":23,"arabic":"١٢٢","translation":"(১২২)","audioUrl":null,"charTypeName":"end"}]}]}