{"id":593,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلْفَجْرِ","translation":"CONSIDER the daybreak","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5994.mp3","surahId":89,"words":[{"id":729,"position":1,"arabic":"وَٱلْفَجْرِ","translation":"শপথ ঊষার","audioUrl":"wbw/089_001_001.mp3","charTypeName":"word"},{"id":730,"position":2,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"وَلَيَالٍ عَشْرٍۢ","translation":"and the ten nights!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5995.mp3","surahId":89,"words":[{"id":1778,"position":1,"arabic":"وَلَيَالٍ","translation":"শপথ রাতের","audioUrl":"wbw/089_002_001.mp3","charTypeName":"word"},{"id":1779,"position":2,"arabic":"عَشْرٍۢ","translation":"দশ","audioUrl":"wbw/089_002_002.mp3","charTypeName":"word"},{"id":1780,"position":3,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"وَٱلشَّفْعِ وَٱلْوَتْرِ","translation":"Consider the multiple and the One!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5996.mp3","surahId":89,"words":[{"id":2408,"position":1,"arabic":"وَٱلشَّفْعِ","translation":"শপথ জোড়ের","audioUrl":"wbw/089_003_001.mp3","charTypeName":"word"},{"id":2409,"position":2,"arabic":"وَٱلْوَتْرِ","translation":"ও বেজোড়ের","audioUrl":"wbw/089_003_002.mp3","charTypeName":"word"},{"id":2410,"position":3,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"وَٱلَّيْلِ إِذَا يَسْرِ","translation":"Consider the night as it runs its course!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5997.mp3","surahId":89,"words":[{"id":3817,"position":1,"arabic":"وَٱلَّيْلِ","translation":"শপথ রাতের","audioUrl":"wbw/089_004_001.mp3","charTypeName":"word"},{"id":3818,"position":2,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/089_004_002.mp3","charTypeName":"word"},{"id":3819,"position":3,"arabic":"يَسْرِ","translation":"তা যেতে থাকে","audioUrl":"wbw/089_004_003.mp3","charTypeName":"word"},{"id":3820,"position":4,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"هَلْ فِى ذَٰلِكَ قَسَمٌۭ لِّذِى حِجْرٍ","translation":"Considering all this - could there be, to anyone endowed with reason, a [more] solemn evidence of the truth?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5998.mp3","surahId":89,"words":[{"id":5125,"position":1,"arabic":"هَلْ","translation":"কি","audioUrl":"wbw/089_005_001.mp3","charTypeName":"word"},{"id":5126,"position":2,"arabic":"فِى","translation":"মধ্যে (আছে)","audioUrl":"wbw/089_005_002.mp3","charTypeName":"word"},{"id":5127,"position":3,"arabic":"ذَٰلِكَ","translation":"এর","audioUrl":"wbw/089_005_003.mp3","charTypeName":"word"},{"id":5128,"position":4,"arabic":"قَسَمٌۭ","translation":"কোনো শপথ (কোনো প্রমাণ)","audioUrl":"wbw/089_005_004.mp3","charTypeName":"word"},{"id":5129,"position":5,"arabic":"لِّذِى","translation":"সম্পন্ন ব্যক্তির জন্য","audioUrl":"wbw/089_005_005.mp3","charTypeName":"word"},{"id":5130,"position":6,"arabic":"حِجْرٍ","translation":"বোধশক্তি","audioUrl":"wbw/089_005_006.mp3","charTypeName":"word"},{"id":5131,"position":7,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"أَلَمْ تَرَ كَيْفَ فَعَلَ رَبُّكَ بِعَادٍ","translation":"ART THOU NOT aware of how thy Sustainer has dealt with [the tribe of] ‘Ad,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5999.mp3","surahId":89,"words":[{"id":6346,"position":1,"arabic":"أَلَمْ","translation":"নি কি","audioUrl":"wbw/089_006_001.mp3","charTypeName":"word"},{"id":6347,"position":2,"arabic":"تَرَ","translation":"তুমি দেখ","audioUrl":"wbw/089_006_002.mp3","charTypeName":"word"},{"id":6348,"position":3,"arabic":"كَيْفَ","translation":"কেমন","audioUrl":"wbw/089_006_003.mp3","charTypeName":"word"},{"id":6349,"position":4,"arabic":"فَعَلَ","translation":"করেছেন","audioUrl":"wbw/089_006_004.mp3","charTypeName":"word"},{"id":6350,"position":5,"arabic":"رَبُّكَ","translation":"তোমার রব","audioUrl":"wbw/089_006_005.mp3","charTypeName":"word"},{"id":6351,"position":6,"arabic":"بِعَادٍ","translation":"আ'দ বংশের সাথে","audioUrl":"wbw/089_006_006.mp3","charTypeName":"word"},{"id":6352,"position":7,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"إِرَمَ ذَاتِ ٱلْعِمَادِ","translation":"[the people of] Iram the many-pillared,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6000.mp3","surahId":89,"words":[{"id":7765,"position":1,"arabic":"إِرَمَ","translation":"ইরাম গোত্রের (প্রতি)","audioUrl":"wbw/089_007_001.mp3","charTypeName":"word"},{"id":7766,"position":2,"arabic":"ذَاتِ","translation":"অধিকারী (ছিল)","audioUrl":"wbw/089_007_002.mp3","charTypeName":"word"},{"id":7767,"position":3,"arabic":"ٱلْعِمَادِ","translation":"সুউচ্চ প্রাসাদের","audioUrl":"wbw/089_007_003.mp3","charTypeName":"word"},{"id":7768,"position":4,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"ٱلَّتِى لَمْ يُخْلَقْ مِثْلُهَا فِى ٱلْبِلَٰدِ","translation":"the like of whom has never been reared in all the land? –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6001.mp3","surahId":89,"words":[{"id":8855,"position":1,"arabic":"ٱلَّتِى","translation":"যা (এমন ছিল যে)","audioUrl":"wbw/089_008_001.mp3","charTypeName":"word"},{"id":8856,"position":2,"arabic":"لَمْ","translation":"নি","audioUrl":"wbw/089_008_002.mp3","charTypeName":"word"},{"id":8857,"position":3,"arabic":"يُخْلَقْ","translation":"নির্মিত হয়","audioUrl":"wbw/089_008_003.mp3","charTypeName":"word"},{"id":8858,"position":4,"arabic":"مِثْلُهَا","translation":"তার সমতুল্য (কোন জাতি)","audioUrl":"wbw/089_008_004.mp3","charTypeName":"word"},{"id":8859,"position":5,"arabic":"فِى","translation":"হতে","audioUrl":"wbw/089_008_005.mp3","charTypeName":"word"},{"id":8860,"position":6,"arabic":"ٱلْبِلَـٰدِ","translation":"দেশ সমূহে","audioUrl":"wbw/089_008_006.mp3","charTypeName":"word"},{"id":8861,"position":7,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"وَثَمُودَ ٱلَّذِينَ جَابُوا۟ ٱلصَّخْرَ بِٱلْوَادِ","translation":"and with [the tribe of] Thamud, who hollowed out rocks in the valley? –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6002.mp3","surahId":89,"words":[{"id":10277,"position":1,"arabic":"وَثَمُودَ","translation":"এবং (কেমন করেছেন সামূদদের সাথে)","audioUrl":"wbw/089_009_001.mp3","charTypeName":"word"},{"id":10278,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/089_009_002.mp3","charTypeName":"word"},{"id":10279,"position":3,"arabic":"جَابُوا۟","translation":"কেটেছিল","audioUrl":"wbw/089_009_003.mp3","charTypeName":"word"},{"id":10280,"position":4,"arabic":"ٱلصَّخْرَ","translation":"পাথর (ভূমি সমূহ)","audioUrl":"wbw/089_009_004.mp3","charTypeName":"word"},{"id":10281,"position":5,"arabic":"بِٱلْوَادِ","translation":"উপত্যকার","audioUrl":"wbw/089_009_005.mp3","charTypeName":"word"},{"id":10282,"position":6,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"وَفِرْعَوْنَ ذِى ٱلْأَوْتَادِ","translation":"and with Pharaoh of the [many] tent-poles?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6003.mp3","surahId":89,"words":[{"id":11493,"position":1,"arabic":"وَفِرْعَوْنَ","translation":"এবং (কেমন করেছেন) ফিরআউনের সাথে","audioUrl":"wbw/089_010_001.mp3","charTypeName":"word"},{"id":11494,"position":2,"arabic":"ذِى","translation":"(যে ছিল) অধিপতি","audioUrl":"wbw/089_010_002.mp3","charTypeName":"word"},{"id":11495,"position":3,"arabic":"ٱلْأَوْتَادِ","translation":"কীলকসমূহের (সৈন্য শিবিরের)","audioUrl":"wbw/089_010_003.mp3","charTypeName":"word"},{"id":11496,"position":4,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"ٱلَّذِينَ طَغَوْا۟ فِى ٱلْبِلَٰدِ","translation":"[It was they] who transgressed all bounds of equity all over their lands,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6004.mp3","surahId":89,"words":[{"id":12830,"position":1,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/089_011_001.mp3","charTypeName":"word"},{"id":12831,"position":2,"arabic":"طَغَوْا۟","translation":"সীমালঙ্ঘন করেছিলো","audioUrl":"wbw/089_011_002.mp3","charTypeName":"word"},{"id":12832,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/089_011_003.mp3","charTypeName":"word"},{"id":12833,"position":4,"arabic":"ٱلْبِلَـٰدِ","translation":"(বিভিন্ন) দেশে","audioUrl":"wbw/089_011_004.mp3","charTypeName":"word"},{"id":12834,"position":5,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]},{"number":12,"arabic":"فَأَكْثَرُوا۟ فِيهَا ٱلْفَسَادَ","translation":"and brought about great corruption therein:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6005.mp3","surahId":89,"words":[{"id":14074,"position":1,"arabic":"فَأَكْثَرُوا۟","translation":"আর বৃদ্ধি করেছিল","audioUrl":"wbw/089_012_001.mp3","charTypeName":"word"},{"id":14075,"position":2,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/089_012_002.mp3","charTypeName":"word"},{"id":14076,"position":3,"arabic":"ٱلْفَسَادَ","translation":"বিপর্যয়/ অশান্তি","audioUrl":"wbw/089_012_003.mp3","charTypeName":"word"},{"id":14077,"position":4,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]},{"number":13,"arabic":"فَصَبَّ عَلَيْهِمْ رَبُّكَ سَوْطَ عَذَابٍ","translation":"and therefore thy Sustainer let loose upon them a scourge of suffering:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6006.mp3","surahId":89,"words":[{"id":15087,"position":1,"arabic":"فَصَبَّ","translation":"তারপর আঘাত করলেন","audioUrl":"wbw/089_013_001.mp3","charTypeName":"word"},{"id":15088,"position":2,"arabic":"عَلَيْهِمْ","translation":"তাদের উপর","audioUrl":"wbw/089_013_002.mp3","charTypeName":"word"},{"id":15089,"position":3,"arabic":"رَبُّكَ","translation":"তোমার রব","audioUrl":"wbw/089_013_003.mp3","charTypeName":"word"},{"id":15090,"position":4,"arabic":"سَوْطَ","translation":"চাবুকের","audioUrl":"wbw/089_013_004.mp3","charTypeName":"word"},{"id":15091,"position":5,"arabic":"عَذَابٍ","translation":"শাস্তির","audioUrl":"wbw/089_013_005.mp3","charTypeName":"word"},{"id":15092,"position":6,"arabic":"١٣","translation":"(১৩)","audioUrl":null,"charTypeName":"end"}]},{"number":14,"arabic":"إِنَّ رَبَّكَ لَبِٱلْمِرْصَادِ","translation":"for, verily, thy Sustainer is ever on the watch!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6007.mp3","surahId":89,"words":[{"id":16267,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/089_014_001.mp3","charTypeName":"word"},{"id":16268,"position":2,"arabic":"رَبَّكَ","translation":"তোমার রব","audioUrl":"wbw/089_014_002.mp3","charTypeName":"word"},{"id":16269,"position":3,"arabic":"لَبِٱلْمِرْصَادِ","translation":"অবশ্যই (ধরবেন) ঘাঁটিতে","audioUrl":"wbw/089_014_003.mp3","charTypeName":"word"},{"id":16270,"position":4,"arabic":"١٤","translation":"(১৪)","audioUrl":null,"charTypeName":"end"}]},{"number":15,"arabic":"فَأَمَّا ٱلْإِنسَٰنُ إِذَا مَا ٱبْتَلَىٰهُ رَبُّهُۥ فَأَكْرَمَهُۥ وَنَعَّمَهُۥ فَيَقُولُ رَبِّىٓ أَكْرَمَنِ","translation":"BUT AS FOR man, whenever his Sustainer tries him by His generosity and by letting him enjoy a life of ease, he says, \"My Sustainer has been [justly] generous towards me\";","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6008.mp3","surahId":89,"words":[{"id":17445,"position":1,"arabic":"فَأَمَّا","translation":"অতঃপর ব্যাপার হলো","audioUrl":"wbw/089_015_001.mp3","charTypeName":"word"},{"id":17446,"position":2,"arabic":"ٱلْإِنسَـٰنُ","translation":"মানুষের","audioUrl":"wbw/089_015_002.mp3","charTypeName":"word"},{"id":17447,"position":3,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/089_015_003.mp3","charTypeName":"word"},{"id":17448,"position":4,"arabic":"مَا","translation":"তাকে","audioUrl":"wbw/089_015_004.mp3","charTypeName":"word"},{"id":17449,"position":5,"arabic":"ٱبْتَلَىٰهُ","translation":"পরীক্ষা করেন","audioUrl":"wbw/089_015_005.mp3","charTypeName":"word"},{"id":17450,"position":6,"arabic":"رَبُّهُۥ","translation":"তার রব","audioUrl":"wbw/089_015_006.mp3","charTypeName":"word"},{"id":17451,"position":7,"arabic":"فَأَكْرَمَهُۥ","translation":"তাকে সম্মান দেন","audioUrl":"wbw/089_015_007.mp3","charTypeName":"word"},{"id":17452,"position":8,"arabic":"وَنَعَّمَهُۥ","translation":"ও তাকে অনুগ্রহ করেন","audioUrl":"wbw/089_015_008.mp3","charTypeName":"word"},{"id":17453,"position":9,"arabic":"فَيَقُولُ","translation":"তখন সে বলে","audioUrl":"wbw/089_015_009.mp3","charTypeName":"word"},{"id":17454,"position":10,"arabic":"رَبِّىٓ","translation":"\"আমার রব","audioUrl":"wbw/089_015_010.mp3","charTypeName":"word"},{"id":17455,"position":11,"arabic":"أَكْرَمَنِ","translation":"আমাকে সম্মানিত করেছেন\"","audioUrl":"wbw/089_015_011.mp3","charTypeName":"word"},{"id":17456,"position":12,"arabic":"١٥","translation":"(১৫)","audioUrl":null,"charTypeName":"end"}]},{"number":16,"arabic":"وَأَمَّآ إِذَا مَا ٱبْتَلَىٰهُ فَقَدَرَ عَلَيْهِ رِزْقَهُۥ فَيَقُولُ رَبِّىٓ أَهَٰنَنِ","translation":"whereas, whenever He tries him by straitening his means of livelihood, he says, \"My Sustainer has disgraced me!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6009.mp3","surahId":89,"words":[{"id":18516,"position":1,"arabic":"وَأَمَّآ","translation":"আর","audioUrl":"wbw/089_016_001.mp3","charTypeName":"word"},{"id":18517,"position":2,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/089_016_002.mp3","charTypeName":"word"},{"id":18518,"position":3,"arabic":"مَا","translation":"তাকে","audioUrl":"wbw/089_016_003.mp3","charTypeName":"word"},{"id":18519,"position":4,"arabic":"ٱبْتَلَىٰهُ","translation":"পরীক্ষা করেন","audioUrl":"wbw/089_016_004.mp3","charTypeName":"word"},{"id":18520,"position":5,"arabic":"فَقَدَرَ","translation":"সংকীর্ণ করেন","audioUrl":"wbw/089_016_005.mp3","charTypeName":"word"},{"id":18521,"position":6,"arabic":"عَلَيْهِ","translation":"তার  উপর","audioUrl":"wbw/089_016_006.mp3","charTypeName":"word"},{"id":18522,"position":7,"arabic":"رِزْقَهُۥ","translation":"তার রিযক","audioUrl":"wbw/089_016_007.mp3","charTypeName":"word"},{"id":18523,"position":8,"arabic":"فَيَقُولُ","translation":"তখন সে বলে","audioUrl":"wbw/089_016_008.mp3","charTypeName":"word"},{"id":18524,"position":9,"arabic":"رَبِّىٓ","translation":"\"আমার রব","audioUrl":"wbw/089_016_009.mp3","charTypeName":"word"},{"id":18525,"position":10,"arabic":"أَهَـٰنَنِ","translation":"আমাকে হেয় করেছেন\"","audioUrl":"wbw/089_016_010.mp3","charTypeName":"word"},{"id":18526,"position":11,"arabic":"١٦","translation":"(১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":17,"arabic":"كَلَّا ۖ بَل لَّا تُكْرِمُونَ ٱلْيَتِيمَ","translation":"But nay, nay, [O men, consider all that you do and fail to do:] you are not generous towards the orphan,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6010.mp3","surahId":89,"words":[{"id":19504,"position":1,"arabic":"كَلَّا ۖ","translation":"কখনও না","audioUrl":"wbw/089_017_001.mp3","charTypeName":"word"},{"id":19506,"position":2,"arabic":"بَل","translation":"বরং","audioUrl":"wbw/089_017_003.mp3","charTypeName":"word"},{"id":19507,"position":3,"arabic":"لَّا","translation":"না","audioUrl":"wbw/089_017_004.mp3","charTypeName":"word"},{"id":19508,"position":4,"arabic":"تُكْرِمُونَ","translation":"তোমরা সম্মান করো","audioUrl":"wbw/089_017_005.mp3","charTypeName":"word"},{"id":19509,"position":5,"arabic":"ٱلْيَتِيمَ","translation":"ইয়াতীমের","audioUrl":"wbw/089_017_006.mp3","charTypeName":"word"},{"id":19510,"position":6,"arabic":"١٧","translation":"(১৭)","audioUrl":null,"charTypeName":"end"}]},{"number":18,"arabic":"وَلَا تَحَٰٓضُّونَ عَلَىٰ طَعَامِ ٱلْمِسْكِينِ","translation":"and you do not urge one another to feed t