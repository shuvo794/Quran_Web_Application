نَّ ٱلسَّوْءِ وَكُنتُمْ قَوْمًۢا بُورًۭا","translation":"Nay, you thought that the Apostle and the believers would never return to their kith and kin: and this seemed goodly to your hearts. And you entertained [such] evil thoughts because you have always been people devoid of all good!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4595.mp3","surahId":48,"words":[{"id":13687,"position":1,"arabic":"بَلْ","translation":"বরং","audioUrl":"wbw/048_012_001.mp3","charTypeName":"word"},{"id":13688,"position":2,"arabic":"ظَنَنتُمْ","translation":"তোমরা ধারণা করেছিলে","audioUrl":"wbw/048_012_002.mp3","charTypeName":"word"},{"id":13689,"position":3,"arabic":"أَن","translation":"যে","audioUrl":"wbw/048_012_003.mp3","charTypeName":"word"},{"id":13690,"position":4,"arabic":"لَّن","translation":"কখনও না","audioUrl":"wbw/048_012_004.mp3","charTypeName":"word"},{"id":13691,"position":5,"arabic":"يَنقَلِبَ","translation":"ফিরে আসতে পারবে","audioUrl":"wbw/048_012_005.mp3","charTypeName":"word"},{"id":13692,"position":6,"arabic":"ٱلرَّسُولُ","translation":"রাসূল","audioUrl":"wbw/048_012_006.mp3","charTypeName":"word"},{"id":13693,"position":7,"arabic":"وَٱلْمُؤْمِنُونَ","translation":"ও মু'মিনরা","audioUrl":"wbw/048_012_007.mp3","charTypeName":"word"},{"id":13694,"position":8,"arabic":"إِلَىٰٓ","translation":"কাছে","audioUrl":"wbw/048_012_008.mp3","charTypeName":"word"},{"id":13695,"position":9,"arabic":"أَهْلِيهِمْ","translation":"তাদের পরিবারের","audioUrl":"wbw/048_012_009.mp3","charTypeName":"word"},{"id":13696,"position":10,"arabic":"أَبَدًۭا","translation":"কখনও","audioUrl":"wbw/048_012_010.mp3","charTypeName":"word"},{"id":13697,"position":11,"arabic":"وَزُيِّنَ","translation":"এবং সুখকর লেগেছিল","audioUrl":"wbw/048_012_011.mp3","charTypeName":"word"},{"id":13698,"position":12,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/048_012_012.mp3","charTypeName":"word"},{"id":13699,"position":13,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/048_012_013.m