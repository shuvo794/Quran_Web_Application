{"id":512,"ayahs":[{"number":10,"arabic":"إِنَّ ٱلَّذِينَ يُبَايِعُونَكَ إِنَّمَا يُبَايِعُونَ ٱللَّهَ يَدُ ٱللَّهِ فَوْقَ أَيْدِيهِمْ ۚ فَمَن نَّكَثَ فَإِنَّمَا يَنكُثُ عَلَىٰ نَفْسِهِۦ ۖ وَمَنْ أَوْفَىٰ بِمَا عَٰهَدَ عَلَيْهُ ٱللَّهَ فَسَيُؤْتِيهِ أَجْرًا عَظِيمًۭا","translation":"Behold, all who pledge their allegiance to thee pledge their allegiance to God: the hand of God is over their hands. Hence, he who breaks his oath, breaks it only to his own hurt; whereas he who remains true to what he has pledged unto God, on him will He bestow a reward supreme.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4593.mp3","surahId":48,"words":[{"id":11063,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/048_010_001.mp3","charTypeName":"word"},{"id":11064,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/048_010_002.mp3","charTypeName":"word"},{"id":11065,"position":3,"arabic":"يُبَايِعُونَكَ","translation":"তোমার কাছে আনুগত্যের শপথ নেয়","audioUrl":"wbw/048_010_003.mp3","charTypeName":"word"},{"id":11066,"position":4,"arabic":"إِنَّمَا","translation":"প্রকৃতপক্ষে","audioUrl":"wbw/048_010_004.mp3","charTypeName":"word"},{"id":11067,"position":5,"arabic":"يُبَايِعُونَ","translation":"তারা আনুগত্যের শপথ নেয়","audioUrl":"wbw/048_010_005.mp3","charTypeName":"word"},{"id":11068,"position":6,"arabic":"ٱللَّهَ","translation":"আল্লাহর (নিকট)","audioUrl":"wbw/048_010_006.mp3","charTypeName":"word"},{"id":11069,"position":7,"arabic":"يَدُ","translation":"(ছিল) হাত","audioUrl":"wbw/048_010_007.mp3","charTypeName":"word"},{"id":11070,"position":8,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/048_010_008.mp3","charTypeName":"word"},{"id":11071,"position":9,"arabic":"فَوْقَ","translation":"উপর","audioUrl":"wbw/048_010_009.mp3","charTypeName":"word"},{"id":11072,"position":10,"arabic":"أَيْدِيهِمْ ۚ","translation":"তাদের হাতগুলোর","audioUrl":"wbw/048_010_010.mp3","charTypeName":"word"},{"id":11074,"position":11,"arabic":"فَمَن","translation":"সুতরাং যে","audioUrl":"wbw/048_010_012.mp3","charTypeName":"word"},{"id":11075,"position":12,"arabic":"نَّكَثَ","translation":"ভঙ্গ করবে (তার ওয়াদা)","audioUrl":"wbw/048_010_013.mp3","charTypeName":"word"},{"id":11076,"position":13,"arabic":"فَإِنَّمَا","translation":"প্রকৃতপক্ষে","audioUrl":"wbw/048_010_014.mp3","charTypeName":"word"},{"id":11077,"position":14,"arabic":"يَنكُثُ","translation":"সে ভঙ্গ করবে","audioUrl":"wbw/048_010_015.mp3","charTypeName":"word"},{"id":11078,"position":15,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/048_010_016.mp3","charTypeName":"word"},{"id":11079,"position":16,"arabic":"نَفْسِهِۦ ۖ","translation":"তার নিজের (কৃত ওয়াদা)","audioUrl":"wbw/048_010_017.mp3","charTypeName":"word"},{"id":11081,"position":17,"arabic":"وَمَنْ","translation":"এবং যে","audioUrl":"wbw/048_010_019.mp3","charTypeName":"word"},{"id":11082,"position":18,"arabic":"أَوْفَىٰ","translation":"পূর্ণ করবে","audioUrl":"wbw/048_010_020.mp3","charTypeName":"word"},{"id":11083,"position":19,"arabic":"بِمَا","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/048_010_021.mp3","charTypeName":"word"},{"id":11084,"position":20,"arabic":"عَـٰهَدَ","translation":"সে অঙ্গীকার করেছে","audioUrl":"wbw/048_010_022.mp3","charTypeName":"word"},{"id":11085,"position":21,"arabic":"عَلَيْهُ","translation":"তার উপর","audioUrl":"wbw/048_010_023.mp3","charTypeName":"word"},{"id":11086,"position":22,"arabic":"ٱللَّهَ","translation":"আল্লাহর সাথে","audioUrl":"wbw/048_010_024.mp3","charTypeName":"word"},{"id":11087,"position":23,"arabic":"فَسَيُؤْتِيهِ","translation":"তবে তাকে শীঘ্রই দিবেন তিনি","audioUrl":"wbw/048_010_025.mp3","charTypeName":"word"},{"id":11088,"position":24,"arabic":"أَجْرًا","translation":"পুরস্কার","audioUrl":"wbw/048_010_026.mp3","charTypeName":"word"},{"id":11089,"position":25,"arabic":"عَظِيمًۭا","translation":"বিরাট","audioUrl":"wbw/048_010_027.mp3","charTypeName":"word"},{"id":11090,"position":26,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"سَيَقُولُ لَكَ ٱلْمُخَلَّفُونَ مِنَ ٱلْأَعْرَابِ شَغَلَتْنَآ أَمْوَٰلُنَا وَأَهْلُونَا فَٱسْتَغْفِرْ لَنَا ۚ يَقُولُونَ بِأَلْسِنَتِهِم مَّا لَيْسَ فِى قُلُوبِهِمْ ۚ قُلْ فَمَن يَمْلِكُ لَكُم مِّنَ ٱللَّهِ شَيْـًٔا إِنْ أَرَادَ بِكُمْ ضَرًّا أَوْ أَرَادَ بِكُمْ نَفْعًۢا ۚ بَلْ كَانَ ٱللَّهُ بِمَا تَعْمَلُونَ خَبِيرًۢا","translation":"Those of the bedouin who stayed behind will say unto thee: “[The need to take care of] our chat­tels and our families kept us busy: do then, [O Prophet,] ask God to forgive us!” [Thus,] they will utter with their tongues something that is not in their hearts. Say: “Who, then, has it in his power to avert from you aught that God may have willed, whether it be His will to harm you or to confer a benefit on you? Nay, but God is fully aware of what you do!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4594.mp3","surahId":48,"words":[{"id":12342,"position":1,"arabic":"سَيَقُولُ","translation":"(হে নবী) বলবে শীঘ্রই","audioUrl":"wbw/048_011_001.mp3","charTypeName":"word"},{"id":12343,"position":2,"arabic":"لَكَ","translation":"তোমাকে","audioUrl":"wbw/048_011_002.mp3","charTypeName":"word"},{"id":12344,"position":3,"arabic":"ٱلْمُخَلَّفُونَ","translation":"পিছনে থেকে যাওয়া লোকেরা","audioUrl":"wbw/048_011_003.mp3","charTypeName":"word"},{"id":12345,"position":4,"arabic":"مِنَ","translation":"মধ্যহতে","audioUrl":"wbw/048_011_004.mp3","charTypeName":"word"},{"id":12346,"position":5,"arabic":"ٱلْأَعْرَابِ","translation":"মরুবাসীদের","audioUrl":"wbw/048_011_005.mp3","charTypeName":"word"},{"id":12347,"position":6,"arabic":"شَغَلَتْنَآ","translation":"\"আমাদেরকে ব্যস্ত রেখেছিল","audioUrl":"wbw/048_011_006.mp3","charTypeName":"word"},{"id":12348,"position":7,"arabic":"أَمْوَٰلُنَا","translation":"আমাদের ধনসম্পদ","audioUrl":"wbw/048_011_007.mp3","charTypeName":"word"},{"id":12349,"position":8,"arabic":"وَأَهْلُونَا","translation":"ও পরিবার পরিজন","audioUrl":"wbw/048_011_008.mp3","c