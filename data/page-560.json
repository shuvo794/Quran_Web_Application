n":"পরে","audioUrl":"wbw/066_004_021.mp3","charTypeName":"word"},{"id":3939,"position":20,"arabic":"ذَٰلِكَ","translation":"উপরন্তু","audioUrl":"wbw/066_004_022.mp3","charTypeName":"word"},{"id":3940,"position":21,"arabic":"ظَهِيرٌ","translation":"সাহায্যকারী","audioUrl":"wbw/066_004_023.mp3","charTypeName":"word"},{"id":3941,"position":22,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"عَسَىٰ رَبُّهُۥٓ إِن طَلَّقَكُنَّ أَن يُبْدِلَهُۥٓ أَزْوَٰجًا خَيْرًۭا مِّنكُنَّ مُسْلِمَٰتٍۢ مُّؤْمِنَٰتٍۢ قَٰنِتَٰتٍۢ تَٰٓئِبَٰتٍ عَٰبِدَٰتٍۢ سَٰٓئِحَٰتٍۢ ثَيِّبَٰتٍۢ وَأَبْكَارًۭا","translation":"[O wives of the Prophet!] Were he to divorce [any of] you, God might well give him in your stead spouses better than you - women who surrender themselves unto God, who truly believe, devoutly obey His will, turn [unto Him] in repentance [whenever they have sinned] worship [Him alone] and go on and on [seeking His goodly acceptance] - be they women previously married or virgins.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5234.mp3","surahId":66,"words":[{"id":5148,"position":1,"arabic":"عَسَىٰ","translation":"সম্ভবতঃ","audioUrl":"wbw/066_005_001.mp3","charTypeName":"word"},{"id":5149,"position":2,"arabic":"رَبُّهُۥٓ","translation":"তার রব","audioUrl":"wbw/066_005_002.mp3","charTypeName":"word"},{"id":5150,"position":3,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/066_005_003.mp3","charTypeName":"word"},{"id":5151,"position":4,"arabic":"طَلَّقَكُنَّ","translation":"তোমাদের তালাক দেয় (নবী)","audioUrl":"wbw/066_005_004.mp3","charTypeName":"word"},{"id":5152,"position":5,"arabic":"أَن","translation":"যে","audioUrl":"wbw/066_005_005.mp3","charTypeName":"word"},{"id":5153,"position":6,"arabic":"يُبْدِلَهُۥٓ","translation":"তাকে বদলে দেবেন","audioUrl":"wbw/066_005_006.mp3","charTypeName":"word"},{"id":5154,"position":7,"arabic":"أَزْوَٰجًا","translation":"(এমন সব) স্ত্রী","audioUrl":"wbw/066_005_007.mp3","charTypeName":"word"},{"id":5155,"position":8,"arabic":"خَيْرًۭا","translation":"উত্তম","audioUrl":"wbw/066_005_008.mp3","charTypeName":"word"},{"id":5156,"position":9,"arabic":"مِّنكُنَّ","translation":"(যারা) তোমাদের চেয়ে","audioUrl":"wbw/066_005_009.mp3","charTypeName":"word"},{"id":5157,"position":10,"arabic":"مُسْلِمَـٰتٍۢ","translation":"আত্নসমর্পণকারিণী","audioUrl":"wbw/066_005_010.mp3","charTypeName":"word"},{"id":5158,"position":11,"arabic":"مُّؤْمِنَـٰتٍۢ","translation":"মুমিনা","audioUrl":"wbw/066_005_011.mp3","charTypeName":"word"},{"id":5159,"position":12,"arabic":"قَـٰنِتَـٰتٍۢ","translation":"আনুগত্যশীলা","audioUrl":"wbw/066_005_012.mp3","charTypeName":"word"},{"id":5160,"position":13,"arabic":"تَـٰٓئِبَـٰتٍ","translation":"তওবাকারিনী","audioUrl":"wbw/066_005_013.mp3","charTypeName":"word"},{"id":5161,"position":14,"arabic":"عَـٰبِدَٰتٍۢ","translation":"ইবাদতকারিণী","audioUrl":"wbw/066_005_014.mp3","charTypeName":"word"},{"id":5162,"position":15,"arabic":"سَـٰٓئِحَـٰتٍۢ","translation":"রোজাদার","audioUrl":"wbw/066_005_015.mp3","charTypeName":"word"},{"id":5163,"position":16,"arabic":"ثَيِّبَـٰتٍۢ","translation":"অকুমারী","audioUrl":"wbw/066_005_016.mp3","charTypeName":"word"},{"id":5164,"position":17,"arabic":"وَأَبْكَارًۭا","translation":"ও কুমারী","audioUrl":"wbw/066_005_017.mp3","charTypeName":"word"},{"id":5165,"position":18,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ قُوٓا۟ أَنفُسَكُمْ وَأَهْلِيكُمْ نَارًۭا وَقُودُهَا ٱلنَّاسُ وَٱلْحِجَارَةُ عَلَيْهَا مَلَٰٓئِكَةٌ غِلَاظٌۭ شِدَادٌۭ لَّا يَعْصُونَ ٱللَّهَ مَآ أَمَرَهُمْ وَيَفْعَلُونَ مَا يُؤْمَرُونَ","translation":"O YOU who have attained to faith! Ward off from yourselves and those who are close to you that fire [of the hereafter] whose fuel is human beings and stones: [lording] over it are angelic powers awesome [and] severe, who do not disobey God in whatever He has commanded them, but [always] do what they are bidden to do.","a