d"},{"id":6448,"position":16,"arabic":"يَعْصُونَ","translation":"তারা অমান্য করে","audioUrl":"wbw/066_006_016.mp3","charTypeName":"word"},{"id":6449,"position":17,"arabic":"ٱللَّهَ","translation":"আল্লাহকে","audioUrl":"wbw/066_006_017.mp3","charTypeName":"word"},{"id":6450,"position":18,"arabic":"مَآ","translation":"যা","audioUrl":"wbw/066_006_018.mp3","charTypeName":"word"},{"id":6451,"position":19,"arabic":"أَمَرَهُمْ","translation":"তাদের নির্দেশ দেন তিনি","audioUrl":"wbw/066_006_019.mp3","charTypeName":"word"},{"id":6452,"position":20,"arabic":"وَيَفْعَلُونَ","translation":"এবং তারা করে","audioUrl":"wbw/066_006_020.mp3","charTypeName":"word"},{"id":6453,"position":21,"arabic":"مَا","translation":"যা","audioUrl":"wbw/066_006_021.mp3","charTypeName":"word"},{"id":6454,"position":22,"arabic":"يُؤْمَرُونَ","translation":"তাদের নির্দেশ দেয়া হয়","audioUrl":"wbw/066_006_022.mp3","charTypeName":"word"},{"id":6455,"position":23,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ كَفَرُوا۟ لَا تَعْتَذِرُوا۟ ٱلْيَوْمَ ۖ إِنَّمَا تُجْزَوْنَ مَا كُنتُمْ تَعْمَلُونَ","translation":"[Hence,] O you who are bent on denying the truth, make no [empty] excuses today: [in the life to come] you shall be but recompensed for what you were doing [in this world].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5236.mp3","surahId":66,"words":[{"id":7841,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"\"ওহে","audioUrl":"wbw/066_007_001.mp3","charTypeName":"word"},{"id":7842,"position":2,"arabic":"ٱلَّذِينَ","translation":"\"যারা","audioUrl":"wbw/066_007_002.mp3","charTypeName":"word"},{"id":7843,"position":3,"arabic":"كَفَرُوا۟","translation":"\"কুফরী করেছ","audioUrl":"wbw/066_007_003.mp3","charTypeName":"word"},{"id":7844,"position":4,"arabic":"لَا","translation":"না","audioUrl":"wbw/066_007_004.mp3","charTypeName":"word"},{"id":7845,"position":5,"arabic":"تَعْتَذِرُوا۟","translation":"তোমরা ওজর পেশ ক