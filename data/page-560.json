{"id":560,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ يَٰٓأَيُّهَا ٱلنَّبِىُّ لِمَ تُحَرِّمُ مَآ أَحَلَّ ٱللَّهُ لَكَ ۖ تَبْتَغِى مَرْضَاتَ أَزْوَٰجِكَ ۚ وَٱللَّهُ غَفُورٌۭ رَّحِيمٌۭ","translation":"O PROPHET! Why dost thou, out of a desire to please [one or another of] thy wives, impose [on thyself] a prohibition of something that God has made lawful to thee? But God is much-forgiving, a dispenser of grace:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5230.mp3","surahId":66,"words":[{"id":555,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/066_001_001.mp3","charTypeName":"word"},{"id":556,"position":2,"arabic":"ٱلنَّبِىُّ","translation":"নবী","audioUrl":"wbw/066_001_002.mp3","charTypeName":"word"},{"id":557,"position":3,"arabic":"لِمَ","translation":"কেন","audioUrl":"wbw/066_001_003.mp3","charTypeName":"word"},{"id":558,"position":4,"arabic":"تُحَرِّمُ","translation":"হারাম কর তুমি","audioUrl":"wbw/066_001_004.mp3","charTypeName":"word"},{"id":559,"position":5,"arabic":"مَآ","translation":"যা","audioUrl":"wbw/066_001_005.mp3","charTypeName":"word"},{"id":560,"position":6,"arabic":"أَحَلَّ","translation":"হালাল করেছেন","audioUrl":"wbw/066_001_006.mp3","charTypeName":"word"},{"id":561,"position":7,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/066_001_007.mp3","charTypeName":"word"},{"id":562,"position":8,"arabic":"لَكَ ۖ","translation":"তোমার জন্যে","audioUrl":"wbw/066_001_008.mp3","charTypeName":"word"},{"id":564,"position":9,"arabic":"تَبْتَغِى","translation":"তুমি চাও (কি)","audioUrl":"wbw/066_001_010.mp3","charTypeName":"word"},{"id":565,"position":10,"arabic":"مَرْضَاتَ","translation":"সন্তুষ্টি","audioUrl":"wbw/066_001_011.mp3","charTypeName":"word"},{"id":566,"position":11,"arabic":"أَزْوَٰجِكَ ۚ","translation":"তোমার স্ত্রীদের","audioUrl":"wbw/066_001_012.mp3","charTypeName":"word"},{"id":568,"position":12,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/066_001_014.mp3","charTypeName":"word"},{"id":569,"position":13,"arabic":"غَفُورٌۭ","translation":"ক্ষমাশীল","audioUrl":"wbw/066_001_015.mp3","charTypeName":"word"},{"id":570,"position":14,"arabic":"رَّحِيمٌۭ","translation":"মেহেরবান","audioUrl":"wbw/066_001_016.mp3","charTypeName":"word"},{"id":571,"position":15,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"قَدْ فَرَضَ ٱللَّهُ لَكُمْ تَحِلَّةَ أَيْمَٰنِكُمْ ۚ وَٱللَّهُ مَوْلَىٰكُمْ ۖ وَهُوَ ٱلْعَلِيمُ ٱلْحَكِيمُ","translation":"God has already enjoined upon you [O believers] the breaking and expiation of [such of] your oaths [as may run counter to what is right and just]: for, God is your Lord Supreme, and He alone is all-knowing, truly wise.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5231.mp3","surahId":66,"words":[{"id":1448,"position":1,"arabic":"قَدْ","translation":"নিশ্চয়","audioUrl":"wbw/066_002_001.mp3","charTypeName":"word"},{"id":1449,"position":2,"arabic":"فَرَضَ","translation":"নির্দিষ্ট করেছেন","audioUrl":"wbw/066_002_002.mp3","charTypeName":"word"},{"id":1450,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/066_002_003.mp3","charTypeName":"word"},{"id":1451,"position":4,"arabic":"لَكُمْ","translation":"তোমাদের জন্যে","audioUrl":"wbw/066_002_004.mp3","charTypeName":"word"},{"id":1452,"position":5,"arabic":"تَحِلَّةَ","translation":"মুক্তির ব্যবস্থা","audioUrl":"wbw/066_002_005.mp3","charTypeName":"word"},{"id":1453,"position":6,"arabic":"أَيْمَـٰنِكُمْ ۚ","translation":"তোমাদের শপথগুলোর","audioUrl":"wbw/066_002_006.mp3","charTypeName":"word"},{"id":1455,"position":7,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/066_002_008.mp3","charTypeName":"word"},{"id":1456,"position":8,"arabic":"مَوْلَىٰكُمْ ۖ","translation":"তোমাদের মনিব","audioUrl":"wbw/066_002_009.mp3","charTypeName":"word"},{"id":1458,"position":9,"arabic":"وَهُوَ","translation":"এবং তিনিই","audioUrl":"wbw/066_002_011.mp3","charTypeName":"word"},{"id":1459,"position":10,"arabic":"ٱلْعَلِيمُ","translation":"সর্বজ্ঞ","audioUrl":"wbw/066_002_012.mp3","charTypeName":"word"},{"id":1460,"position":11,"arabic":"ٱلْحَكِيمُ","translation":"প্রজ্ঞাময়","audioUrl":"wbw/066_002_013.mp3","charTypeName":"word"},{"id":1461,"position":12,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"وَإِذْ أَسَرَّ ٱلنَّبِىُّ إِلَىٰ بَعْضِ أَزْوَٰجِهِۦ حَدِيثًۭا فَلَمَّا نَبَّأَتْ بِهِۦ وَأَظْهَرَهُ ٱللَّهُ عَلَيْهِ عَرَّفَ بَعْضَهُۥ وَأَعْرَضَ عَنۢ بَعْضٍۢ ۖ فَلَمَّا نَبَّأَهَا بِهِۦ قَالَتْ مَنْ أَنۢبَأَكَ هَٰذَا ۖ قَالَ نَبَّأَنِىَ ٱلْعَلِيمُ ٱلْخَبِيرُ","translation":"And lo! [It so happened that] the Prophet told something in confidence to one of his wives; and when she thereupon divulged it, and God made this known to him, he acquainted [others] with some of it and passed over some of it. And as soon as he let her know it, she asked, \"Who has told thee this?\" - [to which] he replied, \"The All-Knowing, the All-Aware has told me.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5232.mp3","surahId":66,"words":[{"id":2493,"position":1,"arabic":"وَإِذْ","translation":"এবং যখন","audioUrl":"wbw/066_003_001.mp3","charTypeName":"word"},{"id":2494,"position":2,"arabic":"أَسَرَّ","translation":"গোপনে বলেছিল","audioUrl":"wbw/066_003_002.mp3","charTypeName":"word"},{"id":2495,"position":3,"arabic":"ٱلنَّبِىُّ","translation":"নবী","audioUrl":"wbw/066_003_003.mp3","charTypeName":"word"},{"id":2496,"position":4,"arabic":"إِلَىٰ","translation":"নিকট","audioUrl":"wbw/066_003_004.mp3","charTypeName":"word"},{"id":2497,"position":5,"arabic":"بَعْضِ","translation":"কারও","audioUrl":"wbw/066_003_005.mp3","charTypeName":"word"},{"id":2498,"position":6,"arabic":"أَزْوَٰجِهِۦ","translation":"তার স্ত্রীদের","audioUrl":"wbw/066_003_006.mp3","charTypeName":"word"},{"id":2499,"position":7,"arabic":"حَدِيثًۭا","translation":"একটি কথা","audioUrl":"wbw/066_003_007.mp3","charTypeName":"word"},{"id":2500,"position":8,"arabic":"فَلَمَّا","translation":"যখন অতঃপর","audioUrl":"wbw/066_003_008.mp3","charTypeName":"word"},{"id":2501,"position":9,"arabic":"نَبَّأَتْ","translation":"সে বলে দেয় (অন্য স্ত্রীকে)","audioUrl":"wbw/066_003_009.mp3","charTypeName":"word"},{"id":2502,"position":10,"arabic":"بِهِۦ","translation":"তা সম্পর্কে","audioUrl":"wbw/066_003_010.mp3","charTypeName":"word"},{"id":2503,"position":11,"arabic":"وَأَظْهَرَهُ","translation":"ও তা প্রকাশ করলেন","audioUrl":"wbw/066_003_011.mp3","charTypeName":"word"},{"id":2504,"position":12,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/066_003_012.mp3","charTypeName":"word"},{"id":2505,"position":13,"arabic":"عَلَيْهِ","translation":"তার নিকট","audioUrl":"wbw/066_003_013.mp3","charTypeName":"word"},{"id":2506,"position":14,"arabic":"عَرَّفَ","translation":"(নবী) ব্যক্ত করল","audioUrl":"wbw/066_003_014.mp3","charTypeName":"word"},{"id":2507,"position":15,"arabic":"بَعْضَهُۥ","translation":"তার কিছুটা","audioUrl":"wbw/066_003_015.mp3","charTypeName":"word"},{"id":2508,"position":16,"arabic":"وَأَعْرَضَ","translation":"ও এড়িয়ে গেল","audioUrl":"wbw/066_003_016.mp3","charTypeName":"word"},{"id":2509,"position":17,"arabic":"عَنۢ","translation":"(যে)","audioUrl":"wbw/066_003_017.mp3","charTypeName":"word"},{"id":2510,"position":18,"arabic":"بَعْضٍۢ ۖ","translation":"কিছু","audioUrl":"wbw/066_003_018.mp3","charTypeName":"word"},{"id":2512,"position":19,"arabic":"فَلَمَّا","translation":"যখন অতঃপর","audioUrl":"wbw/066_003_020.mp3","charTypeName":"word"},{"id":2513,"position":20,"arabic":"نَبَّأَهَا","translation":"তাকে জানাল","audioUrl":"wbw/066_003_021.mp3","charTypeName":"word"},{"id":2514,"position":21,"arabic":"بِهِۦ","translation":"সে সম্পর্কে","audioUrl":"wbw/066_003_022.mp3","charTypeName":"word"},{"id":2515,"position":22,"arabic":"قَالَتْ","translation":"সে বলল (স্ত্রী)","audioUrl":"wbw/066_003_023.mp3","charTypeName":"word"},{"id":2516,"position":23,"arabic":"مَنْ","translation":"\"কে","audioUrl":"wbw/066_003_024.mp3","charTypeName":"word"},{"id":2517,"position":24,"arabic":"أَنۢبَأَكَ","translation":"আপনাকে খবর দিল","audioUrl":"wbw/066_003_025.mp3","charTypeName":"word"},{"id":2518,"position":25,"arabic":"هَـٰذَا ۖ","translation":"এটা\"","audioUrl":"wbw/066_003_026.mp3","charTypeName":"word"},{"id":2520,"position":26,"arabic":"قَالَ","translation":"বলল (নবী)","audioUrl":"wbw/066_003_028.mp3","charTypeName":"word"},{"id":2521,"position":27,"arabic":"نَبَّأَنِىَ","translation":"\"আমাকে খবর দিয়েছেন","audioUrl":"wbw/066_003_029.mp3","charTypeName":"word"},{"id":2522,"position":28,"arabic":"ٱلْعَلِيمُ","translation":"সর্বজ্ঞ","audioUrl":"wbw/066_003_030.mp3","charTypeName":"word"},{"id":2523,"position":29,"arabic":"ٱلْخَبِيرُ","translation":"ওয়াকিবহাল\"","audioUrl":"wbw/066_003_031.mp3","charTypeName":"word"},{"id":2524,"position":30,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"إِن تَتُوبَآ إِلَى ٱللَّهِ فَقَدْ صَغَتْ قُلُوبُكُمَا ۖ وَإِن تَظَٰهَرَا عَلَيْهِ فَإِنَّ ٱللَّهَ هُوَ مَوْلَىٰهُ وَجِبْرِيلُ وَصَٰلِحُ ٱلْمُؤْمِنِينَ ۖ وَٱلْمَلَٰٓئِكَةُ بَعْدَ ذَٰلِكَ ظَهِيرٌ","translation":"[Say, O Prophet:] \"Would that you two turn unto God in repentance, for the hearts of both of you have swerved [from what is right]! And if you uphold each other against him [who is God's message-bearer, know that] God Himself is his Protector, and [that,] therefore, Gabriel, and all the righteous among the believers and all the [other] angels will come to his aid.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5233.mp3","surahId":66,"words":[{"id":3918,"position":1,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/066_004_001.mp3","charTypeName":"word"},{"id":3919,"position":2,"arabic":"تَتُوبَآ","translation":"তোমরা দুজনে তওবা কর","audioUrl":"wbw/066_004_002.mp3","charTypeName":"word"},{"id":3920,"position":3,"arabic":"إِلَى","translation":"নিকট","audioUrl":"wbw/066_004_003.mp3","charTypeName":"word"},{"