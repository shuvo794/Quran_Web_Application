{"id":432,"ayahs":[{"number":32,"arabic":"قَالَ ٱلَّذِينَ ٱسْتَكْبَرُوا۟ لِلَّذِينَ ٱسْتُضْعِفُوٓا۟ أَنَحْنُ صَدَدْنَٰكُمْ عَنِ ٱلْهُدَىٰ بَعْدَ إِذْ جَآءَكُم ۖ بَلْ كُنتُم مُّجْرِمِينَ","translation":"[And] those who were wont to glory in their arrogance will say unto those who had been weak: “Why - did we keep you [forcibly] from following the right path after it had become obvious to you? Nay, it was but you [yourselves] who were guilty!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3638.mp3","surahId":34,"words":[{"id":35063,"position":1,"arabic":"قَالَ","translation":"বলবে","audioUrl":"wbw/034_032_001.mp3","charTypeName":"word"},{"id":35064,"position":2,"arabic":"ٱلَّذِينَ","translation":"(তারা) যারা","audioUrl":"wbw/034_032_002.mp3","charTypeName":"word"},{"id":35065,"position":3,"arabic":"ٱسْتَكْبَرُوا۟","translation":"অহংকারী করেছিলো","audioUrl":"wbw/034_032_003.mp3","charTypeName":"word"},{"id":35066,"position":4,"arabic":"لِلَّذِينَ","translation":"উদ্দেশ্যে (তাদের) যাদের","audioUrl":"wbw/034_032_004.mp3","charTypeName":"word"},{"id":35067,"position":5,"arabic":"ٱسْتُضْعِفُوٓا۟","translation":"দুর্বল করে রাখা হয়েছিলো","audioUrl":"wbw/034_032_005.mp3","charTypeName":"word"},{"id":35068,"position":6,"arabic":"أَنَحْنُ","translation":"\"কি আমরা","audioUrl":"wbw/034_032_006.mp3","charTypeName":"word"},{"id":35069,"position":7,"arabic":"صَدَدْنَـٰكُمْ","translation":"আমরা বাধা দিয়েছিলাম তোমাদেরকে","audioUrl":"wbw/034_032_007.mp3","charTypeName":"word"},{"id":35070,"position":8,"arabic":"عَنِ","translation":"হ'তে","audioUrl":"wbw/034_032_008.mp3","charTypeName":"word"},{"id":35071,"position":9,"arabic":"ٱلْهُدَىٰ","translation":"সৎপথ","audioUrl":"wbw/034_032_009.mp3","charTypeName":"word"},{"id":35072,"position":10,"arabic":"بَعْدَ","translation":"পরে","audioUrl":"wbw/034_032_010.mp3","charTypeName":"word"},{"id":35073,"position":11,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/034_032_011.mp3","charTypeName":"word"},{"id":35074,"position":12,"arabic":"جَآءَكُم ۖ","translation":"এসেছিলো তোমাদের কাছে","audioUrl":"wbw/034_032_012.mp3","charTypeName":"word"},{"id":35076,"position":13,"arabic":"بَلْ","translation":"বরং","audioUrl":"wbw/034_032_014.mp3","charTypeName":"word"},{"id":35077,"position":14,"arabic":"كُنتُم","translation":"তোমরা ছিলে","audioUrl":"wbw/034_032_015.mp3","charTypeName":"word"},{"id":35078,"position":15,"arabic":"مُّجْرِمِينَ","translation":"অপরাধী\"","audioUrl":"wbw/034_032_016.mp3","charTypeName":"word"},{"id":35079,"position":16,"arabic":"٣٢","translation":"(৩২)","audioUrl":null,"charTypeName":"end"}]},{"number":33,"arabic":"وَقَالَ ٱلَّذِينَ ٱسْتُضْعِفُوا۟ لِلَّذِينَ ٱسْتَكْبَرُوا۟ بَلْ مَكْرُ ٱلَّيْلِ وَٱلنَّهَارِ إِذْ تَأْمُرُونَنَآ أَن نَّكْفُرَ بِٱللَّهِ وَنَجْعَلَ لَهُۥٓ أَندَادًۭا ۚ وَأَسَرُّوا۟ ٱلنَّدَامَةَ لَمَّا رَأَوُا۟ ٱلْعَذَابَ وَجَعَلْنَا ٱلْأَغْلَٰلَ فِىٓ أَعْنَاقِ ٱلَّذِينَ كَفَرُوا۟ ۚ هَلْ يُجْزَوْنَ إِلَّا مَا كَانُوا۟ يَعْمَلُونَ","translation":"But those who had been weak will say unto those who had gloried in their arrogance: “Nay, [what kept us away was your] devising of false arguments, night and day, [against God’s messages- as you did] when you persuaded us to blaspheme against God and to claim that there are powers that could rival Him!” And when they see the suffering [that awaits them], they will [all] be unable to express [the full depth of] their remorse: for We shall have put shackles around the necks of those who had been bent on denying the truth: [and] will this be aught but a [just] requital for what they were doing?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3639.mp3","surahId":34,"words":[{"id":35908,"position":1,"arabic":"وَقَالَ","translation":"এবং বলবে","audioUrl":"wbw/034_033_001.mp3","charTypeName":"word"},{"id":35909,"position":2,"arabic":"ٱلَّذِينَ","translation":"(তারা) যাদের","audioUrl":"wbw/034_033_002.mp3","charTypeName":"word"},{"id":35910,"position":3,"arabic":"ٱسْتُضْعِفُوا۟","translation":"দুর্বল করে রাখা হয়েছিলো","audioUrl":"wbw/034_033_003.mp3","charTypeName":"word"},{"id":35911,"position":4,"arabic":"لِلَّذِينَ","translation":"উদ্দেশ্যে (তাদের) যারা","audioUrl":"wbw/034_033_004.mp3","charTypeName":"word"},{"id":35912,"position":5,"arabic":"ٱسْتَكْبَرُوا۟","translation":"অহংকারী করেছিলো","audioUrl":"wbw/034_033_005.mp3","charTypeName":"word"},{"id":35913,"position":6,"arabic":"بَلْ","translation":"\"বরং","audioUrl":"wbw/034_033_006.mp3","charTypeName":"word"},{"id":35914,"position":7,"arabic":"مَكْرُ","translation":"চক্রান্ত (ছিলো)","audioUrl":"wbw/034_033_007.mp3","charTypeName":"word"},{"id":35915,"position":8,"arabic":"ٱلَّيْلِ","translation":"রাতের","audioUrl":"wbw/034_033_008.mp3","charTypeName":"word"},{"id":35916,"position":9,"arabic":"وَٱلنَّهَارِ","translation":"ও দিনের","audioUrl":"wbw/034_033_009.mp3","charTypeName":"word"},{"id":35917,"position":10,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/034_033_010.mp3","charTypeName":"word"},{"id":35918,"position":11,"arabic":"تَأْمُرُونَنَآ","translation":"তোমরা নির্দেশ দিতে আমাদেরকে","audioUrl":"wbw/034_033_011.mp3","charTypeName":"word"},{"id":35919,"position":12,"arabic":"أَن","translation":"যেন","audioUrl":"wbw/034_033_012.mp3","charTypeName":"word"},{"id":35920,"position":13,"arabic":"نَّكْفُرَ","translation":"আমরা অস্বীকার করি","audioUrl":"wbw/034_033_013.mp3","charTypeName":"word"},{"id":35921,"position":14,"arabic":"بِٱللَّهِ","translation":"প্রতি আল্লাহর","audioUrl":"wbw/034_033_014.mp3","charTypeName":"word"},{"id":35922,"position":15,"arabic":"وَنَجْعَلَ","translation":"ও আমরা বানাই (যেন)","audioUrl":"wbw/034_033_015.mp3","charTypeName":"word"},{"id":35923,"position":16,"arabic":"لَهُۥٓ","translation":"জন্যে তাঁর","audioUrl":"wbw/034_033_016.mp3","charTypeName":"word"},{"id":35924,"position":17,"arabic":"أَندَادًۭا ۚ","translation":"সমকক্ষ\"","audioUrl":"wbw/034_033_017.mp3","charTypeName":"word"},{"id":35926,"position":18,"arabic":"وَأَسَرُّوا۟","translation":"এবং তারা গোপন করবে","audioUrl":"wbw/034_033_019.mp3","charTypeName":"word"},{"id":35927,"position":19,"arabic":"ٱلنَّدَامَةَ","translation":"অনুতাপ","audioUrl":"wbw/034_033_020.mp3","charTypeName":"word"},{"id":35928,"position":20,"arabic":"لَمَّا","translation":"যখন","audioUrl":"wbw/034_033_021.mp3","charTypeName":"word"},{"id":35929,"position":21,"arabic":"رَأَوُا۟","translation":"তারা দেখবে","audioUrl":"wbw/034_033_022.mp3","charTypeName":"word"},{"id":35930,"position":22,"arabic":"ٱلْعَذَابَ","translation":"শাস্তি","audioUrl":"wbw/034_033_023.mp3","charTypeName":"word"},{"id":35931,"position":23,"arabic":"وَجَعَلْنَا","translation":"এবং আমরা পরিয়ে দিবো","audioUrl":"wbw/034_033_024.mp3","charTypeName":"word"},{"id":35932,"position":24,"arabic":"ٱلْأَغْلَـٰلَ","translation":"শিকলসমূহ","audioUrl":"wbw/034_033_025.mp3","charTypeName":"word"},{"id":35933,"position":25,"arabic":"فِىٓ","translation":"মধ্যে","audioUrl":"wbw/034_033_026.mp3","charTypeName":"word"},{"id":35934,"position":26,"arabic":"أَعْنَاقِ","translation":"গলাসমূহের","audioUrl":"wbw/034_033_027.mp3","charTypeName":"word"},{"id":35935,"position":27,"arabic":"ٱلَّذِينَ","translation":"(তাদের) যারা","audioUrl":"wbw/034_033_028.mp3","charTypeName":"word"},{"id":35936,"position":28,"arabic":"كَفَرُوا۟ ۚ","translation":"অবিশ্বাস করেছে","audioUrl":"wbw/034_033_029.mp3","charTypeName":"word"},{"id":35938,"position":29,"arabic":"هَلْ","translation":"কি","audioUrl":"wbw/034_033_031.mp3","charTypeName":"word"},{"id":35939,"position":30,"arabic":"يُجْزَوْنَ","translation":"তাদেরকে প্রতিফল দেয়া হবে","audioUrl":"wbw/034_033_032.mp3","charTypeName":"word"},{"id":35940,"position":31,"arabic":"إِلَّا","translation":"এছাড়া","audioUrl":"wbw/034_033_033.mp3","charTypeName":"word"},{"id":35941,"position":32,"arabic":"مَا","translation":"যা","audioUrl":"wbw/034_033_034.mp3","charTypeName":"word"},{"id":35942,"position":33,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/034_033_035.mp3","charTypeName":"word"},{"id":35943,"position":34,"arabic":"يَعْمَلُونَ","translation":"তারা কাজ করতে","audioUrl":"wbw/034_033_036.mp3","charTypeName":"word"},{"id":35944,"position":35,"arabic":"٣٣","translation":"(৩৩)","audioUrl":null,"charTypeName":"end"}]},{"number":34,"arabic":"وَمَآ أَرْسَلْنَا فِى قَرْيَةٍۢ مِّن نَّذِيرٍ إِلَّا قَالَ مُتْرَفُوهَآ إِنَّا بِمَآ أُرْسِلْتُم بِهِۦ كَٰفِرُونَ","translation":"For [thus it is:] whenever We sent a warner to any community, those of its people who had lost themselves entirely in the pursuit of pleasures would declare, “Behold, we deny that there is any truth in [what you claim to be] your message!” –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3640.mp3","surahId":34,"words":[{"id":36808,"position":1,"arabic":"وَمَآ","translation":"এবং না","audioUrl":"wbw/034_034_001.mp3","charTypeName":"word"},{"id":36809,"position":2,"arabic":"أَرْسَلْنَا","translation":"আমরা পাঠিয়েছি","audioUrl":"wbw/034_034_002.mp3","charTypeName":"word"},{"id":36810,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/034_034_003.mp3","charTypeName":"word"},{"id":36811,"position":4,"arabic":"قَرْيَةٍۢ","translation":"কোনো জনবসতির","audioUrl":"wbw/034_034_004.mp3","charTypeName":"word"},{"id":36812,"position":5,"arabic":"مِّن","translation":"কোনো","audioUrl":"wbw/034_034_005.mp3","charTypeName":"word"},{"id":36813,"position":6,"arabic":"نَّذِيرٍ","translation":"সতর্ককারী","audioUrl":"wbw/034_034_006.mp3","charTypeName":"word"},{"id":36814,"position":7,"arabic":"إِلَّا","translation":"এছাড়া","audioUrl":"wbw/034_034_007.mp3","charTypeName":"word"},{"id":36815,"position":8,"arabic":"قَالَ","translation":"বলেছিলো","audioUrl":"wbw/034_034_008.mp3","charTypeName":"word"},{"id":36816,"position":9,"arabic":"مُتْرَفُوهَآ","translation":"বিত্তশালীরা তার","audioUrl":"wbw/034_034_009.mp3","charTypeName":"word"},{"id":36817,"position":10,"arabic":"إِنَّا","translation":"\"নিশ্চয়ই আমরা","audioUrl":"wbw/034_034_010.mp3","charTypeName":"word"},{"id":36818,"position":11,"arabic":"بِمَآ","translation":"(ঐ বিষয়ে) যা নিয়ে","audioUrl":"wbw/034_034_011.mp3","charTypeName":"word"},{"id":36819,"position":12,"arabic":"أُرْسِلْتُم","translation":"তোমরা প্রেরিত হয়েছো","audioUrl":"wbw/034_034_012.mp3","charTypeName":"word"},{"id":36820,"position":13,"arabic":"بِهِۦ","translation":"সম্পর্কে তা","audioUrl":"wbw/034_034_013.mp3","charTypeName":"word"},{"id":36821,"position":14,"arabic":"كَـٰفِرُونَ","translation":"অস্বীকারকারী\"","audioUrl":"wbw/034_034_014.mp3","charTypeName":"word"},{"id":36822,"position":15,"arabic":"٣٤","translation":"(৩৪)","audioUrl":null,"charTypeName":"end"}]},{"number":35,"arabic":"وَقَالُوا۟ نَحْنُ أَكْثَرُ أَمْوَٰلًۭا وَأَوْلَٰدًۭا وَمَا نَحْنُ بِمُعَذَّبِينَ","translation":"and they would add, “Richer [than you] are we in wealth and in children, and [so] we are not going to be made to suffer!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3641.mp3","surahId":34,"words":[{"id":37168,"position":1,"arabic":"وَقَالُوا۟","translation":"এবং তারা বলতো","audioUrl":"wbw/034_035_001.mp3","charTypeName":"word"},{"id":37169,"position":2,"arabic":"نَحْنُ","translation":"\"আমরা","audioUrl":"wbw/034_035_002.mp3","charTypeName":"word"},{"id":37170,"position":3,"arabic":"أَكْثَرُ","translation":"অধিক","audioUrl":"wbw/034_035_003.mp3","charTypeName":"word"},{"id":37171,"position":4,"arabic":"أَمْوَٰلًۭا","translation":"সম্পদসমূহে","audioUrl":"wbw/034_035_004.mp3","charTypeName":"word"},{"id":37172,"position":5,"arabic":"وَأَوْلَـٰدًۭا","translation":"ও সন্তানাদিতে","audioUrl":"wbw/034_035_005.mp3","charTypeName":"word"},{"id":37173,"position":6,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/034_035_006.mp3","charTypeName":"word"},{"id":37174,"position":7,"arabic":"نَحْنُ","translation":"আমরা","audioUrl":"wbw/034_035_007.mp3","charTypeName":"word"},{"id":37175,"position":8,"arabic":"بِمُعَذَّبِينَ","translation":"শাস্তিপ্রাপ্ত হবো\"","audioUrl":"wbw/034_035_008.mp3","charTypeName":"word"},{"id":37176,"position":9,"arabic":"٣٥","translation":"(৩৫)","audioUrl":null,"charTypeName":"end"}]},{"number":36,"arabic":"قُلْ إِنَّ رَبِّى يَبْسُطُ ٱلرِّزْقَ لِمَن يَشَآءُ وَيَقْدِرُ وَلَٰكِنَّ أَكْثَرَ ٱلنَّاسِ لَا يَعْلَمُونَ","translation":"Say: “Behold, my Sustainer grants abundant sustenance, or gives it in scant measure, unto whomever He wills: but most men do not understand [God’s ways].”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3642.mp3","surahId":34,"words":[{"id":38493,"position":1,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/034_036_001.mp3","charTypeName":"word"},{"id":38494,"position":2,"arabic":"إِنَّ","translation":"\"নিশ্চয়ই","audioUrl":"wbw/034_036_002.mp3","charTypeName":"word"},{"id":38495,"position":3,"arabic":"رَبِّى","translation":"আমার রব","audioUrl":"wbw/034_036_003.mp3","charTypeName":"word"},{"id":38496,"position":4,"arabic":"يَبْسُطُ","translation":"প্রশস্ততা দেন","audioUrl":"wbw/034_036_004.mp3","charTypeName":"word"},{"id":38497,"position":5,"arabic":"ٱلرِّزْقَ","translation":"জীবিকায়","audioUrl":"wbw/034_036_005.mp3","charTypeName":"word"},{"id":38498,"position":6,"arabic":"لِمَن","translation":"জন্যে যার","audioUrl":"wbw/034_036_006.mp3","charTypeName":"word"},{"id":38499,"position":7,"arabic":"يَشَآءُ","translation":"তিনি ইচ্ছে করেন","audioUrl":"wbw/034_036_007.mp3","charTypeName":"word"},{"id":38500,"position":8,"arabic":"وَيَقْدِرُ","translation":"আবার পরিমিতও দেন","audioUrl":"wbw/034_036_008.mp3","charTypeName":"word"},{"id":38501,"position":9,"arabic":"وَلَـٰكِنَّ","translation":"কিন্তু","audioUrl":"wbw/034_036_009.mp3","charTypeName":"word"},{"id":38502,"position":10,"arabic":"أَكْثَرَ","translation":"অধিকাংশ","audioUrl":"wbw/034_036_010.mp3","charTypeName":"word"},{"id":38503,"position":11,"arabic":"ٱلنَّاسِ","translation":"মানুষ","audioUrl":"wbw/034_036_011.mp3","charTypeName":"word"},{"id":38504,"position":12,"arabic":"لَا","translation":"না","audioUrl":"wbw/034_036_012.mp3","charTypeName":"word"},{"id":38505,"position":13,"arabic":"يَعْلَمُونَ","translation":"তারা জানে\"","audioUrl":"wbw/034_036_013.mp3","charTypeName":"word"},{"id":38506,"position":14,"arabic":"٣٦","translation":"(৩৬)","audioUrl":null,"charTypeName":"end"}]},{"number":37,"arabic":"وَمَآ أَمْوَٰلُكُمْ وَلَآ أَوْلَٰدُكُم بِٱلَّتِى تُقَرِّبُكُمْ عِندَنَا زُلْفَىٰٓ إِلَّا مَنْ ءَامَنَ وَعَمِلَ صَٰلِحًۭا فَأُو۟لَٰٓئِكَ لَهُمْ جَزَآءُ ٱلضِّعْفِ بِمَا عَمِلُوا۟ وَهُمْ فِى ٱلْغُرُفَٰتِ ءَامِنُونَ","translation":"For, it is neither your riches nor your children that can bring you nearer to Us: only he who attains to faith and does what is right and just [comes near unto Us]; and it is [such as] these whom multiple recompense awaits for all that they have done; and it is they who shall dwell secure in the mansions [of paradise] –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3643.mp3","surahId":34,"words":[{"id":39326,"position":1,"arabic":"وَمَآ","translation":"এবং না","audioUrl":"wbw/034_037_001.mp3","charTypeName":"word"},{"id":39327,"position":2,"arabic":"أَمْوَٰلُكُمْ","translation":"সম্পদসমূহ তোমাদের","audioUrl":"wbw/034_037_002.mp3","charTypeName":"word"},{"id":39328,"position":3,"arabic":"وَلَآ","translation":"আর না","audioUrl":"wbw/034_037_003.mp3","charTypeName":"word"},{"id":39329,"position":4,"arabic":"أَوْلَـٰدُكُم","translation":"সন্তানাদি তোমাদের","audioUrl":"wbw/034_037_004.mp3","charTypeName":"word"},{"id":39330,"position":5,"arabic":"بِٱلَّتِى","translation":"ঐসব যা (না)","audioUrl":"wbw/034_037_005.mp3","charTypeName":"word"},{"id":39331,"position":6,"arabic":"تُقَرِّبُكُمْ","translation":"নিকটবর্তী করবে তোমাদেরকে","audioUrl":"wbw/034_037_006.mp3","charTypeName":"word"},{"id":39332,"position":7,"arabic":"عِندَنَا","translation":"কাছে আমাদের","audioUrl":"wbw/034_037_007.mp3","charTypeName":"word"},{"id":39333,"position":8,"arabic":"زُلْفَىٰٓ","translation":"নিকটবর্তী","audioUrl":"wbw/034_037_008.mp3","charTypeName":"word"},{"id":39334,"position":9,"arabic":"إِلَّا","tr