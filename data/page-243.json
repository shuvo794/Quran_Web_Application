_067_021.mp3","charTypeName":"word"},{"id":58241,"position":20,"arabic":"ٱلْحُكْمُ","translation":"বিধান দেয়ার অধিকার","audioUrl":"wbw/012_067_022.mp3","charTypeName":"word"},{"id":58242,"position":21,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/012_067_023.mp3","charTypeName":"word"},{"id":58243,"position":22,"arabic":"لِلَّهِ ۖ","translation":"আল্লাহ","audioUrl":"wbw/012_067_024.mp3","charTypeName":"word"},{"id":58245,"position":23,"arabic":"عَلَيْهِ","translation":"তাঁরই উপর","audioUrl":"wbw/012_067_026.mp3","charTypeName":"word"},{"id":58246,"position":24,"arabic":"تَوَكَّلْتُ ۖ","translation":"আমি নির্ভর করছি","audioUrl":"wbw/012_067_027.mp3","charTypeName":"word"},{"id":58248,"position":25,"arabic":"وَعَلَيْهِ","translation":"এবং তাঁরই উপর","audioUrl":"wbw/012_067_029.mp3","charTypeName":"word"},{"id":58249,"position":26,"arabic":"فَلْيَتَوَكَّلِ","translation":"নির্ভর করা উচিত","audioUrl":"wbw/012_067_030.mp3","charTypeName":"word"},{"id":58250,"position":27,"arabic":"ٱلْمُتَوَكِّلُونَ","translation":"ভরসাকারীদের\"","audioUrl":"wbw/012_067_031.mp3","charTypeName":"word"},{"id":58251,"position":28,"arabic":"٦٧","translation":"(৬৭)","audioUrl":null,"charTypeName":"end"}]},{"number":68,"arabic":"وَلَمَّا دَخَلُوا۟ مِنْ حَيْثُ أَمَرَهُمْ أَبُوهُم مَّا كَانَ يُغْنِى عَنْهُم مِّنَ ٱللَّهِ مِن شَىْءٍ إِلَّا حَاجَةًۭ فِى نَفْسِ يَعْقُوبَ قَضَىٰهَا ۚ وَإِنَّهُۥ لَذُو عِلْمٍۢ لِّمَا عَلَّمْنَٰهُ وَلَٰكِنَّ أَكْثَرَ ٱلنَّاسِ لَا يَعْلَمُونَ","translation":"But although they entered [Joseph's city] in the way their father had bidden them, this proved of no avail whatever to them against [the plan of] God [His request] had served only to satisfy Jacob's heartfelt desire [to protect them]: for, behold, thanks to what We had imparted unto him, he was indeed endowed with the knowledge [that God's will must always prevail]; but most people know it not.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1664.mp3","surahId":12,"words":[{"id":58610,"posit