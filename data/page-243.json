{"id":243,"ayahs":[{"number":64,"arabic":"قَالَ هَلْ ءَامَنُكُمْ عَلَيْهِ إِلَّا كَمَآ أَمِنتُكُمْ عَلَىٰٓ أَخِيهِ مِن قَبْلُ ۖ فَٱللَّهُ خَيْرٌ حَٰفِظًۭا ۖ وَهُوَ أَرْحَمُ ٱلرَّٰحِمِينَ","translation":"[Jacob] replied: \"Shall I trust you with him in the same way as I trusted you with his brother (Joseph] aforetime? [Nay,] but God's guardianship is better [than yours], for He is the most merciful of the merciful!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1660.mp3","surahId":12,"words":[{"id":56821,"position":1,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/012_064_001.mp3","charTypeName":"word"},{"id":56822,"position":2,"arabic":"هَلْ","translation":"\"কি","audioUrl":"wbw/012_064_002.mp3","charTypeName":"word"},{"id":56823,"position":3,"arabic":"ءَامَنُكُمْ","translation":"তোমাদের আমি বিশ্বাস করবো","audioUrl":"wbw/012_064_003.mp3","charTypeName":"word"},{"id":56824,"position":4,"arabic":"عَلَيْهِ","translation":"তার ব্যাপারে","audioUrl":"wbw/012_064_004.mp3","charTypeName":"word"},{"id":56825,"position":5,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/012_064_005.mp3","charTypeName":"word"},{"id":56826,"position":6,"arabic":"كَمَآ","translation":"যেমন","audioUrl":"wbw/012_064_006.mp3","charTypeName":"word"},{"id":56827,"position":7,"arabic":"أَمِنتُكُمْ","translation":"আমি বিশ্বাস করেছিলাম তোমাদেরকে","audioUrl":"wbw/012_064_007.mp3","charTypeName":"word"},{"id":56828,"position":8,"arabic":"عَلَىٰٓ","translation":"ব্যাপারে","audioUrl":"wbw/012_064_008.mp3","charTypeName":"word"},{"id":56829,"position":9,"arabic":"أَخِيهِ","translation":"তার ভাইয়ের","audioUrl":"wbw/012_064_009.mp3","charTypeName":"word"},{"id":56830,"position":10,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/012_064_010.mp3","charTypeName":"word"},{"id":56831,"position":11,"arabic":"قَبْلُ ۖ","translation":"পূর্ব","audioUrl":"wbw/012_064_011.mp3","charTypeName":"word"},{"id":56833,"position":12,"arabic":"فَٱللَّهُ","translation":"তবে আল্লাহই","audioUrl":"wbw/012_064_013.mp3","charTypeName":"word"},{"id":56834,"position":13,"arabic":"خَيْرٌ","translation":"উত্তম","audioUrl":"wbw/012_064_014.mp3","charTypeName":"word"},{"id":56835,"position":14,"arabic":"حَـٰفِظًۭا ۖ","translation":"রক্ষণাবেক্ষণকারী","audioUrl":"wbw/012_064_015.mp3","charTypeName":"word"},{"id":56837,"position":15,"arabic":"وَهُوَ","translation":"এবং তিনিই","audioUrl":"wbw/012_064_017.mp3","charTypeName":"word"},{"id":56838,"position":16,"arabic":"أَرْحَمُ","translation":"শ্রেষ্ঠ দয়ালু","audioUrl":"wbw/012_064_018.mp3","charTypeName":"word"},{"id":56839,"position":17,"arabic":"ٱلرَّٰحِمِينَ","translation":"দয়াশীলদের (মধ্যে)\"","audioUrl":"wbw/012_064_019.mp3","charTypeName":"word"},{"id":56840,"position":18,"arabic":"٦٤","translation":"(৬৪)","audioUrl":null,"charTypeName":"end"}]},{"number":65,"arabic":"وَلَمَّا فَتَحُوا۟ مَتَٰعَهُمْ وَجَدُوا۟ بِضَٰعَتَهُمْ رُدَّتْ إِلَيْهِمْ ۖ قَالُوا۟ يَٰٓأَبَانَا مَا نَبْغِى ۖ هَٰذِهِۦ بِضَٰعَتُنَا رُدَّتْ إِلَيْنَا ۖ وَنَمِيرُ أَهْلَنَا وَنَحْفَظُ أَخَانَا وَنَزْدَادُ كَيْلَ بَعِيرٍۢ ۖ ذَٰلِكَ كَيْلٌۭ يَسِيرٌۭ","translation":"Thereupon, when they opened their packs, they discovered that their merchandise had been returned to them; [and] they said: \"O our father! What more could we desire? Here is our merchandise: it has been returned to us! [If thou send Benjamin with us,] we shall (again] be able to bring food for our family, and shall guard our brother [well], and receive in addition another camel-load of grain That [which we have brought the first time] was but a scanty measure.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1661.mp3","surahId":12,"words":[{"id":57250,"position":1,"arabic":"وَلَمَّا","translation":"এবং যখন","audioUrl":"wbw/012_065_001.mp3","charTypeName":"word"},{"id":57251,"position":2,"arabic":"فَتَحُوا۟","translation":"তারা খুললো","audioUrl":"wbw/012_065_002.mp3","charTypeName":"word"},{"id":57252,"position":3,"arabic":"مَتَـٰعَهُمْ","translation":"তাদের মালপত্র","audioUrl":"wbw/012_065_003.mp3","charTypeName":"word"},{"id":57253,"position":4,"arabic":"وَجَدُوا۟","translation":"তারা পেলো","audioUrl":"wbw/012_065_004.mp3","charTypeName":"word"},{"id":57254,"position":5,"arabic":"بِضَـٰعَتَهُمْ","translation":"তাদের পণ্যমূল্য","audioUrl":"wbw/012_065_005.mp3","charTypeName":"word"},{"id":57255,"position":6,"arabic":"رُدَّتْ","translation":"ফেরত দেয়া হয়েছে","audioUrl":"wbw/012_065_006.mp3","charTypeName":"word"},{"id":57256,"position":7,"arabic":"إِلَيْهِمْ ۖ","translation":"তাদের প্রতি","audioUrl":"wbw/012_065_007.mp3","charTypeName":"word"},{"id":57258,"position":8,"arabic":"قَالُوا۟","translation":"তারা বললো","audioUrl":"wbw/012_065_009.mp3","charTypeName":"word"},{"id":57259,"position":9,"arabic":"يَـٰٓأَبَانَا","translation":"\"হে আমাদের পিতা","audioUrl":"wbw/012_065_010.mp3","charTypeName":"word"},{"id":57260,"position":10,"arabic":"مَا","translation":"কি","audioUrl":"wbw/012_065_011.mp3","charTypeName":"word"},{"id":57261,"position":11,"arabic":"نَبْغِى ۖ","translation":"আশা করি আমরা","audioUrl":"wbw/012_065_012.mp3","charTypeName":"word"},{"id":57263,"position":12,"arabic":"هَـٰذِهِۦ","translation":"এই যে","audioUrl":"wbw/012_065_014.mp3","charTypeName":"word"},{"id":57264,"position":13,"arabic":"بِضَـٰعَتُنَا","translation":"আমাদের পণ্যমূল্য","audioUrl":"wbw/012_065_015.mp3","charTypeName":"word"},{"id":57265,"position":14,"arabic":"رُدَّتْ","translation":"ফেরত দেয়া হয়েছে","audioUrl":"wbw/012_065_016.mp3","charTypeName":"word"},{"id":57266,"position":15,"arabic":"إِلَيْنَا ۖ","translation":"আমাদের প্রতি","audioUrl":"wbw/012_065_017.mp3","charTypeName":"word"},{"id":57268,"position":16,"arabic":"وَنَمِيرُ","translation":"এবং আমরা খাদ্য এনে দিবো","audioUrl":"wbw/012_065_019.mp3","charTypeName":"word"},{"id":57269,"position":17,"arabic":"أَهْلَنَا","translation":"আমাদের পরিবারকে","audioUrl":"wbw/012_065_020.mp3","charTypeName":"word"},{"id":57270,"position":18,"arabic":"وَنَحْفَظُ","translation":"আমরা দেখাশুনা করবো","audioUrl":"wbw/012_065_021.mp3","charTypeName":"word"},{"id":57271,"position":19,"arabic":"أَخَانَا","translation":"আমাদের ভাইকে","audioUrl":"wbw/012_065_022.mp3","charTypeName":"word"},{"id":57272,"position":20,"arabic":"وَنَزْدَادُ","translation":"ও অতিরিক্ত আনবো আমরা","audioUrl":"wbw/012_065_023.mp3","charTypeName":"word"},{"id":57273,"position":21,"arabic":"كَيْلَ","translation":"পরিমাণ (বরাদ্দ)","audioUrl":"wbw/012_065_024.mp3","charTypeName":"word"},{"id":57274,"position":22,"arabic":"بَعِيرٍۢ ۖ","translation":"এক উটবোঝাই","audioUrl":"wbw/012_065_025.mp3","charTypeName":"word"},{"id":57276,"position":23,"arabic":"ذَٰلِكَ","translation":"ঐ","audioUrl":"wbw/012_065_027.mp3","charTypeName":"word"},{"id":57277,"position":24,"arabic":"كَيْلٌۭ","translation":"পরিমাপ","audioUrl":"wbw/012_065_028.mp3","charTypeName":"word"},{"id":57278,"position":25,"arabic":"يَسِيرٌۭ","translation":"সহজ\"","audioUrl":"wbw/012_065_029.mp3","charTypeName":"word"},{"id":57279,"position":26,"arabic":"٦٥","translation":"(৬৫)","audioUrl":null,"charTypeName":"end"}]},{"number":66,"arabic":"قَالَ لَنْ أُرْسِلَهُۥ مَعَكُمْ حَتَّىٰ تُؤْتُونِ مَوْثِقًۭا مِّنَ ٱللَّهِ لَتَأْتُنَّنِى بِهِۦٓ إِلَّآ أَن يُحَاطَ بِكُمْ ۖ فَلَمَّآ ءَاتَوْهُ مَوْثِقَهُمْ قَالَ ٱللَّهُ عَلَىٰ مَا نَقُولُ وَكِيلٌۭ","translation":"Said [Jacob]: \"I will not send him with you until you give me a solemn pledge, before God, that you will indeed bring him back unto me, unless you yourselves be encompassed [by death]!\" And when they had given him their solemn pledge, [Jacob] said: \"God is witness to all that we say!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1662.mp3","surahId":12,"words":[{"id":57632,"position":1,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/012_066_001.mp3","charTypeName":"word"},{"id":57633,"position":2,"arabic":"لَنْ","translation":"\"কখনও না","audioUrl":"wbw/012_066_002.mp3","charTypeName":"word"},{"id":57634,"position":3,"arabic":"أُرْسِلَهُۥ","translation":"তাকে আমি পাঠাবো","audioUrl":"wbw/012_066_003.mp3","charTypeName":"word"},{"id":57635,"position":4,"arabic":"مَعَكُمْ","translation":"তোমাদের সাথে","audioUrl":"wbw/012_066_004.mp3","charTypeName":"word"},{"id":57636,"position":5,"arabic":"حَتَّىٰ","translation":"যতক্ষণ না","audioUrl":"wbw/012_066_005.mp3","charTypeName":"word"},{"id":57637,"position":6,"arabic":"تُؤْتُونِ","translation":"তোমরা দিবে আমাকে","audioUrl":"wbw/012_066_006.mp3","charTypeName":"word"},{"id":57638,"position":7,"arabic":"مَوْثِقًۭا","translation":"প্রতিশ্রুতি","audioUrl":"wbw/012_066_007.mp3","charTypeName":"word"},{"id":57639,"position":8,"arabic":"مِّنَ","translation":"নামে","audioUrl":"wbw/012_066_008.mp3","charTypeName":"word"},{"id":57640,"position":9,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌র","audioUrl":"wbw/012_066_009.mp3","charTypeName":"word"},{"id":57641,"position":10,"arabic":"لَتَأْتُنَّنِى","translation":"অবশ্যই আমার কাছে আসবে তোমরা","audioUrl":"wbw/012_066_010.mp3","charTypeName":"word"},{"id":57642,"position":11,"arabic":"بِهِۦٓ","translation":"নিয়ে তাকে","audioUrl":"wbw/012_066_011.mp3","charTypeName":"word"},{"id":57643,"position":12,"arabic":"إِلَّآ","translation":"তবে","audioUrl":"wbw/012_066_012.mp3","charTypeName":"word"},{"id":57644,"position":13,"arabic":"أَن","translation":"যদি","audioUrl":"wbw/012_066_013.mp3","charTypeName":"word"},{"id":57645,"position":14,"arabic":"يُحَاطَ","translation":"পরিবেষ্টিত করা হয় (সেটা ভিন্ন কথা)\"","audioUrl":"wbw/012_066_014.mp3","charTypeName":"word"},{"id":57646,"position":15,"arabic":"بِكُمْ ۖ","translation":"তোমাদেরকে\"","audioUrl":"wbw/012_066_015.mp3","charTypeName":"word"},{"id":57648,"position":16,"arabic":"فَلَمَّآ","translation":"অতঃপর যখন","audioUrl":"wbw/012_066_017.mp3","charTypeName":"word"},{"id":57649,"position":17,"arabic":"ءَاتَوْهُ","translation":"তাকে দিলো","audioUrl":"wbw/012_066_018.mp3","charTypeName":"word"},{"id":57650,"position":18,"arabic":"مَوْثِقَهُمْ","translation":"তাদের প্রতিশ্রুতি","audioUrl":"wbw/012_066_019.mp3","charTypeName":"word"},{"id":57651,"position":19,"arabic":"قَالَ","translation":"(ইয়াকুব) বললো","audioUrl":"wbw/012_066_020.mp3","charTypeName":"word"},{"id":57652,"position":20,"arabic":"ٱللَّهُ","translation":"\"আল্লাহর","audioUrl":"wbw/012_066_021.mp3","charTypeName":"word"},{"id":57653,"position":21,"arabic":"عَلَىٰ","translation":"উপর (ভরসা)","audioUrl":"wbw/012_066_022.mp3","charTypeName":"word"},{"id":57654,"position":22,"arabic":"مَا","translation":"যা","audioUrl":"wbw/012_066_023.mp3","charTypeName":"word"},{"id":57655,"position":23,"arabic":"نَقُولُ","translation":"আমরা বলছি","audioUrl":"wbw/012_066_024.mp3","charTypeName":"word"},{"id":57656,"position":24,"arabic":"وَكِيلٌۭ","translation":"তিনিই কর্মবিধায়ক\"","audioUrl":"wbw/012_066_025.mp3","charTypeName":"word"},{"id":57657,"position":25,"arabic":"٦٦","translation":"(৬৬)","audioUrl":null,"charTypeName":"end"}]},{"number":67,"arabic":"وَقَالَ يَٰبَنِىَّ لَا تَدْخُلُوا۟ مِنۢ بَابٍۢ وَٰحِدٍۢ وَٱدْخُلُوا۟ مِنْ أَبْوَٰبٍۢ مُّتَفَرِّقَةٍۢ ۖ وَمَآ أُغْنِى عَنكُم مِّنَ ٱللَّهِ مِن شَىْءٍ ۖ إِنِ ٱلْحُكْمُ إِلَّا لِلَّهِ ۖ عَلَيْهِ تَوَكَّلْتُ ۖ وَعَلَيْهِ فَلْيَتَوَكَّلِ ٱلْمُتَوَكِّلُونَ","translation":"And he added: \"O my sons! Do not enter [the city all] by one gate, but enter by different gates. Yet [even so,] I can be of no avail whatever to you against [anything that may be willed by] God: judgment [as to what is to happen] rests with none but God. In Him have I placed my trust: for, all who have trust [in His existence] must place their trust in Him alone.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1663.mp3","surahId":12,"words":[{"id":58220,"position":1,"arabic":"وَقَالَ","translation":"এবং সে বললো","audioUrl":"wbw/012_067_001.mp3","charTypeName":"word"},{"id":58221,"position":2,"arabic":"يَـٰبَنِىَّ","translation":"\"হে আমার ছেলেরা","audioUrl":"wbw/012_067_002.mp3","charTypeName":"word"},{"id":58222,"position":3,"arabic":"لَا","translation":"না","audioUrl":"wbw/012_067_003