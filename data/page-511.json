28/ar.alafasy/4591.mp3","surahId":48,"words":[{"id":8672,"position":1,"arabic":"إِنَّآ","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/048_008_001.mp3","charTypeName":"word"},{"id":8673,"position":2,"arabic":"أَرْسَلْنَـٰكَ","translation":"তোমাকে আমরা প্রেরণ করেছি","audioUrl":"wbw/048_008_002.mp3","charTypeName":"word"},{"id":8674,"position":3,"arabic":"شَـٰهِدًۭا","translation":"সাক্ষ্যদাতা","audioUrl":"wbw/048_008_003.mp3","charTypeName":"word"},{"id":8675,"position":4,"arabic":"وَمُبَشِّرًۭا","translation":"ও সুসংবাদদাতা হিসেবে","audioUrl":"wbw/048_008_004.mp3","charTypeName":"word"},{"id":8676,"position":5,"arabic":"وَنَذِيرًۭا","translation":"এবং সতর্ককারীরূপে","audioUrl":"wbw/048_008_005.mp3","charTypeName":"word"},{"id":8677,"position":6,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"لِّتُؤْمِنُوا۟ بِٱللَّهِ وَرَسُولِهِۦ وَتُعَزِّرُوهُ وَتُوَقِّرُوهُ وَتُسَبِّحُوهُ بُكْرَةًۭ وَأَصِيلًا","translation":"so that you [O men] might believe in God and His Apostle, and might honour Him, and revere Him, and extol His limitless glory from morn to evening.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4592.mp3","surahId":48,"words":[{"id":9868,"position":1,"arabic":"لِّتُؤْمِنُوا۟","translation":"যাতে তোমরা ঈমান আন","audioUrl":"wbw/048_009_001.mp3","charTypeName":"word"},{"id":9869,"position":2,"arabic":"بِٱللَّهِ","translation":"আল্লাহর উপর","audioUrl":"wbw/048_009_002.mp3","charTypeName":"word"},{"id":9870,"position":3,"arabic":"وَرَسُولِهِۦ","translation":"ও তাঁর রাসূলের উপর","audioUrl":"wbw/048_009_003.mp3","charTypeName":"word"},{"id":9871,"position":4,"arabic":"وَتُعَزِّرُوهُ","translation":"এবং তাঁকে তোমরা সাহায্য কর","audioUrl":"wbw/048_009_004.mp3","charTypeName":"word"},{"id":9872,"position":5,"arabic":"وَتُوَقِّرُوهُ","translation":"ও তাঁকে তোমরা সম্মান কর","audioUrl":"wbw/048_009_005.mp3","charTypeName":"word"},{"id":9873,"position":6,"arabic":"وَتُسَبِّحُوهُ","translation":"এবং তাঁর (অর্থাৎ 