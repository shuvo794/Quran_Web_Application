{"id":511,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ إِنَّا فَتَحْنَا لَكَ فَتْحًۭا مُّبِينًۭا","translation":"VERILY, [O Muhammad,] We have laid open before thee a manifest victory,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4584.mp3","surahId":48,"words":[{"id":226,"position":1,"arabic":"إِنَّا","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/048_001_001.mp3","charTypeName":"word"},{"id":227,"position":2,"arabic":"فَتَحْنَا","translation":"আমরা বিজয় দিয়েছি","audioUrl":"wbw/048_001_002.mp3","charTypeName":"word"},{"id":228,"position":3,"arabic":"لَكَ","translation":"তোমাকে (হে নবী)","audioUrl":"wbw/048_001_003.mp3","charTypeName":"word"},{"id":229,"position":4,"arabic":"فَتْحًۭا","translation":"বিজয়","audioUrl":"wbw/048_001_004.mp3","charTypeName":"word"},{"id":230,"position":5,"arabic":"مُّبِينًۭا","translation":"সুস্পষ্ট","audioUrl":"wbw/048_001_005.mp3","charTypeName":"word"},{"id":231,"position":6,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"لِّيَغْفِرَ لَكَ ٱللَّهُ مَا تَقَدَّمَ مِن ذَنۢبِكَ وَمَا تَأَخَّرَ وَيُتِمَّ نِعْمَتَهُۥ عَلَيْكَ وَيَهْدِيَكَ صِرَٰطًۭا مُّسْتَقِيمًۭا","translation":"so that God might show His forgiveness of all thy faults, past as well as future, and [thus] bestow upon thee the full measure of His blessings, and guide thee on a straight way,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4585.mp3","surahId":48,"words":[{"id":1099,"position":1,"arabic":"لِّيَغْفِرَ","translation":"তিনি ক্ষমা করেন যেন","audioUrl":"wbw/048_002_001.mp3","charTypeName":"word"},{"id":1100,"position":2,"arabic":"لَكَ","translation":"তোমাকে","audioUrl":"wbw/048_002_002.mp3","charTypeName":"word"},{"id":1101,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/048_002_003.mp3","charTypeName":"word"},{"id":1102,"position":4,"arabic":"مَا","translation":"যা","audioUrl":"wbw/048_002_004.mp3","charTypeName":"word"},{"id":1103,"position":5,"arabic":"تَقَدَّمَ","translation":"পূর্বে হয়েছে","audioUrl":"wbw/048_002_005.mp3","charTypeName":"word"},{"id":1104,"position":6,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/048_002_006.mp3","charTypeName":"word"},{"id":1105,"position":7,"arabic":"ذَنۢبِكَ","translation":"তোমার পাপ","audioUrl":"wbw/048_002_007.mp3","charTypeName":"word"},{"id":1106,"position":8,"arabic":"وَمَا","translation":"ও যা","audioUrl":"wbw/048_002_008.mp3","charTypeName":"word"},{"id":1107,"position":9,"arabic":"تَأَخَّرَ","translation":"পরে হয়েছে","audioUrl":"wbw/048_002_009.mp3","charTypeName":"word"},{"id":1108,"position":10,"arabic":"وَيُتِمَّ","translation":"এবং সম্পূর্ণ করেন (যেন)","audioUrl":"wbw/048_002_010.mp3","charTypeName":"word"},{"id":1109,"position":11,"arabic":"نِعْمَتَهُۥ","translation":"তাঁর অনুগ্রহ","audioUrl":"wbw/048_002_011.mp3","charTypeName":"word"},{"id":1110,"position":12,"arabic":"عَلَيْكَ","translation":"তোমার প্রতি","audioUrl":"wbw/048_002_012.mp3","charTypeName":"word"},{"id":1111,"position":13,"arabic":"وَيَهْدِيَكَ","translation":"ও তোমাকে পরিচালনা করেন","audioUrl":"wbw/048_002_013.mp3","charTypeName":"word"},{"id":1112,"position":14,"arabic":"صِرَٰطًۭا","translation":"পথে","audioUrl":"wbw/048_002_014.mp3","charTypeName":"word"},{"id":1113,"position":15,"arabic":"مُّسْتَقِيمًۭا","translation":"সরল সঠিক","audioUrl":"wbw/048_002_015.mp3","charTypeName":"word"},{"id":1114,"position":16,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"وَيَنصُرَكَ ٱللَّهُ نَصْرًا عَزِيزًا","translation":"and [show] that God will succour thee with [His] mighty succour.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4586.mp3","surahId":48,"words":[{"id":2152,"position":1,"arabic":"وَيَنصُرَكَ","translation":"এবং তোমাকে সাহায্য করেন যেন","audioUrl":"wbw/048_003_001.mp3","charTypeName":"word"},{"id":2153,"position":2,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/048_003_002.mp3","charTypeName":"word"},{"id":2154,"position":3,"arabic":"نَصْرًا","translation":"সাহায্য","audioUrl":"wbw/048_003_003.mp3","charTypeName":"word"},{"id":2155,"position":4,"arabic":"عَزِيزًا","translation":"বলিষ্ঠ/ জোর","audioUrl":"wbw/048_003_004.mp3","charTypeName":"word"},{"id":2156,"position":5,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"هُوَ ٱلَّذِىٓ أَنزَلَ ٱلسَّكِينَةَ فِى قُلُوبِ ٱلْمُؤْمِنِينَ لِيَزْدَادُوٓا۟ إِيمَٰنًۭا مَّعَ إِيمَٰنِهِمْ ۗ وَلِلَّهِ جُنُودُ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ ۚ وَكَانَ ٱللَّهُ عَلِيمًا حَكِيمًۭا","translation":"It is He who from on high has bestowed inner peace upon the hearts of the believers, so that - seeing that God’s are all the forces of the heavens and the earth, and that God is all-knowing, truly wise - they might grow yet more firm in their faith;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4587.mp3","surahId":48,"words":[{"id":3464,"position":1,"arabic":"هُوَ","translation":"তিনিই (আল্লাহ)","audioUrl":"wbw/048_004_001.mp3","charTypeName":"word"},{"id":3465,"position":2,"arabic":"ٱلَّذِىٓ","translation":"যিনি","audioUrl":"wbw/048_004_002.mp3","charTypeName":"word"},{"id":3466,"position":3,"arabic":"أَنزَلَ","translation":"অবতীর্ণ করেছেন","audioUrl":"wbw/048_004_003.mp3","charTypeName":"word"},{"id":3467,"position":4,"arabic":"ٱلسَّكِينَةَ","translation":"প্রশান্তি","audioUrl":"wbw/048_004_004.mp3","charTypeName":"word"},{"id":3468,"position":5,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/048_004_005.mp3","charTypeName":"word"},{"id":3469,"position":6,"arabic":"قُلُوبِ","translation":"অন্তর সমূহের","audioUrl":"wbw/048_004_006.mp3","charTypeName":"word"},{"id":3470,"position":7,"arabic":"ٱلْمُؤْمِنِينَ","translation":"মু'মিনদের","audioUrl":"wbw/048_004_007.mp3","charTypeName":"word"},{"id":3471,"position":8,"arabic":"لِيَزْدَادُوٓا۟","translation":"তারা বৃদ্ধি করে যেন","audioUrl":"wbw/048_004_008.mp3","charTypeName":"word"},{"id":3472,"position":9,"arabic":"إِيمَـٰنًۭا","translation":"(আরও) ঈমান","audioUrl":"wbw/048_004_009.mp3","charTypeName":"word"},{"id":3473,"position":10,"arabic":"مَّعَ","translation":"সাথে","audioUrl":"wbw/048_004_010.mp3","charTypeName":"word"},{"id":3474,"position":11,"arabic":"إِيمَـٰنِهِمْ ۗ","translation":"তাদের ঈমানের","audioUrl":"wbw/048_004_011.mp3","charTypeName":"word"},{"id":3476,"position":12,"arabic":"وَلِلَّهِ","translation":"এবং আল্লাহরই জন্য","audioUrl":"wbw/048_004_013.mp3","charTypeName":"word"},{"id":3477,"position":13,"arabic":"جُنُودُ","translation":"সৈন্যসমূহ","audioUrl":"wbw/048_004_014.mp3","charTypeName":"word"},{"id":3478,"position":14,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশের","audioUrl":"wbw/048_004_015.mp3","charTypeName":"word"},{"id":3479,"position":15,"arabic":"وَٱلْأَرْضِ ۚ","translation":"ও পৃথিবীর","audioUrl":"wbw/048_004_016.mp3","charTypeName":"word"},{"id":3481,"position":16,"arabic":"وَكَانَ","translation":"এবং হলেন","audioUrl":"wbw/048_004_018.mp3","charTypeName":"word"},{"id":3482,"position":17,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/048_004_019.mp3","charTypeName":"word"},{"id":3483,"position":18,"arabic":"عَلِيمًا","translation":"সর্বজ্ঞ","audioUrl":"wbw/048_004_020.mp3","charTypeName":"word"},{"id":3484,"position":19,"arabic":"حَكِيمًۭا","translation":"প্রজ্ঞাময়","audioUrl":"wbw/048_004_021.mp3","charTypeName":"word"},{"id":3485,"position":20,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"لِّيُدْخِلَ ٱلْمُؤْمِنِينَ وَٱلْمُؤْمِنَٰتِ جَنَّٰتٍۢ تَجْرِى مِن تَحْتِهَا ٱلْأَنْهَٰرُ خَٰلِدِينَ فِيهَا وَيُكَفِّرَ عَنْهُمْ سَيِّـَٔاتِهِمْ ۚ وَكَانَ ذَٰلِكَ عِندَ ٱللَّهِ فَوْزًا عَظِيمًۭا","translation":"[and] that He might admit the believers, both men and women, into gardens through which running waters flow, therein to abide, and that He might efface their [past bad] deeds: and that is, in the sight of God, indeed a triumph supreme!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4588.mp3","surahId":48,"words":[{"id":4819,"position":1,"arabic":"لِّيُدْخِلَ","translation":"প্রবেশ করান যেন","audioUrl":"wbw/048_005_001.mp3","charTypeName":"word"},{"id":4820,"position":2,"arabic":"ٱلْمُؤْمِنِينَ","translation":"মু'মিন পুরুষদেরকে","audioUrl":"wbw/048_005_002.mp3","charTypeName":"word"},{"id":4821,"position":3,"arabic":"وَٱلْمُؤْمِنَـٰتِ","translation":"ও মু'মিন নারীদেরকে","audioUrl":"wbw/048_005_003.mp3","charTypeName":"word"},{"id":4822,"position":4,"arabic":"جَنَّـٰتٍۢ","translation":"জান্নাতে","audioUrl":"wbw/048_005_004.mp3","charTypeName":"word"},{"id":4823,"position":5,"arabic":"تَجْرِى","translation":"প্রবাহিত হয়","audioUrl":"wbw/048_005_005.mp3","charTypeName":"word"},{"id":4824,"position":6,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/048_005_006.mp3","charTypeName":"word"},{"id":4825,"position":7,"arabic":"تَحْتِهَا","translation":"তার (যার) নিচ","audioUrl":"wbw/048_005_007.mp3","charTypeName":"word"},{"id":4826,"position":8,"arabic":"ٱلْأَنْهَـٰرُ","translation":"ঝর্ণাধারা সমূহ","audioUrl":"wbw/048_005_008.mp3","charTypeName":"word"},{"id":4827,"position":9,"arabic":"خَـٰلِدِينَ","translation":"তারা চিরস্থায়ী হবে","audioUrl":"wbw/048_005_009.mp3","charTypeName":"word"},{"id":4828,"position":10,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/048_005_010.mp3","charTypeName":"word"},{"id":4829,"position":11,"arabic":"وَيُكَفِّرَ","translation":"এবং মিটিয়ে দেবেন","audioUrl":"wbw/048_005_011.mp3","charTypeName":"word"},{"id":4830,"position":12,"arabic":"عَنْهُمْ","translation":"তাদের হতে","audioUrl":"wbw/048_005_012.mp3","charTypeName":"word"},{"id":4831,"position":13,"arabic":"سَيِّـَٔاتِهِمْ ۚ","translation":"তাদের দোষত্রুটি সমূহকে","audioUrl":"wbw/048_005_013.mp3","charTypeName":"word"},{"id":4833,"position":14,"arabic":"وَكَانَ","translation":"এবং হল","audioUrl":"wbw/048_005_015.mp3","charTypeName":"word"},{"id":4834,"position":15,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/048_005_016.mp3","charTypeName":"word"},{"id":4835,"position":16,"arabic":"عِندَ","translation":"নিকট","audioUrl":"wbw/048_005_017.mp3","charTypeName":"word"},{"id":4836,"position":17,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/048_005_018.mp3","charTypeName":"word"},{"id":4837,"position":18,"arabic":"فَوْزًا","translation":"সাফল্য","audioUrl":"wbw/048_005_019.mp3","charTypeName":"word"},{"id":4838,"position":19,"arabic":"عَظِيمًۭا","translation":"বিরাট","audioUrl":"wbw/048_005_020.mp3","charTypeName":"word"},{"id":4839,"position":20,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"وَيُعَذِّبَ ٱلْمُنَٰفِقِينَ وَٱلْمُنَٰفِقَٰتِ وَٱلْمُشْرِكِينَ وَٱلْمُشْرِكَٰتِ ٱلظَّآنِّينَ بِٱللَّهِ ظَنَّ ٱلسَّوْءِ ۚ عَلَيْهِمْ دَآئِرَةُ ٱلسَّوْءِ ۖ وَغَضِبَ ٱللَّهُ عَلَيْهِمْ وَلَعَنَهُمْ وَأَعَدَّ لَهُمْ جَهَنَّمَ ۖ وَسَآءَتْ مَصِيرًۭا","translation":"And [God has willed] to impose suffering [in the life to come] on the hypocrites, both men and women, and on those who ascribe divinity to aught beside Him, both men and women: all who entertain evil thoughts about God. Evil encompasses them from all sides, and God’s condemnation rests upon them; and He has rejected them [from His grace], and has readied hell for them: and how evil a journey’s end!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4589.mp3","surahId":48,"words":[{"id":6052,"position":1,"arabic":"وَيُعَذِّبَ","translation":"এবং তিনি শাস্তি দেবেন","audioUrl":"wbw/048_006_001.mp3","charTypeName":"word"},{"id":6053,"position":2,"arabic":"ٱلْمُنَـٰفِقِينَ","translation":"মুনাফেক পুরুষদেরকে","audioUrl":"wbw/048_006_002.mp3","charTypeName":"word"},{"id":6054,"position":3,"arabic":"وَٱلْمُنَـٰفِقَـٰتِ","translation":"ও মুনাফেক নারীদেরকে","audioUrl":"wbw/048_006_003.mp3","charTypeName":"word"},{"id":6055,"position":4,"arabic":"وَٱلْمُشْرِكِينَ","translation":"এবং মুশরিক পুরুষদেরকে","audioUrl":"wbw/048_006_004.mp3","charTypeName":"word"},{"id":6056,"position":5,"arabic":"وَٱلْمُشْرِكَ