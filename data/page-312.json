{"id":312,"ayahs":[{"number":96,"arabic":"إِنَّ ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ سَيَجْعَلُ لَهُمُ ٱلرَّحْمَٰنُ وُدًّۭا","translation":"VERILY, those who attain to faith and do righteous deeds will the Most Gracious endow with love:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2346.mp3","surahId":19,"words":[{"id":70147,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/019_096_001.mp3","charTypeName":"word"},{"id":70148,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/019_096_002.mp3","charTypeName":"word"},{"id":70149,"position":3,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/019_096_003.mp3","charTypeName":"word"},{"id":70150,"position":4,"arabic":"وَعَمِلُوا۟","translation":"ও কাজ করেছে","audioUrl":"wbw/019_096_004.mp3","charTypeName":"word"},{"id":70151,"position":5,"arabic":"ٱلصَّـٰلِحَـٰتِ","translation":"সৎ","audioUrl":"wbw/019_096_005.mp3","charTypeName":"word"},{"id":70152,"position":6,"arabic":"سَيَجْعَلُ","translation":"অচিরেই সৃষ্টি করবেন (মানুষের মনে)","audioUrl":"wbw/019_096_006.mp3","charTypeName":"word"},{"id":70153,"position":7,"arabic":"لَهُمُ","translation":"তাদের জন্য","audioUrl":"wbw/019_096_007.mp3","charTypeName":"word"},{"id":70154,"position":8,"arabic":"ٱلرَّحْمَـٰنُ","translation":"দয়াময়","audioUrl":"wbw/019_096_008.mp3","charTypeName":"word"},{"id":70155,"position":9,"arabic":"وُدًّۭا","translation":"ভালবাসা","audioUrl":"wbw/019_096_009.mp3","charTypeName":"word"},{"id":70156,"position":10,"arabic":"٩٦","translation":"(৯৬)","audioUrl":null,"charTypeName":"end"}]},{"number":97,"arabic":"فَإِنَّمَا يَسَّرْنَٰهُ بِلِسَانِكَ لِتُبَشِّرَ بِهِ ٱلْمُتَّقِينَ وَتُنذِرَ بِهِۦ قَوْمًۭا لُّدًّۭا","translation":"and only to this end have We made this [divine writ] easy to understand, in thine own tongue, [O Prophet,] so that thou might convey thereby a glad tiding to the God-conscious, and warn thereby those who are given to [futile] contention:","audio":"ht