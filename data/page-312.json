charTypeName":"end"}]},{"number":7,"arabic":"وَإِن تَجْهَرْ بِٱلْقَوْلِ فَإِنَّهُۥ يَعْلَمُ ٱلسِّرَّ وَأَخْفَى","translation":"And if thou say anything aloud, [He hears it] since, behold, He knows [even] the secret [thoughts of man] as well as all that is yet more hidden [within him].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2355.mp3","surahId":20,"words":[{"id":7450,"position":1,"arabic":"وَإِن","translation":"এবং যদি","audioUrl":"wbw/020_007_001.mp3","charTypeName":"word"},{"id":7451,"position":2,"arabic":"تَجْهَرْ","translation":"উঁচু গলায় বলো","audioUrl":"wbw/020_007_002.mp3","charTypeName":"word"},{"id":7452,"position":3,"arabic":"بِٱلْقَوْلِ","translation":"কথাকে ( তাও তিনি শুনেন )","audioUrl":"wbw/020_007_003.mp3","charTypeName":"word"},{"id":7453,"position":4,"arabic":"فَإِنَّهُۥ","translation":"তবে নিশ্চয়ই তিনি","audioUrl":"wbw/020_007_004.mp3","charTypeName":"word"},{"id":7454,"position":5,"arabic":"يَعْلَمُ","translation":"জানেন","audioUrl":"wbw/020_007_005.mp3","charTypeName":"word"},{"id":7455,"position":6,"arabic":"ٱلسِّرَّ","translation":"গুপ্ত","audioUrl":"wbw/020_007_006.mp3","charTypeName":"word"},{"id":7456,"position":7,"arabic":"وَأَخْفَى","translation":"এবং অব্যক্ত ( কথাও )","audioUrl":"wbw/020_007_007.mp3","charTypeName":"word"},{"id":7457,"position":8,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"ٱللَّهُ لَآ إِلَٰهَ إِلَّا هُوَ ۖ لَهُ ٱلْأَسْمَآءُ ٱلْحُسْنَىٰ","translation":"God-there is no deity save Him; His [alone] are the attributes of perfection!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2356.mp3","surahId":20,"words":[{"id":8709,"position":1,"arabic":"ٱللَّهُ","translation":"আল্লাহ ( এমন সত্ত্বা যে )","audioUrl":"wbw/020_008_001.mp3","charTypeName":"word"},{"id":8710,"position":2,"arabic":"لَآ","translation":"নেই","audioUrl":"wbw/020_008_002.mp3","charTypeName":"word"},{"id":8711,"position":3,"arabic":"إِلَـٰهَ","translation":"কোন ইলাহ","audioUrl":"wbw/020_008_003.mp3","charTypeName":"word"},{"id":8712,"position":4,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/020_008_004.mp3","charTypeName":"word"},{"id":8713,"position":5,"arabic":"هُوَ ۖ","translation":"তিনি","audioUrl":"wbw/020_008_005.mp3","charTypeName":"word"},{"id":8715,"position":6,"arabic":"لَهُ","translation":"তাঁরই আছে","audioUrl":"wbw/020_008_007.mp3","charTypeName":"word"},{"id":8716,"position":7,"arabic":"ٱلْأَسْمَآءُ","translation":"নামসমূহ","audioUrl":"wbw/020_008_008.mp3","charTypeName":"word"},{"id":8717,"position":8,"arabic":"ٱلْحُسْنَىٰ","translation":"সুন্দর","audioUrl":"wbw/020_008_009.mp3","charTypeName":"word"},{"id":8718,"position":9,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"وَهَلْ أَتَىٰكَ حَدِيثُ مُوسَىٰٓ","translation":"AND HAS the story of Moses ever come within thy ken?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2357.mp3","surahId":20,"words":[{"id":9935,"position":1,"arabic":"وَهَلْ","translation":"আর কি","audioUrl":"wbw/020_009_001.mp3","charTypeName":"word"},{"id":9936,"position":2,"arabic":"أَتَىٰكَ","translation":"তোমার কাছে এসেছে","audioUrl":"wbw/020_009_002.mp3","charTypeName":"word"},{"id":9937,"position":3,"arabic":"حَدِيثُ","translation":"বৃত্তান্ত","audioUrl":"wbw/020_009_003.mp3","charTypeName":"word"},{"id":9938,"position":4,"arabic":"مُوسَىٰٓ","translation":"মূসার","audioUrl":"wbw/020_009_004.mp3","charTypeName":"word"},{"id":9939,"position":5,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"إِذْ رَءَا نَارًۭا فَقَالَ لِأَهْلِهِ ٱمْكُثُوٓا۟ إِنِّىٓ ءَانَسْتُ نَارًۭا لَّعَلِّىٓ ءَاتِيكُم مِّنْهَا بِقَبَسٍ أَوْ أَجِدُ عَلَى ٱلنَّارِ هُدًۭى","translation":"Lo! he saw a fire [in the desert]; and so he said to his family: \"Wait here! Behold, I perceive a fire [far away]: perhaps I can bring you a brand there from, or find at the fire some guidance.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2358.mp3","surahId":20,"words":[{"id":11115,"position":1,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/020_010_001.mp3","charTypeName":"word"},{"id":11116,"position":2,"arabic":"رَءَا","translation":"সে দেখেছিলো","audioUrl":"wbw/020_010_002.mp3","charTypeName":"word"},{"id":11117,"position":3,"arabic":"نَارًۭا","translation":"আগুন","audioUrl":"wbw/020_010_003.mp3","charTypeName":"word"},{"id":11118,"position":4,"arabic":"فَقَالَ","translation":"তখন বলেছিলো","audioUrl":"wbw/020_010_004.mp3","charTypeName":"word"},{"id":11119,"position":5,"arabic":"لِأَهْلِهِ","translation":"তার পরিবারবর্গকে","audioUrl":"wbw/020_010_005.mp3","charTypeName":"word"},{"id":11120,"position":6,"arabic":"ٱمْكُثُوٓا۟","translation":"\"তোমরা থাকো ( অপেক্ষা করো )","audioUrl":"wbw/020_010_006.mp3","charTypeName":"word"},{"id":11121,"position":7,"arabic":"إِنِّىٓ","translation":"নিশ্চয়ই আমি","audioUrl":"wbw/020_010_007.mp3","charTypeName":"word"},{"id":11122,"position":8,"arabic":"ءَانَسْتُ","translation":"দেখেছি","audioUrl":"wbw/020_010_008.mp3","charTypeName":"word"},{"id":11123,"position":9,"arabic":"نَارًۭا","translation":"আগুন","audioUrl":"wbw/020_010_009.mp3","charTypeName":"word"},{"id":11124,"position":10,"arabic":"لَّعَلِّىٓ","translation":"সম্ভবতঃ আমি","audioUrl":"wbw/020_010_010.mp3","charTypeName":"word"},{"id":11125,"position":11,"arabic":"ءَاتِيكُم","translation":"তোমাদের কাছে আমি আসবো","audioUrl":"wbw/020_010_011.mp3","charTypeName":"word"},{"id":11126,"position":12,"arabic":"مِّنْهَا","translation":"তা থেকে","audioUrl":"wbw/020_010_012.mp3","charTypeName":"word"},{"id":11127,"position":13,"arabic":"بِقَبَسٍ","translation":"( কিছু ) অঙ্গার নিয়ে","audioUrl":"wbw/020_010_013.mp3","charTypeName":"word"},{"id":11128,"position":14,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/020_010_014.mp3","charTypeName":"word"},{"id":11129,"position":15,"arabic":"أَجِدُ","translation":"আমি পাবো","audioUrl":"wbw/020_010_015.mp3","charTypeName":"word"},{"id":11130,"position":16,"arabic":"عَلَى","translation":"কাছে","audioUrl":"wbw/020_010_016.mp3","charTypeName":"word"},{"id":11131,"position":17,"arabic":"ٱلنَّارِ","translation":"আগুনের","audioUrl":"wbw/020_010_017.mp3","charTypeName":"word"},{"id":11132,"position":18,"arabic":"هُدًۭى","translation":"পথের\"","audioUrl":"wbw/020_010_018.mp3","charTypeName":"word"},{"id":11133,"position":19,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"فَلَمَّآ أَتَىٰهَا نُودِىَ يَٰمُوسَىٰٓ","translation":"But when he came close to it, a voice called out: \"O Moses!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2359.mp3","surahId":20,"words":[{"id":12453,"position":1,"arabic":"فَلَمَّآ","translation":"অতঃপর যখন","audioUrl":"wbw/020_011_001.mp3","charTypeName":"word"},{"id":12454,"position":2,"arabic":"أَتَىٰهَا","translation":"তার কাছে আসলো","audioUrl":"wbw/020_011_002.mp3","charTypeName":"word"},{"id":12455,"position":3,"arabic":"نُودِىَ","translation":"তাকে ডাকা হলো","audioUrl":"wbw/020_011_003.mp3","charTypeName":"word"},{"id":12456,"position":4,"arabic":"يَـٰمُوسَىٰٓ","translation":"\"( বলা হলো ) হে মূসা","audioUrl":"wbw/020_011_004.mp3","charTypeName":"word"},{"id":12457,"position":5,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]},{"number":12,"arabic":"إِنِّىٓ أَنَا۠ رَبُّكَ فَٱخْلَعْ نَعْلَيْكَ ۖ إِنَّكَ بِٱلْوَادِ ٱلْمُقَدَّسِ طُوًۭى","translation":"Verily, I am thy Sustainer! Take off, then, thy sandals! Behold, thou art in the twice hallowed valley,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2360.mp3","surahId":20,"words":[{"id":13761,"position":1,"arabic":"إِنِّىٓ","translation":"নিশ্চয়ই আমি","audioUrl":"wbw/020_012_001.mp3","charTypeName":"word"},{"id":13762,"position":2,"arabic":"أَنَا۠","translation":"আমিই","audioUrl":"wbw/020_012_002.mp3","charTypeName":"word"},{"id":13763,"position":3,"arabic":"رَبُّكَ","translation":"তোমার রব","audioUrl":"wbw/020_012_003.mp3","charTypeName":"word"},{"id":13764,"position":4,"arabic":"فَٱخْلَعْ","translation":"অতএব খুলে ফেলো তুমি","audioUrl":"wbw/020_012_004.mp3","charTypeName":"word"},{"id":13765,"position":5,"arabic":"نَعْلَيْكَ ۖ","translation":"তোমার জুতা জোড়া","audioUrl":"wbw/020_012_005.mp3","charTypeName":"word"},{"id":13767,"position":6,"arabic":"إِنَّكَ","translation":"তুমি নিশ্চয়ই","audioUrl":"wbw/020_012_007.mp3","charTypeName":"word"},{"id":13768,"position":7,"arabic":"بِٱلْوَادِ","translation":"উপত্যকার মধ্যে","audioUrl":"wbw/020_012_008.mp3","charTypeName":"word"},{"id":13769,"position":8,"arabic":"ٱلْمُقَدَّسِ","translation":"পবিত্র","audioUrl":"wbw/020_012_009.mp3","charTypeName":"word"},{"id":13770,"position":9,"arabic":"طُوًۭى","translation":"( যার নাম ) তুওয়া","audioUrl":"wbw/020_012_010.mp3","charTypeName":"word"},{"id":13771,"position":10,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]}]}