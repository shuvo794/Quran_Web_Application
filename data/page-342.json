{"id":342,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ قَدْ أَفْلَحَ ٱلْمُؤْمِنُونَ","translation":"TRULY, to a happy state shall attain the believers:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2674.mp3","surahId":23,"words":[{"id":590,"position":1,"arabic":"قَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/023_001_001.mp3","charTypeName":"word"},{"id":591,"position":2,"arabic":"أَفْلَحَ","translation":"সফল হয়েছে","audioUrl":"wbw/023_001_002.mp3","charTypeName":"word"},{"id":592,"position":3,"arabic":"ٱلْمُؤْمِنُونَ","translation":"মু'মিনরা","audioUrl":"wbw/023_001_003.mp3","charTypeName":"word"},{"id":593,"position":4,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"ٱلَّذِينَ هُمْ فِى صَلَاتِهِمْ خَٰشِعُونَ","translation":"those who humble themselves in their prayer,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2675.mp3","surahId":23,"words":[{"id":1546,"position":1,"arabic":"ٱلَّذِينَ","translation":"যারা(এমন লোক যে)","audioUrl":"wbw/023_002_001.mp3","charTypeName":"word"},{"id":1547,"position":2,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/023_002_002.mp3","charTypeName":"word"},{"id":1548,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/023_002_003.mp3","charTypeName":"word"},{"id":1549,"position":4,"arabic":"صَلَاتِهِمْ","translation":"সালাতসমূহের তাদের","audioUrl":"wbw/023_002_004.mp3","charTypeName":"word"},{"id":1550,"position":5,"arabic":"خَـٰشِعُونَ","translation":"বিনয়ী-নম্র-ভীত","audioUrl":"wbw/023_002_005.mp3","charTypeName":"word"},{"id":1551,"position":6,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"وَٱلَّذِينَ هُمْ عَنِ ٱللَّغْوِ مُعْرِضُونَ","translation":"and who turn away from all that is frivolous,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2676.mp3","surahId":23,"words":[{"id":2581,"position":1,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা (ব