010.mp3","charTypeName":"word"},{"id":6508,"position":11,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"فَمَنِ ٱبْتَغَىٰ وَرَآءَ ذَٰلِكَ فَأُو۟لَٰٓئِكَ هُمُ ٱلْعَادُونَ","translation":"whereas such as seek to go beyond that [limit] are truly transgressors;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2680.mp3","surahId":23,"words":[{"id":7907,"position":1,"arabic":"فَمَنِ","translation":"তবে যে","audioUrl":"wbw/023_007_001.mp3","charTypeName":"word"},{"id":7908,"position":2,"arabic":"ٱبْتَغَىٰ","translation":"কামনা করে","audioUrl":"wbw/023_007_002.mp3","charTypeName":"word"},{"id":7909,"position":3,"arabic":"وَرَآءَ","translation":"বাইরে","audioUrl":"wbw/023_007_003.mp3","charTypeName":"word"},{"id":7910,"position":4,"arabic":"ذَٰلِكَ","translation":"এর","audioUrl":"wbw/023_007_004.mp3","charTypeName":"word"},{"id":7911,"position":5,"arabic":"فَأُو۟لَـٰٓئِكَ","translation":"সেক্ষেত্রে ঐসবলোক","audioUrl":"wbw/023_007_005.mp3","charTypeName":"word"},{"id":7912,"position":6,"arabic":"هُمُ","translation":"তারাই","audioUrl":"wbw/023_007_006.mp3","charTypeName":"word"},{"id":7913,"position":7,"arabic":"ٱلْعَادُونَ","translation":"সীমালঙ্ঘনকারী","audioUrl":"wbw/023_007_007.mp3","charTypeName":"word"},{"id":7914,"position":8,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"وَٱلَّذِينَ هُمْ لِأَمَٰنَٰتِهِمْ وَعَهْدِهِمْ رَٰعُونَ","translation":"and who are faithful to their trusts and to their pledges,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2681.mp3","surahId":23,"words":[{"id":9086,"position":1,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা (বৈশিষ্ট হলো যে)","audioUrl":"wbw/023_008_001.mp3","charTypeName":"word"},{"id":9087,"position":2,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/023_008_002.mp3","charTypeName":"word"},{"id":9088,"position":3,"arabic":"لِأَمَـٰنَـٰتِهِمْ","translation":"জন্যে তাদের আমানতসমূহের","audioUrl":"wbw/023_008_003.mp3","charTypeName":"word"},{"id":9089,"position":4,"arabic":"وَعَهْدِهِمْ","translation":"ও তাদের প্রতিশ্রুতির","audioUrl":"wbw/023_008_004.mp3","charTypeName":"word"},{"id":9090,"position":5,"arabic":"رَٰعُونَ","translation":"সংরক্ষণকারী","audioUrl":"wbw/023_008_005.mp3","charTypeName":"word"},{"id":9091,"position":6,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"وَٱلَّذِينَ هُمْ عَلَىٰ صَلَوَٰتِهِمْ يُحَافِظُونَ","translation":"and who guard their prayers [from all worldly intent].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2682.mp3","surahId":23,"words":[{"id":10299,"position":1,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা (বৈশিষ্ট্য হলো যে)","audioUrl":"wbw/023_009_001.mp3","charTypeName":"word"},{"id":10300,"position":2,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/023_009_002.mp3","charTypeName":"word"},{"id":10301,"position":3,"arabic":"عَلَىٰ","translation":"ক্ষেত্রে","audioUrl":"wbw/023_009_003.mp3","charTypeName":"word"},{"id":10302,"position":4,"arabic":"صَلَوَٰتِهِمْ","translation":"তাদের সালাতসমুহের","audioUrl":"wbw/023_009_004.mp3","charTypeName":"word"},{"id":10303,"position":5,"arabic":"يُحَافِظُونَ","translation":"তারা যত্ন করে","audioUrl":"wbw/023_009_005.mp3","charTypeName":"word"},{"id":10304,"position":6,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"أُو۟لَٰٓئِكَ هُمُ ٱلْوَٰرِثُونَ","translation":"It is they, they who shall be the inheritors","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2683.mp3","surahId":23,"words":[{"id":11531,"position":1,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐসবলোক","audioUrl":"wbw/023_010_001.mp3","charTypeName":"word"},{"id":11532,"position":2,"arabic":"هُمُ","translation":"তারাই","audioUrl":"wbw/023_010_002.mp3","charTypeName":"word"},{"id":11533,"position":3,"arabic":"ٱلْوَٰرِثُونَ","translation":"(সেই) উত্তরাধিকারী","audioUrl":"wbw/023_010_003.mp3","charTypeName":"word"},{"id":11534,"position":4,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"ٱلَّذِينَ يَرِثُونَ ٱلْفِرْدَوْسَ هُمْ فِيهَا خَٰلِدُونَ","translation":"that will inherit the paradise; [and] therein shall they abide.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2684.mp3","surahId":23,"words":[{"id":12558,"position":1,"arabic":"ٱلَّذِينَ","translation":"যা্রা","audioUrl":"wbw/023_011_001.mp3","charTypeName":"word"},{"id":12559,"position":2,"arabic":"يَرِثُونَ","translation":"উত্তরাধিকারী হয়েছে","audioUrl":"wbw/023_011_002.mp3","charTypeName":"word"},{"id":12560,"position":3,"arabic":"ٱلْفِرْدَوْسَ","translation":"ফিরদাউসের","audioUrl":"wbw/023_011_003.mp3","charTypeName":"word"},{"id":12561,"position":4,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/023_011_004.mp3","charTypeName":"word"},{"id":12562,"position":5,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/023_011_005.mp3","charTypeName":"word"},{"id":12563,"position":6,"arabic":"خَـٰلِدُونَ","translation":"চিরস্থায়ী হবে","audioUrl":"wbw/023_011_006.mp3","charTypeName":"word"},{"id":12564,"position":7,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]},{"number":12,"arabic":"وَلَقَدْ خَلَقْنَا ٱلْإِنسَٰنَ مِن سُلَٰلَةٍۢ مِّن طِينٍۢ","translation":"NOW, INDEED, We create man out of the essence of clay,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2685.mp3","surahId":23,"words":[{"id":13990,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/023_012_001.mp3","charTypeName":"word"},{"id":13991,"position":2,"arabic":"خَلَقْنَا","translation":"সৃষ্টি করেছি আমরা","audioUrl":"wbw/023_012_002.mp3","charTypeName":"word"},{"id":13992,"position":3,"arabic":"ٱلْإِنسَـٰنَ","translation":"মানুষকে","audioUrl":"wbw/023_012_003.mp3","charTypeName":"word"},{"id":13993,"position":4,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/023_012_004.mp3","charTypeName":"word"},{"id":13994,"position":5,"arabic":"سُلَـٰلَةٍۢ","translation":"নির্যাস","audioUrl":"wbw/023_012_005.mp3","charTypeName":"word"},{"id":13995,"position":6,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/023_012_006.mp3","charTypeName":"word"},{"id":13996,"position":7,"arabic":"طِينٍۢ","translation":"মাটির","audioUrl":"wbw/023_012_007.mp3","charTypeName":"word"},{"id":13997,"position":8,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]},{"number":13,"arabic":"ثُمَّ جَعَلْنَٰهُ نُطْفَةًۭ فِى قَرَارٍۢ مَّكِينٍۢ","translation":"and then We cause him to remain as a drop of sperm in [the wombs] firm keeping,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2686.mp3","surahId":23,"words":[{"id":15224,"position":1,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/023_013_001.mp3","charTypeName":"word"},{"id":15225,"position":2,"arabic":"جَعَلْنَـٰهُ","translation":"তাকে (মানুষকে) আমরা স্হাপন করি","audioUrl":"wbw/023_013_002.mp3","charTypeName":"word"},{"id":15226,"position":3,"arabic":"نُطْفَةًۭ","translation":"শুক্ররূপে","audioUrl":"wbw/023_013_003.mp3","charTypeName":"word"},{"id":15227,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/023_013_004.mp3","charTypeName":"word"},{"id":15228,"position":5,"arabic":"قَرَارٍۢ","translation":"আঁধারের","audioUrl":"wbw/023_013_005.mp3","charTypeName":"word"},{"id":15229,"position":6,"arabic":"مَّكِينٍۢ","translation":"সুরক্ষিত","audioUrl":"wbw/023_013_006.mp3","charTypeName":"word"},{"id":15230,"position":7,"arabic":"١٣","translation":"(১৩)","audioUrl":null,"charTypeName":"end"}]},{"number":14,"arabic":"ثُمَّ خَلَقْنَا ٱلنُّطْفَةَ عَلَقَةًۭ فَخَلَقْنَا ٱلْعَلَقَةَ مُضْغَةًۭ فَخَلَقْنَا ٱلْمُضْغَةَ عِظَٰمًۭا فَكَسَوْنَا ٱلْعِظَٰمَ لَحْمًۭا ثُمَّ أَنشَأْنَٰهُ خَلْقًا ءَاخَرَ ۚ فَتَبَارَكَ ٱللَّهُ أَحْسَنُ ٱلْخَٰلِقِينَ","translation":"and then We create out of the drop of sperm a germ-cell, and then We create out of the germ-cell an embryonic lump, and then We create with