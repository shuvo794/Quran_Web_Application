_015_005.mp3","charTypeName":"word"},{"id":17489,"position":6,"arabic":"١٥","translation":"(১৫)","audioUrl":null,"charTypeName":"end"}]},{"number":16,"arabic":"ثُمَّ إِنَّكُمْ يَوْمَ ٱلْقِيَٰمَةِ تُبْعَثُونَ","translation":"and then, behold! you shall be raised from the dead on Resurrection Day.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2689.mp3","surahId":23,"words":[{"id":18527,"position":1,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/023_016_001.mp3","charTypeName":"word"},{"id":18528,"position":2,"arabic":"إِنَّكُمْ","translation":"নিশ্চয়ই তোমাদের","audioUrl":"wbw/023_016_002.mp3","charTypeName":"word"},{"id":18529,"position":3,"arabic":"يَوْمَ","translation":"দিনে","audioUrl":"wbw/023_016_003.mp3","charTypeName":"word"},{"id":18530,"position":4,"arabic":"ٱلْقِيَـٰمَةِ","translation":"ক্বিয়ামাতের","audioUrl":"wbw/023_016_004.mp3","charTypeName":"word"},{"id":18531,"position":5,"arabic":"تُبْعَثُونَ","translation":"ওঠানো হবে","audioUrl":"wbw/023_016_005.mp3","charTypeName":"word"},{"id":18532,"position":6,"arabic":"١٦","translation":"(১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":17,"arabic":"وَلَقَدْ خَلَقْنَا فَوْقَكُمْ سَبْعَ طَرَآئِقَ وَمَا كُنَّا عَنِ ٱلْخَلْقِ غَٰفِلِينَ","translation":"And, indeed, We have created above you seven [celestial] orbits: and never are We unmindful of [any aspect of Our] creation.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2690.mp3","surahId":23,"words":[{"id":19516,"position":1,"arabic":"وَلَقَدْ","translation":"আর নিশ্চয়ই","audioUrl":"wbw/023_017_001.mp3","charTypeName":"word"},{"id":19517,"position":2,"arabic":"خَلَقْنَا","translation":"আমরা সৃষ্টি করেছি","audioUrl":"wbw/023_017_002.mp3","charTypeName":"word"},{"id":19518,"position":3,"arabic":"فَوْقَكُمْ","translation":"তোমাদের ওপরে","audioUrl":"wbw/023_017_003.mp3","charTypeName":"word"},{"id":19519,"position":4,"arabic":"سَبْعَ","translation":"সাতটি","audioUrl":"wbw/023_017_004.mp3","charTypeName":"word"},{"id