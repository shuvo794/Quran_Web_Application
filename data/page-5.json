{"id":5,"ayahs":[{"number":25,"arabic":"وَبَشِّرِ ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ أَنَّ لَهُمْ جَنَّٰتٍۢ تَجْرِى مِن تَحْتِهَا ٱلْأَنْهَٰرُ ۖ كُلَّمَا رُزِقُوا۟ مِنْهَا مِن ثَمَرَةٍۢ رِّزْقًۭا ۙ قَالُوا۟ هَٰذَا ٱلَّذِى رُزِقْنَا مِن قَبْلُ ۖ وَأُتُوا۟ بِهِۦ مُتَشَٰبِهًۭا ۖ وَلَهُمْ فِيهَآ أَزْوَٰجٌۭ مُّطَهَّرَةٌۭ ۖ وَهُمْ فِيهَا خَٰلِدُونَ","translation":"But unto those who have attained to faith and do good works give the glad tiding that theirs shall be gardens through which running waters flow. Whenever they are granted fruits there from as their appointed sustenance, they will say, \"It is this that in days of yore was granted to us as our sustenance!\"-for they shall be given something that will recall that [past]. And there shall they have spouses pure, and there shall they abide.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/32.mp3","surahId":2,"words":[{"id":27510,"position":1,"arabic":"وَبَشِّرِ","translation":"এবং সুসংবাদ দাও","audioUrl":"wbw/002_025_001.mp3","charTypeName":"word"},{"id":27511,"position":2,"arabic":"ٱلَّذِينَ","translation":"(তাদেরকে) যারা","audioUrl":"wbw/002_025_002.mp3","charTypeName":"word"},{"id":27512,"position":3,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/002_025_003.mp3","charTypeName":"word"},{"id":27513,"position":4,"arabic":"وَعَمِلُوا۟","translation":"ও কাজ করেছে","audioUrl":"wbw/002_025_004.mp3","charTypeName":"word"},{"id":27514,"position":5,"arabic":"ٱلصَّـٰلِحَـٰتِ","translation":"সৎ","audioUrl":"wbw/002_025_005.mp3","charTypeName":"word"},{"id":27515,"position":6,"arabic":"أَنَّ","translation":"যে","audioUrl":"wbw/002_025_006.mp3","charTypeName":"word"},{"id":27516,"position":7,"arabic":"لَهُمْ","translation":"তাদের জন্যে (রয়েছে)","audioUrl":"wbw/002_025_007.mp3","charTypeName":"word"},{"id":27517,"position":8,"arabic":"جَنَّـٰتٍۢ","translation":"জান্নাত","audioUrl":"wbw/002_025_008.mp3","charTypeName":"word"},{"id":27518,"position":9,"arabic":"تَجْرِى","translation":"প্রবাহিত হয়","audioUrl":"wbw/002_025_009.mp3","charTypeName":"word"},{"id":27519,"position":10,"arabic":"مِن","translation":"দিয়ে","audioUrl":"wbw/002_025_010.mp3","charTypeName":"word"},{"id":27520,"position":11,"arabic":"تَحْتِهَا","translation":"তার নিচ","audioUrl":"wbw/002_025_011.mp3","charTypeName":"word"},{"id":27521,"position":12,"arabic":"ٱلْأَنْهَـٰرُ ۖ","translation":"ঝর্ণাধারা","audioUrl":"wbw/002_025_012.mp3","charTypeName":"word"},{"id":27523,"position":13,"arabic":"كُلَّمَا","translation":"যখনই","audioUrl":"wbw/002_025_014.mp3","charTypeName":"word"},{"id":27524,"position":14,"arabic":"رُزِقُوا۟","translation":"তাদের রিযক দেয়া হবে","audioUrl":"wbw/002_025_015.mp3","charTypeName":"word"},{"id":27525,"position":15,"arabic":"مِنْهَا","translation":"তা থেকে","audioUrl":"wbw/002_025_016.mp3","charTypeName":"word"},{"id":27526,"position":16,"arabic":"مِن","translation":"কোনো","audioUrl":"wbw/002_025_017.mp3","charTypeName":"word"},{"id":27527,"position":17,"arabic":"ثَمَرَةٍۢ","translation":"ফলমূল","audioUrl":"wbw/002_025_018.mp3","charTypeName":"word"},{"id":27528,"position":18,"arabic":"رِّزْقًۭا ۙ","translation":"রিযক হিসেবে","audioUrl":"wbw/002_025_019.mp3","charTypeName":"word"},{"id":27530,"position":19,"arabic":"قَالُوا۟","translation":"তারা বলবে","audioUrl":"wbw/002_025_021.mp3","charTypeName":"word"},{"id":27531,"position":20,"arabic":"هَـٰذَا","translation":"''এটা","audioUrl":"wbw/002_025_022.mp3","charTypeName":"word"},{"id":27532,"position":21,"arabic":"ٱلَّذِى","translation":"(তাই) যা","audioUrl":"wbw/002_025_023.mp3","charTypeName":"word"},{"id":27533,"position":22,"arabic":"رُزِقْنَا","translation":"আমাদের রিযক দেওয়া হয়েছিল","audioUrl":"wbw/002_025_024.mp3","charTypeName":"word"},{"id":27534,"position":23,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/002_025_025.mp3","charTypeName":"word"},{"id":27535,"position":24,"arabic":"قَبْلُ ۖ","translation":"পূর্ব''","audioUrl":"wbw/002_025_026.mp3","charTypeName":"word"},{"id":27537,"position":25,"arabic":"وَأُتُوا۟","translation":"এবং তাদেরকে যা দেওয়া হয়েছিল","audioUrl":"wbw/002_025_028.mp3","charTypeName":"word"},{"id":27538,"position":26,"arabic":"بِهِۦ","translation":"(তা থেকে)","audioUrl":"wbw/002_025_029.mp3","charTypeName":"word"},{"id":27539,"position":27,"arabic":"مُتَشَـٰبِهًۭا ۖ","translation":"সদৃশ হবে (পরস্পরে)","audioUrl":"wbw/002_025_030.mp3","charTypeName":"word"},{"id":27541,"position":28,"arabic":"وَلَهُمْ","translation":"এবং তাদের জন্যে","audioUrl":"wbw/002_025_032.mp3","charTypeName":"word"},{"id":27542,"position":29,"arabic":"فِيهَآ","translation":"তারমধ্যে (থাকবে)","audioUrl":"wbw/002_025_033.mp3","charTypeName":"word"},{"id":27543,"position":30,"arabic":"أَزْوَٰجٌۭ","translation":"স্ত্রীরা","audioUrl":"wbw/002_025_034.mp3","charTypeName":"word"},{"id":27544,"position":31,"arabic":"مُّطَهَّرَةٌۭ ۖ","translation":"পবিত্র","audioUrl":"wbw/002_025_035.mp3","charTypeName":"word"},{"id":27546,"position":32,"arabic":"وَهُمْ","translation":"এবং তারা","audioUrl":"wbw/002_025_037.mp3","charTypeName":"word"},{"id":27547,"position":33,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/002_025_038.mp3","charTypeName":"word"},{"id":27548,"position":34,"arabic":"خَـٰلِدُونَ","translation":"চিরস্থায়ী হবে","audioUrl":"wbw/002_025_039.mp3","charTypeName":"word"},{"id":27549,"position":35,"arabic":"٢٥","translation":"(২৫)","audioUrl":null,"charTypeName":"end"}]},{"number":26,"arabic":"۞ إِنَّ ٱللَّهَ لَا يَسْتَحْىِۦٓ أَن يَضْرِبَ مَثَلًۭا مَّا بَعُوضَةًۭ فَمَا فَوْقَهَا ۚ فَأَمَّا ٱلَّذِينَ ءَامَنُوا۟ فَيَعْلَمُونَ أَنَّهُ ٱلْحَقُّ مِن رَّبِّهِمْ ۖ وَأَمَّا ٱلَّذِينَ كَفَرُوا۟ فَيَقُولُونَ مَاذَآ أَرَادَ ٱللَّهُ بِهَٰذَا مَثَلًۭا ۘ يُضِلُّ بِهِۦ كَثِيرًۭا وَيَهْدِى بِهِۦ كَثِيرًۭا ۚ وَمَا يُضِلُّ بِهِۦٓ إِلَّا ٱلْفَٰسِقِينَ","translation":"Behold, God does not disdain to propound a parable of a gnat, or of something [even] less than that. Now, as for those who have attained to faith, they know that it is the truth from their Sustainer - whereas those who are bent on denying the truth say, \"What could God mean by this parable?\" In this way does He cause many a one to go astray, just as He guides many a one aright: but none does He cause thereby to go astray save the iniquitous,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/33.mp3","surahId":2,"words":[{"id":28575,"position":1,"arabic":"۞ إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/002_026_002.mp3","charTypeName":"word"},{"id":28576,"position":2,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/002_026_003.mp3","charTypeName":"word"},{"id":28577,"position":3,"arabic":"لَا","translation":"না","audioUrl":"wbw/002_026_004.mp3","charTypeName":"word"},{"id":28578,"position":4,"arabic":"يَسْتَحْىِۦٓ","translation":"লজ্জাবোধ করেন","audioUrl":"wbw/002_026_005.mp3","charTypeName":"word"},{"id":28579,"position":5,"arabic":"أَن","translation":"যে","audioUrl":"wbw/002_026_006.mp3","charTypeName":"word"},{"id":28580,"position":6,"arabic":"يَضْرِبَ","translation":"তিনি পেশ করবেন","audioUrl":"wbw/002_026_007.mp3","charTypeName":"word"},{"id":28581,"position":7,"arabic":"مَثَلًۭا","translation":"দৃষ্টান্ত","audioUrl":"wbw/002_026_008.mp3","charTypeName":"word"},{"id":28582,"position":8,"arabic":"مَّا","translation":"যা","audioUrl":"wbw/002_026_009.mp3","charTypeName":"word"},{"id":28583,"position":9,"arabic":"بَعُوضَةًۭ","translation":"মশা","audioUrl":"wbw/002_026_010.mp3","charTypeName":"word"},{"id":28584,"position":10,"arabic":"فَمَا","translation":"কিংবা যা","audioUrl":"wbw/002_026_011.mp3","charTypeName":"word"},{"id":28585,"position":11,"arabic":"فَوْقَهَا ۚ","translation":"তারচেয়ে ক্ষুদ্রতর","audioUrl":"wbw/002_026_012.mp3","charTypeName":"word"},{"id":28587,"position":12,"arabic":"فَأَمَّا","translation":"তাই","audioUrl":"wbw/002_026_014.mp3","charTypeName":"word"},{"id":28588,"position":13,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/002_026_015.mp3","charTypeName":"word"},{"id":28589,"position":14,"arabic":"ءَامَ