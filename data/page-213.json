{"id":213,"ayahs":[{"number":34,"arabic":"قُلْ هَلْ مِن شُرَكَآئِكُم مَّن يَبْدَؤُا۟ ٱلْخَلْقَ ثُمَّ يُعِيدُهُۥ ۚ قُلِ ٱللَّهُ يَبْدَؤُا۟ ٱلْخَلْقَ ثُمَّ يُعِيدُهُۥ ۖ فَأَنَّىٰ تُؤْفَكُونَ","translation":"Say: \"Can any of those beings to whom you ascribe a share in God's divinity create [life] in the first instance, and then bring it forth anew?” Say: \"It is God [alone] who creates [all life] in the first instance, and then brings it forth anew. How perverted, then, are your minds!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1398.mp3","surahId":10,"words":[{"id":36534,"position":1,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/010_034_001.mp3","charTypeName":"word"},{"id":36535,"position":2,"arabic":"هَلْ","translation":"\"(আছে) কি","audioUrl":"wbw/010_034_002.mp3","charTypeName":"word"},{"id":36536,"position":3,"arabic":"مِن","translation":"মধ্যে হতে","audioUrl":"wbw/010_034_003.mp3","charTypeName":"word"},{"id":36537,"position":4,"arabic":"شُرَكَآئِكُم","translation":"শরীকদের তোমাদের","audioUrl":"wbw/010_034_004.mp3","charTypeName":"word"},{"id":36538,"position":5,"arabic":"مَّن","translation":"(এমন কেউ) যে","audioUrl":"wbw/010_034_005.mp3","charTypeName":"word"},{"id":36539,"position":6,"arabic":"يَبْدَؤُا۟","translation":"সূচনা করে","audioUrl":"wbw/010_034_006.mp3","charTypeName":"word"},{"id":36540,"position":7,"arabic":"ٱلْخَلْقَ","translation":"সৃষ্টির","audioUrl":"wbw/010_034_007.mp3","charTypeName":"word"},{"id":36541,"position":8,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/010_034_008.mp3","charTypeName":"word"},{"id":36542,"position":9,"arabic":"يُعِيدُهُۥ ۚ","translation":"পুনরাবর্তন ঘটায় তার\"","audioUrl":"wbw/010_034_009.mp3","charTypeName":"word"},{"id":36544,"position":10,"arabic":"قُلِ","translation":"বলো","audioUrl":"wbw/010_034_011.mp3","charTypeName":"word"},{"id":36545,"position":11,"arabic":"ٱللَّهُ","translation":"\"আল্লাহই","audioUrl":"wbw/010_034_012.mp3","charTypeName":"word"},{"id":36546,"position":12,"arabic":"يَبْدَؤُا۟","translation":"সূচনা করেন","audioUrl":"wbw/010_034_013.mp3","charTypeName":"word"},{"id":36547,"position":13,"arabic":"ٱلْخَلْقَ","translation":"সৃষ্টির","audioUrl":"wbw/010_034_014.mp3","charTypeName":"word"},{"id":36548,"position":14,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/010_034_015.mp3","charTypeName":"word"},{"id":36549,"position":15,"arabic":"يُعِيدُهُۥ ۖ","translation":"পুনরাবর্তন ঘটান তার","audioUrl":"wbw/010_034_016.mp3","charTypeName":"word"},{"id":36551,"position":16,"arabic":"فَأَنَّىٰ","translation":"অতএব কোথায়","audioUrl":"wbw/010_034_018.mp3","charTypeName":"word"},{"id":36552,"position":17,"arabic":"تُؤْفَكُونَ","translation":"তোমাদের ফিরানো হচ্ছে\"","audioUrl":"wbw/010_034_019.mp3","charTypeName":"word"},{"id":36553,"position":18,"arabic":"٣٤","translation":"(৩৪)","audioUrl":null,"charTypeName":"end"}]},{"number":35,"arabic":"قُلْ هَلْ مِن شُرَكَآئِكُم مَّن يَهْدِىٓ إِلَى ٱلْحَقِّ ۚ قُلِ ٱللَّهُ يَهْدِى لِلْحَقِّ ۗ أَفَمَن يَهْدِىٓ إِلَى ٱلْحَقِّ أَحَقُّ أَن يُتَّبَعَ أَمَّن لَّا يَهِدِّىٓ إِلَّآ أَن يُهْدَىٰ ۖ فَمَا لَكُمْ كَيْفَ تَحْكُمُونَ","translation":"Say: \"Does any of those beings to whom you ascribe a share in God's divinity guide unto the truth?\" Say: \"It is God [alone] who guides unto the truth. Which, then, is more worthy to be followed - He who guides unto the truth, or he who cannot find the right way unless he is guided? What, then, is amiss with you and your judgment?\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1399.mp3","surahId":10,"words":[{"id":37307,"position":1,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/010_035_001.mp3","charTypeName":"word"},{"id":37308,"position":2,"arabic":"هَلْ","translation":"\"(আছে) কি","audioUrl":"wbw/010_035_002.mp3","charTypeName":"word"},{"id":37309,"position":3,"arabic":"مِن","translation":"মধ্য হতে","audioUrl":"wbw/010_035_003.mp3","charTypeName":"word"},{"id":37310,"position":4,"arabic":"شُرَكَآئِكُم","translation":"শরীক