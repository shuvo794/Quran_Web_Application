ن","translation":"অথবা যে","audioUrl":"wbw/010_035_022.mp3","charTypeName":"word"},{"id":37329,"position":21,"arabic":"لَّا","translation":"না","audioUrl":"wbw/010_035_023.mp3","charTypeName":"word"},{"id":37330,"position":22,"arabic":"يَهِدِّىٓ","translation":"সঠিকপথ পায়","audioUrl":"wbw/010_035_024.mp3","charTypeName":"word"},{"id":37331,"position":23,"arabic":"إِلَّآ","translation":"এ ছাড়া","audioUrl":"wbw/010_035_025.mp3","charTypeName":"word"},{"id":37332,"position":24,"arabic":"أَن","translation":"যে","audioUrl":"wbw/010_035_026.mp3","charTypeName":"word"},{"id":37333,"position":25,"arabic":"يُهْدَىٰ ۖ","translation":"পথ প্রদর্শিত হয়","audioUrl":"wbw/010_035_027.mp3","charTypeName":"word"},{"id":37335,"position":26,"arabic":"فَمَا","translation":"অতএব কি হয়েছে","audioUrl":"wbw/010_035_029.mp3","charTypeName":"word"},{"id":37336,"position":27,"arabic":"لَكُمْ","translation":"তোমাদের","audioUrl":"wbw/010_035_030.mp3","charTypeName":"word"},{"id":37337,"position":28,"arabic":"كَيْفَ","translation":"কেমন","audioUrl":"wbw/010_035_031.mp3","charTypeName":"word"},{"id":37338,"position":29,"arabic":"تَحْكُمُونَ","translation":"তোমরা বিচার করো\"","audioUrl":"wbw/010_035_032.mp3","charTypeName":"word"},{"id":37339,"position":30,"arabic":"٣٥","translation":"(৩৫)","audioUrl":null,"charTypeName":"end"}]},{"number":36,"arabic":"وَمَا يَتَّبِعُ أَكْثَرُهُمْ إِلَّا ظَنًّا ۚ إِنَّ ٱلظَّنَّ لَا يُغْنِى مِنَ ٱلْحَقِّ شَيْـًٔا ۚ إِنَّ ٱللَّهَ عَلِيمٌۢ بِمَا يَفْعَلُونَ","translation":"For, most of them follow nothing but conjecture: [and,] behold, conjecture can never be a substitute for truth. Verily, God has full knowledge of all that they do.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1400.mp3","surahId":10,"words":[{"id":38202,"position":1,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/010_036_001.mp3","charTypeName":"word"},{"id":38203,"position":2,"arabic":"يَتَّبِعُ","translation":"অনুসরণ করে","audioUrl":"wbw/010_036_002.mp3","charTypeName":"word"},{"id":38204,"position":3,"arabic":"أَكْثَرُهُمْ","translation":"অধিকাংশ তাদের","audioUrl":"wbw/010_036_003.mp3","charTypeName":"word"},{"id":38205,"position":4,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/010_036_004.mp3","charTypeName":"word"},{"id":38206,"position":5,"arabic":"ظَنًّا ۚ","translation":"অনুমানের","audioUrl":"wbw/010_036_005.mp3","charTypeName":"word"},{"id":38208,"position":6,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/010_036_007.mp3","charTypeName":"word"},{"id":38209,"position":7,"arabic":"ٱلظَّنَّ","translation":"অনুমান","audioUrl":"wbw/010_036_008.mp3","charTypeName":"word"},{"id":38210,"position":8,"arabic":"لَا","translation":"না","audioUrl":"wbw/010_036_009.mp3","charTypeName":"word"},{"id":38211,"position":9,"arabic":"يُغْنِى","translation":"কাজে আসে","audioUrl":"wbw/010_036_010.mp3","charTypeName":"word"},{"id":38212,"position":10,"arabic":"مِنَ","translation":"ক্ষেত্রে","audioUrl":"wbw/010_036_011.mp3","charTypeName":"word"},{"id":38213,"position":11,"arabic":"ٱلْحَقِّ","translation":"সত্য (পথ লাভের)","audioUrl":"wbw/010_036_012.mp3","charTypeName":"word"},{"id":38214,"position":12,"arabic":"شَيْـًٔا ۚ","translation":"কিছুমাত্র","audioUrl":"wbw/010_036_013.mp3","charTypeName":"word"},{"id":38216,"position":13,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/010_036_015.mp3","charTypeName":"word"},{"id":38217,"position":14,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/010_036_016.mp3","charTypeName":"word"},{"id":38218,"position":15,"arabic":"عَلِيمٌۢ","translation":"খুব অবহিত","audioUrl":"wbw/010_036_017.mp3","charTypeName":"word"},{"id":38219,"position":16,"arabic":"بِمَا","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/010_036_018.mp3","charTypeName":"word"},{"id":38220,"position":17,"arabic":"يَفْعَلُونَ","translation":"তারা করছে","audioUrl":"wbw/010_036_019.mp3","charTypeName":"word"},{"id":38221,"position":18,"arabic":"٣٦","translation":"(৩৬)","audioUrl":null,"charTypeName":"end"}]},{"number":37,"arabic":"وَمَا كَانَ هَٰذَا ٱلْقُرْءَانُ أَن يُفْتَرَىٰ مِن دُونِ ٱللَّهِ وَلَٰكِن تَصْدِيقَ ٱلَّذِى بَيْنَ يَدَيْهِ وَتَفْصِيلَ ٱلْكِتَٰبِ لَا رَيْبَ فِيهِ مِن رَّبِّ ٱلْعَٰلَمِينَ","translation":"Now this Qur'an could not possibly have been devised by anyone save God: nay indeed, it confirms the truth of whatever there still remains [of earlier revelations] and clearly spells out the revelation [which comes] -let there be no doubt about it-from the Sustainer of all the worlds.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1401.mp3","surahId":10,"words":[{"id":39065,"position":1,"arabic":"وَمَا","translation":"এবং নয়","audioUrl":"wbw/010_037_001.mp3","charTypeName":"word"},{"id":39066,"position":2,"arabic":"كَانَ","translation":"হওয়ার","audioUrl":"wbw/010_037_002.mp3","charTypeName":"word"},{"id":39067,"position":3,"arabic":"هَـٰذَا","translation":"এই","audioUrl":"wbw/010_037_003.mp3","charTypeName":"word"},{"id":39068,"position":4,"arabic":"ٱلْقُرْءَانُ","translation":"কুর'আন","audioUrl":"wbw/010_037_004.mp3","charTypeName":"word"},{"id":39069,"position":5,"arabic":"أَن","translation":"(এমন) যে","audioUrl":"wbw/010_037_005.mp3","charTypeName":"word"},{"id":39070,"position":6,"arabic":"يُفْتَرَىٰ","translation":"রচনা করা যেতে পারে","audioUrl":"wbw/010_037_006.mp3","charTypeName":"word"},{"id":39071,"position":7,"arabic":"مِن","translation":"দিয়ে","audioUrl":"wbw/010_037_007.mp3","charTypeName":"word"},{"id":39072,"position":8,"arabic":"دُونِ","translation":"বাদ","audioUrl":"wbw/010_037_008.mp3","charTypeName":"word"},{"id":39073,"position":9,"arabic":"ٱللَّهِ","translation":"আল্লাহ","audioUrl":"wbw/010_037_009.mp3","charTypeName":"word"},{"id":39074,"position":10,"arabic":"وَلَـٰكِن","translation":"বরং (এটা)","audioUrl":"wbw/010_037_010.mp3","charTypeName":"word"},{"id":39075,"position":11,"arabic":"تَصْدِيقَ","translation":"সত্যায়ন","audioUrl":"wbw/010_037_011.mp3","charTypeName":"word"},{"id":39076,"position":12,"arabic":"ٱلَّذِى","translation":"(তার) যা","audioUrl":"wbw/010_037_012.mp3","charTypeName":"word"},{"id":39077,"position":13,"arabic":"بَيْنَ","translation":"মাঝে","audioUrl":"wbw/010_037_013.mp3","charTypeName":"word"},{"id":39078,"position":14,"arabic":"يَدَيْهِ","translation":"হাতের তার","audioUrl":"wbw/010_037_014.mp3","charTypeName":"word"},{"id":39079,"position":15,"arabic":"وَتَفْصِيلَ","translation":"ও বিস্তারিত বর্ণনা","audioUrl":"wbw/010_037_015.mp3","charTypeName":"word"},{"id":39080,"position":16,"arabic":"ٱلْكِتَـٰبِ","translation":"সেই কিতাবের","audioUrl":"wbw/010_037_016.mp3","charTypeName":"word"},{"id":39081,"position":17,"arabic":"لَا","translation":"নেই","audioUrl":"wbw/010_037_017.mp3","charTypeName":"word"},{"id":39082,"position":18,"arabic":"رَيْبَ","translation":"কোনো সন্দেহ","audioUrl":"wbw/010_037_018.mp3","charTypeName":"word"},{"id":39083,"position":19,"arabic":"فِيهِ","translation":"মধ্যে তার(যে এটা)","audioUrl":"wbw/010_037_019.mp3","charTypeName":"word"},{"id":39084,"position":20,"arabic":"مِن","translation":"(এসেছে) পক্ষ হতে","audioUrl":"wbw/010_037_020.mp3","charTypeName":"word"},{"id":39085,"position":21,"arabic":"رَّبِّ","translation":"রবের","audioUrl":"wbw/010_037_021.mp3","charTypeName":"word"},{"id":39086,"position":22,"arabic":"ٱلْعَـٰلَمِينَ","translation":"বিশ্বজগতের","audioUrl":"wbw/010_037_022.mp3","charTypeName":"word"},{"id":39087,"position":23,"arabic":"٣٧","translation":"(৩৭)","audioUrl":null,"charTypeName":"end"}]},{"number":38,"arabic":"أَمْ يَقُولُونَ ٱفْتَرَىٰهُ ۖ قُلْ فَأْتُوا۟ بِسُورَةٍۢ مِّثْلِهِۦ وَٱدْعُوا۟ مَنِ ٱسْتَطَعْتُم مِّن دُونِ ٱللَّهِ إِن كُنتُمْ صَٰدِقِينَ","translation":"And yet, they [who are bent on denying the truth] assert, \"[Muhammad] has invented it!\" Say [unto them]: \"Produce, then, a surah of similar merit; and [to this end] call to your aid whomever you can, other than God, if what you say is true!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1402.mp3","surahId":10,"words":[{"id":39640,"position":1,"arabic":"أَمْ","translation":"অথবা কি","audioUrl":"wbw/010_038_001.mp3","charTypeName":"word"},{"id":39641,"position":2,"arabic":"يَقُولُونَ","translation":"তারা বলে","audioUrl":"wbw/010_038_002.mp3","charTypeName":"word"},{"id":39642,"position":3,"arabic":"ٱفْتَرَىٰهُ ۖ","translation":"\"সে রচনা করেছে তা\"","audioUrl":"wbw/010_038_003.mp3","charTypeName":"word"},{"id":39644,"position":4,"arabic":"قُلْ","translation":"(হে নাবী) বলো","audioUrl":"wbw/010_038_005.mp3","charTypeName":"word"},{"id":39645,"position":5,"arabic":"فَأْتُوا۟","translation":"\"তা হলে তোমরা আসো","audioUrl":"wbw/010_038_006.mp3","charTypeName":"word"},{"id":39646,"position":6,"arabic":"بِسُورَةٍۢ","translation":"নিয়ে একটি সূরাহ (রচনা করে)","audioUrl":"wbw/010_038_007.mp3","charTypeName":"word"},{"id":39647,"position":7,"arabic":"مِّثْلِهِۦ","translation":"মতো তার","audioUrl":"wbw/010_038_008.mp3","charTypeName":"word"},{"id":39648,"position":8,"arabic":"وَٱدْعُوا۟","translation":"এবং তোমরা ডাকো","audioUrl":"wbw/010_038_009.mp3","charTypeName":"word"},{"id":39649,"position":9,"arabic":"مَنِ","translation":"যাকে","audioUrl":"wbw/010_038_010.mp3","charTypeName":"word"},{"id":39650,"position":10,"arabic":"ٱسْتَطَعْتُم","translation":"তোমরা পারো","audioUrl":"wbw/010_038_011.mp3","charTypeName":"word"},{"id":39651,"position":11,"arabic":"مِّن","translation":"দিয়ে","audioUrl":"wbw/010_038_012.mp3","charTypeName":"word"},{"id":39652,"position":12,"arabic":"دُونِ","translation":"বাদ","audioUrl":"wbw/010_038_013.mp3","charTypeName":"word"},{"id":39653,"position":13,"arabic":"ٱللَّهِ","translation":"আল্লাহ","audioUrl":"wbw/010_038_014.mp3","charTypeName":"word"},{"id":39654,"position":14,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/010_038_015.mp3","charTypeName":"word"},{"id":39655,"position":15,"arabic":"كُنتُمْ","translation":"হও তোমরা","audioUrl":"wbw/010_038_016.mp3","charTypeName":"word"},{"id":39656,"position":16,"arabic":"صَـٰدِقِينَ","translation":"সত্যবাদী\"","audioUrl":"wbw/010_038_017.mp3","charTypeName":"word"},{"id":39657,"position":17,"arabic":"٣٨","translation":"(৩৮)","audioUrl":null,"charTypeName":"end"}]},{"number":39,"arabic":"بَلْ كَذَّبُوا۟ بِمَا لَمْ يُحِيطُوا۟ بِعِلْمِهِۦ وَلَمَّا يَأْتِهِمْ تَأْوِيلُهُۥ ۚ كَذَٰلِكَ كَذَّبَ ٱلَّذِينَ مِن قَبْلِهِمْ ۖ فَٱنظُرْ كَيْفَ كَانَ عَٰقِبَةُ ٱلظَّٰلِمِينَ","translation":"Nay, but they are bent on giving the lie to everything the wisdom whereof they do not comprehend, and ere its inner meaning has become clear to them Even thus did those who lived before their time give the lie to the truth: and behold what happened in the end to those evildoers!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1403.mp3","surahId":10,"words":[{"id":40599,"position":1,"arabic":"بَلْ","translation":"বরং","audioUrl":"wbw/010_039_001.mp3","charTypeName":"word"},{"id":40600,"position":2,"arabic":"كَذَّبُوا۟","translation":"তারা মিথ্যা মনে করেছে","audioUrl":"wbw/010_039_002.mp3","charTypeName":"word"},{"id":40601,"position":3,"arabic":"بِمَا","translation":"ঐবিষয়ে যা","audioUrl":"wbw/010_039_003.mp3","charTypeName":"word"},{"id":40602,"position":4,"arabic":"لَمْ","translation":"নি","audioUrl":"wbw/010_039_004.mp3","charTypeName":"word"},{"id":40603,"position":5,"arabic":"يُحِيطُوا۟","translation":"তারা আয়ত্ত করতে পারে","audioUrl":"wbw/010_039_005.mp3","charTypeName":"word"},{"id":40604,"position":6,"arabic":"بِعِلْمِهِۦ","translation":"দিয়ে জ্ঞান তা","audioUrl":"wbw/010_039_006.mp3","charTypeName":"word"},{"id":40605,"position":7,"arabic":"وَلَمَّا","translation":"এবং এখনও নি","audioUrl":"wbw/010_039_007.mp3","charTypeName":"word"},{"id":40606,"position":8,"arabic":"يَأْتِهِمْ","translation":"তাদের কাছে আসে","audioUrl":"wbw/010_039_008.mp3","charTypeName":"word"},{"id":40607,"position":9,"arabic":"تَأْوِيلُهُۥ ۚ","translation":"ব্যাখ্যা তার","audioUrl":"wbw/010_039_009.mp3","charTypeName":"word"},{"id":40609,"position":10,"arabic":"كَذَٰلِكَ","translation":"এভাবে","audioUrl":"wbw/010_039_011.mp3"