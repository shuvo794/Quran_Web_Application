{"id":581,"ayahs":[{"number":20,"arabic":"أَلَمْ نَخْلُقكُّم مِّن مَّآءٍۢ مَّهِينٍۢ","translation":"Did We not create you out of a humble fluid","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5642.mp3","surahId":77,"words":[{"id":22881,"position":1,"arabic":"أَلَمْ","translation":"নাই কি","audioUrl":"wbw/077_020_001.mp3","charTypeName":"word"},{"id":22882,"position":2,"arabic":"نَخْلُقكُّم","translation":"তোমাদেরকে সৃষ্টি আমরা করি","audioUrl":"wbw/077_020_002.mp3","charTypeName":"word"},{"id":22883,"position":3,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/077_020_003.mp3","charTypeName":"word"},{"id":22884,"position":4,"arabic":"مَّآءٍۢ","translation":"পানি","audioUrl":"wbw/077_020_004.mp3","charTypeName":"word"},{"id":22885,"position":5,"arabic":"مَّهِينٍۢ","translation":"তুচ্ছ","audioUrl":"wbw/077_020_005.mp3","charTypeName":"word"},{"id":22886,"position":6,"arabic":"٢٠","translation":"(২০)","audioUrl":null,"charTypeName":"end"}]},{"number":21,"arabic":"فَجَعَلْنَٰهُ فِى قَرَارٍۢ مَّكِينٍ","translation":"which We then let remain in [the womb's] firm keeping","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5643.mp3","surahId":77,"words":[{"id":23954,"position":1,"arabic":"فَجَعَلْنَـٰهُ","translation":"তা আমরা আটকিয়ে অতঃপর রেখেছি","audioUrl":"wbw/077_021_001.mp3","charTypeName":"word"},{"id":23955,"position":2,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/077_021_002.mp3","charTypeName":"word"},{"id":23956,"position":3,"arabic":"قَرَارٍۢ","translation":"স্থানের","audioUrl":"wbw/077_021_003.mp3","charTypeName":"word"},{"id":23957,"position":4,"arabic":"مَّكِينٍ","translation":"সংরক্ষিত","audioUrl":"wbw/077_021_004.mp3","charTypeName":"word"},{"id":23958,"position":5,"arabic":"٢١","translation":"(২১)","audioUrl":null,"charTypeName":"end"}]},{"number":22,"arabic":"إِلَىٰ قَدَرٍۢ مَّعْلُومٍۢ","translation":"for a term pre-ordained?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5644.mp3","surahId":77,"words":[{"id":24939,"position":1,"arabic":"إِلَىٰ","translation":"পর্যন্ত","audioUrl":"wbw/077_022_001.mp3","charTypeName":"word"},{"id":24940,"position":2,"arabic":"قَدَرٍۢ","translation":"সময়","audioUrl":"wbw/077_022_002.mp3","charTypeName":"word"},{"id":24941,"position":3,"arabic":"مَّعْلُومٍۢ","translation":"নির্দিষ্ট","audioUrl":"wbw/077_022_003.mp3","charTypeName":"word"},{"id":24942,"position":4,"arabic":"٢٢","translation":"(২২)","audioUrl":null,"charTypeName":"end"}]},{"number":23,"arabic":"فَقَدَرْنَا فَنِعْمَ ٱلْقَٰدِرُونَ","translation":"Thus have We determined [the nature of man's creation]: and excellent indeed is Our power to determine [what is to be]!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5645.mp3","surahId":77,"words":[{"id":26027,"position":1,"arabic":"فَقَدَرْنَا","translation":"আমরা ক্ষমতাবান অতএব ছিলাম","audioUrl":"wbw/077_023_001.mp3","charTypeName":"word"},{"id":26028,"position":2,"arabic":"فَنِعْمَ","translation":"কত উত্তম অতএব","audioUrl":"wbw/077_023_002.mp3","charTypeName":"word"},{"id":26029,"position":3,"arabic":"ٱلْقَـٰدِرُونَ","translation":"ক্ষমতার অধিকারী","audioUrl":"wbw/077_023_003.mp3","charTypeName":"word"},{"id":26030,"position":4,"arabic":"٢٣","translation":"(২৩)","audioUrl":null,"charTypeName":"end"}]},{"number":24,"arabic":"وَيْلٌۭ يَوْمَئِذٍۢ لِّلْمُكَذِّبِينَ","translation":"Woe, on that Day unto those who give the lie to the truth!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5646.mp3","surahId":77,"words":[{"id":27091,"position":1,"arabic":"وَيْلٌۭ","translation":"ধ্বংস","audioUrl":"wbw/077_024_001.mp3","charTypeName":"word"},{"id":27092,"position":2,"arabic":"يَوْمَئِذٍۢ","translation":"সেদিন","audioUrl":"wbw/077_024_002.mp3","charTypeName":"word"},{"id":27093,"position":3,"arabic":"لِّلْمُكَذِّبِينَ","translation":"মিথ্যারোপকারীদের জন্য","audioUrl":"wbw/077_024_003.mp3","charTypeName":"word"},{"id":27094,"position":4,"arabic":"٢٤","translation":"(২৪)","audioUrl":null,"charTy