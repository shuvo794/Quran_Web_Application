33655,"position":2,"arabic":"ظَلِيلٍۢ","translation":"শৈত্যদাতা","audioUrl":"wbw/077_031_002.mp3","charTypeName":"word"},{"id":33656,"position":3,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/077_031_003.mp3","charTypeName":"word"},{"id":33657,"position":4,"arabic":"يُغْنِى","translation":"রক্ষা করবে","audioUrl":"wbw/077_031_004.mp3","charTypeName":"word"},{"id":33658,"position":5,"arabic":"مِنَ","translation":"থেকে","audioUrl":"wbw/077_031_005.mp3","charTypeName":"word"},{"id":33659,"position":6,"arabic":"ٱللَّهَبِ","translation":"আগুনের শিখা","audioUrl":"wbw/077_031_006.mp3","charTypeName":"word"},{"id":33660,"position":7,"arabic":"٣١","translation":"(৩১)","audioUrl":null,"charTypeName":"end"}]},{"number":32,"arabic":"إِنَّهَا تَرْمِى بِشَرَرٍۢ كَٱلْقَصْرِ","translation":"which – behold!- will throw up sparks like [burning] logs,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5654.mp3","surahId":77,"words":[{"id":34750,"position":1,"arabic":"إِنَّهَا","translation":"তা নিশ্চয়","audioUrl":"wbw/077_032_001.mp3","charTypeName":"word"},{"id":34751,"position":2,"arabic":"تَرْمِى","translation":"নিক্ষেপ করবে","audioUrl":"wbw/077_032_002.mp3","charTypeName":"word"},{"id":34752,"position":3,"arabic":"بِشَرَرٍۢ","translation":"স্কুলিংগকে","audioUrl":"wbw/077_032_003.mp3","charTypeName":"word"},{"id":34753,"position":4,"arabic":"كَٱلْقَصْرِ","translation":"প্রাসাদের ন্যায়","audioUrl":"wbw/077_032_004.mp3","charTypeName":"word"},{"id":34754,"position":5,"arabic":"٣٢","translation":"(৩২)","audioUrl":null,"charTypeName":"end"}]},{"number":33,"arabic":"كَأَنَّهُۥ جِمَٰلَتٌۭ صُفْرٌۭ","translation":"like giant fiery ropes!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5655.mp3","surahId":77,"words":[{"id":35562,"position":1,"arabic":"كَأَنَّهُۥ","translation":"তা যেন","audioUrl":"wbw/077_033_001.mp3","charTypeName":"word"},{"id":35563,"position":2,"arabic":"جِمَـٰلَتٌۭ","translation":"উট সমূহ","audioUrl":"wbw/077_033_002.mp3","charTyp