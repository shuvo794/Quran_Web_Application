{"id":446,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلصَّٰٓفَّٰتِ صَفًّۭا","translation":"CONSIDER these [messages] ranged in serried ranks,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3789.mp3","surahId":37,"words":[{"id":889,"position":1,"arabic":"وَٱلصَّـٰٓفَّـٰتِ","translation":"শপথ সারি বেঁধে দাঁড়ায় যারা","audioUrl":"wbw/037_001_001.mp3","charTypeName":"word"},{"id":890,"position":2,"arabic":"صَفًّۭا","translation":"সারি সারি","audioUrl":"wbw/037_001_002.mp3","charTypeName":"word"},{"id":891,"position":3,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"فَٱلزَّٰجِرَٰتِ زَجْرًۭا","translation":"and restraining [from evil] by a call to restraint,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3790.mp3","surahId":37,"words":[{"id":1977,"position":1,"arabic":"فَٱلزَّٰجِرَٰتِ","translation":"অতঃপর (শপথ) ধমকদানকারীদের","audioUrl":"wbw/037_002_001.mp3","charTypeName":"word"},{"id":1978,"position":2,"arabic":"زَجْرًۭا","translation":"সজোরে","audioUrl":"wbw/037_002_002.mp3","charTypeName":"word"},{"id":1979,"position":3,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"فَٱلتَّٰلِيَٰتِ ذِكْرًا","translation":"and conveying [to all the world] a reminder:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3791.mp3","surahId":37,"words":[{"id":3173,"position":1,"arabic":"فَٱلتَّـٰلِيَـٰتِ","translation":"অতঃপর (শপথ তাদের) পাঠকদের","audioUrl":"wbw/037_003_001.mp3","charTypeName":"word"},{"id":3174,"position":2,"arabic":"ذِكْرًا","translation":"উপদেশবাণী","audioUrl":"wbw/037_003_002.mp3","charTypeName":"word"},{"id":3175,"position":3,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"إِنَّ إِلَٰهَكُمْ لَوَٰحِدٌۭ","translation":"Verily, most surely, your God is One –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3792.mp3","surahId":37,"words":[{"id":4528,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/037_004_001.mp3","charTypeName":"word"},{"id":4529,"position":2,"arabic":"إِلَـٰهَكُمْ","translation":"তোমাদের ইলাহ","audioUrl":"wbw/037_004_002.mp3","charTypeName":"word"},{"id":4530,"position":3,"arabic":"لَوَٰحِدٌۭ","translation":"একজন অবশ্যই","audioUrl":"wbw/037_004_003.mp3","charTypeName":"word"},{"id":4531,"position":4,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"رَّبُّ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ وَمَا بَيْنَهُمَا وَرَبُّ ٱلْمَشَٰرِقِ","translation":"the Sustainer of the heavens and the earth and of all that is between them, and the Sustainer of all the points of sunrise!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3793.mp3","surahId":37,"words":[{"id":5786,"position":1,"arabic":"رَّبُّ","translation":"(তিনি) রব","audioUrl":"wbw/037_005_001.mp3","charTypeName":"word"},{"id":5787,"position":2,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশের","audioUrl":"wbw/037_005_002.mp3","charTypeName":"word"},{"id":5788,"position":3,"arabic":"وَٱلْأَرْضِ","translation":"ও পৃৃথিবীর","audioUrl":"wbw/037_005_003.mp3","charTypeName":"word"},{"id":5789,"position":4,"arabic":"وَمَا","translation":"এবং যা কিছু (আছে)","audioUrl":"wbw/037_005_004.mp3","charTypeName":"word"},{"id":5790,"position":5,"arabic":"بَيْنَهُمَا","translation":"তাদের উভয়ের মাঝে","audioUrl":"wbw/037_005_005.mp3","charTypeName":"word"},{"id":5791,"position":6,"arabic":"وَرَبُّ","translation":"এবং রব","audioUrl":"wbw/037_005_006.mp3","charTypeName":"word"},{"id":5792,"position":7,"arabic":"ٱلْمَشَـٰرِقِ","translation":"উদয়স্থলসমূহের","audioUrl":"wbw/037_005_007.mp3","charTypeName":"word"},{"id":5793,"position":8,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"إِنَّا زَيَّنَّا ٱلسَّمَآءَ ٱلدُّنْيَا بِزِينَةٍ ٱلْكَوَاكِبِ","translation":"Behold, We have adorned the skies nearest to the earth with the beauty of stars,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3794.mp3","surahId":37,"words":[{"id":7081,"position":1,"arabic":"إِنَّا","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/037_006_001.mp3","charTypeName":"word"},{"id":7082,"position":2,"arabic":"زَيَّنَّا","translation":"আমরা সৃুশোভিত করেছি","audioUrl":"wbw/037_006_002.mp3","charTypeName":"word"},{"id":7083,"position":3,"arabic":"ٱلسَّمَآءَ","translation":"আকাশকে","audioUrl":"wbw/037_006_003.mp3","charTypeName":"word"},{"id":7084,"position":4,"arabic":"ٱلدُّنْيَا","translation":"কাছের","audioUrl":"wbw/037_006_004.mp3","charTypeName":"word"},{"id":7085,"position":5,"arabic":"بِزِينَةٍ","translation":"চাকচিক্য দ্বারা","audioUrl":"wbw/037_006_005.mp3","charTypeName":"word"},{"id":7086,"position":6,"arabic":"ٱلْكَوَاكِبِ","translation":"তারকাদের","audioUrl":"wbw/037_006_006.mp3","charTypeName":"word"},{"id":7087,"position":7,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"وَحِفْظًۭا مِّن كُلِّ شَيْطَٰنٍۢ مَّارِدٍۢ","translation":"and have made them secure against every rebellious, satanic force,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3795.mp3","surahId":37,"words":[{"id":8389,"position":1,"arabic":"وَحِفْظًۭا","translation":"এবং (তাকে) (আমরা করেছি) সংরক্ষণ","audioUrl":"wbw/037_007_001.mp3","charTypeName":"word"},{"id":8390,"position":2,"arabic":"مِّن","translation":"হ'তে","audioUrl":"wbw/037_007_002.mp3","charTypeName":"word"},{"id":8391,"position":3,"arabic":"كُلِّ","translation":"প্রত্যেক","audioUrl":"wbw/037_007_003.mp3","charTypeName":"word"},{"id":8392,"position":4,"arabic":"شَيْطَـٰنٍۢ","translation":"শয়তানের","audioUrl":"wbw/037_007_004.mp3","charTypeName":"word"},{"id":8393,"position":5,"arabic":"مَّارِدٍۢ","translation":"(যারা) অবাধ্য","audioUrl":"wbw/037_007_005.mp3","charTypeName":"word"},{"id":8394,"position":6,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"لَّا يَسَّمَّعُونَ إِلَى ٱلْمَلَإِ ٱلْأَعْلَىٰ وَيُقْذَفُونَ مِن كُلِّ جَانِبٍۢ","translation":"[so that] they [who seek to learn the unknowable] should not be able to overhear the host on high, but shall be repelled from all sides,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3796.mp3","surahId":37,"words":[{"id":9572,"position":1,"arabic":"لَّا","translation":"না","audioUrl":"wbw/037_008_001.mp3","charTypeName":"word"},{"id":9573,"position":2,"arabic":"يَسَّمَّعُونَ","translation":"তারা শুনতে পায়","audioUrl":"wbw/037_008_002.mp3","charTypeName":"word"},{"id":9574,"position":3,"arabic":"إِلَى","translation":"(কোন কথা) হ'তে","audioUrl":"wbw/037_008_003.mp3","charTypeName":"word"},{"id":9575,"position":4,"arabic":"ٱلْمَلَإِ","translation":"জগৎ","audioUrl":"wbw/037_008_004.mp3","charTypeName":"word"},{"id":9576,"position":5,"arabic":"ٱلْأَعْلَىٰ","translation":"ওপরের","audioUrl":"wbw/037_008_005.mp3","charTypeName":"word"},{"id":9577,"position":6,"arabic":"وَيُقْذَفُونَ","translation":"এবং নিক্ষেপ করা হয়","audioUrl":"wbw/037_008_006.mp3","charTypeName":"word"},{"id":9578,"position":7,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/037_008_007.mp3","charTypeName":"word"},{"id":9579,"position":8,"arabic":"كُلِّ","translation":"প্রত্যেক","audioUrl":"wbw/037_008_008.mp3","charTypeName":"word"},{"id":9580,"position":9,"arabic":"جَانِبٍۢ","translation":"দিক","audioUrl":"wbw/037_008_009.mp3","charTypeName":"word"},{"id":9581,"position":10,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"دُحُورًۭا ۖ وَلَهُمْ عَذَابٌۭ وَاصِبٌ","translation":"cast out [from all grace], with lasting suffering in store for them [in the life to come];","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3797.mp3","surahId":37,"words":[{"id":10754,"position":1,"arabic":"دُحُورًۭا ۖ","translation":"তাড়ানোর (জন্যে)","audioUrl":"wbw/037_009_001.mp3","charTypeName":"word"},{"id":10756,"position":2,"arabic":"وَلَهُمْ","translation":"এবং তাদের জন্যে রয়েছে","audioUrl":"wbw/037_009_003.mp3","charTypeName":"word"},{"id":10757,"position":3,"arabic":"عَذَابٌۭ","translation":"শাস্তি","audioUrl":"wbw/037_009_004.mp3","charTypeName":"word"},{"id":10758,"position":4,"arabic":"وَاصِبٌ","translation":"অবিরাম","audioUrl":"wbw/037_009_005.mp3","charTypeName":"word"},{"id":10759,"position":5,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"إِلَّا مَنْ خَطِفَ ٱلْخَطْفَةَ فَأَتْبَعَهُۥ شِهَابٌۭ ثَاقِبٌۭ","translation":"but if anyone does succeed in snatching a glimpse [of such knowledge], he is [henceforth] pursued by a piercing flame.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3798.mp3","surahId":37,"words":[{"id":12003,"position":1,"arabic":"إِلَّا","translation":"তবে","audioUrl":"wbw/037_010_001.mp3","charTypeName":"word"},{"id":12004,"position":2,"arabic":"مَنْ","translation":"যে","audioUrl":"wbw/037_010_002.mp3","charTypeName":"word"},{"id":12005,"position":3,"arabic":"خَطِفَ","translation":"হঠাৎ করে (শুনে) নেয়","audioUrl":"wbw/037_010_003.mp3","charTypeName":"word"},{"id":12006,"position":4,"arabic":"ٱلْخَطْفَةَ","translation":"হঠাৎ নেওয়া","audioUrl":"wbw/037_010_004.mp3","charTypeName":"word"},{"id":12007,"position":5,"arabic":"فَأَتْبَعَهُۥ","translation":"তাকে তখন অনুসরণ করে","audioUrl":"wbw/037_010_005.mp3","charTypeName":"word"},{"id":12008,"position":6,"arabic":"شِهَابٌۭ","translation":"উল্কা","audioUrl":"wbw/037_010_006.mp3","charTypeName":"word"},{"id":12009,"position":7,"arabic":"ثَاقِبٌۭ","translation":"জ্বলন্ত","audioUrl":"wbw/037_010_007.mp3","charTypeName":"word"},{"id":12010,"position":8,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"فَٱسْتَفْتِهِمْ أَهُمْ أَشَدُّ خَلْقًا أَم مَّنْ خَلَقْنَآ ۚ إِنَّا خَلَقْنَٰهُم مِّن طِينٍۢ لَّازِبٍۭ","translation":"AND NOW ask those [who deny the truth] to enlight­en thee: Were they more difficult to create than all those [untold marvels] that We have created? - for, behold, them have We created out of [mere] clay commingled with water!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3799.mp3","surahId":37,"words":[{"id":13314,"position":1,"arabic":"فَٱسْتَفْتِهِمْ","translation":"তাদেরকে অতঃপর জিজ্ঞেস করো","audioUrl":"wbw/037_011_001.mp3","charTypeName":"word"},{"id":13315,"position":2,"arabic":"أَهُمْ","translation":"\"তারা কি","audioUrl":"wbw/037_011_002.mp3","charTypeName":"word"},{"id":13316,"position":3,"arabic":"أَشَدُّ","translation":"বেশী কঠিন","audioUrl":"wbw/037_011_003.mp3","charTypeName":"word"},{"id":13317,"position":4,"arabic":"خَلْقًا","translation":"সৃষ্টি হিসেবে","audioUrl":"wbw/037_011_004.mp3","charTypeName":"word"},{"id":13318,"position":5,"arabic":"أَم","translation":"অথবা","audioUrl":"wbw/037_011_005.mp3","charTypeName":"word"},{"id":13319,"position":6,"arabic":"مَّنْ","translation":"(অন্য) যা কিছু","audioUrl":"wbw/037_011_006.mp3","charTypeName":"word"},{"id":13320,"position":7,"arabic":"خَلَقْنَآ ۚ","translation":"আমরা সৃষ্টি করেছি\"","audioUrl":"wbw/037_011_007.mp3","charTypeName":"word"},{"id":13322,"position":8,"arabic":"إِنَّا","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/037_011_009.mp3","charTypeName":"word"},{"id":13323,"position":9,"arabic":"خَلَقْنَـٰهُم","translation":"তাদেরকে আমরা সৃষ্টি করেছি","audioUrl":"wbw/037_011_010.mp3","charTypeName":"word"},{"id":13324,"position":10,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/037_011_011.mp3","charTypeName":"word"},{"id":13325,"position":11,"arabic":"طِينٍۢ","translation":"মাটি","audioUrl":"wbw/037_011_012.mp3","charTypeName":"word"},{"id":13326,"position":12,"arabic":"لَّازِبٍۭ","translation":"(যা) এঁটেল","audioUrl":"wbw/037_011_013.mp3","charTypeName":"word"},{"id":13327,"position":13,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]},{"number":12,"arabic":"بَلْ عَجِبْتَ وَيَسْخَرُونَ","translation":"Nay, but whereas thou dost marvel, they [only] scoff;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3800.mp3","surahId":37,"words":[{"id":14607,"position":1,"arabic":"بَلْ","translation":"বরং","audioUrl":"wbw/037_012_001.mp3","charTypeName":"word"},{"id":14608,"position":2,"arabic":"عَجِبْتَ","translation":"তুমি অবাক হচ্ছো","audioUrl":"wbw/037_012_002.mp3","charTypeName":"word"},{"id":14609,"position":3,"arabic":"وَيَسْخَرُونَ","translation":"আর তারা বিদ্রূপ করছে","audioUrl":"wbw/037_012_003.mp3","charTypeName":"word"},{"id":14610,"position":4,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]},{"number":13,"arabic":"وَإِذَا ذُكِّرُوا۟ لَا يَذْكُرُونَ","translation":"and when they are reminded [of the truth], they refuse to take it to heart;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3801.mp3","surahId":37,"words":[{"id":15699,"position":1,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/037_013_001.mp3","charTypeName":"word"},{"id":15700,"position":2,"arabic":"ذُكِّرُوا۟","translation":"তাদের উপদেশ দেয়া হয়","audioUrl":"wbw/037_013_002.mp3","charTypeName":"word"},{"id":15701,"position":3,"arabic":"لَا","translation":"না","audioUrl":"wbw/037_013_003.mp3","charTypeName":"word"},{"id":15702,"position":4,"arabic":"يَذْكُرُونَ","translation":"তারা উপদেশ গ্রহণ করে","audioUrl":"wbw/037_013_004.mp3","charTypeName":"word"},{"id":15703,"position":5,"arabic":"١٣","translation":"(১৩)","audioUrl":null,"charTypeName":"end"}]},{"number":14,"arabic":"وَإِذَا رَأَوْا۟ ءَايَةًۭ يَسْتَسْخِرُونَ","translation":"and when they become aware of a [divine] message, they turn it to ridicule","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3802.mp3","surahId":37,"words":[{"id":16746,"position":1,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/037_014_001.mp3","charTypeName":"word"},{"id":16747,"position":2,"arabic":"رَأَوْا۟","translation":"তারা দেখে","audioUrl":"wbw/037_014_002.mp3","charTypeName":"word"},{"id":16748,"position":3,"arabic":"ءَايَةًۭ","translation":"কোনো নিদর্শন","audioUrl":"wbw/037_014_003.mp3","charTypeName":"word"},{"id":16749,"position":4,"arabic":"يَسْتَسْخِرُونَ","translation":"তারা উপহাস করে","audioUrl":"wbw/037_014_004.mp3","charTypeName":"word"},{"id":16750,"position":5,"arabic":"١٤","translation":"(১৪)","audioUrl":null,"charTypeName":"end"}]},{"number":15,"arabic":"وَقَالُوٓا۟ إِنْ هَٰذَآ إِلَّا سِحْرٌۭ مُّبِينٌ","translation":"and say: “This is clearly nothing but [a mortal’s] spellbinding eloquence!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3803.mp3","surahId":37,"words":[{"id":17923,"position":1,"arabic":"وَقَالُوٓا۟","translation":"এবং তারা বলে","audioUrl":"wbw/037_015_001.mp3","charTypeName":"word"},{"id":17924,"position":2,"arabic":"إِنْ","translation":"\"নয়","audioUrl":"wbw/037_015_002.mp3","charTypeName":"word"},{"id":17925,"position":3,"arabic":"هَـٰذَآ","translation":"এটা","audioUrl":"wbw/037_015_003.mp3","charTypeName":"word"},{"id":17926,"position":4,"arabic":"إِلَّا","translation":"এ ব্যতীত","audioUrl":"wbw/037_015_004.mp3","charTypeName":"word"},{"id":17927,"position":5,"arabic":"سِحْرٌۭ","translation":"জাদু","audioUrl":"wbw/037_015_005.mp3","charTypeName":"word"},{"id":17928,"position":6,"arabic":"مُّبِينٌ","translation":"সুস্পষ্ট","audioUrl":"wbw/037_015_006.mp3","charTypeName":"word"},{"id":17929,"position":7,"arabic":"١٥","translation":"(১৫)","audioUrl":null,"charTypeName":"end"}]},{"number":16,"arabic":"أَءِذَا مِتْنَا وَكُنَّا تُرَابًۭا وَعِظَٰمًا أَءِنَّا لَمَبْعُوثُونَ","translation":"Why - after we have died and become mere dust and bones, shall we, forsooth, be raised from the dead? –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3804.mp3","surahId":37,"words":[{"id":18937,"position":1,"arabic":"أَءِذَا","translation":"কি যখন","audioUrl":"wbw/037_016_001.mp3","charTypeName":"word"},{"id":18938,"position":2,"arabic":"مِتْنَا","translation":"আমরা মরে যাব","audioUrl":"wbw/037_016_002.mp3","charTypeName":"word"},{"id":18939,"position":3,"arabic":"وَكُنَّا","translation":"এবং আমরা হয়ে যাব","audioUrl":"wbw/037_016_003.mp3","charTypeName":"word"},{"id":18940,"position":4,"arabic":"تُرَابًۭا","translation":"মাটি","audioUrl":"wbw/037_016_004.mp3","charTypeName":"word"},{"id":18941,"position":5,"arabic":"وَعِظَـٰمًا","translation":"ও হাড়","audioUrl":"wbw/037_016_005.mp3","charTypeName":"word"},{"id":18942,"position":6,"arabic":"أَءِنَّا","translation":"নিশ্চয়ই কি আমরা","audioUrl":"wbw/037_016_006.mp3","charTypeName":"word"},{"id":18943,"position":7,"arabic":"لَمَبْعُوثُونَ","translation":"আমাদেরকে উঠানো হবে অবশ্যই","audioUrl":"wbw/037_016_007.mp3","charTypeName":"word"},{"id":18944,"position":8,"arabic":"١٦","translation":"(১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":17,"arabic":"أَوَءَابَآؤُنَا ٱلْأَوَّلُونَ","translation":"and perhaps also our forebears of old?”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3805.mp3","surahId":37,"words":[{"id":20043,"position":1,"arabic":"أَوَءَابَآؤُنَا","translation":"এবং কি (উঠানো হবে) আমাদের পিতৃপুরুষদেরকেও","audioUrl":"wbw/037_017_001.mp3","charTypeName":"word"},{"id":20044,"position":2,"arabic":"ٱلْأَوَّلُونَ","translation":"পূর্বকালের\"","audioUrl":"wbw/037_017_002.mp3","charTypeName":"word"},{"id":20045,"position":3,"arabic":"١٧","translation":"(১৭)","audioUrl":null,"charTypeName":"end"}]},{"number":18,"arabic":"قُلْ نَعَمْ وَأَنتُمْ دَٰخِرُونَ","translation":"Say: “Yea, indeed - and most abject will you then be!” –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3806.mp3","surahId":37,"words":[{"id":21130,"position":1,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/037_018_001.mp3","charTypeName":"word"},{"id":21131,"position":2,"arabic":"نَعَمْ","translation":"\"হ্যাঁ","audioUrl":"wbw/037_018_002.mp3","charTypeName":"word"},{"id":21132,"position":3,"arabic":"وَأَنتُمْ","translation":"এবং তোমরা","audioUrl":"wbw/037_018_003.mp3","charTypeName":"word"},{"id":21133,"position":4,"arabic":"دَٰخِرُونَ","translation":"অপমানিত হবে\"","audioUrl":"wbw/037_018_004.mp3","charTypeName":"word"},{"id":21134,"position":5,"arabic":"١٨","translation":"(১৮)","audioUrl":null,"charTypeName":"end"}]},{"number":19,"arabic":"فَإِنَّمَا هِىَ زَجْرَةٌۭ وَٰحِدَةٌۭ فَإِذَا هُمْ يَنظُرُونَ","translation":"for that [resurrection which they deride] will be [upon them of a sudden, as if it were] but a single accusing cry - and then, lo! they will begin to see [the truth]","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3807.mp3","surahId":37,"words":[{"id":22243,"position":1,"arabic":"فَإِنَّمَا","translation":"মূলতঃ","audioUrl":"wbw/037_019_001.mp3","charTypeName":"word"},{"id":22244,"position":2,"arabic":"هِىَ","translation":"তা (হবে)","audioUrl":"wbw/037_019_002.mp3","charTypeName":"word"},{"id":22245,"position":3,"arabic":"زَجْرَةٌۭ","translation":"বিকট শব্দ কম্পন","audioUrl":"wbw/037_019_003.mp3","charTypeName":"word"},{"id":22246,"position":4,"arabic":"وَٰحِدَةٌۭ","translation":"একটি (মাত্র)","audioUrl":"wbw/037_019_004.mp3","charTypeName":"word"},{"id":22247,"position":5,"arabic":"فَإِذَا","translation":"অতঃপর তখন","audioUrl":"wbw/037_019_005.mp3","charTypeName":"word"},{"id":22248,"position":6,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/037_019_006.mp3","charTypeName":"word"},{"id":22249,"position":7,"arabic":"يَنظُرُونَ","translation":"দেখবে","audioUrl":"wbw/037_019_007.mp3","charTypeName":"word"},{"id":22250,"position":8,"arabic":"١٩","translation":"(১৯)","audioUrl":null,"charTypeName":"end"}]},{"number":20,"arabic":"وَقَالُوا۟ يَٰوَيْلَنَا هَٰذَا يَوْمُ ٱلدِّينِ","translation":"and will say: “Oh, woe unto us! This is the Day of Judgment!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3808.mp3","surahId":37,"words":[{"id":23264,"position":1,"arabic":"وَقَالُوا۟","translation":"এবং তারা বলবে","audioUrl":"wbw/037_020_001.mp3","charTypeName":"word"},{"id":23265,"position":2,"arabic":"يَـٰوَيْلَنَا","translation":"\"আমাদের দুর্ভোগ হায়","audioUrl":"wbw/037_020_002.mp3","charTypeName":"word"},{"id":23266,"position":3,"arabic":"هَـٰذَا","translation":"এটাই","audioUrl":"wbw/037_020_003.mp3","charTypeName":"word"},{"id":23267,"position":4,"arabic":"يَوْمُ","translation":"দিন","audioUrl":"wbw/037_020_004.mp3","charTypeName":"word"},{"id":23268,"position":5,"arabic":"ٱلدِّينِ","translation":"বিচারের\"","audioUrl":"wbw/037_020_005.mp3","charTypeName":"word"},{"id":23269,"position":6,"arabic":"٢٠","translation":"(২০)","audioUrl":null,"charTypeName":"end"}]},{"number":21,"arabic":"هَٰذَا يَوْمُ ٱلْفَصْلِ ٱلَّذِى كُنتُم بِهِۦ تُكَذِّبُونَ","translation":"[And they will be told:] “This is the Day of Distinction [between the true and the false - the Day] which you were wont to call a lie!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3809.mp3","surahId":37,"words":[{"id":24329,"position":1,"arabic":"هَـٰذَا","translation":"\"এটাই","audioUrl":"wbw/037_021_001.mp3","charTypeName":"word"},{"id":24330,"position":2,"arabic":"يَوْمُ","translation":"দিন","audioUrl":"wbw/037_021_002.mp3","charTypeName":"word"},{"id":24331,"position":3,"arabic":"ٱلْفَصْلِ","translation":"মীমাংসার","audioUrl":"wbw/037_021_003.mp3","charTypeName":"word"},{"id":24332,"position":4,"arabic":"ٱلَّذِى","translation":"যা","audioUrl":"wbw/037_021_004.mp3","charTypeName":"word"},{"id":24333,"position":5,"arabic":"كُنتُم","translation":"তোমরা ছিলে","audioUrl":"wbw/037_021_005.mp3","charTypeName":"word"},{"id":24334,"position":6,"arabic":"بِهِۦ","translation":"তা সম্পর্কে","audioUrl":"wbw/037_021_006.mp3","charTypeName":"word"},{"id":24335,"position":7,"arabic":"تُكَذِّبُونَ","translation":"মিথ্যা বলতে\"","audioUrl":"wbw/037_021_007.mp3","charTypeName":"word"},{"id":24336,"position":8,"arabic":"٢١","translation":"(২১)","audioUrl":null,"charTypeName":"end"}]},{"number":22,"arabic":"۞ ٱحْشُرُوا۟ ٱلَّذِينَ ظَلَمُوا۟ وَأَزْوَٰجَهُمْ وَمَا كَانُوا۟ يَعْبُدُونَ","translation":"[And God will thus command:] “Assemble all those who were bent on evildoing, together with others of their ilk and [with] all that they were wont to worship","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3810.mp3","surahId":37,"words":[{"id":25356,"position":1,"arabic":"۞ ٱحْشُرُوا۟","translation":"(বলা হবে) একত্র করে আনো","audioUrl":"wbw/037_022_002.mp3","charTypeName":"word"},{"id":25357,"position":2,"arabic":"ٱلَّذِينَ","translation":"(তাদেরকে) যারা","audioUrl":"wbw/037_022_003.mp3","charTypeName":"word"},{"id":25358,"position":3,"arabic":"ظَلَمُوا۟","translation":"সীমালঙ্ঘন করেছিলো","audioUrl":"wbw/037_022_004.mp3","charTypeName":"word"},{"id":25359,"position":4,"arabic":"وَأَزْوَٰجَهُمْ","translation":"এবং তাদের দোসরদেরকে","audioUrl":"wbw/037_022_005.mp3","charTypeName":"word"},{"id":25360,"position":5,"arabic":"وَمَا","translation":"এবং যাদের","audioUrl":"wbw/037_022_006.mp3","charTypeName":"word"},{"id":25361,"position":6,"arabic":"كَانُوا۟","translation":"তারা","audioUrl":"wbw/037_022_007.mp3","charTypeName":"word"},{"id":25362,"position":7,"arabic":"يَعْبُدُونَ","translation":"উপাসনা করতো","audioUrl":"wbw/037_022_008.mp3","charTypeName":"word"},{"id":25363,"position":8,"arabic":"٢٢","translation":"(২২)","audioUrl":null,"charTypeName":"end"}]},{"number":23,"arabic":"مِن دُونِ ٱللَّهِ فَٱهْدُوهُمْ إِلَىٰ صِرَٰطِ ٱلْجَحِيمِ","translation":"instead of God, and lead them all onto the way to the blazing fire,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3811.mp3","surahId":37,"words":[{"id":26403,"position":1,"arabic":"مِن","translation":"মধ্য হতে","audioUrl":"wbw/037_023_001.mp3","charTypeName":"word"},{"id":26404,"position":2,"arabic":"دُونِ","translation":"ছাড়া","audioUrl":"wbw/037_023_002.mp3","charTypeName":"word"},{"id":26405,"position":3,"arabic":"ٱللَّهِ","translation":"আল্লাহ","audioUrl":"wbw/037_023_003.mp3","charTypeName":"word"},{"id":26406,"position":4,"arabic":"فَٱهْدُوهُمْ","translation":"তাই তাদেরকে পরিচালিত করো","audioUrl":"wbw/037_023_004.mp3","charTypeName":"word"},{"id":26407,"position":5,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/037_023_005.mp3","charTypeName":"word"},{"id":26408,"position":6,"arabic":"صِرَٰطِ","translation":"পথের","audioUrl":"wbw/037_023_006.mp3","charTypeName":"word"},{"id":26409,"position":7,"arabic":"ٱلْجَحِيمِ","translation":"জাহান্নামের","audioUrl":"wbw/037_023_007.mp3","charTypeName":"word"},{"id":26410,"position":8,"arabic":"٢٣","translation":"(২৩)","audioUrl":null,"charTypeName":"end"}]},{"number":24,"arabic":"وَقِفُوهُمْ ۖ إِنَّهُم مَّسْـُٔولُونَ","translation":"and halt them [there]!” [And then,] behold, they shall be asked,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3812.mp3","surahId":37,"words":[{"id":27418,"position":1,"arabic":"وَقِفُوهُمْ ۖ","translation":"এবং থামাও তাদেরকে","audioUrl":"wbw/037_024_001.mp3","charTypeName":"word"},{"id":27420,"position":2,"arabic":"إِنَّهُم","translation":"তারা নিশ্চয়ই","audioUrl":"wbw/037_024_003.mp3","charTypeName":"word"},{"id":27421,"position":3,"arabic":"مَّسْـُٔولُونَ","translation":"জিজ্ঞাসিত হবে\"","audioUrl":"wbw/037_024_004.mp3","charTypeName":"word"},{"id":27422,"position":4,"arabic":"٢٤","translation":"(২৪)","audioUrl":null,"charTypeName":"end"}]}]}