{"id":441,"ayahs":[{"number":13,"arabic":"وَٱضْرِبْ لَهُم مَّثَلًا أَصْحَٰبَ ٱلْقَرْيَةِ إِذْ جَآءَهَا ٱلْمُرْسَلُونَ","translation":"AND SET FORTH unto them a parable - [the story of how] the people of a township [behaved] when [Our] message-bearers came unto them.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3718.mp3","surahId":36,"words":[{"id":15686,"position":1,"arabic":"وَٱضْرِبْ","translation":"এবং বর্ণনা করো","audioUrl":"wbw/036_013_001.mp3","charTypeName":"word"},{"id":15687,"position":2,"arabic":"لَهُم","translation":"তাদের কাছে","audioUrl":"wbw/036_013_002.mp3","charTypeName":"word"},{"id":15688,"position":3,"arabic":"مَّثَلًا","translation":"দৃষ্টান্ত","audioUrl":"wbw/036_013_003.mp3","charTypeName":"word"},{"id":15689,"position":4,"arabic":"أَصْحَـٰبَ","translation":"অধিবাসীদেরকে","audioUrl":"wbw/036_013_004.mp3","charTypeName":"word"},{"id":15690,"position":5,"arabic":"ٱلْقَرْيَةِ","translation":"জনপদের","audioUrl":"wbw/036_013_005.mp3","charTypeName":"word"},{"id":15691,"position":6,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/036_013_006.mp3","charTypeName":"word"},{"id":15692,"position":7,"arabic":"جَآءَهَا","translation":"সেখানে এসেছিলো","audioUrl":"wbw/036_013_007.mp3","charTypeName":"word"},{"id":15693,"position":8,"arabic":"ٱلْمُرْسَلُونَ","translation":"রাসূলগণ","audioUrl":"wbw/036_013_008.mp3","charTypeName":"word"},{"id":15694,"position":9,"arabic":"١٣","translation":"(১৩)","audioUrl":null,"charTypeName":"end"}]},{"number":14,"arabic":"إِذْ أَرْسَلْنَآ إِلَيْهِمُ ٱثْنَيْنِ فَكَذَّبُوهُمَا فَعَزَّزْنَا بِثَالِثٍۢ فَقَالُوٓا۟ إِنَّآ إِلَيْكُم مُّرْسَلُونَ","translation":"Lo! We sent unto them two [apostles], and. they gave the lie to both; and so We strengthened [the two] with a third; and thereupon they said: “Behold, we have been sent unto you [by God]!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3719.mp3","surahId":36,"words":[{"id":16734,"position":1,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/036_014_001.mp3","charTypeName":"word"},{"id":16735,"position":2,"arabic":"أَرْسَلْنَآ","translation":"আমরা পাঠিয়েছিলাম","audioUrl":"wbw/036_014_002.mp3","charTypeName":"word"},{"id":16736,"position":3,"arabic":"إِلَيْهِمُ","translation":"তাদের প্রতি","audioUrl":"wbw/036_014_003.mp3","charTypeName":"word"},{"id":16737,"position":4,"arabic":"ٱثْنَيْنِ","translation":"দু'জনকে","audioUrl":"wbw/036_014_004.mp3","charTypeName":"word"},{"id":16738,"position":5,"arabic":"فَكَذَّبُوهُمَا","translation":"তখন উভয়কে তারা মিথ্যারোপ করলো","audioUrl":"wbw/036_014_005.mp3","charTypeName":"word"},{"id":16739,"position":6,"arabic":"فَعَزَّزْنَا","translation":"আমরা শক্তিশালী করলাম তখন","audioUrl":"wbw/036_014_006.mp3","charTypeName":"word"},{"id":16740,"position":7,"arabic":"بِثَالِثٍۢ","translation":"তৃতীয়জনকে দিয়ে","audioUrl":"wbw/036_014_007.mp3","charTypeName":"word"},{"id":16741,"position":8,"arabic":"فَقَالُوٓا۟","translation":"তারা অতঃপর বললো","audioUrl":"wbw/036_014_008.mp3","charTypeName":"word"},{"id":16742,"position":9,"arabic":"إِنَّآ","translation":"\"নিশ্চয়ই আমরা","audioUrl":"wbw/036_014_009.mp3","charTypeName":"word"},{"id":16743,"position":10,"arabic":"إِلَيْكُم","translation":"তোমাদের প্রতি","audioUrl":"wbw/036_014_010.mp3","charTypeName":"word"},{"id":16744,"position":11,"arabic":"مُّرْسَلُونَ","translation":"প্রেরিত রাসূল\"","audioUrl":"wbw/036_014_011.mp3","charTypeName":"word"},{"id":16745,"position":12,"arabic":"١٤","translation":"(১৪)","audioUrl":null,"charTypeName":"end"}]},{"number":15,"arabic":"قَالُوا۟ مَآ أَنتُمْ إِلَّا بَشَرٌۭ مِّثْلُنَا وَمَآ أَنزَلَ ٱلرَّحْمَٰنُ مِن شَىْءٍ إِنْ أَنتُمْ إِلَّا تَكْذِبُونَ","translation":"[The others] answered: “You are nothing but mortal men like ourselves; moreover, the Most Gracious has never bestowed aught [of revelation] from on high. You do nothing but lie!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3720.mp3","surahId":36,"words":[{"id":17907,"position":1,"arabic":"قَالُوا۟","translation":"(লোকেরা) বললো","audioUrl":"wbw/036_015_001.mp3","charTypeName":"word"},{"id":17908,"position":2,"arabic":"مَآ","translation":"\"না","audioUrl":"wbw/036_015_002.mp3","charTypeName":"word"},{"id":17909,"position":3,"arabic":"أَنتُمْ","translation":"তোমরা","audioUrl":"wbw/036_015_003.mp3","charTypeName":"word"},{"id":17910,"position":4,"arabic":"إِلَّا","translation":"এছাড়া","audioUrl":"wbw/036_015_004.mp3","charTypeName":"word"},{"id":17911,"position":5,"arabic":"بَشَرٌۭ","translation":"মানুষ","audioUrl":"wbw/036_015_005.mp3","charTypeName":"word"},{"id":17912,"position":6,"arabic":"مِّثْلُنَا","translation":"আমাদেরই মতো","audioUrl":"wbw/036_015_006.mp3","charTypeName":"word"},{"id":17913,"position":7,"arabic":"وَمَآ","translation":"না এবং","audioUrl":"wbw/036_015_007.mp3","charTypeName":"word"},{"id":17914,"position":8,"arabic":"أَنزَلَ","translation":"অবতীর্ণ করেছেন","audioUrl":"wbw/036_015_008.mp3","charTypeName":"word"},{"id":17915,"position":9,"arabic":"ٱلرَّحْمَـٰنُ","translation":"দয়াময়","audioUrl":"wbw/036_015_009.mp3","charTypeName":"word"},{"id":17916,"position":10,"arabic":"مِن","translation":"কোনো","audioUrl":"wbw/036_015_010.mp3","charTypeName":"word"},{"id":17917,"position":11,"arabic":"شَىْءٍ","translation":"কিছুই","audioUrl":"wbw/036_015_011.mp3","charTypeName":"word"},{"id":17918,"position":12,"arabic":"إِنْ","translation":"না","audioUrl":"wbw/036_015_012.mp3","charTypeName":"word"},{"id":17919,"position":13,"arabic":"أَنتُمْ","translation":"তোমরা","audioUrl":"wbw/036_015_013.mp3","charTypeName":"word"},{"id":17920,"position":14,"arabic":"إِلَّا","translation":"এছাড়া","audioUrl":"wbw/036_015_014.mp3","charTypeName":"word"},{"id":17921,"position":15,"arabic":"تَكْذِبُونَ","translation":"মিথ্যা বলছো\"","audioUrl":"wbw/036_015_015.mp3","charTypeName":"word"},{"id":17922,"position":16,"arabic":"١٥","translation":"(১৫)","audioUrl":null,"charTypeName":"end"}]},{"number":16,"arabic":"قَالُوا۟ رَبُّنَا يَعْلَمُ إِنَّآ إِلَيْكُمْ لَمُرْسَلُونَ","translation":"Said [the apostles]: “Our Sustainer knows that we have indeed been sent unto you;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3721.mp3","surahId":36,"words":[{"id":18930,"position":1,"arabic":"قَالُوا۟","translation":"(রাসূলগণ) বললেন","audioUrl":"wbw/036_016_001.mp3","charTypeName":"word"},{"id":18931,"position":2,"arabic":"رَبُّنَا","translation":"\"আমাদের রব","audioUrl":"wbw/036_016_002.mp3","charTypeName":"word"},{"id":18932,"position":3,"arabic":"يَعْلَمُ","translation":"জানেন","audioUrl":"wbw/036_016_003.mp3","charTypeName":"word"},{"id":18933,"position":4,"arabic":"إِنَّآ","translation":"নিশ্চযই় আমরা","audioUrl":"wbw/036_016_004.mp3","charTypeName":"word"},{"id":18934,"position":5,"arabic":"إِلَيْكُمْ","translation":"তোমাদের প্রতি","audioUrl":"wbw/036_016_005.mp3","charTypeName":"word"},{"id":18935,"position":6,"arabic":"لَمُرْسَلُونَ","translation":"প্রেরিত অবশ্যই (রাসূল হিসেবে)","audioUrl":"wbw/036_016_006.mp3","charTypeName":"word"},{"id":18936,"position":7,"arabic":"١٦","translation":"(১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":17,"arabic":"وَمَا عَلَيْنَآ إِلَّا ٱلْبَلَٰغُ ٱلْمُبِينُ","translation":"but we are not bound to do more than clearly deliver the mes­sage [entrusted to us].”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3722.mp3","surahId":36,"words":[{"id":20037,"position":1,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/036_017_001.mp3","charTypeName":"word"},{"id":20038,"position":2,"arabic":"عَلَيْنَآ","translation":"আমাদের উপর (দায়িত্ব)","audioUrl":"wbw/036_017_002.mp3","charTypeName":"word"},{"id":20039,"position":3,"arabic":"إِلَّا","translation":"এ ব্যতীত","audioUrl":"wbw/036_017_003.mp3","charTypeName":"word"},{"id":20040,"position":4,"arabic":"ٱلْبَلَـٰغُ","translation":"প্রচার","audioUrl":"wbw/036_017_004.mp3","charTypeName":"word"},{"id":20041,"position":5,"arabic":"ٱلْمُبِينُ","translation":"সুস্পষ্ট (পয়গাম)\"","audioUrl":"wbw/036_017_005.mp3","charTypeName":"word"},{"id":20042,"position":6,"arabic":"١٧","translation":"(১৭)","audioUrl":null,"charTypeName":"end"}]},{"number":18,"arabic":"قَالُوٓا۟ إِنَّا تَطَيَّرْنَا بِكُمْ ۖ لَئِن لَّمْ تَنتَهُوا۟ لَنَرْجُمَنَّكُمْ وَلَيَمَسَّنَّكُم مِّنَّا عَذَابٌ أَلِيمٌۭ","translation":"Said [the others]: “Truly, we augur evil from you! Indeed, if you desist not, we will surely stone you, and grievous suffering is bound to befall you at our hands!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3723.mp3","surahId":36,"words":[{"id":21108,"position":1,"arabic":"قَالُوٓا۟","translation":"তারা বললো","audioUrl":"wbw/036_018_001.mp3","charTypeName":"word"},{"id":21109,"position":2,"arabic":"إِنَّا","translation":"\"নিশ্চযই় আমরা","audioUrl":"wbw/036_018_002.mp3","charTypeName":"word"},{"id":21110,"position":3,"arabic":"تَطَيَّرْنَا","translation":"আমরা অমঙ্গল মনে করি","audioUrl":"wbw/036_018_003.mp3","charTypeName":"word"},{"id":21111,"position":4,"arabic":"بِكُمْ ۖ","translation":"তোমাদেরকে","audioUrl":"wbw/036_018_004.mp3","charTypeName":"word"},{"id":21113,"position":5,"arabic":"لَئِن","translation":"অবশ্যই যদি","audioUrl":"wbw/036_018_006.mp3","charTypeName":"word"},{"id":21114,"position":6,"arabic":"لَّمْ","translation":"না","audioUrl":"wbw/036_018_007.mp3","charTypeName":"word"},{"id":21115,"position":7,"arabic":"تَنتَهُوا۟","translation":"তোমরা বিরত হও","audioUrl":"wbw/036_018_008.mp3","charTypeName":"word"},{"id":21116,"position":8,"arabic":"لَنَرْجُمَنَّكُمْ","translation":"তোমাদেরকে আমরা পাথর মেরে হত্যা করবোই","audioUrl":"wbw/036_018_009.mp3","charTypeName":"word"},{"id":21117,"position":9,"arabic":"وَلَيَمَسَّنَّكُم","translation":"এবং তোমাদেরকে ধরবে অবশ্যই","audioUrl":"wbw/036_018_010.mp3","charTypeName":"word"},{"id":21118,"position":10,"arabic":"مِّنَّا","translation":"আমাদের পক্ষ হ'তে","audioUrl":"wbw/036_018_011.mp3","charTypeName":"word"},{"id":21119,"position":11,"arabic":"عَذَابٌ","translation":"শাস্তি","audioUrl":"wbw/036_018_012.mp3","charTypeName":"word"},{"id":21120,"position":12,"arabic":"أَلِيمٌۭ","translation":"নিদারুণ\"","audioUrl":"wbw/036_018_013.mp3","charTypeName":"word"},{"id":21121,"position":13,"arabic":"١٨","translation":"(১৮)","audioUrl":null,"charTypeName":"end"}]},{"number":19,"arabic":"قَالُوا۟ طَٰٓئِرُكُم مَّعَكُمْ ۚ أَئِن ذُكِّرْتُم ۚ بَلْ أَنتُمْ قَوْمٌۭ مُّسْرِفُونَ","translation":"[The apostles] replied: “Your destiny, good or evil, is [bound up] with yourselves! [Does it seem evil to you] if you are told to take [the truth] to heart? Nay, but you are people who have wasted their own selves!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3724.mp3","surahId":36,"words":[{"id":22231,"position":1,"arabic":"قَالُوا۟","translation":"(রাসূলগণ) বললেন","audioUrl":"wbw/036_019_001.mp3","charTypeName":"word"},{"id":22232,"position":2,"arabic":"طَـٰٓئِرُكُم","translation":"\"তোমাদের অমঙ্গলের (কারণ)","audioUrl":"wbw/036_019_002.mp3","charTypeName":"word"},{"id":22233,"position":3,"arabic":"مَّعَكُمْ ۚ","translation":"তোমাদের সাথে","audioUrl":"wbw/036_019_003.mp3","charTypeName":"word"},{"id":22235,"position":4,"arabic":"أَئِن","translation":"(এসব বলছো) কি","audioUrl":"wbw/036_019_005.mp3","charTypeName":"word"},{"id":22236,"position":5,"arabic":"ذُكِّرْتُم ۚ","translation":"তোমাদের উপদেশ দেওয়া হয়েছে","audioUrl":"wbw/036_019_006.mp3","charTypeName":"word"},{"id":22238,"position":6,"arabic":"بَلْ","translation":"বরং","audioUrl":"wbw/036_019_008.mp3","charTypeName":"word"},{"id":22239,"position":7,"arabic":"أَنتُمْ","translation":"তোমরা","audioUrl":"wbw/036_019_009.mp3","charTypeName":"word"},{"id":22240,"position":8,"arabic":"قَوْمٌۭ","translation":"সম্প্রদায়","audioUrl":"wbw/036_019_010.mp3","charTypeName":"word"},{"id":22241,"position":9,"arabic":"مُّسْرِفُونَ","translation":"সীমালঙ্ঘনকারী\"","audioUrl":"wbw/036_019_011.mp3","charTypeName":"word"},{"id":22242,"position":10,"arabic":"١٩","translation":"(১৯)","audioUrl":null,"charTypeName":"end"}]},{"number":20,"arabic":"وَجَآءَ مِنْ أَقْصَا ٱلْمَدِينَةِ رَجُلٌۭ يَسْعَىٰ قَالَ يَٰقَوْمِ ٱتَّبِعُوا۟ ٱلْمُرْسَلِينَ","translation":"At that, a man came running from the farthest end of the city, [and] exclaimed: “O my people! Follow these message-bearers!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3725.mp3","surahId":36,"words":[{"id":23253,"position":1,"arabic":"وَجَآءَ","translation":"এ অবস্থায় আসলো","audioUrl":"wbw/036_020_001.mp3","charTypeName":"word"},{"id":23254,"position":2,"arabic":"مِنْ","translation":"হ'তে","audioUrl":"wbw/036_020_002.mp3","charTypeName":"word"},{"id":23255,"position":3,"arabic":"أَقْصَا","translation":"এক প্রান্ত","audioUrl":"wbw/036_020_003.mp3","charTypeName":"word"},{"id":23256,"position":4,"arabic":"ٱلْمَدِينَةِ","translation":"শহরের","audioUrl":"wbw/036_020_004.mp3","charTypeName":"word"},{"id":23257,"position":5,"arabic":"رَجُلٌۭ","translation":"এক ব্যক্তি","audioUrl":"wbw/036_020_005.mp3","charTypeName":"word"},{"id":23258,"position":6,"arabic":"يَسْعَىٰ","translation":"দৌঁড়ে","audioUrl":"wbw/036_020_006.mp3","charTypeName":"word"},{"id":23259,"position":7,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/036_020_007.mp3","charTypeName":"word"},{"id":23260,"position":8,"arabic":"يَـٰقَوْمِ","translation":"\"হে আমার জাতি","audioUrl":"wbw/036_020_008.mp3","charTypeName":"word"},{"id":23261,"position":9,"arabic":"ٱتَّبِعُوا۟","translation":"তোমরা অনুসরণ করো","audioUrl":"wbw/036_020_009.mp3","charTypeName":"word"},{"id":23262,"position":10,"arabic":"ٱلْمُرْسَلِينَ","translation":"রাসূলগণকে","audioUrl":"wbw/036_020_010.mp3","charTypeName":"word"},{"id":23263,"position":11,"arabic":"٢٠","translation":"(২০)","audioUrl":null,"charTypeName":"end"}]},{"number":21,"arabic":"ٱتَّبِعُوا۟ مَن لَّا يَسْـَٔلُكُمْ أَجْرًۭا وَهُم مُّهْتَدُونَ","translation":"Follow those who ask no reward of you, and themselves are rightly guided!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3726.mp3","surahId":36,"words":[{"id":24321,"position":1,"arabic":"ٱتَّبِعُوا۟","translation":"তোমরা অনুসরণ করো","audioUrl":"wbw/036_021_001.mp3","charTypeName":"word"},{"id":24322,"position":2,"arabic":"مَن","translation":"(তার) যে","audioUrl":"wbw/036_021_002.mp3","charTypeName":"word"},{"id":24323,"position":3,"arabic":"لَّا","translation":"না","audioUrl":"wbw/036_021_003.mp3","charTypeName":"word"},{"id":24324,"position":4,"arabic":"يَسْـَٔلُكُمْ","translation":"তোমাদের কাছে চায়","audioUrl":"wbw/036_021_004.mp3","charTypeName":"word"},{"id":24325,"position":5,"arabic":"أَجْرًۭا","translation":"কোনো বিনিময়","audioUrl":"wbw/036_021_005.mp3","charTypeName":"word"},{"id":24326,"position":6,"arabic":"وَهُم","translation":"এবং তারা","audioUrl":"wbw/036_021_006.mp3","charTypeName":"word"},{"id":24327,"position":7,"arabic":"مُّهْتَدُونَ","translation":"সৎপথপ্রাপ্ত","audioUrl":"wbw/036_021_007.mp3","charTypeName":"word"},{"id":24328,"position":8,"arabic":"٢١","translation":"(২১)","audioUrl":null,"charTypeName":"end"}]},{"number":22,"arabic":"وَمَا لِىَ لَآ أَعْبُدُ ٱلَّذِى فَطَرَنِى وَإِلَيْهِ تُرْجَعُونَ","translation":"“[As for me,] why should I not worship Him who has brought me into being, and to whom you all will be brought back?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3727.mp3","surahId":36,"words":[{"id":25346,"position":1,"arabic":"وَمَا","translation":"এবং কি","audioUrl":"wbw/036_022_001.mp3","charTypeName":"word"},{"id":25347,"position":2,"arabic":"لِىَ","translation":"আমার জন্য (যুক্তি আছে যে)","audioUrl":"wbw/036_022_002.mp3","charTypeName":"word"},{"id":25348,"position":3,"arabic":"لَآ","translation":"না","audioUrl":"wbw/036_022_003.mp3","charTypeName":"word"},{"id":25349,"position":4,"arabic":"أَعْبُدُ","translation":"ইবাদত করবো আমি","audioUrl":"wbw/036_022_004.mp3","charTypeName":"word"},{"id":25350,"position":5,"arabic":"ٱلَّذِى","translation":"(তাঁর) যিনি","audioUrl":"wbw/036_022_005.mp3","charTypeName":"word"},{"id":25351,"position":6,"arabic":"فَطَرَنِى","translation":"আমাকে সৃষ্টি করেছেন","audioUrl":"wbw/036_022_006.mp3","charTypeName":"word"},{"id":25352,"position":7,"arabic":"وَإِلَيْهِ","translation":"ও তাঁরই দিকে","audioUrl":"wbw/036_022_007.mp3","charTypeName":"word"},{"id":25353,"position":8,"arabic":"تُرْجَعُونَ","translation":"তোমাদেরকে ফিরিয়ে নেয়া হবে","audioUrl":"wbw/036_022_008.mp3","charTypeName":"word"},{"id":25354,"position":9,"arabic":"٢٢","translation":"(২২)","audioUrl":null,"charTypeName":"end"}]},{"number":23,"arabic":"ءَأَتَّخِذُ مِن دُونِهِۦٓ ءَالِهَةً إِن يُرِدْنِ ٱلرَّحْمَٰنُ بِضُرٍّۢ لَّا تُغْنِ عَنِّى شَفَٰعَتُهُمْ شَيْـًۭٔا وَلَا يُنقِذُونِ","translation":"Should I take to worship­ping [other] deities beside Him? [But then,] if the Most Gracious should will that harm befall me, their intercession could not in the least avail me, nor could they save me:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3728.mp3","surahId":36,"words":[{"id":26387,"position":1,"arabic":"ءَأَتَّخِذُ","translation":"গ্রহণ করবো আমি কি","audioUrl":"wbw/036_023_001.mp3","charTypeName":"word"},{"id":26388,"position":2,"arabic":"مِن","translation":"ছাড়া","audioUrl":"wbw/036_023_002.mp3","charTypeName":"word"},{"id":26389,"position":3,"arabic":"دُونِهِۦٓ","translation":"তাঁকে","audioUrl":"wbw/036_023_003.mp3","charTypeName":"word"},{"id":26390,"position":4,"arabic":"ءَالِهَةً","translation":"উপাস্য (অন্য কাউকে)","audioUrl":"wbw/036_023_004.mp3","charTypeName":"word"},{"id":26391,"position":5,"arabic":"إِن","translation":"(অথচ) যদি","audioUrl":"wbw/036_023_005.mp3","charTypeName":"word"},{"id":26392,"position":6,"arabic":"يُرِدْنِ","translation":"আমাকে চান","audioUrl":"wbw/036_023_006.mp3","charTypeName":"word"},{"id":26393,"position":7,"arabic":"ٱلرَّحْمَـٰنُ","translation":"দয়াময়","audioUrl":"wbw/036_023_007.mp3","charTypeName":"word"},{"id":26394,"position":8,"arabic":"بِضُرٍّۢ","translation":"কোনো ক্ষতি করতে","audioUrl":"wbw/036_023_008.mp3","charTypeName":"word"},{"id":26395,"position":9,"arabic":"لَّا","translation":"না","audioUrl":"wbw/036_023_009.mp3","charTypeName":"word"},{"id":26396,"position":10,"arabic":"تُغْنِ","translation":"কাজে আসবে","audioUrl":"wbw/036_023_010.mp3","charTypeName":"word"},{"id":26397,"position":11,"arabic":"عَنِّى","translation":"আমার জন্যে","audioUrl":"wbw/036_023_011.mp3","charTypeName":"word"},{"id":26398,"position":12,"arabic":"شَفَـٰعَتُهُمْ","translation":"তাদের সুপারিশ","audioUrl":"wbw/036_023_012.mp3","charTypeName":"word"},{"id":26399,"position":13,"arabic":"شَيْـًۭٔا","translation":"কিছু মাত্র","audioUrl":"wbw/036_023_013.mp3","charTypeName":"word"},{"id":26400,"position":14,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/036_023_014.mp3","charTypeName":"word"},{"id":26401,"position":15,"arabic":"يُنقِذُونِ","translation":"আমাকে তারা উদ্ধার করতে পারবে","audioUrl":"wbw/036_023_015.mp3","charTypeName":"word"},{"id":26402,"position":16,"arabic":"٢٣","translation":"(২৩)","audioUrl":null,"charTypeName":"end"}]},{"number":24,"arabic":"إِنِّىٓ إِذًۭا لَّفِى ضَلَٰلٍۢ مُّبِينٍ","translation":"and so, behold, I would have indeed, most obviously, lost myself in error!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3729.mp3","surahId":36,"words":[{"id":27408,"position":1,"arabic":"إِنِّىٓ","translation":"নিশ্চয়ই আমি","audioUrl":"wbw/036_024_001.mp3","charTypeName":"word"},{"id":27409,"position":2,"arabic":"إِذًۭا","translation":"তাহ'লে","audioUrl":"wbw/036_024_002.mp3","charTypeName":"word"},{"id":27410,"position":3,"arabic":"لَّفِى","translation":"অবশ্যই মধ্যে হব","audioUrl":"wbw/036_024_003.mp3","charTypeName":"word"},{"id":27411,"position":4,"arabic":"ضَلَـٰلٍۢ","translation":"বিভ্রান্তির","audioUrl":"wbw/036_024_004.mp3","charTypeName":"word"},{"id":27412,"position":5,"arabic":"مُّبِينٍ","translation":"সুস্পষ্ট","audioUrl":"wbw/036_024_005.mp3","charTypeName":"word"},{"id":27413,"position":6,"arabic":"٢٤","translation":"(২৪)","audioUrl":null,"charTypeName":"end"}]},{"number":25,"arabic":"إِنِّىٓ ءَامَنتُ بِرَبِّكُمْ فَٱسْمَعُونِ","translation":"“Verily, [O my people,] in the Sustainer of you all have I come to believe: listen, then, to me!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3730.mp3","surahId":36,"words":[{"id":28473,"position":1,"arabic":"إِنِّىٓ","translation":"নিশ্চযই় আমি","audioUrl":"wbw/036_025_001.mp3","charTypeName":"word"},{"id":28474,"position":2,"arabic":"ءَامَنتُ","translation":"আমি ঈমান এনেছি","audioUrl":"wbw/036_025_002.mp3","charTypeName":"word"},{"id":28475,"position":3,"arabic":"بِرَبِّكُمْ","translation":"প্রতি তোমাদের রবের","audioUrl":"wbw/036_025_003.mp3","charTypeName":"word"},{"id":28476,"position":4,"arabic":"فَٱسْمَعُونِ","translation":"সুতরা তোমরা আমার কথা শোনো (ও মানো)\"","audioUrl":"wbw/036_025_004.mp3","charTypeName":"word"},{"id":28477,"position":5,"arabic":"٢٥","translation":"(২৫)","audioUrl":null,"charTypeName":"end"}]},{"number":26,"arabic":"قِيلَ ٱدْخُلِ ٱلْجَنَّةَ ۖ قَالَ يَٰلَيْتَ قَوْمِى يَعْلَمُونَ","translation":"[And] he was told, “[Thou shalt] enter paradise!” - [whereupon] he exclaimed: “Would that my people knew","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3731.mp3","surahId":36,"words":[{"id":29381,"position":1,"arabic":"قِيلَ","translation":"(তাকে তারা হত্যা করলো এবং তাকে) বলা হলো","audioUrl":"wbw/036_026_001.mp3","charTypeName":"word"},{"id":29382,"position":2,"arabic":"ٱدْخُلِ","translation":"\"প্রবেশ করো","audioUrl":"wbw/036_026_002.mp3","charTypeName":"word"},{"id":29383,"position":3,"arabic":"ٱلْجَنَّةَ ۖ","translation":"জান্নাতে\"","audioUrl":"wbw/036_026_003.mp3","charTypeName":"word"},{"id":29385,"position":4,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/036_026_005.mp3","charTypeName":"word"},{"id":29386,"position":5,"arabic":"يَـٰلَيْتَ","translation":"\"হায় আফসোস্‌","audioUrl":"wbw/036_026_006.mp3","charTypeName":"word"},{"id":29387,"position":6,"arabic":"قَوْمِى","translation":"আমার জাতি","audioUrl":"wbw/036_026_007.mp3","charTypeName":"word"},{"id":29388,"position":7,"arabic":"يَعْلَمُونَ","translation":"(যদি) জানতো","audioUrl":"wbw/036_026_008.mp3","charTypeName":"word"},{"id":29389,"position":8,"arabic":"٢٦","translation":"(২৬)","audioUrl":null,"charTypeName":"end"}]},{"number":27,"arabic":"بِمَا غَفَرَ لِى رَبِّى وَجَعَلَنِى مِنَ ٱلْمُكْرَمِينَ","translation":"how my Sustainer has forgiven me [the sins of my past], and has placed me among the honoured ones!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3732.mp3","surahId":36,"words":[{"id":30371,"position":1,"arabic":"بِمَا","translation":"যে কারণে","audioUrl":"wbw/036_027_001.mp3","charTypeName":"word"},{"id":30372,"position":2,"arabic":"غَفَرَ","translation":"ক্ষমা করেছেন","audioUrl":"wbw/036_027_002.mp3","charTypeName":"word"},{"id":30373,"position":3,"arabic":"لِى","translation":"আমাকে","audioUrl":"wbw/036_027_003.mp3","charTypeName":"word"},{"id":30374,"position":4,"arabic":"رَبِّى","translation":"আমার রব্‌","audioUrl":"wbw/036_027_004.mp3","charTypeName":"word"},{"id":30375,"position":5,"arabic":"وَجَعَلَنِى","translation":"ও আমাকে করেছেন","audioUrl":"wbw/036_027_005.mp3","charTypeName":"word"},{"id":30376,"position":6,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/036_027_006.mp3","charTypeName":"word"},{"id":30377,"position":7,"arabic":"ٱلْمُكْرَمِينَ","translation":"সম্মানিতদের\"","audioUrl":"wbw/036_027_007.mp3","charTypeName":"word"},{"id":30378,"position":8,"arabic":"٢٧","translation":"(২৭)","audioUrl":null,"charTypeName":"end"}]}]}