ِيلًا","translation":"দীর্ঘ","audioUrl":"wbw/076_026_007.mp3","charTypeName":"word"},{"id":29169,"position":8,"arabic":"٢٦","translation":"(২৬)","audioUrl":null,"charTypeName":"end"}]},{"number":27,"arabic":"إِنَّ هَٰٓؤُلَآءِ يُحِبُّونَ ٱلْعَاجِلَةَ وَيَذَرُونَ وَرَآءَهُمْ يَوْمًۭا ثَقِيلًۭا","translation":"Behold, they [who are unmindful of God] love this fleeting life, and leave behind them [all thought of] a grief-laden Day.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5618.mp3","surahId":76,"words":[{"id":29906,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়","audioUrl":"wbw/076_027_001.mp3","charTypeName":"word"},{"id":29907,"position":2,"arabic":"هَـٰٓؤُلَآءِ","translation":"ঐসব লোক","audioUrl":"wbw/076_027_002.mp3","charTypeName":"word"},{"id":29908,"position":3,"arabic":"يُحِبُّونَ","translation":"ভালবাসে","audioUrl":"wbw/076_027_003.mp3","charTypeName":"word"},{"id":29909,"position":4,"arabic":"ٱلْعَاجِلَةَ","translation":"দ্রুত অর্জিত ( বৈষয়িক স্বার্থ)","audioUrl":"wbw/076_027_004.mp3","charTypeName":"word"},{"id":29910,"position":5,"arabic":"وَيَذَرُونَ","translation":"এবং তারা উপেক্ষা করে","audioUrl":"wbw/076_027_005.mp3","charTypeName":"word"},{"id":29911,"position":6,"arabic":"وَرَآءَهُمْ","translation":"তাদের পিছনে","audioUrl":"wbw/076_027_006.mp3","charTypeName":"word"},{"id":29912,"position":7,"arabic":"يَوْمًۭا","translation":"দিনকে","audioUrl":"wbw/076_027_007.mp3","charTypeName":"word"},{"id":29913,"position":8,"arabic":"ثَقِيلًۭا","translation":"ভারী","audioUrl":"wbw/076_027_008.mp3","charTypeName":"word"},{"id":29914,"position":9,"arabic":"٢٧","translation":"(২৭)","audioUrl":null,"charTypeName":"end"}]},{"number":28,"arabic":"نَّحْنُ خَلَقْنَٰهُمْ وَشَدَدْنَآ أَسْرَهُمْ ۖ وَإِذَا شِئْنَا بَدَّلْنَآ أَمْثَٰلَهُمْ تَبْدِيلًا","translation":"[They will not admit to themselves that] it We who have created them and strengthened their make - and [that] if it be Our will We can replace them entirely with others of their kind.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5619.mp3","surahId":76,"words":[{"id":31141,"position":1,"arabic":"نَّحْنُ","translation":"আমরা","audioUrl":"wbw/076_028_001.mp3","charTypeName":"word"},{"id":31142,"position":2,"arabic":"خَلَقْنَـٰهُمْ","translation":"তাদের আমরা সৃষ্টি করেছি","audioUrl":"wbw/076_028_002.mp3","charTypeName":"word"},{"id":31143,"position":3,"arabic":"وَشَدَدْنَآ","translation":"এবং আমরা সুদৃঢ় করেছি","audioUrl":"wbw/076_028_003.mp3","charTypeName":"word"},{"id":31144,"position":4,"arabic":"أَسْرَهُمْ ۖ","translation":"তাদের জোড়ন","audioUrl":"wbw/076_028_004.mp3","charTypeName":"word"},{"id":31146,"position":5,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/076_028_006.mp3","charTypeName":"word"},{"id":31147,"position":6,"arabic":"شِئْنَا","translation":"আমরা চাইবো","audioUrl":"wbw/076_028_007.mp3","charTypeName":"word"},{"id":31148,"position":7,"arabic":"بَدَّلْنَآ","translation":"আমরা বদলে দেবো","audioUrl":"wbw/076_028_008.mp3","charTypeName":"word"},{"id":31149,"position":8,"arabic":"أَمْثَـٰلَهُمْ","translation":"তাদের আকৃতি সমূহ","audioUrl":"wbw/076_028_009.mp3","charTypeName":"word"},{"id":31150,"position":9,"arabic":"تَبْدِيلًا","translation":"পরিবর্তন করে","audioUrl":"wbw/076_028_010.mp3","charTypeName":"word"},{"id":31151,"position":10,"arabic":"٢٨","translation":"(২৮)","audioUrl":null,"charTypeName":"end"}]},{"number":29,"arabic":"إِنَّ هَٰذِهِۦ تَذْكِرَةٌۭ ۖ فَمَن شَآءَ ٱتَّخَذَ إِلَىٰ رَبِّهِۦ سَبِيلًۭا","translation":"VERILY, all this is an admonition: whoever, then, so wills, may unto his Sustainer find a way.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5620.mp3","surahId":76,"words":[{"id":31985,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়","audioUrl":"wbw/076_029_001.mp3","charTypeName":"word"},{"id":31986,"position":2,"arabic":"هَـٰذِهِۦ","translation":"এটা","audioUrl":"wbw/076_029_002.mp3","charTypeName":"word"},{"id":31987,"position":3,"arabic":"تَذْكِرَةٌۭ