ition":9,"arabic":"مَّنثُورًۭا","translation":"বিক্ষিপ্ত","audioUrl":"wbw/076_019_010.mp3","charTypeName":"word"},{"id":21720,"position":10,"arabic":"١٩","translation":"(১৯)","audioUrl":null,"charTypeName":"end"}]},{"number":20,"arabic":"وَإِذَا رَأَيْتَ ثَمَّ رَأَيْتَ نَعِيمًۭا وَمُلْكًۭا كَبِيرًا","translation":"and when thou seest [anything that is] there thou wilt see [only] bliss and a realm transcendent","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5611.mp3","surahId":76,"words":[{"id":23150,"position":1,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/076_020_001.mp3","charTypeName":"word"},{"id":23151,"position":2,"arabic":"رَأَيْتَ","translation":"তুমি দেখবে","audioUrl":"wbw/076_020_002.mp3","charTypeName":"word"},{"id":23152,"position":3,"arabic":"ثَمَّ","translation":"সেখানে","audioUrl":"wbw/076_020_003.mp3","charTypeName":"word"},{"id":23153,"position":4,"arabic":"رَأَيْتَ","translation":"দেখবে","audioUrl":"wbw/076_020_004.mp3","charTypeName":"word"},{"id":23154,"position":5,"arabic":"نَعِيمًۭا","translation":"নিয়ামত","audioUrl":"wbw/076_020_005.mp3","charTypeName":"word"},{"id":23155,"position":6,"arabic":"وَمُلْكًۭا","translation":"এবং সম্রাজ্য","audioUrl":"wbw/076_020_006.mp3","charTypeName":"word"},{"id":23156,"position":7,"arabic":"كَبِيرًا","translation":"বিরাট","audioUrl":"wbw/076_020_007.mp3","charTypeName":"word"},{"id":23157,"position":8,"arabic":"٢٠","translation":"(২০)","audioUrl":null,"charTypeName":"end"}]},{"number":21,"arabic":"عَٰلِيَهُمْ ثِيَابُ سُندُسٍ خُضْرٌۭ وَإِسْتَبْرَقٌۭ ۖ وَحُلُّوٓا۟ أَسَاوِرَ مِن فِضَّةٍۢ وَسَقَىٰهُمْ رَبُّهُمْ شَرَابًۭا طَهُورًا","translation":"Upon those [blest] will be garments of green silk and brocade; and they will be adorned with bracelets of silver. And their Sustainer will them to drink of a drink most pure.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5612.mp3","surahId":76,"words":[{"id":23965,"position":1,"arabic":"عَـٰلِيَهُمْ","translation":"তাদের উপ