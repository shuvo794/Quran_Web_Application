003.mp3","charTypeName":"word"},{"id":11588,"position":4,"arabic":"رَّبِّنَا","translation":"আমাদের রবের","audioUrl":"wbw/076_010_004.mp3","charTypeName":"word"},{"id":11589,"position":5,"arabic":"يَوْمًا","translation":"সেই দিনের","audioUrl":"wbw/076_010_005.mp3","charTypeName":"word"},{"id":11590,"position":6,"arabic":"عَبُوسًۭا","translation":"ভয়ংকর (যা)","audioUrl":"wbw/076_010_006.mp3","charTypeName":"word"},{"id":11591,"position":7,"arabic":"قَمْطَرِيرًۭا","translation":"ক্লেশকর\"","audioUrl":"wbw/076_010_007.mp3","charTypeName":"word"},{"id":11592,"position":8,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"فَوَقَىٰهُمُ ٱللَّهُ شَرَّ ذَٰلِكَ ٱلْيَوْمِ وَلَقَّىٰهُمْ نَضْرَةًۭ وَسُرُورًۭا","translation":"And so, God will preserve them from the woes of that Day, and will bestow on them brightness and joy,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5602.mp3","surahId":76,"words":[{"id":12886,"position":1,"arabic":"فَوَقَىٰهُمُ","translation":"তাদের বাচাবেন অতএব","audioUrl":"wbw/076_011_001.mp3","charTypeName":"word"},{"id":12887,"position":2,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/076_011_002.mp3","charTypeName":"word"},{"id":12888,"position":3,"arabic":"شَرَّ","translation":"অনিষ্ঠতা (থেকে)","audioUrl":"wbw/076_011_003.mp3","charTypeName":"word"},{"id":12889,"position":4,"arabic":"ذَٰلِكَ","translation":"সেই","audioUrl":"wbw/076_011_004.mp3","charTypeName":"word"},{"id":12890,"position":5,"arabic":"ٱلْيَوْمِ","translation":"দিনের","audioUrl":"wbw/076_011_005.mp3","charTypeName":"word"},{"id":12891,"position":6,"arabic":"وَلَقَّىٰهُمْ","translation":"এবং তাদের দান করবেন","audioUrl":"wbw/076_011_006.mp3","charTypeName":"word"},{"id":12892,"position":7,"arabic":"نَضْرَةًۭ","translation":"উৎফুল্লতা","audioUrl":"wbw/076_011_007.mp3","charTypeName":"word"},{"id":12893,"position":8,"arabic":"وَسُرُورًۭا","translation":"ও আনন্দ","audioUrl":"wbw/076_011_008.mp3","charTypeName":"word"},{"id":12894,"position":9,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]},{"number":12,"arabic":"وَجَزَىٰهُم بِمَا صَبَرُوا۟ جَنَّةًۭ وَحَرِيرًۭا","translation":"and will reward them for all their patience in adversity with a garden [of bliss] and with [garments of] silk.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5603.mp3","surahId":76,"words":[{"id":14499,"position":1,"arabic":"وَجَزَىٰهُم","translation":"এবং তাদের প্রতিদান","audioUrl":"wbw/076_012_001.mp3","charTypeName":"word"},{"id":14500,"position":2,"arabic":"بِمَا","translation":"যা বিনিময়ে","audioUrl":"wbw/076_012_002.mp3","charTypeName":"word"},{"id":14501,"position":3,"arabic":"صَبَرُوا۟","translation":"তারা সবর করেছে","audioUrl":"wbw/076_012_003.mp3","charTypeName":"word"},{"id":14502,"position":4,"arabic":"جَنَّةًۭ","translation":"জান্নাত","audioUrl":"wbw/076_012_004.mp3","charTypeName":"word"},{"id":14503,"position":5,"arabic":"وَحَرِيرًۭا","translation":"এবং রেশমীপোশাক","audioUrl":"wbw/076_012_005.mp3","charTypeName":"word"},{"id":14504,"position":6,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]},{"number":13,"arabic":"مُّتَّكِـِٔينَ فِيهَا عَلَى ٱلْأَرَآئِكِ ۖ لَا يَرَوْنَ فِيهَا شَمْسًۭا وَلَا زَمْهَرِيرًۭا","translation":"In that [garden] they will on couches recline, and will know therein neither [burning] sun nor cold severe,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5604.mp3","surahId":76,"words":[{"id":15270,"position":1,"arabic":"مُّتَّكِـِٔينَ","translation":"হেলান দিয়ে বসবে","audioUrl":"wbw/076_013_001.mp3","charTypeName":"word"},{"id":15271,"position":2,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/076_013_002.mp3","charTypeName":"word"},{"id":15272,"position":3,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/076_013_003.mp3","charTypeName":"word"},{"id":15273,"position":4,"arabic":"ٱلْأَرَآئِكِ ۖ","translation":"উচ্চাসনসমুহের","audioUrl":"wbw/076_013_004.mp3","charTypeN