্মিত)","audioUrl":"wbw/076_016_002.mp3","charTypeName":"word"},{"id":18886,"position":3,"arabic":"فِضَّةٍۢ","translation":"রোপ্যের","audioUrl":"wbw/076_016_003.mp3","charTypeName":"word"},{"id":18887,"position":4,"arabic":"قَدَّرُوهَا","translation":"তা তারা পরিমাণ মত ভরবে","audioUrl":"wbw/076_016_004.mp3","charTypeName":"word"},{"id":18888,"position":5,"arabic":"تَقْدِيرًۭا","translation":"পরিমিত পরিমানে","audioUrl":"wbw/076_016_005.mp3","charTypeName":"word"},{"id":18889,"position":6,"arabic":"١٦","translation":"(১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":17,"arabic":"وَيُسْقَوْنَ فِيهَا كَأْسًۭا كَانَ مِزَاجُهَا زَنجَبِيلًا","translation":"And in that [paradise] they will be given to drink of a cup flavoured with ginger,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5608.mp3","surahId":76,"words":[{"id":19574,"position":1,"arabic":"وَيُسْقَوْنَ","translation":"এবং পান করানো হবে তাদের","audioUrl":"wbw/076_017_001.mp3","charTypeName":"word"},{"id":19575,"position":2,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/076_017_002.mp3","charTypeName":"word"},{"id":19576,"position":3,"arabic":"كَأْسًۭا","translation":"সূরা","audioUrl":"wbw/076_017_003.mp3","charTypeName":"word"},{"id":19577,"position":4,"arabic":"كَانَ","translation":"হবে","audioUrl":"wbw/076_017_004.mp3","charTypeName":"word"},{"id":19578,"position":5,"arabic":"مِزَاجُهَا","translation":"যার সংমিশ্রণ","audioUrl":"wbw/076_017_005.mp3","charTypeName":"word"},{"id":19579,"position":6,"arabic":"زَنجَبِيلًا","translation":"আদার","audioUrl":"wbw/076_017_006.mp3","charTypeName":"word"},{"id":19580,"position":7,"arabic":"١٧","translation":"(১৭)","audioUrl":null,"charTypeName":"end"}]},{"number":18,"arabic":"عَيْنًۭا فِيهَا تُسَمَّىٰ سَلْسَبِيلًۭا","translation":"[derived from] a source [to be found] therein, whose name is \"Seek Thy Way\".","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5609.mp3","surahId":76,"words":[{"id":20655,"position":1,"arabic":"