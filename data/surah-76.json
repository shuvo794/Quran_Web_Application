{"id":76,"nameArabic":"سُورَةُ الإِنسَانِ","nameEnglish":"Al-Insaan","nameTranslation":"Man","revelationType":"Medinan","numberOfAyahs":31,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ هَلْ أَتَىٰ عَلَى ٱلْإِنسَٰنِ حِينٌۭ مِّنَ ٱلدَّهْرِ لَمْ يَكُن شَيْـًۭٔا مَّذْكُورًا","translation":"HAS THERE [not] been an endless span of time before man [appeared - a time] when he was not yet a thing to be thought of?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5592.mp3","surahId":76,"words":[{"id":639,"position":1,"arabic":"هَلْ","translation":"কি","audioUrl":"wbw/076_001_001.mp3","charTypeName":"word"},{"id":640,"position":2,"arabic":"أَتَىٰ","translation":"এসেছে","audioUrl":"wbw/076_001_002.mp3","charTypeName":"word"},{"id":641,"position":3,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/076_001_003.mp3","charTypeName":"word"},{"id":642,"position":4,"arabic":"ٱلْإِنسَـٰنِ","translation":"মানুষের","audioUrl":"wbw/076_001_004.mp3","charTypeName":"word"},{"id":643,"position":5,"arabic":"حِينٌۭ","translation":"এক সময়","audioUrl":"wbw/076_001_005.mp3","charTypeName":"word"},{"id":644,"position":6,"arabic":"مِّنَ","translation":"থেকে","audioUrl":"wbw/076_001_006.mp3","charTypeName":"word"},{"id":645,"position":7,"arabic":"ٱلدَّهْرِ","translation":"সীমাহীন কালের","audioUrl":"wbw/076_001_007.mp3","charTypeName":"word"},{"id":646,"position":8,"arabic":"لَمْ","translation":"না","audioUrl":"wbw/076_001_008.mp3","charTypeName":"word"},{"id":647,"position":9,"arabic":"يَكُن","translation":"সে ছিল","audioUrl":"wbw/076_001_009.mp3","charTypeName":"word"},{"id":648,"position":10,"arabic":"شَيْـًۭٔا","translation":"কিছুই","audioUrl":"wbw/076_001_010.mp3","charTypeName":"word"},{"id":649,"position":11,"arabic":"مَّذْكُورًا","translation":"উল্লেখযোগ্য","audioUrl":"wbw/076_001_011.mp3","charTypeName":"word"},{"id":650,"position":12,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"إِنَّا خَلَقْنَا ٱلْإ