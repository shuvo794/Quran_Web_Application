mp3","surahId":76,"words":[{"id":25129,"position":1,"arabic":"إِنَّ","translation":"\"নিশ্চয়","audioUrl":"wbw/076_022_001.mp3","charTypeName":"word"},{"id":25130,"position":2,"arabic":"هَـٰذَا","translation":"এটা","audioUrl":"wbw/076_022_002.mp3","charTypeName":"word"},{"id":25131,"position":3,"arabic":"كَانَ","translation":"হলো","audioUrl":"wbw/076_022_003.mp3","charTypeName":"word"},{"id":25132,"position":4,"arabic":"لَكُمْ","translation":"তোমাদের জন্যে","audioUrl":"wbw/076_022_004.mp3","charTypeName":"word"},{"id":25133,"position":5,"arabic":"جَزَآءًۭ","translation":"প্রতিদান","audioUrl":"wbw/076_022_005.mp3","charTypeName":"word"},{"id":25134,"position":6,"arabic":"وَكَانَ","translation":"এবং হবে","audioUrl":"wbw/076_022_006.mp3","charTypeName":"word"},{"id":25135,"position":7,"arabic":"سَعْيُكُم","translation":"তোমাদের প্রচেষ্টা","audioUrl":"wbw/076_022_007.mp3","charTypeName":"word"},{"id":25136,"position":8,"arabic":"مَّشْكُورًا","translation":"প্রশংসীত\"","audioUrl":"wbw/076_022_008.mp3","charTypeName":"word"},{"id":25137,"position":9,"arabic":"٢٢","translation":"(২২)","audioUrl":null,"charTypeName":"end"}]},{"number":23,"arabic":"إِنَّا نَحْنُ نَزَّلْنَا عَلَيْكَ ٱلْقُرْءَانَ تَنزِيلًۭا","translation":"VERILY, [O believer,] it is We who have bestowed from on high this Qur’an upon thee, step by step - truly a bestowal from on high!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5614.mp3","surahId":76,"words":[{"id":26005,"position":1,"arabic":"إِنَّا","translation":"নিশ্চয়","audioUrl":"wbw/076_023_001.mp3","charTypeName":"word"},{"id":26006,"position":2,"arabic":"نَحْنُ","translation":"আমরা","audioUrl":"wbw/076_023_002.mp3","charTypeName":"word"},{"id":26007,"position":3,"arabic":"نَزَّلْنَا","translation":"আমরা নাযিল করেছি","audioUrl":"wbw/076_023_003.mp3","charTypeName":"word"},{"id":26008,"position":4,"arabic":"عَلَيْكَ","translation":"তোমার উপর","audioUrl":"wbw/076_023_004.mp3","charTypeName":"word"},{"id":26009,"position":5,"arabic":"ٱلْقُرْءَانَ","translation":"কুরআন","audioUrl":"wbw/076_023_005.mp3","charTypeName":"word"},{"id":26010,"position":6,"arabic":"تَنزِيلًۭا","translation":"নাযিল (অল্প অল্প করে)","audioUrl":"wbw/076_023_006.mp3","charTypeName":"word"},{"id":26011,"position":7,"arabic":"٢٣","translation":"(২৩)","audioUrl":null,"charTypeName":"end"}]},{"number":24,"arabic":"فَٱصْبِرْ لِحُكْمِ رَبِّكَ وَلَا تُطِعْ مِنْهُمْ ءَاثِمًا أَوْ كَفُورًۭا","translation":"Await, then, in all patience thy Sustainer's judgment, and pay no heed to any of them, who is a wilful sinner or an ingrate;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5615.mp3","surahId":76,"words":[{"id":27292,"position":1,"arabic":"فَٱصْبِرْ","translation":"অতএব তুমি সবর কর","audioUrl":"wbw/076_024_001.mp3","charTypeName":"word"},{"id":27293,"position":2,"arabic":"لِحُكْمِ","translation":"হুকুমের জন্য","audioUrl":"wbw/076_024_002.mp3","charTypeName":"word"},{"id":27294,"position":3,"arabic":"رَبِّكَ","translation":"তোমার রবের","audioUrl":"wbw/076_024_003.mp3","charTypeName":"word"},{"id":27295,"position":4,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/076_024_004.mp3","charTypeName":"word"},{"id":27296,"position":5,"arabic":"تُطِعْ","translation":"তুমি অনুসরন কর","audioUrl":"wbw/076_024_005.mp3","charTypeName":"word"},{"id":27297,"position":6,"arabic":"مِنْهُمْ","translation":"তাদের মধ্যে","audioUrl":"wbw/076_024_006.mp3","charTypeName":"word"},{"id":27298,"position":7,"arabic":"ءَاثِمًا","translation":"পাপিষ্ঠ (যারা)","audioUrl":"wbw/076_024_007.mp3","charTypeName":"word"},{"id":27299,"position":8,"arabic":"أَوْ","translation":"বা","audioUrl":"wbw/076_024_008.mp3","charTypeName":"word"},{"id":27300,"position":9,"arabic":"كَفُورًۭا","translation":"কাফির","audioUrl":"wbw/076_024_009.mp3","charTypeName":"word"},{"id":27301,"position":10,"arabic":"٢٤","translation":"(২৪)","audioUrl":null,"charTypeName":"end"}]},{"number":25,"arabic":"وَٱذْكُرِ ٱسْمَ رَبِّكَ بُكْرَةًۭ وَأَصِيلًۭا","translation":"and