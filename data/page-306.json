5,"arabic":"مِنكَ","translation":"তোমার থেকে","audioUrl":"wbw/019_018_005.mp3","charTypeName":"word"},{"id":20311,"position":6,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/019_018_006.mp3","charTypeName":"word"},{"id":20312,"position":7,"arabic":"كُنتَ","translation":"তুমি হও","audioUrl":"wbw/019_018_007.mp3","charTypeName":"word"},{"id":20313,"position":8,"arabic":"تَقِيًّۭا","translation":"মুত্তাকী\"","audioUrl":"wbw/019_018_008.mp3","charTypeName":"word"},{"id":20314,"position":9,"arabic":"١٨","translation":"(১৮)","audioUrl":null,"charTypeName":"end"}]},{"number":19,"arabic":"قَالَ إِنَّمَآ أَنَا۠ رَسُولُ رَبِّكِ لِأَهَبَ لَكِ غُلَٰمًۭا زَكِيًّۭا","translation":"[The angel] answered: \"I' am but a messenger of thy Sustainer, [who says,] `I shall bestow upon thee the gift of a son endowed with purity.'\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2269.mp3","surahId":19,"words":[{"id":21403,"position":1,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/019_019_001.mp3","charTypeName":"word"},{"id":21404,"position":2,"arabic":"إِنَّمَآ","translation":"\"প্রকৃতপক্ষে","audioUrl":"wbw/019_019_002.mp3","charTypeName":"word"},{"id":21405,"position":3,"arabic":"أَنَا۠","translation":"আমি","audioUrl":"wbw/019_019_003.mp3","charTypeName":"word"},{"id":21406,"position":4,"arabic":"رَسُولُ","translation":"(প্রেরিত) দূত","audioUrl":"wbw/019_019_004.mp3","charTypeName":"word"},{"id":21407,"position":5,"arabic":"رَبِّكِ","translation":"তোমার রবের","audioUrl":"wbw/019_019_005.mp3","charTypeName":"word"},{"id":21408,"position":6,"arabic":"لِأَهَبَ","translation":"দান করি যেন","audioUrl":"wbw/019_019_006.mp3","charTypeName":"word"},{"id":21409,"position":7,"arabic":"لَكِ","translation":"তোমাকে","audioUrl":"wbw/019_019_007.mp3","charTypeName":"word"},{"id":21410,"position":8,"arabic":"غُلَـٰمًۭا","translation":"এক পুত্র","audioUrl":"wbw/019_019_008.mp3","charTypeName":"word"},{"id":21411,"position":9,"arabic":"زَكِيًّۭا","translation":"পবিত্র\"","audioUrl":"wbw/019_019_009.mp3","charTypeName":"word"},{"id":21412,"position":10,"arabic":"١٩","translation":"(১৯)","audioUrl":null,"charTypeName":"end"}]},{"number":20,"arabic":"قَالَتْ أَنَّىٰ يَكُونُ لِى غُلَٰمٌۭ وَلَمْ يَمْسَسْنِى بَشَرٌۭ وَلَمْ أَكُ بَغِيًّۭا","translation":"Said she: \"How can I have a son when no man has ever touched me? - for, never have I been a loose woman!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2270.mp3","surahId":19,"words":[{"id":22495,"position":1,"arabic":"قَالَتْ","translation":"সে বললো","audioUrl":"wbw/019_020_001.mp3","charTypeName":"word"},{"id":22496,"position":2,"arabic":"أَنَّىٰ","translation":"\"কেমন করে","audioUrl":"wbw/019_020_002.mp3","charTypeName":"word"},{"id":22497,"position":3,"arabic":"يَكُونُ","translation":"হবে","audioUrl":"wbw/019_020_003.mp3","charTypeName":"word"},{"id":22498,"position":4,"arabic":"لِى","translation":"আমার","audioUrl":"wbw/019_020_004.mp3","charTypeName":"word"},{"id":22499,"position":5,"arabic":"غُلَـٰمٌۭ","translation":"পুত্র","audioUrl":"wbw/019_020_005.mp3","charTypeName":"word"},{"id":22500,"position":6,"arabic":"وَلَمْ","translation":"যখন নি","audioUrl":"wbw/019_020_006.mp3","charTypeName":"word"},{"id":22501,"position":7,"arabic":"يَمْسَسْنِى","translation":"আমাকে স্পর্শ করে","audioUrl":"wbw/019_020_007.mp3","charTypeName":"word"},{"id":22502,"position":8,"arabic":"بَشَرٌۭ","translation":"কোন মানুষ","audioUrl":"wbw/019_020_008.mp3","charTypeName":"word"},{"id":22503,"position":9,"arabic":"وَلَمْ","translation":"এবং নই","audioUrl":"wbw/019_020_009.mp3","charTypeName":"word"},{"id":22504,"position":10,"arabic":"أَكُ","translation":"আমি (হই)","audioUrl":"wbw/019_020_010.mp3","charTypeName":"word"},{"id":22505,"position":11,"arabic":"بَغِيًّۭا","translation":"ব্যভিচারিণী\"","audioUrl":"wbw/019_020_011.mp3","charTypeName":"word"},{"id":22506,"position":12,"arabic":"٢٠","translation":"(২০)","audioUrl":null,"charTypeName":"end"}]},{"number":21,"arabic":"قَالَ كَذَٰلِكِ قَالَ رَبُّكِ هُوَ عَلَىَّ هَيِّنٌۭ ۖ وَلِنَجْعَلَهُۥٓ ءَايَةًۭ لِّلنَّاسِ وَرَحْمَةًۭ مِّنَّا ۚ وَكَانَ أَمْرًۭا مَّقْضِيًّۭا","translation":"[The angel] answered: \"Thus it is; [but] thy Sustainer says, `This is easy for Me; and [thou shalt have a son,] so that We might make him a symbol unto mankind and an act of grace from US. And it was a thing decreed [by God]:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2271.mp3","surahId":19,"words":[{"id":23643,"position":1,"arabic":"قَالَ","translation":"(ফেরেশতা) বললো","audioUrl":"wbw/019_021_001.mp3","charTypeName":"word"},{"id":23644,"position":2,"arabic":"كَذَٰلِكِ","translation":"\"এরূপই (হবে)","audioUrl":"wbw/019_021_002.mp3","charTypeName":"word"},{"id":23645,"position":3,"arabic":"قَالَ","translation":"বলেছেন","audioUrl":"wbw/019_021_003.mp3","charTypeName":"word"},{"id":23646,"position":4,"arabic":"رَبُّكِ","translation":"তোমার রব","audioUrl":"wbw/019_021_004.mp3","charTypeName":"word"},{"id":23647,"position":5,"arabic":"هُوَ","translation":"তা","audioUrl":"wbw/019_021_005.mp3","charTypeName":"word"},{"id":23648,"position":6,"arabic":"عَلَىَّ","translation":"আমার উপর","audioUrl":"wbw/019_021_006.mp3","charTypeName":"word"},{"id":23649,"position":7,"arabic":"هَيِّنٌۭ ۖ","translation":"সহজ","audioUrl":"wbw/019_021_007.mp3","charTypeName":"word"},{"id":23651,"position":8,"arabic":"وَلِنَجْعَلَهُۥٓ","translation":"এবং যেন তা আমরা করি","audioUrl":"wbw/019_021_009.mp3","charTypeName":"word"},{"id":23652,"position":9,"arabic":"ءَايَةًۭ","translation":"একটি নিদর্শন","audioUrl":"wbw/019_021_010.mp3","charTypeName":"word"},{"id":23653,"position":10,"arabic":"لِّلنَّاسِ","translation":"মানুষদের জন্য","audioUrl":"wbw/019_021_011.mp3","charTypeName":"word"},{"id":23654,"position":11,"arabic":"وَرَحْمَةًۭ","translation":"ও অনুগ্রহ","audioUrl":"wbw/019_021_012.mp3","charTypeName":"word"},{"id":23655,"position":12,"arabic":"مِّنَّا ۚ","translation":"আমাদের থেকে","audioUrl":"wbw/019_021_013.mp3","charTypeName":"word"},{"id":23657,"position":13,"arabic":"وَكَانَ","translation":"এবং হয়েছে","audioUrl":"wbw/019_021_015.mp3","charTypeName":"word"},{"id":23658,"position":14,"arabic":"أَمْرًۭا","translation":"বিষয় (সিদ্ধান্ত)","audioUrl":"wbw/019_021_016.mp3","charTypeName":"word"},{"id":23659,"position":15,"arabic":"مَّقْضِيًّۭا","translation":"স্থিরীকৃত","audioUrl":"wbw/019_021_017.mp3","charTypeName":"word"},{"id":23660,"position":16,"arabic":"٢١","translation":"(২১)","audioUrl":null,"charTypeName":"end"}]},{"number":22,"arabic":"۞ فَحَمَلَتْهُ فَٱنتَبَذَتْ بِهِۦ مَكَانًۭا قَصِيًّۭا","translation":"and in time she conceived him, and then she withdrew with him to a far-off place.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2272.mp3","surahId":19,"words":[{"id":24614,"position":1,"arabic":"۞ فَحَمَلَتْهُ","translation":"তাকে সে অতঃপর গর্ভধারণ করলো","audioUrl":"wbw/019_022_002.mp3","charTypeName":"word"},{"id":24615,"position":2,"arabic":"فَٱنتَبَذَتْ","translation":"অতঃপর সে পৃথক হয়ে গেলো","audioUrl":"wbw/019_022_003.mp3","charTypeName":"word"},{"id":24616,"position":3,"arabic":"بِهِۦ","translation":"তা নিয়ে","audioUrl":"wbw/019_022_004.mp3","charTypeName":"word"},{"id":24617,"position":4,"arabic":"مَكَانًۭا","translation":"স্থানে","audioUrl":"wbw/019_022_005.mp3","charTypeName":"word"},{"id":24618,"position":5,"arabic":"قَصِيًّۭا","translation":"দূরবর্তী","audioUrl":"wbw/019_022_006.mp3","charTypeName":"word"},{"id":24619,"position":6,"arabic":"٢٢","translation":"(২২)","audioUrl":null,"charTypeName":"end"}]},{"number":23,"arabic":"فَأَجَآءَهَا ٱلْمَخَاضُ إِلَىٰ جِذْعِ ٱلنَّخْلَةِ قَالَتْ يَٰلَيْتَنِى مِتُّ قَبْلَ هَٰذَا وَكُنتُ نَسْيًۭا مَّنسِيًّۭا","translation":"And [when] the throes of childbirth drove her to the trunk of a palm-tree, she exclaimed: \"Oh, would that I had died ere this, and had become a thing forgotten, utterly forgotten!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2273.mp3","surahId":19,"words":[{"id":25693,"position":1,"arabic":"فَأَجَآءَهَا","translation":"অতঃপর তাকে নিয়ে এলো","audioUrl":"wbw/019_023_001.mp3","charTypeName":"word"},{"id":25694,"position":2,"arabic":"ٱلْمَخَاضُ","translation":"প্রসববেদনা","audioUrl":"wbw/019_023_002.mp3","charTypeName":"word"},{"id":25695,"position":3,"arabic":"إِلَىٰ","translation":"কাছে","audioUrl":"wbw/019_023_003.mp3","charTypeName":"word"},{"id":25696,"position":4,"arabic":"جِذْعِ","translation":"কান্ডের","audioUrl":"wbw/019_023_004.mp3","charTypeName":"word"},{"id":25697,"position":5,"arabic":"ٱلنَّخْلَةِ","translation":"খেজুর গাছের","audioUrl":"wbw/019_023_005.mp3","charTypeName":"word"},{"id":25698,"position":6,"arabic":"قَالَتْ","translation":"সে বললো","audioUrl":"wbw/019_023_006.mp3","charTypeName":"word"},{"id":25699,"position":7,"arabic":"يَـٰلَيْتَنِى","translation":"\"হায়! আমার আফসোস","audioUrl":"wbw/019_023_007.mp3","charTypeName":"word"},{"id":25700,"position":8,"arabic":"مِتُّ","translation":"আমি (যদি) মরে যেতাম","audioUrl":"wbw/019_023_008.mp3","charTypeName":"word"},{"id":25701,"position":9,"arabic":"قَبْلَ","translation":"পূর্বে","audioUrl":"wbw/019_023_009.mp3","charTypeName":"word"},{"id":25702,"position":10,"arabic":"هَـٰذَا","translation":"এর","audioUrl":"wbw/019_023_010.mp3","charTypeName":"word"},{"id":25703,"position":11,"arabic":"وَكُنتُ","translation":"এবং আমি হতাম","audioUrl":"wbw/019_023_011.mp3","charTypeName":"word"},{"id":25704,"position":12,"arabic":"نَسْيًۭا","translation":"বিস্মৃত","audioUrl":"wbw/019_023_012.mp3","charTypeName":"word"},{"id":25705,"position":13,"arabic":"مَّنسِيًّۭا","translation":"স্মৃতি বিলুপ্ত\"","audioUrl":"wbw/019_023_013.mp3","charTypeName":"word"},{"id":25706,"position":14,"arabic":"٢٣","translation":"(২৩)","audioUrl":null,"charTypeName":"end"}]},{"number":24,"arabic":"فَنَادَىٰهَا مِن تَحْتِهَآ أَلَّا تَحْزَنِى قَدْ جَعَلَ رَبُّكِ تَحْتَكِ سَرِيًّۭا","translation":"Thereupon [a voice] called out to her from beneath that [palm-tree]: \"Grieve not! Thy Sustainer has provided a rivulet [running] beneath thee;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2274.mp3","surahId":19,"words":[{"id":26761,"position":1,"arabic":"فَنَادَىٰهَا","translation":"অতঃপর ডেকে বললো (ফেরেশতা) তাকে","audioUrl":"wbw/019_024_001.mp3","charTypeName":"word"},{"id":26762,"position":2,"arabic":"مِن","translation":"হ'তে","audioUrl":"wbw/019_024_002.mp3","charTypeName":"word"},{"id":26763,"position":3,"arabic":"تَحْتِهَآ","translation":"তার নিচ","audioUrl":"wbw/019_024_003.mp3","charTypeName":"word"},{"id":26764,"position":4,"arabic":"أَلَّا","translation":"\"যে না","audioUrl":"wbw/019_024_004.mp3","charTypeName":"word"},{"id":26765,"position":5,"arabic":"تَحْزَنِى","translation":"তুমি চিন্তা করো","audioUrl":"wbw/019_024_005.mp3","charTypeName":"word"},{"id":26766,"position":6,"arabic":"قَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/019_024_006.mp3","charTypeName":"word"},{"id":26767,"position":7,"arabic":"جَعَلَ","translation":"সৃষ্টি করেছেন","audioUrl":"wbw/019_024_007.mp3","charTypeName":"word"},{"id":26768,"position":8,"arabic":"رَبُّكِ","translation":"তোমার রব","audioUrl":"wbw/019_024_008.mp3","charTypeName":"word"},{"id":26769,"position":9,"arabic":"تَحْتَكِ","translation":"তোমার নিচে","audioUrl":"wbw/019_024_009.mp3","charTypeName":"word"},{"id":26770,"position":10,"arabic":"سَرِيًّۭا","translation":"এক ঝর্ণা","audioUrl":"wbw/019_024_010.mp3","charTypeName":"word"},{"id":26771,"position":11,"arabic":"٢٤","translation":"(২৪)","audioUrl":null,"charTypeName":"end"}]},{"number":25,"arabic":"وَهُزِّىٓ إِلَيْكِ بِجِذْعِ ٱلنَّخْلَةِ تُسَٰقِطْ عَلَيْكِ رُطَبًۭا جَنِيًّۭا","translation":"and shake the trunk of the palm-tree towards thee: it will drop fresh, ripe dates upon thee.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2275.mp3","surahId":19,"words":[{"id":27790,"position":1,"arabic":"وَهُزِّىٓ","translation":"এবং তুমি নাড়া দাও","audioUrl":"wbw/019_025_001.mp3","charTypeName":"word"},{"id":27791,"position":2,"arabic":"إِلَيْكِ","translation":"তোমার দিকে","audioUrl":"wbw/019_025_002.mp3","charTypeName":"word"},{"id":27792,"position":3,"arabic":"بِجِذْعِ","translation":"কান্ডসহ","audioUrl":"wbw/019_025_003.mp3","charTypeName":"word"},{"id":27793,"position":4,"arabic":"ٱلنَّخْلَةِ","translation":"খেজুর গাছের","audioUrl":"wbw/019_025_004.mp3","charTypeName":"word"},{"id":27794,"position":5,"arabic":"تُسَـٰقِطْ","translation":"ঝরে পড়বে","audioUrl":"wbw/019_025_005.mp3","charTypeName":"word"},{"id":27795,"position":6,"arabic":"عَلَيْكِ","translation":"তোমার উপর","audioUrl":"wbw/019_025_006.mp3","charTypeName":"word"},{"id":27796,"position":7,"arabic":"رُطَبًۭا","translation":"খেজুর","audioUrl":"wbw/019_025_007.mp3","charTypeName":"word"},{"id":27797,"position":8,"arabic":"جَنِيًّۭا","translation":"তাজা","audioUrl":"wbw/019_025_008.mp3","charTypeName":"word"},{"id":27798,"position":9,"arabic":"٢٥","translation":"(২৫)","audioUrl":null,"charTypeName":"end"}]}]}