{"id":306,"ayahs":[{"number":12,"arabic":"يَٰيَحْيَىٰ خُذِ ٱلْكِتَٰبَ بِقُوَّةٍۢ ۖ وَءَاتَيْنَٰهُ ٱلْحُكْمَ صَبِيًّۭا","translation":"[And when the son was born and grew up, he was told,] \"O John! Hold fast unto the divine writ with [all thy] strength!\" - for We granted him wisdom \"while he was yet a little boy,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2262.mp3","surahId":19,"words":[{"id":13678,"position":1,"arabic":"يَـٰيَحْيَىٰ","translation":"\"(বড় হ'লে তাকে বলা হলো) হে ইয়াহইয়া","audioUrl":"wbw/019_012_001.mp3","charTypeName":"word"},{"id":13679,"position":2,"arabic":"خُذِ","translation":"গ্রহণ করো","audioUrl":"wbw/019_012_002.mp3","charTypeName":"word"},{"id":13680,"position":3,"arabic":"ٱلْكِتَـٰبَ","translation":"কিতাবকে","audioUrl":"wbw/019_012_003.mp3","charTypeName":"word"},{"id":13681,"position":4,"arabic":"بِقُوَّةٍۢ ۖ","translation":"সহ দৃঢ়তা\"","audioUrl":"wbw/019_012_004.mp3","charTypeName":"word"},{"id":13683,"position":5,"arabic":"وَءَاتَيْنَـٰهُ","translation":"এবং তাকে আমরা দিয়েছিলাম","audioUrl":"wbw/019_012_006.mp3","charTypeName":"word"},{"id":13684,"position":6,"arabic":"ٱلْحُكْمَ","translation":"প্রজ্ঞা","audioUrl":"wbw/019_012_007.mp3","charTypeName":"word"},{"id":13685,"position":7,"arabic":"صَبِيًّۭا","translation":"বাল্য অবস্থায়","audioUrl":"wbw/019_012_008.mp3","charTypeName":"word"},{"id":13686,"position":8,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]},{"number":13,"arabic":"وَحَنَانًۭا مِّن لَّدُنَّا وَزَكَوٰةًۭ ۖ وَكَانَ تَقِيًّۭا","translation":"as well as, by Our grace, [the gift of] compassion and purity; and he was [always] conscious of Us","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2263.mp3","surahId":19,"words":[{"id":14857,"position":1,"arabic":"وَحَنَانًۭا","translation":"এবং হৃদয়ের কোমলতা","audioUrl":"wbw/019_013_001.mp3","charTypeName":"word"},{"id":14858,"position":2,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/019_013_002.mp3","charTypeName":"word"},{"id":14859,"position":3,"arabic":"لَّدُنَّا","translation":"আমাদের নিকট","audioUrl":"wbw/019_013_003.mp3","charTypeName":"word"},{"id":14860,"position":4,"arabic":"وَزَكَوٰةًۭ ۖ","translation":"এবং পবিত্রতা","audioUrl":"wbw/019_013_004.mp3","charTypeName":"word"},{"id":14862,"position":5,"arabic":"وَكَانَ","translation":"এবং সে ছিলো","audioUrl":"wbw/019_013_006.mp3","charTypeName":"word"},{"id":14863,"position":6,"arabic":"تَقِيًّۭا","translation":"মুত্তাকী","audioUrl":"wbw/019_013_007.mp3","charTypeName":"word"},{"id":14864,"position":7,"arabic":"١٣","translation":"(১৩)","audioUrl":null,"charTypeName":"end"}]},{"number":14,"arabic":"وَبَرًّۢا بِوَٰلِدَيْهِ وَلَمْ يَكُن جَبَّارًا عَصِيًّۭا","translation":"and full of piety towards his parents; and never was he haughty or rebellious.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2264.mp3","surahId":19,"words":[{"id":16788,"position":1,"arabic":"وَبَرًّۢا","translation":"এবং অনুগত","audioUrl":"wbw/019_014_001.mp3","charTypeName":"word"},{"id":16789,"position":2,"arabic":"بِوَٰلِدَيْهِ","translation":"কাছে তার মা বাপের","audioUrl":"wbw/019_014_002.mp3","charTypeName":"word"},{"id":16790,"position":3,"arabic":"وَلَمْ","translation":"এবং না","audioUrl":"wbw/019_014_003.mp3","charTypeName":"word"},{"id":16791,"position":4,"arabic":"يَكُن","translation":"ছিলো","audioUrl":"wbw/019_014_004.mp3","charTypeName":"word"},{"id":16792,"position":5,"arabic":"جَبَّارًا","translation":"উদ্ধত","audioUrl":"wbw/019_014_005.mp3","charTypeName":"word"},{"id":16793,"position":6,"arabic":"عَصِيًّۭا","translation":"অবাধ্য","audioUrl":"wbw/019_014_006.mp3","charTypeName":"word"},{"id":16794,"position":7,"arabic":"١٤","translation":"(১৪)","audioUrl":null,"charTypeName":"end"}]},{"number":15,"arabic":"وَسَلَٰمٌ عَلَيْهِ يَوْمَ وُلِدَ وَيَوْمَ يَمُوتُ وَيَوْمَ يُبْعَثُ حَيًّۭا","translation":"Hence, [God's] peace was upon him on the day when he was born, and on the day of his death, and. will be [upon him] on the day when he shall be raised to life [again].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2265.mp3","surahId":19,"words":[{"id":16816,"position":1,"arabic":"وَسَلَـٰمٌ","translation":"এবং সালাম","audioUrl":"wbw/019_015_001.mp3","charTypeName":"word"},{"id":16817,"position":2,"arabic":"عَلَيْهِ","translation":"তার উপর","audioUrl":"wbw/019_015_002.mp3","charTypeName":"word"},{"id":16818,"position":3,"arabic":"يَوْمَ","translation":"যেদিন","audioUrl":"wbw/019_015_003.mp3","charTypeName":"word"},{"id":16819,"position":4,"arabic":"وُلِدَ","translation":"জন্মলাভ করে সে","audioUrl":"wbw/019_015_004.mp3","charTypeName":"word"},{"id":16820,"position":5,"arabic":"وَيَوْمَ","translation":"ও যেদিন","audioUrl":"wbw/019_015_005.mp3","charTypeName":"word"},{"id":16821,"position":6,"arabic":"يَمُوتُ","translation":"সে মরবে","audioUrl":"wbw/019_015_006.mp3","charTypeName":"word"},{"id":16822,"position":7,"arabic":"وَيَوْمَ","translation":"এবং যেদিন","audioUrl":"wbw/019_015_007.mp3","charTypeName":"word"},{"id":16823,"position":8,"arabic":"يُبْعَثُ","translation":"তাকে উঠানো হবে","audioUrl":"wbw/019_015_008.mp3","charTypeName":"word"},{"id":16824,"position":9,"arabic":"حَيًّۭا","translation":"জীবিত অবস্থায়","audioUrl":"wbw/019_015_009.mp3","charTypeName":"word"},{"id":16825,"position":10,"arabic":"١٥","translation":"(১৫)","audioUrl":null,"charTypeName":"end"}]},{"number":16,"arabic":"وَٱذْكُرْ فِى ٱلْكِتَٰبِ مَرْيَمَ إِذِ ٱنتَبَذَتْ مِنْ أَهْلِهَا مَكَانًۭا شَرْقِيًّۭا","translation":"AND CALL to mind, through this divine writ, Mary. Lo! She withdrew from her family to an eastern place","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2266.mp3","surahId":19,"words":[{"id":18173,"position":1,"arabic":"وَٱذْكُرْ","translation":"এবং বর্ণনা করো (যা)","audioUrl":"wbw/019_016_001.mp3","charTypeName":"word"},{"id":18174,"position":2,"arabic":"فِى","translation":"(বলা হয়েছে) মধ্যে","audioUrl":"wbw/019_016_002.mp3","charTypeName":"word"},{"id":18175,"position":3,"arabic":"ٱلْكِتَـٰبِ","translation":"(এই) কিতাবের","audioUrl":"wbw/019_016_003.mp3","charTypeName":"word"},{"id":18176,"position":4,"arabic":"مَرْيَمَ","translation":"মারইয়াম (সম্পর্কে)","audioUrl":"wbw/019_016_004.mp3","charTypeName":"word"},{"id":18177,"position":5,"arabic":"إِذِ","translation":"যখন","audioUrl":"wbw/019_016_005.mp3","charTypeName":"word"},{"id":18178,"position":6,"arabic":"ٱنتَبَذَتْ","translation":"সে পৃথক হয়ে গেলো","audioUrl":"wbw/019_016_006.mp3","charTypeName":"word"},{"id":18179,"position":7,"arabic":"مِنْ","translation":"থেকে","audioUrl":"wbw/019_016_007.mp3","charTypeName":"word"},{"id":18180,"position":8,"arabic":"أَهْلِهَا","translation":"তার পরিবার","audioUrl":"wbw/019_016_008.mp3","charTypeName":"word"},{"id":18181,"position":9,"arabic":"مَكَانًۭا","translation":"স্থানে","audioUrl":"wbw/019_016_009.mp3","charTypeName":"word"},{"id":18182,"position":10,"arabic":"شَرْقِيًّۭا","translation":"(বায়তুল মুকাদ্দাসের) পূর্বদিকের","audioUrl":"wbw/019_016_010.mp3","charTypeName":"word"},{"id":18183,"position":11,"arabic":"١٦","translation":"(১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":17,"arabic":"فَٱتَّخَذَتْ مِن دُونِهِمْ حِجَابًۭا فَأَرْسَلْنَآ إِلَيْهَا رُوحَنَا فَتَمَثَّلَ لَهَا بَشَرًۭا سَوِيًّۭا","translation":"and kept herself in seclusion from them, whereupon We sent unto her Our angel of revelation, who appeared to her in the shape of a well-made human being.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2267.mp3","surahId":19,"words":[{"id":19209,"position":1,"arabic":"فَٱتَّخَذَتْ","translation":"সে অতঃপর গ্রহণ করেছিলো (স্থান)","audioUrl":"wbw/019_017_001.mp3","charTypeName":"word"},{"id":19210,"position":2,"arabic":"مِن","translation":"মধ্য হতে","audioUrl":"wbw/019_017_002.mp3","charTypeName":"word"},{"id":19211,"position":3,"arabic":"دُونِهِمْ","translation":"তাদের ছাড়া","audioUrl":"wbw/019_017_003.mp3","charTypeName":"word"},{"id":19212,"position":4,"arabic":"حِجَابًۭا","translation":"আড়ালে (অর্থাৎ