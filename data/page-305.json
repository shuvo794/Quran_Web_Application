"word"},{"id":12322,"position":5,"arabic":"ٱلْمِحْرَابِ","translation":"মেহরাব","audioUrl":"wbw/019_011_005.mp3","charTypeName":"word"},{"id":12323,"position":6,"arabic":"فَأَوْحَىٰٓ","translation":"সে অতঃপর ইঙ্গিত করলো","audioUrl":"wbw/019_011_006.mp3","charTypeName":"word"},{"id":12324,"position":7,"arabic":"إِلَيْهِمْ","translation":"তাদের দিকে","audioUrl":"wbw/019_011_007.mp3","charTypeName":"word"},{"id":12325,"position":8,"arabic":"أَن","translation":"যে","audioUrl":"wbw/019_011_008.mp3","charTypeName":"word"},{"id":12326,"position":9,"arabic":"سَبِّحُوا۟","translation":"তোমরা পবিত্রতা ঘোষণা করো","audioUrl":"wbw/019_011_009.mp3","charTypeName":"word"},{"id":12327,"position":10,"arabic":"بُكْرَةًۭ","translation":"সকালে","audioUrl":"wbw/019_011_010.mp3","charTypeName":"word"},{"id":12328,"position":11,"arabic":"وَعَشِيًّۭا","translation":"ও সন্ধ্যায়","audioUrl":"wbw/019_011_011.mp3","charTypeName":"word"},{"id":12329,"position":12,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]}]}