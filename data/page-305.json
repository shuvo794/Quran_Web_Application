{"id":305,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ كٓهيعٓصٓ","translation":"Kaf. Ha. Ya. `Ayn. Sad.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2251.mp3","surahId":19,"words":[{"id":162,"position":1,"arabic":"كٓهيعٓصٓ","translation":"কাফ-হা-ইয়া-'আইন-স-দ","audioUrl":"wbw/019_001_001.mp3","charTypeName":"word"},{"id":163,"position":2,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"ذِكْرُ رَحْمَتِ رَبِّكَ عَبْدَهُۥ زَكَرِيَّآ","translation":"AN ACCOUNT of the grace which thy Sustainer bestowed upon His servant Zachariah:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2252.mp3","surahId":19,"words":[{"id":1025,"position":1,"arabic":"ذِكْرُ","translation":"উল্লেখ (করা হচ্ছে)","audioUrl":"wbw/019_002_001.mp3","charTypeName":"word"},{"id":1026,"position":2,"arabic":"رَحْمَتِ","translation":"অনুগ্রহের","audioUrl":"wbw/019_002_002.mp3","charTypeName":"word"},{"id":1027,"position":3,"arabic":"رَبِّكَ","translation":"তোমার রবের","audioUrl":"wbw/019_002_003.mp3","charTypeName":"word"},{"id":1028,"position":4,"arabic":"عَبْدَهُۥ","translation":"তাঁর দাস","audioUrl":"wbw/019_002_004.mp3","charTypeName":"word"},{"id":1029,"position":5,"arabic":"زَكَرِيَّآ","translation":"যাকারিয়্যার (প্রতি)","audioUrl":"wbw/019_002_005.mp3","charTypeName":"word"},{"id":1030,"position":6,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"إِذْ نَادَىٰ رَبَّهُۥ نِدَآءً خَفِيًّۭا","translation":"When he called out to his Sustainer in the secrecy of his heart,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2253.mp3","surahId":19,"words":[{"id":2146,"position":1,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/019_003_001.mp3","charTypeName":"word"},{"id":2147,"position":2,"arabic":"نَادَىٰ","translation":"সে ডেকেছিলো","audioUrl":"wbw/019_003_002.mp3","charTypeName":"word"},{"id":2148,"position":3,"arabic":"رَبَّهُۥ","translation":"তাঁর রবকে","audioUrl":"wbw/019_003_003.mp3","charTypeName":"word"},{"id":2149,"position":4,"arabic":"نِدَآءً","translation":"ডাক","audioUrl":"wbw/019_003_004.mp3","charTypeName":"word"},{"id":2150,"position":5,"arabic":"خَفِيًّۭا","translation":"নিভৃতে","audioUrl":"wbw/019_003_005.mp3","charTypeName":"word"},{"id":2151,"position":6,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"قَالَ رَبِّ إِنِّى وَهَنَ ٱلْعَظْمُ مِنِّى وَٱشْتَعَلَ ٱلرَّأْسُ شَيْبًۭا وَلَمْ أَكُنۢ بِدُعَآئِكَ رَبِّ شَقِيًّۭا","translation":"he prayed: \"O my Sustainer! Feeble have become my bones, and my head glistens with grey hair. But never yet, O my Lord, has my prayer unto Thee remained unanswered.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2254.mp3","surahId":19,"words":[{"id":3449,"position":1,"arabic":"قَالَ","translation":"সে বলেছিলো","audioUrl":"wbw/019_004_001.mp3","charTypeName":"word"},{"id":3450,"position":2,"arabic":"رَبِّ","translation":"\"হে আমার রব","audioUrl":"wbw/019_004_002.mp3","charTypeName":"word"},{"id":3451,"position":3,"arabic":"إِنِّى","translation":"আমি নিশ্চয়ই (এ অবস্থায় যে)","audioUrl":"wbw/019_004_003.mp3","charTypeName":"word"},{"id":3452,"position":4,"arabic":"وَهَنَ","translation":"নরম হয়েছে","audioUrl":"wbw/019_004_004.mp3","charTypeName":"word"},{"id":3453,"position":5,"arabic":"ٱلْعَظْمُ","translation":"হাড় (মজ্জা)","audioUrl":"wbw/019_004_005.mp3","charTypeName":"word"},{"id":3454,"position":6,"arabic":"مِنِّى","translation":"আমার হ'তে","audioUrl":"wbw/019_004_006.mp3","charTypeName":"word"},{"id":3455,"position":7,"arabic":"وَٱشْتَعَلَ","translation":"এবং উজ্জ্বল (শুভ্র হয়েছে)","audioUrl":"wbw/019_004_007.mp3","charTypeName":"word"},{"id":3456,"position":8,"arabic":"ٱلرَّأْسُ","translation":"মাথা (চুল)","audioUrl":"wbw/019_004_008.mp3","charTypeName":"word"},{"id":3457,"position":9,"arabic":"شَيْبًۭا","translation":"বার্ধক্যের (চিহ্নে)","audioUrl":"wbw/019_004_009.mp3","charTypeName":"word"},{"id":3458,"position":10,"arabic":"وَلَمْ","translation":"এবং নি","audioUrl":"wbw/019_004_010.mp3","charTypeName":"word"},{"id":3459,"position":11,"arabic":"أَكُنۢ","translation":"আমি হই","audioUrl":"wbw/019_004_011.mp3","charTypeName":"word"},{"id":3460,"position":12,"arabic":"بِدُعَآئِكَ","translation":"কারণে তোমাকে ডাকার","audioUrl":"wbw/019_004_012.mp3","charTypeName":"word"},{"id":3461,"position":13,"arabic":"رَبِّ","translation":"হে আমার রব","audioUrl":"wbw/019_004_013.mp3","charTypeName":"word"},{"id":3462,"position":14,"arabic":"شَقِيًّۭا","translation":"ব্যর্থকাম","audioUrl":"wbw/019_004_014.mp3","charTypeName":"word"},{"id":3463,"position":15,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"وَإِنِّى خِفْتُ ٱلْمَوَٰلِىَ مِن وَرَآءِى وَكَانَتِ ٱمْرَأَتِى عَاقِرًۭا فَهَبْ لِى مِن لَّدُنكَ وَلِيًّۭا","translation":"\"Now, behold, I am afraid of [what] my kinsfolk [will do] after I am gone, for my wife has always been barren. Bestow, then, upon me, out of Thy grace, the gift of a successor","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2255.mp3","surahId":19,"words":[{"id":4800,"position":1,"arabic":"وَإِنِّى","translation":"এবং আমি নিশ্চয়ই","audioUrl":"wbw/019_005_001.mp3","charTypeName":"word"},{"id":4801,"position":2,"arabic":"خِفْتُ","translation":"ভয় করছি","audioUrl":"wbw/019_005_002.mp3","charTypeName":"word"},{"id":4802,"position":3,"arabic":"ٱلْمَوَٰلِىَ","translation":"আমার স্বগোত্রদের","audioUrl":"wbw/019_005_003.mp3","charTypeName":"word"},{"id":4803,"position":4,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/019_005_004.mp3","charTypeName":"word"},{"id":4804,"position":5,"arabic":"وَرَآءِى","translation":"আমার পর","audioUrl":"wbw/019_005_005.mp3","charTypeName":"word"},{"id":4805,"position":6,"arabic":"وَكَانَتِ","translation":"এবং হয়েছে","audioUrl":"wbw/019_005_006.mp3","charTypeName":"word"},{"id":4806,"position":7,"arabic":"ٱمْرَأَتِى","translation":"আমার স্ত্রী","audioUrl":"wbw/019_005_007.mp3","charTypeName":"word"},{"id":4807,"position":8,"arabic":"عَاقِرًۭا","translation":"বন্ধ্যা","audioUrl":"wbw/019_005_008.mp3","charTypeName":"word"},{"id":4808,"position":9,"arabic":"فَهَبْ","translation":"তবুও দান করো","audioUrl":"wbw/019_005_009.mp3","charTypeName":"word"},{"id":4809,"position":10,"arabic":"لِى","translation":"আমাকে","audioUrl":"wbw/019_005_010.mp3","charTypeName":"word"},{"id":4810,"position":11,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/019_005_011.mp3","charTypeName":"word"},{"id":4811,"position":12,"arabic":"لَّدُنكَ","translation":"তোমার নিকট","audioUrl":"wbw/019_005_012.mp3","charTypeName":"word"},{"id":4812,"position":13,"arabic":"وَلِيًّۭا","translation":"এক উত্তরাধিকারী","audioUrl":"wbw/019_005_013.mp3","charTypeName":"word"},{"id":4813,"position":14,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"يَرِثُنِى وَيَرِثُ مِنْ ءَالِ يَعْقُوبَ ۖ وَٱجْعَلْهُ رَبِّ رَضِيًّۭا","translation":"who will be my heir as well as an heir [to the dignity] of the House of Jacob; and make him, O my Sustainer, well-pleasing to Thee!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2256.mp3","surahId":19,"words":[{"id":6042,"position":1,"arabic":"يَرِثُنِى","translation":"আমার উত্তরাধিকারী হবে সে","audioUrl":"wbw/019_006_001.mp3","charTypeName":"word"},{"id":6043,"position":2,"arabic":"وَيَرِثُ","translation":"ও উত্তরাধিকারী হবে","audioUrl":"wbw/019_006_002.mp3","charTypeName":"word"},{"id":6044,"position":3,"arabic":"مِنْ","translation":"ব্যাপারে","audioUrl":"wbw/019_006_003.mp3","charTypeName":"word"},{"id":6045,"position":4,"arabic":"ءَالِ","translation":"বংশের","audioUrl":"wbw/019_006_004.mp3","charTypeName":"word"},{"id":6046,"position":5,"arabic":"يَعْقُوبَ ۖ","translation":"ইয়াকুবের","audioUrl":"wbw/019_006_005.mp3","charTypeName":"word"},{"id":6048,"position":6,"arabic":"وَٱجْعَلْهُ","translation":"এবং তাকে করো","audioUrl":"wbw/019_006_007.mp3","charTypeName":"word"},{"id":6049,"position":7,"arabic":"رَبِّ","translation":"হে আমার রব","audioUrl":"wbw/019_006_008.mp3","charTypeName":"word"},{"id":6050,"position":8,"arabic":"رَضِيًّۭا","translation":"সন্তোষজনক\"","audioUrl":"wbw/019_006_009.mp3","charTypeName":"word"},{"id":6051,"position":9,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"يَٰزَكَرِيَّآ إِنَّا نُبَشِّرُكَ بِغُلَٰمٍ ٱسْمُهُۥ يَحْيَىٰ لَمْ نَجْعَل لَّهُۥ مِن قَبْلُ سَمِيًّۭا","translation":"[Thereupon the angels called out unto him: \"O Zachariah! We bring thee the glad tiding of [the birth of] a son whose name shall be John. [And God says,] `Never have We given this name to anyone before him.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2257.mp3","surahId":19,"words":[{"id":7365,"position":1,"arabic":"يَـٰزَكَرِيَّآ","translation":"\"(বলা হলো) হে যাকারিয়্যা","audioUrl":"wbw/019_007_001.mp3","charTypeName":"word"},{"id":7366,"position":2,"arabic":"إِنَّا","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/019_007_002.mp3","charTypeName":"word"},{"id":7367,"position":3,"arabic":"نُبَشِّرُكَ","translation":"তোমাকে সুসংবাদ দিচ্ছি","audioUrl":"wbw/019_007_003.mp3","charTypeName":"word"},{"id":7368,"position":4,"arabic":"بِغُلَـٰمٍ","translation":"সম্পর্কে এক পুত্রের","audioUrl":"wbw/019_007_004.mp3","charTypeName":"word"},{"id":7369,"position":5,"arabic":"ٱسْمُهُۥ","translation":"তার নাম (হবে)","audioUrl":"wbw/019_007_005.mp3","charTypeName":"word"},{"id":7370,"position":6,"arabic":"يَحْيَىٰ","translation":"ইয়াহইয়া","audioUrl":"wbw/019_007_006.mp3","charTypeName":"word"},{"id":7371,"position":7,"arabic":"لَمْ","translation":"নি","audioUrl":"wbw/019_007_007.mp3","charTypeName":"word"},{"id":7372,"position":8,"arabic":"نَجْعَل","translation":"আমরা করি","audioUrl":"wbw/019_007_008.mp3","charTypeName":"word"},{"id":7373,"position":9,"arabic":"لَّهُۥ","translation":"তার জন্য","audioUrl":"wbw/019_007_009.mp3","charTypeName":"word"},{"id":7374,"p