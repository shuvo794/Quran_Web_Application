":"word"},{"id":13013,"position":5,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]},{"number":12,"arabic":"وَمَا يُكَذِّبُ بِهِۦٓ إِلَّا كُلُّ مُعْتَدٍ أَثِيمٍ","translation":"for, none gives the lie to it but such as are wont to transgress against all that is [and are] immersed in sin:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5860.mp3","surahId":83,"words":[{"id":14271,"position":1,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/083_012_001.mp3","charTypeName":"word"},{"id":14272,"position":2,"arabic":"يُكَذِّبُ","translation":"মিথ্যারোপ করে","audioUrl":"wbw/083_012_002.mp3","charTypeName":"word"},{"id":14273,"position":3,"arabic":"بِهِۦٓ","translation":"এতে","audioUrl":"wbw/083_012_003.mp3","charTypeName":"word"},{"id":14274,"position":4,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/083_012_004.mp3","charTypeName":"word"},{"id":14275,"position":5,"arabic":"كُلُّ","translation":"প্রত্যেক","audioUrl":"wbw/083_012_005.mp3","charTypeName":"word"},{"id":14276,"position":6,"arabic":"مُعْتَدٍ","translation":"সীমালঙ্ঘনকারী","audioUrl":"wbw/083_012_006.mp3","charTypeName":"word"},{"id":14277,"position":7,"arabic":"أَثِيمٍ","translation":"পাপী","audioUrl":"wbw/083_012_007.mp3","charTypeName":"word"},{"id":14278,"position":8,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]},{"number":13,"arabic":"إِذَا تُتْلَىٰ عَلَيْهِ ءَايَٰتُنَا قَالَ أَسَٰطِيرُ ٱلْأَوَّلِينَ","translation":"[and so,] whenever Our messages are conveyed to them, they but say, \"Fables of ancient times!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5861.mp3","surahId":83,"words":[{"id":15383,"position":1,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/083_013_001.mp3","charTypeName":"word"},{"id":15384,"position":2,"arabic":"تُتْلَىٰ","translation":"পাঠ করা হয়","audioUrl":"wbw/083_013_002.mp3","charTypeName":"word"},{"id":15385,"position":3,"arabic":"عَلَيْهِ","translation":"তার উপর","au