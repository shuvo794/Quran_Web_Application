"word"},{"id":35606,"position":4,"arabic":"حَـٰفِظِينَ","translation":"তত্ত্বাবধায়ক রূপে","audioUrl":"wbw/083_033_004.mp3","charTypeName":"word"},{"id":35607,"position":5,"arabic":"٣٣","translation":"(৩৩)","audioUrl":null,"charTypeName":"end"}]},{"number":34,"arabic":"فَٱلْيَوْمَ ٱلَّذِينَ ءَامَنُوا۟ مِنَ ٱلْكُفَّارِ يَضْحَكُونَ","translation":"But on the Day [of Judgment], they who had attained to faith will [be able to] laugh at the [erstwhile] deniers of the truth:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5882.mp3","surahId":83,"words":[{"id":36431,"position":1,"arabic":"فَٱلْيَوْمَ","translation":"অতএব আজ","audioUrl":"wbw/083_034_001.mp3","charTypeName":"word"},{"id":36432,"position":2,"arabic":"ٱلَّذِينَ","translation":"(সেদিন) যারা","audioUrl":"wbw/083_034_002.mp3","charTypeName":"word"},{"id":36433,"position":3,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছিলো","audioUrl":"wbw/083_034_003.mp3","charTypeName":"word"},{"id":36434,"position":4,"arabic":"مِنَ","translation":"সাথে","audioUrl":"wbw/083_034_004.mp3","charTypeName":"word"},{"id":36435,"position":5,"arabic":"ٱلْكُفَّارِ","translation":"কাফেরদের","audioUrl":"wbw/083_034_005.mp3","charTypeName":"word"},{"id":36436,"position":6,"arabic":"يَضْحَكُونَ","translation":"উপহাস করবে","audioUrl":"wbw/083_034_006.mp3","charTypeName":"word"},{"id":36437,"position":7,"arabic":"٣٤","translation":"(৩৪)","audioUrl":null,"charTypeName":"end"}]}]}