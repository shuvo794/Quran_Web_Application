,"audioUrl":"wbw/083_029_008.mp3","charTypeName":"word"},{"id":32079,"position":9,"arabic":"٢٩","translation":"(২৯)","audioUrl":null,"charTypeName":"end"}]},{"number":30,"arabic":"وَإِذَا مَرُّوا۟ بِهِمْ يَتَغَامَزُونَ","translation":"and whenever they pass by them, they wink at one another [derisively];","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5878.mp3","surahId":83,"words":[{"id":32746,"position":1,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/083_030_001.mp3","charTypeName":"word"},{"id":32747,"position":2,"arabic":"مَرُّوا۟","translation":"অতিক্রম করত","audioUrl":"wbw/083_030_002.mp3","charTypeName":"word"},{"id":32748,"position":3,"arabic":"بِهِمْ","translation":"তাদের কাছ দিয়ে","audioUrl":"wbw/083_030_003.mp3","charTypeName":"word"},{"id":32749,"position":4,"arabic":"يَتَغَامَزُونَ","translation":"তারা কটাক্ষ করতো","audioUrl":"wbw/083_030_004.mp3","charTypeName":"word"},{"id":32750,"position":5,"arabic":"٣٠","translation":"(৩০)","audioUrl":null,"charTypeName":"end"}]},{"number":31,"arabic":"وَإِذَا ٱنقَلَبُوٓا۟ إِلَىٰٓ أَهْلِهِمُ ٱنقَلَبُوا۟ فَكِهِينَ","translation":"and whenever they return to people of their own kind, they return full of jests;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5879.mp3","surahId":83,"words":[{"id":33800,"position":1,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/083_031_001.mp3","charTypeName":"word"},{"id":33801,"position":2,"arabic":"ٱنقَلَبُوٓا۟","translation":"ফিরে যেতো","audioUrl":"wbw/083_031_002.mp3","charTypeName":"word"},{"id":33802,"position":3,"arabic":"إِلَىٰٓ","translation":"কাছে","audioUrl":"wbw/083_031_003.mp3","charTypeName":"word"},{"id":33803,"position":4,"arabic":"أَهْلِهِمُ","translation":"তাদের পরিজনের","audioUrl":"wbw/083_031_004.mp3","charTypeName":"word"},{"id":33804,"position":5,"arabic":"ٱنقَلَبُوا۟","translation":"তারা ফিরে যেতো","audioUrl":"wbw/083_031_005.mp3","charTypeName":"word"},{"id":33805,"position":6,"arabic":"فَكِهِينَ","tra