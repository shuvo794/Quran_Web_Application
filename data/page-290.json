":"مِنْ","translation":"থেকে","audioUrl":"wbw/017_085_007.mp3","charTypeName":"word"},{"id":66019,"position":7,"arabic":"أَمْرِ","translation":"নির্দেশ","audioUrl":"wbw/017_085_008.mp3","charTypeName":"word"},{"id":66020,"position":8,"arabic":"رَبِّى","translation":"আমার রবের","audioUrl":"wbw/017_085_009.mp3","charTypeName":"word"},{"id":66021,"position":9,"arabic":"وَمَآ","translation":"এবং না","audioUrl":"wbw/017_085_010.mp3","charTypeName":"word"},{"id":66022,"position":10,"arabic":"أُوتِيتُم","translation":"তোমাদের দেয়া হয়েছে","audioUrl":"wbw/017_085_011.mp3","charTypeName":"word"},{"id":66023,"position":11,"arabic":"مِّنَ","translation":"থেকে","audioUrl":"wbw/017_085_012.mp3","charTypeName":"word"},{"id":66024,"position":12,"arabic":"ٱلْعِلْمِ","translation":"জ্ঞান","audioUrl":"wbw/017_085_013.mp3","charTypeName":"word"},{"id":66025,"position":13,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/017_085_014.mp3","charTypeName":"word"},{"id":66026,"position":14,"arabic":"قَلِيلًۭا","translation":"সামান্য\"","audioUrl":"wbw/017_085_015.mp3","charTypeName":"word"},{"id":66027,"position":15,"arabic":"٨٥","translation":"(৮৫)","audioUrl":null,"charTypeName":"end"}]},{"number":86,"arabic":"وَلَئِن شِئْنَا لَنَذْهَبَنَّ بِٱلَّذِىٓ أَوْحَيْنَآ إِلَيْكَ ثُمَّ لَا تَجِدُ لَكَ بِهِۦ عَلَيْنَا وَكِيلًا","translation":"And if We so willed, We could indeed take away whatever We have revealed unto thee, and in that [state of need] thou wouldst find none to plead in thy behalf before Us.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2115.mp3","surahId":17,"words":[{"id":66551,"position":1,"arabic":"وَلَئِن","translation":"এবং অবশ্যই যদি","audioUrl":"wbw/017_086_001.mp3","charTypeName":"word"},{"id":66552,"position":2,"arabic":"شِئْنَا","translation":"আমরা চাইতাম","audioUrl":"wbw/017_086_002.mp3","charTypeName":"word"},{"id":66553,"position":3,"arabic":"لَنَذْهَبَنَّ","translation":"অবশ্যই আমরা যেতাম","audioUrl":"wbw/017_086_003.mp3","charTypeName":"word"},{"id":66554,"position":4,"arabic":"بِٱلَّذِىٓ","translation":"নিয়ে ঐ জিনিস যা","audioUrl":"wbw/017_086_004.mp3","charTypeName":"word"},{"id":66555,"position":5,"arabic":"أَوْحَيْنَآ","translation":"আমরা ওহী করেছি","audioUrl":"wbw/017_086_005.mp3","charTypeName":"word"},{"id":66556,"position":6,"arabic":"إِلَيْكَ","translation":"তোমার প্রতি","audioUrl":"wbw/017_086_006.mp3","charTypeName":"word"},{"id":66557,"position":7,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/017_086_007.mp3","charTypeName":"word"},{"id":66558,"position":8,"arabic":"لَا","translation":"না","audioUrl":"wbw/017_086_008.mp3","charTypeName":"word"},{"id":66559,"position":9,"arabic":"تَجِدُ","translation":"পেতে","audioUrl":"wbw/017_086_009.mp3","charTypeName":"word"},{"id":66560,"position":10,"arabic":"لَكَ","translation":"তোমার জন্যে","audioUrl":"wbw/017_086_010.mp3","charTypeName":"word"},{"id":66561,"position":11,"arabic":"بِهِۦ","translation":"তা সম্পর্কে","audioUrl":"wbw/017_086_011.mp3","charTypeName":"word"},{"id":66562,"position":12,"arabic":"عَلَيْنَا","translation":"বিরুদ্ধে আমাদের","audioUrl":"wbw/017_086_012.mp3","charTypeName":"word"},{"id":66563,"position":13,"arabic":"وَكِيلًا","translation":"কোনো কর্মবিধায়ক","audioUrl":"wbw/017_086_013.mp3","charTypeName":"word"},{"id":66564,"position":14,"arabic":"٨٦","translation":"(৮৬)","audioUrl":null,"charTypeName":"end"}]}]}