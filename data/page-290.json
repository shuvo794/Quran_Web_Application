{"id":290,"ayahs":[{"number":76,"arabic":"وَإِن كَادُوا۟ لَيَسْتَفِزُّونَكَ مِنَ ٱلْأَرْضِ لِيُخْرِجُوكَ مِنْهَا ۖ وَإِذًۭا لَّا يَلْبَثُونَ خِلَٰفَكَ إِلَّا قَلِيلًۭا","translation":"And [since they see that they cannot persuade thee,] they endeavour to estrange thee from the land [of thy birth] with a view to driving thee away from, it-but, then, after thou wilt have left, they themselves will not remain [in it] for more than a little while:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2105.mp3","surahId":17,"words":[{"id":62324,"position":1,"arabic":"وَإِن","translation":"এবং যদিও","audioUrl":"wbw/017_076_001.mp3","charTypeName":"word"},{"id":62325,"position":2,"arabic":"كَادُوا۟","translation":"তারা প্রচেষ্টায় ক্রুটি রাখেনি","audioUrl":"wbw/017_076_002.mp3","charTypeName":"word"},{"id":62326,"position":3,"arabic":"لَيَسْتَفِزُّونَكَ","translation":"অবশ্যই তোমাকে উচ্ছেদ করবে","audioUrl":"wbw/017_076_003.mp3","charTypeName":"word"},{"id":62327,"position":4,"arabic":"مِنَ","translation":"হ'তে","audioUrl":"wbw/017_076_004.mp3","charTypeName":"word"},{"id":62328,"position":5,"arabic":"ٱلْأَرْضِ","translation":"এ দেশ","audioUrl":"wbw/017_076_005.mp3","charTypeName":"word"},{"id":62329,"position":6,"arabic":"لِيُخْرِجُوكَ","translation":"জন্যে তোমাকে বের করার","audioUrl":"wbw/017_076_006.mp3","charTypeName":"word"},{"id":62330,"position":7,"arabic":"مِنْهَا ۖ","translation":"থেকে তা","audioUrl":"wbw/017_076_007.mp3","charTypeName":"word"},{"id":62332,"position":8,"arabic":"وَإِذًۭا","translation":"কিন্তু তাহ'লে","audioUrl":"wbw/017_076_009.mp3","charTypeName":"word"},{"id":62333,"position":9,"arabic":"لَّا","translation":"না","audioUrl":"wbw/017_076_010.mp3","charTypeName":"word"},{"id":62334,"position":10,"arabic":"يَلْبَثُونَ","translation":"তারা টিকতো","audioUrl":"wbw/017_076_011.mp3","charTypeName":"word"},{"id":62335,"position":11,"arabic":"خِلَـٰفَكَ","translation":"তোমার পরে","audioUrl":"wbw/017_076_012.mp3","charTypeName":"word"},{"id":62336,"position":12,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/017_076_013.mp3","charTypeName":"word"},{"id":62337,"position":13,"arabic":"قَلِيلًۭا","translation":"স্বল্পকাল","audioUrl":"wbw/017_076_014.mp3","charTypeName":"word"},{"id":62338,"position":14,"arabic":"٧٦","translation":"(৭৬)","audioUrl":null,"charTypeName":"end"}]},{"number":77,"arabic":"سُنَّةَ مَن قَدْ أَرْسَلْنَا قَبْلَكَ مِن رُّسُلِنَا ۖ وَلَا تَجِدُ لِسُنَّتِنَا تَحْوِيلًا","translation":"[such has been Our] way with all of Our apostles whom We sent before thy time; and no change wilt thou find in Our ways.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2106.mp3","surahId":17,"words":[{"id":62761,"position":1,"arabic":"سُنَّةَ","translation":"স্হায়ী নীতি","audioUrl":"wbw/017_077_001.mp3","charTypeName":"word"},{"id":62762,"position":2,"arabic":"مَن","translation":"(তাদের ক্ষেত্রে) যাদের","audioUrl":"wbw/017_077_002.mp3","charTypeName":"word"},{"id":62763,"position":3,"arabic":"قَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/017_077_003.mp3","charTypeName":"word"},{"id":62764,"position":4,"arabic":"أَرْسَلْنَا","translation":"আমরা পাঠিয়েছি","audioUrl":"wbw/017_077_004.mp3","charTypeName":"word"},{"id":62765,"position":5,"arabic":"قَبْلَكَ","translation":"তোমার পূর্বে","audioUrl":"wbw/017_077_005.mp3","charTypeName":"word"},{"id":62766,"position":6,"arabic":"مِن","translation":"মধ্য থেকে","audioUrl":"wbw/017_077_006.mp3","charTypeName":"word"},{"id":62767,"position":7,"arabic":"رُّسُلِنَا ۖ","translation":"আমাদের রাসূলদের","audioUrl":"wbw/017_077_007.mp3","charTypeName":"word"},{"id":62769,"position":8,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/017_077_009.mp3","charTypeName":"word"},{"id":62770,"position":9,"arabic":"تَجِدُ","translation":"তুমি পাবে","audioUrl":"wbw/017_077_010.mp3","charTypeName":"word"},{"id":62771,"position":10,"arabic":"لِسُنَّتِنَا","translation":"আমাদের বেলায় নীতির","audioUrl":"wbw/017_077_011.mp3","charTypeName":"word"},{"id":62772,"position":11,"arabic":"تَحْوِيلًا","translation":"কোনো পরিবর্তন","audioUrl":"wbw/017_077_012.mp3","charTypeName":"word"},{"id":62773,"position":12,"arabic":"٧٧","translation":"(৭৭)","audioUrl":null,"charTypeName":"end"}]},{"number":78,"arabic":"أَقِمِ ٱلصَّلَوٰةَ لِدُلُوكِ ٱلشَّمْسِ إِلَىٰ غَسَقِ ٱلَّيْلِ وَقُرْءَانَ ٱلْفَجْرِ ۖ إِنَّ قُرْءَانَ ٱلْفَجْرِ كَانَ مَشْهُودًۭا","translation":"BE CONSTANT in [thy] prayer from the time when the sun has passed its zenith till the darkness of night, and [be ever mindful of its] recitation at dawn: for, behold, the recitation [of prayer] at dawn is indeed witnessed [by all that is holy].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2107.mp3","surahId":17,"words":[{"id":63627,"position":1,"arabic":"أَقِمِ","translation":"প্রতিষ্ঠা করো","audioUrl":"wbw/017_078_001.mp3","charTypeName":"word"},{"id":63628,"position":2,"arabic":"ٱلصَّلَوٰةَ","translation":"সালাত","audioUrl":"wbw/017_078_002.mp3","charTypeName":"word"},{"id":63629,"position":3,"arabic":"لِدُلُوكِ","translation":"থেকে ঢলে পড়ার সময়","audioUrl":"wbw/017_078_003.mp3","charTypeName":"word"},{"id":63630,"position":4,"arabic":"ٱلشَّمْسِ","translation":"সূর্য","audioUrl":"wbw/017_078_004.mp3","charTypeName":"word"},{"id":63631,"position":5,"arabic":"إِلَىٰ","translation":"পর্যন্ত","audioUrl":"wbw/017_078_005.mp3","charTypeName":"word"},{"id":63632,"position":6,"arabic":"غَسَقِ","translation":"ঘন অন্ধকার","audioUrl":"wbw/017_078_006.mp3","charTypeName":"word"},{"id":63633,"position":7,"arabic":"ٱلَّيْلِ","translation":"রাতের","audioUrl":"wbw/017_078_007.mp3","charTypeName":"word"},{"id":63634,"position":8,"arabic":"وَقُرْءَانَ","translation":"এবং (সালাত) কুরআন পাঠ","audioUrl":"wbw/017_078_008.mp3","charTypeName":"word"},{"id":63635,"position":9,"arabic":"ٱلْفَجْرِ ۖ","translation":"ফজরের","audioUrl":"wbw/017_078_009.mp3","charTypeName":"word"},{"id":63637,"position":10,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/017_078_011.mp3","charTypeName":"word"},{"id":63638,"position":11,"arabic":"قُرْءَانَ","translation":"(সালাত) কুরআন পাঠ","audioUrl":"wbw/017_078_012.mp3","charTypeName":"word"},{"id":63639,"position":12,"arabic":"ٱلْفَجْرِ","translation":"ফজরের","audioUrl":"wbw/017_078_013.mp3","charTypeName":"word"},{"id":63640,"position":13,"arabic":"كَانَ","translation":"হলো","audioUrl":"wbw/017_078_014.mp3","charTypeName":"word"},{"id":63641,"position":14,"arabic":"مَشْهُودًۭا","translation":"(এমন যাতে) উপস্হিতির সময়","audioUrl":"wbw/017_078_015.mp3","charTypeName":"word"},{"id":63642,"position":15,"arabic":"٧٨","translation":"(৭৮)","audioUrl":null,"charTypeName":"end"}]},{"number":79,"arabic":"وَمِنَ ٱلَّيْلِ فَتَهَجَّدْ بِهِۦ نَافِلَةًۭ لَّكَ عَسَىٰٓ أَن يَبْعَثَكَ رَبُّكَ مَقَامًۭا مَّحْمُودًۭا","translation":"And rise from thy sleep and pray during part of the night [as well], as a free offering from thee, and thy Sustainer may well raise thee to a glorious station [in the life to come].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2108.mp3","surahId":17,"words":[{"id":63750,"position":1,"arabic":"وَمِنَ","translation":"এবং কিছু অংশে","audioUrl":"wbw/017_079_001.mp3","charTypeName":"word"},{"id":63751,"position":2,"arabic":"ٱلَّيْلِ","translation":"রাতের","audioUrl":"wbw/017_079_002.mp3","charTypeName":"word"},{"id":63752,"position":3,"arabic":"فَتَهَجَّدْ","translation":"অতঃপর তাহাজ্জুদ পড়","audioUrl":"wbw/017_079_003.mp3","charTypeName":"word"},{"id":63753,"position":4,"arabic":"بِهِۦ","translation":"সহ তা","audioUrl":"wbw/017_079_004.mp3","charTypeName":"word"},{"id":63754,"position":5,"arabic":"نَافِلَةًۭ","translation":"(নফল) অতিরিক্ত","audioUrl":"wbw/017_079_005.mp3","charTypeName":"word"},{"id":63755,"position":6,"arabic":"لَّكَ","translation":"তোমার জন্যে","audioUrl":"wbw/017_079_006.mp3","charTypeName":"word"},{"id":63756,"position":7,"arabic":"عَسَىٰٓ","translation":"আশা করা যায়","audioUrl":"wbw/017_079_007.mp3","charTypeName":"word"},{"id":63757,"position":8,"arabic":"أَن","translation":"যে","audioUrl":"wbw/017_079_008.mp3","charTypeName":"word"},{"id":63758,"position":9,"arabic":"يَبْعَثَكَ","translation":"তোমাকে পৌঁছাবেন","audioUrl":"wbw/017_079_009.mp3","charTypeName":"word"},{"id":63759,"position":10,"arabic":"رَبُّكَ","translation":"রব তোমার","audioUrl":"wbw/017_079_010.mp3","charTypeName":"word"},{"id":63760,"position":11,"arabic":"مَقَامًۭا","translation":"স্থানে","audioUrl":"wbw/017_079_011.mp3","charTypeName":"word"},{"id":63761,"position":12,"arabic":"مَّحْمُودًۭا","translation":"প্রশংসিত","audioUrl":"wbw/017_079_012.mp3","charTypeName":"word"},{"id":63762,"position":13,"arabic":"٧٩","translation":"(৭৯)","audioUrl":null,"charTypeName":"end"}]},{"number":80,"arabic":"وَقُل رَّبِّ أَدْخِلْنِى مُدْخَلَ صِدْقٍۢ وَأَخْرِجْنِى مُخْرَجَ صِدْقٍۢ وَٱجْعَل لِّى مِن لَّدُنكَ سُلْطَٰنًۭا نَّصِيرًۭا","translation":"And say [in thy prayer]: \"O my Sustainer! Cause me to enter [upon whatever I may do] in a manner. true and sincere, and cause me to leave [it] in a manner true and sincere, and grant me, out of Thy grace, sustaining strength!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2109.mp3","surahId":17,"words":[{"id":64333,"position":1,"arabic":"وَقُل","translation":"এবং বলো","audioUrl":"wbw/017_080_001.mp3","charTypeName":"word"},{"id":64334,"position":2,"arabic":"رَّبِّ","translation":"\"হে আমার রব","audioUrl":"wbw/017_080_002.mp3","charTypeName":"word"},{"id":64335,"position":3,"arabic":"أَدْخِلْنِى","translation":"আমাকে প্রবেশ করাও","audioUrl":"wbw/017_080_003.mp3","charTypeName":"word"},{"id":64336,"position":4,"arabic":"مُدْخَلَ","translation":"প্রবেশ করা","audioUrl":"wbw/017_080_004.mp3","charTypeName":"word"},{"id":64337,"position":5,"arabic":"صِدْقٍۢ","translation":"সত্যের","audioUrl":"wbw/017_080_005.mp3","charTypeName":"word"},{"id":64338,"position":6,"arabic":"وَأَخْرِجْنِى","translation":"এবং আমাকে বের করো","audioUrl":"wbw/017_080_006.mp3","charTypeName":"word"},{"id":64339,"position":7,"arabic":"مُخْرَجَ","translation":"বের করা","audioUrl":"wbw/017_080_007.mp3","charTypeName":"word"},{"id":64340,"position":8,"arabic":"صِدْقٍۢ","translation":"সত্যের","audioUrl":"wbw/017_080_008.mp3","charTypeName":"word"},{"id":64341,"position":9,"arabic":"وَٱجْعَل","translation":"এবং বানাও","audioUrl":"wbw/017_080_009.mp3","charTypeName":"word"},{"id":64342,"position":10,"arabic":"لِّى","translation":"আমার জন্যে","audioUrl":"wbw/017_080_010.mp3","charTypeName":"word"},{"id":64343,"position":11,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/017_080_011.mp3","charTypeName":"word"},{"id":64344,"position":12,"arabic":"لَّدُنكَ","translation":"তোমার নিকট","audioUrl":"wbw/017_080_012.mp3","charTypeName":"word"},{"id":64345,"position":13,"arabic":"سُلْطَـٰنًۭا","translation":"কোনো শক্তিকে","audioUrl":"wbw/017_080_013.mp3","charTypeName":"word"},{"id":64346,"position":14,"arabic":"نَّصِيرًۭا","translation":"বড় সাহায্যকারী\"","audioUrl":"wbw/017_080_014.mp3","charTypeName":"word"},{"id":64347,"position":15,"arabic":"٨٠","translation":"(৮০)","audioUrl":null,"charTypeName":"end"}]},{"number":81,"arabic":"وَقُلْ جَآءَ ٱلْحَقُّ وَزَهَقَ ٱلْبَٰطِلُ ۚ إِنَّ ٱلْبَٰطِلَ كَانَ زَهُوقًۭا","translation":"And say: \"The truth has now come [to light], and falsehood has withered away: for, behold, all falsehood is bound to wither away!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2110.mp3","surahId":17,"words":[{"id":64732,"position":1,"arabic":"وَقُلْ","translation":"এবং বলো","audioUrl":"wbw/017_081_001.mp3","charTypeName":"word"},{"id":64733,"position":2,"arabic":"جَآءَ","translation":"\"এসেছে","audioUrl":"wbw/017_081_002.mp3","charTypeName":"word"},{"id":64734,"position":3,"arabic":"ٱلْحَقُّ","translation":"সত্য","audioUrl":"wbw/017_081_003.mp3","charTypeName":"word"},{"id":64735,"position":4,"arabic":"وَزَهَقَ","translation":"এবং বিলুপ্ত হয়েছে","audioUrl":"wbw/017_081_004.mp3","charTypeName":"word"},{"id":64736,"position":5,"arabic":"ٱلْبَـٰطِلُ ۚ","translation":"মিথ্যা","audioUrl":"wbw/017_081_005.mp3","charTypeName":"word"},{"id":64738,"position":6,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/017_081_007.mp3","charTypeName":"word"},{"id":64739,"position":7,"arabic":"ٱلْبَـٰطِلَ","translation":"মিথ্যা","audioUrl":"wbw/017_081_008.mp3","charTypeName":"word"},{"id":64740,"position":8,"arabic":"كَانَ","translation":"হলো","audioUrl":"wbw/017_081_009.mp3","charTypeName":"word"},{"id":64741,"position":9,"arabic":"زَهُوقًۭا","translation":"বিলুপ্ত হওয়ার\"","audioUrl":"wbw/017_081_010.mp3","charTypeName":"word"},{"id":64742,"position":10,"arabic":"٨١","translation":"(৮১)","audioUrl":null,"charTypeName":"end"}]},{"number":82,"arabic":"وَنُنَزِّلُ مِنَ ٱلْقُرْءَانِ مَا هُوَ شِفَآءٌۭ وَرَحْمَةٌۭ لِّلْمُؤْمِنِينَ ۙ وَلَا يَزِيدُ ٱلظَّٰلِمِينَ إِلَّا خَسَارًۭا","translation":"THUS, step by step, We bestow from on high through this Qur'an all that gives health [to the spirit] and is a grace unto those who believe [in Us], the while it only adds to the ruin of evildoers:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2111.mp3","surahId":17,"words":[{"id":64926,"position":1,"arabic":"وَنُنَزِّلُ","translation":"এবং আমরা অবতীর্ণ করেছি","audioUrl":"wbw/017_082_001.mp3","charTypeName":"word"},{"id":64927,"position":2,"arabic":"مِنَ","translation":"মধ্যে","audioUrl":"wbw/017_082_002.mp3","charTypeName":"word"},{"id":64928,"position":3,"arabic":"ٱلْقُرْءَانِ","translation":"কুরআনের","audioUrl":"wbw/017_082_003.mp3","charTypeName":"word"},{"id":64929,"position":4,"arabic":"مَا","translation":"যা (এমন যে)","audioUrl":"wbw/017_082_004.mp3","charTypeName":"word"},{"id":64930,"position":5,"arabic":"هُوَ","translation":"তা","audioUrl":"wbw/017_082_005.mp3","charTypeName":"word"},{"id":64931,"position":6,"arabic":"شِفَآءٌۭ","translation":"আরোগ্য","audioUrl":"wbw/017_082_006.mp3","charTypeName":"word"},{"id":64932,"position":7,"arabic":"وَرَحْمَةٌۭ","translation":"ও অনুগ্রহ","audioUrl":"wbw/017_082_007.mp3","charTypeName":"word"},{"id":64933,"position":8,"arabic":"لِّلْمُؤْمِنِينَ ۙ","translation":"জন্যে মু'মিনদের","audioUrl":"wbw/017_082_008.mp3","charTypeName":"word"},{"id":64935,"position":9,"arabic":"وَلَا","translation":"কিন্তু না","audioUrl":"wbw/017_082_010.mp3","charTypeName":"word"},{"id":64936,"position":10,"arabic":"يَزِيدُ","translation":"বৃদ্ধি করে","audioUrl":"wbw/017_082_011.mp3","charTypeName":"word"},{"id":64937,"position":11,"arabic":"ٱلظَّـٰلِمِينَ","translation":"সীমালঙ্ঘনকারীদের","audioUrl":"wbw/017_082_012.mp3","charTypeName":"word"},{"id":64938,"position":12,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/017_082_013.mp3","charTypeName":"word"},{"id":64939,"position":13,"arabic":"خَسَارًۭا","translation":"ক্ষতি","audioUrl":"wbw/017_082_014.mp3","charTypeName":"word"},{"id":64940,"position":14,"arabic":"٨٢","translation":"(৮২)","audioUrl":null,"charTypeName":"end"}]},{"number":83,"arabic":"وَإِذَآ أَنْعَمْنَا عَلَى ٱلْإِنسَٰنِ أَعْرَضَ وَنَـَٔا بِجَانِبِهِۦ ۖ وَإِذَا مَسَّهُ ٱلشَّرُّ كَانَ يَـُٔوسًۭا","translation":"for [it often happens that] when We bestow Our blessings upon man, he turns away and arrogantly keeps aloof [from any thought of Us]; and when evil fortune touches him, he abandons all hope.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2112.mp3","surahId":17,"words":[{"id":65250,"position":1,"arabic":"وَإِذَآ","translation":"এবং যখন","audioUrl":"wbw/017_083_001.mp3","charTypeName":"word"},{"id":65251,"position":2,"arabic":"أَنْعَمْنَا","translation":"আমরা অনুগ্রহ করি","audioUrl":"wbw/017_083_002.mp3","charTypeName":"word"},{"id":65252,"position":3,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/017_083_003.mp3","charTypeName":"word"},{"id":65253,"position":4,"arabic":"ٱلْإِنسَـٰنِ","translation":"মানুষের","audioUrl":"wbw/017_083_004.mp3","charTypeName":"word"},{"id":65254,"position":5,"arabic":"أَعْرَضَ","translation":"সে মুখ ফিরায়","audioUrl":"wbw/017_083_005.mp3","charTypeName":"word"},{"id":65255,"position":6,"arab