"arabic":"يَـٰمَرْيَمُ","translation":"\"হে মারইয়াম","audioUrl":"wbw/019_027_007.mp3","charTypeName":"word"},{"id":30013,"position":7,"arabic":"لَقَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/019_027_008.mp3","charTypeName":"word"},{"id":30014,"position":8,"arabic":"جِئْتِ","translation":"এনেছো","audioUrl":"wbw/019_027_009.mp3","charTypeName":"word"},{"id":30015,"position":9,"arabic":"شَيْـًۭٔا","translation":"কিছু","audioUrl":"wbw/019_027_010.mp3","charTypeName":"word"},{"id":30016,"position":10,"arabic":"فَرِيًّۭا","translation":"জঘন্য","audioUrl":"wbw/019_027_011.mp3","charTypeName":"word"},{"id":30017,"position":11,"arabic":"٢٧","translation":"(২৭)","audioUrl":null,"charTypeName":"end"}]},{"number":28,"arabic":"يَٰٓأُخْتَ هَٰرُونَ مَا كَانَ أَبُوكِ ٱمْرَأَ سَوْءٍۢ وَمَا كَانَتْ أُمُّكِ بَغِيًّۭا","translation":"O sister of Aaron! Thy father was not a wicked man, nor was thy mother a loose woman!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2278.mp3","surahId":19,"words":[{"id":30807,"position":1,"arabic":"يَـٰٓأُخْتَ","translation":"হে বোন","audioUrl":"wbw/019_028_001.mp3","charTypeName":"word"},{"id":30808,"position":2,"arabic":"هَـٰرُونَ","translation":"হারূনের","audioUrl":"wbw/019_028_002.mp3","charTypeName":"word"},{"id":30809,"position":3,"arabic":"مَا","translation":"না","audioUrl":"wbw/019_028_003.mp3","charTypeName":"word"},{"id":30810,"position":4,"arabic":"كَانَ","translation":"ছিলেন","audioUrl":"wbw/019_028_004.mp3","charTypeName":"word"},{"id":30811,"position":5,"arabic":"أَبُوكِ","translation":"তোমার বাপ","audioUrl":"wbw/019_028_005.mp3","charTypeName":"word"},{"id":30812,"position":6,"arabic":"ٱمْرَأَ","translation":"ব্যক্তি","audioUrl":"wbw/019_028_006.mp3","charTypeName":"word"},{"id":30813,"position":7,"arabic":"سَوْءٍۢ","translation":"অসৎ","audioUrl":"wbw/019_028_007.mp3","charTypeName":"word"},{"id":30814,"position":8,"arabic":"وَمَا","translation":"আর না","audioUrl":"wbw/019_028_008.mp3","charTypeName":"word"},{"id":30815,"position":9,"arabic":"كَانَتْ","translation":"ছিলেন","audioUrl":"wbw/019_028_009.mp3","charTypeName":"word"},{"id":30816,"position":10,"arabic":"أُمُّكِ","translation":"তোমার মা","audioUrl":"wbw/019_028_010.mp3","charTypeName":"word"},{"id":30817,"position":11,"arabic":"بَغِيًّۭا","translation":"ব্যভিচারিনী (চরিত্রহীনা)\"","audioUrl":"wbw/019_028_011.mp3","charTypeName":"word"},{"id":30818,"position":12,"arabic":"٢٨","translation":"(২৮)","audioUrl":null,"charTypeName":"end"}]},{"number":29,"arabic":"فَأَشَارَتْ إِلَيْهِ ۖ قَالُوا۟ كَيْفَ نُكَلِّمُ مَن كَانَ فِى ٱلْمَهْدِ صَبِيًّۭا","translation":"Thereupon she pointed to him. They exclaimed: \"How can we talk to one who [as yet] is a little boy in the cradle?\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2279.mp3","surahId":19,"words":[{"id":31963,"position":1,"arabic":"فَأَشَارَتْ","translation":"তখন সে ইঙ্গিত করলো","audioUrl":"wbw/019_029_001.mp3","charTypeName":"word"},{"id":31964,"position":2,"arabic":"إِلَيْهِ ۖ","translation":"তার দিকে","audioUrl":"wbw/019_029_002.mp3","charTypeName":"word"},{"id":31966,"position":3,"arabic":"قَالُوا۟","translation":"তারা বললো","audioUrl":"wbw/019_029_004.mp3","charTypeName":"word"},{"id":31967,"position":4,"arabic":"كَيْفَ","translation":"\"কিভাবে","audioUrl":"wbw/019_029_005.mp3","charTypeName":"word"},{"id":31968,"position":5,"arabic":"نُكَلِّمُ","translation":"কথা বলবো আমরা","audioUrl":"wbw/019_029_006.mp3","charTypeName":"word"},{"id":31969,"position":6,"arabic":"مَن","translation":"যে","audioUrl":"wbw/019_029_007.mp3","charTypeName":"word"},{"id":31970,"position":7,"arabic":"كَانَ","translation":"আছে","audioUrl":"wbw/019_029_008.mp3","charTypeName":"word"},{"id":31971,"position":8,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/019_029_009.mp3","charTypeName":"word"},{"id":31972,"position":9,"arabic":"ٱلْمَهْدِ","translation":"দোলনার","audioUrl":"wbw/019_029_010.mp3","charTypeName":"word"},{"id":31973,"position":10,"arabic":"صَبِيًّۭا","trans