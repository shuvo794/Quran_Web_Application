{"id":307,"ayahs":[{"number":26,"arabic":"فَكُلِى وَٱشْرَبِى وَقَرِّى عَيْنًۭا ۖ فَإِمَّا تَرَيِنَّ مِنَ ٱلْبَشَرِ أَحَدًۭا فَقُولِىٓ إِنِّى نَذَرْتُ لِلرَّحْمَٰنِ صَوْمًۭا فَلَنْ أُكَلِّمَ ٱلْيَوْمَ إِنسِيًّۭا","translation":"Eat, then, and drink, and let thine eye be gladdened! And if thou shouldst see any human being, convey this unto him: `Behold, abstinence from speech have I vowed unto the Most Gracious; hence, I may not speak today to any mortal.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2276.mp3","surahId":19,"words":[{"id":28742,"position":1,"arabic":"فَكُلِى","translation":"সুতরাং খাও","audioUrl":"wbw/019_026_001.mp3","charTypeName":"word"},{"id":28743,"position":2,"arabic":"وَٱشْرَبِى","translation":"ও পান করো","audioUrl":"wbw/019_026_002.mp3","charTypeName":"word"},{"id":28744,"position":3,"arabic":"وَقَرِّى","translation":"এবং জুড়াও","audioUrl":"wbw/019_026_003.mp3","charTypeName":"word"},{"id":28745,"position":4,"arabic":"عَيْنًۭا ۖ","translation":"চোখকে","audioUrl":"wbw/019_026_004.mp3","charTypeName":"word"},{"id":28747,"position":5,"arabic":"فَإِمَّا","translation":"অতঃপর যদি","audioUrl":"wbw/019_026_006.mp3","charTypeName":"word"},{"id":28748,"position":6,"arabic":"تَرَيِنَّ","translation":"তুমি দেখো","audioUrl":"wbw/019_026_007.mp3","charTypeName":"word"},{"id":28749,"position":7,"arabic":"مِنَ","translation":"মধ্য হ'তে","audioUrl":"wbw/019_026_008.mp3","charTypeName":"word"},{"id":28750,"position":8,"arabic":"ٱلْبَشَرِ","translation":"মানুষের","audioUrl":"wbw/019_026_009.mp3","charTypeName":"word"},{"id":28751,"position":9,"arabic":"أَحَدًۭا","translation":"কাউকে","audioUrl":"wbw/019_026_010.mp3","charTypeName":"word"},{"id":28752,"position":10,"arabic":"فَقُولِىٓ","translation":"তখন তুমি বলো","audioUrl":"wbw/019_026_011.mp3","charTypeName":"word"},{"id":28753,"position":11,"arabic":"إِنِّى","translation":"\"আমি নিশ্চয়ই","audioUrl":"wbw/019_026_012.mp3","charTypeName":"word"},{"id":28754,"position":12,"arabic":"نَذَرْتُ","t