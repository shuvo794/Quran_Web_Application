hat God should have taken unto Himself a son: limitless is He in His glory! When He wills a thing to be, He but says unto it \"Be\" -and it is!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2285.mp3","surahId":19,"words":[{"id":37108,"position":1,"arabic":"مَا","translation":"নয়","audioUrl":"wbw/019_035_001.mp3","charTypeName":"word"},{"id":37109,"position":2,"arabic":"كَانَ","translation":"কাজ","audioUrl":"wbw/019_035_002.mp3","charTypeName":"word"},{"id":37110,"position":3,"arabic":"لِلَّهِ","translation":"আল্লাহ্‌র জন্য","audioUrl":"wbw/019_035_003.mp3","charTypeName":"word"},{"id":37111,"position":4,"arabic":"أَن","translation":"যে","audioUrl":"wbw/019_035_004.mp3","charTypeName":"word"},{"id":37112,"position":5,"arabic":"يَتَّخِذَ","translation":"তিনি গ্রহণ করবেন","audioUrl":"wbw/019_035_005.mp3","charTypeName":"word"},{"id":37113,"position":6,"arabic":"مِن","translation":"কোন","audioUrl":"wbw/019_035_006.mp3","charTypeName":"word"},{"id":37114,"position":7,"arabic":"وَلَدٍۢ ۖ","translation":"সন্তান","audioUrl":"wbw/019_035_007.mp3","charTypeName":"word"},{"id":37116,"position":8,"arabic":"سُبْحَـٰنَهُۥٓ ۚ","translation":"তিনি পবিত্র","audioUrl":"wbw/019_035_009.mp3","charTypeName":"word"},{"id":37118,"position":9,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/019_035_011.mp3","charTypeName":"word"},{"id":37119,"position":10,"arabic":"قَضَىٰٓ","translation":"স্হির করেন","audioUrl":"wbw/019_035_012.mp3","charTypeName":"word"},{"id":37120,"position":11,"arabic":"أَمْرًۭا","translation":"কোন বিষয়কে","audioUrl":"wbw/019_035_013.mp3","charTypeName":"word"},{"id":37121,"position":12,"arabic":"فَإِنَّمَا","translation":"তখন শুধুমাত্র","audioUrl":"wbw/019_035_014.mp3","charTypeName":"word"},{"id":37122,"position":13,"arabic":"يَقُولُ","translation":"বলেন","audioUrl":"wbw/019_035_015.mp3","charTypeName":"word"},{"id":37123,"position":14,"arabic":"لَهُۥ","translation":"তাকে","audioUrl":"wbw/019_035_016.mp3","charTypeName":"word"},{"id":37124,"position":15,"arabic":"كُن","translation":"\"হও\"","audioUrl":"wbw/019_035_017.mp3","charTypeName":"word"},{"id":37125,"position":16,"arabic":"فَيَكُونُ","translation":"তখনই হয়ে যায়","audioUrl":"wbw/019_035_018.mp3","charTypeName":"word"},{"id":37126,"position":17,"arabic":"٣٥","translation":"(৩৫)","audioUrl":null,"charTypeName":"end"}]},{"number":36,"arabic":"وَإِنَّ ٱللَّهَ رَبِّى وَرَبُّكُمْ فَٱعْبُدُوهُ ۚ هَٰذَا صِرَٰطٌۭ مُّسْتَقِيمٌۭ","translation":"And [thus it was that Jesus always said]: \"Verily, God is my Sustainer as well as your Sustainer; so worship [none but] Him: this (alone] is a straight way.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2286.mp3","surahId":19,"words":[{"id":37922,"position":1,"arabic":"وَإِنَّ","translation":"\"এবং নিশ্চয়ই","audioUrl":"wbw/019_036_001.mp3","charTypeName":"word"},{"id":37923,"position":2,"arabic":"ٱللَّهَ","translation":"আল্লাহ্‌","audioUrl":"wbw/019_036_002.mp3","charTypeName":"word"},{"id":37924,"position":3,"arabic":"رَبِّى","translation":"আমার রব","audioUrl":"wbw/019_036_003.mp3","charTypeName":"word"},{"id":37925,"position":4,"arabic":"وَرَبُّكُمْ","translation":"ও তোমাদের রব","audioUrl":"wbw/019_036_004.mp3","charTypeName":"word"},{"id":37926,"position":5,"arabic":"فَٱعْبُدُوهُ ۚ","translation":"সুতরাং তাঁরই তোমরা ইবাদাত করো","audioUrl":"wbw/019_036_005.mp3","charTypeName":"word"},{"id":37928,"position":6,"arabic":"هَـٰذَا","translation":"এটা","audioUrl":"wbw/019_036_007.mp3","charTypeName":"word"},{"id":37929,"position":7,"arabic":"صِرَٰطٌۭ","translation":"পথ","audioUrl":"wbw/019_036_008.mp3","charTypeName":"word"},{"id":37930,"position":8,"arabic":"مُّسْتَقِيمٌۭ","translation":"সরল সঠিক\"","audioUrl":"wbw/019_036_009.mp3","charTypeName":"word"},{"id":37931,"position":9,"arabic":"٣٦","translation":"(৩৬)","audioUrl":null,"charTypeName":"end"}]},{"number":37,"arabic":"فَٱخْتَلَفَ ٱلْأَحْزَابُ مِنۢ بَيْنِهِمْ ۖ فَوَيْلٌۭ لِّلَّذِينَ كَفَرُوا۟ مِن مَّشْهَدِ يَوْمٍ عَظِيمٍ","translation":"And yet, the sects [that follow the Bible] are at variance among themselves [about the nature of Jesus Woe, then, unto all who deny the truth when that awesome Day will appear!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2287.mp3","surahId":19,"words":[{"id":38749,"position":1,"arabic":"فَٱخْتَلَفَ","translation":"অতঃপর মতভেদ করলো","audioUrl":"wbw/019_037_001.mp3","charTypeName":"word"},{"id":38750,"position":2,"arabic":"ٱلْأَحْزَابُ","translation":"বিভিন্ন দল","audioUrl":"wbw/019_037_002.mp3","charTypeName":"word"},{"id":38751,"position":3,"arabic":"مِنۢ","translation":"থেকে","audioUrl":"wbw/019_037_003.mp3","charTypeName":"word"},{"id":38752,"position":4,"arabic":"بَيْنِهِمْ ۖ","translation":"তাদের মাঝে","audioUrl":"wbw/019_037_004.mp3","charTypeName":"word"},{"id":38754,"position":5,"arabic":"فَوَيْلٌۭ","translation":"সুতরাং দুর্ভোগ","audioUrl":"wbw/019_037_006.mp3","charTypeName":"word"},{"id":38755,"position":6,"arabic":"لِّلَّذِينَ","translation":"(তাদের) জন্যে যারা","audioUrl":"wbw/019_037_007.mp3","charTypeName":"word"},{"id":38756,"position":7,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/019_037_008.mp3","charTypeName":"word"},{"id":38757,"position":8,"arabic":"مِن","translation":"হ'তে","audioUrl":"wbw/019_037_009.mp3","charTypeName":"word"},{"id":38758,"position":9,"arabic":"مَّشْهَدِ","translation":"সাক্ষাত","audioUrl":"wbw/019_037_010.mp3","charTypeName":"word"},{"id":38759,"position":10,"arabic":"يَوْمٍ","translation":"দিনের","audioUrl":"wbw/019_037_011.mp3","charTypeName":"word"},{"id":38760,"position":11,"arabic":"عَظِيمٍ","translation":"কঠিন","audioUrl":"wbw/019_037_012.mp3","charTypeName":"word"},{"id":38761,"position":12,"arabic":"٣٧","translation":"(৩৭)","audioUrl":null,"charTypeName":"end"}]},{"number":38,"arabic":"أَسْمِعْ بِهِمْ وَأَبْصِرْ يَوْمَ يَأْتُونَنَا ۖ لَٰكِنِ ٱلظَّٰلِمُونَ ٱلْيَوْمَ فِى ضَلَٰلٍۢ مُّبِينٍۢ","translation":"How well will they hear and see [the truth] on the Day when they come before U