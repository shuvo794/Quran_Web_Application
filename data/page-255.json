"translation":"জন্যে যার","audioUrl":"wbw/014_002_003.mp3","charTypeName":"word"},{"id":1928,"position":4,"arabic":"مَا","translation":"যা কিছূু","audioUrl":"wbw/014_002_004.mp3","charTypeName":"word"},{"id":1929,"position":5,"arabic":"فِى","translation":"মধ্যে আছে","audioUrl":"wbw/014_002_005.mp3","charTypeName":"word"},{"id":1930,"position":6,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশের","audioUrl":"wbw/014_002_006.mp3","charTypeName":"word"},{"id":1931,"position":7,"arabic":"وَمَا","translation":"ও যা কিছু","audioUrl":"wbw/014_002_007.mp3","charTypeName":"word"},{"id":1932,"position":8,"arabic":"فِى","translation":"মধ্যে আছে","audioUrl":"wbw/014_002_008.mp3","charTypeName":"word"},{"id":1933,"position":9,"arabic":"ٱلْأَرْضِ ۗ","translation":"পৃথিবীর","audioUrl":"wbw/014_002_009.mp3","charTypeName":"word"},{"id":1935,"position":10,"arabic":"وَوَيْلٌۭ","translation":"এবং দুর্ভোগ","audioUrl":"wbw/014_002_011.mp3","charTypeName":"word"},{"id":1936,"position":11,"arabic":"لِّلْكَـٰفِرِينَ","translation":"কাফেরদের জন্যে","audioUrl":"wbw/014_002_012.mp3","charTypeName":"word"},{"id":1937,"position":12,"arabic":"مِنْ","translation":"হতে","audioUrl":"wbw/014_002_013.mp3","charTypeName":"word"},{"id":1938,"position":13,"arabic":"عَذَابٍۢ","translation":"শাস্তি","audioUrl":"wbw/014_002_014.mp3","charTypeName":"word"},{"id":1939,"position":14,"arabic":"شَدِيدٍ","translation":"কঠোর","audioUrl":"wbw/014_002_015.mp3","charTypeName":"word"},{"id":1940,"position":15,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"ٱلَّذِينَ يَسْتَحِبُّونَ ٱلْحَيَوٰةَ ٱلدُّنْيَا عَلَى ٱلْءَاخِرَةِ وَيَصُدُّونَ عَن سَبِيلِ ٱللَّهِ وَيَبْغُونَهَا عِوَجًا ۚ أُو۟لَٰٓئِكَ فِى ضَلَٰلٍۭ بَعِيدٍۢ","translation":"awaits those who choose the life of this world as the sole object of their love, preferring it to [all thought of] the life to come, and who turn others away from the path of God and try to make it appear crooked. Such as these have indeed gone far astray!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1753.mp3","surahId":14,"words":[{"id":3079,"position":1,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/014_003_001.mp3","charTypeName":"word"},{"id":3080,"position":2,"arabic":"يَسْتَحِبُّونَ","translation":"প্রাধান্য দেয়","audioUrl":"wbw/014_003_002.mp3","charTypeName":"word"},{"id":3081,"position":3,"arabic":"ٱلْحَيَوٰةَ","translation":"জীবনকে","audioUrl":"wbw/014_003_003.mp3","charTypeName":"word"},{"id":3082,"position":4,"arabic":"ٱلدُّنْيَا","translation":"পার্থিব","audioUrl":"wbw/014_003_004.mp3","charTypeName":"word"},{"id":3083,"position":5,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/014_003_005.mp3","charTypeName":"word"},{"id":3084,"position":6,"arabic":"ٱلْـَٔاخِرَةِ","translation":"আখিরাতের","audioUrl":"wbw/014_003_006.mp3","charTypeName":"word"},{"id":3085,"position":7,"arabic":"وَيَصُدُّونَ","translation":"ও (মানুষকে) বাধা দেয়","audioUrl":"wbw/014_003_007.mp3","charTypeName":"word"},{"id":3086,"position":8,"arabic":"عَن","translation":"থেকে","audioUrl":"wbw/014_003_008.mp3","charTypeName":"word"},{"id":3087,"position":9,"arabic":"سَبِيلِ","translation":"পথ","audioUrl":"wbw/014_003_009.mp3","charTypeName":"word"},{"id":3088,"position":10,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/014_003_010.mp3","charTypeName":"word"},{"id":3089,"position":11,"arabic":"وَيَبْغُونَهَا","translation":"ও তাকে করতে চায়","audioUrl":"wbw/014_003_011.mp3","charTypeName":"word"},{"id":3090,"position":12,"arabic":"عِوَجًا ۚ","translation":"বাঁকা","audioUrl":"wbw/014_003_012.mp3","charTypeName":"word"},{"id":3092,"position":13,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐসব লোক","audioUrl":"wbw/014_003_014.mp3","charTypeName":"word"},{"id":3093,"position":14,"arabic":"فِى","translation":"মধ্যে আছে","audioUrl":"wbw/014_003_015.mp3","charTypeName":"word"},{"id":3094,"position":15,"arabic":"ضَلَـٰلٍۭ","translation":"বিপথে","audioUrl":"wbw/014_003_016.mp3","charTypeName":"word"},{"id":3095,"position":16,"arabic":"بَعِيدٍۢ","translation":"(বহু) দূরে","audioUrl":"wbw/014_003_017.mp3","charTypeName":"word"},{"id":3096,"position":17,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"وَمَآ أَرْسَلْنَا مِن رَّسُولٍ إِلَّا بِلِسَانِ قَوْمِهِۦ لِيُبَيِّنَ لَهُمْ ۖ فَيُضِلُّ ٱللَّهُ مَن يَشَآءُ وَيَهْدِى مَن يَشَآءُ ۚ وَهُوَ ٱلْعَزِيزُ ٱلْحَكِيمُ","translation":"AND NEVER have We sent forth any apostle otherwise than [with a message] in his own people's tongue, so that he might make [the truth] clear unto them; but God lets go astray him that wills [to go astray], and guides him that wills [to be guided] -for He alone is almighty, truly wise.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1754.mp3","surahId":14,"words":[{"id":4473,"position":1,"arabic":"وَمَآ","translation":"এবং নি","audioUrl":"wbw/014_004_001.mp3","charTypeName":"word"},{"id":4474,"position":2,"arabic":"أَرْسَلْنَا","translation":"আমরা পাঠাই","audioUrl":"wbw/014_004_002.mp3","charTypeName":"word"},{"id":4475,"position":3,"arabic":"مِن","translation":"কোনো","audioUrl":"wbw/014_004_003.mp3","charTypeName":"word"},{"id":4476,"position":4,"arabic":"رَّسُولٍ","translation":"রাসূলকে","audioUrl":"wbw/014_004_004.mp3","charTypeName":"word"},{"id":4477,"position":5,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/014_004_005.mp3","charTypeName":"word"},{"id":4478,"position":6,"arabic":"بِلِسَانِ","translation":"দিয়ে ভাষা","audioUrl":"wbw/014_004_006.mp3","charTypeName":"word"},{"id":4479,"position":7,"arabic":"قَوْمِهِۦ","translation":"তার জাতির","audioUrl":"wbw/014_004_007.mp3","charTypeName":"word"},{"id":4480,"position":8,"arabic":"لِيُبَيِّنَ","translation":"যেন সুস্পষ্ট করে বর্ণনা করেন","audioUrl":"wbw/014_004_008.mp3","charTypeName":"word"},{"id":4481,"position":9,"arabic":"لَهُمْ ۖ","translation":"তাদেরকে","audioUrl":"wbw/014_004_009.mp3","charTypeName":"word"},{"id":4483,"position":10,"arabic":"فَيُضِلُّ","translation":"অতঃপর পথভ্রষ্ট করেন","audioUrl":"wbw/014_004_011.mp3","charTypeName":"word"},{"id":4484,"position":11,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/014_004_012.mp3","charTypeName":"word"},{"id":4485,"position":12,"arabic":"مَن","translation":"যাকে","audioUrl":"wbw/014_004_013.mp3","charTypeName":"word"},{"id":4486,"position":13,"arabic":"يَشَآءُ","translation":"ইচ্ছে করেন","audioUrl":"wbw/014_004_014.mp3","charTypeName":"word"},{"id":4487,"position":14,"arabic":"وَيَهْدِى","translation":"ও সৎ পথ দেখান","audioUrl":"wbw/014_004_015.mp3","charTypeName":"word"},{"id":4488,"position":15,"arabic":"مَن","translation":"যাকে","audioUrl":"wbw/014_004_016.mp3","charTypeName":"word"},{"id":4489,"position":16,"arabic":"يَشَآءُ ۚ","translation":"ইচ্ছে করেন","audioUrl":"wbw/014_004_017.mp3","charTypeName":"word"},{"id":4491,"position":17,"arabic":"وَهُوَ","translation":"এবং তিনি","audioUrl":"wbw/014_004_019.mp3","charTypeName":"word"},{"id":4492,"position":18,"arabic":"ٱلْعَزِيزُ","translation":"পরাক্রমশালী","audioUrl":"wbw/014_004_020.mp3","charTypeName":"word"},{"id":4493,"position":19,"arabic":"ٱلْحَكِيمُ","translation":"প্রজ্ঞাময়","audioUrl":"wbw/014_004_021.mp3","charTypeName":"word"},{"id":4494,"position":20,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"وَلَقَدْ أَرْسَلْنَا مُوسَىٰ بِـَٔايَٰتِنَآ أَنْ أَخْرِجْ قَوْمَكَ مِنَ ٱلظُّلُمَٰتِ إِلَى ٱلنُّورِ وَذَكِّرْهُم بِأَيَّىٰمِ ٱللَّهِ ۚ إِنَّ فِى ذَٰلِكَ لَءَايَٰتٍۢ لِّكُلِّ صَبَّارٍۢ شَكُورٍۢ","translation":"And [thus], indeed, have We sent forth Moses with Our messages [and this Our command]: \"Lead thy people out of the depths of darkness into the light, and remind them of the Days of God!\" Verily, in this [reminder] there are messages indeed for all who are wholly patient in adversity and deeply grateful [to God].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1755.mp3","surahId":14,"words":[{"id":5719,"position":1,"arabic":"وَلَق