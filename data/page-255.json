{"id":255,"ayahs":[{"number":43,"arabic":"وَيَقُولُ ٱلَّذِينَ كَفَرُوا۟ لَسْتَ مُرْسَلًۭا ۚ قُلْ كَفَىٰ بِٱللَّهِ شَهِيدًۢا بَيْنِى وَبَيْنَكُمْ وَمَنْ عِندَهُۥ عِلْمُ ٱلْكِتَٰبِ","translation":"And [if] they who are bent on denying the truth say [unto thee, O Prophet], \"Thou hast not been sent [by God]\", say thou: \"None can bear witness between me and you as God does; and [none can bear witness as does] he who truly understands this divine writ.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1750.mp3","surahId":13,"words":[{"id":43974,"position":1,"arabic":"وَيَقُولُ","translation":"এবং বলে","audioUrl":"wbw/013_043_001.mp3","charTypeName":"word"},{"id":43975,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/013_043_002.mp3","charTypeName":"word"},{"id":43976,"position":3,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/013_043_003.mp3","charTypeName":"word"},{"id":43977,"position":4,"arabic":"لَسْتَ","translation":"\"তুমি নও","audioUrl":"wbw/013_043_004.mp3","charTypeName":"word"},{"id":43978,"position":5,"arabic":"مُرْسَلًۭا ۚ","translation":"প্রেরিত (নাবী)\"","audioUrl":"wbw/013_043_005.mp3","charTypeName":"word"},{"id":43980,"position":6,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/013_043_007.mp3","charTypeName":"word"},{"id":43981,"position":7,"arabic":"كَفَىٰ","translation":"\"যথেষ্ট","audioUrl":"wbw/013_043_008.mp3","charTypeName":"word"},{"id":43982,"position":8,"arabic":"بِٱللَّهِ","translation":"আল্লাহ তা'লা-ই","audioUrl":"wbw/013_043_009.mp3","charTypeName":"word"},{"id":43983,"position":9,"arabic":"شَهِيدًۢا","translation":"সাক্ষী হিসেবে","audioUrl":"wbw/013_043_010.mp3","charTypeName":"word"},{"id":43984,"position":10,"arabic":"بَيْنِى","translation":"আমার মাঝে","audioUrl":"wbw/013_043_011.mp3","charTypeName":"word"},{"id":43985,"position":11,"arabic":"وَبَيْنَكُمْ","translation":"ও তোমাদের মাঝে","audioUrl":"wbw/013_043_012.mp3","charTypeName":"word"},{"id":43986,"position":12,"arabic"