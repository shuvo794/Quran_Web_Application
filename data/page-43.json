{"id":43,"ayahs":[{"number":257,"arabic":"ٱللَّهُ وَلِىُّ ٱلَّذِينَ ءَامَنُوا۟ يُخْرِجُهُم مِّنَ ٱلظُّلُمَٰتِ إِلَى ٱلنُّورِ ۖ وَٱلَّذِينَ كَفَرُوٓا۟ أَوْلِيَآؤُهُمُ ٱلطَّٰغُوتُ يُخْرِجُونَهُم مِّنَ ٱلنُّورِ إِلَى ٱلظُّلُمَٰتِ ۗ أُو۟لَٰٓئِكَ أَصْحَٰبُ ٱلنَّارِ ۖ هُمْ فِيهَا خَٰلِدُونَ","translation":"God is near unto those who have faith, taking them out of deep darkness into the light - whereas near unto those who are bent on denying the truth are the powers of evil that take them out of the light into darkness deep: it is they who are destined for the fire, therein to abide.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/264.mp3","surahId":2,"words":[{"id":87235,"position":1,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/002_257_001.mp3","charTypeName":"word"},{"id":87236,"position":2,"arabic":"وَلِىُّ","translation":"অভিভাবক","audioUrl":"wbw/002_257_002.mp3","charTypeName":"word"},{"id":87237,"position":3,"arabic":"ٱلَّذِينَ","translation":"(তাদের) যারা","audioUrl":"wbw/002_257_003.mp3","charTypeName":"word"},{"id":87238,"position":4,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/002_257_004.mp3","charTypeName":"word"},{"id":87239,"position":5,"arabic":"يُخْرِجُهُم","translation":"তিনি তাদের বের করে আনেন","audioUrl":"wbw/002_257_005.mp3","charTypeName":"word"},{"id":87240,"position":6,"arabic":"مِّنَ","translation":"হতে","audioUrl":"wbw/002_257_006.mp3","charTypeName":"word"},{"id":87241,"position":7,"arabic":"ٱلظُّلُمَـٰتِ","translation":"অন্ধকারগুলো","audioUrl":"wbw/002_257_007.mp3","charTypeName":"word"},{"id":87242,"position":8,"arabic":"إِلَى","translation":"দিকে","audioUrl":"wbw/002_257_008.mp3","charTypeName":"word"},{"id":87243,"position":9,"arabic":"ٱلنُّورِ ۖ","translation":"আলোর","audioUrl":"wbw/002_257_009.mp3","charTypeName":"word"},{"id":87245,"position":10,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/002_257_011.mp3","charTypeName":"word"},{"id":87246,"position":11,"arabic":"كَفَرُوٓا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/002_257_012.mp3","charTypeName":"word"},{"id":87247,"position":12,"arabic":"أَوْلِيَآؤُهُمُ","translation":"তাদের অভিভাবক","audioUrl":"wbw/002_257_013.mp3","charTypeName":"word"},{"id":87248,"position":13,"arabic":"ٱلطَّـٰغُوتُ","translation":"তাগুত (অসত্য দেবতা)","audioUrl":"wbw/002_257_014.mp3","charTypeName":"word"},{"id":87249,"position":14,"arabic":"يُخْرِجُونَهُم","translation":"তাদেরকে তারা বের করে নিয়ে যায়","audioUrl":"wbw/002_257_015.mp3","charTypeName":"word"},{"id":87250,"position":15,"arabic":"مِّنَ","translation":"থেকে","audioUrl":"wbw/002_257_016.mp3","charTypeName":"word"},{"id":87251,"position":16,"arabic":"ٱلنُّورِ","translation":"আলো","audioUrl":"wbw/002_257_017.mp3","charTypeName":"word"},{"id":87252,"position":17,"arabic":"إِلَى","translation":"দিকে","audioUrl":"wbw/002_257_018.mp3","charTypeName":"word"},{"id":87253,"position":18,"arabic":"ٱلظُّلُمَـٰتِ ۗ","translation":"অন্ধকারগুলোর","audioUrl":"wbw/002_257_019.mp3","charTypeName":"word"},{"id":87255,"position":19,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐ সব লোক","audioUrl":"wbw/002_257_021.mp3","charTypeName":"word"},{"id":87256,"position":20,"arabic":"أَصْحَـٰبُ","translation":"অধিবাসী","audioUrl":"wbw/002_257_022.mp3","charTypeName":"word"},{"id":87257,"position":21,"arabic":"ٱلنَّارِ ۖ","translation":"(জাহান্নামের) আগুনের","audioUrl":"wbw/002_257_023.mp3","charTypeName":"word"},{"id":87259,"position":22,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/002_257_025.mp3","charTypeName":"word"},{"id":87260,"position":23,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/002_257_026.mp3","charTypeName":"word"},{"id":87261,"position":24,"arabic":"خَـٰلِدُونَ","translation":"চিরস্থায়ী হবে","audioUrl":"wbw/002_257_027.mp3","charTypeName":"word"},{"id":87262,"position":25,"arabic":"٢٥٧","translation":"(২৫৭)","audioUrl":null,"charTypeName":"end"}]},{"number":258,"arabic":"أَلَمْ تَرَ إِلَى ٱلَّذِى حَآجَّ إِبْرَٰهِۦمَ فِى رَبِّهِۦٓ أَنْ ءَاتَىٰهُ ٱللَّهُ ٱلْمُلْكَ إِذْ قَالَ إِبْرَٰهِۦمُ رَبِّىَ ٱلَّذِى يُحْىِۦ وَيُمِيتُ قَالَ أَنَا۠ أُحْىِۦ وَأُمِيتُ ۖ قَالَ إِبْرَٰهِۦمُ فَإِنَّ ٱللَّهَ يَأْتِى بِٱلشَّمْسِ مِنَ ٱلْمَشْرِقِ فَأْتِ بِهَا مِنَ ٱلْمَغْرِبِ فَبُهِتَ ٱلَّذِى كَفَرَ ۗ وَٱللَّهُ لَا يَهْدِى ٱلْقَوْمَ ٱلظَّٰلِمِينَ","translation":"ART THOU NOT aware of that [king] who argued with Abraham about his Sustainer, (simply] because God had granted him kingship? Lo! Abraham said: \"My Sustainer is He who grants life and deals death.\" [The king] replied: \"I [too] grant life and deal death!\" Said Abraham: \"Verily, God causes the sun to rise in the east; cause it, then, to rise in the west!\" Thereupon he who was bent on denying the truth remained dumbfounded: for God does not guide people who [deliberately] do wrong.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/265.mp3","surahId":2,"words":[{"id":87263,"position":1,"arabic":"أَلَمْ","translation":"নি কি","audioUrl":"wbw/002_258_001.mp3","charTypeName":"word"},{"id":87264,"position":2,"arabic":"تَرَ","translation":"তুমি দেখ","audioUrl":"wbw/002_258_002.mp3","charTypeName":"word"},{"id":87265,"position":3,"arabic":"إِلَى","translation":"প্রতি","audioUrl":"wbw/002_258_003.mp3","charTypeName":"word"},{"id":87266,"position":4,"arabic":"ٱلَّذِى","translation":"(তার) যে","audioUrl":"wbw/002_258_004.mp3","charTypeName":"word"},{"id":87267,"position":5,"arabic":"حَآجَّ","translation":"বিতর্ক করেছিল","audioUrl":"wbw/002_258_005.mp3","charTypeName":"word"},{"id":87268,"position":6,"arabic":"إِبْرَٰهِـۧمَ","translation":"ইবরাহীমের (সাথে)","audioUrl":"wbw/002_258_006.mp3","charTypeName":"word"},{"id":87269,"position":7,"arabic":"فِى","translation":"সম্বন্ধে","audioUrl":"wbw/002_258_007.mp3","charTypeName":"word"},{"id":87270,"position":8,"arabic":"رَبِّهِۦٓ","translation":"তার রব","audioUrl":"wbw/002_258_008.mp3","charTypeName":"word"},{"id":87271,"position":9,"arabic":"أَنْ","translation":"(এজন্য) যে","audioUrl":"wbw/002_258_009.mp3","charTypeName":"word"},{"id":87272,"position":10,"arabic":"ءَاتَىٰهُ","translation":"তাকে দিয়ে ছিলেন","audioUrl":"wbw/002_258_010.mp3","charTypeName":"word"},{"id":87273,"position":11,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/002_258_011.mp3","charTypeName":"word"},{"id":87274,"position":12,"arabic":"ٱلْمُلْكَ","translation":"রাজত্ব","audioUrl":"wbw/002_258_012.mp3","charTypeName":"word"},{"id":87275,"position":13,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/002_258_013.mp3","charTypeName":"word"},{"id":87276,"position":14,"arabic":"قَالَ","translation":"বলেছিল","audioUrl":"wbw/002_258_014.mp3","charTypeName":"word"},{"id":87277,"position":15,"arabic":"إِبْرَٰهِـۧمُ","translation":"ইবরাহীম","audioUrl":"wbw/002_258_015.mp3","charTypeName":"word"},{"id":87278,"position":16,"arabic":"رَبِّىَ","translation":"আমার রব (হচ্ছেন)","audioUrl":"wbw/002_258_016.mp3","charTypeName":"word"},{"id":87279,"position":17,"arabic":"ٱلَّذِى","translation":"(ঐ সত্তা) যিনি","audioUrl":"wbw/002_258_017.mp3","charTypeName":"word"},{"id":87280,"position":18,"arabic":"يُحْىِۦ","translation":"জীবিত করেন","audioUrl":"wbw/002_258_018.mp3","charTypeName":"word"},{"id":87281,"position":19,"arabic":"وَيُمِيتُ","translation":"এবং মৃত্যু ঘটান","audioUrl":"wbw/002_258_019.mp3","charTypeName":"word"},{"id":87282,"position":20,"arabic":"قَالَ","translation":"সে বলল","audioUrl":"wbw/002_258_020.mp3","charTypeName":"word"},{"id":87283,"position":21,"arabic":"أَنَا۠","translation":"আমি","audioUrl":"wbw/002_258_021.mp3","charTypeName":"word"},{"id":87284,"position":22,"arabic":"أُحْىِۦ","translation":"জীবন দান করি","audioUrl":"wbw/002_258_022.mp3","charTypeName":"word"},{"id":87285,"position":23,"arabic":"وَأُمِيتُ ۖ","translation":"ও মৃত্যু ঘটাই","audioUrl":"wbw/002_258_023.mp3","charTypeName":"word"},{"id":87287,"position":24,"arabic":"قَالَ","translation":"বলল","audioUrl":"wbw/002_258_025.mp3","charTypeName":"word"},{"id":87288,"position":25,"arabic":"إِبْرَٰهِـۧمُ","translation":"ইবরাহীম","audioUrl":"wbw/002_258_026.mp3","charTypeName":"word"},{"id":87289,"position":26,"arabic":"فَإِنَّ","translation":"নিশ্চয়ই তবে","audioUrl":"wbw/002_258_027.mp3","charTypeName":"word"},{"id":87290,"position":27,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/002_258_028.mp3","charTypeName":"word"},{"id":87291,"position":28,"arabic":"يَأْتِى","translation":"আনেন","audioUrl":"wbw/002_258_029.mp3","charTypeName":"word"},{"id":87292,"position":29,"arabic":"بِٱلشَّمْسِ","translation":"সূর্যকে নিয়ে","audioUrl":"wbw/002_258_030.mp3","charTypeName":"word"},{"id":87293,"position":30,"arabic":"مِنَ","translation":"হতে","audioUrl":"wbw/002_258_031.mp3","charTypeName":"word"},{"id":87294,"position":31,"arabic":"ٱلْمَشْرِقِ","translation":"পূর্বদিক","audioUrl":"wbw/002_258_032.mp3","charTypeName":"word"},{"id":87295,"position":32,"arabic":"فَأْتِ","translation":"তুমি তাহলে আনো","audioUrl":"wbw/002_258_033.mp3","charTypeName":"word"},{"id":87296,"position":33,"arabic":"بِهَا","translation":"তাকে নিয়ে","audioUrl":"wbw/002_258_034.mp3","charTypeName":"word"},{"id":87297,"position":34,"arabic":"مِنَ","translation":"হতে","audioUrl":"wbw/002_258_035.mp3","charTypeName":"word"},{"id":87298,"position":35,"arabic":"ٱلْمَغْرِبِ","translation":"পশ্চিমদিক","audioUrl":"wbw/002_258_036.mp3","charTypeName":"word"},{"id":87299,"position":36,"arabic":"فَبُهِتَ","translation":"হতবুদ্ধি হয়ে তখন গেল","audioUrl":"wbw/002_258_037.mp3","charTypeName":"word"},{"id":87300,"position":37,"arabic":"ٱلَّذِى","translation":"যে","audioUrl":"wbw/002_258_038.mp3","charTypeName":"word"},{"id":87301,"position":38,"arabic":"كَفَرَ ۗ","translation":"অস্বীকার করেছিল","audioUrl":"wbw/002_258_039.mp3","charTypeName":"word"},{"id":87303,"position":39,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/002_258_041.mp3","charTypeName":"word"},{"id":87304,"position":40,"arabic":"لَا","translation":"না","audioUrl":"wbw/002_258_042.mp3","charTypeName":"word"},{"id":87305,"position":41,"arabic":"يَهْدِى","translation":"সঠিক পথ দেখান","audioUrl":"wbw/002_258_043.mp3","charTypeName":"word"},{"id":87306,"position":42,"arabic":"ٱلْقَوْمَ","translation":"সম্প্রদায়কে","audioUrl":"wbw/002_258_044.mp3","charTypeName":"word"},{"id":87307,"position":43,"arabic":"ٱلظَّـٰلِمِينَ","translation":"সীমালঙ্ঘনকারী","audioUrl":"wbw/002_258_045.mp3","charTypeName":"word"},{"id":87308,"position":44,"arabic":"٢٥٨","translation":"(২৫৮)","audioUrl":null,"charTypeName":"end"}]},{"number":259,"arabic":"أَوْ كَٱلَّذِى مَرَّ عَلَىٰ قَرْيَةٍۢ وَهِىَ خَاوِيَةٌ عَلَىٰ عُرُوشِهَا قَالَ أَنَّىٰ يُحْىِۦ هَٰذِهِ ٱللَّهُ بَعْدَ مَوْتِهَا ۖ فَأَمَاتَهُ ٱللَّهُ مِا۟ئَةَ عَامٍۢ ثُمَّ بَعَثَهُۥ ۖ قَالَ كَمْ لَبِثْتَ ۖ قَالَ لَبِثْتُ يَوْمًا أَوْ بَعْضَ يَوْمٍۢ ۖ قَالَ بَل لَّبِثْتَ مِا۟ئَةَ عَامٍۢ فَٱنظُرْ إِلَىٰ طَعَامِكَ وَشَرَابِكَ لَمْ يَتَسَنَّهْ ۖ وَٱنظُرْ إِلَىٰ حِمَارِكَ وَلِنَجْعَلَكَ ءَايَةًۭ لِّلنَّاسِ ۖ وَٱنظُرْ إِلَى ٱلْعِظَامِ كَيْفَ نُنشِزُهَا ثُمَّ نَكْسُوهَا لَحْمًۭا ۚ فَلَمَّا تَبَيَّنَ لَهُۥ قَالَ أَعْلَمُ أَنَّ ٱللَّهَ عَلَىٰ كُلِّ شَىْءٍۢ قَدِيرٌۭ","translation":"Or [art thou, O man, of the same mind] as he who passed by a town deserted by its people, with its roofs caved in, [and] said, \"How could God bring all this back to life after its death?\" Thereupon God caused him to be dead for a hundred years; where after He brought him back to life [and] said: \"How long hast thou remained thus?\" He answered: \"I have remained thus a day, or part of a day.\" Said [God]: \"Nay, but thou hast remained thus for a hundred years! But look at thy food and thy drink-untouched is it by the passing of years - and look at thine ass! And [We did all this so that We might make thee a symbol unto men. And look at the bones [of animals and men] - how We put them together and then clothe them with flesh!\" And when [all this] became clear to him, he said: \"I know [now] that God has the power to will anything!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/266.mp3","surahId":2,"words":[{"id":87309,"position":1,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/002_259_001.mp3","charTypeName":"word"},{"id":87310,"position":2,"arabic":"كَٱلَّذِى","translation":"যে দৃষ্টান্ত (ঐলোকের)","audioUrl":"wbw/002_259_002.mp3","charTypeName":"word"},{"id":87311,"position":3,"arabic":"مَرَّ","translation":"অতিক্রম করছিল","audioUrl":"wbw/002_259_003.mp3","charTypeName":"word"},{"id":87312,"position":4,"arabic":"عَلَىٰ","translation":"উপর দিয়ে","audioUrl":"wbw/002_259_004.mp3","charTypeName":"word"},{"id":87313,"position":5,"arabic":"قَرْيَةٍۢ","translation":"এক নগরের","audioUrl":"wbw/002_259_005.mp3","charTypeName":"word"},{"id":87314,"position":6,"arabic":"وَهِىَ","translation":"এমনঅবস্থায় যে তা (ছিল)","audioUrl":"wbw/002_259_006.mp3","charTypeName":"word"},{"id":87315,"position":7,"arabic":"خَاوِيَةٌ","translation":"ধ্বংসস্তুপ হয়েছিল","audioUrl":"wbw/002_259_007.mp3","charTypeName":"word"},{"id":87316,"position":8,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/002_259_008.mp3","charTypeName":"word"},{"id":87317,"position":9,"arabic":"عُرُوشِهَا","translation":"তার ছাদগুলোর","audioUrl":"wbw/002_259_009.mp3","charTypeName":"word"},{"id":87318,"position":10,"arabic":"قَالَ","translation":"সে বলল","audioUrl":"wbw/002_259_010.mp3","charTypeName":"word"},{"id":87319,"position":11,"arabic":"أَنَّىٰ","translation":"কিরূপে","audioUrl":"wbw/002_259_011.mp3","charTypeName":"word"},{"id":87320,"position":12,"arabic":"يُحْىِۦ","translation":"জীবিত করবেন","audioUrl":"wbw/002_259_012.mp3","charTypeName":"word"},{"id":87321,"position":13,"arabic":"هَـٰذِهِ","translation":"এটাকে","audioUrl":"wbw/002_259_013.mp3","charTypeName":"word"},{"id":87322,"position":14,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/002_259_014.mp3","charTypeName":"word"},{"id":87323,"position":15,"arabic":"بَعْدَ","translation":"পর","audioUrl":"wbw/002_259_015.mp3","charTypeName":"word"},{"id":87324,"position":16,"arabic":"مَوْتِهَا ۖ","translation":"তার (মৃত্যুর)","a