05,"position":3,"arabic":"وَٱنقَلَبُوا۟","translation":"এবং তারা ফিরে গেলো","audioUrl":"wbw/007_119_003.mp3","charTypeName":"word"},{"id":76206,"position":4,"arabic":"صَـٰغِرِينَ","translation":"লাঞ্ছিত হয়ে","audioUrl":"wbw/007_119_004.mp3","charTypeName":"word"},{"id":76207,"position":5,"arabic":"١١٩","translation":"(১১৯)","audioUrl":null,"charTypeName":"end"}]},{"number":120,"arabic":"وَأُلْقِىَ ٱلسَّحَرَةُ سَٰجِدِينَ","translation":"And down fell the sorcerers, prostrating themselves","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1074.mp3","surahId":7,"words":[{"id":76486,"position":1,"arabic":"وَأُلْقِىَ","translation":"এবং নত করে দিলো","audioUrl":"wbw/007_120_001.mp3","charTypeName":"word"},{"id":76487,"position":2,"arabic":"ٱلسَّحَرَةُ","translation":"জাদুকরদেরকে","audioUrl":"wbw/007_120_002.mp3","charTypeName":"word"},{"id":76488,"position":3,"arabic":"سَـٰجِدِينَ","translation":"সিজদাকারী (হিসেবে)","audioUrl":"wbw/007_120_003.mp3","charTypeName":"word"},{"id":76489,"position":4,"arabic":"١٢٠","translation":"(১২০)","audioUrl":null,"charTypeName":"end"}]}]}