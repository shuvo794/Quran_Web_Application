{"id":164,"ayahs":[{"number":105,"arabic":"حَقِيقٌ عَلَىٰٓ أَن لَّآ أَقُولَ عَلَى ٱللَّهِ إِلَّا ٱلْحَقَّ ۚ قَدْ جِئْتُكُم بِبَيِّنَةٍۢ مِّن رَّبِّكُمْ فَأَرْسِلْ مَعِىَ بَنِىٓ إِسْرَٰٓءِيلَ","translation":"so constituted that I cannot say anything about God but the truth. I have now come unto you with a clear evidence from your Sustainer: let, then, the children of Israel go with me!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1059.mp3","surahId":7,"words":[{"id":72694,"position":1,"arabic":"حَقِيقٌ","translation":"এটা স্হির নিশ্চিত (আমার)","audioUrl":"wbw/007_105_001.mp3","charTypeName":"word"},{"id":72695,"position":2,"arabic":"عَلَىٰٓ","translation":"উপর","audioUrl":"wbw/007_105_002.mp3","charTypeName":"word"},{"id":72696,"position":3,"arabic":"أَن","translation":"যে","audioUrl":"wbw/007_105_003.mp3","charTypeName":"word"},{"id":72697,"position":4,"arabic":"لَّآ","translation":"না","audioUrl":"wbw/007_105_004.mp3","charTypeName":"word"},{"id":72698,"position":5,"arabic":"أَقُولَ","translation":"বলি আমি","audioUrl":"wbw/007_105_005.mp3","charTypeName":"word"},{"id":72699,"position":6,"arabic":"عَلَى","translation":"ব্যাপারে","audioUrl":"wbw/007_105_006.mp3","charTypeName":"word"},{"id":72700,"position":7,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/007_105_007.mp3","charTypeName":"word"},{"id":72701,"position":8,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/007_105_008.mp3","charTypeName":"word"},{"id":72702,"position":9,"arabic":"ٱلْحَقَّ ۚ","translation":"প্রকৃত সত্য","audioUrl":"wbw/007_105_009.mp3","charTypeName":"word"},{"id":72704,"position":10,"arabic":"قَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/007_105_011.mp3","charTypeName":"word"},{"id":72705,"position":11,"arabic":"جِئْتُكُم","translation":"কাছে এসেছি তোমাদের","audioUrl":"wbw/007_105_012.mp3","charTypeName":"word"},{"id":72706,"position":12,"arabic":"بِبَيِّنَةٍۢ","translation":"সহ সুস্পষ্ট প্রমাণ","audioUrl":"wbw/007_105_013.mp3","charTypeName":"