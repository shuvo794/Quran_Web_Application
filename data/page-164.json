.mp3","charTypeName":"word"},{"id":75399,"position":8,"arabic":"نَّكُونَ","translation":"আমরা হবো","audioUrl":"wbw/007_115_008.mp3","charTypeName":"word"},{"id":75400,"position":9,"arabic":"نَحْنُ","translation":"আমরা","audioUrl":"wbw/007_115_009.mp3","charTypeName":"word"},{"id":75401,"position":10,"arabic":"ٱلْمُلْقِينَ","translation":"নিক্ষেপকারী\"","audioUrl":"wbw/007_115_010.mp3","charTypeName":"word"},{"id":75402,"position":11,"arabic":"١١٥","translation":"(১১৫)","audioUrl":null,"charTypeName":"end"}]},{"number":116,"arabic":"قَالَ أَلْقُوا۟ ۖ فَلَمَّآ أَلْقَوْا۟ سَحَرُوٓا۟ أَعْيُنَ ٱلنَّاسِ وَٱسْتَرْهَبُوهُمْ وَجَآءُو بِسِحْرٍ عَظِيمٍۢ","translation":"He answered: \"You throw [first].\" And when they threw down [their staffs], they cast a spell upon the people's eyes, and struck them with awe, and produced mighty sorcery.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1070.mp3","surahId":7,"words":[{"id":75464,"position":1,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/007_116_001.mp3","charTypeName":"word"},{"id":75465,"position":2,"arabic":"أَلْقُوا۟ ۖ","translation":"\"তোমরা ছোঁড়ো\"","audioUrl":"wbw/007_116_002.mp3","charTypeName":"word"},{"id":75467,"position":3,"arabic":"فَلَمَّآ","translation":"অতঃপর যখন","audioUrl":"wbw/007_116_004.mp3","charTypeName":"word"},{"id":75468,"position":4,"arabic":"أَلْقَوْا۟","translation":"তারা ছুঁড়লো","audioUrl":"wbw/007_116_005.mp3","charTypeName":"word"},{"id":75469,"position":5,"arabic":"سَحَرُوٓا۟","translation":"তারা জাদু করলো","audioUrl":"wbw/007_116_006.mp3","charTypeName":"word"},{"id":75470,"position":6,"arabic":"أَعْيُنَ","translation":"চোখগুলোকে","audioUrl":"wbw/007_116_007.mp3","charTypeName":"word"},{"id":75471,"position":7,"arabic":"ٱلنَّاسِ","translation":"মানুষের","audioUrl":"wbw/007_116_008.mp3","charTypeName":"word"},{"id":75472,"position":8,"arabic":"وَٱسْتَرْهَبُوهُمْ","translation":"ও তারা সন্ত্রস্ত করলো তাদেরকে","audioUrl":"wbw/007_116_009.mp3","charTypeName":"word"},{"id":75473,"position":9,"arabic":"وَجَآءُو","translation":"এবং তারা আসলো","audioUrl":"wbw/007_116_010.mp3","charTypeName":"word"},{"id":75474,"position":10,"arabic":"بِسِحْرٍ","translation":"নিয়ে জাদু","audioUrl":"wbw/007_116_011.mp3","charTypeName":"word"},{"id":75475,"position":11,"arabic":"عَظِيمٍۢ","translation":"বড় (ধরনের)","audioUrl":"wbw/007_116_012.mp3","charTypeName":"word"},{"id":75476,"position":12,"arabic":"١١٦","translation":"(১১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":117,"arabic":"۞ وَأَوْحَيْنَآ إِلَىٰ مُوسَىٰٓ أَنْ أَلْقِ عَصَاكَ ۖ فَإِذَا هِىَ تَلْقَفُ مَا يَأْفِكُونَ","translation":"And [then] We inspired Moses, \"Throw down thy staff!\" -and lo! it swallowed up all their deceptions:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1071.mp3","surahId":7,"words":[{"id":75842,"position":1,"arabic":"۞ وَأَوْحَيْنَآ","translation":"এবং ওহী করলাম আমরা","audioUrl":"wbw/007_117_002.mp3","charTypeName":"word"},{"id":75843,"position":2,"arabic":"إِلَىٰ","translation":"প্রতি","audioUrl":"wbw/007_117_003.mp3","charTypeName":"word"},{"id":75844,"position":3,"arabic":"مُوسَىٰٓ","translation":"মূসার","audioUrl":"wbw/007_117_004.mp3","charTypeName":"word"},{"id":75845,"position":4,"arabic":"أَنْ","translation":"যে","audioUrl":"wbw/007_117_005.mp3","charTypeName":"word"},{"id":75846,"position":5,"arabic":"أَلْقِ","translation":"\"ছোঁড়ো","audioUrl":"wbw/007_117_006.mp3","charTypeName":"word"},{"id":75847,"position":6,"arabic":"عَصَاكَ ۖ","translation":"তোমার লাঠি\"","audioUrl":"wbw/007_117_007.mp3","charTypeName":"word"},{"id":75849,"position":7,"arabic":"فَإِذَا","translation":"অতঃপর যখন","audioUrl":"wbw/007_117_009.mp3","charTypeName":"word"},{"id":75850,"position":8,"arabic":"هِىَ","translation":"তা","audioUrl":"wbw/007_117_010.mp3","charTypeName":"word"},{"id":75851,"position":9,"arabic":"تَلْقَفُ","translation":"গিলে ফেলতে লাগলো","audioUrl":"wbw/007_117_011.mp3","charTypeName":"word"},{"id":75852,"position":10,"arabic":"مَا"