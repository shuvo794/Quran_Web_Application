{"id":425,"ayahs":[{"number":51,"arabic":"۞ تُرْجِى مَن تَشَآءُ مِنْهُنَّ وَتُـْٔوِىٓ إِلَيْكَ مَن تَشَآءُ ۖ وَمَنِ ٱبْتَغَيْتَ مِمَّنْ عَزَلْتَ فَلَا جُنَاحَ عَلَيْكَ ۚ ذَٰلِكَ أَدْنَىٰٓ أَن تَقَرَّ أَعْيُنُهُنَّ وَلَا يَحْزَنَّ وَيَرْضَيْنَ بِمَآ ءَاتَيْتَهُنَّ كُلُّهُنَّ ۚ وَٱللَّهُ يَعْلَمُ مَا فِى قُلُوبِكُمْ ۚ وَكَانَ ٱللَّهُ عَلِيمًا حَلِيمًۭا","translation":"[know that] thou mayest put off for a time whichever of them thou pleasest, and mayest take unto thee whichever thou pleasest; and [that,] if thou seek out any from whom thou hast kept away [for a time], thou wilt incur no sin [thereby]: this will make it more likely that their eyes are gladdened [whenever they see thee], and that they do not grieve [whenever they are overlooked], and that all of them may find contentment in whatever thou hast to give them: for God [alone] knows what is in your hearts - and God is indeed all-knowing, for­bearing.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3584.mp3","surahId":33,"words":[{"id":49493,"position":1,"arabic":"۞ تُرْجِى","translation":"দূরে রাখতে পারো","audioUrl":"wbw/033_051_002.mp3","charTypeName":"word"},{"id":49494,"position":2,"arabic":"مَن","translation":"যাকে","audioUrl":"wbw/033_051_003.mp3","charTypeName":"word"},{"id":49495,"position":3,"arabic":"تَشَآءُ","translation":"তুমি চাও","audioUrl":"wbw/033_051_004.mp3","charTypeName":"word"},{"id":49496,"position":4,"arabic":"مِنْهُنَّ","translation":"মধ্য হ'তে তাদের(অর্থাৎ স্ত্রীদের)","audioUrl":"wbw/033_051_005.mp3","charTypeName":"word"},{"id":49497,"position":5,"arabic":"وَتُـْٔوِىٓ","translation":"এবং স্থান দিতে পারো","audioUrl":"wbw/033_051_006.mp3","charTypeName":"word"},{"id":49498,"position":6,"arabic":"إِلَيْكَ","translation":"কাছে তোমার","audioUrl":"wbw/033_051_007.mp3","charTypeName":"word"},{"id":49499,"position":7,"arabic":"مَن","translation":"যাকে","audioUrl":"wbw/033_051_008.mp3","charTypeName":"word"},{"id":49500,"position":8,"arabic":"تَشَآءُ ۖ","translation":"তুমি চাও","audioUrl":"wbw/033_051_009.mp3","charTypeName":"word"},{"id":49502,"position":9,"arabic":"وَمَنِ","translation":"এবং যাকে","audioUrl":"wbw/033_051_011.mp3","charTypeName":"word"},{"id":49503,"position":10,"arabic":"ٱبْتَغَيْتَ","translation":"তুমি কামনা করো","audioUrl":"wbw/033_051_012.mp3","charTypeName":"word"},{"id":49504,"position":11,"arabic":"مِمَّنْ","translation":"তাদের মধ্যে থেকে (যাকে)","audioUrl":"wbw/033_051_013.mp3","charTypeName":"word"},{"id":49505,"position":12,"arabic":"عَزَلْتَ","translation":"তুমি দূরে রেখেছিলে","audioUrl":"wbw/033_051_014.mp3","charTypeName":"word"},{"id":49506,"position":13,"arabic":"فَلَا","translation":"এক্ষেত্রে নেই","audioUrl":"wbw/033_051_015.mp3","charTypeName":"word"},{"id":49507,"position":14,"arabic":"جُنَاحَ","translation":"কোনো পাপ","audioUrl":"wbw/033_051_016.mp3","charTypeName":"word"},{"id":49508,"position":15,"arabic":"عَلَيْكَ ۚ","translation":"উপর তোমার","audioUrl":"wbw/033_051_017.mp3","charTypeName":"word"},{"id":49510,"position":16,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/033_051_019.mp3","charTypeName":"word"},{"id":49511,"position":17,"arabic":"أَدْنَىٰٓ","translation":"অধিক নিকটবর্তী","audioUrl":"wbw/033_051_020.mp3","charTypeName":"word"},{"id":49512,"position":18,"arabic":"أَن","translation":"যে","audioUrl":"wbw/033_051_021.mp3","charTypeName":"word"},{"id":49513,"position":19,"arabic":"تَقَرَّ","translation":"শীতল হবে","audioUrl":"wbw/033_051_022.mp3","charTypeName":"word"},{"id":49514,"position":20,"arabic":"أَعْيُنُهُنَّ","translation":"চোখগুলো তাদের","audioUrl":"wbw/033_051_023.mp3","charTypeName":"word"},{"id":49515,"position":21,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/033_051_024.mp3","charTypeName":"word"},{"id":49516,"position":22,"arabic":"يَحْزَنَّ","translation":"দুঃখ পাবে","audioUrl":"wbw/033_051_025.mp3","charTypeName":"word"},{"id":49517,"position":23,"arabic":"وَيَرْضَيْنَ","translation":"এবং সন্তুষ্ট থাকবে","audioUrl":"wbw/033_051_026.mp3","charTypeName":"word"},{"id":49518,"position":24,"arabic":"بِمَآ","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/033_051_027.mp3","charTypeName":"word"},{"id":49519,"position":25,"arabic":"ءَاتَيْتَهُنَّ","translation":"তুমি দিয়েছো তাদেরকে","audioUrl":"wbw/033_051_028.mp3","charTypeName":"word"},{"id":49520,"position":26,"arabic":"كُلُّهُنَّ ۚ","translation":"সকলে তাদের","audioUrl":"wbw/033_051_029.mp3","charTypeName":"word"},{"id":49522,"position":27,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/033_051_031.mp3","charTypeName":"word"},{"id":49523,"position":28,"arabic":"يَعْلَمُ","translation":"জানেন","audioUrl":"wbw/033_051_032.mp3","charTypeName":"word"},{"id":49524,"position":29,"arabic":"مَا","translation":"যা","audioUrl":"wbw/033_051_033.mp3","charTypeName":"word"},{"id":49525,"position":30,"arabic":"فِى","translation":"মধ্যে (আছে)","audioUrl":"wbw/033_051_034.mp3","charTypeName":"word"},{"id":49526,"position":31,"arabic":"قُلُوبِكُمْ ۚ","translation":"অন্তরসমূহের তোমাদের","audioUrl":"wbw/033_051_035.mp3","charTypeName":"word"},{"id":49528,"position":32,"arabic":"وَكَانَ","translation":"এবং হলেন","audioUrl":"wbw/033_051_037.mp3","charTypeName":"word"},{"id":49529,"position":33,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/033_051_038.mp3","charTypeName":"word"},{"id":49530,"position":34,"arabic":"عَلِيمًا","translation":"সর্বজ্ঞ","audioUrl":"wbw/033_051_039.mp3","charTypeName":"word"},{"id":49531,"position":35,"arabic":"حَلِيمًۭا","translation":"সহনশীল","audioUrl":"wbw/033_051_040.mp3","charTypeName":"word"},{"id":49532,"position":36,"arabic":"٥١","translation":"(৫১)","audioUrl":null,"charTypeName":"end"}]},{"number":52,"arabic":"لَّا يَحِلُّ لَكَ ٱلنِّسَآءُ مِنۢ بَعْدُ وَلَآ أَن تَبَدَّلَ بِهِنَّ مِنْ أَزْوَٰجٍۢ وَلَوْ أَعْجَبَكَ حُسْنُهُنَّ إِلَّا مَا مَلَكَتْ يَمِينُكَ ۗ وَكَانَ ٱللَّهُ عَلَىٰ كُلِّ شَىْءٍۢ رَّقِيبًۭا","translation":"No [other] women shall henceforth be lawful to thee nor art thou [allowed] to supplant [any of] them by other wives, even though their beauty should please thee greatly -: [none shall be lawful to thee] beyond those whom thou [already] hast come to possess. And God keeps watch over everything.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3585.mp3","surahId":33,"words":[{"id":50211,"position":1,"arabic":"لَّا","translation":"নয়","audioUrl":"wbw/033_052_001.mp3","charTypeName":"word"},{"id":50212,"position":2,"arabic":"يَحِلُّ","translation":"বৈধ","audioUrl":"wbw/033_052_002.mp3","charTypeName":"word"},{"id":50213,"position":3,"arabic":"لَكَ","translation":"জন্যে তোমার","audioUrl":"wbw/033_052_003.mp3","charTypeName":"word"},{"id":50214,"position":4,"arabic":"ٱلنِّسَآءُ","translation":"(অন্য) মহিলারা","audioUrl":"wbw/033_052_004.mp3","charTypeName":"word"},{"id":50215,"position":5,"arabic":"مِنۢ","translation":"থেকে","audioUrl":"wbw/033_052_005.mp3","charTypeName":"word"},{"id":50216,"position":6,"arabic":"بَعْدُ","translation":"এরপর","audioUrl":"wbw/033_052_006.mp3","charTypeName":"word"},{"id":50217,"position":7,"arabic":"وَلَآ","translation":"আর না (এটাও)","audioUrl":"wbw/033_052_007.mp3","charTypeName":"word"},{"id":50218,"position":8,"arabic":"أَن","translation":"যে","audioUrl":"wbw/033_052_008.mp3","charTypeName":"word"},{"id":50219,"position":9,"arabic":"تَبَدَّلَ","translation":"পরিবর্তন করবে তুমি","audioUrl":"wbw/033_052_009.mp3","charTypeName":"word"},{"id":50220,"position":10,"arabic":"بِهِنَّ","translation":"বিনিময়ে তাদের (কাউকে)","audioUrl":"wbw/033_052_010.mp3","charTypeName":"word"},{"id":50221,"position":11,"arabic":"مِنْ","translation":"মধ্যে হ'তে","audioUrl":"wbw/033_052_011.mp3","charTypeName":"word"},{"id":50222,"position":12,"arabic":"أَزْوَٰجٍۢ","translation":"(তোমার) স্ত্রীদের","audioUrl":"wbw/033_052_012.mp3","charTypeName":"word"},{"id":50223,"position":13,"arabic":"وَلَوْ","translation":"এবং যদিও","audioUrl":"wbw/033_052_013.mp3","charTypeName":"word"},{"id":50224,"position":14,"arabic":"أَعْجَبَكَ","translation":"তোমাকে মুগ্ধ করে","audioUrl":"wbw/033_052_014.mp3","charTypeName":"word"},{"id":50225,"position":15,"arabic":"حُسْنُهُنَّ","translation":"সৌন্দর্য তাদের","audioUrl":"wbw/033_052_015.mp3","charTypeName":"word"},{"id":50226,"position":16,"arabic":"إِلَّا","translation":"(তবে) ব্যতিক্রম","audioUrl":"wbw/033_052_016.mp3","charTypeName":"word"},{"id":50227,"position":17,"arabic":"مَا","translation":"যা","audioUrl":"wbw/033_052_017.mp3","charTypeName":"word"},{"id":50228,"position":18,"arabic":"مَلَكَتْ","translation":"মালিক হয়েছে","audioUrl":"wbw/033_052_018.mp3","charTypeName":"word"},{"id":50229,"position":19,"arabic":"يَمِينُكَ ۗ","translation":"ডানহাত তোমার (অর্থাৎ দাসী)","audioUrl":"wbw/033_052_019.mp3","charTypeName":"word"},{"id":50231,"position":20,"arabic":"وَكَانَ","translation":"এবং হলেন","audioUrl":"wbw/033_052_021.mp3","charTypeName":"word"},{"id":50232,"position":21,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/033_052_022.mp3","charTypeName":"word"},{"id":50233,"position":22,"arabic":"عَلَىٰ","translation":"উপরে","audioUrl":"wbw/033_052_023.mp3","charTypeName":"word"},{"id":50234,"position":23,"arabic":"كُلِّ","translation":"সব","audioUrl":"wbw/033_052_024.mp3","charTypeName":"word"},{"id":50235,"position":24,"arabic":"شَىْءٍۢ","translation":"কিছুর","audioUrl":"wbw/033_052_025.mp3","charTypeName":"word"},{"id":50236,"position":25,"arabic":"رَّقِيبًۭا","translation":"সজাগ দৃষ্টিবান","audioUrl":"wbw/033_052_026.mp3","charTypeName":"word"},{"id":50237,"position":26,"arabic":"٥٢","translation":"(৫২)","audioUrl":null,"charTypeName":"end"}]},{"number":53,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ لَا تَدْخُلُوا۟ بُيُوتَ ٱلنَّبِىِّ إِلَّآ أَن يُؤْذَنَ لَكُمْ إِلَىٰ طَعَامٍ غَيْرَ نَٰظِرِينَ إِنَىٰهُ وَلَٰكِنْ إِذَا دُعِيتُمْ فَٱدْخُلُوا۟ فَإِذَا طَعِمْتُمْ فَٱنتَشِرُوا۟ وَلَا مُسْتَـْٔنِسِينَ لِحَدِيثٍ ۚ إِنَّ ذَٰلِكُمْ كَانَ يُؤْذِى ٱلنَّبِىَّ فَيَسْتَحْىِۦ مِنكُمْ ۖ وَٱللَّهُ لَا يَسْتَحْىِۦ مِنَ ٱلْحَقِّ ۚ وَإِذَا سَأَلْتُمُوهُنَّ مَتَٰعًۭا فَسْـَٔلُوهُنَّ مِن وَرَآءِ حِجَابٍۢ ۚ ذَٰلِكُمْ أَطْهَرُ لِقُلُوبِكُمْ وَقُلُوبِهِنَّ ۚ وَمَا كَانَ لَكُمْ أَن تُؤْذُوا۟ رَسُولَ ٱللَّهِ وَلَآ أَن تَنكِحُوٓا۟ أَزْوَٰجَهُۥ مِنۢ بَعْدِهِۦٓ أَبَدًا ۚ إِنَّ ذَٰلِكُمْ كَانَ عِندَ ٱللَّهِ عَظِيمًا","translation":"O YOU who have attained to faith! Do not enter the Prophet’s dwellings unless you are given leave; [and when invited] to a meal, do not come [so early as] to wait for it to be readied: but whenever you are invited, enter [at the proper time]; and when you have partaken of the meal, disperse without lingering for the sake of mere talk: that, behold, might give offence to the Prophet, and yet he might feel shy of [asking] you [to leave]: but God is not shy of [teaching you] what is right. And [as for the Prophet’s wives,] whenever you ask them for anything that you need, ask them from behind a screen: this will but deepen the purity of your hearts and theirs. Moreover, it does not behove you to give offence to God’s Apostle - just as it would not behove you ever to marry his widows after he has passed away: that, verily, would be an enormity in the sight of God.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3586.mp3","surahId":33,"words":[{"id":50765,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/033_053_001.mp3","charTypeName":"word"},{"id":50766,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/033_053_002.mp3","charTypeName":"word"},{"id":50767,"position":3,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছো","audioUrl":"wbw/033_053_003.mp3","charTypeName":"word"},{"id":50768,"position":4,"arabic":"لَا","translation":"না","audioUrl":"wbw/033_053_004.mp3","charTypeName":"word"},{"id":50769,"position":5,"arabic":"تَدْخُلُوا۟","translation":"তোমরা প্রবেশ করো","audioUrl":"wbw/033_053_005.mp3","charTypeName":"word"},{"id":50770,"position":6,"arabic":"بُيُوتَ","translation":"ঘরগুলোতে","audioUrl":"wbw/033_053_006.mp3","charTypeName":"word"},{"id":50771,"position":7,"arabic":"ٱلنَّبِىِّ","translation":"নাবীর","audioUrl":"wbw/033_053_007.mp3","charTypeName":"word"},{"id":50772,"position":8,"arabic":"إِلَّآ","translation":"কিন্তু","audioUrl":"wbw/033_053_008.mp3","charTypeName":"word"},{"id":50773,"position":9,"arabic":"أَن","translation":"যদি","audioUrl":"wbw/033_053_009.mp3","charTypeName":"word"},{"id":50774,"position":10,"arabic":"يُؤْذَنَ","translation":"অনুমতি দেওয়া হয়","audioUrl":"wbw/033_053_010.mp3","charTypeName":"word"},{"id":50775,"position":11,"arabic":"لَكُمْ","translation":"জন্যে তোমাদের","audioUrl":"wbw/033_053_011.mp3","charTypeName":"word"},{"id":50776,"position":12,"arabic":"إِلَىٰ","translation":"প্রতি","audioUrl":"wbw/033_053_012.mp3","charTypeName":"word"},{"id":50777,"position":13,"arabic":"طَعَامٍ","translation":"খাওয়ার (দাওয়াতে)","audioUrl":"wbw/033_053_013.mp3","charTypeName":"word"},{"id":50778,"position":14,"arabic":"غَيْرَ","translation":"(তবে এসো না)ছাড়া","audioUrl":"wbw/033_053_014.mp3","charTypeName":"word"},{"id":50779,"position":15,"arabic":"نَـٰظِرِينَ","translation":"অপেক্ষাকারী","audioUrl":"wbw/033_053_015.mp3","charTypeName":"word"},{"id":50780,"position":16,"arabic":"إِنَىٰهُ","translation":"প্রস্তুতির তা","audioUrl":"wbw/033_053_016.mp3","charTypeName":"word"},{"id":50781,"position":17,"arabic":"وَلَـٰكِنْ","translation":"কিন্তু","audioUrl":"wbw/033_053_017.mp3","charTypeName":"word"},{"id":50782,"position":18,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/033_053_018.mp3","charTypeName":"word"},{"id":50783,"position":19,"arabic":"دُعِيتُمْ","translation":"ডাকা হয় তোমাদের","audioUrl":"wbw/033_053_019.mp3","charTypeName":"word"},{"id":50784,"position":20,"arabic":"فَٱدْخُلُوا۟","translation":"তখন তোমরা প্রবেশ করো","audioUrl":"wbw/033_053_020.mp3","charTypeName":"word"},{"id":50785,"position":21,"arabic":"فَإِذَا","translation":"অতঃপর যখন","audioUrl":"wbw/033_053_021.mp3","charTypeName":"word"},{"id":50786,"position":22,"arabic":"طَعِمْتُمْ","translation":"তোমরা খাওয়া শেষ করো","audioUrl":