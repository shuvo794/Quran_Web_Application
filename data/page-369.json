ses thus: “Go forth with My servants by night: for, behold, you will he pursued!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2984.mp3","surahId":26,"words":[{"id":50067,"position":1,"arabic":"۞ وَأَوْحَيْنَآ","translation":"এবং আমরা ওহী পাঠালাম","audioUrl":"wbw/026_052_002.mp3","charTypeName":"word"},{"id":50068,"position":2,"arabic":"إِلَىٰ","translation":"প্রতি","audioUrl":"wbw/026_052_003.mp3","charTypeName":"word"},{"id":50069,"position":3,"arabic":"مُوسَىٰٓ","translation":"মূসার","audioUrl":"wbw/026_052_004.mp3","charTypeName":"word"},{"id":50070,"position":4,"arabic":"أَنْ","translation":"যে","audioUrl":"wbw/026_052_005.mp3","charTypeName":"word"},{"id":50071,"position":5,"arabic":"أَسْرِ","translation":"\"রাতে বের হয়ে যাও","audioUrl":"wbw/026_052_006.mp3","charTypeName":"word"},{"id":50072,"position":6,"arabic":"بِعِبَادِىٓ","translation":"নিয়ে আমার দাসদের","audioUrl":"wbw/026_052_007.mp3","charTypeName":"word"},{"id":50073,"position":7,"arabic":"إِنَّكُم","translation":"নিশ্চয়ই তোমাদেরকে","audioUrl":"wbw/026_052_008.mp3","charTypeName":"word"},{"id":50074,"position":8,"arabic":"مُّتَّبَعُونَ","translation":"পিছনে অনুসরণ করা হবে\"","audioUrl":"wbw/026_052_009.mp3","charTypeName":"word"},{"id":50075,"position":9,"arabic":"٥٢","translation":"(৫২)","audioUrl":null,"charTypeName":"end"}]},{"number":53,"arabic":"فَأَرْسَلَ فِرْعَوْنُ فِى ٱلْمَدَآئِنِ حَٰشِرِينَ","translation":"And Pharaoh sent heralds unto all cities,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2985.mp3","surahId":26,"words":[{"id":50655,"position":1,"arabic":"فَأَرْسَلَ","translation":"অতঃপর পাঠালো","audioUrl":"wbw/026_053_001.mp3","charTypeName":"word"},{"id":50656,"position":2,"arabic":"فِرْعَوْنُ","translation":"ফিরআউন","audioUrl":"wbw/026_053_002.mp3","charTypeName":"word"},{"id":50657,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/026_053_003.mp3","charTypeName":"word"},{"id":50658,"position":4,"arabic":"ٱلْمَدَآئِنِ","translation":"শহরগুলোর","audioUrl":"wbw/026_053_004.mp3","charTypeName":"word"},{"id":50659,"position":5,"arabic":"حَـٰشِرِينَ","translation":"(লোক) সংগ্রহকারীদেরকে","audioUrl":"wbw/026_053_005.mp3","charTypeName":"word"},{"id":50660,"position":6,"arabic":"٥٣","translation":"(৫৩)","audioUrl":null,"charTypeName":"end"}]},{"number":54,"arabic":"إِنَّ هَٰٓؤُلَآءِ لَشِرْذِمَةٌۭ قَلِيلُونَ","translation":"[bidding them to call out his troops and to proclaim:] “Behold, these [children of Israel] are but a contemptible band;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2986.mp3","surahId":26,"words":[{"id":51491,"position":1,"arabic":"إِنَّ","translation":"\"(এই বলে যে) নিশ্চয়ই","audioUrl":"wbw/026_054_001.mp3","charTypeName":"word"},{"id":51492,"position":2,"arabic":"هَـٰٓؤُلَآءِ","translation":"এরা","audioUrl":"wbw/026_054_002.mp3","charTypeName":"word"},{"id":51493,"position":3,"arabic":"لَشِرْذِمَةٌۭ","translation":"অবশ্যই একটি ক্ষুদে দল","audioUrl":"wbw/026_054_003.mp3","charTypeName":"word"},{"id":51494,"position":4,"arabic":"قَلِيلُونَ","translation":"কম (লোক)","audioUrl":"wbw/026_054_004.mp3","charTypeName":"word"},{"id":51495,"position":5,"arabic":"٥٤","translation":"(৫৪)","audioUrl":null,"charTypeName":"end"}]},{"number":55,"arabic":"وَإِنَّهُمْ لَنَا لَغَآئِظُونَ","translation":"but they are indeed filled with hatred of us","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2987.mp3","surahId":26,"words":[{"id":51819,"position":1,"arabic":"وَإِنَّهُمْ","translation":"এবং নিশ্চয়ই তারা","audioUrl":"wbw/026_055_001.mp3","charTypeName":"word"},{"id":51820,"position":2,"arabic":"لَنَا","translation":"জন্যে আমাদের","audioUrl":"wbw/026_055_002.mp3","charTypeName":"word"},{"id":51821,"position":3,"arabic":"لَغَآئِظُونَ","translation":"রাগউদ্রেককারী","audioUrl":"wbw/026_055_003.mp3","charTypeName":"word"},{"id":51822,"position":4,"arabic":"٥٥","translation":"(৫৫)","audioUrl":null,"charTypeName":"end"}]},{"number":56,"arabic":"وَإِنَّا لَج