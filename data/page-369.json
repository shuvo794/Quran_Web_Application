{"id":369,"ayahs":[{"number":40,"arabic":"لَعَلَّنَا نَتَّبِعُ ٱلسَّحَرَةَ إِن كَانُوا۟ هُمُ ٱلْغَٰلِبِينَ","translation":"so that we might follow [in the footsteps of] the sorcerers if it is they who prevail?”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2972.mp3","surahId":26,"words":[{"id":41559,"position":1,"arabic":"لَعَلَّنَا","translation":"সম্ভবতঃ আমরা","audioUrl":"wbw/026_040_001.mp3","charTypeName":"word"},{"id":41560,"position":2,"arabic":"نَتَّبِعُ","translation":"অনুসরণ করবো","audioUrl":"wbw/026_040_002.mp3","charTypeName":"word"},{"id":41561,"position":3,"arabic":"ٱلسَّحَرَةَ","translation":"জাদুকরদের (দ্বীনকে)","audioUrl":"wbw/026_040_003.mp3","charTypeName":"word"},{"id":41562,"position":4,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/026_040_004.mp3","charTypeName":"word"},{"id":41563,"position":5,"arabic":"كَانُوا۟","translation":"তারা হয়","audioUrl":"wbw/026_040_005.mp3","charTypeName":"word"},{"id":41564,"position":6,"arabic":"هُمُ","translation":"তারা","audioUrl":"wbw/026_040_006.mp3","charTypeName":"word"},{"id":41565,"position":7,"arabic":"ٱلْغَـٰلِبِينَ","translation":"বিজয়ী\"","audioUrl":"wbw/026_040_007.mp3","charTypeName":"word"},{"id":41566,"position":8,"arabic":"٤٠","translation":"(৪০)","audioUrl":null,"charTypeName":"end"}]},{"number":41,"arabic":"فَلَمَّا جَآءَ ٱلسَّحَرَةُ قَالُوا۟ لِفِرْعَوْنَ أَئِنَّ لَنَا لَأَجْرًا إِن كُنَّا نَحْنُ ٱلْغَٰلِبِينَ","translation":"Now when the sorcerers came, they said unto Pharaoh: “Verily, we ought to have a great reward if it is we who prevail.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2973.mp3","surahId":26,"words":[{"id":42411,"position":1,"arabic":"فَلَمَّا","translation":"অতঃপর যখন","audioUrl":"wbw/026_041_001.mp3","charTypeName":"word"},{"id":42412,"position":2,"arabic":"جَآءَ","translation":"আসলো (ময়দানে)","audioUrl":"wbw/026_041_002.mp3","charTypeName":"word"},{"id":42413,"position":3,"arabic":"ٱلسَّحَرَةُ","translation":"জাদুকররা","audioUr