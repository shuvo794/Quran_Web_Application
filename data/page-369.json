":"wbw/026_045_003.mp3","charTypeName":"word"},{"id":45292,"position":4,"arabic":"فَإِذَا","translation":"তখনই","audioUrl":"wbw/026_045_004.mp3","charTypeName":"word"},{"id":45293,"position":5,"arabic":"هِىَ","translation":"তা","audioUrl":"wbw/026_045_005.mp3","charTypeName":"word"},{"id":45294,"position":6,"arabic":"تَلْقَفُ","translation":"গিলে ফেলতে লাগলো","audioUrl":"wbw/026_045_006.mp3","charTypeName":"word"},{"id":45295,"position":7,"arabic":"مَا","translation":"যা কিছু","audioUrl":"wbw/026_045_007.mp3","charTypeName":"word"},{"id":45296,"position":8,"arabic":"يَأْفِكُونَ","translation":"তারা মিথ্যা সৃষ্টি করে","audioUrl":"wbw/026_045_008.mp3","charTypeName":"word"},{"id":45297,"position":9,"arabic":"٤٥","translation":"(৪৫)","audioUrl":null,"charTypeName":"end"}]},{"number":46,"arabic":"فَأُلْقِىَ ٱلسَّحَرَةُ سَٰجِدِينَ","translation":"And down fell the sorcerers, prostrating them­selves in adoration,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2978.mp3","surahId":26,"words":[{"id":46025,"position":1,"arabic":"فَأُلْقِىَ","translation":"তখন পড়ে গেলো","audioUrl":"wbw/026_046_001.mp3","charTypeName":"word"},{"id":46026,"position":2,"arabic":"ٱلسَّحَرَةُ","translation":"জাদুকররা","audioUrl":"wbw/026_046_002.mp3","charTypeName":"word"},{"id":46027,"position":3,"arabic":"سَـٰجِدِينَ","translation":"সিজদাকারী হিসেবে","audioUrl":"wbw/026_046_003.mp3","charTypeName":"word"},{"id":46028,"position":4,"arabic":"٤٦","translation":"(৪৬)","audioUrl":null,"charTypeName":"end"}]},{"number":47,"arabic":"قَالُوٓا۟ ءَامَنَّا بِرَبِّ ٱلْعَٰلَمِينَ","translation":"[and] exclaimed: “We have come to believe in the Sustainer of all the worlds,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2979.mp3","surahId":26,"words":[{"id":46645,"position":1,"arabic":"قَالُوٓا۟","translation":"তারা বললো","audioUrl":"wbw/026_047_001.mp3","charTypeName":"word"},{"id":46646,"position":2,"arabic":"ءَامَنَّا","translation":"\"আমরা ঈমান এনেছি","audioUrl":"wbw/026_047_002.mp3","charTypeName":"word"},{"id":46647,"position":3,"arabic":"بِرَبِّ","translation":"উপর রবের","audioUrl":"wbw/026_047_003.mp3","charTypeName":"word"},{"id":46648,"position":4,"arabic":"ٱلْعَـٰلَمِينَ","translation":"বিশ্ব্বজগতের","audioUrl":"wbw/026_047_004.mp3","charTypeName":"word"},{"id":46649,"position":5,"arabic":"٤٧","translation":"(৪৭)","audioUrl":null,"charTypeName":"end"}]},{"number":48,"arabic":"رَبِّ مُوسَىٰ وَهَٰرُونَ","translation":"the Sustainer of Moses and Aaron!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2980.mp3","surahId":26,"words":[{"id":47092,"position":1,"arabic":"رَبِّ","translation":"(যিনি) রব","audioUrl":"wbw/026_048_001.mp3","charTypeName":"word"},{"id":47093,"position":2,"arabic":"مُوسَىٰ","translation":"মূসার","audioUrl":"wbw/026_048_002.mp3","charTypeName":"word"},{"id":47094,"position":3,"arabic":"وَهَـٰرُونَ","translation":"ও হারুনের\"","audioUrl":"wbw/026_048_003.mp3","charTypeName":"word"},{"id":47095,"position":4,"arabic":"٤٨","translation":"(৪৮)","audioUrl":null,"charTypeName":"end"}]},{"number":49,"arabic":"قَالَ ءَامَنتُمْ لَهُۥ قَبْلَ أَنْ ءَاذَنَ لَكُمْ ۖ إِنَّهُۥ لَكَبِيرُكُمُ ٱلَّذِى عَلَّمَكُمُ ٱلسِّحْرَ فَلَسَوْفَ تَعْلَمُونَ ۚ لَأُقَطِّعَنَّ أَيْدِيَكُمْ وَأَرْجُلَكُم مِّنْ خِلَٰفٍۢ وَلَأُصَلِّبَنَّكُمْ أَجْمَعِينَ","translation":"Said [Pharaoh]: “Have you come to believe in him ere I have given you permission? Verily, he must be your master who has taught you magic! But in time you shall come to know [my revenge]: most certainly shall I cut off your hands and your feet in great numbers, because of [your] perverseness, and shall most certainly crucify you in great numbers, all together!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2981.mp3","surahId":26,"words":[{"id":48095,"position":1,"arabic":"قَالَ","translation":"(ফিরআউন) বললো","audioUrl":"wbw/026_049_001.mp3","charTypeName":"word"},{"id":48096,"position":2,"arabic":"ءَامَنتُمْ","translation":"\"কি তোমরা ঈমান আন