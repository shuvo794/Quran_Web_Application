02.mp3","charTypeName":"word"},{"id":85853,"position":3,"arabic":"فَقُلْ","translation":"তবে বলো","audioUrl":"wbw/026_216_003.mp3","charTypeName":"word"},{"id":85854,"position":4,"arabic":"إِنِّى","translation":"\"নিশ্চয়ই আমি","audioUrl":"wbw/026_216_004.mp3","charTypeName":"word"},{"id":85855,"position":5,"arabic":"بَرِىٓءٌۭ","translation":"দায়মুক্ত","audioUrl":"wbw/026_216_005.mp3","charTypeName":"word"},{"id":85856,"position":6,"arabic":"مِّمَّا","translation":"(তা) হ'তে যা","audioUrl":"wbw/026_216_006.mp3","charTypeName":"word"},{"id":85857,"position":7,"arabic":"تَعْمَلُونَ","translation":"তোমরা কাজ করছো\"","audioUrl":"wbw/026_216_007.mp3","charTypeName":"word"},{"id":85858,"position":8,"arabic":"٢١٦","translation":"(২১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":217,"arabic":"وَتَوَكَّلْ عَلَى ٱلْعَزِيزِ ٱلرَّحِيمِ","translation":"and place thy trust in the Almighty, the Dispenser of Grace,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3149.mp3","surahId":26,"words":[{"id":85924,"position":1,"arabic":"وَتَوَكَّلْ","translation":"এবং নির্ভর করো","audioUrl":"wbw/026_217_001.mp3","charTypeName":"word"},{"id":85925,"position":2,"arabic":"عَلَى","translation":"(আল্লাহর) উপর","audioUrl":"wbw/026_217_002.mp3","charTypeName":"word"},{"id":85926,"position":3,"arabic":"ٱلْعَزِيزِ","translation":"(যিনি) পরাক্রমশালী","audioUrl":"wbw/026_217_003.mp3","charTypeName":"word"},{"id":85927,"position":4,"arabic":"ٱلرَّحِيمِ","translation":"পরম দয়ালু","audioUrl":"wbw/026_217_004.mp3","charTypeName":"word"},{"id":85928,"position":5,"arabic":"٢١٧","translation":"(২১৭)","audioUrl":null,"charTypeName":"end"}]},{"number":218,"arabic":"ٱلَّذِى يَرَىٰكَ حِينَ تَقُومُ","translation":"who sees thee when thou standest [alone],","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3150.mp3","surahId":26,"words":[{"id":85929,"position":1,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/026_218_001.mp3","charTypeName":"word"},{"id":85930,"position":2,"arabic":"يَرَىٰكَ","translation":"তোমাকে দেখছেন","audioUrl":"wbw/026_218_002.mp3","charTypeName":"word"},{"id":85931,"position":3,"arabic":"حِينَ","translation":"যখন","audioUrl":"wbw/026_218_003.mp3","charTypeName":"word"},{"id":85932,"position":4,"arabic":"تَقُومُ","translation":"তুমি দাঁড়াও","audioUrl":"wbw/026_218_004.mp3","charTypeName":"word"},{"id":85933,"position":5,"arabic":"٢١٨","translation":"(২১৮)","audioUrl":null,"charTypeName":"end"}]},{"number":219,"arabic":"وَتَقَلُّبَكَ فِى ٱلسَّٰجِدِينَ","translation":"and [sees] thy behaviour among those who prostrate themselves [before Him]:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3151.mp3","surahId":26,"words":[{"id":85952,"position":1,"arabic":"وَتَقَلُّبَكَ","translation":"তোমার গতিবিধি","audioUrl":"wbw/026_219_001.mp3","charTypeName":"word"},{"id":85953,"position":2,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/026_219_002.mp3","charTypeName":"word"},{"id":85954,"position":3,"arabic":"ٱلسَّـٰجِدِينَ","translation":"সিজদাকারীদের","audioUrl":"wbw/026_219_003.mp3","charTypeName":"word"},{"id":85955,"position":4,"arabic":"٢١٩","translation":"(২১৯)","audioUrl":null,"charTypeName":"end"}]},{"number":220,"arabic":"إِنَّهُۥ هُوَ ٱلسَّمِيعُ ٱلْعَلِيمُ","translation":"for, verily, He alone is all-hearing, all-knowing!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3152.mp3","surahId":26,"words":[{"id":85987,"position":1,"arabic":"إِنَّهُۥ","translation":"নিশ্চয়ই তিনি","audioUrl":"wbw/026_220_001.mp3","charTypeName":"word"},{"id":85988,"position":2,"arabic":"هُوَ","translation":"তিনিই","audioUrl":"wbw/026_220_002.mp3","charTypeName":"word"},{"id":85989,"position":3,"arabic":"ٱلسَّمِيعُ","translation":"সবকিছু শুনেন","audioUrl":"wbw/026_220_003.mp3","charTypeName":"word"},{"id":85990,"position":4,"arabic":"ٱلْعَلِيمُ","translation":"সবকিছু জানেন","audioUrl":"wbw/026_220_004.mp3","charTypeName":"word"},{"id":85991,"position":5,"arabic":"٢٢٠","translation":"(২২০)","au