{"id":376,"ayahs":[{"number":207,"arabic":"مَآ أَغْنَىٰ عَنْهُم مَّا كَانُوا۟ يُمَتَّعُونَ","translation":"of what avail to them will be all their past enjoyments?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3139.mp3","surahId":26,"words":[{"id":85547,"position":1,"arabic":"مَآ","translation":"(তাহ'লেও) কি","audioUrl":"wbw/026_207_001.mp3","charTypeName":"word"},{"id":85548,"position":2,"arabic":"أَغْنَىٰ","translation":"উপকারে আসবে","audioUrl":"wbw/026_207_002.mp3","charTypeName":"word"},{"id":85549,"position":3,"arabic":"عَنْهُم","translation":"জন্যে তাদের","audioUrl":"wbw/026_207_003.mp3","charTypeName":"word"},{"id":85550,"position":4,"arabic":"مَّا","translation":"যা কিছু","audioUrl":"wbw/026_207_004.mp3","charTypeName":"word"},{"id":85551,"position":5,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/026_207_005.mp3","charTypeName":"word"},{"id":85552,"position":6,"arabic":"يُمَتَّعُونَ","translation":"তারা উপভোগ করে","audioUrl":"wbw/026_207_006.mp3","charTypeName":"word"},{"id":85553,"position":7,"arabic":"٢٠٧","translation":"(২০৭)","audioUrl":null,"charTypeName":"end"}]},{"number":208,"arabic":"وَمَآ أَهْلَكْنَا مِن قَرْيَةٍ إِلَّا لَهَا مُنذِرُونَ","translation":"And withal, never have We destroyed any community unless it had been warned","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3140.mp3","surahId":26,"words":[{"id":85584,"position":1,"arabic":"وَمَآ","translation":"আর না","audioUrl":"wbw/026_208_001.mp3","charTypeName":"word"},{"id":85585,"position":2,"arabic":"أَهْلَكْنَا","translation":"আমরা ধ্বংস করেছি","audioUrl":"wbw/026_208_002.mp3","charTypeName":"word"},{"id":85586,"position":3,"arabic":"مِن","translation":"কোনো","audioUrl":"wbw/026_208_003.mp3","charTypeName":"word"},{"id":85587,"position":4,"arabic":"قَرْيَةٍ","translation":"জনপদ","audioUrl":"wbw/026_208_004.mp3","charTypeName":"word"},{"id":85588,"position":5,"arabic":"إِلَّا","translation":"এ ছাড়া (যে)","audioUrl":"wbw/026_208_005.mp3","charTypeName":"word"},{"id":85589,"position":6,"arabic":"لَهَا","translation":"জন্যে তার (এসেছে)","audioUrl":"wbw/026_208_006.mp3","charTypeName":"word"},{"id":85590,"position":7,"arabic":"مُنذِرُونَ","translation":"সতর্ককারীরা","audioUrl":"wbw/026_208_007.mp3","charTypeName":"word"},{"id":85591,"position":8,"arabic":"٢٠٨","translation":"(২০৮)","audioUrl":null,"charTypeName":"end"}]},{"number":209,"arabic":"ذِكْرَىٰ وَمَا كُنَّا ظَٰلِمِينَ","translation":"and reminded: for, never do We wrong [anyone].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3141.mp3","surahId":26,"words":[{"id":85605,"position":1,"arabic":"ذِكْرَىٰ","translation":"উপদেশস্বরূপ","audioUrl":"wbw/026_209_001.mp3","charTypeName":"word"},{"id":85606,"position":2,"arabic":"وَمَا","translation":"আর না","audioUrl":"wbw/026_209_002.mp3","charTypeName":"word"},{"id":85607,"position":3,"arabic":"كُنَّا","translation":"আমরা ছিলাম","audioUrl":"wbw/026_209_003.mp3","charTypeName":"word"},{"id":85608,"position":4,"arabic":"ظَـٰلِمِينَ","translation":"সীমালঙ্ঘনকারী","audioUrl":"wbw/026_209_004.mp3","charTypeName":"word"},{"id":85609,"position":5,"arabic":"٢٠٩","translation":"(২০৯)","audioUrl":null,"charTypeName":"end"}]},{"number":210,"arabic":"وَمَا تَنَزَّلَتْ بِهِ ٱلشَّيَٰطِينُ","translation":"And [this divine writ is such a reminder:] no evil spirits have brought it down:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3142.mp3","surahId":26,"words":[{"id":85629,"position":1,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/026_210_001.mp3","charTypeName":"word"},{"id":85630,"position":2,"arabic":"تَنَزَّلَتْ","translation":"অবতীর্ণ করেছে","audioUrl":"wbw/026_210_002.mp3","charTypeName":"word"},{"id":85631,"position":3,"arabic":"بِهِ","translation":"নিয়ে তা","audioUrl":"wbw/026_210_003.mp3","charTypeName":"word"},{"id":85632,"position":4,"arabic":"ٱلشَّيَـٰطِينُ","translation":"শয়তানরা","audioUrl":"wbw/026_210_004.mp3","charTypeName":"word"},{"id":85633,"position":5,"arabic":"٢١٠","translation":"(২১০)","audioUrl":null,"charTypeName":"end"}]},{"number":211,"arabic":"وَمَا يَنۢبَغِى لَهُمْ وَمَا يَسْتَطِيعُونَ","translation":"for, neither does it suit their ends, nor is it in their power [to impart it to man]:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3143.mp3","surahId":26,"words":[{"id":85656,"position":1,"arabic":"وَمَا","translation":"আর না","audioUrl":"wbw/026_211_001.mp3","charTypeName":"word"},{"id":85657,"position":2,"arabic":"يَنۢبَغِى","translation":"উচিত","audioUrl":"wbw/026_211_002.mp3","charTypeName":"word"},{"id":85658,"position":3,"arabic":"لَهُمْ","translation":"জন্যে তাদের","audioUrl":"wbw/026_211_003.mp3","charTypeName":"word"},{"id":85659,"position":4,"arabic":"وَمَا","translation":"আর না","audioUrl":"wbw/026_211_004.mp3","charTypeName":"word"},{"id":85660,"position":5,"arabic":"يَسْتَطِيعُونَ","translation":"তারা সামর্থ্য রাখে","audioUrl":"wbw/026_211_005.mp3","charTypeName":"word"},{"id":85661,"position":6,"arabic":"٢١١","translation":"(২১১)","audioUrl":null,"charTypeName":"end"}]},{"number":212,"arabic":"إِنَّهُمْ عَنِ ٱلسَّمْعِ لَمَعْزُولُونَ","translation":"verily, [even] from hearing it are they utterly debarred!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3144.mp3","surahId":26,"words":[{"id":85662,"position":1,"arabic":"إِنَّهُمْ","translation":"নিশ্চয়ই তাদেরকে","audioUrl":"wbw/026_212_001.mp3","charTypeName":"word"},{"id":85663,"position":2,"arabic":"عَنِ","translation":"হ'তে","audioUrl":"wbw/026_212_002.mp3","charTypeName":"word"},{"id":85664,"position":3,"arabic":"ٱلسَّمْعِ","translation":"শোনা","audioUrl":"wbw/026_212_003.mp3","charTypeName":"word"},{"id":85665,"position":4,"arabic":"لَمَعْزُولُونَ","translation":"অবশ্যই দূরে রাখা হয়েছে","audioUrl":"wbw/026_212_004.mp3","charTypeName":"word"},{"id":85666,"position":5,"arabic":"٢١٢","translation":"(২১২)","audioUrl":null,"charTypeName":"end"}]},{"number":213,"arabic":"فَلَا تَدْعُ مَعَ ٱللَّهِ إِلَٰهًا ءَاخَرَ فَتَكُونَ مِنَ ٱلْمُعَذَّبِينَ","translation":"Hence, [O man,] do not invoke any other deity side by side with God, lest thou find thyself among those who are made to suffer [on Judgment Day].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3145.mp3","surahId":26,"words":[{"id":85743,"position":1,"arabic":"فَلَا","translation":"অতএব না","audioUrl":"wbw/026_213_001.mp3","charTypeName":"word"},{"id":85744,"position":2,"arabic":"تَدْعُ","translation":"তুমি ডেকো","audioUrl":"wbw/026_213_002.mp3","charTypeName":"word"},{"id":85745,"position":3,"arabic":"مَعَ","translation":"সাথে","audioUrl":"wbw/026_213_003.mp3","charTypeName":"word"},{"id":85746,"position":4,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/026_213_004.mp3","charTypeName":"word"},{"id":85747,"position":5,"arabic":"إِلَـٰهًا","translation":"কোনো ইলাহ","audioUrl":"wbw/026_213_005.mp3","charTypeName":"word"},{"id":85748,"position":6,"arabic":"ءَاخَرَ","translation":"অন্য","audioUrl":"wbw/026_213_006.mp3","charTypeName":"word"},{"id":85749,"position":7,"arabic":"فَتَكُونَ","translation":"তাহ'লে তুমি হবে","audioUrl":"wbw/026_213_007.mp3","charTypeName":"word"},{"id":85750,"position":8,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/026_213_008.mp3","charTypeName":"word"},{"id":85751,"position":9,"arabic":"ٱلْمُعَذَّبِينَ","translation":"শাস্তিপ্রাপ্তদের","audioUrl":"wbw/026_213_009.mp3","charTypeName":"word"},{"id":85752,"position":10,"arabic":"٢١٣","translation":"(২১৩)","audioUrl":null,"charTypeName":"end"}]},{"number":214,"arabic":"وَأَنذِرْ عَشِيرَتَكَ ٱلْأَقْرَبِينَ","translation":"And warn [whomever thou canst reach, beginning with] thy kinsfolk,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3146.mp3","surahId":26,"words":[{"id":85753,"position":1,"arabic":"وَأَنذِرْ","translation":"এবং সতর্ক করো","audioUrl":"wbw/026_214_001.mp3","charTypeName":"word"},{"id":85754,"position":2,"arabic":"عَشِيرَتَكَ","translation":"তোমার আত্মীয় স্বজনদের