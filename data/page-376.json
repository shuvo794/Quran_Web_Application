the valleys [of words and thoughts],","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3157.mp3","surahId":26,"words":[{"id":86177,"position":1,"arabic":"أَلَمْ","translation":"কি নি","audioUrl":"wbw/026_225_001.mp3","charTypeName":"word"},{"id":86178,"position":2,"arabic":"تَرَ","translation":"তুমি দেখো","audioUrl":"wbw/026_225_002.mp3","charTypeName":"word"},{"id":86179,"position":3,"arabic":"أَنَّهُمْ","translation":"যে তারা","audioUrl":"wbw/026_225_003.mp3","charTypeName":"word"},{"id":86180,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/026_225_004.mp3","charTypeName":"word"},{"id":86181,"position":5,"arabic":"كُلِّ","translation":"প্রত্যেক","audioUrl":"wbw/026_225_005.mp3","charTypeName":"word"},{"id":86182,"position":6,"arabic":"وَادٍۢ","translation":"উপত্যকার","audioUrl":"wbw/026_225_006.mp3","charTypeName":"word"},{"id":86183,"position":7,"arabic":"يَهِيمُونَ","translation":"উদভ্রান্ত হয়ে ঘুরছে","audioUrl":"wbw/026_225_007.mp3","charTypeName":"word"},{"id":86184,"position":8,"arabic":"٢٢٥","translation":"(২২৫)","audioUrl":null,"charTypeName":"end"}]},{"number":226,"arabic":"وَأَنَّهُمْ يَقُولُونَ مَا لَا يَفْعَلُونَ","translation":"and that they [so often] say what they do not do [or feel]?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3158.mp3","surahId":26,"words":[{"id":86200,"position":1,"arabic":"وَأَنَّهُمْ","translation":"এবং (এও) যে তারা","audioUrl":"wbw/026_226_001.mp3","charTypeName":"word"},{"id":86201,"position":2,"arabic":"يَقُولُونَ","translation":"বলে (এমন কথা)","audioUrl":"wbw/026_226_002.mp3","charTypeName":"word"},{"id":86202,"position":3,"arabic":"مَا","translation":"যা","audioUrl":"wbw/026_226_003.mp3","charTypeName":"word"},{"id":86203,"position":4,"arabic":"لَا","translation":"না","audioUrl":"wbw/026_226_004.mp3","charTypeName":"word"},{"id":86204,"position":5,"arabic":"يَفْعَلُونَ","translation":"(নিজেরা) তারা করে","audioUrl":"wbw/026_226_005.mp3","charTypeName":"word"},{"id":86205,"position":6,"arabic":"٢٢٦","translation":"(২২৬)","audioUrl":null,"charTypeName":"end"}]},{"number":227,"arabic":"إِلَّا ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ وَذَكَرُوا۟ ٱللَّهَ كَثِيرًۭا وَٱنتَصَرُوا۟ مِنۢ بَعْدِ مَا ظُلِمُوا۟ ۗ وَسَيَعْلَمُ ٱلَّذِينَ ظَلَمُوٓا۟ أَىَّ مُنقَلَبٍۢ يَنقَلِبُونَ","translation":"[Most of them are of this kind] save those who have attained to faith, and do righteous deeds, and remember God unceasingly, and defend them­selves [only] after having been wronged, and [trust in God’s promise that] those who are bent on wrong­doing will in time come to know how evil a turn their destinies are bound to take!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3159.mp3","surahId":26,"words":[{"id":86214,"position":1,"arabic":"إِلَّا","translation":"তবে (ব্যতিক্রম)","audioUrl":"wbw/026_227_001.mp3","charTypeName":"word"},{"id":86215,"position":2,"arabic":"ٱلَّذِينَ","translation":"(তারা) যারা","audioUrl":"wbw/026_227_002.mp3","charTypeName":"word"},{"id":86216,"position":3,"arabic":"ءَامَنُوا۟","translation":"ঈমান আনে","audioUrl":"wbw/026_227_003.mp3","charTypeName":"word"},{"id":86217,"position":4,"arabic":"وَعَمِلُوا۟","translation":"ও কাজ করে","audioUrl":"wbw/026_227_004.mp3","charTypeName":"word"},{"id":86218,"position":5,"arabic":"ٱلصَّـٰلِحَـٰتِ","translation":"সৎ","audioUrl":"wbw/026_227_005.mp3","charTypeName":"word"},{"id":86219,"position":6,"arabic":"وَذَكَرُوا۟","translation":"এবং স্মরণ করে","audioUrl":"wbw/026_227_006.mp3","charTypeName":"word"},{"id":86220,"position":7,"arabic":"ٱللَّهَ","translation":"আল্লাহকে","audioUrl":"wbw/026_227_007.mp3","charTypeName":"word"},{"id":86221,"position":8,"arabic":"كَثِيرًۭا","translation":"বেশী বেশী","audioUrl":"wbw/026_227_008.mp3","charTypeName":"word"},{"id":86222,"position":9,"arabic":"وَٱنتَصَرُوا۟","translation":"এবং প্রতিশোধ নেয়","audioUrl":"wbw/026_227_009.mp3","charTypeName":"word"},{"id":86223,"position":10,"arabic":"مِنۢ","translation":"থেকে","audioUrl":"wbw/026_227_010.mp3","charTypeName":"word"},{"id":86224,"position":11,"arabic":"بَعْدِ","translation":"পর","audioUrl":"wbw/026_227_011.mp3","charTypeName":"word"},{"id":86225,"position":12,"arabic":"مَا","translation":"যা","audioUrl":"wbw/026_227_012.mp3","charTypeName":"word"},{"id":86226,"position":13,"arabic":"ظُلِمُوا۟ ۗ","translation":"তারা নির্যাতিত হ'লে","audioUrl":"wbw/026_227_013.mp3","charTypeName":"word"},{"id":86228,"position":14,"arabic":"وَسَيَعْلَمُ","translation":"এবং শীঘ্রই জানবে","audioUrl":"wbw/026_227_015.mp3","charTypeName":"word"},{"id":86229,"position":15,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/026_227_016.mp3","charTypeName":"word"},{"id":86230,"position":16,"arabic":"ظَلَمُوٓا۟","translation":"নির্যাতন করেছে","audioUrl":"wbw/026_227_017.mp3","charTypeName":"word"},{"id":86231,"position":17,"arabic":"أَىَّ","translation":"কোনো","audioUrl":"wbw/026_227_018.mp3","charTypeName":"word"},{"id":86232,"position":18,"arabic":"مُنقَلَبٍۢ","translation":"প্রত্যাবর্তনস্থলে","audioUrl":"wbw/026_227_019.mp3","charTypeName":"word"},{"id":86233,"position":19,"arabic":"يَنقَلِبُونَ","translation":"তারা প্রত্যাবর্তন করছে","audioUrl":"wbw/026_227_020.mp3","charTypeName":"word"},{"id":86234,"position":20,"arabic":"٢٢٧","translation":"(২২৭)","audioUrl":null,"charTypeName":"end"}]}]}