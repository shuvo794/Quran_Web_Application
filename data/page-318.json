{"id":318,"ayahs":[{"number":88,"arabic":"فَأَخْرَجَ لَهُمْ عِجْلًۭا جَسَدًۭا لَّهُۥ خُوَارٌۭ فَقَالُوا۟ هَٰذَآ إِلَٰهُكُمْ وَإِلَٰهُ مُوسَىٰ فَنَسِىَ","translation":"But then, [so they told Moses, the Samaritan] had produced for them [out of the molten gold] the effigy of a calf, which made a lowing sound; and thereupon they said [to one another], \"This is your deity, and the deity of Moses-but he has forgotten [his past]","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2436.mp3","surahId":20,"words":[{"id":67364,"position":1,"arabic":"فَأَخْرَجَ","translation":"অতঃপর বের করলো","audioUrl":"wbw/020_088_001.mp3","charTypeName":"word"},{"id":67365,"position":2,"arabic":"لَهُمْ","translation":"তাদের জন্য","audioUrl":"wbw/020_088_002.mp3","charTypeName":"word"},{"id":67366,"position":3,"arabic":"عِجْلًۭا","translation":"একটি বাছুর","audioUrl":"wbw/020_088_003.mp3","charTypeName":"word"},{"id":67367,"position":4,"arabic":"جَسَدًۭا","translation":"অবয়ব","audioUrl":"wbw/020_088_004.mp3","charTypeName":"word"},{"id":67368,"position":5,"arabic":"لَّهُۥ","translation":"তার ছিলো","audioUrl":"wbw/020_088_005.mp3","charTypeName":"word"},{"id":67369,"position":6,"arabic":"خُوَارٌۭ","translation":"হাম্বা শব্দ","audioUrl":"wbw/020_088_006.mp3","charTypeName":"word"},{"id":67370,"position":7,"arabic":"فَقَالُوا۟","translation":"তখন তারা বললো","audioUrl":"wbw/020_088_007.mp3","charTypeName":"word"},{"id":67371,"position":8,"arabic":"هَـٰذَآ","translation":"\"এটা","audioUrl":"wbw/020_088_008.mp3","charTypeName":"word"},{"id":67372,"position":9,"arabic":"إِلَـٰهُكُمْ","translation":"তোমাদের উপাস্য","audioUrl":"wbw/020_088_009.mp3","charTypeName":"word"},{"id":67373,"position":10,"arabic":"وَإِلَـٰهُ","translation":"ও উপাস্য","audioUrl":"wbw/020_088_010.mp3","charTypeName":"word"},{"id":67374,"position":11,"arabic":"مُوسَىٰ","translation":"মূসার","audioUrl":"wbw/020_088_011.mp3","charTypeName":"word"},{"id":67375,"position":12,"arabic":"فَنَسِىَ","translation":"(মূসা) আসলে ভুলে গিয়েছিলো\"","audioUrl":"wbw/020_088_012.mp3","charTypeName":"word"},{"id":67376,"position":13,"arabic":"٨٨","translation":"(৮৮)","audioUrl":null,"charTypeName":"end"}]},{"number":89,"arabic":"أَفَلَا يَرَوْنَ أَلَّا يَرْجِعُ إِلَيْهِمْ قَوْلًۭا وَلَا يَمْلِكُ لَهُمْ ضَرًّۭا وَلَا نَفْعًۭا","translation":"Why-did they not see that [the thing] could not give them any response, and had no power to harm or to benefit them?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2437.mp3","surahId":20,"words":[{"id":67545,"position":1,"arabic":"أَفَلَا","translation":"নি কি","audioUrl":"wbw/020_089_001.mp3","charTypeName":"word"},{"id":67546,"position":2,"arabic":"يَرَوْنَ","translation":"তারা (ভেবে) দেখে","audioUrl":"wbw/020_089_002.mp3","charTypeName":"word"},{"id":67547,"position":3,"arabic":"أَلَّا","translation":"যে না","audioUrl":"wbw/020_089_003.mp3","charTypeName":"word"},{"id":67548,"position":4,"arabic":"يَرْجِعُ","translation":"ফিরে আসে","audioUrl":"wbw/020_089_004.mp3","charTypeName":"word"},{"id":67549,"position":5,"arabic":"إِلَيْهِمْ","translation":"তাদের দিকে (অর্থাৎ উত্তর দেয়)","audioUrl":"wbw/020_089_005.mp3","charTypeName":"word"},{"id":67550,"position":6,"arabic":"قَوْلًۭا","translation":"কথার","audioUrl":"wbw/020_089_006.mp3","charTypeName":"word"},{"id":67551,"position":7,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/020_089_007.mp3","charTypeName":"word"},{"id":67552,"position":8,"arabic":"يَمْلِكُ","translation":"ক্ষমতা রাখে","audioUrl":"wbw/020_089_008.mp3","charTypeName":"word"},{"id":67553,"position":9,"arabic":"لَهُمْ","translation":"তাদের জন্যে","audioUrl":"wbw/020_089_009.mp3","charTypeName":"word"},{"id":67554,"position":10,"arabic":"ضَرًّۭا","translation":"ক্ষতি (করতে)","audioUrl":"wbw/020_089_010.mp3","charTypeName":"word"},{"id":67555,"position":11,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/020_089_011.mp3","charTypeName":"word"},{"id":67556,"position":12,"arabic":"نَفْعًۭا","translation":"উপকার (করতে)","audioUrl":"wbw/020_089_012.mp3","charTypeName":"word"},{"id":67557,"position":13,"arabic":"٨٩","translation":"(৮৯)","audioUrl":null,"charTypeName":"end"}]},{"number":90,"arabic":"وَلَقَدْ قَالَ لَهُمْ هَٰرُونُ مِن قَبْلُ يَٰقَوْمِ إِنَّمَا فُتِنتُم بِهِۦ ۖ وَإِنَّ رَبَّكُمُ ٱلرَّحْمَٰنُ فَٱتَّبِعُونِى وَأَطِيعُوٓا۟ أَمْرِى","translation":"And, indeed, even before [the return of Moses] had Aaron said unto them: \"O my people! You are but being tempted to evil by this [idol] -for, behold, your [only] Sustainer is the Most Gracious! Follow me, then, and obey my bidding!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2438.mp3","surahId":20,"words":[{"id":68141,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/020_090_001.mp3","charTypeName":"word"},{"id":68142,"position":2,"arabic":"قَالَ","translation":"বলেছিলো","audioUrl":"wbw/020_090_002.mp3","charTypeName":"word"},{"id":68143,"position":3,"arabic":"لَهُمْ","translation":"তাদেরকে","audioUrl":"wbw/020_090_003.mp3","charTypeName":"word"},{"id":68144,"position":4,"arabic":"هَـٰرُونُ","translation":"হারূন","audioUrl":"wbw/020_090_004.mp3","charTypeName":"word"},{"id":68145,"position":5,"arabic":"مِن","translation":"থেকেই","audioUrl":"wbw/020_090_005.mp3","charTypeName":"word"},{"id":68146,"position":6,"arabic":"قَبْلُ","translation":"পূর্ব","audioUrl":"wbw/020_090_006.mp3","charTypeName":"word"},{"id":68147,"position":7,"arabic":"يَـٰقَوْمِ","translation":"\"হে আমার জাতি","audioUrl":"wbw/020_090_007.mp3","charTypeName":"word"},{"id":68148,"position":8,"arabic":"إِنَّمَا","translation":"মূলত","audioUrl":"wbw/020_090_008.mp3","charTypeName":"word"},{"id":68149,"position":9,"arabic":"فُتِنتُم","translation":"তোমাদের পরীক্ষায় ফেলা হয়েছে","audioUrl":"wbw/020_090_009.mp3","charTypeName":"word"},{"id":68150,"position":10,"arabic":"بِهِۦ ۖ","translation":"তা দ্বারা","audioUrl":"wbw/020_090_010.mp3","charTypeName":"word"},{"id":68152,"position":11,"arabic":"وَإِنَّ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/020_090_012.mp3","charTypeName":"word"},{"id":68153,"position":12,"arabic":"رَبَّكُمُ","translation":"তোমাদের রব","audioUrl":"wbw/020_090_013.mp3","charTypeName":"word"},{"id":68154,"position":13,"arabic":"ٱلرَّحْمَـٰنُ","translation":"দয়াময় (আল্লাহ)","audioUrl":"wbw/020_090_014.mp3","charTypeName":"word"},{"id":68155,"position":14,"arabic":"فَٱتَّبِعُونِى","translation":"সুতরাং তোমরা আমাকে অনুসরণ করো","audioUrl":"wbw/020_090_015.mp3","charTypeName":"word"},{"id":68156,"position":15,"arabic":"وَأَطِيعُوٓا۟","translation":"ও তোমরা আনুগত্য করো","audioUrl":"wbw/020_090_016.mp3","charTypeName":"word"},{"id":68157,"position":16,"arabic":"أَمْرِى","translation":"আমার আদেশের\"","audioUrl":"wbw/020_090_017.mp3","charTypeName":"word"},{"id":68158,"position":17,"arabic":"٩٠","translation":"(৯০)","audioUrl":null,"charTypeName":"end"}]},{"number":91,"arabic":"قَالُوا۟ لَن نَّبْرَحَ عَلَيْهِ عَٰكِفِينَ حَتَّىٰ يَرْجِعَ إِلَيْنَا مُوسَىٰ","translation":"[But] they answered: \"By no means shall we cease to worship it until Moses comes back to us!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2439.mp3","surahId":20,"words":[{"id":68228,"position":1,"arabic":"قَالُوا۟","translation":"তারা বলেছিলো","audioUrl":"wbw/020_091_001.mp3","charTypeName":"word"},{"id":68229,"position":2,"arabic":"لَن","translation":"\"কখনও না","audioUrl":"wbw/020_091_002.mp3","charTypeName":"word"},{"id":68230,"position":3,"arabic":"نَّبْرَحَ","translation":"বিরত হবো আমরা","audioUrl":"wbw/020_091_003.mp3","charTypeName":"word"},{"id":68231,"position":4,"arabic":"عَلَيْهِ","translation":"তার কাছে","audioUrl":"wbw/020_091_004.mp3","charTypeName":"word"},{"id":68232,"position":5,"arabic":"عَـٰكِفِينَ","translation":"লেগে থাকা (বা পূজা করা হ'তে)_","audioUrl":"wbw/020_091_005.mp3","charTypeName":"word"},{"id":68233,"position":6,"arabic":"حَتَّىٰ","translation":"যতক্ষণ না","audioUrl":"wbw/020_091_006.mp3","charTypeName":"word"},{"id":68234,"position":7,"arabic":"يَرْجِعَ","translation":"ফিরে আসবে","audioUrl":"wbw/020_091_007.mp3","charTypeName":"word"},{"id":68235,"position":8,"arabic":"إِلَيْنَا","translation":"আমাদের কাছে","audioUrl":"wbw/020_091_008.mp3","charTypeName":"word"},{"id":68236,"position":9,"arabic":"مُوسَىٰ","translation":"মূসা\"","audioUrl":"wbw/020_091_009.mp3","charTypeName":"word"},{"id":68237,"position":10,"arabic":"٩١","translation":"(৯১)","audioUrl":null,"charTypeName":"end"}]},{"number":92,"arabic":"قَالَ يَٰهَٰرُونُ مَا مَنَعَكَ إِذْ رَأَيْتَهُمْ ضَلُّوٓا۟","translation":"[And now that he had come back, Moses] said: \"O Aaron! What has prevented thee, when thou didst see that they had gone astray,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2440.mp3","surahId":20,"words":[{"id":68930,"position":1,"arabic":"قَالَ","translation":"(মূসা) বললো","audioUrl":"wbw/020_092_001.mp3","charTypeName":"word"},{"id":68931,"position":2,"arabic":"يَـٰهَـٰرُونُ","translation":"\"হে হারূন","audioUrl":"wbw/020_092_002.mp3","charTypeName":"word"},{"id":68932,"position":3,"arabic":"مَا","translation":"কিসে","audioUrl":"wbw/020_092_003.mp3","charTypeName":"word"},{"id":68933,"position":4,"arabic":"مَنَعَكَ","translation":"তোমাকে নিষেধ করলো","audioUrl":"wbw/020_092_004.mp3","charTypeName":"word"},{"id":68934,"position":5,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/020_092_005.mp3","charTypeName":"word"},{"id":68935,"position":6,"arabic":"رَأَيْتَهُمْ","translation":"তাদের তুমি দেখলে","audioUrl":"wbw/020_092_006.mp3","charTypeName":"word"},{"id":68936,"position":7,"arabic":"ضَلُّوٓا۟","translation":"তারা পথভ্রষ্ট হয়েছে","audioUrl":"wbw/020_092_007.mp3","charTypeName":"word"},{"id":68937,"position":8,"arabic":"٩٢","translation":"(৯২)","audioUrl":null,"charTypeName":"end"}]},{"number":93,"arabic":"أَلَّا تَتَّبِعَنِ ۖ أَفَعَصَيْتَ أَمْرِى","translation":"from [abandoning them and] following me? Hast thou, then, [deliberately] disobeyed my commandment?\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2441.mp3","surahId":20,"words":[{"id":69294,"position":1,"arabic":"أَلَّا","translation":"যে না","audioUrl":"wbw/020_093_001.mp3","charTypeName":"word"},{"id":69295,"position":2,"arabic":"تَتَّبِعَنِ ۖ","translation":"আমার (আদেশের) অনুসরণ করলে","audioUrl":"wbw/020_093_002.mp3","charTypeName":"word"},{"id":69297,"position":3,"arabic":"أَفَعَصَيْتَ","translation":"তবে কি তুমি অমান্য করেছো","audioUrl":"wbw/020_093_004.mp3","charTypeName":"word"},{"id":69298,"position":4,"arabic":"أَمْرِى","translation":"আমার আদেশের\"","audioUrl":"wbw/020_093_005.mp3","charTypeName":"word"},{"id":69299,"position":5,"arabic":"٩٣","translation":"(৯৩)","audioUrl":null,"charTypeName":"end"}]},{"number":94,"arabic":"قَالَ يَبْنَؤُمَّ لَا تَأْخُذْ بِلِحْيَتِى وَلَا بِرَأْسِىٓ ۖ إِنِّى خَشِيتُ أَن تَقُولَ فَرَّقْتَ بَيْنَ بَنِىٓ إِسْرَٰٓءِيلَ وَلَمْ تَرْقُبْ قَوْلِى","translation":"Answered [Aaron]: \"O my mother's son! Seize me not by my beard, nor by my head! Behold, I was afraid lest [on thy return] thou say, 'Thou hast caused a split among the children of Israel, and hast paid no heed to my bidding!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2442.mp3","surahId":20,"words":[{"id":69563,"position":1,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/020_094_001.mp3","charTypeName":"word"},{"id":69564,"position":2,"arabic":"يَبْنَؤُمَّ","translation":"\"হে আমার মায়ের ছেলে (অর্থাৎ ভাই)","audioUrl":"wbw/020_094_002.mp3","charTypeName":"word"},{"id":69565,"position":3,"arabic":"لَا","translation":"না","audioUrl":"wbw/020_094_003.mp3","charTypeName":"word"},{"id":69566,"position":4,"arabic":"تَأْخُذْ","translation":"ধরো","audioUrl":"wbw/020_094_004.mp3","charTypeName":"word"},{"id":69567,"position":5,"arabic":"بِلِحْيَتِى","translation":"আমার দাড়ি","audioUrl":"wbw/020_094_005.mp3","charTypeName":"word"},{"id":69568,"position":6,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/020_094_006.mp3","charTypeName":"word"},{"id":69569,"position":7,"arabic":"بِرَأْسِىٓ ۖ","translation":"আমার মাথার (চুল)","audioUrl":"wbw/020_094_007.mp3","charTypeName":"word"},{"id":69571,"position":8,"arabic":"إِنِّى","translation":"নিশ্চয়ই আমি","audioUrl":"wbw/020_094_009.mp3","charTypeName":"word"},{"id":69572,"position":9,"arabic":"خَشِيتُ","translation":"আশঙ্কা করেছি","audioUrl":"wbw/020_094_010.mp3","charTypeName":"word"},{"id":69573,"position":10,"arabic":"أَن","translation":"যে","audioUrl":"wbw/020_094_011.mp3","charTypeName":"word"},{"id":69574,"position":11,"arabic":"تَقُولَ","translation":"বলবে তুমি","audioUrl":"wbw/020_094_012.mp3","charTypeName":"word"},{"id":69575,"position":12,"arabic":"فَرَّقْتَ","translation":"\"তুমি বিভেদ সৃষ্টি করেছো","audioUrl":"wbw/020_094_013.mp3","charTypeName":"word"},{"id":69576,"position":13,"arabic":"بَيْنَ","translation":"মাঝে","audioUrl":"wbw/020_094_014.mp3","charTypeName":"word"},{"id":69577,"position":14,"arabic":"بَنِىٓ","translation":"সন্তানদের","audioUrl":"wbw/020_094_015.mp3","charTypeName":"word"},{"id":69578,"position":15,"arabic":"إِسْرَٰٓءِيلَ","translation":"ইসরাঈলের","audioUrl":"wbw/020_094_016.mp3","charTypeName":"word"},{"id":69579,"position":16,"arabic":"وَلَمْ","translation":"এবং নি","audioUrl":"wbw/020_094_017.mp3","charTypeName":"word"},{"id":69580,"position":17,"arabic":"تَرْقُبْ","translation":"তুমি মূল্য দাও","audioUrl":"wbw/020_094_018.mp3","charTypeName":"word"},{"id":69581,"position":18,"arabic":"قَوْلِى","translation":"আমার কথা\"","audioUrl":"wbw/020_094_019.mp3","charTypeName":"word"},{"id":69582,"position":19,"arabic":"٩٤","translation":"(৯৪)","audioUrl":null,"charTypeName":"end"}]},{"number":95,"arabic":"قَالَ فَمَا خَطْبُكَ يَٰسَٰمِرِىُّ","translation":"Said [Moses]: \"What, then, didst thou have in view, O Samaritan?\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2443.mp3","surahId":20,"words":[{"id":69688,"position":1,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/020_095_001.mp3","charTypeName":"word"},{"id":69689,"position":2,"arabic":"فَمَا","translation":"\"তাহ'লে কি","audioUrl":"wbw/020_095_002.mp3","charTypeName":"word"},{"id":69690,"position":3,"arabic":"خَطْبُكَ","translation":"তোমার ব্যাপার","audioUrl":"wbw/020_095_003.mp3","charTypeName":"word"},{"id":69691,"position":4,"arabic":"يَـٰسَـٰمِرِىُّ","translation":"হে সামেরী\"","audioUrl":"wbw/020_095_004.mp3","charTypeName":"word"},{"id":69692,"position":5,"arabic":"٩٥","translation":"(৯৫)","audioUrl":null,"charTypeName":"end"}]},{"number":96,"arabic":"قَالَ بَصُرْتُ بِمَا لَمْ يَبْصُرُوا۟ بِهِۦ فَقَبَضْتُ قَبْضَةًۭ مِّنْ أَثَرِ ٱلرَّسُولِ فَنَبَذْتُهَا وَكَذَٰلِكَ سَوَّلَتْ لِى نَفْسِى","translation":"He answered: \"I have gained insight into something which they were unable to see: and so I took hold of a handful of the Apostle's teachings and cast it away: for thus has my mind prompted me [to act].\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2444.mp3","surahId":20,"words":[{"id":69971,"position":1,"arabic":"قَالَ","translation":"(সামেরী) বললো","audioUrl":"wbw/020_096_001.mp3","charTypeName":"word"},{"id":69972,"position":2,"arabic":"بَصُرْتُ","translation":"\"আমি দেখেছি","audioUrl":"wbw/020_096_002.mp3","charTypeName":"word"},{"id":69973,"position":3,"arabic":"بِمَا","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/020_096_003.mp3","charTypeName":"word"},{"id":69974,"position":4,"arabic":"لَمْ","translation":"নি","audioUrl":"wbw/020_096_004.mp3","charTypeName":"word"},{"id":69975,"position":5,"arabic":"يَبْصُرُوا۟","translation":"তারা দেখে","audioUrl":"wbw/020_096_005.mp3","charTypeName":"word"},{"id":69976,"position":6,"arabic":"بِهِۦ","translation":"সে সম্পর্কে","audioUrl":"wbw/020_096_006.mp3","charTypeName":"word"},{"id":69977,"position":7,"arabic":"فَقَبَضْتُ","translation":"অতঃপর আমি মুঠিতে নিয়েছি","audioUrl":"wbw/020_096_007.mp3","charTypeName":"word"},{"id":69978,"position":8,"arabic":"قَبْضَةًۭ","translation":"এক মুঠো","audioUrl":"wbw/020_096_008.mp3","charTypeName":"word"},{"id":69979,"pos