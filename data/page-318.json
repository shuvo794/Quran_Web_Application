.mp3","surahId":20,"words":[{"id":70651,"position":1,"arabic":"إِنَّمَآ","translation":"প্রকৃতপক্ষে","audioUrl":"wbw/020_098_001.mp3","charTypeName":"word"},{"id":70652,"position":2,"arabic":"إِلَـٰهُكُمُ","translation":"তোমাদের ইলাহ","audioUrl":"wbw/020_098_002.mp3","charTypeName":"word"},{"id":70653,"position":3,"arabic":"ٱللَّهُ","translation":"একমাত্র আল্লাহ","audioUrl":"wbw/020_098_003.mp3","charTypeName":"word"},{"id":70654,"position":4,"arabic":"ٱلَّذِى","translation":"যিনি (এমন যে)","audioUrl":"wbw/020_098_004.mp3","charTypeName":"word"},{"id":70655,"position":5,"arabic":"لَآ","translation":"নেই","audioUrl":"wbw/020_098_005.mp3","charTypeName":"word"},{"id":70656,"position":6,"arabic":"إِلَـٰهَ","translation":"কোন ইলাহ","audioUrl":"wbw/020_098_006.mp3","charTypeName":"word"},{"id":70657,"position":7,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/020_098_007.mp3","charTypeName":"word"},{"id":70658,"position":8,"arabic":"هُوَ ۚ","translation":"তিনি","audioUrl":"wbw/020_098_008.mp3","charTypeName":"word"},{"id":70660,"position":9,"arabic":"وَسِعَ","translation":"পরিবেষ্টিত","audioUrl":"wbw/020_098_010.mp3","charTypeName":"word"},{"id":70661,"position":10,"arabic":"كُلَّ","translation":"সব","audioUrl":"wbw/020_098_011.mp3","charTypeName":"word"},{"id":70662,"position":11,"arabic":"شَىْءٍ","translation":"কিছু","audioUrl":"wbw/020_098_012.mp3","charTypeName":"word"},{"id":70663,"position":12,"arabic":"عِلْمًۭا","translation":"(তাঁর) জ্ঞানে","audioUrl":"wbw/020_098_013.mp3","charTypeName":"word"},{"id":70664,"position":13,"arabic":"٩٨","translation":"(৯৮)","audioUrl":null,"charTypeName":"end"}]}]}