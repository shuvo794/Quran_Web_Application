ll,"charTypeName":"end"}]},{"number":15,"arabic":"وَٱسْتَفْتَحُوا۟ وَخَابَ كُلُّ جَبَّارٍ عَنِيدٍۢ","translation":"And they prayed [to God] that the truth be made to triumph. And [thus it is:] every arrogant enemy of the truth shall be undone [in the life to come],","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1765.mp3","surahId":14,"words":[{"id":17843,"position":1,"arabic":"وَٱسْتَفْتَحُوا۟","translation":"এবং তারা জয়ী হয়ে চাইলো","audioUrl":"wbw/014_015_001.mp3","charTypeName":"word"},{"id":17844,"position":2,"arabic":"وَخَابَ","translation":"কিন্তু ব্যর্থ হলো","audioUrl":"wbw/014_015_002.mp3","charTypeName":"word"},{"id":17845,"position":3,"arabic":"كُلُّ","translation":"প্রত্যেক","audioUrl":"wbw/014_015_003.mp3","charTypeName":"word"},{"id":17846,"position":4,"arabic":"جَبَّارٍ","translation":"উদ্ধত","audioUrl":"wbw/014_015_004.mp3","charTypeName":"word"},{"id":17847,"position":5,"arabic":"عَنِيدٍۢ","translation":"স্বৈরাচারী (সত্যের দুশমন)","audioUrl":"wbw/014_015_005.mp3","charTypeName":"word"},{"id":17848,"position":6,"arabic":"١٥","translation":"(১৫)","audioUrl":null,"charTypeName":"end"}]},{"number":16,"arabic":"مِّن وَرَآئِهِۦ جَهَنَّمُ وَيُسْقَىٰ مِن مَّآءٍۢ صَدِيدٍۢ","translation":"with hell awaiting him; and he shall be made to drink of the water of most bitter distress,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1766.mp3","surahId":14,"words":[{"id":18890,"position":1,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/014_016_001.mp3","charTypeName":"word"},{"id":18891,"position":2,"arabic":"وَرَآئِهِۦ","translation":"তার পিছন (রয়েছে)","audioUrl":"wbw/014_016_002.mp3","charTypeName":"word"},{"id":18892,"position":3,"arabic":"جَهَنَّمُ","translation":"জাহান্নাম","audioUrl":"wbw/014_016_003.mp3","charTypeName":"word"},{"id":18893,"position":4,"arabic":"وَيُسْقَىٰ","translation":"এবং পান করানো হবে","audioUrl":"wbw/014_016_004.mp3","charTypeName":"word"},{"id":18894,"position":5,"arabic":"مِن","translation":"থেক