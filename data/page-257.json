"wbw/014_017_009.mp3","charTypeName":"word"},{"id":20006,"position":10,"arabic":"وَمَا","translation":"কিন্তু না","audioUrl":"wbw/014_017_010.mp3","charTypeName":"word"},{"id":20007,"position":11,"arabic":"هُوَ","translation":"সে (হবে)","audioUrl":"wbw/014_017_011.mp3","charTypeName":"word"},{"id":20008,"position":12,"arabic":"بِمَيِّتٍۢ ۖ","translation":"মৃত","audioUrl":"wbw/014_017_012.mp3","charTypeName":"word"},{"id":20010,"position":13,"arabic":"وَمِن","translation":"এবং থেকে","audioUrl":"wbw/014_017_014.mp3","charTypeName":"word"},{"id":20011,"position":14,"arabic":"وَرَآئِهِۦ","translation":"তার পিছন","audioUrl":"wbw/014_017_015.mp3","charTypeName":"word"},{"id":20012,"position":15,"arabic":"عَذَابٌ","translation":"শাস্তি","audioUrl":"wbw/014_017_016.mp3","charTypeName":"word"},{"id":20013,"position":16,"arabic":"غَلِيظٌۭ","translation":"কঠোর","audioUrl":"wbw/014_017_017.mp3","charTypeName":"word"},{"id":20014,"position":17,"arabic":"١٧","translation":"(১৭)","audioUrl":null,"charTypeName":"end"}]},{"number":18,"arabic":"مَّثَلُ ٱلَّذِينَ كَفَرُوا۟ بِرَبِّهِمْ ۖ أَعْمَٰلُهُمْ كَرَمَادٍ ٱشْتَدَّتْ بِهِ ٱلرِّيحُ فِى يَوْمٍ عَاصِفٍۢ ۖ لَّا يَقْدِرُونَ مِمَّا كَسَبُوا۟ عَلَىٰ شَىْءٍۢ ۚ ذَٰلِكَ هُوَ ٱلضَّلَٰلُ ٱلْبَعِيدُ","translation":"[This, then, is] the parable of those who are bent on denying their Sustainer: all their works are as ashes which the wind blows about fiercely on a stormy day: [in the life to come,] they cannot achieve any benefit whatever from all [the good] that they may have wrought: for this [denial of God] is indeed the farthest one can go astray.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1768.mp3","surahId":14,"words":[{"id":21016,"position":1,"arabic":"مَّثَلُ","translation":"দৃষ্টান্ত","audioUrl":"wbw/014_018_001.mp3","charTypeName":"word"},{"id":21017,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা (তাদের)","audioUrl":"wbw/014_018_002.mp3","charTypeName":"word"},{"id":21018,"position":3,"arabic":"كَفَرُوا۟","