{"id":257,"ayahs":[{"number":11,"arabic":"قَالَتْ لَهُمْ رُسُلُهُمْ إِن نَّحْنُ إِلَّا بَشَرٌۭ مِّثْلُكُمْ وَلَٰكِنَّ ٱللَّهَ يَمُنُّ عَلَىٰ مَن يَشَآءُ مِنْ عِبَادِهِۦ ۖ وَمَا كَانَ لَنَآ أَن نَّأْتِيَكُم بِسُلْطَٰنٍ إِلَّا بِإِذْنِ ٱللَّهِ ۚ وَعَلَى ٱللَّهِ فَلْيَتَوَكَّلِ ٱلْمُؤْمِنُونَ","translation":"Their apostles answered them: \"True, we are nothing but mortal men like yourselves: but God bestows His favour upon whomever He wills of His servants. Withal, it is not within our power to bring you a proof [of our mission], unless it be by God's leave-and [so] it is in God that all believers must place their trust.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1761.mp3","surahId":14,"words":[{"id":13215,"position":1,"arabic":"قَالَتْ","translation":"বলেছিলো","audioUrl":"wbw/014_011_001.mp3","charTypeName":"word"},{"id":13216,"position":2,"arabic":"لَهُمْ","translation":"তাদেরকে","audioUrl":"wbw/014_011_002.mp3","charTypeName":"word"},{"id":13217,"position":3,"arabic":"رُسُلُهُمْ","translation":"তাদের রাসূলরা","audioUrl":"wbw/014_011_003.mp3","charTypeName":"word"},{"id":13218,"position":4,"arabic":"إِن","translation":"\"নই","audioUrl":"wbw/014_011_004.mp3","charTypeName":"word"},{"id":13219,"position":5,"arabic":"نَّحْنُ","translation":"আমরা","audioUrl":"wbw/014_011_005.mp3","charTypeName":"word"},{"id":13220,"position":6,"arabic":"إِلَّا","translation":"ব্যতীত","audioUrl":"wbw/014_011_006.mp3","charTypeName":"word"},{"id":13221,"position":7,"arabic":"بَشَرٌۭ","translation":"মানুষ","audioUrl":"wbw/014_011_007.mp3","charTypeName":"word"},{"id":13222,"position":8,"arabic":"مِّثْلُكُمْ","translation":"তোমাদের মতো","audioUrl":"wbw/014_011_008.mp3","charTypeName":"word"},{"id":13223,"position":9,"arabic":"وَلَـٰكِنَّ","translation":"কিন্তু","audioUrl":"wbw/014_011_009.mp3","charTypeName":"word"},{"id":13224,"position":10,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/014_011_010.mp3","charTypeName":"word"},{"id":13225,"position":11,"ara