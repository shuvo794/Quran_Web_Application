abic":"وَقَالَ","translation":"এবং বলেছিলো","audioUrl":"wbw/014_013_001.mp3","charTypeName":"word"},{"id":15616,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/014_013_002.mp3","charTypeName":"word"},{"id":15617,"position":3,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করেছিলো","audioUrl":"wbw/014_013_003.mp3","charTypeName":"word"},{"id":15618,"position":4,"arabic":"لِرُسُلِهِمْ","translation":"তাদের রাসূলদের","audioUrl":"wbw/014_013_004.mp3","charTypeName":"word"},{"id":15619,"position":5,"arabic":"لَنُخْرِجَنَّكُم","translation":"তোমাদের অবশ্যই বের করবোই","audioUrl":"wbw/014_013_005.mp3","charTypeName":"word"},{"id":15620,"position":6,"arabic":"مِّنْ","translation":"থেকে","audioUrl":"wbw/014_013_006.mp3","charTypeName":"word"},{"id":15621,"position":7,"arabic":"أَرْضِنَآ","translation":"আমাদের দেশ","audioUrl":"wbw/014_013_007.mp3","charTypeName":"word"},{"id":15622,"position":8,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/014_013_008.mp3","charTypeName":"word"},{"id":15623,"position":9,"arabic":"لَتَعُودُنَّ","translation":"তোমরা অবশ্যই ফিরে আসবে","audioUrl":"wbw/014_013_009.mp3","charTypeName":"word"},{"id":15624,"position":10,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/014_013_010.mp3","charTypeName":"word"},{"id":15625,"position":11,"arabic":"مِلَّتِنَا ۖ","translation":"আমাদের ধর্মমতে\"","audioUrl":"wbw/014_013_011.mp3","charTypeName":"word"},{"id":15627,"position":12,"arabic":"فَأَوْحَىٰٓ","translation":"অতঃপর ওহী করলেন","audioUrl":"wbw/014_013_013.mp3","charTypeName":"word"},{"id":15628,"position":13,"arabic":"إِلَيْهِمْ","translation":"তাদের প্রতি","audioUrl":"wbw/014_013_014.mp3","charTypeName":"word"},{"id":15629,"position":14,"arabic":"رَبُّهُمْ","translation":"তাদের রব","audioUrl":"wbw/014_013_015.mp3","charTypeName":"word"},{"id":15630,"position":15,"arabic":"لَنُهْلِكَنَّ","translation":"\"আমরা অবশ্যই ধ্বংস করবোই","audioUrl":"wbw/014_013_016.mp3","charTypeName":"word"},{"id":15631,"position":16,"arabic":"ٱلظَّ