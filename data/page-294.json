{"id":294,"ayahs":[{"number":5,"arabic":"مَّا لَهُم بِهِۦ مِنْ عِلْمٍۢ وَلَا لِءَابَآئِهِمْ ۚ كَبُرَتْ كَلِمَةًۭ تَخْرُجُ مِنْ أَفْوَٰهِهِمْ ۚ إِن يَقُولُونَ إِلَّا كَذِبًۭا","translation":"No knowledge whatever have they of Him, and neither had their forefathers: dreadful -is this saying that comes out of their mouths, [and] nothing but falsehood do they utter!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2145.mp3","surahId":18,"words":[{"id":4719,"position":1,"arabic":"مَّا","translation":"নেই","audioUrl":"wbw/018_005_001.mp3","charTypeName":"word"},{"id":4720,"position":2,"arabic":"لَهُم","translation":"কাছে তাদের","audioUrl":"wbw/018_005_002.mp3","charTypeName":"word"},{"id":4721,"position":3,"arabic":"بِهِۦ","translation":"সম্পর্কে সে","audioUrl":"wbw/018_005_003.mp3","charTypeName":"word"},{"id":4722,"position":4,"arabic":"مِنْ","translation":"কোনো","audioUrl":"wbw/018_005_004.mp3","charTypeName":"word"},{"id":4723,"position":5,"arabic":"عِلْمٍۢ","translation":"জ্ঞান","audioUrl":"wbw/018_005_005.mp3","charTypeName":"word"},{"id":4724,"position":6,"arabic":"وَلَا","translation":"এবং না (আছে)","audioUrl":"wbw/018_005_006.mp3","charTypeName":"word"},{"id":4725,"position":7,"arabic":"لِـَٔابَآئِهِمْ ۚ","translation":"কাছে পিতৃপুরুষদের তাদের","audioUrl":"wbw/018_005_007.mp3","charTypeName":"word"},{"id":4727,"position":8,"arabic":"كَبُرَتْ","translation":"সাংঘাতিক","audioUrl":"wbw/018_005_009.mp3","charTypeName":"word"},{"id":4728,"position":9,"arabic":"كَلِمَةًۭ","translation":"কথা","audioUrl":"wbw/018_005_010.mp3","charTypeName":"word"},{"id":4729,"position":10,"arabic":"تَخْرُجُ","translation":"তা বের হয়","audioUrl":"wbw/018_005_011.mp3","charTypeName":"word"},{"id":4730,"position":11,"arabic":"مِنْ","translation":"থেকে","audioUrl":"wbw/018_005_012.mp3","charTypeName":"word"},{"id":4731,"position":12,"arabic":"أَفْوَٰهِهِمْ ۚ","translation":"মুখগুলোর তাদের","audioUrl":"wbw/018_005_013.mp3","charTypeName":"word"},{"id":4733,"position":13,"arabic":"إِن","translation":"না","audioUrl":"wbw/018_005_015.mp3","charTypeName":"word"},{"id":4734,"position":14,"arabic":"يَقُولُونَ","translation":"তারা বলে","audioUrl":"wbw/018_005_016.mp3","charTypeName":"word"},{"id":4735,"position":15,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/018_005_017.mp3","charTypeName":"word"},{"id":4736,"position":16,"arabic":"كَذِبًۭا","translation":"মিথ্যা","audioUrl":"wbw/018_005_018.mp3","charTypeName":"word"},{"id":4737,"position":17,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"فَلَعَلَّكَ بَٰخِعٌۭ نَّفْسَكَ عَلَىٰٓ ءَاثَٰرِهِمْ إِن لَّمْ يُؤْمِنُوا۟ بِهَٰذَا ٱلْحَدِيثِ أَسَفًا","translation":"But wouldst thou, perhaps, torment thyself to death with grief over them if they are not willing to believe in this message?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2146.mp3","surahId":18,"words":[{"id":5987,"position":1,"arabic":"فَلَعَلَّكَ","translation":"তবে তুমি সম্ভবতঃ","audioUrl":"wbw/018_006_001.mp3","charTypeName":"word"},{"id":5988,"position":2,"arabic":"بَـٰخِعٌۭ","translation":"বিনাশকারী হবে","audioUrl":"wbw/018_006_002.mp3","charTypeName":"word"},{"id":5989,"position":3,"arabic":"نَّفْسَكَ","translation":"তোমার প্রাণ","audioUrl":"wbw/018_006_003.mp3","charTypeName":"word"},{"id":5990,"position":4,"arabic":"عَلَىٰٓ","translation":"থেকে থেকে","audioUrl":"wbw/018_006_004.mp3","charTypeName":"word"},{"id":5991,"position":5,"arabic":"ءَاثَـٰرِهِمْ","translation":"পিছনে তাদের","audioUrl":"wbw/018_006_005.mp3","charTypeName":"word"},{"id":5992,"position":6,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/018_006_006.mp3","charTypeName":"word"},{"id":5993,"position":7,"arabic":"لَّمْ","translation":"না","audioUrl":"wbw/018_006_007.mp3","charTypeName":"word"},{"id":5994,"position":8,"arabic":"يُؤْمِنُوا۟","translation":"তারা ঈমান আনে","audioUrl":"wbw/018_006_008.mp3","charTypeName":"word"},{"id":5995,"position":9,"arabic":"بِهَـٰذَا","translation":"উপর এই","audioUrl":"wbw/018_006_009.mp3","charTypeName":"word"},{"id":5996,"position":10,"arabic":"ٱلْحَدِيثِ","translation":"কথার","audioUrl":"wbw/018_006_010.mp3","charTypeName":"word"},{"id":5997,"position":11,"arabic":"أَسَفًا","translation":"দুঃখে","audioUrl":"wbw/018_006_011.mp3","charTypeName":"word"},{"id":5998,"position":12,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"إِنَّا جَعَلْنَا مَا عَلَى ٱلْأَرْضِ زِينَةًۭ لَّهَا لِنَبْلُوَهُمْ أَيُّهُمْ أَحْسَنُ عَمَلًۭا","translation":"Behold, We have willed that all beauty on earth be a means by which We put men to a test, [showing] which of them are best in conduct;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2147.mp3","surahId":18,"words":[{"id":7301,"position":1,"arabic":"إِنَّا","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/018_007_001.mp3","charTypeName":"word"},{"id":7302,"position":2,"arabic":"جَعَلْنَا","translation":"আমরা বানিয়েছি","audioUrl":"wbw/018_007_002.mp3","charTypeName":"word"},{"id":7303,"position":3,"arabic":"مَا","translation":"যা (আছে)","audioUrl":"wbw/018_007_003.mp3","charTypeName":"word"},{"id":7304,"position":4,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/018_007_004.mp3","charTypeName":"word"},{"id":7305,"position":5,"arabic":"ٱلْأَرْضِ","translation":"জমিনের","audioUrl":"wbw/018_007_005.mp3","charTypeName":"word"},{"id":7306,"position":6,"arabic":"زِينَةًۭ","translation":"শোভা","audioUrl":"wbw/018_007_006.mp3","charTypeName":"word"},{"id":7307,"position":7,"arabic":"لَّهَا","translation":"জন্যে তার","audioUrl":"wbw/018_007_007.mp3","charTypeName":"word"},{"id":7308,"position":8,"arabic":"لِنَبْلُوَهُمْ","translation":"যাতে পরীক্ষা করি আমরা তাদেরকে","audioUrl":"wbw/018_007_008.mp3","charTypeName":"word"},{"id":7309,"position":9,"arabic":"أَيُّهُمْ","translation":"কে মধ্যে তাদের","audioUrl":"wbw/018_007_009.mp3","charTypeName":"word"},{"id":7310,"position":10,"arabic":"أَحْسَنُ","translation":"উত্তম","audioUrl":"wbw/018_007_010.mp3","charTypeName":"word"},{"id":7311,"position":11,"arabic":"عَمَلًۭا","translation":"কাজে","audioUrl":"wbw/018_007_011.mp3","charTypeName":"word"},{"id":7312,"position":12,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"وَإِنَّا لَجَٰعِلُونَ مَا عَلَيْهَا صَعِيدًۭا جُرُزًا","translation":"and, verily, [in time] We shall reduce all that is on it to barren dust!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2148.mp3","surahId":18,"words":[{"id":8571,"position":1,"arabic":"وَإِنَّا","translation":"এবং নিশ্চয়ই আমরা","audioUrl":"wbw/018_008_001.mp3","charTypeName":"word"},{"id":8572,"position":2,"arabic":"لَجَـٰعِلُونَ","translation":"অবশ্যই পরিণতকারী","audioUrl":"wbw/018_008_002.mp3","charTypeName":"word"},{"id":8573,"position":3,"arabic":"مَا","translation":"যা আছে","audioUrl":"wbw/018_008_003.mp3","charTypeName":"word"},{"id":8574,"position":4,"arabic":"عَلَيْهَا","translation":"উপর তার","audioUrl":"wbw/018_008_004.mp3","charTypeName":"word"},{"id":8575,"position":5,"arabic":"صَعِيدًۭا","translation":"ভূমি","audioUrl":"wbw/018_008_005.mp3","charTypeName":"word"},{"id":8576,"position":6,"arabic":"جُرُزًا","translation":"বিরান","audioUrl":"wbw/018_008_006.mp3","charTypeName":"word"},{"id":8577,"position":7,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"أَمْ حَسِبْتَ أَنَّ أَصْحَٰبَ ٱلْكَهْفِ وَٱلرَّقِيمِ كَانُوا۟ مِنْ ءَايَٰتِنَا عَجَبًا","translation":"[AND SINCE the life of this world is but a test, dost thou [really] think that [the parable of] the Men of the Cave and of [their devotion to] the scriptures could be deemed more wondrous than any [other] of Our messages?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2149.mp3","surahId":18,"words":[{"id":9785,"position":1,"arabic":"أَمْ","translation":"কি","audioUrl":"wbw/018_009_001.mp3","charTypeName":"word"},{"id":9786,"position":2,"arabic":"حَسِبْتَ","translation":"তুমি মনে করেছো","audioUrl":"wbw/018_009_002.mp3","charTypeName":"word"},{"id":9787,"position":3,"arabic":"أَنَّ","translation":"যে","audioUrl":"wbw/018_009_003.mp3","charTypeName":"word"},{"id":9788,"position":4,"arabic":"أَصْحَـٰبَ","translation":"অধিবাসীরা","audioUrl":"wbw/018_009_004.mp3","charTypeName":"word"},{"id":9789,"position":5,"arabic":"ٱلْكَهْفِ","translation":"গুহার","audioUrl":"wbw/018_009_005.mp3","charTypeName":"word"},{"id":9790,"position":6,"arabic":"وَٱلرَّقِيمِ","translation":"ও রাকীমের","audioUrl":"wbw/018_009_006.mp3","charTypeName":"word"},{"id":9791,"position":7,"arabic":"كَانُوا۟","translation":"ছিলো","audioUrl":"wbw/018_009_007.mp3","charTypeName":"word"},{"id":9792,"position":8,"arabic":"مِنْ","translation":"মধ্য থেকে","audioUrl":"wbw/018_009_008.mp3","charTypeName":"word"},{"id":9793,"position":9,"arabic":"ءَايَـٰتِنَا","translation":"আমাদের নিদর্শনগুলোর","audioUrl":"wbw/018_009_009.mp3","charTypeName":"word"},{"id":9794,"position":10,"arabic":"عَجَبًا","translation":"আশ্চর্যজনক","audioUrl":"wbw/018_009_010.mp3","charTypeName":"word"},{"id":9795,"position":11,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"إِذْ أَوَى ٱلْفِتْيَةُ إِلَى ٱلْكَهْفِ فَقَالُوا۟ رَبَّنَآ ءَاتِنَا مِن لَّدُنكَ رَحْمَةًۭ وَهَيِّئْ لَنَا مِنْ أَمْرِنَا رَشَدًۭا","translation":"When those youths took refuge in the cave, they prayed: \"O our Sustainer! Bestow on us grace from Thyself, and endow us, whatever our [outward] condition, with consciousness of what is right!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2150.mp3","surahId":18,"words":[{"id":10929,"position":1,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/018_010_001.mp3","charTypeName":"word"},{"id":10930,"position":2,"arabic":"أَوَى","translation":"আশ্রয় নিয়েছিলো","audioUrl":"wbw/018_010_002.mp3","charTypeName":"word"},{"id":10931,"position":3,"arabic":"ٱلْفِتْيَةُ","translation":"যুবকরা","audioUrl":"wbw/018_010_003.mp3","charTypeName":"word"},{"id":10932,"position":4,"arabic":"إِلَى","translation":"মধ্যে","audioUrl":"wbw/018_010_004.mp3","charTypeName":"word"},{"id":10933,"position":5,"arabic":"ٱلْكَهْفِ","translation":"গুহার","audioUrl":"wbw/018_010_005.mp3","charTypeName":"word"},{"id":10934,"position":6,"arabic":"فَقَالُوا۟","translation":"তখন তারা বলেছিলো","audioUrl":"wbw/018_010_006.mp3","charTypeName":"word"},{"id":10935,"position":7,"arabic":"رَبَّنَآ","translation":"\"হে আমাদের রব","audioUrl":"wbw/018_010_007.mp3","charTypeName":"word"},{"id":10936,"position":8,"arabic":"ءَاتِنَا","translation":"আমাদের দাও","audioUrl":"wbw/018_010_008.mp3","charTypeName":"word"},{"id":10937,"position":9,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/018_010_009.mp3","charTypeName":"word"},{"id":10938,"position":10,"arabic":"لَّدُنكَ","translation":"তোমার পক্ষ","audioUrl":"wbw/018_010_010.mp3","charTypeName":"word"},{"id":10939,"position":11,"arabic":"رَحْمَةًۭ","translation":"অনুগ্রহ","audioUrl":"wbw/018_010_011.mp3","charTypeName":"word"},{"id":10940,"position":12,"arabic":"وَهَيِّئْ","translation":"এবং ব্যবস্হা করে দাও","audioUrl":"wbw/018_010_012.mp3","charTypeName":"word"},{"id":10941,"position":13,"arabic":"لَنَا","translation":"জন্যে আমাদের","audioUrl":"wbw/018_010_013.mp3","charTypeName":"word"},{"id":10942,"position":14,"arabic":"مِنْ","translation":"থেকে","audioUrl":"wbw/018_010_014.mp3","charTypeName":"word"},{"id":10943,"position":15,"arabic":"أَمْرِنَا","translation":"আমাদের কাজ","audioUrl":"wbw/018_010_015.mp3","charTypeName":"word"},{"id":10944,"position":16,"arabic":"رَشَدًۭا","translation":"সুষ্ঠ ভাবে\"","audioUrl":"wbw/018_010_016.mp3","charTypeName":"word"},{"id":10945,"position":17,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"فَضَرَبْنَا عَلَىٰٓ ءَاذَانِهِمْ فِى ٱلْكَهْفِ سِنِينَ عَدَدًۭا","translation":"And thereupon We veiled their ears in the cave for many a year,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2151.mp3","surahId":18,"words":[{"id":12247,"position":1,"arabic":"فَضَرَبْنَا","translation":"অতঃপর আমরা (ঘুমের পর্দা) দিলাম","audioUrl":"wbw/018_011_001.mp3","charTypeName":"word"},{"id":12248,"position":2,"arabic":"عَلَىٰٓ","translation":"উপর","audioUrl":"wbw/018_011_002.mp3","charTypeName":"word"},{"id":12249,"position":3,"arabic":"ءَاذَانِهِمْ","translation":"কানগুলোর তাদের","audioUrl":"wbw/018_011_003.mp3","charTypeName":"word"},{"id":12250,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/018_011_004.mp3","charTypeName":"word"},{"id":12251,"position":5,"arabic":"ٱلْكَهْفِ","translation":"গুহার","audioUrl":"wbw/018_011_005.mp3","charTypeName":"word"},{"id":12252,"position":6,"arabic":"سِنِينَ","translation":"বছর","audioUrl":"wbw/018_011_006.mp3","charTypeName":"word"},{"id":12253,"position":7,"arabic":"عَدَدًۭا","translation":"কয়েক","audioUrl":"wbw/018_011_007.mp3","charTypeName":"word"},{"id":12254,"position":8,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]},{"number":12,"arabic":"ثُمَّ بَعَثْنَٰهُمْ لِنَعْلَمَ أَىُّ ٱلْحِزْبَيْنِ أَحْصَىٰ لِمَا لَبِثُوٓا۟ أَمَدًۭا","translation":"and then We awakened Christianity was no longer persecuted and had even become the official religion of the Roman Empire. The ancient coin (dating from the reign of Decius) with which the young man wanted to pay for his purchases immediately aroused curiosity; people began to question the stranger, and the story of the Men of the Cave and their miraculous sleep came to light. them: [and We did all this] so that We might mark out [to the world] which of the two points of view showed a better comprehension of the time-span during which they had remained in this state.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2152.mp3","surahId":18,"words":[{"id":13593,"position":1,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/018_012_001.mp3","charTypeName":"word"},{"id":13594,"position":2,"arabic":"بَعَثْنَـٰهُمْ","translation":"আমরা জাগালাম তাদের","audioUrl":"wbw/018_012_002.mp3","charTypeName":"word"},{"id":13595,"position":3,"arabic":"لِنَعْلَمَ","translation":"যেন আমরা জানি","audioUrl":"wbw/018_012_003.mp3","charTypeName":"word"},{"id":13596,"position":4,"arabic":"أَىُّ","translation":"কোনটি","audioUrl":"wbw/018_012_004.mp3","charTypeName":"word"},{"id":13597,"position":5,"arabic":"ٱلْحِزْبَيْنِ","translation":"দু'দলের","audioUrl":"wbw/018_012_005.mp3","charTypeName":"word"},{"id":13598,"position":6,"arabic":"أَحْصَىٰ","translation":"হিসাব করেছিলো (সঠিক)","audioUrl":"wbw/018_012_006.mp3","charTypeName":"word"},{"id":13599,"position":7,"arabic":"لِمَا","translation":"জন্যে যা","audioUrl":"wbw/018_012_007.mp3","charTypeName":"word"},{"id":13600,"position":8,"arabic":"لَبِثُوٓا۟","translation":"তারা অবস্থান করেছিলো","audioUrl":"wbw/018_012_008.mp3","charTypeName":"word"},{"id":13601,"position":9,"arabic":"أَمَدًۭا","translation":"সময়কাল","audioUrl":"wbw/018_012_009.mp3","charTypeName":"word"},{"id":13602,"position":10,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]},{"number":13,"arabic":"نَّحْنُ نَقُصُّ عَلَيْكَ نَبَأَهُم بِٱلْحَقِّ ۚ إِنَّهُمْ فِتْيَةٌ ءَامَنُوا۟ بِرَبِّهِمْ وَزِدْنَٰهُمْ هُدًۭى","translation":"[And now] We shall truly relate to thee their story: Behold, they were young men who had attained to faith in their Sustainer: and [so] We deepened their consciousness of the right way","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2153.mp3","surahId":18,"words":[{"id":14789,"position":1,"arabic":"نَّحْنُ","translation":"আমরা","audioUrl":"wbw/018_013_001.mp3","charTypeName":"word"},{"id":14790,"position":2,"arabic":"نَقُصُّ","translation":"বর্ণনা করছি","audioUrl":"wbw/018_013_002.mp3","charTypeName":"word"},{"id":14791,"position":3,"arabic":"عَلَيْكَ","translation":"কাছে তোমার","audioUrl":"wbw/018_013_003.mp3","charTypeName":"word"},{"id":14792,"position":4,"arabic":"نَبَأَهُم","translation":"খবর তাদের","audioUrl":"wbw/018_013_004.mp3","charTypeName":"word"},{"id":14793,"position":5,"arabic":"بِٱلْحَقِّ ۚ","translation":"ভাবে সঠিক","audioUrl":"wbw/018_013_005.mp3","charTypeName":"word"},{"id":14795,"position":6,"arabic":"إِنَّهُمْ","translation":"নিশ্চয়ই তারা","audioUrl":"wbw/018_013_007.mp3","charTypeName":"word"},{"id":14796,"position":7,"arabic":"فِتْيَةٌ","translation":"যুবক (ছিলো)","audioUrl":"wbw/018_013_008.mp3","charTypeName":"word"},{"id":14797,"position":8,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছিলো","audioUrl":"wbw/018_013_009.mp3","charTypeName":"word"},{"id":14798,"position":9,"arabic":"بِرَبِّهِمْ","translation":"উপর রবের তাদের","audioUrl":"wbw/018_013_010.mp3","charTypeName":"word"},{"id":14799,"position":10,"arabic":"وَزِدْنَـٰهُمْ","translation":"এবং আমরা বাড়িয়ে দিয়েছিলাম তাদের","audioUrl":"wbw/018_013_011.mp3","charTypeName":"word"},{"id":14800,"position":11,"arabic":"هُدًۭى","translation":"পথের দিশা","audioUrl":"wbw/018_013_012.mp3","charTypeName":"word"},{"id":14801,"position":12,"arabic":"١٣","translation":"(১৩)","audioUrl":null,"charTypeName":"end"}]},{"number":14,"arabic":"وَرَبَطْنَا عَلَىٰ قُلُوبِهِمْ إِذْ قَامُوا۟ فَقَالُوا۟ رَبُّنَا رَبُّ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ لَن نَّدْعُوَا۟ مِن دُونِهِۦٓ إِلَٰهًۭا ۖ لَّقَدْ قُلْنَآ إِذًۭا شَطَطًا","translation":"and endowed their hearts with strength, so that they stood up and said [to one another]: \"Our Sustainer is the Sustainer of the heavens and the earth. Never shall we invoke any deity other than Him: [if we did,] we should indeed have uttered an enormity!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2154.mp3","surahId":18,"words":[{"id":15859,"position":1,"arabic":"وَرَبَطْنَا","translation":"এবং আমরা দৃঢ় করেছিলাম","audioUrl":"wbw/018_014_001.mp3","charTypeName":"word"},{"id":15860,"position":2,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/018_014_002.mp3","charTypeName":"word"},{"id":15861,"position":3,"arabic":"قُلُوبِهِمْ","translation":"অন্তরগুলো তাদের","audioUrl":"wbw/018_014_003.mp3","charTypeName":"word"},{"id":15862,"position":4,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/018_014_004.mp3","charTypeName":"word"},{"id":15863,"position":5,"arabic":"قَامُوا۟","translation":"তারা দাঁড়িয়েছিলো","audioUrl":"wbw/018_014_005.mp3","charTypeName":"word"},{"id":15864,"position":6,"arabic":"فَقَالُوا۟","translation":"তখন তারা বলেছিলো","audioUrl":"wbw/018_014_006.mp3","charTypeName":"word"},{"id":15865,"position":7,"arabic":"رَبُّنَا","translation":"\"আমাদের রব","audioUrl":"wbw/018_014_007.mp3","charTypeName":"word"},{"id":15866,"position":8,"arabic":"رَبُّ","translation":"রব","audioUrl":"wbw/018_014_008.mp3","charTypeName":"word"},{"id":15867,"position":9,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশসমূহের","audioUrl":"wbw/018_014_009.mp3","charTypeName":"word"},{"id":15868,"position":10,"arabic":"وَٱلْأَرْضِ","translation":"এবং পৃথিবীর","audioUrl":"wbw/018_014_010.mp3","charTypeName":"word"},{"id":15869,"position":11,"arabic":"لَن","translation":"কখনও না","audioUrl":"wbw/018_014_011.mp3","charTypeName":"word"},{"id":15870,"position":12,"arabic":"نَّدْعُوَا۟","translation":"আমরা ডাকবো","audioUrl":"wbw/018_014_012.mp3","charTypeName":"word"},{"id":15871,"position":13,"arabic":"مِن","translation":"ছাড়া","audioUrl":"wbw/018_014_013.mp3","charTypeName":"word"},{"id":15872,"position":14,"arabic":"دُونِهِۦٓ","translation":"তাকে","audioUrl":"wbw/018_014_014.mp3","charTypeName":"word"},{"id":15873,"position":15,"arabic":"إِلَـٰهًۭا ۖ","translation":"(অন্য) ইলাহকে","audioUrl":"wbw/018_014_015.mp3","charTypeName":"word"},{"id":15875,"position":16,"arabic":"لَّقَدْ","translation":"নিশ্চয়ই (যদি করি)","audioUrl":"wbw/018_014_017.mp3","charTypeName":"word"},{"id":15876,"position":17,"arabic":"قُلْنَآ","translation":"আমরা বলবো","audioUrl":"wbw/018_014_018.mp3","charTypeName":"word"},{"id":15877,"position":18,"arabic":"إِذًۭا","translation":"তাহ'লে","audioUrl":"wbw/018_014_019.mp3","charTypeName":"word"},{"id":15878,"position":19,"arabic":"شَطَطًا","transla