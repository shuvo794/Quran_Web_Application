{"id":466,"ayahs":[{"number":68,"arabic":"وَنُفِخَ فِى ٱلصُّورِ فَصَعِقَ مَن فِى ٱلسَّمَٰوَٰتِ وَمَن فِى ٱلْأَرْضِ إِلَّا مَن شَآءَ ٱللَّهُ ۖ ثُمَّ نُفِخَ فِيهِ أُخْرَىٰ فَإِذَا هُمْ قِيَامٌۭ يَنظُرُونَ","translation":"And [on that Day,] the trumpet [of judgment] will be sounded, and all [creatures] that are in the heavens and all that are on earth will fall down senseless, unless they be such as God wills [to exempt]. And then it will sound again - and lo! standing [before the Seat of Judgment], they will begin to see [the truth]!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4126.mp3","surahId":39,"words":[{"id":58412,"position":1,"arabic":"وَنُفِخَ","translation":"এবং ফুঁ দেওয়া হবে","audioUrl":"wbw/039_068_001.mp3","charTypeName":"word"},{"id":58413,"position":2,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/039_068_002.mp3","charTypeName":"word"},{"id":58414,"position":3,"arabic":"ٱلصُّورِ","translation":"শিংগার","audioUrl":"wbw/039_068_003.mp3","charTypeName":"word"},{"id":58415,"position":4,"arabic":"فَصَعِقَ","translation":"অতঃপর মূর্ছা যাবে","audioUrl":"wbw/039_068_004.mp3","charTypeName":"word"},{"id":58416,"position":5,"arabic":"مَن","translation":"যারা","audioUrl":"wbw/039_068_005.mp3","charTypeName":"word"},{"id":58417,"position":6,"arabic":"فِى","translation":"মধ্যে (আছে)","audioUrl":"wbw/039_068_006.mp3","charTypeName":"word"},{"id":58418,"position":7,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশের","audioUrl":"wbw/039_068_007.mp3","charTypeName":"word"},{"id":58419,"position":8,"arabic":"وَمَن","translation":"ও যারা","audioUrl":"wbw/039_068_008.mp3","charTypeName":"word"},{"id":58420,"position":9,"arabic":"فِى","translation":"মধ্যে আছে","audioUrl":"wbw/039_068_009.mp3","charTypeName":"word"},{"id":58421,"position":10,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/039_068_010.mp3","charTypeName":"word"},{"id":58422,"position":11,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/039_068_011.mp3","charTypeName":"word"},{"id":58423,"position":12,"arabic":"مَن","translation":"যাদেরকে","audioUrl":"wbw/039_068_012.mp3","charTypeName":"word"},{"id":58424,"position":13,"arabic":"شَآءَ","translation":"ইচ্ছে করবেন","audioUrl":"wbw/039_068_013.mp3","charTypeName":"word"},{"id":58425,"position":14,"arabic":"ٱللَّهُ ۖ","translation":"আল্লাহ","audioUrl":"wbw/039_068_014.mp3","charTypeName":"word"},{"id":58427,"position":15,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/039_068_016.mp3","charTypeName":"word"},{"id":58428,"position":16,"arabic":"نُفِخَ","translation":"ফুঁ দেওয়া হবে","audioUrl":"wbw/039_068_017.mp3","charTypeName":"word"},{"id":58429,"position":17,"arabic":"فِيهِ","translation":"তার মধ্যে","audioUrl":"wbw/039_068_018.mp3","charTypeName":"word"},{"id":58430,"position":18,"arabic":"أُخْرَىٰ","translation":"আবার","audioUrl":"wbw/039_068_019.mp3","charTypeName":"word"},{"id":58431,"position":19,"arabic":"فَإِذَا","translation":"ফলে তখন","audioUrl":"wbw/039_068_020.mp3","charTypeName":"word"},{"id":58432,"position":20,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/039_068_021.mp3","charTypeName":"word"},{"id":58433,"position":21,"arabic":"قِيَامٌۭ","translation":"দাঁড়িয়ে","audioUrl":"wbw/039_068_022.mp3","charTypeName":"word"},{"id":58434,"position":22,"arabic":"يَنظُرُونَ","translation":"দেখতে থাকবে","audioUrl":"wbw/039_068_023.mp3","charTypeName":"word"},{"id":58435,"position":23,"arabic":"٦٨","translation":"(৬৮)","audioUrl":null,"charTypeName":"end"}]},{"number":69,"arabic":"وَأَشْرَقَتِ ٱلْأَرْضُ بِنُورِ رَبِّهَا وَوُضِعَ ٱلْكِتَٰبُ وَجِا۟ىٓءَ بِٱلنَّبِيِّۦنَ وَٱلشُّهَدَآءِ وَقُضِىَ بَيْنَهُم بِٱلْحَقِّ وَهُمْ لَا يُظْلَمُونَ","translation":"And the earth will shine bright with her Sus­tainer’s light. And the record [of everyone’s deeds] will be laid bare, and all the prophets will be brought forward, and all [other] witnesses; and judgment will be passed on them all in justice. And they will not be wronged,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4127.mp3","surahId":39,"words":[{"id":59240,"position":1,"arabic":"وَأَشْرَقَتِ","translation":"এবং উদ্ভাসিত হবে","audioUrl":"wbw/039_069_001.mp3","charTypeName":"word"},{"id":59241,"position":2,"arabic":"ٱلْأَرْضُ","translation":"পৃথিবী","audioUrl":"wbw/039_069_002.mp3","charTypeName":"word"},{"id":59242,"position":3,"arabic":"بِنُورِ","translation":"দিয়ে আলো (আলোতে)","audioUrl":"wbw/039_069_003.mp3","charTypeName":"word"},{"id":59243,"position":4,"arabic":"رَبِّهَا","translation":"তাঁর রবের","audioUrl":"wbw/039_069_004.mp3","charTypeName":"word"},{"id":59244,"position":5,"arabic":"وَوُضِعَ","translation":"এবং উপস্হিত করা হবে","audioUrl":"wbw/039_069_005.mp3","charTypeName":"word"},{"id":59245,"position":6,"arabic":"ٱلْكِتَـٰبُ","translation":"আমলনামা","audioUrl":"wbw/039_069_006.mp3","charTypeName":"word"},{"id":59246,"position":7,"arabic":"وَجِا۟ىٓءَ","translation":"এবং উপস্থিত করা হবে","audioUrl":"wbw/039_069_007.mp3","charTypeName":"word"},{"id":59247,"position":8,"arabic":"بِٱلنَّبِيِّـۧنَ","translation":"নাবী (রাসূল)গণকে","audioUrl":"wbw/039_069_008.mp3","charTypeName":"word"},{"id":59248,"position":9,"arabic":"وَٱلشُّهَدَآءِ","translation":"ও সাক্ষীদেরকে","audioUrl":"wbw/039_069_009.mp3","charTypeName":"word"},{"id":59249,"position":10,"arabic":"وَقُضِىَ","translation":"এবং মীমাংসা করে দেওয়া হবে","audioUrl":"wbw/039_069_010.mp3","charTypeName":"word"},{"id":59250,"position":11,"arabic":"بَيْنَهُم","translation":"তাদের মাঝে","audioUrl":"wbw/039_069_011.mp3","charTypeName":"word"},{"id":59251,"position":12,"arabic":"بِٱلْحَقِّ","translation":"ন্যায়ভাবে","audioUrl":"wbw/039_069_012.mp3","charTypeName":"word"},{"id":59252,"position":13,"arabic":"وَهُمْ","translation":"এবং তাদের (উপর)","audioUrl":"wbw/039_069_013.mp3","charTypeName":"word"},{"id":59253,"position":14,"arabic":"لَا","translation":"না","audioUrl":"wbw/039_069_014.mp3","charTypeName":"word"},{"id":59254,"position":15,"arabic":"يُظْلَمُونَ","translation":"অবিচার করা হবে","audioUrl":"wbw/039_069_015.mp3","charTypeName":"word"},{"id":59255,"position":16,"arabic":"٦٩","translation":"(৬৯)","audioUrl":null,"charTypeName":"end"}]},{"number":70,"arabic":"وَوُفِّيَتْ كُلُّ نَفْسٍۢ مَّا عَمِلَتْ وَهُوَ أَعْلَمُ بِمَا يَفْعَلُونَ","translation":"for every human being will be repaid in full for whatever [good or evil] he has done: and He is fully aware of all that they do.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4128.mp3","surahId":39,"words":[{"id":59645,"position":1,"arabic":"وَوُفِّيَتْ","translation":"এবং পূর্ণ (প্রতিফল) দেওয়া হবে","audioUrl":"wbw/039_070_001.mp3","charTypeName":"word"},{"id":59646,"position":2,"arabic":"كُلُّ","translation":"প্রত্যেক","audioUrl":"wbw/039_070_002.mp3","charTypeName":"word"},{"id":59647,"position":3,"arabic":"نَفْسٍۢ","translation":"ব্যক্তিকে","audioUrl":"wbw/039_070_003.mp3","charTypeName":"word"},{"id":59648,"position":4,"arabic":"مَّا","translation":"যা","audioUrl":"wbw/039_070_004.mp3","charTypeName":"word"},{"id":59649,"position":5,"arabic":"عَمِلَتْ","translation":"সে কর্মে করেছে","audioUrl":"wbw/039_070_005.mp3","charTypeName":"word"},{"id":59650,"position":6,"arabic":"وَهُوَ","translation":"এবং তিনি","audioUrl":"wbw/039_070_006.mp3","charTypeName":"word"},{"id":59651,"position":7,"arabic":"أَعْلَمُ","translation":"খুব জানেন","audioUrl":"wbw/039_070_007.mp3","charTypeName":"word"},{"id":59652,"position":8,"arabic":"بِمَا","translation":"ঐ সম্পর্কে যা","audioUrl":"wbw/039_070_008.mp3","charTypeName":"word"},{"id":59653,"position":9,"arabic":"يَفْعَلُونَ","translation":"তারা করে","audioUrl":"wbw/039_070_009.mp3","charTypeName":"word"},{"id":59654,"position":10,"arabic":"٧٠","translation":"(৭০)","audioUrl":null,"charTypeName":"end"}]},{"number":71,"arabic":"وَسِيقَ ٱلَّذِينَ كَفَرُوٓا۟ إِلَىٰ جَهَنَّمَ زُمَرًا ۖ حَتَّىٰٓ إِذَا جَآءُوهَا فُتِحَتْ أَبْوَٰبُهَا وَقَالَ لَهُمْ خَزَنَتُهَآ أَلَمْ يَأْتِكُمْ رُسُلٌۭ مِّنكُمْ يَتْلُونَ عَلَيْكُمْ ءَايَٰتِ رَبِّكُمْ وَيُنذِرُونَكُمْ لِقَآءَ يَوْمِكُمْ هَٰذَا ۚ قَالُوا۟ بَلَىٰ وَلَٰكِنْ حَقَّتْ كَلِمَةُ ٱلْعَذَابِ عَلَى ٱلْكَٰفِرِينَ","translation":"And those who were bent on denying the truth will be urged on in throngs towards hell till, when they reach it, its gates will be opened, and its keepers will ask them, “Have there not come to you apostles from among yourselves, who conveyed to you your Sustainer’s messages and warned you of the coming of this your Day [of Judgment]?” They will answer: “Yea, indeed!” But the sentence of suffering will [already] have fallen due upon the deniers of the truth;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4129.mp3","surahId":39,"words":[{"id":59865,"position":1,"arabic":"وَسِيقَ","translation":"এবং তাড়িয়ে নেওয়া হবে","audioUrl":"wbw/039_071_001.mp3","charTypeName":"word"},{"id":59866,"position":2,"arabic":"ٱلَّذِينَ","translation":"(তাদেরকে) যারা","audioUrl":"wbw/039_071_002.mp3","charTypeName":"word"},{"id":59867,"position":3,"arabic":"كَفَرُوٓا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/039_071_003.mp3","charTypeName":"word"},{"id":59868,"position":4,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/039_071_004.mp3","charTypeName":"word"},{"id":59869,"position":5,"arabic":"جَهَنَّمَ","translation":"জাহান্নামের","audioUrl":"wbw/039_071_005.mp3","charTypeName":"word"},{"id":59870,"position":6,"arabic":"زُمَرًا ۖ","translation":"দলে দলে","audioUrl":"wbw/039_071_006.mp3","charTypeName":"word"},{"id":59872,"position":7,"arabic":"حَتَّىٰٓ","translation":"শেষ পর্যন্ত","audioUrl":"wbw/039_071_008.mp3","charTypeName":"word"},{"id":59873,"position":8,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/039_071_009.mp3","charTypeName":"word"},{"id":59874,"position":9,"arabic":"جَآءُوهَا","translation":"তার (কাছে) আসবে","audioUrl":"wbw/039_071_010.mp3","charTypeName":"word"},{"id":59875,"position":10,"arabic":"فُتِحَتْ","translation":"খুলে দেওয়া হবে","audioUrl":"wbw/039_071_011.mp3","charTypeName":"word"},{"id":59876,"position":11,