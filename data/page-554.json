dioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"ٱتَّخَذُوٓا۟ أَيْمَٰنَهُمْ جُنَّةًۭ فَصَدُّوا۟ عَن سَبِيلِ ٱللَّهِ ۚ إِنَّهُمْ سَآءَ مَا كَانُوا۟ يَعْمَلُونَ","translation":"They have made their oaths a cover [for their falseness], and thus they turn others away from the Path of God. Evil indeed is all that they are wont to do:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5190.mp3","surahId":63,"words":[{"id":1365,"position":1,"arabic":"ٱتَّخَذُوٓا۟","translation":"তারা গ্রহণ করেছে","audioUrl":"wbw/063_002_001.mp3","charTypeName":"word"},{"id":1366,"position":2,"arabic":"أَيْمَـٰنَهُمْ","translation":"তাদের শপথগুলোকে","audioUrl":"wbw/063_002_002.mp3","charTypeName":"word"},{"id":1367,"position":3,"arabic":"جُنَّةًۭ","translation":"ঢাল (স্বরূপ)","audioUrl":"wbw/063_002_003.mp3","charTypeName":"word"},{"id":1368,"position":4,"arabic":"فَصَدُّوا۟","translation":"অতঃপর তারা বাধা সৃষ্টি করে","audioUrl":"wbw/063_002_004.mp3","charTypeName":"word"},{"id":1369,"position":5,"arabic":"عَن","translation":"থেকে","audioUrl":"wbw/063_002_005.mp3","charTypeName":"word"},{"id":1370,"position":6,"arabic":"سَبِيلِ","translation":"পথ","audioUrl":"wbw/063_002_006.mp3","charTypeName":"word"},{"id":1371,"position":7,"arabic":"ٱللَّهِ ۚ","translation":"আল্লাহর","audioUrl":"wbw/063_002_007.mp3","charTypeName":"word"},{"id":1373,"position":8,"arabic":"إِنَّهُمْ","translation":"তারা নিশ্চয়","audioUrl":"wbw/063_002_009.mp3","charTypeName":"word"},{"id":1374,"position":9,"arabic":"سَآءَ","translation":"কত মন্দ","audioUrl":"wbw/063_002_010.mp3","charTypeName":"word"},{"id":1375,"position":10,"arabic":"مَا","translation":"যা","audioUrl":"wbw/063_002_011.mp3","charTypeName":"word"},{"id":1376,"position":11,"arabic":"كَانُوا۟","translation":"(ছিল)","audioUrl":"wbw/063_002_012.mp3","charTypeName":"word"},{"id":1377,"position":12,"arabic":"يَعْمَلُونَ","translation":"তারা করছে","audioUrl":"wbw/063_002_013.mp3","charTypeName":"word"},{"id":1378,"position":13,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"ذَٰلِكَ بِأَنَّهُمْ ءَامَنُوا۟ ثُمَّ كَفَرُوا۟ فَطُبِعَ عَلَىٰ قُلُوبِهِمْ فَهُمْ لَا يَفْقَهُونَ","translation":"this, because [they profess that] they have attained to faith, whereas [inwardly] they deny the truth - and so, a seal has been set on their hearts so that they can no longer understand [what is true and what false].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5191.mp3","surahId":63,"words":[{"id":2426,"position":1,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/063_003_001.mp3","charTypeName":"word"},{"id":2427,"position":2,"arabic":"بِأَنَّهُمْ","translation":"এ কারণে যে তারা","audioUrl":"wbw/063_003_002.mp3","charTypeName":"word"},{"id":2428,"position":3,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/063_003_003.mp3","charTypeName":"word"},{"id":2429,"position":4,"arabic":"ثُمَّ","translation":"আবার তোমাদের মধ্যে","audioUrl":"wbw/063_003_004.mp3","charTypeName":"word"},{"id":2430,"position":5,"arabic":"كَفَرُوا۟","translation":"কুফুরি করেছে","audioUrl":"wbw/063_003_005.mp3","charTypeName":"word"},{"id":2431,"position":6,"arabic":"فَطُبِعَ","translation":"অতঃপর মোহর করা হয়েছে","audioUrl":"wbw/063_003_006.mp3","charTypeName":"word"},{"id":2432,"position":7,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/063_003_007.mp3","charTypeName":"word"},{"id":2433,"position":8,"arabic":"قُلُوبِهِمْ","translation":"তাদের অন্তরসমূহের","audioUrl":"wbw/063_003_008.mp3","charTypeName":"word"},{"id":2434,"position":9,"arabic":"فَهُمْ","translation":"অতঃপর তারা","audioUrl":"wbw/063_003_009.mp3","charTypeName":"word"},{"id":2435,"position":10,"arabic":"لَا","translation":"না","audioUrl":"wbw/063_003_010.mp3","charTypeName":"word"},{"id":2436,"position":11,"arabic":"يَفْقَهُونَ","translation":"তারা বুঝে","audioUrl":"wbw/063_003_011.mp3","charTypeName":"word"},{"id":2437,"position":12,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"۞ وَإِذَا رَأَيْتَهُمْ تُعْجِبُكَ أَجْسَامُهُمْ ۖ وَإِن يَقُولُوا۟ تَسْمَعْ لِقَوْلِهِمْ ۖ كَأَنَّهُمْ خُشُبٌۭ مُّسَنَّدَةٌۭ ۖ يَحْسَبُونَ كُلَّ صَيْحَةٍ عَلَيْهِمْ ۚ هُمُ ٱلْعَدُوُّ فَٱحْذَرْهُمْ ۚ قَٰتَلَهُمُ ٱللَّهُ ۖ أَنَّىٰ يُؤْفَكُونَ","translation":"Now when thou seest them, their outward appearance may please thee; and when they speak, thou art inclined to lend ear to what they say. [But though they may seem as sure of themselves] as if they were timbers [firmly] propped up, they think that every shout is [directed] against them. They are the [real] enemies [of all faith], so beware of them. [They deserve the imprecation,] \"May God destroy them!\" How perverted are their minds!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5192.mp3","surahId":63,"words":[{"id":3822,"position":1,"arabic":"۞ وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/063_004_002.mp3","charTypeName":"word"},{"id":3823,"position":2,"arabic":"رَأَيْتَهُمْ","translation":"তাদের তুমি দেখ","audioUrl":"wbw/063_004_003.mp3","charTypeName":"word"},{"id":3824,"position":3,"arabic":"تُعْجِبُكَ","translation":"তোমার প্রীতিকর মনে হয়","audioUrl":"wbw/063_004_004.mp3","charTypeName":"word"},{"id":3825,"position":4,"arabic":"أَجْسَامُهُمْ ۖ","translation":"তাদের দেহগুলো","audioUrl":"wbw/063_004_005.mp3","charTypeName":"word"},{"id":3827,"position":5,"arabic":"وَإِن","translation":"এবং যদি","audioUrl":"wbw/063_004_007.mp3","charTypeName":"word"},{"id":3828,"position":6,"arabic":"يَقُولُوا۟","translation":"তারা কথা বলে","audioUrl":"wbw/063_004_008.mp3","charTypeName":"word"},{"id":3829,"position":7,"arabic":"تَسْمَعْ","translation":"তুমি শুনবে","audioUrl":"wbw/063_004_009.mp3","charTypeName":"word"},{"id":3830,"position":8,"arabic":"لِقَوْلِهِمْ ۖ","translation":"তাদের কথাকে","audioUrl":"wbw/063_004_010.mp3","charTypeName":"word"},{"id":3832,"position":9,"arabic":"كَأَنَّهُمْ","translation":"তারা যেন (আসলে)","audioUrl":"wbw/063_004_012.mp3","charTypeName":"word"},{"id":3833,"position":10,"arabic":"خُشُبٌۭ","translation":"কাষ্ঠখণ্ডসমূহ","audioUrl":"wbw/063_004_013.mp3","charTypeName":"word"},{"id":3834,"position":11,"arabic":"مُّسَنَّدَةٌۭ ۖ","translation":"ঠেকান দেয়া","audioUrl":"wbw/063_004_014.mp3","charTypeName":"word"},{"id":3836,"position":12,"arabic":"يَحْسَبُونَ","translation":"তারা মনে করে","audioUrl":"wbw/063_004_016.mp3","charTypeName":"word"},{"id":3837,"position":13,"arabic":"كُلَّ","translation":"প্রত্যেক","audioUrl":"wbw/063_004_017.mp3","charTypeName":"word"},{"id":3838,"position":14,"arabic":"صَيْحَةٍ","translation":"উঁচু আওয়াজ","audioUrl":"wbw/063_004_018.mp3","charTypeName":"word"},{"id":3839,"position":15,"arabic":"عَلَيْهِمْ ۚ","translation":"তাদের বিরুদ্ধে","audioUrl":"wbw/063_004_019.mp3","charTypeName":"word"},{"id":3841,"position":16,"arabic":"هُمُ","translation":"তারাই","audioUrl":"wbw/063_004_021.mp3","charTypeName":"word"},{"id":3842,"position":17,"arabic":"ٱلْعَدُوُّ","translation":"শত্রু","audioUrl":"wbw/063_004_022.mp3","charTypeName":"word"},{"id":3843,"position":18,"arabic":"فَٱحْذَرْهُمْ ۚ","translation":"অতএব সতর্ক হও তাদের (থেকে)","audioUrl":"wbw/063_004_023.mp3","charTypeName":"word"},{"id":3845,"position":19,"arabic":"قَـٰتَلَهُمُ","translation":"তাদের উপর মার","audioUrl":"wbw/063_004_025.mp3","charTypeName":"word"},{"id":3846,"position":20,"arabic":"ٱللَّهُ ۖ","translation":"আল্লাহর","audioUrl":"wbw/063_004_026.mp3","charTypeName":"word"},{"id":3848,"position":21,"arabic":"أَنَّىٰ","translation":"কোথায়","audioUrl":"wbw/063_004_028.mp3","charTypeName":"word"},{"id":3849,"position":22,"arabic":"يُؤْفَكُونَ","translation":"তাদের ফিরিয়ে নেয়া হচ্ছে","audioUrl":"wbw/063_004_029.mp3","charTypeName":"word"},{"id":3850,"position":23,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]}]}