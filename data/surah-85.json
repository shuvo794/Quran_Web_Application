word"},{"id":22974,"position":3,"arabic":"وَرَآئِهِم","translation":"তাদের অলক্ষ্য","audioUrl":"wbw/085_020_003.mp3","charTypeName":"word"},{"id":22975,"position":4,"arabic":"مُّحِيطٌۢ","translation":"(তাদেরকে) পরিবেষ্টনকারী","audioUrl":"wbw/085_020_004.mp3","charTypeName":"word"},{"id":22976,"position":5,"arabic":"٢٠","translation":"(২০)","audioUrl":null,"charTypeName":"end"}]},{"number":21,"arabic":"بَلْ هُوَ قُرْءَانٌۭ مَّجِيدٌۭ","translation":"Nay, but this [divine writ which they reject] is a discourse sublime,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5930.mp3","surahId":85,"words":[{"id":23998,"position":1,"arabic":"بَلْ","translation":"বরং","audioUrl":"wbw/085_021_001.mp3","charTypeName":"word"},{"id":23999,"position":2,"arabic":"هُوَ","translation":"তা","audioUrl":"wbw/085_021_002.mp3","charTypeName":"word"},{"id":24000,"position":3,"arabic":"قُرْءَانٌۭ","translation":"কুর'আন","audioUrl":"wbw/085_021_003.mp3","charTypeName":"word"},{"id":24001,"position":4,"arabic":"مَّجِيدٌۭ","translation":"সম্মানিত","audioUrl":"wbw/085_021_004.mp3","charTypeName":"word"},{"id":24002,"position":5,"arabic":"٢١","translation":"(২১)","audioUrl":null,"charTypeName":"end"}]},{"number":22,"arabic":"فِى لَوْحٍۢ مَّحْفُوظٍۭ","translation":"upon an imperishable tablet [inscribed].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5931.mp3","surahId":85,"words":[{"id":24424,"position":1,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/085_022_001.mp3","charTypeName":"word"},{"id":24425,"position":2,"arabic":"لَوْحٍۢ","translation":"ফলকের","audioUrl":"wbw/085_022_002.mp3","charTypeName":"word"},{"id":24426,"position":3,"arabic":"مَّحْفُوظٍۭ","translation":"সুরক্ষিত","audioUrl":"wbw/085_022_003.mp3","charTypeName":"word"},{"id":24427,"position":4,"arabic":"٢٢","translation":"(২২)","audioUrl":null,"charTypeName":"end"}]}]}