":"مِنۢ","translation":"মধ্য হতে","audioUrl":"wbw/041_014_004.mp3","charTypeName":"word"},{"id":15787,"position":5,"arabic":"بَيْنِ","translation":"থেকে","audioUrl":"wbw/041_014_005.mp3","charTypeName":"word"},{"id":15788,"position":6,"arabic":"أَيْدِيهِمْ","translation":"সামনে তাদের","audioUrl":"wbw/041_014_006.mp3","charTypeName":"word"},{"id":15789,"position":7,"arabic":"وَمِنْ","translation":"ও থেকে","audioUrl":"wbw/041_014_007.mp3","charTypeName":"word"},{"id":15790,"position":8,"arabic":"خَلْفِهِمْ","translation":"তাদের পিছন","audioUrl":"wbw/041_014_008.mp3","charTypeName":"word"},{"id":15791,"position":9,"arabic":"أَلَّا","translation":"(এই বলে) যে না","audioUrl":"wbw/041_014_009.mp3","charTypeName":"word"},{"id":15792,"position":10,"arabic":"تَعْبُدُوٓا۟","translation":"তোমরা ইবাদত করো","audioUrl":"wbw/041_014_010.mp3","charTypeName":"word"},{"id":15793,"position":11,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/041_014_011.mp3","charTypeName":"word"},{"id":15794,"position":12,"arabic":"ٱللَّهَ ۖ","translation":"আল্লাহকে\"","audioUrl":"wbw/041_014_012.mp3","charTypeName":"word"},{"id":15796,"position":13,"arabic":"قَالُوا۟","translation":"তারা বলেছিলো","audioUrl":"wbw/041_014_014.mp3","charTypeName":"word"},{"id":15797,"position":14,"arabic":"لَوْ","translation":"\"যদি","audioUrl":"wbw/041_014_015.mp3","charTypeName":"word"},{"id":15798,"position":15,"arabic":"شَآءَ","translation":"ইচ্ছে করতেন","audioUrl":"wbw/041_014_016.mp3","charTypeName":"word"},{"id":15799,"position":16,"arabic":"رَبُّنَا","translation":"আমাদের রব","audioUrl":"wbw/041_014_017.mp3","charTypeName":"word"},{"id":15800,"position":17,"arabic":"لَأَنزَلَ","translation":"অবশ্যই পাঠাতেন","audioUrl":"wbw/041_014_018.mp3","charTypeName":"word"},{"id":15801,"position":18,"arabic":"مَلَـٰٓئِكَةًۭ","translation":"ফেরেশতাদেরকে","audioUrl":"wbw/041_014_019.mp3","charTypeName":"word"},{"id":15802,"position":19,"arabic":"فَإِنَّا","translation":"সুতরাং নিশ্চয়ই আমরা","audioUrl":"wbw/041_014_020.mp3","charTypeName":"word"},{"id":15803,"position":20,"arabic":"بِمَآ","translation":"দিয়ে ঐ বিষয় যা","audioUrl":"wbw/041_014_021.mp3","charTypeName":"word"},{"id":15804,"position":21,"arabic":"أُرْسِلْتُم","translation":"তোমাদেরকে পাঠানো হয়েছে","audioUrl":"wbw/041_014_022.mp3","charTypeName":"word"},{"id":15805,"position":22,"arabic":"بِهِۦ","translation":"প্রতি তার","audioUrl":"wbw/041_014_023.mp3","charTypeName":"word"},{"id":15806,"position":23,"arabic":"كَـٰفِرُونَ","translation":"তোমরা অস্বীকারকারী\"","audioUrl":"wbw/041_014_024.mp3","charTypeName":"word"},{"id":15807,"position":24,"arabic":"١٤","translation":"(১৪)","audioUrl":null,"charTypeName":"end"}]},{"number":15,"arabic":"فَأَمَّا عَادٌۭ فَٱسْتَكْبَرُوا۟ فِى ٱلْأَرْضِ بِغَيْرِ ٱلْحَقِّ وَقَالُوا۟ مَنْ أَشَدُّ مِنَّا قُوَّةً ۖ أَوَلَمْ يَرَوْا۟ أَنَّ ٱللَّهَ ٱلَّذِى خَلَقَهُمْ هُوَ أَشَدُّ مِنْهُمْ قُوَّةًۭ ۖ وَكَانُوا۟ بِـَٔايَٰتِنَا يَجْحَدُونَ","translation":"Now as for [the tribe of] Ad, they walked arrogantly on earth, [offending] against all right, and saying, “Who could have a power greater than ours?” Why - were they, then, not aware that God, who created them, had a power greater than theirs? But they went on rejecting Our messages;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4233.mp3","surahId":41,"words":[{"id":16872,"position":1,"arabic":"فَأَمَّا","translation":"আর অবস্থা (ছিলো)","audioUrl":"wbw/041_015_001.mp3","charTypeName":"word"},{"id":16873,"position":2,"arabic":"عَادٌۭ","translation":"আ'দের (এমন যে)","audioUrl":"wbw/041_015_002.mp3","charTypeName":"word"},{"id":16874,"position":3,"arabic":"فَٱسْتَكْبَرُوا۟","translation":"পরে তারা অহংকার করলো","audioUrl":"wbw/041_015_003.mp3","charTypeName":"word"},{"id":16875,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/041_015_004.mp3","charTypeName":"word"},{"id":16876,"position":5,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/041_015_005.mp3","charTypeName":"word"},{"id":16877,"position":