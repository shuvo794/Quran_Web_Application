{"id":478,"ayahs":[{"number":12,"arabic":"فَقَضَىٰهُنَّ سَبْعَ سَمَٰوَاتٍۢ فِى يَوْمَيْنِ وَأَوْحَىٰ فِى كُلِّ سَمَآءٍ أَمْرَهَا ۚ وَزَيَّنَّا ٱلسَّمَآءَ ٱلدُّنْيَا بِمَصَٰبِيحَ وَحِفْظًۭا ۚ ذَٰلِكَ تَقْدِيرُ ٱلْعَزِيزِ ٱلْعَلِيمِ","translation":"And He [it is who] decreed that they become seven heavens in two aeons, and imparted unto each heaven its function. And We adorned the skies nearest to the earth with lights, and made them secure: such is the ordaining of the Almighty, the All-Knowing.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4230.mp3","surahId":41,"words":[{"id":13543,"position":1,"arabic":"فَقَضَىٰهُنَّ","translation":"অতঃপর তাদেরকে পরিণত করলেন","audioUrl":"wbw/041_012_001.mp3","charTypeName":"word"},{"id":13544,"position":2,"arabic":"سَبْعَ","translation":"সাত","audioUrl":"wbw/041_012_002.mp3","charTypeName":"word"},{"id":13545,"position":3,"arabic":"سَمَـٰوَاتٍۢ","translation":"আকাশে","audioUrl":"wbw/041_012_003.mp3","charTypeName":"word"},{"id":13546,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/041_012_004.mp3","charTypeName":"word"},{"id":13547,"position":5,"arabic":"يَوْمَيْنِ","translation":"দু'দিনের","audioUrl":"wbw/041_012_005.mp3","charTypeName":"word"},{"id":13548,"position":6,"arabic":"وَأَوْحَىٰ","translation":"এবং ওহী করলেন","audioUrl":"wbw/041_012_006.mp3","charTypeName":"word"},{"id":13549,"position":7,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/041_012_007.mp3","charTypeName":"word"},{"id":13550,"position":8,"arabic":"كُلِّ","translation":"প্রত্যেক","audioUrl":"wbw/041_012_008.mp3","charTypeName":"word"},{"id":13551,"position":9,"arabic":"سَمَآءٍ","translation":"আকাশের","audioUrl":"wbw/041_012_009.mp3","charTypeName":"word"},{"id":13552,"position":10,"arabic":"أَمْرَهَا ۚ","translation":"তাঁর বিধিবিধান","audioUrl":"wbw/041_012_010.mp3","charTypeName":"word"},{"id":13554,"position":11,"arabic":"وَزَيَّنَّا","translation":"এবং আমরা সাজালাম","audioUrl":"wbw/041_012_012.mp3","charTypeName":"word"},{"id":13555,"position":12,"arabic":"ٱلسَّمَآءَ","translation":"আকাশকে","audioUrl":"wbw/041_012_013.mp3","charTypeName":"word"},{"id":13556,"position":13,"arabic":"ٱلدُّنْيَا","translation":"নীচের","audioUrl":"wbw/041_012_014.mp3","charTypeName":"word"},{"id":13557,"position":14,"arabic":"بِمَصَـٰبِيحَ","translation":"প্রদীপমালা দ্বারা","audioUrl":"wbw/041_012_015.mp3","charTypeName":"word"},{"id":13558,"position":15,"arabic":"وَحِفْظًۭا ۚ","translation":"এবং সংরক্ষণ (করলাম)","audioUrl":"wbw/041_012_016.mp3","charTypeName":"word"},{"id":13560,"position":16,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/041_012_018.mp3","charTypeName":"word"},{"id":13561,"position":17,"arabic":"تَقْدِيرُ","translation":"ব্যবস্থাপনা","audioUrl":"wbw/041_012_019.mp3","charTypeName":"word"},{"id":13562,"position":18,"arabic":"ٱلْعَزِيزِ","translation":"পরাক্রমশালীর","audioUrl":"wbw/041_012_020.mp3","charTypeName":"word"},{"id":13563,"position":19,"arabic":"ٱلْعَلِيمِ","translation":"(যিনি) সবকিছু জানেন","audioUrl":"wbw/041_012_021.mp3","charTypeName":"word"},{"id":13564,"position":20,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]},{"number":13,"arabic":"فَإِنْ أَعْرَضُوا۟ فَقُلْ أَنذَرْتُكُمْ صَٰعِقَةًۭ مِّثْلَ صَٰعِقَةِ عَادٍۢ وَثَمُودَ","translation":"BUT IF they turn away, say: “I warn you of [the coming of] a thunderbolt of punishment like the thunderbolt [that fell upon the tribes] of Ad and Thamud!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4231.mp3","surahId":41,"words":[{"id":14715,"position":1,"arabic":"فَإِنْ","translation":"এখন যদি","audioUrl":"wbw/041_013_001.mp3","charTypeName":"word"},{"id":14716,"position":2,"arabic":"أَعْرَضُوا۟","translation":"তারা মুখ ফিরায়","audioUrl":"wbw/041_013_002.mp3","charTypeName":"word"},{"id":14717,"position":3,"arabic":"فَقُلْ","translation":"তবে বলো","audioUrl":"wbw/041_013_003.mp3","charTypeName":"word"},{"id":14718,"position":4,"arabic":"أَنذَرْتُكُمْ","translation":"\"