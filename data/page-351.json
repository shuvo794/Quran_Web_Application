{"id":351,"ayahs":[{"number":11,"arabic":"إِنَّ ٱلَّذِينَ جَآءُو بِٱلْإِفْكِ عُصْبَةٌۭ مِّنكُمْ ۚ لَا تَحْسَبُوهُ شَرًّۭا لَّكُم ۖ بَلْ هُوَ خَيْرٌۭ لَّكُمْ ۚ لِكُلِّ ٱمْرِئٍۢ مِّنْهُم مَّا ٱكْتَسَبَ مِنَ ٱلْإِثْمِ ۚ وَٱلَّذِى تَوَلَّىٰ كِبْرَهُۥ مِنْهُمْ لَهُۥ عَذَابٌ عَظِيمٌۭ","translation":"Verily, numerous among you are those who would falsely accuse others of unchastity: [but, O you who are thus wronged,] deem it not a bad thing for you: nay, it is good for you! [As for the slanderers,] unto every one of them [will be accounted] all that he has earned by [thus] sinning; and awesome suffering awaits any of them who takes it upon himself to enhance this [sin]!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2802.mp3","surahId":24,"words":[{"id":12942,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/024_011_001.mp3","charTypeName":"word"},{"id":12943,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/024_011_002.mp3","charTypeName":"word"},{"id":12944,"position":3,"arabic":"جَآءُو","translation":"তারা এসেছে","audioUrl":"wbw/024_011_003.mp3","charTypeName":"word"},{"id":12945,"position":4,"arabic":"بِٱلْإِفْكِ","translation":"নিয়ে অপবাদ রচনা","audioUrl":"wbw/024_011_004.mp3","charTypeName":"word"},{"id":12946,"position":5,"arabic":"عُصْبَةٌۭ","translation":"(তারা) একটি দল","audioUrl":"wbw/024_011_005.mp3","charTypeName":"word"},{"id":12947,"position":6,"arabic":"مِّنكُمْ ۚ","translation":"তোমাদের মধ্যকার","audioUrl":"wbw/024_011_006.mp3","charTypeName":"word"},{"id":12949,"position":7,"arabic":"لَا","translation":"না","audioUrl":"wbw/024_011_008.mp3","charTypeName":"word"},{"id":12950,"position":8,"arabic":"تَحْسَبُوهُ","translation":"তা তোমরা মনে করো","audioUrl":"wbw/024_011_009.mp3","charTypeName":"word"},{"id":12951,"position":9,"arabic":"شَرًّۭا","translation":"খারাপ","audioUrl":"wbw/024_011_010.mp3","charTypeName":"word"},{"id":12952,"position":10,"arabic":"لَّكُم ۖ","translation":"জন্যে তোমাদের","audioUrl":"wbw/024_011_011.mp3","charTypeName":"word"},{"id":12954,"position":11,"arabic":"بَلْ","translation":"বরং","audioUrl":"wbw/024_011_013.mp3","charTypeName":"word"},{"id":12955,"position":12,"arabic":"هُوَ","translation":"তা","audioUrl":"wbw/024_011_014.mp3","charTypeName":"word"},{"id":12956,"position":13,"arabic":"خَيْرٌۭ","translation":"ভালো","audioUrl":"wbw/024_011_015.mp3","charTypeName":"word"},{"id":12957,"position":14,"arabic":"لَّكُمْ ۚ","translation":"জন্যে তোমাদের","audioUrl":"wbw/024_011_016.mp3","charTypeName":"word"},{"id":12959,"position":15,"arabic":"لِكُلِّ","translation":"জন্যে প্রত্যেক","audioUrl":"wbw/024_011_018.mp3","charTypeName":"word"},{"id":12960,"position":16,"arabic":"ٱمْرِئٍۢ","translation":"ব্যক্তির (রয়েছে)","audioUrl":"wbw/024_011_019.mp3","charTypeName":"word"},{"id":12961,"position":17,"arabic":"مِّنْهُم","translation":"তাদের মধ্য হ'তে","audioUrl":"wbw/024_011_020.mp3","charTypeName":"word"},{"id":12962,"position":18,"arabic":"مَّا","translation":"যতটা","audioUrl":"wbw/024_011_021.mp3","charTypeName":"word"},{"id":12963,"position":19,"arabic":"ٱكْتَسَبَ","translation":"সে অর্জন করেছে","audioUrl":"wbw/024_011_022.mp3","charTypeName":"word"},{"id":12964,"position":20,"arabic":"مِنَ","translation":"হ'তে","audioUrl":"wbw/024_011_023.mp3","charTypeName":"word"},{"id":12965,"position":21,"arabic":"ٱلْإِثْمِ ۚ","translation":"পাপ","audioUrl":"wbw/024_011_024.mp3","charTypeName":"word"},{"id":12967,"position":22,"arabic":"وَٱلَّذِى","translation":"আর যে","audioUrl":"wbw/024_011_026.mp3","charTypeName":"word"},{"id":12968,"position":23,"arabic":"تَوَلَّىٰ","translation":"দায়িত্ব নিয়েছে (নিজের উপর)","audioUrl":"wbw/024_011_027.mp3","charTypeName":"word"},{"id":12969,"position":24,"arabic":"كِبْرَهُۥ","translation":"তার বড় (অংশ)","audioUrl":"wbw/024_011_028.mp3","charTypeName":"word"},{"id":12970,"position":25,"arabic":"مِنْهُمْ","translation":"মধ্য হ'তে তাদের","audioUrl":"wbw/024_011_029.mp3","charTypeName":"word"},{"id":12971,"posit