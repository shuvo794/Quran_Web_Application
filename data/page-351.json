word"},{"id":15349,"position":9,"arabic":"بِٱلشُّهَدَآءِ","translation":"নিয়ে সাক্ষীদেরকে","audioUrl":"wbw/024_013_010.mp3","charTypeName":"word"},{"id":15350,"position":10,"arabic":"فَأُو۟لَـٰٓئِكَ","translation":"তাহ'লে ঐসবলোক","audioUrl":"wbw/024_013_011.mp3","charTypeName":"word"},{"id":15351,"position":11,"arabic":"عِندَ","translation":"নিকটে","audioUrl":"wbw/024_013_012.mp3","charTypeName":"word"},{"id":15352,"position":12,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/024_013_013.mp3","charTypeName":"word"},{"id":15353,"position":13,"arabic":"هُمُ","translation":"তারাই","audioUrl":"wbw/024_013_014.mp3","charTypeName":"word"},{"id":15354,"position":14,"arabic":"ٱلْكَـٰذِبُونَ","translation":"মিথ্যাবাদী","audioUrl":"wbw/024_013_015.mp3","charTypeName":"word"},{"id":15355,"position":15,"arabic":"١٣","translation":"(১৩)","audioUrl":null,"charTypeName":"end"}]},{"number":14,"arabic":"وَلَوْلَا فَضْلُ ٱللَّهِ عَلَيْكُمْ وَرَحْمَتُهُۥ فِى ٱلدُّنْيَا وَٱلْءَاخِرَةِ لَمَسَّكُمْ فِى مَآ أَفَضْتُمْ فِيهِ عَذَابٌ عَظِيمٌ","translation":"And were it not for God’s favour upon you, [O men,] and His grace in this world and in the life to come, awesome suffering would indeed have afflicted you in result of all [the calumny] in which you indulge","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2805.mp3","surahId":24,"words":[{"id":16397,"position":1,"arabic":"وَلَوْلَا","translation":"আর যদি না (হতো)","audioUrl":"wbw/024_014_001.mp3","charTypeName":"word"},{"id":16398,"position":2,"arabic":"فَضْلُ","translation":"অনুগ্রহ","audioUrl":"wbw/024_014_002.mp3","charTypeName":"word"},{"id":16399,"position":3,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/024_014_003.mp3","charTypeName":"word"},{"id":16400,"position":4,"arabic":"عَلَيْكُمْ","translation":"তোমাদের উপর","audioUrl":"wbw/024_014_004.mp3","charTypeName":"word"},{"id":16401,"position":5,"arabic":"وَرَحْمَتُهُۥ","translation":"ও তাঁর দয়া","audioUrl":"wbw/024_014_005.mp3","charTypeNa