{"id":21,"ayahs":[{"number":135,"arabic":"وَقَالُوا۟ كُونُوا۟ هُودًا أَوْ نَصَٰرَىٰ تَهْتَدُوا۟ ۗ قُلْ بَلْ مِلَّةَ إِبْرَٰهِۦمَ حَنِيفًۭا ۖ وَمَا كَانَ مِنَ ٱلْمُشْرِكِينَ","translation":"AND THEY say, \"Be Jews\" - or, \"Christians\" - \"and you shall be on the right path.\" Say: \"Nay, but [ours is] the creed of Abraham, who turned away from all that is false, and was not of those who ascribe divinity to aught beside God.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/142.mp3","surahId":2,"words":[{"id":78573,"position":1,"arabic":"وَقَالُوا۟","translation":"এবং তারা বলে","audioUrl":"wbw/002_135_001.mp3","charTypeName":"word"},{"id":78574,"position":2,"arabic":"كُونُوا۟","translation":"''তোমরা হও","audioUrl":"wbw/002_135_002.mp3","charTypeName":"word"},{"id":78575,"position":3,"arabic":"هُودًا","translation":"ইহুদী","audioUrl":"wbw/002_135_003.mp3","charTypeName":"word"},{"id":78576,"position":4,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/002_135_004.mp3","charTypeName":"word"},{"id":78577,"position":5,"arabic":"نَصَـٰرَىٰ","translation":"খ্রিষ্টান","audioUrl":"wbw/002_135_005.mp3","charTypeName":"word"},{"id":78578,"position":6,"arabic":"تَهْتَدُوا۟ ۗ","translation":"তোমরা সঠিক পথ পাবে''","audioUrl":"wbw/002_135_006.mp3","charTypeName":"word"},{"id":78580,"position":7,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/002_135_008.mp3","charTypeName":"word"},{"id":78581,"position":8,"arabic":"بَلْ","translation":"''(না তা নয়) বরং","audioUrl":"wbw/002_135_009.mp3","charTypeName":"word"},{"id":78582,"position":9,"arabic":"مِلَّةَ","translation":"(গ্রহণ কর) দীনকে","audioUrl":"wbw/002_135_010.mp3","charTypeName":"word"},{"id":78583,"position":10,"arabic":"إِبْرَٰهِـۧمَ","translation":"ইবরাহীমের","audioUrl":"wbw/002_135_011.mp3","charTypeName":"word"},{"id":78584,"position":11,"arabic":"حَنِيفًۭا ۖ","translation":"একনিষ্ঠভাবে","audioUrl":"wbw/002_135_012.mp3","charTypeName":"word"},{"id":78586,"position":12,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/002_135_014.mp3","charTypeName":"word"},{"id":78587,"position":13,"arabic":"كَانَ","translation":"সেছিল","audioUrl":"wbw/002_135_015.mp3","charTypeName":"word"},{"id":78588,"position":14,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/002_135_016.mp3","charTypeName":"word"},{"id":78589,"position":15,"arabic":"ٱلْمُشْرِكِينَ","translation":"মুশরিকদের''","audioUrl":"wbw/002_135_017.mp3","charTypeName":"word"},{"id":78590,"position":16,"arabic":"١٣٥","translation":"(১৩৫)","audioUrl":null,"charTypeName":"end"}]},{"number":136,"arabic":"قُولُوٓا۟ ءَامَنَّا بِٱللَّهِ وَمَآ أُنزِلَ إِلَيْنَا وَمَآ أُنزِلَ إِلَىٰٓ إِبْرَٰهِۦمَ وَإِسْمَٰعِيلَ وَإِسْحَٰقَ وَيَعْقُوبَ وَٱلْأَسْبَاطِ وَمَآ أُوتِىَ مُوسَىٰ وَعِيسَىٰ وَمَآ أُوتِىَ ٱلنَّبِيُّونَ مِن رَّبِّهِمْ لَا نُفَرِّقُ بَيْنَ أَحَدٍۢ مِّنْهُمْ وَنَحْنُ لَهُۥ مُسْلِمُونَ","translation":"Say: \"We believe in God, and in that which has been bestowed from on high upon us, and that which has been bestowed upon Abraham and Ishmael and Isaac and Jacob and, their descendants, and that which has been vouchsafed to Moses and Jesus; and that which has been vouchsafed to all the [other] prophets by their Sustainer: we make no distinction between any of them. And it is unto Him that we surrender ourselves.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/143.mp3","surahId":2,"words":[{"id":78615,"position":1,"arabic":"قُولُوٓا۟","translation":"(হে মুসলমান) তোমরা বলো","audioUrl":"wbw/002_136_001.mp3","charTypeName":"word"},{"id":78616,"position":2,"arabic":"ءَامَنَّا","translation":"''আমরা ঈমান এনেছি","audioUrl":"wbw/002_136_002.mp3","charTypeName":"word"},{"id":78617,"position":3,"arabic":"بِٱللَّهِ","translation":"আল্লাহ্‌র উপর","audioUrl":"wbw/002_136_003.mp3","charTypeName":"word"},{"id":78618,"position":4,"arabic":"وَمَآ","translation":"এবং যা","audioUrl":"wbw/002_136_004.mp3","charTypeName":"word"},{"id":78619,"position":5,"arabic":"أُنزِلَ","translation":"অবতীর্ণ করা হয়েছে","audioUrl":"wbw/002_136_005.mp3","charTypeName":"word"},{"id":78620,"position":6,"arabic":"إِلَيْنَا","translation":"আমাদের প্রতি","audioUrl":"wbw/002_136_006.mp3","charTypeName":"word"},{"id":78621,"position":7,"arabic":"وَمَآ","translation":"এবং যা","audioUrl":"wbw/002_136_007.mp3","charTypeName":"word"},{"id":78622,"position":8,"arabic":"أُنزِلَ","translation":"অবতীর্ণ করা হয়েছে","audioUrl":"wbw/002_136_008.mp3","charTypeName":"word"},{"id":78623,"position":9,"arabic":"إِلَىٰٓ","translation":"প্রতি","audioUrl":"wbw/002_136_009.mp3","charTypeName":"word"},{"id":78624,"position":10,"arabic":"إِبْرَٰهِـۧمَ","translation":"ইবরাহীমের","audioUrl":"wbw/002_136_010.mp3","charTypeName":"word"},{"id":78625,"position":11,"arabic":"وَإِسْمَـٰعِيلَ","translation":"ও ইসমাঈলের","audioUrl":"wbw/002_136_011.mp3","charTypeName":"word"},{"id":78626,"position":12,"arabic":"وَإِسْحَـٰقَ","translation":"ও ইসহাকের","audioUrl":"wbw/002_136_012.mp3","charTypeName":"word"},{"id":78627,"position":13,"arabic":"وَيَعْقُوبَ","translation":"ও ইয়াকুবের","audioUrl":"wbw/002_136_013.mp3","charTypeName":"word"},{"id":78628,"position":14,"arabic":"وَٱلْأَسْبَاطِ","translation":"ও (তাদের) বংশধরদের (উপর)","audioUrl":"wbw/002_136_014.mp3","charTypeName":"word"},{"id":78629,"position":15,"arabic":"وَمَآ","translation":"এবং যা","audioUrl":"wbw/002_136_015.mp3","charTypeName":"word"},{"id":78630,"position":16,"arabic":"أُوتِىَ","translation":"দেওয়া হয়েছে","audioUrl":"wbw/002_136_016.mp3","charTypeName":"word"},{"id":78631,"position":17,"arabic":"مُوسَىٰ","translation":"মূসাকে","audioUrl":"wbw/002_136_017.mp3","charTypeName":"word"},{"id":78632,"position":18,"arabic":"وَعِيسَىٰ","translation":"ও ঈসাকে","audioUrl":"wbw/002_136_018.mp3","charTypeName":"word"},{"id":78633,"position":19,"arabic":"وَمَآ","translation":"এবং যা","audioUrl":"wbw/002_136_019.mp3","charTypeName":"word"},{"id":78634,"position":20,"arabic":"أُوتِىَ","translation":"দেয়া হয়েছে","audioUrl":"wbw/002_136_020.mp3","charTypeName":"word"},{"id":78635,"position":21,"arabic":"ٱلنَّبِيُّونَ","translation":"নবীদেরকে","audioUrl":"wbw/002_136_021.mp3","charTypeName":"word"},{"id":78636,"position":22,"arabic":"مِن","translation":"পক্ষ হতে","audioUrl":"wbw/002_136_022.mp3","charTypeName":"word"},{"id":78637,"position":23,"arabic":"رَّبِّهِمْ","translation":"তাদের রবের","audioUrl":"wbw/002_136_023.mp3","charTypeName":"word"},{"id":78638,"position":24,"arabic":"لَا","translation":"না","audioUrl":"wbw/002_136_024.mp3","charTypeName":"word"},{"id":78639,"position":25,"arabic":"نُفَرِّقُ","translation":"আমরা পার্থক্য করি","audioUrl":"wbw/002_136_025.mp3","charTypeName":"word"},{"id":78640,"position":26,"arabic":"بَيْنَ","translation":"মাঝে","audioUrl":"wbw/002_136_026.mp3","charTypeName":"word"},{"id":78641,"position":27,"arabic":"أَحَدٍۢ","translation":"কারো","audioUrl":"wbw/002_136_027.mp3","charTypeName":"word"},{"id":78642,"position":28,"arabic":"مِّنْهُمْ","translation":"তাদের মধ্য হতে","audioUrl":"wbw/002_136_028.mp3","charTypeName":"word"},{"id":78643,"position":29,"arabic":"وَنَحْنُ","translation":"এবং আমরা","audioUrl":"wbw/002_136_029.mp3","charTypeName":"word"},{"id":78644,"position":30,"arabic":"لَهُۥ","translation":"তাঁরই কাছে","audioUrl":"wbw/002_136_030.mp3","charTypeName":"word"},{"id":78645,"position":31,"arabic":"مُسْلِمُونَ","translation":"আত্মসমর্পণকারী (মুসলিম) হয়েছি''","audioUrl":"wbw/002_136_031.mp3","charTypeName":"word"},{"id":78646,"position":32,"arabic":"١٣٦","translation":"(১৩৬)","audioUrl":null,"charTypeName":"end"}]},{"number":137,"arabic":"فَإِنْ ءَامَنُوا۟ بِمِثْلِ مَآ ءَامَنتُم بِهِۦ فَقَدِ ٱهْتَدَوا۟ ۖ وَّإِن تَوَلَّوْا۟ فَإِنَّمَا هُمْ فِى شِقَاقٍۢ ۖ فَسَيَكْفِيكَهُمُ ٱللَّهُ ۚ وَهُوَ ٱلسَّمِيعُ ٱلْعَلِيمُ","translation":"And if [others] come to believe in the way you believe, they will indeed find themselves on the right path; and if they turn away, it is but they who will be deeply in the wrong, and God will protect thee from them: for He alone is all-hearing, all-knowing.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/144.mp3","surahId":2,"words":[{"id":78825,"position":1,"arabic":"فَإِنْ","translation":"অতএব যদি","audioUrl":"wbw/002_137_001.mp3","charTypeName":"word"},{"id":78826,"position":2,"arabic":"ءَامَنُوا۟","translation":"তারা ঈমান আনে","audioUrl":"wbw/002_137_002.mp3","charTypeName":"word"},{"id":78827,"position":3,"arabic":"بِمِثْلِ","translation":"অনুরূপ","audioUrl":"wbw/002_137_003.mp3","charTypeName":"word"},{"id":78828,"position":4,"arabic":"مَآ","translation":"যেমন","audioUrl":"wbw/002_137_004.mp3","charTypeName":"word"},{"id":78829,"position":5,"arabic":"ءَامَنتُم","translation":"তোমরা ঈমান এনেছ","audioUrl":"wbw/002_137_005.mp3","charTypeName":"word"},{"id":78830,"position":6,"arabic":"بِهِۦ","translation":"তার উপর","audioUrl":"wbw/002_137_006.mp3","charTypeName":"word"},{"id":78831,"position":7,"arabic":"فَقَدِ","translation":"তবে নিশ্চয়ই","audioUrl":"wbw/002_137_007.mp3","charTypeName":"word"},{"id":78832,"position":8,"arabic":"ٱهْتَدَوا۟ ۖ","translation":"তারা সঠিক পথ পাবে","audioUrl":"wbw/002_137_008.mp3","charTypeName":"word"},{"id":78834,"position":9,"arabic":"وَّإِن","translation":"আর যদি","audioUrl":"wbw/002_137_010.mp3","charTypeName":"word"},{"id":78835,"position":10,"arabic":"تَوَلَّوْا۟","translation":"তারা মুখ ফিরায়ে নেয়","audioUrl":"wbw/002_137_011.mp3","charTypeName":"word"},{"id":78836,"position":11,"arabic":"فَإِنَّمَا","translation":"তবে প্রকৃতপক্ষে","audioUrl":"wbw/002_137_012.mp3","charTypeName":"word"},{"id":78837,"position":12,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/002_137_013.mp3","charTypeName":"word"},{"id":78838,"position":13,"arabic":"فِى","translation":"মধ্যে (লিপ্ত)","audioUrl":"wbw/002_137_014.mp3","charTypeName":"word"},{"id":78839,"position":14,"arabic":"شِقَاقٍۢ ۖ","translation":"বিরোধের","audioUrl":"wbw/002_137_015.mp3","charTypeName":"word"},{"id":78841,"position":15,"arabic":"فَسَيَكْفِيكَهُمُ","translation":"সুতরাং তাদের বিরুদ্ধে তোমার জন্য যথেষ্ট","