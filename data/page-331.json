{"id":331,"ayahs":[{"number":102,"arabic":"لَا يَسْمَعُونَ حَسِيسَهَا ۖ وَهُمْ فِى مَا ٱشْتَهَتْ أَنفُسُهُمْ خَٰلِدُونَ","translation":"no sound thereof will they hear; and they will abide in all that their souls have ever desired.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2585.mp3","surahId":21,"words":[{"id":72093,"position":1,"arabic":"لَا","translation":"না","audioUrl":"wbw/021_102_001.mp3","charTypeName":"word"},{"id":72094,"position":2,"arabic":"يَسْمَعُونَ","translation":"তারা শুনতে পাবে","audioUrl":"wbw/021_102_002.mp3","charTypeName":"word"},{"id":72095,"position":3,"arabic":"حَسِيسَهَا ۖ","translation":"তার ক্ষীণতম শব্দও","audioUrl":"wbw/021_102_003.mp3","charTypeName":"word"},{"id":72097,"position":4,"arabic":"وَهُمْ","translation":"আর তারা (হবে)","audioUrl":"wbw/021_102_005.mp3","charTypeName":"word"},{"id":72098,"position":5,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/021_102_006.mp3","charTypeName":"word"},{"id":72099,"position":6,"arabic":"مَا","translation":"যা","audioUrl":"wbw/021_102_007.mp3","charTypeName":"word"},{"id":72100,"position":7,"arabic":"ٱشْتَهَتْ","translation":"চাইবে","audioUrl":"wbw/021_102_008.mp3","charTypeName":"word"},{"id":72101,"position":8,"arabic":"أَنفُسُهُمْ","translation":"তাদের মন","audioUrl":"wbw/021_102_009.mp3","charTypeName":"word"},{"id":72102,"position":9,"arabic":"خَـٰلِدُونَ","translation":"তারা স্থায়ী হবে","audioUrl":"wbw/021_102_010.mp3","charTypeName":"word"},{"id":72103,"position":10,"arabic":"١٠٢","translation":"(১০২)","audioUrl":null,"charTypeName":"end"}]},{"number":103,"arabic":"لَا يَحْزُنُهُمُ ٱلْفَزَعُ ٱلْأَكْبَرُ وَتَتَلَقَّىٰهُمُ ٱلْمَلَٰٓئِكَةُ هَٰذَا يَوْمُكُمُ ٱلَّذِى كُنتُمْ تُوعَدُونَ","translation":"The supreme awesomeness [of the Day of Resurrection] will cause them no grief, since the angels will receive them with the greeting. “This is your Day [of triumph - the Day] which you were promised!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2586.mp3","surahId":21,"words":[{"id":72147,"position":1,"arabic":"لَا","translation":"না","audioUrl":"wbw/021_103_001.mp3","charTypeName":"word"},{"id":72148,"position":2,"arabic":"يَحْزُنُهُمُ","translation":"তাদেরকে চিন্তিত করবে","audioUrl":"wbw/021_103_002.mp3","charTypeName":"word"},{"id":72149,"position":3,"arabic":"ٱلْفَزَعُ","translation":"ভয়","audioUrl":"wbw/021_103_003.mp3","charTypeName":"word"},{"id":72150,"position":4,"arabic":"ٱلْأَكْبَرُ","translation":"মহা","audioUrl":"wbw/021_103_004.mp3","charTypeName":"word"},{"id":72151,"position":5,"arabic":"وَتَتَلَقَّىٰهُمُ","translation":"এবং তাদেরকে অভ্যর্থনা করবে","audioUrl":"wbw/021_103_005.mp3","charTypeName":"word"},{"id":72152,"position":6,"arabic":"ٱلْمَلَـٰٓئِكَةُ","translation":"ফেরেশতারা","audioUrl":"wbw/021_103_006.mp3","charTypeName":"word"},{"id":72153,"position":7,"arabic":"هَـٰذَا","translation":"\"এই","audioUrl":"wbw/021_103_007.mp3","charTypeName":"word"},{"id":72154,"position":8,"arabic":"يَوْمُكُمُ","translation":"তোমাদের দিন","audioUrl":"wbw/021_103_008.mp3","charTypeName":"word"},{"id":72155,"position":9,"arabic":"ٱلَّذِى","translation":"সেই (যারা)","audioUrl":"wbw/021_103_009.mp3","charTypeName":"word"},{"id":72156,"position":10,"arabic":"كُنتُمْ","translation":"তোমরা ছিলে","audioUrl":"wbw/021_103_010.mp3","charTypeName":"word"},{"id":72157,"position":11,"arabic":"تُوعَدُونَ","translation":"প্রতিশ্রুতি দেয়া হয়েছিলো\"","audioUrl":"wbw/021_103_011.mp3","charTypeName":"word"},{"id":72158,"position":12,"arabic":"١٠٣","translation":"(১০৩)","audioUrl":null,"charTypeName":"end"}]},{"number":104,"arabic":"يَوْمَ نَطْوِى ٱلسَّمَآءَ كَطَىِّ ٱلسِّجِلِّ لِلْكُتُبِ ۚ كَمَا بَدَأْنَآ أَوَّلَ خَلْقٍۢ نُّعِيدُهُۥ ۚ وَعْدًا عَلَيْنَآ ۚ إِنَّا كُنَّا فَٰعِلِينَ","translation":"On that Day We shall roll up the skies as written scrolls are rolled up; [and] as We brought into being the first creation, so We shall bring it forth anew a promise which We have willed upon Our­selves: for, behold, We are able t