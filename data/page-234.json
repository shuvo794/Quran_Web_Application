{"id":234,"ayahs":[{"number":109,"arabic":"فَلَا تَكُ فِى مِرْيَةٍۢ مِّمَّا يَعْبُدُ هَٰٓؤُلَآءِ ۚ مَا يَعْبُدُونَ إِلَّا كَمَا يَعْبُدُ ءَابَآؤُهُم مِّن قَبْلُ ۚ وَإِنَّا لَمُوَفُّوهُمْ نَصِيبَهُمْ غَيْرَ مَنقُوصٍۢ","translation":"AND SO, [O Prophet,] be not in doubt about anything that those [misguided people] worship: they but [thoughtlessly] worship as their forefathers worshipped aforetime; and, behold, We shall most certainly give them their full due [for whatever good or evil they have earned], without diminishing aught thereof.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1582.mp3","surahId":11,"words":[{"id":74009,"position":1,"arabic":"فَلَا","translation":"অতএব না","audioUrl":"wbw/011_109_001.mp3","charTypeName":"word"},{"id":74010,"position":2,"arabic":"تَكُ","translation":"তুমি থাকবে","audioUrl":"wbw/011_109_002.mp3","charTypeName":"word"},{"id":74011,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/011_109_003.mp3","charTypeName":"word"},{"id":74012,"position":4,"arabic":"مِرْيَةٍۢ","translation":"সংশয়ের","audioUrl":"wbw/011_109_004.mp3","charTypeName":"word"},{"id":74013,"position":5,"arabic":"مِّمَّا","translation":"তা হ'তে যার","audioUrl":"wbw/011_109_005.mp3","charTypeName":"word"},{"id":74014,"position":6,"arabic":"يَعْبُدُ","translation":"উপাসনা করে","audioUrl":"wbw/011_109_006.mp3","charTypeName":"word"},{"id":74015,"position":7,"arabic":"هَـٰٓؤُلَآءِ ۚ","translation":"এসব (মুশরিকরা)","audioUrl":"wbw/011_109_007.mp3","charTypeName":"word"},{"id":74017,"position":8,"arabic":"مَا","translation":"না","audioUrl":"wbw/011_109_009.mp3","charTypeName":"word"},{"id":74018,"position":9,"arabic":"يَعْبُدُونَ","translation":"তারা উপাসনা করে","audioUrl":"wbw/011_109_010.mp3","charTypeName":"word"},{"id":74019,"position":10,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/011_109_011.mp3","charTypeName":"word"},{"id":74020,"position":11,"arabic":"كَمَا","translation":"যেমন","audioUrl":"wbw/011_109_012.mp3","charTypeName":"word"},{"id":74021,"position":12,"arabic":"يَعْبُدُ","translation":"উপাসনা করতো","audioUrl":"wbw/011_109_013.mp3","charTypeName":"word"},{"id":74022,"position":13,"arabic":"ءَابَآؤُهُم","translation":"তাদের পূর্বপুরুষেরা","audioUrl":"wbw/011_109_014.mp3","charTypeName":"word"},{"id":74023,"position":14,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/011_109_015.mp3","charTypeName":"word"},{"id":74024,"position":15,"arabic":"قَبْلُ ۚ","translation":"পূর্ব","audioUrl":"wbw/011_109_016.mp3","charTypeName":"word"},{"id":74026,"position":16,"arabic":"وَإِنَّا","translation":"এবং নিশ্চয়ই আমরা","audioUrl":"wbw/011_109_018.mp3","charTypeName":"word"},{"id":74027,"position":17,"arabic":"لَمُوَفُّوهُمْ","translation":"অবশ্যই তাদের পুরোপুরি দিবো","audioUrl":"wbw/011_109_019.mp3","charTypeName":"word"},{"id":74028,"position":18,"arabic":"نَصِيبَهُمْ","translation":"তাদের অংশ","audioUrl":"wbw/011_109_020.mp3","charTypeName":"word"},{"id":74029,"position":19,"arabic":"غَيْرَ","translation":"ছাড়া","audioUrl":"wbw/011_109_021.mp3","charTypeName":"word"},{"id":74030,"position":20,"arabic":"مَنقُوصٍۢ","translation":"কম করা","audioUrl":"wbw/011_109_022.mp3","charTypeName":"word"},{"id":74031,"position":21,"arabic":"١٠٩","translation":"(১০৯)","audioUrl":null,"charTypeName":"end"}]},{"number":110,"arabic":"وَلَقَدْ ءَاتَيْنَا مُوسَى ٱلْكِتَٰبَ فَٱخْتُلِفَ فِيهِ ۚ وَلَوْلَا كَلِمَةٌۭ سَبَقَتْ مِن رَّبِّكَ لَقُضِىَ بَيْنَهُمْ ۚ وَإِنَّهُمْ لَفِى شَكٍّۢ مِّنْهُ مُرِيبٍۢ","translation":"And, indeed, [similar was the case when] We vouchsafed the divine writ unto Moses, and some of his people set their own views against it; and had it not been for a decree that had already gone forth from thy Sustainer, judgment would indeed have been passed on them [then and there]: for, behold, they were in grave doubt, amounting to suspicion, about him [who called them unto God].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1583.mp3","surahId":11,"words":[{"id":74120,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/011_110_001.mp3","charTypeName":"word"},{"id":74121,"position":2,"arabic":"ءَاتَيْنَا","translation":"আমরা দিয়েছিলাম","audioUrl":"wbw/011_110_002.mp3","charTypeName":"word"},{"id":74122,"position":3,"arabic":"مُوسَى","translation":"মূসাকে","audioUrl":"wbw/011_110_003.mp3","charTypeName":"word"},{"id":74123,"position":4,"arabic":"ٱلْكِتَـٰبَ","translation":"কিতাব","audioUrl":"wbw/011_110_004.mp3","charTypeName":"word"},{"id":74124,"position":5,"arabic":"فَٱخْتُلِفَ","translation":"অতঃপর মতবিরোধ ঘটেছিলো","audioUrl":"wbw/011_110_005.mp3","charTypeName":"word"},{"id":74125,"position":6,"arabic":"فِيهِ ۚ","translation":"মধ্যে তার","audioUrl":"wbw/011_110_006.mp3","charTypeName":"word"},{"id":74127,"position":7,"arabic":"وَلَوْلَا","translation":"এবং যদি না","audioUrl":"wbw/011_110_008.mp3","charTypeName":"word"},{"id":74128,"position":8,"arabic":"كَلِمَةٌۭ","translation":"একটি বাণী","audioUrl":"wbw/011_110_009.mp3","charTypeName":"word"},{"id":74129,"position":9,"arabic":"سَبَقَتْ","translation":"পূর্বে নির্ধারিত হতো","audioUrl":"wbw/011_110_010.mp3","charTypeName":"word"},{"id":74130,"position":10,"arabic":"مِن","translation":"পক্ষ হ'তে","audioUrl":"wbw/011_110_011.mp3","charTypeName":"word"},{"id":74131,"position":11,"arabic":"رَّبِّكَ","translation":"তোমার রবের","audioUrl":"wbw/011_110_012.mp3","charTypeName":"word"},{"id":74132,"position":12,"arabic":"لَقُضِىَ","translation":"অবশ্যই মীমাংসা করে দেয়া হতো","audioUrl":"wbw/011_110_013.mp3","charTypeName":"word"},{"id":74133,"position":13,"arabic":"بَيْنَهُمْ ۚ","translation":"তাদের মাঝে","audioUrl":"wbw/011_110_014.mp3","charTypeName":"word"},{"id":74135,"position":14,"arabic":"وَإِنَّهُمْ","translation":"এবং নিশ্চয়ই তারা","audioUrl":"wbw/011_110_016.mp3","charTypeName":"word"},{"id":74136,"position":15,"arabic":"لَفِى","translation":"অবশ্যই মধ্যে (আছে)","audioUrl":"wbw/011_110_017.mp3","charTypeName":"word"},{"id":74137,"position":16,"arabic":"شَكٍّۢ","translation":"সন্দেহের","audioUrl":"wbw/011_110_018.mp3","charTypeName":"word"},{"id":74138,"position":17,"arabic":"مِّنْهُ","translation":"তা হ'তে","audioUrl":"wbw/011_110_019.mp3","charTypeName":"word"},{"id":74139,"position":18,"arabic":"مُرِيبٍۢ","translation":"বিভ্রান্তিকর (সন্দেহে)","audioUrl":"wbw/011_110_020.mp3","charTypeName":"word"},{"id":74140,"position":19,"arabic":"١١٠","translation":"(১১০)","audioUrl":null,"charTypeName":"end"}]},{"number":111,"arabic":"وَإِنَّ كُلًّۭا لَّمَّا لَيُوَفِّيَنَّهُمْ رَبُّكَ أَعْمَٰلَهُمْ ۚ إِنَّهُۥ بِمَا يَعْمَلُونَ خَبِيرٌۭ","translation":"And, verily, unto each and all will thy Sustainer give their full due for whatever [good or evil] they may have done: behold, He is aware of all that they do!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1584.mp3","surahId":11,"words":[{"id":74373,"position":1,"arabic":"وَإِنَّ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/011_111_001.mp3","charTypeName":"word"},{"id":74374,"position":2,"arabic":"كُلًّۭا","translation":"প্রত্যেককে (ব্যক্তিকে)","audioUrl":"wbw/011_111_002.mp3","charTypeName":"word"},{"id":74375,"position":3,"arabic":"لَّمَّا","translation":"যখন (সময় আসবে)","audioUrl":"wbw/011_111_003.mp3","charTypeName":"word"},{"id":74376,"position":4,"arabic":"لَيُوَفِّيَنَّهُمْ","translation":"অবশ্যই তাদের পুরোপুরি দিবেন","audioUrl":"wbw/011_111_004.mp3","charTypeName":"word"},{"id":74377,"position":5,"arabic":"رَبُّكَ","translation":"তোমার রব","audioUrl":"wbw/011_111_005.mp3","charTypeName":"word"},{"id":74378,"position":6,"arabic":"أَعْمَـٰلَهُمْ ۚ","translation":"তাদের কাজগুলোর (প্রতিফল)","audioUrl":"wbw/011_111_006.mp3","charTypeName":"word"},{"id":74380,"position":7,"arabic":"إِنَّهُۥ","translation":"নিশ্চয়ই তিনি","audioUrl":"wbw/011_111_008.mp3","charTypeName":"word"},{"id":74381,"position":8,"arabic":"بِمَا","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/011_111_009.mp3","charTypeName":"word"},{"id":74382,"position":9,"arabic":"يَعْمَلُونَ","translation":"তারা কাজ করেছে","audioUrl":"wbw/011_111_010.mp3","charTypeName":"word"},{"id":74383,"position":10,"arabic":"خَبِيرٌۭ","translation":"খুব অবহিত","audioUrl":"wbw/011_111_011.mp3","charTypeName":"word"},{"id":74384,"position":11,"arabic":"١١١","translation":"(১১১)","audioUrl":null,"charTypeName":"end"}]},{"number":112,"arabic":"فَٱسْتَقِمْ كَمَآ أُمِرْتَ وَمَن تَابَ مَعَكَ وَلَا تَطْغَوْا۟ ۚ إِنَّهُۥ بِمَا تَعْمَلُونَ بَصِيرٌۭ","translation":"Pursue, then, the right course, as thou hast been bidden [by God], together with all who, with thee, have turned unto Him; and let none of you behave in an overweening manner: for, verily, He sees all that you do.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1585.mp3","surahId":11,"words":[{"id":74606,"position":1,"arabic":"فَٱسْتَقِمْ","translation":"অতএব সুদৃঢ় থাকো","audioUrl":"wbw/011_112_001.mp3","charTypeName":"word"},{"id":74607,"position":2,"arabic":"كَمَآ","translation":"যেমন","audioUrl":"wbw/011_112_002.mp3","charTypeName":"word"},{"id":74608,"position":3,"arabic":"أُمِرْتَ","translation":"তোমাকে আদেশ করা হয়েছে","audioUrl":"wbw/011_112_003.mp3","charTypeName":"word"},{"id":74609,"position":4,"arabic":"وَمَن","translation":"এবং যে","audioUrl":"wbw/011_112_004.mp3","charTypeName":"word"},{"id":74610,"position":5,"arabic":"تَابَ","translation":"ফিরে এসেছে (ঈমান ও আনুগত্যে)","audioUrl":"wbw/011_112_005.mp3","charTypeName":"word"},{"id":74611,"position":6,"arabic":"مَعَكَ","translation":"তোমার সাথে","audioUrl":"wbw/011_112_006.mp3","charTypeName":"word"},{"id":74612,"position":7,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/011_112_007.mp3","charTypeName":"word"},{"id":74613,"position":8,"arabic":"تَطْغَوْا۟ ۚ","translation":"তোমরা সীমালঙ্ঘন করো","audioUrl":"wbw/011_112_008.mp3","charTypeName":"word"},{"id":74615,"position":9,"arabic":"إِنَّهُۥ","translation":"নিশ্চয়ই তিনি","audioUrl":"wbw/011_112_010.mp3","charTypeName":"word"},{"id":74616,"position":10,"arabic":"بِمَا","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/011_112_011.mp3","charTypeName":"word"},{"id":74617,"position":11,"arabic":"تَعْمَلُونَ","translation":"তোমরা কাজ করছো","audioUrl":"wbw/011_112_012.mp3","charTypeName":"word"},{"id":74618,"position":12,"arabic":"بَصِيرٌۭ","translation":"পূর্ণ দৃষ্টি রাখেন","audioUrl":"wbw/011_112_013.mp3","charTypeName":"word"},{"id":74619,"position":13,"arabic":"١١٢","translation":"(১১২)","audioUrl":null,"charTypeName":"end"}]},{"number":113,"arabic":"وَلَا تَرْكَنُوٓا۟ إِلَى ٱلَّذِينَ ظَلَمُوا۟ فَتَمَسَّكُمُ ٱلنَّارُ وَمَا لَكُم مِّن دُونِ ٱللَّهِ مِنْ أَوْلِيَآءَ ثُمَّ لَا تُنصَرُونَ","translation":"And do not incline towards, nor rely upon, those who are bent on evildoing lest the fire [of the hereafter] touch you: for [then] you would have none to protect you from God, nor would you ever be succoured [by Him].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1586.mp3","surahId":11,"words":[{"id":75004,"position":1,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/011_113_001.mp3","charTypeName":"word"},{"id":75005,"position":2,"arabic":"تَرْكَنُوٓا۟","translation":"তোমরা ঝুঁকো","audioUrl":"wbw/011_113_002.mp3","charTypeName":"word"},{"id":75006,"position":3,"arabic":"إِلَى","translation":"প্রতি","audioUrl":"wbw/011_113_003.mp3","charTypeName":"word"},{"id":75007,"position":4,"arabic":"ٱلَّذِينَ","translation":"(তাদের) যারা","audioUrl":"wbw/011_113_004.mp3","charTypeName":"word"},{"id":75008,"position":5,"arabic":"ظَلَمُوا۟","translation":"সীমালঙ্ঘন করেছে","audioUrl":"wbw/011_113_005.mp3","charTypeName":"word"},{"id":75009,"position":6,"arabic":"فَتَمَسَّكُمُ","translation":"তাহ'লে স্পর্শ করবে তোমাদের","audioUrl":"wbw/011_113_006.mp3","charTypeName":"word"},{"id":75010,"position":7,"arabic":"ٱلنَّارُ","translation":"(জাহান্নামের) আগুন","audioUrl":"wbw/011_113_007.mp3","charTypeName":"word"},{"id":75011,"position":8,"arabic":"وَمَا","translation":"এবং না (হবে)","audioUrl":"wbw/011_113_008.mp3","charTypeName":"word"},{"id":75012,"position":9,"arabic":"لَكُم","translation":"তোমাদের জন্যে","audioUrl":"wbw/011_113_009.mp3","charTypeName":"word"},{"id":75013,"position":10,"arabic":"مِّن","translation":"মধ্য হতে","audioUrl":"wbw/011_113_010.mp3","charTypeName":"word"},{"id":75014,"position":11,"arabic":"دُونِ","translation":"ছাড়া","audioUrl":"wbw/011_113_011.mp3","charTypeName":"word"},{"id":75015,"position":12,"arabic":"ٱللَّهِ","translation":"আল্লাহ","audioUrl":"wbw/011_113_012.mp3","charTypeName":"word"},{"id":75016,"position":13,"arabic":"مِنْ","translation":"কোন","audioUrl":"wbw/011_113_013.mp3","charTypeName":"word"},{"id":75017,"position":14,"arabic":"أَوْلِيَآءَ","translation":"অভিভাবক","audioUrl":"wbw/011_113_014.mp3","charTypeName":"word"},{"id":75018,"position":15,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/011_113_015.mp3","charTypeName":"word"},{"id":75019,"position":16,"arabic":"لَا","translation":"না","audioUrl":"wbw/011_113_016.mp3","charTypeName":"word"},{"id":75020,"position":17,"arabic":"تُنصَرُونَ","translation":"তোমাদের সাহায্য করা হবে","audioUrl":"wbw/011_113_017.mp3","charTypeName":"word"},{"id":75021,"position":18,"arabic":"١١٣","translation":"(১১৩)","audioUrl":null,"charTypeName":"end"}]},{"number":114,"arabic":"وَأَقِمِ ٱلصَّلَوٰةَ طَرَفَىِ ٱلنَّهَارِ وَزُلَفًۭا مِّنَ ٱلَّيْلِ ۚ إِنَّ ٱلْحَسَنَٰتِ يُذْهِبْنَ ٱلسَّيِّـَٔاتِ ۚ ذَٰلِكَ ذِكْرَىٰ لِلذَّٰكِرِينَ","translation":"And be constant in praying at the beginning and the end of the day, as well as during the early watches of the night: for, verily, good deeds drive away evil deeds: this is a reminder to all who bear [God] in mind.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1587.mp3","surahId":11,"words":[{"id":75056,"position":1,"arabic":"وَأَقِمِ","translation":"এবং প্রতিষ্ঠা করো","audioUrl":"wbw/011_114_001.mp3","charTypeName":"word"},{"id":75057,"position":2,"arabic":"ٱلصَّلَوٰةَ","translation":"সালাত","audioUrl":"wbw/011_114_002.mp3","charTypeName":"word"},{"id":75058,"position":3,"ar