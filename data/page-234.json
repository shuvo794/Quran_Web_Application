rl":"wbw/011_115_001.mp3","charTypeName":"word"},{"id":75288,"position":2,"arabic":"فَإِنَّ","translation":"কারণ নিশ্চয়ই","audioUrl":"wbw/011_115_002.mp3","charTypeName":"word"},{"id":75289,"position":3,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/011_115_003.mp3","charTypeName":"word"},{"id":75290,"position":4,"arabic":"لَا","translation":"না","audioUrl":"wbw/011_115_004.mp3","charTypeName":"word"},{"id":75291,"position":5,"arabic":"يُضِيعُ","translation":"নষ্ট করেন","audioUrl":"wbw/011_115_005.mp3","charTypeName":"word"},{"id":75292,"position":6,"arabic":"أَجْرَ","translation":"কর্মফল","audioUrl":"wbw/011_115_006.mp3","charTypeName":"word"},{"id":75293,"position":7,"arabic":"ٱلْمُحْسِنِينَ","translation":"সৎকর্মশীলদের","audioUrl":"wbw/011_115_007.mp3","charTypeName":"word"},{"id":75294,"position":8,"arabic":"١١٥","translation":"(১১৫)","audioUrl":null,"charTypeName":"end"}]},{"number":116,"arabic":"فَلَوْلَا كَانَ مِنَ ٱلْقُرُونِ مِن قَبْلِكُمْ أُو۟لُوا۟ بَقِيَّةٍۢ يَنْهَوْنَ عَنِ ٱلْفَسَادِ فِى ٱلْأَرْضِ إِلَّا قَلِيلًۭا مِّمَّنْ أَنجَيْنَا مِنْهُمْ ۗ وَٱتَّبَعَ ٱلَّذِينَ ظَلَمُوا۟ مَآ أُتْرِفُوا۟ فِيهِ وَكَانُوا۟ مُجْرِمِينَ","translation":"BUT, ALAS, among those generations [whom We destroyed] before your time there were no people endowed with any virtue - [people] who would speak out against the [spread of] corruption on earth -except the few of them whom We saved [because of their righteousness], whereas those who were bent on evildoing only pursued pleasures which corrupted their whole being, and so lost themselves in sinning.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1589.mp3","surahId":11,"words":[{"id":75495,"position":1,"arabic":"فَلَوْلَا","translation":"অতঃপর কেন না","audioUrl":"wbw/011_116_001.mp3","charTypeName":"word"},{"id":75496,"position":2,"arabic":"كَانَ","translation":"(বর্তমান) ছিলো","audioUrl":"wbw/011_116_002.mp3","charTypeName":"word"},{"id":75497,"position":3,"arabic":"مِنَ","translation":"মধ্য হ'তে","a