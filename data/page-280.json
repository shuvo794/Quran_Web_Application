{"id":280,"ayahs":[{"number":111,"arabic":"۞ يَوْمَ تَأْتِى كُلُّ نَفْسٍۢ تُجَٰدِلُ عَن نَّفْسِهَا وَتُوَفَّىٰ كُلُّ نَفْسٍۢ مَّا عَمِلَتْ وَهُمْ لَا يُظْلَمُونَ","translation":"[Be conscious, then, of] the Day when every human being shall come to plead for himself [alone], and every human being shall be repaid in full for whatever he has done, and none shall be wronged.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2012.mp3","surahId":16,"words":[{"id":74393,"position":1,"arabic":"۞ يَوْمَ","translation":"(স্মরণ করো) যেদিন","audioUrl":"wbw/016_111_002.mp3","charTypeName":"word"},{"id":74394,"position":2,"arabic":"تَأْتِى","translation":"আসবে","audioUrl":"wbw/016_111_003.mp3","charTypeName":"word"},{"id":74395,"position":3,"arabic":"كُلُّ","translation":"প্রত্যেক","audioUrl":"wbw/016_111_004.mp3","charTypeName":"word"},{"id":74396,"position":4,"arabic":"نَفْسٍۢ","translation":"ব্যক্তি","audioUrl":"wbw/016_111_005.mp3","charTypeName":"word"},{"id":74397,"position":5,"arabic":"تُجَـٰدِلُ","translation":"যুক্তি দিবে","audioUrl":"wbw/016_111_006.mp3","charTypeName":"word"},{"id":74398,"position":6,"arabic":"عَن","translation":"সম্পর্কে","audioUrl":"wbw/016_111_007.mp3","charTypeName":"word"},{"id":74399,"position":7,"arabic":"نَّفْسِهَا","translation":"তার নিজের","audioUrl":"wbw/016_111_008.mp3","charTypeName":"word"},{"id":74400,"position":8,"arabic":"وَتُوَفَّىٰ","translation":"এবং পূর্ণ দেওয়া হবে","audioUrl":"wbw/016_111_009.mp3","charTypeName":"word"},{"id":74401,"position":9,"arabic":"كُلُّ","translation":"প্রত্যেক","audioUrl":"wbw/016_111_010.mp3","charTypeName":"word"},{"id":74402,"position":10,"arabic":"نَفْسٍۢ","translation":"ব্যক্তিকে","audioUrl":"wbw/016_111_011.mp3","charTypeName":"word"},{"id":74403,"position":11,"arabic":"مَّا","translation":"যা","audioUrl":"wbw/016_111_012.mp3","charTypeName":"word"},{"id":74404,"position":12,"arabic":"عَمِلَتْ","translation":"সে কাজ করেছে","audioUrl":"wbw/016_111_013.mp3","charTypeName":"word"},{"id":74405,"position":13,"arabic":"وَهُمْ","translation":"এবং তাদের (প্রতি)","audioUrl":"wbw/016_111_014.mp3","charTypeName":"word"},{"id":74406,"position":14,"arabic":"لَا","translation":"না","audioUrl":"wbw/016_111_015.mp3","charTypeName":"word"},{"id":74407,"position":15,"arabic":"يُظْلَمُونَ","translation":"অত্যাচার করা হবে","audioUrl":"wbw/016_111_016.mp3","charTypeName":"word"},{"id":74408,"position":16,"arabic":"١١١","translation":"(১১১)","audioUrl":null,"charTypeName":"end"}]},{"number":112,"arabic":"وَضَرَبَ ٱللَّهُ مَثَلًۭا قَرْيَةًۭ كَانَتْ ءَامِنَةًۭ مُّطْمَئِنَّةًۭ يَأْتِيهَا رِزْقُهَا رَغَدًۭا مِّن كُلِّ مَكَانٍۢ فَكَفَرَتْ بِأَنْعُمِ ٱللَّهِ فَأَذَٰقَهَا ٱللَّهُ لِبَاسَ ٱلْجُوعِ وَٱلْخَوْفِ بِمَا كَانُوا۟ يَصْنَعُونَ","translation":"AND GOD propounds [to you] a parable: [Imagine] a town which was [once] secure and at ease, with its sustenance coming to it abundantly from all quarters, and which thereupon blasphemously refused to show gratitude for God's blessings: and therefore God caused it to taste the all-embracing misery of hunger and fear in result of all [the evil] that its people had so persistently wrought.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2013.mp3","surahId":16,"words":[{"id":74744,"position":1,"arabic":"وَضَرَبَ","translation":"এবং পেশ করেন","audioUrl":"wbw/016_112_001.mp3","charTypeName":"word"},{"id":74745,"position":2,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌","audioUrl":"wbw/016_112_002.mp3","charTypeName":"word"},{"id":74746,"position":3,"arabic":"مَثَلًۭا","translation":"দৃষ্টান্ত","audioUrl":"wbw/016_112_003.mp3","charTypeName":"word"},{"id":74747,"position":4,"arabic":"قَرْيَةًۭ","translation":"এক জনপদের","audioUrl":"wbw/016_112_004.mp3","charTypeName":"word"},{"id":74748,"position":5,"arabic":"كَانَتْ","translation":"তা ছিলো","audioUrl":"wbw/016_112_005.mp3","charTypeName":"word"},{"id":74749,"position":6,"arabic":"ءَامِنَةًۭ","translation":"নিরাপদ","audioUrl":"wbw/016_112_006.mp3","charTypeName":"word"},{