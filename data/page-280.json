ِمَا تَصِفُ أَلْسِنَتُكُمُ ٱلْكَذِبَ هَٰذَا حَلَٰلٌۭ وَهَٰذَا حَرَامٌۭ لِّتَفْتَرُوا۟ عَلَى ٱللَّهِ ٱلْكَذِبَ ۚ إِنَّ ٱلَّذِينَ يَفْتَرُونَ عَلَى ٱللَّهِ ٱلْكَذِبَ لَا يُفْلِحُونَ","translation":"Hence, do not utter falsehoods by letting your tongues determine [at your own discretion], \"This is lawful and that is forbidden\", thus attributing your own lying inventions to God: for, behold, they who attribute their own lying inventions to God will never attain to a happy state!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2017.mp3","surahId":16,"words":[{"id":75692,"position":1,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/016_116_001.mp3","charTypeName":"word"},{"id":75693,"position":2,"arabic":"تَقُولُوا۟","translation":"তোমরা বলো","audioUrl":"wbw/016_116_002.mp3","charTypeName":"word"},{"id":75694,"position":3,"arabic":"لِمَا","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/016_116_003.mp3","charTypeName":"word"},{"id":75695,"position":4,"arabic":"تَصِفُ","translation":"বর্ণনা করে","audioUrl":"wbw/016_116_004.mp3","charTypeName":"word"},{"id":75696,"position":5,"arabic":"أَلْسِنَتُكُمُ","translation":"তোমাদের জিহবাসমূহ","audioUrl":"wbw/016_116_005.mp3","charTypeName":"word"},{"id":75697,"position":6,"arabic":"ٱلْكَذِبَ","translation":"মিথ্যা","audioUrl":"wbw/016_116_006.mp3","charTypeName":"word"},{"id":75698,"position":7,"arabic":"هَـٰذَا","translation":"\"এটা","audioUrl":"wbw/016_116_007.mp3","charTypeName":"word"},{"id":75699,"position":8,"arabic":"حَلَـٰلٌۭ","translation":"হালাল","audioUrl":"wbw/016_116_008.mp3","charTypeName":"word"},{"id":75700,"position":9,"arabic":"وَهَـٰذَا","translation":"এবং এটা","audioUrl":"wbw/016_116_009.mp3","charTypeName":"word"},{"id":75701,"position":10,"arabic":"حَرَامٌۭ","translation":"হারাম\"","audioUrl":"wbw/016_116_010.mp3","charTypeName":"word"},{"id":75702,"position":11,"arabic":"لِّتَفْتَرُوا۟","translation":"যাতে তোমরা রটাবে","audioUrl":"wbw/016_116_011.mp3","charTypeName":"word"},{"id":75703,"p