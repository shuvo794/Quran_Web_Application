16_114_011.mp3","charTypeName":"word"},{"id":75084,"position":12,"arabic":"إِيَّاهُ","translation":"তাঁরই শুধু","audioUrl":"wbw/016_114_012.mp3","charTypeName":"word"},{"id":75085,"position":13,"arabic":"تَعْبُدُونَ","translation":"তোমরা ইবাদাত করে থাকো","audioUrl":"wbw/016_114_013.mp3","charTypeName":"word"},{"id":75086,"position":14,"arabic":"١١٤","translation":"(১১৪)","audioUrl":null,"charTypeName":"end"}]},{"number":115,"arabic":"إِنَّمَا حَرَّمَ عَلَيْكُمُ ٱلْمَيْتَةَ وَٱلدَّمَ وَلَحْمَ ٱلْخِنزِيرِ وَمَآ أُهِلَّ لِغَيْرِ ٱللَّهِ بِهِۦ ۖ فَمَنِ ٱضْطُرَّ غَيْرَ بَاغٍۢ وَلَا عَادٍۢ فَإِنَّ ٱللَّهَ غَفُورٌۭ رَّحِيمٌۭ","translation":"He has forbidden to you only carrion, and blood, and the flesh of swine, and that over which any name other than God's has been invoked; but if one is driven [to it] by necessity - neither coveting it nor exceeding his immediate need -verily, God is much forgiving, a dispenser of grace.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2016.mp3","surahId":16,"words":[{"id":75440,"position":1,"arabic":"إِنَّمَا","translation":"(আল্লাহ্‌) মূলতঃ","audioUrl":"wbw/016_115_001.mp3","charTypeName":"word"},{"id":75441,"position":2,"arabic":"حَرَّمَ","translation":"হারাম করেছেন","audioUrl":"wbw/016_115_002.mp3","charTypeName":"word"},{"id":75442,"position":3,"arabic":"عَلَيْكُمُ","translation":"তোমাদের উপর","audioUrl":"wbw/016_115_003.mp3","charTypeName":"word"},{"id":75443,"position":4,"arabic":"ٱلْمَيْتَةَ","translation":"মৃত (জন্তু)","audioUrl":"wbw/016_115_004.mp3","charTypeName":"word"},{"id":75444,"position":5,"arabic":"وَٱلدَّمَ","translation":"ও রক্ত","audioUrl":"wbw/016_115_005.mp3","charTypeName":"word"},{"id":75445,"position":6,"arabic":"وَلَحْمَ","translation":"ও গোশতকে","audioUrl":"wbw/016_115_006.mp3","charTypeName":"word"},{"id":75446,"position":7,"arabic":"ٱلْخِنزِيرِ","translation":"শুকরের","audioUrl":"wbw/016_115_007.mp3","charTypeName":"word"},{"id":75447,"position":8,"arabic":"وَمَآ","translation":"এবং যা","