75928,"position":9,"arabic":"قَبْلُ ۖ","translation":"পূর্ব","audioUrl":"wbw/016_118_009.mp3","charTypeName":"word"},{"id":75930,"position":10,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/016_118_011.mp3","charTypeName":"word"},{"id":75931,"position":11,"arabic":"ظَلَمْنَـٰهُمْ","translation":"তাদের উপর আমরা নির্যাতন করেছি","audioUrl":"wbw/016_118_012.mp3","charTypeName":"word"},{"id":75932,"position":12,"arabic":"وَلَـٰكِن","translation":"কিন্তু","audioUrl":"wbw/016_118_013.mp3","charTypeName":"word"},{"id":75933,"position":13,"arabic":"كَانُوٓا۟","translation":"তারা ছিলো","audioUrl":"wbw/016_118_014.mp3","charTypeName":"word"},{"id":75934,"position":14,"arabic":"أَنفُسَهُمْ","translation":"নিজেদের উপর তাদের","audioUrl":"wbw/016_118_015.mp3","charTypeName":"word"},{"id":75935,"position":15,"arabic":"يَظْلِمُونَ","translation":"অত্যাচার করতো","audioUrl":"wbw/016_118_016.mp3","charTypeName":"word"},{"id":75936,"position":16,"arabic":"١١٨","translation":"(১১৮)","audioUrl":null,"charTypeName":"end"}]}]}