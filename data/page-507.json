{"id":507,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ ٱلَّذِينَ كَفَرُوا۟ وَصَدُّوا۟ عَن سَبِيلِ ٱللَّهِ أَضَلَّ أَعْمَٰلَهُمْ","translation":"AS FOR THOSE who are bent on denying the truth and on barring [others] from the path of God - all their [good] deeds will He let go to waste;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4546.mp3","surahId":47,"words":[{"id":179,"position":1,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/047_001_001.mp3","charTypeName":"word"},{"id":180,"position":2,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/047_001_002.mp3","charTypeName":"word"},{"id":181,"position":3,"arabic":"وَصَدُّوا۟","translation":"ও বাধা দিয়েছে (লোকদেরকে)","audioUrl":"wbw/047_001_003.mp3","charTypeName":"word"},{"id":182,"position":4,"arabic":"عَن","translation":"হতে","audioUrl":"wbw/047_001_004.mp3","charTypeName":"word"},{"id":183,"position":5,"arabic":"سَبِيلِ","translation":"পথ","audioUrl":"wbw/047_001_005.mp3","charTypeName":"word"},{"id":184,"position":6,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/047_001_006.mp3","charTypeName":"word"},{"id":185,"position":7,"arabic":"أَضَلَّ","translation":"ব্যর্থ করে দিয়েছেন তিনি","audioUrl":"wbw/047_001_007.mp3","charTypeName":"word"},{"id":186,"position":8,"arabic":"أَعْمَـٰلَهُمْ","translation":"তাদের কর্ম সমূহকে","audioUrl":"wbw/047_001_008.mp3","charTypeName":"word"},{"id":187,"position":9,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"وَٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ وَءَامَنُوا۟ بِمَا نُزِّلَ عَلَىٰ مُحَمَّدٍۢ وَهُوَ ٱلْحَقُّ مِن رَّبِّهِمْ ۙ كَفَّرَ عَنْهُمْ سَيِّـَٔاتِهِمْ وَأَصْلَحَ بَالَهُمْ","translation":"whereas those who have attained to faith and do righteous deeds, and have come to believe in what has been bestowed from on high on Muhammad - for it is the truth from their Sustainer - [shall attain to God’s grace:] He will efface their [past] bad deeds, and will set their hearts at rest.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4547.mp3","surahId":47,"words":[{"id":1036,"position":1,"arabic":"وَٱلَّذِينَ","translation":"আর যারা","audioUrl":"wbw/047_002_001.mp3","charTypeName":"word"},{"id":1037,"position":2,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/047_002_002.mp3","charTypeName":"word"},{"id":1038,"position":3,"arabic":"وَعَمِلُوا۟","translation":"ও কাজ করেছে","audioUrl":"wbw/047_002_003.mp3","charTypeName":"word"},{"id":1039,"position":4,"arabic":"ٱلصَّـٰلِحَـٰتِ","translation":"সৎকর্মের","audioUrl":"wbw/047_002_004.mp3","charTypeName":"word"},{"id":1040,"position":5,"arabic":"وَءَامَنُوا۟","translation":"এবং ঈমান এনেছে","audioUrl":"wbw/047_002_005.mp3","charTypeName":"word"},{"id":1041,"position":6,"arabic":"بِمَا","translation":"(তার উপর) যা","audioUrl":"wbw/047_002_006.mp3","charTypeName":"word"},{"id":1042,"position":7,"arabic":"نُزِّلَ","translation":"অবতীর্ণ করা হয়েছে","audioUrl":"wbw/047_002_007.mp3","charTypeName":"word"},{"id":1043,"position":8,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/047_002_008.mp3","charTypeName":"word"},{"id":1044,"position":9,"arabic":"مُحَمَّدٍۢ","translation":"মুহাম্মাদের","audioUrl":"wbw/047_002_009.mp3","charTypeName":"word"},{"id":1045,"position":10,"arabic":"وَهُوَ","translation":"এবং তা","audioUrl":"wbw/047_002_010.mp3","charTypeName":"word"},{"id":1046,"position":11,"arabic":"ٱلْحَقُّ","translation":"সত্য","audioUrl":"wbw/047_002_011.mp3","charTypeName":"word"},{"id":1047,"position":12,"arabic":"مِن","translation":"পক্ষ হতে","audioUrl":"wbw/047_002_012.mp3","charTypeName":"word"},{"id":1048,"position":13,"arabic":"رَّبِّهِمْ ۙ","translation":"তাদের রবের","audioUrl":"wbw/047_002_013.mp3","charTypeName":"word"},{"id":1050,"position":14,"arabic":"كَفَّرَ","translation":"(আল্লাহ্‌) মিটিয়ে দিয়েছেন","audioUrl":"wbw/047_002_015.mp3","charTypeName":"word"},{"id":1051,"position":15,"arabic":"عَنْهُمْ","translation":"তাদের হতে","audioUrl":"wbw/047_002_016.mp3","charTypeName":"word"},{"id":1052,"position":16,"arabic":"سَيِّـَٔاتِهِمْ","translation":"তাদের ত্রুটি সমুহ","audioUrl":"wbw/047_002_017.mp3","charTypeName":"word"},{"id":1053,"position":17,"arabic":"وَأَصْلَحَ","translation":"ও শুধরে দিবেন","audioUrl":"wbw/047_002_018.mp3","charTypeName":"word"},{"id":1054,"position":18,"arabic":"بَالَهُمْ","translation":"তাদের অবস্থা","audioUrl":"wbw/047_002_019.mp3","charTypeName":"word"},{"id":1055,"position":19,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"ذَٰلِكَ بِأَنَّ ٱلَّذِينَ كَفَرُوا۟ ٱتَّبَعُوا۟ ٱلْبَٰطِلَ وَأَنَّ ٱلَّذِينَ ءَامَنُوا۟ ٱتَّبَعُوا۟ ٱلْحَقَّ مِن رَّبِّهِمْ ۚ كَذَٰلِكَ يَضْرِبُ ٱللَّهُ لِلنَّاسِ أَمْثَٰلَهُمْ","translation":"This, because they who are bent on denying the truth pursue falsehood, whereas they who have attained to faith pursue [but] the truth [that flows] from their Sustainer. In this way does God set forth unto man the parables of their true state.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4548.mp3","surahId":47,"words":[{"id":2126,"position":1,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/047_003_001.mp3","charTypeName":"word"},{"id":2127,"position":2,"arabic":"بِأَنَّ","translation":"এ কারণে যে","audioUrl":"wbw/047_003_002.mp3","charTypeName":"word"},{"id":2128,"position":3,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/047_003_003.mp3","charTypeName":"word"},{"id":2129,"position":4,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/047_003_004.mp3","charTypeName":"word"},{"id":2130,"position":5,"arabic":"ٱتَّبَعُوا۟","translation":"তারা অনুসরণ করেছে","audioUrl":"wbw/047_003_005.mp3","charTypeName":"word"},{"id":2131,"position":6,"arabic":"ٱلْبَـٰطِلَ","translation":"মিথ্যাকে","audioUrl":"wbw/047_003_006.mp3","charTypeName":"word"},{"id":2132,"position":7,"arabic":"وَأَنَّ","translation":"আর নিশ্চয়ই","audioUrl":"wbw/047_003_007.mp3","charTypeName":"word"},{"id":2133,"position":8,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/047_003_008.mp3","charTypeName":"word"},{"id":2134,"position":9,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/047_003_009.mp3","charTypeName":"word"},{"id":2135,"position":10,"arabic":"ٱتَّبَعُوا۟","translation":"তারা অনুসরণ করেছে","audioUrl":"wbw/047_003_010.mp3","charTypeName":"word"},{"id":2136,"position":11,"arabic":"ٱلْحَقَّ","translation":"সত্যকে","audioUrl":"wbw/047_003_011.mp3","charTypeName":"word"},{"id":2137,"position":12,"arabic":"مِن","translation":"(আগত) পক্ষ হতে","audioUrl":"wbw/047_003_012.mp3","charTypeName":"word"},{"id":2138,"position":13,"arabic":"رَّبِّهِمْ ۚ","translation":"তাদের রবের","audioUrl":"wbw/047_003_013.mp3","charTypeName":"word"},{"id":2140,"position":14,"arabic":"كَذَٰلِكَ","translation":"এভাবে","audioUrl":"wbw/047_003_015.mp3","charTypeName":"word"},{"id":2141,"position":15,"arabic":"يَضْرِبُ","translation":"বর্ণনা করেন","audioUrl":"wbw/047_003_016.mp3","charTypeName":"word"},{"id":2142,"position":16,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌","audioUrl":"wbw/047_003_017.mp3","charTypeName":"word"},{"id":2143,"position":17,"arabic":"لِلنَّاسِ","translation":"লোকদের জন্যে","audioUrl":"wbw/047_003_018.mp3","charTypeName":"word"},{"id":2144,"position":18,"arabic":"أَمْثَـٰلَهُمْ","translation":"তাদের দৃষ্টান্ত সমুহ","audioUrl":"wbw/047_003_019.mp3","charTypeName":"word"},{"id":2145,"position":19,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"فَإِذَا لَقِيتُمُ ٱلَّذِينَ كَفَرُوا۟ فَضَرْبَ ٱلرِّقَابِ حَتَّىٰٓ إِذَآ أَثْخَنتُمُوهُمْ فَشُدُّوا۟ ٱلْوَثَاقَ فَإِمَّا مَنًّۢا بَعْدُ وَإِمَّا فِدَآءً حَتَّىٰ تَضَعَ ٱلْحَرْبُ أَوْزَارَهَا ۚ ذَٰلِكَ وَلَوْ يَشَآءُ ٱللَّهُ لَٱنتَصَرَ مِنْهُمْ وَلَٰكِن لِّيَبْلُوَا۟ بَعْضَكُم بِبَعْضٍۢ ۗ وَٱلَّذِينَ قُتِلُوا۟ فِى سَبِيلِ ٱللَّهِ فَلَن يُضِلَّ أَعْمَٰلَهُمْ","translation":"NOW WHEN you meet [in war] those who are bent on denying the truth, smite their necks until you overcome them fully, and then tighten their bonds; but thereafter [set them free,] either by an act of grace or against ransom, so that the burden of war may be lifted: thus [shall it be]. And [know that] had God so willed, He could indeed punish them [Himself]; but [He wills you to struggle] so as to test you [all] by means of one another. And as for those who are slain in God’s cause, never will He let their deeds go to waste:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4549.mp3","surahId":47,"words":[{"id":3408,"position":1,"arabic":"فَإِذَا","translation":"অতঃপর যখন","audioUrl":"wbw/047_004_001.mp3","charTypeName":"word"},{"id":3409,"position":2,"arabic":"لَقِيتُمُ","translation":"তোমরা যুদ্ধে অবতীর্ণ হবে","audioUrl":"wbw/047_004_002.mp3","charTypeName":"word"},{"id":3410,"position":3,"arabic":"ٱلَّذِينَ","translation":"তাদের সাথে (যারা)","audioUrl":"wbw/047_004_003.mp3","charTypeName":"word"},{"id":3411,"position":4,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/047_004_004.mp3","charTypeName":"word"},{"id":3412,"position":5,"arabic":"فَضَرْبَ","translation":"তখন আঘাত করা(প্রথম কাজ)","audioUrl":"wbw/047_004_005.mp3","charTypeName":"word"},{"id":3413,"position":6,"arabic":"ٱلرِّقَابِ","translation":"(তাদের) ঘাড়ে-গর্দানে","audioUrl":"wbw/047_004_006.mp3","charTypeName":"word"},{"id":3414,"position":7,"arabic":"حَتَّىٰٓ","translation":"এমনকি","audioUrl":"wbw/047_004_007.mp3","charTypeName":"word"},{"id":3415,"position":8,"arabic":"إِذَآ","translation":"যখন","audioUrl":"wbw/047_004_008.mp3","charTypeName":"word"},{"id":3416,"position":9,"arabic":"أَثْخَنتُمُوهُمْ","translation":"তাদেরকে সম্পূর্ণভাবে পরাজিত করবে","audioUrl":"wbw/047_004_009.mp3","charTypeName":"word"},{"id":3417,"position":10,"arabic":"فَشُدُّوا۟","translation":"তোমরা তখন শক্ত করে বাঁধবে","audioUrl":"wbw/047_004_010.mp3","charTypeName":"word"},{"id":3418,"position":11,"arabic":"ٱلْوَثَاقَ","translation":"(বন্দীদের) বাঁধন","audioUrl":"wbw/047_004_011.mp3","charTypeName":"word"},{"id":3419,"position":12,"arabic":"فَإِمَّا","translation":"অতঃপর হয়তো","audioUrl":"wbw/047_004_012.mp3","charTypeName":"word"},{"id":3420,"position":13,"arabic":"مَنًّۢا","translation":"অনুকম্পা করবে","audioUrl":"wbw/047_004_013.mp3","charTypeName":"word"},{"id":3421,"position":14,"arabic":"بَعْدُ","translation":"পরে","audioUrl":"wbw/047_004_014.mp3","charTypeName":"word"},{"id":3422,"position":15,"arabic":"وَإِمَّا","translation":"নাহয়","audioUrl":"wbw/047_004_015.mp3","charTypeName":"word"},{"id":3423,"position":16,"arabic":"فِدَآءً","translation":"মুক্তিপণ নেবে","audioUrl":"wbw/047_004_016.mp3","charTypeName":"word"},{"id":3424,"position":17,"arabic":"حَتَّىٰ","translation":"যতক্ষণ না","audioUrl":"wbw/047_004_017.mp3","charTypeName":"word"},{"id":3425,"position":18,"arabic":"تَضَعَ","translation":"সংবরণ করবে","audioUrl":"wbw/047_004_018.mp3","charTypeName":"word"},{"id":3426,"position":19,"arabic":"ٱلْحَرْبُ","translation":"যুদ্ধ","audioUrl":"wbw/047_004_019.mp3","charTypeName":"word"},{"id":3427,"position":20,"arabic":"أَوْزَارَهَا ۚ","translation":"তার অস্ত্রসমূহকে","audioUrl":"wbw/047_004_020.mp3","charTypeName":"word"},{"id":3429,"position":21,"arabic":"ذَٰلِكَ","translation":"এটা (বিধান)","audioUrl":"wbw/047_004_022.mp3","charTypeName":"word"},{"id":3430,"position":22,"arabic":"وَلَوْ","translation":"এবং যদি","audioUrl":"wbw/047_004_023.mp3","charTypeName":"word"},{"id":3431,"position":23,"arabic":"يَشَآءُ","translation":"ইচ্ছে করতেন","audioUrl":"wbw/047_004_024.mp3","charTypeName":"word"},{"id":3432,"position":24,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌ (তবে)","audioUrl":"wbw/047_004_025.mp3","charTypeName":"word"},{"id":3433,"position":25,"arabic":"لَٱنتَصَرَ","translation":"অবশ্যই প্রতিশোধ গ্রহণ করতেন","audioUrl":"wbw/047_004_026.mp3","charTypeName":"word"},{"id":3434,"position":26,"arabic":"مِنْهُمْ","translation":"তাদের হতে","audioUrl":"wbw/047_004_027.mp3","charTypeName":"word"},{"id":3435,"po