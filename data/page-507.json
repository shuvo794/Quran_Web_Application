d them utterly: and the like thereof awaits all who deny the truth.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4555.mp3","surahId":47,"words":[{"id":11021,"position":1,"arabic":"۞ أَفَلَمْ","translation":"নি তবে কি","audioUrl":"wbw/047_010_002.mp3","charTypeName":"word"},{"id":11022,"position":2,"arabic":"يَسِيرُوا۟","translation":"তারা ভ্রমণ করে","audioUrl":"wbw/047_010_003.mp3","charTypeName":"word"},{"id":11023,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/047_010_004.mp3","charTypeName":"word"},{"id":11024,"position":4,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/047_010_005.mp3","charTypeName":"word"},{"id":11025,"position":5,"arabic":"فَيَنظُرُوا۟","translation":"তারা দেখে তখন (নাই)","audioUrl":"wbw/047_010_006.mp3","charTypeName":"word"},{"id":11026,"position":6,"arabic":"كَيْفَ","translation":"কেমন","audioUrl":"wbw/047_010_007.mp3","charTypeName":"word"},{"id":11027,"position":7,"arabic":"كَانَ","translation":"ছিল","audioUrl":"wbw/047_010_008.mp3","charTypeName":"word"},{"id":11028,"position":8,"arabic":"عَـٰقِبَةُ","translation":"পরিণাম","audioUrl":"wbw/047_010_009.mp3","charTypeName":"word"},{"id":11029,"position":9,"arabic":"ٱلَّذِينَ","translation":"(তাদের) যারা","audioUrl":"wbw/047_010_010.mp3","charTypeName":"word"},{"id":11030,"position":10,"arabic":"مِن","translation":"মধ্য হতে","audioUrl":"wbw/047_010_011.mp3","charTypeName":"word"},{"id":11031,"position":11,"arabic":"قَبْلِهِمْ ۚ","translation":"তাদের পূর্বে (ছিল)","audioUrl":"wbw/047_010_012.mp3","charTypeName":"word"},{"id":11033,"position":12,"arabic":"دَمَّرَ","translation":"ধ্বংস করে দিয়েছেন","audioUrl":"wbw/047_010_014.mp3","charTypeName":"word"},{"id":11034,"position":13,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌","audioUrl":"wbw/047_010_015.mp3","charTypeName":"word"},{"id":11035,"position":14,"arabic":"عَلَيْهِمْ ۖ","translation":"তাদেরকে","audioUrl":"wbw/047_010_016.mp3","charTypeName":"word"},{"id":11037,"position":15,"arabic":"و