{"id":528,"ayahs":[{"number":45,"arabic":"وَأَنَّهُۥ خَلَقَ ٱلزَّوْجَيْنِ ٱلذَّكَرَ وَٱلْأُنثَىٰ","translation":"and that it is He who creates the two kinds - the male and the female –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4829.mp3","surahId":53,"words":[{"id":44949,"position":1,"arabic":"وَأَنَّهُۥ","translation":"এবং (এও) যে","audioUrl":"wbw/053_045_001.mp3","charTypeName":"word"},{"id":44950,"position":2,"arabic":"خَلَقَ","translation":"তিনি সৃষ্টি করেছেন","audioUrl":"wbw/053_045_002.mp3","charTypeName":"word"},{"id":44951,"position":3,"arabic":"ٱلزَّوْجَيْنِ","translation":"দুই যুগল","audioUrl":"wbw/053_045_003.mp3","charTypeName":"word"},{"id":44952,"position":4,"arabic":"ٱلذَّكَرَ","translation":"পুরুষ","audioUrl":"wbw/053_045_004.mp3","charTypeName":"word"},{"id":44953,"position":5,"arabic":"وَٱلْأُنثَىٰ","translation":"ও নারী","audioUrl":"wbw/053_045_005.mp3","charTypeName":"word"},{"id":44954,"position":6,"arabic":"٤٥","translation":"(৪৫)","audioUrl":null,"charTypeName":"end"}]},{"number":46,"arabic":"مِن نُّطْفَةٍ إِذَا تُمْنَىٰ","translation":"out of a [mere] drop of sperm as it is poured forth,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4830.mp3","surahId":53,"words":[{"id":45859,"position":1,"arabic":"مِن","translation":"হতে","audioUrl":"wbw/053_046_001.mp3","charTypeName":"word"},{"id":45860,"position":2,"arabic":"نُّطْفَةٍ","translation":"এক ফোঁটা শুক্রবিন্দু","audioUrl":"wbw/053_046_002.mp3","charTypeName":"word"},{"id":45861,"position":3,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/053_046_003.mp3","charTypeName":"word"},{"id":45862,"position":4,"arabic":"تُمْنَىٰ","translation":"স্খলিত হয়","audioUrl":"wbw/053_046_004.mp3","charTypeName":"word"},{"id":45863,"position":5,"arabic":"٤٦","translation":"(৪৬)","audioUrl":null,"charTypeName":"end"}]},{"number":47,"arabic":"وَأَنَّ عَلَيْهِ ٱلنَّشْأَةَ ٱلْأُخْرَىٰ","translation":"and that [therefore] it is within His power to bring about a second life;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4831.mp3","surahId":53,"words":[{"id":46700,"position":1,"arabic":"وَأَنَّ","translation":"এবং (এও) যে","audioUrl":"wbw/053_047_001.mp3","charTypeName":"word"},{"id":46701,"position":2,"arabic":"عَلَيْهِ","translation":"তাঁরই উপর দায়িত্ব","audioUrl":"wbw/053_047_002.mp3","charTypeName":"word"},{"id":46702,"position":3,"arabic":"ٱلنَّشْأَةَ","translation":"উঠানোর","audioUrl":"wbw/053_047_003.mp3","charTypeName":"word"},{"id":46703,"position":4,"arabic":"ٱلْأُخْرَىٰ","translation":"পুনরায়","audioUrl":"wbw/053_047_004.mp3","charTypeName":"word"},{"id":46704,"position":5,"arabic":"٤٧","translation":"(৪৭)","audioUrl":null,"charTypeName":"end"}]},{"number":48,"arabic":"وَأَنَّهُۥ هُوَ أَغْنَىٰ وَأَقْنَىٰ","translation":"and that it is He alone who frees from want and causes to possess;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4832.mp3","surahId":53,"words":[{"id":47646,"position":1,"arabic":"وَأَنَّهُۥ","translation":"এবং (এও) যে","audioUrl":"wbw/053_048_001.mp3","charTypeName":"word"},{"id":47647,"position":2,"arabic":"هُوَ","translation":"তিনিই","audioUrl":"wbw/053_048_002.mp3","charTypeName":"word"},{"id":47648,"position":3,"arabic":"أَغْنَىٰ","translation":"অভাব দূর করেন","audioUrl":"wbw/053_048_003.mp3","charTypeName":"word"},{"id":47649,"position":4,"arabic":"وَأَقْنَىٰ","translation":"ও সম্পদ দান করেন","audioUrl":"wbw/053_048_004.mp3","charTypeName":"word"},{"id":47650,"position":5,"arabic":"٤٨","translation":"(৪৮)","audioUrl":null,"charTypeName":"end"}]},{"number":49,"arabic":"وَأَنَّهُۥ هُوَ رَبُّ ٱلشِّعْرَىٰ","translation":"and that it is He alone who sustains the bright­est star;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4833.mp3","surahId":53,"words":[{"id":48314,"position":1,"arabic":"وَأَنَّهُۥ","translation":"এবং (এও) যে","audioUrl":"wbw/053_049_001.mp3","charTypeName":"word"},{"id":48315,"position":2,"arabic":"هُوَ","translation":"তিনিই","audioUrl":"wbw/053_049_002.mp3","charTypeName":"word"},{"id":48316,"position":3,"arabic":"رَبُّ","translation":"রব","audioUrl":"wbw/053_049_003.mp3","charTypeName":"word"},{"id":48317,"position":4,"arabic":"ٱلشِّعْرَىٰ","translation":"শি'রা (নক্ষত্রের)","audioUrl":"wbw/053_049_004.mp3","charTypeName":"word"},{"id":48318,"position":5,"arabic":"٤٩","translation":"(৪৯)","audioUrl":null,"charTypeName":"end"}]},{"number":50,"arabic":"وَأَنَّهُۥٓ أَهْلَكَ عَادًا ٱلْأُولَىٰ","translation":"and that it is He who destroyed the ancient [tribes of] Ad","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4834.mp3","surahId":53,"words":[{"id":48615,"position":1,"arabic":"وَأَنَّهُۥٓ","translation":"এবং (এও) যে","audioUrl":"wbw/053_050_001.mp3","charTypeName":"word"},{"id":48616,"position":2,"arabic":"أَهْلَكَ","translation":"তিনি ধ্বংস করেছেন","audioUrl":"wbw/053_050_002.mp3","charTypeName":"word"},{"id":48617,"position":3,"arabic":"عَادًا","translation":"আদকে","audioUrl":"wbw/053_050_003.mp3","charTypeName":"word"},{"id":48618,"position":4,"arabic":"ٱلْأُولَىٰ","translation":"প্রথম","audioUrl":"wbw/053_050_004.mp3","charTypeName":"word"},{"id":48619,"position":5,"arabic":"٥٠","translation":"(৫০)","audioUrl":null,"charTypeName":"end"}]},{"number":51,"arabic":"وَثَمُودَا۟ فَمَآ أَبْقَىٰ","translation":"and Thamud, leaving no trace [of them],","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4835.mp3","surahId":53,"words":[{"id":49648,"position":1,"arabic":"وَثَمُودَا۟","translation":"এবং সামুদকেও","audioUrl":"wbw/053_051_001.mp3","charTypeName":"word"},{"id":49649,"position":2,"arabic":"فَمَآ","translation":"অতঃপর না","audioUrl":"wbw/053_051_002.mp3","charTypeName":"word"},{"id":49650,"position":3,"arabic":"أَبْقَىٰ","translation":"অবশিষ্ট রেখেছেন","audioUrl":"wbw/053_051_003.mp3","charTypeName":"word"},{"id":49651,"position":4,"arabic":"٥١","translation":"(৫১)","audioUrl":null,"charTypeName":"end"}]},{"number":52,"arabic":"وَقَوْمَ نُوحٍۢ مِّن قَبْلُ ۖ إِنَّهُمْ كَانُوا۟ هُمْ أَظْلَمَ وَأَطْغَىٰ","translation":"as well as the people of Noah before them - [since,] verily, they all had been most willful in their evildoing and most overweening –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4836.mp3","surahId":53,"words":[{"id":50274,"position":1,"arabic":"وَقَوْمَ","translation":"এবং জাতিকে","audioUrl":"wbw/053_052_001.mp3","charTypeName":"word"},{"id":50275,"position":2,"arabic":"نُوحٍۢ","translation":"নূহের","audioUrl":"wbw/053_052_002.mp3","charTypeName":"word"},{"id":50276,"position":3,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/053_052_003.mp3","charTypeName":"word"},{"id":50277,"position":4,"arabic":"قَبْلُ ۖ","translation":"ইতিপূর্বে(ধংস করেছেন)","audioUrl":"wbw/053_052_004.mp3","charTypeName":"word"},{"id":50279,"position":5,"arabic":"إِنَّهُمْ","translation":"তারা নিশ্চয়ই","audioUrl":"wbw/053_052_006.mp3","charTypeName":"word"},{"id":50280,"position":6,"arabic":"كَانُوا۟","translation":"ছিল","audioUrl":"wbw/053_052_007.mp3","charTypeName":"word"},{"id":50281,"position":7,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/053_052_008.mp3","charTypeName":"word"},{"id":50282,"position":8,"arabic":"أَظْلَمَ","translation":"বড়ই সীমালঙ্ঘনকারী","audioUrl":"wbw/053_052_009.mp3","charTypeName":"word"},{"id":50283,"position":9,"arabic":"وَأَطْغَىٰ","translation":"ও অতি অবাধ্য","audioUrl":"wbw/053_052_010.mp3","charTypeName":"word"},{"id":50284,"position":10,"arabic":"٥٢","translation":"(৫২)","audioUrl":null,"charTypeName":"end"}]},{"number":53,"arabic":"وَٱلْمُؤْتَفِكَةَ أَهْوَىٰ","translation":"just as He thrust into perdition those cities that were overthrown","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4837.mp3","surahId":53,"words":[{"id":50919,"position":1,"arabic":"وَٱلْمُؤْتَفِكَةَ","translation":"এবং উল্টে দেওয়া জনবসতিসমূহকে","audioUrl":"wbw/053_053_001.mp3","charTypeName":"word"},{"id":50920,"position":2,"arabic":"أَهْوَىٰ","translation":"শূন্যে তুলে নিক্ষেপ করেছিলেন","audioUrl":"wbw/053_053_002.mp3","charTypeName":"word"},{"id":50921,"position":3,"arabic":"٥٣","translation":"(৫৩)","audioUrl":null,"charTypeName":"end"}]},{"number":54,"arabic":"فَغَشَّىٰهَا مَا غَشَّىٰ","translation":"and then covered them from sight forever.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4838.mp3","surahId":53,"words":[{"id":51535,"position":1,"arabic":"فَغَشَّىٰهَا","translation":"তাকে অতঃপর ঢেকে দিল","audioUrl":"wbw/053_054_001.mp3","charTypeName":"word"},{"id":51536,"position":2,"arabic":"مَا","translation":"যা","audioUrl":"wbw/053_054_002.mp3","charTypeName":"word"},{"id":51537,"position":3,"arabic":"غَشَّىٰ","translation":"ঢেকে দেওয়ার ছিল","audioUrl":"wbw/053_054_003.mp3","charTypeName":"word"},{"id":51538,"position":4,"arabic":"٥٤","translation":"(৫৪)","audioUrl":null,"charTypeName":"end"}]},{"number":55,"arabic":"فَبِأَىِّ ءَالَآءِ رَبِّكَ تَتَمَارَىٰ","translation":"About which, then, of thy Sustainer’s powers canst thou [still] remain in doubt?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4839.mp3","surahId":53,"words":[{"id":51989,"position":1,"arabic":"فَبِأَىِّ","translation":"অতএব কোন","audioUrl":"wbw/053_055_001.mp3","charTypeName":"word"},{"id":51990,"position":2,"arabic":"ءَالَآءِ","translation":"অনুগ্রহ সমূহকে","audioUrl":"wbw/053_055_002.mp3","charTypeName":"word"},{"id":51991,"position":3,"arabic":"رَبِّكَ","translation":"তোমার রবের","audioUrl":"wbw/053_055_003.mp3","charTypeName":"word"},{"id":51992,"position":4,"arabic":"تَتَمَارَىٰ","translation":"তুমি সন্দেহ করবে","audioUrl":"wbw/053_055_004.mp3","charTypeName":"word"},{"id":51993,"position":5,"arabic":"٥٥","translation":"(৫৫)","audioUrl":null,"charTypeName":"end"}]},{"number":56,"arabic":"هَٰذَا نَذِيرٌۭ مِّنَ ٱلنُّذُرِ ٱلْأُولَىٰٓ","translation":"THIS IS a warning like those warnings of old:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4840.mp3","surahId":53,"words":[{"id":52182,"position":1,"arabic":"هَـ