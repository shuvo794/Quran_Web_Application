ame":"word"},{"id":53256,"position":5,"arabic":"ٱللَّهِ","translation":"আল্লাহ","audioUrl":"wbw/053_058_005.mp3","charTypeName":"word"},{"id":53257,"position":6,"arabic":"كَاشِفَةٌ","translation":"কোনো প্রকাশকারী","audioUrl":"wbw/053_058_006.mp3","charTypeName":"word"},{"id":53258,"position":7,"arabic":"٥٨","translation":"(৫৮)","audioUrl":null,"charTypeName":"end"}]},{"number":59,"arabic":"أَفَمِنْ هَٰذَا ٱلْحَدِيثِ تَعْجَبُونَ","translation":"Do you, perchance, find this tiding strange?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4843.mp3","surahId":53,"words":[{"id":54094,"position":1,"arabic":"أَفَمِنْ","translation":"তবে কি হতে","audioUrl":"wbw/053_059_001.mp3","charTypeName":"word"},{"id":54095,"position":2,"arabic":"هَـٰذَا","translation":"এই","audioUrl":"wbw/053_059_002.mp3","charTypeName":"word"},{"id":54096,"position":3,"arabic":"ٱلْحَدِيثِ","translation":"কথা","audioUrl":"wbw/053_059_003.mp3","charTypeName":"word"},{"id":54097,"position":4,"arabic":"تَعْجَبُونَ","translation":"তোমরা অবাক হচ্ছ","audioUrl":"wbw/053_059_004.mp3","charTypeName":"word"},{"id":54098,"position":5,"arabic":"٥٩","translation":"(৫৯)","audioUrl":null,"charTypeName":"end"}]},{"number":60,"arabic":"وَتَضْحَكُونَ وَلَا تَبْكُونَ","translation":"And do you laugh instead of weeping,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4844.mp3","surahId":53,"words":[{"id":54420,"position":1,"arabic":"وَتَضْحَكُونَ","translation":"এবং তোমরা হাসি ঠাট্টা করছ","audioUrl":"wbw/053_060_001.mp3","charTypeName":"word"},{"id":54421,"position":2,"arabic":"وَلَا","translation":"অথচ না","audioUrl":"wbw/053_060_002.mp3","charTypeName":"word"},{"id":54422,"position":3,"arabic":"تَبْكُونَ","translation":"তোমরা কাঁদছ","audioUrl":"wbw/053_060_003.mp3","charTypeName":"word"},{"id":54423,"position":4,"arabic":"٦٠","translation":"(৬০)","audioUrl":null,"charTypeName":"end"}]},{"number":61,"arabic":"وَأَنتُمْ سَٰمِدُونَ","translation":"and divert yourselves all the while?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4845.mp3","surahId":53,"words":[{"id":55410,"position":1,"arabic":"وَأَنتُمْ","translation":"এবং তোমরা","audioUrl":"wbw/053_061_001.mp3","charTypeName":"word"},{"id":55411,"position":2,"arabic":"سَـٰمِدُونَ","translation":"উদাসীন হয়ে আছ","audioUrl":"wbw/053_061_002.mp3","charTypeName":"word"},{"id":55412,"position":3,"arabic":"٦١","translation":"(৬১)","audioUrl":null,"charTypeName":"end"}]},{"number":62,"arabic":"فَٱسْجُدُوا۟ لِلَّهِ وَٱعْبُدُوا۟ ۩","translation":"[Nay,] but prostrate yourselves before God, and worship [Him alone]!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4846.mp3","surahId":53,"words":[{"id":55823,"position":1,"arabic":"فَٱسْجُدُوا۟","translation":"অতএব তোমরা সিজদা করো","audioUrl":"wbw/053_062_001.mp3","charTypeName":"word"},{"id":55824,"position":2,"arabic":"لِلَّهِ","translation":"আল্লাহরই জন্যে","audioUrl":"wbw/053_062_002.mp3","charTypeName":"word"},{"id":55825,"position":3,"arabic":"وَٱعْبُدُوا۟ ۩","translation":"এবং তোমরা ইবাদত (সিজদা) করো (তাঁরই)","audioUrl":"wbw/053_062_003.mp3","charTypeName":"word"},{"id":55827,"position":4,"arabic":"٦٢","translation":"(৬২)","audioUrl":null,"charTypeName":"end"}]},{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ ٱقْتَرَبَتِ ٱلسَّاعَةُ وَٱنشَقَّ ٱلْقَمَرُ","translation":"THE LAST HOUR draws near, and the moon is split asunder!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4847.mp3","surahId":54,"words":[{"id":292,"position":1,"arabic":"ٱقْتَرَبَتِ","translation":"নিকটবর্তী হয়েছে","audioUrl":"wbw/054_001_001.mp3","charTypeName":"word"},{"id":293,"position":2,"arabic":"ٱلسَّاعَةُ","translation":"কিয়ামত","audioUrl":"wbw/054_001_002.mp3","charTypeName":"word"},{"id":294,"position":3,"arabic":"وَٱنشَقَّ","translation":"এবং বিদীর্ণ হয়েছে","audioUrl":"wbw/054_001_003.mp3","charTypeName":"word"},{"id":295,"position":4,"arabic":"ٱلْقَمَرُ","translation":"চাঁদ","audioUrl":"wbw/054_001_004.mp3","charTypeName":"word"},{"id":296,"position":5,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"وَإِن يَرَوْا۟ ءَايَةًۭ يُعْرِضُوا۟ وَيَقُولُوا۟ سِحْرٌۭ مُّسْتَمِرٌّۭ","translation":"But if they [who reject all thought of the Last Hour] were to see a sign [of its approach], they would turn aside and say, “An ever-recurring delusion!” –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4848.mp3","surahId":54,"words":[{"id":1168,"position":1,"arabic":"وَإِن","translation":"কিন্তু যদি","audioUrl":"wbw/054_002_001.mp3","charTypeName":"word"},{"id":1169,"position":2,"arabic":"يَرَوْا۟","translation":"তারা দেখে","audioUrl":"wbw/054_002_002.mp3","charTypeName":"word"},{"id":1170,"position":3,"arabic":"ءَايَةًۭ","translation":"কোনো নিদর্শন","audioUrl":"wbw/054_002_003.mp3","charTypeName":"word"},{"id":1171,"position":4,"arabic":"يُعْرِضُوا۟","translation":"তারা মুখ ফিরিয়ে নেয়","audioUrl":"wbw/054_002_004.mp3","charTypeName":"word"},{"id":1172,"position":5,"arabic":"وَيَقُولُوا۟","translation":"এবং তারা বলে","audioUrl":"wbw/054_002_005.mp3","charTypeName":"word"},{"id":1173,"position":6,"arabic":"سِحْرٌۭ","translation":"\"(এটা) জাদু","audioUrl":"wbw/054_002_006.mp3","charTypeName":"word"},{"id":1174,"position":7,"arabic":"مُّسْتَمِرٌّۭ","translation":"চিরাচরিত\"","audioUrl":"wbw/054_002_007.mp3","charTypeName":"word"},{"id":1175,"position":8,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"وَكَذَّبُوا۟ وَٱتَّبَعُوٓا۟ أَهْوَآءَهُمْ ۚ وَكُلُّ أَمْرٍۢ مُّسْتَقِرٌّۭ","translation":"for they are bent on giving it the lie, being always wont to follow their own desires. Yet everything reveals its truth in the end.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4849.mp3","surahId":54,"words":[{"id":2226,"position":1,"arabic":"وَكَذَّبُوا۟","translation":"এবং তারা মিথ্যারোপ করেছে","audioUrl":"wbw/054_003_001.mp3","charTypeName":"word"},{"id":2227,"position":2,"arabic":"وَٱتَّبَعُوٓا۟","translation":"ও অনুসরণ করেছে","audioUrl":"wbw/054_003_002.mp3","charTypeName":"word"},{"id":2228,"position":3,"arabic":"أَهْوَآءَهُمْ ۚ","translation":"তাদের খেয়ালখুশির","audioUrl":"wbw/054_003_003.mp3","charTypeName":"word"},{"id":2230,"position":4,"arabic":"وَكُلُّ","translation":"এবং প্রত্যেক","audioUrl":"wbw/054_003_005.mp3","charTypeName":"word"},{"id":2231,"position":5,"arabic":"أَمْرٍۢ","translation":"কাজই","audioUrl":"wbw/054_003_006.mp3","charTypeName":"word"},{"id":2232,"position":6,"arabic":"مُّسْتَقِرٌّۭ","translation":"লক্ষ্যে পৌঁছুবে","audioUrl":"wbw/054_003_007.mp3","charTypeName":"word"},{"id":2233,"position":7,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"وَلَقَدْ جَآءَهُم مِّنَ ٱلْأَنۢبَآءِ مَا فِيهِ مُزْدَجَرٌ","translation":"And withal, there has come unto them many a tiding that should have restrained [their arrogance]:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4850.mp3","surahId":54,"words":[{"id":3544,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/054_004_001.mp3","charTypeName":"word"},{"id":3545,"position":2,"arabic":"جَآءَهُم","translation":"তাদের কাছে এসেছে","audioUrl":"wbw/054_004_002.mp3","charTypeName":"word"},{"id":3546,"position":3,"arabic":"مِّنَ","translation":"হতে","audioUrl":"wbw/054_004_003.mp3","charTypeName":"word"},{"id":3547,"position":4,"arabic":"ٱلْأَنۢبَآءِ","translation":"সংবাদ গুলো(অতীত জাতিসমূহের)","audioUrl":"wbw/054_004_004.mp3","charTypeName":"word"},{"id":3548,"position":5,"arabic":"مَا","translation":"যার","audioUrl":"wbw/054_004_005.mp3","charTypeName":"word"},{"id":3549,"position":6,"arabic":"فِيهِ","translation":"মধ্যে আছে","audioUrl":"wbw/054_004_006.mp3","charTypeName":"word"},{"id":3550,"position":7,"arabic":"مُزْدَجَرٌ","translation":"সতর্কবাণী","audioUrl":"wbw/054_004_007.mp3","charTypeName":"word"},{"id":3551,"position":8,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"حِكْمَةٌۢ بَٰلِغَةٌۭ ۖ فَمَا تُغْنِ ٱلنُّذُرُ","translation":"far-reaching wisdom [was held out to them]: but [since] all warnings have been of no avail,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4851.mp3","surahId":54,"words":[{"id":4902,"position":1,"arabic":"حِكْمَةٌۢ","translation":"প্রজ্ঞা","audioUrl":"wbw/054_005_001.mp3","charTypeName":"word"},{"id":4903,"position":2,"arabic":"بَـٰلِغَةٌۭ ۖ","translation":"পরিপূর্ণ","audioUrl":"wbw/054_005_002.mp3","charTypeName":"word"},{"id":4905,"position":3,"arabic":"فَمَا","translation":"না কিন্তু","audioUrl":"wbw/054_005_004.mp3","charTypeName":"word"},{"id":4906,"position":4,"arabic":"تُغْنِ","translation":"কাজে আসে","audioUrl":"wbw/054_005_005.mp3","charTypeName":"word"},{"id":4907,"position":5,"arabic":"ٱلنُّذُرُ","translation":"সতর্কবাণী (তাদের জন্য)","audioUrl":"wbw/054_005_006.mp3","charTypeName":"word"},{"id":4908,"position":6,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"فَتَوَلَّ عَنْهُمْ ۘ يَوْمَ يَدْعُ ٱلدَّاعِ إِلَىٰ شَىْءٍۢ نُّكُرٍ","translation":"turn thou away from them. On the Day when the Summoning Voice will sum­mon [man] unto something that the mind cannot conceive,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4852.mp3","surahId":54,"words":[{"id":6152,"position":1,"arabic":"فَتَوَلَّ","translation":"(হে নবী) অতএব মুখ ফিরাও/ উপেক্ষা করো","audioUrl":"wbw/054_006_001.mp3","charTypeName":"word"},{"id":6153,"position":2,"arabic":"عَنْهُمْ ۘ","translation":"তাদের হতে","audioUrl":"wbw/054_006_002.mp3","charTypeName":"word"},{"id":6155,"position":3,"arabic":"يَوْمَ","translation":"যেদিন","audioUrl":"wbw/054_006_004.mp3","charTypeName":"word"},{"id":6156,"position":4,"arabic":"يَدْعُ","translation":"আহ্বান করবে","audioUrl":"wbw/054_006_005.mp3","charTypeName":"word"},{"id":6157,"position":5,"arabic":"ٱلدَّاعِ","translation":"এক আহ্বানকারী","audioUrl":"wbw/054_006_006.mp3","charTypeName":"word"},{"id":6158,"position":6,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/054_006_007.mp3","charTypeName":"word"},{"id":6159,"position":7,"arabic":"شَىْءٍۢ","translation":"একটা জিনিসের","audioUrl":"wbw/054_006_008.mp3","charTypeName":"word"},{"id":6160,"position":8,"arabic":"نُّكُرٍ","translation":"অপ্রীতিকর","audioUrl":"wbw/054_006_009.mp3","charTypeName":"word"},{"id":6161,"position":9,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]}]}