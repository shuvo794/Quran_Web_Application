{"id":320,"ayahs":[{"number":114,"arabic":"فَتَعَٰلَى ٱللَّهُ ٱلْمَلِكُ ٱلْحَقُّ ۗ وَلَا تَعْجَلْ بِٱلْقُرْءَانِ مِن قَبْلِ أَن يُقْضَىٰٓ إِلَيْكَ وَحْيُهُۥ ۖ وَقُل رَّبِّ زِدْنِى عِلْمًۭا","translation":"[Know,] then, [that) God is sublimely exalted. the Ultimate Sovereign, the Ultimate Truth and [knowing this,] do not approach the Qur'an in haste, ere it has been revealed unto thee in full, but [always) say: \"O my Sustainer, cause me to grow in knowledge!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2462.mp3","surahId":20,"words":[{"id":75116,"position":1,"arabic":"فَتَعَـٰلَى","translation":"সুতরাং মহান","audioUrl":"wbw/020_114_001.mp3","charTypeName":"word"},{"id":75117,"position":2,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/020_114_002.mp3","charTypeName":"word"},{"id":75118,"position":3,"arabic":"ٱلْمَلِكُ","translation":"অধিপতি","audioUrl":"wbw/020_114_003.mp3","charTypeName":"word"},{"id":75119,"position":4,"arabic":"ٱلْحَقُّ ۗ","translation":"সত্যিকার","audioUrl":"wbw/020_114_004.mp3","charTypeName":"word"},{"id":75121,"position":5,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/020_114_006.mp3","charTypeName":"word"},{"id":75122,"position":6,"arabic":"تَعْجَلْ","translation":"তাড়াহুড়া করো","audioUrl":"wbw/020_114_007.mp3","charTypeName":"word"},{"id":75123,"position":7,"arabic":"بِٱلْقُرْءَانِ","translation":"নিয়ে কুরআন (পাঠে)","audioUrl":"wbw/020_114_008.mp3","charTypeName":"word"},{"id":75124,"position":8,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/020_114_009.mp3","charTypeName":"word"},{"id":75125,"position":9,"arabic":"قَبْلِ","translation":"এর পূর্ব","audioUrl":"wbw/020_114_010.mp3","charTypeName":"word"},{"id":75126,"position":10,"arabic":"أَن","translation":"যে","audioUrl":"wbw/020_114_011.mp3","charTypeName":"word"},{"id":75127,"position":11,"arabic":"يُقْضَىٰٓ","translation":"সম্পূর্ণ করা হয়","audioUrl":"wbw/020_114_012.mp3","charTypeName":"word"},{"id":75128,"position":12,"arabic":"إِلَيْكَ","translation":"তোমার প্রতি","audioUrl":"wbw/020_114_013.mp3","charTypeName":"word"},{"id":75129,"position":13,"arabic":"وَحْيُهُۥ ۖ","translation":"তার ওহী(প্রেরণ)","audioUrl":"wbw/020_114_014.mp3","charTypeName":"word"},{"id":75131,"position":14,"arabic":"وَقُل","translation":"এবং বলো","audioUrl":"wbw/020_114_016.mp3","charTypeName":"word"},{"id":75132,"position":15,"arabic":"رَّبِّ","translation":"\"হে আমার রব","audioUrl":"wbw/020_114_017.mp3","charTypeName":"word"},{"id":75133,"position":16,"arabic":"زِدْنِى","translation":"আমাকে বাড়িয়ে দাও","audioUrl":"wbw/020_114_018.mp3","charTypeName":"word"},{"id":75134,"position":17,"arabic":"عِلْمًۭا","translation":"জ্ঞান\"","audioUrl":"wbw/020_114_019.mp3","charTypeName":"word"},{"id":75135,"position":18,"arabic":"١١٤","translation":"(১১৪)","audioUrl":null,"charTypeName":"end"}]},{"number":115,"arabic":"وَلَقَدْ عَهِدْنَآ إِلَىٰٓ ءَادَمَ مِن قَبْلُ فَنَسِىَ وَلَمْ نَجِدْ لَهُۥ عَزْمًۭا","translation":"AND, INDEED, long ago did We impose Our commandment on Adam; but he forgot it, and We found no firmness of purpose in him.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2463.mp3","surahId":20,"words":[{"id":75315,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/020_115_001.mp3","charTypeName":"word"},{"id":75316,"position":2,"arabic":"عَهِدْنَآ","translation":"আমরা নির্দেশ দিয়েছিলাম","audioUrl":"wbw/020_115_002.mp3","charTypeName":"word"},{"id":75317,"position":3,"arabic":"إِلَىٰٓ","translation":"প্রতি","audioUrl":"wbw/020_115_003.mp3","charTypeName":"word"},{"id":75318,"position":4,"arabic":"ءَادَمَ","translation":"আদমের","audioUrl":"wbw/020_115_004.mp3","charTypeName":"word"},{"id":75319,"position":5,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/020_115_005.mp3","charTypeName":"word"},{"id":75320,"position":6,"arabic":"قَبْلُ","translation":"ইতিপূর্ব","audioUrl":"wbw/020_115_006.mp3","charTypeName":"word"},{"id":75321,"position":7,"arabic":"فَنَسِىَ","translation":"কিন্তু সে ভুলে যায়","audioUrl":"wbw/020_115_007.mp3","charTypeName":"word"},{"id":75322,"position":8,"arabic":"وَلَمْ","translation":"এবং নি","audioUrl":"wbw/020_115_008.mp3","charTypeName":"word"},{"id":75323,"position":9,"arabic":"نَجِدْ","translation":"আমরা পাই","audioUrl":"wbw/020_115_009.mp3","charTypeName":"word"},{"id":75324,"position":10,"arabic":"لَهُۥ","translation":"তার মধ্যে","audioUrl":"wbw/020_115_010.mp3","charTypeName":"word"},{"id":75325,"position":11,"arabic":"عَزْمًۭا","translation":"দৃঢ় সংকল্প","audioUrl":"wbw/020_115_011.mp3","charTypeName":"word"},{"id":75326,"position":12,"arabic":"١١٥","translation":"(১১৫)","audioUrl":null,"charTypeName":"end"}]},{"number":116,"arabic":"وَإِذْ قُلْنَا لِلْمَلَٰٓئِكَةِ ٱسْجُدُوا۟ لِءَادَمَ فَسَجَدُوٓا۟ إِلَّآ إِبْلِيسَ أَبَىٰ","translation":"For [thus it was:] when We told the angels, \"Prostrate yourselves before Adam!\"- they all prostrated themselves, save Ibis, who refused [to do it];","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2464.mp3","surahId":20,"words":[{"id":75563,"position":1,"arabic":"وَإِذْ","translation":"এবং(স্মরণ করো) যখন","audioUrl":"wbw/020_116_001.mp3","charTypeName":"word"},{"id":75564,"position":2,"arabic":"قُلْنَا","translation":"আমরা বলেছিলাম","audioUrl":"wbw/020_116_002.mp3","charTypeName":"word"},{"id":75565,"position":3,"arabic":"لِلْمَلَـٰٓئِكَةِ","translation":"ফিরিশতাদেরকে","audioUrl":"wbw/020_116_003.mp3","charTypeName":"word"},{"id":75566,"position":4,"arabic":"ٱسْجُدُوا۟","translation":"\"তোমরা সিজদা করো","audioUrl":"wbw/020_116_004.mp3","charTypeName":"word"},{"id":75567,"position":5,"arabic":"لِـَٔادَمَ","translation":"জন্য আদমের\"","audioUrl":"wbw/020_116_005.mp3","charTypeName":"word"},{"id":75568,"position":6,"arabic":"فَسَجَدُوٓا۟","translation":"তখন তারা সিজদা করলো","audioUrl":"wbw/020_116_006.mp3","charTypeName":"word"},{"id":75569,"position":7,"arabic":"إِلَّآ","translation":"কিন্তু","audioUrl":"wbw/020_116_007.mp3","charTypeName":"word"},{"id":75570,"position":8,"arabic":"إِبْلِيسَ","translation":"ইবলিস (করলো না)","audioUrl":"wbw/020_116_008.mp3","charTypeName":"word"},{"id":75571,"position":9,"arabic":"أَبَىٰ","translation":"সে অমান্য করলো","audioUrl":"wbw/020_116_009.mp3","charTypeName":"word"},{"id":75572,"position":10,"arabic":"١١٦","translation":"(১১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":117,"arabic":"فَقُلْنَا يَٰٓـَٔادَمُ إِنَّ هَٰذَا عَدُوٌّۭ لَّكَ وَلِزَوْجِكَ فَلَا يُخْرِجَنَّكُمَا مِنَ ٱلْجَنَّةِ فَتَشْقَىٰٓ","translation":"and thereupon We said: \"O Adam! Verily, this is a foe unto thee and thy wife: so let him not drive the two of you out of this garden and render thee unhappy.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2465.mp3","surahId":20,"words":[{"id":75808,"position":1,"arabic":"فَقُلْنَا","translation":"তখন আমরা বললাম","audioUrl":"wbw/020_117_001.mp3","charTypeName":"word"},{"id":75809,"position":2,"arabic":"يَـٰٓـَٔادَمُ","translation":"\"হে আদম","audioUrl":"wbw/020_117_002.mp3","charTypeName":"word"},{"id":75810,"position":3,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/020_117_003.mp3","charTypeName":"word"},{"id":75811,"position":4,"arabic":"هَـٰذَا","translation":"এটা","audioUrl":"wbw/020_117_004.mp3","charTypeName":"word"},{"id":75812,"position":5,"arabic":"عَدُوٌّۭ","translation":"শত্রু","audioUrl":"wbw/020_117_005.mp3","charTypeName":"word"},{"id":75813,"position":6,"arabic":"لَّكَ","translation":"জন্য তোমার","audioUrl":"wbw/020_117_006.mp3","charTypeName":"word"},{"id":75814,"position":7,"arabic":"وَلِزَوْجِكَ","translation":"এবং জন্য তোমার স্ত্রীর","audioUrl":"wbw/020_117_007.mp3","charTypeName":"word"},{"id":75815,"position":8,"arabic":"فَلَا","translation":"অতএব না যেন","audioUrl":"wbw/020_117_008.mp3","charTypeName":"word"},{"id":75816,"position":9,"arabic":"يُخْرِجَنَّكُمَا","translation":"তোমাদের দু'জনকে বের করে দেয়","audioUrl":"wbw/020_117_009.mp3","charTypeName":"word"},{"id":75817,"position":10,"arabic":"مِنَ","translation":"হ'তে","audioUrl":"wbw/020_117_010.mp3","charTypeName":"word"},{"id":75818,"position":11,"arabic":"ٱلْجَنَّةِ","translation":"জান্নাত","audioUrl":"wbw/020_117_011.mp3","charTypeName":"word"},{"id":75819,"position":12,"arabic":"فَتَشْقَىٰٓ","translation":"ফলে তুমি কষ্টে পড়বে","audioUrl":"wbw/020_117_012.mp3","charTypeName":"word"},{"id":75820,"position":13,"arabic":"١١٧","translation":"(১১৭)","audioUrl":null,"charTypeName":"end"}]},{"number":118,"arabic":"إِنَّ لَكَ أَلَّا تَجُوعَ فِيهَا وَلَا تَعْرَىٰ","translation":"Behold, it is provided for thee that thou shalt not hunger here or feel naked,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2466.mp3","surahId":20,"words":[{"id":75937,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/020_118_001.mp3","charTypeName":"word"},{"id":75938,"position":2,"arabic":"لَكَ","translation":"জন্যে তোমার","audioUrl":"wbw/020_118_002.mp3","charTypeName":"word"},{"id":75939,"position":3,"arabic":"أَلَّا","translation":"(এ ব্যবস্থা) যে না","audioUrl":"wbw/020_118_003.mp3","charTypeName":"word"},{"id":75940,"position":4,"arabic":"تَجُوعَ","translation":"তুমি ক্ষুধার্ত হবে","audioUrl":"wbw/020_118_004.mp3","charTypeName":"word"},{"id":75941,"position":5,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/020_118_005.mp3","charTypeName":"word"},{"id":75942,"position":6,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/020_118_006.mp3","charTypeName":"word"},{"id":75943,"position":7,"arabic":"تَعْرَىٰ","translation":"তুমি উলঙ্গ হবে","audioUrl":"wbw/020_118_007.mp3","charTypeName":"word"},{"id":75944,"position":8,"arabic":"١١٨","translation":"(১১৮)","audioUrl":null,"charTypeName":"end"}]},{"number":119,"arabic":"وَأَنَّكَ لَا تَظْمَؤُا۟ فِيهَا وَلَا تَضْحَىٰ","translation":"and that thou shalt not thirst here or suffer from the heat of the sun.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2467.mp3","surahId":20,"words":[{"id":76107,"position":1,"arabic":"وَأَنَّكَ","translation":"এবং (এও) যে তুমি","audioUrl":"wbw/020_119_001.mp3","charTypeName":"word"},{"id":76108,"position":2,"arabic":"لَا","translation":"না","audioUrl":"wbw/020_119_002.mp3","charTypeName":"word"},{"id":76109,"position":3,"arabic":"تَظْمَؤُا۟","translation":"পিপাসার্ত হবে","audioUrl":"wbw/020_119_003.mp3","charTypeName":"word"},{"id":76110,"position":4,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/020_119_004.mp3","charTypeName":"word"},{"id":76111,"position":5,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/020_119_005.mp3","charTypeName":"word"},{"id":76112,"position":6,"arabic":"تَضْحَىٰ","translation":"রোদে উতপ্ত হবে","audioUrl":"wbw/020_119_006.mp3","charTypeName":"word"},{"id":76113,"position":7,"arabic":"١١٩","translation":"(১১৯)","audioUrl":null,"charTypeName":"end"}]},{"number":120,"arabic":"فَوَسْوَسَ إِلَيْهِ ٱلشَّيْطَٰنُ قَالَ يَٰٓـَٔادَمُ هَلْ أَدُلُّكَ عَلَىٰ شَجَرَةِ ٱلْخُلْدِ وَمُلْكٍۢ لَّا يَبْلَىٰ","translation":"But Satan whispered unto him, saying: \"O Adam! Shall I lead thee to the tree of life eternal; and [thus] to a kingdom that will never decay?\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2468.mp3","surahId":20,"words":[{"id":76499,"position":1,"arabic":"فَوَسْوَسَ","translation":"কিন্তু কুমন্ত্রনা দিলো","audioUrl":"wbw/020_120_001.mp3","charTypeName":"word"},{"id":76500,"position":2,"arabic":"إِلَيْهِ","translation":"তার দিকে","audioUrl":"wbw/020_120_002.mp3","charTypeName":"word"},{"id":76501,"position":3,"arabic":"ٱلشَّيْطَـٰنُ","translation":"শয়তান","audioUrl":"wbw/020_120_003.mp3","charTypeName":"word"},{"id":76502,"position":4,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/020_120_004.mp3","charTypeName":"word"},{"id":76503,"position":5,"arabic":"يَـٰٓـَٔادَمُ","translation":"\"হে আদম","audioUrl":"wbw/020_120_005.mp3","charTypeName":"word"},{"id":76504,"position":6,"arabic":"هَلْ","translation":"কি","audioUrl":"wbw/020_120_006.mp3","charTypeName":"word"},{"id":76505,"position":7,"arabic":"أَدُلُّكَ","translation":"তোমাকে আমি বলে দিবো","audioUrl":"wbw/020_120_007.mp3","charTypeName":"word"},{"id":76506,"position":8,"arabic":"عَلَىٰ","translation":"সমন্ধে","audioUrl":"wbw/020_120_008.mp3","charTypeName":"word"},{"id":76507,"position":9,"arabic":"شَجَرَةِ","translation":"এই গাছের","audioUrl":"wbw/020_120_009.mp3","charTypeName":"word"},{"id":76508,"position":10,"arabic":"ٱلْخُلْدِ","translation":"চিরন্তন জীবনের","audioUrl":"wbw/020_120_010.mp3","charTypeName":"word"},{"id":76509,"position":11,"arabic":"وَمُلْكٍۢ","translation":"ও এমন রাজ্যের","audioUrl":"wbw/020_120_011.mp3","charTypeName":"word"},{"id":76510,"position":12,"arabic":"لَّا","translation":"(যা) না","audioUrl":"wbw/020_120_012.mp3","charTypeName":"word"},{"id":76511,"position":13,"arabic":"يَبْلَىٰ","translation":"ক্ষয় হয়\"","audioUrl":"wbw/020_120_013.mp3","charTypeName":"word"},{"id":76512,"position":14,"arabic":"١٢٠","translation":"(১২০)","audioUrl":null,"charTypeName":"end"}]},{"number":121,"arabic":"فَأَكَلَا مِنْهَا فَبَدَتْ لَهُمَا سَوْءَٰتُهُمَا وَطَفِقَا يَخْصِفَانِ عَلَيْهِمَا مِن وَرَقِ ٱلْجَنَّةِ ۚ وَعَصَىٰٓ ءَادَمُ رَبَّهُۥ فَغَوَىٰ","translation":"And so the two ate [of the fruit] thereof: and thereupon they became conscious of their nakedness and began to cover themselves with pieced-together leaves from the garden. And [thus] did Adam disobey his Sustainer, and thus did he fall into grievous error.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2469.mp3","surahId":20,"words":[{"id":76549,"position":1,"arabic":"فَأَكَلَا","translation":"অতঃপর উভয়ে খেলো","audioUrl":"wbw/020_121_001.mp3","charTypeName":"word"},{"id":76550,"position":2,"arabic":"مِنْهَا","translation":"তা থেকে","audioUrl":"wbw/020_121_002.mp3","charTypeName":"word"},{"id":76551,"position":3,"arabic":"فَبَدَتْ","translation":"তখন প্রকাশ হয়ে পড়লো","audioUrl":"wbw/020_121_003.mp3","charTypeName":"word"},{"id":76552,"position":4,"arabic":"لَهُمَا","translation":"কাছে তাদের উভয়ের","audioUrl":"wbw/020_121_004.mp3","charTypeName":"word"},{"id":76553,"position":5,"arabic":"سَوْءَٰتُهُمَا","translation":"তাদের উভয়ের লজ্জাস্থানসমূহ","audioUrl":"wbw/020_121_005.mp3","charTypeName":"word"},{"id":76554,"position":6,"arabic":"وَطَفِقَا","translation":"এবং উভয়ে শুরু করলো","audioUrl":"wbw/020_121_006.mp3","charTypeName":"word"},{"id":76555,"position":7,"arabic":"يَخْصِفَانِ","translation":"উভয়ে ঢাকতে","audioUrl":"wbw/020_121_007.mp3","charTypeName":"word"},{"id":76556,"position":8,"arabic":"عَلَيْهِمَا","translation":"তাদের দুজনের উপর","audioUrl":"wbw/020_121_008.mp3","charTypeName":"word"},{"id":76557,"position":9,"arabic":"مِن","translation":"দিয়ে","audioUrl":"wbw/020_121_009.mp3","charTypeName":"word"},{"id":76558,"position":10,"arabic":"وَرَقِ","translation":"পাতা","audioUrl":"wbw/020_121_010.mp3","charTypeName":"word"},{"id":76559,"position":11,"arabic":"ٱلْجَنَّةِ ۚ","translation":"জান্নাতের","audioUrl":"wbw/020_121_011.mp3","charTypeName":"word"},{"id":76561,"position":12,"arabic":"وَعَصَىٰٓ","translation":"এবং অমান্য করলো","audioUrl":"wbw/020_121_013.mp3","charTypeName":"word"},{"id":76562,"position":13,"arabic":"ءَادَمُ","translation":"আদম","audioUrl":"wbw/020_121_014.mp3","charTypeName":"word"},{"id":76563,"position":14,"arabic":"رَبَّهُۥ","translation":"তার রবকে","audioUrl":"wbw/020_121_015.mp3","charTypeName":"word"},{"id":76564,"position":15,"arabic":"فَغَوَىٰ","translation":"অতঃপর সে বিভ্রান্ত হলো","audioUrl":"wbw/020_121_016.mp3","charTypeName":"word"},{"id":76565,"position":16,"arabic":"١٢١","translation":"(১২১)","audioUrl":null,"charTypeName":"end"}]},{"number":122,"arabic":"ثُمَّ ٱجْتَبَٰهُ رَبُّهُۥ فَتَابَ عَلَيْهِ وَهَدَىٰ","translation":"Thereafter, [however,) his Sustainer elected him [for His grace], and accepted his repentance, and bestowed His guidance upon him,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2470.mp3","surahId":20,"words":[{"id":76685,"position":1,"arabic":"ثُمَّ","translation":"এরপরে","audioUrl":"wbw/020_122_001.mp3","charTypeName":"word"},{"id":76686,"position":2,"arabic":"ٱجْتَبَـٰهُ","translation":"তাকে মনোনীত করলেন (সম্মানিত করলেন)","audioUrl":"wbw/020_122_002.mp3","charTypeName":"word"},{"id":76687,"position":3,"arabic":"رَبُّهُۥ","translation":"তাঁর রব","audioUrl":"wbw/020_122_003.mp3","charTypeName":"word"},{"id":76688,"position":4,"arabic":"فَتَابَ","translation":"অতঃপর ক্ষমা করলেন","audioUrl":"wbw/020_122_004.mp3","charTypeName":"word"},{"id":76689,"position":5,"arabic":"عَلَيْهِ","translation":"তার প্রতি","audioUrl":"wbw/020_122_005.mp3","charTypeName":"word"},{"id":76690,"position":6,"arabic":"وَهَدَىٰ","translation":"ও পথ দেখালেন","audioUrl":"wbw/020_122_006.mp3","charTypeName":"word"},{"id":76691,"position":7,"arabic":"١٢٢","translation":"(১২২)","audioUrl":null,"charTypeName":"end"}]},{"number":123,"arabic":"قَالَ ٱهْبِطَا مِنْهَا جَمِيعًۢا ۖ بَعْضُكُمْ لِبَعْضٍ عَدُوٌّۭ ۖ فَإِمَّا يَأْتِيَنَّكُم مِّنِّى هُدًۭى فَمَنِ ٱتَّبَعَ هُدَاىَ فَلَا يَضِلُّ وَلَا يَشْقَىٰ","translation":"saying: \"Down with you all from this [state of innocence, and be henceforth] enemies unto one another! None the less, there shall most certainly come unto you guidance from Me: and he who follows My guidance will not go astray, and neither will he be unhappy.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2471.mp3","surahId":20,"words":[{"id":76828,"position":1,"arabic":"قَالَ","translation":"(আল্লাহ) বললেন","audioUrl":"wbw/020_123_001.mp3","charTypeName":"word"},{"id":76829,"position":2,"arabic":"ٱهْبِطَا","translation":"\"উভয়ে নেমে যাও","audioUrl":"wbw/020_123_002.mp3","charTypeName":"word"},{"id":76830,"position":3,"arabic":"مِنْهَا","translation":"তা থেকে","audioUrl":"wbw/020_123_003.mp3","charTypeName":"word"},{"id":76831,"position":4,"arabic":"جَمِيعًۢا ۖ","translation":"এক সঙ্গে","audioUrl":"wbw/020_123_004.mp3","charTypeName":"word"},{"id":76833,"position":5,"arabic":"بَعْضُكُمْ","translation":"তোমরা একে","audioUrl":"wbw/020_123_006.mp3","charT