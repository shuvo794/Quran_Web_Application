{"id":272,"ayahs":[{"number":43,"arabic":"وَمَآ أَرْسَلْنَا مِن قَبْلِكَ إِلَّا رِجَالًۭا نُّوحِىٓ إِلَيْهِمْ ۚ فَسْـَٔلُوٓا۟ أَهْلَ ٱلذِّكْرِ إِن كُنتُمْ لَا تَعْلَمُونَ","translation":"AND [even] before thy time, [O Muhammad,] We never sent [as Our apostles] any but [mortal] men, whom We inspired: and if you have not [yet] realized this, ask the followers of [earlier] revelation,\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1944.mp3","surahId":16,"words":[{"id":44099,"position":1,"arabic":"وَمَآ","translation":"এবং না","audioUrl":"wbw/016_043_001.mp3","charTypeName":"word"},{"id":44100,"position":2,"arabic":"أَرْسَلْنَا","translation":"আমরা পাঠিয়েছি","audioUrl":"wbw/016_043_002.mp3","charTypeName":"word"},{"id":44101,"position":3,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/016_043_003.mp3","charTypeName":"word"},{"id":44102,"position":4,"arabic":"قَبْلِكَ","translation":"তোমার পূর্ব","audioUrl":"wbw/016_043_004.mp3","charTypeName":"word"},{"id":44103,"position":5,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/016_043_005.mp3","charTypeName":"word"},{"id":44104,"position":6,"arabic":"رِجَالًۭا","translation":"মানুষদেরকে","audioUrl":"wbw/016_043_006.mp3","charTypeName":"word"},{"id":44105,"position":7,"arabic":"نُّوحِىٓ","translation":"আমরা ওহী করি","audioUrl":"wbw/016_043_007.mp3","charTypeName":"word"},{"id":44106,"position":8,"arabic":"إِلَيْهِمْ ۚ","translation":"প্রতি তাদের","audioUrl":"wbw/016_043_008.mp3","charTypeName":"word"},{"id":44108,"position":9,"arabic":"فَسْـَٔلُوٓا۟","translation":"অতএব তোমরা জিজ্ঞেস করো","audioUrl":"wbw/016_043_010.mp3","charTypeName":"word"},{"id":44109,"position":10,"arabic":"أَهْلَ","translation":"সম্পন্নদের","audioUrl":"wbw/016_043_011.mp3","charTypeName":"word"},{"id":44110,"position":11,"arabic":"ٱلذِّكْرِ","translation":"(ঐশী)জ্ঞান","audioUrl":"wbw/016_043_012.mp3","charTypeName":"word"},{"id":44111,"position":12,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/016_043_013.mp3","charTypeName":"word"},{"id":44112,"position":13,"arabic":"كُنتُمْ","translation":"তোমরা ছিলে","audioUrl":"wbw/016_043_014.mp3","charTypeName":"word"},{"id":44113,"position":14,"arabic":"لَا","translation":"না","audioUrl":"wbw/016_043_015.mp3","charTypeName":"word"},{"id":44114,"position":15,"arabic":"تَعْلَمُونَ","translation":"তোমরা জানো","audioUrl":"wbw/016_043_016.mp3","charTypeName":"word"},{"id":44115,"position":16,"arabic":"٤٣","translation":"(৪৩)","audioUrl":null,"charTypeName":"end"}]},{"number":44,"arabic":"بِٱلْبَيِّنَٰتِ وَٱلزُّبُرِ ۗ وَأَنزَلْنَآ إِلَيْكَ ٱلذِّكْرَ لِتُبَيِّنَ لِلنَّاسِ مَا نُزِّلَ إِلَيْهِمْ وَلَعَلَّهُمْ يَتَفَكَّرُونَ","translation":"[and they will tell you that their prophets, too, were but mortal men whom We had endowed] with all evidence of the truth and with books of divine wisdom. And upon thee [too] have We bestowed from on high this reminder, so that thou might make clear unto mankind all that has ever been thus bestowed upon them, and that they might take thought.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1945.mp3","surahId":16,"words":[{"id":44887,"position":1,"arabic":"بِٱلْبَيِّنَـٰتِ","translation":"সহ উজ্জ্বল নিদর্শনাবলী","audioUrl":"wbw/016_044_001.mp3","charTypeName":"word"},{"id":44888,"position":2,"arabic":"وَٱلزُّبُرِ ۗ","translation":"ও কিতাবসমূহ","audioUrl":"wbw/016_044_002.mp3","charTypeName":"word"},{"id":44890,"position":3,"arabic":"وَأَنزَلْنَآ","translation":"ও আমরা অবতীর্ণ করেছি","audioUrl":"wbw/016_044_004.mp3","charTypeName":"word"},{"id":44891,"position":4,"arabic":"إِلَيْكَ","translation":"তোমার প্রতি","audioUrl":"wbw/016_044_005.mp3","charTypeName":"word"},{"id":44892,"position":5,"arabic":"ٱلذِّكْرَ","translation":"উপদেশবাণী (কুরআন)","audioUrl":"wbw/016_044_006.mp3","charTypeName":"word"},{"id":44893,"position":6,"arabic":"لِتُبَيِّنَ","translation":"যেন সুস্পস্টভাবে বর্ণনা করো তুমি","audioUrl":"wbw/016_044_007.mp3","charTypeName":"word"},{"id":44894,"position":7,"arabic":"لِلنَّاسِ","translation":"জন্যে মানুষের","audioUrl":"wbw/016_044_008.mp3","charTypeName":"word"},{"id":44895,"position":8,"arabic":"مَا","translation":"যা","audioUrl":"wbw/016_044_009.mp3","charTypeName":"word"},{"id":44896,"position":9,"arabic":"نُزِّلَ","translation":"অবতীর্ণ করা হয়েছে","audioUrl":"wbw/016_044_010.mp3","charTypeName":"word"},{"id":44897,"position":10,"arabic":"إِلَيْهِمْ","translation":"তাদের প্রতি","audioUrl":"wbw/016_044_011.mp3","charTypeName":"word"},{"id":44898,"position":11,"arabic":"وَلَعَلَّهُمْ","translation":"এবং সম্ভবত তারা","audioUrl":"wbw/016_044_012.mp3","charTypeName":"word"},{"id":44899,"position":12,"arabic":"يَتَفَكَّرُونَ","translation":"চিন্তা-ভাবনা করে","audioUrl":"wbw/016_044_013.mp3","charTypeName":"word"},{"id":44900,"position":13,"arabic":"٤٤","translation":"(৪৪)","audioUrl":null,"charTypeName":"end"}]},{"number":45,"arabic":"أَفَأَمِنَ ٱلَّذِينَ مَكَرُوا۟ ٱلسَّيِّـَٔاتِ أَن يَخْسِفَ ٱللَّهُ بِهِمُ ٱلْأَرْضَ أَوْ يَأْتِيَهُمُ ٱلْعَذَابُ مِنْ حَيْثُ لَا يَشْعُرُونَ","translation":"Can, then, they who devise evil schemes ever feel sure that God will not cause the earth to swallow them, or that suffering will not befall them without their perceiving whence [it came]? -","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1946.mp3","surahId":16,"words":[{"id":45580,"position":1,"arabic":"أَفَأَمِنَ","translation":"তবে কি নির্ভয় হয়েছে","audioUrl":"wbw/016_045_001.mp3","charTypeName":"word"},{"id":45581,"position":2,"arabic":"ٱلَّذِينَ","translation":"(তারা) যারা","audioUrl":"wbw/016_045_002.mp3","charTypeName":"word"},{"id":45582,"position":3,"arabic":"مَكَرُوا۟","translation":"চক্রান্ত করে","audioUrl":"wbw/016_045_003.mp3","charTypeName":"word"},{"id":45583,"position":4,"arabic":"ٱلسَّيِّـَٔاتِ","translation":"কুকর্মের","audioUrl":"wbw/016_045_004.mp3","charTypeName":"word"},{"id":45584,"position":5,"arabic":"أَن","translation":"যে","audioUrl":"wbw/016_045_005.mp3","charTypeName":"word"},{"id":45585,"position":6,"arabic":"يَخْسِفَ","translation":"ধসিয়ে দিবেন","audioUrl":"wbw/016_045_006.mp3","charTypeName":"word"},{"id":45586,"position":7,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌","audioUrl":"wbw/016_045_007.mp3","charTypeName":"word"},{"id":45587,"position":8,"arabic":"بِهِمُ","translation":"সহ তাদের","audioUrl":"wbw/016_045_008.mp3","charTypeName":"word"},{"id":45588,"position":9,"arabic":"ٱلْأَرْضَ","translation":"মাটিকে","audioUrl":"wbw/016_045_009.mp3","charTypeName":"word"},{"id":45589,"position":10,"arabic":"أَوْ","translation":"বা","audioUrl":"wbw/016_045_010.mp3","charTypeName":"word"},{"id":45590,"position":11,"arabic":"يَأْتِيَهُمُ","translation":"তাদের উপর আসবে","audioUrl":"wbw/016_045_011.mp3","charTypeName":"word"},{"id":45591,"position":12,"arabic":"ٱلْعَذَابُ","translation":"আযাব","audioUrl":"wbw/016_045_012.mp3","charTypeName":"word"},{"id":45592,"position":13,"arabic":"مِنْ","translation":"থেকে","audioUrl":"wbw/016_045_013.mp3","charTypeName":"word"},{"id":45593,"position":14,"arabic":"حَيْثُ","translation":"যেখান","audioUrl":"wbw/016_045_014.mp3","charTypeName":"word"},{"id":45594,"position":15,"arabic":"لَا","translation":"না","audioUrl":"wbw/016_045_015.mp3","charTypeName":"word"},{"id":45595,"position":16,"arabic":"يَشْعُرُونَ","translation":"তারা ধারণাও করে","audioUrl":"wbw/016_045_016.mp3","charTypeName":"word"},{"id":45596,"position":17,"arabic":"٤٥","translation":"(৪৫)","audioUrl":null,"charTypeName":"end"}]},{"number":46,"arabic":"أَوْ يَأْخُذَهُمْ فِى تَقَلُّبِهِمْ فَمَا هُم بِمُعْجِزِينَ","translation":"or that He will not take them to task [suddenly] in the midst of their comings and goings, without their being able to elude [Him],","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1947.mp3","surahId":16,"words":[{"id":46274,"position":1,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/016_046_001.mp3","charTypeName":"word"},{"id":46275,"position":2,"arabic":"يَأْخُذَهُمْ","translation":"তাদের ধরবেন","audioUrl":"wbw/016_046_002.mp3","charTypeName":"word"},{"id":46276,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/016_046_003.mp3","charTypeName":"word"},{"id":46277,"position":4,"arabic":"تَقَلُّبِهِمْ","translation":"তাদের চলাফেরার","audioUrl":"wbw/016_046_004.mp3","charTypeName":"word"},{"id":46278,"position":5,"arabic":"فَمَا","translation":"অতঃপর না","audioUrl":"wbw/016_046_005.mp3","charTypeName":"word"},{"id":46279,"position":6,"arabic":"هُم","translation":"তারা (হ'তে পারবে)","audioUrl":"wbw/016_046_006.mp3","charTypeName":"word"},{"id":46280,"position":7,"arabic":"بِمُعْجِزِينَ","translation":"(তাঁকে) অক্ষমকারী","audioUrl":"wbw/016_046_007.mp3","charTypeName":"word"},{"id":46281,"position":8,"arabic":"٤٦","translation":"(৪৬)","audioUrl":null,"charTypeName":"end"}]},{"number":47,"arabic":"أَوْ يَأْخُذَهُمْ عَلَىٰ تَخَوُّفٍۢ فَإِنَّ رَبَّكُمْ لَرَءُوفٌۭ رَّحِيمٌ","translation":"or take them to task through slow decay? And yet, behold, your Sustainer is most compassionate, a dispenser of grace!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1948.mp3","surahId":16,"words":[{"id":46967,"position":1,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/016_047_001.mp3","charTypeName":"word"},{"id":46968,"position":2,"arabic":"يَأْخُذَهُمْ","translation":"তাদের ধরবেন","audioUrl":"wbw/016_047_002.mp3","charTypeName":"word"},{"id":46969,"position":3,"arabic":"عَلَىٰ","translation":"অবস্হায়","audioUrl":"wbw/016_047_003.mp3","charTypeName":"word"},{"id":46970,"position":4,"arabic":"تَخَوُّفٍۢ","translation":"ভীত সন্ত্রস্ত","audioUrl":"wbw/016_047_004.mp3","charTypeName":"word"},{"id":46971,"position":5,"arabic":"فَإِنَّ","translation":"তবে নিশ্চয়ই","audioUrl":"wbw/016_047_005.mp3","charTypeName":"word"},{"id":46972,"position":6,"arabic":"رَبَّكُمْ","translation":"তোমাদের রব","audioUrl":"wbw/016_047_006.mp3","charTypeName":"word"},{"id":46973,"position":7,"arabic":"لَرَءُوفٌۭ","translation":"অবশ্যই দয়াপরবশ","audioUrl":"wbw/016_047_007.mp3","charTypeName":"word"},{"id":46974,"position":8,"arabic":"رَّحِيمٌ","translation":"পরম দয়ালু","audioUrl":"wbw/016_047_008.mp3","charTypeName":"word"},{"id":46975,"position":9,"arabic":"٤٧","translation":"(৪৭)","audioUrl":null,"charTypeName":"end"}]},{"number":48,"arabic":"أَوَلَمْ يَرَوْا۟ إِلَىٰ مَا خَلَقَ ٱللَّهُ مِن شَىْءٍۢ يَتَفَيَّؤُا۟ ظِلَٰلُهُۥ عَنِ ٱلْيَمِينِ وَٱلشَّمَآئِلِ سُجَّدًۭا لِّلَّهِ وَهُمْ دَٰخِرُونَ","translation":"HAVE, THEN, they [who deny the truth] never considered any of the things that God has created _ (how] their shadows turn right and left, prostrating themselves before God and utterly submissive [to His will]?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1949.mp3","surahId":16,"words":[{"id":47660,"position":1,"arabic":"أَوَلَمْ","translation":"কি নি","audioUrl":"wbw/016_048_001.mp3","charTypeName":"word"},{"id":47661,"position":2,"arabic":"يَرَوْا۟","translation":"তারা দেখে","audioUrl":"wbw/016_048_002.mp3","charTypeName":"word"},{"id":47662,"position":3,"arabic":"إِلَىٰ","translation":"প্রতি","audioUrl":"wbw/016_048_003.mp3","charTypeName":"word"},{"id":47663,"position":4,"arabic":"مَا","translation":"যা","audioUrl":"wbw/016_048_004.mp3","charTypeName":"word"},{"id":47664,"position":5,"arabic":"خَلَقَ","translation":"সৃষ্টি করেছেন","audioUrl":"wbw/016_048_005.mp3","charTypeName":"word"},{"id":47665,"position":6,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌","audioUrl":"wbw/016_048_006.mp3","charTypeName":"word"},{"id":47666,"position":7,"arabic":"مِن","translation":"কিছু","audioUrl":"wbw/016_048_007.mp3","charTypeName":"word"},{"id":47667,"position":8,"arabic":"شَىْءٍۢ","translation":"বস্তুর","audioUrl":"wbw/016_048_008.mp3","charTypeName":"word"},{"id":47668,"position":9,"arabic":"يَتَفَيَّؤُا۟","translation":"ঝুঁকে পড়ে","audioUrl":"wbw/016_048_009.mp3","charTypeName":"word"},{"id":47669,"position":10,"arabic":"ظِلَـٰلُهُۥ","translation":"তার ছায়াগুলো","audioUrl":"wbw/016_048_010.mp3","charTypeName":"word"},{"id":47670,"position":11,"arabic":"