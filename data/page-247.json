{"id":247,"ayahs":[{"number":96,"arabic":"فَلَمَّآ أَن جَآءَ ٱلْبَشِيرُ أَلْقَىٰهُ عَلَىٰ وَجْهِهِۦ فَٱرْتَدَّ بَصِيرًۭا ۖ قَالَ أَلَمْ أَقُل لَّكُمْ إِنِّىٓ أَعْلَمُ مِنَ ٱللَّهِ مَا لَا تَعْلَمُونَ","translation":"But when the bearer of good tidings came [with Joseph's tunic], he laid it over his face; and he regained his sight, [and] exclaimed: \"Did I not tell you, `Verily, I know, from God, something that you do not know'?\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1692.mp3","surahId":12,"words":[{"id":70032,"position":1,"arabic":"فَلَمَّآ","translation":"অতঃপর যখন","audioUrl":"wbw/012_096_001.mp3","charTypeName":"word"},{"id":70033,"position":2,"arabic":"أَن","translation":"যে","audioUrl":"wbw/012_096_002.mp3","charTypeName":"word"},{"id":70034,"position":3,"arabic":"جَآءَ","translation":"আসলো","audioUrl":"wbw/012_096_003.mp3","charTypeName":"word"},{"id":70035,"position":4,"arabic":"ٱلْبَشِيرُ","translation":"সুসংবাদদাতা","audioUrl":"wbw/012_096_004.mp3","charTypeName":"word"},{"id":70036,"position":5,"arabic":"أَلْقَىٰهُ","translation":"তা (অর্থাৎ জামা) রাখলো","audioUrl":"wbw/012_096_005.mp3","charTypeName":"word"},{"id":70037,"position":6,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/012_096_006.mp3","charTypeName":"word"},{"id":70038,"position":7,"arabic":"وَجْهِهِۦ","translation":"তার মুখের","audioUrl":"wbw/012_096_007.mp3","charTypeName":"word"},{"id":70039,"position":8,"arabic":"فَٱرْتَدَّ","translation":"তখন সে ফিরে পেলো","audioUrl":"wbw/012_096_008.mp3","charTypeName":"word"},{"id":70040,"position":9,"arabic":"بَصِيرًۭا ۖ","translation":"দৃষ্টিশক্তি","audioUrl":"wbw/012_096_009.mp3","charTypeName":"word"},{"id":70042,"position":10,"arabic":"قَالَ","translation":"(ইয়াকুব) বললো","audioUrl":"wbw/012_096_011.mp3","charTypeName":"word"},{"id":70043,"position":11,"arabic":"أَلَمْ","translation":"\"নি কি","audioUrl":"wbw/012_096_012.mp3","charTypeName":"word"},{"id":70044,"position":12,"arabic":"أَقُل","translation":"আমি ব