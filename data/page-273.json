{"id":273,"ayahs":[{"number":55,"arabic":"لِيَكْفُرُوا۟ بِمَآ ءَاتَيْنَٰهُمْ ۚ فَتَمَتَّعُوا۟ ۖ فَسَوْفَ تَعْلَمُونَ","translation":"[as if] to prove their ingratitude for all that We have granted them! Enjoy, then, your [brief] life: but in time you will come to know [the truth]!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1956.mp3","surahId":16,"words":[{"id":52000,"position":1,"arabic":"لِيَكْفُرُوا۟","translation":"জন্যে অস্বীকার করার","audioUrl":"wbw/016_055_001.mp3","charTypeName":"word"},{"id":52001,"position":2,"arabic":"بِمَآ","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/016_055_002.mp3","charTypeName":"word"},{"id":52002,"position":3,"arabic":"ءَاتَيْنَـٰهُمْ ۚ","translation":"আমরা তাদের দিয়েছি","audioUrl":"wbw/016_055_003.mp3","charTypeName":"word"},{"id":52004,"position":4,"arabic":"فَتَمَتَّعُوا۟ ۖ","translation":"তাই তোমরা ভোগ করো","audioUrl":"wbw/016_055_005.mp3","charTypeName":"word"},{"id":52006,"position":5,"arabic":"فَسَوْفَ","translation":"অতঃপর শীঘ্রই","audioUrl":"wbw/016_055_007.mp3","charTypeName":"word"},{"id":52007,"position":6,"arabic":"تَعْلَمُونَ","translation":"তোমরা জানবে","audioUrl":"wbw/016_055_008.mp3","charTypeName":"word"},{"id":52008,"position":7,"arabic":"٥٥","translation":"(৫৫)","audioUrl":null,"charTypeName":"end"}]},{"number":56,"arabic":"وَيَجْعَلُونَ لِمَا لَا يَعْلَمُونَ نَصِيبًۭا مِّمَّا رَزَقْنَٰهُمْ ۗ تَٱللَّهِ لَتُسْـَٔلُنَّ عَمَّا كُنتُمْ تَفْتَرُونَ","translation":"As it is, they ascribe - out of what We provide for them as sustenance - a share unto things of which they know nothing. By God, you shall most certainly be called to account for all your false imagery!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1957.mp3","surahId":16,"words":[{"id":52536,"position":1,"arabic":"وَيَجْعَلُونَ","translation":"এবং তারা নির্ধারণ করে","audioUrl":"wbw/016_056_001.mp3","charTypeName":"word"},{"id":52537,"position":2,"arabic":"لِمَا","translation":"সে বিষয়ে যা","audioUrl":"wbw/016_056_002.mp3","charTypeName":"word"},{"id":52538,"position":3,"arabic":"لَا","translation":"না","audioUrl":"wbw/016_056_003.mp3","charTypeName":"word"},{"id":52539,"position":4,"arabic":"يَعْلَمُونَ","translation":"তারা জানে","audioUrl":"wbw/016_056_004.mp3","charTypeName":"word"},{"id":52540,"position":5,"arabic":"نَصِيبًۭا","translation":"এক অংশ","audioUrl":"wbw/016_056_005.mp3","charTypeName":"word"},{"id":52541,"position":6,"arabic":"مِّمَّا","translation":"তা হ'তে যা","audioUrl":"wbw/016_056_006.mp3","charTypeName":"word"},{"id":52542,"position":7,"arabic":"رَزَقْنَـٰهُمْ ۗ","translation":"আমরা জীবিকা দিয়েছি তাদের","audioUrl":"wbw/016_056_007.mp3","charTypeName":"word"},{"id":52544,"position":8,"arabic":"تَٱللَّهِ","translation":"শপথ আল্লাহর","audioUrl":"wbw/016_056_009.mp3","charTypeName":"word"},{"id":52545,"position":9,"arabic":"لَتُسْـَٔلُنَّ","translation":"অবশ্যই তোমাদের জিজ্ঞেস করা হবে","audioUrl":"wbw/016_056_010.mp3","charTypeName":"word"},{"id":52546,"position":10,"arabic":"عَمَّا","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/016_056_011.mp3","charTypeName":"word"},{"id":52547,"position":11,"arabic":"كُنتُمْ","translation":"তোমরা ছিলে","audioUrl":"wbw/016_056_012.mp3","charTypeName":"word"},{"id":52548,"position":12,"arabic":"تَفْتَرُونَ","translation":"তোমরা রচনা করতে","audioUrl":"wbw/016_056_013.mp3","charTypeName":"word"},{"id":52549,"position":13,"arabic":"٥٦","translation":"(৫৬)","audioUrl":null,"charTypeName":"end"}]},{"number":57,"arabic":"وَيَجْعَلُونَ لِلَّهِ ٱلْبَنَٰتِ سُبْحَٰنَهُۥ ۙ وَلَهُم مَّا يَشْتَهُونَ","translation":"And [thus, too,] they ascribe daughters unto God, who is limitless in His glory - whereas for themselves [they would choose, if they could, only] what they desire:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1958.mp3","surahId":16,"words":[{"id":53046,"position":1,"arabic":"وَيَجْعَلُونَ","translation":"এবং তারা নির্ধারণ করে","audioUrl":"wbw/016_057_001.mp3","charTypeName":"word"},{"id":53047,"position":2,"arabic":"لِلَّهِ","translation":"জন্যে আল্লাহর","audioUrl":"wbw/016_057_002.mp3","charTypeName":"word"},{"id":53048,"position":3,"arabic":"ٱلْبَنَـٰتِ","translation":"কন্যা-সন্তানসমূহ","audioUrl":"wbw/016_057_003.mp3","charTypeName":"word"},{"id":53049,"position":4,"arabic":"سُبْحَـٰنَهُۥ ۙ","translation":"তিনি পবিত্র ও মহান","audioUrl":"wbw/016_057_004.mp3","charTypeName":"word"},{"id":53051,"position":5,"arabic":"وَلَهُم","translation":"এবং জন্যে তাদের","audioUrl":"wbw/016_057_006.mp3","charTypeName":"word"},{"id":53052,"position":6,"arabic":"مَّا","translation":"(তাই) যা","audioUrl":"wbw/016_057_007.mp3","charTypeName":"word"},{"id":53053,"position":7,"arabic":"يَشْتَهُونَ","translation":"তারা কামনা করে","audioUrl":"wbw/016_057_008.mp3","charTypeName":"word"},{"id":53054,"position":8,"arabic":"٥٧","translation":"(৫৭)","audioUrl":null,"charTypeName":"end"}]},{"number":58,"arabic":"وَإِذَا بُشِّرَ أَحَدُهُم بِٱلْأُنثَىٰ ظَلَّ وَجْهُهُۥ مُسْوَدًّۭا وَهُوَ كَظِيمٌۭ","translation":"for, whenever any of them is given the glad tiding of [the birth of] a girl, his face darkens, and he is filled with suppressed anger,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1959.mp3","surahId":16,"words":[{"id":53609,"position":1,"arabic":"وَإِذَا","translation":"অথচ যখন","audioUrl":"wbw/016_058_001.mp3","charTypeName":"word"},{"id":53610,"position":2,"arabic":"بُشِّرَ","translation":"সুখবর দেয়া হয়","audioUrl":"wbw/016_058_002.mp3","charTypeName":"word"},{"id":53611,"position":3,"arabic":"أَحَدُهُم","translation":"তাদের কাউকে","audioUrl":"wbw/016_058_003.mp3","charTypeName":"word"},{"id":53612,"position":4,"arabic":"بِٱلْأُنثَىٰ","translation":"ব্যাপারে কন্যা-সন্তানের","audioUrl":"wbw/016_058_004.mp3","charTypeName":"word"},{"id":53613,"position":5,"arabic":"ظَلَّ","translation":"হয়ে যায়","audioUrl":"wbw/016_058_005.mp3","charTypeName":"word"},{"id":53614,"position":6,"arabic":"وَجْهُهُۥ","translation":"তার মুখ","audioUrl":"wbw/016_058_006.mp3","charTypeName":"word"},{"id":53615,"position":7,"arabic":"مُسْوَدًّۭا","translation":"কালো","audioUrl":"wbw/016_058_007.mp3","charTypeName":"word"},{"id":53616,"position":8,"arabic":"وَهُوَ","translation":"এবং সে (হয়)","audioUrl":"wbw/016_058_008.mp3","charTypeName":"word"},{"id":53617,"position":9,"arabic":"كَظِيمٌۭ","translation":"উত্তেজনা প্রশমনকারী","audioUrl":"wbw/016_058_009.mp3","charTypeName":"word"},{"id":53618,"position":10,"arabic":"٥٨","translation":"(৫৮)","audioUrl":null,"charTypeName":"end"}]},{"number":59,"arabic":"يَتَوَٰرَىٰ مِنَ ٱلْقَوْمِ مِن سُوٓءِ مَا بُشِّرَ بِهِۦٓ ۚ أَيُمْسِكُهُۥ عَلَىٰ هُونٍ أَمْ يَدُسُّهُۥ فِى ٱلتُّرَابِ ۗ أَلَا سَآءَ مَا يَحْكُمُونَ","translation":"avoiding all people because of the [alleged] evil of the glad tiding which he has received, [and debating within himself:] Shall he keep this [child] despite the contempt [which he feels for it]-or shall he bury it in the dust? Old, evil indeed is whatever they decide!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1960.mp3","surahId":16,"words":[{"id":54072,"position":1,"arabic":"يَتَوَٰرَىٰ","translation":"আত্ন গোপন করে","audioUrl":"wbw/016_059_001.mp3","charTypeName":"word"},{"id":54073,"position":2,"arabic":"مِنَ","translation":"থেকে","audioUrl":"wbw/016_059_002.mp3","charTypeName":"word"},{"id":54074,"position":3,"arabic":"ٱلْقَوْمِ","translation":"লোকদের","audioUrl":"wbw/016_059_003.mp3","charTypeName":"word"},{"id":54075,"position":4,"arabic":"مِن","translation":"কারণে","audioUrl":"wbw/016_059_004.mp3","charTypeName":"word"},{"id":54076,"position":5,"arabic":"سُوٓءِ","translation":"লজ্জার","audioUrl":"wbw/016_059_005.mp3","charTypeName":"word"},{"id":54077,"position":6,"arabic":"مَا","translation":"যা","audioUrl":"wbw/016_059_006.mp3","charTypeName":"word"},{"id":54078,"position":7,"arabic":"بُشِّرَ","translation":"সুসংবাদ দেয়া হয়","audioUrl":"wbw/016_059_007.mp3","charTypeName":"word"},{"id":54079,"position":8,"arabic":"بِهِۦٓ ۚ","translation":"সম্পর্কে সে","audioUrl":"wbw/016_059_008.mp3","charTypeName":"word"},{"id":54081,"position":9,"arabic":"أَيُمْسِكُهُۥ","translation":"কি তাকে রেখে দিবে","audioUrl":"wbw/016_059_010.mp3","charTypeName":"word"},{"id":54082,"position":10,"arabic":"عَلَىٰ","translation":"সত্ত্বেও উপর","audioUrl":"wbw/016_059_011.mp3","charTypeName":"word"},{"id":54083,"position":11,"arabic":"هُونٍ","translation":"হীনতা (লাঞ্ছনা সহ্য করে)","audioUrl":"wbw/016_059_012.mp3","charTypeName":"word"},{"id":54084,"position":12,"arabic":"أَمْ","translation":"না","audioUrl":"wbw/016_059_013.mp3","charTypeName":"word"},{"id":54085,"position":13,"arabic":"يَدُسُّهُۥ","translation":"তাকে পুঁতে ফেলবে","audioUrl":"wbw/016_059_014.mp3","charTypeName":"word"},{"id":54086,"position":14,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/016_059_015.mp3","charTypeName":"word"},{"id":54087,"position":15,"arabic":"ٱلتُّرَابِ ۗ","translation":"মাটির","audioUrl":"wbw/016_059_016.mp3","charTypeName":"word"},{"id":54089,"position":16,"arabic":"أَلَا","translation":"সাবধান (লক্ষ্য করো)","audioUrl":"wbw/016_059_018.mp3","charTypeName":"word"},{"id":54090,"position":17,"arabic":"سَآءَ","translation":"কত নিকৃষ্ট","audioUrl":"wbw/016_059_019.mp3","charTypeName":"word"},{"id":54091,"position":18,"arabic":"مَا","translation":"যা","audioUrl":"wbw/016_059_020.mp3","charTypeName":"word"},{"id":54092,"position":19,"arabic":"يَحْكُمُونَ","translation":"তারা সিদ্ধান্ত নেয়","audioUrl":"wbw/016_059_021.mp3","charTypeName":"word"},{"id":54093,"position":20,"arabic":"٥٩","translation":"(৫৯)","audioUrl":null,"charTypeName":"end"}]},{"number":60,"arabic":"لِلَّذِينَ لَا يُؤْمِنُونَ بِٱلْءَاخِرَةِ مَثَلُ ٱلسَّوْءِ ۖ وَلِلَّهِ ٱلْمَثَلُ ٱلْأَعْلَىٰ ۚ وَهُوَ ٱلْعَزِيزُ ٱلْحَكِيمُ","translation":"[Thus it is that] the attribute of evil applies to all who do not believe in the life to come -whereas unto God applies the attribute of all that is most sublime: for He alone is almighty, truly wise!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1961.mp3","surahId":16,"words":[{"id":54770,"position":1,"arabic":"لِلَّذِينَ","translation":"জন্যে যারা তাদের","audioUrl":"wbw/016_060_001.mp3","charTypeName":"word"},{"id":54771,"position":2,"arabic":"لَا","translation":"না","audioUrl":"wbw/016_060_002.mp3","charTypeName":"word"},{"id":54772,"position":3,"arabic":"يُؤْمِنُونَ","translation":"বিশ্বাস করে","audioUrl":"wbw/016_060_003.mp3","charTypeName":"word"},{"id":54773,"position":4,"arabic":"بِٱلْـَٔاخِرَةِ","translation":"আখেরাতের উপর","audioUrl":"wbw/016_060_004.mp3","charTypeName":"word"},{"id":54774,"position":5,"arabic":"مَثَلُ","translation":"দৃষ্টান্ত","audioUrl":"wbw/016_060_005.mp3","charTypeName":"word"},{"id":54775,"position":6,"arabic":"ٱلسَّوْءِ ۖ","translation":"বড় নিকৃষ্ট","audioUrl":"wbw/016_060_006.mp3","charTypeName":"word"},{"id":54777,"position":7,"arabic":"وَلِلَّهِ","translation":"এবং আল্লাহর জন্যে","audioUrl":"wbw/016_060_008.mp3","charTypeName":"word"},{"id":54778,"position":8,"arabic":"ٱلْمَثَلُ","translation":"দৃষ্টান্ত (গুণাবলী)","audioUrl":"wbw/016_060_009.mp3","charTypeName":"word"},{"id":54779,"position":9,"arabic":"ٱلْأَعْلَىٰ ۚ","translation":"সর্বোচ্চ","audioUrl":"wbw/016_060_010.mp3","charTypeName":"word"},{"id":54781,"position":10,"arabic":"وَهُوَ","translation":"এবং তিনিই","audioUrl":"wbw/016_060_012.mp3","charTypeName":"word"},{"id":54782,"position":11,"arabic":"ٱلْعَزِيزُ","translation":"পরাক্রমশালী","audioUrl":"wbw/016_060_013.mp3","charTypeName":"word"},{"id":54783,"position":12,"arabic":"ٱلْحَكِيمُ","translation":"প্রজ্ঞাময়","audioUrl":"wbw/016_060_014.mp3","charTypeName":"word"},{"id":54784,"position":13,"arabic":"٦٠","translation":"(৬০)","audioUrl":null,"charTypeName":"end"}]},{"number":61,"arabic":"وَلَوْ يُؤَاخِذُ ٱللَّهُ ٱلنَّاسَ بِظُلْمِهِم مَّا تَرَكَ عَلَيْهَا مِن دَآبَّةٍۢ وَلَٰكِن يُؤَخِّرُهُمْ إِلَىٰٓ أَجَلٍۢ مُّسَمًّۭى ۖ فَإِذَا جَآءَ أَجَلُهُمْ لَا يَسْتَـْٔخِرُونَ سَاعَةًۭ ۖ وَلَا يَسْتَقْدِمُونَ","translation":"Now if God were to take men [immediately] to task for all the evil that they do [on earth], He would not leave a single living creature upon its face. However, He grants them respite until a term set [by Him]: but when the end of their term approaches, they can neither delay it by a single moment, nor can they hasten it.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1962.mp3","surahId":16,"words":[{"id":55372,"position":1,"arabic":"وَلَوْ","translation":"এবং যদি","audioUrl":"wbw/016_061_001.mp3","charTypeName":"word"},{"id":55373,"position":2,"arabic":"يُؤَاخِذُ","translation":"ধরতেন","audioUrl":"wbw/016_061_002.mp3","charTypeName":"word"},{"id":55374,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌","audioUrl":"wbw/016_061_003.mp3","charTypeName":"word"},{"id":55375,"position":4,"arabic":"ٱلنَّاسَ","translation":"মানুষদেরকে","audioUrl":"wbw/016_061_004.mp3","charTypeName":"word"},{"id":55376,"position":5,"arabic":"بِظُلْمِهِم","translation":"জন্যে তাদের বাড়াবাড়ির","audioUrl":"wbw/016_061_005.mp3","charTypeName":"word"},{"id":55377,"position":6,"arabic":"مَّا","translation":"না","audioUrl":"wbw/016_061_006.mp3","charTypeName":"word"},{"id":55378,"position":7,"arabic":"تَرَكَ","translation":"ছাড়তেন","audioUrl":"wbw/016_061_007.mp3","charTypeName":"word"},{"id":55379,"position":8,"arabic":"عَلَيْهَا","translation":"তার উপর","audioUrl":"wbw/016_061_008.mp3","charTypeName":"word"},{"id":55380,"position":9,"arabic":"مِن","translation":"কোনো","audioUrl":"wbw/016_061_009.mp3","charTypeName":"word"},{"id":55381,"position":10,"arabic":"دَآبَّةٍۢ","translation":"প্রানীকেও","audioUrl":"wbw/016_061_010.mp3","charTypeName":"word"},{"id":55382,"position":11,"arabic":"وَلَـٰكِن","translation":"কিন্তু","audioUrl":"wbw/016_061_011.mp3","charTypeName":"word"},{"id":55383,"position":12,"arabic":"يُؤَخِّرُهُمْ","translation":"তাদের অবকাশ দেন","audioUrl":"wbw/016_061_012.mp3","charTypeName":"word"},{"id":55384,"position":13,"arabic":"إِلَىٰٓ","translation":"পর্যন্ত","audioUrl":"wbw/016_061_013.mp3","charTypeName":"word"},{"id":55385,"position":14,"arabic":"أَجَلٍۢ","translation":"কাল","audioUrl":"wbw/016_061_014.mp3","charTypeName":"word"},{"id":55386,"position":15,"arabic":"مُّسَمًّۭى ۖ","translation":"নির্দিষ্ট","audioUrl":"wbw/016_061_015.mp3","charTypeName":"word"},{"id":55388,"position":16,"arabic":"فَإِذَا","translation":"অতঃপর যখন","audioUrl":"wbw/016_061_017.mp3","charTypeName":"word"},{"id":55389,"position":17,"arabic":"جَآءَ","translation":"আসবে","audioUrl":"wbw/016_061_018.mp3","charTypeName":"word"},{"id":55390,"position":18,"arabic":"أَجَلُهُمْ","translation":"তাদের সময়","audioUrl":"wbw/016_061_019.mp3","charTypeName":"word"},{"id":55391,"position":19,"arabic":"لَا","translation":"না","audioUrl":"wbw/016_061_020.mp3","charTypeName":"word"},{"id":55392,"position":20,"arabic":"يَسْتَـْٔخِرُونَ","translation":"তারা দেরি করতে পারবে","audioUrl":"wbw/016_061_021.mp3","charTypeName":"word"},{"id":55393,"position":21,"arabic":"سَاعَةًۭ ۖ","translation":"এক মুহূর্ত","audioUrl":"wbw/016_061_022.mp3","charTypeName":"word"},{"id":55395,"position":22,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/016_061_024.mp3","charTypeName":"word"},{"id":55396,"position":23,"arabic":"يَسْتَقْدِمُونَ","translation":"তারা তাড়াহুড়ো করতে পারবে","audioUrl":"wbw/016_061_025.mp3","charTypeName":"word"},{"id":55397,"position":24,"arabic":"٦١","translation":"(৬১)","audioUrl":null,"charTypeName":"end"}]},{"number":62,"arabic":"وَيَجْعَلُونَ لِلَّهِ مَا يَكْرَهُونَ وَتَصِفُ أَلْسِنَتُهُمُ ٱلْكَذِبَ أَنَّ لَهُمُ ٱلْحُسْنَىٰ ۖ لَا جَرَمَ أَنَّ لَهُمُ ٱلنَّارَ وَأَنَّهُم مُّفْرَطُونَ","translation":"As it is, they ascribe to God something that they [themselves] dislike -and [all the while] their tongues utter the lie that [by doing so] they earn supreme merit! Truly, they earn but the fire, and will be left out [of God's grace]!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1963.mp3","surahId":16,"words":[{"id":55902,"position":1,"arabic":"وَيَجْعَلُونَ","translation":"এবং তারা সাব্যস্ত করে","audioUrl":"wbw/016_062_001.mp3","charTypeName":"word"},{"id":55903,"position":2,"arabic":"لِلَّهِ","translation":"জন্যে আল্লাহর","audioUrl":"wbw/016_062_002.mp3","charTypeName":"word"},{"id":55904,"position":3,"arabic":"مَا","translation":"যা","audioUrl":"wbw/016_062_003.mp3","charTypeName":"word"},{"id":55905,"position":4,"arabic":"يَكْرَهُونَ","translation":"তারা অপছন্দ করে","audioUrl":"wbw/016_062_004.mp3","charTypeName":"word"},{"id":55906,"position":5,"arabic":"وَتَصِفُ","translation":"এবং বর্ণনা করে","audioUrl":"wbw/016_062_005.mp3","charTypeName":"word"},{"id":55907,"position":6,"arabic":"أَلْسِنَتُهُمُ","translation":"তাদের জিহবাগুলো","audioUrl":"wbw/016_062_006.mp3","charTypeName":"word"},{"id":55908,"position":7,"arabic":"ٱلْكَذِبَ","translation":"মিথ্যা","audioUrl":"wbw/016_062_007.mp3","charTypeName":"word"},{"id":55909,"position":8,"arabic":"أَنَّ","translation":"যে","audioUrl":"wbw/016_062_008.mp3","charTypeName":"word"},{"id":55910,"position":9,"arabic":"لَهُمُ","translation":"জন্যে তাদেরই","audioUrl":"wbw/016_062_009.mp3","charTypeName":"word"},{"id":55911,"position":10,"arabic":"ٱلْحُسْنَىٰ ۖ","translation":"কল্যাণ","audioUrl":"wbw/016_062_010.mp3","charTypeName":"word"},{"id":55913,"position":11,"arabic":"لَا","translation":"নেই","audioUrl":"wbw/016_062_012.mp3","charTypeName":"word"},{"id":55914,"position":12,"arabic":"جَرَمَ","translation":"সন্দেহ","audioUrl":"wbw/016_062_013.mp3","charTypeName":"word"},{"id":55915,"position":13,"arabic":"أَنَّ","translation":"যে","audioUrl":"wbw/016_062_014.mp3","charTypeName":"word"},{"id":55916,"position":14,"arabic":"لَهُمُ","translation":"জন্যে তাদের (রয়েছে)","audioUrl":"wbw/016_062_015.mp3","charTypeName":"word"},{"id":55917,"position":15,"arabic":"ٱلنَّارَ","translation":"আগুন","audioUrl":"wbw/016_062_016.mp3","charTypeName":"word"},{"id":55918,"position":16,"arabic":"وَأَنَّهُم","translation":"এবং (এও) যে তাদের","audioUrl":"wbw/016_062_017.mp3","charTypeName":"word"},{"id":55919,"position":17,"arabic":"مُّفْرَطُونَ","translation":"সবার আগে তারা নিক্ষিপ্ত হবে","audioUrl":"wbw/016_062_018.mp3","charTypeName":"word"},{"id":55920,"position":18,"arabic":"٦٢","translation":"(৬২)","audioUrl":null,"charTypeName":"end"}]},{"number":63,"arabic":"تَٱللَّهِ لَقَدْ أَرْسَلْنَآ إِلَىٰٓ أُمَمٍۢ مِّن قَبْلِكَ فَزَيَّنَ لَهُمُ ٱلشَّيْطَٰنُ أَعْمَٰلَهُمْ فَهُوَ وَلِيُّهُمُ ٱلْيَوْمَ وَلَهُمْ عَذَابٌ أَلِيمٌۭ","translation":"By God, [O Prophet,] even before thy time have We sent apostles unto [various] communities: but [those who were bent on denying the truth have always refused to listen to Our messages because] Satan has made all their own doings seem goodly to them: and he is [as] close to them today [as he was to the sinners of yore]; hence, grievous suffering awaits them.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1964.mp3","surahId":16,"words":[{"id":56187,"position":1,"arabic":"تَٱللَّهِ","translation":"শপথ আল্লাহর","audioUrl":"wbw/016_063_001.mp3","charTypeName":"word"},{"id":56188,"position":2,"arabic":"لَقَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/016_063_002.mp3","charTypeName":"word"},{"id":56189,"position":3,"arabic":"أَرْسَلْنَآ","translation":"আমরা পাঠিয়েছি","audioUrl":"wbw/016_063_003.mp3","charTypeName":"word"},{"id":56190,"position":4,"arabic":"إِلَىٰٓ","translation":"প্রতি","audioUrl":"wbw/016_063_004.mp3","charTypeName":"word"},{"id":56191,"position":5,"arabic":"أُمَمٍۢ","translation":"জাতিসমূহের","audioUrl":"wbw/016_063_005.mp3","charTypeName":"word"},{"id":56192,"position":6,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/016_063_006.mp3","charTypeName":"word"},{"id":56193,"position":7,"arabic":"قَبْلِكَ","translation":"তোমার পূর্ব","audioUrl":"wbw/016_063_007.mp3","charTypeName":"word"},{"id":56194,"position":8,"arabic":"فَزَيَّنَ","translation":"অতঃপর শোভন করেছিলো","audioUrl":"wbw/016_063_008.mp3","charTypeName":"word"},{"id":56195,"position":9,"arabic":"لَهُمُ","translation":"জন্যে তাদের","audioUrl":"wbw/016_063_009.mp3","charTypeName":"word"},{"id":56196,"position":10,"arabic":"ٱلشَّيْطَـٰنُ","translation":"শয়তান","audioUrl":"wbw/016_063_010.mp3","charTypeName":"word"},{"id":56197,"position":11,"arabic":"أَعْمَـٰلَهُمْ","translation":"তাদের কাজগুলোকে","audioUrl":"wbw/016_063_011.mp3","charTypeName":"word"},{"id":56198,"position":12,"arabic":"فَهُوَ","translation":"অতঃপর সেই","audioUrl":"wbw/016_063_012.mp3","charTypeName":"word"},{"id":56199,"position":13,"arabic":"وَلِيُّهُمُ","translation":"তাদের অভিভাবক","audioUrl":"wbw/016_063_013.mp3","charTypeName":"word"},{"id":56200,"position":14,"arabic":"ٱلْيَوْمَ","translation":"আজ","audioUrl":"wbw/016_063_014.mp3","charTypeName":"word"},{"id":56201,"position":15,"arabic":"وَلَهُمْ","translation":"এবং জন্যে তাদের (রয়েছে)","audioUrl":"wbw/016_063_015.mp3","charTypeName":"word"},{"id":56202,"position":16,"arabic":"عَذَابٌ","translation":"শাস্তি","audioUrl":"wbw/016_063_016.mp3","charTypeName":"word"},{"id":56203,"position":17,"arabic":"أَلِيمٌۭ","translation":"নিদারুণ","audioUrl":"wbw/016_063_017.mp3","charTypeName":"word"},{"id":56204,"position":18,"arabic":"٦٣","translation":"(৬৩)","audioUrl":null,"charTypeName":"end"}]},{"number":64,"arabic":"وَمَآ أَنزَلْنَا عَلَيْكَ ٱلْكِتَٰبَ إِلَّا لِتُبَيِّنَ لَهُمُ ٱلَّذِى ٱخْتَلَفُوا۟ فِيهِ ۙ وَهُدًۭى وَرَحْمَةًۭ لِّقَوْمٍۢ يُؤْمِنُونَ","translation":"And upon thee [too] have We bestowed from on' high this divine writ for no other reason than that thou might make clear unto them all [questions of faith] on which they have come to hold divergent views, and [thus offer] guidance and grace unto people who will believe.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1965.mp3","surahId":16,"words":[{"id":56945,"position":1,"arabic":"وَمَآ","translation":"এবং না","audioUrl":"wbw/016_064_001.mp3","charTypeName":"word"},{"id":56946,"position":2,"arabic":"أَنزَلْنَا","translation":"আমরা অবতীর্ণ করেছি","audioUrl":"wbw/016_064_002.mp3","charTypeName":"word"},{"id":56947,"position":3,"arabic":"عَلَيْكَ","translation":"তোমার উপর","audioUrl":"wbw/016_064_003.mp3","charTypeName":"word"},{"id":56948,"position":4,"arabic":"ٱلْكِتَـٰبَ","translation":"কিতাব","audioUrl":"wbw/016_064_004.mp3","charTypeName":"word"},{"id":56949,"position":5,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/016_064_005.mp3","charTypeName":"word"},{"id":56950,"position":6,"arabic":"لِتُبَيِّنَ","translation":"যেন তুমি প্রকাশ করো","audioUrl":"wbw/016_064_006.mp3","charTypeName":"word"},{"id":56951,"position":7,"arabic":"لَهُمُ","translation":"তাদের কাছে","audioUrl":"wbw/016_064_007.mp3","charTypeName":"word"},{"id":56952,"position":8,"arabic":"ٱلَّذِى","translation":"সে বিষয়ে","audioUrl":"wbw/016_064_008.mp3","charTypeName":"word"},{"id":56953,"position":9,"arabic":"ٱخْتَلَفُوا۟","translation":"তারা মত-বিরোধ করেছে","audioUrl":"wbw/016_064_009.mp3","charTypeName":"word"},{"id":56954,"position":10,"arabic":"فِيهِ ۙ","translation":"মধ্যে যার","audioUrl":"wbw/016_064_010.mp3","charTypeName":"word"},{"id":56956,"position":11,"arabic":"وَهُدًۭى","translation":"এবং পথনির্দেশ","audioUrl":"wbw/016_064_012.mp3","charTypeName":"word"},{"id":56957,"position":12,"arabic":"وَرَحْمَةًۭ","translation":"ও দয়াস্বরূপ","audioUrl":"wbw/016_064_013.mp3","charTypeName":"word"},{"id":56958,"position":13,"arabic":"لِّقَوْمٍۢ","translation":"জন্যে লোকদের","audioUrl":"wbw/016_064_014.mp3","charTypeName":"word"},{"id":56959,"position":14,"arabic":"يُؤْمِنُونَ","translation":"(যারা) বিশ্বাস করে","audioUrl":"wbw/016_064_015.mp3","charTypeName":"word"},{"id":56960,"position":15,"arabic":"٦٤","translation":"(৬৪)","audioUrl":null,"charTypeName":"end"}]}]}