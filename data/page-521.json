n/audio/128/ar.alafasy/4689.mp3","surahId":51,"words":[{"id":15989,"position":1,"arabic":"ذُوقُوا۟","translation":"\"(বলা হবে) তোমরা স্বাদ নাও","audioUrl":"wbw/051_014_001.mp3","charTypeName":"word"},{"id":15990,"position":2,"arabic":"فِتْنَتَكُمْ","translation":"তোমাদের বিপর্যয়ের","audioUrl":"wbw/051_014_002.mp3","charTypeName":"word"},{"id":15991,"position":3,"arabic":"هَـٰذَا","translation":"এটা","audioUrl":"wbw/051_014_003.mp3","charTypeName":"word"},{"id":15992,"position":4,"arabic":"ٱلَّذِى","translation":"(সেই জিনিস) যা","audioUrl":"wbw/051_014_004.mp3","charTypeName":"word"},{"id":15993,"position":5,"arabic":"كُنتُم","translation":"তোমরা ছিলে","audioUrl":"wbw/051_014_005.mp3","charTypeName":"word"},{"id":15994,"position":6,"arabic":"بِهِۦ","translation":"সেটাকে","audioUrl":"wbw/051_014_006.mp3","charTypeName":"word"},{"id":15995,"position":7,"arabic":"تَسْتَعْجِلُونَ","translation":"তাড়াতাড়ি চাইতে\"","audioUrl":"wbw/051_014_007.mp3","charTypeName":"word"},{"id":15996,"position":8,"arabic":"١٤","translation":"(১৪)","audioUrl":null,"charTypeName":"end"}]},{"number":15,"arabic":"إِنَّ ٱلْمُتَّقِينَ فِى جَنَّٰتٍۢ وَعُيُونٍ","translation":"[But,] behold, the God-conscious will find themselves amid gardens and springs,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4690.mp3","surahId":51,"words":[{"id":17216,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/051_015_001.mp3","charTypeName":"word"},{"id":17217,"position":2,"arabic":"ٱلْمُتَّقِينَ","translation":"মুত্তাকীরা","audioUrl":"wbw/051_015_002.mp3","charTypeName":"word"},{"id":17218,"position":3,"arabic":"فِى","translation":"(থাকবে) মধ্যে","audioUrl":"wbw/051_015_003.mp3","charTypeName":"word"},{"id":17219,"position":4,"arabic":"جَنَّـٰتٍۢ","translation":"জান্নাতের","audioUrl":"wbw/051_015_004.mp3","charTypeName":"word"},{"id":17220,"position":5,"arabic":"وَعُيُونٍ","translation":"ও ঝর্ণাধারাসমূহের","audioUrl":"wbw/051_015_005.mp3","charTypeName":"word"},{"id":17221,