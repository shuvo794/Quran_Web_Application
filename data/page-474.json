{"id":474,"ayahs":[{"number":59,"arabic":"إِنَّ ٱلسَّاعَةَ لَءَاتِيَةٌۭ لَّا رَيْبَ فِيهَا وَلَٰكِنَّ أَكْثَرَ ٱلنَّاسِ لَا يُؤْمِنُونَ","translation":"Verily, the Last Hour is sure to come: of this there is no doubt; yet most men will not believe it.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4192.mp3","surahId":40,"words":[{"id":54060,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/040_059_001.mp3","charTypeName":"word"},{"id":54061,"position":2,"arabic":"ٱلسَّاعَةَ","translation":"ক্বিয়ামাত","audioUrl":"wbw/040_059_002.mp3","charTypeName":"word"},{"id":54062,"position":3,"arabic":"لَـَٔاتِيَةٌۭ","translation":"আসবে অবশ্যই","audioUrl":"wbw/040_059_003.mp3","charTypeName":"word"},{"id":54063,"position":4,"arabic":"لَّا","translation":"নেই","audioUrl":"wbw/040_059_004.mp3","charTypeName":"word"},{"id":54064,"position":5,"arabic":"رَيْبَ","translation":"কোনো সন্দেহ","audioUrl":"wbw/040_059_005.mp3","charTypeName":"word"},{"id":54065,"position":6,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/040_059_006.mp3","charTypeName":"word"},{"id":54066,"position":7,"arabic":"وَلَـٰكِنَّ","translation":"কিন্তু","audioUrl":"wbw/040_059_007.mp3","charTypeName":"word"},{"id":54067,"position":8,"arabic":"أَكْثَرَ","translation":"অধিকাংশ","audioUrl":"wbw/040_059_008.mp3","charTypeName":"word"},{"id":54068,"position":9,"arabic":"ٱلنَّاسِ","translation":"মানুষই","audioUrl":"wbw/040_059_009.mp3","charTypeName":"word"},{"id":54069,"position":10,"arabic":"لَا","translation":"না","audioUrl":"wbw/040_059_010.mp3","charTypeName":"word"},{"id":54070,"position":11,"arabic":"يُؤْمِنُونَ","translation":"ঈমান আনে","audioUrl":"wbw/040_059_011.mp3","charTypeName":"word"},{"id":54071,"position":12,"arabic":"٥٩","translation":"(৫৯)","audioUrl":null,"charTypeName":"end"}]},{"number":60,"arabic":"وَقَالَ رَبُّكُمُ ٱدْعُونِىٓ أَسْتَجِبْ لَكُمْ ۚ إِنَّ ٱلَّذِينَ يَسْتَكْبِرُونَ عَنْ عِبَادَتِى سَيَدْخُلُونَ جَهَنَّمَ دَاخِرِينَ","translation":"But your Sustainer says: “Call unto Me, [and] I shall respond to you! Verily, they who are too proud to worship Me will enter hell, abased!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4193.mp3","surahId":40,"words":[{"id":54233,"position":1,"arabic":"وَقَالَ","translation":"এবং বলেন","audioUrl":"wbw/040_060_001.mp3","charTypeName":"word"},{"id":54234,"position":2,"arabic":"رَبُّكُمُ","translation":"তোমাদের রব","audioUrl":"wbw/040_060_002.mp3","charTypeName":"word"},{"id":54235,"position":3,"arabic":"ٱدْعُونِىٓ","translation":"\"তোমরা ডাকো আমাকে","audioUrl":"wbw/040_060_003.mp3","charTypeName":"word"},{"id":54236,"position":4,"arabic":"أَسْتَجِبْ","translation":"সাড়া দিবো আমি","audioUrl":"wbw/040_060_004.mp3","charTypeName":"word"},{"id":54237,"position":5,"arabic":"لَكُمْ ۚ","translation":"তোমাদেরকে","audioUrl":"wbw/040_060_005.mp3","charTypeName":"word"},{"id":54239,"position":6,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/040_060_007.mp3","charTypeName":"word"},{"id":54240,"position":7,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/040_060_008.mp3","charTypeName":"word"},{"id":54241,"position":8,"arabic":"يَسْتَكْبِرُونَ","translation":"অহংকার করে (বিমুখ থাকে)","audioUrl":"wbw/040_060_009.mp3","charTypeName":"word"},{"id":54242,"position":9,"arabic":"عَنْ","translation":"হ'তে","audioUrl":"wbw/040_060_010.mp3","charTypeName":"word"},{"id":54243,"position":10,"arabic":"عِبَادَتِى","translation":"আমার ইবাদাত","audioUrl":"wbw/040_060_011.mp3","charTypeName":"word"},{"id":54244,"position":11,"arabic":"سَيَدْخُلُونَ","translation":"অবশ্যই তারা প্রবেশ করবে","audioUrl":"wbw/040_060_012.mp3","charTypeName":"word"},{"id":54245,"position":12,"arabic":"جَهَنَّمَ","translation":"জাহান্নামে","audioUrl":"wbw/040_060_013.mp3","charTypeName":"word"},{"id":54246,"position":13,"arabic":"دَاخِرِينَ","translation":"অপমানিত হয়ে\"","audioUrl":"wbw/040_060_014.mp3","charTypeName":"word"},{"id":54247,"position":14,"arabic":"٦٠","translation":"(৬০)","audioUrl":null,"charTypeName":"end"}]},{"number":61,"arabic":"ٱللَّهُ ٱلَّذِى جَعَلَ لَكُمُ ٱلَّيْلَ لِتَسْكُنُوا۟ فِيهِ وَٱلنَّهَارَ مُبْصِرًا ۚ إِنَّ ٱللَّهَ لَذُو فَضْلٍ عَلَى ٱلنَّاسِ وَلَٰكِنَّ أَكْثَرَ ٱلنَّاسِ لَا يَشْكُرُونَ","translation":"IT IS GOD who has made the night for you, so that you might rest therein, and the day, to make [you] see. Behold, God is indeed limitless in His bounty unto man - but most men are ungrateful.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4194.mp3","surahId":40,"words":[{"id":55267,"position":1,"arabic":"ٱللَّهُ","translation":"(তিনিই) আল্লাহ","audioUrl":"wbw/040_061_001.mp3","charTypeName":"word"},{"id":55268,"position":2,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/040_061_002.mp3","charTypeName":"word"},{"id":55269,"position":3,"arabic":"جَعَلَ","translation":"সৃষ্টি করেছেন","audioUrl":"wbw/040_061_003.mp3","charTypeName":"word"},{"id":55270,"position":4,"arabic":"لَكُمُ","translation":"তোমাদের জন্যে","audioUrl":"wbw/040_061_004.mp3","charTypeName":"word"},{"id":55271,"position":5,"arabic":"ٱلَّيْلَ","translation":"রাতকে","audioUrl":"wbw/040_061_005.mp3","charTypeName":"word"},{"id":55272,"position":6,"arabic":"لِتَسْكُنُوا۟","translation":"তোমরা যেন শান্তি পাও","audioUrl":"wbw/040_061_006.mp3","charTypeName":"word"},{"id":55273,"position":7,"arabic":"فِيهِ","translation":"তার মধ্যে","audioUrl":"wbw/040_061_007.mp3","charTypeName":"word"},{"id":55274,"position":8,"arabic":"وَٱلنَّهَارَ","translation":"এবং দিনকে","audioUrl":"wbw/040_061_008.mp3","charTypeName":"word"},{"id":55275,"position":9,"arabic":"مُبْصِرًا ۚ","translation":"উজ্জ্বল (বানিয়েছেন)","audioUrl":"wbw/040_061_009.mp3","charTypeName":"word"},{"id":55277,"position":10,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/040_061_011.mp3","charTypeName":"word"},{"id":55278,"position":11,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/040_061_012.mp3","charTypeName":"word"},{"id":55279,"position":12,"arabic":"لَذُو","translation":"অবশ্যই","audioUrl":"wbw/040_061_013.mp3","charTypeName":"word"},{"id":55280,"position":13,"arabic":"فَضْلٍ","translation":"অনুগ্রহশীল","audioUrl":"wbw/040_061_014.mp3","charTypeName":"word"},{"id":55281,"position":14,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/040_061_015.mp3","charTypeName":"word"},{"id":55282,"position":15,"arabic":"ٱلنَّاسِ","translation":"মানুষের","audioUrl":"wbw/040_061_016.mp3","charTypeName":"word"},{"id":55283,"position":16,"arabic":"وَلَـٰكِنَّ","translation":"কিন্তু","audioUrl":"wbw/040_061_017.mp3","charTypeName":"word"},{"id":55284,"position":17,"arabic":"أَكْثَرَ","translation":"অধিকাংশ","audioUrl":"wbw/040_061_018.mp3","charTypeName":"word"},{"id":55285,"position":18,"arabic":"ٱلنَّاسِ","translation":"মানুষই","audioUrl":"wbw/040_061_019.mp3","charTypeName":"word"},{"id":55286,"position":19,"arabic":"لَا","translation":"না","audioUrl":"wbw/040_061_020.mp3","charTypeName":"word"},{"id":55287,"position":20,"arabic":"يَشْكُرُونَ","translation":"তারা কৃতজ্ঞতা প্রকাশ করে","audioUrl":"wbw/040_061_021.mp3","charTypeName":"word"},{"id":55288,"position":21,"arabic":"٦١","translation":"(৬১)","audioUrl":null,"charTypeName":"end"}]},{"number":62,"arabic":"ذَٰلِكُمُ ٱللَّهُ رَبُّكُمْ خَٰلِقُ كُلِّ شَىْءٍۢ لَّآ إِلَٰهَ إِلَّا هُوَ ۖ فَأَنَّىٰ تُؤْفَكُونَ","translation":"Such is God, your Sustainer, the Creator of all that exists: there is no deity save Him. How perverted, then, are your minds!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4195.mp3","surahId":40,"words":[{"id":55868,"position":1,"arabic":"ذَٰلِكُمُ","translation":"তিনিই তোমাদের","audioUrl":"wbw/040_062_001.mp3","charTypeName":"word"},{"id":55869,"position":2,"arabic":"ٱللَّهُ","translation":"আল্লাহই","audioUrl":"wbw/040_062_002.mp3","charTypeName":"word"},{"id":55870,"position":3,"arabic":"رَبُّكُمْ","translation":"তোমাদের রব","audioUrl":"wbw/040_062_003.mp3","charTypeName":"word"},{"id":55871,"position":4,"arabic":"خَـٰلِقُ","translation":"স্রষ্টা","audioUrl":"wbw/040_062_004.mp3","charTypeName":"word"},{"id":55872,"position":5,"arabic":"كُلِّ","translation":"সব","audioUrl":"wbw/040_062_005.mp3","charTypeName":"word"},{"id":55873,"position":6,"arabic":"شَىْءٍۢ","translation":"কিছুর","audioUrl":"wbw/040_062_006.mp3","charTypeName":"word"},{"id":55874,"position":7,"arabic":"لَّآ","translation":"নেই","audioUrl":"wbw/040_062_007.mp3","charTypeName":"word"},{"id":55875,"position":8,"arabic":"إِلَـٰهَ","translation":"কোনো ইলাহ","audioUrl":"wbw/040_062_008.mp3","charTypeName":"word"},{"id":55876,"position":9,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/040_062_009.mp3","charTypeName":"word"},{"id":55877,"position":10,"arabic":"هُوَ ۖ","translation":"তিনি","audioUrl":"wbw/040_062_010.mp3","charTypeName":"word"},{"id":55879,"position":11,"arabic":"فَأَنَّىٰ","translation":"তাহ'লে কোথায়","audioUrl":"wbw/040_062_012.mp3","charTypeName":"word"},{"id":55880,"position":12,"arabic":"تُؤْفَكُونَ","translation":"তোমাদের ফিরানো হচ্ছে","audioUrl":"wbw/040_062_013.mp3","charTypeName":"word"},{"id":55881,"position":13,"arabic":"٦٢","translation":"(৬২)","audioUrl":null,"charTypeName":"end"}]},{"number":63,"arabic":"كَذَٰلِكَ يُؤْفَكُ ٱلَّذِينَ كَانُوا۟ بِـَٔايَٰتِ ٱللَّهِ يَجْحَدُونَ","translation":"[For] thus it is: perverted are the minds of those who knowingly reject God’s messages.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4196.mp3","surahId":40,"words":[{"id":56264,"position":1,"arabic":"كَذَٰلِكَ","translation":"এভাবেই","audioUrl":"wbw/040_063_001.mp3","charTypeName":"word"},{"id":56265,"position":2,"arabic":"يُؤْفَكُ","translation":"ফিরানো হয়েছে","audioUrl":"wbw/040_063_002.mp3","charTypeName":"word"},{"id":56266,"position":3,"arabic":"ٱلَّذِينَ","translation":"(তাদেরকে) যারা","audioUrl":"wbw/040_063_003.mp3","charTypeName":"word"},{"id":56267,"position":4,"arabic":"كَانُوا۟","translation":"ছিলো","audioUrl":"wbw/040_063_004.mp3","charTypeName":"word"},{"id":56268,"position":5,"arabic":"بِـَٔايَـٰتِ","translation":"নির্দেশনাবলীকে","audioUrl":"wbw/040_063_005.mp3","charTypeName":"word"},{"id":56269,"position":6,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/040_063_006.mp3","charTypeName":"word"},{"id":56270,"position":7,"arabic":"يَجْحَدُونَ","translation":"অস্বীকার করতো","audioUrl":"wbw/040_063_007.mp3","charTypeName":"word"},{"id":56271,"position":8,"arabic":"٦٣","translation":"(৬৩)","audioUrl":null,"charTypeName":"end"}]},{"number":64,"arabic":"ٱللَّهُ ٱلَّذِى جَعَلَ لَكُمُ ٱلْأَرْضَ قَرَارًۭا وَٱلسَّمَآءَ بِنَآءًۭ وَصَوَّرَكُمْ فَأَحْسَنَ صُوَرَكُمْ وَرَزَقَكُم مِّنَ ٱلطَّيِّبَٰتِ ۚ ذَٰلِكُمُ ٱللَّهُ رَبُّكُمْ ۖ فَتَبَارَكَ ٱللَّهُ رَبُّ ٱلْعَٰلَمِينَ","translation":"It is God who has made the earth a resting- place for you and the sky a canopy, and has formed you - and formed you so well and provided for you sustenance out of the good things of life. Such is God, your Sustainer: hallowed, then, is God, the Sustainer of all the worlds!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4197.mp3","surahId":40,"words":[{"id":56459,"position":1,"arabic":"ٱللَّهُ","translation":"(তিনিই) আল্লাহ","audioUrl":"wbw/040_064_001.mp3","charTypeName":"word"},{"id":56460,"position":2,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/040_064_002.mp3","charTypeName":"word"},{"id":56461,"position":3,"arabic":"جَعَلَ","translation":"বানিয়েছেন","audioUrl":"wbw/040_064_003.mp3","charTypeName":"word"},{"id":56462,"position":4,"arabic":"لَكُمُ","translation":"তোমাদের জন্যে","audioUrl":"wbw/040_064_004.mp3","charTypeName":"word"},{"id":56463,"position":5,"arabic":"ٱلْأَرْضَ","translation":"পৃথিবীকে","audioUrl":"wbw/040_064_005.mp3","charTypeName":"word"},{"id":56464,"position":6,"arabic":"قَرَارًۭا","translation":"বাসস্থান","audioUrl":"wbw/040_064_006.mp3","charTypeName":"word"},{"id":56465,"position":7,"arabic":"وَٱلسَّمَآءَ","translation":"ও আকাশকে","audioUrl":"wbw/040_064_007.mp3","charTypeName":"word"},{"id":56466,"position":8,"arabic":"بِنَآءًۭ","translation":"এবং (চাঁদোয়ার মত) ছাদ","audioUrl":"wbw/040_064_008.mp3","charTypeName":"word"},{"id":56467,"position":9,"arabic":"وَصَوَّرَكُمْ","translation":"তোমাদেরকে আকৃতি দিয়েছেন","audioUrl":"wbw/040_064_009.mp3","charTypeName":"word"},{"id":56468,"position":10,"arabic":"فَأَحْسَنَ","translation":"অতঃপর সুন্দর করেছেন","audioUrl":"wbw/040_064_010.mp3","charTypeName":"word"},{"id":56469,"position":11,"arabic":"صُوَرَكُمْ","translation":"তোমাদের আকৃতিসমূহ","audioUrl":"wbw/040_064_011.mp3","charTypeName":"word"},{"id":56470,"position":12,"arabic":"وَرَزَقَكُم","translation":"এবং তোমাদের জীবিকা দিয়েছেন","audioUrl":"wbw/040_064_012.mp3","charTypeName":"word"},{"id":56471,"position":13,"arabic":"مِّنَ","translation":"থেকে","audioUrl":"wbw/040_064_013.mp3","charTypeName":"word"},{"id":56472,"position":14,"arabic":"ٱلطَّيِّبَـٰتِ ۚ","translation":"পবিত্র জিনিস সমূহের","audioUrl":"wbw/040_064_014.mp3","charTypeName":"word"},{"id":56474,"position":15,"arabic":"ذَٰلِكُمُ","translation":"তিনিই তোমাদের","audioUrl":"wbw/040_064_016.mp3","charTypeName":"word"},{"id":56475,"position":16,"arabic":"ٱللَّهُ","translation":"আল্লাহই","audioUrl":"wbw/040_064_017.mp3","charTypeName":"word"},{"id":56476,"position":17,"arabic":"رَبُّكُمْ ۖ","translation":"তোমাদের রব","audioUrl":"wbw/040_064_018.mp3","charTypeName":"word"},{"id":56478,"position":18,"arabic":"فَتَبَارَكَ","translation":"অতএব কত মহান","audioUrl":"wbw/040_064_020.mp3","charTypeName":"word"},{"id":56479,"position":19,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/040_064_021.mp3","charTypeName":"word"},{"id":56480,"position":20,"arabic":"رَبُّ","translation":"রব","audioUrl":"wbw/040_064_022.mp3","charTypeName":"word"},{"id":56481,"position":21,"arabic":"ٱلْعَـٰلَمِينَ","translation":"বিশ্ব জগতের","audioUrl":"wbw/040_064_023.mp3","charTypeName":"word"},{"id":56482,"position":22,"arabic":"٦٤","translation":"(৬৪)","audioUrl":null,"charTypeName":"end"}]},{"number":65,"arabic":"هُوَ ٱلْحَىُّ لَآ إِلَٰهَ إِلَّا هُوَ فَٱدْعُوهُ مُخْلِصِينَ لَهُ ٱلدِّينَ ۗ ٱلْحَمْدُ لِلَّهِ رَبِّ ٱلْعَٰلَمِينَ","translation":"He is the Ever-Living; there is no deity save Him: call, then, unto Him [alone], sincere in your faith in Him. All praise is due to God, the Sustainer of all the worlds!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4198.mp3","surahId":40,"words":[{"id":57017,"position":1,"arabic":"هُوَ","translation":"তিনি","audioUrl":"wbw/040_065_001.mp3","charTypeName":"word"},{"id":57018,"position":2,"arabic":"ٱلْحَىُّ","translation":"চিরঞ্জীব","audioUrl":"wbw/040_065_002.mp3","charTypeName":"word"},{"id":57019,"position":3,"arabic":"لَآ","translation":"নেই","audioUrl":"wbw/040_065_003.mp3","charTypeName":"word"},{"id":57020,"position":4,"arabic":"إِلَـٰهَ","translation":"কোনো ইলাহ","audioUrl":"wbw/040_065_004.mp3","charTypeName":"word"},{"id":57021,"position":5,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/040_065_005.mp3","charTypeName":"word"},{"id":57022,"position":6,"arabic":"هُوَ","translation":"তিনি","audioUrl":"wbw/040_065_006.mp3","charTypeName":"word"},{"id":57023,"position":7,"arabic":"فَٱدْعُوهُ","translation":"সুতরাং তাঁকেই ডাকো","audioUrl":"wbw/040_065_007.mp3","charTypeName":"word"},{"id":57024,"position":8,"arabic":"مُخْلِصِينَ","translation":"একনিষ্ঠ হয়ে","audioUrl":"wbw/040_065_008.mp3","charTypeName":"word"},{"id":57025,"position":9,"arabic":"لَهُ","translation":"তাঁরই জন্যে","audioUrl":"wbw/040_065_009.mp3","charTypeName":"word"},{"id":57026,"position":10,"arabic":"ٱلدِّينَ ۗ","translation":"আনুগত্যকে (নির্দিষ্ট করে)","audioUrl":"wbw/040_065_010.mp3","charTypeName":"word"},{"id":57028,"position":11,"arabic":"ٱلْحَمْدُ","translation":"সব প্রশংসা","audioUrl":"wbw/040_065_012.mp3","charTypeName":"word"},{"id":57029,"position":12,"arabic":"لِلَّهِ","translation":"আল্লাহর জন্যে","audioUrl":"wbw/040_065_013.mp3","charTypeName":"word"},{"id":57030,"position":13,"arabic":"رَبِّ","translation":"রব","audioUrl":"wbw/040_065_014.mp3","charTypeName":"word"},{"id":57031,"position":14,"arabic":"ٱلْعَـٰلَمِينَ","translation":"বিশ্বজগতের","audioUrl":"wbw/040_065_015.mp3","charTypeName":"word"},{"id":57032,"position":15,"arabic":"٦٥","translation":"(৬৫)","audioUrl":null,"charTypeName":"end"}]},{"number":66,"arabic":"۞ قُلْ إِنِّى نُهِيتُ أَنْ أَعْبُدَ ٱلَّذِينَ تَدْعُونَ مِن دُونِ ٱللَّهِ لَمَّا جَآءَنِىَ ٱلْبَيِّنَٰتُ مِن رَّبِّى وَأُمِرْتُ أَنْ أُسْلِمَ لِرَبِّ ٱلْعَٰلَمِينَ","translation":"Say: “Since all evidence of the truth has come to me from my Sustainer, I am forbidden to worship [any of] those beings whom you invoke instead of God; and I am bidden to surrender myself to the Sustainer of all the worlds.”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4199.mp3","surahId":40,"words":[{"id":57659,"position":1,"arabic":"۞ قُلْ","translation":"(হে নাবী) বলো","audioUrl":"wbw/040_066_002.mp3","charTypeName":"word"},{"id":57660,"position":2,"arabic":"إِنِّى","translation":"\"নিশ্চয়ই আমাকে","audioUrl":"wbw/040_066_003.mp3","charTypeName":"word"},{"id":57661,"position":3,"arabic":"نُهِيتُ","translation":"নিষেধ করা হয়েছে","audioUrl":"wbw/040_066_004.mp3","charTypeName":"word"},{"id":57662,"position":4,"arabic":"أَنْ","translation":"যেন (না)","audioUrl":"wbw/040_066_005.mp3","charTypeName":"word"},{"id":57663,"position":5,"arabic":"أَعْبُدَ","translation":"ইবাদত করি আমি","audioUrl":"wbw/040_066_006.mp3","charTypeName":"word"},{"id":57664,"position":6,"arabic":"ٱلَّذِينَ","translation":"(তাদেরকে) যাদের","audioUrl":"wbw/040_066_007.mp3","charTypeName":"word"},{"id":57665,"position":7,"arabic":"تَدْعُونَ","translation":"তোমরা ডাকো","audioUrl":"wbw/040_066_008.mp3","charTypeName":"word"},{"id":57666,"position":8,"arabic":"مِن","translation":"মধ্য হতে","audioUrl":"wbw/040_066_009.mp3","charTypeName":"word"},{"id":57667,"position":9,"arabic":"دُونِ","translation":"ছাড়া","audioUrl":"wbw/040_066_010.mp3","charTypeName":"word"},{"id":57668,"position":10,"arabic":"ٱللَّهِ","translation":"আল্লাহ","audioUrl":"wbw/040_066_011.mp3","charTypeName":"word"},{"id":57669,"position":11,"arabic":"لَمَّا","translation":"যখন","audioUrl":"wbw/040_066_012.mp3","charTypeName":"word"},{"id":57670,"position":12,"arabic":"جَآءَنِىَ","translation":"আমার কাছে এসেছে","audioUrl":"wbw/040_066_013.mp3","charTypeName":"word"},{"id":57671,"position":13,"arabic":"ٱلْبَيِّنَـٰتُ","translation":"সুস্পষ্ট নিদর্শন","audioUrl":"wbw/040_066_014.mp3","charTypeName":"word"},{"id":57672,"position":14,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/040_066_015.mp3","charTypeName":"word"},{"id":57673,"position":15,"arabic":"رَّبِّى","translation":"আমার রবের","audioUrl":"wbw/040_066_016.mp3","charTypeName":"word"},{"id":57674,"position":16,"arabic":"وَأُمِرْتُ","translation":"এবং আমাকে আদেশ করা হয়েছে","audioUrl":"wbw/040_066_017.mp3","charTypeName":"word"},{"id":57675,"position":17,"arabic":"أَنْ","translation":"যে","audioUrl":"wbw/040_066_018.mp3","charTypeName":"word"},{"id":57676,"position":18,"arabic":"أُسْلِمَ","translation":"আত্মসমর্পণ করি আমি","audioUrl":"wbw/040_066_019.mp3","charTypeName":"word"},{"id":57677,"position":19,"arabic":"لِرَبِّ","translation":"রবের কাছে","audioUrl":"wbw/040_066_020.mp3","charTypeName":"word"},{"id":57678,"position":20,"arabic":"ٱلْعَـٰلَمِينَ","translation":"বিশ্বজগতের","audioUrl":"wbw/040_066_021.mp3","charTypeName":"word"},{"id":57679,"position":21,"arabic":"٦٦","translation":"(৬৬)","audioUrl":null,"charTypeName":"end"}]}]}