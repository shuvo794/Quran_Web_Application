{"id":397,"ayahs":[{"number":7,"arabic":"وَٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ لَنُكَفِّرَنَّ عَنْهُمْ سَيِّـَٔاتِهِمْ وَلَنَجْزِيَنَّهُمْ أَحْسَنَ ٱلَّذِى كَانُوا۟ يَعْمَلُونَ","translation":"And as for those who attain to faith and do righteous deeds, We shall most certainly efface their [previous] bad deeds, and shall most certainly reward them in accordance with the best that they ever did.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3347.mp3","surahId":29,"words":[{"id":8209,"position":1,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/029_007_001.mp3","charTypeName":"word"},{"id":8210,"position":2,"arabic":"ءَامَنُوا۟","translation":"ঈমান আনে","audioUrl":"wbw/029_007_002.mp3","charTypeName":"word"},{"id":8211,"position":3,"arabic":"وَعَمِلُوا۟","translation":"ও কাজ করে","audioUrl":"wbw/029_007_003.mp3","charTypeName":"word"},{"id":8212,"position":4,"arabic":"ٱلصَّـٰلِحَـٰتِ","translation":"সৎ","audioUrl":"wbw/029_007_004.mp3","charTypeName":"word"},{"id":8213,"position":5,"arabic":"لَنُكَفِّرَنَّ","translation":"অবশ্যই মিটিয়ে দিবো আমরা","audioUrl":"wbw/029_007_005.mp3","charTypeName":"word"},{"id":8214,"position":6,"arabic":"عَنْهُمْ","translation":"তাদের হ'তে তাদের","audioUrl":"wbw/029_007_006.mp3","charTypeName":"word"},{"id":8215,"position":7,"arabic":"سَيِّـَٔاتِهِمْ","translation":"দোষগুলো তাদের","audioUrl":"wbw/029_007_007.mp3","charTypeName":"word"},{"id":8216,"position":8,"arabic":"وَلَنَجْزِيَنَّهُمْ","translation":"এবং অবশ্যই আমরা প্রতিফল দিবো তাদেরকে","audioUrl":"wbw/029_007_008.mp3","charTypeName":"word"},{"id":8217,"position":9,"arabic":"أَحْسَنَ","translation":"অতি উত্তম","audioUrl":"wbw/029_007_009.mp3","charTypeName":"word"},{"id":8218,"position":10,"arabic":"ٱلَّذِى","translation":"(বদলে) যা","audioUrl":"wbw/029_007_010.mp3","charTypeName":"word"},{"id":8219,"position":11,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/029_007_011.mp3","charTypeName":"word"},{"id":8220,"position":12,"arabic":"يَعْمَلُونَ","translation":"তারা কাজ করে","audioUrl":"wbw/029_007_012.mp3","charTypeName":"word"},{"id":8221,"position":13,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"وَوَصَّيْنَا ٱلْإِنسَٰنَ بِوَٰلِدَيْهِ حُسْنًۭا ۖ وَإِن جَٰهَدَاكَ لِتُشْرِكَ بِى مَا لَيْسَ لَكَ بِهِۦ عِلْمٌۭ فَلَا تُطِعْهُمَآ ۚ إِلَىَّ مَرْجِعُكُمْ فَأُنَبِّئُكُم بِمَا كُنتُمْ تَعْمَلُونَ","translation":"Now [among the best of righteous deeds which] We have enjoined upon man [is] goodness towards his parents; yet [even so,] should they endeavour to make thee ascribe divinity, side by side with Me, to something which thy mind cannot accept [as divine], obey then, not: [for] it is unto Me that you all must return, whereupon I shall make you [truly] understand [the right and wrong of] all that you were doing [in life].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3348.mp3","surahId":29,"words":[{"id":9361,"position":1,"arabic":"وَوَصَّيْنَا","translation":"এবং জোর নির্দেশ দিয়েছি আমরা","audioUrl":"wbw/029_008_001.mp3","charTypeName":"word"},{"id":9362,"position":2,"arabic":"ٱلْإِنسَـٰنَ","translation":"মানুষকে","audioUrl":"wbw/029_008_002.mp3","charTypeName":"word"},{"id":9363,"position":3,"arabic":"بِوَٰلِدَيْهِ","translation":"কাছে তার পিতা-মাতার প্রতি","audioUrl":"wbw/029_008_003.mp3","charTypeName":"word"},{"id":9364,"position":4,"arabic":"حُسْنًۭا ۖ","translation":"উত্তম (ব্যবহারের)","audioUrl":"wbw/029_008_004.mp3","charTypeName":"word"},{"id":9366,"position":5,"arabic":"وَإِن","translation":"কিন্তু যদি","audioUrl":"wbw/029_008_006.mp3","charTypeName":"word"},{"id":9367,"position":6,"arabic":"جَـٰهَدَاكَ","translation":"তোমাকে দু'জনে চাপ দেয়","audioUrl":"wbw/029_008_007.mp3","charTypeName":"word"},{"id":9368,"position":7,"arabic":"لِتُشْرِكَ","translation":"যেন তুমি শিরক করো","audioUrl":"wbw/029_008_008.mp3","charTypeName":"word"},{"id":9369,"position":8,"arabic":"بِى","translation":"সাথে আমার","audioUrl":"wbw/029_008_009.mp3","charTypeName":"word"},{"id":9370,"position":9,"arabic":"مَا","translation":"যার","audioUrl":"wbw/029_008_010.mp3","charTypeName":"word"},{"id":9371,"position":10,"arabic":"لَيْسَ","translation":"নেই","audioUrl":"wbw/029_008_011.mp3","charTypeName":"word"},{"id":9372,"position":11,"arabic":"لَكَ","translation":"তোমার","audioUrl":"wbw/029_008_012.mp3","charTypeName":"word"},{"id":9373,"position":12,"arabic":"بِهِۦ","translation":"সম্পর্কে সে","audioUrl":"wbw/029_008_013.mp3","charTypeName":"word"},{"id":9374,"position":13,"arabic":"عِلْمٌۭ","translation":"কোনো জ্ঞান","audioUrl":"wbw/029_008_014.mp3","charTypeName":"word"},{"id":9375,"position":14,"arabic":"فَلَا","translation":"তাহ'লে না","audioUrl":"wbw/029_008_015.mp3","charTypeName":"word"},{"id":9376,"position":15,"arabic":"تُطِعْهُمَآ ۚ","translation":"অনুগত্য করো তাদের দু'য়ের","audioUrl":"wbw/029_008_016.mp3","charTypeName":"word"},{"id":9378,"position":16,"arabic":"إِلَىَّ","translation":"দিকে আমারই","audioUrl":"wbw/029_008_018.mp3","charTypeName":"word"},{"id":9379,"position":17,"arabic":"مَرْجِعُكُمْ","translation":"প্রত্যাবর্তন তোমাদের (হবে)","audioUrl":"wbw/029_008_019.mp3","charTypeName":"word"},{"id":9380,"position":18,"arabic":"فَأُنَبِّئُكُم","translation":"তখন আমি জানিয়ে দিবো তোমাদেরকে","audioUrl":"wbw/029_008_020.mp3","charTypeName":"word"},{"id":9381,"position":19,"arabic":"بِمَا","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/029_008_021.mp3","charTypeName":"word"},{"id":9382,"position":20,"arabic":"كُنتُمْ","translation":"তোমরা ছিলে","audioUrl":"wbw/029_008_022.mp3","charTypeName":"word"},{"id":9383,"position":21,"arabic":"تَعْمَلُونَ","translation":"তোমরা কাজ করে","audioUrl":"wbw/029_008_023.mp3","charTypeName":"word"},{"id":9384,"position":22,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"وَٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ لَنُدْخِلَنَّهُمْ فِى ٱلصَّٰلِحِينَ","translation":"But as for those who have attained to faith and have done righteous deeds, We shall most certainly cause them to join the righteous [in the hereafter as well].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3349.mp3","surahId":29,"words":[{"id":10532,"position":1,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/029_009_001.mp3","charTypeName":"word"},{"id":10533,"position":2,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/029_009_002.mp3","charTypeName":"word"},{"id":10534,"position":3,"arabic":"وَعَمِلُوا۟","translation":"ও কাজ করেছে","audioUrl":"wbw/029_009_003.mp3","charTypeName":"word"},{"id":10535,"position":4,"arabic":"ٱلصَّـٰلِحَـٰتِ","translation":"সৎ","audioUrl":"wbw/029_009_004.mp3","charTypeName":"word"},{"id":10536,"position":5,"arabic":"لَنُدْخِلَنَّهُمْ","translation":"অবশ্যই আমরা প্রবেশ করবো তাদেরকে","audioUrl":"wbw/029_009_005.mp3","charTypeName":"word"},{"id":10537,"position":6,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/029_009_006.mp3","charTypeName":"word"},{"id":10538,"position":7,"arabic":"ٱلصَّـٰلِحِينَ","translation":"সৎকর্মশীলদের","audioUrl":"wbw/029_009_007.mp3","charTypeName":"word"},{"id":10539,"position":8,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"وَمِنَ ٱلنَّاسِ مَن يَقُولُ ءَامَنَّا بِٱللَّهِ فَإِذَآ أُوذِىَ فِى ٱللَّهِ جَعَلَ فِتْنَةَ ٱلنَّاسِ كَعَذَابِ ٱللَّهِ وَلَئِن جَآءَ نَصْرٌۭ مِّن رَّبِّكَ لَيَقُولُنَّ إِنَّا كُنَّا مَعَكُمْ ۚ أَوَلَيْسَ ٱللَّهُ بِأَعْلَمَ بِمَا فِى صُدُورِ ٱلْعَٰلَمِينَ","translation":"Now there is among men many a one who says [of himself and of others like him], “We do believe in God” - but whenever he is made to suffer in God’s cause, he thinks that persecution at the hands of man is as [much to be feared, or even more than,] God’s chastisement; whereas, if succour from thy Sustainer comes [to those who truly believe] he is sure to say. “Behold, we have always been with you!” Is not God fully aware of what is in the hearts of all creatures?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3350.mp3","surahId":29,"words":[{"id":11784,"position":1,"arabic":"وَمِنَ","translation":"এবং মধ্যে","audioUrl":"wbw/029_010_001.mp3","charTypeName":"word"},{"id":11785,"position":2,"arabic":"ٱلنَّاسِ","translation":"মানুষের","audioUrl":"wbw/029_010_002.mp3","charTypeName":"word"},{"id":11786,"position":3,"arabic":"مَن","translation":"কেউ কেউ","audioUrl":"wbw/029_010_003.mp3","charTypeName":"word"},{"id":11787,"position":4,"arabic":"يَقُولُ","translation":"বলে","audioUrl":"wbw/029_010_004.mp3","charTypeName":"word"},{"id":11788,"position":5,"arabic":"ءَامَنَّا","translation":"\"ঈমান এনেছি আমরা","audioUrl":"wbw/029_010_005.mp3","charTypeName":"word"},{"id":11789,"position":6,"arabic":"بِٱللَّهِ","translation":"প্রতি আল্লাহ্‌র\"","audioUrl":"wbw/029_010_006.mp3","charTypeName":"word"},{"id":11790,"position":7,"arabic":"فَإِذَآ","translation":"অতঃপর যখন","audioUrl":"wbw/029_010_007.mp3","charTypeName":"word"},{"id":11791,"position":8,"arabic":"أُوذِىَ","translation":"তারা নির্যাতিত হয়","audioUrl":"wbw/029_010_008.mp3","charTypeName":"word"},{"id":11792,"position":9,"arabic":"فِى","translation":"পথে","audioUrl":"wbw/029_010_009.mp3","charTypeName":"word"},{"id":11793,"position":10,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌র","audioUrl":"wbw/029_010_010.mp3","charTypeName":"word"},{"id":11794,"position":11,"arabic":"جَعَلَ","translation":"গণ্য করে","audioUrl":"wbw/029_010_011.mp3","charTypeName":"word"},{"id":11795,"position":12,"arabic":"فِتْنَةَ","translation":"পীড়নকে","audioUrl":"wbw/029_010_012.mp3","charTypeName":"word"},{"id":11796,"position":13,"arabic":"ٱلنَّاسِ","translation":"মানুষের","audioUrl":"wbw/029_010_013.mp3","charTypeName":"word"},{"id":11797,"position":14,"arabic":"كَعَذَابِ","translation":"শাস্তির মতো","audioUrl":"wbw/029_010_014.mp3","charTypeName":"word"},{"id":11798,"position":15,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌র","audioUrl":"wbw/029_010_015.mp3","charTypeName":"word"}