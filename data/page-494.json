{"id":494,"ayahs":[{"number":61,"arabic":"وَإِنَّهُۥ لَعِلْمٌۭ لِّلسَّاعَةِ فَلَا تَمْتَرُنَّ بِهَا وَٱتَّبِعُونِ ۚ هَٰذَا صِرَٰطٌۭ مُّسْتَقِيمٌۭ","translation":"AND, BEHOLD, this [divine writ] is indeed a means to know [that] the Last Hour [is bound to come]; hence, have no doubt whatever about it, but follow Me: this [alone] is a straight way.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4386.mp3","surahId":43,"words":[{"id":54805,"position":1,"arabic":"وَإِنَّهُۥ","translation":"এবং নিশ্চয়ই সে","audioUrl":"wbw/043_061_001.mp3","charTypeName":"word"},{"id":54806,"position":2,"arabic":"لَعِلْمٌۭ","translation":"অবশ্যই নিদর্শন","audioUrl":"wbw/043_061_002.mp3","charTypeName":"word"},{"id":54807,"position":3,"arabic":"لِّلسَّاعَةِ","translation":"ক্বিয়ামাতের জন্যে","audioUrl":"wbw/043_061_003.mp3","charTypeName":"word"},{"id":54808,"position":4,"arabic":"فَلَا","translation":"সুতরাং না","audioUrl":"wbw/043_061_004.mp3","charTypeName":"word"},{"id":54809,"position":5,"arabic":"تَمْتَرُنَّ","translation":"তোমরা সন্দেহ করো","audioUrl":"wbw/043_061_005.mp3","charTypeName":"word"},{"id":54810,"position":6,"arabic":"بِهَا","translation":"তা সম্বন্ধে","audioUrl":"wbw/043_061_006.mp3","charTypeName":"word"},{"id":54811,"position":7,"arabic":"وَٱتَّبِعُونِ ۚ","translation":"এবং আমাকে তোমরা অনুসরণ করো","audioUrl":"wbw/043_061_007.mp3","charTypeName":"word"},{"id":54813,"position":8,"arabic":"هَـٰذَا","translation":"এটাই","audioUrl":"wbw/043_061_009.mp3","charTypeName":"word"},{"id":54814,"position":9,"arabic":"صِرَٰطٌۭ","translation":"পথ","audioUrl":"wbw/043_061_010.mp3","charTypeName":"word"},{"id":54815,"position":10,"arabic":"مُّسْتَقِيمٌۭ","translation":"সরল সঠিক","audioUrl":"wbw/043_061_011.mp3","charTypeName":"word"},{"id":54816,"position":11,"arabic":"٦١","translation":"(৬১)","audioUrl":null,"charTypeName":"end"}]},{"number":62,"arabic":"وَلَا يَصُدَّنَّكُمُ ٱلشَّيْطَٰنُ ۖ إِنَّهُۥ لَكُمْ عَدُوٌّۭ مُّبِينٌۭ","translation":"And let not Satan bars you [from it] - for, verily, he is your open foe!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4387.mp3","surahId":43,"words":[{"id":55544,"position":1,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/043_062_001.mp3","charTypeName":"word"},{"id":55545,"position":2,"arabic":"يَصُدَّنَّكُمُ","translation":"তোমাদেরকে বাঁধা দিতে পারে (যেন)","audioUrl":"wbw/043_062_002.mp3","charTypeName":"word"},{"id":55546,"position":3,"arabic":"ٱلشَّيْطَـٰنُ ۖ","translation":"শয়তান","audioUrl":"wbw/043_062_003.mp3","charTypeName":"word"},{"id":55548,"position":4,"arabic":"إِنَّهُۥ","translation":"নিশ্চয়ই সে","audioUrl":"wbw/043_062_005.mp3","charTypeName":"word"},{"id":55549,"position":5,"arabic":"لَكُمْ","translation":"তোমাদের জন্যে","audioUrl":"wbw/043_062_006.mp3","charTypeName":"word"},{"id":55550,"position":6,"arabic":"عَدُوٌّۭ","translation":"শত্রু","audioUrl":"wbw/043_062_007.mp3","charTypeName":"word"},{"id":55551,"position":7,"arabic":"مُّبِينٌۭ","translation":"প্রকাশ্য","audioUrl":"wbw/043_062_008.mp3","charTypeName":"word"},{"id":55552,"position":8,"arabic":"٦٢","translation":"(৬২)","audioUrl":null,"charTypeName":"end"}]},{"number":63,"arabic":"وَلَمَّا جَآءَ عِيسَىٰ بِٱلْبَيِّنَٰتِ قَالَ قَدْ جِئْتُكُم بِٱلْحِكْمَةِ وَلِأُبَيِّنَ لَكُم بَعْضَ ٱلَّذِى تَخْتَلِفُونَ فِيهِ ۖ فَٱتَّقُوا۟ ٱللَّهَ وَأَطِيعُونِ","translation":"NOW WHEN Jesus came [to his people] with all evidence of the truth, he said: “I have now come unto you with wisdom, and to make clear Unto you some of that on which you are at variance: hence, be conscious of God, and pay heed unto me.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4388.mp3","surahId":43,"words":[{"id":55995,"position":1,"arabic":"وَلَمَّا","translation":"এবং যখন","audioUrl":"wbw/043_063_001.mp3","charTypeName":"word"},{"id":55996,"position":2,"arabic":"جَآءَ","translation":"এসেছিলো","audioUrl":"wbw/043_063_002.mp3","charTypeName":"word"},{"id":55997,"position":3,"arabic":"عِيسَىٰ","translation":"ঈসা","audioUrl":"wbw/043_063_003.mp3","charTypeName":"word"},{"id":55998,"position":4,"arabic":"بِٱلْبَيِّنَـٰتِ","translation":"সুস্পষ্ট নিদর্শনাবলীসহ","audioUrl":"wbw/043_063_004.mp3","charTypeName":"word"},{"id":55999,"position":5,"arabic":"قَالَ","translation":"সে বলেছিলো","audioUrl":"wbw/043_063_005.mp3","charTypeName":"word"},{"id":56000,"position":6,"arabic":"قَدْ","translation":"\"নিশ্চয়ই","audioUrl":"wbw/043_063_006.mp3","charTypeName":"word"},{"id":56001,"position":7,"arabic":"جِئْتُكُم","translation":"আমি তোমাদের কাছে এসেছি","audioUrl":"wbw/043_063_007.mp3","charTypeName":"word"},{"id":56002,"position":8,"arabic":"بِٱلْحِكْمَةِ","translation":"প্রজ্ঞাসহ","audioUrl":"wbw/043_063_008.mp3","charTypeName":"word"},{"id":56003,"position":9,"arabic":"وَلِأُبَيِّنَ","translation":"এবং আমি সুস্পষ্ট করার জন্যে","audioUrl":"wbw/043_063_009.mp3","charTypeName":"word"},{"id":56004,"position":10,"arabic":"لَكُم","translation":"তোমাদের কাছে","audioUrl":"wbw/043_063_010.mp3","charTypeName":"word"},{"id":56005,"position":11,"arabic":"بَعْضَ","translation":"এমন কিছু","audioUrl":"wbw/043_063_011.mp3","charTypeName":"word"},{"id":56006,"position":12,"arabic":"ٱلَّذِى","translation":"যা","audioUrl":"wbw/043_063_012.mp3","charTypeName":"word"},{"id":56007,"position":13,"arabic":"تَخْتَلِفُونَ","translation":"তোমরা মতভেদ করছো","audioUrl":"wbw/043_063_013.mp3","charTypeName":"word"},{"id":56008,"position":14,"arabic":"فِيهِ ۖ","translation":"তার মধ্যে","audioUrl":"wbw/043_063_014.mp3","charTypeName":"word"},{"id":56010,"position":15,"arabic":"فَٱتَّقُوا۟","translation":"সুতরাং তোমরা ভয় করো","audioUrl":"wbw/043_063_016.mp3","charTypeName":"word"},{"id":56011,"position":16,"arabic":"ٱللَّهَ","translation":"আল্লাহকে","audioUrl":"wbw/043_063_017.mp3","charTypeName":"word"},{"id":56012,"position":17,"arabic":"وَأَطِيعُونِ","translation":"এবং তোমরা আনুগত্য করো আমার","audioUrl":"wbw/043_063_018.mp3","charTypeName":"word"},{"id":56013,"position":18,"arabic":"٦٣","translation":"(৬৩)","audioUrl":null,"charTypeName":"end"}]},{"number":64,"arabic":"إِنَّ ٱللَّهَ هُوَ رَبِّى وَرَبُّكُمْ فَٱعْبُدُوهُ ۚ هَٰذَا صِرَٰطٌۭ مُّسْتَقِيمٌۭ","translation":"“Verily, God is my Sustainer as well as your Sustainer; so worship [none but] Him: this [alone] is a straight way!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4389.mp3","surahId":43,"words":[{"id":56538,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/043_064_001.mp3","charTypeName":"word"},{"id":56539,"position":2,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/043_064_002.mp3","charTypeName":"word"},{"id":56540,"position":3,"arabic":"هُوَ","translation":"তিনিই","audioUrl":"wbw/043_064_003.mp3","charTypeName":"word"},{"id":56541,"position":4,"arabic":"رَبِّى","translation":"আমার রব","audioUrl":"wbw/043_064_004.mp3","charTypeName":"word"},{"id":56542,"position":5,"arabic":"وَرَبُّكُمْ","translation":"ও তোমাদের রব","audioUrl":"wbw/043_064_005.mp3","charTypeName":"word"},{"id":56543,"position":6,"arabic":"فَٱعْبُدُوهُ ۚ","translation":"সুতরাং তাঁরই তোমরা ইবাদত করো","audioUrl":"wbw/043_064_006.mp3","charTypeName":"word"},{"id":56545,"position":7,"arabic":"هَـٰذَا","translation":"এটা","audioUrl":"wbw/043_064_008.mp3","charTypeName":"word"},{"id":56546,"position":8,"arabic":"صِرَٰطٌۭ","translation":"পথ","audioUrl":"wbw/043_064_009.mp3","charTypeName":"word"},{"id":56547,"position":9,"arabic":"مُّسْتَقِيمٌۭ","translation":"সরল সঠিক\"","audioUrl":"wbw/043_064_010.mp3","charTypeName":"word"},{"id":56548,"position":10,"arabic":"٦٤","translation":"(৬৪)","audioUrl":null,"charTypeName":"end"}]},{"number":65,"arabic":"فَٱخْتَلَفَ ٱلْأَحْزَابُ مِنۢ بَيْنِهِمْ ۖ فَوَيْلٌۭ لِّلَّذِينَ ظَلَمُوا۟ مِنْ عَذَابِ يَوْمٍ أَلِيمٍ","translation":"But factions from among those [who came after Jesus] began to hold divergent views: woe, then, unto those who are bent on evildoing - [woe] for the suffering [that will befall them] on a grie­vous Day!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4390.mp3","surahId":43,"words":[{"id":57084,"position":1,"arabic":"فَٱخْتَلَفَ","translation":"অতঃপর মতভেদ করলো","audioUrl":"wbw/043_065_001.mp3","charTypeName":"word"},{"id":57085,"position":2,"arabic":"ٱلْأَحْزَابُ","translation":"বিভিন্ন দল","audioUrl":"wbw/043_065_002.mp3","charTypeName":"word"},{"id":57086,"position":3,"arabic":"مِنۢ","translation":"থেকে","audioUrl":"wbw/043_065_003.mp3","charTypeName":"word"},{"id":57087,"position":4,"arabic":"بَيْنِهِمْ ۖ","translation":"তাদের মাঝ","audioUrl":"wbw/043_065_004.mp3","charTypeName":"word"},{"id":57089,"position":5,"arabic":"فَوَيْلٌۭ","translation":"সুতরাং দুর্ভোগ","audioUrl":"wbw/043_065_006.mp3","charTypeName":"word"},{"id":57090,"position":6,"arabic":"لِّلَّذِينَ","translation":"(তাদের) জন্যে যারা","audioUrl":"wbw/043_065_007.mp3","charTypeName":"word"},{"id":57091,"position":7,"arabic":"ظَلَمُوا۟","translation":"সীমালঙ্ঘন করেছে","audioUrl":"wbw/043_065_008.mp3","charTypeName":"word"},{"id":57092,"position":8,"arabic":"مِنْ","translation":"থেকে","audioUrl":"wbw/043_065_009.mp3","charTypeName":"word"},{"id":57093,"position":9,"arabic":"عَذَابِ","translation":"শাস্তির","audioUrl":"wbw/043_065_010.mp3","charTypeName":"word"},{"id":57094,"position":10,"arabic":"يَوْمٍ","translation":"দিনের","audioUrl":"wbw/043_065_011.mp3","charTypeName":"word"},{"id":57095,"position":11,"arabic":"أَلِيمٍ","translation":"নিদারুণ","audioUrl":"wbw/043_065_012.mp3","charTypeName":"word"},{"id":57096,"position":12,"arabic":"٦٥","translation":"(৬৫)","audioUrl":null,"charTypeName":"end"}]},{"number":66,"arabic":"هَلْ يَنظُرُونَ إِلَّا ٱلسَّاعَةَ أَن تَأْتِيَهُم بَغْتَةًۭ وَهُمْ لَا يَشْعُرُونَ","translation":"ARE THEY [who are lost in sin] but waiting for the Last Hour - [waiting] that it come upon them of a sudden, without their being aware [of its approach]?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4391.mp3","surahId":43,"words":[{"id":57491,"position":1,"arabic":"هَلْ","tran