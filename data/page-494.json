":8,"arabic":"٧٢","translation":"(৭২)","audioUrl":null,"charTypeName":"end"}]},{"number":73,"arabic":"لَكُمْ فِيهَا فَٰكِهَةٌۭ كَثِيرَةٌۭ مِّنْهَا تَأْكُلُونَ","translation":"fruits [of those deeds] shall you have in abundance, [and] thereof shall you partake!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4398.mp3","surahId":43,"words":[{"id":60905,"position":1,"arabic":"لَكُمْ","translation":"তোমাদের জন্যে","audioUrl":"wbw/043_073_001.mp3","charTypeName":"word"},{"id":60906,"position":2,"arabic":"فِيهَا","translation":"তার মধ্যে (থাকবে)","audioUrl":"wbw/043_073_002.mp3","charTypeName":"word"},{"id":60907,"position":3,"arabic":"فَـٰكِهَةٌۭ","translation":"ফলমূল","audioUrl":"wbw/043_073_003.mp3","charTypeName":"word"},{"id":60908,"position":4,"arabic":"كَثِيرَةٌۭ","translation":"প্রচুর","audioUrl":"wbw/043_073_004.mp3","charTypeName":"word"},{"id":60909,"position":5,"arabic":"مِّنْهَا","translation":"তা থেকে","audioUrl":"wbw/043_073_005.mp3","charTypeName":"word"},{"id":60910,"position":6,"arabic":"تَأْكُلُونَ","translation":"তোমরা খাবে","audioUrl":"wbw/043_073_006.mp3","charTypeName":"word"},{"id":60911,"position":7,"arabic":"٧٣","translation":"(৭৩)","audioUrl":null,"charTypeName":"end"}]}]}