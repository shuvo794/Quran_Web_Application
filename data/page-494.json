"word"},{"id":57964,"position":4,"arabic":"لِبَعْضٍ","translation":"অপরের জন্যে","audioUrl":"wbw/043_067_004.mp3","charTypeName":"word"},{"id":57965,"position":5,"arabic":"عَدُوٌّ","translation":"শত্রু (হবে)","audioUrl":"wbw/043_067_005.mp3","charTypeName":"word"},{"id":57966,"position":6,"arabic":"إِلَّا","translation":"ব্যতীত","audioUrl":"wbw/043_067_006.mp3","charTypeName":"word"},{"id":57967,"position":7,"arabic":"ٱلْمُتَّقِينَ","translation":"মুত্তাকীরা","audioUrl":"wbw/043_067_007.mp3","charTypeName":"word"},{"id":57968,"position":8,"arabic":"٦٧","translation":"(৬৭)","audioUrl":null,"charTypeName":"end"}]},{"number":68,"arabic":"يَٰعِبَادِ لَا خَوْفٌ عَلَيْكُمُ ٱلْيَوْمَ وَلَآ أَنتُمْ تَحْزَنُونَ","translation":"[And God will say:] “O you servants of Mine! No fear need you have today, and neither shall you grieve –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4393.mp3","surahId":43,"words":[{"id":58481,"position":1,"arabic":"يَـٰعِبَادِ","translation":"\"(বলা হবে) হে আমার দাসরা","audioUrl":"wbw/043_068_001.mp3","charTypeName":"word"},{"id":58482,"position":2,"arabic":"لَا","translation":"নেই","audioUrl":"wbw/043_068_002.mp3","charTypeName":"word"},{"id":58483,"position":3,"arabic":"خَوْفٌ","translation":"কোনো ভয়","audioUrl":"wbw/043_068_003.mp3","charTypeName":"word"},{"id":58484,"position":4,"arabic":"عَلَيْكُمُ","translation":"তোমাদের উপর","audioUrl":"wbw/043_068_004.mp3","charTypeName":"word"},{"id":58485,"position":5,"arabic":"ٱلْيَوْمَ","translation":"আজ","audioUrl":"wbw/043_068_005.mp3","charTypeName":"word"},{"id":58486,"position":6,"arabic":"وَلَآ","translation":"আর না","audioUrl":"wbw/043_068_006.mp3","charTypeName":"word"},{"id":58487,"position":7,"arabic":"أَنتُمْ","translation":"তোমরা","audioUrl":"wbw/043_068_007.mp3","charTypeName":"word"},{"id":58488,"position":8,"arabic":"تَحْزَنُونَ","translation":"চিন্তা করবে","audioUrl":"wbw/043_068_008.mp3","charTypeName":"word"},{"id":58489,"position":9,"arabic":"٦٨","translation":"(৬৮)","audioUrl":null,"charTypeName":"end"}]},{"number":69,"arabic":"ٱلَّذِينَ ءَامَنُوا۟ بِـَٔايَٰتِنَا وَكَانُوا۟ مُسْلِمِينَ","translation":"[O you] who have attained to faith in Our messages and have surrendered your own selves unto Us!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4394.mp3","surahId":43,"words":[{"id":58972,"position":1,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/043_069_001.mp3","charTypeName":"word"},{"id":58973,"position":2,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছিলো","audioUrl":"wbw/043_069_002.mp3","charTypeName":"word"},{"id":58974,"position":3,"arabic":"بِـَٔايَـٰتِنَا","translation":"আমাদের আয়াতগুলোর উপর","audioUrl":"wbw/043_069_003.mp3","charTypeName":"word"},{"id":58975,"position":4,"arabic":"وَكَانُوا۟","translation":"এবং তারা ছিলো","audioUrl":"wbw/043_069_004.mp3","charTypeName":"word"},{"id":58976,"position":5,"arabic":"مُسْلِمِينَ","translation":"আত্মসমর্পণকারী (অর্থাৎ মুসলমান)","audioUrl":"wbw/043_069_005.mp3","charTypeName":"word"},{"id":58977,"position":6,"arabic":"٦٩","translation":"(৬৯)","audioUrl":null,"charTypeName":"end"}]},{"number":70,"arabic":"ٱدْخُلُوا۟ ٱلْجَنَّةَ أَنتُمْ وَأَزْوَٰجُكُمْ تُحْبَرُونَ","translation":"Enter paradise, you and your spouses, with happiness blest!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4395.mp3","surahId":43,"words":[{"id":59359,"position":1,"arabic":"ٱدْخُلُوا۟","translation":"(তাদেরকে বলা হবে) তোমরা প্রবেশ করো","audioUrl":"wbw/043_070_001.mp3","charTypeName":"word"},{"id":59360,"position":2,"arabic":"ٱلْجَنَّةَ","translation":"জান্নাতে","audioUrl":"wbw/043_070_002.mp3","charTypeName":"word"},{"id":59361,"position":3,"arabic":"أَنتُمْ","translation":"তোমরা","audioUrl":"wbw/043_070_003.mp3","charTypeName":"word"},{"id":59362,"position":4,"arabic":"وَأَزْوَٰجُكُمْ","translation":"ও তোমাদের স্ত্রীরা","audioUrl":"wbw/043_070_004.mp3","charTypeName":"word"},{"id":59363,"position":5,"arabic":"تُحْبَرُونَ","translation":"তোমাদের সন্তু