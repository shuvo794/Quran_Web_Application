3","charTypeName":"word"},{"id":45268,"position":30,"arabic":"شَىْءٍۢ","translation":"কিছুর","audioUrl":"wbw/024_045_033.mp3","charTypeName":"word"},{"id":45269,"position":31,"arabic":"قَدِيرٌۭ","translation":"সর্বশক্তিমান","audioUrl":"wbw/024_045_034.mp3","charTypeName":"word"},{"id":45270,"position":32,"arabic":"٤٥","translation":"(৪৫)","audioUrl":null,"charTypeName":"end"}]},{"number":46,"arabic":"لَّقَدْ أَنزَلْنَآ ءَايَٰتٍۢ مُّبَيِّنَٰتٍۢ ۚ وَٱللَّهُ يَهْدِى مَن يَشَآءُ إِلَىٰ صِرَٰطٍۢ مُّسْتَقِيمٍۢ","translation":"INDEED, from on high have We bestowed messages clearly showing the truth; but God guides onto a straight way [only] him that wills [to be guided].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2837.mp3","surahId":24,"words":[{"id":46118,"position":1,"arabic":"لَّقَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/024_046_001.mp3","charTypeName":"word"},{"id":46119,"position":2,"arabic":"أَنزَلْنَآ","translation":"আমরা অবতীর্ণ করেছি","audioUrl":"wbw/024_046_002.mp3","charTypeName":"word"},{"id":46120,"position":3,"arabic":"ءَايَـٰتٍۢ","translation":"নিদর্শনসমূহ","audioUrl":"wbw/024_046_003.mp3","charTypeName":"word"},{"id":46121,"position":4,"arabic":"مُّبَيِّنَـٰتٍۢ ۚ","translation":"সুস্পষ্ট","audioUrl":"wbw/024_046_004.mp3","charTypeName":"word"},{"id":46123,"position":5,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/024_046_006.mp3","charTypeName":"word"},{"id":46124,"position":6,"arabic":"يَهْدِى","translation":"পরিচালিত করবেন","audioUrl":"wbw/024_046_007.mp3","charTypeName":"word"},{"id":46125,"position":7,"arabic":"مَن","translation":"যাকে","audioUrl":"wbw/024_046_008.mp3","charTypeName":"word"},{"id":46126,"position":8,"arabic":"يَشَآءُ","translation":"তিনি চান","audioUrl":"wbw/024_046_009.mp3","charTypeName":"word"},{"id":46127,"position":9,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/024_046_010.mp3","charTypeName":"word"},{"id":46128,"position":10,"arabic":"صِرَٰطٍۢ","translation":"পথের","audioUrl":"wbw/024_046_011.mp3","charTypeName":"word"},{"id":46129,"position":11,"arabic":"مُّسْتَقِيمٍۢ","translation":"সরল সোজা","audioUrl":"wbw/024_046_012.mp3","charTypeName":"word"},{"id":46130,"position":12,"arabic":"٤٦","translation":"(৪৬)","audioUrl":null,"charTypeName":"end"}]},{"number":47,"arabic":"وَيَقُولُونَ ءَامَنَّا بِٱللَّهِ وَبِٱلرَّسُولِ وَأَطَعْنَا ثُمَّ يَتَوَلَّىٰ فَرِيقٌۭ مِّنْهُم مِّنۢ بَعْدِ ذَٰلِكَ ۚ وَمَآ أُو۟لَٰٓئِكَ بِٱلْمُؤْمِنِينَ","translation":"For, [many are] they [who] say, “We believe in God and in the Apostle, and we pay heed!” - but then, some of them turn away after this [assertion]: and these are by no means [true] believers.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2838.mp3","surahId":24,"words":[{"id":46720,"position":1,"arabic":"وَيَقُولُونَ","translation":"এবং তারা বলে","audioUrl":"wbw/024_047_001.mp3","charTypeName":"word"},{"id":46721,"position":2,"arabic":"ءَامَنَّا","translation":"\"আমরা ঈমান এনেছি","audioUrl":"wbw/024_047_002.mp3","charTypeName":"word"},{"id":46722,"position":3,"arabic":"بِٱللَّهِ","translation":"উপর আল্লাহর","audioUrl":"wbw/024_047_003.mp3","charTypeName":"word"},{"id":46723,"position":4,"arabic":"وَبِٱلرَّسُولِ","translation":"ও উপর রাসূলের","audioUrl":"wbw/024_047_004.mp3","charTypeName":"word"},{"id":46724,"position":5,"arabic":"وَأَطَعْنَا","translation":"এবং আমরা আনুগত্য করেছি\"","audioUrl":"wbw/024_047_005.mp3","charTypeName":"word"},{"id":46725,"position":6,"arabic":"ثُمَّ","translation":"এরপর (কিন্তু)","audioUrl":"wbw/024_047_006.mp3","charTypeName":"word"},{"id":46726,"position":7,"arabic":"يَتَوَلَّىٰ","translation":"মুখ ফিরিয়ে নেয়","audioUrl":"wbw/024_047_007.mp3","charTypeName":"word"},{"id":46727,"position":8,"arabic":"فَرِيقٌۭ","translation":"একদল","audioUrl":"wbw/024_047_008.mp3","charTypeName":"word"},{"id":46728,"position":9,"arabic":"مِّنْهُم","translation":"তাদের মধ্য হ'তে","audioUrl":"wbw/024_047_009.mp3","charTypeName":"word"},{"id":46729,"position":10,"arabic":"مِّنۢ","translation":"থেকে","audioUrl":"wbw/024_047_010.mp3","charTypeName":"word"},{"id":46730,"position":11,"arabic":"بَعْدِ","translation":"পর","audioUrl":"wbw/024_047_011.mp3","charTypeName":"word"},{"id":46731,"position":12,"arabic":"ذَٰلِكَ ۚ","translation":"এর","audioUrl":"wbw/024_047_012.mp3","charTypeName":"word"},{"id":46733,"position":13,"arabic":"وَمَآ","translation":"আর না","audioUrl":"wbw/024_047_014.mp3","charTypeName":"word"},{"id":46734,"position":14,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐ সব লোক","audioUrl":"wbw/024_047_015.mp3","charTypeName":"word"},{"id":46735,"position":15,"arabic":"بِٱلْمُؤْمِنِينَ","translation":"মু'মিন","audioUrl":"wbw/024_047_016.mp3","charTypeName":"word"},{"id":46736,"position":16,"arabic":"٤٧","translation":"(৪৭)","audioUrl":null,"charTypeName":"end"}]},{"number":48,"arabic":"وَإِذَا دُعُوٓا۟ إِلَى ٱللَّهِ وَرَسُولِهِۦ لِيَحْكُمَ بَيْنَهُمْ إِذَا فَرِيقٌۭ مِّنْهُم مُّعْرِضُونَ","translation":"And [so it is that] whenever they are summoned unto God and His Apostle in order that [the divine writ] might judge between them, lo! some of them turn away;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2839.mp3","surahId":24,"words":[{"id":47454,"position":1,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/024_048_001.mp3","charTypeName":"word"},{"id":47455,"position":2,"arabic":"دُعُوٓا۟","translation":"ডাকা হয় তাদেরকে","audioUrl":"wbw/024_048_002.mp3","charTypeName":"word"},{"id":47456,"position":3,"arabic":"إِلَى","translation":"দিকে","audioUrl":"wbw/024_048_003.mp3","charTypeName":"word"},{"id":47457,"position":4,"arabic":"ٱللَّهِ","translation":"আল্লাহ তা'লার","audioUrl":"wbw/024_048_004.mp3","charTypeName":"word"},{"id":47458,"position":5,"arabic":"وَرَسُولِهِۦ","translation":"ও তাঁর রাসূলের","audioUrl":"wbw/024_048_005.mp3","charTypeName":"word"},{"id":47459,"position":6,"arabic":"لِيَحْكُمَ","translation":"জন্যে মীমাংসার","audioUrl":"wbw/024_048_006.mp3","charTypeName":"word"},{"id":47460,"position":7,"arabic":"بَيْنَهُمْ","translation":"তাদের মাঝে","audioUrl":"wbw/024_048_007.mp3","charTypeName":"word"},{"id":47461,"position":8,"arabic":"إِذَا","translation":"তখন","audioUrl":"wbw/024_048_008.mp3","charTypeName":"word"},{"id":47462,"position":9,"arabic":"فَرِيقٌۭ","translation":"একদল","audioUrl":"wbw/024_048_009.mp3","charTypeName":"word"},{"id":47463,"position":10,"arabic":"مِّنْهُم","translation":"তাদের মধ্য হ'তে","audioUrl":"wbw/024_048_010.mp3","charTypeName":"word"},{"id":47464,"position":11,"arabic":"مُّعْرِضُونَ","translation":"মুখ ফিরিয়ে নেয়","audioUrl":"wbw/024_048_011.mp3","charTypeName":"word"},{"id":47465,"position":12,"arabic":"٤٨","translation":"(৪৮)","audioUrl":null,"charTypeName":"end"}]},{"number":49,"arabic":"وَإِن يَكُن لَّهُمُ ٱلْحَقُّ يَأْتُوٓا۟ إِلَيْهِ مُذْعِنِينَ","translation":"but if the truth happens to be to their liking, they are quite willing to accept it!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2840.mp3","surahId":24,"words":[{"id":47695,"position":1,"arabic":"وَإِن","translation":"আর যদি","audioUrl":"wbw/024_049_001.mp3","charTypeName":"word"},{"id":47696,"position":2,"arabic":"يَكُن","translation":"হয়","audioUrl":"wbw/024_049_002.mp3","charTypeName":"word"},{"id":47697,"position":3,"arabic":"لَّهُمُ","translation":"জন্যে তাদের","audioUrl":"wbw/024_049_003.mp3","charTypeName":"word"},{"id":47698,"position":4,"arabic":"ٱلْحَقُّ","translation":"সত্য","audioUrl":"wbw/024_049_004.mp3","charTypeName":"word"},{"id":47699,"position":5,"arabic":"يَأْتُوٓا۟","translation":"তারা আসে","audioUrl":"wbw/024_049_005.mp3","charTypeName":"word"},{"id":47700,"position":6,"arabic":"إِلَيْهِ","translation":"তার দিকে","audioUrl":"wbw/024_049_006.mp3","charTypeName":"word"},{"id":47701,"position":7,"arabic":"مُذْعِنِينَ","translation":"বিনীত হয়ে","audioUrl":"wbw/024_049_007.mp3","charTypeName":"word"},{"id":47702,"position":8,"arabic":"٤٩","translation":"(৪৯)","audioUrl":null,"charTypeName":"end"}]},{"number":50,"arabic":"أَفِى قُلُوبِهِم مَّرَضٌ أَمِ ٱرْتَابُوٓا۟ أَمْ يَخَافُونَ أَن يَحِيفَ ٱللَّهُ عَلَيْهِمْ وَرَسُولُهُۥ ۚ بَلْ أُو۟لَٰٓئِكَ هُمُ ٱلظَّٰلِمُونَ","translation":"Is there disease in their hearts? Or have they begun to doubt [that this is a divine writ]? Or do they fear that God and His Apostle might deal unjustly with them? Nay, it is [but] they, they who are doing wrong [to themselves]!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2841.mp3","surahId":24,"words":[{"id":48702,"position":1,"arabic":"أَفِى","translation":"কি আছে","audioUrl":"wbw/024_050_001.mp3","charTypeName":"word"},{"id":48703,"position":2,"arabic":"قُلُوبِهِم","translation":"তাদের অন্তরসমূহে","audioUrl":"wbw/024_050_002.mp3","charTypeName":"word"},{"id":48704,"position":3,"arabic":"مَّرَضٌ","translation":"রোগ","audioUrl":"wbw/024_050_003.mp3","charTypeName":"word"},{"id":48705,"position":4,"arabic":"أَمِ","translation":"অথবা","audioUrl":"wbw/024_050_004.mp3","charTypeName":"word"},{"id":48706,"position":5,"arabic":"ٱرْتَابُوٓا۟","translation":"তারা সন্দেহ করে","audioUrl":"wbw/024_050_005.mp3","charTypeName":"word"},{"id":48707,"position":6,"arabic":"أَمْ","translation":"অথবা","audioUrl":"wbw/024_050_006.mp3","charTypeName":"word"},{"id":48708,"position":7,"arabic":"يَخَافُونَ","translation":"তারা ভয় করে","audioUrl":"wbw/024_050_007.mp3","charTypeName":"word"},{"id":48709,"position":8,"arabic":"أَن","translation":"যে","audioUrl":"wbw/024_050_008.mp3","charTypeName":"word"},{"id":48710,"position":9,"arabic":"يَحِيفَ","translation":"অন্যায় করবেন","audioUrl":"wbw/024_050_009.mp3","charTypeName":"word"},{"id":48711,"position":10,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌","audioUrl":"wbw/024_050_010.mp3","charTypeName":"word"},{"id":48712,"position":11,"arabic":"عَلَيْهِمْ","translation":"তাদের উপর","audioUrl":"wbw/024_050_011.mp3","charTypeName":"word"},{"id":48713,"position":12,"arabic":"وَرَسُولُهُۥ ۚ","translation":"ও তাঁর রাসূল","audioUrl":"wbw/024_050_012.mp3","charTypeName":"word"},{"id":48715,"position":13,"arabic":"بَلْ","translation":"বরং","audioUrl":"wbw/024_050_014.mp3","charTypeName":"word"},{"id":48716,"position":14,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐ সব লোক","audioUrl":"wbw/024_050_015.mp3","charTypeName":"word"},{"id":48717,"position":15,"arabic":"هُمُ","translation":"তারাই","audioUrl":"wbw/024_050_016.mp3","charTypeName":"word"},{"id":48718,"position":16,"arabic":"ٱلظَّـٰلِمُونَ","translation":"সীমালঙ্ঘনকারী","audioUrl":"wbw/024_050_017.mp3","charTypeName":"word"},{"id":48719,"position":17,"arabic":"٥٠","translation":"(৫০)","audioUrl":null,"charTypeName":"end"}]},{"number":51,"arabic":"إِنَّمَا كَانَ قَوْلَ ٱلْمُؤْمِنِينَ إِذَا دُعُوٓا۟ إِلَى ٱللَّهِ وَرَسُولِهِۦ لِيَحْكُمَ بَيْنَهُمْ أَن يَقُولُوا۟ سَمِعْنَا وَأَطَعْنَا ۚ وَأُو۟لَٰٓئِكَ هُمُ ٱلْمُفْلِحُونَ","translation":"The only response of believers, whenever they are summoned unto God and His Apostle in order that [the divine writ] might judge between them, can be no other than, “We have heard, and we pay heed!”- and it is they, they who shall attain to a happy state:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2842.mp3","surahId":24,"words":[{"id":49533,"position":1,"arabic":"إِنَّمَا","translation":"মূলতঃ","audioUrl":"wbw/024_051_001.mp3","charTypeName":"word"},{"id":49534,"position":2,"arabic":"كَانَ","translation":"ছিলো (শোভা পেত)","audioUrl":"wbw/024_051_002.mp3","charTypeName":"word"},{"id":49535,"position":3,"arabic":"قَوْلَ","translation":"উক্তি","audioUrl":"wbw/024_051_003.mp3","charTypeName":"word"},{"id":49536,"position":4,"arabic":"ٱلْمُؤْمِنِينَ","translation":"মু'মিনদের","audioUrl":"wbw/024_051_004.mp3","charTypeName":"word"},{"id":49537,"position":5,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/024_051_005.mp3","charTypeName":"word"},{"id":49538,"position":6,"arabic":"دُعُوٓا۟","translation":"ডাকা হয় তাদেরকে","audioUrl":"wbw/024_051_006.mp3","charTypeName":"word"},{"id":49539,"position":7,"arabic":"إِلَى","translation":"দিকে","audioUrl":"wbw/024_051_007.mp3","charTypeName":"word"},{"id":49540,"position":8,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌র","audioUrl":"wbw/024_051_008.mp3","charTypeName":"word"},{"id":49541,"position":9,"arabic":"وَرَسُولِهِۦ","translation":"ও তাঁর রাসূলের","audioUrl":"wbw/024_051_009.mp3","charTypeName":"word"},{"id":49542,"position":10,"arabic":"لِيَحْكُمَ","translation":"জন্যে মীমাংসার","audioUrl":"wbw/024_051_010.mp3","charTypeName":"word"},{"id":49543,"position":11,"arabic":"بَيْنَهُمْ","translation":"তাদের মাঝে","audioUrl":"wbw/024_051_011.mp3","charTypeName":"word"},{"id":49544,"position":12,"arabic":"أَن","translation":"যে","audioUrl":"wbw/024_051_012.mp3","charTypeName":"word"},{"id":49545,"position":13,"arabic":"يَقُولُوا۟","translation":"তারা বলবে","audioUrl":"wbw/024_051_013.mp3","charTypeName":"word"},{"id":49546,"position":14,"arabic":"سَمِعْنَا","translation":"\"আমরা শুনলাম","audioUrl":"wbw/024_051_014.mp3","charTypeName":"word"},{"id":49547,"position":15,"arabic":"وَأَطَعْنَا ۚ","translation":"ও আমরা মেনে নিলাম\"","audioUrl":"wbw/024_051_015.mp3","charTypeName":"word"},{"id":49549,"position":16,"arabic":"وَأُو۟لَـٰٓئِكَ","translation":"আর ঐসব লোক","audioUrl":"wbw/024_051_017.mp3","charTypeName":"word"},{"id":49550,"position":17,"arabic":"هُمُ","translation":"তারাই","audioUrl":"wbw/024_051_018.mp3","charTypeName":"word"},{"id":49551,"position":18,"arabic":"ٱلْمُفْلِحُونَ","translation":"সফলকাম","audioUrl":"wbw/024_051_019.mp3","charTypeName":"word"},{"id":49552,"position":19,"arabic":"٥١","translation":"(৫১)","audioUrl":null,"charTypeName":"end"}]},{"number":52,"arabic":"وَمَن يُطِعِ ٱللَّهَ وَرَسُولَهُۥ وَيَخْشَ ٱللَّهَ وَيَتَّقْهِ فَأُو۟لَٰٓئِكَ هُمُ ٱلْفَآئِزُونَ","translation":"for, they who pay heed unto God and His Apostle, and stand in awe of God and are conscious of Him, it is they, they who shall triumph [in the end]!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2843.mp3","surahId":24,"words":[{"id":49978,"position":1,"arabic":"وَمَن","translation":"আর যে","audioUrl":"wbw/024_052_001.mp3","charTypeName":"word"},{"id":49979,"position":2,"arabic":"يُطِعِ","translation":"আনুগত্য করে","audioUrl":"wbw/024_052_002.mp3","charTypeName":"word"},{"id":49980,"position":3,"arabic":"ٱللَّهَ","translation":"আল্লাহ্‌র","audioUrl":"wbw/024_052_003.mp3","charTypeName":"word"},{"id":49981,"position":4,"arabic":"وَرَسُولَهُۥ","translation":"ও তাঁর রাসূলের","audioUrl":"wbw/024_052_004.mp3","charTypeName":"word"},{"id":49982,"position":5,"arabic":"وَيَخْشَ","translation":"এবং ভয় করে","audioUrl":"wbw/024_052_005.mp3","charTypeName":"word"},{"id":49983,"position":6,"arabic":"ٱللَّهَ","translation":"আল্লাহ্‌কে","audioUrl":"wbw/024_052_006.mp3","charTypeName":"word"},{"id":49984,"position":7,"arabic":"وَيَتَّقْهِ","translation":"ও (তাঁর শাস্তি হ'তে) সাবধান থাকে","audioUrl":"wbw/024_052_007.mp3","charTypeName":"word"},{"id":49985,"position":8,"arabic":"فَأُو۟لَـٰٓئِكَ","translation":"অতঃপর ঐসব লোক","audioUrl":"wbw/024_052_008.mp3","charTypeName":"word"},{"id":49986,"position":9,"arabic":"هُمُ","translation":"তারাই","audioUrl":"wbw/024_052_009.mp3","charTypeName":"word"},{"id":49987,"position":10,"arabic":"ٱلْفَآئِزُونَ","translation":"সফলকাম","audioUrl":"wbw/024_052_010.mp3","charTypeName":"word"},{"id":49988,"position":11,"arabic":"٥٢","translation":"(৫২)","audioUrl":null,"charTypeName":"end"}]},{"number":53,"arabic":"۞ وَأَقْسَمُوا۟ بِٱللَّهِ جَهْدَ أَيْمَٰنِهِمْ لَئِنْ أَمَرْتَهُمْ لَيَخْرُجُنَّ ۖ قُل لَّا تُقْسِمُوا۟ ۖ طَاعَةٌۭ مَّعْرُوفَةٌ ۚ إِنَّ ٱللَّهَ خَبِيرٌۢ بِمَا تَعْمَلُونَ","translation":"Now [as for those half-hearted ones,] they do swear by God with their most solemn oaths that if thou [O Apostle] shouldst ever bid them to do so, they would most certainly go forth [and sacrifice themselves]. Say: “Swear not! Reasonable compliance [with God’s message is all that is required of you]. Verily, God is aware of all that you do!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2844.mp3","surahId":24,"words":[{"id":50616,"position":1,"arabic":"۞ وَأَقْسَمُوا۟","translation":"এবং (মুনাফিকরা) শপথ করে","audioUrl":"wbw/024_053_002.mp3","charTypeName":"word"},{"id":50617,"position":2,"arabic":"بِٱللَّهِ","translation":"নামে আল্লাহ্‌র","audioUrl":"wbw/024_053_003.mp3","charTypeName":"word"},{"id":50618,"position":3,"arabic":"جَهْدَ","translation":"দৃঢ় ভাবে (করে)","audioUrl":"wbw/024_053_004.mp3","charTypeName":"word"},{"id":50619,"position":4,"arabic":"أَيْمَـٰنِهِمْ","translation":"তাদের শপথগুলোকে","audioUrl":"wbw/024_053_005.mp3","charTypeName":"word"},{"id":50620,"position":5,"arabic":"لَئِنْ","translation":"অবশ্যই যদি","audioUrl":"wbw/024_053_006.mp3","charTypeName":"word"},{"id":50621,"position":6,"arabic":"أَمَرْتَهُمْ","translation":"তাদেরকে তুমি নির্দেশ দাও","audioUrl":"wbw/024_053_007.mp3","charTypeName":"word"},{"id":50622,"position":7,"arabic":"لَيَخْرُجُنَّ ۖ","translation":"অবশ্যই তারা (জিহাদের জন্যে) বের হবে","audioUrl":"wbw/024_053_008.mp3","charTypeName":"word"},{"id":50624,"position":8,"arabic":"قُل","translation":"বলো","audioUrl":"wbw/024_053_010.mp3","charTypeName":"word"},{"id":50625,"position":9,"arabic":"لَّا","translation":"\"না","audioUrl":"wbw/024_053_011.mp3","charTypeName":"word"},{"id":50626,"position":10,"arabic":"تُقْسِمُوا۟ ۖ","translation":"তোমরা শপথ করো","audioUrl":"wbw/024_053_012.mp3","charTypeName":"word"},{"id":50628,"position":11,"arabic":"طَاعَةٌۭ","translation":"আনুগত্য","audioUrl":"wbw/024_053_014.mp3","charTypeName":"word"},{"id":50629,"position":12,"arabic":"مَّعْرُوفَةٌ ۚ","translation":"যথার্থই (কাম্য)","audioUrl":"wbw/024_053_015.mp3","charTypeName":"word"},{"id":50631,"position":13,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/024_053_017.mp3","charTypeName":"word"},{"id":50632,"position":14,"arabic":"ٱللَّهَ","translation":"আল্লাহ্‌","audioUrl":"wbw/024_053_018.mp3","charTypeName":"word"},{"id":50633,"position":15,"arabic":"خَبِيرٌۢ","translation":"খুব অবহিত","audioUrl":"wbw/024_053_019.mp3","charTypeName":"word"},{"id":50634,"position":16,"arabic":"بِمَا","translation":"ঐ সম্পর্কে যা","audioUrl":"wbw/024_053_020.mp3","charTypeName":"word"},{"id":50635,"position":17,"arabic":"تَعْمَلُونَ","translation":"কাজ করছো তোমরা\"","audioUrl":"wbw/024_053_021.mp3","charTypeName":"word"},{"id":50636,"position":18,"arabic":"٥٣","translation":"(৫৩)","audioUrl":null,"charTypeName":"end"}]}]}