{"id":356,"ayahs":[{"number":44,"arabic":"يُقَلِّبُ ٱللَّهُ ٱلَّيْلَ وَٱلنَّهَارَ ۚ إِنَّ فِى ذَٰلِكَ لَعِبْرَةًۭ لِّأُو۟لِى ٱلْأَبْصَٰرِ","translation":"It is God who causes night and day to alter­nate: in this [too], behold, there is surely a lesson for all who have eyes to see!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2835.mp3","surahId":24,"words":[{"id":44766,"position":1,"arabic":"يُقَلِّبُ","translation":"আবর্তন ঘটান","audioUrl":"wbw/024_044_001.mp3","charTypeName":"word"},{"id":44767,"position":2,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/024_044_002.mp3","charTypeName":"word"},{"id":44768,"position":3,"arabic":"ٱلَّيْلَ","translation":"রাতকে","audioUrl":"wbw/024_044_003.mp3","charTypeName":"word"},{"id":44769,"position":4,"arabic":"وَٱلنَّهَارَ ۚ","translation":"ও দিনকে","audioUrl":"wbw/024_044_004.mp3","charTypeName":"word"},{"id":44771,"position":5,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/024_044_006.mp3","charTypeName":"word"},{"id":44772,"position":6,"arabic":"فِى","translation":"মধ্যে (রয়েছে)","audioUrl":"wbw/024_044_007.mp3","charTypeName":"word"},{"id":44773,"position":7,"arabic":"ذَٰلِكَ","translation":"এর","audioUrl":"wbw/024_044_008.mp3","charTypeName":"word"},{"id":44774,"position":8,"arabic":"لَعِبْرَةًۭ","translation":"অবশ্যই শিক্ষা","audioUrl":"wbw/024_044_009.mp3","charTypeName":"word"},{"id":44775,"position":9,"arabic":"لِّأُو۟لِى","translation":"জন্যে সম্পন্নদের","audioUrl":"wbw/024_044_010.mp3","charTypeName":"word"},{"id":44776,"position":10,"arabic":"ٱلْأَبْصَـٰرِ","translation":"অন্তর্দৃষ্টি","audioUrl":"wbw/024_044_011.mp3","charTypeName":"word"},{"id":44777,"position":11,"arabic":"٤٤","translation":"(৪৪)","audioUrl":null,"charTypeName":"end"}]},{"number":45,"arabic":"وَٱللَّهُ خَلَقَ كُلَّ دَآبَّةٍۢ مِّن مَّآءٍۢ ۖ فَمِنْهُم مَّن يَمْشِى عَلَىٰ بَطْنِهِۦ وَمِنْهُم مَّن يَمْشِى عَلَىٰ رِجْلَيْنِ وَمِنْهُم مَّن يَمْشِى عَلَىٰٓ أَرْبَعٍۢ ۚ يَخْلُقُ ٱللَّهُ مَا يَشَآءُ ۚ إِنَّ ٱللَّهَ عَلَىٰ كُلِّ شَىْءٍۢ قَدِيرٌۭ","translation":"And it is God who has created all animals out of water; and [He has willed that] among them are such as crawl on their bellies, and such as walk on two legs, and such as walk on four. God creates what He will: for, verily, God has the power to will anything.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2836.mp3","surahId":24,"words":[{"id":45236,"position":1,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ তা'লা","audioUrl":"wbw/024_045_001.mp3","charTypeName":"word"},{"id":45237,"position":2,"arabic":"خَلَقَ","translation":"সৃষ্টি করেছেন","audioUrl":"wbw/024_045_002.mp3","charTypeName":"word"},{"id":45238,"position":3,"arabic":"كُلَّ","translation":"সব","audioUrl":"wbw/024_045_003.mp3","charTypeName":"word"},{"id":45239,"position":4,"arabic":"دَآبَّةٍۢ","translation":"জীবকে","audioUrl":"wbw/024_045_004.mp3","charTypeName":"word"},{"id":45240,"position":5,"arabic":"مِّن","translation":"হ'তে","audioUrl":"wbw/024_045_005.mp3","charTypeName":"word"},{"id":45241,"position":6,"arabic":"مَّآءٍۢ ۖ","translation":"পানি","audioUrl":"wbw/024_045_006.mp3","charTypeName":"word"},{"id":45243,"position":7,"arabic":"فَمِنْهُم","translation":"অতঃপর তাদের মধ্যে হ'তে","audioUrl":"wbw/024_045_008.mp3","charTypeName":"word"},{"id":45244,"position":8,"arabic":"مَّن","translation":"কেউ","audioUrl":"wbw/024_045_009.mp3","charTypeName":"word"},{"id":45245,"position":9,"arabic":"يَمْشِى","translation":"চলে","audioUrl":"wbw/024_045_010.mp3","charTypeName":"word"},{"id":45246,"position":10,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/024_045_011.mp3","charTypeName":"word"},{"id":45247,"position":11,"arabic":"بَطْنِهِۦ","translation":"তার পেটের","audioUrl":"wbw/024_045_012.mp3","charTypeName":"word"},{"id":45248,"position":12,"arabic":"وَمِنْهُم","translation":"আবার তাদের মধ্যে হ'তে","audioUrl":"wbw/024_045_013.mp3","charTypeName":"word"},{"id":45249,"position":13,"arabic":"مَّن","translation":"কেউ","audioUrl":"wbw/0