.islamic.network/quran/audio/128/ar.alafasy/5224.mp3","surahId":65,"words":[{"id":7812,"position":1,"arabic":"لِيُنفِقْ","translation":"খরচ যেন করে","audioUrl":"wbw/065_007_001.mp3","charTypeName":"word"},{"id":7813,"position":2,"arabic":"ذُو","translation":"আছে","audioUrl":"wbw/065_007_002.mp3","charTypeName":"word"},{"id":7814,"position":3,"arabic":"سَعَةٍۢ","translation":"সচ্ছল ব্যক্তি","audioUrl":"wbw/065_007_003.mp3","charTypeName":"word"},{"id":7815,"position":4,"arabic":"مِّن","translation":"অনুযায়ী","audioUrl":"wbw/065_007_004.mp3","charTypeName":"word"},{"id":7816,"position":5,"arabic":"سَعَتِهِۦ ۖ","translation":"তার সচ্ছলতা","audioUrl":"wbw/065_007_005.mp3","charTypeName":"word"},{"id":7818,"position":6,"arabic":"وَمَن","translation":"এবং যার","audioUrl":"wbw/065_007_007.mp3","charTypeName":"word"},{"id":7819,"position":7,"arabic":"قُدِرَ","translation":"সীমিত করা হয়েছে","audioUrl":"wbw/065_007_008.mp3","charTypeName":"word"},{"id":7820,"position":8,"arabic":"عَلَيْهِ","translation":"তার উপর","audioUrl":"wbw/065_007_009.mp3","charTypeName":"word"},{"id":7821,"position":9,"arabic":"رِزْقُهُۥ","translation":"তার রিযক","audioUrl":"wbw/065_007_010.mp3","charTypeName":"word"},{"id":7822,"position":10,"arabic":"فَلْيُنفِقْ","translation":"সে খরচ অতঃপর করবে","audioUrl":"wbw/065_007_011.mp3","charTypeName":"word"},{"id":7823,"position":11,"arabic":"مِمَّآ","translation":"যা (তা) থেকে","audioUrl":"wbw/065_007_012.mp3","charTypeName":"word"},{"id":7824,"position":12,"arabic":"ءَاتَىٰهُ","translation":"তাকে দিয়েছেন","audioUrl":"wbw/065_007_013.mp3","charTypeName":"word"},{"id":7825,"position":13,"arabic":"ٱللَّهُ ۚ","translation":"আল্লাহ","audioUrl":"wbw/065_007_014.mp3","charTypeName":"word"},{"id":7827,"position":14,"arabic":"لَا","translation":"না","audioUrl":"wbw/065_007_016.mp3","charTypeName":"word"},{"id":7828,"position":15,"arabic":"يُكَلِّفُ","translation":"কষ্ট দেন","audioUrl":"wbw/065_007_017.mp3","charTypeName":"word"},{"id":7829,"position":16,"arabic":