{"id":559,"ayahs":[{"number":6,"arabic":"أَسْكِنُوهُنَّ مِنْ حَيْثُ سَكَنتُم مِّن وُجْدِكُمْ وَلَا تُضَآرُّوهُنَّ لِتُضَيِّقُوا۟ عَلَيْهِنَّ ۚ وَإِن كُنَّ أُو۟لَٰتِ حَمْلٍۢ فَأَنفِقُوا۟ عَلَيْهِنَّ حَتَّىٰ يَضَعْنَ حَمْلَهُنَّ ۚ فَإِنْ أَرْضَعْنَ لَكُمْ فَـَٔاتُوهُنَّ أُجُورَهُنَّ ۖ وَأْتَمِرُوا۟ بَيْنَكُم بِمَعْرُوفٍۢ ۖ وَإِن تَعَاسَرْتُمْ فَسَتُرْضِعُ لَهُۥٓ أُخْرَىٰ","translation":"[Hence,] let the women [who are undergoing a waiting-period] live in the same manner as you live yourselves, In accordance with your means; and do not harass them with a view to making their lives a misery. And if they happen to be with child, spend freely on them until they deliver their burden; and if they nurse your offspring [after the divorce has become final], give them their [due] recompense; and take counsel with one another in a fair manner [about the child's future]. And if both of you find it difficult [that the mother should nurse the child], let another woman nurse it on behalf of him [who has begotten it].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5223.mp3","surahId":65,"words":[{"id":6396,"position":1,"arabic":"أَسْكِنُوهُنَّ","translation":"তাদের বাস করতে দাও","audioUrl":"wbw/065_006_001.mp3","charTypeName":"word"},{"id":6397,"position":2,"arabic":"مِنْ","translation":"মধ্য হতে","audioUrl":"wbw/065_006_002.mp3","charTypeName":"word"},{"id":6398,"position":3,"arabic":"حَيْثُ","translation":"যেখানে","audioUrl":"wbw/065_006_003.mp3","charTypeName":"word"},{"id":6399,"position":4,"arabic":"سَكَنتُم","translation":"তোমরা বাস কর","audioUrl":"wbw/065_006_004.mp3","charTypeName":"word"},{"id":6400,"position":5,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/065_006_005.mp3","charTypeName":"word"},{"id":6401,"position":6,"arabic":"وُجْدِكُمْ","translation":"তোমাদের সামর্থ","audioUrl":"wbw/065_006_006.mp3","charTypeName":"word"},{"id":6402,"position":7,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/065_006_007.mp3","charTypeName":"word"},{"id":6403,"position":8,"arabic":"تُضَآرُّوهُنَّ","translation":"তাদের তোমরা কষ্ট দিও","audioUrl":"wbw/065_006_008.mp3","charTypeName":"word"},{"id":6404,"position":9,"arabic":"لِتُضَيِّقُوا۟","translation":"সঙ্কটে ফেলবার জন্যে","audioUrl":"wbw/065_006_009.mp3","charTypeName":"word"},{"id":6405,"position":10,"arabic":"عَلَيْهِنَّ ۚ","translation":"তাদেরকে","audioUrl":"wbw/065_006_010.mp3","charTypeName":"word"},{"id":6407,"position":11,"arabic":"وَإِن","translation":"এবং যদি","audioUrl":"wbw/065_006_012.mp3","charTypeName":"word"},{"id":6408,"position":12,"arabic":"كُنَّ","translation":"তারা হয়","audioUrl":"wbw/065_006_013.mp3","charTypeName":"word"},{"id":6409,"position":13,"arabic":"أُو۟لَـٰتِ","translation":"যারা","audioUrl":"wbw/065_006_014.mp3","charTypeName":"word"},{"id":6410,"position":14,"arabic":"حَمْلٍۢ","translation":"গর্ভবতী","audioUrl":"wbw/065_006_015.mp3","charTypeName":"word"},{"id":6411,"position":15,"arabic":"فَأَنفِقُوا۟","translation":"তোমরা খরচ তবে কর","audioUrl":"wbw/065_006_016.mp3","charTypeName":"word"},{"id":6412,"position":16,"arabic":"عَلَيْهِنَّ","translation":"তাদের উপর","audioUrl":"wbw/065_006_017.mp3","charTypeName":"word"},{"id":6413,"position":17,"arabic":"حَتَّىٰ","translation":"যতক্ষণ না","audioUrl":"wbw/065_006_018.mp3","charTypeName":"word"},{"id":6414,"position":18,"arabic":"يَضَعْنَ","translation":"প্রসব করে","audioUrl":"wbw/065_006_019.mp3","charTypeName":"word"},{"id":6415,"position":19,"arabic":"حَمْلَهُنَّ ۚ","translation":"তাদের গর্ভ","audioUrl":"wbw/065_006_020.mp3","charTypeName":"word"},{"id":6417,"position":20,"arabic":"فَإِنْ","translation":"যদি অতঃপর","audioUrl":"wbw/065_006_022.mp3","charTypeName":"word"},{"id":6418,"position":21,"arabic":"أَرْضَعْنَ","translation":"তারা দুধপান করায়","audioUrl":"wbw/065_006_023.mp3","charTypeName":"word"},{"id":6419,"position":22,"arabic":"لَكُمْ","translation":"তোমাদের (বাচ্চাদের)কে","audioUrl":"wbw/065_006_024.mp3","charTypeName":"word"},{"id":6420,"position":23,"arabic":"فَـَٔاتُو