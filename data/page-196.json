{"id":196,"ayahs":[{"number":55,"arabic":"فَلَا تُعْجِبْكَ أَمْوَٰلُهُمْ وَلَآ أَوْلَٰدُهُمْ ۚ إِنَّمَا يُرِيدُ ٱللَّهُ لِيُعَذِّبَهُم بِهَا فِى ٱلْحَيَوٰةِ ٱلدُّنْيَا وَتَزْهَقَ أَنفُسُهُمْ وَهُمْ كَٰفِرُونَ","translation":"Let not, then, their worldly goods or [the happiness which they may derive from] their children excite thy admiration: God but wants to chastise them by these means in this worldly life, and [to cause] their souls to depart while they are [still] denying the truth.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1290.mp3","surahId":9,"words":[{"id":51589,"position":1,"arabic":"فَلَا","translation":"অতএব না","audioUrl":"wbw/009_055_001.mp3","charTypeName":"word"},{"id":51590,"position":2,"arabic":"تُعْجِبْكَ","translation":"তোমাকে বিস্মিত করে (যেন)","audioUrl":"wbw/009_055_002.mp3","charTypeName":"word"},{"id":51591,"position":3,"arabic":"أَمْوَٰلُهُمْ","translation":"ধনসম্পদ তাদের","audioUrl":"wbw/009_055_003.mp3","charTypeName":"word"},{"id":51592,"position":4,"arabic":"وَلَآ","translation":"ও না","audioUrl":"wbw/009_055_004.mp3","charTypeName":"word"},{"id":51593,"position":5,"arabic":"أَوْلَـٰدُهُمْ ۚ","translation":"সন্তান-সন্ততি তাদের","audioUrl":"wbw/009_055_005.mp3","charTypeName":"word"},{"id":51595,"position":6,"arabic":"إِنَّمَا","translation":"প্রকৃতপক্ষে","audioUrl":"wbw/009_055_007.mp3","charTypeName":"word"},{"id":51596,"position":7,"arabic":"يُرِيدُ","translation":"চান","audioUrl":"wbw/009_055_008.mp3","charTypeName":"word"},{"id":51597,"position":8,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/009_055_009.mp3","charTypeName":"word"},{"id":51598,"position":9,"arabic":"لِيُعَذِّبَهُم","translation":"যেন শাস্তি দেন তাদের","audioUrl":"wbw/009_055_010.mp3","charTypeName":"word"},{"id":51599,"position":10,"arabic":"بِهَا","translation":"দিয়ে তা","audioUrl":"wbw/009_055_011.mp3","charTypeName":"word"},{"id":51600,"position":11,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/009_055_012.mp3","charTypeName":"word"},{"id":51601,"position":12,"arabic":"ٱلْحَيَوٰةِ","translation":"জীবনে","audioUrl":"wbw/009_055_013.mp3","charTypeName":"word"},{"id":51602,"position":13,"arabic":"ٱلدُّنْيَا","translation":"পার্থিব","audioUrl":"wbw/009_055_014.mp3","charTypeName":"word"},{"id":51603,"position":14,"arabic":"وَتَزْهَقَ","translation":"ও চলে যায়","audioUrl":"wbw/009_055_015.mp3","charTypeName":"word"},{"id":51604,"position":15,"arabic":"أَنفُسُهُمْ","translation":"অাত্মা তাদের","audioUrl":"wbw/009_055_016.mp3","charTypeName":"word"},{"id":51605,"position":16,"arabic":"وَهُمْ","translation":"এমতাবস্থায় যে তারা","audioUrl":"wbw/009_055_017.mp3","charTypeName":"word"},{"id":51606,"position":17,"arabic":"كَـٰفِرُونَ","translation":"কাফের","audioUrl":"wbw/009_055_018.mp3","charTypeName":"word"},{"id":51607,"position":18,"arabic":"٥٥","translation":"(৫৫)","audioUrl":null,"charTypeName":"end"}]},{"number":56,"arabic":"وَيَحْلِفُونَ بِٱللَّهِ إِنَّهُمْ لَمِنكُمْ وَمَا هُم مِّنكُمْ وَلَٰكِنَّهُمْ قَوْمٌۭ يَفْرَقُونَ","translation":"And they swear by God that they do indeed belong to you -the while they do not belong to you, but are [only] people ridden by fear:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1291.mp3","surahId":9,"words":[{"id":52158,"position":1,"arabic":"وَيَحْلِفُونَ","translation":"এবং তারা শপথ করে বলে","audioUrl":"wbw/009_056_001.mp3","charTypeName":"word"},{"id":52159,"position":2,"arabic":"بِٱللَّهِ","translation":"নামে আল্লাহর","audioUrl":"wbw/009_056_002.mp3","charTypeName":"word"},{"id":52160,"position":3,"arabic":"إِنَّهُمْ","translation":"নিশ্চয়ই তারা","audioUrl":"wbw/009_056_003.mp3","charTypeName":"word"},{"id":52161,"position":4,"arabic":"لَمِنكُمْ","translation":"অবশ্যই অন্তর্ভুক্ত তোমাদের","audioUrl":"wbw/009_056_004.mp3","charTypeName":"word"},{"id":52162,"position":5,"arabic":"وَمَا","translation":"কিন্ত না","audioUrl":"wbw/009_056_005.mp3","charTypeName":"word"},{"id":52163,"position":6,"arabic":"هُم","translation":"তারা","audioUrl":"wbw/009_056_006.mp3","charTypeName":"word"},{"id":52164,"position":7,"arabic":"مِّنكُمْ","translation":"অন্তর্ভুক্ত তোমাদের","audioUrl":"wbw/009_056_007.mp3","charTypeName":"word"},{"id":52165,"position":8,"arabic":"وَلَـٰكِنَّهُمْ","translation":"কিন্তু তারা","audioUrl":"wbw/009_056_008.mp3","charTypeName":"word"},{"id":52166,"position":9,"arabic":"قَوْمٌۭ","translation":"(এমন) সম্প্রদায়","audioUrl":"wbw/009_056_009.mp3","charTypeName":"word"},{"id":52167,"position":10,"arabic":"يَفْرَقُونَ","translation":"(যারা) ভয় করে","audioUrl":"wbw/009_056_010.mp3","charTypeName":"word"},{"id":52168,"position":11,"arabic":"٥٦","translation":"(৫৬)","audioUrl":null,"charTypeName":"end"}]},{"number":57,"arabic":"لَوْ يَجِدُونَ مَلْجَـًٔا أَوْ مَغَٰرَٰتٍ أَوْ مُدَّخَلًۭا لَّوَلَّوْا۟ إِلَيْهِ وَهُمْ يَجْمَحُونَ","translation":"if they could but find a place of refuge, or any cavern, or a crevice [in the earth], they would turn towards it in headlong haste.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1292.mp3","surahId":9,"words":[{"id":52834,"position":1,"arabic":"لَوْ","translation":"যদি","audioUrl":"wbw/009_057_001.mp3","charTypeName":"word"},{"id":52835,"position":2,"arabic":"يَجِدُونَ","translation":"তারা পেতো","audioUrl":"wbw/009_057_002.mp3","charTypeName":"word"},{"id":52836,"position":3,"arabic":"مَلْجَـًٔا","translation":"আশ্রয়স্থল","audioUrl":"wbw/009_057_003.mp3","charTypeName":"word"},{"id":52837,"position":4,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/009_057_004.mp3","charTypeName":"word"},{"id":52838,"position":5,"arabic":"مَغَـٰرَٰتٍ","translation":"গুহা","audioUrl":"wbw/009_057_005.mp3","charTypeName":"word"},{"id":52839,"position":6,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/009_057_006.mp3","charTypeName":"word"},{"id":52840,"position":7,"arabic":"مُدَّخَلًۭا","translation":"ঢোকার জায়গা","audioUrl":"wbw/009_057_007.mp3","charTypeName":"word"},{"id":52841,"position":8,"arabic":"لَّوَلَّوْا۟","translation":"অবশ্যই তারা ফিরে যেতো","audioUrl":"wbw/009_057_008.mp3","charTypeName":"word"},{"id":52842,"position":9,"arabic":"إِلَيْهِ","translation":"সেদিকে","audioUrl":"wbw/009_057_009.mp3","charTypeName":"word"},{"id":52843,"position":10,"arabic":"وَهُمْ","translation":"এ অবস্থায় যে তারা","audioUrl":"wbw/009_057_010.mp3","charTypeName":"word"},{"id":52844,"position":11,"arabic":"يَجْمَحُونَ","translation":"দ্রুত ছুটে যেতো","audioUrl":"wbw/009_057_011.mp3","charTypeName":"word"},{"id":52845,"position":12,"arabic":"٥٧","translation":"(৫৭)","audioUrl":null,"charTypeName":"end"}]},{"number":58,"arabic":"وَمِنْهُم مَّن يَلْمِزُكَ فِى ٱلصَّدَقَٰتِ فَإِنْ أُعْطُوا۟ مِنْهَا رَضُوا۟ وَإِن لَّمْ يُعْطَوْا۟ مِنْهَآ إِذَا هُمْ يَسْخَطُونَ","translation":"And among them are such as find fault with thee [O Prophet] concerning [the distribution of] the offerings given for the sake of God: if they are given something thereof, they are well-pleased; but if they are not given anything thereof, lo! they are consumed with anger.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1293.mp3","surahId":9,"words":[{"id":53165,"position":1,"arabic":"وَمِنْهُم","translation":"এবং মধ্যে (আছে) তাদের","audioUrl":"wbw/009_058_001.mp3","charTypeName":"word"},{"id":53166,"position":2,"arabic":"مَّن","translation":"কেউ কেউ","audioUrl":"wbw/009_058_002.mp3","charTypeName":"word"},{"id":53167,"position":3,"arabic":"يَلْمِزُكَ","translation":"তোমাকে দোষারোপ করবে","audioUrl":"wbw/009_058_003.mp3","charTypeName":"word"},{"id":53168,"position":4,"arabic":"فِى","translation":"ব্যাপারে","audioUrl":"wbw/009_058_004.mp3","charTypeName":"word"},{"id":53169,"position":5,"arabic":"ٱلصَّدَقَـٰتِ","translation":"সদকা (বণ্টনের)","audioUrl":"wbw/009_058_005.mp3","charTypeName":"word"},{"id":53170,"position":6,"arabic":"فَإِنْ","translation":"কিন্তু যদি","audioUrl":"wbw/009_058_006.mp3","charTypeName":"word"},{"id":53171,"position":7,"arabic":"أُعْطُوا۟","translation":"তাদের দেয়া হয়","audioUrl":"wbw/009_058_007.mp3","charTypeName":"word"},{"id":53172,"position":8,"arabic":"مِنْهَا","translation":"থেকে তা (কিছু)","audioUrl":"wbw/009_058_008.mp3","charTypeName":"word"},{"id":53173,"position":9,"arabic":"رَضُوا۟","translation":"তারা খুশি হয়","audioUrl":"wbw/009_058_009.mp3","charTypeName":"word"},{"id":53174,"position":10,"arabic":"وَإِن","translation":"আর যদি","audioUrl":"wbw/009_058_010.mp3","charTypeName":"word"},{"id":53175,"position":11,"arabic":"لَّمْ","translation":"না","audioUrl":"wbw/009_058_011.mp3","charTypeName":"word"},{"id":53176,"position":12,"arabic":"يُعْطَوْا۟","translation":"তাদের দেয়া হয়","audioUrl":"wbw/009_058_012.mp3","charTypeName":"word"},{"id":53177,"position":13,"arabic":"مِنْهَآ","translation":"হতে তা (কিছুই)","audioUrl":"wbw/009_058_013.mp3","charTypeName":"word"},{"id":53178,"position":14,"arabic":"إِذَا","translation":"তখন","audioUrl":"wbw/009_058_014.mp3","charTypeName":"word"},{"id":53179,"position":15,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/009_058_015.mp3","charTypeName":"word"},{"id":53180,"position":16,"arabic":"يَسْخَطُونَ","translation":"অসন্তোষ হয়ে যায়","audioUrl":"wbw/009_058_016.mp3","charTypeName":"word"},{"id":53181,"position":17,"arabic":"٥٨","translation":"(৫৮)","audioUrl":null,"charTypeName":"end"}]},{"number":59,"arabic":"وَلَوْ أَنَّهُمْ رَضُوا۟ مَآ ءَاتَىٰهُمُ ٱللَّهُ وَرَسُولُهُۥ وَقَالُوا۟ حَسْبُنَا ٱللَّهُ سَيُؤْتِينَا ٱللَّهُ مِن فَضْلِهِۦ وَرَسُولُهُۥٓ إِنَّآ إِلَى ٱللَّهِ رَٰغِبُونَ","translation":"And yet, [it would be but for their own good] if they were to content themselves with what God has given them and [caused] His Apostle [to give them], and would say, \"God is enough for us! God will give us [whatever He wills] out of His bounty, and [will cause] His Apostle [to give us, too]: verily, unto God alone do we turn with hope!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1294.mp3","surahId":9,"words":[{"id":53784,"position":1,"arabic":"وَلَوْ","translation":"এবং যদি","audioUrl":"wbw/009_059_001.mp3","charTypeName":"word"},{"id":53785,"position":2,"arabic":"أَنَّهُمْ","translation":"তারা","audioUrl":"wbw/009_059_002.mp3","charTypeName":"word"},{"id":53786,"position":3,"arabic":"رَضُوا۟","translation":"খুশি হতো","audioUrl":"wbw/009_059_003.mp3","charTypeName":"word"},{"id":53787,"position":4,"arabic":"مَآ","translation":"যা","audioUrl":"wbw/009_059_004.mp3","charTypeName":"word"},{"id":53788,"position":5,"arabic":"ءَاتَىٰهُمُ","translation":"দিয়েছেন তাদের","audioUrl":"wbw/009_059_005.mp3","charTypeName":"word"},{"id":53789,"position":6,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/009_059_006.mp3","charTypeName":"word"},{"id":53790,"position":7,"arabic":"وَرَسُولُهُۥ","translation":"এবং রাসূল তাঁর","audioUrl":"wbw/009_059_007.mp3","charTypeName":"word"},{"id":53791,"position":8,"arabic":"وَقَالُوا۟","translation":"এবং (উত্তম হতো যদি) তারা বলতো","audioUrl":"wbw/009_059_008.mp3","charTypeName":"word"},{"id":53792,"position":9,"arabic":"حَسْبُنَا","translation":"\"আমাদের জন্যে যথেষ্ঠ","audioUrl":"wbw/009_059_009.mp3","charTypeName":"word"},{"id":53793,"position":10,"arabic":"ٱللَّهُ","translation":"আল্লাহই","audioUrl":"wbw/009_059_010.mp3","charTypeName":"word"},{"id":53794,"position":11,"arabic":"سَيُؤْتِينَا","translation":"শীঘ্রই আমাদের দিবেন","audioUrl":"wbw/009_059_011.mp3","charTypeName":"word"},{"id":53795,"position":12,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/009_059_012.mp3","charTypeName":"word"},{"id":53796,"position":13,"arabic":"مِن","translation":"হতে","audioUrl":"wbw/009_059_013.mp3","charTypeName":"word"},{"id":53797,"position":14,"arabic":"فَضْلِهِۦ","translation":"অনুগ্রহ তাঁর","audioUrl":"wbw/009_059_014.mp3","charTypeName":"word"},{"id":53798,"position":15,"arabic":"وَرَسُولُهُۥٓ","translation":"ও রাসূল তাঁর","audioUrl":"wbw/009_059_015.mp3","charTypeName":"word"},{"id":53799,"position":16,"arabic":"إِنَّآ","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/009_059_016.mp3","charTypeName":"word"},{"id":53800,"position":17,"arabic":"إِلَى","translation":"প্রতি","audioUrl":"wbw/009_059_017.mp3","charTypeName":"word"},{"id":53801,"position":18,"arabic":"ٱللَّهِ","translation":"আল্লাহরই","audioUrl":"wbw/009_059_018.mp3","charTypeName":"word"},{"id":53802,"position":19,"arabic":"رَٰغِبُونَ","translation":"অনুরক্ত\"","audioUrl":"wbw/009_059_019.mp3","charTypeName":"word"},{"id":53803,"position":20,"arabic":"٥٩","translation":"(৫৯)","audioUrl":null,"charTypeName":"end"}]},{"number":60,"arabic":"۞ إِنَّمَا ٱلصَّدَقَٰتُ لِلْفُقَرَآءِ وَٱلْمَسَٰكِينِ وَٱلْعَٰمِلِينَ عَلَيْهَا وَٱلْمُؤَلَّفَةِ قُلُوبُهُمْ وَفِى ٱلرِّقَابِ وَٱلْغَٰرِمِينَ وَفِى سَبِيلِ ٱللَّهِ وَٱبْنِ ٱلسَّبِيلِ ۖ فَرِيضَةًۭ مِّنَ ٱللَّهِ ۗ وَٱللَّهُ عَلِيمٌ حَكِيمٌۭ","translation":"The offerings given for the sake of God are [meant] only for the poor and the needy, and those who are in charge thereof, and those whose hearts are to be won over, and for the freeing of human beings from bondage, and [for] those who are over burdened with debts, and [for every struggle] in God's cause, and [for] the wayfarer: [this is] an ordinance from God - and God is all-knowing, wise.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1295.mp3","surahId":9,"words":[{"id":54616,"position":1,"arabic":"۞ إِنَّمَا","translation":"প্রকৃতপক্ষে","audioUrl":"wbw/009_060_002.mp3","charTypeName":"word"},{"id":54617,"position":2,"arabic":"ٱلصَّدَقَـٰتُ","translation":"সদকা","audioUrl":"wbw/009_060_003.mp3","charTypeName":"word"},{"id":54618,"position":3,"arabic":"لِلْفُقَرَآءِ","translation":"জন্যে ফকীরদের","audioUrl":"wbw/009_060_004.mp3","charTypeName":"word"},{"id":54619,"position":4,"arabic":"وَٱلْمَسَـٰكِينِ","translation":"ও অভাবগ্রস্তদের","audioUrl":"wbw/009_060_005.mp3","charTypeName":"word"},{"id":54620,"position":5,"arabic":"وَٱلْعَـٰمِلِينَ","translation":"ও কর্মচারীদের (জন্যে)","audioUrl":"wbw/009_060_006.mp3","charTypeName":"word"},{"id":54621,"position":6,"arabic":"عَلَيْهَا","translation":"উপর তার","audioUrl":"wbw/009_060_007.mp3","charTypeName":"word"},{"id":54622,"position":7,"arabic":"وَٱلْمُؤَلَّفَةِ","translation":"ও আকৃষ্ট করতে (দীনের প্রতি)","audioUrl":"wbw/009_060_008.mp3","charTypeName":"word"},{"id":54623,"position":8,"arabic":"قُلُوبُهُمْ","translation":"অন্তর তাদের","audioUrl":"wbw/009_060_009.mp3","charTypeName":"word"},{"id":54624,"position":9,"arabic":"وَفِى","translation":"এবং ক্ষেত্রে","audioUrl":"wbw/009_060_010.mp3","charTypeName":"word"},{"id":54625,"position":10,"arabic":"ٱلرِّقَابِ","translation":"গলদেশের মুক্তিদানের (অর্থাৎ দাস মুক্তির)","audioUrl":"wbw/009_060_011.mp3","charTypeName":"word"},{"id":54626,"position":11,"arabic":"وَٱلْغَـٰرِمِينَ","translation":"ও ঋণগ্রস্তদের (সাহায্যে)","audioUrl":"wbw/009_060_012.mp3","charTypeName":"word"},{"id":54627,"position":12,"arabic":"وَفِى","translation":"ও মধ্যে","audioUrl":"wbw/009_060_013.mp3","charTypeName":"word"},{"id":54628,"position":13,"arabic":"سَبِيلِ","translation":"পথের","audioUrl":"wbw/009_060_014.mp3","charTypeName":"word"},{"id":54629,"position":14,"arabic":"ٱللَّهِ","translation":"আল্লাহর (অর্থাৎ জিহাদে)","audioUrl":"wbw/009_060_015.mp3","charTypeName":"word"},{"id":54630,"position":15,"arabic":"وَٱبْنِ","translation":"ও ছেলে","audioUrl":"wbw/009_060_016.mp3","charTypeName":"word"},{"id":54631,"position":16,"arabic":"ٱلسَّبِيلِ ۖ","translation":"পথের","audioUrl":"wbw/009_060_017.mp3","charTypeName":"word"},{"id":54633,"position":17,"arabic":"فَرِيضَةًۭ","translation":"নির্ধারিত","audioUrl":"wbw/009_060_019.mp3","charTypeName":"word"},{"id":54634,"position":18,"arabic":"مِّنَ","translation":"হতে","audioUrl":"wbw/009_060_020.mp3","charTypeName":"word"},{"id":54635,"position":19,"arabic":"ٱللَّهِ ۗ","translation":"আল্লাহর","audioUrl":"wbw/009_060_021.mp3","charTypeName":"word"},{"id":54637,"position":20,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/009_060_023.mp3","charTypeName":"word"},{"id":54638,"position":21,"arabic":"عَلِيمٌ","translation":"সবকিছুই জানেন","audioUrl":"wbw/009_060_024.mp3","charTypeName":"word"},{"id":54639,"position":22,"arabic":"حَكِيمٌۭ","translation":"মহাবিজ্ঞ","audioUrl":"wbw/009_060_025.mp3","charTypeName":"word"},{"id":54640,"position":23,"arabic":"٦٠","translation":"(৬০)","audioUrl":null,"charTypeName":"end"}]},{"number":61,"arabic":"وَمِنْهُمُ ٱلَّذِينَ يُؤْذُونَ ٱلنَّبِىَّ وَيَقُولُونَ هُوَ أُذُنٌۭ ۚ قُلْ أُذُنُ خَيْرٍۢ لَّكُمْ يُؤْمِنُ بِٱللَّهِ وَيُؤْمِنُ لِلْمُؤْمِنِينَ وَرَحْمَةٌۭ لِّلَّذِينَ ءَامَنُوا۟ مِنكُمْ ۚ وَٱلَّذِينَ يُؤْذُونَ رَسُولَ ٱللَّهِ لَهُمْ عَذَابٌ أَلِيمٌۭ","translation":"AND AMONG those [enemies of the truth] there are such as malign the Prophet by saying, \"He is all ear.\" Say: \"[Yes,] he is all ear, [listening] to what is good for you! He believes in God, and trusts the believers, and is [a manifestation of God's] grace towards such of you as have [truly] attained to faith. And as for those who malign God's Apostle - grievous suffering awaits them [in the life to come]!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1296.mp3","surahId":9,"words":[{"id":55413,"position":1,"arabic":"وَمِنْهُمُ","translation":"এবং মধ্যে (আছে) তাদের","audioUrl":"wbw/009_061_001.mp3","charTypeName":"word"},{"id":55414,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/009_061_002.mp3","charTypeName":"word"},{"id":55415,"position":3,"arabic":"يُؤْذُونَ","translation":"কষ্ট দেয়","audioUrl":"wbw/009_061_003.mp3","charTypeName":"word"},{"id":55416,"position":4,"arabic":"ٱلنَّبِىَّ","translation":"নাবীকে","audioUrl":"wbw/009_061_004.mp3","charTypeName":"word"},{"id":55417,"position":5,"arabic":"وَيَقُولُونَ","translation":"এবং তারা বলে","audioUrl":"wbw/009_061_005.mp3","charTypeName":"word"},{"id":55418,"position":6,"arabic":"هُوَ","translation":"\"সে","audioUrl":"wbw/009_061_006.mp3","charTypeName":"word"},{"id":55419,"position":7,"arabic":"أُذُنٌۭ ۚ","translation":"কান (কথা শুনে)\"","audioUrl":"wbw/009_061_007.mp3","charTypeName":"word"},{"id":55421,"position":8,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/009_061_009.mp3","charTypeName":"word"},{"id":55422,"position":9,"arabic":"أُذُنُ","translation":"\"কান (কথা শুনা)","audioUrl":"wbw/009_061_010.mp3","charTypeName":"word"},{"id":55423,"position":10,"arabic":"خَيْرٍۢ","translation":"উত্তম","audioUrl":"wbw/009_061_011.mp3","charTypeName":"word"},{"id":55424,"position":11,"arabic":"لَّكُمْ","translation":"জন্যে তোমাদের","audioUrl":"wbw/009_061_012.mp3","charTypeName":"word"},{"id":55425,"position":12,"arabic":"يُؤْمِنُ","translation":"সে ঈমান রাখে","audioUrl":"wbw/009_061_013.mp3","charTypeName":"word"},{"id":55426,"position":13,"arabic":"بِٱللَّهِ","translation":"উপর আল্লাহর","audioUrl":"wbw/009_061_014.mp3","charTypeName":"word"},{"id":55427,"position":14,"arabic":"وَيُؤْمِنُ","translation":"ও বিশ্বাস করে","audioUrl":"wbw/009_061_015.mp3","charTypeName":"word"},{"id":55428,"position":15,"arabic":"لِلْمُؤْمِنِينَ","translation":"প্রতি মু'মিনদের","audioUrl":"wbw/009_061_016.mp3","charTypeName":"word"},{"id":55429,"position":16,"arabic":"وَرَحْمَةٌۭ","translation":"ও দয়া","audioUrl":"wbw/009_061_017.mp3","charTypeName":"word"},{"id":55430,"position":17,"arabic":"لِّلَّذِينَ","translation":"(তাদের) জন্যে যারা","audioUrl":"wbw/009_061_018.mp3","charTypeName":"word"},{"id":55431,"position":18,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/009_061_019.mp3","charTypeName":"word"},{"id":55432,"position":19,"arabic":"مِنكُمْ ۚ","translation":"মধ্য থেকে তোমাদের\"","audioUrl":"wbw/009_061_020.mp3","charTypeName":"word"},{"id":55434,"position":20,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/009_061_022.mp3","charTypeName":"word"},{"id":55435,"position":21,"arabic":"يُؤْذُونَ","translation":"কষ্ট দেয়","audioUrl":"wbw/009_061_023.mp3","charTypeName":"word"},{"id":55436,"position":22,"arabic":"رَسُولَ","translation":"রাসূলকে","audioUrl":"wbw/009_061_024.mp3","charTypeName":"word"},{"id":55437,"position":23,"arabic":"ٱللَّهِ","tran