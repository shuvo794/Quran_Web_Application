04_149_011.mp3","charTypeName":"word"},{"id":80349,"position":12,"arabic":"كَانَ","translation":"হলেন","audioUrl":"wbw/004_149_012.mp3","charTypeName":"word"},{"id":80350,"position":13,"arabic":"عَفُوًّۭا","translation":"ক্ষমাশীল","audioUrl":"wbw/004_149_013.mp3","charTypeName":"word"},{"id":80351,"position":14,"arabic":"قَدِيرًا","translation":"(শাস্তি দেওয়ারও) ক্ষমতাবান","audioUrl":"wbw/004_149_014.mp3","charTypeName":"word"},{"id":80352,"position":15,"arabic":"١٤٩","translation":"(১৪৯)","audioUrl":null,"charTypeName":"end"}]},{"number":150,"arabic":"إِنَّ ٱلَّذِينَ يَكْفُرُونَ بِٱللَّهِ وَرُسُلِهِۦ وَيُرِيدُونَ أَن يُفَرِّقُوا۟ بَيْنَ ٱللَّهِ وَرُسُلِهِۦ وَيَقُولُونَ نُؤْمِنُ بِبَعْضٍۢ وَنَكْفُرُ بِبَعْضٍۢ وَيُرِيدُونَ أَن يَتَّخِذُوا۟ بَيْنَ ذَٰلِكَ سَبِيلًا","translation":"VERILY, those who deny God and His apostles by endeavouring to make a distinction between [belief in] God and [belief in] His apostles, and who say, \"We believe in the one but we deny the other,\" and want to pursue a path in-between -","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/643.mp3","surahId":4,"words":[{"id":80363,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়","audioUrl":"wbw/004_150_001.mp3","charTypeName":"word"},{"id":80364,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/004_150_002.mp3","charTypeName":"word"},{"id":80365,"position":3,"arabic":"يَكْفُرُونَ","translation":"অমান্য করে","audioUrl":"wbw/004_150_003.mp3","charTypeName":"word"},{"id":80366,"position":4,"arabic":"بِٱللَّهِ","translation":"আল্লাহকে","audioUrl":"wbw/004_150_004.mp3","charTypeName":"word"},{"id":80367,"position":5,"arabic":"وَرُسُلِهِۦ","translation":"ও তাঁর রাসূলকে","audioUrl":"wbw/004_150_005.mp3","charTypeName":"word"},{"id":80368,"position":6,"arabic":"وَيُرِيدُونَ","translation":"ও তারা চায়","audioUrl":"wbw/004_150_006.mp3","charTypeName":"word"},{"id":80369,"position":7,"arabic":"أَن","translation":"যে","audioUrl":"wbw/004_150_007.mp3","charTypeName":"word"},{"id":80370,"position":8,"arabic":"يُفَرِّقُوا۟","translation":"তারা পার্থক্য করবে","audioUrl":"wbw/004_150_008.mp3","charTypeName":"word"},{"id":80371,"position":9,"arabic":"بَيْنَ","translation":"মাঝে","audioUrl":"wbw/004_150_009.mp3","charTypeName":"word"},{"id":80372,"position":10,"arabic":"ٱللَّهِ","translation":"আল্লাহর (প্রতি ঈমানে)","audioUrl":"wbw/004_150_010.mp3","charTypeName":"word"},{"id":80373,"position":11,"arabic":"وَرُسُلِهِۦ","translation":"এবং তাঁর রাসূলদের (প্রতি ঈমানে)","audioUrl":"wbw/004_150_011.mp3","charTypeName":"word"},{"id":80374,"position":12,"arabic":"وَيَقُولُونَ","translation":"ও তারা বলে","audioUrl":"wbw/004_150_012.mp3","charTypeName":"word"},{"id":80375,"position":13,"arabic":"نُؤْمِنُ","translation":"''ঈমান আনব আমরা","audioUrl":"wbw/004_150_013.mp3","charTypeName":"word"},{"id":80376,"position":14,"arabic":"بِبَعْضٍۢ","translation":"কাউকে","audioUrl":"wbw/004_150_014.mp3","charTypeName":"word"},{"id":80377,"position":15,"arabic":"وَنَكْفُرُ","translation":"ও অস্বীকার করব আমরা","audioUrl":"wbw/004_150_015.mp3","charTypeName":"word"},{"id":80378,"position":16,"arabic":"بِبَعْضٍۢ","translation":"কাউকে''","audioUrl":"wbw/004_150_016.mp3","charTypeName":"word"},{"id":80379,"position":17,"arabic":"وَيُرِيدُونَ","translation":"ও তারা চায়","audioUrl":"wbw/004_150_017.mp3","charTypeName":"word"},{"id":80380,"position":18,"arabic":"أَن","translation":"যে","audioUrl":"wbw/004_150_018.mp3","charTypeName":"word"},{"id":80381,"position":19,"arabic":"يَتَّخِذُوا۟","translation":"তারা গ্রহণ করবে","audioUrl":"wbw/004_150_019.mp3","charTypeName":"word"},{"id":80382,"position":20,"arabic":"بَيْنَ","translation":"মধ্যবর্তী","audioUrl":"wbw/004_150_020.mp3","charTypeName":"word"},{"id":80383,"position":21,"arabic":"ذَٰلِكَ","translation":"এর","audioUrl":"wbw/004_150_021.mp3","charTypeName":"word"},{"id":80384,"position":22,"arabic":"سَبِيلًا","translation":"পথ","audioUrl":"wbw/004_150_022.mp3","charTypeName":"word"},{"id":80385,"position":23,"ara