{"id":102,"ayahs":[{"number":148,"arabic":"۞ لَّا يُحِبُّ ٱللَّهُ ٱلْجَهْرَ بِٱلسُّوٓءِ مِنَ ٱلْقَوْلِ إِلَّا مَن ظُلِمَ ۚ وَكَانَ ٱللَّهُ سَمِيعًا عَلِيمًا","translation":"God does not like any evil to be mentioned openly, unless it be by him who has been wronged (thereby) And God is indeed all-hearing, all-knowing,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/641.mp3","surahId":4,"words":[{"id":80185,"position":1,"arabic":"۞ لَّا","translation":"না","audioUrl":"wbw/004_148_002.mp3","charTypeName":"word"},{"id":80186,"position":2,"arabic":"يُحِبُّ","translation":"পছন্দ করেন","audioUrl":"wbw/004_148_003.mp3","charTypeName":"word"},{"id":80187,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/004_148_004.mp3","charTypeName":"word"},{"id":80188,"position":4,"arabic":"ٱلْجَهْرَ","translation":"প্রকাশ করাকে","audioUrl":"wbw/004_148_005.mp3","charTypeName":"word"},{"id":80189,"position":5,"arabic":"بِٱلسُّوٓءِ","translation":"মন্দ দিক","audioUrl":"wbw/004_148_006.mp3","charTypeName":"word"},{"id":80190,"position":6,"arabic":"مِنَ","translation":"(থেকে)","audioUrl":"wbw/004_148_007.mp3","charTypeName":"word"},{"id":80191,"position":7,"arabic":"ٱلْقَوْلِ","translation":"কথা (ও কাজের)","audioUrl":"wbw/004_148_008.mp3","charTypeName":"word"},{"id":80192,"position":8,"arabic":"إِلَّا","translation":"এ ব্যতীত","audioUrl":"wbw/004_148_009.mp3","charTypeName":"word"},{"id":80193,"position":9,"arabic":"مَن","translation":"যাকে","audioUrl":"wbw/004_148_010.mp3","charTypeName":"word"},{"id":80194,"position":10,"arabic":"ظُلِمَ ۚ","translation":"জুলুম করা হয়েছে","audioUrl":"wbw/004_148_011.mp3","charTypeName":"word"},{"id":80196,"position":11,"arabic":"وَكَانَ","translation":"এবং হলেন","audioUrl":"wbw/004_148_013.mp3","charTypeName":"word"},{"id":80197,"position":12,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/004_148_014.mp3","charTypeName":"word"},{"id":80198,"position":13,"arabic":"سَمِيعًا","translation":"সর্বশ্রোতা","audioUr