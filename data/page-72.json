{"id":72,"ayahs":[{"number":166,"arabic":"وَمَآ أَصَٰبَكُمْ يَوْمَ ٱلْتَقَى ٱلْجَمْعَانِ فَبِإِذْنِ ٱللَّهِ وَلِيَعْلَمَ ٱلْمُؤْمِنِينَ","translation":"and all that befell you on the day when the two hosts met in battle happened by God's leave, so that He might mark out the [true] believers,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/459.mp3","surahId":3,"words":[{"id":82453,"position":1,"arabic":"وَمَآ","translation":"এবং যা (মুসিবত)","audioUrl":"wbw/003_166_001.mp3","charTypeName":"word"},{"id":82454,"position":2,"arabic":"أَصَـٰبَكُمْ","translation":"পৌঁছেছে তোমাদের","audioUrl":"wbw/003_166_002.mp3","charTypeName":"word"},{"id":82455,"position":3,"arabic":"يَوْمَ","translation":"দিনে","audioUrl":"wbw/003_166_003.mp3","charTypeName":"word"},{"id":82456,"position":4,"arabic":"ٱلْتَقَى","translation":"মুকাবিলার","audioUrl":"wbw/003_166_004.mp3","charTypeName":"word"},{"id":82457,"position":5,"arabic":"ٱلْجَمْعَانِ","translation":"দুই দলের","audioUrl":"wbw/003_166_005.mp3","charTypeName":"word"},{"id":82458,"position":6,"arabic":"فَبِإِذْنِ","translation":"তা (এসেছে) অনুমতিক্রমে","audioUrl":"wbw/003_166_006.mp3","charTypeName":"word"},{"id":82459,"position":7,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/003_166_007.mp3","charTypeName":"word"},{"id":82460,"position":8,"arabic":"وَلِيَعْلَمَ","translation":"এবং তিনি যেন জানেন","audioUrl":"wbw/003_166_008.mp3","charTypeName":"word"},{"id":82461,"position":9,"arabic":"ٱلْمُؤْمِنِينَ","translation":"মু'মিনদেরকে","audioUrl":"wbw/003_166_009.mp3","charTypeName":"word"},{"id":82462,"position":10,"arabic":"١٦٦","translation":"(১৬৬)","audioUrl":null,"charTypeName":"end"}]},{"number":167,"arabic":"وَلِيَعْلَمَ ٱلَّذِينَ نَافَقُوا۟ ۚ وَقِيلَ لَهُمْ تَعَالَوْا۟ قَٰتِلُوا۟ فِى سَبِيلِ ٱللَّهِ أَوِ ٱدْفَعُوا۟ ۖ قَالُوا۟ لَوْ نَعْلَمُ قِتَالًۭا لَّٱتَّبَعْنَٰكُمْ ۗ هُمْ لِلْكُفْرِ يَوْمَئِذٍ أَقْرَبُ مِنْهُمْ لِلْإِيمَٰنِ ۚ يَقُولُونَ بِأَفْوَٰهِهِم مَّا لَيْسَ فِى قُلُوبِهِمْ ۗ وَٱللَّهُ أَعْلَ