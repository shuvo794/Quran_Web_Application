{"id":179,"ayahs":[{"number":17,"arabic":"فَلَمْ تَقْتُلُوهُمْ وَلَٰكِنَّ ٱللَّهَ قَتَلَهُمْ ۚ وَمَا رَمَيْتَ إِذْ رَمَيْتَ وَلَٰكِنَّ ٱللَّهَ رَمَىٰ ۚ وَلِيُبْلِىَ ٱلْمُؤْمِنِينَ مِنْهُ بَلَآءً حَسَنًا ۚ إِنَّ ٱللَّهَ سَمِيعٌ عَلِيمٌۭ","translation":"And yet, [O believers,] it was not you who slew the enemy, but it was God who slew them; and it was not thou who cast [terror into them, O Prophet], when thou didst cast it, but it was God who cast it: and [He did all this] in order that He might test the believers by a goodly test of His Own or daining. Verily, God is all-hearing, all-knowing!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1177.mp3","surahId":8,"words":[{"id":19323,"position":1,"arabic":"فَلَمْ","translation":"আসলে কর নি","audioUrl":"wbw/008_017_001.mp3","charTypeName":"word"},{"id":19324,"position":2,"arabic":"تَقْتُلُوهُمْ","translation":"তোমরা হত্যা তাদেরকে","audioUrl":"wbw/008_017_002.mp3","charTypeName":"word"},{"id":19325,"position":3,"arabic":"وَلَـٰكِنَّ","translation":"কিন্তু","audioUrl":"wbw/008_017_003.mp3","charTypeName":"word"},{"id":19326,"position":4,"arabic":"ٱللَّهَ","translation":"আল্লাহই","audioUrl":"wbw/008_017_004.mp3","charTypeName":"word"},{"id":19327,"position":5,"arabic":"قَتَلَهُمْ ۚ","translation":"হত্যা করেছেন তাদের","audioUrl":"wbw/008_017_005.mp3","charTypeName":"word"},{"id":19329,"position":6,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/008_017_007.mp3","charTypeName":"word"},{"id":19330,"position":7,"arabic":"رَمَيْتَ","translation":"তুমি নিক্ষেপ করেছিলে(কংকর)","audioUrl":"wbw/008_017_008.mp3","charTypeName":"word"},{"id":19331,"position":8,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/008_017_009.mp3","charTypeName":"word"},{"id":19332,"position":9,"arabic":"رَمَيْتَ","translation":"তুমি নিক্ষেপ করেছিলে","audioUrl":"wbw/008_017_010.mp3","charTypeName":"word"},{"id":19333,"position":10,"arabic":"وَلَـٰكِنَّ","translation":"কিন্তু","audioUrl":"wbw/008_017_011.mp3","charTypeName":"word"},{"id":19334,"position":11,"arabic":"ٱللَّهَ","translation":"আল্লাহই","audioUrl":"wbw/008_017_012.mp3","charTypeName":"word"},{"id":19335,"position":12,"arabic":"رَمَىٰ ۚ","translation":"নিক্ষেপ করেছিলেন","audioUrl":"wbw/008_017_013.mp3","charTypeName":"word"},{"id":19337,"position":13,"arabic":"وَلِيُبْلِىَ","translation":"এবং জন্যে পরীক্ষার","audioUrl":"wbw/008_017_015.mp3","charTypeName":"word"},{"id":19338,"position":14,"arabic":"ٱلْمُؤْمِنِينَ","translation":"মু'মিনদেরকে","audioUrl":"wbw/008_017_016.mp3","charTypeName":"word"},{"id":19339,"position":15,"arabic":"مِنْهُ","translation":"হতে তা","audioUrl":"wbw/008_017_017.mp3","charTypeName":"word"},{"id":19340,"position":16,"arabic":"بَلَآءً","translation":"পরীক্ষা","audioUrl":"wbw/008_017_018.mp3","charTypeName":"word"},{"id":19341,"position":17,"arabic":"حَسَنًا ۚ","translation":"উত্তম","audioUrl":"wbw/008_017_019.mp3","charTypeName":"word"},{"id":19343,"position":18,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/008_017_021.mp3","charTypeName":"word"},{"id":19344,"position":19,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/008_017_022.mp3","charTypeName":"word"},{"id":19345,"position":20,"arabic":"سَمِيعٌ","translation":"সবকিছু শুনেন","audioUrl":"wbw/008_017_023.mp3","charTypeName":"word"},{"id":19346,"position":21,"arabic":"عَلِيمٌۭ","translation":"সবকিছু জানেন","audioUrl":"wbw/008_017_024.mp3","charTypeName":"word"},{"id":19347,"position":22,"arabic":"١٧","translation":"(১৭)","audioUrl":null,"charTypeName":"end"}]},{"number":18,"arabic":"ذَٰلِكُمْ وَأَنَّ ٱللَّهَ مُوهِنُ كَيْدِ ٱلْكَٰفِرِينَ","translation":"This [was God's purpose] -and also [to show] that God renders vain the artful schemes of those who deny the truth.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1178.mp3","surahId":8,"words":[{"id":20396,"position":1,"arabic":"ذَٰلِكُمْ","translation":"এ (আচরণ)তোমাদের (সাথে)","audioUrl":"wbw/008_018_001.mp3","charTypeName":"word"},{"id":20397,"position":2,"arabic":"وَأَنَّ","translation":"আর যে(কাফেরদের সাথে এরূপ)","audioUrl":"wbw/008_018_002.mp3","charTypeName":"word"},{"id":20398,"position":3,"arabic":"ٱللَّهَ","translation":"আল্লাহই","audioUrl":"wbw/008_018_003.mp3","charTypeName":"word"},{"id":20399,"position":4,"arabic":"مُوهِنُ","translation":"দুর্বলকারী","audioUrl":"wbw/008_018_004.mp3","charTypeName":"word"},{"id":20400,"position":5,"arabic":"كَيْدِ","translation":"কৌশল","audioUrl":"wbw/008_018_005.mp3","charTypeName":"word"},{"id":20401,"position":6,"arabic":"ٱلْكَـٰفِرِينَ","translation":"কাফেরদের","audioUrl":"wbw/008_018_006.mp3","charTypeName":"word"},{"id":20402,"position":7,"arabic":"١٨","translation":"(১৮)","audioUrl":null,"charTypeName":"end"}]},{"number":19,"arabic":"إِن تَسْتَفْتِحُوا۟ فَقَدْ جَآءَكُمُ ٱلْفَتْحُ ۖ وَإِن تَنتَهُوا۟ فَهُوَ خَيْرٌۭ لَّكُمْ ۖ وَإِن تَعُودُوا۟ نَعُدْ وَلَن تُغْنِىَ عَنكُمْ فِئَتُكُمْ شَيْـًۭٔا وَلَوْ كَثُرَتْ وَأَنَّ ٱللَّهَ مَعَ ٱلْمُؤْمِنِينَ","translation":"If you have been praying for victory, [O believers] - victory has now indeed come unto you. And if you abstain [from sinning], it will be for your own good; but if you revert to it, We shall revoke [Our promise of aid] - and never will your community be of any avail to you, however great its numbers: for, behold, God is [only] with those who believe!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1179.mp3","surahId":8,"words":[{"id":21470,"position":1,"arabic":"إِن","translation":"(হে কাফেররা) যদি","audioUrl":"wbw/008_019_001.mp3","charTypeName":"word"},{"id":21471,"position":2,"arabic":"تَسْتَفْتِحُوا۟","translation":"তোমরা মীমাংসা চাও","audioUrl":"wbw/008_019_002.mp3","charTypeName":"word"},{"id":21472,"position":3,"arabic":"فَقَدْ","translation":"তবে নিশ্চয়ই","audioUrl":"wbw/008_019_003.mp3","charTypeName":"word"},{"id":21473,"position":4,"arabic":"جَآءَكُمُ","translation":"কাছে এসেছে তোমাদের","audioUrl":"wbw/008_019_004.mp3","charTypeName":"word"},{"id":21474,"position":5,"arabic":"ٱلْفَتْحُ ۖ","translation":"মীমাংসা","audioUrl":"wbw/008_019_005.mp3","charTypeName":"word"},{"id":21476,"position":6,"arabic":"وَإِن","translation":"এবং যদি","audioUrl":"wbw/008_019_007.mp3","charTypeName":"word"},{"id":21477,"position":7,"arabic":"تَنتَهُوا۟","translation":"তোমরা বিরত হও","audioUrl":"wbw/008_019_008.mp3","charTypeName":"word"},{"id":21478,"position":8,"arabic":"فَهُوَ","translation":"তবে তা","audioUrl":"wbw/008_019_009.mp3","charTypeName":"word"},{"id":21479,"position":9,"arabic":"خَيْرٌۭ","translation":"উত্তম","audioUrl":"wbw/008_019_010.mp3","charTypeName":"word"},{"id":21480,"position":10,"arabic":"لَّكُمْ ۖ","translation":"জন্যে তোমাদের","audioUrl":"wbw/008_019_011.mp3","charTypeName":"word"},{"id":21482,"position":11,"arabic":"وَإِن","translation":"এবং যদি","audioUrl":"wbw/008_019_013.mp3","charTypeName":"word"},{"id":21483,"position":12,"arabic":"تَعُودُوا۟","translation":"তোমরা পুনরাবৃত্তি করো","audioUrl":"wbw/008_019_014.mp3","charTypeName":"word"},{"id":21484,"position":13,"arabic":"نَعُدْ","translation":"পুনরাবৃত্তি করবো আমরা","audioUrl":"wbw/008_019_015.mp3","charTypeName":"word"},{"id":21485,"position":14,"arabic":"وَلَن","translation":"এবং কখনও না","audioUrl":"wbw/008_019_016.mp3","charTypeName":"word"},{"id":21486,"position":15,"arabic":"تُغْنِىَ","translation":"কাজে আসবে","audioUrl":"wbw/008_019_017.mp3","charTypeName":"word"},{"id":21487,"position":16,"arabic":"عَنكُمْ","translation":"জন্যে তোমাদের","audioUrl":"wbw/008_019_018.mp3","charTypeName":"word"},{"id":21488,"position":17,"arabic":"فِئَتُكُمْ","translation":"দলবল তোমাদের","audioUrl":"wbw/008_019_019.mp3","charTypeName":"word"},{"id":21489,"position":18,"arabic":"شَيْـًۭٔا","translation":"কিছুমাত্রই","audioUrl":"wbw/008_019_020.mp3","charTypeName":"word"},{"id":21490,"position":19,"arabic":"وَلَوْ","translation":"আর যদি","audioUrl":"wbw/008_019_021.mp3","charTypeName":"word"},{"id":21491,"position":20,"arabic":"كَثُرَتْ","translation":"অধিকও হয়(তবুও)","audioUrl":"wbw/008_019_022.mp3","charTypeName":"word"},{"id":21492,"position":21,"arabic":"وَأَنَّ","translation":"এবং (জেনে রেখো) যে","audioUrl":"wbw/008_019_023.mp3","charTypeName":"word"},{"id":21493,"position":22,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/008_019_024.mp3","charTypeName":"word"},{"id":21494,"position":23,"arabic":"مَعَ","translation":"সাথে(আছেন)","audioUrl":"wbw/008_019_025.mp3","charTypeName":"word"},{"id":21495,"position":24,"arabic":"ٱلْمُؤْمِنِينَ","translation":"মু'মিনদের","audioUrl":"wbw/008_019_026.mp3","charTypeName":"word"},{"id":21496,"position":25,"arabic":"١٩","translation":"(১৯)","audioUrl":null,"charTypeName":"end"}]},{"number":20,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوٓا۟ أَطِيعُوا۟ ٱللَّهَ وَرَسُولَهُۥ وَلَا تَوَلَّوْا۟ عَنْهُ وَأَنتُمْ تَسْمَعُونَ","translation":"[Hence,] O you who have attained to faith, pay heed unto God and His Apostle, and do not turn away from Him now that you hear [His message];","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1180.mp3","surahId":8,"words":[{"id":22558,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/008_020_001.mp3","charTypeName":"word"},{"id":22559,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/008_020_002.mp3","charTypeName":"word"},{"id":22560,"position":3,"arabic":"ءَامَنُوٓا۟","translation":"ঈমান এনেছো","audioUrl":"wbw/008_020_003.mp3","charTypeName":"word"},{"id":22561,"position":4,"arabic":"أَطِيعُوا۟","translation":"তোমরা আনুগত্য করো","audioUrl":"wbw/008_020_004.mp3","charTypeName":"word"},{"id":22562,"position":5,"arabic":"ٱللَّهَ","translation":"আল্লাহর","audioUrl":"wbw/008_020_005.mp3","charTypeName":"word"},{"id":22563,"position":6,"arabic":"وَرَسُولَهُۥ","translation":"ও রাসূলের তাঁর","audioUrl":"wbw/008_020_006.mp3","charTypeName":"word"},{"id":22564,"position":7,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/008_020_007.mp3","charTypeName":"word"},{"id":22565,"position":8,"arabic":"تَوَلَّوْا۟","translation":"তোমরা মুখ ফিরাবে","audioUrl":"wbw/008_020_008.mp3","charTypeName":"word"},{"id":22566,"position":9,"arabic":"عَنْهُ","translation":"হতে তা","audioUrl":"wbw/008_020_009.mp3","charTypeName":"word"},{"id":22567,"position":10,"arabic":"وَأَنتُمْ","translation":"যখন তোমরা","audioUrl":"wbw/008_020_010.mp3","charTypeName":"word"},{"id":22568,"position":11,"arabic":"تَسْمَعُونَ","translation":"তোমরা শুনছো","audioUrl":"wbw/008_020_011.mp3","charTypeName":"word"},{"id":22569,"position":12,"arabic":"٢٠","translation":"(২০)","audioUrl":null,"charTypeName":"end"}]},{"number":21,"arabic":"وَلَا تَكُونُوا۟ كَٱلَّذِينَ قَالُوا۟ سَمِعْنَا وَهُمْ لَا يَسْمَعُونَ","translation":"and be not like those who say, \"We have heard\", the while they do not hearken.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1181.mp3","surahId":8,"words":[{"id":23725,"position":1,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/008_021_001.mp3","charTypeName":"word"},{"id":23726,"position":2,"arabic":"تَكُونُوا۟","translation":"তোমরা হয়ো","audioUrl":"wbw/008_021_002.mp3","charTypeName":"word"},{"id":23727,"position":3,"arabic":"كَٱلَّذِينَ","translation":"(তাদের) মতো যারা","audioUrl":"wbw/008_021_003.mp3","charTypeName":"word"},{"id":23728,"position":4,"arabic":"قَالُوا۟","translation":"বলেছিলো","audioUrl":"wbw/008_021_004.mp3","charTypeName":"word"},{"id":23729,"position":5,"arabic":"سَمِعْنَا","translation":"\"আমরা শুনলাম\"","audioUrl":"wbw/008_021_005.mp3","charTypeName":"word"},{"id":23730,"position":6,"arabic":"وَهُمْ","translation":"অথচ তারা","audioUrl":"wbw/008_021_006.mp3","charTypeName":"word"},{"id":23731,"position":7,"arabic":"لَا","translation":"না","audioUrl":"wbw/008_021_007.mp3","charTypeName":"word"},{"id":23732,"position":8,"arabic":"يَسْمَعُونَ","translation":"তারা শোনে","audioUrl":"wbw/008_021_008.mp3","charTypeName":"word"},{"id":23733,"position":9,"arabic":"٢١","translation":"(২১)","audioUrl":null,"charTypeName":"end"}]},{"number":22,"arabic":"۞ إِنَّ شَرَّ ٱلدَّوَآبِّ عِندَ ٱللَّهِ ٱلصُّمُّ ٱلْبُكْمُ ٱلَّذِينَ لَا يَعْقِلُونَ","translation":"Verily, the vilest of all creatures in the sight of God are those deaf, those dumb ones who do not use their reason.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1182.mp3","surahId":8,"words":[{"id":24683,"position":1,"arabic":"۞ إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/008_022_002.mp3","charTypeName":"word"},{"id":24684,"position":2,"arabic":"شَرَّ","translation":"নিকৃষ্ট","audioUrl":"wbw/008_022_003.mp3","charTypeName":"word"},{"id":24685,"position":3,"arabic":"ٱلدَّوَآبِّ","translation":"জীবগুলোর(মধ্যে)","audioUrl":"wbw/008_022_004.mp3","charTypeName":"word"},{"id":24686,"position":4,"arabic":"عِندَ","translation":"কাছে","audioUrl":"wbw/008_022_005.mp3","charTypeName":"word"},{"id":24687,"position":5,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/008_022_006.mp3","charTypeName":"word"},{"id":24688,"position":6,"arabic":"ٱلصُّمُّ","translation":"(এসব) বধির","audioUrl":"wbw/008_022_007.mp3","charTypeName":"word"},{"id":24689,"position":7,"arabic":"ٱلْبُكْمُ","translation":"বোবা","audioUrl":"wbw/008_022_008.mp3","charTypeName":"word"},{"id":24690,"position":8,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/008_022_009.mp3","charTypeName":"word"},{"id":24691,"position":9,"arabic":"لَا","translation":"না","audioUrl":"wbw/008_022_010.mp3","charTypeName":"word"},{"id":24692,"position":10,"arabic":"يَعْقِلُونَ","translation":"বুদ্ধি কাজে লাগায়","audioUrl":"wbw/008_022_011.mp3","charTypeName":"word"},{"id":24693,"position":11,"arabic":"٢٢","translation":"(২২)","audioUrl":null,"charTypeName":"end"}]},{"number":23,"arabic":"وَلَوْ عَلِمَ ٱللَّهُ فِيهِمْ خَيْرًۭا لَّأَسْمَعَهُمْ ۖ وَلَوْ أَسْمَعَهُمْ لَتَوَلَّوا۟ وَّهُم مُّعْرِضُونَ","translation":"For, if God had seen any good in them, He would certainly have made them hear: but [as it is,] even if He had made them hear, they would surely have turned away in their obstinacy.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1183.mp3","surahId":8,"words":[{"id":25783,"position":1,"arabic":"وَلَوْ","translation":"এবং যদি","audioUrl":"wbw/008_023_001.mp3","charTypeName":"word"},{"id":25784,"position":2,"arabic":"عَلِمَ","translation":"জানতেন","audioUrl":"wbw/008_023_002.mp3","charTypeName":"word"},{"id":25785,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/008_023_003.mp3","charTypeName":"word"},{"id":25786,"position":4,"arabic":"فِيهِمْ","translation":"মধ্যে তাদের(রয়েছে)","audioUrl":"wbw/008_023_004.mp3","charTypeName":"word"},{"id":25787,"position":5,"arabic":"خَيْرًۭا","translation":"কোনো কল্যাণ","audioUrl":"wbw/008_023_005.mp3","charTypeName":"word"},{"id":25788,"position":6,"arabic":"لَّأَسْمَعَهُمْ ۖ","translation":"অবশ্যই শুনাতেন তাদের","audioUrl":"wbw/008_023_006.mp3","charTypeName":"word"},{"id":25790,"position":7,"arabic":"وَلَوْ","translation":"এবং যদি","audioUrl":"wbw/008_023_008.mp3","charTypeName":"word"},{"id":25791,"position":8,"arabic":"أَسْمَعَهُمْ","translation":"তিনি শুনাতেনও তাদের","audioUrl":"wbw/008_023_009.mp3","charTypeName":"word"},{"id":25792,"position":9,"arabic":"لَتَوَلَّوا۟","translation":"অবশ্যই তারা মুখ ফিরাতো","audioUrl":"wbw/008_023_010.mp3","charTypeName":"word"},{"id":25793,"position":10,"arabic":"وَّهُم","translation":"ও তারা","audioUrl":"wbw/008_023_011.mp3","charTypeName":"word"},{"id":25794,"position":11,"arabic":"مُّعْرِضُونَ","translation":"উপেক্ষা করতো","audioUrl":"wbw/008_023_012.mp3","charTypeName":"word"},{"id":25795,"position":12,"arabic":"٢٣","translation":"(২৩)","audioUrl":null,"charTypeName":"end"}]},{"number":24,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ ٱسْتَجِيبُوا۟ لِلَّهِ وَلِلرَّسُولِ إِذَا دَعَاكُمْ لِمَا يُحْيِيكُمْ ۖ وَٱعْلَمُوٓا۟ أَنَّ ٱللَّهَ يَحُولُ بَيْنَ ٱلْمَرْءِ وَقَلْبِهِۦ وَأَنَّهُۥٓ إِلَيْهِ تُحْشَرُونَ","translation":"O you who have attained to faith! Respond to the call of God and the Apostle whenever he calls you unto that which will give you life; a