{"id":59,"ayahs":[{"number":71,"arabic":"يَٰٓأَهْلَ ٱلْكِتَٰبِ لِمَ تَلْبِسُونَ ٱلْحَقَّ بِٱلْبَٰطِلِ وَتَكْتُمُونَ ٱلْحَقَّ وَأَنتُمْ تَعْلَمُونَ","translation":"O followers of earlier revelation! Why do you cloak the truth with falsehood and conceal the truth of which you are [so well] aware?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/364.mp3","surahId":3,"words":[{"id":60150,"position":1,"arabic":"يَـٰٓأَهْلَ","translation":"হে আহলি","audioUrl":"wbw/003_071_001.mp3","charTypeName":"word"},{"id":60151,"position":2,"arabic":"ٱلْكِتَـٰبِ","translation":"কিতাব","audioUrl":"wbw/003_071_002.mp3","charTypeName":"word"},{"id":60152,"position":3,"arabic":"لِمَ","translation":"কেন","audioUrl":"wbw/003_071_003.mp3","charTypeName":"word"},{"id":60153,"position":4,"arabic":"تَلْبِسُونَ","translation":"তোমরা মিলাও","audioUrl":"wbw/003_071_004.mp3","charTypeName":"word"},{"id":60154,"position":5,"arabic":"ٱلْحَقَّ","translation":"হককে","audioUrl":"wbw/003_071_005.mp3","charTypeName":"word"},{"id":60155,"position":6,"arabic":"بِٱلْبَـٰطِلِ","translation":"বাতিলের সাথে","audioUrl":"wbw/003_071_006.mp3","charTypeName":"word"},{"id":60156,"position":7,"arabic":"وَتَكْتُمُونَ","translation":"এবং তোমরা গোপন করছ","audioUrl":"wbw/003_071_007.mp3","charTypeName":"word"},{"id":60157,"position":8,"arabic":"ٱلْحَقَّ","translation":"হককে","audioUrl":"wbw/003_071_008.mp3","charTypeName":"word"},{"id":60158,"position":9,"arabic":"وَأَنتُمْ","translation":"অথচ তোমরা","audioUrl":"wbw/003_071_009.mp3","charTypeName":"word"},{"id":60159,"position":10,"arabic":"تَعْلَمُونَ","translation":"(ভালভাবেই) জান","audioUrl":"wbw/003_071_010.mp3","charTypeName":"word"},{"id":60160,"position":11,"arabic":"٧١","translation":"(৭১)","audioUrl":null,"charTypeName":"end"}]},{"number":72,"arabic":"وَقَالَت طَّآئِفَةٌۭ مِّنْ أَهْلِ ٱلْكِتَٰبِ ءَامِنُوا۟ بِٱلَّذِىٓ أُنزِلَ عَلَى ٱلَّذِينَ ءَامَنُوا۟ وَجْهَ ٱلنَّهَارِ وَٱكْفُرُوٓا۟ ءَاخِرَهُۥ لَعَلَّهُمْ يَرْجِعُونَ","translation":"And some of 