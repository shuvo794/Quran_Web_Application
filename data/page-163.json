{"id":163,"ayahs":[{"number":96,"arabic":"وَلَوْ أَنَّ أَهْلَ ٱلْقُرَىٰٓ ءَامَنُوا۟ وَٱتَّقَوْا۟ لَفَتَحْنَا عَلَيْهِم بَرَكَٰتٍۢ مِّنَ ٱلسَّمَآءِ وَٱلْأَرْضِ وَلَٰكِن كَذَّبُوا۟ فَأَخَذْنَٰهُم بِمَا كَانُوا۟ يَكْسِبُونَ","translation":"Yet if the people of those communities had but attained to faith and been conscious of Us, We would indeed have opened up for them blessings out of heaven and earth: but they gave the lie to the truth - and so We took them to task through what they [themselves] had been doing.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1050.mp3","surahId":7,"words":[{"id":70081,"position":1,"arabic":"وَلَوْ","translation":"এবং যদি","audioUrl":"wbw/007_096_001.mp3","charTypeName":"word"},{"id":70082,"position":2,"arabic":"أَنَّ","translation":"নিশ্চিত","audioUrl":"wbw/007_096_002.mp3","charTypeName":"word"},{"id":70083,"position":3,"arabic":"أَهْلَ","translation":"অধিবাসিরা","audioUrl":"wbw/007_096_003.mp3","charTypeName":"word"},{"id":70084,"position":4,"arabic":"ٱلْقُرَىٰٓ","translation":"জনপদের","audioUrl":"wbw/007_096_004.mp3","charTypeName":"word"},{"id":70085,"position":5,"arabic":"ءَامَنُوا۟","translation":"ঈমান আনতো","audioUrl":"wbw/007_096_005.mp3","charTypeName":"word"},{"id":70086,"position":6,"arabic":"وَٱتَّقَوْا۟","translation":"ও তাকওয়া অবলম্বন করতো","audioUrl":"wbw/007_096_006.mp3","charTypeName":"word"},{"id":70087,"position":7,"arabic":"لَفَتَحْنَا","translation":"অবশ্যই খুলে দিতাম আমরা","audioUrl":"wbw/007_096_007.mp3","charTypeName":"word"},{"id":70088,"position":8,"arabic":"عَلَيْهِم","translation":"উপর তাদের","audioUrl":"wbw/007_096_008.mp3","charTypeName":"word"},{"id":70089,"position":9,"arabic":"بَرَكَـٰتٍۢ","translation":"কল্যাণসমূহ","audioUrl":"wbw/007_096_009.mp3","charTypeName":"word"},{"id":70090,"position":10,"arabic":"مِّنَ","translation":"থেকে","audioUrl":"wbw/007_096_010.mp3","charTypeName":"word"},{"id":70091,"position":11,"arabic":"ٱلسَّمَآءِ","translation":"আকাশ","audioUrl":"wbw/007_096_011.mp3","charTypeName":"word"},{"id":70092,"position":12,"arabic":"وَٱلْأَرْضِ","translation":"ও জমিন (থেকে)","audioUrl":"wbw/007_096_012.mp3","charTypeName":"word"},{"id":70093,"position":13,"arabic":"وَلَـٰكِن","translation":"কিন্তু","audioUrl":"wbw/007_096_013.mp3","charTypeName":"word"},{"id":70094,"position":14,"arabic":"كَذَّبُوا۟","translation":"তারা মিথ্যারোপ করেছিলো","audioUrl":"wbw/007_096_014.mp3","charTypeName":"word"},{"id":70095,"position":15,"arabic":"فَأَخَذْنَـٰهُم","translation":"সুতরাং ধরেছি আমরা তাদেরকে","audioUrl":"wbw/007_096_015.mp3","charTypeName":"word"},{"id":70096,"position":16,"arabic":"بِمَا","translation":"সহ তা যা","audioUrl":"wbw/007_096_016.mp3","charTypeName":"word"},{"id":70097,"position":17,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/007_096_017.mp3","charTypeName":"word"},{"id":70098,"position":18,"arabic":"يَكْسِبُونَ","translation":"তারা অর্জন করতে","audioUrl":"wbw/007_096_018.mp3","charTypeName":"word"},{"id":70099,"position":19,"arabic":"٩٦","translation":"(৯৬)","audioUrl":null,"charTypeName":"end"}]},{"number":97,"arabic":"أَفَأَمِنَ أَهْلُ ٱلْقُرَىٰٓ أَن يَأْتِيَهُم بَأْسُنَا بَيَٰتًۭا وَهُمْ نَآئِمُونَ","translation":"Can, then, the people of any community ever feel secure that Our punishment will not come upon them by night, while they are asleep?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1051.mp3","surahId":7,"words":[{"id":70381,"position":1,"arabic":"أَفَأَمِنَ","translation":"কি তবে নির্ভয় হয়েছে","audioUrl":"wbw/007_097_001.mp3","charTypeName":"word"},{"id":70382,"position":2,"arabic":"أَهْلُ","translation":"অধিবাসীরা","audioUrl":"wbw/007_097_002.mp3","charTypeName":"word"},{"id":70383,"position":3,"arabic":"ٱلْقُرَىٰٓ","translation":"জনপদের","audioUrl":"wbw/007_097_003.mp3","charTypeName":"word"},{"id":70384,"position":4,"arabic":"أَن","translation":"(এ বিপদ হতে) যে","audioUrl":"wbw/007_097_004.mp3","charTypeName":"word"},{"id":70385,"position":5,"arabic":"يَأْتِيَهُم","translation":"তাদের উপর আসবে","audioUrl":"wbw/007_097_005.mp3","charTypeName":"word"},{"id":70386,"position":6,"arabic":"بَأْسُنَا","translation":"কঠোর শাস্তি আমাদের","audioUrl":"wbw/007_097_006.mp3","charTypeName":"word"},{"id":70387,"position":7,"arabic":"بَيَـٰتًۭا","translation":"রাত্রে","audioUrl":"wbw/007_097_007.mp3","charTypeName":"word"},{"id":70388,"position":8,"arabic":"وَهُمْ","translation":"যখন তারা","audioUrl":"wbw/007_097_008.mp3","charTypeName":"word"},{"id":70389,"position":9,"arabic":"نَآئِمُونَ","translation":"ঘুমন্ত থাকবে","audioUrl":"wbw/007_097_009.mp3","charTypeName":"word"},{"id":70390,"position":10,"arabic":"٩٧","translation":"(৯৭)","audioUrl":null,"charTypeName":"end"}]},{"number":98,"arabic":"أَوَأَمِنَ أَهْلُ ٱلْقُرَىٰٓ أَن يَأْتِيَهُم بَأْسُنَا ضُحًۭى وَهُمْ يَلْعَبُونَ","translation":"Why, can the people of any community ever feel secure that Our punishment will not come upon them in broad daylight, while they are engaged in (worldly] play?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1052.mp3","surahId":7,"words":[{"id":70678,"position":1,"arabic":"أَوَأَمِنَ","translation":"কিংবা নির্ভয় হয়েছে","audioUrl":"wbw/007_098_001.mp3","charTypeName":"word"},{"id":70679,"position":2,"arabic":"أَهْلُ","translation":"অধিবাসীরা","audioUrl":"wbw/007_098_002.mp3","charTypeName":"word"},{"id":70680,"position":3,"arabic":"ٱلْقُرَىٰٓ","translation":"জনপদের","audioUrl":"wbw/007_098_003.mp3","charTypeName":"word"},{"id":70681,"position":4,"arabic":"أَن","translation":"(এ বিপদ হতে) যে","audioUrl":"wbw/007_098_004.mp3","charTypeName":"word"},{"id":70682,"position":5,"arabic":"يَأْتِيَهُم","translation":"তাদের উপর আসবে","audioUrl":"wbw/007_098_005.mp3","charTypeName":"word"},{"id":70683,"position":6,"arabic":"بَأْسُنَا","translation":"শাস্তি আমাদের","audioUrl":"wbw/007_098_006.mp3","charTypeName":"word"},{"id":70684,"position":7,"arabic":"ضُحًۭى","translation":"দিনের বেলায়  (পুর্বাহ্নে)","audioUrl":"wbw/007_098_007.mp3","charTypeName":"word"},{"id":70685,"position":8,"arabic":"وَهُمْ","translation":"যখন তারা","audioUrl":"wbw/007_098_008.mp3","charTypeName":"word"},{"id":70686,"position":9,"arabic":"يَلْعَبُونَ","translation":"খেলায় মেতে থাকে","audioUrl":"wbw/007_098_009.mp3","charTypeName":"word"},{"id":70687,"position":10,"arabic":"٩٨","translation":"(৯৮)","audioUrl":null,"charTypeName":"end"}]},{"number":99,"arabic":"أَفَأَمِنُوا۟ مَكْرَ ٱللَّهِ ۚ فَلَا يَأْمَنُ مَكْرَ ٱللَّهِ إِلَّا ٱلْقَوْمُ ٱلْخَٰسِرُونَ","translation":"Can they, then, ever feel secure from God's deep devising? But none feels secure from God's deep devising save people who are [already] lost.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1053.mp3","surahId":7,"words":[{"id":71035,"position":1,"arabic":"أَفَأَمِنُوا۟","translation":"কি তবে তারা নির্ভয় হয়েছে","audioUrl":"wbw/007_099_001.mp3","charTypeName":"word"},{"id":71036,"position":2,"arabic":"مَكْرَ","translation":"পরিকল্পনা (হতে)","audioUrl":"wbw/007_099_002.mp3","charTypeName":"word"},{"id":71037,"position":3,"arabic":"ٱللَّهِ ۚ","translation":"আল্লাহর","audioUrl":"wbw/007_099_003.mp3","charTypeName":"word"},{"id":71039,"position":4,"arabic":"فَلَا","translation":"অথচ না","audioUrl":"wbw/007_099_005.mp3","charTypeName":"word"},{"id":71040,"position":5,"arabic":"يَأْمَنُ","translation":"নির্ভয়  হয়","audioUrl":"wbw/007_099_006.mp3","charTypeName":"word"},{"id":71041,"position":6,"arabic":"مَكْرَ","translation":"পরিকল্পনা(হতে)","audioUrl":"wbw/007_099_007.mp3","charTypeName":"word"},{"id":71042,"position":7,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/007_099_008.mp3","charTypeName":"word"},{"id":71043,"position":8,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/007_099_009.mp3","charTypeName":"word"},{"id":71044,"position":9,"arabic":"ٱلْقَوْمُ","translation":"(এমন) সম্প্রদায়","audioUrl":"wbw/007_099_010.mp3","charTypeName":"word"},{"id":71045,"position":10,"arabic":"ٱلْخَـٰسِرُونَ","translation":"(যারা) ক্ষতিগ্রস্ত","audioUrl":"wbw/007_099_011.mp3","charTypeName":"word"},{"id":71046,"position":11,"arabic":"٩٩","translation":"(৯৯)","audioUrl":null,"charTypeName":"end"}]},{"number":100,"arabic":"أَوَلَمْ يَهْدِ لِلَّذِينَ يَرِثُونَ ٱلْأَرْضَ مِنۢ بَعْدِ أَهْلِهَآ أَن لَّوْ نَشَآءُ أَصَبْنَٰهُم بِذُنُوبِهِمْ ۚ وَنَطْبَعُ عَلَىٰ قُلُوبِهِمْ فَهُمْ لَا يَسْمَعُونَ","translation":"Has it, then, not become obvious unto those who have inherited the earth in the wake of former generations that, if We so willed, We could smite them [too] by means of their sins, sealing their hearts so that they cannot hear [the truth]?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1054.mp3","surahId":7,"words":[{"id":71167,"position":1,"arabic":"أَوَلَمْ","translation":"কি নি","audioUrl":"wbw/007_100_001.mp3","charTypeName":"word"},{"id":71168,"position":2,"arabic":"يَهْدِ","translation":"সৎপথ পায়","audioUrl":"wbw/007_100_002.mp3","charTypeName":"word"},{"id":71169,"position":3,"arabic":"لِلَّذِينَ","translation":"কাছে তাদের(যাদেরকে)","audioUrl":"wbw/007_100_003.mp3","charTypeName":"word"},{"id":71170,"position":4,"arabic":"يَرِثُونَ","translation":"উত্তরাধিকারী করা হয়েছে","audioUrl":"wbw/007_100_004.mp3","charTypeName":"word"},{"id":71171,"position":5,"arabic":"ٱلْأَرْضَ","translation":"পৃথিবীর","audioUrl":"wbw/007_100_005.mp3","charTypeName":"word"},{"id":71172,"position":6,"arabic":"مِنۢ","translation":"থেকে","audioUrl":"wbw/007_100_006.mp3","charTypeName":"word"},{"id":71173,"position":7,"arabic":"بَعْدِ","translation":"পর","audioUrl":"wbw/007_100_007.mp3","charTypeName":"word"},{"id":71174,"position":8,"arabic":"أَهْلِهَآ","translation":"তার (পুর্ববর্তী) অধিবাসীদের","audioUrl":"wbw/007_100_008.mp3","charTypeName":"word"},{"id":71175,"position":9,"arabic":"أَن","translation":"যে","audioUrl":"wbw/007_100_009.mp3","charTypeName":"word"},{"id":71176,"position":10,"arabic":"لَّوْ","translation":"যদি","audioUrl":"wbw/007_100_010.mp3","charTypeName":"word"},{"id":71177,"position":11,"arabic":"نَشَآءُ","translation":"ইচ্ছে করি আমরা","audioUrl":"wbw/007_100_011.mp3","charTypeName":"word"},{"id":71178,"position":12,"arabic":"أَصَبْنَـٰهُم","translation":"শাস্তি দিবো আমরা তাদেরকে","audioUrl":"wbw/007_100_012.mp3","charTypeName":"word"},{"id":71179,"position":13,"arabic":"بِذُنُوبِهِمْ ۚ","translation":"কারণে পাপগুলোর তাদের","audioUrl":"wbw/007_100_013.mp3","charTypeName":"word"},{"id":71181,"position":14,"arabic":"وَنَطْبَعُ","translation":"এবং সীল লাগাবো","audioUrl":"wbw/007_100_015.mp3","charTypeName":"word"},{"id":71182,"position":15,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/007_100_016.mp3","charTypeName":"word"},{"id":71183,"position":16,"arabic":"قُلُوبِهِمْ","translation":"অন্তরগুলোর তাদের","audioUrl":"wbw/007_100_017.mp3","charTypeName":"word"},{"id":71184,"position":17,"arabic":"فَهُمْ","translation":"অতঃপর তারা","audioUrl":"wbw/007_100_018.mp3","charTypeName":"word"},{"id":71185,"position":18,"arabic":"لَا","translation":"না","audioUrl":"wbw/007_100_019.mp3","charTypeName":"word"},{"id":71186,"position":19,"arabic":"يَسْمَعُونَ","translation":"শুনবে","audioUrl":"wbw/007_100_020.mp3","charTypeName":"word"},{"id":71187,"position":20,"arabic":"١٠٠","translation":"(১০০)","audioUrl":null,"charTypeName":"end"}]},{"number":101,"arabic":"تِلْكَ ٱلْقُرَىٰ نَقُصُّ عَلَيْكَ مِنْ أَنۢبَآئِهَا ۚ وَلَقَدْ جَآءَتْهُمْ رُسُلُهُم بِٱلْبَيِّنَٰتِ فَمَا كَانُوا۟ لِيُؤْمِنُوا۟ بِمَا كَذَّبُوا۟ مِن قَبْلُ ۚ كَذَٰلِكَ يَطْبَعُ ٱللَّهُ عَلَىٰ قُلُوبِ ٱلْكَٰفِرِينَ","translation":"Unto those [earlier] communities - some of whose stories We [now] relate unto thee -there had indeed come apostles of their own with all evidence of the truth; but they would not believe in anything to which they had once given the lie: thus it is that God seals the hearts of those who deny the truth;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1055.mp3","surahId":7,"words":[{"id":71586,"position":1,"arabic":"تِلْكَ","translation":"এই (সব)","audioUrl":"wbw/007_101_001.mp3","charTypeName":"word"},{"id":71587,"position":2,"arabic":"ٱلْقُرَىٰ","translation":"জনপদসমূহ","audioUrl":"wbw/007_101_002.mp3","charTypeName":"word"},{"id":71588,"position":3,"arabic":"نَقُصُّ","translation":"বর্ণনা করেছি আমরা","audioUrl":"wbw/007_101_003.mp3","charTypeName":"word"},{"id":71589,"position":4,"arabic":"عَلَيْكَ","translation":"কাছে তোমার","audioUrl":"wbw/007_101_004.mp3","charTypeName":"word"},{"id":71590,"position":5,"arabic":"مِنْ","translation":"কিছু","audioUrl":"wbw/007_101_005.mp3","charTypeName":"word"},{"id":71591,"position":6,"arabic":"أَنۢبَآئِهَا ۚ","translation":"বৃত্তান্তগুলোর তাদের","audioUrl":"wbw/007_101_006.mp3","charTypeName":"word"},{"id":71593,"position":7,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/007_101_008.mp3","charTypeName":"word"},{"id":71594,"position":8,"arabic":"جَآءَتْهُمْ","translation":"কাছে এসেছিলো তাদের","audioUrl":"wbw/007_101_009.mp3","charTypeName":"word"},{"id":71595,"position":9,"arabic":"رُسُلُهُم","translation":"রাসূলগণ তাদের","audioUrl":"wbw/007_101_010.mp3","charTypeName":"word"},{"id":71596,"position":10,"arabic":"بِٱلْبَيِّنَـٰتِ","translation":"সহ স্পষ্ট প্রমাণ","audioUrl":"wbw/007_101_011.mp3","charTypeName":"word"},{"id":71597,"position":11,"arabic":"فَمَا","translation":"আসলে না","audioUrl":"wbw/007_101_012.mp3","charTypeName":"word"},{"id":71598,"position":12,"arabic":"كَانُوا۟","translation":"তারা ছিলো (এমন)","audioUrl":"wbw/007_101_013.mp3","charTypeName":"word"},{"id":71599,"position":13,"arabic":"لِيُؤْمِنُوا۟","translation":"যে তারা ঈমান আনবে","audioUrl":"wbw/007_101_014.mp3","charTypeName":"word"},{"id":71600,"position":14,"arabic":"بِمَا","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/007_101_015.mp3","charTypeName":"word"},{"id":71601,"position":15,"arabic":"كَذَّبُوا۟","translation":"তারা প্রত্যাখ্যান করেছে","audioUrl":"wbw/007_101_016.mp3","charTypeName":"word"},{"id":71602,"position":16,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/007_101_017.mp3","charT