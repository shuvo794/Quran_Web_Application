{"id":580,"ayahs":[{"number":26,"arabic":"وَمِنَ ٱلَّيْلِ فَٱسْجُدْ لَهُۥ وَسَبِّحْهُ لَيْلًۭا طَوِيلًا","translation":"and during some of the night, and prostrate thyself before Him, and extol His limitless glory throughout the long night.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5617.mp3","surahId":76,"words":[{"id":29162,"position":1,"arabic":"وَمِنَ","translation":"মধ্য হতে","audioUrl":"wbw/076_026_001.mp3","charTypeName":"word"},{"id":29163,"position":2,"arabic":"ٱلَّيْلِ","translation":"রাতে","audioUrl":"wbw/076_026_002.mp3","charTypeName":"word"},{"id":29164,"position":3,"arabic":"فَٱسْجُدْ","translation":"সিজদা অতঃপর করো","audioUrl":"wbw/076_026_003.mp3","charTypeName":"word"},{"id":29165,"position":4,"arabic":"لَهُۥ","translation":"তাকে","audioUrl":"wbw/076_026_004.mp3","charTypeName":"word"},{"id":29166,"position":5,"arabic":"وَسَبِّحْهُ","translation":"এবং তাঁর তসবিহ কর","audioUrl":"wbw/076_026_005.mp3","charTypeName":"word"},{"id":29167,"position":6,"arabic":"لَيْلًۭا","translation":"রাতে","audioUrl":"wbw/076_026_006.mp3","charTypeName":"word"},{"id":29168,"position":7,"arabic":"طَوِيلًا","translation":"দীর্ঘ","audioUrl":"wbw/076_026_007.mp3","charTypeName":"word"},{"id":29169,"position":8,"arabic":"٢٦","translation":"(২৬)","audioUrl":null,"charTypeName":"end"}]},{"number":27,"arabic":"إِنَّ هَٰٓؤُلَآءِ يُحِبُّونَ ٱلْعَاجِلَةَ وَيَذَرُونَ وَرَآءَهُمْ يَوْمًۭا ثَقِيلًۭا","translation":"Behold, they [who are unmindful of God] love this fleeting life, and leave behind them [all thought of] a grief-laden Day.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5618.mp3","surahId":76,"words":[{"id":29906,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়","audioUrl":"wbw/076_027_001.mp3","charTypeName":"word"},{"id":29907,"position":2,"arabic":"هَـٰٓؤُلَآءِ","translation":"ঐসব লোক","audioUrl":"wbw/076_027_002.mp3","charTypeName":"word"},{"id":29908,"position":3,"arabic":"يُحِبُّونَ","translation":"ভালবাসে","audioUrl":"wbw/076_027_003.mp3","charTypeName":"word"},{"id":29909,"position":4,"arabic":"ٱلْعَاجِلَةَ","translation":"দ্রুত অর্জিত ( বৈষয়িক স্বার্থ)","audioUrl":"wbw/076_027_004.mp3","charTypeName":"word"},{"id":29910,"position":5,"arabic":"وَيَذَرُونَ","translation":"এবং তারা উপেক্ষা করে","audioUrl":"wbw/076_027_005.mp3","charTypeName":"word"},{"id":29911,"position":6,"arabic":"وَرَآءَهُمْ","translation":"তাদের পিছনে","audioUrl":"wbw/076_027_006.mp3","charTypeName":"word"},{"id":29912,"position":7,"arabic":"يَوْمًۭا","translation":"দিনকে","audioUrl":"wbw/076_027_007.mp3","charTypeName":"word"},{"id":29913,"position":8,"arabic":"ثَقِيلًۭا","translation":"ভারী","audioUrl":"wbw/076_027_008.mp3","charTypeName":"word"},{"id":29914,"position":9,"arabic":"٢٧","translation":"(২৭)","audioUrl":null,"charTypeName":"end"}]},{"number":28,"arabic":"نَّحْنُ خَلَقْنَٰهُمْ وَشَدَدْنَآ أَسْرَهُمْ ۖ وَإِذَا شِئْنَا بَدَّلْنَآ أَمْثَٰلَهُمْ تَبْدِيلًا","translation":"[They will not admit to themselves that] it We who have created them and strengthened their make - and [that] if it be Our will We can replace them entirely with others of their kind.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5619.mp3","surahId":76,"words":[{"id":31141,"position":1,"arabic":"نَّحْنُ","translation":"আমরা","audioUrl":"wbw/076_028_001.mp3","charTypeName":"word"},{"id":31142,"position":2,"arabic":"خَلَقْنَـٰهُمْ","translation":"তাদের আমরা সৃষ্টি করেছি","audioUrl":"wbw/076_028_002.mp3","charTypeName":"word"},{"id":31143,"position":3,"arabic":"وَشَدَدْنَآ","translation":"এবং আমরা সুদৃঢ় করেছি","audioUrl":"wbw/076_028_003.mp3","charTypeName":"word"},{"id":31144,"position":4,"arabic":"أَسْرَهُمْ ۖ","translation":"তাদের জোড়ন","audioUrl":"wbw/076_028_004.mp3","charTypeName":"word"},{"id":31146,"position":5,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/076_028_006.mp3","charTypeName":"word"},{"id":31147,"position":6,"arabic":"شِئْنَا","translation":"আমরা চাইবো","audioUrl":"wbw/076_028_007.mp3","charTypeName":"word"},{"id":31148,"position":7,"arabic":"بَدَّلْنَآ","translation":"আমরা বদলে দেবো","audioUrl":"wbw/076_028_008.mp3","charTypeName":"word"},{"id":31149,"position":8,"arabic":"أَمْثَـٰلَهُمْ","translation":"তাদের আকৃতি সমূহ","audioUrl":"wbw/076_028_009.mp3","charTypeName":"word"},{"id":31150,"position":9,"arabic":"تَبْدِيلًا","translation":"পরিবর্তন করে","audioUrl":"wbw/076_028_010.mp3","charTypeName":"word"},{"id":31151,"position":10,"arabic":"٢٨","translation":"(২৮)","audioUrl":null,"charTypeName":"end"}]},{"number":29,"arabic":"إِنَّ هَٰذِهِۦ تَذْكِرَةٌۭ ۖ فَمَن شَآءَ ٱتَّخَذَ إِلَىٰ رَبِّهِۦ سَبِيلًۭا","translation":"VERILY, all this is an admonition: whoever, then, so wills, may unto his Sustainer find a way.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5620.mp3","surahId":76,"words":[{"id":31985,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়","audioUrl":"wbw/076_029_001.mp3","charTypeName":"word"},{"id":31986,"position":2,"arabic":"هَـٰذِهِۦ","translation":"এটা","audioUrl":"wbw/076_029_002.mp3","charTypeName":"word"},{"id":31987,"position":3,"arabic":"تَذْكِرَةٌۭ ۖ","translation":"নসীহত","audioUrl":"wbw/076_029_003.mp3","charTypeName":"word"},{"id":31989,"position":4,"arabic":"فَمَن","translation":"যে অতএব","audioUrl":"wbw/076_029_005.mp3","charTypeName":"word"},{"id":31990,"position":5,"arabic":"شَآءَ","translation":"চায়","audioUrl":"wbw/076_029_006.mp3","charTypeName":"word"},{"id":31991,"position":6,"arabic":"ٱتَّخَذَ","translation":"গ্রহন করবে","audioUrl":"wbw/076_029_007.mp3","charTypeName":"word"},{"id":31992,"position":7,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/076_029_008.mp3","charTypeName":"word"},{"id":31993,"position":8,"arabic":"رَبِّهِۦ","translation":"তার রবের","audioUrl":"wbw/076_029_009.mp3","charTypeName":"word"},{"id":31994,"position":9,"arabic":"سَبِيلًۭا","translation":"পথ","audioUrl":"wbw/076_029_010.mp3","charTypeName":"word"},{"id":31995,"position":10,"arabic":"٢٩","translation":"(২৯)","audioUrl":null,"charTypeName":"end"}]},{"number":30,"arabic":"وَمَا تَشَآءُونَ إِلَّآ أَن يَشَآءَ ٱللَّهُ ۚ إِنَّ ٱللَّهَ كَانَ عَلِيمًا حَكِيمًۭا","translation":"But you cannot will it unless God wills [to show you that way]: for, behold, God is indeed all-seeing, wise.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5621.mp3","surahId":76,"words":[{"id":32874,"position":1,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/076_030_001.mp3","charTypeName":"word"},{"id":32875,"position":2,"arabic":"تَشَآءُونَ","translation":"তোমরা চাও","audioUrl":"wbw/076_030_002.mp3","charTypeName":"word"},{"id":32876,"position":3,"arabic":"إِلَّآ","translation":"এছাড়া","audioUrl":"wbw/076_030_003.mp3","charTypeName":"word"},{"id":32877,"position":4,"arabic":"أَن","translation":"যে","audioUrl":"wbw/076_030_004.mp3","charTypeName":"word"},{"id":32878,"position":5,"arabic":"يَشَآءَ","translation":"চান","audioUrl":"wbw/076_030_005.mp3","charTypeName":"word"},{"id":32879,"position":6,"arabic":"ٱللَّهُ ۚ","translation":"আল্লাহ","audioUrl":"wbw/076_030_006.mp3","charTypeName":"word"},{"id":32881,"position":7,"arabic":"إِنَّ","translation":"নিশ্চয়","audioUrl":"wbw/076_030_008.mp3","charTypeName":"word"},{"id":32882,"position":8,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/076_030_009.mp3","charTypeName":"word"},{"id":32883,"position":9,"arabic":"كَانَ","translation":"হলেন","audioUrl":"wbw/076_030_010.mp3","charTypeName":"word"},{"id":32884,"position":10,"arabic":"عَلِيمًا","translation":"সর্বজ্ঞ","audioUrl":"wbw/076_030_011.mp3","charTypeName":"word"},{"id":32885,"position":11,"arabic":"حَكِيمًۭا","translation":"প্রজ্ঞাময়","audioUrl":"wbw/076_030_012.mp3","charTypeName":"word"},{"id":32886,"position":12,"arabic":"٣٠","translation":"(৩০)","audioUrl":null,"charTypeName":"end"}]},{"number":31,"arabic":"يُدْخِلُ مَن يَشَآءُ فِى رَحْمَتِهِۦ ۚ وَٱلظَّٰلِمِينَ أَعَدَّ لَهُمْ عَذَابًا أَلِيمًۢا","translation":"He admits unto His grace everyone who wills [to be admitted]; but as for the evildoers - for them has He readied grievous suffering [in the life to come].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5622.mp3","surahId":76,"words":[{"id":33277,"position":1,"arabic":"يُدْخِلُ","translation":"প্রবেশ করান","audioUrl":"wbw/076_031_001.mp3","charTypeName":"word"},{"id":33278,"position":2,"arabic":"مَن","translation":"যাকে","audioUrl":"wbw/076_031_002.mp3","charTypeName":"word"},{"id":33279,"position":3,"arabic":"يَشَآءُ","translation":"তিনি চান","audioUrl":"wbw/076_031_003.mp3","charTypeName":"word"},{"id":33280,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/076_031_004.mp3","charTypeName":"word"},{"id":33281,"position":5,"arabic":"رَحْمَتِهِۦ ۚ","translation":"তাঁর রহমতের","audioUrl":"wbw/076_031_005.mp3","charTypeName":"word"},{"id":33283,"position":6,"arabic":"وَٱلظَّـٰلِمِينَ","translation":"এবং যালেমদের","audioUrl":"wbw/076_031_007.mp3","charTypeName":"word"},{"id":33284,"position":7,"arabic":"أَعَدَّ","translation":"প্রস্তুত রেখেছেন","audioUrl":"wbw/076_031_008.mp3","charTypeName":"word"},{"id":33285,"position":8,"arabic":"لَهُمْ","translation":"তাদের জন্যে","audioUrl":"wbw/076_031_009.mp3","charTypeName":"word"},{"id":33286,"position":9,"arabic":"عَذَابًا","translation":"আযাব","audioUrl":"wbw/076_031_010.mp3","charTypeName":"word"},{"id":33287,"position":10,"arabic":"أَلِيمًۢا","translation":"বড় পীড়াদায়ক","audioUrl":"wbw/076_031_011.mp3","charTypeName":"word"},{"id":33288,"position":11,"arabic":"٣١","translation":"(৩১)","audioUrl":null,"charTypeName":"end"}]},{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلْمُرْسَلَٰتِ عُرْفًۭا","translation":"CONSIDER these [messages,] sent forth in waves","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5623.mp3","surahId":77,"words":[{"id":673,"position":1,"arabic":"وَٱلْمُرْسَلَـٰتِ","translation":"শপথ প্রেরিত (বায়ুর)","audioUrl":"wbw/077_001_001.mp3","charTypeName":"word"},{"id":674,"position":2,"arabic":"عُرْفًۭا","translation":"কল্যাণ সুরূপ","audioUrl":"wbw/077_001_002.mp3","charTypeName":"word"},{"id":675,"position":3,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"فَٱلْعَٰصِفَٰتِ عَصْفًۭا","translation":"and then storming on with a tempest's force!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5624.mp3","surahId":77,"words":[{"id":1659,"position":1,"arabic":"فَٱلْعَـٰصِفَـٰتِ","translation":"অতঃপর ঝটিকার","audioUrl":"wbw/077_002_001.mp3","charTypeName":"word"},{"id":1660,"position":2,"arabic":"عَصْفًۭا","translation":"প্রলংকরী","audioUrl":"wbw/077_002_002.mp3","charTypeName":"word"},{"id":1661,"position":3,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"وَٱلنَّٰشِرَٰتِ نَشْرًۭا","translation":"Consider these [messages] that spread [the truth] far and wide,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5625.mp3","surahId":77,"words":[{"id":2790,"position":1,"arabic":"وَٱلنَّـٰشِرَٰتِ","translation":"এবং (মেঘপুঞ্জ) বিস্তারকারী (বায়ুর)","audioUrl":"wbw/077_003_001.mp3","charTypeName":"word"},{"id":2791,"position":2,"arabic":"نَشْرًۭا","translation":"বিস্তার করা","audioUrl":"wbw/077_003_002.mp3","charTypeName":"word"},{"id":2792,"position":3,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"فَٱلْفَٰرِقَٰتِ فَرْقًۭا","translation":"thus separating [right and wrong] with all clarity,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5626.mp3","surahId":77,"words":[{"id":4142,"position":1,"arabic":"فَٱلْفَـٰرِقَـٰتِ","translation":"প্রৃথককারী (বায়ুর) অতংপর","audioUrl":"wbw/077_004_001.mp3","charTypeName":"word"},{"id":4143,"position":2,"arabic":"فَرْقًۭا","translation":"পৃথক করা (মেঘকে)","audioUrl":"wbw/077_004_002.mp3","charTypeName":"word"},{"id":4144,"position":3,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"فَٱلْمُلْقِيَٰتِ ذِكْرًا","translation":"and then giving forth a reminder,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5627.mp3","surahId":77,"words":[{"id":5433,"position":1,"arabic":"فَٱلْمُلْقِيَـٰتِ","translation":"অতংপর জাগ্রতকারীদের (অন্তরে)","audioUrl":"wbw/077_005_001.mp3","charTypeName":"word"},{"id":5434,"position":2,"arabic":"ذِكْرًا","translation":"উপদেশ","audioUrl":"wbw/077_005_002.mp3","charTypeName":"word"},{"id":5435,"position":3,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"عُذْرًا أَوْ نُذْرًا","translation":"[promising] freedom from blame or [offering] a warning!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5628.mp3","surahId":77,"words":[{"id":6648,"position":1,"arabic":"عُذْرًا","translation":"অনুশোচনা করা","audioUrl":"wbw/077_006_001.mp3","charTypeName":"word"},{"id":6649,"position":2,"arabic":"أَوْ","translation":"বা","audioUrl":"wbw/077_006_002.mp3","charTypeName":"word"},{"id":6650,"position":3,"arabic":"نُذْرًا","translation":"সতর্কতা সুরূপ","audioUrl":"wbw/077_006_003.mp3","charTypeName":"word"},{"id":6651,"position":4,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"إِنَّمَا تُوعَدُونَ لَوَٰقِعٌۭ","translation":"BEHOLD, all that you are told to expect will surely come to pass.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5629.mp3","surahId":77,"words":[{"id":8009,"position":1,"arabic":"إِنَّمَا","translation":"(যা) মূলতঃ","audioUrl":"wbw/077_007_001.mp3","charTypeName":"word"},{"id":8010,"position":2,"arabic":"تُوعَدُونَ","translation":"তোমাদের ওয়াদা করা হয়েছে","audioUrl":"wbw/077_007_002.mp3","charTypeName":"word"},{"id":8011,"position":3,"arabic":"لَوَٰقِعٌۭ","translation":"সংঘটিত হবে অবশ্যই","audioUrl":"wbw/077_007_003.mp3","charTypeName":"word"},{"id":8012,"position":4,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"فَإِذَا ٱلنُّجُومُ ط