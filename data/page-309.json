{"id":309,"ayahs":[{"number":52,"arabic":"وَنَٰدَيْنَٰهُ مِن جَانِبِ ٱلطُّورِ ٱلْأَيْمَنِ وَقَرَّبْنَٰهُ نَجِيًّۭا","translation":"And [remember how] We called upon him from the right-hand slope of Mount Sinai and drew him near [unto Us] in mystic communion,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2302.mp3","surahId":19,"words":[{"id":50285,"position":1,"arabic":"وَنَـٰدَيْنَـٰهُ","translation":"এবং তাকে আমরা ডেকেছি","audioUrl":"wbw/019_052_001.mp3","charTypeName":"word"},{"id":50286,"position":2,"arabic":"مِن","translation":"হ'তে","audioUrl":"wbw/019_052_002.mp3","charTypeName":"word"},{"id":50287,"position":3,"arabic":"جَانِبِ","translation":"দিক","audioUrl":"wbw/019_052_003.mp3","charTypeName":"word"},{"id":50288,"position":4,"arabic":"ٱلطُّورِ","translation":"তুর (পাহাড়ের)","audioUrl":"wbw/019_052_004.mp3","charTypeName":"word"},{"id":50289,"position":5,"arabic":"ٱلْأَيْمَنِ","translation":"ডান (দিক)","audioUrl":"wbw/019_052_005.mp3","charTypeName":"word"},{"id":50290,"position":6,"arabic":"وَقَرَّبْنَـٰهُ","translation":"এবং তাকে আমরা কাছে টেনেছিলাম","audioUrl":"wbw/019_052_006.mp3","charTypeName":"word"},{"id":50291,"position":7,"arabic":"نَجِيًّۭا","translation":"অন্তরঙ্গ আলাপের জন্যে","audioUrl":"wbw/019_052_007.mp3","charTypeName":"word"},{"id":50292,"position":8,"arabic":"٥٢","translation":"(৫২)","audioUrl":null,"charTypeName":"end"}]},{"number":53,"arabic":"وَوَهَبْنَا لَهُۥ مِن رَّحْمَتِنَآ أَخَاهُ هَٰرُونَ نَبِيًّۭا","translation":"and [how], out of Our grace, We granted unto him his brother Aaron, to be a prophet [by his side].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2303.mp3","surahId":19,"words":[{"id":50853,"position":1,"arabic":"وَوَهَبْنَا","translation":"এবং আমরা বানালাম","audioUrl":"wbw/019_053_001.mp3","charTypeName":"word"},{"id":50854,"position":2,"arabic":"لَهُۥ","translation":"তার জন্যে","audioUrl":"wbw/019_053_002.mp3","charTypeName":"word"},{"id":50855,"position":3,"arabic":"مِن","translation":"হ'তে","audioUrl":"wbw/019_053_003.mp3","charTypeName":"word"},{"id":50856,"position":4,"arabic":"رَّحْمَتِنَآ","translation":"আমাদের অনুগ্রহ","audioUrl":"wbw/019_053_004.mp3","charTypeName":"word"},{"id":50857,"position":5,"arabic":"أَخَاهُ","translation":"তার ভাই","audioUrl":"wbw/019_053_005.mp3","charTypeName":"word"},{"id":50858,"position":6,"arabic":"هَـٰرُونَ","translation":"হারুনকে","audioUrl":"wbw/019_053_006.mp3","charTypeName":"word"},{"id":50859,"position":7,"arabic":"نَبِيًّۭا","translation":"নাবীরূপে","audioUrl":"wbw/019_053_007.mp3","charTypeName":"word"},{"id":50860,"position":8,"arabic":"٥٣","translation":"(৫৩)","audioUrl":null,"charTypeName":"end"}]},{"number":54,"arabic":"وَٱذْكُرْ فِى ٱلْكِتَٰبِ إِسْمَٰعِيلَ ۚ إِنَّهُۥ كَانَ صَادِقَ ٱلْوَعْدِ وَكَانَ رَسُولًۭا نَّبِيًّۭا","translation":"AND CALL to mind, through this divine writ, Ishmael. Behold, he was always true to his promise, and was an apostle [of God], a prophet,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2304.mp3","surahId":19,"words":[{"id":51106,"position":1,"arabic":"وَٱذْكُرْ","translation":"এবং স্মরণ করো","audioUrl":"wbw/019_054_001.mp3","charTypeName":"word"},{"id":51107,"position":2,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/019_054_002.mp3","charTypeName":"word"},{"id":51108,"position":3,"arabic":"ٱلْكِتَـٰبِ","translation":"কিতাবের","audioUrl":"wbw/019_054_003.mp3","charTypeName":"word"},{"id":51109,"position":4,"arabic":"إِسْمَـٰعِيلَ ۚ","translation":"ইসমাইলকে","audioUrl":"wbw/019_054_004.mp3","charTypeName":"word"},{"id":51111,"position":5,"arabic":"إِنَّهُۥ","translation":"সে নিশ্চয়ই","audioUrl":"wbw/019_054_006.mp3","charTypeName":"word"},{"id":51112,"position":6,"arabic":"كَانَ","translation":"ছিলো","audioUrl":"wbw/019_054_007.mp3","charTypeName":"word"},{"id":51113,"position":7,"arabic":"صَادِقَ","translation":"সত্যতা রক্ষাকারী","audioUrl":"wbw/019_054_008.mp3","charTypeName":"word"},{"id":51114,"position":8,"arabic":"ٱلْوَعْدِ","translation":"প্রতিশ্রুতির","audioUrl":"wbw/019_054_009.mp3","charTypeName":"word"},{"id":51115,"position":9,"arabic":"وَكَانَ","translation":"এবং ছিলো","audioUrl":"wbw/019_054_010.mp3","charTypeName":"word"},{"id":51116,"position":10,"arabic":"رَسُولًۭا","translation":"রাসূল","audioUrl":"wbw/019_054_011.mp3","charTypeName":"word"},{"id":51117,"position":11,"arabic":"نَّبِيًّۭا","translation":"নাবী","audioUrl":"wbw/019_054_012.mp3","charTypeName":"word"},{"id":51118,"position":12,"arabic":"٥٤","translation":"(৫৪)","audioUrl":null,"charTypeName":"end"}]},{"number":55,"arabic":"وَكَانَ يَأْمُرُ أَهْلَهُۥ بِٱلصَّلَوٰةِ وَٱلزَّكَوٰةِ وَكَانَ عِندَ رَبِّهِۦ مَرْضِيًّۭا","translation":"who used to enjoin upon his people prayer and charity, and found favour in his Sustainer's sight.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2305.mp3","surahId":19,"words":[{"id":51971,"position":1,"arabic":"وَكَانَ","translation":"এবং","audioUrl":"wbw/019_055_001.mp3","charTypeName":"word"},{"id":51972,"position":2,"arabic":"يَأْمُرُ","translation":"আদেশ দিতো","audioUrl":"wbw/019_055_002.mp3","charTypeName":"word"},{"id":51973,"position":3,"arabic":"أَهْلَهُۥ","translation":"তার পরিজনবর্গকে","audioUrl":"wbw/019_055_003.mp3","charTypeName":"word"},{"id":51974,"position":4,"arabic":"بِٱلصَّلَوٰةِ","translation":"সালাতের ব্যাপারে","audioUrl":"wbw/019_055_004.mp3","charTypeName":"word"},{"id":51975,"position":5,"arabic":"وَٱلزَّكَوٰةِ","translation":"ও যাকাতের","audioUrl":"wbw/019_055_005.mp3","charTypeName":"word"},{"id":51976,"position":6,"arabic":"وَكَانَ","translation":"এবং সে ছিলো","audioUrl":"wbw/019_055_006.mp3","charTypeName":"word"},{"id":51977,"position":7,"arabic":"عِندَ","translation":"কাছে","audioUrl":"wbw/019_055_007.mp3","charTypeName":"word"},{"id":51978,"position":8,"arabic":"رَبِّهِۦ","translation":"তার রবের","audioUrl":"wbw/019_055_008.mp3","charTypeName":"word"},{"id":51979,"position":9,"arabic":"مَرْضِيًّۭا","translation":"প্রিয়পাত্র","audioUrl":"wbw/019_055_009.mp3","charTypeName":"word"},{"id":51980,"position":10,"arabic":"٥٥","translation":"(৫৫)","audioUrl":null,"charTypeName":"end"}]},{"number":56,"arabic":"وَٱذْكُرْ فِى ٱلْكِتَٰبِ إِدْرِيسَ ۚ إِنَّهُۥ كَانَ صِدِّيقًۭا نَّبِيًّۭا","translation":"AND CALL to mind, through this divine writ, Idris. Behold, he was a man of truth, a prophet,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2306.mp3","surahId":19,"words":[{"id":52367,"position":1,"arabic":"وَٱذْكُرْ","translation":"এবং উল্লেখ করো (যা)","audioUrl":"wbw/019_056_001.mp3","charTypeName":"word"},{"id":52368,"position":2,"arabic":"فِى","translation":"মধ্যে (বলা হচ্ছে)","audioUrl":"wbw/019_056_002.mp3","charTypeName":"word"},{"id":52369,"position":3,"arabic":"ٱلْكِتَـٰبِ","translation":"(এই) কিতাবের","audioUrl":"wbw/019_056_003.mp3","charTypeName":"word"},{"id":52370,"position":4,"arabic":"إِدْرِيسَ ۚ","translation":"ইদরীস (সম্পর্কে)","audioUrl":"wbw/019_056_004.mp3","charTypeName":"word"},{"id":52372,"position":5,"arabic":"إِنَّهُۥ","translation":"সে নিশ্চয়ই","audioUrl":"wbw/019_056_006.mp3","charTypeName":"word"},{"id":52373,"position":6,"arabic":"كَانَ","translation":"ছিলো","audioUrl":"wbw/019_056_007.mp3","charTypeName":"word"},{"id":52374,"position":7,"arabic":"صِدِّيقًۭا","translation":"সত্যনিষ্ঠ","audioUrl":"wbw/019_056_008.mp3","charTypeName":"word"},{"id":52375,"position":8,"arabic":"نَّبِيًّۭا","translation":"নাবী","audioUrl":"wbw/019_056_009.mp3","charTypeName":"word"},{"id":52376,"position":9,"arabic":"٥٦","translation":"(৫৬)","audioUrl":null,"charTypeName":"end"}]},{"number":57,"arabic":"وَرَفَعْنَٰهُ مَكَانًا عَلِيًّا","translation":"whom We exalted onto a lofty station.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2307.mp3","surahId":19,"words":[{"id":52730,"position":1,"arabic":"وَرَفَعْنَـٰهُ","translation":"এবং তাকে আমরা উন্নীত করেছিলাম","audioUrl":"wbw/019_057_001.mp3","charTypeName":"word"},{"id":52731,"position":2,"arabic":"مَكَانًا","translation":"স্থা