{"id":510,"ayahs":[{"number":30,"arabic":"وَلَوْ نَشَآءُ لَأَرَيْنَٰكَهُمْ فَلَعَرَفْتَهُم بِسِيمَٰهُمْ ۚ وَلَتَعْرِفَنَّهُمْ فِى لَحْنِ ٱلْقَوْلِ ۚ وَٱللَّهُ يَعْلَمُ أَعْمَٰلَكُمْ","translation":"Now had We so willed, We could have shown them clearly to thee, so that thou wouldst know them for sure as by a visible mark: but [even so,] thou wilt most certainly recognize them by the tone of their voice. And God knows all that you do, [O men;]","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4575.mp3","surahId":47,"words":[{"id":32568,"position":1,"arabic":"وَلَوْ","translation":"এবং যদি","audioUrl":"wbw/047_030_001.mp3","charTypeName":"word"},{"id":32569,"position":2,"arabic":"نَشَآءُ","translation":"আমরা ইচ্ছে করি","audioUrl":"wbw/047_030_002.mp3","charTypeName":"word"},{"id":32570,"position":3,"arabic":"لَأَرَيْنَـٰكَهُمْ","translation":"আমরা অবশ্যই তাদের দেখাতে পারি","audioUrl":"wbw/047_030_003.mp3","charTypeName":"word"},{"id":32571,"position":4,"arabic":"فَلَعَرَفْتَهُم","translation":"তুমি তখন তাদের চিনবেই","audioUrl":"wbw/047_030_004.mp3","charTypeName":"word"},{"id":32572,"position":5,"arabic":"بِسِيمَـٰهُمْ ۚ","translation":"দ্বারা তাদের লক্ষণগুলো","audioUrl":"wbw/047_030_005.mp3","charTypeName":"word"},{"id":32574,"position":6,"arabic":"وَلَتَعْرِفَنَّهُمْ","translation":"এবং তাদেরকে তুমি অবশ্যই চিনবে","audioUrl":"wbw/047_030_007.mp3","charTypeName":"word"},{"id":32575,"position":7,"arabic":"فِى","translation":"আছে","audioUrl":"wbw/047_030_008.mp3","charTypeName":"word"},{"id":32576,"position":8,"arabic":"لَحْنِ","translation":"ভংগিতে","audioUrl":"wbw/047_030_009.mp3","charTypeName":"word"},{"id":32577,"position":9,"arabic":"ٱلْقَوْلِ ۚ","translation":"কথা (বলার)","audioUrl":"wbw/047_030_010.mp3","charTypeName":"word"},{"id":32579,"position":10,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ্‌ই","audioUrl":"wbw/047_030_012.mp3","charTypeName":"word"},{"id":32580,"position":11,"arabic":"يَعْلَمُ","translation":"জানেন","audioUrl":"wbw/047_030_013.mp3","charTypeName":"word"},{"id":32581,"position":12,"arabic":"أَعْمَـٰلَكُمْ","translation":"তোমাদের কর্মসমূহকে","audioUrl":"wbw/047_030_014.mp3","charTypeName":"word"},{"id":32582,"position":13,"arabic":"٣٠","translation":"(৩০)","audioUrl":null,"charTypeName":"end"}]},{"number":31,"arabic":"وَلَنَبْلُوَنَّكُمْ حَتَّىٰ نَعْلَمَ ٱلْمُجَٰهِدِينَ مِنكُمْ وَٱلصَّٰبِرِينَ وَنَبْلُوَا۟ أَخْبَارَكُمْ","translation":"and most certainly We shall try you all, so that We might mark out those of you who strive hard [in Our cause] and are patient in adversity: for We shall put to a test [the truth of] all your assertions.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4576.mp3","surahId":47,"words":[{"id":33458,"position":1,"arabic":"وَلَنَبْلُوَنَّكُمْ","translation":"এবং তোমাদের পরীক্ষা করব  আমরা অবশ্যই","audioUrl":"wbw/047_031_001.mp3","charTypeName":"word"},{"id":33459,"position":2,"arabic":"حَتَّىٰ","translation":"যতক্ষণ না","audioUrl":"wbw/047_031_002.mp3","charTypeName":"word"},{"id":33460,"position":3,"arabic":"نَعْلَمَ","translation":"আমরা জানবো","audioUrl":"wbw/047_031_003.mp3","charTypeName":"word"},{"id":33461,"position":4,"arabic":"ٱلْمُجَـٰهِدِينَ","translation":"মুজাহিদদেরকে","audioUrl":"wbw/047_031_004.mp3","charTypeName":"word"},{"id":33462,"position":5,"arabic":"مِنكُمْ","translation":"তোমাদের মধ্যকার","audioUrl":"wbw/047_031_005.mp3","charTypeName":"word"},{"id":33463,"position":6,"arabic":"وَٱلصَّـٰبِرِينَ","translation":"ও ধৈর্যশীলদেরকে","audioUrl":"wbw/047_031_006.mp3","charTypeName":"word"},{"id":33464,"position":7,"arabic":"وَنَبْلُوَا۟","translation":"এবং আমরা পরীক্ষা করবো","audioUrl":"wbw/047_031_007.mp3","charTypeName":"word"},{"id":33465,"position":8,"arabic":"أَخْبَارَكُمْ","translation":"তোমাদের খবরাদি","audioUrl":"wbw/047_031_008.mp3","charTypeName":"word"},{"id":33466,"position":9,"arabic":"٣١","translation":"(৩১)","audioUrl":null,"charTypeName":"end"}]},{"number":32,"arabic":"إِنَّ ٱلَّذِينَ كَفَرُوا۟ وَصَدُّوا۟ عَن سَبِيلِ ٱللَّهِ وَشَآقُّوا۟ ٱلرَّسُولَ مِنۢ بَعْدِ مَا تَبَيَّنَ لَهُمُ ٱلْهُدَىٰ لَن يَضُرُّوا۟ ٱللَّهَ شَيْـًۭٔا وَسَيُحْبِطُ أَعْمَٰلَهُمْ","translation":"Verily, they who are bent on denying the truth and on barring [others] from the path of God, and [who thus] cut themselves off from the Apostle after guidance has been vouchsafed to them, can in no wise harm God; but He will cause all their deeds to come to nought.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4577.mp3","surahId":47,"words":[{"id":34484,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/047_032_001.mp3","charTypeName":"word"},{"id":34485,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/047_032_002.mp3","charTypeName":"word"},{"id":34486,"position":3,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/047_032_003.mp3","charTypeName":"word"},{"id":34487,"position":4,"arabic":"وَصَدُّوا۟","translation":"ও বাধা দিয়েছে (লোকদেরকে)","audioUrl":"wbw/047_032_004.mp3","charTypeName":"word"},{"id":34488,"position":5,"arabic":"عَن","translation":"হতে","audioUrl":"wbw/047_032_005.mp3","charTypeName":"word"},{"id":34489,"position":6,"arabic":"سَبِيلِ","translation":"পথ","audioUrl":"wbw/047_032_006.mp3","charTypeName":"word"},{"id":34490,"position":7,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌র","audioUrl":"wbw/047_032_007.mp3","charTypeName":"word"},{"id":34491,"position":8,"arabic":"وَشَآقُّوا۟","translation":"এবং বিরোধিতা করেছে","audioUrl":"wbw/047_032_008.mp3","charTypeName":"word"},{"id":34492,"position":9,"arabic":"ٱلرَّسُولَ","translation":"রাসুলের","audioUrl":"wbw/047_032_009.mp3","charTypeName":"word"},{"id":34493,"position":10,"arabic":"مِنۢ","translation":"মধ্য হতে","audioUrl":"wbw/047_032_010.mp3","charTypeName":"word"},{"id":34494,"position":11,"arabic":"بَعْدِ","translation":"এরপরেও","audioUrl":"wbw/047_032_011.mp3","charTypeName":"word"},{"id":34495,"position":12,"arabic":"مَا","translation":"যা","audioUrl":"wbw/047_032_012.mp3","charTypeName":"word"},{"id":34496,"position":13,"arabic":"تَبَيَّنَ","translation":"সুস্পষ্ট হয়েছে","audioUrl":"wbw/047_032_013.mp3","charTypeName":"word"},{"id":34497,"position":14,"arabic":"لَهُمُ","translation":"তাদের কাছে","audioUrl":"wbw/047_032_014.mp3","charTypeName":"word"},{"id":34498,"position":15,"arabic":"ٱلْهُدَىٰ","translation":"(অর্থাৎ) সৎপথ","audioUrl":"wbw/047_032_015.mp3","charTypeName":"word"},{"id":34499,"position":16,"arabic":"لَن","translation":"কখনও না","audioUrl":"wbw/047_032_016.mp3","charTypeName":"word"},{"id":34500,"position":17,"arabic":"يَضُرُّوا۟","translation":"তারা ক্ষতি করতে পারবে","audioUrl":"wbw/047_032_017.mp3","charTypeName":"word"},{"id":34501,"position":18,"arabic":"ٱللَّهَ","translation":"আল্লাহকে","audioUrl":"wbw/047_032_018.mp3","charTypeName":"word"},{"id":34502,"position":19,"arabic":"شَيْـًۭٔا","translation":"কিছুমাত্রও","audioUrl":"wbw/047_032_019.mp3","charTypeName":"word"},{"id":34503,"position":20,"arabic":"وَسَيُحْبِطُ","translation":"এবং অচিরেই তিনি বিনষ্ট করে দিবেন","audioUrl":"wbw/047_032_020.mp3","charTypeName":"word"},{"id":34504,"position":21,"arabic":"أَعْمَـٰلَهُمْ","translation":"তাদের কর্মসমূহকে","audioUrl":"wbw/047_032_021.mp3","charTypeName":"word"},{"id":34505,"position":22,"arabic":"٣٢","translation":"(৩২)","audioUrl":null,"charTypeName":"end"}]},{"number":33,"arabic":"۞ يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوٓا۟ أَطِيعُوا۟ ٱللَّهَ وَأَطِيعُوا۟ ٱلرَّسُولَ وَلَا تُبْطِلُوٓا۟ أَعْمَٰلَكُمْ","translation":"O you who have attained to faith! Pay heed unto God, and pay heed unto the Apostle, and let not your [good] deeds come to nought!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4578.mp3","surahId":47,"words":[{"id":36021,"position":1,"arabic":"۞ يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/047_033_002.mp3","charTypeName":"word"},{"id":36022,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/047_033_003.mp3","charTypeName":"word"},{"id":36023,"position":3,"arabic":"ءَامَنُوٓا۟","translation":"ঈমান এনেছ","audioUrl":"wbw/047_033_004.mp3","charTypeName":"word"},{"id":36024,"position":4,"arabic":"أَطِيعُوا۟","translation":"তোমরা আনুগত্য করো","audioUrl":"wbw/047_033_005.mp3","charTypeName":"word"},{"id":36025,"position":5,"arabic":"ٱللَّهَ","translation":"আল্লাহ্‌র","audioUrl":"wbw/047_033_006.mp3","charTypeName":"word"},{"id":36026,"position":6,"arabic":"وَأَطِيعُوا۟","translation":"ও আনুগত্য করো","audioUrl":"wbw/047_033_007.mp3","charTypeName":"word"},{"id":36027,"position":7,"arabic":"ٱلرَّسُولَ","translation":"রাসুলের","audioUrl":"wbw/047_033_008.mp3","charTypeName":"word"},{"id":36028,"position":8,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/047_033_009.mp3","charTypeName":"word"},{"id":36029,"position":9,"arabic":"تُبْطِلُوٓا۟","translation":"তোমরা বিনষ্ট করো","audioUrl":"wbw/047_033_010.mp3","charTypeName":"word"},{"id":36030,"position":10,"arabic":"أَعْمَـٰلَكُمْ","translation":"তোমাদের কর্মসমূহকে","audioUrl":"wbw/047_033_011.mp3","charTypeName":"word"},{"id":36031,"position":11,"arabic":"٣٣","translation":"(৩৩)","audioUrl":null,"charTypeName":"end"}]},{"number":34,"arabic":"إِنَّ ٱلَّذِينَ كَفَرُوا۟ وَصَدُّوا۟ عَن سَبِيلِ ٱللَّهِ ثُمَّ مَاتُوا۟ وَهُمْ كُفَّارٌۭ فَلَن يَغْفِرَ ٱللَّهُ لَهُمْ","translation":"Verily, as for those who are bent on denying the truth and on barring [others] from the path of God, and then die as deniers of the truth - indeed, God will not grant them forgiveness!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4579.mp3","surahId":47,"words":[{"id":36296,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/047_034_001.mp3","charTypeName":"word"},{"id":36297,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/047_034_002.mp3","charTypeName":"word"},{"id":36298,"position":3,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/047_034_003.mp3","charTypeName":"word"},{"id":36299,"position":4,"arabic":"وَصَدُّوا۟","translation":"ও বাধা দিয়েছে (লোকদেরকে)","audioUrl":"wbw/047_034_004.mp3","charTypeName":"word"},{"id":36300,"position":5,"arabic":"عَن","translation":"হতে","audioUrl":"wbw/047_034_005.mp3","charTypeName":"word"},{"id":36301,"position":6,"arabic":"سَبِيلِ","translation":"পথ","audioUrl":"wbw/047_034_006.mp3","charTypeName":"word"},{"id":36302,"position":7,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌র","audioUrl":"wbw/047_034_007.mp3","charTypeName":"word"},{"id":36303,"position":8,"arabic":"ثُمَّ","translation":"তারপর","audioUrl":"wbw/047_034_008.mp3","charTypeName":"word"},{"id":36304,"position":9,"arabic":"مَاتُوا۟","translation":"তারা মারা গেছে","audioUrl":"wbw/047_034_009.mp3","charTypeName":"word"},{"id":36305,"position":10,"arabic":"وَهُمْ","translation":"এমতাবস্থায় যে","audioUrl":"wbw/047_034_010.mp3","charTypeName":"word"},{"id":36306,"position":11,"arabic":"كُفَّارٌۭ","translation":"কাফের (ছিল)","audioUrl":"wbw/047_034_011.mp3","charTypeName":"word"},{"id":36307,"position":12,"arabic":"فَلَن","translation":"ফলে কখনও না","audioUrl":"wbw/047_034_012.mp3","charTypeName":"word"},{"id":36308,"position":13,"arabic":"يَغْفِرَ","translation":"ক্ষমা করবেন","audioUrl":"wbw/047_034_013.mp3","charTypeName":"word"},{"id":36309,"position":14,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌","audioUrl":"wbw/047_034_014.mp3","charTypeName":"word"},{"id":36310,"position":15,"arabic":"لَهُمْ","translation":"তাদেরকে","audioUrl":"wbw/047_034_015.mp3","charTypeName":"word"},{"id":36311,"position":16,"arabic":"٣٤","translation":"(৩৪)","audioUrl":null,"charTypeName":"end"}]},{"number":35,"arabic":"فَلَا تَهِنُوا۟ وَتَدْعُوٓا۟ إِلَى ٱلسَّلْمِ وَأَنتُمُ ٱلْأَعْلَوْنَ وَٱللَّهُ مَعَكُمْ وَلَن يَتِرَكُمْ أَعْمَٰلَكُمْ","translation":"AND SO, [when you fight in a just cause,] do not lose heart and [never] beg for peace: for, seeing that God is with you, you are bound to rise high [in the end]; and never will He let your [good] deeds go to waste.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4580.mp3","surahId":47,"words":[{"id":37095,"position":1,"arabic":"فَلَا","translation":"অতএব না","audioUrl":"wbw/047_035_001.mp3","charTypeName":"word"},{"id":37096,"position":2,"arabic":"تَهِنُوا۟","translation":"তোমরা সাহস হারিয়ো না","audioUrl":"wbw/047_035_002.mp3","charTypeName":"word"},{"id":37097,"position":3,"arabic":"وَتَدْعُوٓا۟","translation":"এবং তোমরা আহবান করো (না)","audioUrl":"wbw/047_035_003.mp3","charTypeName":"word"},{"id":37098,"position":4,"arabic":"إِلَى","translation":"দিকে","audioUrl":"wbw/047_035_004.mp3","charTypeName":"word"},{"id":37099,"position":5,"arabic":"ٱلسَّلْمِ","translation":"সন্ধির","audioUrl":"wbw/047_035_005.mp3","charTypeName":"word"},{"id":37100,"position":6,"arabic":"وَأَنتُمُ","translation":"এবং তোমরাই (হবে)","audioUrl":"wbw/047_035_006.mp3","charTypeName":"word"},{"id":37101,"position":7,"arabic":"ٱلْأَعْلَوْنَ","translation":"বিজয়ী","audioUrl":"wbw/047_035_007.mp3","charTypeName":"word"},{"id":37102,"position":8,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ্‌","audioUrl":"wbw/047_035_008.mp3","charTypeName":"word"},{"id":37103,"position":9,"arabic":"مَعَكُمْ","translation":"তোমাদের সাথে (আছেন)","audioUrl":"wbw/047_035_009.mp3","charTypeName":"word"},{"id":37104,"position":10,"arabic":"وَلَن","translation":"এবং কখনও না","audioUrl":"wbw/047_035_010.mp3","charTypeName":"word"},{"id":37105,"position":11,"arabic":"يَتِرَكُمْ","translation":"তোমাদের কমাবেন","audioUrl":"wbw/047_035_011.mp3","charTypeName":"word"},{"id":37106,"position":12,"arabic":"أَعْمَـٰلَكُمْ","translation":"তোমাদের কর্মসমূহকে","audioUrl":"wbw/047_035_012.mp3","charTypeName":"word"},{"id":37107,"position":13,"arabic":"٣٥","translation":"(৩৫)","audioUrl":null,"charTypeName":"end"}]},{"number":36,"arabic":"إِنَّمَا ٱلْحَيَوٰةُ ٱلدُّنْيَا لَعِبٌۭ وَلَهْوٌۭ ۚ وَإِن تُؤْمِنُوا۟ وَتَتَّقُوا۟ يُؤْتِكُمْ أُجُورَكُمْ وَلَا يَسْـَٔلْكُمْ أَمْوَٰلَكُمْ","translation":"The life of this world is but a play and a passing delight: but if you believe [in God] and are conscious of Him, He will grant you your deserts. And withal, He does not demand of you [to sacrifice in His cause all of] your possessions:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4581.mp3","surahId":47,"words":[{"id":37907,"position":1,"arabic":"إِنَّمَا","translation":"প্রকৃতপক্ষে","audioUrl":"wbw/047_036_001.mp3","charTypeName":"word"},{"id":37908,"position":2,"arabic":"ٱلْحَيَوٰةُ","translation":"জীবন","audioUrl":"wbw/047_036_002.mp3","charTypeName":"word"},{"id":37909,"position":3,"arabic":"ٱلدُّنْيَا","translation":"পার্থিব","audioUrl":"wbw/047_036_003.mp3","charTypeName":"word"},{"id":37910,"position":4,"arabic":"لَعِبٌۭ","translation":"খেলা","audioUrl":"wbw/047_036_004.mp3","charTypeName":"word"},{"id":37911,"position":5,"arabic":"وَلَهْوٌۭ ۚ","translation":"ও তামাশা (মাত্র)","audioUrl":"wbw/047_036_005.mp3","charTypeName":"word"},{"id":37913,"position":6,"arabic":"وَإِن","translation":"এবং যদি","audioUrl":"wbw/047_036_007.mp3","charTypeName":"word"},{"id":37914,"position":7,"arabic":"تُؤْمِنُوا۟","translation":"তোমরা ঈমান আন","audioUrl":"wbw/047_036_008.mp3","charTypeName":"word"},{"id":37915,"position":8,"arabic":"وَتَتَّقُوا۟","translation":"ও তোমরা ভয় করে চল","audioUrl":"wbw/047_036_009.mp3","charTypeName":"word"},{"id":37916,"position":9,"arabic":"يُؤْتِكُمْ","translation":"তিনি তোমাদের দান করবেন","audioUrl":"wbw/047_036_010.mp3","charTypeName":"word"},{"id":37917,"position":10,"arabic":"أُجُورَكُمْ","translation":"তোমাদের কর্মফলসমূহকে","audioUrl":"wbw/047_036_011.mp3","charTypeName":"word"},{"id":37918,"position":11,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/047_036_012.mp3","charTypeName":"word"},{"id":37919,"position":12,"arabic":"يَسْـَٔلْكُمْ","translation":"তোমাদের থেকে তিনি চান","audioUrl":"wbw/047_036_013.mp3","charTypeName":"word"},{"id":37920,"position":13,"arabic":"أَمْوَٰلَكُمْ","translation":"তোমাদের সম্পদগুলোকে","audioUrl":"wbw/047_036_014.mp3","charTypeName":"word"},{"id":37921,"position":14,"arabic":"٣٦","translation":"(৩৬)","audioUrl":null,"charTypeName":"end"}]},{"number":37,"arabic":"إِن يَسْـَٔلْكُمُوهَا فَيُحْفِكُمْ تَبْخَلُوا۟ وَيُخْرِجْ أَضْغَٰنَكُمْ","translation":"[for,] if He were to demand of you all of them, and urge you, you would niggardly cling [to them], and so He would [but] bring out your moral failings.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4582.mp3","surahId":47,"words":[{"id":39292,"position":1,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/047_037_001.mp3","charTypeName":"word"},{"id":39293,"position":2,"arabic":"يَسْـَٔلْكُمُوهَا","translation":"তা তোমাদের থেকে চান তিনি","audioUrl":"wbw/047_037_002.mp3","charTypeName":"word"},{"id":39294,"position":3,"arabic":"فَيُحْفِكُمْ","translation":"অতঃপর তোমাদেরকে  চাপ দেন","audioUrl":"wbw/047_037_003.mp3","charTypeName":"word"},{"id":39295,"position":4,"arabic":"تَبْخَلُوا۟","translation":"তোমরা কৃপণতা করবে","audioUrl":"wbw/047_037_004.mp3","charTypeName":"word"},{"id":39296,"position":5,"arabic":"وَيُخْرِجْ","translation":"এবং তিনি প্রকাশ করবেন","audioUrl":"wbw/047_037_005.mp3","charTypeName":"word"},{"id":39297,"position":6,"arabic":"أَضْغَـٰنَكُمْ","translation":"তোমাদের গোপন ত্রুটিকে","audioUrl":"wbw/047_037_006.mp3","charTypeName":"word"},{"id":39298,"position":7,"arabic":"٣٧","translation":"(৩৭)","audioUrl":null,"charTypeName":"end"}]},{"number":38,"arabic":"هَٰٓأَنتُمْ هَٰٓؤُلَآءِ تُدْعَوْنَ لِتُنفِقُوا۟ فِى سَبِيلِ ٱللَّهِ فَمِنكُم مَّن يَبْخَلُ ۖ وَمَن يَبْخَلْ فَإِنَّمَا يَبْخَلُ عَن نَّفْسِهِۦ ۚ وَٱللَّهُ ٱلْغَنِىُّ وَأَنتُمُ ٱلْفُقَرَآءُ ۚ وَإِن تَتَوَلَّوْا۟ يَسْتَبْدِلْ قَوْمًا غَيْرَكُمْ ثُمَّ لَا يَكُونُوٓا۟ أَمْثَٰلَكُم","translation":"Behold, [O believers,] it is you who are called upon to spend freely in God’s cause: but [even] among you are such as turn out to be niggardly! And yet, he who acts niggardly [in God’s cause] is but niggardly towards his own self: for God is indeed self-sufficient, whereas you stand in need [of Him]; and if you turn away [from Him], He will cause other people to take your place, and they will not be the likes of you!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4583.mp3","surahId":47,"words":[{"id":39594,"position":1,"arabic":"هَـٰٓأَنتُمْ","translation":"তোমরা দেখ","audioUrl":"wbw/047_038_001.mp3","charTypeName":"word"},{"id":39595,"position":2,"arabic":"هَـٰٓؤُلَآءِ","translation":"ঐসব লোক (যাদের)","audioUrl":"wbw/047_038_002.mp3","charTypeName":"word"},{"id":39596,"position":3,"arabic":"تُدْعَوْنَ","translation":"আহবান করা হচ্ছে","audioUrl":"wbw/047_038_003.mp3","charTypeName":"word"},{"id":39597,"position":4,"arabic":"لِتُنفِقُوا۟","translation":"তোমরা খরচ কর যেন","audioUrl":"wbw/047_038_004.mp3","charTypeName":"word"},{"id":39598,"position":5,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/047_038_005.mp3","charTypeName":"word"},{"id":39599,"position":6,"arabic":"سَبِيلِ","translation":"পথের","audioUrl":"wbw/047_038_006.mp3","charTypeName":"word"},{"id":39600,"position":7,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌র","audioUrl":"wbw/047_038_007.mp3","charTypeName":"word"},{"id":39601,"position":8,"arabic":"فَمِنكُم","translation":"তখন তোমাদের মধ্য হতে","audioUrl":"wbw/047_038_008.mp3","charTypeName":"word"},{"id":39602,"position":9,"arabic":"مَّن","translation":"কেউ কেউ","audioUrl":"wbw/047_038_009.mp3","charTypeName":"word"},{"id":39603,"position":10,"arabic":"يَبْخَلُ ۖ","translation":"কৃপণতা করে","audioUrl":"wbw/047_038_010.mp3","charTypeName":"word"},{"id":39605,"position":11,"arabic":"وَمَن","translation":"অথচ যে","audioUrl":"wbw/047_038_012.mp3","charTypeName":"word"},{"id":39606,"position":12,"arabic":"يَبْخَلْ","translation":"কৃপণতা করে","audioUrl":"wbw/047_038_013.mp3","charTypeName":"word"},{"id":39607,"position":13,"arabic":"فَإِنَّمَا","translation":"প্রকৃতপক্ষে","audioUrl":"wbw/047_038_014.mp3","charTypeName":"word"},{"id":39608,"position":14,"arabic":"يَبْخَلُ","translation":"সে কৃপণতা করে","audioUrl":"wbw/047_038_015.mp3","