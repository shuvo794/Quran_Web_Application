{"id":49,"ayahs":[{"number":283,"arabic":"۞ وَإِن كُنتُمْ عَلَىٰ سَفَرٍۢ وَلَمْ تَجِدُوا۟ كَاتِبًۭا فَرِهَٰنٌۭ مَّقْبُوضَةٌۭ ۖ فَإِنْ أَمِنَ بَعْضُكُم بَعْضًۭا فَلْيُؤَدِّ ٱلَّذِى ٱؤْتُمِنَ أَمَٰنَتَهُۥ وَلْيَتَّقِ ٱللَّهَ رَبَّهُۥ ۗ وَلَا تَكْتُمُوا۟ ٱلشَّهَٰدَةَ ۚ وَمَن يَكْتُمْهَا فَإِنَّهُۥٓ ءَاثِمٌۭ قَلْبُهُۥ ۗ وَٱللَّهُ بِمَا تَعْمَلُونَ عَلِيمٌۭ","translation":"And if you are on a journey and cannot find a scribe, pledges [may be taken] in hand: but if you trust one another, then let him who is trusted fulfil his trust, and let him be conscious of God, his Sustainer. And do not conceal what you have witnessed - for, verily, he who conceals it is sinful at heart; and God has full knowledge of all that you do.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/290.mp3","surahId":2,"words":[{"id":88091,"position":1,"arabic":"۞ وَإِن","translation":"এবং যদি","audioUrl":"wbw/002_283_002.mp3","charTypeName":"word"},{"id":88092,"position":2,"arabic":"كُنتُمْ","translation":"তোমরা থাক","audioUrl":"wbw/002_283_003.mp3","charTypeName":"word"},{"id":88093,"position":3,"arabic":"عَلَىٰ","translation":"মধ্যে","audioUrl":"wbw/002_283_004.mp3","charTypeName":"word"},{"id":88094,"position":4,"arabic":"سَفَرٍۢ","translation":"সফরের","audioUrl":"wbw/002_283_005.mp3","charTypeName":"word"},{"id":88095,"position":5,"arabic":"وَلَمْ","translation":"এবং না","audioUrl":"wbw/002_283_006.mp3","charTypeName":"word"},{"id":88096,"position":6,"arabic":"تَجِدُوا۟","translation":"তোমরা পাও","audioUrl":"wbw/002_283_007.mp3","charTypeName":"word"},{"id":88097,"position":7,"arabic":"كَاتِبًۭا","translation":"কোনো লেখক","audioUrl":"wbw/002_283_008.mp3","charTypeName":"word"},{"id":88098,"position":8,"arabic":"فَرِهَـٰنٌۭ","translation":"তবে বন্ধকি বস্তু","audioUrl":"wbw/002_283_009.mp3","charTypeName":"word"},{"id":88099,"position":9,"arabic":"مَّقْبُوضَةٌۭ ۖ","translation":"হস্তগত (রাখতে পার)","audioUrl":"wbw/002_283_010.mp3","charTypeName":"word"},{"id":88101,"position":10,"arabic":"فَإِنْ","translation":"অতঃপর যদি","audioUrl":"wbw/002_283_012.mp3","charTypeName":"word"},{"id":88102,"position":11,"arabic":"أَمِنَ","translation":"বিশ্বাস করে","audioUrl":"wbw/002_283_013.mp3","charTypeName":"word"},{"id":88103,"position":12,"arabic":"بَعْضُكُم","translation":"তোমাদের কেউ","audioUrl":"wbw/002_283_014.mp3","charTypeName":"word"},{"id":88104,"position":13,"arabic":"بَعْضًۭا","translation":"অন্যকে","audioUrl":"wbw/002_283_015.mp3","charTypeName":"word"},{"id":88105,"position":14,"arabic":"فَلْيُؤَدِّ","translation":"তবে সে যেন ফিরেয়ে দেয়","audioUrl":"wbw/002_283_016.mp3","charTypeName":"word"},{"id":88106,"position":15,"arabic":"ٱلَّذِى","translation":"যার (উপর)","audioUrl":"wbw/002_283_017.mp3","charTypeName":"word"},{"id":88107,"position":16,"arabic":"ٱؤْتُمِنَ","translation":"বিশ্বাস করা হয়েছিল","audioUrl":"wbw/002_283_018.mp3","charTypeName":"word"},{"id":88108,"position":17,"arabic":"أَمَـٰنَتَهُۥ","translation":"তার আমানতের","audioUrl":"wbw/002_283_019.mp3","charTypeName":"word"},{"id":88109,"position":18,"arabic":"وَلْيَتَّقِ","translation":"এবং সে যেন ভয় করে","audioUrl":"wbw/002_283_020.mp3","charTypeName":"word"},{"id":88110,"position":19,"arabic":"ٱللَّهَ","translation":"আল্লাহকে","audioUrl":"wbw/002_283_021.mp3","charTypeName":"word"},{"id":88111,"position":20,"arabic":"رَبَّهُۥ ۗ","translation":"(যিনি) তার রব","audioUrl":"wbw/002_283_022.mp3","charTypeName":"word"},{"id":88113,"position":21,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/002_283_024.mp3","charTypeName":"word"},{"id":88114,"position":22,"arabic":"تَكْتُمُوا۟","translation":"তোমরা গোপন করবে","audioUrl":"wbw/002_283_025.mp3","charTypeName":"word"},{"id":88115,"position":23,"arabic":"ٱلشَّهَـٰدَةَ ۚ","translation":"সাক্ষ্য","audioUrl":"wbw/002_283_026.mp3","charTypeName":"word"},{"id":88117,"position":24,"arabic":"وَمَن","translation":"এবং যে","audioUrl":"wbw/002_283_028.mp3","charTypeName":"word"},{"id":88118,"position":25,"arabic":"يَكْتُمْهَا","translation":"তা গোপন করবে","audioUrl":"wbw/002_283_029.mp3","charTypeName":"word"},{"id":88119,"position":26,"arabic":"فَإِنَّهُۥٓ","translation":"তাহলে সে নিশ্চয়ই","audioUrl":"wbw/002_283_030.mp3","charTypeName":"word"},{"id":88120,"position":27,"arabic":"ءَاثِمٌۭ","translation":"পাপী","audioUrl":"wbw/002_283_031.mp3","charTypeName":"word"},{"id":88121,"position":28,"arabic":"قَلْبُهُۥ ۗ","translation":"তার অন্তর","audioUrl":"wbw/002_283_032.mp3","charTypeName":"word"},{"id":88123,"position":29,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/002_283_034.mp3","charTypeName":"word"},{"id":88124,"position":30,"arabic":"بِمَا","translation":"সে বিষয়ে","audioUrl":"wbw/002_283_035.mp3","charTypeName":"word"},{"id":88125,"position":31,"arabic":"تَعْمَلُونَ","translation":"তোমরা কাজ কর","audioUrl":"wbw/002_283_036.mp3","charTypeName":"word"},{"id":88126,"position":32,"arabic":"عَلِيمٌۭ","translation":"খুব অবহিত","audioUrl":"wbw/002_283_037.mp3","charTypeName":"word"},{"id":88127,"position":33,"arabic":"٢٨٣","translation":"(২৮৩)","audioUrl":null,"charTypeName":"end"}]},{"number":284,"arabic":"لِّلَّهِ مَا فِى ٱلسَّمَٰوَٰتِ وَمَا فِى ٱلْأَرْضِ ۗ وَإِن تُبْدُوا۟ مَا فِىٓ أَنفُسِكُمْ أَوْ تُخْفُوهُ يُحَاسِبْكُم بِهِ ٱللَّهُ ۖ فَيَغْفِرُ لِمَن يَشَآءُ وَيُعَذِّبُ مَن يَشَآءُ ۗ وَٱللَّهُ عَلَىٰ كُلِّ شَىْءٍۢ قَدِيرٌ","translation":"Unto God belongs all that is in the heavens and all that is on earth. And whether you bring into the open what is in your minds or conceal it, God will call you to account for it; and then He will forgive whom He wills, and will chastise whom He wills: for God has the power to will anything.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/291.mp3","surahId":2,"words":[{"id":88128,"position":1,"arabic":"لِّلَّهِ","translation":"আল্লাহর জন্য","audioUrl":"wbw/002_284_001.mp3","charTypeName":"word"},{"id":88129,"position":2,"arabic":"مَا","translation":"যা কিছু","audioUrl":"wbw/002_284_002.mp3","charTypeName":"word"},{"id":88130,"position":3,"arabic":"فِى","translation":"মধ্যে (আছে)","audioUrl":"wbw/002_284_003.mp3","charTypeName":"word"},{"id":88131,"position":4,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশ সমূহের","audioUrl":"wbw/002_284_004.mp3","charTypeName":"word"},{"id":88132,"position":5,"arabic":"وَمَا","translation":"ও যা কিছু","audioUrl":"wbw/002_284_005.mp3","charTypeName":"word"},{"id":88133,"position":6,"arabic":"فِى","translation":"মধ্যে (আছে)","audioUrl":"wbw/002_284_006.mp3","charTypeName":"word"},{"id":88134,"position":7,"arabic":"ٱلْأَرْضِ ۗ","translation":"পৃথিবীর","audioUrl":"wbw/002_284_007.mp3","charTypeName":"word"},{"id":88136,"position":8,"arabic":"وَإِن","translation":"এবং যদি","audioUrl":"wbw/002_284_009.mp3","charTypeName":"word"},{"id":88137,"position":9,"arabic":"تُبْدُوا۟","translation":"তোমরা প্রকাশ কর","audioUrl":"wbw/002_284_010.mp3","charTypeName":"word"},{"id":88138,"position":10,"arabic":"مَا","translation":"যা কিছু","audioUrl":"wbw/002_284_011.mp3","charTypeName":"word"},{"id":88139,"position":11,"arabic":"فِىٓ","translation":"মধ্যে (আছে)","audioUrl":"wbw/002_284_012.mp3","charTypeName":"word"},{"id":88140,"position":12,"arabic":"أَنفُسِكُمْ","translation":"তোমাদের মনের","audioUrl":"wbw/002_284_013.mp3","charTypeName":"word"},{"id":88141,"position":13,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/002_284_014.mp3","charTypeName":"word"},{"id":88142,"position":14,"arabic":"تُخْفُوهُ","translation":"গোপন কর তোমরা তা","audioUrl":"wbw/002_284_015.mp3","charTypeName":"word"},{"id":88143,"position":15,"arabic":"يُحَاسِبْكُم","translation":"তোমাদেরকে হিসাব নিবেন","audioUrl":"wbw/002_284_016.mp3","charTypeName":"word"},{"id":88144,"position":16,"arabic":"بِهِ","translation":"তা সম্পর্কে","audioUrl":"wbw/002_284_017.mp3","charTypeName":"word"},{"id":88145,"position":17,"arabic":"ٱللَّهُ ۖ","translation":"আল্লাহ","audioUrl":"wbw/002_284_018.mp3","charTypeName":"word"},{"id":88147,"position":18,"arabic":"فَيَغْفِرُ","translation":"অতঃপর ক্ষমা করবেন","audioUrl":"wbw/002_284_020.mp3","charTypeName":"word"},{"id":88148,"position":19,"arabic":"لِمَن","translation":"যাকে","audioUrl":"wbw/002_284_021.mp3","charTypeName":"word"},{"id":88149,"position":20,"arabic":"يَشَآءُ","translation":"তিনি ইচ্ছা করবেন","audioUrl":"wbw/002_284_022.mp3","charTypeName":"word"},{"id":88150,"position":21,"arabic":"وَيُعَذِّبُ","translation":"এবং তিনি শাস্তি দিবেন","audioUrl":"wbw/002_284_023.mp3","charTypeName":"word"},{"id":88151,"position":22,"arabic":"مَن","translation":"যাকে","audioUrl":"wbw/002_284_024.mp3","charTypeName":"word"},{"id":88152,"position":23,"arabic":"يَشَآءُ ۗ","translation":"তিনি ইচ্ছা করবেন","audioUrl":"wbw/002_284_025.mp3","charTypeName":"word"},{"id":88154,"position":24,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/002_284_027.mp3","charTypeName":"word"},{"id":88155,"position":25,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/002_284_028.mp3","charTypeName":"word"},{"id":88156,"position":26,"arabic":"كُلِّ","translation":"সব","audioUrl":"wbw/002_284_029.mp3","charTypeName":"word"},{"id":88157,"position":27,"arabic":"شَىْءٍۢ","translation":"কিছুর","audioUrl":"wbw/002_284_030.mp3","charTypeName":"word"},{"id":88158,"position":28,"arabic":"قَدِيرٌ","translation":"সর্বশক্তিমান","audioUrl":"wbw/002_284_031.mp3","charTypeName":"word"},{"id":88159,"position":29,"arabic":"٢٨٤","translation":"(২৮৪)","audioUrl":null,"charTypeName":"end"}]},{"number":285,"arabic":"ءَامَنَ ٱلرَّسُولُ بِمَآ أُنزِلَ إِلَيْهِ مِن رَّبِّهِۦ وَٱلْمُؤْمِنُونَ ۚ كُلٌّ ءَامَنَ بِٱللَّهِ وَمَلَٰٓئِكَتِهِۦ وَكُتُبِهِۦ وَرُسُلِهِۦ لَا نُفَرِّقُ بَيْنَ أَحَدٍۢ مِّن رُّسُلِهِۦ ۚ وَقَالُوا۟ سَمِعْنَا وَأَطَعْنَا ۖ غُفْرَانَكَ رَبَّنَا وَإِلَيْكَ ٱلْمَصِيرُ","translation":"THE APOSTLE, and the believers with him, believe in what has been bestowed upon him from on high by his Sustainer: they all believe in God, and His angels, and His revelations, and His apostles, making no distinction between any of His apostles; and they say: We have heard, and we pay heed. Grant us Thy forgiveness, O our Sustainer, for with Thee is all journeys' end!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/292.mp3","surahId":2,"words":[{"id":88160,"position":1,"arabic":"ءَامَنَ","translation":"ঈমান এনেছে","audioUrl":"wbw/002_285_001.mp3","charTypeName":"word"},{"id":88161,"position":2,"arabic":"ٱلرَّسُولُ","translation":"রাসূল","audioUrl":"wbw/002_285_002.mp3","charTypeName":"word"},{"id":88162,"position":3,"arabic":"بِمَآ","translation":"ঐ বিষয় যা","audioUrl":"wbw/002_285_003.mp3","charTypeName":"word"},{"id":88163,"position":4,"arabic":"أُنزِلَ","translation":"অবতীর্ণ করা হয়েছে","audioUrl":"wbw/002_285_004.mp3","charTypeName":"word"},{"id":88164,"position":5,"arabic":"إِلَيْهِ","translation":"তাঁর প্রতি","audioUrl":"wbw/002_285_005.mp3","charTypeName":"word"},{"id":88165,"position":6,"arabic":"مِن","translation":"পক্ষ হতে","audioUrl":"wbw/002_285_006.mp3","charTypeName":"word"},{"id":88166,"position":7,"arabic":"رَّبِّهِۦ","translation":"তাঁর রবের","audioUrl":"wbw/002_285_007.mp3","charTypeName":"word"},{"id":88167,"position":8,"arabic":"وَٱلْمُؤْمِنُونَ ۚ","translation":"এবং মু'মিনরাও","audioUrl":"wbw/002_285_008.mp3","charTypeName":"word"},{"id":88169,"position":9,"arabic":"كُلٌّ","translation":"সবাই","audioUrl":"wbw/002_285_010.mp3","charTypeName":"word"},{"id":88170,"position":10,"arabic":"ءَامَنَ","translation":"ঈমান এনেছে","audioUrl":"wbw/002_285_011.mp3","charTypeName":"word"},{"id":88171,"position":11,"arabic":"بِٱللَّهِ","translation":"আল্লাহর উপর","audioUrl":"wbw/002_285_012.mp3","charTypeName":"word"},{"id":88172,"position":12,"arabic":"وَمَلَـٰٓئِكَتِهِۦ","translation":"এবং তাঁর ফেরেশতাদের","audioUrl":"wbw/002_285_013.mp3","charTypeName":"word"},{"id":88173,"position":13,"arabic":"وَكُتُبِهِۦ","translation":"ও তাঁর কিতাবগুলোর","audioUrl":"wbw/002_285_014.mp3","charTypeName":"word"},{"id":88174,"position":14,"arabic":"وَرُسُلِهِۦ","translation":"এবং তাঁর রাসূলদের (উপর)","audioUrl":"wbw/002_285_015.mp3","charTypeName":"word"},{"id":88175,"position":15,"arabic":"لَا","translation":"(তারা বলে) না","audioUrl":"wbw/002_285_016.mp3","charTypeName":"word"},{"id":88176,"position":16,"arabic":"نُفَرِّقُ","translation":"আমরা পার্থক্য করি","audioUrl":"wbw/002_285_017.mp3","charTypeName":"word"},{"id":88177,"position":17,"arabic":"بَيْنَ","translation":"মাঝে","audioUrl":"wbw/002_285_018.mp3","charTypeName":"word"},{"id":88178,"position":18,"arabic":"أَحَدٍۢ","translation":"কারো","audioUrl":"wbw/002_285_019.mp3","charTypeName":"word"},{"id":88179,"position":19,"arabic":"مِّن","translation":"মধ্য হতে","audioUrl":"wbw/002_285_020.mp3","charTypeName":"word"},{"id":88180,"position":20,"arabic":"رُّسُلِهِۦ ۚ","translation":"তাঁর রাসূলদের","audioUrl":"wbw/002_285_021.mp3","charTypeName":"word"},{"id":88182,"position":21,"arabic":"وَقَالُوا۟","translation":"এবং তারা বলে","audioUrl":"wbw/002_285_023.mp3","charTypeName":"word"},{"id":88183,"position":22,"arabic":"سَمِعْنَا","translation":"আমরা শুনলাম","audioUrl":"wbw/002_285_024.mp3","charTypeName":"word"},{"id":88184,"position":23,"arabic":"وَأَطَعْنَا ۖ","translation":"এবং আমরা মানলাম","audioUrl":"wbw/002_285_025.mp3","charTypeName":"word"},{"id":88186,"position":24,"arabic":"غُفْرَانَكَ","translation":"আমরা তোমার ক্ষমা (চাই)","audioUrl":"wbw/002_285_027.mp3","charTypeName":"word"},{"id":88187,"position":25,"arabic":"رَبَّنَا","translation":"হে আমাদের রব","audioUrl":"wbw/002_285_028.mp3","charTypeName":"word"},{"id":88188,"position":26,"arabic":"وَإِلَيْكَ","translation":"এবং তোমারই কাছে","audioUrl":"wbw/002_285_029.mp3","charTypeName":"word"},{"id":88189,"position":27,"arabic":"ٱلْمَصِيرُ","translation":"প্রত্যাবর্তন (হবে)","audioUrl":"wbw/002_285_030.mp3","charTypeName":"word"},{"id":88190,"position":28,"arabic":"٢٨٥","translation":"(২৮৫)","audioUrl":null,"charTypeName":"end"}]},{"number":286,"arabic":"لَا يُكَلِّفُ ٱللَّهُ نَفْسًا إِلَّا وُسْعَهَا ۚ لَهَا مَا كَسَبَتْ وَعَلَيْهَا مَا ٱكْتَسَبَتْ ۗ رَبَّنَا لَا تُؤَاخِذْنَآ إِن نَّسِينَآ أَوْ أَخْطَأْنَا ۚ رَبَّنَا وَلَا تَحْمِلْ عَلَيْنَآ إِصْرًۭا كَمَا حَمَلْتَهُۥ عَلَى ٱلَّذِينَ مِن قَبْلِنَا ۚ رَبَّنَا وَلَا تُحَمِّلْنَا مَا لَا طَاقَةَ لَنَا بِهِۦ ۖ وَٱعْفُ عَنَّا وَٱغْفِرْ لَنَا وَٱرْحَمْنَآ ۚ أَنتَ مَوْلَىٰنَا فَٱنصُرْنَا عَلَى ٱلْقَوْمِ ٱلْكَٰفِرِينَ","translation":"God does not burden any human being with more than he is well able to bear: in his favour shall be whatever good he does, and against him whatever evil he does. O our Sustainer! Take us not to task if we forget or unwittingly do wrong! \"O our Sustainer! Lay not upon us a burden such as Thou didst lay upon those who lived before us! O our Sustainer! Make us not bear burdens which we have no strength to bear! \"And efface Thou our sins, and grant us forgiveness, and bestow Thy mercy upon us! Thou art our Lord Supreme: succour us, then, against people who deny the truth!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/293.mp3","surahId":2,"words":[{"id":88191,"position":1,"arabic":"لَا","translation":"না","audioUrl":"wbw/002_286_001.mp3","charTypeName":"word"},{"id":88192,"position":2,"arabic":"يُكَلِّفُ","translation":"দায়িত্বভার দেন","audioUrl":"wbw/002_286_002.mp3","charTypeName":"word"},{"id":88193,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/002_286_003.mp3","charTypeName":"word"},{"id":88194,"position":4,"arabic":"نَفْسًا","translation":"কোনো ব্যক্তিকে","audioUrl":"wbw/002_286_004.mp3","charTypeName":"word"},{"id":88195,"position":5,"arabic":"إِلَّا","translation":"এছাড়া যা","audioUrl":"wbw/002_286_005.mp3","charTypeName":"word"},{"id":88196,"position":6,"arabic":"وُسْعَهَا ۚ","translation":"তার সামর্থ্য (আছে)","audioUrl":"wbw/002_286_006.mp3","charTypeName":"word"},{"id":88198,"position":7,"arabic":"لَهَا","translation":"তার জন্য (আছে)","audioUrl":"wbw/002_286_008.mp3","charTypeName":"word"},{"id":88199,"position":8,"arabic":"مَا","translation":"যা (পূণ্য)","audioUrl":"wbw/002_286_009.mp3","charTypeName