"audioUrl":"wbw/002_085_052.mp3","charTypeName":"word"},{"id":66198,"position":49,"arabic":"تَعْمَلُونَ","translation":"তোমরা করছ","audioUrl":"wbw/002_085_053.mp3","charTypeName":"word"},{"id":66199,"position":50,"arabic":"٨٥","translation":"(৮৫)","audioUrl":null,"charTypeName":"end"}]},{"number":86,"arabic":"أُو۟لَٰٓئِكَ ٱلَّذِينَ ٱشْتَرَوُا۟ ٱلْحَيَوٰةَ ٱلدُّنْيَا بِٱلْءَاخِرَةِ ۖ فَلَا يُخَفَّفُ عَنْهُمُ ٱلْعَذَابُ وَلَا هُمْ يُنصَرُونَ","translation":"All who buy the life of this world at the price of the life to come - their suffering shall not be lightened, nor shall they be succoured!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/93.mp3","surahId":2,"words":[{"id":66593,"position":1,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐ সব (লোক)","audioUrl":"wbw/002_086_001.mp3","charTypeName":"word"},{"id":66594,"position":2,"arabic":"ٱلَّذِينَ","translation":"(তারাই) যারা","audioUrl":"wbw/002_086_002.mp3","charTypeName":"word"},{"id":66595,"position":3,"arabic":"ٱشْتَرَوُا۟","translation":"কিনে নিয়েছে","audioUrl":"wbw/002_086_003.mp3","charTypeName":"word"},{"id":66596,"position":4,"arabic":"ٱلْحَيَوٰةَ","translation":"জীবনকে","audioUrl":"wbw/002_086_004.mp3","charTypeName":"word"},{"id":66597,"position":5,"arabic":"ٱلدُّنْيَا","translation":"পার্থিব","audioUrl":"wbw/002_086_005.mp3","charTypeName":"word"},{"id":66598,"position":6,"arabic":"بِٱلْـَٔاخِرَةِ ۖ","translation":"আখিরাতের বিনিময়ে","audioUrl":"wbw/002_086_006.mp3","charTypeName":"word"},{"id":66600,"position":7,"arabic":"فَلَا","translation":"না ফলে","audioUrl":"wbw/002_086_008.mp3","charTypeName":"word"},{"id":66601,"position":8,"arabic":"يُخَفَّفُ","translation":"হালকা করা হবে","audioUrl":"wbw/002_086_009.mp3","charTypeName":"word"},{"id":66602,"position":9,"arabic":"عَنْهُمُ","translation":"তাদের থেকে","audioUrl":"wbw/002_086_010.mp3","charTypeName":"word"},{"id":66603,"position":10,"arabic":"ٱلْعَذَابُ","translation":"শাস্তি","audioUrl":"wbw/002_086_011.mp3","charTypeName":"word"},{"id":66604,"position":11,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/002_086_012.mp3","charTypeName":"word"},{"id":66605,"position":12,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/002_086_013.mp3","charTypeName":"word"},{"id":66606,"position":13,"arabic":"يُنصَرُونَ","translation":"সাহায্যপ্রাপ্ত হবে","audioUrl":"wbw/002_086_014.mp3","charTypeName":"word"},{"id":66607,"position":14,"arabic":"٨٦","translation":"(৮৬)","audioUrl":null,"charTypeName":"end"}]},{"number":87,"arabic":"وَلَقَدْ ءَاتَيْنَا مُوسَى ٱلْكِتَٰبَ وَقَفَّيْنَا مِنۢ بَعْدِهِۦ بِٱلرُّسُلِ ۖ وَءَاتَيْنَا عِيسَى ٱبْنَ مَرْيَمَ ٱلْبَيِّنَٰتِ وَأَيَّدْنَٰهُ بِرُوحِ ٱلْقُدُسِ ۗ أَفَكُلَّمَا جَآءَكُمْ رَسُولٌۢ بِمَا لَا تَهْوَىٰٓ أَنفُسُكُمُ ٱسْتَكْبَرْتُمْ فَفَرِيقًۭا كَذَّبْتُمْ وَفَرِيقًۭا تَقْتُلُونَ","translation":"For, indeed, We vouchsafed unto Moses the divine writ and caused apostle after apostle to follow him; and We vouchsafed unto Jesus, the son of Mary, all evidence of the truth, and strengthened him with holy inspiration. [Yet] is it not so that every time an apostle came unto you with something that was not to your liking, you gloried in your arrogance, and to some of them you gave the lie, while others you would slay?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/94.mp3","surahId":2,"words":[{"id":66891,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/002_087_001.mp3","charTypeName":"word"},{"id":66892,"position":2,"arabic":"ءَاتَيْنَا","translation":"আমরা দিয়েছি","audioUrl":"wbw/002_087_002.mp3","charTypeName":"word"},{"id":66893,"position":3,"arabic":"مُوسَى","translation":"মূসাকে","audioUrl":"wbw/002_087_003.mp3","charTypeName":"word"},{"id":66894,"position":4,"arabic":"ٱلْكِتَـٰبَ","translation":"কিতাব","audioUrl":"wbw/002_087_004.mp3","charTypeName":"word"},{"id":66895,"position":5,"arabic":"وَقَفَّيْنَا","translation":"এবং পর্যায়ক্রমে আমরা পাঠিয়েছি","audioUrl":"wbw/002_087_005.mp3","charTypeName":"word"},{"id":66896,"position":6,"arabic":"مِنۢ","translation":"থেকে","audioUrl":"wbw/002_087_006.mp3","charTypeName":"word"},{"id":66897,"position":7,"arabic":"بَعْدِهِۦ","translation":"তারপর","audioUrl":"wbw/002_087_007.mp3","charTypeName":"word"},{"id":66898,"position":8,"arabic":"بِٱلرُّسُلِ ۖ","translation":"রাসূলদেরকে","audioUrl":"wbw/002_087_008.mp3","charTypeName":"word"},{"id":66900,"position":9,"arabic":"وَءَاتَيْنَا","translation":"এবং আমরা দিয়েছি","audioUrl":"wbw/002_087_010.mp3","charTypeName":"word"},{"id":66901,"position":10,"arabic":"عِيسَى","translation":"ঈসাকে","audioUrl":"wbw/002_087_011.mp3","charTypeName":"word"},{"id":66902,"position":11,"arabic":"ٱبْنَ","translation":"পুত্র","audioUrl":"wbw/002_087_012.mp3","charTypeName":"word"},{"id":66903,"position":12,"arabic":"مَرْيَمَ","translation":"মারইয়ামের","audioUrl":"wbw/002_087_013.mp3","charTypeName":"word"},{"id":66904,"position":13,"arabic":"ٱلْبَيِّنَـٰتِ","translation":"সুস্পষ্ট নিদর্শনসমূহ","audioUrl":"wbw/002_087_014.mp3","charTypeName":"word"},{"id":66905,"position":14,"arabic":"وَأَيَّدْنَـٰهُ","translation":"ও তাকে আমরা সাহায্য করেছি","audioUrl":"wbw/002_087_015.mp3","charTypeName":"word"},{"id":66906,"position":15,"arabic":"بِرُوحِ","translation":"আত্মা দিয়ে","audioUrl":"wbw/002_087_016.mp3","charTypeName":"word"},{"id":66907,"position":16,"arabic":"ٱلْقُدُسِ ۗ","translation":"পবিত্র","audioUrl":"wbw/002_087_017.mp3","charTypeName":"word"},{"id":66909,"position":17,"arabic":"أَفَكُلَّمَا","translation":"যখনই অতঃপর কি","audioUrl":"wbw/002_087_019.mp3","charTypeName":"word"},{"id":66910,"position":18,"arabic":"جَآءَكُمْ","translation":"তোমাদের কাছে এসেছে","audioUrl":"wbw/002_087_020.mp3","charTypeName":"word"},{"id":66911,"position":19,"arabic":"رَسُولٌۢ","translation":"কোনো রাসূল","audioUrl":"wbw/002_087_021.mp3","charTypeName":"word"},{"id":66912,"position":20,"arabic":"بِمَا","translation":"তা নিয়ে যা","audioUrl":"wbw/002_087_022.mp3","charTypeName":"word"},{"id":66913,"position":21,"arabic":"لَا","translation":"না","audioUrl":"wbw/002_087_023.mp3","charTypeName":"word"},{"id":66914,"position":22,"arabic":"تَهْوَىٰٓ","translation":"পছন্দ করে","audioUrl":"wbw/002_087_024.mp3","charTypeName":"word"},{"id":66915,"position":23,"arabic":"أَنفُسُكُمُ","translation":"তোমাদের মন","audioUrl":"wbw/002_087_025.mp3","charTypeName":"word"},{"id":66916,"position":24,"arabic":"ٱسْتَكْبَرْتُمْ","translation":"তোমরা অহঙ্কার করেছ","audioUrl":"wbw/002_087_026.mp3","charTypeName":"word"},{"id":66917,"position":25,"arabic":"فَفَرِيقًۭا","translation":"অতঃপর একদলকে","audioUrl":"wbw/002_087_027.mp3","charTypeName":"word"},{"id":66918,"position":26,"arabic":"كَذَّبْتُمْ","translation":"তোমরা অস্বীকার করছো","audioUrl":"wbw/002_087_028.mp3","charTypeName":"word"},{"id":66919,"position":27,"arabic":"وَفَرِيقًۭا","translation":"আর একদলকে","audioUrl":"wbw/002_087_029.mp3","charTypeName":"word"},{"id":66920,"position":28,"arabic":"تَقْتُلُونَ","translation":"তোমরা হত্যা করেছ","audioUrl":"wbw/002_087_030.mp3","charTypeName":"word"},{"id":66921,"position":29,"arabic":"٨٧","translation":"(৮৭)","audioUrl":null,"charTypeName":"end"}]},{"number":88,"arabic":"وَقَالُوا۟ قُلُوبُنَا غُلْفٌۢ ۚ بَل لَّعَنَهُمُ ٱللَّهُ بِكُفْرِهِمْ فَقَلِيلًۭا مَّا يُؤْمِنُونَ","translation":"But they say, \"Our hearts are already full of knowledge.\" Nay, but God has rejected them because of their refusal to acknowledge the truth: for, few are the things in which they believe.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/95.mp3","surahId":2,"words":[{"id":67308,"position":1,"arabic":"وَقَالُوا۟","translation":"এবং তারা বলেছিল","audioUrl":"wbw/002_088_001.mp3","charTypeName":"word"},{"id":67309,"position":2,"arabic":"قُلُوبُنَا","translation":"''আমাদের অন্তর","audioUrl":"wbw/002_088_002.mp3","charTypeName":"word"},{"id":67310,"position":3,"arabic":"غُلْفٌۢ ۚ","translation":"আচ্ছাদিত (সুরক্ষিত)''","audioUrl":"wbw/002_088_003.mp3","charTypeName":"word"},{"id":67312,"position":4,"arabic":"بَل","translation":"বরং