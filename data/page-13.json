{"id":13,"ayahs":[{"number":84,"arabic":"وَإِذْ أَخَذْنَا مِيثَٰقَكُمْ لَا تَسْفِكُونَ دِمَآءَكُمْ وَلَا تُخْرِجُونَ أَنفُسَكُم مِّن دِيَٰرِكُمْ ثُمَّ أَقْرَرْتُمْ وَأَنتُمْ تَشْهَدُونَ","translation":"And lo! We accepted your solemn pledge that you would not shed one another's blood, and would not drive one another from your homelands - whereupon you acknowledged it; and thereto you bear witness [even now].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/91.mp3","surahId":2,"words":[{"id":65722,"position":1,"arabic":"وَإِذْ","translation":"এবং যখন","audioUrl":"wbw/002_084_001.mp3","charTypeName":"word"},{"id":65723,"position":2,"arabic":"أَخَذْنَا","translation":"আমরা নিয়েছিলাম","audioUrl":"wbw/002_084_002.mp3","charTypeName":"word"},{"id":65724,"position":3,"arabic":"مِيثَـٰقَكُمْ","translation":"তোমাদের প্রতিশ্রুতি","audioUrl":"wbw/002_084_003.mp3","charTypeName":"word"},{"id":65725,"position":4,"arabic":"لَا","translation":"''(যে) না","audioUrl":"wbw/002_084_004.mp3","charTypeName":"word"},{"id":65726,"position":5,"arabic":"تَسْفِكُونَ","translation":"তোমরা ঝরাবে","audioUrl":"wbw/002_084_005.mp3","charTypeName":"word"},{"id":65727,"position":6,"arabic":"دِمَآءَكُمْ","translation":"তোমাদের রক্ত","audioUrl":"wbw/002_084_006.mp3","charTypeName":"word"},{"id":65728,"position":7,"arabic":"وَلَا","translation":"না এবং","audioUrl":"wbw/002_084_007.mp3","charTypeName":"word"},{"id":65729,"position":8,"arabic":"تُخْرِجُونَ","translation":"তোমরা তাড়িয়ে দেবে","audioUrl":"wbw/002_084_008.mp3","charTypeName":"word"},{"id":65730,"position":9,"arabic":"أَنفُسَكُم","translation":"তোমাদের নিজেদেরকে","audioUrl":"wbw/002_084_009.mp3","charTypeName":"word"},{"id":65731,"position":10,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/002_084_010.mp3","charTypeName":"word"},{"id":65732,"position":11,"arabic":"دِيَـٰرِكُمْ","translation":"তোমাদের ঘর''","audioUrl":"wbw/002_084_011.mp3","charTypeName":"word"},{"id":65733,"position":12,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/002_084_012.mp3","charTypeName":"word"},{"id":65734,"position":13,"arabic":"أَقْرَرْتُمْ","translation":"তোমরা স্বীকার করেছিলে","audioUrl":"wbw/002_084_013.mp3","charTypeName":"word"},{"id":65735,"position":14,"arabic":"وَأَنتُمْ","translation":"এবং তোমরাই","audioUrl":"wbw/002_084_014.mp3","charTypeName":"word"},{"id":65736,"position":15,"arabic":"تَشْهَدُونَ","translation":"সাক্ষ্য দিচ্ছ","audioUrl":"wbw/002_084_015.mp3","charTypeName":"word"},{"id":65737,"position":16,"arabic":"٨٤","translation":"(৮৪)","audioUrl":null,"charTypeName":"end"}]},{"number":85,"arabic":"ثُمَّ أَنتُمْ هَٰٓؤُلَآءِ تَقْتُلُونَ أَنفُسَكُمْ وَتُخْرِجُونَ فَرِيقًۭا مِّنكُم مِّن دِيَٰرِهِمْ تَظَٰهَرُونَ عَلَيْهِم بِٱلْإِثْمِ وَٱلْعُدْوَٰنِ وَإِن يَأْتُوكُمْ أُسَٰرَىٰ تُفَٰدُوهُمْ وَهُوَ مُحَرَّمٌ عَلَيْكُمْ إِخْرَاجُهُمْ ۚ أَفَتُؤْمِنُونَ بِبَعْضِ ٱلْكِتَٰبِ وَتَكْفُرُونَ بِبَعْضٍۢ ۚ فَمَا جَزَآءُ مَن يَفْعَلُ ذَٰلِكَ مِنكُمْ إِلَّا خِزْىٌۭ فِى ٱلْحَيَوٰةِ ٱلدُّنْيَا ۖ وَيَوْمَ ٱلْقِيَٰمَةِ يُرَدُّونَ إِلَىٰٓ أَشَدِّ ٱلْعَذَابِ ۗ وَمَا ٱللَّهُ بِغَٰفِلٍ عَمَّا تَعْمَلُونَ","translation":"And yet, it is you who slay one another and drive some of your own people from their homelands, aiding one another against them in sin and hatred; but if they come to you as captives, you ransom them - although the very [act of] driving them away has been made unlawful to you!. Do you, then, believe in some parts of the divine writ and deny the truth of other parts? What, then, could be the reward of those among you who do such things but ignominy in the life of this world and, on the Day of Resurrection, commitment to most grievous suffering? For God is not unmindful of what you do.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/92.mp3","surahId":2,"words":[{"id":66146,"position":1,"arabic":"ثُمَّ","translation":"আবার","audioUrl":"wbw/002_085_001.mp3","charTypeName":"word"},{"id":66147,"position":2,"arabic":"أَنتُمْ","translation":"তোমরাই","audioUrl":"wbw/002_085_002.mp3","charTypeName":"word"},{"id":66148,"position":3,"arabic":"هَـٰٓؤُلَآءِ","translation":"ঐসব (লোক যারা)","audioUrl":"wbw/002_085_003.mp3","charTypeName":"word"},{"id":66149,"position":4,"arabic":"تَقْتُلُونَ","translation":"তোমরা হত্যা করছ","audioUrl":"wbw/002_085_004.mp3","charTypeName":"word"},{"id":66150,"position":5,"arabic":"أَنفُسَكُمْ","translation":"তোমাদের নিজেদেরকে","audioUrl":"wbw/002_085_005.mp3","charTypeName":"word"},{"id":66151,"position":6,"arabic":"وَتُخْرِجُونَ","translation":"এবং তোমরা তাড়িয়ে দিচ্ছ","audioUrl":"wbw/002_085_006.mp3","charTypeName":"word"},{"id":66152,"position":7,"arabic":"فَرِيقًۭا","translation":"এক দলকে","audioUrl":"wbw/002_085_007.mp3","charTypeName":"word"},{"id":66153,"position":8,"arabic":"مِّنكُم","translation":"তোমাদের মধ্য থেকে","audioUrl":"wbw/002_085_008.mp3","charTypeName":"word"},{"id":66154,"position":9,"arabic":"مِّن","translation":"হতে","audioUrl":"wbw/002_085_009.mp3","charTypeName":"word"},{"id":66155,"position":10,"arabic":"دِيَـٰرِهِمْ","translation":"তাদের ঘরগুলো","audioUrl":"wbw/002_085_010.mp3","charTypeName":"word"},{"id":66156,"position":11,"arabic":"تَظَـٰهَرُونَ","translation":"তোমরা সাহায্য করছ","audioUrl":"wbw/002_085_011.mp3","charTypeName":"word"},{"id":66157,"position":12,"arabic":"عَلَيْهِم","translation":"তাদের বিরুদ্ধে","audioUrl":"wbw/002_085_012.mp3","charTypeName":"word"},{"id":66158,"position":13,"arabic":"بِٱلْإِثْمِ","translation":"অন্যায়","audioUrl":"wbw/002_085_013.mp3","charTypeName":"word"},{"id":66159,"position":14,"arabic":"وَٱلْعُدْوَٰنِ","translation":"ও সীমালঙ্ঘন","audioUrl":"wbw/002_085_014.mp3","charTypeName":"word"},{"id":66160,"position":15,"arabic":"وَإِن","translation":"এবং যদি","audioUrl":"wbw/002_085_015.mp3","charTypeName":"word"},{"id":66161,"position":16,"arabic":"يَأْتُوكُمْ","translation":"তোমাদের কাছে আসে","audioUrl":"wbw/002_085_016.mp3","charTypeName":"word"},{"id":66162,"position":17,"arabic":"أُسَـٰرَىٰ","translation":"বন্দি (হয়ে)","audioUrl":"wbw/002_085_017.mp3","charTypeName":"word"},{"id":66163,"position":18,"arabic":"تُفَـٰدُوهُمْ","translation":"তাদের ছাড়াও মুক্তিপণ দিয়ে","audioUrl":"wbw/002_085_018.mp3","charTypeName":"word"},{"id":66164,"position":19,"arabic":"وَهُوَ","translation":"অথচ তা","audioUrl":"wbw/002_085_019.mp3","charTypeName":"word"},{"id":66165,"position":20,"arabic":"مُحَرَّمٌ","translation":"নিষিদ্ধ","audioUrl":"wbw/002_085_020.mp3","charTypeName":"word"},{"id":66166,"position":21,"arabic":"عَلَيْكُمْ","translation":"তোমাদের উপর","audioUrl":"wbw/002_085_021.mp3","charTypeName":"word"},{"id":66167,"position":22,"arabic":"إِخْرَاجُهُمْ ۚ","translation":"তাদের তাড়িয়ে দেওয়া","audioUrl":"wbw/002_085_022.mp3","charTypeName":"word"},{"id":66169,"position":23,"arabic":"أَفَتُؤْمِنُونَ","translation":"তোমরা তবে কি বিশ্বাস কর","audioUrl":"wbw/002_085_024.mp3","charTypeName":"word"},{"id":66170,"position":24,"arabic":"بِبَعْضِ","translation":"কিছু অংশের(ব্যাপারে)","audioUrl":"wbw/002_085_025.mp3","charTypeName":"word"},{"id":66171,"position":25,"arabic":"ٱلْكِتَـٰبِ","translation":"কিতাবের","audioUrl":"wbw/002_085_026.mp3","charTypeName":"word"},{"id":66172,"position":26,"arabic":"وَتَكْفُرُونَ","translation":"এবং অবিশ্বাস কর","audioUrl":"wbw/002_085_027.mp3","charTypeName":"word"},{"id":66173,"position":27,"arabic":"بِبَعْضٍۢ ۚ","translation":"(অপর) কিছু অংশকে","audioUrl":"wbw/002_085_028.mp3","charTypeName":"word"},{"id":66175,"position":28,"arabic":"فَمَا","translation":"সুতরাং কী(হতে পারে)","audioUrl":"wbw/002_085_030.mp3","charTypeName":"word"},{"id":66176,"position":29,"arabic":"جَزَآءُ","translation":"প্রতিদান","audioUrl":"wbw/002_085_031.mp3","charTypeName":"word"},{"id":66177,"position":30,"arabic":"مَن","translation":"যে","audioUrl":"wbw/002_085_032.mp3","charTypeName":"word"},{"id":66178,"position":31,"arabic":"يَفْعَلُ","translation":"করবে","audioUrl":"wbw/002_085_033.mp3","charTypeName":"word"},{"id":66179,"position":32,"arabic":"ذَٰلِكَ","translation":"এরূপ","audioUrl":"wbw/002_085_034.mp3","c