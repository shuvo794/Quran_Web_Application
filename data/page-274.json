{"id":274,"ayahs":[{"number":65,"arabic":"وَٱللَّهُ أَنزَلَ مِنَ ٱلسَّمَآءِ مَآءًۭ فَأَحْيَا بِهِ ٱلْأَرْضَ بَعْدَ مَوْتِهَآ ۚ إِنَّ فِى ذَٰلِكَ لَءَايَةًۭ لِّقَوْمٍۢ يَسْمَعُونَ","translation":"AND GOD sends down water from the skies, giving life thereby to the earth after it had been lifeless: in this, behold, there is a message indeed for people who [are willing to] listen.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1966.mp3","surahId":16,"words":[{"id":57447,"position":1,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ্‌","audioUrl":"wbw/016_065_001.mp3","charTypeName":"word"},{"id":57448,"position":2,"arabic":"أَنزَلَ","translation":"বর্ষণ করেন","audioUrl":"wbw/016_065_002.mp3","charTypeName":"word"},{"id":57449,"position":3,"arabic":"مِنَ","translation":"থেকে","audioUrl":"wbw/016_065_003.mp3","charTypeName":"word"},{"id":57450,"position":4,"arabic":"ٱلسَّمَآءِ","translation":"আকাশ","audioUrl":"wbw/016_065_004.mp3","charTypeName":"word"},{"id":57451,"position":5,"arabic":"مَآءًۭ","translation":"পানি","audioUrl":"wbw/016_065_005.mp3","charTypeName":"word"},{"id":57452,"position":6,"arabic":"فَأَحْيَا","translation":"অতঃপর প্রাণ দেন","audioUrl":"wbw/016_065_006.mp3","charTypeName":"word"},{"id":57453,"position":7,"arabic":"بِهِ","translation":"দিয়ে তা","audioUrl":"wbw/016_065_007.mp3","charTypeName":"word"},{"id":57454,"position":8,"arabic":"ٱلْأَرْضَ","translation":"জমিকে","audioUrl":"wbw/016_065_008.mp3","charTypeName":"word"},{"id":57455,"position":9,"arabic":"بَعْدَ","translation":"পর","audioUrl":"wbw/016_065_009.mp3","charTypeName":"word"},{"id":57456,"position":10,"arabic":"مَوْتِهَآ ۚ","translation":"তার মৃত্যুর","audioUrl":"wbw/016_065_010.mp3","charTypeName":"word"},{"id":57458,"position":11,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/016_065_012.mp3","charTypeName":"word"},{"id":57459,"position":12,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/016_065_013.mp3","charTypeName":"word"},{"id":57460,"position":13,"arabic":"ذَٰلِكَ","translation":"এর","audioUrl":"wbw/016_065_014.mp3","charTypeName":"word"},{"id":57461,"position":14,"arabic":"لَـَٔايَةًۭ","translation":"অবশ্যই নিদর্শন","audioUrl":"wbw/016_065_015.mp3","charTypeName":"word"},{"id":57462,"position":15,"arabic":"لِّقَوْمٍۢ","translation":"জন্যে লোকদের","audioUrl":"wbw/016_065_016.mp3","charTypeName":"word"},{"id":57463,"position":16,"arabic":"يَسْمَعُونَ","translation":"(যারা) শুনে","audioUrl":"wbw/016_065_017.mp3","charTypeName":"word"},{"id":57464,"position":17,"arabic":"٦٥","translation":"(৬৫)","audioUrl":null,"charTypeName":"end"}]},{"number":66,"arabic":"وَإِنَّ لَكُمْ فِى ٱلْأَنْعَٰمِ لَعِبْرَةًۭ ۖ نُّسْقِيكُم مِّمَّا فِى بُطُونِهِۦ مِنۢ بَيْنِ فَرْثٍۢ وَدَمٍۢ لَّبَنًا خَالِصًۭا سَآئِغًۭا لِّلشَّٰرِبِينَ","translation":"And, behold, in the cattle [too] there is indeed a lesson for you: We give you to drink of that [fluid] which is [secreted from] within their bellies between that which is to be eliminated [from the animal's body] and [its] life-blood: milk pure and pleasant to those who drink it.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1967.mp3","surahId":16,"words":[{"id":57913,"position":1,"arabic":"وَإِنَّ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/016_066_001.mp3","charTypeName":"word"},{"id":57914,"position":2,"arabic":"لَكُمْ","translation":"জন্যে তোমাদের","audioUrl":"wbw/016_066_002.mp3","charTypeName":"word"},{"id":57915,"position":3,"arabic":"فِى","translation":"মধ্যে রয়েছে","audioUrl":"wbw/016_066_003.mp3","charTypeName":"word"},{"id":57916,"position":4,"arabic":"ٱلْأَنْعَـٰمِ","translation":"গবাদিপশুর","audioUrl":"wbw/016_066_004.mp3","charTypeName":"word"},{"id":57917,"position":5,"arabic":"لَعِبْرَةًۭ ۖ","translation":"অবশ্যই শিক্ষা","audioUrl":"wbw/016_066_005.mp3","charTypeName":"word"},{"id":57919,"position":6,"arabic":"نُّسْقِيكُم","translation":"আমরা পান করাই তোমাদের","audioUrl":"wbw/016_066_007.mp3","charTypeName":"word"},{"id":57920,"position":7,"arabic":"مِّمَّا","translation":"তা হ'তে যা","audioUrl":"wbw/016_066_008.mp3","charTypeName":"word"},{"id":57921,"position":8,"arabic":"فِى","translation":"মধ্যে আছে","audioUrl":"wbw/016_066_009.mp3","charTypeName":"word"},{"id":57922,"position":9,"arabic":"بُطُونِهِۦ","translation":"তার পেটগুলোর","audioUrl":"wbw/016_066_010.mp3","charTypeName":"word"},{"id":57923,"position":10,"arabic":"مِنۢ","translation":"থেকে","audioUrl":"wbw/016_066_011.mp3","charTypeName":"word"},{"id":57924,"position":11,"arabic":"بَيْنِ","translation":"মধ্য","audioUrl":"wbw/016_066_012.mp3","charTypeName":"word"},{"id":57925,"position":12,"arabic":"فَرْثٍۢ","translation":"গোবর","audioUrl":"wbw/016_066_013.mp3","charTypeName":"word"},{"id":57926,"position":13,"arabic":"وَدَمٍۢ","translation":"ও রক্তের","audioUrl":"wbw/016_066_014.mp3","charTypeName":"word"},{"id":57927,"position":14,"arabic":"لَّبَنًا","translation":"(তা হলো) দুধ","audioUrl":"wbw/016_066_015.mp3","charTypeName":"word"},{"id":57928,"position":15,"arabic":"خَالِصًۭا","translation":"বিশুদ্ধ","audioUrl":"wbw/016_066_016.mp3","charTypeName":"word"},{"id":57929,"position":16,"arabic":"سَآئِغًۭا","translation":"উপাদেয়","audioUrl":"wbw/016_066_017.mp3","charTypeName":"word"},{"id":57930,"position":17,"arabic":"لِّلشَّـٰرِبِينَ","translation":"জন্যে পানকারীদের","audioUrl":"wbw/016_066_018.mp3","charTypeName":"word"},{"id":57931,"position":18,"arabic":"٦٦","translation":"(৬৬)","audioUrl":null,"charTypeName":"end"}]},{"number":67,"arabic":"وَمِن ثَمَرَٰتِ ٱلنَّخِيلِ وَٱلْأَعْنَٰبِ تَتَّخِذُونَ مِنْهُ سَكَرًۭا وَرِزْقًا حَسَنًا ۗ إِنَّ فِى ذَٰلِكَ لَءَايَةًۭ لِّقَوْمٍۢ يَعْقِلُونَ","translation":"And [We grant you nourishment] from the fruit of date-palms and vines: from it you derive intoxicants as well as wholesome sustenance -in this, behold, there is a message indeed for people who use their reason!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1968.mp3","surahId":16,"words":[{"id":58381,"position":1,"arabic":"وَمِن","translation":"এবং থেকে","audioUrl":"wbw/016_067_001.mp3","charTypeName":"word"},{"id":58382,"position":2,"arabic":"ثَمَرَٰتِ","translation":"ফলগুলো","audioUrl":"wbw/016_067_002.mp3","charTypeName":"word"},{"id":58383,"position":3,"arabic":"ٱلنَّخِيلِ","translation":"খেজুর গাছের","audioUrl":"wbw/016_067_003.mp3","charTypeName":"word"},{"id":58384,"position":4,"arabic":"وَٱلْأَعْنَـٰبِ","translation":"ও আঙ্গুরগুলো","audioUrl":"wbw/016_067_004.mp3","charTypeName":"word"},{"id":58385,"position":5,"arabic":"تَتَّخِذُونَ","translation":"তোমরা গ্রহণ করো","audioUrl":"wbw/016_067_005.mp3","charTypeName":"word"},{"id":58386,"position":6,"arabic":"مِنْهُ","translation":"তা থেকে","audioUrl":"wbw/016_067_006.mp3","charTypeName":"word"},{"id":58387,"position":7,"arabic":"سَكَرًۭا","translation":"মাদকদ্রব্য","audioUrl":"wbw/016_067_007.mp3","charTypeName":"word"},{"id":58388,"position":8,"arabic":"وَرِزْقًا","translation":"ও জীবিকা","audioUrl":"wbw/016_067_008.mp3","charTypeName":"word"},{"id":58389,"position":9,"arabic":"حَسَنًا ۗ","translation":"উত্তম","audioUrl":"wbw/016_067_009.mp3","charTypeName":"word"},{"id":58391,"position":10,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/016_067_011.mp3","charTypeName":"word"},{"id":58392,"position":11,"arabic":"فِى","translation":"মধ্যে আছে","audioUrl":"wbw/016_067_012.mp3","charTypeName":"word"},{"id":58393,"position":12,"arabic":"ذَٰلِكَ","translation":"এর","audioUrl":"wbw/016_067_013.mp3","charTypeName":"word"},{"id":58394,"position":13,"arabic":"لَـَٔايَةًۭ","translation":"অবশ্যই নিদর্শন","audioUrl":"wbw/016_067_014.mp3","charTypeName":"word"},{"id":58395,"position":14,"arabic":"لِّقَوْمٍۢ","translation":"জন্যে লোকদের","audioUrl":"wbw/016_067_015.mp3","charTypeName":"word"},{"id":58396,"position":15,"arabic":"يَعْقِلُونَ","translation":"(যারা) জ্ঞান রাখে","audioUrl":"wbw/016_067_016.mp3","charTypeName":"word"},{"id":58397,"position":16,"arabic":"٦٧","translation":"(৬৭)","audioUrl":null,"charTypeName":"end"}]},{"number":68,"arabic":"وَأَوْحَىٰ رَبُّكَ إِلَى ٱلنَّحْلِ أَنِ ٱتَّخِذِى مِنَ ٱلْجِبَالِ بُيُوتًۭا وَمِنَ ٱلشَّجَرِ وَمِمَّا يَعْرِشُونَ","translation":"And [consider how] thy Sustainer has inspired the bee: \"Prepare for thyself dwellings in mountains and in trees, and in what [men] may build [for thee by way of hives];","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1969.mp3","surahId":16,"words":[{"id":58858,"position":1,"arabic":"وَأَوْحَىٰ","translation":"এবং ওহী করেন","audioUrl":"wbw/016_068_001.mp3","charTypeName":"word"},{"id":58859,"position":2,"arabic":"رَبُّكَ","translation":"তার রব","audioUrl":"wbw/016_068_002.mp3","charTypeName":"word"},{"id":58860,"position":3,"arabic":"إِلَى","translation":"প্রতি","audioUrl":"wbw/016_068_003.mp3","charTypeName":"word"},{"id":58861,"position":4,"arabic":"ٱلنَّحْلِ","translation":"মৌমাছির","audioUrl":"wbw/016_068_004.mp3","charTypeName":"word"},{"id":58862,"position":5,"arabic":"أَنِ","translation":"যে","audioUrl":"wbw/016_068_005.mp3","charTypeName":"word"},{"id":58863,"position":6,"arabic":"ٱتَّخِذِى","translation":"\"গ্রহণ করো (বানাও)","audioUrl":"wbw/016_068_006.mp3","charTypeName":"word"},{"id":58864,"position":7,"arabic":"مِنَ","translation":"মধ্যে","audioUrl":"wbw/016_068_007.mp3","charTypeName":"word"},{"id":58865,"position":8,"arabic":"ٱلْجِبَالِ","translation":"পাহাড়গুলোর","audioUrl":"wbw/016_068_008.mp3","charTypeName":"word"},{"id":58866,"position":9,"arabic":"بُيُوتًۭا","translation":"ঘরসমূহ (অর্থাৎ চাক)","audioUrl":"wbw/016_068_009.mp3","charTypeName":"word"},{"id":58867,"position":10,"arabic":"وَمِنَ","translation":"ও মধ্যে","audioUrl":"wbw/016_068_010.mp3","charTypeName":"word"},{"id":58868,"position":11,"arabic":"ٱلشَّجَرِ","translation":"গাছের","audioUrl":"wbw/016_068_011.mp3","charTypeName":"word"},{"id":58869,"position":12,"arabic":"وَمِمَّا","translation":"এবং ঐ বস্তুর মধ্যে যা","audioUrl":"wbw/016_068_012.mp3","charTypeName":"word"},{"id":58870,"position":13,"arabic":"يَعْرِشُونَ","translation":"তারা উঁচু করে (দালান বা মাচা)","audioUrl":"wbw/016_068_013.mp3","charTypeName":"word"},{"id":58871,"position":14,"arabic":"٦٨","translation":"(৬৮)","audioUrl":null,"charTypeName":"end"}]},{"number":69,"arabic":"ثُمَّ كُلِى مِن كُلِّ ٱلثَّمَرَٰتِ فَٱسْلُكِى سُبُلَ رَبِّكِ ذُلُلًۭا ۚ يَخْرُجُ مِنۢ بُطُونِهَا شَرَابٌۭ مُّخْتَلِفٌ أَلْوَٰنُهُۥ فِيهِ شِفَآءٌۭ لِّلنَّاسِ ۗ إِنَّ فِى ذَٰلِكَ لَءَايَةًۭ لِّقَوْمٍۢ يَتَفَكَّرُونَ","translation":"and then eat of all manner of fruit, and follow humbly the paths ordained for thee by thy Sustainer.\" [And lo!] there issues from within these [bees] a fluid of many hues, wherein there is health for man. In all this, behold, there is a message indeed for people who think!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1970.mp3","surahId":16,"words":[{"id":59192,"position":1,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/016_069_001.mp3","charTypeName":"word"},{"id":59193,"position":2,"arabic":"كُلِى","translation":"খাও","audioUrl":"wbw/016_069_002.mp3","charTypeName":"word"},{"id":59194,"position":3,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/016_069_003.mp3","charTypeName":"word"},{"id":59195,"position":4,"arabic":"كُلِّ","translation":"প্রত্যেক","audioUrl":"wbw/016_069_004.mp3","charTypeName":"word"},{"id":59196,"position":5,"arabic":"ٱلثَّمَرَٰتِ","translation":"ফলসমূহ","audioUrl":"wbw/016_069_005.mp3","charTypeName":"word"},{"id":59197,"position":6,"arabic":"فَٱسْلُكِى","translation":"অতঃপর চলো","audioUrl":"wbw/016_069_006.mp3","charTypeName":"word"},{"id":59198,"position":7,"arabic":"سُبُلَ","translation":"পথসমূহে","audioUrl":"wbw/016_069_007.mp3","charTypeName":"word"},{"id":59199,"position":8,"arabic":"رَبِّكِ","translation":"তোমার রবের","audioUrl":"wbw/016_069_008.mp3","charTypeName":"word"},{"id":59200,"position":9,"arabic":"ذُلُلًۭا ۚ","translation":"সহজ\"","audioUrl":"wbw/016_069_009.mp3","charTypeName":"word"},{"id":59202,"position":10,"arabic":"يَخْرُجُ","translation":"বের হয়","audioUrl":"