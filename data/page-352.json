{"id":352,"ayahs":[{"number":21,"arabic":"۞ يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ لَا تَتَّبِعُوا۟ خُطُوَٰتِ ٱلشَّيْطَٰنِ ۚ وَمَن يَتَّبِعْ خُطُوَٰتِ ٱلشَّيْطَٰنِ فَإِنَّهُۥ يَأْمُرُ بِٱلْفَحْشَآءِ وَٱلْمُنكَرِ ۚ وَلَوْلَا فَضْلُ ٱللَّهِ عَلَيْكُمْ وَرَحْمَتُهُۥ مَا زَكَىٰ مِنكُم مِّنْ أَحَدٍ أَبَدًۭا وَلَٰكِنَّ ٱللَّهَ يُزَكِّى مَن يَشَآءُ ۗ وَٱللَّهُ سَمِيعٌ عَلِيمٌۭ","translation":"O You who have attained to faith! Follow not Satan’s footsteps: for he who follows Satan’s foot­steps [will find that], behold, he enjoins but deeds of abomination and all that runs counter to reason. And were it not for God’s favour upon you and His grace, not one of you would ever have remained pure. For [thus it is:] God who causes whomever He wills to grow in purity: for God is all-hearing, all-­knowing.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2812.mp3","surahId":24,"words":[{"id":23586,"position":1,"arabic":"۞ يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/024_021_002.mp3","charTypeName":"word"},{"id":23587,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/024_021_003.mp3","charTypeName":"word"},{"id":23588,"position":3,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছো","audioUrl":"wbw/024_021_004.mp3","charTypeName":"word"},{"id":23589,"position":4,"arabic":"لَا","translation":"না","audioUrl":"wbw/024_021_005.mp3","charTypeName":"word"},{"id":23590,"position":5,"arabic":"تَتَّبِعُوا۟","translation":"তোমরা অনুসরণ করো","audioUrl":"wbw/024_021_006.mp3","charTypeName":"word"},{"id":23591,"position":6,"arabic":"خُطُوَٰتِ","translation":"পদাঙ্ক","audioUrl":"wbw/024_021_007.mp3","charTypeName":"word"},{"id":23592,"position":7,"arabic":"ٱلشَّيْطَـٰنِ ۚ","translation":"শয়তানের","audioUrl":"wbw/024_021_008.mp3","charTypeName":"word"},{"id":23594,"position":8,"arabic":"وَمَن","translation":"আর যে","audioUrl":"wbw/024_021_010.mp3","charTypeName":"word"},{"id":23595,"position":9,"arabic":"يَتَّبِعْ","translation":"অনুসরণ করবে","audioUrl":"wbw/024_021_011.mp3","charTypeName":"word"},{"id":23596,"position":10,"arabic":"خُطُوَٰتِ","translation":"পদাঙ্ক","audioUrl":"wbw/024_021_012.mp3","charTypeName":"word"},{"id":23597,"position":11,"arabic":"ٱلشَّيْطَـٰنِ","translation":"শয়তানের","audioUrl":"wbw/024_021_013.mp3","charTypeName":"word"},{"id":23598,"position":12,"arabic":"فَإِنَّهُۥ","translation":"তাহ'লে সে নিশ্চয়ই","audioUrl":"wbw/024_021_014.mp3","charTypeName":"word"},{"id":23599,"position":13,"arabic":"يَأْمُرُ","translation":"নির্দেশ দেবে","audioUrl":"wbw/024_021_015.mp3","charTypeName":"word"},{"id":23600,"position":14,"arabic":"بِٱلْفَحْشَآءِ","translation":"প্রতি নির্লজ্জতার","audioUrl":"wbw/024_021_016.mp3","charTypeName":"word"},{"id":23601,"position":15,"arabic":"وَٱلْمُنكَرِ ۚ","translation":"ও মন্দ কাজের","audioUrl":"wbw/024_021_017.mp3","charTypeName":"word"},{"id":23603,"position":16,"arabic":"وَلَوْلَا","translation":"না যদি আর (হতো)","audioUrl":"wbw/024_021_019.mp3","charTypeName":"word"},{"id":23604,"position":17,"arabic":"فَضْلُ","translation":"অনুগ্রহ","audioUrl":"wbw/024_021_020.mp3","charTypeName":"word"},{"id":23605,"position":18,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌র","audioUrl":"wbw/024_021_021.mp3","charTypeName":"word"},{"id":23606,"position":19,"arabic":"عَلَيْكُمْ","translation":"তোমাদের উপর","audioUrl":"wbw/024_021_022.mp3","charTypeName":"word"},{"id":23607,"position":20,"arabic":"وَرَحْمَتُهُۥ","translation":"ও তাঁর দয়া","audioUrl":"wbw/024_021_023.mp3","charTypeName":"word"},{"id":23608,"position":21,"arabic":"مَا","translation":"না","audioUrl":"wbw/024_021_024.mp3","charTypeName":"word"},{"id":23609,"position":22,"arabic":"زَكَىٰ","translation":"পবিত্র হ'তে পারতো","audioUrl":"wbw/024_021_025.mp3","charTypeName":"word"},{"id":23610,"position":23,"arabic":"مِنكُم","translation":"তোমাদের মধ্যে","audioUrl":"wbw/024_021_026.mp3","charTypeName":"word"},{"id":23611,"position":24,"arabic":"مِّنْ","translation":"কোন","audioUrl":"wbw/024_021_027.mp3","charTypeName":"word"},{"id":23