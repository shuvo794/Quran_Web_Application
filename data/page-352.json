should forgive you your sins, seeing that God is much-forgiving, a dispenser of grace?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2813.mp3","surahId":24,"words":[{"id":24943,"position":1,"arabic":"وَلَا","translation":"আর না (যেন)","audioUrl":"wbw/024_022_001.mp3","charTypeName":"word"},{"id":24944,"position":2,"arabic":"يَأْتَلِ","translation":"শপথ গ্রহণ করে","audioUrl":"wbw/024_022_002.mp3","charTypeName":"word"},{"id":24945,"position":3,"arabic":"أُو۟لُوا۟","translation":"অধিকারীরা","audioUrl":"wbw/024_022_003.mp3","charTypeName":"word"},{"id":24946,"position":4,"arabic":"ٱلْفَضْلِ","translation":"অনুগ্রহের","audioUrl":"wbw/024_022_004.mp3","charTypeName":"word"},{"id":24947,"position":5,"arabic":"مِنكُمْ","translation":"তোমাদের মধ্য থেকে","audioUrl":"wbw/024_022_005.mp3","charTypeName":"word"},{"id":24948,"position":6,"arabic":"وَٱلسَّعَةِ","translation":"ও প্রাচুর্যের (অধিকারীরা)","audioUrl":"wbw/024_022_006.mp3","charTypeName":"word"},{"id":24949,"position":7,"arabic":"أَن","translation":"যে","audioUrl":"wbw/024_022_007.mp3","charTypeName":"word"},{"id":24950,"position":8,"arabic":"يُؤْتُوٓا۟","translation":"তারা দিবে (না)","audioUrl":"wbw/024_022_008.mp3","charTypeName":"word"},{"id":24951,"position":9,"arabic":"أُو۟لِى","translation":"অধিকারীদের","audioUrl":"wbw/024_022_009.mp3","charTypeName":"word"},{"id":24952,"position":10,"arabic":"ٱلْقُرْبَىٰ","translation":"নৈকট্যের (আত্মীয় স্বজনকে)","audioUrl":"wbw/024_022_010.mp3","charTypeName":"word"},{"id":24953,"position":11,"arabic":"وَٱلْمَسَـٰكِينَ","translation":"ও অভাবগ্রস্তদেরকে","audioUrl":"wbw/024_022_011.mp3","charTypeName":"word"},{"id":24954,"position":12,"arabic":"وَٱلْمُهَـٰجِرِينَ","translation":"ও মুহাজিরদেরকে","audioUrl":"wbw/024_022_012.mp3","charTypeName":"word"},{"id":24955,"position":13,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/024_022_013.mp3","charTypeName":"word"},{"id":24956,"position":14,"arabic":"سَبِيلِ","translation":"পথের","audioUrl":"wbw/024_022_014.mp3","charTypeName":"word"},{"id":24957,"position":15,"arabic":"ٱللَّهِ ۖ","translation":"আল্লাহ্‌র","audioUrl":"wbw/024_022_015.mp3","charTypeName":"word"},{"id":24959,"position":16,"arabic":"وَلْيَعْفُوا۟","translation":"এবং যেন তারা ক্ষমা করে দেয়","audioUrl":"wbw/024_022_017.mp3","charTypeName":"word"},{"id":24960,"position":17,"arabic":"وَلْيَصْفَحُوٓا۟ ۗ","translation":"এবং যেন দোষ-ত্রুটি উপেক্ষা করে","audioUrl":"wbw/024_022_018.mp3","charTypeName":"word"},{"id":24962,"position":18,"arabic":"أَلَا","translation":"না কি","audioUrl":"wbw/024_022_020.mp3","charTypeName":"word"},{"id":24963,"position":19,"arabic":"تُحِبُّونَ","translation":"তোমরা পছন্দ করো","audioUrl":"wbw/024_022_021.mp3","charTypeName":"word"},{"id":24964,"position":20,"arabic":"أَن","translation":"যে","audioUrl":"wbw/024_022_022.mp3","charTypeName":"word"},{"id":24965,"position":21,"arabic":"يَغْفِرَ","translation":"ক্ষমা করবেন","audioUrl":"wbw/024_022_023.mp3","charTypeName":"word"},{"id":24966,"position":22,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌","audioUrl":"wbw/024_022_024.mp3","charTypeName":"word"},{"id":24967,"position":23,"arabic":"لَكُمْ ۗ","translation":"তোমাদেরকে","audioUrl":"wbw/024_022_025.mp3","charTypeName":"word"},{"id":24969,"position":24,"arabic":"وَٱللَّهُ","translation":"আর আল্লাহ্‌","audioUrl":"wbw/024_022_027.mp3","charTypeName":"word"},{"id":24970,"position":25,"arabic":"غَفُورٌۭ","translation":"বড় ক্ষমাশীল","audioUrl":"wbw/024_022_028.mp3","charTypeName":"word"},{"id":24971,"position":26,"arabic":"رَّحِيمٌ","translation":"পরম দয়ালু","audioUrl":"wbw/024_022_029.mp3","charTypeName":"word"},{"id":24972,"position":27,"arabic":"٢٢","translation":"(২২)","audioUrl":null,"charTypeName":"end"}]},{"number":23,"arabic":"إِنَّ ٱلَّذِينَ يَرْمُونَ ٱلْمُحْصَنَٰتِ ٱلْغَٰفِلَٰتِ ٱلْمُؤْمِنَٰتِ لُعِنُوا۟ فِى ٱلدُّنْيَا وَٱلْءَاخِرَةِ وَلَهُمْ عَذَابٌ عَظِيمٌۭ","translation":"[But,] verily, those who [falsely, and without repentance,] accuse chaste women who may have been unthinkingly c