{"id":184,"ayahs":[{"number":53,"arabic":"ذَٰلِكَ بِأَنَّ ٱللَّهَ لَمْ يَكُ مُغَيِّرًۭا نِّعْمَةً أَنْعَمَهَا عَلَىٰ قَوْمٍ حَتَّىٰ يُغَيِّرُوا۟ مَا بِأَنفُسِهِمْ ۙ وَأَنَّ ٱللَّهَ سَمِيعٌ عَلِيمٌۭ","translation":"This, because God would never change the blessings with which He has graced a people unless they change their inner selves: and [know] that God is all-hearing, all-seeing.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1213.mp3","surahId":8,"words":[{"id":50534,"position":1,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/008_053_001.mp3","charTypeName":"word"},{"id":50535,"position":2,"arabic":"بِأَنَّ","translation":"এজন্যে যে","audioUrl":"wbw/008_053_002.mp3","charTypeName":"word"},{"id":50536,"position":3,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/008_053_003.mp3","charTypeName":"word"},{"id":50537,"position":4,"arabic":"لَمْ","translation":"না","audioUrl":"wbw/008_053_004.mp3","charTypeName":"word"},{"id":50538,"position":5,"arabic":"يَكُ","translation":"ছিলেন","audioUrl":"wbw/008_053_005.mp3","charTypeName":"word"},{"id":50539,"position":6,"arabic":"مُغَيِّرًۭا","translation":"পরিবর্তনকারী","audioUrl":"wbw/008_053_006.mp3","charTypeName":"word"},{"id":50540,"position":7,"arabic":"نِّعْمَةً","translation":"(তাঁর)অনুগ্রহের","audioUrl":"wbw/008_053_007.mp3","charTypeName":"word"},{"id":50541,"position":8,"arabic":"أَنْعَمَهَا","translation":"যা তিনি দান করেছেন","audioUrl":"wbw/008_053_008.mp3","charTypeName":"word"},{"id":50542,"position":9,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/008_053_009.mp3","charTypeName":"word"},{"id":50543,"position":10,"arabic":"قَوْمٍ","translation":"সম্প্রদায়ের","audioUrl":"wbw/008_053_010.mp3","charTypeName":"word"},{"id":50544,"position":11,"arabic":"حَتَّىٰ","translation":"যতক্ষণ না","audioUrl":"wbw/008_053_011.mp3","charTypeName":"word"},{"id":50545,"position":12,"arabic":"يُغَيِّرُوا۟","translation":"তারা পরিবর্তন করে","audioUrl":"wbw/008_053_012.mp3","charTypeName":"word"},{"id":50546,"position":13,"arabic":"مَا","translation":"তা","audioUrl":"wbw/008_053_013.mp3","charTypeName":"word"},{"id":50547,"position":14,"arabic":"بِأَنفُسِهِمْ ۙ","translation":"উপর নিজেদের তাদের","audioUrl":"wbw/008_053_014.mp3","charTypeName":"word"},{"id":50549,"position":15,"arabic":"وَأَنَّ","translation":"এবং (এও) যে","audioUrl":"wbw/008_053_016.mp3","charTypeName":"word"},{"id":50550,"position":16,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/008_053_017.mp3","charTypeName":"word"},{"id":50551,"position":17,"arabic":"سَمِيعٌ","translation":"সবকিছু শুনেন","audioUrl":"wbw/008_053_018.mp3","charTypeName":"word"},{"id":50552,"position":18,"arabic":"عَلِيمٌۭ","translation":"সবকিছু জানেন","audioUrl":"wbw/008_053_019.mp3","charTypeName":"word"},{"id":50553,"position":19,"arabic":"٥٣","translation":"(৫৩)","audioUrl":null,"charTypeName":"end"}]},{"number":54,"arabic":"كَدَأْبِ ءَالِ فِرْعَوْنَ ۙ وَٱلَّذِينَ مِن قَبْلِهِمْ ۚ كَذَّبُوا۟ بِـَٔايَٰتِ رَبِّهِمْ فَأَهْلَكْنَٰهُم بِذُنُوبِهِمْ وَأَغْرَقْنَآ ءَالَ فِرْعَوْنَ ۚ وَكُلٌّۭ كَانُوا۟ ظَٰلِمِينَ","translation":"[To those sinners shall happen] the like of what happened to Pharaoh's people and those who lived before them: they gave the lie to their Sustainer's messages - and so We destroyed them in return for their sins, and caused Pharaoh's people to drown: for they were evildoers all.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1214.mp3","surahId":8,"words":[{"id":51164,"position":1,"arabic":"كَدَأْبِ","translation":"মতো স্বভাবের","audioUrl":"wbw/008_054_001.mp3","charTypeName":"word"},{"id":51165,"position":2,"arabic":"ءَالِ","translation":"বংশধরদের","audioUrl":"wbw/008_054_002.mp3","charTypeName":"word"},{"id":51166,"position":3,"arabic":"فِرْعَوْنَ ۙ","translation":"ফিরাউনের","audioUrl":"wbw/008_054_003.mp3","charTypeName":"word"},{"id":51168,"position":4,"arabic":"وَٱلَّذِينَ","translation":"ও যারা (ছিলো)","audioUrl":"wbw/008_054_005.mp3","charTypeName":"word"},{"id":51169,"position":5,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/008_054_006.mp3","charTypeName":"word"},{"id":51170,"position":6,"arabic":"قَبْلِهِمْ ۚ","translation":"পূর্ব তাদের(এদের সাথে তাই হবে)","audioUrl":"wbw/008_054_007.mp3","charTypeName":"word"},{"id":51172,"position":7,"arabic":"كَذَّبُوا۟","translation":"তারা অস্বীকার করেছিলো","audioUrl":"wbw/008_054_009.mp3","charTypeName":"word"},{"id":51173,"position":8,"arabic":"بِـَٔايَـٰتِ","translation":"প্রতি নিদর্শনগুলোর","audioUrl":"wbw/008_054_010.mp3","charTypeName":"word"},{"id":51174,"position":9,"arabic":"رَبِّهِمْ","translation":"রবের তাদের","audioUrl":"wbw/008_054_011.mp3","charTypeName":"word"},{"id":51175,"position":10,"arabic":"فَأَهْلَكْنَـٰهُم","translation":"তাই ধ্বংস করেছিলাম আমরা তাদেরকে","audioUrl":"wbw/008_054_012.mp3","charTypeName":"word"},{"id":51176,"position":11,"arabic":"بِذُنُوبِهِمْ","translation":"কারণে পাপসমূহের তাদের","audioUrl":"wbw/008_054_013.mp3","charTypeName":"word"},{"id":51177,"position":12,"arabic":"وَأَغْرَقْنَآ","translation":"এবং ডুবিয়ে দিয়েছিলাম আমরা","audioUrl":"wbw/008_054_014.mp3","charTypeName":"word"},{"id":51178,"position":13,"arabic":"ءَالَ","translation":"বংশধরদের","audioUrl":"wbw/008_054_015.mp3","charTypeName":"word"},{"id":51179,"position":14,"arabic":"فِرْعَوْنَ ۚ","translation":"ফিরআউনের","audioUrl":"wbw/008_054_016.mp3","charTypeName":"word"},{"id":51181,"position":15,"arabic":"وَكُلٌّۭ","translation":"এবং সবাই","audioUrl":"wbw/008_054_018.mp3","charTypeName":"word"},{"id":51182,"position":16,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/008_054_019.mp3","charTypeName":"word"},{"id":51183,"position":17,"arabic":"ظَـٰلِمِينَ","translation":"সীমালঙ্ঘনকারী","audioUrl":"wbw/008_054_020.mp3","charTypeName":"word"},{"id":51184,"position":18,"arabic":"٥٤","translation":"(৫৪)","audioUrl":null,"charTypeName":"end"}]},{"number":55,"arabic":"إِنَّ شَرَّ ٱلدَّوَآبِّ عِندَ ٱللَّهِ ٱلَّذِينَ كَفَرُوا۟ فَهُمْ لَا يُؤْمِنُونَ","translation":"Ver