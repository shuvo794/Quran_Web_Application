:"wbw/008_058_002.mp3","charTypeName":"word"},{"id":53261,"position":3,"arabic":"مِن","translation":"হতে","audioUrl":"wbw/008_058_003.mp3","charTypeName":"word"},{"id":53262,"position":4,"arabic":"قَوْمٍ","translation":"কোনো জাতি","audioUrl":"wbw/008_058_004.mp3","charTypeName":"word"},{"id":53263,"position":5,"arabic":"خِيَانَةًۭ","translation":"বিশ্বাসভঙ্গের","audioUrl":"wbw/008_058_005.mp3","charTypeName":"word"},{"id":53264,"position":6,"arabic":"فَٱنۢبِذْ","translation":"তবে নিক্ষেপ করো","audioUrl":"wbw/008_058_006.mp3","charTypeName":"word"},{"id":53265,"position":7,"arabic":"إِلَيْهِمْ","translation":"দিকে তাদের (তাদের সন্ধিচুক্তি)","audioUrl":"wbw/008_058_007.mp3","charTypeName":"word"},{"id":53266,"position":8,"arabic":"عَلَىٰ","translation":"ভাবে","audioUrl":"wbw/008_058_008.mp3","charTypeName":"word"},{"id":53267,"position":9,"arabic":"سَوَآءٍ ۚ","translation":"সমান (একই)","audioUrl":"wbw/008_058_009.mp3","charTypeName":"word"},{"id":53269,"position":10,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/008_058_011.mp3","charTypeName":"word"},{"id":53270,"position":11,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/008_058_012.mp3","charTypeName":"word"},{"id":53271,"position":12,"arabic":"لَا","translation":"না","audioUrl":"wbw/008_058_013.mp3","charTypeName":"word"},{"id":53272,"position":13,"arabic":"يُحِبُّ","translation":"ভালোবাসেন","audioUrl":"wbw/008_058_014.mp3","charTypeName":"word"},{"id":53273,"position":14,"arabic":"ٱلْخَآئِنِينَ","translation":"বিশ্বাসভঙ্গকারীদেরকে","audioUrl":"wbw/008_058_015.mp3","charTypeName":"word"},{"id":53274,"position":15,"arabic":"٥٨","translation":"(৫৮)","audioUrl":null,"charTypeName":"end"}]},{"number":59,"arabic":"وَلَا يَحْسَبَنَّ ٱلَّذِينَ كَفَرُوا۟ سَبَقُوٓا۟ ۚ إِنَّهُمْ لَا يُعْجِزُونَ","translation":"And let them not think - those who are bent on denying the truth -that they shall escapee [God]: behold, they can never frustrate [His purpose].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1219.mp3","surahId":8,"words":[{"id":53804,"position":1,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/008_059_001.mp3","charTypeName":"word"},{"id":53805,"position":2,"arabic":"يَحْسَبَنَّ","translation":"(যেন) তারা মনে করে","audioUrl":"wbw/008_059_002.mp3","charTypeName":"word"},{"id":53806,"position":3,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/008_059_003.mp3","charTypeName":"word"},{"id":53807,"position":4,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করেছে (যে)","audioUrl":"wbw/008_059_004.mp3","charTypeName":"word"},{"id":53808,"position":5,"arabic":"سَبَقُوٓا۟ ۚ","translation":"তারা আগে চলে গিয়েছে","audioUrl":"wbw/008_059_005.mp3","charTypeName":"word"},{"id":53810,"position":6,"arabic":"إِنَّهُمْ","translation":"নিশ্চয়ই তারা","audioUrl":"wbw/008_059_007.mp3","charTypeName":"word"},{"id":53811,"position":7,"arabic":"لَا","translation":"না","audioUrl":"wbw/008_059_008.mp3","charTypeName":"word"},{"id":53812,"position":8,"arabic":"يُعْجِزُونَ","translation":"অক্ষম করতে পারবে (আল্লাহকে)","audioUrl":"wbw/008_059_009.mp3","charTypeName":"word"},{"id":53813,"position":9,"arabic":"٥٩","translation":"(৫৯)","audioUrl":null,"charTypeName":"end"}]},{"number":60,"arabic":"وَأَعِدُّوا۟ لَهُم مَّا ٱسْتَطَعْتُم مِّن قُوَّةٍۢ وَمِن رِّبَاطِ ٱلْخَيْلِ تُرْهِبُونَ بِهِۦ عَدُوَّ ٱللَّهِ وَعَدُوَّكُمْ وَءَاخَرِينَ مِن دُونِهِمْ لَا تَعْلَمُونَهُمُ ٱللَّهُ يَعْلَمُهُمْ ۚ وَمَا تُنفِقُوا۟ مِن شَىْءٍۢ فِى سَبِيلِ ٱللَّهِ يُوَفَّ إِلَيْكُمْ وَأَنتُمْ لَا تُظْلَمُونَ","translation":"Hence, make ready against them whatever force and war mounts you are able to muster, so that you might deter thereby the enemies of God, who are your enemies as well, and others besides them of whom you may be unaware, [but] of whom God is aware; and whatever you may expend in God's cause shall be repaid to you in full, and you shall not be wronged.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1220.mp3","surahId":8,"words":[{"id":54385,"positio