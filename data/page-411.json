{"id":411,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ الٓمٓ","translation":"Alif. Lam. Mim.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3470.mp3","surahId":31,"words":[{"id":791,"position":1,"arabic":"الٓمٓ","translation":"আলিফ লাম - মীম-","audioUrl":"wbw/031_001_001.mp3","charTypeName":"word"},{"id":792,"position":2,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"تِلْكَ ءَايَٰتُ ٱلْكِتَٰبِ ٱلْحَكِيمِ","translation":"THESE ARE MESSAGES of the divine writ, full of wisdom,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3471.mp3","surahId":31,"words":[{"id":1877,"position":1,"arabic":"تِلْكَ","translation":"এই","audioUrl":"wbw/031_002_001.mp3","charTypeName":"word"},{"id":1878,"position":2,"arabic":"ءَايَـٰتُ","translation":"আয়াতগুলো","audioUrl":"wbw/031_002_002.mp3","charTypeName":"word"},{"id":1879,"position":3,"arabic":"ٱلْكِتَـٰبِ","translation":"কিতাবের","audioUrl":"wbw/031_002_003.mp3","charTypeName":"word"},{"id":1880,"position":4,"arabic":"ٱلْحَكِيمِ","translation":"(যা) জ্ঞানময়","audioUrl":"wbw/031_002_004.mp3","charTypeName":"word"},{"id":1881,"position":5,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"هُدًۭى وَرَحْمَةًۭ لِّلْمُحْسِنِينَ","translation":"providing guidance and grace unto the doers of good","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3472.mp3","surahId":31,"words":[{"id":3047,"position":1,"arabic":"هُدًۭى","translation":"পথ নির্দেশনা","audioUrl":"wbw/031_003_001.mp3","charTypeName":"word"},{"id":3048,"position":2,"arabic":"وَرَحْمَةًۭ","translation":"ও দয়াস্বরূপ","audioUrl":"wbw/031_003_002.mp3","charTypeName":"word"},{"id":3049,"position":3,"arabic":"لِّلْمُحْسِنِينَ","translation":"জন্যে সৎকর্মশীলদের","audioUrl":"wbw/031_003_003.mp3","charTypeName":"word"},{"id":3050,"position":4,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"ٱلَّذِينَ يُقِيمُونَ ٱلصَّلَوٰةَ وَيُؤْتُونَ ٱلزَّكَوٰةَ وَهُم بِٱلْءَاخِرَةِ هُمْ يُوقِنُونَ","translation":"who are constant in prayer and dispense charity: for it is they, they who in their innermost are certain of the life to come!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3473.mp3","surahId":31,"words":[{"id":4389,"position":1,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/031_004_001.mp3","charTypeName":"word"},{"id":4390,"position":2,"arabic":"يُقِيمُونَ","translation":"তারা প্রতিষ্ঠা করে","audioUrl":"wbw/031_004_002.mp3","charTypeName":"word"},{"id":4391,"position":3,"arabic":"ٱلصَّلَوٰةَ","translation":"সালাত","audioUrl":"wbw/031_004_003.mp3","charTypeName":"word"},{"id":4392,"position":4,"arabic":"وَيُؤْتُونَ","translation":"ও তারা দেয়","audioUrl":"wbw/031_004_004.mp3","charTypeName":"word"},{"id":4393,"position":5,"arabic":"ٱلزَّكَوٰةَ","translation":"যাকাত","audioUrl":"wbw/031_004_005.mp3","charTypeName":"word"},{"id":4394,"position":6,"arabic":"وَهُم","translation":"এবং তারা","audioUrl":"wbw/031_004_006.mp3","charTypeName":"word"},{"id":4395,"position":7,"arabic":"بِٱلْـَٔاخِرَةِ","translation":"উপর আখিরাতের","audioUrl":"wbw/031_004_007.mp3","charTypeName":"word"},{"id":4396,"position":8,"arabic":"هُمْ","translation":"তারাই","audioUrl":"wbw/031_004_008.mp3","charTypeName":"word"},{"id":4397,"position":9,"arabic":"يُوقِنُونَ","translation":"দৃঢ় বিশ্বাস করে","audioUrl":"wbw/031_004_009.mp3","charTypeName":"word"},{"id":4398,"position":10,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"أُو۟لَٰٓئِكَ عَلَىٰ هُدًۭى مِّن رَّبِّهِمْ ۖ وَأُو۟لَٰٓئِكَ هُمُ ٱلْمُفْلِحُونَ","translation":"It is they who follow the guidance [that comes to them] from their Sustainer; and it is they, they who shall attain to a happy state!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3474.mp3","surahId":31,"words":[{"id":5628,"position":1,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐসব (লোকই)","audioUrl":"wbw/031_005_001.mp3","charTypeName":"word"},{"id":5629,"position":2,"arabic":"عَلَىٰ","translation":"উপর (প্রতিষ্ঠিত)","audioUrl":"wbw/031_005_002.mp3","charTypeName":"word"},{"id":5630,"position":3,"arabic":"هُدًۭى","translation":"পথনির্দেশের","audioUrl":"wbw/031_005_003.mp3","charTypeName":"word"},{"id":5631,"position":4,"arabic":"مِّن","translation":"পক্ষ থেকে","audioUrl":"wbw/031_005_004.mp3","charTypeName":"word"},{"id":5632,"position":5,"arabic":"رَّبِّهِمْ ۖ","translation":"রবের তাদের","audioUrl":"wbw/031_005_005.mp3","charTypeName":"word"},{"id":5634,"position":6,"arabic":"وَأُو۟لَـٰٓئِكَ","translation":"এবং ঐসব (লোক)","audioUrl":"wbw/031_005_007.mp3","charTypeName":"word"},{"id":5635,"position":7,"arabic":"هُمُ","translation":"তারাই","audioUrl":"wbw/031_005_008.mp3","charTypeName":"word"},{"id":5636,"position":8,"arabic":"ٱلْمُفْلِحُونَ","translation":"সফলকাম","audioUrl":"wbw/031_005_009.mp3","charTypeName":"word"},{"id":5637,"position":9,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"وَمِنَ ٱلنَّاسِ مَن يَشْتَرِى لَهْوَ ٱلْحَدِيثِ لِيُضِلَّ عَن سَبِيلِ ٱللَّهِ بِغَيْرِ عِلْمٍۢ وَيَتَّخِذَهَا هُزُوًا ۚ أُو۟لَٰٓئِكَ لَهُمْ عَذَابٌۭ مُّهِينٌۭ","translation":"But among men there is many a one that prefers a mere play with words [to divine guidance], so as to lead [those] without knowledge astray from the path of God, and to turn it to ridicule: for such there is shameful suffering in store.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3475.mp3","surahId":31,"words":[{"id":6917,"position":1,"arabic":"وَمِنَ","translation":"এবং মধ্য থেকে","audioUrl":"wbw/031_006_001.mp3","charTypeName":"word"},{"id":6918,"position":2,"arabic":"ٱلنَّاسِ","translation":"মানুষের (এমনও আছে)","audioUrl":"wbw/031_006_002.mp3","charTypeName":"word"},{"id":6919,"position":3,"arabic":"مَن","translation":"যে","audioUrl":"wbw/031_006_003.mp3","charTypeName":"word"},{"id":6920,"position":4,"arabic":"يَشْتَرِى","translation":"কোনো","audioUrl":"wbw/031_006_004.mp3","charTypeName":"word"},{"id":6921,"position":5,"arabic":"لَهْوَ","translation":"অসার","audioUrl":"wbw/031_006_005.mp3","charTypeName":"word"},{"id":6922,"position":6,"arabic":"ٱلْحَدِيثِ","translation":"কথা","audioUrl":"wbw/031_006_006.mp3","charTypeName":"word"},{"id":6923,"position":7,"arabic":"لِيُضِلَّ","translation":"যেন সে বিভ্রান্ত করতে পারে","audioUrl":"wbw/031_006_007.mp3","charTypeName":"word"},{"id":6924,"position":8,"arabic":"عَن","translation":"থেকে","audioUrl":"wbw/031_006_008.mp3","charTypeName":"word"},{"id":6925,"position":9,"arabic":"سَبِيلِ","translation":"পথ","audioUrl":"wbw/031_006_009.mp3","charTypeName":"word"},{"id":6926,"position":10,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/031_006_010.mp3","charTypeName":"word"},{"id":6927,"position":11,"arabic":"بِغَيْرِ","translation":"ছাড়া","audioUrl":"wbw/031_006_011.mp3","charTypeName":"word"},{"id":6928,"position":12,"arabic":"عِلْمٍۢ","translation":"কোনো জ্ঞান","audioUrl":"wbw/031_006_012.mp3","charTypeName":"word"},{"id":6929,"position":13,"arabic":"وَيَتَّخِذَهَا","translation":"এবং গ্রহণ করে তা","audioUrl":"wbw/031_006_013.mp3","charTypeName":"word"},{"id":6930,"position":14,"arabic":"هُزُوًا ۚ","translation":"বিদ্রুপরূপে","audioUrl":"wbw/031_006_014.mp3","charTypeName":"word"},{"id":6932,"position":15,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐসব (লোক)","audioUrl":"wbw/031_006_016.mp3","charTypeName":"word"},{"id":6933,"position":16,"arabic":"لَهُمْ","translation":"জন্যে তাদের (রয়েছে)","audioUrl":"wbw/031_006_017.mp3","charTypeName":"word"},{"id":6934,"position":17,"arabic":"عَذَابٌۭ","translation":"শাস্তি","audioUrl":"wbw/031_006_018.mp3","charTypeName":"word"},{"id":6935,"position":18,"arabic":"مُّهِينٌۭ","translation":"অপমানকর","audioUrl":"wbw/031_006_019.mp3","charTypeName":"word"},{"id":6936,"position":19,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"وَإِذَا تُتْلَىٰ عَلَيْهِ ءَايَٰتُنَا وَلَّىٰ مُسْتَكْبِرًۭا كَأَن لَّمْ يَسْمَعْهَا كَأَنَّ فِىٓ أُذُنَيْهِ وَقْرًۭا ۖ فَبَشِّرْهُ بِعَذَابٍ أَلِيمٍ","translation":"For, whenever Our messages are conveyed to such a one, he turns away in his arrogance as though he had not heard them - as though there were deafness in his ears. Give him, then, the tiding of grievous suffering [in the life to come].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3476.mp3","surahId":31,"words":[{"id":8242,"position":1,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/031_007_001.mp3","charTypeName":"word"},{"id":8243,"position":2,"arabic":"تُتْلَىٰ","translation":"তিলাওয়াত করা হয়","audioUrl":"wbw/031_007_002.mp3","charTypeName":"word"},{"id":8244,"position":3,"arabic":"عَلَيْهِ","translation":"নিকট তার","audioUrl":"wbw/031_007_003.mp3","charTypeName":"word"},{"id":8245,"position":4,"arabic":"ءَايَـٰتُنَا","translation":"আয়াতসমূহ আমাদের","audioUrl":"wbw/031_007_004.mp3","charTypeName":"word"},{"id":8246,"position":5,"arabic":"وَلَّىٰ","translation":"সে মুখ ফিরায়","audioUrl":"wbw/031_007_005.mp3","charTypeName":"word"},{"id":8247,"position":6,"arabic":"مُسْتَكْبِرًۭا","translation":"অহঙ্কারী হিসেবে","audioUrl":"wbw/031_007_006.mp3","charTypeName":"word"},{"id":8248,"position":7,"arabic":"كَأَن","translation":"যেন","audioUrl":"wbw/031_007_007.mp3","charTypeName":"word"},{"id":8249,"position":8,"arabic":"لَّمْ","translation":"নি","audioUrl":"wbw/031_007_008.mp3","charTypeName":"word"},{"id":8250,"position":9,"arabic":"يَسْمَعْهَا","translation":"শুনতে পায় তা","audioUrl":"wbw/031_007_009.mp3","charTypeName":"word"},{"id":8251,"position":10,"arabic":"كَأَنَّ","translation":"যেন","audioUrl":"wbw/031_007_010.mp3","charTypeName":"word"},{"id":8252,"position":11,"arabic":"فِىٓ","translation":"মধ্যে (আছে)","audioUrl":"wbw/031_007_011.mp3","charTypeName":"word"},{"id":8253,"position":12,"arabic":"أُذُنَيْهِ","translation":"দু'কানের তার","audioUrl":"wbw/031_007_012.mp3","charTypeName":"word"},{"id":8254,"position":13,"arabic":"وَقْرًۭا ۖ","translation":"বধিরতা","audioUrl":"wbw/031_007_013.mp3","charTypeName":"word"},{"id":8256,"position":14,"arabic":"فَبَشِّرْهُ","translation":"অতএব সুসংবাদ দাও তাকে","audioUrl":"wbw/031_007_015.mp3","charTypeName":"word"},{"id":8257,"position":15,"arabic":"بِعَذَابٍ","translation":"ব্যাপারে শাস্তির","audioUrl":"wbw/031_007_016.mp3","charTypeName":"word"},{"id":8258,"position":16,"arabic":"أَلِيمٍ","translation":"নিদারুণ","audioUrl":"wbw/031_007_017.mp3","charTypeName":"word"},{"id":8259,"position":17,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"إِنَّ ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ لَهُمْ جَنَّٰتُ ٱلنَّعِيمِ","translation":"[As against this,] verily, those who attain to faith and do righteous deeds shall have gardens of bliss,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3477.mp3","surahId":31,"words":[{"id":9434,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/031_008_001.mp3","charTypeName":"word"},{"id":9435,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/031_008_002.mp3","charTypeName":"word"},{"id":9436,"position":3,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/031_008_003.mp3","charTypeName":"word"},{"id":9437,"position":4,"arabic":"وَعَمِلُوا۟","translation":"ও কাজ করেছে","audioUrl":"wbw/031_008_004.mp3","charTypeName":"word"},{"id":9438,"position":5,"arabic":"ٱلصَّـٰلِحَـٰتِ","translation":"সৎ","audioUrl":"wbw/031_008_005.mp3","charTypeName":"word"},{"id":9439,"position":6,"arabic":"لَهُمْ","translation":"জন্যে তাদের (রয়েছে)","audioUrl":"wbw/031_008_006.mp3","charTypeName":"word"},{"id":9440,"position":7,"arabic":"جَنَّـٰتُ","translation":"জান্নাতসমুহ","audioUrl":"wbw/031_008_007.mp3","charTypeName":"word"},{"id":9441,"position":8,"arabic":"ٱلنَّعِيمِ","translation":"সুখকর","audioUrl":"wbw/031_008_008.mp3","charTypeName":"word"},{"id":9442,"position":9,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"خَٰلِدِينَ فِيهَا ۖ وَعْدَ ٱللَّهِ حَقًّۭا ۚ وَهُوَ ٱلْعَزِيزُ ٱلْحَكِيمُ","translation":"to abide therein in accordance with God’s true promise: for He alone is almighty, truly wise.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3478.mp3","surahId":31,"words":[{"id":10583,"position":1,"arabic":"خَـٰلِدِينَ","translation":"চিরস্থায়ীভাবে থাকবে তারা","audioUrl":"wbw/031_009_001.mp3","charTypeName":"word"},{"id":10584,"position":2,"arabic":"فِيهَا ۖ","translation":"মধ্যে তার","audioUrl":"wbw/031_009_002.mp3","charTypeName":"word"},{"id":10586,"position":3,"arabic":"وَعْدَ","translation":"প্রতিশ্রুতি","audioUrl":"wbw/031_009_004.mp3","charTypeName":"word"},{"id":10587,"position":4,"arabic":"ٱللَّهِ","translation":"আল্লাহ","audioUrl":"wbw/031_009_005.mp3","charTypeName":"word"},{"id":10588,"position":5,"arabic":"حَقًّۭا ۚ","translation":"সত্য","audioUrl":"wbw/031_009_006.mp3","charTypeName":"word"},{"id":10590,"position":6,"arabic":"وَهُوَ","translation":"এবং তিনিই","audioUrl":"wbw/031_009_008.mp3","charTypeName":"word"},{"id":10591,"position":7,"arabic":"ٱلْعَزِيزُ","translation":"পরাক্রমশালী","audioUrl":"wbw/031_009_009.mp3","charTypeName":"word"},{"id":10592,"position":8,"arabic":"ٱلْحَكِيمُ","translation":"প্রজ্ঞাময়","audioUrl":"wbw/031_009_010.mp3","charTypeName":"word"},{"id":10593,"position":9,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"خَلَقَ ٱلسَّمَٰوَٰتِ بِغَيْرِ عَمَدٍۢ تَرَوْنَهَا ۖ وَأَلْقَىٰ فِى ٱلْأَرْضِ رَوَٰسِىَ أَن تَمِيدَ بِكُمْ وَبَثَّ فِيهَا مِن كُلِّ دَآبَّةٍۢ ۚ وَأَنزَلْنَا مِنَ ٱلسَّمَآءِ مَآءًۭ فَأَنۢبَتْنَا فِيهَا مِن كُلِّ زَوْجٍۢ كَرِيمٍ","translation":"He [it is who] has created the skies without any supports that you could see, and has placed firm mountains upon the earth, lest it sway with you, and has caused all manner of living creatures to multiply thereon. And We send down water from the skies, and thus We cause every noble kind [of life] to grow on earth.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3479.mp3","surahId":31,"words":[{"id":11835,"position":1,"arabic":"خَلَقَ","translation":"তিনি সৃষ্টি করেছেন","audioUrl":"wbw/031_010_001.mp3","charTypeName":"word"},{"id":11836,"position":2,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশসমূহ","audioUrl":"wbw/031_010_002.mp3","charTypeName":"word"},{"id":11837,"position":3,"arabic":"بِغَيْرِ","translation":"ছাড়া","audioUrl":"wbw/031_010_003.mp3","charTypeName":"word"},{"id":11838,"position":4,"arabic":"عَمَدٍۢ","translation":"কোন খুঁটি","audioUrl":"wbw/031_010_004.mp3","charTypeName":"word"},{"id":11839,"position":5,"arabic":"تَرَوْنَهَا ۖ","translation":"তোমরা দেখছো তা","audioUrl":"wbw/031_010_005.mp3","charTypeName":"word"},{"id":11841,"position":6,"arabic":"وَأَلْقَىٰ","translation":"এবং স্থাপন করেছেন","audioUrl":"wbw/031_010_007.mp3","charTypeName":"word"},{"id":11842,"position":7,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/031_010_008.mp3","charTypeName":"word"},{"id":11843,"position":8,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/031_010_009.mp3","charTypeName":"word"},{"id":11844,"position":9,"arabic":"رَوَٰسِىَ","translation":"পর্বতমালা","audioUrl":"wbw/031_010_010.mp3","charTypeName":"word"},{"id":11845,"position":10,"arabic":"أَن","translation":"( এমন না হয় ) যে","audioUrl":"wbw/031_010_011.mp3","charTypeName":"word"},{"id":11846,"position":11,"arabic":"تَمِيدَ","translation":"ঢলে যায়","audioUrl":"wbw/031_010_012.mp3","charTypeName":"word"},{"id":11847,"position":12,"arabic":"بِكُمْ","translation":"নিয়ে তোমাদেরকে","audioUrl":"wbw/031_010_013.mp3","charTypeName":"word"},{"id":11848,"position":13,"arabic":"وَبَثَّ","translation":"এবং ছড়িয়ে দিয়েছেন","audioUrl":"wbw/031_010_014.mp3","charTypeName":"word"},{"id":11849,"position":14,"arabic":"فِيهَا","translation":"মধ্যে তার","audioUrl":"wbw/031_010_015.mp3","charTypeName":"word"},{"id":11850,"position":15,"arabic":"مِن","translation":"প্রকার","audioUrl":"wbw/031_010_016.mp3","charTypeName":"word"},{"id":11851,"position":16,"arabic":"كُلِّ","translation":"প্রত্যেক","audioUrl":"wbw/031_010_017.mp3","charTypeName":"word"},{"id":11852,"position":17,"arabic":"دَآبَّةٍۢ ۚ","translation":"জীবজন্তু","audioUrl":"wbw/031_010_018.mp3","charTypeName":"word"},{"id":11854,"position":18,"arabic":"وَأَنزَلْنَا","translation":"এবং আমরা বর্ষণ করেছি","audioUrl":"wbw/031_010_020.mp3","charTypeName":"word"},{"id":11855,"position":19,"arabic":"مِنَ","translation":"থেকে","audioUrl":"wbw/031_010_021.mp3","charTypeName":"word"},{"id":11856,"position":20,"arabic":"ٱلسَّمَآءِ","translation":"আকাশ","audioUrl":"wbw/031_010_022.mp3","charTypeName":"word"},{"id":11857,"position":21,"arabic":"مَآءًۭ","translation":"পানি","audioUrl":"wbw/031_010_023.mp3","charTypeName":"word"},{"id":11858,"position":22,"arabic":"فَأَنۢبَتْنَا","translation":"অতঃপর উৎপন্ন করি আমরা","audioUrl":"wbw/031_010_024.mp3","charTypeName":"word"},{"id":11859,"position":23,"arabic":"فِيهَا","translation":"মধ্যে তার","audioUrl":"wbw/031_010_025.mp3","charTypeName":"word"},{"id":11860,"position":24,"arabic":"مِن","translation":"প্রকার","audioUrl":"wbw/031_010_026.mp3","charTypeName":"word"},{"id":11861,"position":25,"arabic":"كُلِّ","translation":"প্রত্যেক","audioUrl":"wbw/031_010_027.mp3","charTypeName":"word"},{"id":11862,"position":26,"arabic":"زَوْجٍۢ","translation":"জোড়া জোড়া (উদ্ভিদ)","audioUrl":"wbw/031_010_028.mp3","charTypeName":"word"},{"id":11863,"position":27,"arabic":"كَرِيمٍ","translation":"উত্তম","audioUrl":"wbw/031_010_029.mp3","charTypeName":"word"},{"id":11864,"position":28,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"هَٰذَا خَلْقُ ٱللَّهِ فَأَرُونِى مَاذَا خَلَقَ ٱلَّذِينَ مِن دُونِهِۦ ۚ بَلِ ٱلظَّٰلِمُونَ فِى ضَلَٰلٍۢ مُّبِينٍۢ","translation":"[All] this is God’s creation: show Me, then, what others than He may have created! Nay, but the evildoers are obviously lost in error!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3480.mp3","surahId":31,"words":[{"id":13131,"position":1,"arabic":"هَـٰذَا","translation":"এটা","audioUrl":"wbw/031_011_001.mp3","charTypeName":"word"},{"id":13132,"position":2,"arabic":"خَلْقُ","translation":"সৃষ্টি","audioUrl":"wbw/031_011_002.mp3","charTypeName":"word"},{"id":13133,"position":3,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/031_011_003.mp3","charTypeName":"word"},{"id":13134,"position":4,"arabic":"فَأَرُونِى","translation":"তাহ'লে দেখাও তোমরা আমাকে","audioUrl":"wbw/031_011_004.mp3","charTypeName":"word"},{"id":13135,"position":5,"arabic":"مَاذَا","translation":"কি","audioUrl":"wbw/031_011_005.mp3","charTypeName":"word"},{"id":13136,"position":6,"arabic":"خَلَقَ","translation":"সৃষ্টি করেছে","audioUrl":"wbw/031_011_006.mp3","charTypeName":"word"},{"id":13137,"position":7,"arabic":"ٱلَّذِينَ","translation":"(তারা) যারা (আছে)","audioUrl":"wbw/031_011_007.mp3","charTypeName":"word"},{"id":13138,"position":8,"arabic":"مِن","translation":"ছাড়া","audioUrl":"wbw/031_011_008.mp3","charTypeName":"word"},{"id":13139,"position":9,"arabic":"دُونِهِۦ ۚ","translation":"তিনি","audioUrl":"wbw/031_011_009.mp3","charTypeName":"word"},{"id":13141,"position":10,"arabic":"بَلِ","translation":"বরং","audioUrl":"wbw/031_011_011.mp3","charTypeName":"word"},{"id":13142,"position":11,"arabic":"ٱلظَّـٰلِمُونَ","translation":"সীমালঙ্ঘনকারীরা","audioUrl":"wbw/031_011_012.mp3","charTypeName":"word"},{"id":13143,"position":12,"arabic":"فِى","translation":"মধ্যে(লিপ্ত)","audioUrl":"wbw/031_011_013.mp3","charTypeName":"word"},{"id":13144,"position":13,"arabic":"ضَلَـٰلٍۢ","translation":"বিভ্রান্তির","audioUrl":"wbw/031_011_014.mp3","charTypeName":"word"},{"id":13145,"position":14,"arabic":"مُّبِينٍۢ","translation":"সুস্পষ্ট","audioUrl":"wbw/031_011_015.mp3","charTypeName":"word"},{"id":13146,"position":15,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":