,"translation":"অতঃপর যখন","audioUrl":"wbw/061_006_026.mp3","charTypeName":"word"},{"id":6321,"position":26,"arabic":"جَآءَهُم","translation":"তাদের তিনি (কাছে) আসলেন","audioUrl":"wbw/061_006_027.mp3","charTypeName":"word"},{"id":6322,"position":27,"arabic":"بِٱلْبَيِّنَـٰتِ","translation":"সুস্পষ্ট প্রমাণাদিসহ","audioUrl":"wbw/061_006_028.mp3","charTypeName":"word"},{"id":6323,"position":28,"arabic":"قَالُوا۟","translation":"তারা বলল","audioUrl":"wbw/061_006_029.mp3","charTypeName":"word"},{"id":6324,"position":29,"arabic":"هَـٰذَا","translation":"\"এটা","audioUrl":"wbw/061_006_030.mp3","charTypeName":"word"},{"id":6325,"position":30,"arabic":"سِحْرٌۭ","translation":"জাদু","audioUrl":"wbw/061_006_031.mp3","charTypeName":"word"},{"id":6326,"position":31,"arabic":"مُّبِينٌۭ","translation":"প্রকাশ্য\"","audioUrl":"wbw/061_006_032.mp3","charTypeName":"word"},{"id":6327,"position":32,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"وَمَنْ أَظْلَمُ مِمَّنِ ٱفْتَرَىٰ عَلَى ٱللَّهِ ٱلْكَذِبَ وَهُوَ يُدْعَىٰٓ إِلَى ٱلْإِسْلَٰمِ ۚ وَٱللَّهُ لَا يَهْدِى ٱلْقَوْمَ ٱلظَّٰلِمِينَ","translation":"And who could be more wicked than one who invents [such] a lie about [a message from] God, seeing that he is [but] being called to self-surrender unto Him? But God does not bestow His guidance upon evil-doing folk.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5170.mp3","surahId":61,"words":[{"id":7736,"position":1,"arabic":"وَمَنْ","translation":"এবং কে","audioUrl":"wbw/061_007_001.mp3","charTypeName":"word"},{"id":7737,"position":2,"arabic":"أَظْلَمُ","translation":"অধিক যালেম","audioUrl":"wbw/061_007_002.mp3","charTypeName":"word"},{"id":7738,"position":3,"arabic":"مِمَّنِ","translation":"(তার) অপেক্ষা","audioUrl":"wbw/061_007_003.mp3","charTypeName":"word"},{"id":7739,"position":4,"arabic":"ٱفْتَرَىٰ","translation":"যে রচনা করে","audioUrl":"wbw/061_007_004.mp3","charTypeName":"word"},{"id":7740,"position":5,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/061_007_005.mp3","charTypeName":"word"},{"id":7741,"position":6,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/061_007_006.mp3","charTypeName":"word"},{"id":7742,"position":7,"arabic":"ٱلْكَذِبَ","translation":"মিথ্যা","audioUrl":"wbw/061_007_007.mp3","charTypeName":"word"},{"id":7743,"position":8,"arabic":"وَهُوَ","translation":"অথচ তাকে","audioUrl":"wbw/061_007_008.mp3","charTypeName":"word"},{"id":7744,"position":9,"arabic":"يُدْعَىٰٓ","translation":"আহ্বান করা হয়","audioUrl":"wbw/061_007_009.mp3","charTypeName":"word"},{"id":7745,"position":10,"arabic":"إِلَى","translation":"দিকে","audioUrl":"wbw/061_007_010.mp3","charTypeName":"word"},{"id":7746,"position":11,"arabic":"ٱلْإِسْلَـٰمِ ۚ","translation":"ইসলামের","audioUrl":"wbw/061_007_011.mp3","charTypeName":"word"},{"id":7748,"position":12,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/061_007_013.mp3","charTypeName":"word"},{"id":7749,"position":13,"arabic":"لَا","translation":"না","audioUrl":"wbw/061_007_014.mp3","charTypeName":"word"},{"id":7750,"position":14,"arabic":"يَهْدِى","translation":"পথ দেখান","audioUrl":"wbw/061_007_015.mp3","charTypeName":"word"},{"id":7751,"position":15,"arabic":"ٱلْقَوْمَ","translation":"লোকদের","audioUrl":"wbw/061_007_016.mp3","charTypeName":"word"},{"id":7752,"position":16,"arabic":"ٱلظَّـٰلِمِينَ","translation":"যালেম","audioUrl":"wbw/061_007_017.mp3","charTypeName":"word"},{"id":7753,"position":17,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"يُرِيدُونَ لِيُطْفِـُٔوا۟ نُورَ ٱللَّهِ بِأَفْوَٰهِهِمْ وَٱللَّهُ مُتِمُّ نُورِهِۦ وَلَوْ كَرِهَ ٱلْكَٰفِرُونَ","translation":"They aim to extinguish God's light with their utterances: but God has willed to spread His light in all its fullness, however hateful this may be to all who deny the truth","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5171.mp3","surahId":61,"words":[{"id":8908,"position":1,"arabic":"يُرِيدُونَ","translation":"তারা চায়","audioUrl":"wbw/061_008_001.mp3","charTypeName":"word"},{"id":8909,"position":2,"arabic":"لِيُطْفِـُٔوا۟","translation":"নিভিয়ে দিতে","audioUrl":"wbw/061_008_002.mp3","charTypeName":"word"},{"id":8910,"position":3,"arabic":"نُورَ","translation":"নূর","audioUrl":"wbw/061_008_003.mp3","charTypeName":"word"},{"id":8911,"position":4,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/061_008_004.mp3","charTypeName":"word"},{"id":8912,"position":5,"arabic":"بِأَفْوَٰهِهِمْ","translation":"তাদের মুখের (ফুঁৎকার) দিয়ে","audioUrl":"wbw/061_008_005.mp3","charTypeName":"word"},{"id":8913,"position":6,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/061_008_006.mp3","charTypeName":"word"},{"id":8914,"position":7,"arabic":"مُتِمُّ","translation":"সম্পূর্নকারী","audioUrl":"wbw/061_008_007.mp3","charTypeName":"word"},{"id":8915,"position":8,"arabic":"نُورِهِۦ","translation":"তাঁর নূর","audioUrl":"wbw/061_008_008.mp3","charTypeName":"word"},{"id":8916,"position":9,"arabic":"وَلَوْ","translation":"এবং যদিও","audioUrl":"wbw/061_008_009.mp3","charTypeName":"word"},{"id":8917,"position":10,"arabic":"كَرِهَ","translation":"অপছন্দ করে","audioUrl":"wbw/061_008_010.mp3","charTypeName":"word"},{"id":8918,"position":11,"arabic":"ٱلْكَـٰفِرُونَ","translation":"কাফিররা","audioUrl":"wbw/061_008_011.mp3","charTypeName":"word"},{"id":8919,"position":12,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"هُوَ ٱلَّذِىٓ أَرْسَلَ رَسُولَهُۥ بِٱلْهُدَىٰ وَدِينِ ٱلْحَقِّ لِيُظْهِرَهُۥ عَلَى ٱلدِّينِ كُلِّهِۦ وَلَوْ كَرِهَ ٱلْمُشْرِكُونَ","translation":"He it is who has sent forth His Apostle with [the task of] spreading guidance and the religion of truth, to the end that He make it prevail over all [false] religion, however hateful this may be to those who ascribe divinity to aught but God.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5172.mp3","surahId":61,"words":[{"id":10121,"position":1,"arabic":"هُوَ","translation":"তিনিই","audioUrl":"wbw/061_009_001.mp3","charTypeName":"word"},{"id":10122,"position":2,"arabic":"ٱلَّذِىٓ","translation":"যিনি","audioUrl":"wbw/061_009_002.mp3","charTypeName":"word"},{"id":10123,"position":3,"arabic":"أَرْسَلَ","translation":"পাঠিয়েছেন","audioUrl":"wbw/061_009_003.mp3","charTypeName":"word"},{"id":10124,"position":4,"arabic":"رَسُولَهُۥ","translation":"তাঁর রাসূলকে","audioUrl":"wbw/061_009_004.mp3","charTypeName":"word"},{"id":10125,"position":5,"arabic":"بِٱلْهُدَىٰ","translation":"হেদায়াতসহ","audioUrl":"wbw/061_009_005.mp3","charTypeName":"word"},{"id":10126,"position":6,"arabic":"وَدِينِ","translation":"ও দ্বীন","audioUrl":"wbw/061_009_006.mp3","charTypeName":"word"},{"id":10127,"position":7,"arabic":"ٱلْحَقِّ","translation":"সত্য","audioUrl":"wbw/061_009_007.mp3","charTypeName":"word"},{"id":10128,"position":8,"arabic":"لِيُظْهِرَهُۥ","translation":"তা বিজয়ী করে যেন","audioUrl":"wbw/061_009_008.mp3","charTypeName":"word"},{"id":10129,"position":9,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/061_009_009.mp3","charTypeName":"word"},{"id":10130,"position":10,"arabic":"ٱلدِّينِ","translation":"দ্বীনের","audioUrl":"wbw/061_009_010.mp3","charTypeName":"word"},{"id":10131,"position":11,"arabic":"كُلِّهِۦ","translation":"সর্বপ্রকারের","audioUrl":"wbw/061_009_011.mp3","charTypeName":"word"},{"id":10132,"position":12,"arabic":"وَلَوْ","translation":"এবং যদিও","audioUrl":"wbw/061_009_012.mp3","charTypeName":"word"},{"id":10133,"position":13,"arabic":"كَرِهَ","translation":"অপছন্দ করে","audioUrl":"wbw/061_009_013.mp3","charTypeName":"word"},{"id":10134,"position":14,"arabic":"ٱلْمُشْرِكُونَ","translation":"মুশরিকরা","audioUrl":"wbw/061_009_014.mp3","charTypeName":"word"},{"id":10135,"position":15,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ هَلْ أَدُلُّكُمْ عَلَىٰ تِجَٰرَةٍۢ تُنجِيكُم مِّنْ عَذَابٍ أَلِيمٍۢ","translat