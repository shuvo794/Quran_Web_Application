bw/061_013_005.mp3","charTypeName":"word"},{"id":15118,"position":5,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/061_013_006.mp3","charTypeName":"word"},{"id":15119,"position":6,"arabic":"وَفَتْحٌۭ","translation":"ও বিজয়","audioUrl":"wbw/061_013_007.mp3","charTypeName":"word"},{"id":15120,"position":7,"arabic":"قَرِيبٌۭ ۗ","translation":"আসন্ন","audioUrl":"wbw/061_013_008.mp3","charTypeName":"word"},{"id":15122,"position":8,"arabic":"وَبَشِّرِ","translation":"এবং সুসংবাদ দাও","audioUrl":"wbw/061_013_010.mp3","charTypeName":"word"},{"id":15123,"position":9,"arabic":"ٱلْمُؤْمِنِينَ","translation":"মু'মিনদের","audioUrl":"wbw/061_013_011.mp3","charTypeName":"word"},{"id":15124,"position":10,"arabic":"١٣","translation":"(১৩)","audioUrl":null,"charTypeName":"end"}]},{"number":14,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ كُونُوٓا۟ أَنصَارَ ٱللَّهِ كَمَا قَالَ عِيسَى ٱبْنُ مَرْيَمَ لِلْحَوَارِيِّۦنَ مَنْ أَنصَارِىٓ إِلَى ٱللَّهِ ۖ قَالَ ٱلْحَوَارِيُّونَ نَحْنُ أَنصَارُ ٱللَّهِ ۖ فَـَٔامَنَت طَّآئِفَةٌۭ مِّنۢ بَنِىٓ إِسْرَٰٓءِيلَ وَكَفَرَت طَّآئِفَةٌۭ ۖ فَأَيَّدْنَا ٱلَّذِينَ ءَامَنُوا۟ عَلَىٰ عَدُوِّهِمْ فَأَصْبَحُوا۟ ظَٰهِرِينَ","translation":"O YOU who have attained to faith! Be helpers [in the cause of God - even as Jesus, the son of Mary, said unto the white-garbed ones, \"Who will be my helpers in God's cause?\" - whereupon the white-garbed [disciples] replied, \"We shall be [thy] helpers [in the cause] of God!\" And so [it happened that] some of the children of Israel came to believe [in the apostleship of Jesus], whereas others denied the truth. But [now] We have given strength against their foes unto those who have [truly] attained to faith: and they have become the ones that shall prevail.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5177.mp3","surahId":61,"words":[{"id":16163,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"ওহে","audioUrl":"wbw/061_014_001.mp3","charTypeName":"word"},{"id":16164,"position":2,"arabic":"ٱلَّ