{"id":519,"ayahs":[{"number":16,"arabic":"وَلَقَدْ خَلَقْنَا ٱلْإِنسَٰنَ وَنَعْلَمُ مَا تُوَسْوِسُ بِهِۦ نَفْسُهُۥ ۖ وَنَحْنُ أَقْرَبُ إِلَيْهِ مِنْ حَبْلِ ٱلْوَرِيدِ","translation":"NOW, VERILY, it is We who have created man, and We know what his innermost self whispers within him: for We are closer to him than his neck-vein.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4646.mp3","surahId":50,"words":[{"id":18240,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/050_016_001.mp3","charTypeName":"word"},{"id":18241,"position":2,"arabic":"خَلَقْنَا","translation":"আমরা সৃষ্টি করেছি","audioUrl":"wbw/050_016_002.mp3","charTypeName":"word"},{"id":18242,"position":3,"arabic":"ٱلْإِنسَـٰنَ","translation":"মানুষকে","audioUrl":"wbw/050_016_003.mp3","charTypeName":"word"},{"id":18243,"position":4,"arabic":"وَنَعْلَمُ","translation":"এবং  আমরা জানি","audioUrl":"wbw/050_016_004.mp3","charTypeName":"word"},{"id":18244,"position":5,"arabic":"مَا","translation":"যা","audioUrl":"wbw/050_016_005.mp3","charTypeName":"word"},{"id":18245,"position":6,"arabic":"تُوَسْوِسُ","translation":"কুমন্ত্রণা দেয়","audioUrl":"wbw/050_016_006.mp3","charTypeName":"word"},{"id":18246,"position":7,"arabic":"بِهِۦ","translation":"তা সম্পর্কে","audioUrl":"wbw/050_016_007.mp3","charTypeName":"word"},{"id":18247,"position":8,"arabic":"نَفْسُهُۥ ۖ","translation":"(অর্থাৎ) তার প্রবৃত্তি","audioUrl":"wbw/050_016_008.mp3","charTypeName":"word"},{"id":18249,"position":9,"arabic":"وَنَحْنُ","translation":"এবং আমরা","audioUrl":"wbw/050_016_010.mp3","charTypeName":"word"},{"id":18250,"position":10,"arabic":"أَقْرَبُ","translation":"অধিক নিকটে","audioUrl":"wbw/050_016_011.mp3","charTypeName":"word"},{"id":18251,"position":11,"arabic":"إِلَيْهِ","translation":"তার","audioUrl":"wbw/050_016_012.mp3","charTypeName":"word"},{"id":18252,"position":12,"arabic":"مِنْ","translation":"চেয়েও","audioUrl":"wbw/050_016_013.mp3","charTypeName":"word"},{"id":18253,"position":13,"arabic":"حَبْلِ","translation":"ধমনী/ শিরার","audioUrl":"wbw/050_016_014.mp3","charTypeName":"word"},{"id":18254,"position":14,"arabic":"ٱلْوَرِيدِ","translation":"ঘাড়ের","audioUrl":"wbw/050_016_015.mp3","charTypeName":"word"},{"id":18255,"position":15,"arabic":"١٦","translation":"(১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":17,"arabic":"إِذْ يَتَلَقَّى ٱلْمُتَلَقِّيَانِ عَنِ ٱلْيَمِينِ وَعَنِ ٱلشِّمَالِ قَعِيدٌۭ","translation":"[And so,] whenever the two demands [of his nature] come face to face, contending from the right and from the left,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4647.mp3","surahId":50,"words":[{"id":19273,"position":1,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/050_017_001.mp3","charTypeName":"word"},{"id":19274,"position":2,"arabic":"يَتَلَقَّى","translation":"গ্রহণ করে (অর্থাৎ লিখে)","audioUrl":"wbw/050_017_002.mp3","charTypeName":"word"},{"id":19275,"position":3,"arabic":"ٱلْمُتَلَقِّيَانِ","translation":"দুজন গ্রহণকারী (লেখক)","audioUrl":"wbw/050_017_003.mp3","charTypeName":"word"},{"id":19276,"position":4,"arabic":"عَنِ","translation":"থেকে","audioUrl":"wbw/050_017_004.mp3","charTypeName":"word"},{"id":19277,"position":5,"arabic":"ٱلْيَمِينِ","translation":"ডান দিক","audioUrl":"wbw/050_017_005.mp3","charTypeName":"word"},{"id":19278,"position":6,"arabic":"وَعَنِ","translation":"ও থেকে","audioUrl":"wbw/050_017_006.mp3","charTypeName":"word"},{"id":19279,"position":7,"arabic":"ٱلشِّمَالِ","translation":"ও বাম দিক","audioUrl":"wbw/050_017_007.mp3","charTypeName":"word"},{"id":19280,"position":8,"arabic":"قَعِيدٌۭ","translation":"বসে","audioUrl":"wbw/050_017_008.mp3","charTypeName":"word"},{"id":19281,"position":9,"arabic":"١٧","translation":"(১৭)","audioUrl":null,"charTypeName":"end"}]},{"number":18,"arabic":"مَّا يَلْفِظُ مِن قَوْلٍ إِلَّا لَدَيْهِ رَقِيبٌ عَتِيدٌۭ","translation":"not even a word can he utter but there is a watcher with him, ever-present.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4648.mp3","surahId":50,"words":[{"id":20348,"position":1,"arabic":"مَّا","translation":"না","audioUrl":"wbw/050_018_001.mp3","charTypeName":"word"},{"id":20349,"position":2,"arabic":"يَلْفِظُ","translation":"সে উচ্চারণ করে","audioUrl":"wbw/050_018_002.mp3","charTypeName":"word"},{"id":20350,"position":3,"arabic":"مِن","translation":"কোনো","audioUrl":"wbw/050_018_003.mp3","charTypeName":"word"},{"id":20351,"position":4,"arabic":"قَوْلٍ","translation":"কথা","audioUrl":"wbw/050_018_004.mp3","charTypeName":"word"},{"id":20352,"position":5,"arabic":"إِلَّا","translation":"এছাড়া যে","audioUrl":"wbw/050_018_005.mp3","charTypeName":"word"},{"id":20353,"position":6,"arabic":"لَدَيْهِ","translation":"তার কাছে (থাকে)","audioUrl":"wbw/050_018_006.mp3","charTypeName":"word"},{"id":20354,"position":7,"arabic":"رَقِيبٌ","translation":"প্রহরী","audioUrl":"wbw/050_018_007.mp3","charTypeName":"word"},{"id":20355,"position":8,"arabic":"عَتِيدٌۭ","translation":"তৎপর","audioUrl":"wbw/050_018_008.mp3","charTypeName":"word"},{"id":20356,"position":9,"arabic":"١٨","translation":"(১৮)","audioUrl":null,"charTypeName":"end"}]},{"number":19,"arabic":"وَجَآءَتْ سَكْرَةُ ٱلْمَوْتِ بِٱلْحَقِّ ۖ ذَٰلِكَ مَا كُنتَ مِنْهُ تَحِيدُ","translation":"And [then,] the twilight of death brings with it the [full] truth that [very thing, O man,] from which thou wouldst always look away! –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4649.mp3","surahId":50,"words":[{"id":21427,"position":1,"arabic":"وَجَآءَتْ","translation":"এবং আসবে","audioUrl":"wbw/050_019_001.mp3","charTypeName":"word"},{"id":21428,"position":2,"arabic":"سَكْرَةُ","translation":"যন্ত্রণা","audioUrl":"wbw/050_019_002.mp3","charTypeName":"word"},{"id":21429,"position":3,"arabic":"ٱلْمَوْتِ","translation":"মৃত্যুর","audioUrl":"wbw/050_019_003.mp3","charTypeName":"word"},{"id":21430,"position":4,"arabic":"بِٱلْحَقِّ ۖ","translation":"সত্য সহকারে","audioUrl":"wbw/050_019_004.mp3","charTypeName":"word"},{"id":21432,"position":5,"arabic":"ذَٰلِكَ","translation":"\"(বলা হবে এটা) তাই","audioUrl":"wbw/050_019_006.mp3","charTypeName":"word"},{"id":21433,"position":6,"arabic":"مَا","translation":"যা","audioUrl":"wbw/050_019_007.mp3","charTypeName":"word"},{"id":21434,"position":7,"arabic":"كُنتَ","translation":"তুমি ছিলে","audioUrl":"wbw/050_019_008.mp3","charTypeName":"word"},{"id":21435,"position":8,"arabic":"مِنْهُ","translation":"তা হতে","audioUrl":"wbw/050_019_009.mp3","charTypeName":"word"},{"id":21436,"position":9,"arabic":"تَحِيدُ","translation":"পাশ কাটাতে/ পালিয়ে থাকতে\"","audioUrl":"wbw/050_019_010.mp3","charTypeName":"word"},{"id":21437,"position":10,"arabic":"١٩","translation":"(১৯)","audioUrl":null,"charTypeName":"end"}]},{"number":20,"arabic":"وَنُفِخَ فِى ٱلصُّورِ ۚ ذَٰلِكَ يَوْمُ ٱلْوَعِيدِ","translation":"and [in the end] the trumpet [of resurrection] will be blown: that will be the Day of a warning fulfilled.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4650.mp3","surahId":50,"words":[{"id":22526,"position":1,"arabic":"وَنُفِخَ","translation":"এবং ফুঁ দেওয়া হবে","audioUrl":"wbw/050_020_001.mp3","charTypeName":"word"},{"id":22527,"position":2,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/050_020_002.mp3","charTypeName":"word"},{"id":22528,"position":3,"arabic":"ٱلصُّورِ ۚ","translation":"শিঙার","audioUrl":"wbw/050_020_003.mp3","charTypeName":"word"},{"id":22530,"position":4,"arabic":"ذَٰلِكَ","translation":"(এটাই) সেই","audioUrl":"wbw/050_020_005.mp3","charTypeName":"word"},{"id":22531,"position":5,"arabic":"يَوْمُ","translation":"দিন (যার)","audioUrl":"wbw/050_020_006.mp3","charTypeName":"word"},{"id":22532,"position":6,"arabic":"ٱلْوَعِيدِ","translation":"ভয় দেখানো হতো","audioUrl":"wbw/050_020_007.mp3","charTypeName":"word"},{"id":22533,"position":7,"arabic":"٢٠","translation":"(২০)","audioUrl":null,"charTypeName":"end"}]},{"number":21,"arabic":"وَجَآءَتْ كُلُّ نَفْسٍۢ مَّعَهَا سَآئِقٌۭ وَشَهِيدٌۭ","translation":"And every human being will come forward with [his erstwhile] inner urges and [his] conscious mind,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4651.mp3","surahId":50,"words":[{"id":23677,"position":1,"arabic":"وَجَآءَتْ","translation":"এবং আসবে","audioUrl":"wbw/050_021_001.mp3","charTypeName":"word"},{"id":23678,"position":2,"arabic":"كُلُّ","translation":"প্রত্যেক","audioUrl":"wbw/050_021_002.mp3","charTypeName":"word"},{"id":23679,"position":3,"arabic":"نَفْسٍۢ","translation":"ব্যক্তি","audioUrl":"wbw/050_021_003.mp3","charTypeName":"word"},{"id":23680,"position":4,"arabic":"مَّعَهَا","translation":"তার সাথে (থাকবে)","audioUrl":"wbw/050_021_004.mp3","charTypeName":"word"},{"id":23681,"position":5,"arabic":"سَآئِقٌۭ","translation":"একজন চালক","audioUrl":"wbw/050_021_005.mp3","charTypeName":"word"},{"id":23682,"position":6,"arabic":"وَشَهِيدٌۭ","translation":"ও একজন সাক্ষী","audioUrl":"wbw/050_021_006.mp3","charTypeName":"word"},{"id":23683,"position":7,"arabic":"٢١","translation":"(২১)","audioUrl":null,"charTypeName":"end"}]},{"number":22,"arabic":"لَّقَدْ كُنتَ فِى غَفْلَةٍۢ مِّنْ هَٰذَا فَكَشَفْنَا عَنكَ غِطَآءَكَ فَبَصَرُكَ ٱلْيَوْمَ حَدِيدٌۭ","translation":"[and will be told:] “Indeed, unmindful hast thou been of this [Day of Judgment]; but now We have lifted from thee thy veil, and sharp is thy sight today!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4652.mp3","surahId":50,"words":[{"id":24645,"position":1,"arabic":"لَّقَدْ","translation":"\"নিশ্চয়ই","audioUrl":"wbw/050_022_001.mp3","charTypeName":"word"},{"id":24646,"position":2,"arabic":"كُنتَ","translation":"তুমি ছিলে","audioUrl":"wbw/050_022_002.mp3","charTypeName":"word"},{"id":24647,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/050_022_003.mp3","charTypeName":"word"},{"id":24648,"position":4,"arabic":"غَفْلَةٍۢ","translation":"উদাসীনতার","audioUrl":"wbw/050_022_004.mp3","charTypeName":"word"},{"id":24649,"position":5,"arabic":"مِّنْ","translation":"হতে","audioUrl":"wbw/050_022_005.mp3","charTypeName":"word"},{"id":24650,"position":6,"arabic":"هَـٰذَا","translation":"এটা","audioUrl":"wbw/050_022_006.mp3","charTypeName":"word"},{"id":24651,"position":7,"arabic":"فَكَشَفْنَا","translation":"আমরা এখন সরিয়ে নিয়েছি","audioUrl":"wbw/050_022_007.mp3","charTypeName":"word"},{"id":24652,"position":8,"arabic":"عَنكَ","translation":"তোমার হতে","audioUrl":"wbw/050_022_008.mp3","charTypeName":"word"},{"id":24653,"position":9,"arabic":"غِطَآءَكَ","translation":"তোমার পর্দা","audioUrl":"wbw/050_022_009.mp3","charTypeName":"word"},{"id":24654,"position":10,"arabic":"فَبَصَرُكَ","translation":"ফলে তোমার দৃষ্টি","audioUrl":"wbw/050_022_010.mp3","charTypeName":"word"},{"id":24655,"position":11,"arabic":"ٱلْيَوْمَ","translation":"আজ","audioUrl":"wbw/050_022_011.mp3","charTypeName":"word"},{"id":24656,"position":12,"arabic":"حَدِيدٌۭ","translation":"প্রখর\"","audioUrl":"wbw/050_022_012.mp3","charTypeName":"word"},{"id":24657,"position":13,"arabic":"٢٢","translation":"(২২)","audioUrl":null,"charTypeName":"end"}]},{"number":23,"arabic":"وَقَالَ قَرِينُهُۥ هَٰذَا مَا لَدَىَّ عَتِيدٌ","translation":"And one part of him will say: “This it is that has been ever-present with me!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4653.mp3","surahId":50,"words":[{"id":26342,"position":1,"arabic":"وَقَالَ","translation":"এবং বলবে","audioUrl":"wbw/050_023_001.mp3","charTypeName":"word"},{"id":26343,"position":2,"arabic":"قَرِينُهُۥ","translation":"তার সঙ্গী","audioUrl":"wbw/050_023_002.mp3","charTypeName":"word"},{"id":26344,"position":3,"arabic":"هَـٰذَا","translation":"\"এই","audioUrl":"wbw/050_023_003.mp3","charTypeName":"word"},{"id":26345,"position":4,"arabic":"مَا","translation":"যে (ছিল)","audioUrl":"wbw/050_023_004.mp3","charTypeName":"word"},{"id":26346,"position":5,"arabic":"لَدَىَّ","translation":"আমার কাছে","audioUrl":"wbw/050_023_005.mp3","charTypeName":"word"},{"id":26347,"position":6,"arabic":"عَتِيدٌ","translation":"প্রস্তুত\"","audioUrl":"wbw/050_023_006.mp3","charTypeName":"word"},{"id":26348,"position":7,"arabic":"٢٣","translation":"(২৩)","audioUrl":null,"charTypeName":"end"}]},{"number":24,"arabic":"أَلْقِيَا فِى جَهَنَّمَ كُلَّ كَفَّارٍ عَنِيدٍۢ","translation":"[Whereupon God will command:] “Cast, cast into hell every [such] stubborn enemy of the truth,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4654.mp3","surahId":50,"words":[{"id":26793,"position":1,"arabic":"أَلْقِيَا","translation":"\"(বলা হবে) নিক্ষেপ কর দু'জনে","audioUrl":"wbw/050_024_001.mp3","charTypeName":"word"},{"id":26794,"position":2,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/050_024_002.mp3","charTypeName":"word"},{"id":26795,"position":3,"arabic":"جَهَنَّمَ","translation":"জাহান্নামের","audioUrl":"wbw/050_024_003.mp3","charTypeName":"word"},{"id":26796,"position":4,"arabic":"كُلَّ","translation":"প্রত্যেক","audioUrl":"wbw/050_024_004.mp3","charTypeName":"word"},{"id":26797,"position":5,"arabic":"كَفَّارٍ","translation":"কট্টর কাফিরকে","audioUrl":"wbw/050_024_005.mp3","charTypeName":"word"},{"id":26798,"position":6,"arabic":"عَنِيدٍۢ","translation":"(যে ছিল) উদ্ধত","audioUrl":"wbw/050_024_006.mp3","charTypeName":"word"},{"id":26799,"position":7,"arabic":"٢٤","translation":"(২৪)","audioUrl":null,"charTypeName":"end"}]},{"number":25,"arabic":"مَّنَّاعٍۢ لِّلْخَيْرِ مُعْتَدٍۢ مُّرِيبٍ","translation":"[every] withholder of good [and] sinful aggressor [and] fomentor of distrust [between man and man – everyone]","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4655.mp3","surahId":50,"words":[{"id":27847,"position":1,"arabic":"مَّنَّاعٍۢ","translation":"প্রবল বাধাদান কারী","audioUrl":"wbw/050_025_001.mp3","charTypeName":"word"},{"id":27848,"position":2,"arabic":"لِّلْخَيْرِ","translation":"কল্যাণ (কাজের)","audioUrl":"wbw/050_025_002.mp3","charTypeName":"word"},{"id":27849,"position":3,"arabic":"مُعْتَدٍۢ","translation":"সীমা লংঘনকারী","audioUrl":"wbw/050_025_003.mp3","charTypeName":"word"},{"id":27850,"position":4,"arabic":"مُّرِيبٍ","translation":"সন্দেহপোষণকারী","audioUrl":"wbw/050_025_004.mp3","charTypeName":"word"},{"id":27851,"position":5,"arabic":"٢٥","translation":"(২৫)","audioUrl":null,"charTypeName":"end"}]},{"number":26,"arabic":"ٱلَّذِى جَعَلَ مَعَ ٱللَّهِ إِلَٰهًا ءَاخَرَ فَأَلْقِيَاهُ فِى ٱلْعَذَابِ ٱلشَّدِيدِ","translation":"who has set up another deity beside God: cast him, then, cast him into suffering severe!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4656.mp3","surahId":50,"words":[{"id":28792,"position":1,"arabic":"ٱلَّذِى","translation":"যে","audioUrl":"wbw/050_026_001.mp3","charTypeName":"word"},{"id":28793,"position":2,"arabic":"جَعَلَ","translation":"বানিয়েছিল","audioUrl":"wbw/050_026_002.mp3","charTypeName":"word"},{"id":28794,"position":3,"arabic":"مَعَ","translation":"সাথে","audioUrl":"wbw/050_026_003.mp3","charTypeName":"word"},{"id":28795,"position":4,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/050_026_004.mp3","charTypeName":"word"},{"id":28796,"position":5,"arabic":"إِلَـٰهًا","translation":"উপাস্য","audioUrl":"wbw/050_026_005.mp3","charTypeName":"word"},{"id":28797,"position":6,"arabic":"ءَاخَرَ","translation":"অন্যকেও","audioUrl":"wbw/050_026_006.mp3","charTypeName":"word"},{"id":28798,"position":7,"arabic":"فَأَلْقِيَاهُ","translation":"তাকে তাই দু'জনে নিক্ষেপ কর","audioUrl":"wbw/050_026_007.mp3","charTypeName":"word"},{"id":28799,"position":8,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/050_026_008.mp3","charTypeName":"word"},{"id":28800,"position":9,"arabic":"ٱلْعَذَابِ","translation":"শাস্তির","audioUrl":"wbw/050_026_009.mp3","charTypeName":"word"},{"id":28801,"position":10,"arabic":"ٱلشَّدِيدِ","translation":"কঠিন\"","audioUrl":"wbw/050_026_010.mp3","charTypeName":"word"},{"id":28802,"position":11,"arabic":"٢٦","translation":"(২৬)","audioUrl":null,"charTypeName":"end"}]},{"number":27,"arabic":"۞ قَالَ قَرِينُهُۥ رَبَّنَا مَآ أَطْغَيْتُهُۥ 