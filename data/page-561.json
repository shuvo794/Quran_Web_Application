{"id":561,"ayahs":[{"number":8,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ تُوبُوٓا۟ إِلَى ٱللَّهِ تَوْبَةًۭ نَّصُوحًا عَسَىٰ رَبُّكُمْ أَن يُكَفِّرَ عَنكُمْ سَيِّـَٔاتِكُمْ وَيُدْخِلَكُمْ جَنَّٰتٍۢ تَجْرِى مِن تَحْتِهَا ٱلْأَنْهَٰرُ يَوْمَ لَا يُخْزِى ٱللَّهُ ٱلنَّبِىَّ وَٱلَّذِينَ ءَامَنُوا۟ مَعَهُۥ ۖ نُورُهُمْ يَسْعَىٰ بَيْنَ أَيْدِيهِمْ وَبِأَيْمَٰنِهِمْ يَقُولُونَ رَبَّنَآ أَتْمِمْ لَنَا نُورَنَا وَٱغْفِرْ لَنَآ ۖ إِنَّكَ عَلَىٰ كُلِّ شَىْءٍۢ قَدِيرٌۭ","translation":"O you who have attained to faith! Turn unto God in sincere repentance: it may well be that your Sustainer will efface from you your bad deeds, and will admit you into gardens through which running waters flow, on a Day on which God will not shame the Prophet and those who share his faith: their light will spread rapidly before them, and on their right; [and] they will pray: \"O our Sustainer! Cause this our light to shine for us forever, and forgive us our sins: for, verily, Thou hast the power to will anything!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5237.mp3","surahId":66,"words":[{"id":8990,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"ওহে","audioUrl":"wbw/066_008_001.mp3","charTypeName":"word"},{"id":8991,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/066_008_002.mp3","charTypeName":"word"},{"id":8992,"position":3,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছ","audioUrl":"wbw/066_008_003.mp3","charTypeName":"word"},{"id":8993,"position":4,"arabic":"تُوبُوٓا۟","translation":"তোমরা তওবা কর","audioUrl":"wbw/066_008_004.mp3","charTypeName":"word"},{"id":8994,"position":5,"arabic":"إِلَى","translation":"নিকট","audioUrl":"wbw/066_008_005.mp3","charTypeName":"word"},{"id":8995,"position":6,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/066_008_006.mp3","charTypeName":"word"},{"id":8996,"position":7,"arabic":"تَوْبَةًۭ","translation":"তওবা","audioUrl":"wbw/066_008_007.mp3","charTypeName":"word"},{"id":8997,"position":8,"arabic":"نَّصُوحًا","translation":"খালেস","audioUrl":"wbw/066_008_008.mp3","charTypeName":"word"},{"id":8998,"position":9,"arabic":"عَسَىٰ","translation":"সম্ভবতঃ","audioUrl":"wbw/066_008_009.mp3","charTypeName":"word"},{"id":8999,"position":10,"arabic":"رَبُّكُمْ","translation":"তোমাদের রব","audioUrl":"wbw/066_008_010.mp3","charTypeName":"word"},{"id":9000,"position":11,"arabic":"أَن","translation":"যে","audioUrl":"wbw/066_008_011.mp3","charTypeName":"word"},{"id":9001,"position":12,"arabic":"يُكَفِّرَ","translation":"মোচন করবেন","audioUrl":"wbw/066_008_012.mp3","charTypeName":"word"},{"id":9002,"position":13,"arabic":"عَنكُمْ","translation":"তোমাদের থেকে","audioUrl":"wbw/066_008_013.mp3","charTypeName":"word"},{"id":9003,"position":14,"arabic":"سَيِّـَٔاتِكُمْ","translation":"তোমাদের দোষগুলো","audioUrl":"wbw/066_008_014.mp3","charTypeName":"word"},{"id":9004,"position":15,"arabic":"وَيُدْخِلَكُمْ","translation":"এবং তোমাদের প্রবেশ করাবেন","audioUrl":"wbw/066_008_015.mp3","charTypeName":"word"},{"id":9005,"position":16,"arabic":"جَنَّـٰتٍۢ","translation":"জান্নাতে","audioUrl":"wbw/066_008_016.mp3","charTypeName":"word"},{"id":9006,"position":17,"arabic":"تَجْرِى","translation":"প্রবাহিত হয়","audioUrl":"wbw/066_008_017.mp3","charTypeName":"word"},{"id":9007,"position":18,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/066_008_018.mp3","charTypeName":"word"},{"id":9008,"position":19,"arabic":"تَحْتِهَا","translation":"তার পাদদেশ","audioUrl":"wbw/066_008_019.mp3","charTypeName":"word"},{"id":9009,"position":20,"arabic":"ٱلْأَنْهَـٰرُ","translation":"ঝর্নাধারাসমূহ","audioUrl":"wbw/066_008_020.mp3","charTypeName":"word"},{"id":9010,"position":21,"arabic":"يَوْمَ","translation":"সেদিন","audioUrl":"wbw/066_008_021.mp3","charTypeName":"word"},{"id":9011,"position":22,"arabic":"لَا","translation":"না","audioUrl":"wbw/066_008_022.mp3","charTypeName":"word"},{"id":9012,"position":23,"arabic":"يُخْزِى","translation":"লাঞ্চিত করবেন","audioUrl":"wbw/066_008_023.mp3","charTypeName":"wo