{"id":594,"ayahs":[{"number":24,"arabic":"يَقُولُ يَٰلَيْتَنِى قَدَّمْتُ لِحَيَاتِى","translation":"He will say, \"Oh, would that I had. provided beforehand for my life [to come]!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6017.mp3","surahId":89,"words":[{"id":27112,"position":1,"arabic":"يَقُولُ","translation":"সে বলবে","audioUrl":"wbw/089_024_001.mp3","charTypeName":"word"},{"id":27113,"position":2,"arabic":"يَـٰلَيْتَنِى","translation":"\"হায় আমার আফসোস","audioUrl":"wbw/089_024_002.mp3","charTypeName":"word"},{"id":27114,"position":3,"arabic":"قَدَّمْتُ","translation":"আমি আগে পাঠাতাম (যদি)","audioUrl":"wbw/089_024_003.mp3","charTypeName":"word"},{"id":27115,"position":4,"arabic":"لِحَيَاتِى","translation":"আমার এ জীবনের জন্য (কিছু নেকী)\"","audioUrl":"wbw/089_024_004.mp3","charTypeName":"word"},{"id":27116,"position":5,"arabic":"٢٤","translation":"(২৪)","audioUrl":null,"charTypeName":"end"}]},{"number":25,"arabic":"فَيَوْمَئِذٍۢ لَّا يُعَذِّبُ عَذَابَهُۥٓ أَحَدٌۭ","translation":"For, none can make suffer as He will make suffer [the sinners] on that Day,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6018.mp3","surahId":89,"words":[{"id":27903,"position":1,"arabic":"فَيَوْمَئِذٍۢ","translation":"অতঃপর সেদিন","audioUrl":"wbw/089_025_001.mp3","charTypeName":"word"},{"id":27904,"position":2,"arabic":"لَّا","translation":"না","audioUrl":"wbw/089_025_002.mp3","charTypeName":"word"},{"id":27905,"position":3,"arabic":"يُعَذِّبُ","translation":"শাস্তি দিতে পারবে","audioUrl":"wbw/089_025_003.mp3","charTypeName":"word"},{"id":27906,"position":4,"arabic":"عَذَابَهُۥٓ","translation":"তাঁর শাস্তির মতো","audioUrl":"wbw/089_025_004.mp3","charTypeName":"word"},{"id":27907,"position":5,"arabic":"أَحَدٌۭ","translation":"(অন্য) কেউ","audioUrl":"wbw/089_025_005.mp3","charTypeName":"word"},{"id":27908,"position":6,"arabic":"٢٥","translation":"(২৫)","audioUrl":null,"charTypeName":"end"}]},{"number":26,"arabic":"وَلَا يُوثِقُ وَثَاقَهُۥٓ أَحَد