TypeName":"word"},{"id":5751,"position":6,"arabic":"أَحَدٌۭ","translation":"কেউ","audioUrl":"wbw/090_005_006.mp3","charTypeName":"word"},{"id":5752,"position":7,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"يَقُولُ أَهْلَكْتُ مَالًۭا لُّبَدًا","translation":"He boasts, \"I have spent wealth abundant!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6029.mp3","surahId":90,"words":[{"id":6784,"position":1,"arabic":"يَقُولُ","translation":"সে বলে","audioUrl":"wbw/090_006_001.mp3","charTypeName":"word"},{"id":6785,"position":2,"arabic":"أَهْلَكْتُ","translation":"\"আমি নিঃশেষ করেছি","audioUrl":"wbw/090_006_002.mp3","charTypeName":"word"},{"id":6786,"position":3,"arabic":"مَالًۭا","translation":"ধনসম্পদ","audioUrl":"wbw/090_006_003.mp3","charTypeName":"word"},{"id":6787,"position":4,"arabic":"لُّبَدًا","translation":"বিপুল (পরিমাণ)\"","audioUrl":"wbw/090_006_004.mp3","charTypeName":"word"},{"id":6788,"position":5,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"أَيَحْسَبُ أَن لَّمْ يَرَهُۥٓ أَحَدٌ","translation":"Does he, then, think that no one sees him?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6030.mp3","surahId":90,"words":[{"id":7286,"position":1,"arabic":"أَيَحْسَبُ","translation":"সে মনে করে কি","audioUrl":"wbw/090_007_001.mp3","charTypeName":"word"},{"id":7287,"position":2,"arabic":"أَن","translation":"যে","audioUrl":"wbw/090_007_002.mp3","charTypeName":"word"},{"id":7288,"position":3,"arabic":"لَّمْ","translation":"নি","audioUrl":"wbw/090_007_003.mp3","charTypeName":"word"},{"id":7289,"position":4,"arabic":"يَرَهُۥٓ","translation":"তাকে দেখে","audioUrl":"wbw/090_007_004.mp3","charTypeName":"word"},{"id":7290,"position":5,"arabic":"أَحَدٌ","translation":"কেউ","audioUrl":"wbw/090_007_005.mp3","charTypeName":"word"},{"id":7291,"position":6,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic"