{"id":471,"ayahs":[{"number":34,"arabic":"وَلَقَدْ جَآءَكُمْ يُوسُفُ مِن قَبْلُ بِٱلْبَيِّنَٰتِ فَمَا زِلْتُمْ فِى شَكٍّۢ مِّمَّا جَآءَكُم بِهِۦ ۖ حَتَّىٰٓ إِذَا هَلَكَ قُلْتُمْ لَن يَبْعَثَ ٱللَّهُ مِنۢ بَعْدِهِۦ رَسُولًۭا ۚ كَذَٰلِكَ يُضِلُّ ٱللَّهُ مَنْ هُوَ مُسْرِفٌۭ مُّرْتَابٌ","translation":"“And [remember:] it was to you that Joseph came aforetime with all evidence of the truth; but you never ceased to throw doubt on all [the messages] that he brought you - so much so that when he died, you said, ‘Never will God send any apostle [even] after him!’ “In this way God lets go astray such as waste their own selves by throwing suspicion [on His revela­tions] –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4167.mp3","surahId":40,"words":[{"id":36193,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/040_034_001.mp3","charTypeName":"word"},{"id":36194,"position":2,"arabic":"جَآءَكُمْ","translation":"কাছে এসেছিলো তোমাদের","audioUrl":"wbw/040_034_002.mp3","charTypeName":"word"},{"id":36195,"position":3,"arabic":"يُوسُفُ","translation":"ইউসুফ","audioUrl":"wbw/040_034_003.mp3","charTypeName":"word"},{"id":36196,"position":4,"arabic":"مِن","translation":"পূর্বে","audioUrl":"wbw/040_034_004.mp3","charTypeName":"word"},{"id":36197,"position":5,"arabic":"قَبْلُ","translation":"ইতি","audioUrl":"wbw/040_034_005.mp3","charTypeName":"word"},{"id":36198,"position":6,"arabic":"بِٱلْبَيِّنَـٰتِ","translation":"সুস্পষ্ট প্রমাণসহ","audioUrl":"wbw/040_034_006.mp3","charTypeName":"word"},{"id":36199,"position":7,"arabic":"فَمَا","translation":"কিন্তু","audioUrl":"wbw/040_034_007.mp3","charTypeName":"word"},{"id":36200,"position":8,"arabic":"زِلْتُمْ","translation":"তোমরা ছিলে সর্বদা","audioUrl":"wbw/040_034_008.mp3","charTypeName":"word"},{"id":36201,"position":9,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/040_034_009.mp3","charTypeName":"word"},{"id":36202,"position":10,"arabic":"شَكٍّۢ","translation":"সন্দেহের","audioUrl":"wbw/040_034_010.mp3","charTypeName":"word"},{"id":36203,"position":11,"arabic":"مِّمَّا","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/040_034_011.mp3","charTypeName":"word"},{"id":36204,"position":12,"arabic":"جَآءَكُم","translation":"তোমাদের কাছে এনেছিলো","audioUrl":"wbw/040_034_012.mp3","charTypeName":"word"},{"id":36205,"position":13,"arabic":"بِهِۦ ۖ","translation":"সে সম্পর্কে","audioUrl":"wbw/040_034_013.mp3","charTypeName":"word"},{"id":36207,"position":14,"arabic":"حَتَّىٰٓ","translation":"অবশেষে","audioUrl":"wbw/040_034_015.mp3","charTypeName":"word"},{"id":36208,"position":15,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/040_034_016.mp3","charTypeName":"word"},{"id":36209,"position":16,"arabic":"هَلَكَ","translation":"সে মারা গেলো","audioUrl":"wbw/040_034_017.mp3","charTypeName":"word"},{"id":36210,"position":17,"arabic":"قُلْتُمْ","translation":"তোমরা বলেছিলে","audioUrl":"wbw/040_034_018.mp3","charTypeName":"word"},{"id":36211,"position":18,"arabic":"لَن","translation":"\"কখনও না","audioUrl":"wbw/040_034_019.mp3","charTypeName":"word"},{"id":36212,"position":19,"arabic":"يَبْعَثَ","translation":"পাঠাবেন","audioUrl":"wbw/040_034_020.mp3","charTypeName":"word"},{"id":36213,"position":20,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/040_034_021.mp3","charTypeName":"word"},{"id":36214,"position":21,"arabic":"مِنۢ","translation":"পরে","audioUrl":"wbw/040_034_022.mp3","charTypeName":"word"},{"id":36215,"position":22,"arabic":"بَعْدِهِۦ","translation":"তার","audioUrl":"wbw/040_034_023.mp3","charTypeName":"word"},{"id":36216,"position":23,"arabic":"رَسُولًۭا ۚ","translation":"কোনো রাসূল\"","audioUrl":"wbw/040_034_024.mp3","charTypeName":"word"},{"id":36218,"position":24,"arabic":"كَذَٰلِكَ","translation":"এভাবে","audioUrl":"wbw/040_034_026.mp3","charTypeName":"word"},{"id":36219,"position":25,"arabic":"يُضِلُّ","translation":"বিভ্রান্ত করেন","audioUrl":"wbw/040_034_027.mp3","charTypeName":"word"},{"id":36220,"position":26,"arabic":"ٱللَّهُ","trans