ion":"(যা) অহংকারী","audioUrl":"wbw/040_035_024.mp3","charTypeName":"word"},{"id":37044,"position":23,"arabic":"جَبَّارٍۢ","translation":"স্বৈরাচারী\"","audioUrl":"wbw/040_035_025.mp3","charTypeName":"word"},{"id":37045,"position":24,"arabic":"٣٥","translation":"(৩৫)","audioUrl":null,"charTypeName":"end"}]},{"number":36,"arabic":"وَقَالَ فِرْعَوْنُ يَٰهَٰمَٰنُ ٱبْنِ لِى صَرْحًۭا لَّعَلِّىٓ أَبْلُغُ ٱلْأَسْبَٰبَ","translation":"But Pharaoh said: “O Haman! Build me a lofty tower, that haply I may attain to the [right] means","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4169.mp3","surahId":40,"words":[{"id":37897,"position":1,"arabic":"وَقَالَ","translation":"এবং বললো","audioUrl":"wbw/040_036_001.mp3","charTypeName":"word"},{"id":37898,"position":2,"arabic":"فِرْعَوْنُ","translation":"ফিরআউন","audioUrl":"wbw/040_036_002.mp3","charTypeName":"word"},{"id":37899,"position":3,"arabic":"يَـٰهَـٰمَـٰنُ","translation":"\"হে হামান","audioUrl":"wbw/040_036_003.mp3","charTypeName":"word"},{"id":37900,"position":4,"arabic":"ٱبْنِ","translation":"নির্মাণ করো","audioUrl":"wbw/040_036_004.mp3","charTypeName":"word"},{"id":37901,"position":5,"arabic":"لِى","translation":"আমার জন্যে","audioUrl":"wbw/040_036_005.mp3","charTypeName":"word"},{"id":37902,"position":6,"arabic":"صَرْحًۭا","translation":"সুউচ্চ প্রাসাদ","audioUrl":"wbw/040_036_006.mp3","charTypeName":"word"},{"id":37903,"position":7,"arabic":"لَّعَلِّىٓ","translation":"যাতে","audioUrl":"wbw/040_036_007.mp3","charTypeName":"word"},{"id":37904,"position":8,"arabic":"أَبْلُغُ","translation":"আমি পৌঁছি","audioUrl":"wbw/040_036_008.mp3","charTypeName":"word"},{"id":37905,"position":9,"arabic":"ٱلْأَسْبَـٰبَ","translation":"পথসমূহে","audioUrl":"wbw/040_036_009.mp3","charTypeName":"word"},{"id":37906,"position":10,"arabic":"٣٦","translation":"(৩৬)","audioUrl":null,"charTypeName":"end"}]},{"number":37,"arabic":"أَسْبَٰبَ ٱلسَّمَٰوَٰتِ فَأَطَّلِعَ إِلَىٰٓ إِلَٰهِ مُوسَىٰ وَإِنِّى لَأَظُنُّهُۥ كَٰذِبًۭا ۚ وَكَذَٰلِكَ زُيِّنَ لِفِرْعَوْنَ سُوٓءُ عَمَلِهِۦ وَصُدَّ عَنِ ٱلسَّبِيلِ ۚ وَمَا كَيْدُ فِرْعَوْنَ إِلَّا فِى تَبَابٍۢ","translation":"the means of approach to the heavens - and that [thus] I may have a look at the god of Moses: for, behold, I am indeed certain that he is a liar!” And thus, goodly seemed unto Pharaoh the evil of his own doings, and so he was barred from the path [of truth]: and Pharaoh’s guile did not lead to aught but ruin.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4170.mp3","surahId":40,"words":[{"id":38612,"position":1,"arabic":"أَسْبَـٰبَ","translation":"পথসমূহ","audioUrl":"wbw/040_037_001.mp3","charTypeName":"word"},{"id":38613,"position":2,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশের","audioUrl":"wbw/040_037_002.mp3","charTypeName":"word"},{"id":38614,"position":3,"arabic":"فَأَطَّلِعَ","translation":"আমি অতঃপর উঁকি মেরে দেখি","audioUrl":"wbw/040_037_003.mp3","charTypeName":"word"},{"id":38615,"position":4,"arabic":"إِلَىٰٓ","translation":"কাছে","audioUrl":"wbw/040_037_004.mp3","charTypeName":"word"},{"id":38616,"position":5,"arabic":"إِلَـٰهِ","translation":"ইলাহর","audioUrl":"wbw/040_037_005.mp3","charTypeName":"word"},{"id":38617,"position":6,"arabic":"مُوسَىٰ","translation":"মূসার","audioUrl":"wbw/040_037_006.mp3","charTypeName":"word"},{"id":38618,"position":7,"arabic":"وَإِنِّى","translation":"এবং নিশ্চয়ই আমি","audioUrl":"wbw/040_037_007.mp3","charTypeName":"word"},{"id":38619,"position":8,"arabic":"لَأَظُنُّهُۥ","translation":"আমি অবশ্যই তাকে মনে করি","audioUrl":"wbw/040_037_008.mp3","charTypeName":"word"},{"id":38620,"position":9,"arabic":"كَـٰذِبًۭا ۚ","translation":"মিথ্যাবাদী\"","audioUrl":"wbw/040_037_009.mp3","charTypeName":"word"},{"id":38622,"position":10,"arabic":"وَكَذَٰلِكَ","translation":"এবং এভাবে","audioUrl":"wbw/040_037_011.mp3","charTypeName":"word"},{"id":38623,"position":11,"arabic":"زُيِّنَ","translation":"শোভন করা হয়েছিলো","audioUrl":"wbw/040_037_012.mp3","charTypeName":"word"},{"id":38624,"positio