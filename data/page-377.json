{"id":377,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ طسٓ ۚ تِلْكَ ءَايَٰتُ ٱلْقُرْءَانِ وَكِتَابٍۢ مُّبِينٍ","translation":"Ta. Sin. THESE ARE MESSAGES of the Qur’an - a di­vine writ clear in itself and clearly showing the truth:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3160.mp3","surahId":27,"words":[{"id":759,"position":1,"arabic":"طسٓ ۚ","translation":"ত্বা-সীন","audioUrl":"wbw/027_001_001.mp3","charTypeName":"word"},{"id":761,"position":2,"arabic":"تِلْكَ","translation":"এই","audioUrl":"wbw/027_001_003.mp3","charTypeName":"word"},{"id":762,"position":3,"arabic":"ءَايَـٰتُ","translation":"আয়াতসমূহ","audioUrl":"wbw/027_001_004.mp3","charTypeName":"word"},{"id":763,"position":4,"arabic":"ٱلْقُرْءَانِ","translation":"কুরআনের","audioUrl":"wbw/027_001_005.mp3","charTypeName":"word"},{"id":764,"position":5,"arabic":"وَكِتَابٍۢ","translation":"ও কিতাবের","audioUrl":"wbw/027_001_006.mp3","charTypeName":"word"},{"id":765,"position":6,"arabic":"مُّبِينٍ","translation":"(যা) সুস্পষ্ট","audioUrl":"wbw/027_001_007.mp3","charTypeName":"word"},{"id":766,"position":7,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"هُدًۭى وَبُشْرَىٰ لِلْمُؤْمِنِينَ","translation":"a guidance and a glad tiding to the believers","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3161.mp3","surahId":27,"words":[{"id":1819,"position":1,"arabic":"هُدًۭى","translation":"(এটা) পথ নির্দেশ","audioUrl":"wbw/027_002_001.mp3","charTypeName":"word"},{"id":1820,"position":2,"arabic":"وَبُشْرَىٰ","translation":"ও সুসংবাদ","audioUrl":"wbw/027_002_002.mp3","charTypeName":"word"},{"id":1821,"position":3,"arabic":"لِلْمُؤْمِنِينَ","translation":"জন্যে মু'মিনদের","audioUrl":"wbw/027_002_003.mp3","charTypeName":"word"},{"id":1822,"position":4,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"ٱلَّذِينَ يُقِيمُونَ ٱلصَّلَوٰةَ وَيُؤْتُونَ ٱلزَّكَوٰةَ وَهُم بِٱلْءَاخِرَةِ هُمْ يُوقِنُونَ","translation":"who are constant in prayer and spend in charity: for it is they, they who in their innermost are certain of the life to come!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3162.mp3","surahId":27,"words":[{"id":2943,"position":1,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/027_003_001.mp3","charTypeName":"word"},{"id":2944,"position":2,"arabic":"يُقِيمُونَ","translation":"প্রতিষ্ঠা করে","audioUrl":"wbw/027_003_002.mp3","charTypeName":"word"},{"id":2945,"position":3,"arabic":"ٱلصَّلَوٰةَ","translation":"সালাত","audioUrl":"wbw/027_003_003.mp3","charTypeName":"word"},{"id":2946,"position":4,"arabic":"وَيُؤْتُونَ","translation":"ও আদায় করে","audioUrl":"wbw/027_003_004.mp3","charTypeName":"word"},{"id":2947,"position":5,"arabic":"ٱلزَّكَوٰةَ","translation":"যাকাত","audioUrl":"wbw/027_003_005.mp3","charTypeName":"word"},{"id":2948,"position":6,"arabic":"وَهُم","translation":"এবং তারা","audioUrl":"wbw/027_003_006.mp3","charTypeName":"word"},{"id":2949,"position":7,"arabic":"بِٱلْـَٔاخِرَةِ","translation":"উপর আখেরাতের","audioUrl":"wbw/027_003_007.mp3","charTypeName":"word"},{"id":2950,"position":8,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/027_003_008.mp3","charTypeName":"word"},{"id":2951,"position":9,"arabic":"يُوقِنُونَ","translation":"দৃঢ় বিশ্বাস রাখে","audioUrl":"wbw/027_003_009.mp3","charTypeName":"word"},{"id":2952,"position":10,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"إِنَّ ٱلَّذِينَ لَا يُؤْمِنُونَ بِٱلْءَاخِرَةِ زَيَّنَّا لَهُمْ أَعْمَٰلَهُمْ فَهُمْ يَعْمَهُونَ","translation":"As for those who will not believe in the life to come - behold, goodly have We made their own doings appear unto them, and so they stumble blindly to and fro","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3163.mp3","surahId":27,"words":[{"id":4269,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/027_004_001.mp3","charTypeName":"word"},{"id":4270,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/027_004_002.mp3","charTypeName":"word"},{"id":4271,"position":3,"arabic":"لَا","translation":"না","audioUrl":"wbw/027_004_003.mp3","charTypeName":"word"},{"id":4272,"position":4,"arabic":"يُؤْمِنُونَ","translation":"বিশ্বাস করে","audioUrl":"wbw/027_004_004.mp3","charTypeName":"word"},{"id":4273,"position":5,"arabic":"بِٱلْـَٔاخِرَةِ","translation":"উপর আখেরাতের","audioUrl":"wbw/027_004_005.mp3","charTypeName":"word"},{"id":4274,"position":6,"arabic":"زَيَّنَّا","translation":"আমরা সুশোভন করেছি","audioUrl":"wbw/027_004_006.mp3","charTypeName":"word"},{"id":4275,"position":7,"arabic":"لَهُمْ","translation":"জন্যে তাদের","audioUrl":"wbw/027_004_007.mp3","charTypeName":"word"},{"id":4276,"position":8,"arabic":"أَعْمَـٰلَهُمْ","translation":"কাজকর্মসমূহকে তাদের","audioUrl":"wbw/027_004_008.mp3","charTypeName":"word"},{"id":4277,"position":9,"arabic":"فَهُمْ","translation":"ফলে তারা","audioUrl":"wbw/027_004_009.mp3","charTypeName":"word"},{"id":4278,"position":10,"arabic":"يَعْمَهُونَ","translation":"বিভ্রান্তিতে ঘুরে বেড়াচ্ছে","audioUrl":"wbw/027_004_010.mp3","charTypeName":"word"},{"id":4279,"position":11,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"أُو۟لَٰٓئِكَ ٱلَّذِينَ لَهُمْ سُوٓءُ ٱلْعَذَابِ وَهُمْ فِى ٱلْءَاخِرَةِ هُمُ ٱلْأَخْسَرُونَ","translation":"It is they whom the worst of suffering awaits: for it is they, they who in the life to come shall be the greatest losers!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3164.mp3","surahId":27,"words":[{"id":5533,"position":1,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐসব (লোক)","audioUrl":"wbw/027_005_001.mp3","charTypeName":"word"},{"id":5534,"position":2,"arabic":"ٱلَّذِينَ","translation":"তারাই","audioUrl":"wbw/027_005_002.mp3","charTypeName":"word"},{"id":5535,"position":3,"arabic":"لَهُمْ","translation":"জন্যে যাদের (রয়েছে)","audioUrl":"wbw/027_005_003.mp3","charTypeName":"word"},{"id":5536,"position":4,"arabic":"سُوٓءُ","translation":"(অত্যন্ত) খারাপ","audioUrl":"wbw/027_005_004.mp3","charTypeName":"word"},{"id":5537,"position":5,"arabic":"ٱلْعَذَابِ","translation":"শাস্তি","audioUrl":"wbw/027_005_005.mp3","charTypeName":"word"},{"id":5538,"position":6,"arabic":"وَهُمْ","translation":"এবং তারা হবে","audioUrl":"wbw/027_005_006.mp3","charTypeName":"word"},{"id":5539,"position":7,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/027_005_007.mp3","charTypeName":"word"},{"id":5540,"position":8,"arabic":"ٱلْـَٔاخِرَةِ","translation":"আখেরাতে","audioUrl":"wbw/027_005_008.mp3","charTypeName":"word"},{"id":5541,"position":9,"arabic":"هُمُ","translation":"তারাই","audioUrl":"wbw/027_005_009.mp3","charTypeName":"word"},{"id":5542,"position":10,"arabic":"ٱلْأَخْسَرُونَ","translation":"সর্বাধিক ক্ষতিগ্রস্ত","audioUrl":"wbw/027_005_010.mp3","charTypeName":"word"},{"id":5543,"position":11,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"وَإِنَّكَ لَتُلَقَّى ٱلْقُرْءَانَ مِن لَّدُنْ حَكِيمٍ عَلِيمٍ","translation":"But [as for thee, O believer,] verily, thou hast received this Qur’an out of the grace of One who is wise, all-knowing.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3165.mp3","surahId":27,"words":[{"id":6789,"position":1,"arabic":"وَإِنَّكَ","translation":"আর (হে নাবী) নিশ্চয়ই তুমি","audioUrl":"wbw/027_006_001.mp3","charTypeName":"word"},{"id":6790,"position":2,"arabic":"لَتُلَقَّى","translation":"অবশ্যই লাভ করেছো","audioUrl":"wbw/027_006_002.mp3","charTypeName":"word"},{"id":6791,"position":3,"arabic":"ٱلْقُرْءَانَ","translation":"(এই) কুরআন","audioUrl":"wbw/027_006_003.mp3","charTypeName":"word"},{"id":6792,"position":4,"arabic":"مِن","translation":"হ'তে","audioUrl":"wbw/027_006_004.mp3","charTypeName":"word"},{"id":6793,"position":5,"arabic":"لَّدُنْ","translation":"পক্ষ","audioUrl":"wbw/027_006_005.mp3","charTypeName":"word"},{"id":6794,"position":6,"arabic":"حَكِيمٍ","translation":"মহাবিজ্ঞ","audioUrl":"wbw/027_006_006.mp3","charTypeName":"word"},{"id":6795,"position":7,"arabic":"عَلِيمٍ","translation":"সর্বাধিক জ্ঞানী (আল্লাহর)","audioUrl":"wbw/027_006_007.mp3","charTypeName":"word"},{"id":6796,"position":8,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"إِذْ قَالَ مُوسَىٰ لِأَهْلِهِۦٓ إِنِّىٓ ءَانَسْتُ نَارًۭا سَـَٔاتِيكُم مِّنْهَا بِخَبَرٍ أَوْ ءَاتِيكُم بِشِهَابٍۢ قَبَسٍۢ لَّعَلَّكُمْ تَصْطَلُونَ","translation":"Lo! [While lost in the desert,] Moses said to his family: “Behold, I perceive a fire [far away]; I may bring you from there some tiding [as to which way we arc to pursue], or bring you [at least] a burning brand so that you might warm yourselves.”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3166.mp3","surahId":27,"words":[{"id":8131,"position":1,"arabic":"إِذْ","translation":"(স্মরণ করো) যখন","audioUrl":"wbw/027_007_001.mp3","charTypeName":"word"},{"id":8132,"position":2,"arabic":"قَالَ","translation":"বলেছিলো","audioUrl":"wbw/027_007_002.mp3","charTypeName":"word"},{"id":8133,"position":3,"arabic":"مُوسَىٰ","translation":"মূসা","audioUrl":"wbw/027_007_003.mp3","charTypeName":"word"},{"id":8134,"position":4,"arabic":"لِأَهْلِهِۦٓ","translation":"উদ্দেশ্যে তার পরিবারের","audioUrl":"wbw/027_007_004.mp3","charTypeName":"word"},{"id":8135,"position":5,"arabic":"إِنِّىٓ","translation":"\"নিশ্চয়ই আমি","audioUrl":"wbw/027_007_005.mp3","charTypeName":"word"},{"id":8136,"position":6,"arabic":"ءَانَسْتُ","translation":"দেখেছি","audioUrl":"wbw/027_007_006.mp3","charTypeName":"word"},{"id":8137,"position":7,"arabic":"نَارًۭا","translation":"আগুন","audioUrl":"wbw/027_007_007.mp3","charTypeName":"word"},{"id":8138,"position":8,"arabic":"سَـَٔاتِيكُم","translation":"অচিরেই তোমাদের (কাছে) আসবো আমি","audioUrl":"wbw/027_007_008.mp3","charTypeName":"word"},{"id":8139,"position":9,"arabic":"مِّنْهَا","translation":"তা হ'তে","audioUrl":"wbw/027_00