009_003.mp3","charTypeName":"word"},{"id":10493,"position":4,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/027_009_004.mp3","charTypeName":"word"},{"id":10494,"position":5,"arabic":"ٱلْعَزِيزُ","translation":"মহাপরাক্রমশালী","audioUrl":"wbw/027_009_005.mp3","charTypeName":"word"},{"id":10495,"position":6,"arabic":"ٱلْحَكِيمُ","translation":"প্রজ্ঞামময়\"","audioUrl":"wbw/027_009_006.mp3","charTypeName":"word"},{"id":10496,"position":7,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"وَأَلْقِ عَصَاكَ ۚ فَلَمَّا رَءَاهَا تَهْتَزُّ كَأَنَّهَا جَآنٌّۭ وَلَّىٰ مُدْبِرًۭا وَلَمْ يُعَقِّبْ ۚ يَٰمُوسَىٰ لَا تَخَفْ إِنِّى لَا يَخَافُ لَدَىَّ ٱلْمُرْسَلُونَ","translation":"[And then He said:] “Now throw down thy staff!” But when he saw it move rapidly, as if it were a serpent, he drew back [in terror], and did not [dare to] return. [And God spoke to him again:] O Moses! Fear not - for, behold, no fear need the message-bearers have in My Presence,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3169.mp3","surahId":27,"words":[{"id":11699,"position":1,"arabic":"وَأَلْقِ","translation":"আর (হে মূসা) তুমি ছোঁড়ো","audioUrl":"wbw/027_010_001.mp3","charTypeName":"word"},{"id":11700,"position":2,"arabic":"عَصَاكَ ۚ","translation":"তোমার লাঠি\"","audioUrl":"wbw/027_010_002.mp3","charTypeName":"word"},{"id":11702,"position":3,"arabic":"فَلَمَّا","translation":"অতঃপর যখন","audioUrl":"wbw/027_010_004.mp3","charTypeName":"word"},{"id":11703,"position":4,"arabic":"رَءَاهَا","translation":"সে দেখলো তা","audioUrl":"wbw/027_010_005.mp3","charTypeName":"word"},{"id":11704,"position":5,"arabic":"تَهْتَزُّ","translation":"গড়িয়ে চলছে","audioUrl":"wbw/027_010_006.mp3","charTypeName":"word"},{"id":11705,"position":6,"arabic":"كَأَنَّهَا","translation":"যেন তা","audioUrl":"wbw/027_010_007.mp3","charTypeName":"word"},{"id":11706,"position":7,"arabic":"جَآنٌّۭ","translation":"সাপ","audioUrl":"wbw/027_010_008.mp3","charTypeN