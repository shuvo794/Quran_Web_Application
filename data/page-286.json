":6,"arabic":"لِيَذَّكَّرُوا۟","translation":"যেন তারা শিক্ষা নেয়","audioUrl":"wbw/017_041_006.mp3","charTypeName":"word"},{"id":41943,"position":7,"arabic":"وَمَا","translation":"কিন্তু না","audioUrl":"wbw/017_041_007.mp3","charTypeName":"word"},{"id":41944,"position":8,"arabic":"يَزِيدُهُمْ","translation":"বৃদ্ধি পায় তাদের","audioUrl":"wbw/017_041_008.mp3","charTypeName":"word"},{"id":41945,"position":9,"arabic":"إِلَّا","translation":"এছাড়া","audioUrl":"wbw/017_041_009.mp3","charTypeName":"word"},{"id":41946,"position":10,"arabic":"نُفُورًۭا","translation":"বিমুখতা","audioUrl":"wbw/017_041_010.mp3","charTypeName":"word"},{"id":41947,"position":11,"arabic":"٤١","translation":"(৪১)","audioUrl":null,"charTypeName":"end"}]},{"number":42,"arabic":"قُل لَّوْ كَانَ مَعَهُۥٓ ءَالِهَةٌۭ كَمَا يَقُولُونَ إِذًۭا لَّٱبْتَغَوْا۟ إِلَىٰ ذِى ٱلْعَرْشِ سَبِيلًۭا","translation":"Say: \"If there were-as some people assert [other] deities side by side with Him, surely [even] they would have to strive to find a way unto Him who is enthroned on His almightiness?\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2071.mp3","surahId":17,"words":[{"id":42685,"position":1,"arabic":"قُل","translation":"বলো","audioUrl":"wbw/017_042_001.mp3","charTypeName":"word"},{"id":42686,"position":2,"arabic":"لَّوْ","translation":"\"যদি","audioUrl":"wbw/017_042_002.mp3","charTypeName":"word"},{"id":42687,"position":3,"arabic":"كَانَ","translation":"থাকতো","audioUrl":"wbw/017_042_003.mp3","charTypeName":"word"},{"id":42688,"position":4,"arabic":"مَعَهُۥٓ","translation":"তাঁর সাথে","audioUrl":"wbw/017_042_004.mp3","charTypeName":"word"},{"id":42689,"position":5,"arabic":"ءَالِهَةٌۭ","translation":"কোনো ইলাহ","audioUrl":"wbw/017_042_005.mp3","charTypeName":"word"},{"id":42690,"position":6,"arabic":"كَمَا","translation":"যেমন","audioUrl":"wbw/017_042_006.mp3","charTypeName":"word"},{"id":42691,"position":7,"arabic":"يَقُولُونَ","translation":"তারা বলে","audioUrl":"wbw/017_042_007.mp3","charTypeName":"word"},{"id":42692,"position":8,"arabic":"إِذًۭا","translation":"তাহ'লে","audioUrl":"wbw/017_042_008.mp3","charTypeName":"word"},{"id":42693,"position":9,"arabic":"لَّٱبْتَغَوْا۟","translation":"তারা অবশ্যই খোঁজ করতো","audioUrl":"wbw/017_042_009.mp3","charTypeName":"word"},{"id":42694,"position":10,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/017_042_010.mp3","charTypeName":"word"},{"id":42695,"position":11,"arabic":"ذِى","translation":"অধিপতির","audioUrl":"wbw/017_042_011.mp3","charTypeName":"word"},{"id":42696,"position":12,"arabic":"ٱلْعَرْشِ","translation":"আরশের","audioUrl":"wbw/017_042_012.mp3","charTypeName":"word"},{"id":42697,"position":13,"arabic":"سَبِيلًۭا","translation":"পথ\"","audioUrl":"wbw/017_042_013.mp3","charTypeName":"word"},{"id":42698,"position":14,"arabic":"٤٢","translation":"(৪২)","audioUrl":null,"charTypeName":"end"}]},{"number":43,"arabic":"سُبْحَٰنَهُۥ وَتَعَٰلَىٰ عَمَّا يَقُولُونَ عُلُوًّۭا كَبِيرًۭا","translation":"Limitless is He in His glory, and sublimely, immeasurably exalted above anything that men may say [about Him]","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2072.mp3","surahId":17,"words":[{"id":43474,"position":1,"arabic":"سُبْحَـٰنَهُۥ","translation":"তিনি পবিত্র","audioUrl":"wbw/017_043_001.mp3","charTypeName":"word"},{"id":43475,"position":2,"arabic":"وَتَعَـٰلَىٰ","translation":"ও মহিমাময়","audioUrl":"wbw/017_043_002.mp3","charTypeName":"word"},{"id":43476,"position":3,"arabic":"عَمَّا","translation":"তা হ'তে যা","audioUrl":"wbw/017_043_003.mp3","charTypeName":"word"},{"id":43477,"position":4,"arabic":"يَقُولُونَ","translation":"তারা বলে","audioUrl":"wbw/017_043_004.mp3","charTypeName":"word"},{"id":43478,"position":5,"arabic":"عُلُوًّۭا","translation":"উপরে","audioUrl":"wbw/017_043_005.mp3","charTypeName":"word"},{"id":43479,"position":6,"arabic":"كَبِيرًۭا","translation":"বহু","audioUrl":"wbw/017_043_006.mp3","charTypeName":"word"},{"id":43480,"position":7,"arabic":"٤٣","translation":"(৪৩)","audioUrl":null,"charTypeName":"end"}]},{"number":44,"arabic":"تُسَبِّحُ لَهُ ٱلسَّمَٰوَٰتُ ٱلسَّبْعُ وَٱلْأَرْضُ وَمَن فِيهِنَّ ۚ وَإِن مِّن شَىْءٍ إِلَّا يُسَبِّحُ بِحَمْدِهِۦ وَلَٰكِن لَّا تَفْقَهُونَ تَسْبِيحَهُمْ ۗ إِنَّهُۥ كَانَ حَلِيمًا غَفُورًۭا","translation":"The seven heavens extol His limitless glory, and the earth, and all that they contain; and there is not a single thing but extols His limitless glory and praise: but you [O men] fail to grasp the manner of their glorifying Him! Verily, He is forbearing, much-forgiving!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2073.mp3","surahId":17,"words":[{"id":44187,"position":1,"arabic":"تُسَبِّحُ","translation":"পবিত্রতা ঘোষণা করছে","audioUrl":"wbw/017_044_001.mp3","charTypeName":"word"},{"id":44188,"position":2,"arabic":"لَهُ","translation":"জন্যে তাঁর","audioUrl":"wbw/017_044_002.mp3","charTypeName":"word"},{"id":44189,"position":3,"arabic":"ٱلسَّمَـٰوَٰتُ","translation":"আকাশমন্ডলী","audioUrl":"wbw/017_044_003.mp3","charTypeName":"word"},{"id":44190,"position":4,"arabic":"ٱلسَّبْعُ","translation":"সাত","audioUrl":"wbw/017_044_004.mp3","charTypeName":"word"},{"id":44191,"position":5,"arabic":"وَٱلْأَرْضُ","translation":"ও পৃথিবী","audioUrl":"wbw/017_044_005.mp3","charTypeName":"word"},{"id":44192,"position":6,"arabic":"وَمَن","translation":"এবং যা কিছু আছে","audioUrl":"wbw/017_044_006.mp3","charTypeName":"word"},{"id":44193,"position":7,"arabic":"فِيهِنَّ ۚ","translation":"মধ্যে তাদের","audioUrl":"wbw/017_044_007.mp3","charTypeName":"word"},{"id":44195,"position":8,"arabic":"وَإِن","translation":"এবং নেই","audioUrl":"wbw/017_044_009.mp3","charTypeName":"word"},{"id":44196,"position":9,"arabic":"مِّن","translation":"কোনো","audioUrl":"wbw/017_044_010.mp3","charTypeName":"word"},{"id":44197,"position":10,"arabic":"شَىْءٍ","translation":"বস্তু","audioUrl":"wbw/017_044_011.mp3","charTypeName":"word"},{"id":44198,"position":11,"arabic":"إِلَّا","translation":"এছাড়া যে","audioUrl":"wbw/017_044_012.mp3","charTypeName":"word"},{"id":44199,"position":12,"arabic":"يُسَبِّحُ","translation":"পবিত্রতা ঘোষণা করছে","audioUrl":"wbw/017_044_013.mp3","charTypeName":"word"},{"id":44200,"position":13,"arabic":"بِحَمْدِهِۦ","translation":"সাথে তাঁর সপ্রশংসার","audioUrl":"wbw/017_044_014.mp3","charTypeName":"word"},{"id":44201,"position":14,"arabic":"وَلَـٰكِن","translation":"কিন্তু","audioUrl":"wbw/017_044_015.mp3","charTypeName":"word"},{"id":44202,"position":15,"arabic":"لَّا","translation":"না","audioUrl":"wbw/017_044_016.mp3","charTypeName":"word"},{"id":44203,"position":16,"arabic":"تَفْقَهُونَ","translation":"তোমরা অনুধাবন করো","audioUrl":"wbw/017_044_017.mp3","charTypeName":"word"},{"id":44204,"position":17,"arabic":"تَسْبِيحَهُمْ ۗ","translation":"তাদের পবিত্রতা ঘোষণা করা","audioUrl":"wbw/017_044_018.mp3","charTypeName":"word"},{"id":44206,"position":18,"arabic":"إِنَّهُۥ","translation":"নিশ্চয়ই তিনি","audioUrl":"wbw/017_044_020.mp3","charTypeName":"word"},{"id":44207,"position":19,"arabic":"كَانَ","translation":"হলেন","audioUrl":"wbw/017_044_021.mp3","charTypeName":"word"},{"id":44208,"position":20,"arabic":"حَلِيمًا","translation":"সহনশীল","audioUrl":"wbw/017_044_022.mp3","charTypeName":"word"},{"id":44209,"position":21,"arabic":"غَفُورًۭا","translation":"ক্ষমা পরায়ণ\"","audioUrl":"wbw/017_044_023.mp3","charTypeName":"word"},{"id":44210,"position":22,"arabic":"٤٤","translation":"(৪৪)","audioUrl":null,"charTypeName":"end"}]},{"number":45,"arabic":"وَإِذَا قَرَأْتَ ٱلْقُرْءَانَ جَعَلْنَا بَيْنَكَ وَبَيْنَ ٱلَّذِينَ لَا يُؤْمِنُونَ بِٱلْءَاخِرَةِ حِجَابًۭا مَّسْتُورًۭا","translation":"But [thus it is:] whenever thou recitest the Qur'an, We place an invisible barrier between thee and those who will not believe in the life to come: -","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2074.mp3","surahId":17,"words":[{"id":44936,"position":1,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/017_045_001.mp3","charTypeName":"word"},{"id":44937,"position":2,"arabic":"قَرَأْتَ","translation":"তুমি পাঠ করো","audioUrl":"wbw/017_045_002.mp3","charTypeName":"word"},{"id":44938,"position":3,"arabic":"ٱلْقُرْءَانَ","translation":"কুরআন","audioUrl":"wbw/017_045_003.mp3","charTypeName":"word"},{"id":44939,"position":4,"arabic":"جَعَلْنَا","translation":"আমরা বানাই","audioUrl":"wbw/017_045_004.mp3","charTypeName":"word"},{"id":44940,"position":5,"arabic":"بَيْنَكَ","translation":"তোমার মাঝে","audioUrl":"wbw/017_045_005.mp3","charTypeName":"word"},{"id":44941,"position":6,"arabic":"وَبَيْنَ","translation":"ও মাঝে","audioUrl":"wbw/017_045_006.mp3","charTypeName":"word"},{"id":44942,"position":7,"arabic":"ٱلَّذِينَ","translation":"তাদের (যারা)","audioUrl":"wbw/017_045_007.mp3","charTypeName":"word"},{"id":44943,"position":8,"arabic":"لَا","translation":"না","audioUrl":"wbw/017_045_008.mp3","charTypeName":"word"},{"id":44944,"position":9,"arabic":"يُؤْمِنُونَ","translation":"ঈমান আনে","audioUrl":"wbw/017_045_009.mp3","charTypeName":"word"},{"id":44945,"position":10,"arabic":"بِٱلْـَٔاخِرَةِ","translation":"উপর আখিরাতের","audioUrl":"wbw/017_045_010.mp3","charTypeName":"word"},{"id":44946,"position":11,"arabic":"حِجَابًۭا","translation":"পর্দা","audioUrl":"wbw/017_045_011.mp3","charTypeName":"word"},{"id":44947,"position":12,"arabic":"مَّسْتُورًۭا","translation":"প্রচ্ছন্ন","audioUrl":"wbw/017_045_012.mp3","charTypeName":"word"},{"id":44948,"position":13,"arabic":"٤٥","translation":"(৪৫)","audioUrl":null,"charTypeName":"end"}]},{"number":46,"arabic":"وَجَعَلْنَا عَلَىٰ قُلُوبِهِمْ أَكِنَّةً أَن يَفْقَهُوهُ وَفِىٓ ءَاذَانِهِمْ وَقْرًۭا ۚ وَإِذَا ذَكَرْتَ رَبَّكَ فِى ٱلْقُرْءَانِ وَحْدَهُۥ وَلَّوْا۟ عَلَىٰٓ أَدْبَٰرِهِمْ نُفُورًۭا","translation":"for, over their hearts We have laid veils which prevent them from grasping its purport, and into their ears, deafness. And so, whenever thou dost mention, while reciting the Qur'an, thy Sustainer as the one and only Divine Being, they turn their backs [upon thee] in aversion.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2075.mp3","surahId":17,"words":[{"id":45695,"position":1,"arabic":"وَجَعَلْنَا","translation":"এবং আমরা রেখে দিই","audioUrl":"wbw/017_046_001.mp3","charTypeName":"word"},{"id":45696,"position":2,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/017_046_002.mp3","charTypeName":"word"},{"id":45697,"position":3,"arabic":"قُلُوبِهِمْ","translation":"অন্তরসমূহের তাদের","audioUrl":"wbw/017_046_003.mp3","charTypeName":"word"},{"id":45698,"position":4,"arabic":"أَكِنَّةً","translation":"আবরণ","audioUrl":"wbw/017_046_004.mp3","charTypeName":"word"},{"id":45699,"position":5,"arabic":"أَن","translation":"যে (না)","audioUrl":"wbw/017_046_005.mp3","charTypeName":"word"},{"id":45700,"position":6,"arabic":"يَفْقَهُوهُ","translation":"তা তারা বুঝে","audioUrl":"wbw/017_046_006.mp3","charTypeName":"word"},{"id":45701,"position":7,"arabic":"وَفِىٓ","translation":"এবং মধ্যে আছে","audioUrl":"wbw/017_046_007.mp3","charTypeName":"word"},{"id":45702,"position":8,"arabic":"ءَاذَانِهِمْ","translation":"কানগুলোর তাদের","audioUrl":"wbw/017_046_008.mp3","charTypeName":"word"},{"id":45703,"position":9,"arabic":"وَقْرًۭا ۚ","translation":"বধিরতা","audioUrl":"wbw/017_046_009.mp3","charTypeName":"word"},{"id":45705,"position":10,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/017_046_011.mp3","charTypeName":"word"},{"id":45706,"position":11,"arabic":"ذَكَرْتَ","translation":"তুমি উল্লেখ করো","audioUrl":"wbw/017_046_012.mp3","charTypeName":"word"},{"id":45707,"position":12,"arabic":"رَبَّكَ","translation":"তোমার রবকে","audioUrl":"wbw/017_046_013.mp3","charTypeName":"word"},{"id":45708,"position":13,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/017_046_014.mp3","charTypeName":"word"},{"id":45709,"position":14,"arabic":"ٱلْقُرْءَانِ","translation":"কুরআনের","audioUrl":"wbw/017_046_015.mp3","charTypeName":"word"},{"id":45710,"position":15,"arabic":"وَحْدَهُۥ","translation":"তাঁর একত্ত্বতা","audioUrl":"wbw/017_0