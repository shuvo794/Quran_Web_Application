{"id":286,"ayahs":[{"number":39,"arabic":"ذَٰلِكَ مِمَّآ أَوْحَىٰٓ إِلَيْكَ رَبُّكَ مِنَ ٱلْحِكْمَةِ ۗ وَلَا تَجْعَلْ مَعَ ٱللَّهِ إِلَٰهًا ءَاخَرَ فَتُلْقَىٰ فِى جَهَنَّمَ مَلُومًۭا مَّدْحُورًا","translation":"this is part of that knowledge of right and wrong with which thy Sustainer has inspired thee. Hence, do not set up any other deity side by side with God, lest thou be cast into hell, blamed [by thyself] and rejected [by Him]!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2068.mp3","surahId":17,"words":[{"id":40319,"position":1,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/017_039_001.mp3","charTypeName":"word"},{"id":40320,"position":2,"arabic":"مِمَّآ","translation":"থেকে ঐ বিষয় যা","audioUrl":"wbw/017_039_002.mp3","charTypeName":"word"},{"id":40321,"position":3,"arabic":"أَوْحَىٰٓ","translation":"ওহী করেছেন","audioUrl":"wbw/017_039_003.mp3","charTypeName":"word"},{"id":40322,"position":4,"arabic":"إِلَيْكَ","translation":"তোমার প্রতি","audioUrl":"wbw/017_039_004.mp3","charTypeName":"word"},{"id":40323,"position":5,"arabic":"رَبُّكَ","translation":"তোমার রব","audioUrl":"wbw/017_039_005.mp3","charTypeName":"word"},{"id":40324,"position":6,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/017_039_006.mp3","charTypeName":"word"},{"id":40325,"position":7,"arabic":"ٱلْحِكْمَةِ ۗ","translation":"প্রজ্ঞার","audioUrl":"wbw/017_039_007.mp3","charTypeName":"word"},{"id":40327,"position":8,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/017_039_009.mp3","charTypeName":"word"},{"id":40328,"position":9,"arabic":"تَجْعَلْ","translation":"বানিও","audioUrl":"wbw/017_039_010.mp3","charTypeName":"word"},{"id":40329,"position":10,"arabic":"مَعَ","translation":"সাথে","audioUrl":"wbw/017_039_011.mp3","charTypeName":"word"},{"id":40330,"position":11,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/017_039_012.mp3","charTypeName":"word"},{"id":40331,"position":12,"arabic":"إِلَـٰهًا","translation":"ইলাহ","audioUrl":"wbw/017_039_013.mp3","charTypeName":"word"},{"id":40332,"position":13,"arabic":"ءَاخَرَ","translation":"অন্য (কাউকে)","audioUrl":"wbw/017_039_014.mp3","charTypeName":"word"},{"id":40333,"position":14,"arabic":"فَتُلْقَىٰ","translation":"তাহ'লে নিক্ষিপ্ত হবে","audioUrl":"wbw/017_039_015.mp3","charTypeName":"word"},{"id":40334,"position":15,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/017_039_016.mp3","charTypeName":"word"},{"id":40335,"position":16,"arabic":"جَهَنَّمَ","translation":"জাহান্নামের","audioUrl":"wbw/017_039_017.mp3","charTypeName":"word"},{"id":40336,"position":17,"arabic":"مَلُومًۭا","translation":"নিন্দিত অবস্হায়","audioUrl":"wbw/017_039_018.mp3","charTypeName":"word"},{"id":40337,"position":18,"arabic":"مَّدْحُورًا","translation":"(অনুগ্রহ থেকে) বিতাড়িত হয়ে","audioUrl":"wbw/017_039_019.mp3","charTypeName":"word"},{"id":40338,"position":19,"arabic":"٣٩","translation":"(৩৯)","audioUrl":null,"charTypeName":"end"}]},{"number":40,"arabic":"أَفَأَصْفَىٰكُمْ رَبُّكُم بِٱلْبَنِينَ وَٱتَّخَذَ مِنَ ٱلْمَلَٰٓئِكَةِ إِنَٰثًا ۚ إِنَّكُمْ لَتَقُولُونَ قَوْلًا عَظِيمًۭا","translation":"HAS, THEN, your Sustainer distinguished you by [giving you] sons, and taken unto Himself daughters in the guise of angels? Verily, you are uttering a dreadful saying!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2069.mp3","surahId":17,"words":[{"id":41060,"position":1,"arabic":"أَفَأَصْفَىٰكُمْ","translation":"তবে কি ধন্য করেছেন তোমাদেরকে","audioUrl":"wbw/017_040_001.mp3","charTypeName":"word"},{"id":41061,"position":2,"arabic":"رَبُّكُم","translation":"রব তোমাদের","audioUrl":"wbw/017_040_002.mp3","charTypeName":"word"},{"id":41062,"position":3,"arabic":"بِٱلْبَنِينَ","translation":"দিয়ে পুত্র সন্তানদের","audioUrl":"wbw/017_040_003.mp3","charTypeName":"word"},{"id":41063,"position":4,"arabic":"وَٱتَّخَذَ","translation":"অথচ তিনি গ্রহণ করেছেন","audioUrl":"wbw/017_040_004.mp3","charTypeName":"word"},{"id":41064,"position":5,"arabic":"مِنَ","translation":"থেকে","audi