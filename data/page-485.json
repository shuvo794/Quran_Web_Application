:"١٩","translation":"(১৯)","audioUrl":null,"charTypeName":"end"}]},{"number":20,"arabic":"مَن كَانَ يُرِيدُ حَرْثَ ٱلْءَاخِرَةِ نَزِدْ لَهُۥ فِى حَرْثِهِۦ ۖ وَمَن كَانَ يُرِيدُ حَرْثَ ٱلدُّنْيَا نُؤْتِهِۦ مِنْهَا وَمَا لَهُۥ فِى ٱلْءَاخِرَةِ مِن نَّصِيبٍ","translation":"To him who desires a harvest in the life to come, We shall grant an increase in his harvest; whereas to him who desires [but] a harvest in this world, We [may] give something thereof - but he will have no share in [the blessings of] the life to come.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4292.mp3","surahId":42,"words":[{"id":22345,"position":1,"arabic":"مَن","translation":"যে","audioUrl":"wbw/042_020_001.mp3","charTypeName":"word"},{"id":22346,"position":2,"arabic":"كَانَ","translation":"ছিল","audioUrl":"wbw/042_020_002.mp3","charTypeName":"word"},{"id":22347,"position":3,"arabic":"يُرِيدُ","translation":"কামনা করে","audioUrl":"wbw/042_020_003.mp3","charTypeName":"word"},{"id":22348,"position":4,"arabic":"حَرْثَ","translation":"ফসল","audioUrl":"wbw/042_020_004.mp3","charTypeName":"word"},{"id":22349,"position":5,"arabic":"ٱلْـَٔاخِرَةِ","translation":"পরকালের","audioUrl":"wbw/042_020_005.mp3","charTypeName":"word"},{"id":22350,"position":6,"arabic":"نَزِدْ","translation":"বাড়িয়ে দিই আমরা","audioUrl":"wbw/042_020_006.mp3","charTypeName":"word"},{"id":22351,"position":7,"arabic":"لَهُۥ","translation":"তার জন্যে","audioUrl":"wbw/042_020_007.mp3","charTypeName":"word"},{"id":22352,"position":8,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/042_020_008.mp3","charTypeName":"word"},{"id":22353,"position":9,"arabic":"حَرْثِهِۦ ۖ","translation":"তার ফসলের","audioUrl":"wbw/042_020_009.mp3","charTypeName":"word"},{"id":22355,"position":10,"arabic":"وَمَن","translation":"এবং যে","audioUrl":"wbw/042_020_011.mp3","charTypeName":"word"},{"id":22356,"position":11,"arabic":"كَانَ","translation":"ছিল","audioUrl":"wbw/042_020_012.mp3","charTypeName":"word"},{"id":22357,"position":12,"arabic":"يُرِيدُ","translation":"কামনা করে","audioUrl":"wbw/042_020_013.mp3","charTypeName":"word"},{"id":22358,"position":13,"arabic":"حَرْثَ","translation":"ফসল","audioUrl":"wbw/042_020_014.mp3","charTypeName":"word"},{"id":22359,"position":14,"arabic":"ٱلدُّنْيَا","translation":"দুনিয়ার","audioUrl":"wbw/042_020_015.mp3","charTypeName":"word"},{"id":22360,"position":15,"arabic":"نُؤْتِهِۦ","translation":"তাকে দিই আমরা","audioUrl":"wbw/042_020_016.mp3","charTypeName":"word"},{"id":22361,"position":16,"arabic":"مِنْهَا","translation":"তা থেকে কিছু","audioUrl":"wbw/042_020_017.mp3","charTypeName":"word"},{"id":22362,"position":17,"arabic":"وَمَا","translation":"এবং নেই","audioUrl":"wbw/042_020_018.mp3","charTypeName":"word"},{"id":22363,"position":18,"arabic":"لَهُۥ","translation":"তার জন্যে","audioUrl":"wbw/042_020_019.mp3","charTypeName":"word"},{"id":22364,"position":19,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/042_020_020.mp3","charTypeName":"word"},{"id":22365,"position":20,"arabic":"ٱلْـَٔاخِرَةِ","translation":"পরকালের","audioUrl":"wbw/042_020_021.mp3","charTypeName":"word"},{"id":22366,"position":21,"arabic":"مِن","translation":"কোনো","audioUrl":"wbw/042_020_022.mp3","charTypeName":"word"},{"id":22367,"position":22,"arabic":"نَّصِيبٍ","translation":"অংশ","audioUrl":"wbw/042_020_023.mp3","charTypeName":"word"},{"id":22368,"position":23,"arabic":"٢٠","translation":"(২০)","audioUrl":null,"charTypeName":"end"}]},{"number":21,"arabic":"أَمْ لَهُمْ شُرَكَٰٓؤُا۟ شَرَعُوا۟ لَهُم مِّنَ ٱلدِّينِ مَا لَمْ يَأْذَنۢ بِهِ ٱللَّهُ ۚ وَلَوْلَا كَلِمَةُ ٱلْفَصْلِ لَقُضِىَ بَيْنَهُمْ ۗ وَإِنَّ ٱلظَّٰلِمِينَ لَهُمْ عَذَابٌ أَلِيمٌۭ","translation":"Is it that they [who care for no more than this world] believe in forces supposed to have a share in God’s divinity, which enjoin upon them as a moral law something that God has never allowed? Now were it not for [God’s] decree on the final judgment, all would indeed have been decided be­tween them [in this world]: but, verily, grievous suffering awaits the evildoers [in the life to come].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4293.mp3","surahId":42,"words":[{"id":23463,"position":1,"arabic":"أَمْ","translation":"তবে কি","audioUrl":"wbw/042_021_001.mp3","charTypeName":"word"},{"id":23464,"position":2,"arabic":"لَهُمْ","translation":"তাদের জন্যে আছে","audioUrl":"wbw/042_021_002.mp3","charTypeName":"word"},{"id":23465,"position":3,"arabic":"شُرَكَـٰٓؤُا۟","translation":"(কতক) শরিক","audioUrl":"wbw/042_021_003.mp3","charTypeName":"word"},{"id":23466,"position":4,"arabic":"شَرَعُوا۟","translation":"(যারা) বিধান দিয়েছে","audioUrl":"wbw/042_021_004.mp3","charTypeName":"word"},{"id":23467,"position":5,"arabic":"لَهُم","translation":"তাদের জন্যে (ভিন্ন কিছু)","audioUrl":"wbw/042_021_005.mp3","charTypeName":"word"},{"id":23468,"position":6,"arabic":"مِّنَ","translation":"থেকে","audioUrl":"wbw/042_021_006.mp3","charTypeName":"word"},{"id":23469,"position":7,"arabic":"ٱلدِّينِ","translation":"ধর্মের","audioUrl":"wbw/042_021_007.mp3","charTypeName":"word"},{"id":23470,"position":8,"arabic":"مَا","translation":"যার","audioUrl":"wbw/042_021_008.mp3","charTypeName":"word"},{"id":23471,"position":9,"arabic":"لَمْ","translation":"না","audioUrl":"wbw/042_021_009.mp3","charTypeName":"word"},{"id":23472,"position":10,"arabic":"يَأْذَنۢ","translation":"অনুমতি দেন নি","audioUrl":"wbw/042_021_010.mp3","charTypeName":"word"},{"id":23473,"position":11,"arabic":"بِهِ","translation":"সে সম্পর্কে","audioUrl":"wbw/042_021_011.mp3","charTypeName":"word"},{"id":23474,"position":12,"arabic":"ٱللَّهُ ۚ","translation":"আল্লাহ","audioUrl":"wbw/042_021_012.mp3","charTypeName":"word"},{"id":23476,"position":13,"arabic":"وَلَوْلَا","translation":"এবং যদি না (নির্ধারিত হতো)","audioUrl":"wbw/042_021_014.mp3","charTypeName":"word"},{"id":23477,"position":14,"arabic":"كَلِمَةُ","translation":"একটি কথা","audioUrl":"wbw/042_021_015.mp3","charTypeName":"word"},{"id":23478,"position":15,"arabic":"ٱلْفَص