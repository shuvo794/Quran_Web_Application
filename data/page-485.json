"word"},{"id":24492,"position":2,"arabic":"ٱلظَّـٰلِمِينَ","translation":"সীমালঙ্ঘনকারীদেরকে","audioUrl":"wbw/042_022_002.mp3","charTypeName":"word"},{"id":24493,"position":3,"arabic":"مُشْفِقِينَ","translation":"ভীত অবস্থায়","audioUrl":"wbw/042_022_003.mp3","charTypeName":"word"},{"id":24494,"position":4,"arabic":"مِمَّا","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/042_022_004.mp3","charTypeName":"word"},{"id":24495,"position":5,"arabic":"كَسَبُوا۟","translation":"তারা কামাই করেছে","audioUrl":"wbw/042_022_005.mp3","charTypeName":"word"},{"id":24496,"position":6,"arabic":"وَهُوَ","translation":"এবং তা","audioUrl":"wbw/042_022_006.mp3","charTypeName":"word"},{"id":24497,"position":7,"arabic":"وَاقِعٌۢ","translation":"পতিত হবেই","audioUrl":"wbw/042_022_007.mp3","charTypeName":"word"},{"id":24498,"position":8,"arabic":"بِهِمْ ۗ","translation":"তাদের উপর","audioUrl":"wbw/042_022_008.mp3","charTypeName":"word"},{"id":24500,"position":9,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/042_022_010.mp3","charTypeName":"word"},{"id":24501,"position":10,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/042_022_011.mp3","charTypeName":"word"},{"id":24502,"position":11,"arabic":"وَعَمِلُوا۟","translation":"ও কাজ করেছে","audioUrl":"wbw/042_022_012.mp3","charTypeName":"word"},{"id":24503,"position":12,"arabic":"ٱلصَّـٰلِحَـٰتِ","translation":"সৎ","audioUrl":"wbw/042_022_013.mp3","charTypeName":"word"},{"id":24504,"position":13,"arabic":"فِى","translation":"মধ্যে (হবে)","audioUrl":"wbw/042_022_014.mp3","charTypeName":"word"},{"id":24505,"position":14,"arabic":"رَوْضَاتِ","translation":"বাগানসমূহের","audioUrl":"wbw/042_022_015.mp3","charTypeName":"word"},{"id":24506,"position":15,"arabic":"ٱلْجَنَّاتِ ۖ","translation":"জান্নাতের","audioUrl":"wbw/042_022_016.mp3","charTypeName":"word"},{"id":24508,"position":16,"arabic":"لَهُم","translation":"তাদের জন্যে রয়েছে","audioUrl":"wbw/042_022_018.mp3","charTypeName":"word"},{"id":24509,"position":17,"arabic":