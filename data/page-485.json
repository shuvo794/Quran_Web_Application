{"id":485,"ayahs":[{"number":16,"arabic":"وَٱلَّذِينَ يُحَآجُّونَ فِى ٱللَّهِ مِنۢ بَعْدِ مَا ٱسْتُجِيبَ لَهُۥ حُجَّتُهُمْ دَاحِضَةٌ عِندَ رَبِّهِمْ وَعَلَيْهِمْ غَضَبٌۭ وَلَهُمْ عَذَابٌۭ شَدِيدٌ","translation":"And as for those who would [still] argue about God after He has been acknowledged [by them] all their arguments are null and void in their Sustainer’s sight, and upon them will fall [His] condemnation, and for them is suffering severe in store:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4288.mp3","surahId":42,"words":[{"id":18059,"position":1,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/042_016_001.mp3","charTypeName":"word"},{"id":18060,"position":2,"arabic":"يُحَآجُّونَ","translation":"বিতর্ক করে","audioUrl":"wbw/042_016_002.mp3","charTypeName":"word"},{"id":18061,"position":3,"arabic":"فِى","translation":"সম্পর্কে","audioUrl":"wbw/042_016_003.mp3","charTypeName":"word"},{"id":18062,"position":4,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌র দ্বীনের","audioUrl":"wbw/042_016_004.mp3","charTypeName":"word"},{"id":18063,"position":5,"arabic":"مِنۢ","translation":"মধ্য হতে","audioUrl":"wbw/042_016_005.mp3","charTypeName":"word"},{"id":18064,"position":6,"arabic":"بَعْدِ","translation":"পরেও","audioUrl":"wbw/042_016_006.mp3","charTypeName":"word"},{"id":18065,"position":7,"arabic":"مَا","translation":"যা","audioUrl":"wbw/042_016_007.mp3","charTypeName":"word"},{"id":18066,"position":8,"arabic":"ٱسْتُجِيبَ","translation":"সাড়া দেওয়া হয়েছে (অর্থাৎ দ্বীন গ্রহণের পরেও)","audioUrl":"wbw/042_016_008.mp3","charTypeName":"word"},{"id":18067,"position":9,"arabic":"لَهُۥ","translation":"তাকে","audioUrl":"wbw/042_016_009.mp3","charTypeName":"word"},{"id":18068,"position":10,"arabic":"حُجَّتُهُمْ","translation":"তাদের যুক্তিতর্ক","audioUrl":"wbw/042_016_010.mp3","charTypeName":"word"},{"id":18069,"position":11,"arabic":"دَاحِضَةٌ","translation":"নিরর্থক","audioUrl":"wbw/042_016_011.mp3","charTypeName":"word"},{"id":18070,"position":12,"arabic":"عِندَ","translation":"কাছে","audioUrl":"wbw/042_016_012.mp3","charTypeName":"word"},{"id":18071,"position":13,"arabic":"رَبِّهِمْ","translation":"তাদের রবের","audioUrl":"wbw/042_016_013.mp3","charTypeName":"word"},{"id":18072,"position":14,"arabic":"وَعَلَيْهِمْ","translation":"এবং তাদের উপর","audioUrl":"wbw/042_016_014.mp3","charTypeName":"word"},{"id":18073,"position":15,"arabic":"غَضَبٌۭ","translation":"অভিসম্পাত","audioUrl":"wbw/042_016_015.mp3","charTypeName":"word"},{"id":18074,"position":16,"arabic":"وَلَهُمْ","translation":"এবং তাদের জন্যে","audioUrl":"wbw/042_016_016.mp3","charTypeName":"word"},{"id":18075,"position":17,"arabic":"عَذَابٌۭ","translation":"শাস্তি (রয়েছে)","audioUrl":"wbw/042_016_017.mp3","charTypeName":"word"},{"id":18076,"position":18,"arabic":"شَدِيدٌ","translation":"কঠিন","audioUrl":"wbw/042_016_018.mp3","charTypeName":"word"},{"id":18077,"position":19,"arabic":"١٦","translation":"(১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":17,"arabic":"ٱللَّهُ ٱلَّذِىٓ أَنزَلَ ٱلْكِتَٰبَ بِٱلْحَقِّ وَٱلْمِيزَانَ ۗ وَمَا يُدْرِيكَ لَعَلَّ ٱلسَّاعَةَ قَرِيبٌۭ","translation":"[for] it is God [Himself] who has bestowed revelation from on high, setting forth the truth, and [thus given man] a balance [wherewith to weigh right and wrong]. And for all thou knowest, the Last Hour may well be near!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4289.mp3","surahId":42,"words":[{"id":19066,"position":1,"arabic":"ٱللَّهُ","translation":"(তিনিই) আল্লাহ্‌","audioUrl":"wbw/042_017_001.mp3","charTypeName":"word"},{"id":19067,"position":2,"arabic":"ٱلَّذِىٓ","translation":"যিনি","audioUrl":"wbw/042_017_002.mp3","charTypeName":"word"},{"id":19068,"position":3,"arabic":"أَنزَلَ","translation":"অবতীর্ণ করেছেন","audioUrl":"wbw/042_017_003.mp3","charTypeName":"word"},{"id":19069,"position":4,"arabic":"ٱلْكِتَـٰبَ","translation":"কিতাব","audioUrl":"wbw/042_017_004.mp3","charTypeName":"word"},{"id":19070,"position":5,"arabic":"بِٱلْحَ