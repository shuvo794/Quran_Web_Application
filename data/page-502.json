{"id":502,"ayahs":[{"number":33,"arabic":"وَبَدَا لَهُمْ سَيِّـَٔاتُ مَا عَمِلُوا۟ وَحَاقَ بِهِم مَّا كَانُوا۟ بِهِۦ يَسْتَهْزِءُونَ","translation":"And [on that Day,] the evil of their doings will become obvious to them, and they will be over­whelmed by the very thing which they were wont to deride.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4506.mp3","surahId":45,"words":[{"id":35362,"position":1,"arabic":"وَبَدَا","translation":"এবং প্রকাশ হবে","audioUrl":"wbw/045_033_001.mp3","charTypeName":"word"},{"id":35363,"position":2,"arabic":"لَهُمْ","translation":"তাদের কাছে","audioUrl":"wbw/045_033_002.mp3","charTypeName":"word"},{"id":35364,"position":3,"arabic":"سَيِّـَٔاتُ","translation":"মন্দ কাজগুলো","audioUrl":"wbw/045_033_003.mp3","charTypeName":"word"},{"id":35365,"position":4,"arabic":"مَا","translation":"যা কিছু","audioUrl":"wbw/045_033_004.mp3","charTypeName":"word"},{"id":35366,"position":5,"arabic":"عَمِلُوا۟","translation":"তারা করেছিলো","audioUrl":"wbw/045_033_005.mp3","charTypeName":"word"},{"id":35367,"position":6,"arabic":"وَحَاقَ","translation":"এবং ঘিরে ফেলবে","audioUrl":"wbw/045_033_006.mp3","charTypeName":"word"},{"id":35368,"position":7,"arabic":"بِهِم","translation":"তাদেরকে","audioUrl":"wbw/045_033_007.mp3","charTypeName":"word"},{"id":35369,"position":8,"arabic":"مَّا","translation":"যা","audioUrl":"wbw/045_033_008.mp3","charTypeName":"word"},{"id":35370,"position":9,"arabic":"كَانُوا۟","translation":"তারা ছিল","audioUrl":"wbw/045_033_009.mp3","charTypeName":"word"},{"id":35371,"position":10,"arabic":"بِهِۦ","translation":"সে সম্বন্ধে","audioUrl":"wbw/045_033_010.mp3","charTypeName":"word"},{"id":35372,"position":11,"arabic":"يَسْتَهْزِءُونَ","translation":"বিদ্রুপ করত","audioUrl":"wbw/045_033_011.mp3","charTypeName":"word"},{"id":35373,"position":12,"arabic":"٣٣","translation":"(৩৩)","audioUrl":null,"charTypeName":"end"}]},{"number":34,"arabic":"وَقِيلَ ٱلْيَوْمَ نَنسَىٰكُمْ كَمَا نَسِيتُمْ لِقَآءَ يَوْمِكُمْ هَٰذَا وَمَأْوَىٰكُمُ ٱلنَّارُ وَمَا لَكُم مِّن نَّٰصِرِينَ","translation":"And [the word] will be spoken: “Today We shall be oblivious of you as you were oblivious of the coming of this your Day [of Judgment]; and so your goal is the fire, and you shall have none to succour you:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4507.mp3","surahId":45,"words":[{"id":36252,"position":1,"arabic":"وَقِيلَ","translation":"এবং বলা হবে","audioUrl":"wbw/045_034_001.mp3","charTypeName":"word"},{"id":36253,"position":2,"arabic":"ٱلْيَوْمَ","translation":"\"আজ","audioUrl":"wbw/045_034_002.mp3","charTypeName":"word"},{"id":36254,"position":3,"arabic":"نَنسَىٰكُمْ","translation":"তোমাদেরকে ভুলে যাব আমরা","audioUrl":"wbw/045_034_003.mp3","charTypeName":"word"},{"id":36255,"position":4,"arabic":"كَمَا","translation":"যেমন","audioUrl":"wbw/045_034_004.mp3","charTypeName":"word"},{"id":36256,"position":5,"arabic":"نَسِيتُمْ","translation":"তোমরা ভুলে গিয়েছিলে","audioUrl":"wbw/045_034_005.mp3","charTypeName":"word"},{"id":36257,"position":6,"arabic":"لِقَآءَ","translation":"সাক্ষাতকে","audioUrl":"wbw/045_034_006.mp3","charTypeName":"word"},{"id":36258,"position":7,"arabic":"يَوْمِكُمْ","translation":"তোমাদের দিনের","audioUrl":"wbw/045_034_007.mp3","charTypeName":"word"},{"id":36259,"position":8,"arabic":"هَـٰذَا","translation":"এই","audioUrl":"wbw/045_034_008.mp3","charTypeName":"word"},{"id":36260,"position":9,"arabic":"وَمَأْوَىٰكُمُ","translation":"এবং তোমাদের আশ্রয়স্থল","audioUrl":"wbw/045_034_009.mp3","charTypeName":"word"},{"id":36261,"position":10,"arabic":"ٱلنَّارُ","translation":"আগুন","audioUrl":"wbw/045_034_010.mp3","charTypeName":"word"},{"id":36262,"position":11,"arabic":"وَمَا","translation":"এবং নেই","audioUrl":"wbw/045_034_011.mp3","charTypeName":"word"},{"id":36263,"position":12,"arabic":"لَكُم","translation":"তোমাদের জন্য","audioUrl":"wbw/045_034_012.mp3","charTypeName":"word"},{"id":36264,"position":13,"arabic":"مِّن","translation":"কেউ","audioUrl":"wbw/045_034_013.mp3","charTypeName":"word"},{"id":36265,"position":14,"arabic":"نَّـٰصِرِينَ","translation":"সাহায্যকারীদের","audioUrl":"wbw/045_034_014.mp3","charTypeName":"word"},{"id":36266,"position":15,"arabic":"٣٤","translation":"(৩৪)","audioUrl":null,"charTypeName":"end"}]},{"number":35,"arabic":"ذَٰلِكُم بِأَنَّكُمُ ٱتَّخَذْتُمْ ءَايَٰتِ ٱللَّهِ هُزُوًۭا وَغَرَّتْكُمُ ٱلْحَيَوٰةُ ٱلدُّنْيَا ۚ فَٱلْيَوْمَ لَا يُخْرَجُونَ مِنْهَا وَلَا هُمْ يُسْتَعْتَبُونَ","translation":"this, because you made God’s messages the target of your mockery, having allowed the life of this world to beguile you!” On that Day, therefore, they will not be brought out of the fire, nor will they be allowed to make amends.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4508.mp3","surahId":45,"words":[{"id":37046,"position":1,"arabic":"ذَٰلِكُم","translation":"এটা তোমাদের","audioUrl":"wbw/045_035_001.mp3","charTypeName":"word"},{"id":37047,"position":2,"arabic":"بِأَنَّكُمُ","translation":"এ কারণে যে","audioUrl":"wbw/045_035_002.mp3","charTypeName":"word"},{"id":37048,"position":3,"arabic":"ٱتَّخَذْتُمْ","translation":"তোমরা গ্রহণ করেছিলে","audioUrl":"wbw/045_035_003.mp3","charTypeName":"word"},{"id":37049,"position":4,"arabic":"ءَايَـٰتِ","translation":"নিদর্শনাবলীকে","audioUrl":"wbw/045_035_004.mp3","charTypeName":"word"},{"id":37050,"position":5,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/045_035_005.mp3","charTypeName":"word"},{"id":37051,"position":6,"arabic":"هُزُوًۭا","translation":"বিদ্রুপরূপে","audioUrl":"wbw/045_035_006.mp3","charTypeName":"word"},{"id":37052,"position":7,"arabic":"وَغَرَّتْكُمُ","translation":"ও তোমাদেরকে ধোঁকা দিয়েছিল","audioUrl":"wbw/045_035_007.mp3","charTypeName":"word"},{"id":37053,"position":8,"arabic":"ٱلْحَيَوٰةُ","translation":"জীবন","audioUrl":"wbw/045_035_008.mp3","charTypeName":"word"},{"id":37054,"position":9,"arabic":"ٱلدُّنْيَا ۚ","translation":"পার্থিব\"","audioUrl":"wbw/045_035_009.mp3","charTypeName":"word"},{"id":37056,"position":10,"arabic":"فَٱلْيَوْمَ","translation":"সুতরাং আজ","audioUrl":"wbw/045_035_011.mp3","charTypeName":"word"},{"id":37057,"position":11,"arabic":"لَا","translation":"না","audioUrl":"wbw/045_035_012.mp3","charTypeName":"word"},{"id":37058,"position":12,"arabic":"يُخْرَجُونَ","translation":"তাদের বের করা হবে","audioUrl":"wbw/045_035_013.mp3","charTypeName":"word"},{"id":37059,"position":13,"arabic":"مِنْهَا","translation":"তা থেকে","audioUrl":"wbw/045_035_014.mp3","charTypeName":"word"},{"id":37060,"position":14,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/045_035_015.mp3","charTypeName":"word"},{"id":37061,"position":15,"arabic":"هُمْ","translation":"তাদেরকে","audioUrl":"wbw/045_035_016.mp3","charTypeName":"word"},{"id":37062,"position":16,"arabic":"يُسْتَعْتَبُونَ","translation":"সন্তুষ্টি লাভের সুযোগ দেওয়া হবে","audioUrl":"wbw/045_035_017.mp3","charTypeName":"word"},{"id":37063,"position":17,"arabic":"٣٥","translation":"(৩৫)","audioUrl":null,"charTypeName":"end"}]},{"number":36,"arabic":"فَلِلَّهِ ٱلْحَمْدُ رَبِّ ٱلسَّمَٰوَٰتِ وَرَبِّ ٱلْأَرْضِ رَبِّ ٱلْعَٰلَمِينَ","translation":"AND THUS, all praise is due to God, Sustainer of the heavens and Sustainer of the earth: the Sustainer of all the worlds!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4509.mp3","surahId":45,"words":[{"id":37888,"position":1,"arabic":"فَلِلَّهِ","translation":"সুতরাং আল্লাহর জন্যে","audioUrl":"wbw/045_036_001.mp3","charTypeName":"word"},{"id":37889,"position":2,"arabic":"ٱلْحَمْدُ","translation":"সকল প্রশংসা","audioUrl":"wbw/045_036_002.mp3","charTypeName":"word"},{"id":37890,"position":3,"arabic":"رَبِّ","translation":"(যিনি) রব","audioUrl":"wbw/045_036_003.mp3","charTypeName":"word"},{"id":37891,"position":4,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশের","audioUrl":"wbw/045_036_004.mp3","charTypeName":"word"},{"id":37892,"position":5,"arabic":"وَرَبِّ","translation":"ও রব","audioUrl":"wbw/045_036_005.mp3","charTypeName":"word"},{"id":37893,"position":6,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/045_036_006.mp3","charTypeName":"word"},{"id":37894,"position":7,"arabic":"رَبِّ","translation":"রব","audioUrl":"wbw/045_036_007.mp3","charTypeName":"word"},{"id":37895,"position":8,"arabic":"ٱلْعَـٰلَمِينَ","translation":"বিশ্বজগতের","audioUrl":"wbw/045_036_008.mp3","charTypeName":"word"},{"id":37896,"position":9,"arabic":"٣٦","translation":"(৩৬)","audioUrl":null,"charTypeName":"end"}]},{"number":37,"arabic":"وَلَهُ ٱلْكِبْرِيَآءُ فِى ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ ۖ وَهُوَ ٱلْعَزِيزُ ٱلْحَكِيمُ","translation":"And His alone is all majesty in the heavens and on earth; and He alone is almighty, truly wise!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4510.mp3","surahId":45,"words":[{"id":38727,"position":1,"arabic":"وَلَهُ","translation":"এবং তাঁরই জন্যে","audioUrl":"wbw/045_037_001.mp3","charTypeName":"word"},{"id":38728,"position":2,"arabic":"ٱلْكِبْرِيَآءُ","translation":"গৌরব-গরিমা","audioUrl":"wbw/045_037_002.mp3","charTypeName":"word"},{"id":38729,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/045_037_003.mp3","charTypeName":"word"},{"id":38730,"position":4,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশের","audioUrl":"wbw/045_037_004.mp3","charTypeName":"word"},{"id":38731,"position":5,"arabic":"وَٱلْأَرْضِ ۖ","translation":"এবং পৃথিবীর","audioUrl":"wbw/045_037_005.mp3","charTypeName":"word"},{"id":38733,"position":6,"arabic":"وَهُوَ","translation":"এবং তিনিই","audioUrl":"wbw/045_037_007.mp3","charTypeName":"word"},{"id":38734,"position":7,"arabic":"ٱلْعَزِيزُ","translation":"পরাক্রমশালী","audioUrl":"wbw/045_037_008.mp3","charTypeName":"word"},{"id":38735,"position":8,"arabic":"ٱلْحَكِيمُ","translation":"প্রজ্ঞাময়","audioUrl":"wbw/045_037_009.mp3","charTypeName":"word"},{"id":38736,"position":9,"arabic":"٣٧","translation":"(৩৭)","audioUrl":null,"charTypeName":"end"}]},{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ حمٓ","translation":"Ha. Mim.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4511.mp3","surahId":46,"words":[{"id":175,"position":1,"arabic":"حمٓ","translation":"হা-মীম","audioUrl":"wbw/046_001_001.mp3","charTypeName":"word"},{"id":176,"position":2,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"تَنزِيلُ ٱلْكِتَٰبِ مِنَ ٱللَّهِ ٱلْعَزِيزِ ٱلْحَكِيمِ","translation":"THE BESTOWAL from on high of this divine writ I issues from God, the Almighty, the Wise.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4512.mp3","surahId":46,"words":[{"id":1012,"position":1,"arabic":"تَنزِيلُ","translation":"অবতীর্ণ করা","audioUrl":"wbw/046_002_001.mp3","charTypeName":"word"},{"id":1013,"position":2,"arabic":"ٱلْكِتَـٰبِ","translation":"এই কিতাব","audioUrl":"wbw/046_002_002.mp3","charTypeName":"word"},{"id":1014,"position":3,"arabic":"مِنَ","translation":"পক্ষ হতে","audioUrl":"wbw/046_002_003.mp3","charTypeName":"word"},{"id":1015,"position":4,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/046_002_004.mp3","charTypeName":"word"},{"id":1016,"position":5,"arabic":"ٱلْعَزِيزِ","translation":"(যিনি) পরাক্রমশালী","audioUrl":"wbw/046_002_005.mp3","charTypeName":"word"},{"id":1017,"position":6,"arabic":"ٱلْحَكِيمِ","translation":"মহাবিজ্ঞ","audioUrl":"wbw/046_002_006.mp3","charTypeName":"word"},{"id":1018,"position":7,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"مَا خَلَقْنَا ٱلسَّمَٰوَٰتِ وَٱلْأَرْضَ وَمَا بَيْنَهُمَآ إِلَّا بِٱلْحَقِّ وَأَجَلٍۢ مُّسَمًّۭى ۚ وَٱلَّذِينَ كَفَرُوا۟ عَمَّآ أُنذِرُوا۟ مُعْرِضُونَ","translation":"We have not created the heavens and the earth and all that is between them otherwise than in accord­ance with [an inner] truth, and for a term set [by Us]: and yet, they who are bent on denying the truth turn aside from the warning which has been conveyed unto them.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4513.mp3","surahId":46,"words":[{"id":2104,"position":1,"arabic":"مَا","translation":"না","audioUrl":"wbw/046_003_001.mp3","charTypeName":"word"},{"id":2105,"position":2,"arabic":"خَلَقْنَا","translation":"আমরা সৃষ্টি করেছি","audioUrl":"wbw/046_003_002.mp3","charTypeName":"word"},{"id":2106,"position":3,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশ","audioUrl":"wbw/046_003_003.mp3","charTypeName":"word"},{"id":2107,"position":4,"arabic":"وَٱلْأَرْضَ","translation":"আর (না)পৃথিবীকে","audioUrl":"wbw/046_003_004.mp3","charTypeName":"word"},{"id":2108,"position":5,"arabic":"وَمَا","translation":"এবং যা কিছু (আছে)","audioUrl":"wbw/046_003_005.mp3","charTypeName":"word"},{"id":2109,"position":6,"arabic":"بَيْنَهُمَآ","translation":"উভয়ের মাঝে","audioUrl":"wbw/046_003_006.mp3","charTypeName":"word"},{"id":2110,"position":7,"arabic":"إِلَّا","translation":"ব্যতীত","audioUrl":"wbw/046_003_007.mp3","charTypeName":"word"},{"id":2111,"position":8,"arabic":"بِٱلْحَقِّ","translation":"যথাযথভাবে","audioUrl":"wbw/046_003_008.mp3","charTypeName":"word"},{"id":2112,"position":9,"arabic":"وَأَجَلٍۢ","translation":"এবং একটা সময়ের (জন্যে)","audioUrl":"wbw/046_003_009.mp3","charTypeName":"word"},{"id":2113,"position":10,"arabic":"مُّسَمًّۭى ۚ","translation":"সুনির্দিষ্ট","audioUrl":"wbw/046_003_010.mp3","charTypeName":"word"},{"id":2115,"position":11,"arabic":"وَٱلَّذِينَ","translation":"কিন্তু যারা","audioUrl":"wbw/046_003_012.mp3","charTypeName":"word"},{"id":2116,"position":12,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/046_003_013.mp3","charTypeName":"word"},{"id":2117,"position":13,"arabic":"عَمَّآ","translation":"সে সম্পর্কে যার","audioUrl":"wbw/046_003_014.mp3","charTypeName":"word"},{"id":2118,"position":14,"arabic":"أُنذِرُوا۟","translation":"তাদেরকে সতর্ক করা হয়েছে","audioUrl":"wbw/046_003_015.mp3","charTypeName":"word"},{"id":2119,"position":15,"arabic":"مُعْرِضُونَ","translation":"(তা হতে) তারা মুখ ফিরিয়ে নিয়েছে","audioUrl":"wbw/046_003_016.mp3","charTypeName":"word"},{"id":2120,"position":16,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"قُلْ أَرَءَيْتُم مَّا تَدْعُونَ مِن دُونِ ٱللَّهِ أَرُونِى مَاذَا خَلَقُوا۟ مِنَ ٱلْأَرْضِ أَمْ لَهُمْ شِرْكٌۭ فِى ٱلسَّمَٰوَٰتِ ۖ ٱئْتُونِى بِكِتَٰبٍۢ مِّن قَبْلِ هَٰذَآ أَوْ أَثَٰرَةٍۢ مِّنْ عِلْمٍ إِن كُنتُمْ صَٰدِقِينَ","translation":"Say: “Have you [really] given thought to what it is that you invoke instead of God? Show me what these [beings or forces] have created anywhere on earth! Or had they, perchance, a share in [creating] the heavens? [If so,] bring me any divine writ pre­ceding this one, or any [other] vestige of knowledge - if what you claim is true!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4514.mp3","surahId":46,"words":[{"id":3373,"position":1,"arabic":"قُلْ","translation":"(হে নাবী) বলো","audioUrl":"wbw/046_004_001.mp3","charTypeName":"word"},{"id":3374,"position":2,"arabic":"أَرَءَيْتُم","translation":"\"তোমরা কি (ভেবে) দেখেছ","audioUrl":"wbw/046_004_002.mp3","charTypeName":"word"},{"id":3375,"position":3,"arabic":"مَّا","translation":"যাদেরকে","audioUrl":"wbw/046_004_003.mp3","charTypeName":"word"},{"id":3376,"position":4,"arabic":"تَدْعُونَ","translation":"তোমরা ডাক","audioUrl":"wbw/046_004_004.mp3","charTypeName":"word"},{"id":3377,"position":5,"arabic":"مِن","translation":"মধ্য হতে","audioUrl":"wbw/046_004_005.mp3","charTypeName":"word"},{"id":3378,"position":6,"arabic":"دُونِ","translation":"ছাড়া","audioUrl":"wbw/046_004_006.mp3","charTypeName":"word"},{"id":3379,"position":7,"arabic":"ٱللَّهِ","translation":"আল্লাহকে (তারা কারা?)","audioUrl":"wbw/046_004_007.mp3","charTypeName":"word"},{"id":3380,"position":8,"arabic":"أَرُونِى","translation":"আমাকে দেখাও","audioUrl":"wbw/046_004_008.mp3","charTypeName":"word"},{"id":3381,"position":9,"arabic":"مَاذَا","translation":"কি","audioUrl":"wbw/046_004_009.mp3","charTypeName":"word"},{"id":3382,"position":10,"arabic":"خَلَقُوا۟","translation":"তারা সৃষ্টি