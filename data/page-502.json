":"জ্ঞান","audioUrl":"wbw/046_004_027.mp3","charTypeName":"word"},{"id":3400,"position":27,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/046_004_028.mp3","charTypeName":"word"},{"id":3401,"position":28,"arabic":"كُنتُمْ","translation":"তোমরা হও","audioUrl":"wbw/046_004_029.mp3","charTypeName":"word"},{"id":3402,"position":29,"arabic":"صَـٰدِقِينَ","translation":"সত্যবাদী\"","audioUrl":"wbw/046_004_030.mp3","charTypeName":"word"},{"id":3403,"position":30,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"وَمَنْ أَضَلُّ مِمَّن يَدْعُوا۟ مِن دُونِ ٱللَّهِ مَن لَّا يَسْتَجِيبُ لَهُۥٓ إِلَىٰ يَوْمِ ٱلْقِيَٰمَةِ وَهُمْ عَن دُعَآئِهِمْ غَٰفِلُونَ","translation":"And who could be more astray than one who invokes, instead of God, such as will not respond to him either now or on the Day of Resurrection, and are not even conscious of being invoked?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4515.mp3","surahId":46,"words":[{"id":4772,"position":1,"arabic":"وَمَنْ","translation":"এবং কে","audioUrl":"wbw/046_005_001.mp3","charTypeName":"word"},{"id":4773,"position":2,"arabic":"أَضَلُّ","translation":"অধিক বিভ্রান্ত (হতে পারে)","audioUrl":"wbw/046_005_002.mp3","charTypeName":"word"},{"id":4774,"position":3,"arabic":"مِمَّن","translation":"তার চেয়ে যে","audioUrl":"wbw/046_005_003.mp3","charTypeName":"word"},{"id":4775,"position":4,"arabic":"يَدْعُوا۟","translation":"ডাকে","audioUrl":"wbw/046_005_004.mp3","charTypeName":"word"},{"id":4776,"position":5,"arabic":"مِن","translation":"মধ্য হতে","audioUrl":"wbw/046_005_005.mp3","charTypeName":"word"},{"id":4777,"position":6,"arabic":"دُونِ","translation":"ছাড়া","audioUrl":"wbw/046_005_006.mp3","charTypeName":"word"},{"id":4778,"position":7,"arabic":"ٱللَّهِ","translation":"আল্লাহ","audioUrl":"wbw/046_005_007.mp3","charTypeName":"word"},{"id":4779,"position":8,"arabic":"مَن","translation":"(এমন সত্তাকে) যা","audioUrl":"wbw/046_005_008.mp3","charTypeName":"word"},{"i