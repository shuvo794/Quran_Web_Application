 [will show that He] has always been fully aware of them?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6157.mp3","surahId":100,"words":[{"id":12259,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/100_011_001.mp3","charTypeName":"word"},{"id":12260,"position":2,"arabic":"رَبَّهُم","translation":"তাদের রব","audioUrl":"wbw/100_011_002.mp3","charTypeName":"word"},{"id":12261,"position":3,"arabic":"بِهِمْ","translation":"তাদের সাথে","audioUrl":"wbw/100_011_003.mp3","charTypeName":"word"},{"id":12262,"position":4,"arabic":"يَوْمَئِذٍۢ","translation":"সেদিন","audioUrl":"wbw/100_011_004.mp3","charTypeName":"word"},{"id":12263,"position":5,"arabic":"لَّخَبِيرٌۢ","translation":"অবশ্যই তা ভালো করেই জানেন","audioUrl":"wbw/100_011_005.mp3","charTypeName":"word"},{"id":12264,"position":6,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]}]}