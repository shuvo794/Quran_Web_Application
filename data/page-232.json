","charTypeName":"word"},{"id":69922,"position":6,"arabic":"بُعْدًۭا","translation":"ধ্বংস হলো","audioUrl":"wbw/011_095_007.mp3","charTypeName":"word"},{"id":69923,"position":7,"arabic":"لِّمَدْيَنَ","translation":"জন্যে মাদয়ানবাসীদের","audioUrl":"wbw/011_095_008.mp3","charTypeName":"word"},{"id":69924,"position":8,"arabic":"كَمَا","translation":"যেমন","audioUrl":"wbw/011_095_009.mp3","charTypeName":"word"},{"id":69925,"position":9,"arabic":"بَعِدَتْ","translation":"ধ্বংস করা হয়েছিলো","audioUrl":"wbw/011_095_010.mp3","charTypeName":"word"},{"id":69926,"position":10,"arabic":"ثَمُودُ","translation":"সামূদ জাতিকে","audioUrl":"wbw/011_095_011.mp3","charTypeName":"word"},{"id":69927,"position":11,"arabic":"٩٥","translation":"(৯৫)","audioUrl":null,"charTypeName":"end"}]},{"number":96,"arabic":"وَلَقَدْ أَرْسَلْنَا مُوسَىٰ بِـَٔايَٰتِنَا وَسُلْطَٰنٍۢ مُّبِينٍ","translation":"AND, INDEED, We sent Moses with Our messages and a manifest authority [from Us]","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1569.mp3","surahId":11,"words":[{"id":70200,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/011_096_001.mp3","charTypeName":"word"},{"id":70201,"position":2,"arabic":"أَرْسَلْنَا","translation":"আমরা পাঠিয়েছিলাম","audioUrl":"wbw/011_096_002.mp3","charTypeName":"word"},{"id":70202,"position":3,"arabic":"مُوسَىٰ","translation":"মূসাকে","audioUrl":"wbw/011_096_003.mp3","charTypeName":"word"},{"id":70203,"position":4,"arabic":"بِـَٔايَـٰتِنَا","translation":"দিয়ে আমাদের নিদর্শনাবলী","audioUrl":"wbw/011_096_004.mp3","charTypeName":"word"},{"id":70204,"position":5,"arabic":"وَسُلْطَـٰنٍۢ","translation":"এবং প্রমাণ (দিয়ে)","audioUrl":"wbw/011_096_005.mp3","charTypeName":"word"},{"id":70205,"position":6,"arabic":"مُّبِينٍ","translation":"সুস্পষ্ট","audioUrl":"wbw/011_096_006.mp3","charTypeName":"word"},{"id":70206,"position":7,"arabic":"٩٦","translation":"(৯৬)","audioUrl":null,"charTypeName":"end"}]},{"number":97,"arabic":"إِلَىٰ فِرْعَوْ