mp3","charTypeName":"word"},{"id":68924,"position":11,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/011_092_012.mp3","charTypeName":"word"},{"id":68925,"position":12,"arabic":"رَبِّى","translation":"আমার রব","audioUrl":"wbw/011_092_013.mp3","charTypeName":"word"},{"id":68926,"position":13,"arabic":"بِمَا","translation":"সে সম্বন্ধে যা","audioUrl":"wbw/011_092_014.mp3","charTypeName":"word"},{"id":68927,"position":14,"arabic":"تَعْمَلُونَ","translation":"তোমরা করছো","audioUrl":"wbw/011_092_015.mp3","charTypeName":"word"},{"id":68928,"position":15,"arabic":"مُحِيطٌۭ","translation":"পরিবেষ্টন করে আছেন","audioUrl":"wbw/011_092_016.mp3","charTypeName":"word"},{"id":68929,"position":16,"arabic":"٩٢","translation":"(৯২)","audioUrl":null,"charTypeName":"end"}]},{"number":93,"arabic":"وَيَٰقَوْمِ ٱعْمَلُوا۟ عَلَىٰ مَكَانَتِكُمْ إِنِّى عَٰمِلٌۭ ۖ سَوْفَ تَعْلَمُونَ مَن يَأْتِيهِ عَذَابٌۭ يُخْزِيهِ وَمَنْ هُوَ كَٰذِبٌۭ ۖ وَٱرْتَقِبُوٓا۟ إِنِّى مَعَكُمْ رَقِيبٌۭ","translation":"Hence, O my people, do [to me] anything that may be within your power, [while] I, behold, shall labour [in God's way]; in time you will come to know which [of us] shall be visited by suffering that will cover him with ignominy, and which [of us] is a liar. Watch, then, [for what is coming:] behold, I shall watch with you!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1566.mp3","surahId":11,"words":[{"id":69244,"position":1,"arabic":"وَيَـٰقَوْمِ","translation":"এবং হে আমার জাতি","audioUrl":"wbw/011_093_001.mp3","charTypeName":"word"},{"id":69245,"position":2,"arabic":"ٱعْمَلُوا۟","translation":"তোমরা কাজ করো","audioUrl":"wbw/011_093_002.mp3","charTypeName":"word"},{"id":69246,"position":3,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/011_093_003.mp3","charTypeName":"word"},{"id":69247,"position":4,"arabic":"مَكَانَتِكُمْ","translation":"তোমাদের নিজ নিজ অবস্থানের","audioUrl":"wbw/011_093_004.mp3","charTypeName":"word"},{"id":69248,"position":5,"arabic":"إِنِّى","translation":"নিশ্চয়ই আমিও","audioUrl":"wbw/011_093_005.mp3","charTypeName":"word"},{"id":69249,"position":6,"arabic":"عَـٰمِلٌۭ ۖ","translation":"কাজ করছি (আমার অবস্থানে)","audioUrl":"wbw/011_093_006.mp3","charTypeName":"word"},{"id":69251,"position":7,"arabic":"سَوْفَ","translation":"শীঘ্রই","audioUrl":"wbw/011_093_008.mp3","charTypeName":"word"},{"id":69252,"position":8,"arabic":"تَعْلَمُونَ","translation":"তোমরা জানবে","audioUrl":"wbw/011_093_009.mp3","charTypeName":"word"},{"id":69253,"position":9,"arabic":"مَن","translation":"(যে) কে সেই","audioUrl":"wbw/011_093_010.mp3","charTypeName":"word"},{"id":69254,"position":10,"arabic":"يَأْتِيهِ","translation":"যার উপর আসবে","audioUrl":"wbw/011_093_011.mp3","charTypeName":"word"},{"id":69255,"position":11,"arabic":"عَذَابٌۭ","translation":"শাস্তি","audioUrl":"wbw/011_093_012.mp3","charTypeName":"word"},{"id":69256,"position":12,"arabic":"يُخْزِيهِ","translation":"তাকে লাঞ্ছিত করে ছাড়বে","audioUrl":"wbw/011_093_013.mp3","charTypeName":"word"},{"id":69257,"position":13,"arabic":"وَمَنْ","translation":"এবং কে","audioUrl":"wbw/011_093_014.mp3","charTypeName":"word"},{"id":69258,"position":14,"arabic":"هُوَ","translation":"সে","audioUrl":"wbw/011_093_015.mp3","charTypeName":"word"},{"id":69259,"position":15,"arabic":"كَـٰذِبٌۭ ۖ","translation":"মিথ্যাবাদী","audioUrl":"wbw/011_093_016.mp3","charTypeName":"word"},{"id":69261,"position":16,"arabic":"وَٱرْتَقِبُوٓا۟","translation":"এবং তোমরা প্রতীক্ষা করো","audioUrl":"wbw/011_093_018.mp3","charTypeName":"word"},{"id":69262,"position":17,"arabic":"إِنِّى","translation":"নিশ্চয়ই আমি","audioUrl":"wbw/011_093_019.mp3","charTypeName":"word"},{"id":69263,"position":18,"arabic":"مَعَكُمْ","translation":"তোমাদের সাথে","audioUrl":"wbw/011_093_020.mp3","charTypeName":"word"},{"id":69264,"position":19,"arabic":"رَقِيبٌۭ","translation":"প্রতীক্ষাকারী\"","audioUrl":"wbw/011_093_021.mp3","charTypeName":"word"},{"id":69265,"position":20,"arabic":"٩٣","translation":"(৯৩)","audioUrl":null,"charTypeName":"end"}]},{"number":94,"arabic":"وَلَمَّا جَآءَ أَمْرُنَا نَجَّيْنَا شُعَيْبًۭا وَٱلَّذِينَ ءَامَنُوا۟ مَعَهُۥ بِرَحْمَةٍۢ مِّنَّا وَأَخَذَتِ ٱلَّذِينَ ظَلَمُوا۟ ٱلصَّيْحَةُ فَأَصْبَحُوا۟ فِى دِيَٰرِهِمْ جَٰثِمِينَ","translation":"And so, when Our judgment came to pass, by Our grace We saved Shu'ayb and those who shared his faith, whereas the blast [of Our punishment] overtook those who had been bent on evildoing: and then they lay lifeless, in their very homes, on the ground,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1567.mp3","surahId":11,"words":[{"id":69462,"position":1,"arabic":"وَلَمَّا","translation":"এবং যখন","audioUrl":"wbw/011_094_001.mp3","charTypeName":"word"},{"id":69463,"position":2,"arabic":"جَآءَ","translation":"আসলো","audioUrl":"wbw/011_094_002.mp3","charTypeName":"word"},{"id":69464,"position":3,"arabic":"أَمْرُنَا","translation":"আমাদের নির্দেশ","audioUrl":"wbw/011_094_003.mp3","charTypeName":"word"},{"id":69465,"position":4,"arabic":"نَجَّيْنَا","translation":"আমরা রক্ষা করলাম","audioUrl":"wbw/011_094_004.mp3","charTypeName":"word"},{"id":69466,"position":5,"arabic":"شُعَيْبًۭا","translation":"শুআইবকে","audioUrl":"wbw/011_094_005.mp3","charTypeName":"word"},{"id":69467,"position":6,"arabic":"وَٱلَّذِينَ","translation":"ও যারা","audioUrl":"wbw/011_094_006.mp3","charTypeName":"word"},{"id":69468,"position":7,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছিলো","audioUrl":"wbw/011_094_007.mp3","charTypeName":"word"},{"id":69469,"position":8,"arabic":"مَعَهُۥ","translation":"তার সাথে","audioUrl":"wbw/011_094_008.mp3","charTypeName":"word"},{"id":69470,"position":9,"arabic":"بِرَحْمَةٍۢ","translation":"অনুগ্রহ দিয়ে","audioUrl":"wbw/011_094_009.mp3","charTypeName":"word"},{"id":69471,"position":10,"arabic":"مِّنَّا","translation":"আমাদের পক্ষ থেকে","audioUrl":"wbw/011_094_010.mp3","charTypeName":"word"},{"id":69472,"position":11,"arabic":"وَأَخَذَتِ","translation":"এবং ধরলো","audioUrl":"wbw/011_094_011.mp3","charTypeName"