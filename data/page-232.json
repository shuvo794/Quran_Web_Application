{"id":232,"ayahs":[{"number":89,"arabic":"وَيَٰقَوْمِ لَا يَجْرِمَنَّكُمْ شِقَاقِىٓ أَن يُصِيبَكُم مِّثْلُ مَآ أَصَابَ قَوْمَ نُوحٍ أَوْ قَوْمَ هُودٍ أَوْ قَوْمَ صَٰلِحٍۢ ۚ وَمَا قَوْمُ لُوطٍۢ مِّنكُم بِبَعِيدٍۢ","translation":"\"And, O my people, let not [your] dissent from me drive you into sin, lest there befall you the like of what befell the people of Noah, or the people of Hud. or the people of Salih: and [remember that] the people of Lot lived not very far from you!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1562.mp3","surahId":11,"words":[{"id":67737,"position":1,"arabic":"وَيَـٰقَوْمِ","translation":"এবং হে আমার জাতি","audioUrl":"wbw/011_089_001.mp3","charTypeName":"word"},{"id":67738,"position":2,"arabic":"لَا","translation":"না (যেন)","audioUrl":"wbw/011_089_002.mp3","charTypeName":"word"},{"id":67739,"position":3,"arabic":"يَجْرِمَنَّكُمْ","translation":"তোমাদেরকে অপরাধ করতে (উদ্বুদ্ধ করে)","audioUrl":"wbw/011_089_003.mp3","charTypeName":"word"},{"id":67740,"position":4,"arabic":"شِقَاقِىٓ","translation":"আমার (সাথে) বিরোধ","audioUrl":"wbw/011_089_004.mp3","charTypeName":"word"},{"id":67741,"position":5,"arabic":"أَن","translation":"(এতদূর) যে","audioUrl":"wbw/011_089_005.mp3","charTypeName":"word"},{"id":67742,"position":6,"arabic":"يُصِيبَكُم","translation":"তোমাদের উপর আপতিত হয়","audioUrl":"wbw/011_089_006.mp3","charTypeName":"word"},{"id":67743,"position":7,"arabic":"مِّثْلُ","translation":"তেমনি (শাস্তি)","audioUrl":"wbw/011_089_007.mp3","charTypeName":"word"},{"id":67744,"position":8,"arabic":"مَآ","translation":"যেমন","audioUrl":"wbw/011_089_008.mp3","charTypeName":"word"},{"id":67745,"position":9,"arabic":"أَصَابَ","translation":"আপতিত হয়েছিলো","audioUrl":"wbw/011_089_009.mp3","charTypeName":"word"},{"id":67746,"position":10,"arabic":"قَوْمَ","translation":"জাতির (উপর)","audioUrl":"wbw/011_089_010.mp3","charTypeName":"word"},{"id":67747,"position":11,"arabic":"نُوحٍ","translation":"নূহের","audioUrl":"wbw/011_089_011.mp3"