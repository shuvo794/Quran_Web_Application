rd"},{"id":68508,"position":3,"arabic":"مَا","translation":"না","audioUrl":"wbw/011_091_003.mp3","charTypeName":"word"},{"id":68509,"position":4,"arabic":"نَفْقَهُ","translation":"আমরা বুঝি","audioUrl":"wbw/011_091_004.mp3","charTypeName":"word"},{"id":68510,"position":5,"arabic":"كَثِيرًۭا","translation":"অনেক (কথাই)","audioUrl":"wbw/011_091_005.mp3","charTypeName":"word"},{"id":68511,"position":6,"arabic":"مِّمَّا","translation":"তা হ'তে যা","audioUrl":"wbw/011_091_006.mp3","charTypeName":"word"},{"id":68512,"position":7,"arabic":"تَقُولُ","translation":"বলো তুমি","audioUrl":"wbw/011_091_007.mp3","charTypeName":"word"},{"id":68513,"position":8,"arabic":"وَإِنَّا","translation":"এবং নিশ্চয়ই আমরা","audioUrl":"wbw/011_091_008.mp3","charTypeName":"word"},{"id":68514,"position":9,"arabic":"لَنَرَىٰكَ","translation":"আমরা অবশ্যই তোমাকে দেখছি","audioUrl":"wbw/011_091_009.mp3","charTypeName":"word"},{"id":68515,"position":10,"arabic":"فِينَا","translation":"আমাদের মাঝে","audioUrl":"wbw/011_091_010.mp3","charTypeName":"word"},{"id":68516,"position":11,"arabic":"ضَعِيفًۭا ۖ","translation":"দুর্বল হিসেবে","audioUrl":"wbw/011_091_011.mp3","charTypeName":"word"},{"id":68518,"position":12,"arabic":"وَلَوْلَا","translation":"এবং যদি থাকত না","audioUrl":"wbw/011_091_013.mp3","charTypeName":"word"},{"id":68519,"position":13,"arabic":"رَهْطُكَ","translation":"তোমার স্বজনবর্গ","audioUrl":"wbw/011_091_014.mp3","charTypeName":"word"},{"id":68520,"position":14,"arabic":"لَرَجَمْنَـٰكَ ۖ","translation":"তোমাকে আমরা পাথর ছুড়ে মেরে ফেলতাম","audioUrl":"wbw/011_091_015.mp3","charTypeName":"word"},{"id":68522,"position":15,"arabic":"وَمَآ","translation":"এবং নও","audioUrl":"wbw/011_091_017.mp3","charTypeName":"word"},{"id":68523,"position":16,"arabic":"أَنتَ","translation":"তুমি","audioUrl":"wbw/011_091_018.mp3","charTypeName":"word"},{"id":68524,"position":17,"arabic":"عَلَيْنَا","translation":"আমাদের উপর","audioUrl":"wbw/011_091_019.mp3","charTypeName":"word"},{"id":68525,"position":18,"a