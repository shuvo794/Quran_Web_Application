{"id":123,"ayahs":[{"number":90,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوٓا۟ إِنَّمَا ٱلْخَمْرُ وَٱلْمَيْسِرُ وَٱلْأَنصَابُ وَٱلْأَزْلَٰمُ رِجْسٌۭ مِّنْ عَمَلِ ٱلشَّيْطَٰنِ فَٱجْتَنِبُوهُ لَعَلَّكُمْ تُفْلِحُونَ","translation":"O YOU who have attained to faith! Intoxicants, and games of chance, and idolatrous practices, and the divining of the future are but a loathsome evil of Satan's doing:' shun it, then, so that you might attain to a happy state!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/759.mp3","surahId":5,"words":[{"id":68026,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/005_090_001.mp3","charTypeName":"word"},{"id":68027,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/005_090_002.mp3","charTypeName":"word"},{"id":68028,"position":3,"arabic":"ءَامَنُوٓا۟","translation":"ঈমান এনেছো","audioUrl":"wbw/005_090_003.mp3","charTypeName":"word"},{"id":68029,"position":4,"arabic":"إِنَّمَا","translation":"মূলতঃ","audioUrl":"wbw/005_090_004.mp3","charTypeName":"word"},{"id":68030,"position":5,"arabic":"ٱلْخَمْرُ","translation":"মদ","audioUrl":"wbw/005_090_005.mp3","charTypeName":"word"},{"id":68031,"position":6,"arabic":"وَٱلْمَيْسِرُ","translation":"ও জুয়া","audioUrl":"wbw/005_090_006.mp3","charTypeName":"word"},{"id":68032,"position":7,"arabic":"وَٱلْأَنصَابُ","translation":"ও পূজার বেদীগুলো","audioUrl":"wbw/005_090_007.mp3","charTypeName":"word"},{"id":68033,"position":8,"arabic":"وَٱلْأَزْلَـٰمُ","translation":"ও ভাগ্য নির্ধারক তীরগুলো","audioUrl":"wbw/005_090_008.mp3","charTypeName":"word"},{"id":68034,"position":9,"arabic":"رِجْسٌۭ","translation":"অপবিত্র","audioUrl":"wbw/005_090_009.mp3","charTypeName":"word"},{"id":68035,"position":10,"arabic":"مِّنْ","translation":"এক ধরণের","audioUrl":"wbw/005_090_010.mp3","charTypeName":"word"},{"id":68036,"position":11,"arabic":"عَمَلِ","translation":"কাজ","audioUrl":"wbw/005_090_011.mp3","charTypeName":"word"},{"id":68037,"position":12,"arabic":"ٱلشَّيْطَـٰنِ","translation":"শয়তানের","audioUrl":"wbw/005_090_012.mp3","charTypeName":"word"},{"id":68038,"position":13,"arabic":"فَٱجْتَنِبُوهُ","translation":"তাই বেঁচে থাকো তা হতে","audioUrl":"wbw/005_090_013.mp3","charTypeName":"word"},{"id":68039,"position":14,"arabic":"لَعَلَّكُمْ","translation":"যেন তোমরা","audioUrl":"wbw/005_090_014.mp3","charTypeName":"word"},{"id":68040,"position":15,"arabic":"تُفْلِحُونَ","translation":"সফলকাম হতে পারো","audioUrl":"wbw/005_090_015.mp3","charTypeName":"word"},{"id":68041,"position":16,"arabic":"٩٠","translation":"(৯০)","audioUrl":null,"charTypeName":"end"}]},{"number":91,"arabic":"إِنَّمَا يُرِيدُ ٱلشَّيْطَٰنُ أَن يُوقِعَ بَيْنَكُمُ ٱلْعَدَٰوَةَ وَٱلْبَغْضَآءَ فِى ٱلْخَمْرِ وَٱلْمَيْسِرِ وَيَصُدَّكُمْ عَن ذِكْرِ ٱللَّهِ وَعَنِ ٱلصَّلَوٰةِ ۖ فَهَلْ أَنتُم مُّنتَهُونَ","translation":"By means of intoxicants and games of chance Satan seeks only to sow enmity and hatred among you, and to turn you away from the remembrance of God and from prayer. Will you not, then, desist?'","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/760.mp3","surahId":5,"words":[{"id":68484,"position":1,"arabic":"إِنَّمَا","translation":"মূলতঃ","audioUrl":"wbw/005_091_001.mp3","charTypeName":"word"},{"id":68485,"position":2,"arabic":"يُرِيدُ","translation":"চায়","audioUrl":"wbw/005_091_002.mp3","charTypeName":"word"},{"id":68486,"position":3,"arabic":"ٱلشَّيْطَـٰنُ","translation":"শয়তান","audioUrl":"wbw/005_091_003.mp3","charTypeName":"word"},{"id":68487,"position":4,"arabic":"أَن","translation":"যে","audioUrl":"wbw/005_091_004.mp3","charTypeName":"word"},{"id":68488,"position":5,"arabic":"يُوقِعَ","translation":"ঘটাবে","audioUrl":"wbw/005_091_005.mp3","charTypeName":"word"},{"id":68489,"position":6,"arabic":"بَيْنَكُمُ","translation":"মাঝে তোমাদের","audioUrl":"wbw/005_091_006.mp3","charTypeName":"word"},{"id":68490,"position":7,"arabic":"ٱلْعَدَٰوَةَ","translation":"শত্রুতা","audioUrl":"wbw/005_091_007.mp3","charTypeName":"word"},{"id":68491,"position":8,"arabic":"وَٱلْبَغْضَآءَ","translation":"ও বিদ্বেষ","audioUrl":"wbw/005_091_008.mp3","charTypeName":"word"},{"id":68492,"position":9,"arabic":"فِى","translation":"মাধ্যমে","audioUrl":"wbw/005_091_009.mp3","charTypeName":"word"},{"id":68493,"position":10,"arabic":"ٱلْخَمْرِ","translation":"মদের","audioUrl":"wbw/005_091_010.mp3","charTypeName":"word"},{"id":68494,"position":11,"arabic":"وَٱلْمَيْسِرِ","translation":"ও জুয়ার","audioUrl":"wbw/005_091_011.mp3","charTypeName":"word"},{"id":68495,"position":12,"arabic":"وَيَصُدَّكُمْ","translation":"ও বাধা দিবে তোমাদের","audioUrl":"wbw/005_091_012.mp3","charTypeName":"word"},{"id":68496,"position":13,"arabic":"عَن","translation":"হতে","audioUrl":"wbw/005_091_013.mp3","charTypeName":"word"},{"id":68497,"position":14,"arabic":"ذِكْرِ","translation":"স্মরণ","audioUrl":"wbw/005_091_014.mp3","charTypeName":"word"},{"id":68498,"position":15,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/005_091_015.mp3","charTypeName":"word"},{"id":68499,"position":16,"arabic":"وَعَنِ","translation":"ও হতে","audioUrl":"wbw/005_091_016.mp3","charTypeName":"word"},{"id":68500,"position":17,"arabic":"ٱلصَّلَوٰةِ ۖ","translation":"সালাত","audioUrl":"wbw/005_091_017.mp3","charTypeName":"word"},{"id":68502,"position":18,"arabic":"فَهَلْ","translation":"তবুও কি","audioUrl":"wbw/005_091_019.mp3","charTypeName":"word"},{"id":68503,"position":19,"arabic":"أَنتُم","translation":"তোমরা","audioUrl":"wbw/005_091_020.mp3","charTypeName":"word"},{"id":68504,"position":20,"arabic":"مُّنتَهُونَ","translation":"নিবৃত্ত হবে (না)","audioUrl":"wbw/005_091_021.mp3","charTypeName":"word"},{"id":68505,"position":21,"arabic":"٩١","translation":"(৯১)","audioUrl":null,"charTypeName":"end"}]},{"number":92,"arabic":"وَأَطِيعُوا۟ ٱللَّهَ وَأَطِيعُوا۟ ٱلرَّسُولَ وَٱحْذَرُوا۟ ۚ فَإِن تَوَلَّيْتُمْ فَٱعْلَمُوٓا۟ أَنَّمَا عَلَىٰ رَسُولِنَا ٱلْبَلَٰغُ ٱلْمُبِينُ","translation":"Hence, pay heed unto God, and pay heed unto the Apostle, and be ever on your guard [against evil]; and if you turn away, then know that Our Apostle's only duty is a clear delivery of the message [entrusted to him].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/761.mp3","surahId":5,"words":[{"id":68755,"position":1,"arabic":"وَأَطِيعُوا۟","translation":"এবং তোমরা আনুগত্য করো","audioUrl":"wbw/005_092_001.mp3","charTypeName":"word"},{"id":68756,"position":2,"arabic":"ٱللَّهَ","translation":"আল্লাহর","audioUrl":"wbw/005_092_002.mp3","charTypeName":"word"},{"id":68757,"position":3,"arabic":"وَأَطِيعُوا۟","translation":"ও তোমরা আনুগত্য করো","audioUrl":"wbw/005_092_003.mp3","charTypeName":"word"},{"id":68758,"position":4,"arabic":"ٱلرَّسُولَ","translation":"রাসূলের","audioUrl":"wbw/005_092_004.mp3","charTypeName":"word"},{"id":68759,"position":5,"arabic":"وَٱحْذَرُوا۟ ۚ","translation":"ও তোমরা সতর্ক হও","audioUrl":"wbw/005_092_005.mp3","charTypeName":"word"},{"id":68761,"position":6,"arabic":"فَإِن","translation":"অতঃপর যদি","audioUrl":"wbw/005_092_007.mp3","charTypeName":"word"},{"id":68762,"position":7,"arabic":"تَوَلَّيْتُمْ","translation":"মুখ ফিরিয়ে নাও তোমরা","audioUrl":"wbw/005_092_008.mp3","charTypeName":"word"},{"id":68763,"position":8,"arabic":"فَٱعْلَمُوٓا۟","translation":"তবে তোমরা জেনে রেখো","audioUrl":"wbw/005_092_009.mp3","charTypeName":"word"},{"id":68764,"position":9,"arabic":"أَنَّمَا","translation":"যে কেবল","audioUrl":"wbw/005_092_010.mp3","charTypeName":"word"},{"id":68765,"position":10,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/005_092_011.mp3","charTypeName":"word"},{"id":68766,"position":11,"arabic":"رَسُولِنَا","translation":"রাসূলের আমাদের (দায়িত্ব)","audioUrl":"wbw/005_092_012.mp3","charTypeName":"word"},{"id":68767,"position":12,"arabic":"ٱلْبَلَـٰغُ","translation":"(নির্দেশাবলী)প্রচার করা","audioUrl":"wbw/005_092_013.mp3","charTypeName":"word"},{"id":68768,"position":13,"arabic":"ٱلْمُبِينُ","translation":"সুস্পষ্টভাবে","audioUrl":"wbw/005_092_014.mp3","charTypeName":"word"},{"id":68769,"position":14,"arabic":"٩٢","translation":"(৯২)","audioUrl":null,"charTypeName":"end"}]},{"number":93,"arabic":"لَيْسَ عَلَى ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ جُنَاحٌۭ فِيمَا طَعِمُوٓا۟ إِذَا مَا ٱتَّقَوا۟ وَّءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ ثُمَّ ٱتَّقَوا۟ وَّءَامَنُوا۟ ثُمَّ ٱتَّقَوا۟ وَّأَحْسَنُوا۟ ۗ وَٱللَّهُ يُحِبُّ ٱلْمُحْسِنِينَ","translation":"Those who have attained to faith and do righteous deeds incur no sin by partaking of whatever they may, so long as they are conscious of God and [truly] believe and do righteous deeds, and continue to be conscious of God and to believe, and grow ever more conscious of God, and persevere in doing good: for God loves the doers of good.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/762.mp3","surahId":5,"words":[{"id":69115,"position":1,"arabic":"لَيْسَ","translation":"নেই","audioUrl":"wbw/005_093_001.mp3","charTypeName":"word"},{"id":69116,"position":2,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/005_093_002.mp3","charTypeName":"word"},{"id":69117,"position":3,"arabic":"ٱلَّذِينَ","translation":"(তাদের) যারা","audioUrl":"wbw/005_093_003.mp3","charTypeName":"word"},{"id":69118,"position":4,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/005_093_004.mp3","charTypeName":"word"},{"id":69119,"position":5,"arabic":"وَعَمِلُوا۟","translation":"ও কাজ করেছে","audioUrl":"wbw/005_093_005.mp3","charTypeName":"word"},{"id":69120,"position":6,"arabic":"ٱلصَّـٰلِحَـٰتِ","translation":"সৎ","audioUrl":"wbw/005_093_006.mp3","charTypeName":"word"},{"id":69121,"position":7,"arabic":"جُنَاحٌۭ","translation":"পাপ","audioUrl":"wbw/005_093_007.mp3","charTypeName":"word"},{"id":69122,"position":8,"arabic":"فِيمَا","translation":"তার মধ্যে যা","audioUrl":"wbw/005_093_008.mp3","charTypeName":"word"},{"id":69123,"position":9,"arabic":"طَعِمُوٓا۟","translation":"তারা খেয়েছে (পূর্বে)","audioUrl":"wbw/005_093_009.mp3","charTypeName":"word"},{"id":69124,"position":10,"arabic":"إِذَا","tran