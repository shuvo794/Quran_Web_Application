,"audioUrl":null,"charTypeName":"end"}]},{"number":94,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ لَيَبْلُوَنَّكُمُ ٱللَّهُ بِشَىْءٍۢ مِّنَ ٱلصَّيْدِ تَنَالُهُۥٓ أَيْدِيكُمْ وَرِمَاحُكُمْ لِيَعْلَمَ ٱللَّهُ مَن يَخَافُهُۥ بِٱلْغَيْبِ ۚ فَمَنِ ٱعْتَدَىٰ بَعْدَ ذَٰلِكَ فَلَهُۥ عَذَابٌ أَلِيمٌۭ","translation":"O YOU who have attained to faith! Most certainly God will try you by means of the game which may come within the reach of your hands and your weapons [while you are on pilgrimage], so that God might mark out those who fear Him although He is beyond the reach of human perception. And as for him who, after all this, transgresses the bounds of what is right-grievous suffering awaits him!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/763.mp3","surahId":5,"words":[{"id":69538,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/005_094_001.mp3","charTypeName":"word"},{"id":69539,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/005_094_002.mp3","charTypeName":"word"},{"id":69540,"position":3,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছো","audioUrl":"wbw/005_094_003.mp3","charTypeName":"word"},{"id":69541,"position":4,"arabic":"لَيَبْلُوَنَّكُمُ","translation":"অবশ্যই পরীক্ষা করবেন তোমাদের","audioUrl":"wbw/005_094_004.mp3","charTypeName":"word"},{"id":69542,"position":5,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/005_094_005.mp3","charTypeName":"word"},{"id":69543,"position":6,"arabic":"بِشَىْءٍۢ","translation":"দিয়ে(কিছু) জিনিস","audioUrl":"wbw/005_094_006.mp3","charTypeName":"word"},{"id":69544,"position":7,"arabic":"مِّنَ","translation":"থেকে","audioUrl":"wbw/005_094_007.mp3","charTypeName":"word"},{"id":69545,"position":8,"arabic":"ٱلصَّيْدِ","translation":"শিকারের","audioUrl":"wbw/005_094_008.mp3","charTypeName":"word"},{"id":69546,"position":9,"arabic":"تَنَالُهُۥٓ","translation":"নাগালে আসে যা","audioUrl":"wbw/005_094_009.mp3","charTypeName":"word"},{"id":69547,"position":10,"arabic":"أَ