0.mp3","charTypeName":"word"},{"id":14714,"position":19,"arabic":"١٣","translation":"(১৩)","audioUrl":null,"charTypeName":"end"}]},{"number":14,"arabic":"وَمَن يَعْصِ ٱللَّهَ وَرَسُولَهُۥ وَيَتَعَدَّ حُدُودَهُۥ يُدْخِلْهُ نَارًا خَٰلِدًۭا فِيهَا وَلَهُۥ عَذَابٌۭ مُّهِينٌۭ","translation":"And whoever rebels against God and His Apostle and transgresses His bounds, him will He commit unto fire, therein to abide; and shameful suffering awaits him.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/507.mp3","surahId":4,"words":[{"id":15769,"position":1,"arabic":"وَمَن","translation":"এবং যে","audioUrl":"wbw/004_014_001.mp3","charTypeName":"word"},{"id":15770,"position":2,"arabic":"يَعْصِ","translation":"অবাধ্য হবে","audioUrl":"wbw/004_014_002.mp3","charTypeName":"word"},{"id":15771,"position":3,"arabic":"ٱللَّهَ","translation":"আল্লাহর","audioUrl":"wbw/004_014_003.mp3","charTypeName":"word"},{"id":15772,"position":4,"arabic":"وَرَسُولَهُۥ","translation":"ও তাঁর রাসূলের","audioUrl":"wbw/004_014_004.mp3","charTypeName":"word"},{"id":15773,"position":5,"arabic":"وَيَتَعَدَّ","translation":"এবং লঙ্ঘন করবে","audioUrl":"wbw/004_014_005.mp3","charTypeName":"word"},{"id":15774,"position":6,"arabic":"حُدُودَهُۥ","translation":"সীমাসমূহের তাঁর","audioUrl":"wbw/004_014_006.mp3","charTypeName":"word"},{"id":15775,"position":7,"arabic":"يُدْخِلْهُ","translation":"তাকে তিনি প্রবেশ করাবেন","audioUrl":"wbw/004_014_007.mp3","charTypeName":"word"},{"id":15776,"position":8,"arabic":"نَارًا","translation":"(জাহান্নামের) আগুনে","audioUrl":"wbw/004_014_008.mp3","charTypeName":"word"},{"id":15777,"position":9,"arabic":"خَـٰلِدًۭا","translation":"সে স্থায়ী হবে","audioUrl":"wbw/004_014_009.mp3","charTypeName":"word"},{"id":15778,"position":10,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/004_014_010.mp3","charTypeName":"word"},{"id":15779,"position":11,"arabic":"وَلَهُۥ","translation":"এবং তার জন্য (রয়েছে)","audioUrl":"wbw/004_014_011.mp3","charTypeName":"word"},{"id"