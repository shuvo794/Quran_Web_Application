{"id":128,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ ٱلْحَمْدُ لِلَّهِ ٱلَّذِى خَلَقَ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضَ وَجَعَلَ ٱلظُّلُمَٰتِ وَٱلنُّورَ ۖ ثُمَّ ٱلَّذِينَ كَفَرُوا۟ بِرَبِّهِمْ يَعْدِلُونَ","translation":"ALL PRAISE is due to God, who has created the heavens and the earth, and brought into being deep darkness as well as light: and yet, those who are bent on denying the truth regard other powers as their Sustainer's equals!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/790.mp3","surahId":6,"words":[{"id":736,"position":1,"arabic":"ٱلْحَمْدُ","translation":"সকল প্রশংসা","audioUrl":"wbw/006_001_001.mp3","charTypeName":"word"},{"id":737,"position":2,"arabic":"لِلَّهِ","translation":"জন্যে আল্লাহরই","audioUrl":"wbw/006_001_002.mp3","charTypeName":"word"},{"id":738,"position":3,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/006_001_003.mp3","charTypeName":"word"},{"id":739,"position":4,"arabic":"خَلَقَ","translation":"সৃষ্টি করেছেন","audioUrl":"wbw/006_001_004.mp3","charTypeName":"word"},{"id":740,"position":5,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশসমূহ","audioUrl":"wbw/006_001_005.mp3","charTypeName":"word"},{"id":741,"position":6,"arabic":"وَٱلْأَرْضَ","translation":"ও পৃথিবী","audioUrl":"wbw/006_001_006.mp3","charTypeName":"word"},{"id":742,"position":7,"arabic":"وَجَعَلَ","translation":"ও বানিয়েছেন","audioUrl":"wbw/006_001_007.mp3","charTypeName":"word"},{"id":743,"position":8,"arabic":"ٱلظُّلُمَـٰتِ","translation":"অন্ধকারসমূহ","audioUrl":"wbw/006_001_008.mp3","charTypeName":"word"},{"id":744,"position":9,"arabic":"وَٱلنُّورَ ۖ","translation":"ও আলো","audioUrl":"wbw/006_001_009.mp3","charTypeName":"word"},{"id":746,"position":10,"arabic":"ثُمَّ","translation":"এরপরও","audioUrl":"wbw/006_001_011.mp3","charTypeName":"word"},{"id":747,"position":11,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/006_001_012.mp3","charTypeName":"word"},{"id":748,"position":12,"arabic":"كَفَرُوا۟","translation":"অবিশ্বাস করেছে","audioUrl":"wbw/006_001_013.mp3","charTypeName":"word"},{"id":749,"position":13,"arabic":"بِرَبِّهِمْ","translation":"প্রতি রবের তাদের","audioUrl":"wbw/006_001_014.mp3","charTypeName":"word"},{"id":750,"position":14,"arabic":"يَعْدِلُونَ","translation":"তাঁর সমকক্ষ দাঁড় করায় (অন্যান্যদেরকে)","audioUrl":"wbw/006_001_015.mp3","charTypeName":"word"},{"id":751,"position":15,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"هُوَ ٱلَّذِى خَلَقَكُم مِّن طِينٍۢ ثُمَّ قَضَىٰٓ أَجَلًۭا ۖ وَأَجَلٌۭ مُّسَمًّى عِندَهُۥ ۖ ثُمَّ أَنتُمْ تَمْتَرُونَ","translation":"He it is who has created you out of clay, and then has decreed a term [for you] - a term known [only] to him. And yet you doubt –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/791.mp3","surahId":6,"words":[{"id":1802,"position":1,"arabic":"هُوَ","translation":"তিনিই (আল্লাহ)","audioUrl":"wbw/006_002_001.mp3","charTypeName":"word"},{"id":1803,"position":2,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/006_002_002.mp3","charTypeName":"word"},{"id":1804,"position":3,"arabic":"خَلَقَكُم","translation":"সৃষ্টি করেছেন তোমাদের","audioUrl":"wbw/006_002_003.mp3","charTypeName":"word"},{"id":1805,"position":4,"arabic":"مِّن","translation":"হতে","audioUrl":"wbw/006_002_004.mp3","charTypeName":"word"},{"id":1806,"position":5,"arabic":"طِينٍۢ","translation":"মাটি","audioUrl":"wbw/006_002_005.mp3","charTypeName":"word"},{"id":1807,"position":6,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/006_002_006.mp3","charTypeName":"word"},{"id":1808,"position":7,"arabic":"قَضَىٰٓ","translation":"নির্দিষ্ট করেছেন","audioUrl":"wbw/006_002_007.mp3","charTypeName":"word"},{"id":1809,"position":8,"arabic":"أَجَلًۭا ۖ","translation":"একটি মেয়াদ (জীবনকাল)","audioUrl":"wbw/006_002_008.mp3","charTypeName":"word"},{"id":1811,"position":9,"arabic":"وَأَجَلٌۭ","translation":"এবং (এছাড়াও) একটি মেয়াদ (অর্থাৎ ক্বিয়ামাত)","audioUrl":"wbw/006_002_010.mp3","charTypeName":"word"},{"id":1812,"position":10,"arabic":"مُّسَمًّى","translation":"নির্ধারিত (আছে)","audioUrl":"wbw/006_002_011.mp3","charTypeName":"word"},{"id":1813,"position":11,"arabic":"عِندَهُۥ ۖ","translation":"কাছে তাঁর","audioUrl":"wbw/006_002_012.mp3","charTypeName":"word"},{"id":1815,"position":12,"arabic":"ثُمَّ","translation":"এরপরও","audioUrl":"wbw/006_002_014.mp3","charTypeName":"word"},{"id":1816,"position":13,"arabic":"أَنتُمْ","translation":"তোমরা","audioUrl":"wbw/006_002_015.mp3","charTypeName":"word"},{"id":1817,"position":14,"arabic":"تَمْتَرُونَ","translation":"সন্দেহ করছো","audioUrl":"wbw/006_002_016.mp3","charTypeName":"word"},{"id":1818,"position":15,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"وَهُوَ ٱللَّهُ فِى ٱلسَّمَٰوَٰتِ وَفِى ٱلْأَرْضِ ۖ يَعْلَمُ سِرَّكُمْ وَجَهْرَكُمْ وَيَعْلَمُ مَا تَكْسِبُونَ","translation":"although He is God in the heavens and on earth, knowing all that you keep secret as well as all that you do openly, and knowing what you deserve.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/792.mp3","surahId":6,"words":[{"id":2956,"position":1,"arabic":"وَهُوَ","translation":"এবং তিনিই","audioUrl":"wbw/006_003_001.mp3","charTypeName":"word"},{"id":2957,"position":2,"arabic":"ٱللَّهُ","translation":"আল্লাহ (যিনি)","audioUrl":"wbw/006_003_002.mp3","charTypeName":"word"},{"id":2958,"position":3,"arabic":"فِى","translation":"আছেন","audioUrl":"wbw/006_003_003.mp3","charTypeName":"word"},{"id":2959,"position":4,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশসমূহে","audioUrl":"wbw/006_003_004.mp3","charTypeName":"word"},{"id":2960,"position":5,"arabic":"وَفِى","translation":"এবং আছেন","audioUrl":"wbw/006_003_005.mp3","charTypeName":"word"},{"id":2961,"position":6,"arabic":"ٱلْأَرْضِ ۖ","translation":"পৃথিবীতে","audioUrl":"wbw/006_003_006.mp3","charTypeName":"word"},{"id":2963,"position":7,"arabic":"يَعْلَمُ","translation":"তিনি জানেন","audioUrl":"wbw/006_003_008.mp3","charTypeName":"word"},{"id":2964,"position":8,"arabic":"سِرَّكُمْ","translation":"গোপন বিষয় তোমাদের","audioUrl":"wbw/006_003_009.mp3","charTypeName":"word"},{"id":2965,"position":9,"arabic":"وَجَهْرَكُمْ","translation":"ও প্রকাশ্য বিষয় তোমাদের","audioUrl":"wbw/006_003_010.mp3","charTypeName":"word"},{"id":2966,"position":10,"arabic":"وَيَعْلَمُ","translation":"এবং তিনি জানেন","audioUrl":"wbw/006_003_011.mp3","charTypeName":"word"},{"id":2967,"position":11,"arabic":"مَا","translation":"যা","audioUrl":"wbw/006_003_012.mp3","charTypeName":"word"},{"id":2968,"position":12,"arabic":"تَكْسِبُونَ","translation":"তোমরা অর্জন করো","audioUrl":"wbw/006_003_013.mp3","charTypeName":"word"},{"id":2969,"position":13,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"وَمَا تَأْتِيهِم مِّنْ ءَايَةٍۢ مِّنْ ءَايَٰتِ رَبِّهِمْ إِلَّا كَانُوا۟ عَنْهَا مُعْرِضِينَ","translation":"Yet whenever any of their Sustainer's messages comes unto them, they [who are bent on denying the truth] turn their backs upon it:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/793.mp3","surahId":6,"words":[{"id":4296,"position":1,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/006_004_001.mp3","charTypeName":"word"},{"id":4297,"position":2,"arabic":"تَأْتِيهِم","translation":"কাছে এসেছে তাদের","audioUrl":"wbw/006_004_002.mp3","charTypeName":"word"},{"id":4298,"position":3,"arabic":"مِّنْ","translation":"কোনো","audioUrl":"wbw/006_004_003.mp3","charTypeName":"word"},{"id":4299,"position":4,"arabic":"ءَايَةٍۢ","translation":"(এমন) নিদর্শন","audioUrl":"wbw/006_004_004.mp3","charTypeName":"word"},{"id":4300,"position":5,"arabic":"مِّنْ","translation":"মধ্য হতে","audioUrl":"wbw/006_004_005.mp3","charTypeName":"word"},{"id":4301,"position":6,"arabic":"ءَايَـٰتِ","translation":"নিদর্শনগুলোর","audioUrl":"wbw/006_004_006.mp3","charTypeName":"word"},{"id":4302,"position":7,"arabic":"رَبِّهِمْ","translation":"রবের তাদের","audioUrl":"wbw/006_004_007.mp3","charTypeName":"word"},{"id":4303,"position":8,"arabic":"إِلَّا","translation":"এ ছাড়া যে","audioUrl":"wbw/006_004_008.mp3","charTypeName":"word"},{"id":4304,"position":9,"arabic":"كَانُوا۟","translation":"তারা হয়েছিলো","audioUrl":"wbw/006_004_009.mp3","charTypeName":"word"},{"id":4305,"position":10,"arabic":"عَنْهَا","translation":"হতে তা","audioUrl":"wbw/006_004_010.mp3","charTypeName":"word"},{"id":4306,"position":11,"arabic":"مُعْرِضِينَ","translation":"বিমুখ","audioUrl":"wbw/006_004_011.mp3","charTypeName":"word"},{"id":4307,"position":12,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"فَقَدْ كَذَّبُوا۟ بِٱلْحَقِّ لَمَّا جَآءَهُمْ ۖ فَسَوْفَ يَأْتِيهِمْ أَنۢبَٰٓؤُا۟ مَا كَانُوا۟ بِهِۦ يَسْتَهْزِءُونَ","translation":"and so they give the lie to this truth now that it has come unto them. In time, however, they will come to understand what it was that they were wont to deride.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/794.mp3","surahId":6,"words":[{"id":5584,"position":1,"arabic":"فَقَدْ","translation":"সুতরাং নিশ্চয়ই","audioUrl":"wbw/006_005_001.mp3","charTypeName":"word"},{"id":5585,"position":2,"arabic":"كَذَّبُوا۟","translation":"তারা মিথ্যা প্রতিপন্ন করেছে","audioUrl":"wbw/006_005_002.mp3","charTypeName":"word"},{"id":5586,"position":3,"arabic":"بِٱلْحَقِّ","translation":"প্রতি সত্যের","audioUrl":"wbw/006_005_003.mp3","charTypeName":"word"},{"id":5587,"position":4,"arabic":"لَمَّا","translation":"যখনই","audioUrl":"wbw/006_005_004.mp3","charTypeName":"word"},{"id":5588,"position":5,"arabic":"جَآءَهُمْ ۖ","translation":"কাছে তা এসেছে তাদের","audioUrl":"wbw/006_005_005.mp3","charTypeName":"word"},{"id":5590,"position":6,"arabic":"فَسَوْفَ","translation":"সুতরাং শীঘ্রই","audioUrl":"wbw/006_005_007.mp3","charTypeName":"word"},{"id":5591,"position":7,"arabic":"يَأْتِيهِمْ","translation":"কাছে আসবে তাদের","audioUrl":"wbw/006_005_008.mp3","charTypeName":"word"},{"id":5592,"position":8,"arabic":"أَنۢبَـٰٓؤُا۟","translation":"সংবাদ","audioUrl":"wbw/006_005_009.mp3","charTypeName":"word"},{"id":5593,"position":9,"arabic":"مَا","translation":"ঐ বিষয়ের","audioUrl":"wbw/006_005_010.mp3","charTypeName":"word"},{"id":5594,"position":10,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/006_005_011.mp3","charTypeName":"word"},{"id":5595,"position":11,"arabic":"بِهِۦ","translation":"নিয়ে যা","audioUrl":"wbw/006_005_012.mp3","charTypeName":"word"},{"id":5596,"position":12,"arabic":"يَسْتَهْزِءُونَ","translation":"ঠাট্টা বিদ্রুপ করতো","audioUrl":"wbw/006_005_013.mp3","charTypeName":"word"},{"id":5597,"position":13,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"أَلَمْ يَرَوْا۟ كَمْ أَهْلَكْنَا مِن قَبْلِهِم مِّن قَرْنٍۢ مَّكَّنَّٰهُمْ فِى ٱلْأَرْضِ مَا لَمْ نُمَكِّن لَّكُمْ وَأَرْسَلْنَا ٱلسَّمَآءَ عَلَيْهِم مِّدْرَارًۭا وَجَعَلْنَا ٱلْأَنْهَٰرَ تَجْرِى مِن تَحْتِهِمْ فَأَهْلَكْنَٰهُم بِذُنُوبِهِمْ وَأَنشَأْنَا مِنۢ بَعْدِهِمْ قَرْنًا ءَاخَرِينَ","translation":"Do they not see how many a generation We have destroyed before their time - [people] whom We had given a [bountiful] place on earth, the like of which We never gave unto you, and upon whom We showered heavenly blessings abundant, and at whose feet We made running waters flow? And yet we destroyed them for their sins, and gave rise to other people in their stead.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/795.mp3","surahId":6,"words":[{"id":6848,"position":1,"arabic":"أَلَمْ","translation":"কি নি","audioUrl":"wbw/006_006_001.mp3","charTypeName":"word"},{"id":6849,"position":2,"arabic":"يَرَوْا۟","translation":"তারা দেখে","audioUrl":"wbw/006_006_002.mp3","charTypeName":"word"},{"id":6850,"position":3,"arabic":"كَمْ","translation":"কত (জাতিকে)","audioUrl":"wbw/006_006_003.mp3","charTypeName":"word"},{"id":6851,"position":4,"arabic":"أَهْلَكْنَا","translation":"ধ্বংস করেছি আমরা","audioUrl":"wbw/006_006_004.mp3","charTypeName":"word"},{"id":6852,"position":5,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/006_006_005.mp3","charTypeName":"word"},{"id":6853,"position":6,"arabic":"قَبْلِهِم","translation":"পূর্ব তাদের","audioUrl":"wbw/006_006_006.mp3","charTypeName":"word"},{"id":6854,"position":7,"arabic":"مِّن","translation":"হতে","audioUrl":"wbw/006_006_007.mp3","charTypeName":"word"},{"id":6855,"position":8,"arabic":"قَرْنٍۢ","translation":"মানবগোষ্ঠী","audioUrl":"wbw/006_006_008.mp3","charTypeName":"word"},{"id":6856,"position":9,"arabic":"مَّكَّنَّـٰهُمْ","translation":"আমরা প্রতিষ্ঠিত করেছিলাম তাদের","audioUrl":"wbw/006_006_009.mp3","charTypeName":"word"},{"id":6857,"position":10,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/006_006_010.mp3","charTypeName":"word"},{"id":6858,"position":11,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর (এমনভাবে)","audioUrl":"wbw/006_006_011.mp3","charTypeName":"word"},{"id":6859,"position":12,"arabic":"مَا","translation":"যেমনটি","audioUrl":"wbw/006_006_012.mp3","charTypeName":"word"},{"id":6860,"position":13,"arabic":"لَمْ","translation":"না","audioUrl":"wbw/006_006_013.mp3","charTypeName":"word"},{"id":6861,"position":14,"arabic":"نُمَكِّن","translation":"আমরা প্রতিষ্ঠিত করেছি","audioUrl":"wbw/006_006_014.mp3","charTypeName":"word"},{"id":6862,"position":15,"arabic":"لَّكُمْ","translation":"তোমাদেরকে","audioUrl":"wbw/006_006_015.mp3","charTypeName":"word"},{"id":6863,"position":16,"arabic":"وَأَرْسَلْنَا","translation":"এবং আমরা পাঠিয়েছিলাম","audioUrl":"wbw/006_006_016.mp3","charTypeName":"word"},{"id":6864,"position":17,"arabic":"ٱلسَّمَآءَ","translation":"আকাশ (থেকে)","audioUrl":"wbw/006_006_017.mp3","charTypeName":"word"},{"id":6865,"position":18,"arabic":"عَلَيْهِم","translation":"উপর তাদের","audioUrl":"wbw/006_006_018.mp3","charTypeName":"word"},{"id":6866,"position":19,"arabic":"مِّدْرَارًۭا","translation":"মুষলধারে বৃষ্টি","audioUrl":"wbw/006_006_019.mp3","charTypeName":"word"},{"id":6867,"position":20,"arabic":"وَجَعَلْنَا","translation":"ও করেছিলাম আমরা","audioUrl":"wbw/006_006_020.mp3","charTypeName":"word"},{"id":6868,"position":21,"arabic":"ٱلْأَنْهَـٰرَ","translation":"নদীসমূহকে","audioUrl":"wbw/006_006_021.mp3","charTypeName":"word"},{"id":6869,"position":22,"arabic":"تَجْرِى","translation":"প্রবাহিত","audioUrl":"wbw/006_006_022.mp3","charTypeName":"word"},{"id":6870,"position":23,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/006_006_023.mp3","charTypeName":"word"},{"id":6871,"position":24,"arabic":"تَحْتِهِمْ","translation":"নিচ তাদের(ভূমি)","audioUrl":"wbw/006_006_024.mp3","charTypeName":"word"},{"id":6872,"position":25,"arabic":"فَأَهْلَكْنَـٰهُم","translation":"অতঃপর আমরা ধ্বংস করেছি তাদের","audioUrl":"wbw/006_006_025.mp3","charTypeName":"word"},{"id":6873,"position":26,"arabic":"بِذُنُوبِهِمْ","translation":"কারণে পাপের তাদের","audioUrl":"wbw/006_006_026.mp3","charTypeName":"word"},{"id":6874,"position":27,"arabic":"وَأَنشَأْنَا","translation":"ও সৃষ্টি করেছি আমরা","audioUrl":"wbw/006_006_027.mp3","charTypeName":"word"},{"id":6875,"position":28,"arabic":"مِنۢ","translation":"থেকে","audioUrl":"wbw/006_006_028.mp3","charTypeName":"word"},{"id":6876,"position":29,"arabic":"بَعْدِهِمْ","translation":"পর তাদের","audioUrl":"wbw/006_006_029.mp3","charTypeName":"word"},{"id":6877,"position":30,"arabic":"قَرْنًا","translation":"জাতিকে","audioUrl":"wbw/006_006_030.mp3","charTypeName":"word"},{"id":6878,"position":31,"arabic":"ءَاخَرِينَ","translation":"অন্যান্য","audioUrl":"wbw/006_006_031.mp3","charTypeName":"word"},{"id":6879,"position":32,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"وَلَوْ نَزَّلْنَا عَلَيْكَ كِتَٰبًۭا فِى قِرْطَاسٍۢ فَلَمَسُوهُ بِأَيْدِيهِمْ لَقَالَ ٱلَّذِينَ كَفَرُوٓا۟ إِنْ هَٰذَآ إِلَّا سِحْرٌۭ مُّبِينٌۭ","translation":"But even if we had sent down unto thee [O Prophet] a writing on paper, and they had touched it with their own hands - those who are bent on denying the truth would indeed have said, \"This is clearly nothing but a deception!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/796.mp3","surahId":6,"words":[{"id":8182,"position":1,"arabic":"وَلَوْ","translation":"এবং যদি","audioUrl":"wbw/006_007_001.mp3","charTypeName":"word"},{"id":8183,"position":2,"arabic":"نَزَّلْنَا","translation":"অবতীর্ণ করতাম আমরা","audioUrl":"wbw/006_007_002.mp3","charTypeName":"word"},{"id":8184,"position":3,"arabic":"عَلَيْكَ","translation":"উপর তোমার","audioUrl":"wbw/006_007_003.mp3","charTypeName":"word"},{"id":8185,"position":4,"arabic":"كِتَـٰبًۭا","translation":"(লিখিত) কিতাব","audioUrl":"wbw/006_007_004.mp3","charTypeName":"word"},{"id":8186,"position":5,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/006_007_005.mp3","charTypeName":"word"},{"id":8187,"position":6,"arabic":"قِرْطَاسٍۢ","translation":"কাগজের","audioUrl":"wbw/006_007_006.mp3","charTypeName":"word"},{"id":8188,"position":7,"arabic":"فَلَمَسُوهُ","translation":"অতঃপর তারা স্পর্শ করতো তা","audioUrl":"wbw/006_007_007.mp3","charTypeName":"word"},{"id":8189,"position":8,"arabic":"بِأَيْدِيهِمْ","translation":"দিয়ে হাত তাদের","audioUrl":"wbw/006_007_008.mp3","charTypeName":"word"},{"id":8190,"position":9,"arabic":"لَقَالَ","translation":"(তবুও) অবশ্যই বলতো","audioUrl":"wbw/006_007_009.mp3","charTypeName":"word"},{"id":8191,"position":10,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/006_007_010.mp3","charTypeName":"word"},{"id":8192,"position":11,"arabic":"كَفَرُوٓا۟","translation":"অবিশ্বাস করেছে","audioUrl":"wbw/006_007_011.mp3","charTypeName":"word"},{"id":8193,"position":12,"arabic":"إِنْ","translation":"\"নয়","audioUrl":"wbw/006_007_012.mp3","charTypeName":"word"},{"id":8194,"position":13,"arabic":"هَـٰذَآ","translation":"\"এটা","audioUrl":"wbw/006_007_013.mp3","charTypeName":"word"},{"id":8195,"position":14,"arabic":"إِلَّا","translation":"এ ছাড়া যে","audioUrl":"wbw/006_007_014.mp3","charTypeName":"word"},{"id":8196,"position":15,"arabic":"سِحْرٌۭ","translation":"জাদু\"","audioUrl":"wbw/006_007_015.mp3","charTypeName":"word"},{"id":8197,"position":16,"arabic":"مُّبِينٌۭ","translation":"সুস্পষ্ট\"","audioUrl":"wbw/006_007_016.mp3","charTypeName":"word"},{"id":8198,"position":17,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"وَقَالُوا۟ لَوْلَآ أُنزِلَ عَلَيْهِ مَلَكٌۭ ۖ وَلَوْ أَنزَلْنَا مَلَكًۭا لَّقُضِىَ ٱلْأَمْرُ ثُمَّ لَا يُنظَرُونَ","translation":"They are saying, too, \"Why has not an angel (visibly] been sent down unto him?\" But had we sent down an angel, all would indeed have been decided, and they would have been allowed no further respite [for repentance.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/797.mp3","surahId":6,"words":[{"id":9346,"position":1,"arabic":"وَقَالُوا۟","translation":"এবং তারা বলে","audioUrl":"wbw/006_008_001.mp3","charTypeName":"word"},{"id":9347,"position":2,"arabic":"لَوْلَآ","translation":"\"কেন না","audioUrl":"wbw/006_008_002.mp3","charTypeName":"word"},{"id":9348,"position":3,"arabic":"أُنزِلَ","translation":"অবতীর্ণ করা হলো","audioUrl":"wbw/006_008_003.mp3","charTypeName":"word"},{"id":9349,"position":4,"arabic":"عَلَيْهِ","translation":"কাছে তার","audioUrl":"wbw/006_008_004.mp3","charTypeName":"word"},{"id":9350,"position":5,"arabic":"مَلَكٌۭ ۖ","translation":"ফেরেশতা (সাক্ষী রূপে)\"","audioUrl":"wbw/006_008_005.mp3","charTypeName":"word"},{"id":9352,"position":6,"arabic":"وَلَوْ","translation":"এবং যদি","audioUrl":"wbw/006_008_007.mp3","charTypeName":"word"},{"id":9353,"position":7,"arabic":"أَنزَلْنَا","translation":"অবতীর্ণ করতাম আমরা","audioUrl":"wbw/006_008_008.mp3","charTypeName":"word"},{"id":9354,"position":8,"arabic":"مَلَكًۭا","translation":"ফেরেশতা (সাক্ষীরূপে)","audioUrl":"wbw/006_008_009.mp3","charTypeName":"word"},{"id":9355,"position":9,"arabic":"لَّقُضِىَ","translation":"অবশ্যই মীমাংসা হয়ে যেতো","audioUrl":"wbw/006_008_010.mp3","charTypeName":"word"},{"id":9356,"position":10,"arabic":"ٱلْأَمْرُ","translation":"(সব) বিষ