{"id":227,"ayahs":[{"number":46,"arabic":"قَالَ يَٰنُوحُ إِنَّهُۥ لَيْسَ مِنْ أَهْلِكَ ۖ إِنَّهُۥ عَمَلٌ غَيْرُ صَٰلِحٍۢ ۖ فَلَا تَسْـَٔلْنِ مَا لَيْسَ لَكَ بِهِۦ عِلْمٌ ۖ إِنِّىٓ أَعِظُكَ أَن تَكُونَ مِنَ ٱلْجَٰهِلِينَ","translation":"[God] answered: \"O Noah, behold, he was not of thy family, for, verily, he was unrighteous in his conduct. And thou shalt not ask of Me anything whereof thou canst not have any knowledge: thus, behold, do I admonish thee lest thou become one of those who are unaware [of what is right].\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1519.mp3","surahId":11,"words":[{"id":46029,"position":1,"arabic":"قَالَ","translation":"(আল্লাহ) বললেন","audioUrl":"wbw/011_046_001.mp3","charTypeName":"word"},{"id":46030,"position":2,"arabic":"يَـٰنُوحُ","translation":"\"হে নূহ","audioUrl":"wbw/011_046_002.mp3","charTypeName":"word"},{"id":46031,"position":3,"arabic":"إِنَّهُۥ","translation":"সে নিশ্চয়ই","audioUrl":"wbw/011_046_003.mp3","charTypeName":"word"},{"id":46032,"position":4,"arabic":"لَيْسَ","translation":"নয়","audioUrl":"wbw/011_046_004.mp3","charTypeName":"word"},{"id":46033,"position":5,"arabic":"مِنْ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/011_046_005.mp3","charTypeName":"word"},{"id":46034,"position":6,"arabic":"أَهْلِكَ ۖ","translation":"তোমার পরিবারের","audioUrl":"wbw/011_046_006.mp3","charTypeName":"word"},{"id":46036,"position":7,"arabic":"إِنَّهُۥ","translation":"নিশ্চয়ই তা","audioUrl":"wbw/011_046_008.mp3","charTypeName":"word"},{"id":46037,"position":8,"arabic":"عَمَلٌ","translation":"কাজ","audioUrl":"wbw/011_046_009.mp3","charTypeName":"word"},{"id":46038,"position":9,"arabic":"غَيْرُ","translation":"নয়/অ","audioUrl":"wbw/011_046_010.mp3","charTypeName":"word"},{"id":46039,"position":10,"arabic":"صَـٰلِحٍۢ ۖ","translation":"সৎ","audioUrl":"wbw/011_046_011.mp3","charTypeName":"word"},{"id":46041,"position":11,"arabic":"فَلَا","translation":"অতএব না","audioUrl":"wbw/011_046_013.mp3","charTypeName":"word"},{"id":46042,"position":12,"arabic":"تَسْـَٔلْنِ","translation":"আমার কাছে অনুরোধ করো","audioUrl":"wbw/011_046_014.mp3","charTypeName":"word"},{"id":46043,"position":13,"arabic":"مَا","translation":"যার","audioUrl":"wbw/011_046_015.mp3","charTypeName":"word"},{"id":46044,"position":14,"arabic":"لَيْسَ","translation":"নেই","audioUrl":"wbw/011_046_016.mp3","charTypeName":"word"},{"id":46045,"position":15,"arabic":"لَكَ","translation":"তোমার","audioUrl":"wbw/011_046_017.mp3","charTypeName":"word"},{"id":46046,"position":16,"arabic":"بِهِۦ","translation":"সে সম্বন্ধে","audioUrl":"wbw/011_046_018.mp3","charTypeName":"word"},{"id":46047,"position":17,"arabic":"عِلْمٌ ۖ","translation":"কোন জ্ঞান","audioUrl":"wbw/011_046_019.mp3","charTypeName":"word"},{"id":46049,"position":18,"arabic":"إِنِّىٓ","translation":"নিশ্চয়ই আমি","audioUrl":"wbw/011_046_021.mp3","charTypeName":"word"},{"id":46050,"position":19,"arabic":"أَعِظُكَ","translation":"তোমাকে উপদেশ দিচ্ছি","audioUrl":"wbw/011_046_022.mp3","charTypeName":"word"},{"id":46051,"position":20,"arabic":"أَن","translation":"যে (না)","audioUrl":"wbw/011_046_023.mp3","charTypeName":"word"},{"id":46052,"position":21,"arabic":"تَكُونَ","translation":"তুমি হয়ো","audioUrl":"wbw/011_046_024.mp3","charTypeName":"word"},{"id":46053,"position":22,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/011_046_025.mp3","charTypeName":"word"},{"id":46054,"position":23,"arabic":"ٱلْجَـٰهِلِينَ","translation":"মূর্খদের\"","audioUrl":"wbw/011_046_026.mp3","charTypeName":"word"},{"id":46055,"position":24,"arabic":"٤٦","translation":"(৪৬)","audioUrl":null,"charTypeName":"end"}]},{"number":47,"arabic":"قَالَ رَبِّ إِنِّىٓ أَعُوذُ بِكَ أَنْ أَسْـَٔلَكَ مَا لَيْسَ لِى بِهِۦ عِلْمٌۭ ۖ وَإِلَّا تَغْفِرْ لِى وَتَرْحَمْنِىٓ أَكُن مِّنَ ٱلْخَٰسِرِينَ","translation":"Said [Noah]: \"O my Sustainer! Verily, I seek refuge with Thee from [ever again] asking of Thee anything whereof I cannot have any knowledge! For unless Thou grant me forgiveness and bestow Thy mercy upon me, I shall be among the lost!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1520.mp3","surahId":11,"words":[{"id":46671,"position":1,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/011_047_001.mp3","charTypeName":"word"},{"id":46672,"position":2,"arabic":"رَبِّ","translation":"\"হে আমার রব","audioUrl":"wbw/011_047_002.mp3","charTypeName":"word"},{"id":46673,"position":3,"arabic":"إِنِّىٓ","translation":"নিশ্চয়ই আমি","audioUrl":"wbw/011_047_003.mp3","charTypeName":"word"},{"id":46674,"position":4,"arabic":"أَعُوذُ","translation":"আশ্রয় চাচ্ছি","audioUrl":"wbw/011_047_004.mp3","charTypeName":"word"},{"id":46675,"position":5,"arabic":"بِكَ","translation":"কাছে তোমার","audioUrl":"wbw/011_047_005.mp3","charTypeName":"word"},{"id":46676,"position":6,"arabic":"أَنْ","translation":"যে","audioUrl":"wbw/011_047_006.mp3","charTypeName":"word"},{"id":46677,"position":7,"arabic":"أَسْـَٔلَكَ","translation":"তোমার কাছে আমি অনুরোধ করবো","audioUrl":"wbw/011_047_007.mp3","charTypeName":"word"},{"id":46678,"position":8,"arabic":"مَا","translation":"যার","audioUrl":"wbw/011_047_008.mp3","charTypeName":"word"},{"id":46679,"position":9,"arabic":"لَيْسَ","translation":"নেই","audioUrl":"wbw/011_047_009.mp3","charTypeName":"word"},{"id":46680,"position":10,"arabic":"لِى","translation":"আমার","audioUrl":"wbw/011_047_010.mp3","charTypeName":"word"},{"id":46681,"position":11,"arabic":"بِهِۦ","translation":"তা সম্বন্ধে","audioUrl":"wbw/011_047_011.mp3","charTypeName":"word"},{"id":46682,"position":12,"arabic":"عِلْمٌۭ ۖ","translation":"কোন জ্ঞান","audioUrl":"wbw/011_047_012.mp3","charTypeName":"word"},{"id":46684,"position":13,"arabic":"وَإِلَّا","translation":"এবং যদি না","audioUrl":"wbw/011_047_014.mp3","charTypeName":"word"},{"id":46685,"position":14,"arabic":"تَغْفِرْ","translation":"মাফ করো তুমি","audioUrl":"wbw/011_047_015.mp3","charTypeName":"word"},{"id":46686,"position":15,"arabic":"لِى","translation":"আমাকে","audioUrl":"wbw/011_047_016.mp3","charTypeName":"word"},{"id":46687,"position":16,"arabic":"وَتَرْحَمْنِىٓ","translation":"এবং (না) আমাকে তুমি দয়া করো","audioUrl":"wbw/011_047_017.mp3","charTypeName":"word"},{"id":46688,"position":17,"arabic":"أَكُن","translation":"আমি হয়ে যাবো","audioUrl":"wbw/011_047_018.mp3","charTypeName":"word"},{"id":46689,"position":18,"arabic":"مِّنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/011_047_019.mp3","charTypeName":"word"},{"id":46690,"position":19,"arabic":"ٱلْخَـٰسِرِينَ","translation":"ক্ষতিগ্রস্তদের\"","audioUrl":"wbw/011_047_020.mp3","charTypeName":"word"},{"id":46691,"position":20,"arabic":"٤٧","translation":"(৪৭)","audioUrl":null,"charTypeName":"end"}]},{"number":48,"arabic":"قِيلَ يَٰنُوحُ ٱهْبِطْ بِسَلَٰمٍۢ مِّنَّا وَبَرَكَٰتٍ عَلَيْكَ وَعَلَىٰٓ أُمَمٍۢ مِّمَّن مَّعَكَ ۚ وَأُمَمٌۭ سَنُمَتِّعُهُمْ ثُمَّ يَمَسُّهُم مِّنَّا عَذَابٌ أَلِيمٌۭ","translation":"[Thereupon] the word was spoken: \"O Noah! Disembark in peace from Us, and with [Our] blessings upon thee as well as upon the people [who are with thee, and the righteous ones that will spring from thee and] from those who are with thee. But [as for the unrighteous] folk [that will spring from you] - We shall allow them to enjoy life [for a little while], and then there will befall them grievous suffering from Us.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1521.mp3","surahId":11,"words":[{"id":47425,"position":1,"arabic":"قِيلَ","translation":"বলা হলো","audioUrl":"wbw/011_048_001.mp3","charTypeName":"word"},{"id":47426,"position":2,"arabic":"يَـٰنُوحُ","translation":"\"হে নূহ","audioUrl":"wbw/011_048_002.mp3","charTypeName":"word"},{"id":47427,"position":3,"arabic":"ٱهْبِطْ","translation":"অবতরণ করো","audioUrl":"wbw/011_048_003.mp3","charTypeName":"word"},{"id":47428,"position":4,"arabic":"بِسَلَـٰمٍۢ","translation":"শান্তিসহ","audioUrl":"wbw/011_048_004.mp3","charTypeName":"word"},{"id":47429,"position":5,"arabic":"مِّنَّا","translation":"আমাদের পক্ষ হ'তে","audioUrl":"wbw/011_048_005.mp3","charTypeName":"word"},{"id":47430,"position":6,"arabic":"وَبَرَكَـٰتٍ","translation":"ও কল্যাণ (সহ)","audioUrl":"wbw/011_048_006.mp3","charTypeName":"word"},{"id":47431,"position":7,"arabic":"عَلَيْكَ","translation":"তোমার উপর","audioUrl":"wbw/011_048_007.mp3","charTypeName":"word"},{"id":47432,"position":8,"arabic":"وَعَلَىٰٓ","translation":"এবং উপর","audioUrl":"wbw/011_048_008.mp3","charTypeName":"word"},{"id":47433,"position":9,"arabic":"أُمَمٍۢ","translation":"(সে সব) সম্প্রদায়ের","audioUrl":"wbw/011_048_009.mp3","charTypeName":"word"},{"id":47434,"position":10,"arabic":"مِّمَّن","translation":"তাদের মধ্যে যারা","audioUrl":"wbw/011_048_010.mp3","charTypeName":"word"},{"id":47435,"position":11,"arabic":"مَّعَكَ ۚ","translation":"তোমার সাথে (আছে)","audioUrl":"wbw/011_048_011.mp3","charTypeName":"word"},{"id":47437,"position":12,"arabic":"وَأُمَمٌۭ","translation":"ও অন্য কিছু সম্প্রদায়","audioUrl":"wbw/011_048_013.mp3","charTypeName":"word"},{"id":47438,"position":13,"arabic":"سَنُمَتِّعُهُمْ","translation":"তাদের আমরা জীবনোপকরণ দিবো","audioUrl":"wbw/011_048_014.mp3","charTypeName":"word"},{"id":47439,"position":14,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/011_048_015.mp3","charTypeName":"word"},{"id":47440,"position":15,"arabic":"يَمَسُّهُم","translation":"তাদের স্পর্শ করবে","audioUrl":"wbw/011_048_016.mp3","charTypeName":"word"},{"id":47441,"position":16,"arabic":"مِّنَّا","translation":"আমাদের পক্ষ হ'তে","audioUrl":"wbw/011_048_017.mp3","charTypeName":"word"},{"id":47442,"position":17,"arabic":"عَذَابٌ","translation":"শাস্তি","audioUrl":"wbw/011_048_018.mp3","charTypeName":"word"},{"id":47443,"position":18,"arabic":"أَلِيمٌۭ","translation":"নিদারুণ\"","audioUrl":"wbw/011_048_019.mp3","charTypeName":"word"},{"id":47444,"position":19,"arabic":"٤٨","translation":"(৪৮)","audioUrl":null,"charTypeName":"end"}]},{"number":49,"arabic":"تِلْكَ مِنْ أَنۢبَآءِ ٱلْغَيْبِ نُوحِيهَآ إِلَيْكَ ۖ مَا كُنتَ تَعْلَمُهَآ أَنتَ وَلَا قَوْمُكَ مِن قَبْلِ هَٰذَا ۖ فَٱصْبِرْ ۖ إِنَّ ٱلْعَٰقِبَةَ لِلْمُتَّقِينَ","translation":"THESE ACCOUNTS of something that was beyond the reach of thy perception We [now] reveal unto thee, [O Muhammad: for] neither thou nor thy people knew them [fully] ere this. Be, then, [like Noah,] patient in adversity - for, behold, the future belongs to the God-conscious!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1522.mp3","surahId":11,"words":[{"id":48119,"position":1,"arabic":"تِلْكَ","translation":"(হে নাবী) এই","audioUrl":"wbw/011_049_001.mp3","charTypeName":"word"},{"id":48120,"position":2,"arabic":"مِنْ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/011_049_002.mp3","charTypeName":"word"},{"id":48121,"position":3,"arabic":"أَنۢبَآءِ","translation":"সংবাদ সমূহ","audioUrl":"wbw/011_049_003.mp3","charTypeName":"word"},{"id":48122,"position":4,"arabic":"ٱلْغَيْبِ","translation":"অদৃশ্যের","audioUrl":"wbw/011_049_004.mp3","charTypeName":"word"},{"id":48123,"position":5,"arabic":"نُوحِيهَآ","translation":"যা ওহী করছি আমরা","audioUrl":"wbw/011_049_005.mp3","charTypeName":"word"},{"id":48124,"position":6,"arabic":"إِلَيْكَ ۖ","translation":"তোমার প্রতি","audioUrl":"wbw/011_049_006.mp3","charTypeName":"word"},{"id":48126,"position":7,"arabic":"مَا","translation":"না","audioUrl":"wbw/011_049_008.mp3","charTypeName":"word"},{"id":48127,"position":8,"arabic":"كُنتَ","translation":"তুমি ছিলে","audioUrl":"wbw/011_049_009.mp3","charTypeName":"word"},{"id":48128,"position":9,"arabic":"تَعْلَمُهَآ","translation":"তা জানতে","audioUrl":"wbw/011_049_010.mp3","charTypeName":"word"},{"id":48129,"position":10,"arabic":"أَنتَ","translation":"তুমি","audioUrl":"wbw/011_049_011.mp3","charTypeName":"word"},{"id":48130,"position":11,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/011_049_012.mp3","charTypeName":"word"},{"id":48131,"position":12,"arabic":"قَوْمُكَ","translation":"তোমার জাতি","audioUrl":"wbw/011_049_013.mp3","charTypeName":"word"},{"id":48132,"position":13,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/011_049_014.mp3","charTypeName":"word"},{"id":48133,"position":14,"arabic":"قَبْلِ","translation":"পূর্বে","audioUrl":"wbw/011_049_015.mp3","charTypeName":"word"},{"id":48134,"position":15,"arabic":"هَـٰذَا ۖ","translation":"এটার","audioUrl":"wbw/011_049_016.mp3","charTypeName":"word"},{"id":48136,"position":16,"arabic":"فَٱصْبِرْ ۖ","translation":"অতএব ধৈর্য ধরো","audioUrl":"wbw/011_049_018.mp3","charTypeName":"word"},{"id":48138,"position":17,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/011_049_020.mp3","charTypeName":"word"},{"id":48139,"position":18,"arabic":"ٱلْعَـٰقِبَةَ","translation":"(শুভ) পরিণাম","audioUrl":"wbw/011_049_021.mp3","charTypeName":"word"},{"id":48140,"position":19,"arabic":"لِلْمُتَّقِينَ","translation":"মুত্তাকীদের জন্যে\"","audioUrl":"wbw/011_049_022.mp3","charTypeName":"word"},{"id":48141,"position":20,"arabic":"٤٩","translation":"(৪৯)","audioUrl":null,"charTypeName":"end"}]},{"number":50,"arabic":"وَإِلَىٰ عَادٍ أَخَاهُمْ هُودًۭا ۚ قَالَ يَٰقَوْمِ ٱعْبُدُوا۟ ٱللَّهَ مَا لَكُم مِّنْ إِلَٰهٍ غَيْرُهُۥٓ ۖ إِنْ أَنتُمْ إِلَّا مُفْتَرُونَ","translation":"AND UNTO [the tribe of] `Ad [We sent] their brother Hud. He said: \"O my people! Worship God [alone]: you have no deity other than Him. [As it is,] you are but inventors of falsehood!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1523.mp3","surahId":11,"words":[{"id":48806,"position":1,"arabic":"وَإِلَىٰ","translation":"এবং প্রতি","audioUrl":"wbw/011_050_001.mp3","charTypeName":"word"},{"id":48807,"position":2,"arabic":"عَادٍ","translation":"আদ-এর","audioUrl":"wbw/011_050_002.mp3","charTypeName":"word"},{"id":48808,"position":3,"arabic":"أَخَاهُمْ","translation":"তাদের ভাই","audioUrl":"wbw/011_050_003.mp3","charTypeName":"word"},{"id":48809,"position":4,"arabic":"هُودًۭا ۚ","translation":"হূদকে (পাঠিয়েছিলাম)","audioUrl":"wbw/011_050_004.mp3","charTypeName":"word"},{"id":48811,"position":5,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/011_050_006.mp3","charTypeName":"word"},{"id":48812,"position":6,"arabic":"يَـٰقَوْمِ","translation":"\"হে আমার জাতি","audioUrl":"wbw/011_050_007.mp3","charTypeName":"word"},{"id":48813,"position":7,"arabic":"ٱعْبُدُوا۟","translation":"তোমরা ইবাদত করো","audioUrl":"wbw/011_050_008.mp3","charTypeName":"word"},{"id":48814,"position":8,"arabic":"ٱللَّهَ","translation":"আল্লাহর","audioUrl":"wbw/011_050_009.mp3","charTypeName":"word"},{"id":48815,"position":9,"arabic":"مَا","translation":"নেই","audioUrl":"wbw/011_050_010.mp3","charTypeName":"word"},{"id":48816,"position":10,"arabic":"لَكُم","translation":"তোমাদের জন্যে","audioUrl":"wbw/011_050_011.mp3","charTypeName":"word"},{"id":48817,"position":11,"arabic":"مِّنْ","translation":"কোন","audioUrl":"wbw/011_050_012.mp3","charTypeName":"word"},{"id":48818,"position":12,"arabic":"إِلَـٰهٍ","translation":"ইলাহ","audioUrl":"wbw/011_050_013.mp3","charTypeName":"word"},{"id":48819,"position":13,"arabic":"غَيْرُهُۥٓ ۖ","translation":"তিনি ছাড়া","audioUrl":"wbw/011_050_014.mp3","charTypeName":"word"},{"id":48821,"position":14,"arabic":"إِنْ","translation":"নও","audioUrl":"wbw/011_050_016.mp3","charTypeName":"word"},{"id":48822,"position":15,"arabic":"أَنتُمْ","translation":"তোমরা","audioUrl":"wbw/011_050_017.mp3","charTypeName":"word"},{"id":48823,"position":16,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/011_050_018.mp3","charTypeName":"word"},{"id":48824,"position":17,"arabic":"مُفْتَرُونَ","translation":"মিথ্যারচনাকারী","audioUrl":"wbw/011_050_019.mp3","charTypeName":"word"},{"id":48825,"position":18,"arabic":"٥٠","translation":"(৫০)","audioUrl":null,"charTypeName":"end"}]},{"number":51,"arabic":"يَٰقَوْمِ لَآ أَسْـَٔلُكُمْ عَلَيْهِ أَجْرًا ۖ إِنْ أَجْرِىَ إِلَّا عَلَى ٱلَّذِى فَطَرَنِىٓ ۚ أَفَلَا تَعْقِلُونَ","translation":"\"O my people! No reward do I ask of you for this [message]: my reward rests with none but Him who brought me into being. Will you not, then, use your reason?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1524.mp3","surahId":11,"words":[{"id":49363,"position":1,"arabic":"يَـٰقَوْمِ","translation":"হে আমার জাতি","audioUrl":"wbw/011_051_001.mp3","charTypeName":"word"},{"id":49364,"position":2,"arabic":"لَآ","translation":"না","audioUrl":"wbw/011_051_002.mp3","charTypeName":"word"},{"id":49365,"position":3,"arabic":"أَسْـَٔلُكُمْ","translation":"তোমাদের কাছে আমি চাই","audioUrl":"wbw/011_051_003.mp3","charTypeName":"word"},{"id":49366,"position":4,"arabic":"عَلَيْهِ","translation":"এর বিনিময়ে","audioUrl":"wbw/011_051_004.mp3","charTypeName":"word"},{"id":49367,"position":5,"arabic":"أَجْرًا ۖ","translation":"কোন পারিশ্রামিক","audioUrl":"wbw/011_051_005.mp3","charTypeName":"word"},{"id":49369,"position":6,"arabic":"إِنْ","translation":"নেই","audioUrl":"wbw/011_051_007.mp3","charTypeName":"word"},{"id":49370,"position":7,"arabic":"أَجْرِىَ","translation":"আমার পারিশ্রমিক","audioUrl":"wbw/011_051_008.mp3","charTypeName":"word"},{"id":49371,"position":8,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/011_051_009.mp3","charTypeName":"word"},{"id":49372,"position":9,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/011_051_010.mp3","charTypeName":"word"},{"id":49373,"position":10,"arabic":"ٱلَّذِى","translation":"(তাঁর) যিনি","audioUrl":"wbw/011_051_011.mp3","charTypeName":"word"},{"id":49374,"position":11,"arabic":"فَطَرَنِىٓ ۚ","translation":"আমাকে সৃষ্টি করেছেন","audioUrl":"wbw/011_051_012.mp3","charTypeName":"word"},{"id":49376,"position":12,"arabic":"أَفَلَا","translation":"তবুও কি না","audioUrl":"wbw/011_051_014.mp3","charTypeName":"word"},{"id":49377,"position":13,"arabic":"تَعْقِلُونَ","translation":"তোমরা বুদ্ধি কাজে লাগাবে","audioUrl":"wbw/011_051_015.mp3","charTypeName":"word"},{"id":49378,"position":14,"arabic":"٥١","translation":"(৫১)","audioUrl":null,"charTypeName":"end"}]},{"number":52,"arabic":"وَيَٰقَوْمِ ٱسْتَغْفِرُوا۟ رَبَّكُمْ ثُمَّ تُوبُوٓا۟ إِلَيْهِ يُرْسِلِ ٱلسَّمَآءَ عَلَيْكُم مِّدْرَارًۭا وَيَزِدْكُمْ قُوَّةً إِلَىٰ قُوَّتِكُمْ وَلَا تَتَوَلَّوْا۟ مُجْرِمِينَ","translation":"\"Hence, O my people, ask your Sustainer to forgive you your sins, and then turn towards Him in repentance-[whereupon] He will shower upon you heavenly blessings abundant, and will add strength to your strength: only do not turn away [from me] as people lost in sin!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1525.mp3","surahId":11,"words":[{"id":50103,"position":1,"arabic":"وَيَـٰقَوْمِ","translation":"এবং হে আমার জাতি","audioUrl":"wbw/011_052_001.mp3","charTypeName":"word"},{"id":50104,"position":2,"arabic":"ٱسْتَغْفِرُوا۟","translation":"তোমরা ক্ষমা চাও","audioUrl":"wbw/011_052_002.mp3","charTypeName":"word"},{"id":50105,"position":3,"arabic":"رَبَّكُمْ","translation":"তোমাদের রবের (কাছে)","audioUrl":"wbw/011_052_003.mp3","charTypeName":"word"},{"id":50106,"position":4,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/011_052_004.mp3","charTypeName":"word"},{"id":50107,"position":5,"arabic":"تُوبُوٓا۟","translation":"ফিরে এসো তোমরা","audioUrl":"wbw/011_052_005.mp3","charTypeName":"word"},{"id":50108,"position":6,"arabic":"إِلَيْهِ","translation":"তাঁরই দিকে","audioUrl":"wbw/011_052_006.mp3","charTypeName":"word"},{"id":50109,"position":7,"arabic":"يُرْسِلِ","translation":"তিনি প্রেরণ করবেন","audioUrl":"wbw/011_052_007.mp3","charTypeName":"word"},{"id":50110,"position":8,"arabic":"ٱلسَّمَآءَ","translation":"আকাশ থেকে (বৃষ্টি)","audioUrl":"wbw/011_052_008.mp3","charTypeName":"word"},{"id":50111,"position":9,"arabic":"عَلَيْكُم","translation":"তোমাদের উপর","audioUrl":"wbw/011_052_009.mp3","charTypeName":"word"},{"id":50112,"position":10,"arabic":"مِّدْرَارًۭا","translation":"মুষলধারে","audioUrl":"wbw/011_052_010.mp3","charTypeName":"word"},{"id":50113,"position":11,"arabic":"وَيَزِدْكُمْ","translation":"এবং তোমাদের বৃদ্ধি করবেন","audioUrl":"wbw/011_052_011.mp3","charTypeName":"word"},{"id":50114,"position":12,"arabic":"قُوَّةً","translation":"শক্তি","audioU