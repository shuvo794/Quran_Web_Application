006.mp3","charTypeName":"word"},{"id":50667,"position":7,"arabic":"نَحْنُ","translation":"আমরা","audioUrl":"wbw/011_053_007.mp3","charTypeName":"word"},{"id":50668,"position":8,"arabic":"بِتَارِكِىٓ","translation":"পরিত্যাগকারী","audioUrl":"wbw/011_053_008.mp3","charTypeName":"word"},{"id":50669,"position":9,"arabic":"ءَالِهَتِنَا","translation":"আমাদের উপাস্যদেরকে","audioUrl":"wbw/011_053_009.mp3","charTypeName":"word"},{"id":50670,"position":10,"arabic":"عَن","translation":"কারণে","audioUrl":"wbw/011_053_010.mp3","charTypeName":"word"},{"id":50671,"position":11,"arabic":"قَوْلِكَ","translation":"তোমার কথার","audioUrl":"wbw/011_053_011.mp3","charTypeName":"word"},{"id":50672,"position":12,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/011_053_012.mp3","charTypeName":"word"},{"id":50673,"position":13,"arabic":"نَحْنُ","translation":"আমরা","audioUrl":"wbw/011_053_013.mp3","charTypeName":"word"},{"id":50674,"position":14,"arabic":"لَكَ","translation":"তোমার প্রতি","audioUrl":"wbw/011_053_014.mp3","charTypeName":"word"},{"id":50675,"position":15,"arabic":"بِمُؤْمِنِينَ","translation":"বিশ্বাসী","audioUrl":"wbw/011_053_015.mp3","charTypeName":"word"},{"id":50676,"position":16,"arabic":"٥٣","translation":"(৫৩)","audioUrl":null,"charTypeName":"end"}]}]}