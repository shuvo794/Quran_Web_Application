{"id":261,"ayahs":[{"number":43,"arabic":"مُهْطِعِينَ مُقْنِعِى رُءُوسِهِمْ لَا يَرْتَدُّ إِلَيْهِمْ طَرْفُهُمْ ۖ وَأَفْـِٔدَتُهُمْ هَوَآءٌۭ","translation":"the while they will be running confusedly to and fro, with their heads upraised [in supplication], unable to look away from what they shall behold, and their hearts an abysmal void.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1793.mp3","surahId":14,"words":[{"id":44061,"position":1,"arabic":"مُهْطِعِينَ","translation":"ছুটোছুটি করবে","audioUrl":"wbw/014_043_001.mp3","charTypeName":"word"},{"id":44062,"position":2,"arabic":"مُقْنِعِى","translation":"উত্তোলনকারী হয়ে","audioUrl":"wbw/014_043_002.mp3","charTypeName":"word"},{"id":44063,"position":3,"arabic":"رُءُوسِهِمْ","translation":"তাদের মাথাগুলো","audioUrl":"wbw/014_043_003.mp3","charTypeName":"word"},{"id":44064,"position":4,"arabic":"لَا","translation":"না","audioUrl":"wbw/014_043_004.mp3","charTypeName":"word"},{"id":44065,"position":5,"arabic":"يَرْتَدُّ","translation":"ফিরবে","audioUrl":"wbw/014_043_005.mp3","charTypeName":"word"},{"id":44066,"position":6,"arabic":"إِلَيْهِمْ","translation":"তাদের দিকে","audioUrl":"wbw/014_043_006.mp3","charTypeName":"word"},{"id":44067,"position":7,"arabic":"طَرْفُهُمْ ۖ","translation":"তাদের পলক","audioUrl":"wbw/014_043_007.mp3","charTypeName":"word"},{"id":44069,"position":8,"arabic":"وَأَفْـِٔدَتُهُمْ","translation":"এবং তাদের অন্তরগুলো (হবে)","audioUrl":"wbw/014_043_009.mp3","charTypeName":"word"},{"id":44070,"position":9,"arabic":"هَوَآءٌۭ","translation":"(আশা) শূন্য","audioUrl":"wbw/014_043_010.mp3","charTypeName":"word"},{"id":44071,"position":10,"arabic":"٤٣","translation":"(৪৩)","audioUrl":null,"charTypeName":"end"}]},{"number":44,"arabic":"وَأَنذِرِ ٱلنَّاسَ يَوْمَ يَأْتِيهِمُ ٱلْعَذَابُ فَيَقُولُ ٱلَّذِينَ ظَلَمُوا۟ رَبَّنَآ أَخِّرْنَآ إِلَىٰٓ أَجَلٍۢ قَرِيبٍۢ نُّجِبْ دَعْوَتَكَ وَنَتَّبِعِ ٱلرُّسُلَ ۗ أَوَلَمْ تَكُونُوٓا۟ أَقْسَمْتُم مِّن قَبْلُ مَا لَكُم مِّن زَوَالٍۢ","translation":"Hence, warn men of the Day when this suffering may befall them, and when those who did wrong [in their lifetime] will exclaim: \"O our Sustainer! Grant us respite for a short while, so that we might respond to Thy call and follow the apostles!\" [But God will answer:] \"Why - were you not aforetime wont to swear that no kind of resurrection and retribution awaited you?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1794.mp3","surahId":14,"words":[{"id":44346,"position":1,"arabic":"وَأَنذِرِ","translation":"এবং সতর্ক করো","audioUrl":"wbw/014_044_001.mp3","charTypeName":"word"},{"id":44347,"position":2,"arabic":"ٱلنَّاسَ","translation":"মানুষকে","audioUrl":"wbw/014_044_002.mp3","charTypeName":"word"},{"id":44348,"position":3,"arabic":"يَوْمَ","translation":"সেদিনের","audioUrl":"wbw/014_044_003.mp3","charTypeName":"word"},{"id":44349,"position":4,"arabic":"يَأْتِيهِمُ","translation":"তাদের আসবে","audioUrl":"wbw/014_044_004.mp3","charTypeName":"word"},{"id":44350,"position":5,"arabic":"ٱلْعَذَابُ","translation":"শাস্তি","audioUrl":"wbw/014_044_005.mp3","charTypeName":"word"},{"id":44351,"position":6,"arabic":"فَيَقُولُ","translation":"তখন বলবে","audioUrl":"wbw/014_044_006.mp3","charTypeName":"word"},{"id":44352,"position":7,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/014_044_007.mp3","charTypeName":"word"},{"id":44353,"position":8,"arabic":"ظَلَمُوا۟","translation":"সীমালঙ্ঘন করেছিলো","audioUrl":"wbw/014_044_008.mp3","charTypeName":"word"},{"id":44354,"position":9,"arabic":"رَبَّنَآ","translation":"\"হে আমাদের রব","audioUrl":"wbw/014_044_009.mp3","charTypeName":"word"},{"id":44355,"position":10,"arabic":"أَخِّرْنَآ","translation":"আমাদের অবকাশ দিন","audioUrl":"wbw/014_044_010.mp3","charTypeName":"word"},{"id":44356,"position":11,"arabic":"إِلَىٰٓ","translation":"পর্যন্ত","audioUrl":"wbw/014_044_011.mp3","charTypeName":"word"},{"id":44357,"position":12,"arabic":"أَجَلٍۢ","translation":"(কিছু) কাল","audioUrl":"wbw/014_044_012.mp3","charTypeName":"word"},{"id":44358,"position":13,"arabic":"قَرِيبٍۢ","translation":"নিকটবর্তী","audioUrl":"wbw/014_044_013.mp3","charTypeName":"word"},{"id":44359,"position":14,"arabic":"نُّجِبْ","translation":"আমরা সাড়া দিবো","audioUrl":"wbw/014_044_014.mp3","charTypeName":"word"},{"id":44360,"position":15,"arabic":"دَعْوَتَكَ","translation":"তোমার ডাকে","audioUrl":"wbw/014_044_015.mp3","charTypeName":"word"},{"id":44361,"position":16,"arabic":"وَنَتَّبِعِ","translation":"ও আমরা অনুসরণ করবো","audioUrl":"wbw/014_044_016.mp3","charTypeName":"word"},{"id":44362,"position":17,"arabic":"ٱلرُّسُلَ ۗ","translation":"রাসূলদের\"","audioUrl":"wbw/014_044_017.mp3","charTypeName":"word"},{"id":44364,"position":18,"arabic":"أَوَلَمْ","translation":"\"কি না","audioUrl":"wbw/014_044_019.mp3","charTypeName":"word"},{"id":44365,"position":19,"arabic":"تَكُونُوٓا۟","translation":"করতে তোমরা ছিলে","audioUrl":"wbw/014_044_020.mp3","charTypeName":"word"},{"id":44366,"position":20,"arabic":"أَقْسَمْتُم","translation":"তোমরা শপথ","audioUrl":"wbw/014_044_021.mp3","charTypeName":"word"},{"id":44367,"position":21,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/014_044_022.mp3","charTypeName":"word"},{"id":44368,"position":22,"arabic":"قَبْلُ","translation":"আগে","audioUrl":"wbw/014_044_023.mp3","charTypeName":"word"},{"id":44369,"position":23,"arabic":"مَا","translation":"নেই","audioUrl":"wbw/014_044_024.mp3","charTypeName":"word"},{"id":44370,"position":24,"arabic":"لَكُم","translation":"তোমাদের জন্যে","audioUrl":"wbw/014_044_025.mp3","charTypeName":"word"},{"id":44371,"position":25,"arabic":"مِّن","translation":"কোনো","audioUrl":"wbw/014_044_026.mp3","charTypeName":"word"},{"id":44372,"position":26,"arabic":"زَوَالٍۢ","translation":"পতন","audioUrl":"wbw/014_044_027.mp3","charTypeName":"word"},{"id":44373,"position":27,"arabic":"٤٤","translation":"(৪৪)","audioUrl":null,"charTypeName":"end"}]},{"number":45,"arabic":"وَسَكَنتُمْ فِى مَسَٰكِنِ ٱلَّذِينَ ظَلَمُوٓا۟ أَنفُسَهُمْ وَتَبَيَّنَ لَكُمْ كَيْفَ فَعَلْنَا بِهِمْ وَضَرَبْنَا لَكُمُ ٱلْأَمْثَالَ","translation":"And yet, you dwelt in the dwelling-places of those who had sinned against their own selves [before your time], and it was made obvious to you how We had dealt with them: for We have set forth unto you many a parable [of sin, resurrection and divine retribution].\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1795.mp3","surahId":14,"words":[{"id":45508,"position":1,"arabic":"وَسَكَنتُمْ","translation":"এবং তোমরা বসবাস করছিলে","audioUrl":"wbw/014_045_001.mp3","charTypeName":"word"},{"id":45509,"position":2,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/014_045_002.mp3","charTypeName":"word"},{"id":45510,"position":3,"arabic":"مَسَـٰكِنِ","translation":"বাসভূমিসমূহের","audioUrl":"wbw/014_045_003.mp3","charTypeName":"word"},{"id":45511,"position":4,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/014_045_004.mp3","charTypeName":"word"},{"id":45512,"position":5,"arabic":"ظَلَمُوٓا۟","translation":"সীমালঙ্ঘন করেছিলো","audioUrl":"wbw/014_045_005.mp3","charTypeName":"word"},{"id":45513,"position":6,"arabic":"أَنفُسَهُمْ","translation":"তাদের নিজেদের উপর","audioUrl":"wbw/014_045_006.mp3","charTypeName":"word"},{"id":45514,"position":7,"arabic":"وَتَبَيَّنَ","translation":"অথচ  স্পষ্ট ছিলো","audioUrl":"wbw/014_045_007.mp3","charTypeName":"word"},{"id":45515,"position":8,"arabic":"لَكُمْ","translation":"কাছে তোমাদের","audioUrl":"wbw/014_045_008.mp3","charTypeName":"word"},{"id":45516,"position":9,"arabic":"كَيْفَ","translation":"কেমন (আচরণ)","audioUrl":"wbw/014_045_009.mp3","charTypeName":"word"},{"id":45517,"position":10,"arabic":"فَعَلْنَا","translation":"আমরা করেছিলাম","audioUrl":"wbw/014_045_010.mp3","charTypeName":"word"},{"id":45518,"position":11,"arabic":"بِهِمْ","translation":"সাথে তাদের","audioUrl":"wbw/014_045_011.mp3","charTypeName":"word"},{"id":45519,"position":12,"arabic":"وَضَرَبْنَا","translation":"এবং আমরা বর্ণনা করেছি","audioUrl":"wbw/014_045_012.mp3","charTypeName":"word"},{"id":45520,"position":13,"arabic":"لَكُمُ","translation":"জন্যে তোমাদের","audioUrl":"wbw/014_045_013.mp3","charTypeName":"word"},{"id":45521,"position":14,"arabic":"ٱلْأَمْثَالَ","translation":"দৃষ্টান্তসমূহ\"","audioUrl":"wbw/014_045_014.mp3","charTypeName":"word"},{"id":45522,"position":15,"arabic":"٤٥","translation":"(৪৫)","audioUrl":null,"charTypeName":"end"}]},{"number":46,"arabic":"وَقَدْ مَكَرُوا۟ مَكْرَهُمْ وَعِندَ ٱللَّهِ مَكْرُهُمْ وَإِن كَانَ مَكْرُهُمْ لِتَزُولَ مِنْهُ ٱلْجِبَالُ","translation":"And [this retribution will befall all evildoers because] they devise that false imagery of theirs - and all their false imagery is within God's knowledge. [And never can the blasphemers prevail against the truth - not] even if their false imagery were so (well devised and so powerful] that mountains could be moved thereby.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1796.mp3","surahId":14,"words":[{"id":46229,"position":1,"arabic":"وَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/014_046_001.mp3","charTypeName":"word"},{"id":46230,"position":2,"arabic":"مَكَرُوا۟","translation":"তারা চক্রান্ত করেছিলো","audioUrl":"wbw/014_046_002.mp3","charTypeName":"word"},{"id":46231,"position":3,"arabic":"مَكْرَهُمْ","translation":"তাদের চক্রান্ত","audioUrl":"wbw/014_046_003.mp3","charTypeName":"word"},{"id":46232,"position":4,"arabic":"وَعِندَ","translation":"কিন্তু কাছে","audioUrl":"wbw/014_046_004.mp3","charTypeName":"word"},{"id":46233,"position":5,"arabic":"ٱللَّهِ","translation":"আল্লাহর (ছিলো)","audioUrl":"wbw/014_046_005.mp3","charTypeName":"word"},{"id":46234,"position":6,"arabic":"مَكْرُهُمْ","translation":"তাদের চক্রান্ত","audioUrl":"wbw/014_046_006.mp3","charTypeName":"word"},{"id":46235,"position":7,"arabic":"وَإِن","translation":"এবং যদিও","audioUrl":"wbw/014_046_007.mp3","charTypeName":"word"},{"id":46236,"position":8,"arabic":"كَانَ","translation":"ছিলো","audioUrl":"wbw/014_046_008.mp3","charTypeName":"word"},{"id":46237,"position":9,"arabic":"مَكْرُهُمْ","translation":"তাদের চক্রান্ত (এমন ভয়ানক)","audioUrl":"wbw/014_046_009.mp3","charTypeName":"word"},{"id":46238,"position":10,"arabic":"لِتَزُولَ","translation":"যেন টলে যেতো","audioUrl":"wbw/014_046_010.mp3","charTypeName":"word"},{"id":46239,"position":11,"arabic":"مِنْهُ","translation":"তা থেকে","audioUrl":"wbw/014_046_011.mp3","charTypeName":"word"},{"id":46240,"position":12,"arabic":"ٱلْجِبَالُ","translation":"পর্বতসমূহ","audioUrl":"wbw/014_046_012.mp3","charTypeName":"word"},{"id":46241,"position":13,"arabic":"٤٦","translation":"(৪৬)","audioUrl":null,"charTypeName":"end"}]},{"number":47,"arabic":"فَلَا تَحْسَبَنَّ ٱللَّهَ مُخْلِفَ وَعْدِهِۦ رُسُلَهُۥٓ ۗ إِنَّ ٱللَّهَ عَزِيزٌۭ ذُو ٱنتِقَامٍۢ","translation":"HENCE, do not think that God will fail to fulfil the promise which He gave to His apostles: verily, God is almighty, an avenger of evil!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1797.mp3","surahId":14,"words":[{"id":46898,"position":1,"arabic":"فَلَا","translation":"অতএব না","audioUrl":"wbw/014_047_001.mp3","charTypeName":"word"},{"id":46899,"position":2,"arabic":"تَحْسَبَنَّ","translation":"নিশ্চয়ই তুমি মনে করবে","audioUrl":"wbw/014_047_002.mp3","charTypeName":"word"},{"id":46900,"position":3,"arabic":"ٱللَّهَ","translation":"আল্লাহকে","audioUrl":"wbw/014_047_003.mp3","charTypeName":"word"},{"id":46901,"position":4,"arabic":"مُخْلِفَ","translation":"ভঙ্গকারী","audioUrl":"wbw/014_047_004.mp3","charTypeName":"word"},{"id":46902,"position":5,"arabic":"وَعْدِهِۦ","translation":"তাঁর প্রতিশ্রুতি","audioUrl":"wbw/014_047_005.mp3","charTypeName":"word"},{"id":46903,"position":6,"arabic":"رُسُلَهُۥٓ ۗ","translation":"তাঁর রাসূলদের (কাছে)","audioUrl":"wbw/014_047_006.mp3","charTypeName":"word"},{"id":46905,"position":7,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/014_047_008.mp3","charTypeName":"word"},{"id":46906,"position":8,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/014_047_009.mp3","charTypeName":"word"},{"id":46907,"position":9,"arabic":"عَزِيزٌۭ","translation":"পরাক্রমশালী","audioUrl":"wbw/014_047_010.mp3","charTypeName":"word"},{"id":46908,"position":10,"arabic":"ذُو","translation":"সমর্থ","audioUrl":"wbw/014_047_011.mp3","charTypeName":"word"},{"id":46909,"position":11,"arabic":"ٱنتِقَامٍۢ","translation":"প্রতিশোধ গ্রহণে","audioUrl":"wbw/014_047_012.mp3","charTypeName":"word"},{"id":46910,"position":12,"arabic":"٤٧","translation":"(৪৭)","audioUrl":null,"charTypeName":"end"}]},{"number":48,"arabic":"يَوْمَ تُبَدَّلُ ٱلْأَرْضُ غَيْرَ ٱلْأَرْضِ وَٱلسَّمَٰوَٰتُ ۖ وَبَرَزُوا۟ لِلَّهِ ٱلْوَٰحِدِ ٱلْقَهَّارِ","translation":"[His promise will be fulfilled] on the Day when the earth shall be changed into another earth, as shall be the heavens and when [all men] shall appear before God, the One who holds absolute sway over all that exists.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1798.mp3","surahId":14,"words":[{"id":47634,"position":1,"arabic":"يَوْمَ","translation":"সেদিন","audioUrl":"wbw/014_048_001.mp3","charTypeName":"word"},{"id":47635,"position":2,"arabic":"تُبَدَّلُ","translation":"পরিবর্তিত হবে","audioUrl":"wbw/014_048_002.mp3","charTypeName":"word"},{"id":47636,"position":3,"arabic":"ٱلْأَرْضُ","translation":"(এই) পৃথিবী","audioUrl":"wbw/014_048_003.mp3","charTypeName":"word"},{"id":47637,"position":4,"arabic":"غَيْرَ","translation":"অন্য","audioUrl":"wbw/014_048_004.mp3","charTypeName":"word"},{"id":47638,"position":5,"arabic":"ٱلْأَرْضِ","translation":"পৃৃথিবীতে","audioUrl":"wbw/014_048_005.mp3","charTypeName":"word"},{"id":47639,"position":6,"arabic":"وَٱلسَّمَـٰوَٰتُ ۖ","translation":"এবং আকাশমন্ডলী","audioUrl":"wbw/014_048_006.mp3","charTypeName":"word"},{"id":47641,"position":7,"arabic":"وَبَرَزُوا۟","translation":"এবং উপস্থিত হবে (উন্মোচিত হবে)","audioUrl":"wbw/014_048_008.mp3","charTypeName":"word"},{"id":47642,"position":8,"arabic":"لِلَّهِ","translation":"আল্লাহর কাছে","audioUrl":"wbw/014_048_009.mp3","charTypeName":"word"},{"id":47643,"position":9,"arabic":"ٱلْوَٰحِدِ","translation":"(যিনি) এক","audioUrl":"wbw/014_048_010.mp3","charTypeName":"word"},{"id":47644,"position":10,"arabic":"ٱلْقَهَّارِ","translation":"পরাক্রমশালী","audioUrl":"wbw/014_048_011.mp3","charTypeName":"word"},{"id":47645,"position":11,"arabic":"٤٨","translation":"(৪৮)","audioUrl":null,"charTypeName":"end"}]},{"number":49,"arabic":"وَتَرَى ٱلْمُجْرِمِينَ يَوْمَئِذٍۢ مُّقَرَّنِينَ فِى ٱلْأَصْفَادِ","translation":"For on that Day thou wilt see all who were lost in sin linked together in fetters,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1799.mp3","surahId":14,"words":[{"id":48290,"position":1,"arabic":"وَتَرَى","translation":"এবং তুমি দেখবে","audioUrl":"wbw/014_049_001.mp3","charTypeName":"word"},{"id":48291,"position":2,"arabic":"ٱلْمُجْرِمِينَ","translation":"অপরাধীদেরকে","audioUrl":"wbw/014_049_002.mp3","charTypeName":"word"},{"id":48292,"position":3,"arabic":"يَوْمَئِذٍۢ","translation":"সেদিন","audioUrl":"wbw/014_049_003.mp3","charTypeName":"word"},{"id":48293,"position":4,"arabic":"مُّقَرَّنِينَ","translation":"কঠোরভাবে বাঁধা","audioUrl":"wbw/014_049_004.mp3","charTypeName":"word"},{"id":48294,"position":5,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/014_049_005.mp3","charTypeName":"word"},{"id":48295,"position":6,"arabic":"ٱلْأَصْفَادِ","translation":"শেকলসমূহের","audioUrl":"wbw/014_049_006.mp3","charTypeName":"word"},{"id":48296,"position":7,"arabic":"٤٩","translation":"(৪৯)","audioUrl":null,"charTypeName":"end"}]},{"number":50,"arabic":"سَرَابِيلُهُم مِّن قَطِرَانٍۢ وَتَغْشَىٰ وُجُوهَهُمُ ٱلنَّارُ","translation":"clothed in garments of black pitch, with fire veiling their faces.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1800.mp3","surahId":14,"words":[{"id":48436,"position":1,"arabic":"سَرَابِيلُهُم","translation":"তাদের জামাসমূহ (হবে)","audioUrl":"wbw/014_050_001.mp3","charTypeName":"word"},{"id":48437,"position":2,"arabic":"مِّن","translation":"তৈরি","audioUrl":"wbw/014_050_002.mp3","charTypeName":"word"},{"id":48438,"position":3,"arabic":"قَطِرَانٍۢ","translation":"আলকাতরার","audioUrl":"wbw/014_050_003.mp3","charTypeName":"word"},{"id":48439,"position":4,"arabic":"وَتَغْشَىٰ","translation":"ও ছেয়ে ফেলবে","audioUrl":"wbw/014_050_004.mp3","charTypeName":"word"},{"id":48440,"position":5,"arabic":"وُجُوهَهُمُ","translation":"তাদের মুখসমূহকে","audioUrl":"wbw/014_050_005.mp3","charTypeName":"word"},{"id":48441,"position":6,"arabic":"ٱلنَّارُ","translation":"আগুন","audioUrl":"wbw/014_050_006.mp3","charTypeName":"word"},{"id":48442,"position":7,"arabic":"٥٠","translation":"(৫০)","audioUrl":null,"charTypeName":"end"}]},{"number":51,"arabic":"لِيَجْزِىَ ٱللَّهُ كُلَّ نَفْسٍۢ مَّا كَسَبَتْ ۚ إِنَّ ٱللَّهَ سَرِيعُ ٱلْحِسَابِ","translation":"[And all shall be judged on that Day,] so that God may requite every human being for all that he has earned [in life]: verily, God is swift in reckoning!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1801.mp3","surahId":14,"words":[{"id":49564,"position":1,"arabic":"لِيَجْزِىَ","translation":"যেন প্রতিফল দেন","audioUrl":"wbw/014_051_001.mp3","charTypeName":"word"},{"id":49565,"position":2,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/014_051_002.mp3","charTypeName":"word"},{"id":49566,"position":3,"arabic":"كُلَّ","translation":"প্রত্যেক","audioUrl":"wbw/014_051_003.mp3","charTypeName":"word"},{"id":49567,"position":4,"arabic":"نَفْسٍۢ","translation":"ব্যক্তিকে","audioUrl":"wbw/014_051_004.mp3","charTypeName":"word"},{"id":49568,"position":5,"arabic":"مَّا","translation":"যা","audioUrl":"wbw/014_051_005.mp3","charTypeName":"word"},{"id":49569,"position":6,"arabic":"كَسَبَتْ ۚ","translation":"সে উপার্জন করেছে","audioUrl":"wbw/014_051_006.mp3","charTypeName":"word"},{"id":49571,"position":7,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/014_051_008.mp3","charTypeName":"word"},{"id":49572,"position":8,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/014_051_009.mp3","charTypeName":"word"},{"id":49573,"position":9,"arabic":"سَرِيعُ","translation":"দ্রুত","audioUrl":"wbw/014_051_010.mp3","charTypeName":"word"},{"id":49574,"position":10,"arabic":"ٱلْحِسَابِ","translation":"হিসেব গ্রহণে","audioUrl":"wbw/014_051_011.mp3","charTypeName":"word"},{"id":49575,"position":11,"arabic":"٥١","translation":"(৫১)","audioUrl":null,"charTypeName":"end"}]},{"number":52,"arabic":"هَٰذَا بَلَٰغٌۭ لِّلنَّاسِ وَلِيُنذَرُوا۟ بِهِۦ وَلِيَعْلَمُوٓا۟ أَنَّمَا هُوَ إِلَٰهٌۭ وَٰحِدٌۭ وَلِيَذَّكَّرَ أُو۟لُوا۟ ٱلْأَلْبَٰبِ","translation":"THIS IS A MESSAGE unto all mankind. Hence, let them be warned thereby, and let them know that He is the One and Only God; and let those who are endowed with insight take this to heart!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1802.mp3","surahId":14,"words":[{"id":50238,"position":1,"arabic":"هَـٰذَا","translation":"এটা","audioUrl":"wbw/014_052_001.mp3","charTypeName":"word"},{"id":50239,"position":2,"arabic":"بَلَـٰغٌۭ","translation":"এক বার্তা","audioUrl":"wbw/014_052_002.mp3","charTypeName":"word"},{"id":50240,"position":3,"arabic":"لِّلنَّاسِ","translation":"মানুষের জন্যে","audioUrl":"wbw/014_052_003.mp3","charTypeName":"word"},{"id":50241,"position":4,"arabic":"وَلِيُنذَرُوا۟","translation":"এবং তাদের যেন সতর্ক করা হয়","audioUrl":"wbw/014_052_004.mp3","charTypeName":"word"},{"id":50242,"position":5,"arabic":"بِهِۦ","translation":"দিয়ে তা","audioUrl":"wbw/014_052_005.mp3","charTypeName":"word"},{"id":50243,"position":6,"arabic":"وَلِيَعْلَمُوٓا۟","translation":"এবং যেন তারা জানে","audioUrl":"wbw/014_052_006.mp3","charTypeName":"word"},{"id":50244,"position":7,"arabic":"أَنَّمَا","translation":"প্রকৃতপক্ষে","audioUrl":"wbw/014_052_007.mp3","charTypeName":"word"},{"id":50245,"position":8,"arabic":"هُوَ","translation":"তিনিই","audioUrl":"wbw/014_052_008.mp3","charTypeName":"word"},{"id":50246,"position":9,"arabic":"إِلَـٰهٌۭ","translation":"ইলাহ","audioUrl":"wbw/014_052_009.mp3","charTypeName":"word"},{"id":50247,"position":10,"arabic":"وَٰحِدٌۭ","translation":"একমাত্র","audioUrl":"wbw/014_052_010.mp3","charTypeName":"word"},{"id":50248,"position":11,"arabic":"وَلِيَذَّكَّرَ","translation":"ও যেন শিক্ষা গ্রহণ করে","audioUrl":"wbw/014_052_011.mp3","charTypeName":"word"},{"id":50249,"position":12,"arabic":"أُو۟لُوا۟","translation":"সম্পন্নরা","audioUrl":"wbw/014_052_012.mp3","charTypeName":"word"},{"id":50250,"position":13,"arabic":"ٱلْأَلْبَـٰبِ","translation":"বোধ (লোকেরা)","audioUrl":"wbw/014_052_013.mp3","charTypeName":"word"},{"id":50251,"position":14,"arabic":"٥٢","translation":"(৫২)","audioUrl":null,"charTypeName":"end"}]}]}