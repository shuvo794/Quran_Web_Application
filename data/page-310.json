translation":"(৭০)","audioUrl":null,"charTypeName":"end"}]},{"number":71,"arabic":"وَإِن مِّنكُمْ إِلَّا وَارِدُهَا ۚ كَانَ عَلَىٰ رَبِّكَ حَتْمًۭا مَّقْضِيًّۭا","translation":"And every one of you will come within sight of it: this is, with thy Sustainer, a decree that must be fulfilled.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2321.mp3","surahId":19,"words":[{"id":60091,"position":1,"arabic":"وَإِن","translation":"এবং নেই","audioUrl":"wbw/019_071_001.mp3","charTypeName":"word"},{"id":60092,"position":2,"arabic":"مِّنكُمْ","translation":"তোমাদের মধ্যে কেউ","audioUrl":"wbw/019_071_002.mp3","charTypeName":"word"},{"id":60093,"position":3,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/019_071_003.mp3","charTypeName":"word"},{"id":60094,"position":4,"arabic":"وَارِدُهَا ۚ","translation":"অতিক্রমকারী তা","audioUrl":"wbw/019_071_004.mp3","charTypeName":"word"},{"id":60096,"position":5,"arabic":"كَانَ","translation":"(এটা) হলো","audioUrl":"wbw/019_071_006.mp3","charTypeName":"word"},{"id":60097,"position":6,"arabic":"عَلَىٰ","translation":"কাছে","audioUrl":"wbw/019_071_007.mp3","charTypeName":"word"},{"id":60098,"position":7,"arabic":"رَبِّكَ","translation":"তোমার রবের","audioUrl":"wbw/019_071_008.mp3","charTypeName":"word"},{"id":60099,"position":8,"arabic":"حَتْمًۭا","translation":"চুড়ান্ত","audioUrl":"wbw/019_071_009.mp3","charTypeName":"word"},{"id":60100,"position":9,"arabic":"مَّقْضِيًّۭا","translation":"অনিবার্য","audioUrl":"wbw/019_071_010.mp3","charTypeName":"word"},{"id":60101,"position":10,"arabic":"٧١","translation":"(৭১)","audioUrl":null,"charTypeName":"end"}]},{"number":72,"arabic":"ثُمَّ نُنَجِّى ٱلَّذِينَ ٱتَّقَوا۟ وَّنَذَرُ ٱلظَّٰلِمِينَ فِيهَا جِثِيًّۭا","translation":"And once again: We shall save [from hell] those who have been conscious of Us; but We shall leave in it the evildoers, on their knees.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2322.mp3","surahId":19,"words":[{"id":60646,"position":1,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/019_072_001.mp3","charTypeName":"word"},{"id":60647,"position":2,"arabic":"نُنَجِّى","translation":"উদ্ধার করবো আমরা","audioUrl":"wbw/019_072_002.mp3","charTypeName":"word"},{"id":60648,"position":3,"arabic":"ٱلَّذِينَ","translation":"(তাদেরকে) যারা","audioUrl":"wbw/019_072_003.mp3","charTypeName":"word"},{"id":60649,"position":4,"arabic":"ٱتَّقَوا۟","translation":"তাকওয়া অবলম্বন করেছে","audioUrl":"wbw/019_072_004.mp3","charTypeName":"word"},{"id":60650,"position":5,"arabic":"وَّنَذَرُ","translation":"ও রেখে দিবো আমরা","audioUrl":"wbw/019_072_005.mp3","charTypeName":"word"},{"id":60651,"position":6,"arabic":"ٱلظَّـٰلِمِينَ","translation":"সীমালঙ্ঘনকারীদেরকে","audioUrl":"wbw/019_072_006.mp3","charTypeName":"word"},{"id":60652,"position":7,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/019_072_007.mp3","charTypeName":"word"},{"id":60653,"position":8,"arabic":"جِثِيًّۭا","translation":"নতজানু অবস্থায়","audioUrl":"wbw/019_072_008.mp3","charTypeName":"word"},{"id":60654,"position":9,"arabic":"٧٢","translation":"(৭২)","audioUrl":null,"charTypeName":"end"}]},{"number":73,"arabic":"وَإِذَا تُتْلَىٰ عَلَيْهِمْ ءَايَٰتُنَا بَيِّنَٰتٍۢ قَالَ ٱلَّذِينَ كَفَرُوا۟ لِلَّذِينَ ءَامَنُوٓا۟ أَىُّ ٱلْفَرِيقَيْنِ خَيْرٌۭ مَّقَامًۭا وَأَحْسَنُ نَدِيًّۭا","translation":"AS IT IS, whenever Our messages are conveyed to them in all their clarity, those who are bent on denying the truth are wont to say unto those who have attained to faith: \"Which of the two kinds of man is in a stronger position and superior as a community?\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2323.mp3","surahId":19,"words":[{"id":60934,"position":1,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/019_073_001.mp3","charTypeName":"word"},{"id":60935,"position":2,"arabic":"تُتْلَىٰ","translation":"আবৃত্তি করা হয়","audioUrl":"wbw/019_073_002.mp3","charTypeName":"word"},{"id":60936,"position":3,"arabic":"عَلَيْهِمْ","tra