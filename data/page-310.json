{"id":310,"ayahs":[{"number":65,"arabic":"رَّبُّ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ وَمَا بَيْنَهُمَا فَٱعْبُدْهُ وَٱصْطَبِرْ لِعِبَٰدَتِهِۦ ۚ هَلْ تَعْلَمُ لَهُۥ سَمِيًّۭا","translation":"the Sustainer of the heavens and the earth and all that is between them! Worship, then, Him alone, and remain steadfast in His worship! Dost thou know any whose name is worthy to be mentioned side by side with His?\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2315.mp3","surahId":19,"words":[{"id":57057,"position":1,"arabic":"رَّبُّ","translation":"রব","audioUrl":"wbw/019_065_001.mp3","charTypeName":"word"},{"id":57058,"position":2,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশের","audioUrl":"wbw/019_065_002.mp3","charTypeName":"word"},{"id":57059,"position":3,"arabic":"وَٱلْأَرْضِ","translation":"ও পৃথিবীর","audioUrl":"wbw/019_065_003.mp3","charTypeName":"word"},{"id":57060,"position":4,"arabic":"وَمَا","translation":"এবং যা কিছু (আছে)","audioUrl":"wbw/019_065_004.mp3","charTypeName":"word"},{"id":57061,"position":5,"arabic":"بَيْنَهُمَا","translation":"উভয়ের মাঝে","audioUrl":"wbw/019_065_005.mp3","charTypeName":"word"},{"id":57062,"position":6,"arabic":"فَٱعْبُدْهُ","translation":"তাঁরই সুতরাং ইবাদাত করুন","audioUrl":"wbw/019_065_006.mp3","charTypeName":"word"},{"id":57063,"position":7,"arabic":"وَٱصْطَبِرْ","translation":"এবং ধৈর্য্য ধরুন","audioUrl":"wbw/019_065_007.mp3","charTypeName":"word"},{"id":57064,"position":8,"arabic":"لِعِبَـٰدَتِهِۦ ۚ","translation":"তাঁর ইবাদাতের উপর","audioUrl":"wbw/019_065_008.mp3","charTypeName":"word"},{"id":57066,"position":9,"arabic":"هَلْ","translation":"কি","audioUrl":"wbw/019_065_010.mp3","charTypeName":"word"},{"id":57067,"position":10,"arabic":"تَعْلَمُ","translation":"জানেন আপনি (কাউকে)","audioUrl":"wbw/019_065_011.mp3","charTypeName":"word"},{"id":57068,"position":11,"arabic":"لَهُۥ","translation":"তাঁর জন্য","audioUrl":"wbw/019_065_012.mp3","charTypeName":"word"},{"id":57069,"position":12,"arabic":"سَمِيًّۭا","translation":