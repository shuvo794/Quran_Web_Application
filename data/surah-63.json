ioUrl":"wbw/063_005_006.mp3","charTypeName":"word"},{"id":5102,"position":7,"arabic":"رَسُولُ","translation":"রাসূূল\"","audioUrl":"wbw/063_005_007.mp3","charTypeName":"word"},{"id":5103,"position":8,"arabic":"ٱللَّهِ","translation":"আল্লাহর\"","audioUrl":"wbw/063_005_008.mp3","charTypeName":"word"},{"id":5104,"position":9,"arabic":"لَوَّوْا۟","translation":"তারা ফিরিয়ে নেয়","audioUrl":"wbw/063_005_009.mp3","charTypeName":"word"},{"id":5105,"position":10,"arabic":"رُءُوسَهُمْ","translation":"তাদের মাথাগুলো","audioUrl":"wbw/063_005_010.mp3","charTypeName":"word"},{"id":5106,"position":11,"arabic":"وَرَأَيْتَهُمْ","translation":"এবং তুমি তাদের দেখো","audioUrl":"wbw/063_005_011.mp3","charTypeName":"word"},{"id":5107,"position":12,"arabic":"يَصُدُّونَ","translation":"বিরত থাকে (আসা থেকে)","audioUrl":"wbw/063_005_012.mp3","charTypeName":"word"},{"id":5108,"position":13,"arabic":"وَهُم","translation":"এবং তারা","audioUrl":"wbw/063_005_013.mp3","charTypeName":"word"},{"id":5109,"position":14,"arabic":"مُّسْتَكْبِرُونَ","translation":"অহংকারী","audioUrl":"wbw/063_005_014.mp3","charTypeName":"word"},{"id":5110,"position":15,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"سَوَآءٌ عَلَيْهِمْ أَسْتَغْفَرْتَ لَهُمْ أَمْ لَمْ تَسْتَغْفِرْ لَهُمْ لَن يَغْفِرَ ٱللَّهُ لَهُمْ ۚ إِنَّ ٱللَّهَ لَا يَهْدِى ٱلْقَوْمَ ٱلْفَٰسِقِينَ","translation":"As for them it is all the same whether thou dost pray that they be forgiven or dost not pray for them: God will nor forgive them - for, behold, God does not bestow His guidance upon such iniquitous folk.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5194.mp3","surahId":63,"words":[{"id":6353,"position":1,"arabic":"سَوَآءٌ","translation":"সমান","audioUrl":"wbw/063_006_001.mp3","charTypeName":"word"},{"id":6354,"position":2,"arabic":"عَلَيْهِمْ","translation":"তাদের জন্যে","audioUrl":"wbw/063_006_002.mp3","charTypeName":"word"},{"id":6355,"position":3,"arabic":"أَسْتَغْفَرْتَ","t