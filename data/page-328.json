{"id":328,"ayahs":[{"number":73,"arabic":"وَجَعَلْنَٰهُمْ أَئِمَّةًۭ يَهْدُونَ بِأَمْرِنَا وَأَوْحَيْنَآ إِلَيْهِمْ فِعْلَ ٱلْخَيْرَٰتِ وَإِقَامَ ٱلصَّلَوٰةِ وَإِيتَآءَ ٱلزَّكَوٰةِ ۖ وَكَانُوا۟ لَنَا عَٰبِدِينَ","translation":"and made them leaders who would guide [others] in accordance with Our behest: for We inspired them [with a will] to do good works, and to be constant in prayer, and to dispense charity: and Us [alone] did they worship.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2556.mp3","surahId":21,"words":[{"id":61008,"position":1,"arabic":"وَجَعَلْنَـٰهُمْ","translation":"এবং তাদেরকে আমরা বানিয়েছিলাম","audioUrl":"wbw/021_073_001.mp3","charTypeName":"word"},{"id":61009,"position":2,"arabic":"أَئِمَّةًۭ","translation":"নেতৃবৃন্দ","audioUrl":"wbw/021_073_002.mp3","charTypeName":"word"},{"id":61010,"position":3,"arabic":"يَهْدُونَ","translation":"তারা পথপ্রদর্শন করতো","audioUrl":"wbw/021_073_003.mp3","charTypeName":"word"},{"id":61011,"position":4,"arabic":"بِأَمْرِنَا","translation":"আমাদের নির্দেশ অনুসারে","audioUrl":"wbw/021_073_004.mp3","charTypeName":"word"},{"id":61012,"position":5,"arabic":"وَأَوْحَيْنَآ","translation":"এবং আমরা ওহী করেছিলাম","audioUrl":"wbw/021_073_005.mp3","charTypeName":"word"},{"id":61013,"position":6,"arabic":"إِلَيْهِمْ","translation":"তাদের প্রতি","audioUrl":"wbw/021_073_006.mp3","charTypeName":"word"},{"id":61014,"position":7,"arabic":"فِعْلَ","translation":"কাজ করতে","audioUrl":"wbw/021_073_007.mp3","charTypeName":"word"},{"id":61015,"position":8,"arabic":"ٱلْخَيْرَٰتِ","translation":"ভালো ভালো","audioUrl":"wbw/021_073_008.mp3","charTypeName":"word"},{"id":61016,"position":9,"arabic":"وَإِقَامَ","translation":"ও প্রতিষ্ঠা করতে","audioUrl":"wbw/021_073_009.mp3","charTypeName":"word"},{"id":61017,"position":10,"arabic":"ٱلصَّلَوٰةِ","translation":"সালাত","audioUrl":"wbw/021_073_010.mp3","charTypeName":"word"},{"id":61018,"position":11,"arabic":"وَإِيتَآءَ","translation":"ও প্রদান করতো","audioUrl":"wbw/021_073_011.mp3","charTypeName":"word"},{"id":61019,"position":12,"arabic":"ٱلزَّكَوٰةِ ۖ","translation":"জাকাত","audioUrl":"wbw/021_073_012.mp3","charTypeName":"word"},{"id":61021,"position":13,"arabic":"وَكَانُوا۟","translation":"এবং তারা ছিলো","audioUrl":"wbw/021_073_014.mp3","charTypeName":"word"},{"id":61022,"position":14,"arabic":"لَنَا","translation":"জন্যে আমাদের","audioUrl":"wbw/021_073_015.mp3","charTypeName":"word"},{"id":61023,"position":15,"arabic":"عَـٰبِدِينَ","translation":"ইবাদাতকারী","audioUrl":"wbw/021_073_016.mp3","charTypeName":"word"},{"id":61024,"position":16,"arabic":"٧٣","translation":"(৭৩)","audioUrl":null,"charTypeName":"end"}]},{"number":74,"arabic":"وَلُوطًا ءَاتَيْنَٰهُ حُكْمًۭا وَعِلْمًۭا وَنَجَّيْنَٰهُ مِنَ ٱلْقَرْيَةِ ٱلَّتِى كَانَت تَّعْمَلُ ٱلْخَبَٰٓئِثَ ۗ إِنَّهُمْ كَانُوا۟ قَوْمَ سَوْءٍۢ فَٰسِقِينَ","translation":"AND UNTO Lot, too, We vouchsafed sound judg­ment and knowledge [of right and wrong], and saved him from that community which was given to deeds of abomination. [We destroyed those people - forr,] verily, they were people lost in evil, depraved –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2557.mp3","surahId":21,"words":[{"id":61434,"position":1,"arabic":"وَلُوطًا","translation":"এবং লূতকে","audioUrl":"wbw/021_074_001.mp3","charTypeName":"word"},{"id":61435,"position":2,"arabic":"ءَاتَيْنَـٰهُ","translation":"তাকে আমরা দিয়েছিলাম","audioUrl":"wbw/021_074_002.mp3","charTypeName":"word"},{"id":61436,"position":3,"arabic":"حُكْمًۭا","translation":"প্রজ্ঞা","audioUrl":"wbw/021_074_003.mp3","charTypeName":"word"},{"id":61437,"position":4,"arabic":"وَعِلْمًۭا","translation":"ও জ্ঞান","audioUrl":"wbw/021_074_004.mp3","charTypeName":"word"},{"id":61438,"position":5,"arabic":"وَنَجَّيْنَـٰهُ","translation":"এবং তাকে আমরা উদ্ধার করেছিলাম","audioUrl":"wbw/021_074_005.mp3","charTypeName":"word"},{"id":61439,"position":6,"arabic":"مِنَ","translation":"থেকে","audioUrl":"wbw/021_074_006.mp3","charTypeName":"word"},{"id":61440,"position":7,"arabic":"ٱلْقَرْيَةِ","translation":"জনপদ","audioUrl":"wbw/021_074_007.mp3","charTypeName":"word"},{"id":61441,"position":8,"arabic":"ٱلَّتِى","translation":"যা","audioUrl":"wbw/021_074_008.mp3","charTypeName":"word"},{"id":61442,"position":9,"arabic":"كَانَت","translation":"ছিলো","audioUrl":"wbw/021_074_009.mp3","charTypeName":"word"},{"id":61443,"position":10,"arabic":"تَّعْمَلُ","translation":"করতে","audioUrl":"wbw/021_074_010.mp3","charTypeName":"word"},{"id":61444,"position":11,"arabic":"ٱلْخَبَـٰٓئِثَ ۗ","translation":"অশ্লীল কর্মসমূহে","audioUrl":"wbw/021_074_011.mp3","charTypeName":"word"},{"id":61446,"position":12,"arabic":"إِنَّهُمْ","translation":"নিশ্চয়ই তারা","audioUrl":"wbw/021_074_013.mp3","charTypeName":"word"},{"id":61447,"position":13,"arabic":"كَانُوا۟","translation":"ছিলো","audioUrl":"wbw/021_074_014.mp3","charTypeName":"word"},{"id":61448,"position":14,"arabic":"قَوْمَ","translation":"জাতি","audioUrl":"wbw/021_074_015.mp3","charTypeName":"word"},{"id":61449,"position":15,"arabic":"سَوْءٍۢ","translation":"খারাপ","audioUrl":"wbw/021_074_016.mp3","charTypeName":"word"},{"id":61450,"position":16,"arabic":"فَـٰسِقِينَ","translation":"সত্যত্যাগী","audioUrl":"wbw/021_074_017.mp3","charTypeName":"word"},{"id":61451,"position":17,"arabic":"٧٤","translation":"(৭৪)","audioUrl":null,"charTypeName":"end"}]},{"number":75,"arabic":"وَأَدْخَلْنَٰهُ فِى رَحْمَتِنَآ ۖ إِنَّهُۥ مِنَ ٱلصَّٰلِحِينَ","translation":"whereas him We admitted unto Our grace: for, behold, he was among the righteous.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2558.mp3","surahId":21,"words":[{"id":61866,"position":1,"arabic":"وَأَدْخَلْنَـٰهُ","translation":"এবং তাকে আমরা প্রবেশ করিয়েছিলাম","audioUrl":"wbw/021_075_001.mp3","charTypeName":"word"},{"id":61867,"position":2,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/021_075_002.mp3","charTypeName":"word"},{"id":61868,"position":3,"arabic":"رَحْمَتِنَآ ۖ","translation":"আমাদের অনুগ্রহের","audioUrl":"wbw/021_075_003.mp3","charTypeName":"word"},{"id":61870,"position":4,"arabic":"إِنَّهُۥ","translation":"নিশ্চয়ই সে (ছিলো)","audioUrl":"wbw/021_075_005.mp3","charTypeName":"word"},{"id":61871,"position":5,"arabic":"مِنَ","translation":"অন্যতম","audioUrl":"wbw/021_075_006.mp3","charTypeName":"word"},{"id":61872,"position":6,"arabic":"ٱلصَّـٰلِحِينَ","translation":"সৎকর্মশীলদের","audioUrl":"wbw/021_075_007.mp3","charTypeName":"word"},{"id":61873,"position":7,"arabic":"٧٥","translation":"(৭৫)","audioUrl":null,"charTypeName":"end"}]},{"number":76,"arabic":"وَنُوحًا إِذْ نَادَىٰ مِن قَبْلُ فَٱسْتَجَبْنَا لَهُۥ فَنَجَّيْنَٰهُ وَأَهْلَهُۥ مِنَ ٱلْكَرْبِ ٱلْعَظِيمِ","translation":"AND [remember] Noah - [how,] when He called out [unto Us], long before [the time of Abraham and Lot], We responded to him and saved him and his house­hold from that awesome calamity;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2559.mp3","surahId":21,"words":[{"id":62508,"position":1,"arabic":"وَنُوحًا","translation":"এবং নূহকে (স্মরণ করো)","audioUrl":"wbw/021_076_001.mp3","charTypeName":"word"},{"id":62509,"position":2,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/021_076_002.mp3","charTypeName":"word"},{"id":62510,"position":3,"arabic":"نَادَىٰ","translation":"সে ডেকেছিলো","audioUrl":"wbw/021_076_003.mp3","charTypeName":"word"},{"id":62511,"position":4,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/021_076_004.mp3","charTypeName":"word"},{"id":62512,"position":5,"arabic":"قَبْلُ","translation":"ইতিপূর্ব","audioUrl":"wbw/021_076_005.mp3","charTypeName":"word"},{"id":62513,"position":6,"arabic":"فَٱسْتَجَبْنَا","translation":"তখন আমরা সাড়া দিয়েছিলাম","audioUrl":"wbw/021_076_006.mp3","charTypeName":"word"},{"id":62514,"position":7,"arabic":"لَهُۥ","translation":"তার ডাকে","audioUrl":"wbw/021_076_007.mp3","charTypeName":"word"},{"id":62515,"position":8,"arabic":"فَنَجَّيْنَـٰهُ","translation":"অতঃপর তাকে আমরা উদ্ধার করেছিলাম","audioUrl":"wbw/021_076_008.mp3","charTypeName":"word"},{"id":62516,"position":9,"arabic":"وَأَهْلَهُۥ","translation":"ও তার পরিবারকে","audioUrl":"wbw/021_076_009.mp3","charTypeName":"word"},{"id":62517,"position":10,"arabic":"مِنَ","translation":"হ'তে","audioUrl":"wbw/021_076_010.mp3","charTypeName":"word"},{"id":62518,"position":11,"arabic":"ٱلْكَرْبِ","translation":"সংকট","audioUrl":"wbw/021_076_011.mp3","charTypeName":"word"},{"id":62519,"position":12,"arabic":"ٱلْعَظِيمِ","translation":"মহা","audioUrl":"wbw/021_076_012.mp3","charTypeName":"word"},{"id":62520,"position":13,"arabic":"٧٦","translation":"(৭৬)","audioUrl":null,"charTypeName":"end"}]},{"number":77,"arabic":"وَنَصَرْنَٰهُ مِنَ ٱلْقَوْمِ ٱلَّذِينَ كَذَّبُوا۟ بِـَٔايَٰتِنَآ ۚ إِنَّهُمْ كَانُوا۟ قَوْمَ سَوْءٍۢ فَأَغْرَقْنَٰهُمْ أَجْمَعِينَ","translation":"and [how] We succoured him against the people who had given the lie to Our messages: verily, they were people lost in evil - and [so] We caused them all to drown.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2560.mp3","surahId":21,"words":[{"id":62790,"position":1,"arabic":"وَنَصَرْنَـٰهُ","translation":"এবং তাকে আমরা সাহায্য করেছিলাম","audioUrl":"wbw/021_077_001.mp3","charTypeName":"word"},{"id":62791,"position":2,"arabic":"مِنَ","translation":"বিরুদ্ধে","audioUrl":"wbw/021_077_002.mp3","charTypeName":"word"},{"id":62792,"position":3,"arabic":"ٱلْقَوْمِ","translation":"(এমন) লোকদের","audioUrl":"wbw/021_077_003.mp3","charTypeName":"word"},{"id":62793,"position":4,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/021_077_004.mp3","charTypeName":"word"},{"id":62794,"position":5,"arabic":"كَذَّبُوا۟","translation":"মিথ্যারোপ করেছিলো","audioUrl":"wbw/021_077_005.mp3","charTypeName":"word"},{"id":62795,"position":6,"arabic":"بِـَٔايَـٰتِنَآ ۚ","translation":"আমাদের নিদর্শনাবলীকে","audioUrl":"wbw/021_077_006.mp3","charTypeName":"word"},{"id":62797,"position":7,"arabic":"إِنَّهُمْ","translation":"নিশ্চয়ই তারা","audioUrl":"wbw/021_077_008.mp3","charTypeName":"word"},{"id":62798,"position":8,"arabic":"كَانُوا۟","translation":"ছিলো","audioUrl":"wbw/021_077_009.mp3","charTypeName":"word"},{"id":62799,"position":9,"arabic":"قَوْمَ","translation":"লোক","audioUrl":"wbw/021_077_010.mp3","charTypeName":"word"},{"id":62800,"position":10,"arabic":"سَوْءٍۢ","translation":"খারাপ","audioUrl":"wbw/021_077_011.mp3","charTypeName":"word"},{"id":62801,"position":11,"arabic":"فَأَغْرَقْنَـٰهُمْ","translation":"সুতরাং তাদের আমরা ডুবিয়ে দিই","audioUrl":"wbw/021_077_012.mp3","charTypeName":"word"},{"id":62802,"position":12,"arabic":"أَجْمَعِينَ","translation":"সকলকেই","audioUrl":"wbw/021_077_013.mp3","charTypeName":"word"},{"id":62803,"position":13,"arabic":"٧٧","translation":"(৭৭)","audioUrl":null,"charTypeName":"end"}]},{"number":78,"arabic":"وَدَاوُۥدَ وَسُلَيْمَٰنَ إِذْ يَحْكُمَانِ فِى ٱلْحَرْثِ إِذْ نَفَشَتْ فِيهِ غَنَمُ ٱلْقَوْمِ وَكُنَّا لِحُكْمِهِمْ شَٰهِدِينَ","translation":"AND [remember] David and Solomon - [how it was] when both of them gave judgment concerning the field into which some people’s sheep had strayed by night and pastured therein, and [how] We bore witness to their judgment:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2561.mp3","surahId":21,"words":[{"id":63649,"position":1,"arabic":"وَدَاوُۥدَ","translation":"এবং (স্মরণ করো) দাঊদকে","audioUrl":"wbw/021_078_001.mp3","charTypeName":"word"},{"id":63650,"position":2,"arabic":"وَسُلَيْمَـٰنَ","translation":"ও সুলাইমানকে","audioUrl":"wbw/021_078_002.mp3","charTypeName":"word"},{"id":63651,"position":3,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/021_078_003.mp3","charTypeName":"word"},{"id":63652,"position":4,"arabic":"يَحْكُمَانِ","translation":"উভয়ে বিচার করেছিলো","audioUrl":"wbw/021_078_004.mp3","charTypeName":"word"},{"id":63653,"position":5,"arabic":"فِى","translation":"সম্পর্কে","audioUrl":"wbw/021_078_005.mp3","charTypeName":"word"},{"id":63654,"position":6,"arabic":"ٱلْحَرْثِ","translation":"এক ক্ষেত","audioUrl":"wbw/021_078_006.mp3","charTypeName":"word"},{"id":63655,"position":7,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/021_078_007.mp3","charTypeName":"word"},{"id":63656,"position":8,"arabic":"نَفَشَتْ","translation":"রাতে ছড়িয়ে পড়েছিলো","audioUrl":"wbw/021_078_008.mp3","charTypeName":"word"},{"id":63657,"position":9,"arabic":"فِيهِ","translation":"তার মধ্যে","audioUrl":"wbw/021_078_009.mp3","charTypeName":"word"},{"id":63658,"position":10,"arabic":"غَنَمُ","translation":"মেষ","audioUrl":"wbw/021_078_010.mp3","charTypeName":"word"},{"id":63659,"position":11,"arabic":"ٱلْقَوْمِ","translation":"কিছু লোকের","audioUrl":"wbw/021_078_011.mp3","charTypeName":"word"},{"id":63660,"position":12,"arabic":"وَكُنَّا","translation":"এবং আমরা ছিলাম","audioUrl":"wbw/021_078_012.mp3","charTypeName":"word"},{"id":63661,"position":13,"arabic":"لِحُكْمِهِمْ","translation":"জন্যে তাদের বিচারের","audioUrl":"wbw/021_078_013.mp3","charTypeName":"word"},{"id":63662,"position":14,"arabic":"شَـٰهِدِينَ","translation":"পর্যবেক্ষক","audioUrl":"wbw/021_078_014.mp3","charTypeName":"word"},{"id":63663,"position":15,"arabic":"٧٨","translation":"(৭৮)","audioUrl":null,"charTypeName":"end"}]},{"number":79,"arabic":"فَفَهَّمْنَٰهَا سُلَيْمَٰنَ ۚ وَكُلًّا ءَاتَيْنَا حُكْمًۭا وَعِلْمًۭا ۚ وَسَخَّرْنَا مَعَ دَاوُۥدَ ٱلْجِبَالَ يُسَبِّحْنَ وَٱلطَّيْرَ ۚ وَكُنَّا فَٰعِلِينَ","translation":"for, [though] We made Solomon understand the case [more profoundly] yet We vouchsafed unto both of them sound judgment and knowledge [of right and wrong]. And We caused the mountains to join David in extolling Our limitless glory, and likewise the birds: for We are able to do [all things].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2562.mp3","surahId":21,"words":[{"id":63926,"position":1,"arabic":"فَفَهَّمْنَـٰهَا","translation":"অতঃপর তা আমরা বুঝিয়ে দিই","audioUrl":"wbw/021_079_001.mp3","charTypeName":"word"},{"id":63927,"position":2,"arabic":"سُلَيْمَـٰنَ ۚ","translation":"সুলাইমানকে","audioUrl":"wbw/021_079_002.mp3","charTypeName":"word"},{"id":63929,"position":3,"arabic":"وَكُلًّا","translation":"অথচ প্রত্যেককেই","audioUrl":"wbw/021_079_004.mp3","charTypeName":"word"},{"id":63930,"position":4,"arabic":"ءَاتَيْنَا","translation":"আমরা দিয়েছি","audioUrl":"wbw/021_079_005.mp3","charTypeName":"word"},{"id":63931,"position":5,"arabic":"حُكْمًۭا","translation":"প্রজ্ঞা","audioUrl":"wbw/021_079_006.mp3","charTypeName":"word"},{"id":63932,"position":6,"arabic":"وَعِلْمًۭا ۚ","translation":"ও জ্ঞান","audioUrl":"wbw/021_079_007.mp3","charTypeName":"word"},{"id":63934,"position":7,"arabic":"وَسَخَّرْنَا","translation":"এবং আমরা নিয়ন্ত্রিত করে দিয়েছিলাম","audioUrl":"wbw/021_079_009.mp3","charTypeName":"word"},{"id":63935,"position":8,"arabic":"مَعَ","translation":"সাথে","audioUrl":"wbw/021_079_010.mp3","charTypeName":"word"},{"id":63936,"position":9,"arabic":"دَاوُۥدَ","translation":"দাঊদের","audioUrl":"wbw/021_079_011.mp3","charTypeName":"word"},{"id":63937,"position":10,"arabic":"ٱلْجِبَالَ","translation":"পাহাড়গুলোকে","audioUrl":"wbw/021_079_012.mp3","charTypeName":"word"},{"id":63938,"position":11,"arabic":"يُسَبِّحْنَ","translation":"তারা পবিত্রতা ঘোষণা করতো","audioUrl":"wbw/021_079_013.mp3","charTypeName":"word"},{"id":63939,"position":12,"arabic":"وَٱلطَّيْرَ ۚ","translation":"এবং পাখিদেরকেও (নিয়ন্ত্রিত করেছিলাম)","audioUrl":"wbw/021_079_014.mp3","charTypeName":"word"},{"id":63941,"position":13,"arabic":"وَكُنَّا","translation":"এবং আমরা ছিলাম","audioUrl":"wbw/021_079_016.mp3","charTypeName":"word"},{"id":63942,"position":14,"arabic":"فَـٰعِلِينَ","translation":"(এসবের) সম্পাদনকারী","audioUrl":"wbw/021_079_017.mp3","charTypeName":"word"},{"id":63943,"position":15,"arabic":"٧٩","translation":"(৭৯)","audioUrl":null,"charTypeName":"end"}]},{"number":80,"arabic":"وَعَلَّمْنَٰهُ صَنْعَةَ لَبُوسٍۢ لَّكُمْ لِتُحْصِنَكُم مِّنۢ بَأْسِكُمْ ۖ فَهَلْ أَنتُمْ شَٰكِرُونَ","translation":"And We taught him how to make garments [of God- consciousness] for you, [O men,] so that they might