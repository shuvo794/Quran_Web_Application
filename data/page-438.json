{"id":438,"ayahs":[{"number":31,"arabic":"وَٱلَّذِىٓ أَوْحَيْنَآ إِلَيْكَ مِنَ ٱلْكِتَٰبِ هُوَ ٱلْحَقُّ مُصَدِّقًۭا لِّمَا بَيْنَ يَدَيْهِ ۗ إِنَّ ٱللَّهَ بِعِبَادِهِۦ لَخَبِيرٌۢ بَصِيرٌۭ","translation":"And [know that] all of the divine writ with which We have inspired thee is the very truth, confirming the truth of whatever there still remains of earlier revelations for, behold, of [the needs of] His servants God is fully aware, all-seeing.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3691.mp3","surahId":35,"words":[{"id":34224,"position":1,"arabic":"وَٱلَّذِىٓ","translation":"এবং(হে নাবী) যা","audioUrl":"wbw/035_031_001.mp3","charTypeName":"word"},{"id":34225,"position":2,"arabic":"أَوْحَيْنَآ","translation":"আমরা ওহী করেছি","audioUrl":"wbw/035_031_002.mp3","charTypeName":"word"},{"id":34226,"position":3,"arabic":"إِلَيْكَ","translation":"তোমার প্রতি","audioUrl":"wbw/035_031_003.mp3","charTypeName":"word"},{"id":34227,"position":4,"arabic":"مِنَ","translation":"থেকে","audioUrl":"wbw/035_031_004.mp3","charTypeName":"word"},{"id":34228,"position":5,"arabic":"ٱلْكِتَـٰبِ","translation":"কিতাব","audioUrl":"wbw/035_031_005.mp3","charTypeName":"word"},{"id":34229,"position":6,"arabic":"هُوَ","translation":"তাই","audioUrl":"wbw/035_031_006.mp3","charTypeName":"word"},{"id":34230,"position":7,"arabic":"ٱلْحَقُّ","translation":"সত্য","audioUrl":"wbw/035_031_007.mp3","charTypeName":"word"},{"id":34231,"position":8,"arabic":"مُصَدِّقًۭا","translation":"(তা) সত্যায়নকারী ও সমর্থক","audioUrl":"wbw/035_031_008.mp3","charTypeName":"word"},{"id":34232,"position":9,"arabic":"لِّمَا","translation":"তার যা","audioUrl":"wbw/035_031_009.mp3","charTypeName":"word"},{"id":34233,"position":10,"arabic":"بَيْنَ","translation":"পূর্বে (এসেছে)","audioUrl":"wbw/035_031_010.mp3","charTypeName":"word"},{"id":34234,"position":11,"arabic":"يَدَيْهِ ۗ","translation":"তার","audioUrl":"wbw/035_031_011.mp3","charTypeName":"word"},{"id":34236,"position":12,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/035_031_013.mp3","charTypeName":"word"},{"id":34237,"position":13,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/035_031_014.mp3","charTypeName":"word"},{"id":34238,"position":14,"arabic":"بِعِبَادِهِۦ","translation":"তাঁর দাসদের সম্পর্কে","audioUrl":"wbw/035_031_015.mp3","charTypeName":"word"},{"id":34239,"position":15,"arabic":"لَخَبِيرٌۢ","translation":"অবশ্যই সব জানেন","audioUrl":"wbw/035_031_016.mp3","charTypeName":"word"},{"id":34240,"position":16,"arabic":"بَصِيرٌۭ","translation":"সব দেখেন","audioUrl":"wbw/035_031_017.mp3","charTypeName":"word"},{"id":34241,"position":17,"arabic":"٣١","translation":"(৩১)","audioUrl":null,"charTypeName":"end"}]},{"number":32,"arabic":"ثُمَّ أَوْرَثْنَا ٱلْكِتَٰبَ ٱلَّذِينَ ٱصْطَفَيْنَا مِنْ عِبَادِنَا ۖ فَمِنْهُمْ ظَالِمٌۭ لِّنَفْسِهِۦ وَمِنْهُم مُّقْتَصِدٌۭ وَمِنْهُمْ سَابِقٌۢ بِٱلْخَيْرَٰتِ بِإِذْنِ ٱللَّهِ ۚ ذَٰلِكَ هُوَ ٱلْفَضْلُ ٱلْكَبِيرُ","translation":"And so, We have bestowed this divine writ as a heritage unto such of Our servants as We chose: and among them are some who sin against themselves; and some who keep half-way [between right and wrong]; and some who, by God’s leave, are fore­most in deeds of goodness: [and] this, indeed, is a merit most high!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3692.mp3","surahId":35,"words":[{"id":35080,"position":1,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/035_032_001.mp3","charTypeName":"word"},{"id":35081,"position":2,"arabic":"أَوْرَثْنَا","translation":"আমরা উত্তরাধিকার বানিয়েছি","audioUrl":"wbw/035_032_002.mp3","charTypeName":"word"},{"id":35082,"position":3,"arabic":"ٱلْكِتَـٰبَ","translation":"কিতাবের","audioUrl":"wbw/035_032_003.mp3","charTypeName":"word"},{"id":35083,"position":4,"arabic":"ٱلَّذِينَ","translation":"( তাদেরকে ) যাদের","audioUrl":"wbw/035_032_004.mp3","charTypeName":"word"},{"id":35084,"position":5,"arabic":"ٱصْطَفَيْنَا","translation":"আমরা মনোনীত করেছি","audioUrl":"wbw/035_032_005.mp3","charTypeName":"word"},{"id":35085,"position":6,"arabic":"مِنْ","translation":"মধ্য হ'তে","audioUrl":"wbw/035_032_006.mp3","charTypeName":"word"},{"id":35086,"position":7,"arabic":"عِبَادِنَا ۖ","translation":"আমাদের দাসদের","audioUrl":"wbw/035_032_007.mp3","charTypeName":"word"},{"id":35088,"position":8,"arabic":"فَمِنْهُمْ","translation":"অতঃপর তাদের মধ্যে","audioUrl":"wbw/035_032_009.mp3","charTypeName":"word"},{"id":35089,"position":9,"arabic":"ظَالِمٌۭ","translation":"(কেউ হয়েছে) অত্যাচারী","audioUrl":"wbw/035_032_010.mp3","charTypeName":"word"},{"id":35090,"position":10,"arabic":"لِّنَفْسِهِۦ","translation":"তার নিজের প্রতি","audioUrl":"wbw/035_032_011.mp3","charTypeName":"word"},{"id":35091,"position":11,"arabic":"وَمِنْهُم","translation":"আবার তাদের মধ্য (রয়েছে)","audioUrl":"wbw/035_032_012.mp3","charTypeName":"word"},{"id":35092,"position":12,"arabic":"مُّقْتَصِدٌۭ","translation":"(কেউ) মধ্যপন্থী","audioUrl":"wbw/035_032_013.mp3","charTypeName":"word"},{"id":35093,"position":13,"arabic":"وَمِنْهُمْ","translation":"আবার তাদের মধ্যে (রয়েছে)","audioUrl":"wbw/035_032_014.mp3","charTypeName":"word"},{"id":35094,"position":14,"arabic":"سَابِقٌۢ","translation":"(কেউ) অগ্রগামী","audioUrl":"wbw/035_032_015.mp3","charTypeName":"word"},{"id":35095,"position":15,"arabic":"بِٱلْخَيْرَٰتِ","translation":"কল্যাণকর কাজসমূহে","audioUrl":"wbw/035_032_016.mp3","charTypeName":"word"},{"id":35096,"position":16,"arabic":"بِإِذْنِ","translation":"অনুমতিক্রমে","audioUrl":"wbw/035_032_017.mp3","charTypeName":"word"},{"id":35097,"position":17,"arabic":"ٱللَّهِ ۚ","translation":"আল্লাহর","audioUrl":"wbw/035_032_018.mp3","charTypeName":"word"},{"id":35099,"position":18,"arabic":"ذَٰلِكَ","translation":"এটাই","audioUrl":"wbw/035_032_020.mp3","charTypeName":"word"},{"id":35100,"position":19,"arabic":"هُوَ","translation":"সেই","audioUrl":"wbw/035_032_021.mp3","charTypeName":"word"},{"id":35101,"position":20,"arabic":"ٱلْفَضْلُ","translation":"অনুগ্রহ","audioUrl":"wbw/035_032_022.mp3","charTypeName":"word"},{"id":35102,"position":21,"arabic":"ٱلْكَبِيرُ","translation":"মহা","audioUrl":"wbw/035_032_023.mp3","charTypeName":"word"},{"id":35103,"position":22,"arabic":"٣٢","translation":"(৩২)","audioUrl":null,"charTypeName":"end"}]},{"number":33,"arabic":"جَنَّٰتُ عَدْنٍۢ يَدْخُلُونَهَا يُحَلَّوْنَ فِيهَا مِنْ أَسَاوِرَ مِن ذَهَبٍۢ وَلُؤْلُؤًۭا ۖ وَلِبَاسُهُمْ فِيهَا حَرِيرٌۭ","translation":"[Hence,] gardens of perpetual bliss will they enter, therein to be adorned with bracelets of gold and pearls, and therein to be clad in raiments of silk;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3693.mp3","surahId":35,"words":[{"id":35945,"position":1,"arabic":"جَنَّـٰتُ","translation":"বেহেশতসমূহ (রয়েছে)","audioUrl":"wbw/035_033_001.mp3","charTypeName":"word"},{"id":35946,"position":2,"arabic":"عَدْنٍۢ","translation":"স্থায়ী","audioUrl":"wbw/035_033_002.mp3","charTypeName":"word"},{"id":35947,"position":3,"arabic":"يَدْخُلُونَهَا","translation":"তাতে তারা প্রবেশ করবে","audioUrl":"wbw/035_033_003.mp3","charTypeName":"word"},{"id":35948,"position":4,"arabic":"يُحَلَّوْنَ","translation":"অলংকৃত করা হবে(তাদেরকে)","audioUrl":"wbw/035_033_004.mp3","charTypeName":"word"},{"id":35949,"position":5,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/035_033_005.mp3","charTypeName":"word"},{"id":35950,"position":6,"arabic":"مِنْ","translation":"দিয়ে","audioUrl":"wbw/035_033_006.mp3","charTypeName":"word"},{"id":35951,"position":7,"arabic":"أَسَاوِرَ","translation":"বালা","audioUrl":"wbw/035_033_007.mp3","charTypeName":"word"},{"id":35952,"position":8,"arabic":"مِن","translation":"দ্বারা (নির্মিত)","audioUrl":"wbw/035_033_008.mp3","charTypeName":"word"},{"id":35953,"position":9,"arabic":"ذَهَبٍۢ","translation":"স্বর্ণের","audioUrl":"wbw/035_033_009.mp3","charTypeName":"word"},{"id":35954,"position":10,"arabic":"وَلُؤْلُؤًۭا ۖ","translation":"ও মনি মুক্তার","audioUrl":"wbw/035_033_010.mp3","charTypeName":"word"},{"id":35956,"position":11,"arabic":"وَلِبَاسُهُمْ","translation":"এবং তাদের পোশাক (হবে)","audioUrl":"wbw/035_033_012.mp3","charTypeName":"word"},{"id":35957,"position":12,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/035_033_013.mp3","charTypeName":"word"},{"id":35958,"position":13,"arabic":"حَرِيرٌۭ","translation":"রেশমের","audioUrl":"wbw/035_033_014.mp3","charTypeName":"word"},{"id":35959,"position":14,"arabic":"٣٣","translation":"(৩৩)","audioUrl":null,"charTypeName":"end"}]},{"number":34,"arabic":"وَقَالُوا۟ ٱلْحَمْدُ لِلَّهِ ٱلَّذِىٓ أَذْهَبَ عَنَّا ٱلْحَزَنَ ۖ إِنَّ رَبَّنَا لَغَفُورٌۭ شَكُورٌ","translation":"and they will say: “All praise is due to God, who has caused all sorrow to leave us: for, verily, our Sustainer is indeed much-forgiving, ever-responsive to gratitude –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3694.mp3","surahId":35,"words":[{"id":36823,"position":1,"arabic":"وَقَالُوا۟","translation":"এবং তারা বলবে","audioUrl":"wbw/035_034_001.mp3","charTypeName":"word"},{"id":36824,"position":2,"arabic":"ٱلْحَمْدُ","translation":"\"সব প্রশংসা","audioUrl":"wbw/035_034_002.mp3","charTypeName":"word"},{"id":36825,"position":3,"arabic":"لِلَّهِ","translation":"আল্লাহর-ই জন্য","audioUrl":"wbw/035_034_003.mp3","charTypeName":"word"},{"id":36826,"position":4,"arabic":"ٱلَّذِىٓ","translation":"যিনি","audioUrl":"wbw/035_034_004.mp3","charTypeName":"word"},{"id":36827,"position":5,"arabic":"أَذْهَبَ","translation":"দূর করেছেন","audioUrl":"wbw/035_034_005.mp3","charTypeName":"word"},{"id":36828,"position":6,"arabic":"عَنَّا","translation":"আমাদের থেকে","audioUrl":"wbw/035_034_006.mp3","charTypeName":"word"},{"id":36829,"position":7,"arabic":"ٱلْحَزَنَ ۖ","translation":"দুশ্চিন্তা","audioUrl":"wbw/035_034_007.mp3","charTypeName":"word"},{"id":36831,"position":8,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/035_034_009.mp3","charTypeName":"word"},{"id":36832,"position":9,"arabic":"رَبَّنَا","translation":"আমাদের রব","audioUrl":"wbw/035_034_010.mp3","charTypeName":"word"},{"id":36833,"position":10,"arabic":"لَغَفُورٌۭ","translation":"অবশ্যই ক্ষমাশীল","audioUrl":"wbw/035_034_011.mp3","charTypeName":"word"},{"id":36834,"position":11,"arabic":"شَكُورٌ","translation":"গুণগ্রাহী","audioUrl":"wbw/035_034_012.mp3","charTypeName":"word"},{"id":36835,"position":12,"arabic":"٣٤","translation":"(৩৪)","audioUrl":null,"charTypeName":"end"}]},{"number":35,"arabic":"ٱلَّذِىٓ أَحَلَّنَا دَارَ ٱلْمُقَامَةِ مِن فَضْلِهِۦ لَا يَمَسُّنَا فِيهَا نَصَبٌۭ وَلَا يَمَسُّنَا فِيهَا لُغُوبٌۭ","translation":"He who, out of His bounty, has made us alight in this abode of life enduring, wherein no struggle can assail us, and wherein no weariness can touch us!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3695.mp3","surahId":35,"words":[{"id":37617,"position":1,"arabic":"ٱلَّذِىٓ","translation":"যিনি","audioUrl":"wbw/035_035_001.mp3","charTypeName":"word"},{"id":37618,"position":2,"arabic":"أَحَلَّنَا","translation":"আমাদের জন্যে স্হান দিয়েছেন","audioUrl":"wbw/035_035_002.mp3","charTypeName":"word"},{"id":37619,"position":3,"arabic":"دَارَ","translation":"আরাম","audioUrl":"wbw/035_035_003.mp3","charTypeName":"word"},{"id":37620,"position":4,"arabic":"ٱلْمُقَامَةِ","translation":"স্হায়ী","audioUrl":"wbw/035_035_004.mp3","charTypeName":"word"},{"id":37621,"position":5,"arabic":"مِن","translation":"অনুগ্রহের মাধ্যমে","audioUrl":"wbw/035_035_005.mp3","charTypeName":"word"},{"id":37622,"position":6,"arabic":"فَضْلِهِۦ","translation":"তাঁর","audioUrl":"wbw/035_035_006.mp3","charTypeName":"word"},{"id":37623,"position":7,"arabic":"لَا","translation":"না","audioUrl":"wbw/035_035_007.mp3","charTypeName":"word"},{"id":37624,"position":8,"arabic":"يَمَسُّنَا","translation":"আমাদের স্পর্শ করবে","audioUrl":"wbw/035_035_008.mp3","charTypeName":"word"},{"id":37625,"position":9,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/035_035_009.mp3","charTypeName":"word"},{"id":37626,"position":10,"arabic":"نَصَبٌۭ","translation":"কোনো কষ্ট","audioUrl":"wbw/035_035_010.mp3","charTypeName":"word"},{"id":37627,"position":11,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/035_035_011.mp3","charTypeName":"word"},{"id":37628,"position":12,"arabic":"يَمَسُّنَا","translation":"আমাদেরকে স্পর্শ করবে","audioUrl":"wbw/035_035_012.mp3","charTypeName":"word"},{"id":37629,"position":13,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/035_035_013.mp3","charTypeName":"word"},{"id":37630,"position":14,"arabic":"لُغُوبٌۭ","translation":"কোনো ক্লান্তি\"","audioUrl":"wbw/035_035_014.mp3","charTypeName":"word"},{"id":37631,"position":15,"arabic":"٣٥","translation":"(৩৫)","audioUrl":null,"charTypeName":"end"}]},{"number":36,"arabic":"وَٱلَّذِينَ كَفَرُوا۟ لَهُمْ نَارُ جَهَنَّمَ لَا يُقْضَىٰ عَلَيْهِمْ فَيَمُوتُوا۟ وَلَا يُخَفَّفُ عَنْهُم مِّنْ عَذَابِهَا ۚ كَذَٰلِكَ نَجْزِى كُلَّ كَفُورٍۢ","translation":"But as for those who are bent on denying the truth - the fire of hell awaits them: no end shall be put to their lives so that they could die, nor shall aught of the suffering caused by that [fire] be lightened for them: thus shall We requite all who are bereft of gratitude.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3696.mp3","surahId":35,"words":[{"id":38038,"position":1,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/035_036_001.mp3","charTypeName":"word"},{"id":38039,"position":2,"arabic":"كَفَرُوا۟","translation":"অবিশ্বাস করেছে","audioUrl":"wbw/035_036_002.mp3","charTypeName":"word"},{"id":38040,"position":3,"arabic":"لَهُمْ","translation":"তাদের জন্যে (রয়েছে)","audioUrl":"wbw/035_036_003.mp3","charTypeName":"word"},{"id":38041,"position":4,"arabic":"نَارُ","translation":"আগুন","audioUrl":"wbw/035_036_004.mp3","charTypeName":"word"},{"id":38042,"position":5,"arabic":"جَهَنَّمَ","translation":"জাহান্নামের","audioUrl":"wbw/035_036_005.mp3","charTypeName":"word"},{"id":38043,"position":6,"arabic":"لَا","translation":"না","audioUrl":"wbw/035_036_006.mp3","charTypeName":"word"},{"id":38044,"position":7,"arabic":"يُقْضَىٰ","translation":"আদেশ দেয়া হবে(মৃত্যু)","audioUrl":"wbw/035_036_007.mp3","charTypeName":"word"},{"id":38045,"position":8,"arabic":"عَلَيْهِمْ","translation":"তাদের উপর","audioUrl":"wbw/035_036_008.mp3","charTypeName":"word"},{"id":38046,"position":9,"arabic":"فَيَمُوتُوا۟","translation":"যে তারা মরবে","audioUrl":"wbw/035_036_009.mp3","charTypeName":"word"},{"id":38047,"position":10,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/035_036_010.mp3","charTypeName":"word"},{"id":38048,"position":11,"arabic":"يُخَفَّفُ","translation":"হাল্কা করা হবে","audioUrl":"wbw/035_036_011.mp3","charTypeName":"word"},{"id":38049,"position":12,"arabic":"عَنْهُم","translation":"তাদের থেকে","audioUrl":"wbw/035_036_012.mp3","charTypeName":"word"},{"id":38050,"position":13,"arabic":"مِّنْ","translation":"কিছু","audioUrl":"wbw/035_036_013.mp3","charTypeName":"word"},{"id":38051,"position":14,"arabic":"عَذَابِهَا ۚ","translation":"তার শাস্তি","audioUrl":"wbw/035_036_014.mp3","charTypeName":"word"},{"id":38053,"position":15,"arabic":"كَذَٰلِكَ","translation":"এরূপে","audioUrl":"wbw/035_036_016.mp3","charTypeName":"word"},{"id":38054,"position":16,"arabic":"نَجْزِى","translation":"প্রতিফল দিই আমরা","audioUrl":"wbw/035_036_017.mp3","charTypeName":"word"},{"id":38055,"position":17,"arabic":"كُلَّ","translation":"প্রত্যেকে","audioUrl":"wbw/035_036_018.mp3","charTypeName":"word"},{"id":38056,"position":18,"arabic":"كَفُورٍۢ","translation":"অকৃতজ্ঞকে","audioUrl":"wbw/035_036_019.mp3","charTypeName":"word"},{"id":38057,"position":19,"arabic":"٣٦","translation":"(৩৬)","audioUrl":null,"charTypeName":"end"}]},{"number":37,"arabic":"وَهُمْ يَصْطَرِخُونَ فِيهَا رَبَّنَآ أَخْرِجْنَا نَعْمَلْ صَٰلِحًا غَيْرَ ٱلَّذِى كُنَّا نَعْمَلُ ۚ أَوَلَمْ نُعَمِّرْكُم مَّا يَتَذَكَّرُ فِيهِ مَن تَذَكَّرَ وَجَآءَكُمُ ٱلنَّذِيرُ ۖ فَذُوقُوا۟ فَمَا لِلظَّٰلِمِينَ مِن نَّصِيرٍ","translation":"And in that [hell] they will cry aloud: “O our Sustainer! Cause us to come out [of this suffering]! We shall [henceforth] do good deeds, not such as we were wont to do [aforetime]!” [But We shall answer:] “Did We not grant you a life long enough so that whoever was willing to take thought could bethink himself? And [withal,] a war­ner had come unto you! Taste, then, [the fruit of your evil deeds]: for evildoers shall have none to succour them!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3697.mp3","surahId":35,"words":[{"id":39350,"position":1,"arabic":"وَهُمْ","translation":"এবং তারা","audioUrl":"wbw/035_037_001.mp3","charTypeName":"word"},{"id":39351,"position":2,"arabic":"يَصْطَرِخُونَ","translation":"চিৎকার করে বলবে","audioUrl":"wbw/035_037_002.mp3","charTypeName":"word"},{"id":39352,"position":3,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/035_037_003.mp3","charTypeName":"word"},{"id":39353,"position":4,"arabic":"رَبَّنَآ","translation":"\"হে আমাদের রব","audioUrl":"wbw/035_037_004.mp3","charTypeName":"word"},{"id":39354,"position":5,"arabic":"أَخْرِجْنَا","translation":"আমাদেরকে বের করুন","audioUrl":"wbw/035_037_005.mp3","charTypeName":"word"},{"id":39355,"position":6,"arabic":"نَعْمَلْ","translation":"আমরা কাজ করবো","audioUrl":"wbw/035_037_006.mp3","charTypeName":"word"},{"id":39356,"position":7,"arabic":"صَـٰلِحًا","translation":"সৎ","audioUrl":"wbw/035_037_007.mp3","charTypeName":"word"},{"id":39357,"position":8,"arabic":"غَيْرَ","translation":"(তা হ'তে)ভিন্নতর","audioUrl":"wbw/035_037_008.mp3","charTypeName":"word"},{"id":39358,"position":9,"arabic":"ٱلَّذِى","translation":"যা","audioUrl":"wbw/035_037_009.mp3","charTypeName":"word"},{"id":39359,"position":10,"arabic":"كُنَّا","translation":"আমরা","audioUrl":"wbw/035_037_010.mp3","charTypeName":"word"},{"id":39360,"position":11,"arabic":"نَعْمَلُ ۚ","translation":"করতেছিলাম\"","audioUrl":"wbw/035_037_011.mp3","charTypeName":"word"},{"id":39362,"position":12,"arabic":"أَوَلَمْ","translation":"(বলা হবে) নি কি","audioUrl":"wbw/035_037_013.mp3","charTypeName":"word"},{"id":39363,"position":13,"arabic":"نُعَمِّرْكُم","translation":"তোমাদের আমরা আয়ু বৃদ্ধি করেছি","audioUrl":"wbw/035_037_014.mp3","charTypeName":"word"},{"id":39364,"position":14,"arabic":"مَّا","translation":"যাতে","audioUrl":"wbw/035_037_015.mp3","charTypeName":"word"},{"id":39365,"position":15,"arabic":"يَتَذَكَّرُ","translation":"শিক্ষা গ্রহণ করতে","audioUrl":"wbw/035_037_016.mp3","charTypeName":"word"},{"id":39366,"position":16,"arabic":"فِيهِ","translation":"তার মধ্যে","audioUrl":"wbw/035_037_017.mp3","charTypeName":"word"},{"id":39367,"position":17,"arabic":"مَن","translation":"কেউ","audioUrl":"wbw/035_037_018.mp3","charTypeName":"word"},{"id":39368,"position":18,"arabic":"تَذَكَّرَ","translation":"শিক্ষা নিতে (চাইলে)","audioUrl":"wbw/035_037_019.mp3","charTypeName":"word"},{"id":39369,"position":19,"arabic":"وَجَآءَكُمُ","translation":"এবং তোমাদের (কাছে) এসেছিলেন","audioUrl":"wbw/035_037_020.mp3","charTypeName":"word"},{"id":39370,"position":20,"arabic":"ٱلنَّذِيرُ ۖ","translation":"সতর্ককারী","audioUrl":"wbw/035_037_021.mp3","charTypeName":"word"},{"id":39372,"position":21,"arabic":"فَذُوقُوا۟","translation":"সুতরাং তোমরা স্বাদ নাও","audioUrl":"wbw/035_037_023.mp3","charTypeName":"word"},{"id":39373,"position":22,"arabic":"فَمَا","translation":"অতঃপর নাই","audioUrl":"wbw/035_037_024.mp3","charTypeName":"word"},{"id":39374,"position":23,"arabic":"لِلظَّـٰلِمِينَ","translation":"সীমালঙ্ঘনকারীদের জন্যে","audioUrl":"wbw/035_037_025.mp3","charTypeName":"word"},{"id":39375,"position":24,"arabic":"مِن","translation":"কোনো","audioUrl":"wbw/035_037_026.mp3","charTypeName":"word"},{"id":39376,"position":25,"arabic":"نَّصِيرٍ","translation":"সাহায্যকারী","audioUrl":"wbw/035_037_027.mp3","charTypeName":"word"},{"id":39377,"position":26,"arabic":"٣٧","translation":"(৩৭)","audioUrl":null,"charTypeName":"end"}]},{"number":38,"arabic":"إِنَّ ٱللَّهَ عَٰلِمُ غَيْبِ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ ۚ إِنَّهُۥ عَلِيمٌۢ بِذَاتِ ٱلصُّدُورِ","translation":"Verily, God knows the hidden reality of the heavens and the earth: [and,] behold, He has full knowledge of what is in the hearts [of men].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3698.mp3","surahId":35,"words":[{"id":40195,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/035_038_001.mp3","charTypeName":"word"},{"id":40196,"position":2,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/035_038_002.mp3","charTypeName":"word"},{"id":40197,"position":3,"arabic":"عَـٰلِمُ","translation":"অবগত","audioUrl":"wbw/035_038_003.mp3","charTypeName":"word"},{"id":40198,"position":4,"arabic":"غَيْبِ","translation":"গোপন রহস্যের","audioUrl":"wbw/035_038_004.mp3","charTypeName":"word"},{"id":40199,"position":5,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশের","audioUrl":"wbw/035_038_005.mp3","charTypeName":"word"},{"id":40200,"position":6,"arabic":"وَٱلْأَرْضِ ۚ","translation":"ও পৃথিবীর","audioUrl":"wbw/035_038_006.mp3","charTypeName":"word"},{"id":40202,"position":7,"arabic":"إِنَّهُۥ","translation":"তিনি নিশ্চযই়","audioUrl":"wbw/035_038_008.mp3","charTypeName":"word"},{"id":40203,"position":8,"arabic":"عَلِيمٌۢ","translation":"খুব অবহিত","audioUrl":"wbw/035_038_009.mp3","charTypeName":"word"},{"id":40204,"position":9,"arabic":"بِذَاتِ","translation":"অবস্থা সম্পর্কে","audioUrl":"wbw/035_038_010.mp3","charTypeName":"word"},{"id":40205,"position":10,"arabic":"ٱلصُّدُورِ","translation":"অন্তরসমূহের","audioUrl":"wbw/035_038_011.mp3","charTypeName":"word"},{"id":40206,"position":11,"arabic":"٣٨","translation":"(৩৮)","audioUrl":null,"charTypeName":"end"}]}]}