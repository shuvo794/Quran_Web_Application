{"id":529,"ayahs":[{"number":7,"arabic":"خُشَّعًا أَبْصَٰرُهُمْ يَخْرُجُونَ مِنَ ٱلْأَجْدَاثِ كَأَنَّهُمْ جَرَادٌۭ مُّنتَشِرٌۭ","translation":"they will come forth from their graves, with their eyes downcast, [swarming about] like locusts scattered [by the wind],","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4853.mp3","surahId":54,"words":[{"id":7486,"position":1,"arabic":"خُشَّعًا","translation":"অবনমিত অবস্থায়(থাকবে)","audioUrl":"wbw/054_007_001.mp3","charTypeName":"word"},{"id":7487,"position":2,"arabic":"أَبْصَـٰرُهُمْ","translation":"তাদের দৃষ্টি","audioUrl":"wbw/054_007_002.mp3","charTypeName":"word"},{"id":7488,"position":3,"arabic":"يَخْرُجُونَ","translation":"তারা বের হবে (সেদিন)","audioUrl":"wbw/054_007_003.mp3","charTypeName":"word"},{"id":7489,"position":4,"arabic":"مِنَ","translation":"হতে","audioUrl":"wbw/054_007_004.mp3","charTypeName":"word"},{"id":7490,"position":5,"arabic":"ٱلْأَجْدَاثِ","translation":"কবরসমূহ","audioUrl":"wbw/054_007_005.mp3","charTypeName":"word"},{"id":7491,"position":6,"arabic":"كَأَنَّهُمْ","translation":"(মনে হবে) তারা যেন","audioUrl":"wbw/054_007_006.mp3","charTypeName":"word"},{"id":7492,"position":7,"arabic":"جَرَادٌۭ","translation":"পঙ্গপাল","audioUrl":"wbw/054_007_007.mp3","charTypeName":"word"},{"id":7493,"position":8,"arabic":"مُّنتَشِرٌۭ","translation":"বিক্ষিপ্ত","audioUrl":"wbw/054_007_008.mp3","charTypeName":"word"},{"id":7494,"position":9,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"مُّهْطِعِينَ إِلَى ٱلدَّاعِ ۖ يَقُولُ ٱلْكَٰفِرُونَ هَٰذَا يَوْمٌ عَسِرٌۭ","translation":"running in con­fusion towards the Summoning Voice; [and] those who [now] deny the truth will exclaim, “Calamitous is this Day!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4854.mp3","surahId":54,"words":[{"id":8731,"position":1,"arabic":"مُّهْطِعِينَ","translation":"তারা দৌড়াবে (ভীতবিহ্বল হয়ে)","audioUrl":"wbw/054_008_001.mp3","charTypeName":"word"},{"id":873