َآ أَبْصَٰرُهُمْ وَلَآ أَفْـِٔدَتُهُم مِّن شَىْءٍ إِذْ كَانُوا۟ يَجْحَدُونَ بِـَٔايَٰتِ ٱللَّهِ وَحَاقَ بِهِم مَّا كَانُوا۟ بِهِۦ يَسْتَهْزِءُونَ","translation":"And yet, We had established them securely in a manner in which We have never established you, [O people of later times;] and We had endowed them with hearing, and sight, and [knowledgeable] hearts: but neither their hearing, nor their sight, nor their hearts were of the least avail to them, seeing that they went on rejecting God’s messages; and [in the end] they were overwhelmed by the very thing which they had been wont to deride.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4536.mp3","surahId":46,"words":[{"id":29000,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/046_026_001.mp3","charTypeName":"word"},{"id":29001,"position":2,"arabic":"مَكَّنَّـٰهُمْ","translation":"তাদেরকে আমরা ক্ষমতা দিয়েছিলাম","audioUrl":"wbw/046_026_002.mp3","charTypeName":"word"},{"id":29002,"position":3,"arabic":"فِيمَآ","translation":"এমন বিষয়ে যার","audioUrl":"wbw/046_026_003.mp3","charTypeName":"word"},{"id":29003,"position":4,"arabic":"إِن","translation":"না","audioUrl":"wbw/046_026_004.mp3","charTypeName":"word"},{"id":29004,"position":5,"arabic":"مَّكَّنَّـٰكُمْ","translation":"তোমাদেরকে আমরা ক্ষমতা দিয়েছি","audioUrl":"wbw/046_026_005.mp3","charTypeName":"word"},{"id":29005,"position":6,"arabic":"فِيهِ","translation":"সেসব বিষয়ে","audioUrl":"wbw/046_026_006.mp3","charTypeName":"word"},{"id":29006,"position":7,"arabic":"وَجَعَلْنَا","translation":"এবং আমরা দিয়েছিলাম","audioUrl":"wbw/046_026_007.mp3","charTypeName":"word"},{"id":29007,"position":8,"arabic":"لَهُمْ","translation":"তাদেরকে","audioUrl":"wbw/046_026_008.mp3","charTypeName":"word"},{"id":29008,"position":9,"arabic":"سَمْعًۭا","translation":"কান","audioUrl":"wbw/046_026_009.mp3","charTypeName":"word"},{"id":29009,"position":10,"arabic":"وَأَبْصَـٰرًۭا","translation":"ও চোখ","audioUrl":"wbw/046_026_010.mp3","c