of His bounty, and thus have cause to be grateful [to Him].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1915.mp3","surahId":16,"words":[{"id":16760,"position":1,"arabic":"وَهُوَ","translation":"এবং তিনি","audioUrl":"wbw/016_014_001.mp3","charTypeName":"word"},{"id":16761,"position":2,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/016_014_002.mp3","charTypeName":"word"},{"id":16762,"position":3,"arabic":"سَخَّرَ","translation":"অধীন করেছেন","audioUrl":"wbw/016_014_003.mp3","charTypeName":"word"},{"id":16763,"position":4,"arabic":"ٱلْبَحْرَ","translation":"সমুদ্রকে","audioUrl":"wbw/016_014_004.mp3","charTypeName":"word"},{"id":16764,"position":5,"arabic":"لِتَأْكُلُوا۟","translation":"যেন তোমরা  খেতে পারো","audioUrl":"wbw/016_014_005.mp3","charTypeName":"word"},{"id":16765,"position":6,"arabic":"مِنْهُ","translation":"তা থেকে","audioUrl":"wbw/016_014_006.mp3","charTypeName":"word"},{"id":16766,"position":7,"arabic":"لَحْمًۭا","translation":"(মাছ) গোশত","audioUrl":"wbw/016_014_007.mp3","charTypeName":"word"},{"id":16767,"position":8,"arabic":"طَرِيًّۭا","translation":"তাজা","audioUrl":"wbw/016_014_008.mp3","charTypeName":"word"},{"id":16768,"position":9,"arabic":"وَتَسْتَخْرِجُوا۟","translation":"তোমরা বের করতে পারো","audioUrl":"wbw/016_014_009.mp3","charTypeName":"word"},{"id":16769,"position":10,"arabic":"مِنْهُ","translation":"তা থেকে","audioUrl":"wbw/016_014_010.mp3","charTypeName":"word"},{"id":16770,"position":11,"arabic":"حِلْيَةًۭ","translation":"সৌন্দর্য শোভা (মনি-মুক্তা)","audioUrl":"wbw/016_014_011.mp3","charTypeName":"word"},{"id":16771,"position":12,"arabic":"تَلْبَسُونَهَا","translation":"তোমরা তা পরিধান করো","audioUrl":"wbw/016_014_012.mp3","charTypeName":"word"},{"id":16772,"position":13,"arabic":"وَتَرَى","translation":"এবং দেখছো","audioUrl":"wbw/016_014_013.mp3","charTypeName":"word"},{"id":16773,"position":14,"arabic":"ٱلْفُلْكَ","translation":"নৌযানসমূহকে","audioUrl":"wbw/016_014_014.mp3","charTypeName":"word"},{"id":1