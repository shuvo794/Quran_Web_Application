{"id":268,"ayahs":[{"number":7,"arabic":"وَتَحْمِلُ أَثْقَالَكُمْ إِلَىٰ بَلَدٍۢ لَّمْ تَكُونُوا۟ بَٰلِغِيهِ إِلَّا بِشِقِّ ٱلْأَنفُسِ ۚ إِنَّ رَبَّكُمْ لَرَءُوفٌۭ رَّحِيمٌۭ","translation":"And they carry your loads to [many] a place which [otherwise] you would be unable to reach without great hardship to yourselves. Verily, your Sustainer is most compassionate, a dispenser of grace!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1908.mp3","surahId":16,"words":[{"id":8395,"position":1,"arabic":"وَتَحْمِلُ","translation":"এবং তা বহন করে","audioUrl":"wbw/016_007_001.mp3","charTypeName":"word"},{"id":8396,"position":2,"arabic":"أَثْقَالَكُمْ","translation":"তোমাদের ভার","audioUrl":"wbw/016_007_002.mp3","charTypeName":"word"},{"id":8397,"position":3,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/016_007_003.mp3","charTypeName":"word"},{"id":8398,"position":4,"arabic":"بَلَدٍۢ","translation":"এমন শহরের","audioUrl":"wbw/016_007_004.mp3","charTypeName":"word"},{"id":8399,"position":5,"arabic":"لَّمْ","translation":"না","audioUrl":"wbw/016_007_005.mp3","charTypeName":"word"},{"id":8400,"position":6,"arabic":"تَكُونُوا۟","translation":"তোমরা ছিলে","audioUrl":"wbw/016_007_006.mp3","charTypeName":"word"},{"id":8401,"position":7,"arabic":"بَـٰلِغِيهِ","translation":"সেখানে পৌঁছাতে সক্ষম","audioUrl":"wbw/016_007_007.mp3","charTypeName":"word"},{"id":8402,"position":8,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/016_007_008.mp3","charTypeName":"word"},{"id":8403,"position":9,"arabic":"بِشِقِّ","translation":"সহ কষ্ট","audioUrl":"wbw/016_007_009.mp3","charTypeName":"word"},{"id":8404,"position":10,"arabic":"ٱلْأَنفُسِ ۚ","translation":"প্রানান্ত","audioUrl":"wbw/016_007_010.mp3","charTypeName":"word"},{"id":8406,"position":11,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/016_007_012.mp3","charTypeName":"word"},{"id":8407,"position":12,"arabic":"رَبَّكُمْ","translation":"তোমার রব","audioUrl":"wbw/016_007_013.mp3","charTypeName":"word"},{"id":8408,"position":13,"arabic":"لَرَءُوفٌۭ","translation":"অবশ্যই অনুগ্রহশীল","audioUrl":"wbw/016_007_014.mp3","charTypeName":"word"},{"id":8409,"position":14,"arabic":"رَّحِيمٌۭ","translation":"পরম দয়ালু","audioUrl":"wbw/016_007_015.mp3","charTypeName":"word"},{"id":8410,"position":15,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"وَٱلْخَيْلَ وَٱلْبِغَالَ وَٱلْحَمِيرَ لِتَرْكَبُوهَا وَزِينَةًۭ ۚ وَيَخْلُقُ مَا لَا تَعْلَمُونَ","translation":"And (it is He who creates] horses and mules and asses for you to ride, as well as for [their] beauty: and He will yet create things of which [today] you have no knowledge.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1909.mp3","surahId":16,"words":[{"id":9587,"position":1,"arabic":"وَٱلْخَيْلَ","translation":"এবং ঘোড়া (সৃষ্টি করেছেন)","audioUrl":"wbw/016_008_001.mp3","charTypeName":"word"},{"id":9588,"position":2,"arabic":"وَٱلْبِغَالَ","translation":"ও খচ্চর","audioUrl":"wbw/016_008_002.mp3","charTypeName":"word"},{"id":9589,"position":3,"arabic":"وَٱلْحَمِيرَ","translation":"ও গাধা","audioUrl":"wbw/016_008_003.mp3","charTypeName":"word"},{"id":9590,"position":4,"arabic":"لِتَرْكَبُوهَا","translation":"জন্যে তোমাদের চড়ার","audioUrl":"wbw/016_008_004.mp3","charTypeName":"word"},{"id":9591,"position":5,"arabic":"وَزِينَةًۭ ۚ","translation":"ও শোভা (স্বরূপ)","audioUrl":"wbw/016_008_005.mp3","charTypeName":"word"},{"id":9593,"position":6,"arabic":"وَيَخْلُقُ","translation":"এবং তিনি সৃষ্টি করেছেন","audioUrl":"wbw/016_008_007.mp3","charTypeName":"word"},{"id":9594,"position":7,"arabic":"مَا","translation":"(কিছু) যা","audioUrl":"wbw/016_008_008.mp3","charTypeName":"word"},{"id":9595,"position":8,"arabic":"لَا","translation":"না","audioUrl":"wbw/016_008_009.mp3","charTypeName":"word"},{"id":9596,"position":9,"arabic":"تَعْلَمُونَ","translation":"তোমরা জানো","audioUrl":"wbw/016_008_010.mp3","charTypeName":"word"},{"id":9597,"position":10,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"وَعَلَى ٱللَّهِ قَصْدُ ٱلسَّبِيلِ وَمِنْهَا جَآئِرٌۭ ۚ وَلَوْ شَآءَ لَهَدَىٰكُمْ أَجْمَعِينَ","translation":"And [because He is your Creator,] it rests with God alone to show you the right path: yet there is [many a one] who swerves from it. However, had He so willed, He would have guided you all aright.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1910.mp3","surahId":16,"words":[{"id":10760,"position":1,"arabic":"وَعَلَى","translation":"এবং উপর","audioUrl":"wbw/016_009_001.mp3","charTypeName":"word"},{"id":10761,"position":2,"arabic":"ٱللَّهِ","translation":"আল্লাহর (দায়িত্ব)","audioUrl":"wbw/016_009_002.mp3","charTypeName":"word"},{"id":10762,"position":3,"arabic":"قَصْدُ","translation":"প্রদর্শন","audioUrl":"wbw/016_009_003.mp3","charTypeName":"word"},{"id":10763,"position":4,"arabic":"ٱلسَّبِيلِ","translation":"পথ","audioUrl":"wbw/016_009_004.mp3","charTypeName":"word"},{"id":10764,"position":5,"arabic":"وَمِنْهَا","translation":"কিন্তু তা থেকে আছে","audioUrl":"wbw/016_009_005.mp3","charTypeName":"word"},{"id":10765,"position":6,"arabic":"جَآئِرٌۭ ۚ","translation":"বাঁকা (পথও)","audioUrl":"wbw/016_009_006.mp3","charTypeName":"word"},{"id":10767,"position":7,"arabic":"وَلَوْ","translation":"এবং যদি","audioUrl":"wbw/016_009_008.mp3","charTypeName":"word"},{"id":10768,"position":8,"arabic":"شَآءَ","translation":"ইচ্ছে করেন","audioUrl":"wbw/016_009_009.mp3","charTypeName":"word"},{"id":10769,"position":9,"arabic":"لَهَدَىٰكُمْ","translation":"অবশ্যই সৎপথে পরিচালনা করতেন তোমাদের","audioUrl":"wbw/016_009_010.mp3","charTypeName":"word"},{"id":10770,"position":10,"arabic":"أَجْمَعِينَ","translation":"সকলকেই","audioUrl":"wbw/016_009_011.mp3","charTypeName":"word"},{"id":10771,"position":11,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"هُوَ ٱلَّذِىٓ أَنزَلَ مِنَ ٱلسَّمَآءِ مَآءًۭ ۖ لَّكُم مِّنْهُ شَرَابٌۭ وَمِنْهُ شَجَرٌۭ فِيهِ تُسِيمُونَ","translation":"It is He who sends down water from the skies; you drink thereof, and thereof [drink] the plants upon which you pasture your beasts;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1911.mp3","surahId":16,"words":[{"id":12011,"position":1,"arabic":"هُوَ","translation":"তিনিই (রব)","audioUrl":"wbw/016_010_001.mp3","charTypeName":"word"},{"id":12012,"position":2,"arabic":"ٱلَّذِىٓ","translation":"যিনি","audioUrl":"wbw/016_010_002.mp3","charTypeName":"word"},{"id":12013,"position":3,"arabic":"أَنزَلَ","translation":"বর্ষণ করেছেন","audioUrl":"wbw/016_010_003.mp3","charTypeName":"word"},{"id":12014,"position":4,"arabic":"مِنَ","translation":"থেকে","audioUrl":"wbw/016_010_004.mp3","charTypeName":"word"},{"id":12015,"position":5,"arabic":"ٱلسَّمَآءِ","translation":"আকাশ","audioUrl":"wbw/016_010_005.mp3","charTypeName":"word"},{"id":12016,"position":6,"arabic":"مَآءًۭ ۖ","translation":"পানি","audioUrl":"wbw/016_010_006.mp3","charTypeName":"word"},{"id":12018,"position":7,"arabic":"لَّكُم","translation":"জন্যে তোমাদের","audioUrl":"wbw/016_010_008.mp3","charTypeName":"word"},{"id":12019,"position":8,"arabic":"مِّنْهُ","translation":"কিছু তার","audioUrl":"wbw/016_010_009.mp3","charTypeName":"word"},{"id":12020,"position":9,"arabic":"شَرَابٌۭ","translation":"পানীয় (পেয়ে থাকো)","audioUrl":"wbw/016_010_010.mp3","charTypeName":"word"},{"id":12021,"position":10,"arabic":"وَمِنْهُ","translation":"এবং তা থেকে","audioUrl":"wbw/016_010_011.mp3","charTypeName":"word"},{"id":12022,"position":11,"arabic":"شَجَرٌۭ","translation":"গাছপালা (জন্মে)","audioUrl":"wbw/016_010_012.mp3","charTypeName":"word"},{"id":12023,"position":12,"arabic":"فِيهِ","translation":"তার মধ্যে","audioUrl":"wbw/016_010_013.mp3","charTypeName":"word"},{"id":12024,"position":13,"arabic":"تُسِيمُونَ","translation":"তোমরা পশু চরিয়ে থাকো","audioUrl":"wbw/016_010_014.mp3","charTypeName":"word"},{"id":12025,"position":14,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"يُنۢبِتُ لَكُم بِهِ ٱلزَّرْعَ وَٱلزَّيْتُونَ وَٱلنَّخِيلَ وَٱلْأَعْنَٰبَ وَمِن كُلِّ ٱلثَّمَرَٰتِ ۗ إِنَّ فِى ذَٰلِكَ لَءَايَةًۭ لِّقَوْمٍۢ يَتَفَكَّرُونَ","translation":"[and] by virtue thereof He causes crops to grow for you, and olive trees, and date palms, and grapes, and all [other] kinds of fruit: in this, behold, there is a message indeed for people who think!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1912.mp3","surahId":16,"words":[{"id":13332,"position":1,"arabic":"يُنۢبِتُ","translation":"তিনি উদগত করেন","audioUrl":"wbw/016_011_001.mp3","charTypeName":"word"},{"id":13333,"position":2,"arabic":"لَكُم","translation":"জন্যে তোমাদের","audioUrl":"wbw/016_011_002.mp3","charTypeName":"word"},{"id":13334,"position":3,"arabic":"بِهِ","translation":"দিয়ে তা","audioUrl":"wbw/016_011_003.mp3","charTypeName":"word"},{"id":13335,"position":4,"arabic":"ٱلزَّرْعَ","translation":"শস্য","audioUrl":"wbw/016_011_004.mp3","charTypeName":"word"},{"id":13336,"position":5,"arabic":"وَٱلزَّيْتُونَ","translation":"ও যায়তুনসমূহ","audioUrl":"wbw/016_011_005.mp3","charTypeName":"word"},{"id":13337,"position":6,"arabic":"وَٱلنَّخِيلَ","translation":"ও খেজুরসমূহ","audioUrl":"wbw/016_011_006.mp3","charTypeName":"word"},{"id":13338,"position":7,"arabic":"وَٱلْأَعْنَـٰبَ","translation":"ও আঙ্গুরসমূহ","audioUrl":"wbw/016_011_007.mp3","charTypeName":"word"},{"id":13339,"position":8,"arabic":"وَمِن","translation":"এবং ধরণের","audioUrl":"wbw/016_011_008.mp3","charTypeName":"word"},{"id":13340,"position":9,"arabic":"كُلِّ","translation":"সব","audioUrl":"wbw/016_011_009.mp3","charTypeName":"word"},{"id":13341,"position":10,"arabic":"ٱلثَّمَرَٰتِ ۗ","translation":"ফলসমূহ","audioUrl":"wbw/016_011_010.mp3","charTypeName":"word"},{"id":13343,"position":11,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/016_011_012.mp3","charTypeName":"word"},{"id":13344,"position":12,"arabic":"فِى","translation":"মধ্যে (রয়েছে)","audioUrl":"wbw/016_011_013.mp3","charTypeName":"word"},{"id":13345,"position":13,"arabic":"ذَٰلِكَ","translation":"এর","audioUrl":"wbw/016_011_014.mp3","charTypeName":"word"},{"id":13346,"position":14,"arabic":"لَـَٔايَةًۭ","translation":"অবশ্যই নিদর্শন","audioUrl":"wbw/016_011_015.mp3","charTypeName":"word"},{"id":13347,"position":15,"arabic":"لِّقَوْمٍۢ","translation":"লোকদের জন্যে","audioUrl":"wbw/016_011_016.mp3","charTypeName":"word"},{"id":13348,"position":16,"arabic":"يَتَفَكَّرُونَ","translation":"(যারা) চিন্তা ভাবনা করে","audioUrl":"wbw/016_011_017.mp3","charTypeName":"word"},{"id":13349,"position":17,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]},{"number":12,"arabic":"وَسَخَّرَ لَكُمُ ٱلَّيْلَ وَٱلنَّهَارَ وَٱلشَّمْسَ وَٱلْقَمَرَ ۖ وَٱلنُّجُومُ مُسَخَّرَٰتٌۢ بِأَمْرِهِۦٓ ۗ إِنَّ فِى ذَٰلِكَ لَءَايَٰتٍۢ لِّقَوْمٍۢ يَعْقِلُونَ","translation":"And He has made the night and the day and the sun and the moon subservient [to His laws, so that they be of use] to you; and all the stars are subservient to His command: in this, behold, there are messages indeed for people who use their reason!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1913.mp3","surahId":16,"words":[{"id":14611,"position":1,"arabic":"وَسَخَّرَ","translation":"এবং অধীন করেছেন","audioUrl":"wbw/016_012_001.mp3","charTypeName":"word"},{"id":14612,"position":2,"arabic":"لَكُمُ","translation":"তোমাদের জন্যে","audioUrl":"wbw/016_012_002.mp3","charTypeName":"word"},{"id":14613,"position":3,"arabic":"ٱلَّيْلَ","translation":"রাতকে","audioUrl":"wbw/016_012_003.mp3","charTypeName":"word"},{"id":14614,"position":4,"arabic":"وَٱلنَّهَارَ","translation":"ও দিনকে","audioUrl":"wbw/016_012_004.mp3","charTypeName":"word"},{"id":14615,"position":5,"arabic":"وَٱلشَّمْسَ","translation":"এবং সূর্যকে","audioUrl":"wbw/016_012_005.mp3","charTypeName":"word"},{"id":14616,"position":6,"arabic":"وَٱلْقَمَرَ ۖ","translation":"ও চাঁদকে","audioUrl":"wbw/016_012_006.mp3","charTypeName":"word"},{"id":14618,"position":7,"arabic":"وَٱلنُّجُومُ","translation":"এবং তারাগুলোও","audioUrl":"wbw/016_012_008.mp3","charTypeName":"word"},{"id":14619,"position":8,"arabic":"مُسَخَّرَٰتٌۢ","translation":"অধীন হয়েছে","audioUrl":"wbw/016_012_009.mp3","charTypeName":"word"},{"id":14620,"position":9,"arabic":"بِأَمْرِهِۦٓ ۗ","translation":"দিয়ে তাঁর বিধান","audioUrl":"wbw/016_012_010.mp3","charTypeName":"word"},{"id":14622,"position":10,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/016_012_012.mp3","charTypeName":"word"},{"id":14623,"position":11,"arabic":"فِى","translation":"মধ্যে (রয়েছে)","audioUrl":"wbw/016_012_013.mp3","charTypeName":"word"},{"id":14624,"position":12,"arabic":"ذَٰلِكَ","translation":"এর","audioUrl":"wbw/016_012_014.mp3","charTypeName":"word"},{"id":14625,"position":13,"arabic":"لَـَٔايَـٰتٍۢ","translation":"অবশ্যই নিদর্শনসমূহ","audioUrl":"wbw/016_012_015.mp3","charTypeName":"word"},{"id":14626,"position":14,"arabic":"لِّقَوْمٍۢ","translation":"জন্যে লোকদের","audioUrl":"wbw/016_012_016.mp3","charTypeName":"word"},{"id":14627,"position":15,"arabic":"يَعْقِلُونَ","translation":"(যারা)জ্ঞান রাখে","audioUrl":"wbw/016_012_017.mp3","charTypeName":"word"},{"id":14628,"position":16,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]},{"number":13,"arabic":"وَمَا ذَرَأَ لَكُمْ فِى ٱلْأَرْضِ مُخْتَلِفًا أَلْوَٰنُهُۥٓ ۗ إِنَّ فِى ذَٰلِكَ لَءَايَةًۭ لِّقَوْمٍۢ يَذَّكَّرُونَ","translation":"And all the [beauty of] many hues-which He has created for you on earth: in this, behold, there is a message for people who (are willing to] take it to heart!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1914.mp3","surahId":16,"words":[{"id":15704,"position":1,"arabic":"وَمَا","translation":"আরো (কিছু) যা","audioUrl":"wbw/016_013_001.mp3","charTypeName":"word"},{"id":15705,"position":2,"arabic":"ذَرَأَ","translation":"সৃষ্টি করেছেন","audioUrl":"wbw/016_013_002.mp3","charTypeName":"word"},{"id":15706,"position":3,"arabic":"لَكُمْ"