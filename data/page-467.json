َصْحَـٰبُ","translation":"অধিবাসী","audioUrl":"wbw/040_006_009.mp3","charTypeName":"word"},{"id":5887,"position":10,"arabic":"ٱلنَّارِ","translation":"জাহান্নামের","audioUrl":"wbw/040_006_010.mp3","charTypeName":"word"},{"id":5888,"position":11,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"ٱلَّذِينَ يَحْمِلُونَ ٱلْعَرْشَ وَمَنْ حَوْلَهُۥ يُسَبِّحُونَ بِحَمْدِ رَبِّهِمْ وَيُؤْمِنُونَ بِهِۦ وَيَسْتَغْفِرُونَ لِلَّذِينَ ءَامَنُوا۟ رَبَّنَا وَسِعْتَ كُلَّ شَىْءٍۢ رَّحْمَةًۭ وَعِلْمًۭا فَٱغْفِرْ لِلَّذِينَ تَابُوا۟ وَٱتَّبَعُوا۟ سَبِيلَكَ وَقِهِمْ عَذَابَ ٱلْجَحِيمِ","translation":"THEY WHO BEAR [within themselves the knowl­edge of] the throne of [God’s] almightiness, as well as all who are near it, extol their Sustainer’s limitless glory and praise, and have faith in Him, and ask forgiveness for all [others] who have attained to faith: “O our Sustainer! Thou embracest all things within [Thy] grace and knowledge: forgive, then, their sins unto those who repent and follow Thy path, and preserve them from suffering through the blazing fire!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4140.mp3","surahId":40,"words":[{"id":7225,"position":1,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/040_007_001.mp3","charTypeName":"word"},{"id":7226,"position":2,"arabic":"يَحْمِلُونَ","translation":"ধারণ করছে","audioUrl":"wbw/040_007_002.mp3","charTypeName":"word"},{"id":7227,"position":3,"arabic":"ٱلْعَرْشَ","translation":"(আল্লাহর) আরশ","audioUrl":"wbw/040_007_003.mp3","charTypeName":"word"},{"id":7228,"position":4,"arabic":"وَمَنْ","translation":"এবং যারা (আছে)","audioUrl":"wbw/040_007_004.mp3","charTypeName":"word"},{"id":7229,"position":5,"arabic":"حَوْلَهُۥ","translation":"তার চার পাশে","audioUrl":"wbw/040_007_005.mp3","charTypeName":"word"},{"id":7230,"position":6,"arabic":"يُسَبِّحُونَ","translation":"তারা মহিমা ঘোষণা করছে","audioUrl":"wbw/040_007_006.mp3","charTypeName":"word"},{"id":7231,"position"