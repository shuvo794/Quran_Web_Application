,{"id":2041,"position":10,"arabic":"إِلَـٰهَ","translation":"কোনো ইলাহ","audioUrl":"wbw/040_003_011.mp3","charTypeName":"word"},{"id":2042,"position":11,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/040_003_012.mp3","charTypeName":"word"},{"id":2043,"position":12,"arabic":"هُوَ ۖ","translation":"তিনি","audioUrl":"wbw/040_003_013.mp3","charTypeName":"word"},{"id":2045,"position":13,"arabic":"إِلَيْهِ","translation":"তাঁরই দিকে","audioUrl":"wbw/040_003_015.mp3","charTypeName":"word"},{"id":2046,"position":14,"arabic":"ٱلْمَصِيرُ","translation":"প্রত্যাবর্তন (হবে সকলের)","audioUrl":"wbw/040_003_016.mp3","charTypeName":"word"},{"id":2047,"position":15,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"مَا يُجَٰدِلُ فِىٓ ءَايَٰتِ ٱللَّهِ إِلَّا ٱلَّذِينَ كَفَرُوا۟ فَلَا يَغْرُرْكَ تَقَلُّبُهُمْ فِى ٱلْبِلَٰدِ","translation":"NONE BUT THOSE who are bent on denying the truth would call God’s messages in question. But let it not deceive thee that they seem to be able to do as they please on earth:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4137.mp3","surahId":40,"words":[{"id":3286,"position":1,"arabic":"مَا","translation":"না","audioUrl":"wbw/040_004_001.mp3","charTypeName":"word"},{"id":3287,"position":2,"arabic":"يُجَـٰدِلُ","translation":"তর্ক করে","audioUrl":"wbw/040_004_002.mp3","charTypeName":"word"},{"id":3288,"position":3,"arabic":"فِىٓ","translation":"ক্ষেত্রে","audioUrl":"wbw/040_004_003.mp3","charTypeName":"word"},{"id":3289,"position":4,"arabic":"ءَايَـٰتِ","translation":"নিদর্শনাবলীর","audioUrl":"wbw/040_004_004.mp3","charTypeName":"word"},{"id":3290,"position":5,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/040_004_005.mp3","charTypeName":"word"},{"id":3291,"position":6,"arabic":"إِلَّا","translation":"এ ব্যতীত","audioUrl":"wbw/040_004_006.mp3","charTypeName":"word"},{"id":3292,"position":7,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/040_004_007.mp3","charTy