{"id":83,"ayahs":[{"number":27,"arabic":"وَٱللَّهُ يُرِيدُ أَن يَتُوبَ عَلَيْكُمْ وَيُرِيدُ ٱلَّذِينَ يَتَّبِعُونَ ٱلشَّهَوَٰتِ أَن تَمِيلُوا۟ مَيْلًا عَظِيمًۭا","translation":"And God wants to turn unto you in His mercy, whereas those who follow [only] their own lusts want you to drift far away from the right path.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/520.mp3","surahId":4,"words":[{"id":29525,"position":1,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/004_027_001.mp3","charTypeName":"word"},{"id":29526,"position":2,"arabic":"يُرِيدُ","translation":"চান","audioUrl":"wbw/004_027_002.mp3","charTypeName":"word"},{"id":29527,"position":3,"arabic":"أَن","translation":"যে","audioUrl":"wbw/004_027_003.mp3","charTypeName":"word"},{"id":29528,"position":4,"arabic":"يَتُوبَ","translation":"ক্ষমা করবেন","audioUrl":"wbw/004_027_004.mp3","charTypeName":"word"},{"id":29529,"position":5,"arabic":"عَلَيْكُمْ","translation":"তোমাদেরকে","audioUrl":"wbw/004_027_005.mp3","charTypeName":"word"},{"id":29530,"position":6,"arabic":"وَيُرِيدُ","translation":"এবং চায়","audioUrl":"wbw/004_027_006.mp3","charTypeName":"word"},{"id":29531,"position":7,"arabic":"ٱلَّذِينَ","translation":"(তারা) যারা","audioUrl":"wbw/004_027_007.mp3","charTypeName":"word"},{"id":29532,"position":8,"arabic":"يَتَّبِعُونَ","translation":"অনুসরণ করে","audioUrl":"wbw/004_027_008.mp3","charTypeName":"word"},{"id":29533,"position":9,"arabic":"ٱلشَّهَوَٰتِ","translation":"কুপ্রবৃত্তির","audioUrl":"wbw/004_027_009.mp3","charTypeName":"word"},{"id":29534,"position":10,"arabic":"أَن","translation":"যে","audioUrl":"wbw/004_027_010.mp3","charTypeName":"word"},{"id":29535,"position":11,"arabic":"تَمِيلُوا۟","translation":"তোমরা ঝুঁকে পড় (পথভ্রষ্টতার দিকে)","audioUrl":"wbw/004_027_011.mp3","charTypeName":"word"},{"id":29536,"position":12,"arabic":"مَيْلًا","translation":"ঝুঁকা","audioUrl":"wbw/004_027_012.mp3","charTypeName":"word"},{"id":29537,"position":13,"arabic":"عَظِيمًۭا","translation":"ভীষণভাবে","audioUrl":"wbw/004_027_013.mp3","charTypeName":"word"},{"id":29538,"position":14,"arabic":"٢٧","translation":"(২৭)","audioUrl":null,"charTypeName":"end"}]},{"number":28,"arabic":"يُرِيدُ ٱللَّهُ أَن يُخَفِّفَ عَنكُمْ ۚ وَخُلِقَ ٱلْإِنسَٰنُ ضَعِيفًۭا","translation":"God wants to lighten your burdens: for man has been created weak.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/521.mp3","surahId":4,"words":[{"id":30561,"position":1,"arabic":"يُرِيدُ","translation":"চান","audioUrl":"wbw/004_028_001.mp3","charTypeName":"word"},{"id":30562,"position":2,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/004_028_002.mp3","charTypeName":"word"},{"id":30563,"position":3,"arabic":"أَن","translation":"(যে)","audioUrl":"wbw/004_028_003.mp3","charTypeName":"word"},{"id":30564,"position":4,"arabic":"يُخَفِّفَ","translation":"হালকা করতে","audioUrl":"wbw/004_028_004.mp3","charTypeName":"word"},{"id":30565,"position":5,"arabic":"عَنكُمْ ۚ","translation":"তোমাদের থেকে (বোঝা)","audioUrl":"wbw/004_028_005.mp3","charTypeName":"word"},{"id":30567,"position":6,"arabic":"وَخُلِقَ","translation":"আর সৃষ্টি করা হয়েছে","audioUrl":"wbw/004_028_007.mp3","charTypeName":"word"},{"id":30568,"position":7,"arabic":"ٱلْإِنسَـٰنُ","translation":"মানুষকে","audioUrl":"wbw/004_028_008.mp3","charTypeName":"word"},{"id":30569,"position":8,"arabic":"ضَعِيفًۭا","translation":"দুর্বলভাবে","audioUrl":"wbw/004_028_009.mp3","charTypeName":"word"},{"id":30570,"position":9,"arabic":"٢٨","translation":"(২৮)","audioUrl":null,"charTypeName":"end"}]},{"number":29,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ لَا تَأْكُلُوٓا۟ أَمْوَٰلَكُم بَيْنَكُم بِٱلْبَٰطِلِ إِلَّآ أَن تَكُونَ تِجَٰرَةً عَن تَرَاضٍۢ مِّنكُمْ ۚ وَلَا تَقْتُلُوٓا۟ أَنفُسَكُمْ ۚ إِنَّ ٱللَّهَ كَانَ بِكُمْ رَحِيمًۭا","translation":"O YOU who have attained to faith! Do not devour one another's possessions wrongfully - not even by way of trade based on mutual agreement - and do not destroy one another: for, behold, God is indeed a dispenser of grace unto you!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/522.mp3","surahId":4,"words":[{"id":31567,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"ওহে","audioUrl":"wbw/004_029_001.mp3","charTypeName":"word"},{"id":31568,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/004_029_002.mp3","charTypeName":"word"},{"id":31569,"position":3,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/004_029_003.mp3","charTypeName":"word"},{"id":31570,"position":4,"arabic":"لَا","translation":"না","audioUrl":"wbw/004_029_004.mp3","charTypeName":"word"},{"id":31571,"position":5,"arabic":"تَأْكُلُوٓا۟","translation":"তোমরা খেয়ো","audioUrl":"wbw/004_029_005.mp3","charTypeName":"word"},{"id":31572,"position":6,"arabic":"أَمْوَٰلَكُم","translation":"তোমাদের মাল-সম্পদ","audioUrl":"wbw/004_029_006.mp3","charTypeName":"word"},{"id":31573,"position":7,"arabic":"بَيْنَكُم","translation":"তোমাদের মাঝে","audioUrl":"wbw/004_029_007.mp3","charTypeName":"word"},{"id":31574,"position":8,"arabic":"بِٱلْبَـٰطِلِ","translation":"অন্যায়ভাবে","audioUrl":"wbw/004_029_008.mp3","charTypeName":"word"},{"id":31575,"position":9,"arabic":"إِلَّآ","translation":"তবে (অবশ্যই)","audioUrl":"wbw/004_029_009.mp3","charTypeName":"word"},{"id":31576,"position":10,"arabic":"أَن","translation":"(যে)","audioUrl":"wbw/004_029_010.mp3","charTypeName":"word"},{"id":31577,"position":11,"arabic":"تَكُونَ","translation":"হবে","audioUrl":"wbw/004_029_011.mp3","charTypeName":"word"},{"id":31578,"position":12,"arabic":"تِجَـٰرَةً","translation":"ব্যবসা","audioUrl":"wbw/004_029_012.mp3","charTypeName":"word"},{"id":31579,"position":13,"arabic":"عَن","translation":"ভিত্তিতে","audioUrl":"wbw/004_029_013.mp3","charTypeName":"word"},{"id":31580,"position":14,"arabic":"تَرَاضٍۢ","translation":"সন্তোষের","audioUrl":"wbw/004_029_014.mp3","charTypeName":"word"},{"id":31581,"position":15,"arabic":"مِّنكُمْ ۚ","translation":"তোমাদের মধ্যকার","audioUrl":"wbw/004_029_015.mp3","charTypeName":"word"},{"id":31583,"position":16,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/004_029_017.mp3","charTypeName":"word"},{"id":31584,"position":17,"arabic":"تَقْتُلُوٓا۟","translation":"তোমরা হত্যা করো","audioUrl":"wbw/004_029_018.mp3","charTypeName":"word"},{"id":31585,"position":18,"arabic":"أَنفُسَكُمْ ۚ","translation":"তোমাদের নিজেদেরকে","audioUrl":"wbw/004_029_019.mp3","charTypeName":"word"},{"id":31587,"position":19,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/004_029_021.mp3","charTypeName":"word"},{"id":31588,"position":20,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/004_029_022.mp3","charTypeName":"word"},{"id":31589,"position":21,"arabic":"كَانَ","translation":"হলেন","audioUrl":"wbw/004_029_023.mp3","charTypeName":"word"},{"id":31590,"position":22,"arabic":"بِكُمْ","translation":"তোমাদের উপর","audioUrl":"wbw/004_029_024.mp3","charTypeName":"word"},{"id":31591,"position":23,"arabic":"رَحِيمًۭا","translation":"মেহেরবান","audioUrl":"wbw/004_029_025.mp3","charTypeName":"word"},{"id":31592,"position":24,"arabic":"٢٩","translation":"(২৯)","audioUrl":null,"charTypeName":"end"}]},{"number":30,"arabic":"وَمَن يَفْعَلْ ذَٰلِكَ عُدْوَٰنًۭا وَظُلْمًۭا فَسَوْفَ نُصْلِيهِ نَارًۭا ۚ وَكَانَ ذَٰلِكَ عَلَى ٱللَّهِ يَسِيرًا","translation":"And as for him who does this with malicious intent and a will to do wrong - him shall We, in time, cause to endure [suffering through] fire: for this is indeed easy for God.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/523.mp3","surahId":4,"words":[{"id":32486,"position":1,"arabic":"وَمَن","translation":"এবং যে","audioUrl":"wbw/004_030_001.mp3","charTypeName":"word"},{"id":32487,"position":2,"arabic":"يَفْعَلْ","translation":"করবে","audioUrl":"wbw/004_030_002.mp3","charTypeName":"word"},{"id":32488,"position":3,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/004_030_003.mp3","charTypeName":"word"},{"id":32489,"position":4,"arabic":"عُدْوَٰنًۭا","translation":"বাড়াবাড়ি স্বরূপ","audioUrl":"wbw/004_030_004.mp3","charTypeName":"word"},{"id":32490,"position":5,"arabic":"وَظُلْمًۭا","translation":"ও জুলুম স্বরূপ","audioUrl":"wbw/004_030_005.mp3","charTypeName":"word"},{"id":32491,"position":6,"arabic":"فَسَوْفَ","translation":"শীঘ্রই তা হলে","audioUrl":"wbw/004_030_006.mp3","charTypeName":"word"},{"id":32492,"position":7,"arabic":"نُصْلِيهِ","translation":"তাকে ঝলসাব আমরা","audioUrl":"wbw/004_030_007.mp3","charTypeName":"word"},{"id":32493,"position":8,"arabic":"نَارًۭا ۚ","translation":"আগুনে","audioUrl":"wbw/004_030_008.mp3","charTypeName":"word"},{"id":32495,"position":9,"arabic":"وَكَانَ","translation":"এবং হলো","audioUrl":"wbw/004_030_010.mp3","charTypeName":"word"},{"id":32496,"position":10,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/004_030_011.mp3","charTypeName":"word"},{"id":32497,"position":11,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/004_030_012.mp3","charTypeName":"word"},{"id":32498,"position":12,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌র","audioUrl":"wbw/004_030_013.mp3","charTypeName":"word"},{"id":32499,"position":13,"arabic":"يَسِيرًا","translation":"সহজ","audioUrl":"wbw/004_030_014.mp3","charTypeName":"word"},{"id":32500,"position":14,"arabic":"٣٠","translation":"(৩০)","audioUrl":null,"charTypeName":"end"}]},{"number":31,"arabic":"إِن تَجْتَنِبُوا۟ كَبَآئِرَ مَا تُنْهَوْنَ عَنْهُ نُكَفِّرْ عَنكُمْ سَيِّـَٔاتِكُمْ وَنُدْخِلْكُم مُّدْخَلًۭا كَرِيمًۭا","translation":"If you avoid the great sins, which you have been enjoined to shun, We shall efface your [minor] bad deeds, and shall cause you to enter an abode of glory.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/524.mp3","surahId":4,"words":[{"id":33339,"position":1,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/004_031_001.mp3","charTypeName":"word"},{"id":33340,"position":2,"arabic":"تَجْتَنِبُوا۟","translation":"তোমরা বেঁচে চল","audioUrl":"wbw/004_031_002.mp3","charTypeName":"word"},{"id":33341,"position":3,"arabic":"كَبَآئِرَ","translation":"বড় বড় গুনাহ (থেকে)","audioUrl":"wbw/004_031_003.mp3","charTypeName":"word"},{"id":33342,"position":4,"arabic":"مَا","translation":"যা","audioUrl":"wbw/004_031_004.mp3","charTypeName":"word"},{"id":33343,"position":5,"arabic":"تُنْهَوْنَ","translation":"তোমাদের নিষেধ করা হয়","audioUrl":"wbw/004_031_005.mp3","charTypeName":"word"},{"id":33344,"position":6,"arabic":"عَنْهُ","translation":"তা থেকে","audioUrl":"wbw/004_031_006.mp3","charTypeName":"word"},{"id":33345,"position":7,"arabic":"نُكَفِّرْ","translation":"মোচন করব আমরা","audioUrl":"wbw/004_031_007.mp3","charTypeName":"word"},{"id":33346,"position":8,"arabic":"عَنكُمْ","translation":"তোমাদের থেকে","audioUrl":"wbw/004_031_008.mp3","charTypeName":"word"},{"id":33347,"position":9,"arabic":"سَيِّـَٔاتِكُمْ","translation":"তোমাদের ছোট পাপগুলো","audioUrl":"wbw/004_031_009.mp3","charTypeName":"word"},{"id":33348,"position":10,"arabic":"وَنُدْخِلْكُم","translation":"ও তোমাদের আমরা প্রবেশ করাব","audioUrl":"wbw/004_031_010.mp3","charTypeName":"word"},{"id":33349,"position":11,"arabic":"مُّدْخَلًۭا","translation":"প্রবেশ পথে","audioUrl":"wbw/004_031_011.mp3","charTypeName":"word"},{"id":33350,"position":12,"arabic":"كَرِيمًۭا","translation":"সন্মানজনক","audioUrl":"wbw/004_031_012.mp3","charTypeName":"word"},{"id":33351,"position":13,"arabic":"٣١","translation":"(৩১)","audioUrl":null,"charTypeName":"end"}]},{"number":32,"arabic":"وَلَا تَتَمَنَّوْا۟ مَا فَضَّلَ ٱللَّهُ بِهِۦ بَعْضَكُمْ عَلَىٰ بَعْضٍۢ ۚ لِّلرِّجَالِ نَصِيبٌۭ مِّمَّا ٱكْتَسَبُوا۟ ۖ وَلِلنِّسَآءِ نَصِيبٌۭ مِّمَّا ٱكْتَسَبْنَ ۚ وَسْـَٔلُوا۟ ٱللَّهَ مِن فَضْلِهِۦٓ ۗ إِنَّ ٱللَّهَ كَانَ بِكُلِّ شَىْءٍ عَلِيمًۭا","translation":"Hence, do not covet the bounties which God has bestowed more abundantly on some of you than on others. Men shall have a benefit from what they earn, and women shall have a benefit from what they earn. Ask, therefore, God [to give you] out of His bounty: behold, God has indeed full knowledge of everything.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/525.mp3","surahId":4,"words":[{"id":34370,"position":1,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/004_032_001.mp3","charTypeName":"word"},{"id":34371,"position":2,"arabic":"تَتَمَنَّوْا۟","translation":"তোমরা লোভ করো","audioUrl":"wbw/004_032_002.mp3","charTypeName":"word"},{"id":34372,"position":3,"arabic":"مَا","translation":"যা","audioUrl":"wbw/004_032_003.mp3","charTypeName":"word"},{"id":34373,"position":4,"arabic":"فَضَّلَ","translation":"শ্রেষ্টত্ব দিয়েছেন","audioUrl":"wbw/004_032_004.mp3","charTypeName":"word"},{"id":34374,"position":5,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/004_032_005.mp3","charTypeName":"word"},{"id":34375,"position":6,"arabic":"بِهِۦ","translation":"তার","audioUrl":"wbw/004_032_006.mp3","charTypeName":"word"},{"id":34376,"position":7,"arabic":"بَعْضَكُمْ","translation":"তোমাদের কাউকে","audioUrl":"wbw/004_032_007.mp3","charTypeName":"word"},{"id":34377,"position":8,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/004_032_008.mp3","charTypeName":"word"},{"id":34378,"position":9,"arabic":"بَعْضٍۢ ۚ","translation":"কারও","audioUrl":"wbw/004_032_009.mp3","charTypeName":"word"},{"id":34380,"position":10,"arabic":"لِّلرِّجَالِ","translation":"পুরুষদের জন্য","audioUrl":"wbw/004_032_011.mp3","charTypeName":"word"},{"id":34381,"position":11,"arabic":"نَصِيبٌۭ","translation":"অংশ (রয়েছে)","audioUrl":"wbw/004_032_012.mp3","charTypeName":"word"},{"id":34382,"position":12,"arabic":"مِّمَّا","translation":"তা হতে যা","audioUrl":"wbw/004_032_013.mp3","charTypeName":"word"},{"id":34383,"position":13,"arabic":"ٱكْتَسَبُوا۟ ۖ","translation":"তারা অর্জন করেছে","audioUrl":"wbw/004_032_014.mp3","charTypeName":"word"},{"id":34385,"position":14,"arabic":"وَلِلنِّسَآءِ","translation":"এবং মহিলাদের জন্য (রয়েছে)","audioUrl":"wbw/004_032_016.mp3","charTypeName":"word"},{"id":34386,"position":15,"arabic":"نَصِيبٌۭ","translation":"অংশ