, and near kinsfolk, and those to whom you have pledged your troth give them, therefore, their share. Behold, God is indeed a witness unto everything.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/526.mp3","surahId":4,"words":[{"id":35301,"position":1,"arabic":"وَلِكُلٍّۢ","translation":"এবং প্রত্যেকের জন্য","audioUrl":"wbw/004_033_001.mp3","charTypeName":"word"},{"id":35302,"position":2,"arabic":"جَعَلْنَا","translation":"আমরা বানিয়েছি","audioUrl":"wbw/004_033_002.mp3","charTypeName":"word"},{"id":35303,"position":3,"arabic":"مَوَٰلِىَ","translation":"উত্তরাধিকারী","audioUrl":"wbw/004_033_003.mp3","charTypeName":"word"},{"id":35304,"position":4,"arabic":"مِمَّا","translation":"তাহতে যা","audioUrl":"wbw/004_033_004.mp3","charTypeName":"word"},{"id":35305,"position":5,"arabic":"تَرَكَ","translation":"ত্যাগ করেছে","audioUrl":"wbw/004_033_005.mp3","charTypeName":"word"},{"id":35306,"position":6,"arabic":"ٱلْوَٰلِدَانِ","translation":"পিতা মাতা","audioUrl":"wbw/004_033_006.mp3","charTypeName":"word"},{"id":35307,"position":7,"arabic":"وَٱلْأَقْرَبُونَ ۚ","translation":"এবং আত্মীয় স্বজনরা (তাদের)","audioUrl":"wbw/004_033_007.mp3","charTypeName":"word"},{"id":35309,"position":8,"arabic":"وَٱلَّذِينَ","translation":"আর যাদের (সাথে)","audioUrl":"wbw/004_033_009.mp3","charTypeName":"word"},{"id":35310,"position":9,"arabic":"عَقَدَتْ","translation":"আবদ্ধ হয়েছে","audioUrl":"wbw/004_033_010.mp3","charTypeName":"word"},{"id":35311,"position":10,"arabic":"أَيْمَـٰنُكُمْ","translation":"তোমাদের অঙ্গীকার","audioUrl":"wbw/004_033_011.mp3","charTypeName":"word"},{"id":35312,"position":11,"arabic":"فَـَٔاتُوهُمْ","translation":"সেক্ষেত্রে তাদেরকে দাও","audioUrl":"wbw/004_033_012.mp3","charTypeName":"word"},{"id":35313,"position":12,"arabic":"نَصِيبَهُمْ ۚ","translation":"তাদের অংশ","audioUrl":"wbw/004_033_013.mp3","charTypeName":"word"},{"id":35315,"position":13,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/004_033_015.mp3","charTypeName":"word"},{"i