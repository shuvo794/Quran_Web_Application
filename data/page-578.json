{"id":578,"ayahs":[{"number":20,"arabic":"كَلَّا بَلْ تُحِبُّونَ ٱلْعَاجِلَةَ","translation":"NAY, but [most of] you love this fleeting life,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5571.mp3","surahId":75,"words":[{"id":22876,"position":1,"arabic":"كَلَّا","translation":"কক্ষন না","audioUrl":"wbw/075_020_001.mp3","charTypeName":"word"},{"id":22877,"position":2,"arabic":"بَلْ","translation":"বরং","audioUrl":"wbw/075_020_002.mp3","charTypeName":"word"},{"id":22878,"position":3,"arabic":"تُحِبُّونَ","translation":"তোমরা পছন্দ করো","audioUrl":"wbw/075_020_003.mp3","charTypeName":"word"},{"id":22879,"position":4,"arabic":"ٱلْعَاجِلَةَ","translation":"পার্থিব জীবন","audioUrl":"wbw/075_020_004.mp3","charTypeName":"word"},{"id":22880,"position":5,"arabic":"٢٠","translation":"(২০)","audioUrl":null,"charTypeName":"end"}]},{"number":21,"arabic":"وَتَذَرُونَ ٱلْءَاخِرَةَ","translation":"and give no thought to the life to come [and to Judgment Day]!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5572.mp3","surahId":75,"words":[{"id":23962,"position":1,"arabic":"وَتَذَرُونَ","translation":"এবং তোমরা উপেক্ষা করো","audioUrl":"wbw/075_021_001.mp3","charTypeName":"word"},{"id":23963,"position":2,"arabic":"ٱلْـَٔاخِرَةَ","translation":"পরকাল","audioUrl":"wbw/075_021_002.mp3","charTypeName":"word"},{"id":23964,"position":3,"arabic":"٢١","translation":"(২১)","audioUrl":null,"charTypeName":"end"}]},{"number":22,"arabic":"وُجُوهٌۭ يَوْمَئِذٍۢ نَّاضِرَةٌ","translation":"Some faces will on that Day be bright with happiness,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5573.mp3","surahId":75,"words":[{"id":24917,"position":1,"arabic":"وُجُوهٌۭ","translation":"কিছুু মুখ","audioUrl":"wbw/075_022_001.mp3","charTypeName":"word"},{"id":24918,"position":2,"arabic":"يَوْمَئِذٍۢ","translation":"সে দিন","audioUrl":"wbw/075_022_002.mp3","charTypeName":"word"},{"id":24919,"position":3,"arabic":"نَّاضِرَةٌ","translation":"উজ্জ্বল হবে","audioUrl":"wbw/075_022_003.mp3","charTypeName":"word"},{"id":24920,"position":4,"arabic":"٢٢","translation":"(২২)","audioUrl":null,"charTypeName":"end"}]},{"number":23,"arabic":"إِلَىٰ رَبِّهَا نَاظِرَةٌۭ","translation":"looking up to their Sustainer;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5574.mp3","surahId":75,"words":[{"id":25829,"position":1,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/075_023_001.mp3","charTypeName":"word"},{"id":25830,"position":2,"arabic":"رَبِّهَا","translation":"তার রবের","audioUrl":"wbw/075_023_002.mp3","charTypeName":"word"},{"id":25831,"position":3,"arabic":"نَاظِرَةٌۭ","translation":"দৃষ্টিমান হবে","audioUrl":"wbw/075_023_003.mp3","charTypeName":"word"},{"id":25832,"position":4,"arabic":"٢٣","translation":"(২৩)","audioUrl":null,"charTypeName":"end"}]},{"number":24,"arabic":"وَوُجُوهٌۭ يَوْمَئِذٍۭ بَاسِرَةٌۭ","translation":"and some faces will on that Day be overcast with despair,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5575.mp3","surahId":75,"words":[{"id":27414,"position":1,"arabic":"وَوُجُوهٌۭ","translation":"এবং কিছু মুখ","audioUrl":"wbw/075_024_001.mp3","charTypeName":"word"},{"id":27415,"position":2,"arabic":"يَوْمَئِذٍۭ","translation":"সে দিন","audioUrl":"wbw/075_024_002.mp3","charTypeName":"word"},{"id":27416,"position":3,"arabic":"بَاسِرَةٌۭ","translation":"স্লান হবে","audioUrl":"wbw/075_024_003.mp3","charTypeName":"word"},{"id":27417,"position":4,"arabic":"٢٤","translation":"(২৪)","audioUrl":null,"charTypeName":"end"}]},{"number":25,"arabic":"تَظُنُّ أَن يُفْعَلَ بِهَا فَاقِرَةٌۭ","translation":"knowing that a crushing calamity is about to befall them.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5576.mp3","surahId":75,"words":[{"id":27962,"position":1,"arabic":"تَظُنُّ","translation":"ধারণা করবে","audioUrl":"wbw/075_025_001.mp3","charTypeName":"word"},{"id":27963,"position":2,"arabic":"أَن","translation":"যে","audioUrl":"wbw/075_025_002.mp3","charTypeName":"word"},{"id":27964,"position":3,"arabic":"يُفْعَلَ","translation":"করা হবে","audioUrl":"wbw/075_025_003.mp3","charTypeName":"word"},{"id":27965,"position":4,"arabic":"بِهَا","translation":"তার সাথে","audioUrl":"wbw/075_025_004.mp3","charTypeName":"word"},{"id":27966,"position":5,"arabic":"فَاقِرَةٌۭ","translation":"কোমর চূর্ণ আচরণ","audioUrl":"wbw/075_025_005.mp3","charTypeName":"word"},{"id":27967,"position":6,"arabic":"٢٥","translation":"(২৫)","audioUrl":null,"charTypeName":"end"}]},{"number":26,"arabic":"كَلَّآ إِذَا بَلَغَتِ ٱلتَّرَاقِىَ","translation":"NAY, but when [the last breath] comes up to the throat [of a dying man],","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5577.mp3","surahId":75,"words":[{"id":28937,"position":1,"arabic":"كَلَّآ","translation":"কক্ষন না","audioUrl":"wbw/075_026_001.mp3","charTypeName":"word"},{"id":28938,"position":2,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/075_026_002.mp3","charTypeName":"word"},{"id":28939,"position":3,"arabic":"بَلَغَتِ","translation":"পৌছবে","audioUrl":"wbw/075_026_003.mp3","charTypeName":"word"},{"id":28940,"position":4,"arabic":"ٱلتَّرَاقِىَ","translation":"কণ্ঠ দেশে (প্রাণ)","audioUrl":"wbw/075_026_004.mp3","charTypeName":"word"},{"id":28941,"position":5,"arabic":"٢٦","translation":"(২৬)","audioUrl":null,"charTypeName":"end"}]},{"number":27,"arabic":"وَقِيلَ مَنْ ۜ رَاقٍۢ","translation":"and people ask, \"Is there any wizard [that could save him]?\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5578.mp3","surahId":75,"words":[{"id":29807,"position":1,"arabic":"وَقِيلَ","translation":"এবং বলা হবে","audioUrl":"wbw/075_027_001.mp3","charTypeName":"word"},{"id":29808,"position":2,"arabic":"مَنْ ۜ","translation":"\"কে","audioUrl":"wbw/075_027_002.mp3","charTypeName":"word"},{"id":29810,"position":3,"arabic":"رَاقٍۢ","translation":"ঝাড়ফুককারী\"","audioUrl":"wbw/075_027_004.mp3","charTypeName":"word"},{"id":29811,"position":4,"arabic":"٢٧","translation":"(২৭)","audioUrl":null,"charTypeName":"end"}]},{"number":28,"arabic":"وَظَنَّ أَنَّهُ ٱلْفِرَاقُ","translation":"the while he [himself] knows that this is the parting,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5579.mp3","surahId":75,"words":[{"id":30715,"position":1,"arabic":"وَظَنَّ","translation":"এবং সে মনে করবে","audioUrl":"wbw/075_028_001.mp3","charTypeName":"word"},{"id":30716,"position":2,"arabic":"أَنَّهُ","translation":"তার যে","audioUrl":"wbw/075_028_002.mp3","charTypeName":"word"},{"id":30717,"position":3,"arabic":"ٱلْفِرَاقُ","translation":"বিদায়ক্ষণ","audioUrl":"wbw/075_028_003.mp3","charTypeName":"word"},{"id":30718,"position":4,"arabic":"٢٨","translation":"(২৮)","audioUrl":null,"charTypeName":"end"}]},{"number":29,"arabic":"وَٱلْتَفَّتِ ٱلسَّاقُ بِٱلسَّاقِ","translation":"and is enwrapped in the pangs of death","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5580.mp3","surahId":75,"words":[{"id":31739,"position":1,"arabic":"وَٱلْتَفَّتِ","translation":"এবং জড়িয়ে যাবে","audioUrl":"wbw/075_029_001.mp3","charTypeName":"word"},{"id":31740,"position":2,"arabic":"ٱلسَّاقُ","translation":"পিন্ডলির","audioUrl":"wbw/075_029_002.mp3","charTypeName":"word"},{"id":31741,"position":3,"arabic":"بِٱلسَّاقِ","translation":"পিন্ডলি সাথে","audioUrl":"wbw/075_029_003.mp3","charTypeName":"word"},{"id":31742,"position":4,"arabic":"٢٩","translation":"(২৯)","audioUrl":null,"charTypeName":"end"}]},{"number":30,"arabic":"إِلَىٰ رَبِّكَ يَوْمَئِذٍ ٱلْمَسَاقُ","translation":"at that time towards thy Sustainer does he feel impelled to turn!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5581.mp3","surahId":75,"words":[{"id":32866,"position":1,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/075_030_001.mp3","charTypeName":"word"},{"id":32867,"position":2,"arabic":"رَبِّكَ","translation":"তোমার রবের","audioUrl":"wbw/075_030_002.mp3","charTypeName":"word"},{"id":32868,"position":3,"arabic":"يَوْمَئِذٍ","translation":"সে দিন","audioUrl":"wbw/075_030_003.mp3","charTypeName":"word"},{"id":32869,"position":4,"arabic":"ٱلْمَسَاقُ","translation":"যাত্রা","audioUrl":"wbw/075_030_004.mp3","charTypeName":"word"},{"id":32870,"position":5,"arabic":"٣٠","translation":"(৩০)","audioUrl":null,"charTypeName":"end"}]},{"number":31,"arabic":"فَلَا صَدَّقَ وَلَا صَلَّىٰ","translation":"[Useless, though, will be his repentance: for [as long as he was alive] he did not accept the truth, nor did he pray [for enlightenment],","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5582.mp3","surahId":75,"words":[{"id":33725,"position":1,"arabic":"فَلَا","translation":"না অতঃপর","audioUrl":"wbw/075_031_001.mp3","charTypeName":"word"},{"id":33726,"position":2,"arabic":"صَدَّقَ","translation":"সত্য মানল","audioUrl":"wbw/075_031_002.mp3","charTypeName":"word"},{"id":33727,"position":3,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/075_031_003.mp3","charTypeName":"word"},{"id":33728,"position":4,"arabic":"صَلَّىٰ","translation":"নামায পড়ল","audioUrl":"wbw/075_031_004.mp3","charTypeName":"word"},{"id":33729,"position":5,"arabic":"٣١","translation":"(৩১)","audioUrl":null,"charTypeName":"end"}]},{"number":32,"arabic":"وَلَٰكِن كَذَّبَ وَتَوَلَّىٰ","translation":"but, on the contrary, he gave the lie to the truth and turned away [from it],","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5583.mp3","surahId":75,"words":[{"id":34746,"position":1,"arabic":"وَلَـٰكِن","translation":"বরং","audioUrl":"wbw/075_032_001.mp3","charTypeName":"word"},{"id":34747,"position":2,"arabic":"كَذَّبَ","translation":"মিথ্যারোপ করল","audioUrl":"wbw/075_032_002.mp3","charTypeName":"word"},{"id":34748,"position":3,"arabic":"وَتَوَلَّىٰ","translation":"ও ফিরে গেল","audioUrl":"wbw/075_032_003.mp3","charTypeName":"word"},{"id":34749,"position":4,"arabic":"٣٢","translation":"(৩২)","audioUrl":null,"charTypeName":"end"}]},{"number":33,"arabic":"ثُمَّ ذَهَبَ إِلَىٰٓ أَهْلِهِۦ يَتَمَطَّىٰٓ","translation":"and then