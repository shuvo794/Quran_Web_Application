003.mp3","charTypeName":"word"},{"id":2754,"position":4,"arabic":"إِمَّا","translation":"হয়","audioUrl":"wbw/076_003_004.mp3","charTypeName":"word"},{"id":2755,"position":5,"arabic":"شَاكِرًۭا","translation":"শুকুর কারি হবে","audioUrl":"wbw/076_003_005.mp3","charTypeName":"word"},{"id":2756,"position":6,"arabic":"وَإِمَّا","translation":"আর না হয়","audioUrl":"wbw/076_003_006.mp3","charTypeName":"word"},{"id":2757,"position":7,"arabic":"كَفُورًا","translation":"অকৃতজ্ঞ হবে","audioUrl":"wbw/076_003_007.mp3","charTypeName":"word"},{"id":2758,"position":8,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"إِنَّآ أَعْتَدْنَا لِلْكَٰفِرِينَ سَلَٰسِلَا۟ وَأَغْلَٰلًۭا وَسَعِيرًا","translation":"[Now,] behold, for those who deny the truth We have readied chains and shackles, and a blazing flame","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5595.mp3","surahId":76,"words":[{"id":4055,"position":1,"arabic":"إِنَّآ","translation":"আমরা নিশ্চয়ই","audioUrl":"wbw/076_004_001.mp3","charTypeName":"word"},{"id":4056,"position":2,"arabic":"أَعْتَدْنَا","translation":"আমরা প্রস্তুত","audioUrl":"wbw/076_004_002.mp3","charTypeName":"word"},{"id":4057,"position":3,"arabic":"لِلْكَـٰفِرِينَ","translation":"কাফির দের জন্যে","audioUrl":"wbw/076_004_003.mp3","charTypeName":"word"},{"id":4058,"position":4,"arabic":"سَلَـٰسِلَا۟","translation":"শিকলসমূহ","audioUrl":"wbw/076_004_004.mp3","charTypeName":"word"},{"id":4059,"position":5,"arabic":"وَأَغْلَـٰلًۭا","translation":"এবং গলারবেড়ী সমূহ","audioUrl":"wbw/076_004_005.mp3","charTypeName":"word"},{"id":4060,"position":6,"arabic":"وَسَعِيرًا","translation":"এবং প্রজ্জলিত আগুন","audioUrl":"wbw/076_004_006.mp3","charTypeName":"word"},{"id":4061,"position":7,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"إِنَّ ٱلْأَبْرَارَ يَشْرَبُونَ مِن كَأْسٍۢ كَانَ مِزَاجُهَا كَافُورًا","translation":"[whereas,] behold, the truly virtuous shall drink 