/046_030_003.mp3","charTypeName":"word"},{"id":32551,"position":4,"arabic":"سَمِعْنَا","translation":"আমরা শুনেছি","audioUrl":"wbw/046_030_004.mp3","charTypeName":"word"},{"id":32552,"position":5,"arabic":"كِتَـٰبًا","translation":"এক কিতাব","audioUrl":"wbw/046_030_005.mp3","charTypeName":"word"},{"id":32553,"position":6,"arabic":"أُنزِلَ","translation":"অবতীর্ণ করা হয়েছে","audioUrl":"wbw/046_030_006.mp3","charTypeName":"word"},{"id":32554,"position":7,"arabic":"مِنۢ","translation":"মধ্য হতে","audioUrl":"wbw/046_030_007.mp3","charTypeName":"word"},{"id":32555,"position":8,"arabic":"بَعْدِ","translation":"পরে","audioUrl":"wbw/046_030_008.mp3","charTypeName":"word"},{"id":32556,"position":9,"arabic":"مُوسَىٰ","translation":"মুসার","audioUrl":"wbw/046_030_009.mp3","charTypeName":"word"},{"id":32557,"position":10,"arabic":"مُصَدِّقًۭا","translation":"সত্যায়নকারী/ সমর্থনকারী","audioUrl":"wbw/046_030_010.mp3","charTypeName":"word"},{"id":32558,"position":11,"arabic":"لِّمَا","translation":"তার যা","audioUrl":"wbw/046_030_011.mp3","charTypeName":"word"},{"id":32559,"position":12,"arabic":"بَيْنَ","translation":"তার পূর্বে (এসেছে)","audioUrl":"wbw/046_030_012.mp3","charTypeName":"word"},{"id":32560,"position":13,"arabic":"يَدَيْهِ","translation":"তার পূর্বে (এসেছে)","audioUrl":"wbw/046_030_013.mp3","charTypeName":"word"},{"id":32561,"position":14,"arabic":"يَهْدِىٓ","translation":"(এই কিতাব) পথ দেখায়","audioUrl":"wbw/046_030_014.mp3","charTypeName":"word"},{"id":32562,"position":15,"arabic":"إِلَى","translation":"দিকে","audioUrl":"wbw/046_030_015.mp3","charTypeName":"word"},{"id":32563,"position":16,"arabic":"ٱلْحَقِّ","translation":"সত্যের","audioUrl":"wbw/046_030_016.mp3","charTypeName":"word"},{"id":32564,"position":17,"arabic":"وَإِلَىٰ","translation":"এবং দিকে","audioUrl":"wbw/046_030_017.mp3","charTypeName":"word"},{"id":32565,"position":18,"arabic":"طَرِيقٍۢ","translation":"পথের","audioUrl":"wbw/046_030_018.mp3","charTypeName":"word"},{"id":32566,"position":19,"arabic":"مُّسْتَقِيمٍۢ","translation":"সরল সঠিক","audioUrl":"wbw/046_030_019.mp3","charTypeName":"word"},{"id":32567,"position":20,"arabic":"٣٠","translation":"(৩০)","audioUrl":null,"charTypeName":"end"}]},{"number":31,"arabic":"يَٰقَوْمَنَآ أَجِيبُوا۟ دَاعِىَ ٱللَّهِ وَءَامِنُوا۟ بِهِۦ يَغْفِرْ لَكُم مِّن ذُنُوبِكُمْ وَيُجِرْكُم مِّنْ عَذَابٍ أَلِيمٍۢ","translation":"“O our people! Respond to God’s call, and have faith in Him: He will forgive you [whatever is past] of your sins, and deliver you from grievous suffering [in the life to come].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4541.mp3","surahId":46,"words":[{"id":33443,"position":1,"arabic":"يَـٰقَوْمَنَآ","translation":"হে আমাদের জাতি","audioUrl":"wbw/046_031_001.mp3","charTypeName":"word"},{"id":33444,"position":2,"arabic":"أَجِيبُوا۟","translation":"তোমরা সাড়া দাও","audioUrl":"wbw/046_031_002.mp3","charTypeName":"word"},{"id":33445,"position":3,"arabic":"دَاعِىَ","translation":"আহবানকারীর (ডাকে)","audioUrl":"wbw/046_031_003.mp3","charTypeName":"word"},{"id":33446,"position":4,"arabic":"ٱللَّهِ","translation":"আল্লাহর (দিকে)","audioUrl":"wbw/046_031_004.mp3","charTypeName":"word"},{"id":33447,"position":5,"arabic":"وَءَامِنُوا۟","translation":"এবং ঈমান আন","audioUrl":"wbw/046_031_005.mp3","charTypeName":"word"},{"id":33448,"position":6,"arabic":"بِهِۦ","translation":"তার উপর","audioUrl":"wbw/046_031_006.mp3","charTypeName":"word"},{"id":33449,"position":7,"arabic":"يَغْفِرْ","translation":"ক্ষমা করবেন (আল্লাহ)","audioUrl":"wbw/046_031_007.mp3","charTypeName":"word"},{"id":33450,"position":8,"arabic":"لَكُم","translation":"তোমাদের জন্যে","audioUrl":"wbw/046_031_008.mp3","charTypeName":"word"},{"id":33451,"position":9,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/046_031_009.mp3","charTypeName":"word"},{"id":33452,"position":10,"arabic":"ذُنُوبِكُمْ","translation":"তোমাদের পাপ গুলোকে","audioUrl":"wbw/046_031_010.mp3","charTypeName":"word"},{"id":33453,"position":11,"arabic":"وَيُجِرْكُم","translation":"এবং তোমাদের রক্ষা করবেন","audioUrl":"wbw/046_031_011.mp3","charTypeName":"word"},{"id":33454,"position":12,"arabic":"مِّنْ","translation":"হতে","audioUrl":"wbw/046_031_012.mp3","charTypeName":"word"},{"id":33455,"position":13,"arabic":"عَذَابٍ","translation":"শাস্তি","audioUrl":"wbw/046_031_013.mp3","charTypeName":"word"},{"id":33456,"position":14,"arabic":"أَلِيمٍۢ","translation":"নিদারুণ কষ্টকর","audioUrl":"wbw/046_031_014.mp3","charTypeName":"word"},{"id":33457,"position":15,"arabic":"٣١","translation":"(৩১)","audioUrl":null,"charTypeName":"end"}]},{"number":32,"arabic":"وَمَن لَّا يُجِبْ دَاعِىَ ٱللَّهِ فَلَيْسَ بِمُعْجِزٍۢ فِى ٱلْأَرْضِ وَلَيْسَ لَهُۥ مِن دُونِهِۦٓ أَوْلِيَآءُ ۚ أُو۟لَٰٓئِكَ فِى ضَلَٰلٍۢ مُّبِينٍ","translation":"But he who does not respond to God’s call can never elude [Him] on earth, nor can he has any protector against Him [in the life to come]: all such are most obviously lost in error.”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4542.mp3","surahId":46,"words":[{"id":34464,"position":1,"arabic":"وَمَن","translation":"আর যে","audioUrl":"wbw/046_032_001.mp3","charTypeName":"word"},{"id":34465,"position":2,"arabic":"لَّا","translation":"না","audioUrl":"wbw/046_032_002.mp3","charTypeName":"word"},{"id":34466,"position":3,"arabic":"يُجِبْ","translation":"সাড়া দেয়","audioUrl":"wbw/046_032_003.mp3","charTypeName":"word"},{"id":34467,"position":4,"arabic":"دَاعِىَ","translation":"আহবানকারীর (ডাকে)","audioUrl":"wbw/046_032_004.mp3","charTypeName":"word"},{"id":34468,"position":5,"arabic":"ٱللَّهِ","translation":"আল্লাহর (দিকে)","audioUrl":"wbw/046_032_005.mp3","charTypeName":"word"},{"id":34469,"position":6,"arabic":"فَلَيْسَ","translation":"তবে সে নয়","audioUrl":"wbw/046_032_006.mp3","charTypeName":"word"},{"id":34470,"position":7,"arabic":"بِمُعْجِزٍۢ","translation":"(আল্লাহকে) ব্যর্থ করে দিতে সক্ষম","audioUrl":"wbw/046_032_007.mp3","charTypeName":"word"},{"id":34471,"position":8,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/046_032_008.mp3","charTypeName":"word"},{"id":34472,"position":9,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/046_032_009.mp3","charTypeName":"word"},{"id":34473,"position":10,"arabic":"وَلَيْسَ","translation":"আর নেই","audioUrl":"wbw/046_032_010.mp3","charTypeName":"word"},{"id":34474,"position":11,"arabic":"لَهُۥ","translation":"তার জন্যে","audioUrl":"wbw/046_032_011.mp3","charTypeName":"word"},{"id":34475,"position":12,"arabic":"مِن","translation":"ব্যতীত","audioUrl":"wbw/046_032_012.mp3","charTypeName":"word"},{"id":34476,"position":13,"arabic":"دُونِهِۦٓ","translation":"তিনি","audioUrl":"wbw/046_032_013.mp3","charTypeName":"word"},{"id":34477,"position":14,"arabic":"أَوْلِيَآءُ ۚ","translation":"কোন পৃষ্ঠপোষক","audioUrl":"wbw/046_032_014.mp3","charTypeName":"word"},{"id":34479,"position":15,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐসব লোক","audioUrl":"wbw/046_032_016.mp3","charTypeName":"word"},{"id":34480,"position":16,"arabic":"فِى","translation":"(পড়ে আছে) মধ্যে","audioUrl":"wbw/046_032_017.mp3","charTypeName":"word"},{"id":34481,"position":17,"arabic":"ضَلَـٰلٍۢ","translation":"বিভ্রান্তির","audioUrl":"wbw/046_032_018.mp3","charTypeName":"word"},{"id":34482,"position":18,"arabic":"مُّبِينٍ","translation":"সুস্পষ্ট\"","audioUrl":"wbw/046_032_019.mp3","charTypeName":"word"},{"id":34483,"position":19,"arabic":"٣٢","translation":"(৩২)","audioUrl":null,"charTypeName":"end"}]},{"number":33,"arabic":"أَوَلَمْ يَرَوْا۟ أَنَّ ٱللَّهَ ٱلَّذِى خَلَقَ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضَ وَلَمْ يَعْىَ بِخَلْقِهِنَّ بِقَٰدِرٍ عَلَىٰٓ أَن يُحْۦِىَ ٱلْمَوْتَىٰ ۚ بَلَىٰٓ إِنَّهُۥ عَلَىٰ كُلِّ شَىْءٍۢ قَدِيرٌۭ","translation":"ARE, THEN, they [who deny the life to come] not aware that God, who has created the heavens and the earth and never been wearied by their creation, has [also] the power to bring the dead back to life? Yea, verily, He has the power to will anything!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4543.mp3","surahId":46,"words":[{"id":35456,"position":1,"arabic":"أَوَلَمْ","translation":"কি না","audioUrl":"wbw/046_033_001.mp3","charTypeName":"word"},{"id":35457,"position":2,"arabic":"يَرَوْا۟","translation":"তারা অনুধাবন করে","audioUrl":"wbw/046_033_002.mp3","charTypeName":"word"},{"id":35458,"position":3,"arabic":"أَنَّ","translation":"যে","audioUrl":"wbw/046_033_003.mp3","charTypeName":"word"},{"id":35459,"position":4,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/046_033_004.mp3","charTypeName":"word"},{"id":35460,"position":5,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/046_033_005.mp3","charTypeName":"word"},{"id":35461,"position":6,"arabic":"خَلَقَ","translation":"সৃষ্টি করেছেন","audioUrl":"wbw/046_033_006.mp3","charTypeName":"word"},{"id":35462,"position":7,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশ","audioUrl":"wbw/046_033_007.mp3","charTypeName":"word"},{"id":35463,"position":8,"arabic":"وَٱلْأَرْضَ","translation":"ও পৃথিবীকে","audioUrl":"wbw/046_033_008.mp3","charTypeName":"word"},{"id":35464,"position":9,"arabic":"وَلَمْ","translation":"এবং নি","audioUrl":"wbw/046_033_009.mp3","charTypeName":"word"},{"id":35465,"position":10,"arabic":"يَعْىَ","translation":"ক্লান্তি বোধ করেন","audioUrl":"wbw/046_033_010.mp3","charTypeName":"word"},{"id":35466,"position":11,"arabic":"بِخَلْقِهِنَّ","translation":"তাদের সৃষ্টিতে","audioUrl":"wbw/046_033_011.mp3","charTypeName":"word"},{"id":35467,"position":12,"arabic":"بِقَـٰدِرٍ","translation":"(তিনিই তো) সক্ষম","audioUrl":"wbw/046_033_012.mp3","charTypeName":"word"},{"id":35468,"position":13,"arabic":"عَلَىٰٓ","translation":"(এর) উপর","audioUrl":"wbw/046_033_013.mp3","charTypeName":"word"},{"id":35469,"position":14,"arabic":"أَن","translation":"যে","audioUrl":"wbw/046_033_014.mp3","charTypeName":"word"},{"id":35470,"position":15,"arabic":"يُحْـِۧىَ","translation":"তিনি জীবিত করবেন","audioUrl":"wbw/046_033_015.mp3","charTypeName":"word"},{"id":35471,"position":16,"arabic":"ٱلْمَوْتَىٰ ۚ","t