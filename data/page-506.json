:"wbw/046_034_004.mp3","charTypeName":"word"},{"id":36279,"position":5,"arabic":"عَلَى","translation":"নিকট","audioUrl":"wbw/046_034_005.mp3","charTypeName":"word"},{"id":36280,"position":6,"arabic":"ٱلنَّارِ","translation":"আগুনের","audioUrl":"wbw/046_034_006.mp3","charTypeName":"word"},{"id":36281,"position":7,"arabic":"أَلَيْسَ","translation":"\"(বলা হবে) নয় কি","audioUrl":"wbw/046_034_007.mp3","charTypeName":"word"},{"id":36282,"position":8,"arabic":"هَـٰذَا","translation":"এটা","audioUrl":"wbw/046_034_008.mp3","charTypeName":"word"},{"id":36283,"position":9,"arabic":"بِٱلْحَقِّ ۖ","translation":"সত্য\"","audioUrl":"wbw/046_034_009.mp3","charTypeName":"word"},{"id":36285,"position":10,"arabic":"قَالُوا۟","translation":"তারা বলবে","audioUrl":"wbw/046_034_011.mp3","charTypeName":"word"},{"id":36286,"position":11,"arabic":"بَلَىٰ","translation":"\"হ্যাঁ নিশ্চয়ই","audioUrl":"wbw/046_034_012.mp3","charTypeName":"word"},{"id":36287,"position":12,"arabic":"وَرَبِّنَا ۚ","translation":"আমাদের রবের শপথ (এটা সত্য)\"","audioUrl":"wbw/046_034_013.mp3","charTypeName":"word"},{"id":36289,"position":13,"arabic":"قَالَ","translation":"(আল্লাহ) বলবেন","audioUrl":"wbw/046_034_015.mp3","charTypeName":"word"},{"id":36290,"position":14,"arabic":"فَذُوقُوا۟","translation":"\"এখন তোমরা স্বাদ নাও","audioUrl":"wbw/046_034_016.mp3","charTypeName":"word"},{"id":36291,"position":15,"arabic":"ٱلْعَذَابَ","translation":"শাস্তির","audioUrl":"wbw/046_034_017.mp3","charTypeName":"word"},{"id":36292,"position":16,"arabic":"بِمَا","translation":"এ কারণে যা","audioUrl":"wbw/046_034_018.mp3","charTypeName":"word"},{"id":36293,"position":17,"arabic":"كُنتُمْ","translation":"তোমরা করছিলে","audioUrl":"wbw/046_034_019.mp3","charTypeName":"word"},{"id":36294,"position":18,"arabic":"تَكْفُرُونَ","translation":"অস্বীকার\"","audioUrl":"wbw/046_034_020.mp3","charTypeName":"word"},{"id":36295,"position":19,"arabic":"٣٤","translation":"(৩৪)","audioUrl":null,"charTypeName":"end"}]},{"number":35,"arabic":"فَٱصْبِرْ كَمَا صَبَرَ أُو۟لُوا۟ ٱلْعَزْمِ مِنَ ٱلرُّسُلِ وَلَا تَسْتَعْجِل لَّهُمْ ۚ كَأَنَّهُمْ يَوْمَ يَرَوْنَ مَا يُوعَدُونَ لَمْ يَلْبَثُوٓا۟ إِلَّا سَاعَةًۭ مِّن نَّهَارٍۭ ۚ بَلَٰغٌۭ ۚ فَهَلْ يُهْلَكُ إِلَّا ٱلْقَوْمُ ٱلْفَٰسِقُونَ","translation":"REMAIN, then, [O believer,] patient in adversity, just as all of the apostles, endowed with firmness of heart, bore themselves with patience. And do not ask for a speedy doom of those [who still deny the truth]: on the Day when they see [the fulfillment of] what they were promised, [it will seem to them] as though they had dwelt [on earth] no longer than one hour of [an earthly] day! [This is Our] message. Will, then, any be [really] destroyed save iniquitous folk?”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4545.mp3","surahId":46,"words":[{"id":37064,"position":1,"arabic":"فَٱصْبِرْ","translation":"অতএব (হে নবী) ধৈর্য ধরো","audioUrl":"wbw/046_035_001.mp3","charTypeName":"word"},{"id":37065,"position":2,"arabic":"كَمَا","translation":"যেমন","audioUrl":"wbw/046_035_002.mp3","charTypeName":"word"},{"id":37066,"position":3,"arabic":"صَبَرَ","translation":"ধৈর্য ধরেছে","audioUrl":"wbw/046_035_003.mp3","charTypeName":"word"},{"id":37067,"position":4,"arabic":"أُو۟لُوا۟","translation":"তারা","audioUrl":"wbw/046_035_004.mp3","charTypeName":"word"},{"id":37068,"position":5,"arabic":"ٱلْعَزْمِ","translation":"দৃঢ়সংকল্পসম্পন্ন","audioUrl":"wbw/046_035_005.mp3","charTypeName":"word"},{"id":37069,"position":6,"arabic":"مِنَ","translation":"মধ্য থেকে","audioUrl":"wbw/046_035_006.mp3","charTypeName":"word"},{"id":37070,"position":7,"arabic":"ٱلرُّسُلِ","translation":"রাসূলগণের","audioUrl":"wbw/046_035_007.mp3","charTypeName":"word"},{"id":37071,"position":8,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/046_035_008.mp3","charTypeName":"word"},{"id":37072,"position":9,"arabic":"تَسْتَعْجِل","translation":"তাড়াহুড়া করো","audioUrl":"wbw/046_035_009.mp3","charTypeName":"word"},{"id":37073,"position":10,"