{"id":209,"ayahs":[{"number":7,"arabic":"إِنَّ ٱلَّذِينَ لَا يَرْجُونَ لِقَآءَنَا وَرَضُوا۟ بِٱلْحَيَوٰةِ ٱلدُّنْيَا وَٱطْمَأَنُّوا۟ بِهَا وَٱلَّذِينَ هُمْ عَنْ ءَايَٰتِنَا غَٰفِلُونَ","translation":"Verily, as for those who do not believe that they are destined to meet Us, but content themselves with the life of this world and do not look beyond it, and are heedless of Our messages -","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1371.mp3","surahId":10,"words":[{"id":7989,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/010_007_001.mp3","charTypeName":"word"},{"id":7990,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/010_007_002.mp3","charTypeName":"word"},{"id":7991,"position":3,"arabic":"لَا","translation":"না","audioUrl":"wbw/010_007_003.mp3","charTypeName":"word"},{"id":7992,"position":4,"arabic":"يَرْجُونَ","translation":"আশা রাখে","audioUrl":"wbw/010_007_004.mp3","charTypeName":"word"},{"id":7993,"position":5,"arabic":"لِقَآءَنَا","translation":"সাক্ষাতের আমাদের","audioUrl":"wbw/010_007_005.mp3","charTypeName":"word"},{"id":7994,"position":6,"arabic":"وَرَضُوا۟","translation":"ও পরিতৃপ্ত হয়েছে","audioUrl":"wbw/010_007_006.mp3","charTypeName":"word"},{"id":7995,"position":7,"arabic":"بِٱلْحَيَوٰةِ","translation":"নিয়ে জীবন","audioUrl":"wbw/010_007_007.mp3","charTypeName":"word"},{"id":7996,"position":8,"arabic":"ٱلدُّنْيَا","translation":"পার্থিব","audioUrl":"wbw/010_007_008.mp3","charTypeName":"word"},{"id":7997,"position":9,"arabic":"وَٱطْمَأَنُّوا۟","translation":"এবং নিশ্চিত থাকে","audioUrl":"wbw/010_007_009.mp3","charTypeName":"word"},{"id":7998,"position":10,"arabic":"بِهَا","translation":"নিয়ে তা","audioUrl":"wbw/010_007_010.mp3","charTypeName":"word"},{"id":7999,"position":11,"arabic":"وَٱلَّذِينَ","translation":"এবং (এমন) যারা","audioUrl":"wbw/010_007_011.mp3","charTypeName":"word"},{"id":8000,"position":12,"arabic":"هُمْ","translation":"তারাই","audioUrl":"wbw/010_007_012.mp3","charTypeName":"word"},{"id":8001,"position":13,"arabic":"عَنْ","translation":"হতে","audioUrl":"wbw/010_007_013.mp3","charTypeName":"word"},{"id":8002,"position":14,"arabic":"ءَايَـٰتِنَا","translation":"নিদর্শনগুলো আমাদের","audioUrl":"wbw/010_007_014.mp3","charTypeName":"word"},{"id":8003,"position":15,"arabic":"غَـٰفِلُونَ","translation":"উদাসীন","audioUrl":"wbw/010_007_015.mp3","charTypeName":"word"},{"id":8004,"position":16,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"أُو۟لَٰٓئِكَ مَأْوَىٰهُمُ ٱلنَّارُ بِمَا كَانُوا۟ يَكْسِبُونَ","translation":"their goal is the fire in return for all [the evil] that they were wont to do.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1372.mp3","surahId":10,"words":[{"id":9162,"position":1,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐসব লোক","audioUrl":"wbw/010_008_001.mp3","charTypeName":"word"},{"id":9163,"position":2,"arabic":"مَأْوَىٰهُمُ","translation":"তাদের বাসস্থান (হবে)","audioUrl":"wbw/010_008_002.mp3","charTypeName":"word"},{"id":9164,"position":3,"arabic":"ٱلنَّارُ","translation":"আগুন","audioUrl":"wbw/010_008_003.mp3","charTypeName":"word"},{"id":9165,"position":4,"arabic":"بِمَا","translation":"এ কারণে যা","audioUrl":"wbw/010_008_004.mp3","charTypeName":"word"},{"id":9166,"position":5,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/010_008_005.mp3","charTypeName":"word"},{"id":9167,"position":6,"arabic":"يَكْسِبُونَ","translation":"তারা অর্জন করতে","audioUrl":"wbw/010_008_006.mp3","charTypeName":"word"},{"id":9168,"position":7,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"إِنَّ ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ يَهْدِيهِمْ رَبُّهُم بِإِيمَٰنِهِمْ ۖ تَجْرِى مِن تَحْتِهِمُ ٱلْأَنْهَٰرُ فِى جَنَّٰتِ ٱلنَّعِيمِ","translation":"[But,] verily, as for those who have attained to faith and do righteous deeds - their Sustainer guides them aright by means of their faith. [In the life to come,] running waters will flow at their feet in gardens of bliss;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1373.mp3","surahId":10,"words":[{"id":10354,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/010_009_001.mp3","charTypeName":"word"},{"id":10355,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/010_009_002.mp3","charTypeName":"word"},{"id":10356,"position":3,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/010_009_003.mp3","charTypeName":"word"},{"id":10357,"position":4,"arabic":"وَعَمِلُوا۟","translation":"ও কাজ করেছে","audioUrl":"wbw/010_009_004.mp3","charTypeName":"word"},{"id":10358,"position":5,"arabic":"ٱلصَّـٰلِحَـٰتِ","translation":"সৎ","audioUrl":"wbw/010_009_005.mp3","charTypeName":"word"},{"id":10359,"position":6,"arabic":"يَهْدِيهِمْ","translation":"সৎপথে পরিচালিত করবেন তাদেরকে","audioUrl":"wbw/010_009_006.mp3","charTypeName":"word"},{"id":10360,"position":7,"arabic":"رَبُّهُم","translation":"রব তাদের","audioUrl":"wbw/010_009_007.mp3","charTypeName":"word"},{"id":10361,"position":8,"arabic":"بِإِيمَـٰنِهِمْ ۖ","translation":"কারনে ঈমানের তাদের","audioUrl":"wbw/010_009_008.mp3","charTypeName":"word"},{"id":10363,"position":9,"arabic":"تَجْرِى","translation":"প্রবাহিত হয়","audioUrl":"wbw/010_009_010.mp3","charTypeName":"word"},{"id":10364,"position":10,"arabic":"مِن","translation":"দিয়ে","audioUrl":"wbw/010_009_011.mp3","charTypeName":"word"},{"id":10365,"position":11,"arabic":"تَحْتِهِمُ","translation":"নিচ তাদের","audioUrl":"wbw/010_009_012.mp3","charTypeName":"word"},{"id":10366,"position":12,"arabic":"ٱلْأَنْهَـٰرُ","translation":"ঝর্ণাধারাসমূহ","audioUrl":"wbw/010_009_013.mp3","charTypeName":"word"},{"id":10367,"position":13,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/010_009_014.mp3","charTypeName":"word"},{"id":10368,"position":14,"arabic":"جَنَّـٰتِ","translation":"জান্নাতের","audioUrl":"wbw/010_009_015.mp3","charTypeName":"word"},{"id":10369,"position":15,"arabic":"ٱلنَّعِيمِ","translation":"সুখকর","audioUrl":"wbw/010_009_016.mp3","charTypeName":"word"},{"id":10370,"position":16,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"دَعْوَىٰهُمْ فِيهَا سُبْحَٰنَكَ ٱللَّهُمَّ وَتَحِيَّتُهُمْ فِيهَا سَلَٰمٌۭ ۚ وَءَاخِرُ دَعْوَىٰهُمْ أَنِ ٱلْحَمْدُ لِلَّهِ رَبِّ ٱلْعَٰلَمِينَ","translation":"[and] in that [state of happiness] they will call out, \"Limitless art Thou in Thy glory, O God!\"-and will be answered with the greeting, \"Peace!\" And their call will close with [the words], \"All praise is due to God, the Sustainer of all the worlds!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1374.mp3","surahId":10,"words":[{"id":11593,"position":1,"arabic":"دَعْوَىٰهُمْ","translation":"তাদের ধ্বনি (হবে)","audioUrl":"wbw/010_010_001.mp3","charTypeName":"word"},{"id":11594,"position":2,"arabic":"فِيهَا","translation":"মধ্যে তার","audioUrl":"wbw/010_010_002.mp3","charTypeName":"word"},{"id":11595,"position":3,"arabic":"سُبْحَـٰنَكَ","translation":"পবিত্র তুমি","audioUrl":"wbw/010_010_003.mp3","charTypeName":"word"},{"id":11596,"position":4,"arabic":"ٱللَّهُمَّ","translation":"হে আল্লাহ\"","audioUrl":"wbw/010_010_004.mp3","charTypeName":"word"},{"id":11597,"position":5,"arabic":"وَتَحِيَّتُهُمْ","translation":"ও তাদের অভিবাদন (হবে)","audioUrl":"wbw/010_010_005.mp3","charTypeName":"word"},{"id":11598,"position":6,"arabic":"فِيهَا","translation":"মধ্যে তার","audioUrl":"wbw/010_010_006.mp3","charTypeName":"word"},{"id":11599,"position":7,"arabic":"سَلَـٰمٌۭ ۚ","translation":"\"সালাম (বর্ষিত হোক)\"","audioUrl":"wbw/010_010_007.mp3","charTypeName":"word"},{"id":11601,"position":8,"arabic":"وَءَاخِرُ","translation":"এবং শেষ (হবে)","audioUrl":"wbw/010_010_009.mp3","charTypeName":"word"},{"id":11602,"position":9,"arabic":"دَعْوَىٰهُمْ","translation":"ধ্বনি তাদের","audioUrl":"wbw/010_010_010.mp3","charTypeName":"word"},{"id":11603,"position":10,"arabic":"أَنِ","translation":"এই (যে)","audioUrl":"wbw/010_010_011.mp3","charTypeName":"word"},{"id":11604,"position":11,"arabic":"ٱلْحَمْدُ","translation":"\"সব প্রশংসা","audioUrl":"wbw/010_010_012.mp3","charTypeName":"word"},{"id":11605,"position":12,"arabic":"لِلَّهِ","translation":"জন্যে আল্লাহরই","audioUrl":"wbw/010_010_013.mp3","charTypeName":"word"},{"id":11606,"position":13,"arabic":"رَبِّ","translation":"রব","audioUrl":"wbw/010_010_014.mp3","charTypeName":"word"},{"id":11607,"position":14,"arabic":"ٱلْعَـٰلَمِينَ","translation":"বিশ্বজগতের\"","audioUrl":"wbw/010_010_015.mp3","charTypeName":"word"},{"id":11608,"position":15,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"۞ وَلَوْ يُعَجِّلُ ٱللَّهُ لِلنَّاسِ ٱلشَّرَّ ٱسْتِعْجَالَهُم بِٱلْخَيْرِ لَقُضِىَ إِلَيْهِمْ أَجَلُهُمْ ۖ فَنَذَرُ ٱلَّذِينَ لَا يَرْجُونَ لِقَآءَنَا فِى طُغْيَٰنِهِمْ يَعْمَهُونَ","translation":"NOW IF GOD were to hasten for human beings the ill [which they deserve by their sinning] in the same manner as they [themselves] would hasten [the coming to them of what they consider to be] good, their end would indeed come forthwith! But We leave them alone [for a while] -all those who do not believe that they are destined to meet Us: [We leave them alone] in their overweening arrogance, blindly stumbling to and fro.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1375.mp3","surahId":10,"words":[{"id":12922,"position":1,"arabic":"۞ وَلَوْ","translation":"এবং যদি","audioUrl":"wbw/010_011_002.mp3","charTypeName":"word"},{"id":12923,"position":2,"arabic":"يُعَجِّلُ","translation":"তাড়াতাড়ি করতেন","audioUrl":"wbw/010_011_003.mp3","charTypeName":"word"},{"id":12924,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/010_011_004.mp3","charTypeName":"word"},{"id":12925,"position":4,"arabic":"لِلنَّاسِ","translation":"জন্যে মানুষের","audioUrl":"wbw/010_011_005.mp3","charTypeName":"word"},{"id":12926,"position":5,"arabic":"ٱلشَّرَّ","translation":"অকল্যাণ","audioUrl":"wbw/010_011_006.mp3","charTypeName":"word"},{"id":12927,"position":6,"arabic":"ٱسْتِعْجَالَهُم","translation":"(যেমন) তারা তাড়াতাড়ি চায়","audioUrl":"wbw/010_011_007.mp3","charTypeName":"word"},{"id":12928,"position":7,"arabic":"بِٱلْخَيْرِ","translation":"ব্যাপারে (দুনিয়ার) কল্যাণের","audioUrl":"wbw/010_011_008.mp3","charTypeName":"word"},{"id":12929,"position":8,"arabic":"لَقُضِىَ","translation":"অবশ্যই পুরা হয়ে যেতো","audioUrl":"wbw/010_011_009.mp3","charTypeName":"word"},{"id":12930,"position":9,"arabic":"إِلَيْهِمْ","translation":"প্রতি তাদের","audioUrl":"wbw/010_011_010.mp3","charTypeName":"word"},{"id":12931,"position":10,"arabic":"أَجَلُهُمْ ۖ","translation":"মেয়াদ তাদের","audioUrl":"wbw/010_011_011.mp3","charTypeName":"word"},{"id":12933,"position":11,"arabic":"فَنَذَرُ","translation":"অতএব আমরা ছেড়ে দিয়েছি","audioUrl":"wbw/010_011_013.mp3","charTypeName":"word"},{"id":12934,"position":12,"arabic":"ٱلَّذِينَ","translation":"(তাদেরকে) যারা","audioUrl":"wbw/010_011_014.mp3","charTypeName":"word"},{"id":12935,"position":13,"arabic":"لَا","translation":"না","audioUrl":"wbw/010_011_015.mp3","charTypeName":"word"},{"id":12936,"position":14,"arabic":"يَرْجُونَ","translation":"আশা রাখে","audioUrl":"wbw/010_011_016.mp3","charTypeName":"word"},{"id":12937,"position":15,"arabic":"لِقَآءَنَا","translation":"সাক্ষাতের আমাদের","audioUrl":"wbw/010_011_017.mp3","charTypeName":"word"},{"id":12938,"position":16,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/010_011_018.mp3","charTypeName":"word"},{"id":12939,"position":17,"arabic":"طُغْيَـٰنِهِمْ","translation":"অবাধ্যতার তাদের","audioUrl":"wbw/010_011_019.mp3","charTypeName":"word"},{"id":12940,"position":18,"arabic":"يَعْمَهُونَ","translation":"উদ্‌ভ্রান্ত হয়ে ঘুরে বেড়ায়","audioUrl":"wbw/010_011_020.mp3","charTypeName":"word"},{"id":12941,"position":19,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]},{"number":12,"arabic":"وَإِذَا مَسَّ ٱلْإِنسَٰنَ ٱلضُّرُّ دَعَانَا لِجَنۢبِهِۦٓ أَوْ قَاعِدًا أَوْ قَآئِمًۭا فَلَمَّا كَشَفْنَا عَنْهُ ضُرَّهُۥ مَرَّ كَأَن لَّمْ يَدْعُنَآ إِلَىٰ ضُرٍّۢ مَّسَّهُۥ ۚ كَذَٰلِكَ زُيِّنَ لِلْمُسْرِفِينَ مَا كَانُوا۟ يَعْمَلُونَ","translation":"For [thus it is:] when affliction befalls man, he cries out unto Us, whether he be lying on his side or sitting or standing; but as soon as We have freed him of his affliction, he goes on as though he had never invoked Us to save him from the affliction that befell him! Thus do their own doings seem goodly unto those who waste their own selves.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1376.mp3","surahId":10,"words":[{"id":14200,"position":1,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/010_012_001.mp3","charTypeName":"word"},{"id":14201,"position":2,"arabic":"مَسَّ","translation":"স্পর্শ করে","audioUrl":"wbw/010_012_002.mp3","charTypeName":"word"},{"id":14202,"position":3,"arabic":"ٱلْإِنسَـٰنَ","translation":"মানুষকে","audioUrl":"wbw/010_012_003.mp3","charTypeName":"word"},{"id":14203,"position":4,"arabic":"ٱلضُّرُّ","translation":"দুঃখ-দৈন্য (দিয়ে)","audioUrl":"wbw/010_012_004.mp3","charTypeName":"word"},{"id":14204,"position":5,"arabic":"دَعَانَا","translation":"(তখন) ডাকে আমাদেরকে","audioUrl":"wbw/010_012_005.mp3","charTypeName":"word"},{"id":14205,"position":6,"arabic":"لِجَنۢبِهِۦٓ","translation":"উপর পাশের তার (অর্থাৎ শুয়ে)","audioUrl":"wbw/010_012_006.mp3","charTypeName":"word"},{"id":14206,"position":7,"arabic":"أَوْ","translation":"বা","audioUrl":"wbw/010_012_007.mp3","charTypeName":"word"},{"id":14207,"position":8,"arabic":"قَاعِدًا","translation":"বসে","audioUrl":"wbw/010_012_008.mp3","charTypeName":"word"},{"id":14208,"position":9,"arabic":"أَوْ","translation":"বা","audioUrl":"wbw/010_012_009.mp3","charTypeName":"word"},{"id":14209,"position":10,"arabic":"قَآئِمًۭا","translation":"দাঁড়িয়ে","audioUrl":"wbw/010_012_010.mp3","charTypeName":"word"},{"id":14210,"position":11,"arabic":"فَلَمَّا","translation":"অতঃপর যখন","audioUrl":"wbw/010_012_011.mp3","charTypeName":"word"},{"id":14211,"position":12,"arabic":"كَشَفْنَا","translation":"আমরা দূর করি","audioUrl":"wbw/010_012_012.mp3","charTypeName":"word"},{"id":14212,"position":13,"arabic":"عَنْهُ","translation":"থেকে তার","audioUrl":"wbw/010_012_013.mp3","charTypeName":"word"},{"id":14213,"position":14,"arabic":"ضُرَّهُۥ","translation":"দুঃখ-দৈন্য তার","audioUrl":"wbw/010_012_014.mp3","charTypeName":"word"},{"id":14214,"position":15,"arabic":"مَرَّ","translation":"সে চলে (এমনভাবে)","audioUrl":"wbw/010_012_015.mp3","charTypeName":"word"},{"id":14215,"position":16,"arabic":"كَأَن","translation":"যেন","audioUrl":"wbw/010_012_016.mp3","charTypeName":"word"},{"id":14216,"position":17,"arabic":"لَّمْ","translation":"নি","audioUrl":"wbw/010_012_017.mp3","charTypeName":"word"},{"id":14217,"position":18,"arabic":"يَدْعُنَآ","translation":"আমাদেরকে ডাকেই","audioUrl":"wbw/010_012_018.mp3","charTypeName":"word"},{"id":14218,"position":19,"arabic":"إِلَىٰ","translation":"জন্যে","audioUrl":"wbw/010_012_019.mp3","charTypeName":"word"},{"id":14219,"position":20,"arabic":"ضُرٍّۢ","translation":"দুঃখের","audioUrl":"wbw/010_012_020.mp3","charTypeName":"word"},{"id":14220,"position":21,"arabic":"مَّسَّهُۥ ۚ","translation":"স্পর্শ করেছিলো তাকে","audioUrl":"wbw/010_012_021.mp3","charTypeName":"word"},{"id":14222,"position":22,"arabic":"كَذَٰلِكَ","translation":"এভাবে","audioUrl":"wbw/010_012_023.mp3","charTypeName":"word"},{"id":14223,"position":23,"arabic":"زُيِّنَ","translation":"সুশোভিত করা হয়েছে","audioUrl":"wbw/010_012_024.mp3","charTypeName":"word"},{"id":14224,"position":24,"arabic":"لِلْمُسْرِفِينَ","translation":"জন্যে সীমালঙ্ঘনকারীদের","audioUrl":"wbw/010_012_025.mp3","charTypeName":"word"},{"id":14225,"position":25,"arabic":"مَا","translation":"যা","audioUrl":"wbw/010_012_026.mp3","charTypeName":"word"},{"id":14226,"position":26,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/010_012_027.mp3","charTypeName":"word"},{"id":14227,"position":27,"arabic":"يَعْمَلُونَ","translation":"তারা কাজ করতে","audioUrl":"wbw/010_012_028.mp3","charTypeName":"word"},{"id":14228,"position":28,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]},{"number":13,"arabic":"وَلَقَدْ أَهْلَكْنَا ٱلْقُرُونَ مِن قَبْلِكُمْ لَمَّا ظَلَمُوا۟ ۙ وَجَآءَتْهُمْ رُسُلُهُم بِٱلْبَيِّنَٰتِ وَمَا كَانُوا۟ لِيُؤْمِنُوا۟ ۚ كَذَٰلِكَ نَجْزِى ٱلْقَوْمَ ٱلْمُجْرِمِينَ","translation":"And, indeed, We destroyed before your time [whole] generations when they [persistently] did evil although the apostles sent unto them brought them all evidence of the truth; for they refused to believe [them]. Thus do We requite people who are lost in sin.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1377.mp3","surahId":10,"words":[{"id":15282,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/010_013_001.mp3","charTypeName":"word"},{"id":15283,"position":2,"arabic":"أَهْلَكْنَا","translation":"ধ্বংস করেছি আমরা","audioUrl":"wbw/010_013_002.mp3","charTypeName":"word"},{"id":15284,"position":3,"arabic":"ٱلْقُرُونَ","translation":"বহু মানবগোষ্ঠীকে","audioUrl":"wbw/010_013_003.mp3","charTypeName":"word"},{"id":15285,"position":4,"arabic":"مِن","translation":"থেকেও","audioUrl":"wbw/010_013_004.mp3","charTypeName":"word"},{"id":15286,"position":5,"arabic":"قَبْلِكُمْ","translation":"পূর্ব তোমাদের","audioUrl":"wbw/010_013_005.mp3","charTypeName":"word"},{"id":15287,"position":6,"arabic":"لَمَّا","translation":"যখন","audioUrl":"wbw/010_013_006.mp3","charTypeName":"word"},{"id":15288,"position":7,"arabic":"ظَلَمُوا۟ ۙ","translation":"তারা অবিচার করেছিলো","audioUrl":"wbw/010_013_007.mp3","charTypeName":"word"},{"id":15290,"position":8,"arabic":"وَجَآءَتْهُمْ","translation":"ও কাছে এসেছিলো তাদের","audioUrl":"wbw/010_013_009.mp3","charTypeName":"word"},{"id":15291,"position":9,"arabic":"رُسُلُهُم","translation":"রাসূলরা তাদের","audioUrl":"wbw/010_013_010.mp3","charTypeName":"word"},{"id":15292,"position":10,"arabic":"بِٱلْبَيِّنَـٰتِ","translation":"সহ সুস্পষ্ট নিদর্শনগুলো","audioUrl":"wbw/010_013_011.mp3","charTypeName":"word"},{"id":15293,"position":11,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/010_013_012.mp3","charTypeName":"word"},{"id":15294,"position":12,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/010_013_013.mp3","charTypeName":"word"},{"id":15295,"position":13,"arabic":"لِيُؤْمِنُوا۟ ۚ","translation":"জন্যে ঈমান আনার","audioUrl":"wbw/010_013_014.mp3","charTypeName":"word"},{"id":15297,"position":14,"arabic":"كَذَٰلِكَ","translation":"এভাবে","audioUrl":"wbw/010_013_016.mp3","charTypeName":"word"},{"id":15298,"position":15,"arabic":"نَجْزِى","translation":"প্রতিফল দিই আমরা","audioUrl":"wbw/010_013_017.mp3","charTypeName":"word"},{"id":15299,"position":16,"arabic":"ٱلْقَوْمَ","translation":"সসম্প্রদায়কে","audioUrl":"wbw/010_013_018.mp3","charTypeName":"word"},{"id":15300,"position":17,"arabic":"ٱلْمُجْرِمِينَ","translation":"অপরাধী","audioUrl":"wbw/010_013_019.mp3","charTypeName":"word"},{"id":15301,"position":18,"arabic":"١٣","translation":"(১৩)","audioUrl":null,"charTypeName":"end"}]},{"number":14,"arabic":"ثُمَّ جَعَلْنَٰكُمْ خَلَٰٓئِفَ فِى ٱلْأَرْضِ مِنۢ بَعْدِهِمْ لِنَنظُرَ كَيْفَ تَعْمَلُونَ","translation":"And thereupon We made you their successors on earth, so that We might behold how you act.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1378.mp3","surahId":10,"words":[{"id":16342,"position":1,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/010_014_001.mp3","charTypeName":"word"},{"id":16343,"position":2,"arabic":"جَعَلْنَـٰكُمْ","translation":"আমরা বানালাম তোমাদেরকে","audioUrl":"wbw/010_014_002.mp3","charTypeName":"word"},{"id":16344,"position":3,"arabic":"خَلَـٰٓئِفَ","translation":"প্রতিনিধি","audioUrl":"wbw/010_014_003.mp3","charTypeName":"word"},{"id":16345,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/010_014_004.mp3","charTypeName":"word"},{"id":16346,"position":5,"arab