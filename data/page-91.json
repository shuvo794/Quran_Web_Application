{"id":91,"ayahs":[{"number":80,"arabic":"مَّن يُطِعِ ٱلرَّسُولَ فَقَدْ أَطَاعَ ٱللَّهَ ۖ وَمَن تَوَلَّىٰ فَمَآ أَرْسَلْنَٰكَ عَلَيْهِمْ حَفِيظًۭا","translation":"Whoever pays heed unto the Apostle pays heed unto God thereby; and as for those who turn away - We have not sent thee to be their keeper.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/573.mp3","surahId":4,"words":[{"id":64178,"position":1,"arabic":"مَّن","translation":"যে","audioUrl":"wbw/004_080_001.mp3","charTypeName":"word"},{"id":64179,"position":2,"arabic":"يُطِعِ","translation":"আনুগত্য করে","audioUrl":"wbw/004_080_002.mp3","charTypeName":"word"},{"id":64180,"position":3,"arabic":"ٱلرَّسُولَ","translation":"রাসূলের","audioUrl":"wbw/004_080_003.mp3","charTypeName":"word"},{"id":64181,"position":4,"arabic":"فَقَدْ","translation":"তবে নিশ্চয়","audioUrl":"wbw/004_080_004.mp3","charTypeName":"word"},{"id":64182,"position":5,"arabic":"أَطَاعَ","translation":"সে আনুগত্য করল","audioUrl":"wbw/004_080_005.mp3","charTypeName":"word"},{"id":64183,"position":6,"arabic":"ٱللَّهَ ۖ","translation":"আল্লাহর","audioUrl":"wbw/004_080_006.mp3","charTypeName":"word"},{"id":64185,"position":7,"arabic":"وَمَن","translation":"এবং যে","audioUrl":"wbw/004_080_008.mp3","charTypeName":"word"},{"id":64186,"position":8,"arabic":"تَوَلَّىٰ","translation":"মুখ ফিরাল (তাতে দুঃখ নেই)","audioUrl":"wbw/004_080_009.mp3","charTypeName":"word"},{"id":64187,"position":9,"arabic":"فَمَآ","translation":"কারণ না","audioUrl":"wbw/004_080_010.mp3","charTypeName":"word"},{"id":64188,"position":10,"arabic":"أَرْسَلْنَـٰكَ","translation":"তোমাকে আমরা পাঠিয়েছি","audioUrl":"wbw/004_080_011.mp3","charTypeName":"word"},{"id":64189,"position":11,"arabic":"عَلَيْهِمْ","translation":"তাদের উপর","audioUrl":"wbw/004_080_012.mp3","charTypeName":"word"},{"id":64190,"position":12,"arabic":"حَفِيظًۭا","translation":"পাহারাদার হিসেবে","audioUrl":"wbw/004_080_013.mp3","charTypeName":"word"},{"id":64191,"position":13,"arabic":"٨٠","translation":"(৮০)","audioUrl":null,"charTypeName":"end"}]},{"number":81,"arabic":"وَيَقُولُونَ طَاعَةٌۭ فَإِذَا بَرَزُوا۟ مِنْ عِندِكَ بَيَّتَ طَآئِفَةٌۭ مِّنْهُمْ غَيْرَ ٱلَّذِى تَقُولُ ۖ وَٱللَّهُ يَكْتُبُ مَا يُبَيِّتُونَ ۖ فَأَعْرِضْ عَنْهُمْ وَتَوَكَّلْ عَلَى ٱللَّهِ ۚ وَكَفَىٰ بِٱللَّهِ وَكِيلًا","translation":"And they say, \"We do pay heed unto thee'' - but when they leave thy presence, some of them devise, in the dark of night, [beliefs] other than thou art voicing; and all the while God records what they thus devise in the dark of night. Leave them, then, alone, and place thy trust in God: for none is as worthy of trust as God.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/574.mp3","surahId":4,"words":[{"id":64595,"position":1,"arabic":"وَيَقُولُونَ","translation":"এবং তারা বলে","audioUrl":"wbw/004_081_001.mp3","charTypeName":"word"},{"id":64596,"position":2,"arabic":"طَاعَةٌۭ","translation":"''আনুগত্য (করি আমরা)''","audioUrl":"wbw/004_081_002.mp3","charTypeName":"word"},{"id":64597,"position":3,"arabic":"فَإِذَا","translation":"অতঃপর যখন","audioUrl":"wbw/004_081_003.mp3","charTypeName":"word"},{"id":64598,"position":4,"arabic":"بَرَزُوا۟","translation":"তারা বের হয়","audioUrl":"wbw/004_081_004.mp3","charTypeName":"word"},{"id":64599,"position":5,"arabic":"مِنْ","translation":"হতে","audioUrl":"wbw/004_081_005.mp3","charTypeName":"word"},{"id":64600,"position":6,"arabic":"عِندِكَ","translation":"তোমার নিকট","audioUrl":"wbw/004_081_006.mp3","charTypeName":"word"},{"id":64601,"position":7,"arabic":"بَيَّتَ","translation":"রাত্রে পরামর্শ করে","audioUrl":"wbw/004_081_007.mp3","charTypeName":"word"},{"id":64602,"position":8,"arabic":"طَآئِفَةٌۭ","translation":"এক দল","audioUrl":"wbw/004_081_008.mp3","charTypeName":"word"},{"id":64603,"position":9,"arabic":"مِّنْهُمْ","translation":"তাদের মধ্য হতে","audioUrl":"wbw/004_081_009.mp3","charTypeName":"word"},{"id":64604,"position":10,"arabic":"غَيْرَ","translation":"(তার) বিপরীত","audioUrl":"wbw/004_081_010.mp3","charTypeName":"word"},{"id":64605,"position":11,"arabic":"ٱلَّذِى","translation":"যা","audioUrl":"wbw/004_081_011.mp3","charTypeName":"word"},{"id":64606,"position":12,"arabic":"تَقُولُ ۖ","translation":"তুমি বল","audioUrl":"wbw/004_081_012.mp3","charTypeName":"word"},{"id":64608,"position":13,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/004_081_014.mp3","charTypeName":"word"},{"id":64609,"position":14,"arabic":"يَكْتُبُ","translation":"লিখছেন","audioUrl":"wbw/004_081_015.mp3","charTypeName":"word"},{"id":64610,"position":15,"arabic":"مَا","translation":"যা","audioUrl":"wbw/004_081_016.mp3","charTypeName":"word"},{"id":64611,"position":16,"arabic":"يُبَيِّتُونَ ۖ","translation":"শলা পরামর্শ করে তারা","audioUrl":"wbw/004_081_017.mp3","charTypeName":"word"},{"id":64613,"position":17,"arabic":"فَأَعْرِضْ","translation":"অতএব উপেক্ষা কর","audioUrl":"wbw/004_081_019.mp3","charTypeName":"word"},{"id":64614,"position":18,"arabic":"عَنْهُمْ","translation":"তাদেরকে","audioUrl":"wbw/004_081_020.mp3","charTypeName":"word"},{"id":64615,"position":19,"arabic":"وَتَوَكَّلْ","translation":"ও ভরসা কর তুমি","audioUrl":"wbw/004_081_021.mp3","charTypeName":"word"},{"id":64616,"position":20,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/004_081_022.mp3","charTypeName":"word"},{"id":64617,"position":21,"arabic":"ٱللَّهِ ۚ","translation":"আল্লাহর","audioUrl":"wbw/004_081_023.mp3","charTypeName":"word"},{"id":64619,"position":22,"arabic":"وَكَفَىٰ","translation":"এবং যথেষ্ট","audioUrl":"wbw/004_081_025.mp3","charTypeName":"word"},{"id":64620,"position":23,"arabic":"بِٱللَّهِ","translation":"আল্লাহই","audioUrl":"wbw/004_081_026.mp3","charTypeName":"word"},{"id":64621,"position":24,"arabic":"وَكِيلًا","translation":"ভরসার স্থল হিসেবে","audioUrl":"wbw/004_081_027.mp3","charTypeName":"word"},{"id":64622,"position":25,"arabic":"٨١","translation":"(৮১)","audioUrl":null,"charTypeName":"end"}]},{"number":82,"arabic":"أَفَلَا يَتَدَبَّرُونَ ٱلْقُرْءَانَ ۚ وَلَوْ كَانَ مِنْ عِندِ غَيْرِ ٱللَّهِ لَوَجَدُوا۟ فِيهِ ٱخْتِلَٰفًۭا كَثِيرًۭا","translation":"Will they not, then, try to understand this Qur’an? Had it issued from any but God, they would surely have found in it many an inner contradiction!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/575.mp3","surahId":4,"words":[{"id":65022,"position":1,"arabic":"أَفَلَا","translation":"অতঃপর কি না","audioUrl":"wbw/004_082_001.mp3","charTypeName":"word"},{"id":65023,"position":2,"arabic":"يَتَدَبَّرُونَ","translation":"তারা চিন্তা-ভাবনা করে","audioUrl":"wbw/004_082_002.mp3","charTypeName":"word"},{"id":65024,"position":3,"arabic":"ٱلْقُرْءَانَ ۚ","translation":"কুরআন (সম্পর্কে)","audioUrl":"wbw/004_082_003.mp3","charTypeName":"word"},{"id":65026,"position":4,"arabic":"وَلَوْ","translation":"এবং যদি","audioUrl":"wbw/004_082_005.mp3","charTypeName":"word"},{"id":65027,"position":5,"arabic":"كَانَ","translation":"হতো","audioUrl":"wbw/004_082_006.mp3","charTypeName":"word"},{"id":65028,"position":6,"arabic":"مِنْ","translation":"থেকে","audioUrl":"wbw/004_082_007.mp3","charTypeName":"word"},{"id":65029,"position":7,"arabic":"عِندِ","translation":"নিকট (অন্য কারো)","audioUrl":"wbw/004_082_008.mp3","charTypeName":"word"},{"id":65030,"position":8,"arabic":"غَيْرِ","translation":"ব্যতীত","audioUrl":"wbw/004_082_009.mp3","charTypeName":"word"},{"id":65031,"position":9,"arabic":"ٱللَّهِ","translation":"আল্লাহ","audioUrl":"wbw/004_082_010.mp3","charTypeName":"word"},{"id":65032,"position":10,"arabic":"لَوَجَدُوا۟","translation":"তারা পেত অবশ্যই","audioUrl":"wbw/004_082_011.mp3","charTypeName":"word"},{"id":65033,"position":11,"arabic":"فِيهِ","translation":"তার মধ্যে","audioUrl":"wbw/004_082_012.mp3","charTypeName":"word"},{"id":65034,"position":12,"arabic":"ٱخْتِلَـٰفًۭا","translation":"অসঙ্গতি","audioUrl":"wbw/004_082_013.mp3","charTypeName":"word"},{"id":65035,"position":13,"arabic":"كَثِيرًۭا","translation":"বহু","audioUrl":"wbw/004_082_014.mp3","charTypeName":"word"},{"id":65036,"position":14,"arabic":"٨٢","translation":"(৮২)","audioUrl":null,"charTypeName":"end"}]},{"number":83,"arabic":"وَإِذَا جَآءَهُمْ أَمْرٌۭ مِّنَ ٱلْأَمْنِ أَوِ ٱلْخَوْفِ أَذَاعُوا۟ بِهِۦ ۖ وَلَوْ رَدُّوهُ إِلَى ٱلرَّسُولِ وَإِلَىٰٓ أُو۟لِى ٱلْأَمْرِ مِنْهُمْ لَعَلِمَهُ ٱلَّذِينَ يَسْتَنۢبِطُونَهُۥ مِنْهُمْ ۗ وَلَوْلَا فَضْلُ ٱللَّهِ عَلَيْكُمْ وَرَحْمَتُهُۥ لَٱتَّبَعْتُمُ ٱلشَّيْطَٰنَ إِلَّا قَلِيلًۭا","translation":"AND IF any [secret] matter pertaining to peace or war comes within their ken, they spread it abroad - whereas, if they would but refer it unto the Apostle and unto those from among the believers who have been entrusted with authority, such of them as are engaged in obtaining intelligence would indeed know [what to do with] it And but for God's bounty towards you, and His grace, all but a few of you would certainly have followed Satan.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/576.mp3","surahId":4,"words":[{"id":65556,"position":1,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/004_083_001.mp3","charTypeName":"word"},{"id":65557,"position":2,"arabic":"جَآءَهُمْ","translation":"কাছে আসে তাদের","audioUrl":"wbw/004_083_002.mp3","charTypeName":"word"},{"id":65558,"position":3,"arabic":"أَمْرٌۭ","translation":"কোন বিষয় (সংবাদ)","audioUrl":"wbw/004_083_003.mp3","charTypeName":"word"},{"id":65559,"position":4,"arabic":"مِّنَ","translation":"(থেকে)","audioUrl":"wbw/004_083_004.mp3","charTypeName":"word"},{"id":65560,"position":5,"arabic":"ٱلْأَمْنِ","translation":"শান্তির","audioUrl":"wbw/004_083_005.mp3","charTypeName":"word"},{"id":65561,"position":6,"arabic":"أَوِ","translation":"বা","audioUrl":"wbw/004_083_006.mp3","charTypeName":"word"},{"id":65562,"position":7,"arabic":"ٱلْخَوْفِ","translation":"ভয়ের","audioUrl":"wbw/004_083_007.mp3","charTypeName":"word"},{"id":65563,"position":8,"arabic":"أَذَاعُوا۟","translation":"তারা প্রচার করে","audioUrl":"wbw/004_083_008.mp3","charTypeName":"word"},{"id":65564,"position":9,"arabic":"بِهِۦ ۖ","translation":"তা সম্পর্কে","audioUrl":"wbw/004_083_009.mp3","charTypeName":"word"},{"id":65566,"position":10,"arabic":"وَلَوْ","translation":"কিন্তু যদি","audioUrl":"wbw/004_083_011.mp3","charTypeName":"word"},{"id":65567,"position":11,"arabic":"رَدُّوهُ","translation":"তা পৌঁছে দিত","audioUrl":"wbw/004_083_012.mp3","charTypeName":"word"},{"id":65568,"position":12,"arabic":"إِلَى","translation":"কাছে","audioUrl":"wbw/004_083_013.mp3","charTypeName":"word"},{"id":65569,"position":13,"arabic":"ٱلرَّسُولِ","translation":"রাসূলের","audioUrl":"wbw/004_083_014.mp3","charTypeName":"word"},{"id":65570,"position":14,"arabic":"وَإِلَىٰٓ","translation":"ও কাছে","audioUrl":"wbw/004_083_015.mp3","charTypeName":"word"},{"id":65571,"position":15,"arabic":"أُو۟لِى","translation":"(প্রথম)","audioUrl":"wbw/004_083_016.mp3","charTypeName":"word"},{"id":65572,"position":16,"arabic":"ٱلْأَمْرِ","translation":"দায়িত্বশীলদের","audioUrl":"wbw/004_083_017.mp3","charTypeName":"word"},{"id":65573,"position":17,"arabic":"مِنْهُمْ","translation":"তাদের মধ্যকার","audioUrl":"wbw/004_083_018.mp3","charTypeName":"word"},{"id":65574,"position":18,"arabic":"لَعَلِمَهُ","translation":"তা অবশ্যই জেনে নিত","audioUrl":"wbw/004_083_019.mp3","charTypeName":"word"},{"id":65575,"position":19,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/004_083_020.mp3","charTypeName":"word"},{"id":65576,"position":20,"arabic":"يَسْتَنۢبِطُونَهُۥ","translation":"তার তথ্যানুসন্ধান করে","audioUrl":"wbw/004_083_021.mp3","charTypeName":"word"},{"id":65577,"position":21,"arabic":"مِنْهُمْ ۗ","translation":"তাদের মধ্য হতে","audioUrl":"wbw/004_083_022.mp3","charTypeName":"word"},{"id":65579,"position":22,"arabic":"وَلَوْلَا","translation":"এবং যদি না (থাকত)","audioUrl":"wbw/004_083_024.mp3","charTypeName":"word"},{"id":65580,"position":23,"arabic":"فَضْلُ","translation":"অনুগ্রহ","audioUrl":"wbw/004_083_025.mp3","charTypeName":"word"},{"id":65581,"position":24,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/004_083_026.mp3","charTypeName":"word"},{"id":65582,"position":25,"arabic":"عَلَيْكُمْ","translation":"তোমাদের উপর","audioUrl":"wbw/004_083_027.mp3","charTypeName":"word"},{"id":65583,"position":26,"arabic":"وَرَحْمَتُهُۥ","translation":"ও তাঁর রহমত (তবে এ সব কারণে)","audioUrl":"wbw/004_083_028.mp3","charTypeName":"word"},{"id":65584,"position":27,"arabic":"لَٱتَّبَعْتُمُ","translation":"তোমরা অনুসরণ করতেই","audioUrl":"wbw/004_083_029.mp3","charTypeName":"word"},{"id":65585,"position":28,"arabic":"ٱلشَّيْطَـٰنَ","translation":"শয়তানের","audioUrl":"wbw/004_083_030.mp3","charTypeName":"word"},{"id":65586,"position":29,"arabic":"إِلَّا","translation":"এ ব্যতীত","audioUrl":"wbw/004_083_031.mp3","charTypeName":"word"},{"id":65587,"position":30,"arabic":"قَلِيلًۭا","translation":"অল্প সংখ্যক","audioUrl":"wbw/004_083_032.mp3","charTypeName":"word"},{"id":65588,"position":31,"arabic":"٨٣","translation":"(৮৩)","audioUrl":null,"charTypeName":"end"}]},{"number":84,"arabic":"فَقَٰتِلْ فِى سَبِيلِ ٱللَّهِ لَا تُكَلَّفُ إِلَّا نَفْسَكَ ۚ وَحَرِّضِ ٱلْمُؤْمِنِينَ ۖ عَسَى ٱللَّهُ أَن يَكُفَّ بَأْسَ ٱلَّذِينَ كَفَرُوا۟ ۚ وَٱللَّهُ أَشَدُّ بَأْسًۭا وَأَشَدُّ تَنكِيلًۭا","translation":"Fight thou, then, in God's cause - since thou art but responsible for thine own self - and inspire the believers to overcome all fear of death. God may well curb the might of those who are bent on denying the truth: for God is stronger in might, and stronger in ability to deter.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/577.mp3","surahId":4,"words":[{"id":65946,"position":1,"arabic":"فَقَـٰتِلْ","translation":"লড়াই কর অতএব","audioUrl":"wbw/004_084_001.mp3","charTypeName":"word"},{"id":65947,"position":2,"arabic":"فِى","translation":"(মধ্যে)","audioUrl":"wbw/004_084_002.mp3","charTypeName":"word"},{"id":65948,"position":3,"arabic":"سَبِيلِ","translation":"পথে","audioUrl":"wbw/004_084_003.mp3","charTypeName":"word"},{"id":65949,"position":4,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/004_084_004.mp3","charTypeName":"word"},{"id":65950,"position":5,"arabic":"لَا","translation":"না","audioUrl":"wbw/004_084_005.mp3","charTypeName":"word"},{"id":65951,"position":6,"arabic":"تُكَلَّفُ","translation":"দায়ী করা হবে","audioUrl":"wbw/004_084_006.mp3","charTypeName":"word"},{"id":65952,"position":7,"arabic":"إِلَّا","translation":"এছাড়া","audioUrl":"wbw/004_084_007.mp3","charTypeName":"word"},{"id":65953,"position":8,"arabic":"نَفْسَكَ ۚ","translation":"তোমার নিজেকে","audioUrl":"wbw/004_084_008.mp3","charTypeName":"word"},{"id":65955,"position":9,"arabic":"وَحَرِّضِ","translation":"ও উদ্বুদ্ধ কর (যুদ্ধে)","audioUrl":"wbw/004_084_010.mp3","charTypeName":"word"},{"id":65956,"position":10,"arabic":"ٱلْمُؤْمِنِينَ ۖ","translation":"মু’মিনদেরকে","audioUrl":"wbw/004_084_011.mp3","charTypeName":"word"},{"id":65958,"position":11,"arabic":"عَسَى","translation":"হয়ত","audioUrl":"wbw/004_084_013.mp3","charTypeName":"word"},{"id":65959,"position":12,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/004_084_014.mp3","charTypeName":"word"},{"id":65960,"position":13,"arabic":"أَن","translation":"(যে)","audioUrl":"wbw/004_084_015.mp3","charTypeName":"word"},{"id":65961,"position":14,"arabic":"يَكُفَّ","translation":"খর্ব করবেন","audioUrl":"wbw/004_084_016.mp3","charTypeName":"word"},{"id":65962,"position":15,"arabic":"بَأْسَ","translation":"শক্তি (ঐসব লোকদের)","audioUrl":"wbw/004_084_017.mp3","charTypeName":"word"},{"id":65963,"position":16,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/004_084_018.mp3","charTypeName":"word"},{"id":65964,"position":17,"arabic":"كَفَرُوا۟ ۚ","translation":"কুফুরী করেছে","audioUrl":"wbw/004_084_019.mp3","charTypeName":"word"},{"id":65966,"position":18,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/004_084_021.mp3","charTypeName":"word"},{"id":65967,"position":19,"arabic":"أَشَدُّ","translation":"প্রবলতর","audioUrl":"wbw/004_084_022.mp3","charTypeName":"word"},{"id":65968,