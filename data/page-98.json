{"id":98,"ayahs":[{"number":122,"arabic":"وَٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ سَنُدْخِلُهُمْ جَنَّٰتٍۢ تَجْرِى مِن تَحْتِهَا ٱلْأَنْهَٰرُ خَٰلِدِينَ فِيهَآ أَبَدًۭا ۖ وَعْدَ ٱللَّهِ حَقًّۭا ۚ وَمَنْ أَصْدَقُ مِنَ ٱللَّهِ قِيلًۭا","translation":"Yet those who attain to faith and do righteous deeds We shall bring into gardens through which running waters flow, therein to abide beyond the count of time: this is, in truth, God's promise - and whose word could be truer than God's?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/615.mp3","surahId":4,"words":[{"id":76692,"position":1,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/004_122_001.mp3","charTypeName":"word"},{"id":76693,"position":2,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/004_122_002.mp3","charTypeName":"word"},{"id":76694,"position":3,"arabic":"وَعَمِلُوا۟","translation":"ও কাজ করেছে","audioUrl":"wbw/004_122_003.mp3","charTypeName":"word"},{"id":76695,"position":4,"arabic":"ٱلصَّـٰلِحَـٰتِ","translation":"নেকীর","audioUrl":"wbw/004_122_004.mp3","charTypeName":"word"},{"id":76696,"position":5,"arabic":"سَنُدْخِلُهُمْ","translation":"তাদের প্রবেশ করাব আমরা","audioUrl":"wbw/004_122_005.mp3","charTypeName":"word"},{"id":76697,"position":6,"arabic":"جَنَّـٰتٍۢ","translation":"জান্নাতে","audioUrl":"wbw/004_122_006.mp3","charTypeName":"word"},{"id":76698,"position":7,"arabic":"تَجْرِى","translation":"প্রবাহিত হয়","audioUrl":"wbw/004_122_007.mp3","charTypeName":"word"},{"id":76699,"position":8,"arabic":"مِن","translation":"(থেকে)","audioUrl":"wbw/004_122_008.mp3","charTypeName":"word"},{"id":76700,"position":9,"arabic":"تَحْتِهَا","translation":"তার পাদদেশে","audioUrl":"wbw/004_122_009.mp3","charTypeName":"word"},{"id":76701,"position":10,"arabic":"ٱلْأَنْهَـٰرُ","translation":"ঝর্ণাধারাসমুহ","audioUrl":"wbw/004_122_010.mp3","charTypeName":"word"},{"id":76702,"position":11,"arabic":"خَـٰلِدِينَ","translation":"তারা অবস্থানকারী হবে","audioUrl":"wbw/004_122_011.mp3","charTypeName":"word"},{"id":76703,"position":12,"arabic":"فِيهَآ","translation":"তার মধ্যে","audioUrl":"wbw/004_122_012.mp3","charTypeName":"word"},{"id":76704,"position":13,"arabic":"أَبَدًۭا ۖ","translation":"চিরকাল","audioUrl":"wbw/004_122_013.mp3","charTypeName":"word"},{"id":76706,"position":14,"arabic":"وَعْدَ","translation":"ওয়াদা","audioUrl":"wbw/004_122_015.mp3","charTypeName":"word"},{"id":76707,"position":15,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/004_122_016.mp3","charTypeName":"word"},{"id":76708,"position":16,"arabic":"حَقًّۭا ۚ","translation":"সত্য","audioUrl":"wbw/004_122_017.mp3","charTypeName":"word"},{"id":76710,"position":17,"arabic":"وَمَنْ","translation":"এবং কে","audioUrl":"wbw/004_122_019.mp3","charTypeName":"word"},{"id":76711,"position":18,"arabic":"أَصْدَقُ","translation":"অধিক সত্যবাদী","audioUrl":"wbw/004_122_020.mp3","charTypeName":"word"},{"id":76712,"position":19,"arabic":"مِنَ","translation":"চেয়ে","audioUrl":"wbw/004_122_021.mp3","charTypeName":"word"},{"id":76713,"position":20,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/004_122_022.mp3","charTypeName":"word"},{"id":76714,"position":21,"arabic":"قِيلًۭا","translation":"কথায়","audioUrl":"wbw/004_122_023.mp3","charTypeName":"word"},{"id":76715,"position":22,"arabic":"١٢٢","translation":"(১২২)","audioUrl":null,"charTypeName":"end"}]},{"number":123,"arabic":"لَّيْسَ بِأَمَانِيِّكُمْ وَلَآ أَمَانِىِّ أَهْلِ ٱلْكِتَٰبِ ۗ مَن يَعْمَلْ سُوٓءًۭا يُجْزَ بِهِۦ وَلَا يَجِدْ لَهُۥ مِن دُونِ ٱللَّهِ وَلِيًّۭا وَلَا نَصِيرًۭا","translation":"It may not accord with your wishful thinking - nor with the wishful thinking of the fol­lowers of earlier revelation - [that] he who does evil shall be requited for it, and shall find none to protect him from God, and none to bring him succour,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/616.mp3","surahId":4,"words":[{"id":76937,"position":1,"arabic":"لَّيْسَ","translation":"না (হবে শেষ পরিণিতি)","audioUrl":"wbw/004_123_001.mp3","charTypeName":"word"},{"id":76938,"position":2,"arabic":"بِأَمَانِيِّكُمْ","translation":"তোমাদের আকাঙ্ক্ষা অনুযায়ী","audioUrl":"wbw/004_123_002.mp3","charTypeName":"word"},{"id":76939,"position":3,"arabic":"وَلَآ","translation":"আর না","audioUrl":"wbw/004_123_003.mp3","charTypeName":"word"},{"id":76940,"position":4,"arabic":"أَمَانِىِّ","translation":"আকাঙ্ক্ষা (অনুযায়ী)","audioUrl":"wbw/004_123_004.mp3","charTypeName":"word"},{"id":76941,"position":5,"arabic":"أَهْلِ","translation":"আহলি","audioUrl":"wbw/004_123_005.mp3","charTypeName":"word"},{"id":76942,"position":6,"arabic":"ٱلْكِتَـٰبِ ۗ","translation":"কিতাবদের","audioUrl":"wbw/004_123_006.mp3","charTypeName":"word"},{"id":76944,"position":7,"arabic":"مَن","translation":"যে","audioUrl":"wbw/004_123_008.mp3","charTypeName":"word"},{"id":76945,"position":8,"arabic":"يَعْمَلْ","translation":"কাজ করবে","audioUrl":"wbw/004_123_009.mp3","charTypeName":"word"},{"id":76946,"position":9,"arabic":"سُوٓءًۭا","translation":"মন্দ","audioUrl":"wbw/004_123_010.mp3","charTypeName":"word"},{"id":76947,"position":10,"arabic":"يُجْزَ","translation":"প্রতিফল দেয়া হবে","audioUrl":"wbw/004_123_011.mp3","charTypeName":"word"},{"id":76948,"position":11,"arabic":"بِهِۦ","translation":"সে অনুযায়ী","audioUrl":"wbw/004_123_012.mp3","charTypeName":"word"},{"id":76949,"position":12,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/004_123_013.mp3","charTypeName":"word"},{"id":76950,"position":13,"arabic":"يَجِدْ","translation":"সে পাবে","audioUrl":"wbw/004_123_014.mp3","charTypeName":"word"},{"id":76951,"position":14,"arabic":"لَهُۥ","translation":"তার জন্য","audioUrl":"wbw/004_123_015.mp3","charTypeName":"word"},{"id":76952,"position":15,"arabic":"مِن","translation":"(থেকে)","audioUrl":"wbw/004_123_016.mp3","charTypeName":"word"},{"id":76953,"position":16,"arabic":"دُونِ","translation":"ছাড়া","audioUrl":"wbw/004_123_017.mp3","charTypeName":"word"},{"id":76954,"position":17,"arabic":"ٱللَّهِ","translation":"আল্লাহ","audioUrl":"wbw/004_123_018.mp3","charTypeName":"word"},{"id":76955,"position":18,"arabic":"وَلِيًّۭا","translation":"কোন অভিভাবক","audioUrl":"wbw/004_123_019.mp3","charTypeName":"word"},{"id":76956,"position":19,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/004_123_020.mp3","charTypeName":"word"},{"id":76957,"position":20,"arabic":"نَصِيرًۭا","translation":"কোন সাহায্যকারী","audioUrl":"wbw/004_123_021.mp3","charTypeName":"word"},{"id":76958,"position":21,"arabic":"١٢٣","translation":"(১২৩)","audioUrl":null,"charTypeName":"end"}]},{"number":124,"arabic":"وَمَن يَعْمَلْ مِنَ ٱلصَّٰلِحَٰتِ مِن ذَكَرٍ أَوْ أُنثَىٰ وَهُوَ مُؤْمِنٌۭ فَأُو۟لَٰٓئِكَ يَدْخُلُونَ ٱلْجَنَّةَ وَلَا يُظْلَمُونَ نَقِيرًۭا","translation":"whereas anyone - be it man or woman - who does [whatever he can] of good deeds and is a believer withal, shall enter paradise, and shall not be wronged by as much as [would fill] the groove of a date-stone.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/617.mp3","surahId":4,"words":[{"id":76959,"position":1,"arabic":"وَمَن","translation":"এবং যে","audioUrl":"wbw/004_124_001.mp3","charTypeName":"word"},{"id":76960,"position":2,"arabic":"يَعْمَلْ","translation":"কাজ করবে","audioUrl":"wbw/004_124_002.mp3","charTypeName":"word"},{"id":76961,"position":3,"arabic":"مِنَ","translation":"(থেকে)","audioUrl":"wbw/004_124_003.mp3","charTypeName":"word"},{"id":76962,"position":4,"arabic":"ٱلصَّـٰلِحَـٰتِ","translation":"নেকীসমূহের","audioUrl":"wbw/004_124_004.mp3","charTypeName":"word"},{"id":76963,"position":5,"arabic":"مِن","translation":"মধ্য হতে","audioUrl":"wbw/004_124_005.mp3","charTypeName":"word"},{"id":76964,"position":6,"arabic":"ذَكَرٍ","translation":"পুরুষদের","audioUrl":"wbw/004_124_006.mp3","charTypeName":"word"},{"id":76965,"position":7,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/004_124_007.mp3","charTypeName":"word"},{"id":76966,"position":8,"arabic":"أُنثَىٰ","translation":"নারীদের","audioUrl":"wbw/004_124_008.mp3","charTypeName":"word"},{"id":76967,"position":9,"arabic":"وَهُوَ","translation":"এবং সে","audioUrl":"wbw/004_124_009.mp3","charTypeName":"word"},{"id":76968,"position":10,"arabic":"مُؤْمِنٌۭ","translation":"মু'মিনও","audioUrl":"wbw/004_124_010.mp3","charTypeName":"word"},{"id":76969,"position":11,"arabic":"فَأُو۟لَـٰٓئِكَ","translation":"ঐসব লোক তখন","audioUrl":"wbw/004_124_011.mp3","charTypeName":"word"},{"id":76970,"position":12,"arabic":"يَدْخُلُونَ","translation":"প্রবেশ করবে","audioUrl":"wbw/004_124_012.mp3","charTypeName":"word"},{"id":76971,"position":13,"arabic":"ٱلْجَنَّةَ","translation":"জান্নাতে","audioUrl":"wbw/004_124_013.mp3","charTypeName":"word"},{"id":76972,"position":14,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/004_124_014.mp3","charTypeName":"word"},{"id":76973,"position":15,"arabic":"يُظْلَمُونَ","translation":"জুলুম করা হবে","audioUrl":"wbw/004_124_015.mp3","charTypeName":"word"},{"id":76974,"position":16,"arabic":"نَقِيرًۭا","translation":"সামান্য পরিমাণেও","audioUrl":"wbw/004_124_016.mp3","charTypeName":"word"},{"id":76975,"position":17,"arabic":"١٢٤","translation":"(১২৪)","audioUrl":null,"charTypeName":"end"}]},{"number":125,"arabic":"وَمَنْ أَحْسَنُ دِينًۭا مِّمَّنْ أَسْلَمَ وَجْهَهُۥ لِلَّهِ وَهُوَ مُحْسِنٌۭ وَٱتَّبَعَ مِلَّةَ إِبْرَٰهِيمَ حَنِيفًۭا ۗ وَٱتَّخَذَ ٱللَّهُ إِبْرَٰهِيمَ خَلِيلًۭا","translation":"And who could be of better faith than he who surrenders his whole being unto God and is a doer of good withal, and follows the creed of Abraham, who turned away from all that is false - seeing that God exalted Abraham with His love?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/618.mp3","surahId":4,"words":[{"id":77160,"position":1,"arabic":"وَمَنْ","translation":"এবং কার","audioUrl":"wbw/004_125_001.mp3","charTypeName":"word"},{"id":77161,"position":2,"arabic":"أَحْسَنُ","translation":"উত্তম","audioUrl":"wbw/004_125_002.mp3","charTypeName":"word"},{"id":77162,"position":3,"arabic":"دِينًۭا","translation":"জীবন-যাপন পন্থা","audioUrl":"wbw/004_125_003.mp3","charTypeName":"word"},{"id":77163,"position":4,"arabic":"مِّمَّنْ","translation":"(তার) চেয়ে যে","audioUrl":"wbw/004_125_004.mp3","charTypeName":"word"},{"id":77164,"position":5,"arabic":"أَسْلَمَ","translation":"আত্মসমর্পণ করল","audioUrl":"wbw/004_125_005.mp3","charTypeName":"word"},{"id":77165,"position":6,"arabic":"وَجْهَهُۥ","translation":"তার নিজেকে","audioUrl":"wbw/004_125_006.mp3","charTypeName":"word"},{"id":77166,"position":7,"arabic":"لِلَّهِ","translation":"আল্লাহর কাছে","audioUrl":"wbw/004_125_007.mp3","charTypeName":"word"},{"id":77167,"position":8,"arabic":"وَهُوَ","translation":"এবং সে","audioUrl":"wbw/004_125_008.mp3","charTypeName":"word"},{"id":77168,"position":9,"arabic":"مُحْسِنٌۭ","translation":"সৎকর্মশীলও","audioUrl":"wbw/004_125_009.mp3","charTypeName":"word"},{"id":77169,"position":10,"arabic":"وَٱتَّبَعَ","translation":"এবং অনুসরণ করল","audioUrl":"wbw/004_125_010.mp3","charTypeName":"word"},{"id":77170,"position":11,"arabic":"مِلَّةَ","translation":"পন্থা","audioUrl":"wbw/004_125_011.mp3","charTypeName":"word"},{"id":77171,"position":12,"arabic":"إِبْرَٰهِيمَ","translation":"ইবরাহীমের","audioUrl":"wbw/004_125_012.mp3","charTypeName":"word"},{"id":77172,"position":13,"arabic":"حَنِيفًۭا ۗ","translation":"একনিষ্ঠভাবে","audioUrl":"wbw/004_125_013.mp3","charTypeName":"word"},{"id":77174,"position":14,"arabic":"وَٱتَّخَذَ","translation":"এবং গ্রহণ করেছেন","audioUrl":"wbw/004_125_015.mp3","charTypeName":"word"},{"id":77175,"position":15,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/004_125_016.mp3","charTypeName":"word"},{"id":77176,"position":16,"arabic":"إِبْرَٰهِيمَ","translation":"ইবরাহীমকে","audioUrl":"wbw/004_125_017.mp3","charTypeName":"word"},{"id":77177,"position":17,"arabic":"خَلِيلًۭا","translation":"বন্ধু হিসেবে","audioUrl":"wbw/004_125_018.mp3","charTypeName":"word"},{"id":77178,"position":18,"arabic":"١٢٥","translation":"(১২৫)","audioUrl":null,"charTypeName":"end"}]},{"number":126,"arabic":"وَلِلَّهِ مَا فِى ٱلسَّمَٰوَٰتِ وَمَا فِى ٱلْأَرْضِ ۚ وَكَانَ ٱللَّهُ بِكُلِّ شَىْءٍۢ مُّحِيطًۭا","translation":"For, unto God belongs all that is in the heavens and all that is on earth; and, indeed, God encompasses everything.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/619.mp3","surahId":4,"words":[{"id":77277,"position":1,"arabic":"وَلِلَّهِ","translation":"এবং আল্লাহরই জন্য","audioUrl":"wbw/004_126_001.mp3","charTypeName":"word"},{"id":77278,"position":2,"arabic":"مَا","translation":"যা কিছু (আছে)","audioUrl":"wbw/004_126_002.mp3","charTypeName":"word"},{"id":77279,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/004_126_003.mp3","charTypeName":"word"},{"id":77280,"position":4,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আসমানসমূহের","audioUrl":"wbw/004_126_004.mp3","charTypeName":"word"},{"id":77281,"position":5,"arabic":"وَمَا","translation":"ও যা কিছু (আছে)","audioUrl":"wbw/004_126_005.mp3","charTypeName":"word"},{"id":77282,"position":6,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/004_126_006.mp3","charTypeName":"word"},{"id":77283,"position":7,"arabic":"ٱلْأَرْضِ ۚ","translation":"পৃথিবীর","audioUrl":"wbw/004_126_007.mp3","charTypeName":"word"},{"id":77285,"position":8,"arabic":"وَكَانَ","translation":"এবং হলেন","audioUrl":"wbw/004_126_009.mp3","charTypeName":"word"},{"id":77286,"position":9,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/004_126_010.mp3","charTypeName":"word"},{"id":77287,"position":10,"arabic":"بِكُلِّ","translation":"সব","audioUrl":"wbw/004_126_011.mp3","charTypeName":"word"},{"id":77288,"position":11,"arabic":"شَىْءٍۢ","translation":"কিছুকে","audioUrl":"wbw/004_126_012.mp3","charTypeName":"word"},{"id":77289,"position":12,"arabic":"مُّحِيطًۭا","translation":"পরিবেষ্টনকারী","audioUrl":"wbw/004_126_013.mp3","charTypeName":"word"},{"id":77290,"position":13,"arabic":"١٢٦","translation":"(১২৬)","audioUrl":null,"charTypeName":"end"}]},{"number":127,"arabic":"وَيَسْتَفْتُونَكَ فِى ٱلنِّسَآءِ ۖ قُلِ ٱللَّهُ يُفْتِيكُمْ فِيهِنَّ وَمَا يُتْلَىٰ عَلَيْكُمْ فِى ٱلْكِتَٰبِ فِى يَتَٰمَى ٱلنِّسَآءِ ٱلَّٰتِى لَا تُؤْتُونَهُنَّ مَا كُتِبَ لَهُنَّ وَتَرْغَبُونَ أَن تَنكِحُوهُنَّ وَٱلْمُسْتَضْعَفِينَ مِنَ ٱلْوِلْدَٰنِ وَأَن تَقُومُوا۟ لِلْيَتَٰمَىٰ بِٱلْقِسْطِ ۚ وَمَا تَفْعَلُوا۟ مِنْ خَيْرٍۢ فَإِنَّ ٱللَّهَ كَانَ بِهِۦ عَلِيمًۭا","translation":"AND THEY will ask thee to enlighten them about the laws concerning women. Say: \"God [Himself] en­lightens you about the laws concerning them\"- for [His will is shown] in what is being conveyed unto you through this divine writ about orphan women [in your charge], to whom - because you yourselves may be desirous of marrying them - you do not give that which has been ordained for them; and about help­less children; and about your duty to treat orphans with equity. And whatever good you may do - be­hold, God has indeed full knowledge thereof.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/620.mp3","surahId":4,"words":[{"id":77472,"position":1,"arabic":"وَيَسْتَفْتُونَكَ","translation":"এবং তোমাকে তারা ব্যবস্থা জিজ্ঞাসা করে","audioUrl":"wbw/004_127_001.mp3","charTypeName":"word"},{"id":77473,"position":2,"arabic":"فِى","translation":"সম্পর্কে","audioUrl":"wbw/004_127_002.mp3","charTypeName":"word"},{"id":77474,"position":3,"arabic":"ٱلنِّسَآءِ ۖ","translation":"স্ত্রীলোকদের","audioUrl":"wbw/004_127_003.mp3","charTypeName":"word"},{"id":77476,"position":4,"arabic":"قُلِ","translation":"বল","audioUrl":"wbw/004_127_005.mp3","charTypeName":"word"},{"id":77477,"position":5,"arabic":"ٱللَّهُ","translation":"''আল্লাহ","audioUrl":"wbw/004_127_006.mp3","charTypeName":"word"},{"id":77478,"position":6,"arabic":"يُفْتِيكُمْ","translation":"তোমাদের ব্যবস্থা বলে দিচ্ছেন","audioUrl":"wbw/004_127_007.mp3","charTypeName":"word"},{"id":77479,"position":7,"arabic":"فِيهِنَّ","translation":"তাদের সম্পর্কে","audioUrl":"wbw/004_127_008.mp3","charTypeName":"word"},{"id":77480,"p