{"id":412,"ayahs":[{"number":12,"arabic":"وَلَقَدْ ءَاتَيْنَا لُقْمَٰنَ ٱلْحِكْمَةَ أَنِ ٱشْكُرْ لِلَّهِ ۚ وَمَن يَشْكُرْ فَإِنَّمَا يَشْكُرُ لِنَفْسِهِۦ ۖ وَمَن كَفَرَ فَإِنَّ ٱللَّهَ غَنِىٌّ حَمِيدٌۭ","translation":"and, indeed, we granted this wisdom unto Luq­man: “Be grateful unto God - for he who is grateful [unto Him] is but grateful for the good of his own self; whereas he who chooses to be ungrateful [ought to know that], verily, God is self-sufficient, ever to be praised!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3481.mp3","surahId":31,"words":[{"id":14433,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/031_012_001.mp3","charTypeName":"word"},{"id":14434,"position":2,"arabic":"ءَاتَيْنَا","translation":"দিয়েছিলাম আমরা","audioUrl":"wbw/031_012_002.mp3","charTypeName":"word"},{"id":14435,"position":3,"arabic":"لُقْمَـٰنَ","translation":"লুকমানকে","audioUrl":"wbw/031_012_003.mp3","charTypeName":"word"},{"id":14436,"position":4,"arabic":"ٱلْحِكْمَةَ","translation":"প্রজ্ঞা","audioUrl":"wbw/031_012_004.mp3","charTypeName":"word"},{"id":14437,"position":5,"arabic":"أَنِ","translation":"যে","audioUrl":"wbw/031_012_005.mp3","charTypeName":"word"},{"id":14438,"position":6,"arabic":"ٱشْكُرْ","translation":"\"তুমি কৃতজ্ঞতা প্রকাশ করো","audioUrl":"wbw/031_012_006.mp3","charTypeName":"word"},{"id":14439,"position":7,"arabic":"لِلَّهِ ۚ","translation":"জন্যে আল্লাহ্‌রই\"","audioUrl":"wbw/031_012_007.mp3","charTypeName":"word"},{"id":14441,"position":8,"arabic":"وَمَن","translation":"এবং যে","audioUrl":"wbw/031_012_009.mp3","charTypeName":"word"},{"id":14442,"position":9,"arabic":"يَشْكُرْ","translation":"(আল্লাহর) কৃতজ্ঞতা প্রকাশ করে","audioUrl":"wbw/031_012_010.mp3","charTypeName":"word"},{"id":14443,"position":10,"arabic":"فَإِنَّمَا","translation":"তখন মূলতঃ","audioUrl":"wbw/031_012_011.mp3","charTypeName":"word"},{"id":14444,"position":11,"arabic":"يَشْكُرُ","translation":"সে কৃতজ্ঞতা প্রকাশ করে","audioUrl":"wbw/031_012_012.mp3","charTypeName":"word"},{"id":14445,"position":12,"arabic":"لِنَفْسِهِۦ ۖ","translation":"জন্যে নিজের তার","audioUrl":"wbw/031_012_013.mp3","charTypeName":"word"},{"id":14447,"position":13,"arabic":"وَمَن","translation":"এবং যে","audioUrl":"wbw/031_012_015.mp3","charTypeName":"word"},{"id":14448,"position":14,"arabic":"كَفَرَ","translation":"অকৃতজ্ঞ হয়","audioUrl":"wbw/031_012_016.mp3","charTypeName":"word"},{"id":14449,"position":15,"arabic":"فَإِنَّ","translation":"তবে নিশ্চয়ই","audioUrl":"wbw/031_012_017.mp3","charTypeName":"word"},{"id":14450,"position":16,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/031_012_018.mp3","charTypeName":"word"},{"id":14451,"position":17,"arabic":"غَنِىٌّ","translation":"অমুখাপেক্ষী","audioUrl":"wbw/031_012_019.mp3","charTypeName":"word"},{"id":14452,"position":18,"arabic":"حَمِيدٌۭ","translation":"প্রশংসিত","audioUrl":"wbw/031_012_020.mp3","charTypeName":"word"},{"id":14453,"position":19,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]},{"number":13,"arabic":"وَإِذْ قَالَ لُقْمَٰنُ لِٱبْنِهِۦ وَهُوَ يَعِظُهُۥ يَٰبُنَىَّ لَا تُشْرِكْ بِٱللَّهِ ۖ إِنَّ ٱلشِّرْكَ لَظُلْمٌ عَظِيمٌۭ","translation":"And, lo, Luqman spoke thus unto his son, admonishing him: “O my dear son! Do not ascribe divine powers to aught beside God: for, behold, such [a false] ascribing of divinity is indeed an awesome wrong!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3482.mp3","surahId":31,"words":[{"id":15534,"position":1,"arabic":"وَإِذْ","translation":"এবং (স্মরণ করো) যখন","audioUrl":"wbw/031_013_001.mp3","charTypeName":"word"},{"id":15535,"position":2,"arabic":"قَالَ","translation":"বলেছিলো","audioUrl":"wbw/031_013_002.mp3","charTypeName":"word"},{"id":15536,"position":3,"arabic":"لُقْمَـٰنُ","translation":"লুকমান","audioUrl":"wbw/031_013_003.mp3","charTypeName":"word"},{"id":15537,"position":4,"arabic":"لِٱبْنِهِۦ","translation":"উদ্দেশ্যে পুত্রের তার","audioUrl":"wbw/031_013_004.mp3","charTypeName":"word"},{"id":15538,"position":5,"arabic":"وَهُوَ","translation":"এমতাবস্হায় যে সে","audioUrl":"wbw/031_013_005.mp3","charTypeName":"word"},{"id":15539,"position":6,"arabic":"يَعِظُهُۥ","translation":"উপদেশ দিচ্ছিলো তাকে","audioUrl":"wbw/031_013_006.mp3","charTypeName":"word"},{"id":15540,"position":7,"arabic":"يَـٰبُنَىَّ","translation":"\"হে আমার পুত্র","audioUrl":"wbw/031_013_007.mp3","charTypeName":"word"},{"id":15541,"position":8,"arabic":"لَا","translation":"না","audioUrl":"wbw/031_013_008.mp3","charTypeName":"word"},{"id":15542,"position":9,"arabic":"تُشْرِكْ","translation":"শিরক করো","audioUrl":"wbw/031_013_009.mp3","charTypeName":"word"},{"id":15543,"position":10,"arabic":"بِٱللَّهِ ۖ","translation":"সাথে আল্লাহর(কাউকে)","audioUrl":"wbw/031_013_010.mp3","charTypeName":"word"},{"id":15545,"position":11,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/031_013_012.mp3","charTypeName":"word"},{"id":15546,"position":12,"arabic":"ٱلشِّرْكَ","translation":"শিরক করা","audioUrl":"wbw/031_013_013.mp3","charTypeName":"word"},{"id":15547,"position":13,"arabic":"لَظُلْمٌ","translation":"অবশ্যই সীমালঙ্ঘন","audioUrl":"wbw/031_013_014.mp3","charTypeName":"word"},{"id":15548,"position":14,"arabic":"عَظِيمٌۭ","translation":"চরম\"","audioUrl":"wbw/031_013_015.mp3","charTypeName":"word"},{"id":15549,"position":15,"arabic":"١٣","translation":"(১৩)","audioUrl":null,"charTypeName":"end"}]},{"number":14,"arabic":"وَوَصَّيْنَا ٱلْإِنسَٰنَ بِوَٰلِدَيْهِ حَمَلَتْهُ أُمُّهُۥ وَهْنًا عَلَىٰ وَهْنٍۢ وَفِصَٰلُهُۥ فِى عَامَيْنِ أَنِ ٱشْكُرْ لِى وَلِوَٰلِدَيْكَ إِلَىَّ ٱلْمَصِيرُ","translation":"“And [God says:] ‘We have enjoined upon man goodness towards his parents: his mother bore him by bearing strain upon strain, and his utter dependence on her lasted two years: [hence, O man,] be grateful towards Me and towards thy parents, [and remember that] with Me is all journeys’ end.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3483.mp3","surahId":31,"words":[{"id":16577,"position":1,"arabic":"وَوَصَّيْنَا","translation":"এবং জোর উপদেশ দিয়েছি আমরা","audioUrl":"wbw/031_014_001.mp3","charTypeName":"word"},{"id":16578,"position":2,"arabic":"ٱلْإِنسَـٰنَ","translation":"মানুষকে","audioUrl":"wbw/031_014_002.mp3","charTypeName":"word"},{"id":16579,"position":3,"arabic":"بِوَٰلِدَيْهِ","translation":"সাথে তার মাতা-পিতার (ভালো ব্যবহারের জন্যে)","audioUrl":"wbw/031_014_003.mp3","charTypeName":"word"},{"id":16580,"position":4,"arabic":"حَمَلَتْهُ","translation":"বহন করেছে তাকে (পেটে)","audioUrl":"wbw/031_014_004.mp3","charTypeName":"word"},{"id":16581,"position":5,"arabic":"أُمُّهُۥ","translation":"মা তার","audioUrl":"wbw/031_014_005.mp3","charTypeName":"word"},{"id":16582,"position":6,"arabic":"وَهْنًا","translation":"কষ্টের","audioUrl":"wbw/031_014_006.mp3","charTypeName":"word"},{"id":16583,"position":7,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/031_014_007.mp3","charTypeName":"word"},{"id":16584,"position":8,"arabic":"وَهْنٍۢ","translation":"কষ্ট (করে)","audioUrl":"wbw/031_014_008.mp3","charTypeName":"word"},{"id":16585,"position":9,"arabic":"وَفِصَـٰلُهُۥ","translation":"এবং দুধ ছাড়ান তার","audioUrl":"wbw/031_014_009.mp3","charTypeName":"word"},{"id":16586,"position":10,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/031_014_010.mp3","charTypeName":"word"},{"id":16587,"position":11,"arabic":"عَامَيْنِ","translation":"দু'বছরের","audioUrl":"wbw/031_014_011.mp3","charTypeName":"word"},{"id":16588,"position":12,"arabic":"أَنِ","translation":"যে","audioUrl":"wbw/031_014_012.mp3","charTypeName":"word"},{"id":16589,"position":13,"arabic":"ٱشْكُرْ","translation":"\"কৃতজ্ঞতা প্রকাশ করো","audioUrl":"wbw/031_014_013.mp3","charTypeName":"word"},{"id":16590,"position":14,"arabic":"لِى","translation":"প্রতি আমার","audioUrl":"wbw/031_014_014.mp3","charTypeName":"word"},{"id":16591,"position":15,"arabic":"وَلِوَٰلِدَيْكَ","translation":"এবং প্রতি তোমার মা-বাপেরও","audioUrl":"wbw/031_014_015.mp3","charTypeName":"word"},{"id":16592,"position":16,"arabic":"إِلَىَّ","translation":"দিকে আমারই","audioUrl":"wbw/031_014_016.mp3","charTypeName":"word"},{"id":16593,"position":17,"arabic":"ٱلْمَصِيرُ","translation":"(তোমাদের) প্রত্যাবর্তন","audioUrl":"wbw/031_014_017.mp3","charTypeName":"word"},{"id":16594,"position":18,"arabic":"١٤","translation":"(১৪)","audioUrl":null,"charTypeName":"end"}]},{"number":15,"arabic":"وَإِن جَٰهَدَاكَ عَلَىٰٓ أَن تُشْرِكَ بِى مَا لَيْسَ لَكَ بِهِۦ عِلْمٌۭ فَلَا تُطِعْهُمَا ۖ وَصَاحِبْهُمَا فِى ٱلدُّنْيَا مَعْرُوفًۭا ۖ وَٱتَّبِعْ سَبِيلَ مَنْ أَنَابَ إِلَىَّ ۚ ثُمَّ إِلَىَّ مَرْجِعُكُمْ فَأُنَبِّئُكُم بِمَا كُنتُمْ تَعْمَلُونَ","translation":"“‘[Revere thy parents;] yet should they endeavour to make thee ascribe divinity, side by side with Me, to something which thy mind cannot accept [as divine], obey them not; but [even then] bear them company in this world’s life with kindness, and follow the path of those who turn towards Me. In the end, unto Me you all must return; and thereupon I shall make you [truly] understand all that you were doing [in life].’","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3484.mp3","surahId":31,"words":[{"id":17765,"position":1,"arabic":"وَإِن","translation":"এবং যদি","audioUrl":"wbw/031_015_001.mp3","charTypeName":"word"},{"id":17766,"position":2,"arabic":"جَـٰهَدَاكَ","translation":"তারা দু'জনে তোমাকে চাপ দেয়","audioUrl":"wbw/031_015_002.mp3","charTypeName":"word"},{"id":17767,"position":3,"arabic":"عَلَىٰٓ","translation":"(এর)উপর","audioUrl":"wbw/031_015_003.mp3","charTypeName":"word"},{"id":17768,"position":4,"arabic":"أَن","translation":"যে","audioUrl":"wbw/031_015_004.mp3","charTypeName":"word"},{"id":17769,"position":5,"arabic":"تُشْرِكَ","translation":"তুমি শিরক করো","audioUrl":"wbw/031_015_005.mp3","charTypeName":"word"},{"id":17770,"position":6,"arabic":"بِى","translation":"সাথে আমার","audioUrl":"wbw/031_015_006.mp3","charTypeName":"word"},{"id":17771,"position":7,"arabic":"مَا","translation":"যা","audioUr