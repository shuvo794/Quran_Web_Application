.mp3","charTypeName":"word"},{"id":54686,"position":4,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/030_060_004.mp3","charTypeName":"word"},{"id":54687,"position":5,"arabic":"حَقٌّۭ ۖ","translation":"সত্য","audioUrl":"wbw/030_060_005.mp3","charTypeName":"word"},{"id":54689,"position":6,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/030_060_007.mp3","charTypeName":"word"},{"id":54690,"position":7,"arabic":"يَسْتَخِفَّنَّكَ","translation":"তোমাকে হালকা পায় (বিচলিত করে)","audioUrl":"wbw/030_060_008.mp3","charTypeName":"word"},{"id":54691,"position":8,"arabic":"ٱلَّذِينَ","translation":"(তারা)যারা","audioUrl":"wbw/030_060_009.mp3","charTypeName":"word"},{"id":54692,"position":9,"arabic":"لَا","translation":"না","audioUrl":"wbw/030_060_010.mp3","charTypeName":"word"},{"id":54693,"position":10,"arabic":"يُوقِنُونَ","translation":"দৃঢ় বিশ্বাস করে","audioUrl":"wbw/030_060_011.mp3","charTypeName":"word"},{"id":54694,"position":11,"arabic":"٦٠","translation":"(৬০)","audioUrl":null,"charTypeName":"end"}]}]}