{"id":410,"ayahs":[{"number":51,"arabic":"وَلَئِنْ أَرْسَلْنَا رِيحًۭا فَرَأَوْهُ مُصْفَرًّۭا لَّظَلُّوا۟ مِنۢ بَعْدِهِۦ يَكْفُرُونَ","translation":"But thus it is: if We send a wind [that scorches their land], and they see it turn yellow, they begin, after that [erstwhile joy], to deny the truth [of Our almightiness and grace]!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3460.mp3","surahId":30,"words":[{"id":49460,"position":1,"arabic":"وَلَئِنْ","translation":"এবং অবশ্যই যদি","audioUrl":"wbw/030_051_001.mp3","charTypeName":"word"},{"id":49461,"position":2,"arabic":"أَرْسَلْنَا","translation":"আমরা পাঠাই","audioUrl":"wbw/030_051_002.mp3","charTypeName":"word"},{"id":49462,"position":3,"arabic":"رِيحًۭا","translation":"(এমন)বাতাস","audioUrl":"wbw/030_051_003.mp3","charTypeName":"word"},{"id":49463,"position":4,"arabic":"فَرَأَوْهُ","translation":"ফলে তারা দেখে তা","audioUrl":"wbw/030_051_004.mp3","charTypeName":"word"},{"id":49464,"position":5,"arabic":"مُصْفَرًّۭا","translation":"হলুদ রঙ","audioUrl":"wbw/030_051_005.mp3","charTypeName":"word"},{"id":49465,"position":6,"arabic":"لَّظَلُّوا۟","translation":"অবশ্যই লেগে থাকে তবুও","audioUrl":"wbw/030_051_006.mp3","charTypeName":"word"},{"id":49466,"position":7,"arabic":"مِنۢ","translation":"থেকে","audioUrl":"wbw/030_051_007.mp3","charTypeName":"word"},{"id":49467,"position":8,"arabic":"بَعْدِهِۦ","translation":"পর তার","audioUrl":"wbw/030_051_008.mp3","charTypeName":"word"},{"id":49468,"position":9,"arabic":"يَكْفُرُونَ","translation":"অকৃতজ্ঞতা করতে","audioUrl":"wbw/030_051_009.mp3","charTypeName":"word"},{"id":49469,"position":10,"arabic":"٥١","translation":"(৫১)","audioUrl":null,"charTypeName":"end"}]},{"number":52,"arabic":"فَإِنَّكَ لَا تُسْمِعُ ٱلْمَوْتَىٰ وَلَا تُسْمِعُ ٱلصُّمَّ ٱلدُّعَآءَ إِذَا وَلَّوْا۟ مُدْبِرِينَ","translation":"And, verily, thou canst not make the dead hear: and [so, too,] thou canst not make the deaf [of heart] hear this call when they turn their backs [on thee] and go away,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3461.mp3","surahId":30,"words":[{"id":50171,"position":1,"arabic":"فَإِنَّكَ","translation":"তাই নিশ্চয়ই তুমি","audioUrl":"wbw/030_052_001.mp3","charTypeName":"word"},{"id":50172,"position":2,"arabic":"لَا","translation":"না","audioUrl":"wbw/030_052_002.mp3","charTypeName":"word"},{"id":50173,"position":3,"arabic":"تُسْمِعُ","translation":"শুনাতে পারো","audioUrl":"wbw/030_052_003.mp3","charTypeName":"word"},{"id":50174,"position":4,"arabic":"ٱلْمَوْتَىٰ","translation":"মৃতদেরকে","audioUrl":"wbw/030_052_004.mp3","charTypeName":"word"},{"id":50175,"position":5,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/030_052_005.mp3","charTypeName":"word"},{"id":50176,"position":6,"arabic":"تُسْمِعُ","translation":"শুনাতে পারো","audioUrl":"wbw/030_052_006.mp3","charTypeName":"word"},{"id":50177,"position":7,"arabic":"ٱلصُّمَّ","translation":"বধিরকেও","audioUrl":"wbw/030_052_007.mp3","charTypeName":"word"},{"id":50178,"position":8,"arabic":"ٱلدُّعَآءَ","translation":"আহবান","audioUrl":"wbw/030_052_008.mp3","charTypeName":"word"},{"id":50179,"position":9,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/030_052_009.mp3","charTypeName":"word"},{"id":50180,"position":10,"arabic":"وَلَّوْا۟","translation":"তারা ফিরায়","audioUrl":"wbw/030_052_010.mp3","charTypeName":"word"},{"id":50181,"position":11,"arabic":"مُدْبِرِينَ","translation":"পিঠসমূহ","audioUrl":"wbw/030_052_011.mp3","charTypeName":"word"},{"id":50182,"position":12,"arabic":"٥٢","translation":"(৫২)","audioUrl":null,"charTypeName":"end"}]},{"number":53,"arabic":"وَمَآ أَنتَ بِهَٰدِ ٱلْعُمْىِ عَن ضَلَٰلَتِهِمْ ۖ إِن تُسْمِعُ إِلَّا مَن يُؤْمِنُ بِـَٔايَٰتِنَا فَهُم مُّسْلِمُونَ","translation":"just as thou canst not lead the blind [of heart] out of their error: none canst thou make hear [thy call] save such as [are willing to] believe in Our messages, and thus surrender them­selves unto Us.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3462.mp3","surahId":30,"words":[{"id":50749,"position":1,"arabic":"وَمَآ","translation":"এবং না","audioUrl":"wbw/030_053_001.mp3","charTypeName":"word"},{"id":50750,"position":2,"arabic":"أَنتَ","translation":"তুমি","audioUrl":"wbw/030_053_002.mp3","charTypeName":"word"},{"id":50751,"position":3,"arabic":"بِهَـٰدِ","translation":"পথপ্রদর্শক","audioUrl":"wbw/030_053_003.mp3","charTypeName":"word"},{"id":50752,"position":4,"arabic":"ٱلْعُمْىِ","translation":"অন্ধলোকদের","audioUrl":"wbw/030_053_004.mp3","charTypeName":"word"},{"id":50753,"position":5,"arabic":"عَن","translation":"হ'তে","audioUrl":"wbw/030_053_005.mp3","charTypeName":"word"},{"id":50754,"position":6,"arabic":"ضَلَـٰلَتِهِمْ ۖ","translation":"পথভ্রষ্টতা তাদের","audioUrl":"wbw/030_053_006.mp3","charTypeName":"word"},{"id":50756,"position":7,"arabic":"إِن","translation":"না","audioUrl":"wbw/030_053_008.mp3","charTypeName":"word"},{"id":50757,"position":8,"arabic":"تُسْمِعُ","translation":"তুমি শুনাতে পারো","audioUrl":"wbw/030_053_009.mp3","charTypeName":"word"},{"id":50758,"position":9,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/030_053_010.mp3","charTypeName":"word"},{"id":50759,"position":10,"arabic":"مَن","translation":"(তাকে) যে","audioUrl":"wbw/030_053_011.mp3","charTypeName":"word"},{"id":50760,"position":11,"arabic":"يُؤْمِنُ","translation":"ঈমান আনে","audioUrl":"wbw/030_053_012.mp3","charTypeName":"word"},{"id":50761,"position":12,"arabic":"بِـَٔايَـٰتِنَا","translation":"প্রতি আমাদের নিদর্শনসমূহের","audioUrl":"wbw/030_053_013.mp3","charTypeName":"word"},{"id":50762,"position":13,"arabic":"فَهُم","translation":"কারণ তারা","audioUrl":"wbw/030_053_014.mp3","charTypeName":"word"},{"id":50763,"position":14,"arabic":"مُّسْلِمُونَ","translation":"আত্নসমর্পনকারী (মুসলমান)","audioUrl":"wbw/030_053_015.mp3","charTypeName":"word"},{"id":50764,"position":15,"arabic":"٥٣","translation":"(৫৩)","audioUrl":null,"charTypeName":"end"}]},{"number":54,"arabic":"۞ ٱللَّهُ ٱلَّذِى خَلَقَكُم مِّن ضَعْفٍۢ ثُمَّ جَعَلَ مِنۢ بَعْدِ ضَعْفٍۢ قُوَّةًۭ ثُمَّ جَعَلَ مِنۢ بَعْدِ قُوَّةٍۢ ضَعْفًۭا وَشَيْبَةًۭ ۚ يَخْلُقُ مَا يَشَآءُ ۖ وَهُوَ ٱلْعَلِيمُ ٱلْقَدِيرُ","translation":"IT IS GOD who creates you [all in a states of weak­ness, and then, after weakness, ordains strength [for you], and then, after [a period of] strength, ordains [old-age] weakness and grey hair. He creates what He wills; and He alone is all-knowing, infinite in His power.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3463.mp3","surahId":30,"words":[{"id":51126,"position":1,"arabic":"۞ ٱللَّهُ","translation":"( তিনিই ) আল্লাহ","audioUrl":"wbw/030_054_002.mp3","charTypeName":"word"},{"id":51127,"position":2,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/030_054_003.mp3","charTypeName":"word"},{"id":51128,"position":3,"arabic":"خَلَقَكُم","translation":"সৃষ্টি করেছেন তোমাদের","audioUrl":"wbw/030_054_004.mp3","charTypeName":"word"},{"id":51129,"position":4,"arabic":"مِّن","translation":"হ'তে","audioUrl":"wbw/030_054_005.mp3","charTypeName":"word"},{"id":51130,"position":5,"arabic":"ضَعْفٍۢ","translation":"দুর্বল অবস্থা","audioUrl":"wbw/030_054_006.mp3","charTypeName":"word"},{"id":51131,"position":6,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/030_054_007.mp3","charTypeName":"word"},{"id":51132,"position":7,"arabic":"جَعَلَ","translation":"দান করেছেন","audioUrl":"wbw/030_054_008.mp3","charTypeName":"word"},{"id":51133,"position":8,"arabic":"مِنۢ","translation":"থেকে","audioUrl":"wbw/030_054_009.mp3","charTypeName":"word"},{"id":51134,"position":9,"arabic":"بَعْدِ","translation":"পর","audioUrl":"wbw/030_054_010.mp3","charTypeName":"word"},{"id":51135,"position":10,"arabic":"ضَعْفٍۢ","translation":"দুর্বল অবস্থার","audioUrl":"wbw/030_054_011.mp3","charTypeName":"word"},{"id":51136,"position":11,"arabic":"قُوَّةًۭ","translation":"শক্তি","audioUrl":"wbw/030_054_012.mp3","charTypeName":"word"},{"id":51137,"position":12,"arabic":"ثُمَّ","translation":"এরপর","audi