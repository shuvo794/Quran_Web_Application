,{"id":35117,"position":5,"arabic":"لَّدَيْنَا","translation":"আমাদের কাছে","audioUrl":"wbw/036_032_005.mp3","charTypeName":"word"},{"id":35118,"position":6,"arabic":"مُحْضَرُونَ","translation":"উপস্থিত করা হবে","audioUrl":"wbw/036_032_006.mp3","charTypeName":"word"},{"id":35119,"position":7,"arabic":"٣٢","translation":"(৩২)","audioUrl":null,"charTypeName":"end"}]},{"number":33,"arabic":"وَءَايَةٌۭ لَّهُمُ ٱلْأَرْضُ ٱلْمَيْتَةُ أَحْيَيْنَٰهَا وَأَخْرَجْنَا مِنْهَا حَبًّۭا فَمِنْهُ يَأْكُلُونَ","translation":"And [yet,] they have a sign [of Our power to create and to resurrect] in the lifeless earth which We make alive, and out of which We bring forth grain, whereof they may eat;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3738.mp3","surahId":36,"words":[{"id":35972,"position":1,"arabic":"وَءَايَةٌۭ","translation":"এবং (অন্যতম) নিদর্শন","audioUrl":"wbw/036_033_001.mp3","charTypeName":"word"},{"id":35973,"position":2,"arabic":"لَّهُمُ","translation":"তাদের জন্য (রয়েছে)","audioUrl":"wbw/036_033_002.mp3","charTypeName":"word"},{"id":35974,"position":3,"arabic":"ٱلْأَرْضُ","translation":"মাটি","audioUrl":"wbw/036_033_003.mp3","charTypeName":"word"},{"id":35975,"position":4,"arabic":"ٱلْمَيْتَةُ","translation":"নিষ্প্রাণ","audioUrl":"wbw/036_033_004.mp3","charTypeName":"word"},{"id":35976,"position":5,"arabic":"أَحْيَيْنَـٰهَا","translation":"তাকে আমরা জীবিত করি","audioUrl":"wbw/036_033_005.mp3","charTypeName":"word"},{"id":35977,"position":6,"arabic":"وَأَخْرَجْنَا","translation":"ও আমরা উৎপন্ন করি","audioUrl":"wbw/036_033_006.mp3","charTypeName":"word"},{"id":35978,"position":7,"arabic":"مِنْهَا","translation":"তা থেকে","audioUrl":"wbw/036_033_007.mp3","charTypeName":"word"},{"id":35979,"position":8,"arabic":"حَبًّۭا","translation":"শস্যদানা","audioUrl":"wbw/036_033_008.mp3","charTypeName":"word"},{"id":35980,"position":9,"arabic":"فَمِنْهُ","translation":"অতঃপর তা থেকে","audioUrl":"wbw/036_033_009.mp3","charTypeName":"word"},{"id":35981,"position":10,"arabic":"يَأْكُلُونَ","translation":"তারা খায়","audioUrl":"wbw/036_033_010.mp3","charTypeName":"word"},{"id":35982,"position":11,"arabic":"٣٣","translation":"(৩৩)","audioUrl":null,"charTypeName":"end"}]},{"number":34,"arabic":"وَجَعَلْنَا فِيهَا جَنَّٰتٍۢ مِّن نَّخِيلٍۢ وَأَعْنَٰبٍۢ وَفَجَّرْنَا فِيهَا مِنَ ٱلْعُيُونِ","translation":"and [how] We make gardens of date-palms and vines [grow] thereon, and cause springs to gush [forth] within it,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3739.mp3","surahId":36,"words":[{"id":36725,"position":1,"arabic":"وَجَعَلْنَا","translation":"এবং আমরা বানিয়েছি","audioUrl":"wbw/036_034_001.mp3","charTypeName":"word"},{"id":36726,"position":2,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/036_034_002.mp3","charTypeName":"word"},{"id":36727,"position":3,"arabic":"جَنَّـٰتٍۢ","translation":"বাগানসমূহ","audioUrl":"wbw/036_034_003.mp3","charTypeName":"word"},{"id":36728,"position":4,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/036_034_004.mp3","charTypeName":"word"},{"id":36729,"position":5,"arabic":"نَّخِيلٍۢ","translation":"খেজুরের","audioUrl":"wbw/036_034_005.mp3","charTypeName":"word"},{"id":36730,"position":6,"arabic":"وَأَعْنَـٰبٍۢ","translation":"ও আঙ্গুরের","audioUrl":"wbw/036_034_006.mp3","charTypeName":"word"},{"id":36731,"position":7,"arabic":"وَفَجَّرْنَا","translation":"এবং আমরা বইয়ে দিয়েছি","audioUrl":"wbw/036_034_007.mp3","charTypeName":"word"},{"id":36732,"position":8,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/036_034_008.mp3","charTypeName":"word"},{"id":36733,"position":9,"arabic":"مِنَ","translation":"মধ্য হতে","audioUrl":"wbw/036_034_009.mp3","charTypeName":"word"},{"id":36734,"position":10,"arabic":"ٱلْعُيُونِ","translation":"ঝর্ণা সমূহ","audioUrl":"wbw/036_034_010.mp3","charTypeName":"word"},{"id":36735,"position":11,"arabic":"٣٤","translation":"(৩৪)","audioUrl":null,"charTypeName":"end"}]},{"number":35,"arabic":"لِيَأْكُلُوا۟ مِن ثَمَرِهِۦ وَمَا عَمِلَتْهُ أَيْدِيهِمْ ۖ أَفَلَا يَشْكُرُونَ","translation":"so that they may eat of the fruit thereof, though it was not their hands that made it. Will they not, then, be grateful?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3740.mp3","surahId":36,"words":[{"id":37639,"position":1,"arabic":"لِيَأْكُلُوا۟","translation":"তারা খেতে পারে যেন","audioUrl":"wbw/036_035_001.mp3","charTypeName":"word"},{"id":37640,"position":2,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/036_035_002.mp3","charTypeName":"word"},{"id":37641,"position":3,"arabic":"ثَمَرِهِۦ","translation":"তার ফলমূল","audioUrl":"wbw/036_035_003.mp3","charTypeName":"word"},{"id":37642,"position":4,"arabic":"وَمَا","translation":"অথচ নি","audioUrl":"wbw/036_035_004.mp3","charTypeName":"word"},{"id":37643,"position":5,"arabic":"عَمِلَتْهُ","translation":"তা সৃষ্টি করেছে","audioUrl":"wbw/036_035_005.mp3","charTypeName":"word"},{"id":37644,"position":6,"arabic":"أَيْدِيهِمْ ۖ","translation":"তাদের হাতগুলো","audioUrl":"wbw/036_035_006.mp3","charTypeName":"word"},{"id":37646,"position":7,"arabic":"أَفَلَا","translation":"তবুও কি না","audioUrl":"wbw/036_035_008.mp3","charTypeName":"word"},{"id":37647,"position":8,"arabic":"يَشْكُرُونَ","translation":"তারা কৃতজ্ঞতা প্রকাশ করে","audioUrl":"wbw/036_035_009.mp3","charTypeName":"word"},{"id":37648,"position":9,"arabic":"٣٥","translation":"(৩৫)","audioUrl":null,"charTypeName":"end"}]},{"number":36,"arabic":"سُبْحَٰنَ ٱلَّذِى خَلَقَ ٱلْأَزْوَٰجَ كُلَّهَا مِمَّا تُنۢبِتُ ٱلْأَرْضُ وَمِنْ أَنفُسِهِمْ وَمِمَّا لَا يَعْلَمُونَ","translation":"Limitless in His glory is He who has created opposites in whatever the earth produces, and in men’s own selves, and in that of which [as yet] they have no knowledge.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3741.mp3","surahId":36,"words":[{"id":38514,"position":1,"arabic":"سُبْحَـٰنَ","translation":"(আল্লাহ) মহান পবিত্র","audioUrl":"wbw/036_036_001.mp3","charTypeName":"word"},{"id":38515,"position":2,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/036_036_002.mp3","charTypeName":"word"},{"id":38516,"position":3,"arabic":"خَلَقَ","translation":"সৃষ্টি করেছেন","audioUrl":"wbw/036_036_003.mp3","charTypeName":"word"},{"id":38517,"position":4,"arabic":"ٱلْأَزْوَٰجَ","translation":"জোড়া জোড়া","audioUrl":"wbw/036_036_004.mp3","charTypeName":"word"},{"id":38518,"position":5,"arabic":"كُلَّهَا","translation":"সব কিছুকেই","audioUrl":"wbw/036_036_005.mp3","charTypeName":"word"},{"id":38519,"position":6,"arabic":"مِمَّا","translation":"তা হ'তে যা","audioUrl":"wbw/036_036_006.mp3","charTypeName":"word"},{"id":38520,"position":7,"arabic":"تُنۢبِتُ","translation":"উৎপন্ন করে","audioUrl":"wbw/036_036_007.mp3","charTypeName":"word"},{"id":38521,"position":8,"arabic":"ٱلْأَرْضُ","translation":"ভূমি","audioUrl":"wbw/036_036_008.mp3","charTypeName":"word"},{"id":38522,"position":9,"arabic":"وَمِنْ","translation":"এবং মধ্য হ'তে","audioUrl":"wbw/036_036_009.mp3","charTypeName":"word"},{"id":38523,"position":10,"arabic":"أَنفُسِهِمْ","translation":"তাদের নিজেদের (মানব জাতিরও)","audioUrl":"wbw/036_036_010.mp3","charTypeName":"word"},{"id":38524,"position":11,"arabic":"وَمِمَّا","translation":"এবং তাহ'তেও যা","audioUrl":"wbw/036_036_011.mp3","charTypeName":"word"},{"id":38525,"position":12,"arabic":"لَا","translation":"না","audioUrl":"wbw/036_036_012.mp3","charTypeName":"word"},{"id":38526,"position":13,"arabic":"يَعْلَمُونَ","translation":"(এখনও) তারা জানে","audioUrl":"wbw/036_036_013.mp3","charTypeName":"word"},{"id":38527,"position":14,"arabic":"٣٦","translation":"(৩৬)","audioUrl":null,"charTypeName":"end"}]},{"number":37,"arabic":"وَءَايَةٌۭ لَّهُمُ ٱلَّيْلُ نَسْلَخُ مِنْهُ ٱلنَّهَارَ فَإِذَا هُم مُّظْلِمُونَ","translation":"And [of Our sway over all that exists] they have a sign in the night: We withdraw from it the [light of] day - and lo! they are in darkness.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3742.mp3","surahId":36,"words":[{"id":39386,"position":1,"arabic":"وَءَايَةٌۭ","translation":"এবং (আরো) একটি নিদর্শন","audioUrl":"wbw/036_037_001.mp3","charTypeName":"word"},{"id":39387,"position":2,"arabic":"لَّهُمُ","translation":"তাদের জন্যে","audioUrl":"wbw/036_037_002.mp3","charTypeName":"word"},{"id":39388,"position":3,"arabic":"ٱلَّيْلُ","translation":"রাত","audioUrl":"wbw/036_037_003.mp3","charTypeName":"word"},{"id":39389,"position":4,"arabic":"نَسْلَخُ","translation":"সরিয়ে দিই আমরা","audioUrl":"wbw/036_037_004.mp3","charTypeName":"word"},{"id":39390,"position":5,"arabic":"مِنْهُ","translation":"তা থেকে","audioUrl":"wbw/036_037_005.mp3","charTypeName":"word"},{"id":39391,"position":6,"arabic":"ٱلنَّهَارَ","translation":"দিনকে","audioUrl":"wbw/036_037_006.mp3","charTypeName":"word"},{"id":39392,"position":7,"arabic":"فَإِذَا","translation":"অতঃপর তখন","audioUrl":"wbw/036_037_007.mp3","charTypeName":"word"},{"id":39393,"position":8,"arabic":"هُم","translation":"তারা","audioUrl":"wbw/036_037_008.mp3","charTypeName":"word"},{"id":39394,"position":9,"arabic":"مُّظْلِمُونَ","translation":"অন্ধকারাচ্ছন্ন (হয়ে যায়)","audioUrl":"wbw/036_037_009.mp3","charTypeName":"word"},{"id":39395,"position":10,"arabic":"٣٧","translation":"(৩৭)","audioUrl":null,"charTypeName":"end"}]},{"number":38,"arabic":"وَٱلشَّمْسُ تَجْرِى لِمُسْتَقَرٍّۢ لَّهَا ۚ ذَٰلِكَ تَقْدِيرُ ٱلْعَزِيزِ ٱلْعَلِيمِ","translation":"And [they have a sign in] the sun: it runs in an orbit of its own [and] that is laid down by the will of the Almighty, the All-Knowing;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3743.mp3","surahId":36,"words":[{"id":40071,"position":1,"arabic":"وَٱلشَّمْسُ","translation":"এবং সূর্য","audioUrl":"wbw/036_038_001.mp3","charTypeName":"word"},{"id":40072,"position":2,"arabic":"تَجْرِى","translation":"আবর্তন করে","audioUrl":"wbw/036_038_002.mp3","charTypeName":"word"},{"id":40073,"position":3,"arabic":"لِمُسْتَقَرٍّۢ","translation":"নির্দিষ্ট গন্ডির মধ্যে","audioUrl":"wbw/036_038_003.mp3","char