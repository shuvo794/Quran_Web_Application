{"id":442,"ayahs":[{"number":28,"arabic":"۞ وَمَآ أَنزَلْنَا عَلَىٰ قَوْمِهِۦ مِنۢ بَعْدِهِۦ مِن جُندٍۢ مِّنَ ٱلسَّمَآءِ وَمَا كُنَّا مُنزِلِينَ","translation":"And after that, no host out of heaven did We send down against his people, nor did We need to send down any:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3733.mp3","surahId":36,"words":[{"id":31381,"position":1,"arabic":"۞ وَمَآ","translation":"এবং না","audioUrl":"wbw/036_028_002.mp3","charTypeName":"word"},{"id":31382,"position":2,"arabic":"أَنزَلْنَا","translation":"আমরা অবতীর্ণ করেছি","audioUrl":"wbw/036_028_003.mp3","charTypeName":"word"},{"id":31383,"position":3,"arabic":"عَلَىٰ","translation":"বিরুদ্ধে","audioUrl":"wbw/036_028_004.mp3","charTypeName":"word"},{"id":31384,"position":4,"arabic":"قَوْمِهِۦ","translation":"তার জাতির","audioUrl":"wbw/036_028_005.mp3","charTypeName":"word"},{"id":31385,"position":5,"arabic":"مِنۢ","translation":"পরে","audioUrl":"wbw/036_028_006.mp3","charTypeName":"word"},{"id":31386,"position":6,"arabic":"بَعْدِهِۦ","translation":"তার","audioUrl":"wbw/036_028_007.mp3","charTypeName":"word"},{"id":31387,"position":7,"arabic":"مِن","translation":"কোনো","audioUrl":"wbw/036_028_008.mp3","charTypeName":"word"},{"id":31388,"position":8,"arabic":"جُندٍۢ","translation":"সৈন্য","audioUrl":"wbw/036_028_009.mp3","charTypeName":"word"},{"id":31389,"position":9,"arabic":"مِّنَ","translation":"থেকে","audioUrl":"wbw/036_028_010.mp3","charTypeName":"word"},{"id":31390,"position":10,"arabic":"ٱلسَّمَآءِ","translation":"আকাশ","audioUrl":"wbw/036_028_011.mp3","charTypeName":"word"},{"id":31391,"position":11,"arabic":"وَمَا","translation":"আর না","audioUrl":"wbw/036_028_012.mp3","charTypeName":"word"},{"id":31392,"position":12,"arabic":"كُنَّا","translation":"আমরা ছিলাম","audioUrl":"wbw/036_028_013.mp3","charTypeName":"word"},{"id":31393,"position":13,"arabic":"مُنزِلِينَ","translation":"অবতীর্ণকারী","audioUrl":"wbw/036_028_014.mp3","charTypeName":"word"},{"id":31394,"po