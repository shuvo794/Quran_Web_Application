{"id":171,"ayahs":[{"number":160,"arabic":"وَقَطَّعْنَٰهُمُ ٱثْنَتَىْ عَشْرَةَ أَسْبَاطًا أُمَمًۭا ۚ وَأَوْحَيْنَآ إِلَىٰ مُوسَىٰٓ إِذِ ٱسْتَسْقَىٰهُ قَوْمُهُۥٓ أَنِ ٱضْرِب بِّعَصَاكَ ٱلْحَجَرَ ۖ فَٱنۢبَجَسَتْ مِنْهُ ٱثْنَتَا عَشْرَةَ عَيْنًۭا ۖ قَدْ عَلِمَ كُلُّ أُنَاسٍۢ مَّشْرَبَهُمْ ۚ وَظَلَّلْنَا عَلَيْهِمُ ٱلْغَمَٰمَ وَأَنزَلْنَا عَلَيْهِمُ ٱلْمَنَّ وَٱلسَّلْوَىٰ ۖ كُلُوا۟ مِن طَيِّبَٰتِ مَا رَزَقْنَٰكُمْ ۚ وَمَا ظَلَمُونَا وَلَٰكِن كَانُوٓا۟ أَنفُسَهُمْ يَظْلِمُونَ","translation":"And We divided them into twelve tribes, [or] communities. And when his people asked Moses for water, We inspired him, \"Strike the rock with thy staff!\" -whereupon twelve springs gushed forth from it, so that all the people knew whence to drink., And We caused the clouds to comfort them with their shade, and We sent down unto them manna and quails, [saying:] \"Partake of the good things which We have provided for you as sustenance.\" And [by all their sinning] they did no harm unto Us-but [only] against their own selves did they sin.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1114.mp3","surahId":7,"words":[{"id":81798,"position":1,"arabic":"وَقَطَّعْنَـٰهُمُ","translation":"এবং আমরা বিভক্ত করেছিলাম তাদেরকে","audioUrl":"wbw/007_160_001.mp3","charTypeName":"word"},{"id":81799,"position":2,"arabic":"ٱثْنَتَىْ","translation":"বারো","audioUrl":"wbw/007_160_002.mp3","charTypeName":"word"},{"id":81800,"position":3,"arabic":"عَشْرَةَ","translation":"বারো","audioUrl":"wbw/007_160_003.mp3","charTypeName":"word"},{"id":81801,"position":4,"arabic":"أَسْبَاطًا","translation":"গোত্র","audioUrl":"wbw/007_160_004.mp3","charTypeName":"word"},{"id":81802,"position":5,"arabic":"أُمَمًۭا ۚ","translation":"দলে","audioUrl":"wbw/007_160_005.mp3","charTypeName":"word"},{"id":81804,"position":6,"arabic":"وَأَوْحَيْنَآ","translation":"এবং আমরা ওহী করলাম","audioUrl":"wbw/007_160_007.mp3","charTypeName":"word"},{"id":81805,"position":7,"arabic":"إِلَىٰ","translation":"প্রতি","audioUrl":"wbw/007_160_008.mp3","charTypeName":"word"},{"id":81806,"position":8,"arabic":"مُوسَىٰٓ","translation":"মূসার","audioUrl":"wbw/007_160_009.mp3","charTypeName":"word"},{"id":81807,"position":9,"arabic":"إِذِ","translation":"যখন","audioUrl":"wbw/007_160_010.mp3","charTypeName":"word"},{"id":81808,"position":10,"arabic":"ٱسْتَسْقَىٰهُ","translation":"তার কাছে পানি চাইলো","audioUrl":"wbw/007_160_011.mp3","charTypeName":"word"},{"id":81809,"position":11,"arabic":"قَوْمُهُۥٓ","translation":"তার জাতি","audioUrl":"wbw/007_160_012.mp3","charTypeName":"word"},{"id":81810,"position":12,"arabic":"أَنِ","translation":"যে","audioUrl":"wbw/007_160_013.mp3","charTypeName":"word"},{"id":81811,"position":13,"arabic":"ٱضْرِب","translation":"\"আঘাত করো","audioUrl":"wbw/007_160_014.mp3","charTypeName":"word"},{"id":81812,"position":14,"arabic":"بِّعَصَاكَ","translation":"তোমার লাঠি দিয়ে","audioUrl":"wbw/007_160_015.mp3","charTypeName":"word"},{"id":81813,"position":15,"arabic":"ٱلْحَجَرَ ۖ","translation":"পাথরকে\"","audioUrl":"wbw/007_160_016.mp3","charTypeName":"word"},{"id":81815,"position":16,"arabic":"فَٱنۢبَجَسَتْ","translation":"ফলে ফেটে বের হলো","audioUrl":"wbw/007_160_018.mp3","charTypeName":"word"},{"id":81816,"position":17,"arabic":"مِنْهُ","translation":"থেকে তা","audioUrl":"wbw/007_160_019.mp3","charTypeName":"word"},{"id":81817,"position":18,"arabic":"ٱثْنَتَا","translation":"বারোটি","audioUrl":"wbw/007_160_020.mp3","charTypeName":"word"},{"id":81818,"position":19,"arabic":"عَشْرَةَ","translation":"বারোটি","audioUrl":"wbw/007_160_021.mp3","charTypeName":"word"},{"id":81819,"position":20,"arabic":"عَيْنًۭا ۖ","translation":"ঝর্ণা","audioUrl":"wbw/007_160_022.mp3","charTypeName":"word"},{"id":81821,"position":21,"arabic":"قَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/007_160_024.mp3","charTypeName":"word"},{"id":81822,"position":22,"arabic":"عَلِمَ","translation":"চিনে নিলো","audioUrl":"wbw/007_160_025.mp3","charTypeName":"word"},{"id":81823,"position":23,"arabic":"كُلُّ","translation":"প্রত্যেক","audioUrl":"wbw/007_160_026.mp3","charTypeName":"word"},{"id":81824,"position":24,"arabic":"أُنَاسٍۢ","translation":"(গোত্রের) মানুষ","audioUrl":"wbw/007_160_027.mp3","charTypeName":"word"},{"id":81825,"position":25,"arabic":"مَّشْرَبَهُمْ ۚ","translation":"পানস্থান তাদের","audioUrl":"wbw/007_160_028.mp3","charTypeName":"word"},{"id":81827,"position":26,"arabic":"وَظَلَّلْنَا","translation":"এবং ছায়া করলাম আমরা","audioUrl":"wbw/007_160_030.mp3","charTypeName":"word"},{"id":81828,"position":27,"arabic":"عَلَيْهِمُ","translation":"উপর তাদের","audioUrl":"wbw/007_160_031.mp3","charTypeName":"word"},{"id":81829,"position":28,"arabic":"ٱلْغَمَـٰمَ","translation":"মেঘমালার","audioUrl":"wbw/007_160_032.mp3","charTypeName":"word"},{"id":81830,"position":29,"arabic":"وَأَنزَلْنَا","translation":"এবং অবতীর্ণ করলাম আমরা","audioUrl":"wbw/007_160_033.mp3","charTypeName":"word"},{"id":81831,"position":30,"arabic":"عَلَيْهِمُ","translation":"উপর তাদের","audioUrl":"wbw/007_160_034.mp3","charTypeName":"word"},{"id":81832,"position":31,"arabic":"ٱلْمَنَّ","translation":"মান্না'","audioUrl":"wbw/007_160_035.mp3","charTypeName":"word"},{"id":81833,"position":32,"arabic":"وَٱلسَّلْوَىٰ ۖ","translation":"ও \"সালওয়া\"","audioUrl":"wbw/007_160_036.mp3","charTypeName":"word"},{"id":81835,"position":33,"arabic":"كُلُوا۟","translation":"\"(এবং বললাম) তোমরা খাও","audioUrl":"wbw/007_160_038.mp3","charTypeName":"word"},{"id":81836,"position":34,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/007_160_039.mp3","charTypeName":"word"},{"id":81837,"position":35,"arabic":"طَيِّبَـٰتِ","translation":"পবিত্র বস্তুগুলো","audioUrl":"wbw/007_160_040.mp3","charTypeName":"word"},{"id":81838,"position":36,"arabic":"مَا","translation":"যা","audioUrl":"wbw/007_160_041.mp3","charTypeName":"word"},{"id":81839,"position":37,"arabic":"رَزَقْنَـٰكُمْ ۚ","translation":"আমরা জীবিকা দিয়েছি তোমাদের\"","audioUrl":"wbw/007_160_042.mp3","charTypeName":"word"},{"id":81841,"position":38,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/007_160_044.mp3","charTypeName":"word"},{"id":81842,"position":39,"arabic":"ظَلَمُونَا","translation":"তারা আমার উপর অন্যায় করেছে","audioUrl":"wbw/007_160_045.mp3","charTypeName":"word"},{"id":81843,"position":40,"arabic":"وَلَـٰكِن","translation":"কিন্তু","audioUrl":"wbw/007_160_046.mp3","charTypeName":"word"},{"id":81844,"position":41,"arabic":"كَانُوٓا۟","translation":"তারা ছিলো","audioUrl":"wbw/007_160_047.mp3","charTypeName":"word"},{"id":81845,"position":42,"arabic":"أَنفُسَهُمْ","translation":"নিজেদের উপর তাদের","audioUrl":"wbw/007_160_048.mp3","charTypeName":"word"},{"id":81846,"position":43,"arabic":"يَظْلِمُونَ","translation":"অন্যায় করতো","audioUrl":"wbw/007_160_049.mp3","charTypeName":"word"},{"id":81847,"position":44,"arabic":"١٦٠","translation":"(১৬০)","audioUrl":null,"charTypeName":"end"}]},{"number":161,"arabic":"وَإِذْ قِيلَ لَهُمُ ٱسْكُنُوا۟ هَٰذِهِ ٱلْقَرْيَةَ وَكُلُوا۟ مِنْهَا حَيْثُ شِئْتُمْ وَقُولُوا۟ حِطَّةٌۭ وَٱدْخُلُوا۟ ٱلْبَابَ سُجَّدًۭا نَّغْفِرْ لَكُمْ خَطِيٓـَٰٔتِكُمْ ۚ سَنَزِيدُ ٱلْمُحْسِنِينَ","translation":"And [remember] when you were told: \"Dwell in this land and eat of its food as you may desire; but say, `Remove Thou from us the burden of our sins,' and enter the gate humbly - [whereupon] We shall forgive you your sins [and] shall amply reward the doers of good.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1115.mp3","surahId":7,"words":[{"id":81952,"position":1,"arabic":"وَإِذْ","translation":"এবং যখন","audioUrl":"wbw/007_161_001.mp3","charTypeName":"word"},{"id":81953,"position":2,"arabic":"قِيلَ","translation":"বলা হয়েছিলো","audioUrl":"wbw/007_161_002.mp3","charTypeName":"word"},{"id":81954,"position":3,"arabic":"لَهُمُ","translation":"উদ্দেশ্যে তাদের","audioUrl":"wbw/007_161_003.mp3","charTypeName":"word"},{"id":81955,"position":4,"arabic":"ٱسْكُنُوا۟","translation":"\"তোমরা বাস করো","audioUrl":"wbw/007_161_004.mp3","charTypeName":"word"},{"id":81956,"position":5,"arabic":"هَـٰذِهِ","translation":"এই","audioUrl":"wbw/007_161_005.mp3","charTypeName":"word"},{"id":81957,"position":6,"arabic":"ٱلْقَرْيَةَ","translation":"জনপদে","audioUrl":"wbw/007_161_006.mp3","charTypeName":"word"},{"id":81958,"position":7,"arabic":"وَكُلُوا۟","translation":"এবং তোমরা খাও","audioUrl":"wbw/007_161_007.mp3","charTypeName":"word"},{"id":81959,"position":8,"arabic":"مِنْهَا","translation":"হতে তা","audioUrl":"wbw/007_161_008.mp3","charTypeName":"word"},{"id":81960,"position":9,"arabic":"حَيْثُ","translation":"যেখান (থেকে)","audioUrl":"wbw/007_161_009.mp3","charTypeName":"word"},{"id":81961,"position":10,"arabic":"شِئْتُمْ","translation":"তোমরা চাও","audioUrl":"wbw/007_161_010.mp3","charTypeName":"word"},{"id":81962,"position":11,"arabic":"وَقُولُوا۟","translation":"ও তোমরা বলো","audioUrl":"wbw/007_161_011.mp3","charTypeName":"word"},{"id":81963,"position":12,"arabic":"حِطَّةٌۭ","translation":"\"হিত্তাতুন (ক্ষমা চাই)\"","audioUrl":"wbw/007_161_012.mp3","charTypeName":"word"},{"id":81964,"position":13,"arabic":"وَٱدْخُلُوا۟","translation":"এবং তোমরা প্রবেশ করো","audioUrl":"wbw/007_161_013.mp3","charTypeName":"word"},{"id":81965,"position":14,"arabic":"ٱلْبَابَ","translation":"দরজায়","audioUrl":"wbw/007_161_014.mp3","charTypeName":"word"},{"id":81966,"position":15,"arabic":"سُجَّدًۭا","translation":"মাথা নত করে","audioUrl":"wbw/007_161_015.mp3","charTypeName":"word"},{"id":81967,"position":16,"arabic":"نَّغْفِرْ","translation":"আমরা ক্ষমা করবো","audioUrl":"wbw/007_161_016.mp3","charTypeName":"word"},{"id":81968,"position":17,"arabic":"لَكُمْ","translation":"জন্যে তোমাদের","audioUrl":"wbw/007_161_017.mp3","charTypeName":"word"},{"id":81969,"position":18,"arabic":"خَطِيٓـَٔـٰتِكُمْ ۚ","translation":"পাপসমূহকে তোমাদের","audioUrl":"wbw/007_161_018.mp3","charTypeName":"word"},{"id":81971,"position":19,"arabic":"سَنَزِيدُ","translation":"শীঘ্রই আমরা বৃদ্ধি করবো (অনুগ্রহ)","audioUrl":"wbw/007_161_020.mp3","charTypeName":"word"},{"id":81972,"posit