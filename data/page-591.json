{"id":591,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلسَّمَآءِ وَٱلطَّارِقِ","translation":"CONSIDER the heavens and that which comes in the night!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5932.mp3","surahId":86,"words":[{"id":716,"position":1,"arabic":"وَٱلسَّمَآءِ","translation":"শপথ আকাশের","audioUrl":"wbw/086_001_001.mp3","charTypeName":"word"},{"id":717,"position":2,"arabic":"وَٱلطَّارِقِ","translation":"এবং রাত্রে আত্মপ্রকাশকারী (নক্ষত্রের)","audioUrl":"wbw/086_001_002.mp3","charTypeName":"word"},{"id":718,"position":3,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"وَمَآ أَدْرَىٰكَ مَا ٱلطَّارِقُ","translation":"And what could make thee conceive what it is that comes in the night?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5933.mp3","surahId":86,"words":[{"id":1764,"position":1,"arabic":"وَمَآ","translation":"এবং কিসে","audioUrl":"wbw/086_002_001.mp3","charTypeName":"word"},{"id":1765,"position":2,"arabic":"أَدْرَىٰكَ","translation":"তোমাকে জানাবে","audioUrl":"wbw/086_002_002.mp3","charTypeName":"word"},{"id":1766,"position":3,"arabic":"مَا","translation":"কি সেই","audioUrl":"wbw/086_002_003.mp3","charTypeName":"word"},{"id":1767,"position":4,"arabic":"ٱلطَّارِقُ","translation":"রাতে আত্মপ্রকাশকারী","audioUrl":"wbw/086_002_004.mp3","charTypeName":"word"},{"id":1768,"position":5,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"ٱلنَّجْمُ ٱلثَّاقِبُ","translation":"It is the star that pierces through [life's] darkness:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5934.mp3","surahId":86,"words":[{"id":2882,"position":1,"arabic":"ٱلنَّجْمُ","translation":"নক্ষত্র","audioUrl":"wbw/086_003_001.mp3","charTypeName":"word"},{"id":2883,"position":2,"arabic":"ٱلثَّاقِبُ","translation":"উজ্জ্বল","audioUrl":"wbw/086_003_002.mp3","charTypeName":"word"},{"id":2884,"position":3,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"إِن كُلُّ نَفْسٍۢ لَّمَّا عَلَيْهَا حَافِظٌۭ","translation":"[for] no human being has ever been left unguarded.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5935.mp3","surahId":86,"words":[{"id":4239,"position":1,"arabic":"إِن","translation":"নেই","audioUrl":"wbw/086_004_001.mp3","charTypeName":"word"},{"id":4240,"position":2,"arabic":"كُلُّ","translation":"কোন","audioUrl":"wbw/086_004_002.mp3","charTypeName":"word"},{"id":4241,"position":3,"arabic":"نَفْسٍۢ","translation":"ব্যক্তি","audioUrl":"wbw/086_004_003.mp3","charTypeName":"word"},{"id":4242,"position":4,"arabic":"لَّمَّا","translation":"এ ছাড়া যে","audioUrl":"wbw/086_004_004.mp3","charTypeName":"word"},{"id":4243,"position":5,"arabic":"عَلَيْهَا","translation":"তার উপর","audioUrl":"wbw/086_004_005.mp3","charTypeName":"word"},{"id":4244,"position":6,"arabic":"حَافِظٌۭ","translation":"তত্ত্বাবধায়ক","audioUrl":"wbw/086_004_006.mp3","charTypeName":"word"},{"id":4245,"position":7,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"فَلْيَنظُرِ ٱلْإِنسَٰنُ مِمَّ خُلِقَ","translation":"LET MAN, then, observe out of what he has been created:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5936.mp3","surahId":86,"words":[{"id":5502,"position":1,"arabic":"فَلْيَنظُرِ","translation":"অতএব লক্ষ করা উচিৎ","audioUrl":"wbw/086_005_001.mp3","charTypeName":"word"},{"id":5503,"position":2,"arabic":"ٱلْإِنسَـٰنُ","translation":"মানুষের","audioUrl":"wbw/086_005_002.mp3","charTypeName":"word"},{"id":5504,"position":3,"arabic":"مِمَّ","translation":"কি থেকে","audioUrl":"wbw/086_005_003.mp3","charTypeName":"word"},{"id":5505,"position":4,"arabic":"خُلِقَ","translation":"সৃষ্টি করা হয়েছে (তাকে)","audioUrl":"wbw/086_005_004.mp3","charTypeName":"word"},{"id":5506,"position":5,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"خُلِقَ مِن مَّآءٍۢ دَافِقٍۢ","translation":"he has been created out of a seminal fluid","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5937.mp3","surahId":86,"words":[{"id":6738,"position":1,"arabic":"خُلِقَ","translation":"সৃষ্টি করা হয়েছে","audioUrl":"wbw/086_006_001.mp3","charTypeName":"word"},{"id":6739,"position":2,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/086_006_002.mp3","charTypeName":"word"},{"id":6740,"position":3,"arabic":"مَّآءٍۢ","translation":"পানি","audioUrl":"wbw/086_006_003.mp3","charTypeName":"word"},{"id":6741,"position":4,"arabic":"دَافِقٍۢ","translation":"সবেগে স্খলিত","audioUrl":"wbw/086_006_004.mp3","charTypeName":"word"},{"id":6742,"position":5,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"يَخْرُجُ مِنۢ بَيْنِ ٱلصُّلْبِ وَٱلتَّرَآئِبِ","translation":"issuing from between the loins [of man] and the pelvic arch [of woman].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5938.mp3","surahId":86,"words":[{"id":8081,"position":1,"arabic":"يَخْرُجُ","translation":"যা বের হয়","audioUrl":"wbw/086_007_001.mp3","charTypeName":"word"},{"id":8082,"position":2,"arabic":"مِنۢ","translation":"থেকে","audioUrl":"wbw/086_007_002.mp3","charTypeName":"word"},{"id":8083,"position":3,"arabic":"بَيْنِ","translation":"মাঝ","audioUrl":"wbw/086_007_003.mp3","charTypeName":"word"},{"id":8084,"position":4,"arabic":"ٱلصُّلْبِ","translation":"মেরুদণ্ড","audioUrl":"wbw/086_007_004.mp3","charTypeName":"word"},{"id":8085,"position":5,"arabic":"وَٱلتَّرَآئِبِ","translation":"ও বক্ষপিঞ্জরের","audioUrl":"wbw/086_007_005.mp3","charTypeName":"word"},{"id":8086,"position":6,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"إِنَّهُۥ عَلَىٰ رَجْعِهِۦ لَقَادِرٌۭ","translation":"Now, verily, He [who thus creates man in the first instance] is well able to bring him back [to life]","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5939.mp3","surahId":86,"words":[{"id":9253,"position":1,"arabic":"إِنَّهُۥ","translation":"নিশ্চয়ই তিনি","audioUrl":"wbw/086_008_001.mp3","charTypeName":"word"},{"id":9254,"position":2,"arabic":"عَلَىٰ","translation":"ব্যাপারে","audioUrl":"wbw/086_008_002.mp3","charTypeName":"word"},{"id":9255,"position":3,"arabic":"رَجْعِهِۦ","translation":"তার প্রত্যাবর্তনে","audioUrl":"wbw/086_008_003.mp3","charTypeName":"word"},{"id":9256,"position":4,"arabic":"لَقَادِرٌۭ","translation":"অবশ্যই সক্ষম","audioUrl":"wbw/086_008_004.mp3","charTypeName":"word"},{"id":9257,"position":5,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"يَوْمَ تُبْلَى ٱلسَّرَآئِرُ","translation":"on the Day when all secrets will be laid bare,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5940.mp3","surahId":86,"words":[{"id":10450,"position":1,"arabic":"يَوْمَ","translation":"সেদিন","audioUrl":"wbw/086_009_001.mp3","charTypeName":"word"},{"id":10451,"position":2,"arabic":"تُبْلَى","translation":"পরীক্ষা করা হবে","audioUrl":"wbw/086_009_002.mp3","charTypeName":"word"},{"id":10452,"position":3,"arabic":"ٱلسَّرَآئِرُ","translation":"গোপন বিষয়াবলী","audioUrl":"wbw/086_009_003.mp3","charTypeName":"word"},{"id":10453,"position":4,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"فَمَا لَهُۥ مِن قُوَّةٍۢ وَلَا نَاصِرٍۢ","translation":"and [man] will have neither strength nor helper!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5941.mp3","surahId":86,"words":[{"id":11664,"position":1,"arabic":"فَمَا","translation":"অতঃপর না","audioUrl":"wbw/086_010_001.mp3","charTypeName":"word"},{"id":11665,"position":2,"arabic":"لَهُۥ","translation":"তার জন্য (থাকবে)","audioUrl":"wbw/086_010_002.mp3","charTypeName":"word"},{"id":11666,"position":3,"arabic":"مِن","translation":"কোন","audioUrl":"wbw/086_010_003.mp3","charTypeName":"word"},{"id":11667,"position":4,"arabic":"قُوَّةٍۢ","translation":"শক্তি","audioUrl":"wbw/086_010_004.mp3","charTypeName":"word"},{"id":11668,"position":5,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/086_010_005.mp3","charTypeName":"word"},{"id":11669,"position":6,"arabic":"نَاصِرٍۢ","translation":"কোনো সাহায্যকারী","audioUrl":"wbw/086_010_006.mp3","charTypeName":"word"},{"id":11670,"position":7,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"وَٱلسَّمَآءِ ذَاتِ ٱلرَّجْعِ","translation":"Consider the heavens, ever-revolving,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5942.mp3","surahId":86,"words":[{"id":13040,"position":1,"arabic":"وَٱلسَّمَآءِ","translation":"শপথ আকাশের","audioUrl":"wbw/086_011_001.mp3","charTypeName":"word"},{"id":13041,"position":2,"arabic":"ذَاتِ","translation":"ধারণকারী","audioUrl":"wbw/086_011_002.mp3","charTypeName":"word"},{"id":13042,"position":3,"arabic":"ٱلرَّجْعِ","translation":"বৃষ্টির","audioUrl":"wbw/086_011_003.mp3","charTypeName":"word"},{"id":13043,"position":4,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]},{"number":12,"arabic":"وَٱلْأَرْضِ ذَاتِ ٱلصَّدْعِ","translation":"and the earth, bursting forth with plants!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5943.mp3","surahId":86,"words":[{"id":14495,"position":1,"arabic":"وَٱلْأَرْضِ","translation":"শপথ পৃথিবীর (যা)","audioUrl":"wbw/086_012_001.mp3","charTypeName":"word"},{"id":14496,"position":2,"arabic":"ذَاتِ","translation":"বিশিষ্ট","audioUrl":"wbw/086_012_002.mp3","charTypeName":"word"},{"id":14497,"position":3,"arabic":"ٱلصَّدْعِ","translation":"বিদীর্ণ (বক্ষ)","audioUrl":"wbw/086_012_003.mp3","charTypeName":"word"},{"id":14498,"position":4,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]},{"number":13,"arabic":"إِنَّهُۥ لَقَوْلٌۭ فَصْلٌۭ","translation":"BEHOLD, this [divine writ] is indeed a word that between truth and falsehood,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5944.mp3","surahId":86,"words":[{"id":15402,"position":1,"arabic":"إِنَّهُۥ","translation":"নিশ্চয় তা","audioUrl":"wbw/086_013_001.mp3","charTypeName":"word"},{"id":15403,"position":2,"arabic":"لَقَوْلٌۭ","translation":"অবশ্যই বাণী","audioUrl":"wbw/086_013_002.mp3","charTypeName":"word"},{"id":15404,"position":3,"arabic":"فَصْلٌۭ","translation":"মীমাংসাকারী","audioUrl":"wbw/086_013_003.mp3","charTypeName":"word"},{"id":15405,"position":4,"arabic":"١٣","translation":"(১৩)","audioUrl":null,"charTypeName":"end"}]},{"number":14,"arabic":"وَمَا هُوَ بِٱلْهَزْلِ","translation":"and is no idle tale.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5945.mp3","surahId":86,"words":[{"id":16447,"position":1,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/086_014_001.mp3","charTypeName":"word"},{"id":16448,"position":2,"arabic":"هُوَ","translation":"তা","audioUrl":"wbw/086_014_002.mp3","charTypeName":"word"},{"id":16449,"position":3,"arabic":"بِٱلْهَزْلِ","translation":"হাসি-ঠাট্টার কথা","audioUrl":"wbw/086_014_003.mp3","charTypeName":"word"},{"id":16450,"position":4,"arabic":"١٤","translation":"(১৪)","audioUrl":null,"charTypeName":"end"}]},{"number":15,"arabic":"إِنَّهُمْ يَكِيدُونَ كَيْدًۭا","translation":"Behold, they [who refuse to accept it] devise many a false argument [to disprove its truth];","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5946.mp3","surahId":86,"words":[{"id":17607,"position":1,"arabic":"إِنَّهُمْ","translation":"নিশ্চয়ই তারা","audioUrl":"wbw/086_015_001.mp3","charTypeName":"word"},{"id":17608,"position":2,"arabic":"يَكِيدُونَ","translation":"ষড়যন্ত্র করছে","audioUrl":"wbw/086_015_002.mp3","charTypeName":"word"},{"id":17609,"position":3,"arabic":"كَيْدًۭا","translation":"ভীষণ ষড়যন্ত্র","audioUrl":"wbw/086_015_003.mp3","charTypeName":"word"},{"id":17610,"position":4,"arabic":"١٥","translation":"(১৫)","audioUrl":null,"charTypeName":"end"}]},{"number":16,"arabic":"وَأَكِيدُ كَيْدًۭا","translation":"but I shall bring all their scheming to nought.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5947.mp3","surahId":86,"words":[{"id":18777,"position":1,"arabic":"وَأَكِيدُ","translation":"এবং আমি কৌশল করছি","audioUrl":"wbw/086_016_001.mp3","charTypeName":"word"},{"id":18778,"position":2,"arabic":"كَيْدًۭا","translation":"ভীষণ কৌশল","audioUrl":"wbw/086_016_002.mp3","charTypeName":"word"},{"id":18779,"position":3,"arabic":"١٦","translation":"(১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":17,"arabic":"فَمَهِّلِ ٱلْكَٰفِرِينَ أَمْهِلْهُمْ رُوَيْدًۢا","translation":"Let, then, the deniers of the truth have their will: let them have their will for a little while.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5948.mp3","surahId":86,"words":[{"id":19707,"position":1,"arabic":"فَمَهِّلِ","translation":"তাই অবকাশ দাও","audioUrl":"wbw/086_017_001.mp3","charTypeName":"word"},{"id":19708,"position":2,"arabic":"ٱلْكَـٰفِرِينَ","translation":"কাফেরদেরকে","audioUrl":"wbw/086_017_002.mp3","charTypeName":"word"},{"id":19709,"position":3,"arabic":"أَمْهِلْهُمْ","translation":"তাদের অবকাশ দাও","audioUrl":"wbw/086_017_003.mp3","charTypeName":"word"},{"id":19710,"position":4,"arabic":"رُوَيْدًۢا","translation":"কিছুক্ষণের","audioUrl":"wbw/086_017_004.mp3","charTypeName":"word"},{"id":19711,"position":5,"arabic":"١٧","translation":"(১৭)","audioUrl":null,"charTypeName":"end"}]},{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ سَبِّحِ ٱسْمَ رَبِّكَ ٱلْأَعْلَى","translation":"EXTOL the limitless glory of thy Sustainer's name: [the glory of] the Al-Highest,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5949.mp3","surahId":87,"words":[{"id":719,"position":1,"arabic":"سَبِّحِ","translation":"মহিমা ঘোষণা করো","audioUrl":"wbw/087_001_001.mp3","charTypeName":"word"},{"id":720,"position":2,"arabic":"ٱسْمَ","translation":"নামের","audioUrl":"wbw/087_001_002.mp3","charTypeName":"word"},{"id":721,"position":3,"arabic":"رَبِّكَ","translation":"তোমার রবের","audioUrl":"wbw/087_001_003.mp3","charTypeName":"word"},{"id":722,"position":4,"arabic":"ٱلْأَعْلَى","translation":"সুমহান","audioUrl":"wbw/087_001_004.mp3","charTypeName":"word"},{"id":723,"position":5,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"ٱلَّذِى خَلَقَ فَسَوَّىٰ","translation":"who creates [every thing], and thereupon forms it in accordance with what it is meant to be,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5950.mp3","surahId":87,"words":[{"id":1760,"position":1,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/087_002_001.mp3","charTypeName":"word"},{"id":1761,"position":2,"arabic":"خَلَقَ","translation":"সৃষ্টি করেছেন","audioUrl":"wbw/087_002_002.mp3","charTypeName":"word"},{"id":1762,"position":3,"arabic":"فَسَوَّىٰ","translation":"অতঃপর সুবিন্যস্ত করেছেন","audioUrl":"wbw/087_002_003.mp3","charTypeName":"word"},{"id":1763,"position":4,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"وَٱلَّذِى قَدَّرَ فَهَدَىٰ","translation":"and who determines the nature [of all that exists], and thereupon guides it [towards its fulfilment],","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5951.mp3","surahId":87,"words":[{"id":2885,"position":1,"arabic":"وَٱلَّذِى","translation":"এবং যিনি","audioUrl":"wbw/087_003_001.mp3","charTypeName":"word"},{"id":2886,"position":2,"arabic":"قَدَّرَ","translation":"নিয়তি নির্ধারণ করেছেন","audioUrl":"wbw/087_003_002.mp3","charTypeName":"word"},{"id":2887,"position":3,"arabic":"فَهَدَىٰ","translation":"অতঃপর পথ দেখিয়েছেন","audioUrl":"wbw/087_003_003.mp3","charTypeName":"word"},{"id":2888,"position":4,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"وَٱلَّذِىٓ أَخْرَجَ ٱلْمَرْعَىٰ","translation":"and who brings forth herbage,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5952.mp3","surahId":87,"words":[{"id":3248,"position":1,"arabic":"وَٱلَّذِىٓ","translation":"এবং যিনি","audioUrl":"wbw/087_004_001.mp3","charTypeName":"word"},{"id":3249,"position":2,"arabic":"أَخْرَجَ","translation":"উৎপন্ন করেছেন","audioUrl":"wbw/087_004_002.mp3","charTypeName":"word"},{"id":3250,"position":3,"arabic":"ٱلْمَرْعَىٰ","translation":"তৃণ","audioUrl":"wbw/087_004_003.mp3","charTypeName":"word"},{"id":3251,"position":4,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"فَجَعَلَهُۥ غُثَآءً أَحْوَىٰ","translation":"and thereupon causes it to decay into rust-brown stubble!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5953.mp3","surahId":87,"words":[{"id":5507,"position":1,"arabic":"فَجَعَلَهُۥ","translation":"অতঃপর তা পরিণত করেছেন","audioUrl":"wbw/087_005_001.mp3","charTypeName":"word"},{"id":5508,"position":2,"arabic":"غُثَآءً","translation":"আবর্জনায়","audioUrl":"wbw/087_005_002.mp3","charTypeName":"word"},{"id":5509,"position":3,"arabic":"أَحْوَىٰ","translation":"কালো","audioUrl":"wbw/087_005_003.mp3","charTypeName":"word"},{"id":5510,"position":4,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"سَنُقْرِئُكَ فَلَا تَنسَىٰٓ","translation":"WE SHALL teach thee, and thou wilt not forget [aught of what thou art taught],","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5954.mp3","surahId":87,"words":[{"id":6743,"position":1,"arabic":"سَنُقْرِئُكَ","translation":"তোমাকে শীঘ্রই আমরা পড়িয়ে দেব","audioUrl":"wbw/087_006_001.mp3","charTypeName":"word"},{"id":6744,"position":2,"arabic":"فَلَا","translation":"অতঃপর না","audioUrl":"wbw/087_006_002.mp3","charTypeName":"word"},{"id":6745,"position":3,"arabic":"تَنسَىٰٓ","translation":"তুমি ভুলবে","audioUrl":"wbw/087_006_003.mp3","charTypeName":"word"},{"id":6746,"position":4,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"إِلَّا مَا شَآءَ ٱللَّهُ ۚ إِنَّهُۥ يَعْلَمُ ٱلْجَه