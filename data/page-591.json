":6,"arabic":"يَحْيَىٰ","translation":"বাঁচবে","audioUrl":"wbw/087_013_006.mp3","charTypeName":"word"},{"id":15412,"position":7,"arabic":"١٣","translation":"(১৩)","audioUrl":null,"charTypeName":"end"}]},{"number":14,"arabic":"قَدْ أَفْلَحَ مَن تَزَكَّىٰ","translation":"To happiness [in the life to come] will indeed attain he who attains to purity [in this world],","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5962.mp3","surahId":87,"words":[{"id":16451,"position":1,"arabic":"قَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/087_014_001.mp3","charTypeName":"word"},{"id":16452,"position":2,"arabic":"أَفْلَحَ","translation":"সে সাফল্য পেলো","audioUrl":"wbw/087_014_002.mp3","charTypeName":"word"},{"id":16453,"position":3,"arabic":"مَن","translation":"যে","audioUrl":"wbw/087_014_003.mp3","charTypeName":"word"},{"id":16454,"position":4,"arabic":"تَزَكَّىٰ","translation":"পবিত্র হলো","audioUrl":"wbw/087_014_004.mp3","charTypeName":"word"},{"id":16455,"position":5,"arabic":"١٤","translation":"(১৪)","audioUrl":null,"charTypeName":"end"}]},{"number":15,"arabic":"وَذَكَرَ ٱسْمَ رَبِّهِۦ فَصَلَّىٰ","translation":"and remembers his Sustainer's name, and prays [unto Him].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5963.mp3","surahId":87,"words":[{"id":17611,"position":1,"arabic":"وَذَكَرَ","translation":"স্মরণ করল","audioUrl":"wbw/087_015_001.mp3","charTypeName":"word"},{"id":17612,"position":2,"arabic":"ٱسْمَ","translation":"নাম","audioUrl":"wbw/087_015_002.mp3","charTypeName":"word"},{"id":17613,"position":3,"arabic":"رَبِّهِۦ","translation":"তার রবের","audioUrl":"wbw/087_015_003.mp3","charTypeName":"word"},{"id":17614,"position":4,"arabic":"فَصَلَّىٰ","translation":"অতঃপর সে  সালাত পড়ল","audioUrl":"wbw/087_015_004.mp3","charTypeName":"word"},{"id":17615,"position":5,"arabic":"١٥","translation":"(১৫)","audioUrl":null,"charTypeName":"end"}]}]}