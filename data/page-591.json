3","charTypeName":"word"},{"id":9265,"position":3,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"فَذَكِّرْ إِن نَّفَعَتِ ٱلذِّكْرَىٰ","translation":"REMIND, THEN, [others of the truth, regardless of] whether this reminding [would seem to] be of use [or not]:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5957.mp3","surahId":87,"words":[{"id":10457,"position":1,"arabic":"فَذَكِّرْ","translation":"অতঃপর উপদেশ দাও","audioUrl":"wbw/087_009_001.mp3","charTypeName":"word"},{"id":10458,"position":2,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/087_009_002.mp3","charTypeName":"word"},{"id":10459,"position":3,"arabic":"نَّفَعَتِ","translation":"কল্যাণকর হয়","audioUrl":"wbw/087_009_003.mp3","charTypeName":"word"},{"id":10460,"position":4,"arabic":"ٱلذِّكْرَىٰ","translation":"উপদেশ","audioUrl":"wbw/087_009_004.mp3","charTypeName":"word"},{"id":10461,"position":5,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"سَيَذَّكَّرُ مَن يَخْشَىٰ","translation":"in mind will keep it he who stands in awe [of God],","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5958.mp3","surahId":87,"words":[{"id":11671,"position":1,"arabic":"سَيَذَّكَّرُ","translation":"সে শীঘ্রই শিক্ষা নেবে","audioUrl":"wbw/087_010_001.mp3","charTypeName":"word"},{"id":11672,"position":2,"arabic":"مَن","translation":"যে","audioUrl":"wbw/087_010_002.mp3","charTypeName":"word"},{"id":11673,"position":3,"arabic":"يَخْشَىٰ","translation":"ভয় করে","audioUrl":"wbw/087_010_003.mp3","charTypeName":"word"},{"id":11674,"position":4,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"وَيَتَجَنَّبُهَا ٱلْأَشْقَى","translation":"but aloof from it will remain that most hapless wretch –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5959.mp3","surahId":87,"words":[{"id":13050,"position":1,"arabic":"وَيَتَجَنَّبُهَا","translation":"আর তা