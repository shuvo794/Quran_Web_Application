,"audioUrl":"wbw/067_023_001.mp3","charTypeName":"word"},{"id":25908,"position":2,"arabic":"هُوَ","translation":"\"তিনিই","audioUrl":"wbw/067_023_002.mp3","charTypeName":"word"},{"id":25909,"position":3,"arabic":"ٱلَّذِىٓ","translation":"যিনি","audioUrl":"wbw/067_023_003.mp3","charTypeName":"word"},{"id":25910,"position":4,"arabic":"أَنشَأَكُمْ","translation":"তোমাদের সৃষ্টি করেছেন","audioUrl":"wbw/067_023_004.mp3","charTypeName":"word"},{"id":25911,"position":5,"arabic":"وَجَعَلَ","translation":"এবং দিয়েছেন","audioUrl":"wbw/067_023_005.mp3","charTypeName":"word"},{"id":25912,"position":6,"arabic":"لَكُمُ","translation":"তোমাদের জন্য","audioUrl":"wbw/067_023_006.mp3","charTypeName":"word"},{"id":25913,"position":7,"arabic":"ٱلسَّمْعَ","translation":"শ্রবণশক্তি","audioUrl":"wbw/067_023_007.mp3","charTypeName":"word"},{"id":25914,"position":8,"arabic":"وَٱلْأَبْصَـٰرَ","translation":"ও দৃষ্টিশক্তি","audioUrl":"wbw/067_023_008.mp3","charTypeName":"word"},{"id":25915,"position":9,"arabic":"وَٱلْأَفْـِٔدَةَ ۖ","translation":"এবং অন্তঃকরণ","audioUrl":"wbw/067_023_009.mp3","charTypeName":"word"},{"id":25917,"position":10,"arabic":"قَلِيلًۭا","translation":"কমই","audioUrl":"wbw/067_023_011.mp3","charTypeName":"word"},{"id":25918,"position":11,"arabic":"مَّا","translation":"যা","audioUrl":"wbw/067_023_012.mp3","charTypeName":"word"},{"id":25919,"position":12,"arabic":"تَشْكُرُونَ","translation":"তোমরা শোকর কর\"","audioUrl":"wbw/067_023_013.mp3","charTypeName":"word"},{"id":25920,"position":13,"arabic":"٢٣","translation":"(২৩)","audioUrl":null,"charTypeName":"end"}]},{"number":24,"arabic":"قُلْ هُوَ ٱلَّذِى ذَرَأَكُمْ فِى ٱلْأَرْضِ وَإِلَيْهِ تُحْشَرُونَ","translation":"Say: \"It is He who has multiplied you on earth; and it is unto Him that you shall be gathered [on resurrection].\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5265.mp3","surahId":67,"words":[{"id":26986,"position":1,"arabic":"قُلْ","translation":"বল","audioUrl":"wbw/067_024_001.mp3","cha