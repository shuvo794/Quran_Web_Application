{"id":563,"ayahs":[{"number":13,"arabic":"وَأَسِرُّوا۟ قَوْلَكُمْ أَوِ ٱجْهَرُوا۟ بِهِۦٓ ۖ إِنَّهُۥ عَلِيمٌۢ بِذَاتِ ٱلصُّدُورِ","translation":"AND [know, O men, that] whether you keep your beliefs secret or state them openly, He has full knowledge indeed of all that is in [your] hearts.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5254.mp3","surahId":67,"words":[{"id":15125,"position":1,"arabic":"وَأَسِرُّوا۟","translation":"এবং তোমরা গোপন কর","audioUrl":"wbw/067_013_001.mp3","charTypeName":"word"},{"id":15126,"position":2,"arabic":"قَوْلَكُمْ","translation":"তোমাদের কথা","audioUrl":"wbw/067_013_002.mp3","charTypeName":"word"},{"id":15127,"position":3,"arabic":"أَوِ","translation":"অথবা","audioUrl":"wbw/067_013_003.mp3","charTypeName":"word"},{"id":15128,"position":4,"arabic":"ٱجْهَرُوا۟","translation":"প্রকাশ কর","audioUrl":"wbw/067_013_004.mp3","charTypeName":"word"},{"id":15129,"position":5,"arabic":"بِهِۦٓ ۖ","translation":"তাকে","audioUrl":"wbw/067_013_005.mp3","charTypeName":"word"},{"id":15131,"position":6,"arabic":"إِنَّهُۥ","translation":"তিনি নিশ্চয়ই","audioUrl":"wbw/067_013_007.mp3","charTypeName":"word"},{"id":15132,"position":7,"arabic":"عَلِيمٌۢ","translation":"খুব জ্ঞাত","audioUrl":"wbw/067_013_008.mp3","charTypeName":"word"},{"id":15133,"position":8,"arabic":"بِذَاتِ","translation":"অবস্থা সম্পর্কে","audioUrl":"wbw/067_013_009.mp3","charTypeName":"word"},{"id":15134,"position":9,"arabic":"ٱلصُّدُورِ","translation":"অন্তরগুলোর","audioUrl":"wbw/067_013_010.mp3","charTypeName":"word"},{"id":15135,"position":10,"arabic":"١٣","translation":"(১৩)","audioUrl":null,"charTypeName":"end"}]},{"number":14,"arabic":"أَلَا يَعْلَمُ مَنْ خَلَقَ وَهُوَ ٱللَّطِيفُ ٱلْخَبِيرُ","translation":"How could it be that He who has created [all] should not know [all]? Yea, He alone is unfathomable [in His wisdom], aware!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5255.mp3","surahId":67,"words":[{"id":16202,"position":1,"arabic":"أَلَا","translation":"না কি","audioUrl":"wbw/067_014_001.mp3","charTypeName":"word"},{"id":16203,"position":2,"arabic":"يَعْلَمُ","translation":"তিনি জানেন","audioUrl":"wbw/067_014_002.mp3","charTypeName":"word"},{"id":16204,"position":3,"arabic":"مَنْ","translation":"যিনি","audioUrl":"wbw/067_014_003.mp3","charTypeName":"word"},{"id":16205,"position":4,"arabic":"خَلَقَ","translation":"সৃষ্টি করেছেন","audioUrl":"wbw/067_014_004.mp3","charTypeName":"word"},{"id":16206,"position":5,"arabic":"وَهُوَ","translation":"অথচ তিনি","audioUrl":"wbw/067_014_005.mp3","charTypeName":"word"},{"id":16207,"position":6,"arabic":"ٱللَّطِيفُ","translation":"সূক্ষ্মদর্শী","audioUrl":"wbw/067_014_006.mp3","charTypeName":"word"},{"id":16208,"position":7,"arabic":"ٱلْخَبِيرُ","translation":"খুব অবগত","audioUrl":"wbw/067_014_007.mp3","charTypeName":"word"},{"id":16209,"position":8,"arabic":"١٤","translation":"(১৪)","audioUrl":null,"charTypeName":"end"}]},{"number":15,"arabic":"هُوَ ٱلَّذِى جَعَلَ لَكُمُ ٱلْأَرْضَ ذَلُولًۭا فَٱمْشُوا۟ فِى مَنَاكِبِهَا وَكُلُوا۟ مِن رِّزْقِهِۦ ۖ وَإِلَيْهِ ٱلنُّشُورُ","translation":"He it is who has made the earth easy to live upon: go about, then, in all its regions, and partake the sustenance which He provides: but [always bear in mind that] unto Him you shall be resurrected.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5256.mp3","surahId":67,"words":[{"id":17389,"position":1,"arabic":"هُوَ","translation":"তিনিই","audioUrl":"wbw/067_015_001.mp3","charTypeName":"word"},{"id":17390,"position":2,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/067_015_002.mp3","charTypeName":"word"},{"id":17391,"position":3,"arabic":"جَعَلَ","translation":"বানিয়েছেন","audioUrl":"wbw/067_015_003.mp3","charTypeName":"word"},{"id":17392,"position":4,"arabic":"لَكُمُ","translation":"তোমাদের জন্য","audioUrl":"wbw/067_015_004.mp3","charTypeName":"word"},{"id":17393,"position":5,"arabic":"ٱلْأَرْضَ","translation":"ভূতলকে","audioUrl":"wbw/067_015_005.mp3","charTypeName":"word"},{"id":17394,"position":6,"arabic":"ذَلُولًۭا","translation":"অধীন","audioUrl":"wbw/067_015_006.mp3","charTypeName":"word"},{"id":17395,"position":7,"arabic":"فَٱمْشُوا۟","translation":"তোমরা অতঃপর চল","audioUrl":"wbw/067_015_007.mp3","charTypeName":"word"},{"id":17396,"position":8,"arabic":"فِى","translation":"উপর","audioUrl":"wbw/067_015_008.mp3","charTypeName":"word"},{"id":17397,"position":9,"arabic":"مَنَاكِبِهَا","translation":"তার বক্ষের","audioUrl":"wbw/067_015_009.mp3","charTypeName":"word"},{"id":17398,"position":10,"arabic":"وَكُلُوا۟","translation":"এবং তোমরা খাও","audioUrl":"wbw/067_015_010.mp3","charTypeName":"word"},{"id":17399,"position":11,"arabic":"مِن","translation":"হতে","audioUrl":"wbw/067_015_011.mp3","charTypeName":"word"},{"id":17400,"position":12,"arabic":"رِّزْقِهِۦ ۖ","translation":"তার রিযক","audioUrl":"wbw/067_015_012.mp3","charTypeName":"word"},{"id":17402,"position":13,"arabic":"وَإِلَيْهِ","translation":"এবং তাঁরই দিকে","audioUrl":"wbw/067_015_014.mp3","charTypeName":"word"},{"id":17403,"position":14,"arabic":"ٱلنُّشُورُ","translation":"পুনরুত্থান","audioUrl":"wbw/067_015_015.mp3","charTypeName":"word"},{"id":17404,"position":15,"arabic":"١٥","translation":"(১৫)","audioUrl":null,"charTypeName":"end"}]},{"number":16,"arabic":"ءَأَمِنتُم مَّن فِى ٱلسَّمَآءِ أَن يَخْسِفَ بِكُمُ ٱلْأَرْضَ فَإِذَا هِىَ تَمُورُ","translation":"Can you ever feel secure that He who is in heaven will not cause the earth to swallow you up when, lo and behold, it begins to quake?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5257.mp3","surahId":67,"words":[{"id":18479,"position":1,"arabic":"ءَأَمِنتُم","translation":"তোমরা নিরাপদ কি হয়েছ","audioUrl":"wbw/067_016_001.mp3","charTypeName":"word"},{"id":18480,"position":2,"arabic":"مَّن","translation":"(তাঁর থেকে) যিনি","audioUrl":"wbw/067_016_002.mp3","charTypeName":"word"},{"id":18481,"position":3,"arabic":"فِى","translation":"আছেন","audioUrl":"wbw/067_016_003.mp3","charTypeName":"word"},{"id":18482,"position":4,"arabic":"ٱلسَّمَآءِ","translation":"আসমানে","audioUrl":"wbw/067_016_004.mp3","charTypeName":"word"},{"id":18483,"position":5,"arabic":"أَن","translation":"যে","audioUrl":"wbw/067_016_005.mp3","charTypeName":"word"},{"id":18484,"position":6,"arabic":"يَخْسِفَ","translation":"ধসিয়ে দেবেন","audioUrl":"wbw/067_016_006.mp3","charTypeName":"word"},{"id":18485,"position":7,"arabic":"بِكُمُ","translation":"তোমাদের সহ","audioUrl":"wbw/067_016_007.mp3","charTypeName":"word"},{"id":18486,"position":8,"arabic":"ٱلْأَرْضَ","translation":"মাটিকে","audioUrl":"wbw/067_016_008.mp3","charTypeName":"word"},{"id":18487,"position":9,"arabic":"فَإِذَا","translation":"অতঃপর","audioUrl":"wbw/067_016_009.mp3","charTypeName":"word"},{"id":18488,"position":10,"arabic":"هِىَ","translation":"তা","audioUrl":"wbw/067_016_010.mp3","charTypeName":"word"},{"id":18489,"position":11,"arabic":"تَمُورُ","translation":"কাঁপবে","audioUrl":"wbw/067_016_011.mp3","charTypeName":"word"},{"id":18490,"position":12,"arabic":"١٦","translation":"(১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":17,"arabic":"أَمْ أَمِنتُم مَّن فِى ٱلسَّمَآءِ أَن يُرْسِلَ عَلَيْكُمْ حَاصِبًۭا ۖ فَسَتَعْلَمُونَ كَيْفَ نَذِيرِ","translation":"Or can you ever feel secure that He who is in heaven will not let loose against you a deadly stormwind, whereupon you would come to know how [true] My warning was?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5258.mp3","surahId":67,"words":[{"id":19455,"position":1,"arabic":"أَمْ","translation":"অথবা","audioUrl":"wbw/067_017_001.mp3","charTypeName":"word"},{"id":19456,"position":2,"arabic":"أَمِنتُم","translation":"তোমরা নির্ভয় হয়েছ","audioUrl":"wbw/067_017_002.mp3","charTypeName":"word"},{"id":19457,"position":3,"arabic":"مَّن","translation":"(তাঁর থেকে) যিনি","audioUrl":"wbw/067_017_003.mp3","charTypeName":"word"},{"id":19458,"position":4,"arabic":"فِى","translation":"আছেন","audioUrl":"wbw/067_017_004.mp3","charTypeName":"word"},{"id":19459,"position":5,"arabic":"ٱلسَّمَآءِ","translation":"আসমানে","audioUrl":"wbw/067_017_005.mp3","charTypeName":"word"},{"id":19460,"position":6,"arabic":"أَن","translation":"যে","audioUrl":"wbw/067_017_006.mp3","charTypeName":"word"},{"id":19461,"position":7,"arabic":"يُرْسِلَ","translation":"পাঠাবেন","audioUrl":"wbw/067_017_007.mp3","charTypeName":"word"},{"id":19462,"position":8,"arabic":"عَلَيْكُمْ","translation":"তোমাদের উপর","audioUrl":"wbw/067_017_008.mp3","charTypeName":"word"},{"id":19463,"position":9,"arabic":"حَاصِبًۭا ۖ","translation":"কঙ্করবর্ষী ঝঞ্ঝা","audioUrl":"wbw/067_017_009.mp3","charTypeName":"word"},{"id":19465,"position":10,"arabic":"فَسَتَعْلَمُونَ","translation":"তোমরা জানবে তখন","audioUrl":"wbw/067_017_011.mp3","charTypeName":"word"},{"id":19466,"position":11,"arabic":"كَيْفَ","translation":"কেমন","audioUrl":"wbw/067_017_012.mp3","charTypeName":"word"},{"id":19467,"position":12,"arabic":"نَذِيرِ","translation":"আমার সতর্কীকরণ","audioUrl":"wbw/067_017_013.mp3","charTypeName":"word"},{"id":19468,"position":13,"arabic":"١٧","translation":"(১৭)","audioUrl":null,"charTypeName":"end"}]},{"number":18,"arabic":"وَلَقَدْ كَذَّبَ ٱلَّذِينَ مِن قَبْلِهِمْ فَكَيْفَ كَانَ نَكِيرِ","translation":"And, indeed, [many of] those who lived aforetime did give the lie [to My warnings]: and how awesome was My rejection [of them]!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5259.mp3","surahId":67,"words":[{"id":20539,"position":1,"arabic":"وَلَقَدْ","translation":"এবং করে ছিল নিশ্চয়","audioUrl":"wbw/067_018_001.mp3","charTypeName":"word"},{"id":20540,"position":2,"arabic":"كَذَّبَ","translation":"মিথ্যারোপ","audioUrl":"wbw/067_018_002.mp3","charTypeName":"word"},{"id":20541,"position":3,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/067_018_003.mp3","charTypeName":"word"},{"id":20542,"position":4,"arabic":"مِن","translation":"(ছিল)","audioUrl":"wbw/067_018_004.mp3","charTypeName":"word"},{"id":20543,"position":5,"arabic":"قَبْلِهِمْ","translation":"তাদের পূর্বে","audioUrl":"wbw/067_018_005.mp3","charTypeName":"word"},{"id":20544,"position":6,"arabic":"فَكَيْفَ","translation":"কেমন ফলে","audioUrl":"wbw/067_018_006.mp3","charTypeName":"word"},{"id":20545,"position":7,"arabic":"كَانَ","translation":"ছিল","audioUrl":"wbw/067_018_007.mp3","charTypeName":"word"},{"id":20546,"position":8,"arabic":"نَكِيرِ","translation":"আমার পাক্‌ড়াও","audioUrl":"wbw/067_018_008.mp3","charTypeName":"word"},{"id":20547,"position":9,"arabic":"١٨","translation":"(১৮)","audioUrl":null,"charTypeName":"end"}]},{"number":19,"arabic":"أَوَلَمْ يَرَوْا۟ إِلَى ٱلطَّيْرِ فَوْقَهُمْ صَٰٓفَّٰتٍۢ وَيَقْبِضْنَ ۚ مَا يُمْسِكُهُنَّ إِلَّا ٱلرَّحْمَٰنُ ۚ إِنَّهُۥ بِكُلِّ شَىْءٍۭ بَصِيرٌ","translation":"Have they, then, never beheld the birds above them, spreading their wings and drawing them in? None but the Most Gracious upholds them: for, verily, He keeps all things in His sight.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5260.mp3","surahId":67,"words":[{"id":21617,"position":1,"arabic":"أَوَلَمْ","translation":"কি নাই","audioUrl":"wbw/067_019_001.mp3","charTypeName":"word"},{"id":21618,"position":2,"arabic":"يَرَوْا۟","translation":"তারা দেখে","audioUrl":"wbw/067_019_002.mp3","charTypeName":"word"},{"id":21619,"position":3,"arabic":"إِلَى","translation":"প্রতি","audioUrl":"wbw/067_019_003.mp3","charTypeName":"word"},{"id":21620,"position":4,"arabic":"ٱلطَّيْرِ","translation":"পাখিগুলির","audioUrl":"wbw/067_019_004.mp3","charTypeName":"word"},{"id":21621,"position":5,"arabic":"فَوْقَهُمْ","translation":"তাদের উপরে","audioUrl":"wbw/067_019_005.mp3","charTypeName":"word"},{"id":21622,"position":6,"arabic":"صَـٰٓفَّـٰتٍۢ","translation":"পাখা বিস্তার করে","audioUrl":"wbw/067_019_006.mp3","charTypeName":"word"},{"id":21623,"position":7,"arabic":"وَيَقْبِضْنَ ۚ","translation":"ও গুটিয়ে নেয়","audioUrl":"wbw/067_019_007.mp3","charTypeName":"word"},{"id":21625,"position":8,"arabic":"مَا","translation":"না","audioUrl":"wbw/067_019_009.mp3","charTypeName":"word"},{"id":21626,"position":9,"arabic":"يُمْسِكُهُنَّ","translation":"তাদের ধরে ধরে (অন্য কেউ)","audioUrl":"wbw/067_019_010.mp3","charTypeName":"word"},{"id":21627,"position":10,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/067_019_011.mp3","charTypeName":"word"},{"id":21628,"position":11,"arabic":"ٱلرَّحْمَـٰنُ ۚ","translation":"দয়াবান","audioUrl":"wbw/067_019_012.mp3","charTypeName":"word"},{"id":21630,"position":12,"arabic":"إِنَّهُۥ","translation":"তিনি নিশ্চয়","audioUrl":"wbw/067_019_014.mp3","charTypeName":"word"},{"id":21631,"position":13,"arabic":"بِكُلِّ","translation":"সব উপর","audioUrl":"wbw/067_019_015.mp3","charTypeName":"word"},{"id":21632,"position":14,"arabic":"شَىْءٍۭ","translation":"কিছুর","audioUrl":"wbw/067_019_016.mp3","charTypeName":"word"},{"id":21633,"position":15,"arabic":"بَصِيرٌ","translation":"দৃষ্টিবান","audioUrl":"wbw/067_019_017.mp3","charTypeName":"word"},{"id":21634,"position":16,"arabic":"١٩","translation":"(১৯)","audioUrl":null,"charTypeName":"end"}]},{"number":20,"arabic":"أَمَّنْ هَٰذَا ٱلَّذِى هُوَ جُندٌۭ لَّكُمْ يَنصُرُكُم مِّن دُونِ ٱلرَّحْمَٰنِ ۚ إِنِ ٱلْكَٰفِرُونَ إِلَّا فِى غُرُورٍ","translation":"[And] is there any, besides the Most Gracious, that could be a shield for you, and could succour you [against danger]? They who deny this truth are but lost in self- delusion!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5261.mp3","surahId":67,"words":[{"id":22685,"position":1,"arabic":"أَمَّنْ","translation":"অথবা কোন","audioUrl":"wbw/067_020_001.mp3","charTypeName":"word"},{"id":22686,"position":2,"arabic":"هَـٰذَا","translation":"এমন","audioUrl":"wbw/067_020_002.mp3","charTypeName":"word"},{"id":22687,"position":3,"arabic":"ٱلَّذِى","translation":"যা","audioUrl":"wbw/067_020_003.mp3","charTypeName":"word"},{"id":22688,"position":4,"arabic":"هُوَ","translation":"সেই","audioUrl":"wbw/067_020_004.mp3","charTypeName":"word"},{"id":22689,"position":5,"arabic":"جُندٌۭ","translation":"সৈন্যবাহিনী","audioUrl":"wbw/067_020_005.mp3","charTypeName":"word"},{"id":22690,"position":6,"arabic":"لَّكُمْ","translation":"তোমাদের জন্য আছে","audioUrl":"wbw/067_020_006.mp3","charTypeName":"word"},{"id":22691,"position":7,"arabic":"يَنصُرُكُم","translation":"তোমাদের সাহায্য করবে","audioUrl":"wbw/067_020_007.mp3","charTypeName":"word"},{"id":22692,"position":8,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/067_020_008.mp3","charTypeName":"word"},{"id":22693,"position":9,"arabic":"دُونِ","translation":"ছাড়া","audioUrl":"wbw/067_020_009.mp3","charTypeName":"word"},{"id":22694,"position":10,"arabic":"ٱلرَّحْمَـٰنِ ۚ","translation":"রহমান","audioUrl":"wbw/067_020_010.mp3","charTypeName":"word"},{"id":22696,"position":11,"arabic":"إِنِ","translation":"নয়","audioUrl":"wbw/067_020_012.mp3","charTypeName":"word"},{"id":22697,"position":12,"arabic":"ٱلْكَـٰفِرُونَ","translation":"আমান্যকারীরা","audioUrl":"wbw/067_020_013.mp3","charTypeName":"word"},{"id":22698,"position":13,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/067_020_014.mp3","charTypeName":"word"},{"id":22699,"position":14,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/067_020_015.mp3","charTypeName":"word"},{"id":22700,"position":15,"arabic":"غُرُورٍ","translation":"ধোঁকার","audioUrl":"wbw/067_020_016.mp3","charTypeName":"word"},{"id":22701,"position":16,"arabic":"٢٠","translation":"(২০)","audioUrl":null,"charTypeName":"end"}]},{"number":21,"arabic":"أَمَّنْ هَٰذَا ٱلَّذِى يَرْزُقُكُمْ إِنْ أَمْسَكَ رِزْقَهُۥ ۚ بَل لَّجُّوا۟ فِى عُتُوٍّۢ وَنُفُورٍ","translation":"Or is there any that could provide you with sustenance if He should withhold His provision [from you]? Nay, but they [who are bent on denying the truth] stubbornly persist in their disdain [of God's messages] and in their headlong flight [from Him]!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5262.mp3","surahId":67,"words":[{"id":23872,"position":1,"arabic":"أَمَّنْ","tr