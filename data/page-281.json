07,"position":6,"arabic":"صِرَٰطٍۢ","translation":"পথের","audioUrl":"wbw/016_121_007.mp3","charTypeName":"word"},{"id":76608,"position":7,"arabic":"مُّسْتَقِيمٍۢ","translation":"সরল সঠিক","audioUrl":"wbw/016_121_008.mp3","charTypeName":"word"},{"id":76609,"position":8,"arabic":"١٢١","translation":"(১২১)","audioUrl":null,"charTypeName":"end"}]},{"number":122,"arabic":"وَءَاتَيْنَٰهُ فِى ٱلدُّنْيَا حَسَنَةًۭ ۖ وَإِنَّهُۥ فِى ٱلْءَاخِرَةِ لَمِنَ ٱلصَّٰلِحِينَ","translation":"And so We vouchsafed him good in this world; and, verily, in the life to come [too] he shall find himself among the righteous.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2023.mp3","surahId":16,"words":[{"id":76762,"position":1,"arabic":"وَءَاتَيْنَـٰهُ","translation":"এবং তাকে আমরা দিয়েছিলাম","audioUrl":"wbw/016_122_001.mp3","charTypeName":"word"},{"id":76763,"position":2,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/016_122_002.mp3","charTypeName":"word"},{"id":76764,"position":3,"arabic":"ٱلدُّنْيَا","translation":"দুনিয়ার","audioUrl":"wbw/016_122_003.mp3","charTypeName":"word"},{"id":76765,"position":4,"arabic":"حَسَنَةًۭ ۖ","translation":"কল্যাণ","audioUrl":"wbw/016_122_004.mp3","charTypeName":"word"},{"id":76767,"position":5,"arabic":"وَإِنَّهُۥ","translation":"এবং নিশ্চয়ই সে","audioUrl":"wbw/016_122_006.mp3","charTypeName":"word"},{"id":76768,"position":6,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/016_122_007.mp3","charTypeName":"word"},{"id":76769,"position":7,"arabic":"ٱلْـَٔاخِرَةِ","translation":"আখেরাতে (হবে)","audioUrl":"wbw/016_122_008.mp3","charTypeName":"word"},{"id":76770,"position":8,"arabic":"لَمِنَ","translation":"অবশ্যই অন্তর্ভুক্ত","audioUrl":"wbw/016_122_009.mp3","charTypeName":"word"},{"id":76771,"position":9,"arabic":"ٱلصَّـٰلِحِينَ","translation":"সৎকর্মশীলদের","audioUrl":"wbw/016_122_010.mp3","charTypeName":"word"},{"id":76772,"position":10,"arabic":"١٢٢","translation":"(১২২)","audioUrl":null,"charTypeName":"end"}]},{"number":123,"arabic":"ثُمَّ أَوْحَيْنَآ إِلَيْكَ أَنِ ٱتَّبِعْ مِلَّةَ إِبْرَٰهِيمَ حَنِيفًۭا ۖ وَمَا كَانَ مِنَ ٱلْمُشْرِكِينَ","translation":"And lastly, We have inspired thee, [O Muhammad, with this message:] \"Follow the creed of Abraham, who turned away from all that is false, and was not of those who ascribe divinity to aught beside God;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2024.mp3","surahId":16,"words":[{"id":76849,"position":1,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/016_123_001.mp3","charTypeName":"word"},{"id":76850,"position":2,"arabic":"أَوْحَيْنَآ","translation":"আমরা ওহী করেছি","audioUrl":"wbw/016_123_002.mp3","charTypeName":"word"},{"id":76851,"position":3,"arabic":"إِلَيْكَ","translation":"তোমার প্রতি","audioUrl":"wbw/016_123_003.mp3","charTypeName":"word"},{"id":76852,"position":4,"arabic":"أَنِ","translation":"যে","audioUrl":"wbw/016_123_004.mp3","charTypeName":"word"},{"id":76853,"position":5,"arabic":"ٱتَّبِعْ","translation":"\"অনুসরণ করো","audioUrl":"wbw/016_123_005.mp3","charTypeName":"word"},{"id":76854,"position":6,"arabic":"مِلَّةَ","translation":"মিল্লাতের (আদর্শের)","audioUrl":"wbw/016_123_006.mp3","charTypeName":"word"},{"id":76855,"position":7,"arabic":"إِبْرَٰهِيمَ","translation":"ইবরাহীমের","audioUrl":"wbw/016_123_007.mp3","charTypeName":"word"},{"id":76856,"position":8,"arabic":"حَنِيفًۭا ۖ","translation":"একনিষ্ঠভাবে","audioUrl":"wbw/016_123_008.mp3","charTypeName":"word"},{"id":76858,"position":9,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/016_123_010.mp3","charTypeName":"word"},{"id":76859,"position":10,"arabic":"كَانَ","translation":"সে ছিলো","audioUrl":"wbw/016_123_011.mp3","charTypeName":"word"},{"id":76860,"position":11,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/016_123_012.mp3","charTypeName":"word"},{"id":76861,"position":12,"arabic":"ٱلْمُشْرِكِينَ","translation":"মুশরিকদের\"","audioUrl":"wbw/016_123_013.mp3","charTypeName":"word"},{"id":76862,"position":13,"arabic":"١٢٣","translation":"(১২৩)","audioUrl":null,"charTypeName":"end"}]},{"number":124,"arabic":"إِنَّمَا جُعِلَ ٱلسَّبْتُ عَلَى ٱلَّذِينَ ٱخْتَلَفُوا۟ فِيهِ ۚ وَإِنَّ رَبَّكَ لَيَحْكُمُ بَيْنَهُمْ يَوْمَ ٱلْقِيَٰمَةِ فِيمَا كَانُوا۟ فِيهِ يَخْتَلِفُونَ","translation":"[and know that the observance of] the Sabbath was ordained only for those who came to hold divergent views about him; but, verily, God will judge between them on Resurrection Day with regard to all on which they were wont to differ.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2025.mp3","surahId":16,"words":[{"id":77082,"position":1,"arabic":"إِنَّمَا","translation":"প্রকৃতপক্ষে","audioUrl":"wbw/016_124_001.mp3","charTypeName":"word"},{"id":77083,"position":2,"arabic":"جُعِلَ","translation":"বাধ্যতামূলক করা হয়েছিলো","audioUrl":"wbw/016_124_002.mp3","charTypeName":"word"},{"id":77084,"position":3,"arabic":"ٱلسَّبْتُ","translation":"শনিবার","audioUrl":"wbw/016_124_003.mp3","charTypeName":"word"},{"id":77085,"position":4,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/016_124_004.mp3","charTypeName":"word"},{"id":77086,"position":5,"arabic":"ٱلَّذِينَ","translation":"(তাদের) যারা","audioUrl":"wbw/016_124_005.mp3","charTypeName":"word"},{"id":77087,"position":6,"arabic":"ٱخْتَلَفُوا۟","translation":"মতভেদ করেছিলো","audioUrl":"wbw/016_124_006.mp3","charTypeName":"word"},{"id":77088,"position":7,"arabic":"فِيهِ ۚ","translation":"তার মধ্যে","audioUrl":"wbw/016_124_007.mp3","charTypeName":"word"},{"id":77090,"position":8,"arabic":"وَإِنَّ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/016_124_009.mp3","charTypeName":"word"},{"id":77091,"position":9,"arabic":"رَبَّكَ","translation":"তোমার রব","audioUrl":"wbw/016_124_010.mp3","charTypeName":"word"},{"id":77092,"position":10,"arabic":"لَيَحْكُمُ","translation":"অবশ্যই মীমাংসা করে দিবেন","audioUrl":"wbw/016_124_011.mp3","charTypeName":"word"},{"id":77093,"position":11,"arabic":"بَيْنَهُمْ","translation":"তাদের মাঝে","audioUrl":"wbw/016_124_012.mp3