de God. But if you remain patient in adversity and conscious of Him - this, behold, is something to set one's heart upon.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/479.mp3","surahId":3,"words":[{"id":84210,"position":1,"arabic":"۞ لَتُبْلَوُنَّ","translation":"তোমাদের অবশ্যই পরীক্ষা করা হবে","audioUrl":"wbw/003_186_002.mp3","charTypeName":"word"},{"id":84211,"position":2,"arabic":"فِىٓ","translation":"মধ্যে","audioUrl":"wbw/003_186_003.mp3","charTypeName":"word"},{"id":84212,"position":3,"arabic":"أَمْوَٰلِكُمْ","translation":"তোমাদের সম্পদ সমূহের","audioUrl":"wbw/003_186_004.mp3","charTypeName":"word"},{"id":84213,"position":4,"arabic":"وَأَنفُسِكُمْ","translation":"ও তোমাদের জান সমূহে","audioUrl":"wbw/003_186_005.mp3","charTypeName":"word"},{"id":84214,"position":5,"arabic":"وَلَتَسْمَعُنَّ","translation":"এবং তোমরা অবশ্যই শুনবে","audioUrl":"wbw/003_186_006.mp3","charTypeName":"word"},{"id":84215,"position":6,"arabic":"مِنَ","translation":"তাদের থেকে","audioUrl":"wbw/003_186_007.mp3","charTypeName":"word"},{"id":84216,"position":7,"arabic":"ٱلَّذِينَ","translation":"যাদের","audioUrl":"wbw/003_186_008.mp3","charTypeName":"word"},{"id":84217,"position":8,"arabic":"أُوتُوا۟","translation":"দেয়া হয়েছে","audioUrl":"wbw/003_186_009.mp3","charTypeName":"word"},{"id":84218,"position":9,"arabic":"ٱلْكِتَـٰبَ","translation":"কিতাব","audioUrl":"wbw/003_186_010.mp3","charTypeName":"word"},{"id":84219,"position":10,"arabic":"مِن","translation":"(থেকে)","audioUrl":"wbw/003_186_011.mp3","charTypeName":"word"},{"id":84220,"position":11,"arabic":"قَبْلِكُمْ","translation":"তোমাদের পূর্বে","audioUrl":"wbw/003_186_012.mp3","charTypeName":"word"},{"id":84221,"position":12,"arabic":"وَمِنَ","translation":"এবং হতেও","audioUrl":"wbw/003_186_013.mp3","charTypeName":"word"},{"id":84222,"position":13,"arabic":"ٱلَّذِينَ","translation":"(তাদের) যারা","audioUrl":"wbw/003_186_014.mp3","charTypeName":"word"},{"id":84223,"position":14,"arabic":"أَشْرَكُوٓا۟","translation":"শিরক করেছে","audioUrl":"wbw/003_186_015.mp3","charTypeName":"word"},{"id":84224,"position":15,"arabic":"أَذًۭى","translation":"কষ্টদায়ক (কথা)","audioUrl":"wbw/003_186_016.mp3","charTypeName":"word"},{"id":84225,"position":16,"arabic":"كَثِيرًۭا ۚ","translation":"অনেক","audioUrl":"wbw/003_186_017.mp3","charTypeName":"word"},{"id":84227,"position":17,"arabic":"وَإِن","translation":"এবং যদি","audioUrl":"wbw/003_186_019.mp3","charTypeName":"word"},{"id":84228,"position":18,"arabic":"تَصْبِرُوا۟","translation":"তোমরা সবর কর","audioUrl":"wbw/003_186_020.mp3","charTypeName":"word"},{"id":84229,"position":19,"arabic":"وَتَتَّقُوا۟","translation":"ও তোমরা তাকওয়া অবলম্বন কর","audioUrl":"wbw/003_186_021.mp3","charTypeName":"word"},{"id":84230,"position":20,"arabic":"فَإِنَّ","translation":"তবে নিশ্চয়","audioUrl":"wbw/003_186_022.mp3","charTypeName":"word"},{"id":84231,"position":21,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/003_186_023.mp3","charTypeName":"word"},{"id":84232,"position":22,"arabic":"مِنْ","translation":"অন্যতম","audioUrl":"wbw/003_186_024.mp3","charTypeName":"word"},{"id":84233,"position":23,"arabic":"عَزْمِ","translation":"দৃঢ় সংকল্পের","audioUrl":"wbw/003_186_025.mp3","charTypeName":"word"},{"id":84234,"position":24,"arabic":"ٱلْأُمُورِ","translation":"ব্যাপার","audioUrl":"wbw/003_186_026.mp3","charTypeName":"word"},{"id":84235,"position":25,"arabic":"١٨٦","translation":"(১৮৬)","audioUrl":null,"charTypeName":"end"}]}]}