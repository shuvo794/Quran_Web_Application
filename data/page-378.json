ion":"না\"","audioUrl":"wbw/027_018_018.mp3","charTypeName":"word"},{"id":20854,"position":19,"arabic":"يَشْعُرُونَ","translation":"টেরও পাবে\"","audioUrl":"wbw/027_018_019.mp3","charTypeName":"word"},{"id":20855,"position":20,"arabic":"١٨","translation":"(১৮)","audioUrl":null,"charTypeName":"end"}]},{"number":19,"arabic":"فَتَبَسَّمَ ضَاحِكًۭا مِّن قَوْلِهَا وَقَالَ رَبِّ أَوْزِعْنِىٓ أَنْ أَشْكُرَ نِعْمَتَكَ ٱلَّتِىٓ أَنْعَمْتَ عَلَىَّ وَعَلَىٰ وَٰلِدَىَّ وَأَنْ أَعْمَلَ صَٰلِحًۭا تَرْضَىٰهُ وَأَدْخِلْنِى بِرَحْمَتِكَ فِى عِبَادِكَ ٱلصَّٰلِحِينَ","translation":"Thereupon [Solomon] smiled joyously at her words, and said: “O my Sustainer! Inspire me so that I may forever be grateful for those blessings of Thine with which Thou hast graced me and my parents, and that I may do what is right [in a manner] that will please Thee; and include me, by Thy grace, among Thy righteous servants!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3178.mp3","surahId":27,"words":[{"id":21872,"position":1,"arabic":"فَتَبَسَّمَ","translation":"তখন (সুলায়মান) মুচকি হাসলো","audioUrl":"wbw/027_019_001.mp3","charTypeName":"word"},{"id":21873,"position":2,"arabic":"ضَاحِكًۭا","translation":"হাসি","audioUrl":"wbw/027_019_002.mp3","charTypeName":"word"},{"id":21874,"position":3,"arabic":"مِّن","translation":"কারণে","audioUrl":"wbw/027_019_003.mp3","charTypeName":"word"},{"id":21875,"position":4,"arabic":"قَوْلِهَا","translation":"কথার তার","audioUrl":"wbw/027_019_004.mp3","charTypeName":"word"},{"id":21876,"position":5,"arabic":"وَقَالَ","translation":"এবং বললো","audioUrl":"wbw/027_019_005.mp3","charTypeName":"word"},{"id":21877,"position":6,"arabic":"رَبِّ","translation":"\"হে আমার রব","audioUrl":"wbw/027_019_006.mp3","charTypeName":"word"},{"id":21878,"position":7,"arabic":"أَوْزِعْنِىٓ","translation":"সামর্থ্য দাও","audioUrl":"wbw/027_019_007.mp3","charTypeName":"word"},{"id":21879,"position":8,"arabic":"أَنْ","translation":"যেন","audioUrl":"wbw/027_019_008.mp3","charTypeName":"word"},{"id":21880,"position":9,"arabic":"أَشْكُرَ","translation":"কৃতজ্ঞতা প্রকাশ করতে পারি আমি","audioUrl":"wbw/027_019_009.mp3","charTypeName":"word"},{"id":21881,"position":10,"arabic":"نِعْمَتَكَ","translation":"অনুগ্রহের তোমার","audioUrl":"wbw/027_019_010.mp3","charTypeName":"word"},{"id":21882,"position":11,"arabic":"ٱلَّتِىٓ","translation":"যা","audioUrl":"wbw/027_019_011.mp3","charTypeName":"word"},{"id":21883,"position":12,"arabic":"أَنْعَمْتَ","translation":"অনুগ্রহ করেছো তুমি","audioUrl":"wbw/027_019_012.mp3","charTypeName":"word"},{"id":21884,"position":13,"arabic":"عَلَىَّ","translation":"আমার উপর","audioUrl":"wbw/027_019_013.mp3","charTypeName":"word"},{"id":21885,"position":14,"arabic":"وَعَلَىٰ","translation":"ও উপর","audioUrl":"wbw/027_019_014.mp3","charTypeName":"word"},{"id":21886,"position":15,"arabic":"وَٰلِدَىَّ","translation":"আমার পিতা মাতার","audioUrl":"wbw/027_019_015.mp3","charTypeName":"word"},{"id":21887,"position":16,"arabic":"وَأَنْ","translation":"এবং যেন","audioUrl":"wbw/027_019_016.mp3","charTypeName":"word"},{"id":21888,"position":17,"arabic":"أَعْمَلَ","translation":"আমি করি","audioUrl":"wbw/027_019_017.mp3","charTypeName":"word"},{"id":21889,"position":18,"arabic":"صَـٰلِحًۭا","translation":"(এমন) সৎ কাজ","audioUrl":"wbw/027_019_018.mp3","charTypeName":"word"},{"id":21890,"position":19,"arabic":"تَرْضَىٰهُ","translation":"যা পছন্দ করো তুমি","audioUrl":"wbw/027_019_019.mp3","charTypeName":"word"},{"id":21891,"position":20,"arabic":"وَأَدْخِلْنِى","translation":"এবং অন্তর্ভুক্ত করো আমাকে","audioUrl":"wbw/027_019_020.mp3","charTypeName":"word"},{"id":21892,"position":21,"arabic":"بِرَحْمَتِكَ","translation":"দ্বারা অনুগ্রহ তোমার","audioUrl":"wbw/027_019_021.mp3","charTypeName":"word"},{"id":21893,"position":22,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/027_019_022.mp3","charTypeName":"word"},{"id":21894,"position":23,"arabic":"عِبَادِكَ","translation":"তোমাদের দাসদের","audioUrl":"wbw/027_019_023.mp3","charTypeName":"word"},{"id":21895,"position":24,"arabic":"ٱلصَّـٰلِحِينَ","translation":"(যারা) সৎকর্মপরায়ণ\"","audioUrl":"wbw/027_019_024.mp3","charTypeName":"word"},{"id":21896,"position":25,"arabic":"١٩","translation":"(১৯)","audioUrl":null,"charTypeName":"end"}]},{"number":20,"arabic":"وَتَفَقَّدَ ٱلطَّيْرَ فَقَالَ مَا لِىَ لَآ أَرَى ٱلْهُدْهُدَ أَمْ كَانَ مِنَ ٱلْغَآئِبِينَ","translation":"And [one day] he looked in vain for [a parti­cular one of] the birds; and so he said: How is it that I do not see the hoopoe? Or could he be among the absent?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3179.mp3","surahId":27,"words":[{"id":23004,"position":1,"arabic":"وَتَفَقَّدَ","translation":"এবং (একবার) সে সন্ধান নিলো","audioUrl":"wbw/027_020_001.mp3","charTypeName":"word"},{"id":23005,"position":2,"arabic":"ٱلطَّيْرَ","translation":"পাখীকে (দলের)","audioUrl":"wbw/027_020_002.mp3","charTypeName":"word"},{"id":23006,"position":3,"arabic":"فَقَالَ","translation":"অতঃপর বললো","audioUrl":"wbw/027_020_003.mp3","charTypeName":"word"},{"id":23007,"position":4,"arabic":"مَا","translation":"\"কি (হলো)","audioUrl":"wbw/027_020_004.mp3","charTypeName":"word"},{"id":23008,"position":5,"arabic":"لِىَ","translation":"\"আমার","audioUrl":"wbw/027_020_005.mp3","charTypeName":"word"},{"id":23009,"position":6,"arabic":"لَآ","translation":"না","audioUrl":"wbw/027_020_006.mp3","charTypeName":"word"},{"id":23010,"position":7,"arabic":"أَرَى","translation":"দেখছি আমি","audioUrl":"wbw/027_020_007.mp3","charTypeName":"word"},{"id":23011,"position":8,"arabic":"ٱلْهُدْهُدَ","translation":"হুদহুদ পাখীকে","audioUrl":"wbw/027_020_008.mp3","charTypeName":"word"},{"id":23012,"position":9,"arabic":"أَمْ","translation":"কি","audioUrl":"wbw/027_020_009.mp3","charTypeName":"word"},{"id":23013,"position":10,"arabic":"كَانَ","translation":"সে হয়েছে","audioUrl":"wbw/027_020_010.mp3","charTypeName":"word"},{"id":23014,"position":11,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/027_020_011.mp3","charTypeName":"word"},{"id":23015,"position":12,"arabic":"ٱلْغَآئِبِينَ","translation":"অনুপস্থিতদের","audioUrl":"wbw/027_020_012.mp3","charTypeName":"word"},{"id":23016,"position":13,"arabic":"٢٠","translation":"(২০)","audioUrl":null,"charTypeName":"end"}]},{"number":21,"arabic":"لَأُعَذِّبَنَّهُۥ عَذَابًۭا شَدِيدًا أَوْ لَأَا۟ذْبَحَنَّهُۥٓ أَوْ لَيَأْتِيَنِّى بِسُلْطَٰنٍۢ مُّبِينٍۢ","translation":"[If so,] I will punish him most severely or will kill him unless he bring me a convincing excuse!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3180.mp3","surahId":27,"words":[{"id":24025,"position":1,"arabic":"لَأُعَذِّبَنَّهُۥ","translation":"অবশ্যই শাস্তি দিবো আমি তাকে","audioUrl":"wbw/027_021_001.mp3","charTypeName":"word"},{"id":24026,"position":2,"arabic":"عَذَابًۭا","translation":"শাস্তি","audioUrl":"wbw/027_021_002.mp3","charTypeName":"word"},{"id":24027,"position":3,"arabic":"شَدِيدًا","translation":"কঠিন","audioUrl":"wbw/027_021_003.mp3","charTypeName":"word"},{"id":24028,"position":4,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/027_021_004.mp3","charTypeName":"word"},{"id":24029,"position":5,"arabic":"لَأَا۟ذْبَحَنَّهُۥٓ","translation":"অবশ্যই জবেহ করবোই আমি তাকে","audioUrl":"wbw/027_021_005.mp3","charTypeName":"word"},{"id":24030,"position":6,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/027_021_006.mp3","charTypeName":"word"},{"id":24031,"position":7,"arabic":"لَيَأْتِيَنِّى","translation":"অবশ্যই আমার কাছে আসবে","audioUrl":"wbw/027_021_007.mp3","charTypeName":"word"},{"id":24032,"position":8,"arabic":"بِسُلْطَـٰنٍۢ","translation":"নিয়ে প্রমাণ","audioUrl":"wbw/027_021_008.mp3","charTypeName":"word"},{"id":24033,"position":9,"arabic":"مُّبِينٍۢ","translation":"সুস্পষ্ট\"","audioUrl":"wbw/027_021_009.mp3","charTypeName":"word"},{"id":24034,"position":10,"arabic":"٢١","translation":"(২১)","audioUrl":null,"charTypeName":"end"}]},{"number":22,"arabic":"فَمَكَثَ غَيْرَ بَعِيدٍۢ فَقَالَ أَحَطتُ بِمَا لَمْ تُحِطْ بِهِۦ وَجِئْتُكَ مِن سَبَإٍۭ بِنَبَإٍۢ يَقِينٍ","translation":"But [the hoopoe] tarried but a short while; and [when it came] it said: “I have encompassed [with my knowledge] something that thou hast never yet encompassed [with thine] - for I have come to thee from Sheba with a tiding sure!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3181.mp3","surahId":27,"words":[{"id":25040,"position":1,"arabic":"فَمَكَثَ","translation":"অতঃপর (পাখীটি) অতিবাহিত করলো","audioUrl":"wbw/027_022_001.mp3","charTypeName":"word"},{"id":25041,"position":2,"arabic":"غَيْرَ","translation":"নয়","audioUrl":"wbw/027_022_002.mp3","charTypeName":"word"},{"id":25042,"position":3,"arabic":"بَعِيدٍۢ","translation":"দৃঢ়ে (অতি অল্প সময়)","audioUrl":"wbw/027_022_003.mp3","charTypeName":"word"},{"id":25043,"position":4,"arabic":"فَقَالَ","translation":"অতঃপর বললো","audioUrl":"wbw/027_022_004.mp3","charTypeName":"word"},{"id":25044,"position":5,"arabic":"أَحَطتُ","translation":"\"আমি অবগত হয়েছি","audioUrl":"wbw/027_022_005.mp3","charTypeName":"word"},{"id":25045,"position":6,"arabic":"بِمَا","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/027_022_006.mp3","charTypeName":"word"},{"id":25046,"position":7,"arabic":"لَمْ","translation":"নি","audioUrl":"wbw/027_022_007.mp3","charTypeName":"word"},{"id":25047,"position":8,"arabic":"تُحِطْ","translation":"আপনি অবগত হন","audioUrl":"wbw/027_022_008.mp3","charTypeName":"word"},{"id":25048,"position":9,"arabic":"بِهِۦ","translation":"সম্পর্কে সে","audioUrl":"wbw/027_022_009.mp3","charTypeName":"word"},{"id":25049,"position":10,"arabic":"وَجِئْتُكَ","translation":"এবং আপনার কাছে এসেছি","audioUrl":"wbw/027_022_010.mp3","charTypeName":"word"},{"id":25050,"position":11,"arabic":"مِن","translation":"সম্পর্কে","audioUrl":"wbw/027_022_011.mp3","charTypeName":"word"},{"id":25051,"position":12,"arabic":"سَبَإٍۭ","translation":"সাবা'","audioUrl":"wbw/027_022_012.mp3","charTypeName":"word"},{"id":25052,"position":13,"arabic":"بِنَبَإٍۢ","translation":"নিয়ে (কি