{"id":378,"ayahs":[{"number":14,"arabic":"وَجَحَدُوا۟ بِهَا وَٱسْتَيْقَنَتْهَآ أَنفُسُهُمْ ظُلْمًۭا وَعُلُوًّۭا ۚ فَٱنظُرْ كَيْفَ كَانَ عَٰقِبَةُ ٱلْمُفْسِدِينَ","translation":"- and in their wickedness and self-exaltation they rejected them, although their minds were convinced of their truth: and behold what hap­pened in the end to those spreaders of corruption!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3173.mp3","surahId":27,"words":[{"id":16492,"position":1,"arabic":"وَجَحَدُوا۟","translation":"এবং তারা প্রত্যাখ্যান করলো","audioUrl":"wbw/027_014_001.mp3","charTypeName":"word"},{"id":16493,"position":2,"arabic":"بِهَا","translation":"প্রতি সেগুলোর","audioUrl":"wbw/027_014_002.mp3","charTypeName":"word"},{"id":16494,"position":3,"arabic":"وَٱسْتَيْقَنَتْهَآ","translation":"অথচ সেগুলো মেনে নিয়েছিলো","audioUrl":"wbw/027_014_003.mp3","charTypeName":"word"},{"id":16495,"position":4,"arabic":"أَنفُسُهُمْ","translation":"তাদের অন্তরগুলো (কিন্তু অমান্য করলো)","audioUrl":"wbw/027_014_004.mp3","charTypeName":"word"},{"id":16496,"position":5,"arabic":"ظُلْمًۭا","translation":"অন্যায়ভাবে","audioUrl":"wbw/027_014_005.mp3","charTypeName":"word"},{"id":16497,"position":6,"arabic":"وَعُلُوًّۭا ۚ","translation":"ও অহংকারবশত","audioUrl":"wbw/027_014_006.mp3","charTypeName":"word"},{"id":16499,"position":7,"arabic":"فَٱنظُرْ","translation":"তাই দেখো","audioUrl":"wbw/027_014_008.mp3","charTypeName":"word"},{"id":16500,"position":8,"arabic":"كَيْفَ","translation":"কেমন","audioUrl":"wbw/027_014_009.mp3","charTypeName":"word"},{"id":16501,"position":9,"arabic":"كَانَ","translation":"ছিলো","audioUrl":"wbw/027_014_010.mp3","charTypeName":"word"},{"id":16502,"position":10,"arabic":"عَـٰقِبَةُ","translation":"পরিণাম","audioUrl":"wbw/027_014_011.mp3","charTypeName":"word"},{"id":16503,"position":11,"arabic":"ٱلْمُفْسِدِينَ","translation":"বিপর্যয় সৃষ্টিকারীদের","audioUrl":"wbw/027_014_012.mp3","charTypeName":"word"},{"id":16504,"position":12,"arabic":"١٤","translation":"(১৪)","audioUrl":null,"charTypeName":"end"}]},{"number":15,"arabic":"وَلَقَدْ ءَاتَيْنَا دَاوُۥدَ وَسُلَيْمَٰنَ عِلْمًۭا ۖ وَقَالَا ٱلْحَمْدُ لِلَّهِ ٱلَّذِى فَضَّلَنَا عَلَىٰ كَثِيرٍۢ مِّنْ عِبَادِهِ ٱلْمُؤْمِنِينَ","translation":"AND, INDEED, We granted [true] knowledge unto David and Solomon [as well]; and both were wont to say: All praise is due to God, who has [thus] favoured us above many of His believing servants!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3174.mp3","surahId":27,"words":[{"id":17641,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/027_015_001.mp3","charTypeName":"word"},{"id":17642,"position":2,"arabic":"ءَاتَيْنَا","translation":"দান করেছিলাম আমরা","audioUrl":"wbw/027_015_002.mp3","charTypeName":"word"},{"id":17643,"position":3,"arabic":"دَاوُۥدَ","translation":"দাউদকে","audioUrl":"wbw/027_015_003.mp3","charTypeName":"word"},{"id":17644,"position":4,"arabic":"وَسُلَيْمَـٰنَ","translation":"ও সুলায়মানকে","audioUrl":"wbw/027_015_004.mp3","charTypeName":"word"},{"id":17645,"position":5,"arabic":"عِلْمًۭا ۖ","translation":"জ্ঞান","audioUrl":"wbw/027_015_005.mp3","charTypeName":"word"},{"id":17647,"position":6,"arabic":"وَقَالَا","translation":"এবং তারা দু'জনে বলেছিলো","audioUrl":"wbw/027_015_007.mp3","charTypeName":"word"},{"id":17648,"position":7,"arabic":"ٱلْحَمْدُ","translation":"\"সব প্রশংসা","audioUrl":"wbw/027_015_008.mp3","charTypeName":"word"},{"id":17649,"position":8,"arabic":"لِلَّهِ","translation":"জন্যে আল্লাহর","audioUrl":"wbw/027_015_009.mp3","charTypeName":"word"},{"id":17650,"position":9,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/027_015_010.mp3","charTypeName":"word"},{"id":17651,"position":10,"arabic":"فَضَّلَنَا","translation":"শ্রেষ্টত্ব দিয়েছেন আমাদেরকে","audioUrl":"wbw/027_015_011.mp3","charTypeName":"word"},{"id":17652,"position":11,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/027_015_012.mp3","charTypeName":"word"},{"id":17653,"position":12,"arabic":"كَثِيرٍۢ","translation":"অনেকের","audioUrl":"wbw/027_015_013.mp3","charTypeName":"word"},{"id":17654,"position":13,"arabic":"مِّنْ","translation":"মধ্য হ'তে","audioUrl":"wbw/027_015_014.mp3","charTypeName":"word"},{"id":17655,"position":14,"arabic":"عِبَادِهِ","translation":"দাসদের","audioUrl":"wbw/027_015_015.mp3","charTypeName":"word"},{"id":17656,"position":15,"arabic":"ٱلْمُؤْمِنِينَ","translation":"মু'মিন\"","audioUrl":"wbw/027_015_016.mp3","charTypeName":"word"},{"id":17657,"position":16,"arabic":"١٥","translation":"(১৫)","audioUrl":null,"charTypeName":"end"}]},{"number":16,"arabic":"وَوَرِثَ سُلَيْمَٰنُ دَاوُۥدَ ۖ وَقَالَ يَٰٓأَيُّهَا ٱلنَّاسُ عُلِّمْنَا مَنطِقَ ٱلطَّيْرِ وَأُوتِينَا مِن كُلِّ شَىْءٍ ۖ إِنَّ هَٰذَا لَهُوَ ٱلْفَضْلُ ٱلْمُبِينُ","translation":"And [in this insight] Solomon was [truly] David’s heir; and he would say: “O you people! We have been taught the speech of birds, and have been given [in abundance] of all [good] things: this, behold, is indeed a manifest favour [from God]!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3175.mp3","surahId":27,"words":[{"id":18688,"position":1,"arabic":"وَوَرِثَ","translation":"এবং উত্তরাধিকারী হয়েছে","audioUrl":"wbw/027_016_001.mp3","charTypeName":"word"},{"id":18689,"position":2,"arabic":"سُلَيْمَـٰنُ","translation":"সুলায়মান","audioUrl":"wbw/027_016_002.mp3","charTypeName":"word"},{"id":18690,"position":3,"arabic":"دَاوُۥدَ ۖ","translation":"দাউদের","audioUrl":"wbw/027_016_003.mp3","charTypeName":"word"},{"id":18692,"position":4,"arabic":"وَقَالَ","translation":"এবং (সুলাইমান) বলেছিলো","audioUrl":"wbw/027_016_005.mp3","charTypeName":"word"},{"id":18693,"position":5,"arabic":"يَـٰٓأَيُّهَا","translation":"\"হে","audioUrl":"wbw/027_016_006.mp3","charTypeName":"word"},{"id":18694,"position":6,"arabic":"ٱلنَّاسُ","translation":"মানুষ","audioUrl":"wbw/027_016_007.mp3","charTypeName":"word"},{"id":18695,"position":7,"arabic":"عُلِّمْنَا","translation":"শিখানো হয়েছে আমাদেরকে","audioUrl":"wbw/027_016_008.mp3","charTypeName":"word"},{"id":18696,"position":8,"arabic":"مَنطِقَ","translation":"ভাষা","audioUrl":"wbw/027_016_009.mp3","charTypeName":"word"},{"id":18697,"position":9,"arabic":"ٱلطَّيْرِ","translation":"পাখীদের","audioUrl":"wbw/027_016_010.mp3","charTypeName":"word"},{"id":18698,"position":10,"arabic":"وَأُوتِينَا","translation":"এবং দেয়া হয়েছে আমাদেরকে","audioUrl":"wbw/027_016_011.mp3","charTypeName":"word"},{"id":18699,"position":11,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/027_016_012.mp3","charTypeName":"word"},{"id":18700,"position":12,"arabic":"كُلِّ","translation":"সব","audioUrl":"wbw/027_016_013.mp3","charTypeName":"word"},{"id":18701,"position":13,"arabic":"شَىْءٍ ۖ","translation":"কিছুই","audioUrl":"wbw/027_016_014.mp3","charTypeName":"word"},{"id":18703,"position":14,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/027_016_016.mp3","charTypeName":"word"},{"id":18704,"position":15,"arabic":"هَـٰذَا","translation":"এটা","audioUrl":"wbw/027_016_017.mp3","charTypeName":"word"},{"id":18705,"position":16,"arabic":"لَهُوَ","translation":"অবশ্যই তা","audioUrl":"wbw/027_016_018.mp3","charTypeName":"word"},{"id":18706,"position":17,"arabic":"ٱلْفَضْلُ","translation":"অনুগ্রহ","audioUrl":"wbw/027_016_019.mp3","charTypeName":"word"},{"id":18707,"position":18,"arabic":"ٱلْمُبِينُ","translation":"সুস্পষ্ট\"","audioUrl":"wbw/027_016_020.mp3","charTypeName":"word"},{"id":18708,"position":19,"arabic":"١٦","translation":"(১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":17,"arabic":"وَحُشِرَ لِسُلَيْمَٰنَ جُنُودُهُۥ مِنَ ٱلْجِنِّ وَٱلْإِنسِ وَٱلطَّيْرِ فَهُمْ يُوزَعُونَ","translation":"And [one day] there were assembled before Solomon his hosts of invisible beings, and of men, and of birds; and then they were led forth in orderly ranks,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3176.mp3","surahId":27,"words":[{"id":19784,"position":1,"arabic":"وَحُشِرَ","translation":"আর একত্র করা হয়েছিলো",