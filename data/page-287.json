{"id":287,"ayahs":[{"number":50,"arabic":"۞ قُلْ كُونُوا۟ حِجَارَةً أَوْ حَدِيدًا","translation":"Say: \"[You will be raised from the dead even though] you be stones or iron","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2079.mp3","surahId":17,"words":[{"id":48386,"position":1,"arabic":"۞ قُلْ","translation":"বলো","audioUrl":"wbw/017_050_002.mp3","charTypeName":"word"},{"id":48387,"position":2,"arabic":"كُونُوا۟","translation":"\"তোমরা হয়ে যাও","audioUrl":"wbw/017_050_003.mp3","charTypeName":"word"},{"id":48388,"position":3,"arabic":"حِجَارَةً","translation":"পাথর","audioUrl":"wbw/017_050_004.mp3","charTypeName":"word"},{"id":48389,"position":4,"arabic":"أَوْ","translation":"বা","audioUrl":"wbw/017_050_005.mp3","charTypeName":"word"},{"id":48390,"position":5,"arabic":"حَدِيدًا","translation":"লোহা","audioUrl":"wbw/017_050_006.mp3","charTypeName":"word"},{"id":48391,"position":6,"arabic":"٥٠","translation":"(৫০)","audioUrl":null,"charTypeName":"end"}]},{"number":51,"arabic":"أَوْ خَلْقًۭا مِّمَّا يَكْبُرُ فِى صُدُورِكُمْ ۚ فَسَيَقُولُونَ مَن يُعِيدُنَا ۖ قُلِ ٱلَّذِى فَطَرَكُمْ أَوَّلَ مَرَّةٍۢ ۚ فَسَيُنْغِضُونَ إِلَيْكَ رُءُوسَهُمْ وَيَقُولُونَ مَتَىٰ هُوَ ۖ قُلْ عَسَىٰٓ أَن يَكُونَ قَرِيبًۭا","translation":"or any [other] substance which, to your minds, appears yet farther removed [from life]!\" And [if] thereupon they ask, \"Who is it that will' bring us back [to life]?\"-say thou: \"He who has brought you into being in the first instance.\" And [if] thereupon they shake their heads at thee [in disbelief] and ask, \"When shall this be?\"-say thou: \"It may well be soon,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2080.mp3","surahId":17,"words":[{"id":49050,"position":1,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/017_051_001.mp3","charTypeName":"word"},{"id":49051,"position":2,"arabic":"خَلْقًۭا","translation":"(এমন) সৃষ্টি","audioUrl":"wbw/017_051_002.mp3","charTypeName":"word"},{"id":49052,"position":3,"arabic":"مِّ