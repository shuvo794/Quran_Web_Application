{"id":192,"ayahs":[{"number":32,"arabic":"يُرِيدُونَ أَن يُطْفِـُٔوا۟ نُورَ ٱللَّهِ بِأَفْوَٰهِهِمْ وَيَأْبَى ٱللَّهُ إِلَّآ أَن يُتِمَّ نُورَهُۥ وَلَوْ كَرِهَ ٱلْكَٰفِرُونَ","translation":"They want to extinguish God's [guiding] light with their utterances: but God will not allow [this to pass], for He has willed to spread His light in all its fullness, however hateful this may be to all who deny the truth.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1267.mp3","surahId":9,"words":[{"id":34657,"position":1,"arabic":"يُرِيدُونَ","translation":"তারা চায়","audioUrl":"wbw/009_032_001.mp3","charTypeName":"word"},{"id":34658,"position":2,"arabic":"أَن","translation":"যে","audioUrl":"wbw/009_032_002.mp3","charTypeName":"word"},{"id":34659,"position":3,"arabic":"يُطْفِـُٔوا۟","translation":"তারা ফুঁৎকারে নিভাবে","audioUrl":"wbw/009_032_003.mp3","charTypeName":"word"},{"id":34660,"position":4,"arabic":"نُورَ","translation":"আলো","audioUrl":"wbw/009_032_004.mp3","charTypeName":"word"},{"id":34661,"position":5,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/009_032_005.mp3","charTypeName":"word"},{"id":34662,"position":6,"arabic":"بِأَفْوَٰهِهِمْ","translation":"দিয়ে মুখ তাদের","audioUrl":"wbw/009_032_006.mp3","charTypeName":"word"},{"id":34663,"position":7,"arabic":"وَيَأْبَى","translation":"কিন্তু প্রত্যাখ্যান করেন","audioUrl":"wbw/009_032_007.mp3","charTypeName":"word"},{"id":34664,"position":8,"arabic":"ٱللَّهُ","translation":"আল্লাহ (সে ইচ্ছা)","audioUrl":"wbw/009_032_008.mp3","charTypeName":"word"},{"id":34665,"position":9,"arabic":"إِلَّآ","translation":"এ ছাড়া","audioUrl":"wbw/009_032_009.mp3","charTypeName":"word"},{"id":34666,"position":10,"arabic":"أَن","translation":"যে","audioUrl":"wbw/009_032_010.mp3","charTypeName":"word"},{"id":34667,"position":11,"arabic":"يُتِمَّ","translation":"তিনি পূর্ণ করবেন","audioUrl":"wbw/009_032_011.mp3","charTypeName":"word"},{"id":34668,"position":12,"arabic":"نُورَهُۥ","translation":"আলো তাঁর","audioUrl":"wbw/009_032_012.mp3","charTypeName":"word"},{"id":34669,"position":13,"arabic":"وَلَوْ","translation":"এবং যদিও","audioUrl":"wbw/009_032_013.mp3","charTypeName":"word"},{"id":34670,"position":14,"arabic":"كَرِهَ","translation":"অপছন্দ করে","audioUrl":"wbw/009_032_014.mp3","charTypeName":"word"},{"id":34671,"position":15,"arabic":"ٱلْكَـٰفِرُونَ","translation":"কাফেররা","audioUrl":"wbw/009_032_015.mp3","charTypeName":"word"},{"id":34672,"position":16,"arabic":"٣٢","translation":"(৩২)","audioUrl":null,"charTypeName":"end"}]},{"number":33,"arabic":"هُوَ ٱلَّذِىٓ أَرْسَلَ رَسُولَهُۥ بِٱلْهُدَىٰ وَدِينِ ٱلْحَقِّ لِيُظْهِرَهُۥ عَلَى ٱلدِّينِ كُلِّهِۦ وَلَوْ كَرِهَ ٱلْمُشْرِكُونَ","translation":"He it is who has sent forth His Apostle with the [task of spreading] guidance and the religion of truth, to the end that He may cause it to prevail over all [false] religion -however hateful this may be to those who ascribe divinity to aught beside God.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1268.mp3","surahId":9,"words":[{"id":35480,"position":1,"arabic":"هُوَ","translation":"তিনি (আল্লাহই)","audioUrl":"wbw/009_033_001.mp3","charTypeName":"word"},{"id":35481,"position":2,"arabic":"ٱلَّذِىٓ","translation":"যিনি","audioUrl":"wbw/009_033_002.mp3","charTypeName":"word"},{"id":35482,"position":3,"arabic":"أَرْسَلَ","translation":"পাঠিয়েছেন","audioUrl":"wbw/009_033_003.mp3","charTypeName":"word"},{"id":35483,"position":4,"arabic":"رَسُولَهُۥ","translation":"রাসূূলকে তাঁর","audioUrl":"wbw/009_033_004.mp3","charTypeName":"word"},{"id":35484,"position":5,"arabic":"بِٱلْهُدَىٰ","translation":"দিয়ে পথনির্দেশ","audioUrl":"wbw/009_033_005.mp3","charTypeName":"word"},{"id":35485,"position":6,"arabic":"وَدِينِ","translation":"ও দীন","audioUrl":"wbw/009_033_006.mp3","charTypeName":"word"},{"id":35486,"position":7,"arabic":"ٱلْحَقِّ","translation":"সত্য(সহ)","audioUrl":"wbw/009_033_007.mp3","charTypeName":"word"},{"id":35487,"position":8,"arabic":"لِيُظْهِرَهُۥ","translation":"যেন তিনি বিজয়ী করেন তা","audioUrl":"wbw/009_033_008.mp3","charTypeName":"word"},{"id":35488,"position":9,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/009_033_009.mp3","charTypeName":"word"},{"id":35489,"position":10,"arabic":"ٱلدِّينِ","translation":"দীনের","audioUrl":"wbw/009_033_010.mp3","charTypeName":"word"},{"id":35490,"position":11,"arabic":"كُلِّهِۦ","translation":"সব অপর","audioUrl":"wbw/009_033_011.mp3","charTypeName":"word"},{"id":35491,"position":12,"arabic":"وَلَوْ","translation":"এবং যদিও","audioUrl":"wbw/009_033_012.mp3","charTypeName":"word"},{"id":35492,"position":13,"arabic":"كَرِهَ","translation":"অপছন্দ করে","audioUrl":"wbw/009_033_013.mp3","charTypeName":"word"},{"id":35493,"position":14,"arabic":"ٱلْمُشْرِكُونَ","translation":"মুশরিকরা","audioUrl":"wbw/009_033_014.mp3","charTypeName":"word"},{"id":35494,"position":15,"arabic":"٣٣","translation":"(৩৩)","audioUrl":null,"charTypeName":"end"}]},{"number":34,"arabic":"۞ يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوٓا۟ إِنَّ كَثِيرًۭا مِّنَ ٱلْأَحْبَارِ وَٱلرُّهْبَانِ لَيَأْكُلُونَ أَمْوَٰلَ ٱلنَّاسِ بِٱلْبَٰطِلِ وَيَصُدُّونَ عَن سَبِيلِ ٱللَّهِ ۗ وَٱلَّذِينَ يَكْنِزُونَ ٱلذَّهَبَ وَٱلْفِضَّةَ وَلَا يُنفِقُونَهَا فِى سَبِيلِ ٱللَّهِ فَبَشِّرْهُم بِعَذَابٍ أَلِيمٍۢ","translation":"O you who have attained to faith! Behold, many of the rabbis and monks do indeed wrongfully devour men's possessions and turn [others] away from the path of God. But as for all who lay up treasures of gold and silver and do not spend them for the sake of God - give them the tiding of grievous suffering [in the life to come]:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1269.mp3","surahId":9,"words":[{"id":36163,"position":1,"arabic":"۞ يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/009_034_002.mp3","charTypeName":"word"},{"id":36164,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/009_034_003.mp3","charTypeName":"word"},{"id":36165,"position":3,"arabic":"ءَامَنُوٓا۟","tr