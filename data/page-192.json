:"wbw/009_034_020.mp3","charTypeName":"word"},{"id":36182,"position":19,"arabic":"ٱلذَّهَبَ","translation":"সোনা","audioUrl":"wbw/009_034_021.mp3","charTypeName":"word"},{"id":36183,"position":20,"arabic":"وَٱلْفِضَّةَ","translation":"ও রূপা","audioUrl":"wbw/009_034_022.mp3","charTypeName":"word"},{"id":36184,"position":21,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/009_034_023.mp3","charTypeName":"word"},{"id":36185,"position":22,"arabic":"يُنفِقُونَهَا","translation":"তারা ব্যয় করে তা","audioUrl":"wbw/009_034_024.mp3","charTypeName":"word"},{"id":36186,"position":23,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/009_034_025.mp3","charTypeName":"word"},{"id":36187,"position":24,"arabic":"سَبِيلِ","translation":"পথের","audioUrl":"wbw/009_034_026.mp3","charTypeName":"word"},{"id":36188,"position":25,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/009_034_027.mp3","charTypeName":"word"},{"id":36189,"position":26,"arabic":"فَبَشِّرْهُم","translation":"তাই সুসংবাদ দাও তাদেরকে","audioUrl":"wbw/009_034_028.mp3","charTypeName":"word"},{"id":36190,"position":27,"arabic":"بِعَذَابٍ","translation":"সম্পর্কে শাস্তি","audioUrl":"wbw/009_034_029.mp3","charTypeName":"word"},{"id":36191,"position":28,"arabic":"أَلِيمٍۢ","translation":"অতি কষ্টদায়ক","audioUrl":"wbw/009_034_030.mp3","charTypeName":"word"},{"id":36192,"position":29,"arabic":"٣٤","translation":"(৩৪)","audioUrl":null,"charTypeName":"end"}]},{"number":35,"arabic":"يَوْمَ يُحْمَىٰ عَلَيْهَا فِى نَارِ جَهَنَّمَ فَتُكْوَىٰ بِهَا جِبَاهُهُمْ وَجُنُوبُهُمْ وَظُهُورُهُمْ ۖ هَٰذَا مَا كَنَزْتُمْ لِأَنفُسِكُمْ فَذُوقُوا۟ مَا كُنتُمْ تَكْنِزُونَ","translation":"on the Day when that [hoarded wealth] shall be heated in the fire of hell and their foreheads and their sides and their backs branded therewith, [those sinners shall be told:] \"These are the treasures which you have laid up for yourselves! Taste, then, [the evil of] your hoarded treasures!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1270.mp3","surahId":9,"words":[{"id":37276,"position":1,"arabic":"يَوْمَ","translation":"যেদিন","audioUrl":"wbw/009_035_001.mp3","charTypeName":"word"},{"id":37277,"position":2,"arabic":"يُحْمَىٰ","translation":"গরম করা হবে","audioUrl":"wbw/009_035_002.mp3","charTypeName":"word"},{"id":37278,"position":3,"arabic":"عَلَيْهَا","translation":"উপর তার","audioUrl":"wbw/009_035_003.mp3","charTypeName":"word"},{"id":37279,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/009_035_004.mp3","charTypeName":"word"},{"id":37280,"position":5,"arabic":"نَارِ","translation":"আগুনের","audioUrl":"wbw/009_035_005.mp3","charTypeName":"word"},{"id":37281,"position":6,"arabic":"جَهَنَّمَ","translation":"জাহান্নামের","audioUrl":"wbw/009_035_006.mp3","charTypeName":"word"},{"id":37282,"position":7,"arabic":"فَتُكْوَىٰ","translation":"অতঃপর দাগ দেয়া হবে","audioUrl":"wbw/009_035_007.mp3","charTypeName":"word"},{"id":37283,"position":8,"arabic":"بِهَا","translation":"দিয়ে তা","audioUrl":"wbw/009_035_008.mp3","charTypeName":"word"},{"id":37284,"position":9,"arabic":"جِبَاهُهُمْ","translation":"কপালে তাদের","audioUrl":"wbw/009_035_009.mp3","charTypeName":"word"},{"id":37285,"position":10,"arabic":"وَجُنُوبُهُمْ","translation":"ও পাশে তাদের","audioUrl":"wbw/009_035_010.mp3","charTypeName":"word"},{"id":37286,"position":11,"arabic":"وَظُهُورُهُمْ ۖ","translation":"ও পিঠে তাদের","audioUrl":"wbw/009_035_011.mp3","charTypeName":"word"},{"id":37288,"position":12,"arabic":"هَـٰذَا","translation":"\"(বলা হবে) এই","audioUrl":"wbw/009_035_013.mp3","charTypeName":"word"},{"id":37289,"position":13,"arabic":"مَا","translation":"যা","audioUrl":"wbw/009_035_014.mp3","charTypeName":"word"},{"id":37290,"position":14,"arabic":"كَنَزْتُمْ","translation":"জমা করেছিলে তোমরা","audioUrl":"wbw/009_035_015.mp3","charTypeName":"word"},{"id":37291,"position":15,"arabic":"لِأَنفُسِكُمْ","translation":"জন্যে নিজেদের তোমাদের","audioUrl":"wbw/009_035_016.mp3","charTypeName":"word"},{"id":3729