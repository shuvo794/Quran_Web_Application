{"id":532,"ayahs":[{"number":17,"arabic":"رَبُّ ٱلْمَشْرِقَيْنِ وَرَبُّ ٱلْمَغْرِبَيْنِ","translation":"[He is] the Sustainer of the two farthest points of sunrise, and the Sustainer of the two farthest points of sunset.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4918.mp3","surahId":55,"words":[{"id":19356,"position":1,"arabic":"رَبُّ","translation":"(তিনিই) মালিক","audioUrl":"wbw/055_017_001.mp3","charTypeName":"word"},{"id":19357,"position":2,"arabic":"ٱلْمَشْرِقَيْنِ","translation":"দুই উদয়াচলের","audioUrl":"wbw/055_017_002.mp3","charTypeName":"word"},{"id":19358,"position":3,"arabic":"وَرَبُّ","translation":"ও মালিক","audioUrl":"wbw/055_017_003.mp3","charTypeName":"word"},{"id":19359,"position":4,"arabic":"ٱلْمَغْرِبَيْنِ","translation":"দুই অস্তাচলের","audioUrl":"wbw/055_017_004.mp3","charTypeName":"word"},{"id":19360,"position":5,"arabic":"١٧","translation":"(১৭)","audioUrl":null,"charTypeName":"end"}]},{"number":18,"arabic":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ","translation":"Which, then, of your Sustain­er’s powers can you disavow?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4919.mp3","surahId":55,"words":[{"id":20415,"position":1,"arabic":"فَبِأَىِّ","translation":"অতএব কোন কোন","audioUrl":"wbw/055_018_001.mp3","charTypeName":"word"},{"id":20416,"position":2,"arabic":"ءَالَآءِ","translation":"অনুগ্রহকে","audioUrl":"wbw/055_018_002.mp3","charTypeName":"word"},{"id":20417,"position":3,"arabic":"رَبِّكُمَا","translation":"তোমাদের উভয়ের রবের","audioUrl":"wbw/055_018_003.mp3","charTypeName":"word"},{"id":20418,"position":4,"arabic":"تُكَذِّبَانِ","translation":"উভয়ে অস্বীকার করবে","audioUrl":"wbw/055_018_004.mp3","charTypeName":"word"},{"id":20419,"position":5,"arabic":"١٨","translation":"(১৮)","audioUrl":null,"charTypeName":"end"}]},{"number":19,"arabic":"مَرَجَ ٱلْبَحْرَيْنِ يَلْتَقِيَانِ","translation":"He has given freedom to the two great bodies of water, so that they might meet:","audio":"https://cdn.i