{"id":161,"ayahs":[{"number":82,"arabic":"وَمَا كَانَ جَوَابَ قَوْمِهِۦٓ إِلَّآ أَن قَالُوٓا۟ أَخْرِجُوهُم مِّن قَرْيَتِكُمْ ۖ إِنَّهُمْ أُنَاسٌۭ يَتَطَهَّرُونَ","translation":"But his people's only answer was this: \"Expel them from your land! Verily, they are folk who make themselves out to be pure!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1036.mp3","surahId":7,"words":[{"id":64882,"position":1,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/007_082_001.mp3","charTypeName":"word"},{"id":64883,"position":2,"arabic":"كَانَ","translation":"ছিলো","audioUrl":"wbw/007_082_002.mp3","charTypeName":"word"},{"id":64884,"position":3,"arabic":"جَوَابَ","translation":"উত্তর","audioUrl":"wbw/007_082_003.mp3","charTypeName":"word"},{"id":64885,"position":4,"arabic":"قَوْمِهِۦٓ","translation":"জাতির তার","audioUrl":"wbw/007_082_004.mp3","charTypeName":"word"},{"id":64886,"position":5,"arabic":"إِلَّآ","translation":"এ ছাড়া","audioUrl":"wbw/007_082_005.mp3","charTypeName":"word"},{"id":64887,"position":6,"arabic":"أَن","translation":"যে","audioUrl":"wbw/007_082_006.mp3","charTypeName":"word"},{"id":64888,"position":7,"arabic":"قَالُوٓا۟","translation":"তারা বলেছিলো","audioUrl":"wbw/007_082_007.mp3","charTypeName":"word"},{"id":64889,"position":8,"arabic":"أَخْرِجُوهُم","translation":"\"বের করে দাও তাদের","audioUrl":"wbw/007_082_008.mp3","charTypeName":"word"},{"id":64890,"position":9,"arabic":"مِّن","translation":"হতে","audioUrl":"wbw/007_082_009.mp3","charTypeName":"word"},{"id":64891,"position":10,"arabic":"قَرْيَتِكُمْ ۖ","translation":"জনপদ তোমাদের","audioUrl":"wbw/007_082_010.mp3","charTypeName":"word"},{"id":64893,"position":11,"arabic":"إِنَّهُمْ","translation":"নিশ্চয়ই তারা","audioUrl":"wbw/007_082_012.mp3","charTypeName":"word"},{"id":64894,"position":12,"arabic":"أُنَاسٌۭ","translation":"(এমন) লোক","audioUrl":"wbw/007_082_013.mp3","charTypeName":"word"},{"id":64895,"position":13,"arabic":"يَتَطَهَّرُونَ","translation":"যারা অতি পবিত্র থাকতে চায়\"","audioUrl":"wbw/007_082_014.mp3","charTypeName":"word"},{"id":64896,"position":14,"arabic":"٨٢","translation":"(৮২)","audioUrl":null,"charTypeName":"end"}]},{"number":83,"arabic":"فَأَنجَيْنَٰهُ وَأَهْلَهُۥٓ إِلَّا ٱمْرَأَتَهُۥ كَانَتْ مِنَ ٱلْغَٰبِرِينَ","translation":"Thereupon We saved him and his household except his wife, who was among those that stayed behind","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1037.mp3","surahId":7,"words":[{"id":65242,"position":1,"arabic":"فَأَنجَيْنَـٰهُ","translation":"অতঃপর আমরা উদ্ধার করলাম তাকে","audioUrl":"wbw/007_083_001.mp3","charTypeName":"word"},{"id":65243,"position":2,"arabic":"وَأَهْلَهُۥٓ","translation":"ও তার পরিবারকে","audioUrl":"wbw/007_083_002.mp3","charTypeName":"word"},{"id":65244,"position":3,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/007_083_003.mp3","charTypeName":"word"},{"id":65245,"position":4,"arabic":"ٱمْرَأَتَهُۥ","translation":"স্ত্রী তার","audioUrl":"wbw/007_083_004.mp3","charTypeName":"word"},{"id":65246,"position":5,"arabic":"كَانَتْ","translation":"সে ছিলো","audioUrl":"wbw/007_083_005.mp3","charTypeName":"word"},{"id":65247,"position":6,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/007_083_006.mp3","charTypeName":"word"},{"id":65248,"position":7,"arabic":"ٱلْغَـٰبِرِينَ","translation":"পিছনে অবস্থানকারীদের","audioUrl":"wbw/007_083_007.mp3","charTypeName":"word"},{"id":65249,"position":8,"arabic":"٨٣","translation":"(৮৩)","audioUrl":null,"charTypeName":"end"}]},{"number":84,"arabic":"وَأَمْطَرْنَا عَلَيْهِم مَّطَرًۭا ۖ فَٱنظُرْ كَيْفَ كَانَ عَٰقِبَةُ ٱلْمُجْرِمِينَ","translation":"the while We rained a rain [of destruction] upon the others: and behold what happened in the end to those people lost in sin!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1038.mp3","surahId":7,"words":[{"id":65669,"position":1,"arabic":"وَأَمْطَرْنَا","translation":"এবং বৃষ্টিবর্ষণ করেছিলাম আমরা","audioUrl":"wbw/007_084_001.mp3","charTypeName":"word"},{"id":65670,"position":2,"arabic":"عَلَيْهِم","translation":"উপর তাদের","audioUrl":"wbw/007_084_002.mp3","charTypeName":"word"},{"id":65671,"position":3,"arabic":"مَّطَرًۭا ۖ","translation":"(পাথর) বৃষ্টি","audioUrl":"wbw/007_084_003.mp3","charTypeName":"word"},{"id":65673,"position":4,"arabic":"فَٱنظُرْ","translation":"অতঃপর লক্ষ্য করো","audioUrl":"wbw/007_084_005.mp3","charTypeName":"word"},{"id":65674,"position":5,"arabic":"كَيْفَ","translation":"কেমন","audioUrl":"wbw/007_084_006.mp3","charTypeName":"word"},{"id":65675,"position":6,"arabic":"كَانَ","translation":"ছিলো","audioUrl":"wbw/007_084_007.mp3","charTypeName":"word"},{"id":65676,"position":7,"arabic":"عَـٰقِبَةُ","translation":"পরিণাম","audioUrl":"wbw/007_084_008.mp3","charTypeName":"word"},{"id":65677,"position":8,"arabic":"ٱلْمُجْرِمِينَ","translation":"অপরাধীদের","audioUrl":"wbw/007_084_009.mp3","charTypeName":"word"},{"id":65678,"position":9,"arabic":"٨٤","translation":"(৮৪)","audioUrl":null,"charTypeName":"end"}]},{"number":85,"arabic":"وَإِلَىٰ مَدْيَنَ أَخَاهُمْ شُعَيْبًۭا ۗ قَالَ يَٰقَوْمِ ٱعْبُدُوا۟ ٱللَّهَ مَا لَكُم مِّنْ إِلَٰهٍ غَيْرُهُۥ ۖ قَدْ جَآءَتْكُم بَيِّنَةٌۭ مِّن رَّبِّكُمْ ۖ فَأَوْفُوا۟ ٱلْكَيْلَ وَٱلْمِيزَانَ وَلَا تَبْخَسُوا۟ ٱلنَّاسَ أَشْيَآءَهُمْ وَلَا تُفْسِدُوا۟ فِى ٱلْأَرْضِ بَعْدَ إِصْلَٰحِهَا ۚ ذَٰلِكُمْ خَيْرٌۭ لَّكُمْ إِن كُنتُم مُّؤْمِنِينَ","translation":"AND UNTO [the people of] Madyan [We sent] their brother Shu'ayb. He said: \"O my people! Worship God alone: you have no deity other than Him. Clear evidence of the truth has now come unto you from your Sustainer. Give, therefore, full measure and weight [in all your dealings], and do not deprive people of what is rightfully theirs; and do not spread corruption on earth after it has be, en so well ordered: [all] this is for your own good, 'if you would but believe.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1039.mp3","surahId":7,"words":[{"id":66028,"position":1,"arabic":"وَإِلَىٰ","translation":"এবং দিকে","audioUrl":"wbw/007_085_001.mp3","charTypeName":"word"},{"id":66029,"position":2,"arabic":"مَدْيَنَ","translation":"মাদইয়ানের","audioUrl":"wbw/007_085_002.mp3","charTypeName":"word"},{"id":66030,"position":3,"arabic":"أَخَاهُمْ","translation":"তাদের ভাই","audioUrl":"wbw/007_085_003.mp3","charTypeName":"word"},{"id":66031,"position":4,"arabic":"شُعَيْبًۭا ۗ","translation":"শুয়াইবকে","audioUrl":"wbw/007_085_004.mp3","charTypeName":"word"},{"id":66033,"position":5,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/007_085_006.mp3","charTypeName":"word"},{"id":66034,"position":6,"arabic":"يَـٰقَوْمِ","translation":"\"হে আমার জাতি","audioUrl":"wbw/007_085_007.mp3","charTypeName":"word"},{"id":66035,"position":7,"arabic":"ٱعْبُدُوا۟","translation":"তোমরা ইবাদত করো","audioUrl":"wbw/007_085_008.mp3","charTypeName":"word"},{"id":66036,"position":8,"arabic":"ٱللَّهَ","translation":"আল্লাহর","audioUrl":"wbw/007_085_009.mp3","charTypeName":"word"},{"id":66037,"position":9,"arabic":"مَا","translation":"নেই","audioUrl":"wbw/007_085_010.mp3","charTypeName":"word"},{"id":66038,"position":10,"arabic":"لَكُم","translation":"জন্যে তোমাদের","audioUrl":"wbw/007_085_011.mp3","charTypeName":"word"},{"id":66039,"position":11,"arabic":"مِّنْ","translation":"কোনো","audioUrl":"wbw/007_085_012.mp3","charTypeName":"word"},{"id":66040,"position":12,"arabic":"إِلَـٰهٍ","translation":"ইলাহ","audioUrl":"wbw/007_085_013.mp3","charTypeName":"word"},{"id":66041,"position":13,"arabic":"غَيْرُهُۥ ۖ","translation":"ছাড়া তিনি","audioUrl":"wbw/007_085_014.mp3","charTypeName":"word"},{"id":66043,"position":14,"arabic":"قَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/007_085_016.mp3","charTypeName":"word"},{"id":66044,"position":15,"arabic":"جَآءَتْكُم","translation":"কাছে এসেছে তোমাদের","audioUrl":"wbw/007_085_017.mp3","charTypeName":"word"},{"id":66045,"position":16,"arabic":"بَيِّنَةٌۭ","translation":"সুস্পষ্ট প্রমাণ","audioUrl":"wbw/007_085_018.mp3","charTypeName":"word"},{"id":66046,"position":17,"arabic":"مِّن","translation":"পক্ষ হতে","audioUrl":"wbw/007_085_019.mp3","charTypeName":"word"},{"id":66047,"position":18,"arabic":"رَّبِّكُمْ ۖ","translation":"রবের তোমাদের","audioUrl":"wbw/007_085_020.mp3","charTypeName":"word"},{"id":66049,"position":19,"arabic":"فَأَوْفُوا۟","translation":"অতএব তোমরা পূর্ণ করো","audioUrl":"wbw/007_085_022.mp3","charTypeName":"word"},{"id":66050,"position":20,"arabic":"ٱلْكَيْلَ","translation":"মাপ","audioUrl":"wbw/007_085_023.mp3","charTypeName":"word"},{"id":66051,"position":21,"arabic":"وَٱلْمِيزَانَ","translation":"ও ওজন","audioUrl":"wbw/007_085_024.mp3","charTypeName":"word"},{"id":66052,"position":22,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/007_085_025.mp3","charTypeName":"word"},{"id":66053,"position":23,"arabic":"تَبْخَسُوا۟","translation":"তোমরা কম দিও","audioUrl":"wbw/007_085_026.mp3","charTypeName":"word"},{"id":66054,"position":24,"arabic":"ٱلنَّاسَ","translation":"মানুষদেরকে","audioUrl":"wbw/007_085_027.mp3","charTypeName":"word"},{"id":66055,"position":25,"arabic":"أَشْيَآءَهُمْ","translation":"তাদের (প্রাপ্য) দ্রব্যে","audioUrl":"wbw/007_085_028.mp3","charTypeName":"word"},{"id":66056,"position":26,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/007_085_029.mp3","charTypeName":"word"},{"id":66057,"position":27,"arabic":"تُفْسِدُوا۟","translation":"তোমরা বিপর্যয় করো","audioUrl":"wbw/007_085_030.mp3","charTypeName":"word"},{"id":66058,"position":28,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/007_085_031.mp3","charTypeName":"word"},{"id":66059,"position":29,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/007_085_032.mp3","charTypeName":"word"},{"id":66060,"position":30,"arabic":"بَعْدَ","translation":"পরেও","audioUrl":"wbw/007_085_033.mp3","charTypeName":"word"},{"id":66061,"position":31,"arabic":"إِصْلَـٰحِهَا ۚ","translation":"সংস্কারের তার","audioUrl":"wbw/007_085_034.mp3","charTypeName":"word"},{"id":66063,"position":32,"arabic":"ذَٰلِكُمْ","translation":"এটা","audioUrl":"wbw/007_085_036.mp3","charTypeName":"word"},{"id":66064,"position":33,"arabic":"خَيْرٌۭ","translation":"উত্তম","audioUrl":"wbw/007_085_037.mp3","charTypeName":"word"},{"id":66065,"position":34,"arabic":"لَّكُمْ","translation":"জন্যে তোমাদের","audioUrl":"wbw/007_085_038.mp3","charTypeName":"word"},{"id":66066,"position":35,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/007_085_039.mp3","charTypeName":"word"},{"id":66067,"position":36,"arabic":"كُنتُم","translation":"হও তোমরা","audioUrl":"wbw/007_085_040.mp3","charTypeName":"word"},{"id":66068,"position":37,"arabic":"مُّؤْمِنِينَ","translation":"মু'মিন","audioUrl":"wbw/007_085_041.mp3","charTypeName":"word"},{"id":66069,"position":38,"arabic":"٨٥","translation":"(৮৫)","audioUrl":null,"charTypeName":"end"}]},{"number":86,"arabic":"وَلَا تَقْعُدُوا۟ بِكُلِّ صِرَٰطٍۢ تُوعِدُونَ وَتَصُدُّونَ عَن سَبِيلِ ٱللَّهِ مَنْ ءَامَنَ بِهِۦ وَتَبْغُونَهَا عِوَجًۭا ۚ وَٱذْكُرُوٓا۟ إِذْ كُنتُمْ قَلِيلًۭا فَكَثَّرَكُمْ ۖ وَٱنظُرُوا۟ كَيْفَ كَانَ عَٰقِبَةُ ٱلْمُفْسِدِينَ","translation":"And do not lie in ambush by every road [that leads to the truth], threatening and trying to turn away from God's path all who believe in Him, and trying to make it appear crooked. And remember [the time] when you were few, and [how] He made you many: and behold what happened in the end to the spreaders of corruption!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1040.mp3","surahId":7,"words":[{"id":66466,"position":1,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/007_086_001.mp3","charTypeName":"word"},{"id":66467,"position":2,"arabic":"تَقْعُدُوا۟","translation":"তোমরা বসবে","audioUrl":"wbw/007_086_002.mp3","charTypeName":"word"},{"id":66468,"position":3,"arabic":"بِكُلِّ","translation":"উপর প্রত্যেক","audioUrl":"wbw/007_086_003.mp3","charTypeName":"word"},{"id":66469,"position":4,"arabic":"صِرَٰطٍۢ","translation":"রাস্তার","audioUrl":"wbw/007_086_004.mp3","charTypeName":"word"},{"id":66470,"position":5,"arabic":"تُوعِدُونَ","translation":"তোমরা ভয় দেখাবে (না)","audioUrl":"wbw/007_086_005.mp3","charTypeName":"word"},{"id":66471,"position":6,"arabic":"وَتَصُدُّونَ","translation":"ও তোমরা বাধা দিবে (না)","audioUrl":"wbw/007_086_006.mp3","charTypeName":"word"},{"id":66472,"position":7,"arabic":"عَن","translation":"হতে","audioUrl":"wbw/007_086_007.mp3","charTypeName":"word"},{"id":66473,"position":8,"arabic":"سَبِيلِ","translation":"পথ","audioUrl":"wbw/007_086_008.mp3","charTypeName":"word"},{"id":66474,"position":9,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/007_086_009.mp3","charTypeName":"word"},{"id":66475,"position":10,"arabic":"مَنْ","translation":"(তাকে) যে","audioUrl":"wbw/007_086_010.mp3","charTypeName":"word"},{"id":66476,"position":11,"arabic":"ءَامَنَ","translation":"ঈমান আনে","audioUrl":"wbw/007_086_011.mp3","charTypeName":"word"},{"id":66477,"position":12,"arabic":"بِهِۦ","translation":"উপর তাঁর","audioUrl":"wbw/007_086_012.mp3","charTypeName":"word"},{"id":66478,"position":13,"arabic":"وَتَبْغُونَهَا","translation":"এবং (না) তোমরা অনুসন্ধান করবে তাতে","audioUrl":"wbw/007_086_013.mp3","charTypeName":"word"},{"id":66479,"position":14,"arabic":"عِوَجًۭا ۚ","translation":"বক্রতা","audioUrl":"wbw/007_086_014.mp3","charTypeName":"word"},{"id":66481,"position":15,"arabic":"وَٱذْكُرُوٓا۟","translation":"এবং তোমরা স্মরণ করো","audioUrl":"wbw/007_086_016.mp3","charTypeName":"word"},{"id":66482,"position":16,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/007_086_017.mp3","charTypeName":"word"},{"id":66483,"position":17,"arabic":"كُنتُمْ","translation":"তোমরা ছিলে","audioUrl":"wbw/007_086_018.mp3","charTypeName":"word"},{"id":66484,"position":18,"arabic":"قَلِيلًۭا","translation":"(সংখ্যায়) অল্প","audioUrl":"wbw/007_086_019.mp3","charTypeName":"word"},{"id":66485,"position":19,"arabic":"فَكَثَّرَكُمْ ۖ","translation":"অতঃপর আধিক্য দিয়েছেন তোমাদেরকে","audioUrl":"wbw/007_086_020.mp3","charTypeName":"word"},{"id":66487,"position":20,"arabic":"وَٱنظُرُوا۟","translation":"এবং তোমরা লক্ষ্য করো","audioUrl":"wbw/007_086_022.mp3","charTypeName":"word"},{"id":66488,"position":21,"arabic":"كَيْفَ","translation":"কিরূপ","audioUrl":"wbw/007_086_023.mp3","charTypeName":"word"},{"id":66489,"position":22,"arabic":"كَانَ","translation":"ছিলো","audioUrl":"wbw/007_086_024.mp3","charTypeName":"word"},{"id":66490,"position":23,"arabic":"عَـٰقِبَةُ","translation":"পরিণাম","audioUrl":"wbw/007_086_025.mp3","charTypeName":"word"},{"id":66491,"position":24,"arabic":"ٱلْمُفْسِدِينَ","translation":"বিপর্যয় সৃষ্টিকারীদের","audioUrl":"wbw/007_086_026.mp3","charTypeName":"word"},{"id":66492,"position":25,"arabic":"٨٦","translation":"(৮৬)","audioUrl":null,"charTypeName":"end"}]},{"number":87,"arabic":"وَإِن كَانَ طَآئِفَةٌۭ مِّنكُمْ ءَامَنُوا۟ بِٱلَّذِىٓ أُرْسِلْتُ بِهِۦ وَطَآئِفَةٌۭ لَّمْ يُؤْمِنُوا۟ فَٱصْبِرُوا۟ حَتَّىٰ يَحْكُمَ ٱللَّهُ بَيْنَنَا ۚ وَهُوَ خَيْرُ ٱلْحَٰكِمِينَ","translation":"\"And if there be some among you who have come to believe in the message which I bear, the while the others do not believe, then have patience in adversity till God shall judge between us [and them]: for He is the best of all judges!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1041.mp3","surahId":7,"words":[{"id":67027,"position":1,"arabic":"وَإِن","translation":"এবং যদি","audioUrl":"wbw/007_087_001.mp3","charTypeName":"word"},{"id":67028,"position":2,"arabic":"كَانَ","translation":"(এমন) হয়","audioUrl":"wbw/007_087_002.mp3","charTypeName":"word"},{"id":67029,"position":3,"arabic":"طَآئِفَةٌۭ","translation":"একদল","audioUrl":"wbw/007_087_003.mp3","charTypeName":"word"},{"id":67030,"position":4,"arabic":"مِّنكُمْ","translation":"মধ্য হতে তোমাদের","audioUrl":"wbw/007_087_004.mp3","charTypeName":"word"},{"id":67031,"position":5,"arabic":"ءَامَنُوا۟","translation":"(যারা) ঈমান আনে","audioUrl":"wbw/007_087_005.mp3","charTypeName":"word"},{"id":67032,"position":6,"arabic":"بِٱلَّذِىٓ","translation":"প্রতি ঐ বিষয়ের","a