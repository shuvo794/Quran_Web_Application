dioUrl":"wbw/006_122_024.mp3","charTypeName":"word"},{"id":76683,"position":24,"arabic":"يَعْمَلُونَ","translation":"তারা কাজ করতে","audioUrl":"wbw/006_122_025.mp3","charTypeName":"word"},{"id":76684,"position":25,"arabic":"١٢٢","translation":"(১২২)","audioUrl":null,"charTypeName":"end"}]},{"number":123,"arabic":"وَكَذَٰلِكَ جَعَلْنَا فِى كُلِّ قَرْيَةٍ أَكَٰبِرَ مُجْرِمِيهَا لِيَمْكُرُوا۟ فِيهَا ۖ وَمَا يَمْكُرُونَ إِلَّا بِأَنفُسِهِمْ وَمَا يَشْعُرُونَ","translation":"And it is in this way that We cause the great ones in every land to become its [greatest] evildoers, there to weave their schemes: yet it is only against themselves that they scheme -and they perceive it not.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/912.mp3","surahId":6,"words":[{"id":76902,"position":1,"arabic":"وَكَذَٰلِكَ","translation":"এবং এভাবে","audioUrl":"wbw/006_123_001.mp3","charTypeName":"word"},{"id":76903,"position":2,"arabic":"جَعَلْنَا","translation":"আমরা নিযুক্ত করেছি","audioUrl":"wbw/006_123_002.mp3","charTypeName":"word"},{"id":76904,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/006_123_003.mp3","charTypeName":"word"},{"id":76905,"position":4,"arabic":"كُلِّ","translation":"প্রত্যেক","audioUrl":"wbw/006_123_004.mp3","charTypeName":"word"},{"id":76906,"position":5,"arabic":"قَرْيَةٍ","translation":"জনপদের","audioUrl":"wbw/006_123_005.mp3","charTypeName":"word"},{"id":76907,"position":6,"arabic":"أَكَـٰبِرَ","translation":"বড় বড়","audioUrl":"wbw/006_123_006.mp3","charTypeName":"word"},{"id":76908,"position":7,"arabic":"مُجْرِمِيهَا","translation":"অপরাধীদেরকে তার","audioUrl":"wbw/006_123_007.mp3","charTypeName":"word"},{"id":76909,"position":8,"arabic":"لِيَمْكُرُوا۟","translation":"যেন তারা চক্রান্ত করে","audioUrl":"wbw/006_123_008.mp3","charTypeName":"word"},{"id":76910,"position":9,"arabic":"فِيهَا ۖ","translation":"মধ্যে তার","audioUrl":"wbw/006_123_009.mp3","charTypeName":"word"},{"id":76912,"position":10,"arabic":"وَمَا","translatio