ِ مُكَلِّبِينَ تُعَلِّمُونَهُنَّ مِمَّا عَلَّمَكُمُ ٱللَّهُ ۖ فَكُلُوا۟ مِمَّآ أَمْسَكْنَ عَلَيْكُمْ وَٱذْكُرُوا۟ ٱسْمَ ٱللَّهِ عَلَيْهِ ۖ وَٱتَّقُوا۟ ٱللَّهَ ۚ إِنَّ ٱللَّهَ سَرِيعُ ٱلْحِسَابِ","translation":"They will ask thee as to what is lawful to them. Say: \"Lawful to you are all the good things of life.\" And as for those hunting animals which you train by imparting to them something of the knowledge that God has imparted to yourselves-eat of what they seize for you, but mention God's name over it. and remain conscious of God: verily, God is swift in reckoning.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/673.mp3","surahId":5,"words":[{"id":4062,"position":1,"arabic":"يَسْـَٔلُونَكَ","translation":"তোমাকে তারা প্রশ্ন করে","audioUrl":"wbw/005_004_001.mp3","charTypeName":"word"},{"id":4063,"position":2,"arabic":"مَاذَآ","translation":"কি","audioUrl":"wbw/005_004_002.mp3","charTypeName":"word"},{"id":4064,"position":3,"arabic":"أُحِلَّ","translation":"বৈধ করা হয়েছে","audioUrl":"wbw/005_004_003.mp3","charTypeName":"word"},{"id":4065,"position":4,"arabic":"لَهُمْ ۖ","translation":"জন্যে তাদের","audioUrl":"wbw/005_004_004.mp3","charTypeName":"word"},{"id":4067,"position":5,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/005_004_006.mp3","charTypeName":"word"},{"id":4068,"position":6,"arabic":"أُحِلَّ","translation":"\"বৈধ করা হয়েছে","audioUrl":"wbw/005_004_007.mp3","charTypeName":"word"},{"id":4069,"position":7,"arabic":"لَكُمُ","translation":"জন্যে তোমাদের","audioUrl":"wbw/005_004_008.mp3","charTypeName":"word"},{"id":4070,"position":8,"arabic":"ٱلطَّيِّبَـٰتُ ۙ","translation":"পবিত্র জিনিসগুলো","audioUrl":"wbw/005_004_009.mp3","charTypeName":"word"},{"id":4072,"position":9,"arabic":"وَمَا","translation":"এবং যাদের","audioUrl":"wbw/005_004_011.mp3","charTypeName":"word"},{"id":4073,"position":10,"arabic":"عَلَّمْتُم","translation":"(শিকার) শিক্ষা দিয়েছো তোমরা","audioUrl":"wbw/005_004_012.mp3","charTypeName":"word"},{"id":4074,"positi