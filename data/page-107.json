n":26,"arabic":"وَٱتَّقُوا۟","translation":"এবং তোমরা ভয় করো","audioUrl":"wbw/005_004_030.mp3","charTypeName":"word"},{"id":4092,"position":27,"arabic":"ٱللَّهَ ۚ","translation":"আল্লাহকে","audioUrl":"wbw/005_004_031.mp3","charTypeName":"word"},{"id":4094,"position":28,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/005_004_033.mp3","charTypeName":"word"},{"id":4095,"position":29,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/005_004_034.mp3","charTypeName":"word"},{"id":4096,"position":30,"arabic":"سَرِيعُ","translation":"দ্রুত","audioUrl":"wbw/005_004_035.mp3","charTypeName":"word"},{"id":4097,"position":31,"arabic":"ٱلْحِسَابِ","translation":"হিসাব (গ্রহণে)","audioUrl":"wbw/005_004_036.mp3","charTypeName":"word"},{"id":4098,"position":32,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"ٱلْيَوْمَ أُحِلَّ لَكُمُ ٱلطَّيِّبَٰتُ ۖ وَطَعَامُ ٱلَّذِينَ أُوتُوا۟ ٱلْكِتَٰبَ حِلٌّۭ لَّكُمْ وَطَعَامُكُمْ حِلٌّۭ لَّهُمْ ۖ وَٱلْمُحْصَنَٰتُ مِنَ ٱلْمُؤْمِنَٰتِ وَٱلْمُحْصَنَٰتُ مِنَ ٱلَّذِينَ أُوتُوا۟ ٱلْكِتَٰبَ مِن قَبْلِكُمْ إِذَآ ءَاتَيْتُمُوهُنَّ أُجُورَهُنَّ مُحْصِنِينَ غَيْرَ مُسَٰفِحِينَ وَلَا مُتَّخِذِىٓ أَخْدَانٍۢ ۗ وَمَن يَكْفُرْ بِٱلْإِيمَٰنِ فَقَدْ حَبِطَ عَمَلُهُۥ وَهُوَ فِى ٱلْءَاخِرَةِ مِنَ ٱلْخَٰسِرِينَ","translation":"Today, all the good things of life have been made lawful to you. And the food of those who have been vouchsafed revelation aforetime is lawful to you, and your food is lawful to them. And [lawful to you are], in wedlock, women from among those who believe [in this divine writ], and, in wedlock, women from among those who have been vouchsafed revelation before your time -provided that you give them their dowers, taking them in honest wedlock, not in fornication, nor as secret love-companions. But as for him who rejects belief [in God] - in vain will be all his works: for in the life to come he shall be among the lost.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/674.mp3","surahId":5,"words":[{"id":5345,"position":1,"arabic":"ٱلْيَوْمَ","translation":"আজ","audioUrl":"wbw/005_005_001.mp3","charTypeName":"word"},{"id":5346,"position":2,"arabic":"أُحِلَّ","translation":"বৈধ করা হলো","audioUrl":"wbw/005_005_002.mp3","charTypeName":"word"},{"id":5347,"position":3,"arabic":"لَكُمُ","translation":"জন্যে তোমাদের","audioUrl":"wbw/005_005_003.mp3","charTypeName":"word"},{"id":5348,"position":4,"arabic":"ٱلطَّيِّبَـٰتُ ۖ","translation":"পবিত্র (জিনিস) সমূহ","audioUrl":"wbw/005_005_004.mp3","charTypeName":"word"},{"id":5350,"position":5,"arabic":"وَطَعَامُ","translation":"ও খাবার","audioUrl":"wbw/005_005_006.mp3","charTypeName":"word"},{"id":5351,"position":6,"arabic":"ٱلَّذِينَ","translation":"(তাদের) যাদের","audioUrl":"wbw/005_005_007.mp3","charTypeName":"word"},{"id":5352,"position":7,"arabic":"أُوتُوا۟","translation":"দেয়া হয়েছে","audioUrl":"wbw/005_005_008.mp3","charTypeName":"word"},{"id":5353,"position":8,"arabic":"ٱلْكِتَـٰبَ","translation":"কিতাব","audioUrl":"wbw/005_005_009.mp3","charTypeName":"word"},{"id":5354,"position":9,"arabic":"حِلٌّۭ","translation":"বৈধ","audioUrl":"wbw/005_005_010.mp3","charTypeName":"word"},{"id":5355,"position":10,"arabic":"لَّكُمْ","translation":"জন্যেও তোমাদের","audioUrl":"wbw/005_005_011.mp3","charTypeName":"word"},{"id":5356,"position":11,"arabic":"وَطَعَامُكُمْ","translation":"এবং খাবার তোমাদের","audioUrl":"wbw/005_005_012.mp3","charTypeName":"word"},{"id":5357,"position":12,"arabic":"حِلٌّۭ","translation":"বৈধ","audioUrl":"wbw/005_005_013.mp3","charTypeName":"word"},{"id":5358,"position":13,"arabic":"لَّهُمْ ۖ","translation":"জন্যে তাদের","audioUrl":"wbw/005_005_014.mp3","charTypeName":"word"},{"id":5360,"position":14,"arabic":"وَٱلْمُحْصَنَـٰتُ","translation":"এবং সচ্চরিত্রা নারীরা","audioUrl":"wbw/005_005_016.mp3","charTypeName":"word"},{"id":5361,"position":15,"arabic":"مِنَ","translation":"মধ্য হতে","audioUrl":"wbw/005_005_017.mp3","charTypeName":"word"},{"id":5362,"position":16,"arabi