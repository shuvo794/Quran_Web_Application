{"id":490,"ayahs":[{"number":11,"arabic":"وَٱلَّذِى نَزَّلَ مِنَ ٱلسَّمَآءِ مَآءًۢ بِقَدَرٍۢ فَأَنشَرْنَا بِهِۦ بَلْدَةًۭ مَّيْتًۭا ۚ كَذَٰلِكَ تُخْرَجُونَ","translation":"And He it is who sends down, again and again, waters from the sky in due measure: and [as] We raise therewith dead land to life, even thus will you be brought forth [from the dead].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4336.mp3","surahId":43,"words":[{"id":12233,"position":1,"arabic":"وَٱلَّذِى","translation":"এবং যিনি","audioUrl":"wbw/043_011_001.mp3","charTypeName":"word"},{"id":12234,"position":2,"arabic":"نَزَّلَ","translation":"বর্ষণ করেছেন","audioUrl":"wbw/043_011_002.mp3","charTypeName":"word"},{"id":12235,"position":3,"arabic":"مِنَ","translation":"থেকে","audioUrl":"wbw/043_011_003.mp3","charTypeName":"word"},{"id":12236,"position":4,"arabic":"ٱلسَّمَآءِ","translation":"আকাশ","audioUrl":"wbw/043_011_004.mp3","charTypeName":"word"},{"id":12237,"position":5,"arabic":"مَآءًۢ","translation":"পানি","audioUrl":"wbw/043_011_005.mp3","charTypeName":"word"},{"id":12238,"position":6,"arabic":"بِقَدَرٍۢ","translation":"পরিমিতভাবে","audioUrl":"wbw/043_011_006.mp3","charTypeName":"word"},{"id":12239,"position":7,"arabic":"فَأَنشَرْنَا","translation":"আমরা অতঃপর জীবিত করি","audioUrl":"wbw/043_011_007.mp3","charTypeName":"word"},{"id":12240,"position":8,"arabic":"بِهِۦ","translation":"তা দিয়ে","audioUrl":"wbw/043_011_008.mp3","charTypeName":"word"},{"id":12241,"position":9,"arabic":"بَلْدَةًۭ","translation":"ভূমিকে","audioUrl":"wbw/043_011_009.mp3","charTypeName":"word"},{"id":12242,"position":10,"arabic":"مَّيْتًۭا ۚ","translation":"মৃত (নিষ্প্রাণ)","audioUrl":"wbw/043_011_010.mp3","charTypeName":"word"},{"id":12244,"position":11,"arabic":"كَذَٰلِكَ","translation":"এভাবেই","audioUrl":"wbw/043_011_012.mp3","charTypeName":"word"},{"id":12245,"position":12,"arabic":"تُخْرَجُونَ","translation":"তোমাদের ওঠানো হবে","audioUrl":"wbw/043_011_013.mp3","charTypeName":"word"},{"id":12246,"position":13,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]},{"number":12,"arabic":"وَٱلَّذِى خَلَقَ ٱلْأَزْوَٰجَ كُلَّهَا وَجَعَلَ لَكُم مِّنَ ٱلْفُلْكِ وَٱلْأَنْعَٰمِ مَا تَرْكَبُونَ","translation":"And He it is who has created all opposites. And He [it is who] has provided for you all those ships and animals whereon you ride,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4337.mp3","surahId":43,"words":[{"id":13581,"position":1,"arabic":"وَٱلَّذِى","translation":"এবং যিনি","audioUrl":"wbw/043_012_001.mp3","charTypeName":"word"},{"id":13582,"position":2,"arabic":"خَلَقَ","translation":"সৃষ্টি করেছেন","audioUrl":"wbw/043_012_002.mp3","charTypeName":"word"},{"id":13583,"position":3,"arabic":"ٱلْأَزْوَٰجَ","translation":"জোড়া জোড়া","audioUrl":"wbw/043_012_003.mp3","charTypeName":"word"},{"id":13584,"position":4,"arabic":"كُلَّهَا","translation":"তার প্রত্যেকটি (জিনিসকে)","audioUrl":"wbw/043_012_004.mp3","charTypeName":"word"},{"id":13585,"position":5,"arabic":"وَجَعَلَ","translation":"এবং সৃষ্টি করেছেন","audioUrl":"wbw/043_012_005.mp3","charTypeName":"word"},{"id":13586,"position":6,"arabic":"لَكُم","translation":"তোমাদের জন্যে","audioUrl":"wbw/043_012_006.mp3","charTypeName":"word"},{"id":13587,"position":7,"arabic":"مِّنَ","translation":"কিছু","audioUrl":"wbw/043_012_007.mp3","charTypeName":"word"},{"id":13588,"position":8,"arabic":"ٱلْفُلْكِ","translation":"নৌযান","audioUrl":"wbw/043_012_008.mp3","charTypeName":"word"},{"id":13589,"position":9,"arabic":"وَٱلْأَنْعَـٰمِ","translation":"ও চতুষ্পদ জন্তু","audioUrl":"wbw/043_012_009.mp3","charTypeName":"word"},{"id":13590,"position":10,"arabic":"مَا","translation":"যার (উপর)","audioUrl":"wbw/043_012_010.mp3","charTypeName":"word"},{"id":13591,"position":11,"arabic":"تَرْكَبُونَ","translation":"তোমরা চড়তে পারো","audioUrl":"wbw/043_012_011.mp3","charTypeName":"word"},{"id":13592,"position":12,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]},{"number":13,"arabic":"لِتَسْتَوُۥا۟ عَلَىٰ ظُهُورِهِۦ ثُمَّ تَذْكُرُوا۟ نِعْمَةَ رَبِّكُمْ إِذَا ٱسْتَوَيْتُمْ عَلَيْهِ وَتَقُولُوا۟ سُبْحَٰنَ ٱلَّذِى سَخَّرَ لَنَا هَٰذَا وَمَا كُنَّا لَهُۥ مُقْرِنِينَ","translation":"in order that you might gain mastery over them, and that, whenever you have mastered them, you might remember your Sustainer’s blessings and say: “Limitless in His glory is He who has made [all] this subservient to our use - since [but for Him,] we would not have been able to attain to it.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4338.mp3","surahId":43,"words":[{"id":14768,"position":1,"arabic":"لِتَسْتَوُۥا۟","translation":"তোমরা যেন স্হির হয়ে বসতে পারো","audioUrl":"wbw/043_013_001.mp3","charTypeName":"word"},{"id":14769,"position":2,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/043_013_002.mp3","charTypeName":"word"},{"id":14770,"position":3,"arabic":"ظُهُورِهِۦ","translation":"তাদের পিঠের","audioUrl":"wbw/043_013_003.mp3","charTypeName":"word"},{"id":14771,"position":4,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/043_013_004.mp3","charTypeName":"word"},{"id":14772,"position":5,"arabic":"تَذْكُرُوا۟","translation":"তোমরা স্মরণ করো","audioUrl":"wbw/043_013_005.mp3","charTypeName":"word"},{"id":14773,"position":6,"arabic":"نِعْمَةَ","translation":"অনুগ্রহের (কথা)","audioUrl":"wbw/043_013_006.mp3","charTypeName":"word"},{"id":14774,"position":7,"arabic":"رَبِّكُمْ","translation":"তোমাদের রবের","audioUrl":"wbw/043_013_007.mp3","charTypeName":"word"},{"id":14775,"position":8,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/043_013_008.mp3","charTypeName":"word"},{"id":14776,"position":9,"arabic":"ٱسْتَوَيْتُمْ","translation":"তোমরা চড়ে বসো","audioUrl":"wbw/043_013_009.mp3","charTypeName":"word"},{"id":14777,"position":10,"arabic":"عَلَيْهِ","translation":"তার উপর","audioUrl":"wbw/043_013_010.mp3","charTypeName":"word"},{"id":14778,"position":11,"arabic":"وَتَقُولُوا۟","translation":"এবং তোমরা বলো","audioUrl":"wbw/043_013_011.mp3","charTypeName":"word"},{"id":14779,"position":12,"arabic":"سُبْحَـٰنَ","translation":"\"মহান পবিত্র (আল্লাহ)","audioUrl":"wbw/043_013_012.mp3","charTypeName":"word"},{"id":14780,"position":13,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/043_013_013.mp3","charTypeName":"word"},{"id":14781,"position":14,"arabic":"سَخَّرَ","translation":"বশ করে দিয়েছেন","audioUrl":"wbw/043_013_014.mp3","charTypeName":"word"},{"id":14782,"position":15,"arabic":"لَنَا","translation":"আমাদের জন্যে","audioUrl":"wbw/043_013_015.mp3","charTypeName":"word"},{"id":14783,"position":16,"arabic":"هَـٰذَا","translation":"এটা","audioUrl":"wbw/043_013_016.mp3","charTypeName":"word"},{"id":14784,"position":17,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/043_013_017.mp3","charTypeName":"word"},{"id":14785,"position":18,"arabic":"كُنَّا","translation":"আমরা ছিলাম","audioUrl":"wbw/043_013_018.mp3","charTypeName":"word"},{"id":14786,"position":19,"arabic":"لَهُۥ","translation":"তাকে","audioUrl":"wbw/043_013_019.mp3","charTypeName":"word"},{"id":14787,"position":20,"arabic":"مُقْرِنِينَ","translation":"বশীভূতকারী","audioUrl":"wbw/043_013_020.mp3","charTypeName":"word"},{"id":14788,"position":21,"arabic":"١٣","translation":"(১৩)","audioUrl":null,"charTypeName":"end"}]},{"number":14,"arabic":"وَإِنَّآ إِلَىٰ رَبِّنَا لَمُنقَلِبُونَ","translation":"Hence, verily, it is unto Him that we must always turn.”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4339.mp3","surahId":43,"words":[{"id":15849,"position":1,"arabic":"وَإِنَّآ","translation":"এবং নিশ্চয়ই আমরা","audioUrl":"wbw/043_014_001.mp3","charTypeName":"word"},{"id":15850,"position":2,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/043_014_002.mp3","charTypeName":"word"},{"id":15851,"position":3,"arabic":"رَبِّنَا","translation":"আমাদের রবের","audioUrl":"wbw/043_014_003.mp3","charTypeName":"word"},{"id":15852,"position":4,"arabic":"لَمُنقَلِبُونَ","translation":"অবশ্যই প্রত্যাবর্তনকারী\"","audioUrl":"wbw/043_014_004.mp3","charTypeName":"word"},{"id":15853,"position":5,"arabic":"١٤","translation":"(১৪)","audioUrl":null,"charTypeName":"end"}]},{"number":15,"arabic":"وَجَعَلُوا۟ لَهُۥ مِنْ عِبَادِهِۦ جُزْءًا ۚ إِنَّ ٱلْإِنسَٰنَ لَكَفُورٌۭ مُّبِينٌ","translation":"AND YET, they attribute to Him offspring from among some of the beings created by Him! Verily, most obviously bereft of all gratitude is man!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4340.mp3","surahId":43,"words":[{"id":16968,"position":1,"arabic":"وَجَعَلُوا۟","translation":"এবং (এ সত্ত্বেও) সাব্যস্ত করেছে তারা","audioUrl":"wbw/043_015_001.mp3","charTypeName":"word"},{"id":16969,"position":2,"arabic":"لَهُۥ","translation":"তাঁর জন্যে","audioUrl":"wbw/043_015_002.mp3","charTypeName":"word"},{"id":16970,"position":3,"arabic":"مِنْ","translation":"মধ্য হ'তে (কতককে)","audioUrl":"wbw/043_015_003.mp3","charTypeName":"word"},{"id":16971,"position":4,"arabic":"عِبَادِهِۦ","translation":"তাঁর দাসদের","audioUrl":"wbw/043_015_004.mp3","charTypeName":"word"},{"id":16972,"position":5,"arabic":"جُزْءًا ۚ","translation":"একটি অংশ","audioUrl":"wbw/043_015_005.mp3","charTypeName":"word"},{"id":16974,"position":6,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/043_015_007.mp3","charTypeName":"word"},{"id":16975,"position":7,"arabic":"ٱلْإِنسَـٰنَ","translation":"মানুষ","audioUrl":"wbw/043_015_008.mp3","charTypeName":"word"},{"id":16976,"position":8,"arabic":"لَكَفُورٌۭ","translation":"অকৃতজ্ঞ অবশ্যই","audioUrl":"wbw/043_015_009.mp3","charTypeName":"word"},{"id":16977,"position":9,"arabic":"مُّبِينٌ","translation":"স্পষ্টই","audioUrl":"wbw/043_015_010.mp3","charTypeName":"word"},{"id":16978,"position":10,"arabic":"١٥","translation":"(১৫)","audioUrl":null,"charTypeName":"end"}]},{"number":16,"arabic":"أَمِ ٱتَّخَذَ مِمَّا يَخْلُقُ بَنَاتٍۢ وَأَصْفَىٰكُم بِٱلْبَنِينَ","translation":"Or [do you think], perchance, that out of all His creation He has chosen for Himself daughters, and favoured you with sons?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4341.mp3","surahId":43,"words":[{"id":18078,"position":1,"arabic":"أَمِ","translation":"তবে কি","audioUrl":"wbw/043_016_001.mp3","charTypeName":"word"},{"id":18079,"position":2,"arabic":"ٱتَّخَذَ","translation":"তিনি গ্রহণ করেছেন","audioUrl":"wbw/043_016_002.mp3","charTypeName":"word"},{"id":18080,"position":3,"arabic":"مِمَّا","translation":"তা হ'তে যা","audioUrl":"wbw/043_016_003.mp3","charTypeName":"word"},{"id":18081,"position":4,"arabic":"يَخْلُقُ","translation":"তিনি সৃষ্টি করেন","audioUrl":"wbw/043_016_004.mp3","charTypeName":"word"},{"id":18082,"position":5,"arabic":"بَنَاتٍۢ","translation":"অথচ কন্যারূপে","audioUrl":"wbw/043_016_005.mp3","charTypeName":"word"},{"id":18083,"position":6,"arabic":"وَأَصْفَىٰكُم","translation":"তোমাদেরকে নির্ধারণ করেছেন","audioUrl":"wbw/043_016_006.mp3","charTypeName":"word"},{"id":18084,"position":7,"arabic":"بِٱلْبَنِينَ","translation":"পুত্রদের দিয়ে","audioUrl":"wbw/043_016_007.mp3","charTypeName":"word"},{"id":18085,"position":8,"arabic":"١٦","translation":"(১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":17,"arabic":"وَإِذَا بُشِّرَ أَحَدُهُم بِمَا ضَرَبَ لِلرَّحْمَٰنِ مَثَلًۭا ظَلَّ وَجْهُهُۥ مُسْوَدًّۭا وَهُوَ كَظِيمٌ","translation":"For [thus it is:] if any of them is given the glad tiding of [the birth of] what he so readily attributes to the Most Gracious, his face darkens, and he is filled with suppressed anger:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4342.mp3","surahId":43,"words":[{"id":19079,"position":1,"arabic":"وَإِذَا","translation":"অথচ যখন","audioUrl":"wbw/043_017_001.mp3","charTypeName":"word"},{"id":19080,"position":2,"arabic":"بُشِّرَ","translation":"সুসংবাদ দেওয়া হয়","audioUrl":"wbw/043_017_002.mp3","charTypeName":"word"},{"id":19081,"position":3,"arabic":"أَحَدُهُم","translation":"তাদের কাউকে","audioUrl":"wbw/043_017_003.mp3","charTypeName":"word"},{"id":19082,"position":4,"arabic":"بِمَا","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/043_017_004.mp3","charTypeName":"word"},{"id":19083,"position":5,"arabic":"ضَرَبَ","translation":"সে আরোপ করে","audioUrl":"wbw/043_017_005.mp3","charTypeName":"word"},{"id":19084,"position":6,"arabic":"لِلرَّحْمَـٰنِ","translation":"দয়াময়ের জন্যে","audioUrl":"wbw/043_017_006.mp3","charTypeName":"word"},{"id":19085,"position":7,"arabic":"مَثَلًۭا","translation":"(কন্যা গ্রহণের) দৃষ্টান্ত হিসেবে","audioUrl":"wbw/043_017_007.mp3","charTypeName":"word"},{"id":19086,"position":8,"arabic":"ظَلَّ","translation":"হয়ে যায়","audioUrl":"wbw/043_017_008.mp3","charTypeName":"word"},{"id":19087,"position":9,"arabic":"وَجْهُهُۥ","translation":"তার মুখমন্ডল","audioUrl":"wbw/043_017_009.mp3","charTypeName":"word"},{"id":19088,"position":10,"arabic":"مُسْوَدًّۭا","translation":"কালো","audioUrl":"wbw/043_017_010.mp3","charTypeName":"word"},{"id":19089,"position":11,"arabic":"وَهُوَ","translation":"এ অবস্থায় সে","audioUrl":"wbw/043_017_011.mp3","charTypeName":"word"},{"id":19090,"position":12,"arabic":"كَظِيمٌ","translation":"দুশ্চিন্তাগ্রস্তও (হয়ে যায়)","audioUrl":"wbw/043_017_012.mp3","charTypeName":"word"},{"id":19091,"position":13,"arabic":"١٧","translation":"(১৭)","audioUrl":null,"charTypeName":"end"}]},{"number":18,"arabic":"أَوَمَن يُنَشَّؤُا۟ فِى ٱلْحِلْيَةِ وَهُوَ فِى ٱلْخِصَامِ غَيْرُ مُبِينٍۢ","translation":"“What! [Am I to have a daughter -] one who is to be reared [only] for the sake of ornament?” and thereupon he finds himself torn by a vague inner conflict.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4343.mp3","surahId":43,"words":[{"id":20199,"position":1,"arabic":"أَوَمَن","translation":"কি (আল্লাহর ভাগে সে সন্তান) যে","audioUrl":"wbw/043_018_001.mp3","charTypeName":"word"},{"id":20200,"position":2,"arabic":"يُنَشَّؤُا۟","translation":"লালিত পালিত হয়","audioUrl":"wbw/043_018_002.mp3","charTypeName":"word"},{"id":20201,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/043_018_003.mp3","charTypeName":"word"},{"id":20202,"position":4,"arabic":"ٱلْحِلْيَةِ","translation":"অলংকারের","audioUrl":"wbw/043_018_004.mp3","charTypeName":"word"},{"id":20203,"position":5,"arabic":"وَهُوَ","translation":"এবং সে","audioUrl":"wbw/043_018_005.mp3","charTypeName":"word"},{"id":20204,"position":6,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/043_018_006.mp3","charTypeName":"word"},{"id":20205,"position":7,"arabic":"ٱلْخِصَامِ","translation":"বিতর্কের","audioUrl":"wbw/043_018_007.mp3","charTypeName":"word"},{"id":20206,"position":8,"arabic":"غَيْرُ","translation":"নয়","audioUrl":"wbw/043_018_008.mp3","charTypeName":"word"},{"id":20207,"position":9,"arabic":"مُبِينٍۢ","translation":"সুস্পষ্ট","audioUrl":"wbw/043_018_009.mp3","charTypeName":"word"},{"id":20208,"position":10,"arabic":"١٨","translation":"(১৮)","audioUrl":null,"charTypeName":"end"}]},{"number":19,"arabic":"وَجَعَلُوا۟ ٱلْمَلَٰٓئِكَةَ ٱلَّذِينَ هُمْ عِبَٰدُ ٱلرَّحْمَٰنِ إِنَٰثًا ۚ أَشَهِدُوا۟ خَلْقَهُمْ ۚ سَتُكْتَبُ شَهَٰدَتُهُمْ وَيُسْـَٔلُونَ","translation":"And [yet] they claim that the angels - who in themselves are but beings created by the Most Gracious - are females: [but] did they witness their creation? This false claim of theirs will be recorded, and they will be called to account [for it on Judgment Day]!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4344.mp3","surahId":43,"words":[{"id":21267,"position":1,"arabic":"وَجَعَلُوا۟","translation":"এবং তারা গণ্য করে","audioUrl":"wbw/043_019_001.mp3","charTypeName":"word"},{"id":21268,"position":2,"arabic":"ٱلْمَلَـٰٓئِكَةَ","translation":"ফেরেশতাগণকে","audioUrl":"wbw/043_019_002.mp3","charTypeName":"word"},{"id":21269,"position":3,"arabic":"ٱلَّذِينَ","translation":"যারা (এমন যে)","audioUrl":"wbw/043_019_003.mp3","charTypeName":"word"},{"id":21270,"position":4,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/043_019_004.mp3","charTypeName":"word"},{"id":21271,"position":5,"arabic":"عِبَـٰدُ","translation":"দাস","audioUrl":"wbw/043_019_005.mp3","charTypeName":"word"},{"id":21272,"position":6,"arabic":"ٱلرَّحْمَـٰنِ","translation":"দয়াময়ের","audioUrl":"wbw/043_019_006.mp3","charTypeName":"word"},{"id":21273,"position":7,"arabic":"إِنَـٰثًا ۚ","translation":"নারীরূপে","audioUrl":"wbw/043_019_007.mp3","charTypeName":"word"},{"id":21275,"position":8,"arabic":"أَشَهِدُوا۟","translation":"কি তারা প্রত্যক্ষ করেছে","audioUrl":"wbw/043_019_009.mp3","charTypeName":"word"},{"id":21276,"position":9,"arabic":"خَلْقَهُمْ ۚ","translation":"তাদের সৃষ্টি","audioUrl":"wbw/043_019_010.mp3","charTypeName":"word"},{"id":21278,"position":10,"arabic":"سَتُكْتَبُ","translation":"অচিরেই লিখে রাখা হবে","audioUrl":"wbw/043_019_012.mp3","charTypeName":"word"},{"id":21279,"position":11,"arabic":"شَهَـٰدَتُهُمْ","translation":"তাদের সাক্ষ্য","audioUrl":"wbw/043_019_013.mp3","charTypeName":"word"},{"id":21280,"position":12,"arabic":"وَيُسْـَٔلُونَ","translation":"এবং তাদের জিজ্ঞেস করা হবে","audioUrl":"wbw/043_019_014.mp3","charTypeName":"word"},{"id":21281,"position":13,"arabic":"١٩","translation":"(১৯)","audioUrl":null,"charTypeName":"end"}]},{"number":20,"arabic":"وَقَالُوا۟ لَوْ شَآءَ ٱلرَّحْمَٰنُ مَا عَبَدْنَٰهُم ۗ مَّا لَهُم بِذَٰلِكَ مِنْ عِلْمٍ ۖ إِنْ هُمْ إِلَّا يَخْرُصُونَ","translation":"Yet they say, “Had [not] the Most Gracious so willed, we would never have worshipped them!” [But] they cannot have any knowledge of [His having willed] such a thing: they do nothing but guess.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4345.mp3","surahId":43,"words":[{"id":22369,"position":1,"arabic":"وَقَالُوا۟","translation":"এবং তারা বলে","audioUrl":"wbw/043_020_001.mp3","charTypeName":"word"},{"id":22370,"position":2,"arabic":"لَوْ","translation":"\"যদি","audioUrl":"wbw/043_020_002.mp3","charTypeName":"word"},{"id":22371,"position":3,"arabic":"شَآءَ","translation":"ইচ্ছে করতেন","audioUrl":"wbw/043_020_003.mp3","charTypeName":"word"},{"id":22372,"position":4,"arabic":"ٱلرَّحْمَـٰنُ","translation":"দয়াময়","audioUrl":"wbw/043_020_004.mp3","charTypeName":"word"},{"id":22373,"position":5,"arabic":"مَا","translation":"না\"","audioUrl":"wbw/043_020_005.mp3","charTypeName":"word"},{"id":22374,"position":6,"arabic":"عَبَدْنَـٰهُم ۗ","translation":"তাদের আমরা পূজা করতাম\"","audioUrl":"wbw/043_020_006.mp3","charTypeName":"word"},{"id":22376,"position":7,"arabic":"مَّا","translation":"নেই","audioUrl":"wbw/043_020_008.mp3","charTypeName":"word"},{"id":22377,"position":8,"arabic":"لَهُم","translation":"তাদের জন্যে","audioUrl":"wbw/043_020_009.mp3","charTypeName":"word"},{"id":22378,"position":9,"arabic":"بِذَٰلِكَ","translation":"এই সম্পর্কে","audioUrl":"wbw/043_020_010.mp3","charTypeName":"word"},{"id":22379,"position":10,"arabic":"مِنْ","translation":"কোনো","audioUrl":"wbw/043_020_011.mp3","charTypeName":"word"},{"id":22380,"position":11,"arabic":"عِلْمٍ ۖ","translation":"জ্ঞান","audioUrl":"wbw/043_020_012.mp3","charTypeName":"word"},{"id":22382,"position":12,"arabic":"إِنْ","translation":"না","audioUrl":"wbw/043_020_014.mp3","charTypeName":"word"},{"id":22383,"position":13,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/043_020_015.mp3","charTypeName":"word"},{"id":22384,"position":14,"arabic":"إِلَّا","translation":"এ ব্যতীত","audioUrl":"wbw/043_020_016.mp3","charTypeName":"word"},{"id":22385,"position":15,"arabic":"يَخْرُصُونَ","translation":"আন্দাজ অনুমান করে","audioUrl":"wbw/043_020_017.mp3","charTypeName":"word"},{"id":22386,"position":16,"arabic":"٢٠","translation":"(২০)","audioUrl":null,"charTypeName":"end"}]},{"number":21,"arabic":"أَمْ ءَاتَيْنَٰهُمْ كِتَٰبًۭا مِّن قَبْلِهِۦ فَهُم بِهِۦ مُسْتَمْسِكُونَ","translation":"Or have We, perchance, vouchsafed them, before this one, a revelation [to the contrary,] to which they are still holding fast?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4346.mp3","surahId":43,"words":[{"id":23488,"position":1,"arabic":"أَمْ","translation":"তবে কি","audioUrl":"wbw/043_021_001.mp3","charTypeName":"word"},{"id":23489,"position":2,"arabic":"ءَاتَيْنَـٰهُمْ","translation":"তাদেরকে আমরা দিয়েছি","audioUrl":"wbw/043_021_002.mp3","charTypeName":"word"},{"id":23490,"position":3,"arabic":"كِتَـٰبًۭا","translation":"কোন কিতাব (তার স্বপক্ষে)","audioUrl":"wbw/043_021_003.mp3","charTypeName":"word"},{"id":23491,"position":4,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/043_021_004.mp3","charTypeName":"word"},{"id":23492,"position":5,"arabic":"قَبْلِهِۦ","translation":"এর পূর্বে","audioUrl":"wbw/043_021_005.mp3","charTypeName":"word"},{"id":23493,"position":6,"arabic":"فَهُم","translation":"অতঃপর তারা","audioUrl":"wbw/043_021_006.mp3","charTypeName":"word"},{"id":23494,"position":7,"arabic":"بِهِۦ","translation":"তাকে","audioUrl":"wbw/043_021_007.mp3","charTypeName":"word"},{"id":23495,"position":8,"arabic":"مُسْتَمْسِكُونَ","translation":"দৃঢ়ভাবে ধারণকারী","audioUrl":"wbw/043_021_008.mp3","charTypeName":"word"},{"id":23496,"position":9,"arabic":"٢١","translation":"(২১)","audioUrl":null,"charTypeName":"end"}]},{"number":22,"arabic":"بَلْ قَالُوٓا۟ إِنَّا وَجَدْنَآ ءَابَآءَنَا عَلَىٰٓ أُمَّةٍۢ وَإِنَّا عَلَىٰٓ ءَاثَٰرِهِم مُّهْتَدُونَ","translation":"Nay, but they say, “Behold, We found our forefathers agreed on what to believe - and, verily, it is in their footsteps that we find our guidance!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4347.mp3","surahId":43,"words":[{"id":24519,"position":1,"arabic":"بَلْ","translation":"(না) বরং","audioUrl":"wbw/043_022_001.mp3","charTypeName":"word"},{"id":24520,"position":2,"arabic":"قَالُوٓا۟","translation":"তারা বলে","audioUrl":"wbw/043_022_002.mp3","charTypeName":"word"},{"id":24521,"position":3,"arabic":"إِنَّا","translation":"\"নিশ্চয়ই আমরা","audioUrl":"wbw/043_022_003.mp3","charTypeName":"word"},{"id":24522,"position":4,"arabic":"وَجَدْنَآ","translation":"আমরা পেয়েছি","audioUrl":"wbw/043_022_004.mp3","charTypeName":"word"},{"id":24523,"position":5,"arabic":"ءَابَآءَنَا