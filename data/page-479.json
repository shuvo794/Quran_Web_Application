{"id":479,"ayahs":[{"number":21,"arabic":"وَقَالُوا۟ لِجُلُودِهِمْ لِمَ شَهِدتُّمْ عَلَيْنَا ۖ قَالُوٓا۟ أَنطَقَنَا ٱللَّهُ ٱلَّذِىٓ أَنطَقَ كُلَّ شَىْءٍۢ وَهُوَ خَلَقَكُمْ أَوَّلَ مَرَّةٍۢ وَإِلَيْهِ تُرْجَعُونَ","translation":"And they will ask their skins, “Why did you bear witness against us?” - [and] these will reply: “God, who gives speech to all things, has given speech to us [as well]: for He [it is who] has created you in the first instance - and unto Him you are [now] brought back.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4239.mp3","surahId":41,"words":[{"id":23443,"position":1,"arabic":"وَقَالُوا۟","translation":"এবং তারা বলবে","audioUrl":"wbw/041_021_001.mp3","charTypeName":"word"},{"id":23444,"position":2,"arabic":"لِجُلُودِهِمْ","translation":"তাদের ত্বকগুলোকে","audioUrl":"wbw/041_021_002.mp3","charTypeName":"word"},{"id":23445,"position":3,"arabic":"لِمَ","translation":"\"কেন","audioUrl":"wbw/041_021_003.mp3","charTypeName":"word"},{"id":23446,"position":4,"arabic":"شَهِدتُّمْ","translation":"তোমরা সাক্ষ্য দিয়েছো","audioUrl":"wbw/041_021_004.mp3","charTypeName":"word"},{"id":23447,"position":5,"arabic":"عَلَيْنَا ۖ","translation":"আমাদের বিরুদ্ধে\"","audioUrl":"wbw/041_021_005.mp3","charTypeName":"word"},{"id":23449,"position":6,"arabic":"قَالُوٓا۟","translation":"তারা বলবে","audioUrl":"wbw/041_021_007.mp3","charTypeName":"word"},{"id":23450,"position":7,"arabic":"أَنطَقَنَا","translation":"\"আমাদের বাকশক্তি দিয়েছেন","audioUrl":"wbw/041_021_008.mp3","charTypeName":"word"},{"id":23451,"position":8,"arabic":"ٱللَّهُ","translation":"\"(সেই) আল্লাহ-ই","audioUrl":"wbw/041_021_009.mp3","charTypeName":"word"},{"id":23452,"position":9,"arabic":"ٱلَّذِىٓ","translation":"যিনি","audioUrl":"wbw/041_021_010.mp3","charTypeName":"word"},{"id":23453,"position":10,"arabic":"أَنطَقَ","translation":"বাকশক্তি দিয়েছেন","audioUrl":"wbw/041_021_011.mp3","charTypeName":"word"},{"id":23454,"position":11,"arabic":"كُلَّ","translation":"সব","audioUrl":"wbw/041_021_012.mp3","charTypeName":"word"},{"id":23455,"position":12,"arabic":"شَىْءٍۢ","translation":"কিছুকে","audioUrl":"wbw/041_021_013.mp3","charTypeName":"word"},{"id":23456,"position":13,"arabic":"وَهُوَ","translation":"এবং তিনি","audioUrl":"wbw/041_021_014.mp3","charTypeName":"word"},{"id":23457,"position":14,"arabic":"خَلَقَكُمْ","translation":"তোমাদেরকে সৃষ্টি করেছেন","audioUrl":"wbw/041_021_015.mp3","charTypeName":"word"},{"id":23458,"position":15,"arabic":"أَوَّلَ","translation":"প্রথম","audioUrl":"wbw/041_021_016.mp3","charTypeName":"word"},{"id":23459,"position":16,"arabic":"مَرَّةٍۢ","translation":"বার","audioUrl":"wbw/041_021_017.mp3","charTypeName":"word"},{"id":23460,"position":17,"arabic":"وَإِلَيْهِ","translation":"এবং তাঁরই দিকে","audioUrl":"wbw/041_021_018.mp3","charTypeName":"word"},{"id":23461,"position":18,"arabic":"تُرْجَعُونَ","translation":"তোমাদের ফিরিয়ে নেয়া হবে\"","audioUrl":"wbw/041_021_019.mp3","charTypeName":"word"},{"id":23462,"position":19,"arabic":"٢١","translation":"(২১)","audioUrl":null,"charTypeName":"end"}]},{"number":22,"arabic":"وَمَا كُنتُمْ تَسْتَتِرُونَ أَن يَشْهَدَ عَلَيْكُمْ سَمْعُكُمْ وَلَآ أَبْصَٰرُكُمْ وَلَا جُلُودُكُمْ وَلَٰكِن ظَنَنتُمْ أَنَّ ٱللَّهَ لَا يَعْلَمُ كَثِيرًۭا مِّمَّا تَعْمَلُونَ","translation":"And you did not try to hide [your sins] lest your hearing or your sight or your skins bear witness against you: nay, but you thought that God did not know much of what you were doing –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4240.mp3","surahId":41,"words":[{"id":24428,"position":1,"arabic":"وَمَا","translation":"আর না","audioUrl":"wbw/041_022_001.mp3","charTypeName":"word"},{"id":24429,"position":2,"arabic":"كُنتُمْ","translation":"তোমরা","audioUrl":"wbw/041_022_002.mp3","charTypeName":"word"},{"id":24430,"position":3,"arabic":"تَسْتَتِرُونَ","translation":"লুকাতে (তখন জানতেন)","audioUrl":"wbw/041_022_003.mp3","charTypeName":"word"},{"id":24431,"position":4,"arabic":"أَن","translation":"যে","audioUrl":"wbw/041_022_004.mp3","charTypeName":"word"},{"id":24432,"position":5,"arabic":"يَشْهَدَ","translation":"সাক্ষ্য দিবে","audioUrl":"wbw/041_022_005.mp3","charTypeName":"word"},{"id":24433,"position":6,"arabic":"عَلَيْكُمْ","translation":"তোমাদের বিরুদ্ধে","audioUrl":"wbw/041_022_006.mp3","charTypeName":"word"},{"id":24434,"position":7,"arabic":"سَمْعُكُمْ","translation":"তোমাদের কান","audioUrl":"wbw/041_022_007.mp3","charTypeName":"word"},{"id":24435,"position":8,"arabic":"وَلَآ","translation":"এবং না (জানতে)","audioUrl":"wbw/041_022_008.mp3","charTypeName":"word"},{"id":24436,"position":9,"arabic":"أَبْصَـٰرُكُمْ","translation":"তোমাদের চোখগুলো (সাক্ষ্য দিবে)","audioUrl":"wbw/041_022_009.mp3","charTypeName":"word"},{"id":24437,"position":10,"arabic":"وَلَا","translation":"আর না (জানতে)","audioUrl":"wbw/041_022_010.mp3","charTypeName":"word"},{"id":24438,"position":11,"arabic":"جُلُودُكُمْ","translation":"তোমাদের ত্বকগুলো (সাক্ষ্য দিবে)","audioUrl":"wbw/041_022_011.mp3","charTypeName":"word"},{"id":24439,"position":12,"arabic":"وَلَـٰكِن","translation":"কিন্তু","audioUrl":"wbw/041_022_012.mp3","charTypeName":"word"},{"id":24440,"position":13,"arabic":"ظَنَنتُمْ","translation":"তোমরা মনে করতে","audioUrl":"wbw/041_022_013.mp3","charTypeName":"word"},{"id":24441,"position":14,"arabic":"أَنَّ","translation":"যে","audioUrl":"wbw/041_022_014.mp3","charTypeName":"word"},{"id":24442,"position":15,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/041_022_015.mp3","charTypeName":"word"},{"id":24443,"position":16,"arabic":"لَا","translation":"না","audioUrl":"wbw/041_022_016.mp3","charTypeName":"word"},{"id":24444,"position":17,"arabic":"يَعْلَمُ","translation":"জানেন কিছুই","audioUrl":"wbw/041_022_017.mp3","charTypeName":"word"},{"id":24445,"position":18,"arabic":"كَثِيرًۭا","translation":"অনেক","audioUrl":"wbw/041_022_018.mp3","charTypeName":"word"},{"id":24446,"position":19,"arabic":"مِّمَّا","translation":"ঐ বিষয়কে যা","audioUrl":"wbw/041_022_019.mp3","charTypeName":"word"},{"id":24447,"position":20,"arabic":"تَعْمَلُونَ","translation":"তোমরা কাজ করতে","audioUrl":"wbw/041_022_020.mp3","charTypeName":"word"},{"id":24448,"position":21,"arabic":"٢٢","translation":"(২২)","audioUrl":null,"charTypeName":"end"}]},{"number":23,"arabic":"وَذَٰلِكُمْ ظَنُّكُمُ ٱلَّذِى ظَنَنتُم بِرَبِّكُمْ أَرْدَىٰكُمْ فَأَصْبَحْتُم مِّنَ ٱلْخَٰسِرِينَ","translation":"and that very thought which you thought about your Sustainer has brought you to perdition, and so now you find yourselves among the lost!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4241.mp3","surahId":41,"words":[{"id":25506,"position":1,"arabic":"وَذَٰلِكُمْ","translation":"এবং সেটা (ছিলো)","audioUrl":"wbw/041_023_001.mp3","charTypeName":"word"},{"id":25507,"position":2,"arabic":"ظَنُّكُمُ","translation":"তোমাদের ধারণা","audioUrl":"wbw/041_023_002.mp3","charTypeName":"word"},{"id":25508,"position":3,"arabic":"ٱلَّذِى","translation":"যা","audioUrl":"wbw/041_023_003.mp3","charTypeName":"word"},{"id":25509,"position":4,"arabic":"ظَنَنتُم","translation":"তোমরা ধারণা করেছিলে","audioUrl":"wbw/041_023_004.mp3","charTypeName":"word"},{"id":25510,"position":5,"arabic":"بِرَبِّكُمْ","translation":"সম্পর্কে রব তোমাদের","audioUrl":"wbw/041_023_005.mp3","charTypeName":"word"},{"id":25511,"position":6,"arabic":"أَرْدَىٰكُمْ","translation":"(এটাই) তোমাদেরকে ধ্বংস করেছে","audioUrl":"wbw/041_023_006.mp3","charTypeName":"word"},{"id":25512,"position":7,"arabic":"فَأَصْبَحْتُم","translation":"এখন তোমরা হয়েছো","audioUrl":"wbw/041_023_007.mp3","charTypeName":"word"},{"id":25513,"position":8,"arabic":"مِّنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/041_023_008.mp3","charTypeName":"word"},{"id":25514,"position":9,"arabic":"ٱلْخَـٰسِرِينَ","translation":"ক্ষতিগ্রস্তদের","audioUrl":"wbw/041_023_009.mp3","charTypeName":"word"},{"id":25515,"position":10,"arabic":"٢٣","translation":"(২৩)","audioUrl":null,"charTypeName":"end"}]},{"number":24,"arabic":"فَإِن يَصْبِرُوا۟ فَٱلنَّارُ مَثْوًۭى لَّهُمْ ۖ وَإِن يَسْتَعْتِبُوا۟ فَمَا هُم مِّنَ ٱلْمُعْتَبِينَ","translation":"And then, [even] if they endure [their lot] in patience, the fire will still be their abode; and if they pray to be allowed to make amends, they will not be allowed to do so:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4242.mp3","surahId":41,"words":[{"id":26576,"position":1,"arabic":"فَإِن","translation":"সুতরাং যদি","audioUrl":"wbw/041_024_001.mp3","charTypeName":"word"},{"id":26577,"position":2,"arabic":"يَصْبِرُوا۟","translation":"তারা ধৈর্য্য ধরে (আর নাই ধরে)","audioUrl":"wbw/041_024_002.mp3","charTypeName":"word"},{"id":26578,"position":3,"arabic":"فَٱلنَّارُ","translation":"জাহান্নাম তবুও","audioUrl":"wbw/041_024_003.mp3","charTypeName":"word"},{"id":26579,"position":4,"arabic":"مَثْوًۭى","translation":"আবাস","audioUrl":"wbw/041_024_004.mp3","charTypeName":"word"},{"id":26580,"position":5,"arabic":"لَّهُمْ ۖ","translation":"তাদের জন্যে","audioUrl":"wbw/041_024_005.mp3","charTypeName":"word"},{"id":26582,"position":6,"arabic":"وَإِن","translation":"এবং যদি","audioUrl":"wbw/041_024_007.mp3","charTypeName":"word"},{"id":26583,"position":7,"arabic":"يَسْتَعْتِبُوا۟","translation":"তারা অনুগ্রহ করতে চায়ও","audioUrl":"wbw/041_024_008.mp3","charTypeName":"word"},{"id":26584,"position":8,"arabic":"فَمَا","translation":"তবুও না","audioUrl":"wbw/041_024_009.mp3","charTypeName":"word"},{"id":26585,"position":9,"arabic":"هُم","translation":"তারা (হবে)","audioUrl":"wbw/041_024_010.mp3","charTypeName":"word"},{"id":26586,"position":10,"arabic":"مِّنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/041_024_011.mp3","charTypeName":"word"},{"id":26587,"position":11,"arabic":"ٱلْمُعْتَبِينَ","translation":"অনুগ্রহ প্রাপ্তদের","audioUrl":"wbw/041_024_012.mp3","charTypeName":"word"},{"id":26588,"position":12,"arabic":"٢٤","translation":"(২৪)","audioUrl":null,"charTypeName":"end"}]},{"number":25,"arabic":"۞ وَقَيَّضْنَا لَهُمْ قُرَنَآءَ فَزَيَّنُوا۟ لَهُم مَّا بَيْنَ أَيْدِيهِمْ وَمَا خَلْفَهُمْ وَحَقَّ عَلَيْهِمُ ٱلْقَوْلُ فِىٓ أُمَمٍۢ قَدْ خَلَتْ مِن قَبْلِهِم مِّنَ ٱلْجِنِّ وَٱلْإِنسِ ۖ إِنَّهُمْ كَانُوا۟ خَٰسِرِينَ","translation":"for [when they became obli­vious of Us,] We assigned to them [their own evil impulses as their] other selves, and these made appear goodly to them whatever lay open before them and whatever was beyond their ken. And so, the sentence [of doom] will have fallen due upon them together with the [other sinful] com­munities of invisible beings and humans that passed away before their time: verily, they [all] will indeed be lost!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4243.mp3","surahId":41,"words":[{"id":27586,"position":1,"arabic":"۞ وَقَيَّضْنَا","translation":"এবং আমরা নির্ধারণ করেছি","audioUrl":"wbw/041_025_002.mp3","charTypeName":"word"},{"id":27587,"position":2,"arabic":"لَهُمْ","translation":"তাদের জন্যে","audioUrl":"wbw/041_025_003.mp3","charTypeName":"word"},{"id":27588,"position":3,"arabic":"قُرَنَآءَ","translation":"(পথভ্রষ্ট) সঙ্গীদেরকে","audioUrl":"wbw/041_025_004.mp3","charTypeName":"word"},{"id":27589,"position":4,"arabic":"فَزَيَّنُوا۟","translation":"আর তারা শোভন করে দেখায়","audioUrl":"wbw/041_025_005.mp3","charTypeName":"word"},{"id":27590,"position":5,"arabic":"لَهُم","translation":"তাদেরকে","audioUrl":"wbw/041_025_006.mp3","charTypeName":"word"},{"id":27591,"position":6,"arabic":"مَّا","translation":"যা কিছু (আছে)","audioUrl":"wbw/041_025_007.mp3","charTypeName":"word"},{"id":27592,"position":7,"arabic":"بَيْنَ","translation":"সামনে","audioUrl":"wbw/041_025_008.mp3","charTypeName":"word"},{"id":27593,"position":8,"arabic":"أَيْدِيهِمْ","translation":"তাদের","audioUrl":"wbw/041_025_009.mp3","charTypeName":"word"},{"id":27594,"position":9,"arabic":"وَمَا","translation":"এবং যা কিছু আছে","audioUrl":"wbw/041_025_010.mp3","charTypeName":"word"},{"id":27595,"position":10,"arabic":"خَلْفَهُمْ","translation":"তাদের পিছনে","audioUrl":"wbw/041_025_011.mp3","charTypeName":"word"},{"id":27596,"position":11,"arabic":"وَحَقَّ","translation":"এবং বাস্তব হলো","audioUrl":"wbw/041_025_012.mp3","charTypeName":"word"},{"id":27597,"position":12,"arabic":"عَلَيْهِمُ","translation":"তাদের উপর","audioUrl":"wbw/041_025_013.mp3","charTypeName":"word"},{"id":27598,"position":13,"arabic":"ٱلْقَوْلُ","translation":"সেই বাণী (যা কার্যকর হয়েছে)","audioUrl":"wbw/041_025_014.mp3","charTypeName":"word"},{"id":27599,"position":14,"arabic":"فِىٓ","translation":"উপর","audioUrl":"wbw/041_025_015.mp3","charTypeName":"word"},{"id":27600,"position":15,"arabic":"أُمَمٍۢ","translation":"জাতিসমূহের (যারা)","audioUrl":"wbw/041_025_016.mp3","charTypeName":"word"},{"id":27601,"position":16,"arabic":"قَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/041_025_017.mp3","charTypeName":"word"},{"id":27602,"position":17,"arabic":"خَلَتْ","translation":"অতীত হয়েছে","audioUrl":"wbw/041_025_018.mp3","charTypeName":"word"},{"id":27603,"position":18,"arabic":"مِن","translation":"পূর্বের","audioUrl":"wbw/041_025_019.mp3","charTypeName":"word"},{"id":27604,"position":19,"arabic":"قَبْلِهِم","translation":"তাদের","audioUrl":"wbw/041_025_020.mp3","charTypeName":"word"},{"id":27605,"position":20,"arabic":"مِّنَ","translation":"মধ্য হ'তে","audioUrl":"wbw/041_025_021.mp3","charTypeName":"word"},{"id":27606,"position":21,"arabic":"ٱلْجِنِّ","translation":"জিনের","audioUrl":"wbw/041_025_022.mp3","charTypeName":"word"},{"id":27607,"position":22,"arabic":"وَٱلْإِنسِ ۖ","translation":"ও মানুষের","audioUrl":"wbw/041_025_023.mp3","charTypeName":"word"},{"id":27609,"position":23,"arabic":"إِنَّهُمْ","translation":"তারা নিশ্চয়ই","audioUrl":"wbw/041_025_025.mp3","charTypeName":"word"},{"id":27610,"position":24,"arabic":"كَانُوا۟","translation":"ছিলো","audioUrl":"wbw/041_025_026.mp3","charTypeName":"word"},{"id":27611,"position":25,"arabic":"خَـٰسِرِينَ","translation":"ক্ষতিগ্রস্ত","audioUrl":"wbw/041_025_027.mp3","charTypeName":"word"},{"id":27612,"position":26,"arabic":"٢٥","translation":"(২৫)","audioUrl":null,"charTypeName":"end"}]},{"number":26,"arabic":"وَقَالَ ٱلَّذِينَ كَفَرُوا۟ لَا تَسْمَعُوا۟ لِهَٰذَا ٱلْقُرْءَانِ وَٱلْغَوْا۟ فِيهِ لَعَلَّكُمْ تَغْلِبُونَ","translation":"NOW THOSE who are bent on denying the truth say [unto one another]: “Do not listen to this Qur’an, but rather talk frivolously about it, so that you might gain the upper hand!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4244.mp3","surahId":41,"words":[{"id":28619,"position":1,"arabic":"وَقَالَ","translation":"এবং বলে","audioUrl":"wbw/041_026_001.mp3","charTypeName":"word"},{"id":28620,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/041_026_002.mp3","charTypeName":"word"},{"id":28621,"position":3,"arabic":"كَفَرُوا۟","translation":"অবিশ্বাস করেছে","audioUrl":"wbw/041_026_003.mp3","charTypeName":"word"},{"id":28622,"position":4,"arabic":"لَا","translation":"\"না","audioUrl":"wbw/041_026_004.mp3","charTypeName":"word"},{"id":28623,"position":5,"arabic":"تَسْمَعُوا۟","translation":"তোমরা শুনো","audioUrl":"wbw/041_026_005.mp3","charTypeName":"word"},{"id":28624,"position":6,"arabic":"لِهَـٰذَا","translation":"এই","audioUrl":"wbw/041_026_006.mp3","charTypeName":"word"},{"id":28625,"position":7,"arabic":"ٱلْقُرْءَانِ","translation":"কুরআন","audioUrl":"wbw/041_026_007.mp3","charTypeName":"word"},{"id":28626,"position":8,"arabic":"وَٱلْغَوْا۟","translation":"এবং গোলমাল সৃষ্টি করো তোমরা","audioUrl":"wbw/041_026_008.mp3","charTypeName":"word"},{"id":28627,"position":9,"arabic":"فِيهِ","translation":"তার মধ্যে","audioUrl":"wbw/041_026_009.mp3","charTypeName":"word"},{"id":28628,"position":10,"arabic":"لَعَلَّكُمْ","translation":"তোমরা সম্ভবতঃ","audioUrl":"wbw/041_026_010.mp3","charTypeName":"word"},{"id":28629,"position":11,"arabic":"تَغْلِبُونَ","translation":"জয়ী হবে\"","audioUrl":"wbw/041_026_011.mp3","charTypeName":"word"},{"id":28630,"position":12,"arabic":"٢٦","translation":"(২৬)","audioUrl":null,"charTypeName":"end"}]},{"number":27,"arabic":"فَلَنُذِيقَنَّ ٱلَّذِينَ كَفَرُوا۟ عَذَابًۭا شَدِيدًۭا وَلَنَجْزِيَنَّهُمْ أَسْوَأَ ٱلَّذِى كَانُوا۟ يَعْمَلُونَ","translation":"But We shall most certainly give those who are [thus] bent on denying the truth a taste of suffering severe, and We shall most certainly requite them according to the worst of their deeds!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4245.mp3","surahId":41,"words":[{"id":29514,"position":1,"arabic":"فَلَنُذِيقَنَّ","translation":"সুতরাং আমরা আস্বাদন করাবোই","audioUrl":"wbw/041_027_001.mp3","charTypeName":"word"},{"id":29515,"position":2,"arabic":"ٱلَّذِينَ","translation":"(তাদেরকে) যারা","audioUrl":"wbw/041_027_002.mp3","charTypeName":"word"},{"id":29516,"position":3,"arabic":"كَفَرُوا۟","translation":"অবিশ্বাস করেছে","audioUrl":"wbw/041_027_003.mp3","charTypeName":"word"},{"id":29517,"position":4,"arabic":"عَذَابًۭا","translation":"শাস্তি","audioUrl":"wbw/041_027_004.mp3","charTypeName":"word"},{"id":29518,"position":5,"arabic":"شَدِيدًۭا","translation":"কঠোর","audioUrl":"wbw/041_027_005.mp3","charTypeName":"word"},{"id":29519,"position":6,"arabic":"وَلَنَجْزِيَنَّهُمْ","translation":"এবং আমরা তাদেরকে প্রতিফল দিবোই","audioUrl":"wbw/041_027_006.mp3","charTypeName":"word"},{"id":29520,"position":7,"arabic":"أَسْوَأَ","translation":"নিকৃষ্ট কাজের","audioUrl":"wbw/041_027_007.mp3","charTypeName":"word"},{"id":29521,"position":8,"arabic":"ٱلَّذِى","translation":"যা","audioUrl":"wbw/041_027_008.mp3","charTypeName":"word"},{"id":29522,"position":9,"arabic":"كَانُوا۟","translation":"তারা","audioUrl":"wbw/041_027_009.mp3","charTypeName":"word"},{"id":29523,"position":10,"arabic":"يَعْمَلُونَ","translation":"কাজ করেছিলো","audioUrl":"wbw/041_027_010.mp3","charTypeName":"word"},{"id":29524,"position":11,"arabic":"٢٧","translation":"(২৭)","audioUrl":null,"charTypeName":"end"}]},{"number":28,"arabic":"ذَٰلِكَ جَزَآءُ أَعْدَآءِ ٱللَّهِ ٱلنَّارُ ۖ لَهُمْ فِيهَا دَارُ ٱلْخُلْدِ ۖ جَزَآءًۢ بِمَا كَانُوا۟ بِـَٔايَٰتِنَا يَجْحَ