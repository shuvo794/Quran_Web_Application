{"id":97,"ayahs":[{"number":114,"arabic":"۞ لَّا خَيْرَ فِى كَثِيرٍۢ مِّن نَّجْوَىٰهُمْ إِلَّا مَنْ أَمَرَ بِصَدَقَةٍ أَوْ مَعْرُوفٍ أَوْ إِصْلَٰحٍۭ بَيْنَ ٱلنَّاسِ ۚ وَمَن يَفْعَلْ ذَٰلِكَ ٱبْتِغَآءَ مَرْضَاتِ ٱللَّهِ فَسَوْفَ نُؤْتِيهِ أَجْرًا عَظِيمًۭا","translation":"NO GOOD comes, as a rule, out of secret confabulations - saving such as are devoted to en­joining charity, or equitable dealings, or setting things to rights between people: and unto him who does this out of a longing for God's goodly acceptance We shall in time grant a mighty reward.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/607.mp3","surahId":4,"words":[{"id":75203,"position":1,"arabic":"۞ لَّا","translation":"নাই","audioUrl":"wbw/004_114_002.mp3","charTypeName":"word"},{"id":75204,"position":2,"arabic":"خَيْرَ","translation":"কোন কল্যাণ","audioUrl":"wbw/004_114_003.mp3","charTypeName":"word"},{"id":75205,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/004_114_004.mp3","charTypeName":"word"},{"id":75206,"position":4,"arabic":"كَثِيرٍۢ","translation":"অধিকাংশের","audioUrl":"wbw/004_114_005.mp3","charTypeName":"word"},{"id":75207,"position":5,"arabic":"مِّن","translation":"(থেকে)","audioUrl":"wbw/004_114_006.mp3","charTypeName":"word"},{"id":75208,"position":6,"arabic":"نَّجْوَىٰهُمْ","translation":"তাদের গোপন পরামর্শের","audioUrl":"wbw/004_114_007.mp3","charTypeName":"word"},{"id":75209,"position":7,"arabic":"إِلَّا","translation":"তবে (দোষ নেই তার শলাপরামর্শে)","audioUrl":"wbw/004_114_008.mp3","charTypeName":"word"},{"id":75210,"position":8,"arabic":"مَنْ","translation":"যে","audioUrl":"wbw/004_114_009.mp3","charTypeName":"word"},{"id":75211,"position":9,"arabic":"أَمَرَ","translation":"নির্দেশ দেয়","audioUrl":"wbw/004_114_010.mp3","charTypeName":"word"},{"id":75212,"position":10,"arabic":"بِصَدَقَةٍ","translation":"দান খয়রাতের","audioUrl":"wbw/004_114_011.mp3","charTypeName":"word"},{"id":75213,"position":11,"arabic":"أَوْ","translation":"বা","audioUrl":"wbw/004_114_012.mp3","charTypeName":"word"},{"id":75214,"position":12,"arabic":"مَعْرُوفٍ","translation":"সৎকাজের","audioUrl":"wbw/004_114_013.mp3","charTypeName":"word"},{"id":75215,"position":13,"arabic":"أَوْ","translation":"বা","audioUrl":"wbw/004_114_014.mp3","charTypeName":"word"},{"id":75216,"position":14,"arabic":"إِصْلَـٰحٍۭ","translation":"সন্ধি স্থাপনের","audioUrl":"wbw/004_114_015.mp3","charTypeName":"word"},{"id":75217,"position":15,"arabic":"بَيْنَ","translation":"মাঝে","audioUrl":"wbw/004_114_016.mp3","charTypeName":"word"},{"id":75218,"position":16,"arabic":"ٱلنَّاسِ ۚ","translation":"লোকদের","audioUrl":"wbw/004_114_017.mp3","charTypeName":"word"},{"id":75220,"position":17,"arabic":"وَمَن","translation":"এবং যে","audioUrl":"wbw/004_114_019.mp3","charTypeName":"word"},{"id":75221,"position":18,"arabic":"يَفْعَلْ","translation":"করে","audioUrl":"wbw/004_114_020.mp3","charTypeName":"word"},{"id":75222,"position":19,"arabic":"ذَٰلِكَ","translation":"এরূপ","audioUrl":"wbw/004_114_021.mp3","charTypeName":"word"},{"id":75223,"position":20,"arabic":"ٱبْتِغَآءَ","translation":"সন্ধানে","audioUrl":"wbw/004_114_022.mp3","charTypeName":"word"},{"id":75224,"position":21,"arabic":"مَرْضَاتِ","translation":"সন্তুষ্টির","audioUrl":"wbw/004_114_023.mp3","charTypeName":"word"},{"id":75225,"position":22,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/004_114_024.mp3","charTypeName":"word"},{"id":75226,"position":23,"arabic":"فَسَوْفَ","translation":"শীঘ্রই সেক্ষেত্রে","audioUrl":"wbw/004_114_025.mp3","charTypeName":"word"},{"id":75227,"position":24,"arabic":"نُؤْتِيهِ","translation":"তাকে আমরা দেব","audioUrl":"wbw/004_114_026.mp3","charTypeName":"word"},{"id":75228,"position":25,"arabic":"أَجْرًا","translation":"প্রতিফল","audioUrl":"wbw/004_114_027.mp3","charTypeName":"word"},{"id":75229,"position":26,"arabic":"عَظِيمًۭا","translation":"বিরাট","audioUrl":"wbw/004_114_028.mp3","charTypeName":"word"},{"id":75230,"position":27,"arabic":"١١٤","translation":"(১১৪)","audioUrl":null,"charTypeName":"end"}]},{"number":115,"arabic":"وَمَن يُشَاقِقِ ٱلرَّسُولَ مِنۢ بَعْدِ مَا تَبَيَّنَ لَهُ ٱلْهُدَىٰ وَيَتَّبِعْ غَيْرَ سَبِيلِ ٱلْمُؤْمِنِينَ نُوَلِّهِۦ مَا تَوَلَّىٰ وَنُصْلِهِۦ جَهَنَّمَ ۖ وَسَآءَتْ مَصِيرًا","translation":"But as for him who, after guidance has been vouchsafed to him, cuts himself off from the Apostle and follows a path other than that of the believers - him shall We leave unto that which he himself has chosen, and shall cause him to endure hell: and how evil a journey’s end!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/608.mp3","surahId":4,"words":[{"id":75403,"position":1,"arabic":"وَمَن","translation":"এবং যে","audioUrl":"wbw/004_115_001.mp3","charTypeName":"word"},{"id":75404,"position":2,"arabic":"يُشَاقِقِ","translation":"বিরুদ্ধাচারণ করে","audioUrl":"wbw/004_115_002.mp3","charTypeName":"word"},{"id":75405,"position":3,"arabic":"ٱلرَّسُولَ","translation":"রাসূলের","audioUrl":"wbw/004_115_003.mp3","charTypeName":"word"},{"id":75406,"position":4,"arabic":"مِنۢ","translation":"(থেকে)","audioUrl":"wbw/004_115_004.mp3","charTypeName":"word"},{"id":75407,"position":5,"arabic":"بَعْدِ","translation":"এরপরেও","audioUrl":"wbw/004_115_005.mp3","charTypeName":"word"},{"id":75408,"position":6,"arabic":"مَا","translation":"যা","audioUrl":"wbw/004_115_006.mp3","charTypeName":"word"},{"id":75409,"position":7,"arabic":"تَبَيَّنَ","translation":"সুস্পষ্ট হয়েছে","audioUrl":"wbw/004_115_007.mp3","charTypeName":"word"},{"id":75410,"position":8,"arabic":"لَهُ","translation":"তার কাছে","audioUrl":"wbw/004_115_008.mp3","charTypeName":"word"},{"id":75411,"position":9,"arabic":"ٱلْهُدَىٰ","translation":"সৎ পথ","audioUrl":"wbw/004_115_009.mp3","charTypeName":"word"},{"id":75412,"position":10,"arabic":"وَيَتَّبِعْ","translation":"ও অনুসরণ করে","audioUrl":"wbw/004_115_010.mp3","charTypeName":"word"},{"id":75413,"position":11,"arabic":"غَيْرَ","translation":"ব্যতীত","audioUrl":"wbw/004_115_011.mp3","charTypeName":"word"},{"id":75414,"position":12,"arabic":"سَبِيلِ","translation":"পথ","audioUrl":"wbw/004_115_012.mp3","charTypeName":"word"},{"id":75415,"position":13,"arabic":"ٱلْمُؤْمِنِينَ","translation":"মু'মিনদের (তাহলে)","audioUrl":"wbw/004_115_013.mp3","charTypeName":"word"},{"id":75416,"position":14,"arabic":"نُوَلِّهِۦ","translation":"তাকে ফিরাব আমরা","audioUrl":"wbw/004_115_014.mp3","charTypeName":"word"},{"id":75417,"position":15,"arabic":"مَا","translation":"(সে দিকেই) যে দিকে","audioUrl":"wbw/004_115_015.mp3","charTypeName":"word"},{"id":75418,"position":16,"arabic":"تَوَلَّىٰ","translation":"সে ফিরেছে","audioUrl":"wbw/004_115_016.mp3","charTypeName":"word"},{"id":75419,"position":17,"arabic":"وَنُصْلِهِۦ","translation":"ও তাকে দগ্ধ করব আমরা","audioUrl":"wbw/004_115_017.mp3","charTypeName":"word"},{"id":75420,"position":18,"arabic":"جَهَنَّمَ ۖ","translation":"জাহান্নামে","audioUrl":"wbw/004_115_018.mp3","charTypeName":"word"},{"id":75422,"position":19,"arabic":"وَسَآءَتْ","translation":"এবং (তা) কত নিকৃষ্ট","audioUrl":"wbw/004_115_020.mp3","charTypeName":"word"},{"id":75423,"position":20,"arabic":"مَصِيرًا","translation":"গন্তব্যস্থল","audioUrl":"wbw/004_115_021.mp3","charTypeName":"word"},{"id":75424,"position":21,"arabic":"١١٥","translation":"(১১৫)","audioUrl":null,"charTypeName":"end"}]},{"number":116,"arabic":"إِنَّ ٱللَّهَ لَا يَغْفِرُ أَن يُشْرَكَ بِهِۦ وَيَغْفِرُ مَا دُونَ ذَٰلِكَ لِمَن يَشَآءُ ۚ وَمَن يُشْرِكْ بِٱللَّهِ فَقَدْ ضَلَّ ضَلَٰلًۢا بَعِيدًا","translation":"VERILY, God does not forgive the ascribing of divinity to aught beside Him, although He forgives any lesser sin unto whomever He wills: for those who ascribe divinity to aught beside God have indeed gone far astray.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/609.mp3","surahId":4,"words":[{"id":75573,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/004_116_001.mp3","charTypeName":"word"},{"id":75574,"position":2,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/004_116_002.mp3","charTypeName":"word"},{"id":75575,"position":3,"arabic":"لَا","translation":"না","audioUrl":"wbw/004_116_003.mp3","charTypeName":"word"},{"id":75576,"position":4,"arabic":"يَغْفِرُ","translation":"মাফ করেন","audioUrl":"wbw/004_116_004.mp3","charTypeName":"word"},{"id":75577,"position":5,"arabic":"أَن","translation":"(যে)","audioUrl":"wbw/004_116_005.mp3","charTypeName":"word"},{"id":75578,"position":6,"arabic":"يُشْرَكَ","translation":"শিরক করাকে","audioUrl":"wbw/004_116_006.mp3","charTypeName":"word"},{"id":75579,"position":7,"arabic":"بِهِۦ","translation":"তার সাথে","audioUrl":"wbw/004_116_007.mp3","charTypeName":"word"},{"id":75580,"position":8,"arabic":"وَيَغْفِرُ","translation":"কিন্তু মাফ করবেন","audioUrl":"wbw/004_116_008.mp3","charTypeName":"word"},{"id":75581,"position":9,"arabic":"مَا","translation":"যা (আছে)","audioUrl":"wbw/004_116_009.mp3","charTypeName":"word"},{"id":75582,"position":10,"arabic":"دُونَ","translation":"ব্যতীত","audioUrl":"wbw/004_116_010.mp3","charTypeName":"word"},{"id":75583,"position":11,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/004_116_011.mp3","charTypeName":"word"},{"id":75584,"position":12,"arabic":"لِمَن","translation":"যাকে","audioUrl":"wbw/004_116_012.mp3","charTypeName":"word"},{"id":75585,"position":13,"arabic":"يَشَآءُ ۚ","translation":"তিনি ইচ্ছে করবেন","audioUrl":"wbw/004_116_013.mp3","charTypeName":"word"},{"id":75587,"position":14,"arabic":"وَمَن","translation":"ও যে","audioUrl":"wbw/004_116_015.mp3","charTypeName":"word"},{"id":75588,"position":15,"arabic":"يُشْرِكْ","translation":"শিরক করে","audioUrl":"wbw/004_116_016.mp3","charTypeName":"word"},{"id":75589,"position":16,"arabic":"بِٱللَّهِ","translation":"আল্লাহর সাথে","audioUrl":"wbw/004_116_017.mp3","charTypeName":"word"},{"id":75590,"position":17,"arabic":"فَقَدْ","translation":"নিশ্চয় অতঃপর","audioUrl":"wbw/004_116_018.mp3","charTypeName":"word"},{"id":75591,"position":18,"arabic":"ضَلَّ","translation":"সে পথভ্রষ্ট হয়েছে","audioUrl":"wbw/004_116_019.mp3","charTypeName":"word"},{"id":75592,"position":19,"arabic":"ضَلَـٰلًۢا","translation":"পথভ্রষ্টতায়","audioUrl":"wbw/004_116_020.mp3","charTypeName":"word"},{"id":75593,"position":20,"arabic":"بَعِيدًا","translation":"বহুদূরে","audioUrl":"wbw/004_116_021.mp3","charTypeName":"word"},{"id":75594,"position":21,"arabic":"١١٦","translation":"(১১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":117,"arabic":"إِن يَدْعُونَ مِن دُونِهِۦٓ إِلَّآ إِنَٰثًۭا وَإِن يَدْعُونَ إِلَّا شَيْطَٰنًۭا مَّرِيدًۭا","translation":"In His stead, they invoke only life­less symbols - thus invoking none but a rebellious Satan","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/610.mp3","surahId":4,"words":[{"id":75859,"position":1,"arabic":"إِن","translation":"না","audioUrl":"wbw/004_117_001.mp3","charTypeName":"word"},{"id":75860,"position":2,"arabic":"يَدْعُونَ","translation":"তারা ডাকে","audioUrl":"wbw/004_117_002.mp3","charTypeName":"word"},{"id":75861,"position":3,"arabic":"مِن","translation":"(থেকে)","audioUrl":"wbw/004_117_003.mp3","charTypeName":"word"},{"id":75862,"position":4,"arabic":"دُونِهِۦٓ","translation":"তাঁকে ছাড়া","audioUrl":"wbw/004_117_004.mp3","charTypeName":"word"},{"id":75863,"position":5,"arabic":"إِلَّآ","translation":"কিন্তু","audioUrl":"wbw/004_117_005.mp3","charTypeName":"word"},{"id":75864,"position":6,"arabic":"إِنَـٰثًۭا","translation":"দেবীদেরকে","audioUrl":"wbw/004_117_006.mp3","charTypeName":"word"},{"id":75865,"position":7,"arabic":"وَإِن","translation":"এবং না","audioUrl":"wbw/004_117_007.mp3","charTypeName":"word"},{"id":75866,"position":8,"arabic":"يَدْعُونَ","translation":"তারা ডাকে","audioUrl":"wbw/004_117_008.mp3","charTypeName":"word"},{"id":75867,"position":9,"arabic":"إِلَّا","translation":"এছাড়া","audioUrl":"wbw/004_117_009.mp3","charTypeName":"word"},{"id":75868,"position":10,"arabic":"شَيْطَـٰنًۭا","translation":"শয়তানকে","audioUrl":"wbw/004_117_010.mp3","charTypeName":"word"},{"id":758