":"তুমি দেখো,","audioUrl":"wbw/069_039_003.mp3","charTypeName":"word"},{"id":40598,"position":4,"arabic":"٣٩","translation":"(৩৯)","audioUrl":null,"charTypeName":"end"}]},{"number":40,"arabic":"إِنَّهُۥ لَقَوْلُ رَسُولٍۢ كَرِيمٍۢ","translation":"Behold, this [Qur’an] is indeed the [inspired] word of a noble apostle,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5363.mp3","surahId":69,"words":[{"id":41152,"position":1,"arabic":"إِنَّهُۥ","translation":"নিশ্চয় তা","audioUrl":"wbw/069_040_001.mp3","charTypeName":"word"},{"id":41153,"position":2,"arabic":"لَقَوْلُ","translation":"বানী অবশ্যই","audioUrl":"wbw/069_040_002.mp3","charTypeName":"word"},{"id":41154,"position":3,"arabic":"رَسُولٍۢ","translation":"একজন রসূল (এর)","audioUrl":"wbw/069_040_003.mp3","charTypeName":"word"},{"id":41155,"position":4,"arabic":"كَرِيمٍۢ","translation":"সম্মানিত","audioUrl":"wbw/069_040_004.mp3","charTypeName":"word"},{"id":41156,"position":5,"arabic":"٤٠","translation":"(৪০)","audioUrl":null,"charTypeName":"end"}]},{"number":41,"arabic":"وَمَا هُوَ بِقَوْلِ شَاعِرٍۢ ۚ قَلِيلًۭا مَّا تُؤْمِنُونَ","translation":"and is not – however little you may [be prepared to] believe it - the word of a poet;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5364.mp3","surahId":69,"words":[{"id":42179,"position":1,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/069_041_001.mp3","charTypeName":"word"},{"id":42180,"position":2,"arabic":"هُوَ","translation":"তা","audioUrl":"wbw/069_041_002.mp3","charTypeName":"word"},{"id":42181,"position":3,"arabic":"بِقَوْلِ","translation":"কথা","audioUrl":"wbw/069_041_003.mp3","charTypeName":"word"},{"id":42182,"position":4,"arabic":"شَاعِرٍۢ ۚ","translation":"কবির","audioUrl":"wbw/069_041_004.mp3","charTypeName":"word"},{"id":42184,"position":5,"arabic":"قَلِيلًۭا","translation":"কমই","audioUrl":"wbw/069_041_006.mp3","charTypeName":"word"},{"id":42185,"position":6,"arabic":"مَّا","translation":"যা","audioUrl":"wbw/069_041_007.mp3","charTypeName":"word"},{"id":42186,"position":7,"arabic":"تُؤْمِنُونَ","translation":"তোমরা ইমান আন","audioUrl":"wbw/069_041_008.mp3","charTypeName":"word"},{"id":42187,"position":8,"arabic":"٤١","translation":"(৪১)","audioUrl":null,"charTypeName":"end"}]},{"number":42,"arabic":"وَلَا بِقَوْلِ كَاهِنٍۢ ۚ قَلِيلًۭا مَّا تَذَكَّرُونَ","translation":"and neither is it - however little you may [be prepared to] take it to heart - the word of a soothsayer:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5365.mp3","surahId":69,"words":[{"id":43018,"position":1,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/069_042_001.mp3","charTypeName":"word"},{"id":43019,"position":2,"arabic":"بِقَوْلِ","translation":"বানী","audioUrl":"wbw/069_042_002.mp3","charTypeName":"word"},{"id":43020,"position":3,"arabic":"كَاهِنٍۢ ۚ","translation":"কোন গণকের","audioUrl":"wbw/069_042_003.mp3","charTypeName":"word"},{"id":43022,"position":4,"arabic":"قَلِيلًۭا","translation":"কমই","audioUrl":"wbw/069_042_005.mp3","charTypeName":"word"},{"id":43023,"position":5,"arabic":"مَّا","translation":"যা","audioUrl":"wbw/069_042_006.mp3","charTypeName":"word"},{"id":43024,"position":6,"arabic":"تَذَكَّرُونَ","translation":"তোমরা উপদেশ গ্রহণ কর","audioUrl":"wbw/069_042_007.mp3","charTypeName":"word"},{"id":43025,"position":7,"arabic":"٤٢","translation":"(৪২)","audioUrl":null,"charTypeName":"end"}]},{"number":43,"arabic":"تَنزِيلٌۭ مِّن رَّبِّ ٱلْعَٰلَمِينَ","translation":"[it is] a revelation from the Sustainer of all the worlds.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5366.mp3","surahId":69,"words":[{"id":43710,"position":1,"arabic":"تَنزِيلٌۭ","translation":"নাযিলকৃত","audioUrl":"wbw/069_043_001.mp3","charTypeName":"word"},{"id":43711,"position":2,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/069_043_002.mp3","charTypeName":"word"},{"id":43712,"position":3,"arabic":"رَّبِّ","translation":"রবের","audioUrl":"wbw/069_043_003.mp3","charTypeName":"word"},{"id":43713,"position":4,"arabic":"ٱلْعَـٰلَمِينَ","translation":"মহাবিশ্বের","audioUrl":"wbw/069_043_004.mp3","charTypeName":"word"},{"id":43714,"position":5,"arabic":"٤٣","translation":"(৪৩)","audioUrl":null,"charTypeName":"end"}]},{"number":44,"arabic":"وَلَوْ تَقَوَّلَ عَلَيْنَا بَعْضَ ٱلْأَقَاوِيلِ","translation":"Now if he [whom We have entrusted with it] had dared to attribute some [of his own] sayings unto Us,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5367.mp3","surahId":69,"words":[{"id":44524,"position":1,"arabic":"وَلَوْ","translation":"এবং যদি","audioUrl":"wbw/069_044_001.mp3","charTypeName":"word"},{"id":44525,"position":2,"arabic":"تَقَوَّلَ","translation":"কথা বানাত","audioUrl":"wbw/069_044_002.mp3","charTypeName":"word"},{"id":44526,"position":3,"arabic":"عَلَيْنَا","translation":"আমাদের বিপক্ষে","audioUrl":"wbw/069_044_003.mp3","charTypeName":"word"},{"id":44527,"position":4,"arabic":"بَعْضَ","translation":"কিছু","audioUrl":"wbw/069_044_004.mp3","charTypeName":"word"},{"id":44528,"position":5,"arabic":"ٱلْأَقَاوِيلِ","translation":"কথা","audioUrl":"wbw/069_044_005.mp3","charTypeName":"word"},{"id":44529,"position":6,"arabic":"٤٤","translation":"(৪৪)","audioUrl":null,"charTypeName":"end"}]},{"number":45,"arabic":"لَأَخَذْنَا مِنْهُ بِٱلْيَمِينِ","translation":"We would indeed have seized him by his right hand,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5368.mp3","surahId":69,"words":[{"id":45227,"position":1,"arabic":"لَأَخَذْنَا","translation":"অবশ্যই আমরা ধরতাম","audioUrl":"wbw/069_045_001.mp3","charTypeName":"word"},{"id":45228,"position":2,"arabic":"مِنْهُ","translation":"তাকে","audioUrl":"wbw/069_045_002.mp3","charTypeName":"word"},{"id":45229,"position":3,"arabic":"بِٱلْيَمِينِ","translation":"ডান হাত দ্বারা;","audioUrl":"wbw/069_045_003.mp3","charTypeName":"word"},{"id":45230,"position":4,"arabic":"٤٥","translation":"(৪৫)","audioUrl":null,"charTypeName":"end"}]},{"number":46,"arabic":"ثُمَّ ل