ous!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5371.mp3","surahId":69,"words":[{"id":47088,"position":1,"arabic":"وَإِنَّهُۥ","translation":"এবং তা","audioUrl":"wbw/069_048_001.mp3","charTypeName":"word"},{"id":47089,"position":2,"arabic":"لَتَذْكِرَةٌۭ","translation":"অবশ্যই উপদেশ","audioUrl":"wbw/069_048_002.mp3","charTypeName":"word"},{"id":47090,"position":3,"arabic":"لِّلْمُتَّقِينَ","translation":"মুত্তাকীদের","audioUrl":"wbw/069_048_003.mp3","charTypeName":"word"},{"id":47091,"position":4,"arabic":"٤٨","translation":"(৪৮)","audioUrl":null,"charTypeName":"end"}]},{"number":49,"arabic":"وَإِنَّا لَنَعْلَمُ أَنَّ مِنكُم مُّكَذِّبِينَ","translation":"And, behold, well do We know that among you are such as will give the lie to it:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5372.mp3","surahId":69,"words":[{"id":47934,"position":1,"arabic":"وَإِنَّا","translation":"এবং নিশ্চয় আমরা","audioUrl":"wbw/069_049_001.mp3","charTypeName":"word"},{"id":47935,"position":2,"arabic":"لَنَعْلَمُ","translation":"অবশ্যই জানি","audioUrl":"wbw/069_049_002.mp3","charTypeName":"word"},{"id":47936,"position":3,"arabic":"أَنَّ","translation":"যে","audioUrl":"wbw/069_049_003.mp3","charTypeName":"word"},{"id":47937,"position":4,"arabic":"مِنكُم","translation":"তোমাদের মধ্যে","audioUrl":"wbw/069_049_004.mp3","charTypeName":"word"},{"id":47938,"position":5,"arabic":"مُّكَذِّبِينَ","translation":"অস্বীকারকারীরা (সম্পূর্ণ).","audioUrl":"wbw/069_049_005.mp3","charTypeName":"word"},{"id":47939,"position":6,"arabic":"٤٩","translation":"(৪৯)","audioUrl":null,"charTypeName":"end"}]},{"number":50,"arabic":"وَإِنَّهُۥ لَحَسْرَةٌ عَلَى ٱلْكَٰفِرِينَ","translation":"yet, behold, this [rejection] will indeed become a source of bitter regret for all who deny the truth [of God's revelation] –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5373.mp3","surahId":69,"words":[{"id":48697,"position":1,"arabic":"وَإِنَّهُۥ","translation":"এবং নিশ্চয় তা","audioUrl":"wbw/069_050_001.mp3","charTypeName":"word"},{"id":48698,"position":2,"arabic":"لَحَسْرَةٌ","translation":"আক্ষেপের","audioUrl":"wbw/069_050_002.mp3","charTypeName":"word"},{"id":48699,"position":3,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/069_050_003.mp3","charTypeName":"word"},{"id":48700,"position":4,"arabic":"ٱلْكَـٰفِرِينَ","translation":"কাফিরদের.","audioUrl":"wbw/069_050_004.mp3","charTypeName":"word"},{"id":48701,"position":5,"arabic":"٥٠","translation":"(৫০)","audioUrl":null,"charTypeName":"end"}]},{"number":51,"arabic":"وَإِنَّهُۥ لَحَقُّ ٱلْيَقِينِ","translation":"for, verily, it is truth absolute!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5374.mp3","surahId":69,"words":[{"id":49239,"position":1,"arabic":"وَإِنَّهُۥ","translation":"ও নিশ্চয় তা","audioUrl":"wbw/069_051_001.mp3","charTypeName":"word"},{"id":49240,"position":2,"arabic":"لَحَقُّ","translation":"অবশ্যই সত্য","audioUrl":"wbw/069_051_002.mp3","charTypeName":"word"},{"id":49241,"position":3,"arabic":"ٱلْيَقِينِ","translation":"সুনিশ্চিত","audioUrl":"wbw/069_051_003.mp3","charTypeName":"word"},{"id":49242,"position":4,"arabic":"٥١","translation":"(৫১)","audioUrl":null,"charTypeName":"end"}]},{"number":52,"arabic":"فَسَبِّحْ بِٱسْمِ رَبِّكَ ٱلْعَظِيمِ","translation":"Extol, then the limitless glory of thy Sustainer's mighty name!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5375.mp3","surahId":69,"words":[{"id":49973,"position":1,"arabic":"فَسَبِّحْ","translation":"অতএব তাসবীহ পাঠ কর","audioUrl":"wbw/069_052_001.mp3","charTypeName":"word"},{"id":49974,"position":2,"arabic":"بِٱسْمِ","translation":"নামের","audioUrl":"wbw/069_052_002.mp3","charTypeName":"word"},{"id":49975,"position":3,"arabic":"رَبِّكَ","translation":"তোমার রবের","audioUrl":"wbw/069_052_003.mp3","charTypeName":"word"},{"id":49976,"position":4,"arabic":"ٱلْعَظِيمِ","translation":"মহান","audioUrl":"wbw/069_052_004.mp3","charTypeName":"word"},{"id":49977,"position":5,