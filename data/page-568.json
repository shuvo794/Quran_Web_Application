{"id":568,"ayahs":[{"number":35,"arabic":"فَلَيْسَ لَهُ ٱلْيَوْمَ هَٰهُنَا حَمِيمٌۭ","translation":"and so, no friend has here today,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5358.mp3","surahId":69,"words":[{"id":37301,"position":1,"arabic":"فَلَيْسَ","translation":"নাই অতএব","audioUrl":"wbw/069_035_001.mp3","charTypeName":"word"},{"id":37302,"position":2,"arabic":"لَهُ","translation":"তার জন্য","audioUrl":"wbw/069_035_002.mp3","charTypeName":"word"},{"id":37303,"position":3,"arabic":"ٱلْيَوْمَ","translation":"আজ","audioUrl":"wbw/069_035_003.mp3","charTypeName":"word"},{"id":37304,"position":4,"arabic":"هَـٰهُنَا","translation":"এখানে","audioUrl":"wbw/069_035_004.mp3","charTypeName":"word"},{"id":37305,"position":5,"arabic":"حَمِيمٌۭ","translation":"কোন অন্তরঙ্গ বন্ধু,","audioUrl":"wbw/069_035_005.mp3","charTypeName":"word"},{"id":37306,"position":6,"arabic":"٣٥","translation":"(৩৫)","audioUrl":null,"charTypeName":"end"}]},{"number":36,"arabic":"وَلَا طَعَامٌ إِلَّا مِنْ غِسْلِينٍۢ","translation":"nor any food save the filth","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5359.mp3","surahId":69,"words":[{"id":38032,"position":1,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/069_036_001.mp3","charTypeName":"word"},{"id":38033,"position":2,"arabic":"طَعَامٌ","translation":"খাবার","audioUrl":"wbw/069_036_002.mp3","charTypeName":"word"},{"id":38034,"position":3,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/069_036_003.mp3","charTypeName":"word"},{"id":38035,"position":4,"arabic":"مِنْ","translation":"থেকে","audioUrl":"wbw/069_036_004.mp3","charTypeName":"word"},{"id":38036,"position":5,"arabic":"غِسْلِينٍۢ","translation":"ক্ষতনিংস্রিত রস","audioUrl":"wbw/069_036_005.mp3","charTypeName":"word"},{"id":38037,"position":6,"arabic":"٣٦","translation":"(৩৬)","audioUrl":null,"charTypeName":"end"}]},{"number":37,"arabic":"لَّا يَأْكُلُهُۥٓ إِلَّا ٱلْخَٰطِـُٔونَ","translation":"which none but the sinners eat!\"","audio"