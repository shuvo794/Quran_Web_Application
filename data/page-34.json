{"id":34,"ayahs":[{"number":216,"arabic":"كُتِبَ عَلَيْكُمُ ٱلْقِتَالُ وَهُوَ كُرْهٌۭ لَّكُمْ ۖ وَعَسَىٰٓ أَن تَكْرَهُوا۟ شَيْـًۭٔا وَهُوَ خَيْرٌۭ لَّكُمْ ۖ وَعَسَىٰٓ أَن تُحِبُّوا۟ شَيْـًۭٔا وَهُوَ شَرٌّۭ لَّكُمْ ۗ وَٱللَّهُ يَعْلَمُ وَأَنتُمْ لَا تَعْلَمُونَ","translation":"FIGHTING is ordained for you, even though it be hateful to you; but it may well be that you hate a thing the while it is good for you, and it may well be that you love a thing the while it is bad for you: and God knows, whereas you do not know.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/223.mp3","surahId":2,"words":[{"id":85822,"position":1,"arabic":"كُتِبَ","translation":"ফরজ করা হল","audioUrl":"wbw/002_216_001.mp3","charTypeName":"word"},{"id":85823,"position":2,"arabic":"عَلَيْكُمُ","translation":"তোমাদের ওপর","audioUrl":"wbw/002_216_002.mp3","charTypeName":"word"},{"id":85824,"position":3,"arabic":"ٱلْقِتَالُ","translation":"যুদ্ধ","audioUrl":"wbw/002_216_003.mp3","charTypeName":"word"},{"id":85825,"position":4,"arabic":"وَهُوَ","translation":"অথচ তা","audioUrl":"wbw/002_216_004.mp3","charTypeName":"word"},{"id":85826,"position":5,"arabic":"كُرْهٌۭ","translation":"অপ্রিয়","audioUrl":"wbw/002_216_005.mp3","charTypeName":"word"},{"id":85827,"position":6,"arabic":"لَّكُمْ ۖ","translation":"তোমাদের কাছে","audioUrl":"wbw/002_216_006.mp3","charTypeName":"word"},{"id":85829,"position":7,"arabic":"وَعَسَىٰٓ","translation":"কিন্তু হতে পারে","audioUrl":"wbw/002_216_008.mp3","charTypeName":"word"},{"id":85830,"position":8,"arabic":"أَن","translation":"যে","audioUrl":"wbw/002_216_009.mp3","charTypeName":"word"},{"id":85831,"position":9,"arabic":"تَكْرَهُوا۟","translation":"তোমরা অপছন্দ কর","audioUrl":"wbw/002_216_010.mp3","charTypeName":"word"},{"id":85832,"position":10,"arabic":"شَيْـًۭٔا","translation":"কোনো জিনিস","audioUrl":"wbw/002_216_011.mp3","charTypeName":"word"},{"id":85833,"position":11,"arabic":"وَهُوَ","translation":"অথচ তা","audioUrl":"wbw/002_216_012.mp3","charTypeName":"word"},{"id":85834,"position":12,"arabic":"خَيْرٌۭ","translation":"কল্যাণকর","audioUrl":"wbw/002_216_013.mp3","charTypeName":"word"},{"id":85835,"position":13,"arabic":"لَّكُمْ ۖ","translation":"তোমাদের জন্যে","audioUrl":"wbw/002_216_014.mp3","charTypeName":"word"},{"id":85837,"position":14,"arabic":"وَعَسَىٰٓ","translation":"আবার হতে পারে","audioUrl":"wbw/002_216_016.mp3","charTypeName":"word"},{"id":85838,"position":15,"arabic":"أَن","translation":"যে","audioUrl":"wbw/002_216_017.mp3","charTypeName":"word"},{"id":85839,"position":16,"arabic":"تُحِبُّوا۟","translation":"তোমরা পছন্দ কর","audioUrl":"wbw/002_216_018.mp3","charTypeName":"word"},{"id":85840,"position":17,"arabic":"شَيْـًۭٔا","translation":"কোনো জিনিস","audioUrl":"wbw/002_216_019.mp3","charTypeName":"word"},{"id":85841,"position":18,"arabic":"وَهُوَ","translation":"অথচ তা","audioUrl":"wbw/002_216_020.mp3","charTypeName":"word"},{"id":85842,"position":19,"arabic":"شَرٌّۭ","translation":"অকল্যাণকর","audioUrl":"wbw/002_216_021.mp3","charTypeName":"word"},{"id":85843,"position":20,"arabic":"لَّكُمْ ۗ","translation":"তোমাদের জন্যে","audioUrl":"wbw/002_216_022.mp3","charTypeName":"word"},{"id":85845,"position":21,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/002_216_024.mp3","charTypeName":"word"},{"id":85846,"position":22,"arabic":"يَعْلَمُ","translation":"জানেন","audioUrl":"wbw/002_216_025.mp3","charTypeName":"word"},{"id":85847,"position":23,"arabic":"وَأَنتُمْ","translation":"কিন্তু তোমরা","audioUrl":"wbw/002_216_026.mp3","charTypeName":"word"},{"id":85848,"position":24,"arabic":"لَا","translation":"না","audioUrl":"wbw/002_216_027.mp3","charTypeName":"word"},{"id":85849,"position":25,"arabic":"تَعْلَمُونَ","translation":"জান","audioUrl":"wbw/002_216_028.mp3","charTypeName":"word"},{"id":85850,"position":26,"arabic":"٢١٦","translation":"(২১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":217,"arabic":"يَسْـَٔلُونَكَ عَنِ ٱلشَّهْرِ ٱلْحَرَامِ قِتَالٍۢ فِيهِ ۖ قُلْ قِتَالٌۭ فِيهِ كَبِيرٌۭ ۖ وَصَدٌّ عَن سَبِيلِ ٱللَّهِ وَكُفْرٌۢ بِهِۦ وَٱلْمَسْجِدِ ٱلْحَرَامِ وَإِخْرَاجُ أَهْلِهِۦ مِنْهُ أَكْبَرُ عِندَ ٱللَّهِ ۚ وَٱلْفِتْنَةُ أَكْبَرُ مِنَ ٱلْقَتْلِ ۗ وَلَا يَزَالُونَ يُقَٰتِلُونَكُمْ حَتَّىٰ يَرُدُّوكُمْ عَن دِينِكُمْ إِنِ ٱسْتَطَٰعُوا۟ ۚ وَمَن يَرْتَدِدْ مِنكُمْ عَن دِينِهِۦ فَيَمُتْ وَهُوَ كَافِرٌۭ فَأُو۟لَٰٓئِكَ حَبِطَتْ أَعْمَٰلُهُمْ فِى ٱلدُّنْيَا وَٱلْءَاخِرَةِ ۖ وَأُو۟لَٰٓئِكَ أَصْحَٰبُ ٱلنَّارِ ۖ هُمْ فِيهَا خَٰلِدُونَ","translation":"They will ask thee about fighting in the sacred month. Say: \"Fighting in it is an awesome thing (grave transgression); but turning men away from the path of God and denying Him, and [turning them away from] the Inviolable House of Worship and expelling its people there from - [all this] is yet more awesome (greater transgression) in the sight of God, since oppression is more awesome (greater transgression) than killing.\" [Your enemies] will not cease to fight against you till they have turned you away from your faith, if they can. But if any of you should turn away from his faith and die as a denier of the truth - these it is whose works will go for nought in this world and in the life to come; and these it is who are destined for the fire, therein to abide.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/224.mp3","surahId":2,"words":[{"id":85859,"position":1,"arabic":"يَسْـَٔلُونَكَ","translation":"তোমাকে প্রশ্ন করে তারা","audioUrl":"wbw/002_217_001.mp3","charTypeName":"word"},{"id":85860,"position":2,"arabic":"عَنِ","translation":"সম্পর্কে","audioUrl":"wbw/002_217_002.mp3","charTypeName":"word"},{"id":85861,"position":3,"arabic":"ٱلشَّهْرِ","translation":"মাসে","audioUrl":"wbw/002_217_003.mp3","charTypeName":"word"},{"id":85862,"position":4,"arabic":"ٱلْحَرَامِ","translation":"নিষিদ্ধ","audioUrl":"wbw/002_217_004.mp3","charTypeName":"word"},{"id":85863,"position":5,"arabic":"قِتَالٍۢ","translation":"যুদ্ধ করা","audioUrl":"wbw/002_217_005.mp3","charTypeName":"word"},{"id":85864,"position":6,"arabic":"فِيهِ ۖ","translation":"তার মধ্যে","audioUrl":"wbw/002_217_006.mp3","charTypeName":"word"},{"id":85866,"position":7,"arabic":"قُلْ","translation":"তুমি বলো","audioUrl":"wbw/002_217_008.mp3","charTypeName":"word"},{"id":85867,"position":8,"arabic":"قِتَالٌۭ","translation":"যুদ্ধ করা","audioUrl":"wbw/002_217_009.mp3","charTypeName":"word"},{"id":85868,"position":9,"arabic":"فِيهِ","translation":"তার মধ্যে","audioUrl":"wbw/002_217_010.mp3","charTypeName":"word"},{"id":85869,"position":10,"arabic":"كَبِيرٌۭ ۖ","translation":"বড় (পাপ)","audioUrl":"wbw/002_217_011.mp3","charTypeName":"word"},{"id":85871,"position":11,"arabic":"وَصَدٌّ","translation":"কিন্তু বাধাদেওয়া","audioUrl":"wbw/002_217_013.mp3","charTypeName":"word"},{"id":85872,"position":12,"arabic":"عَن","translation":"হতে","audioUrl":"wbw/002_217_014.mp3","charTypeName":"word"},{"id":85873,"position":13,"arabic":"سَبِيلِ","translation":"পথ","audioUrl":"wbw/002_217_015.mp3","charTypeName":"word"},{"id":85874,"position":14,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/002_217_016.mp3","charTypeName":"word"},{"id":85875,"position":15,"arabic":"وَكُفْرٌۢ","translation":"ও অস্বীকার করা","audioUrl":"wbw/002_217_017.mp3","charTypeName":"word"},{"id":85876,"position":16,"arabic":"بِهِۦ","translation":"তার প্রতি","audioUrl":"wbw/002_217_018.mp3","charTypeName":"word"},{"id":85877,"position":17,"arabic":"وَٱلْمَسْجِدِ","translation":"ও মসজিদে","audioUrl":"wbw/002_217_019.mp3","charTypeName":"word"},{"id":85878,"position":18,"arabic":"ٱلْحَرَامِ","translation":"হারামে (যেতে বাধাদান)","audioUrl":"wbw/002_217_020.mp3","charTypeName":"word"},{"id":85879,"position":19,"arabic":"وَإِخْرَاجُ","translation":"ও বের করে দেওয়া","audioUrl":"wbw/002_217_021.mp3","charTypeName":"word"},{"id":85880,"position":20,"arabic":"أَهْلِهِۦ","translation":"তার বাসিন্দাদেরকে","audioUrl":"wbw/002_217_022.mp3","charTypeName":"word"},{"id":85881,"position":21,"arabic":"مِنْهُ","translation":"তা থেকে","audioUrl":"wbw/00