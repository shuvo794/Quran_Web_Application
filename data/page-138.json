{"id":138,"ayahs":[{"number":82,"arabic":"ٱلَّذِينَ ءَامَنُوا۟ وَلَمْ يَلْبِسُوٓا۟ إِيمَٰنَهُم بِظُلْمٍ أُو۟لَٰٓئِكَ لَهُمُ ٱلْأَمْنُ وَهُم مُّهْتَدُونَ","translation":"Those who have attained to faith, and who have not obscured their faith by wrongdoing-it is they who shall be secure, since it is they who have found the right path!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/871.mp3","surahId":6,"words":[{"id":65210,"position":1,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/006_082_001.mp3","charTypeName":"word"},{"id":65211,"position":2,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/006_082_002.mp3","charTypeName":"word"},{"id":65212,"position":3,"arabic":"وَلَمْ","translation":"এবং নি","audioUrl":"wbw/006_082_003.mp3","charTypeName":"word"},{"id":65213,"position":4,"arabic":"يَلْبِسُوٓا۟","translation":"মিশ্রিত করেছে","audioUrl":"wbw/006_082_004.mp3","charTypeName":"word"},{"id":65214,"position":5,"arabic":"إِيمَـٰنَهُم","translation":"ঈমান তাদের","audioUrl":"wbw/006_082_005.mp3","charTypeName":"word"},{"id":65215,"position":6,"arabic":"بِظُلْمٍ","translation":"সাথে সীমালঙ্ঘনের","audioUrl":"wbw/006_082_006.mp3","charTypeName":"word"},{"id":65216,"position":7,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐ সব লোক","audioUrl":"wbw/006_082_007.mp3","charTypeName":"word"},{"id":65217,"position":8,"arabic":"لَهُمُ","translation":"জন্যে তাদের (রয়েছে)","audioUrl":"wbw/006_082_008.mp3","charTypeName":"word"},{"id":65218,"position":9,"arabic":"ٱلْأَمْنُ","translation":"নিরাপত্তা","audioUrl":"wbw/006_082_009.mp3","charTypeName":"word"},{"id":65219,"position":10,"arabic":"وَهُم","translation":"এবং তারা","audioUrl":"wbw/006_082_010.mp3","charTypeName":"word"},{"id":65220,"position":11,"arabic":"مُّهْتَدُونَ","translation":"সৎপথ প্রাপ্ত","audioUrl":"wbw/006_082_011.mp3","charTypeName":"word"},{"id":65221,"position":12,"arabic":"٨٢","translation":"(৮২)","audioUrl":null,"charTypeName":"end"}]},{"number":83,"arabic":"وَتِلْكَ حُجَّتُنَآ ءَاتَيْنَٰهَآ إِبْرَٰهِيمَ عَلَىٰ قَوْمِهِۦ ۚ نَرْفَعُ دَرَجَٰتٍۢ مَّن نَّشَآءُ ۗ إِنَّ رَبَّكَ حَكِيمٌ عَلِيمٌۭ","translation":"And this was Our argument which We vouchsafed unto Abraham against his people: [for] We do raise by degrees whom We will. Verily, thy Sustainer is wise, all-knowing.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/872.mp3","surahId":6,"words":[{"id":65408,"position":1,"arabic":"وَتِلْكَ","translation":"এবং এই","audioUrl":"wbw/006_083_001.mp3","charTypeName":"word"},{"id":65409,"position":2,"arabic":"حُجَّتُنَآ","translation":"আমাদের যুক্তি","audioUrl":"wbw/006_083_002.mp3","charTypeName":"word"},{"id":65410,"position":3,"arabic":"ءَاتَيْنَـٰهَآ","translation":"আমরা দিয়েছিলাম তা","audioUrl":"wbw/006_083_003.mp3","charTypeName":"word"},{"id":65411,"position":4,"arabic":"إِبْرَٰهِيمَ","translation":"ইবরাহীমের","audioUrl":"wbw/006_083_004.mp3","charTypeName":"word"},{"id":65412,"position":5,"arabic":"عَلَىٰ","translation":"মুকাবিলায়","audioUrl":"wbw/006_083_005.mp3","charTypeName":"word"},{"id":65413,"position":6,"arabic":"قَوْمِهِۦ ۚ","translation":"জাতির তার","audioUrl":"wbw/006_083_006.mp3","charTypeName":"word"},{"id":65415,"position":7,"arabic":"نَرْفَعُ","translation":"উন্নীত আমরা করি","audioUrl":"wbw/006_083_008.mp3","charTypeName":"word"},{"id":65416,"position":8,"arabic":"دَرَجَـٰتٍۢ","translation":"মর্যাদাসমূহে","audioUrl":"wbw/006_083_009.mp3","charTypeName":"word"},{"id":65417,"position":9,"arabic":"مَّن","translation":"যাকে","audioUrl":"wbw/006_083_010.mp3","charTypeName":"word"},{"id":65418,"position":10,"arabic":"نَّشَآءُ ۗ","translation":"ইচ্ছে করি আমরা","audioUrl":"wbw/006_083_011.mp3","charTypeName":"word"},{"id":65420,"position":11,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/006_083_013.mp3","charTypeName":"word"},{"id":65421,"position":12,"arabic":"رَبَّكَ","translation":"তোমার রব","audioUrl":"wbw/006_083_014.mp3","charTypeName":"word"},{"id":65422,"position":13,"arabic":"حَكِيمٌ","translation":"প্রজ্ঞাময়","audioUrl":"wbw/006_083_015.mp3","charTypeName":"word"},{"id":65423,"position":14,"arabic":"عَلِيمٌۭ","translation":"মহাজ্ঞানী","audioUrl":"wbw/006_083_016.mp3","charTypeName":"word"},{"id":65424,"position":15,"arabic":"٨٣","translation":"(৮৩)","audioUrl":null,"charTypeName":"end"}]},{"number":84,"arabic":"وَوَهَبْنَا لَهُۥٓ إِسْحَٰقَ وَيَعْقُوبَ ۚ كُلًّا هَدَيْنَا ۚ وَنُوحًا هَدَيْنَا مِن قَبْلُ ۖ وَمِن ذُرِّيَّتِهِۦ دَاوُۥدَ وَسُلَيْمَٰنَ وَأَيُّوبَ وَيُوسُفَ وَمُوسَىٰ وَهَٰرُونَ ۚ وَكَذَٰلِكَ نَجْزِى ٱلْمُحْسِنِينَ","translation":"And We bestowed upon him Isaac and Jacob; and We guided each of them as We had guided Noah aforetime. And out of his offspring, [We bestowed prophethood upon] David, and Solomon, and Job, and Joseph, and Moses, and Aaron: for thus do We reward the doers of good;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/873.mp3","surahId":6,"words":[{"id":65900,"position":1,"arabic":"وَوَهَبْنَا","translation":"এবং  দান করেছি আমরা","audioUrl":"wbw/006_084_001.mp3","charTypeName":"word"},{"id":65901,"position":2,"arabic":"لَهُۥٓ","translation":"তাকে","audioUrl":"wbw/006_084_002.mp3","charTypeName":"word"},{"id":65902,"position":3,"arabic":"إِسْحَـٰقَ","translation":"ইসহাক","audioUrl":"wbw/006_084_003.mp3","charTypeName":"word"},{"id":65903,"position":4,"arabic":"وَيَعْقُوبَ ۚ","translation":"ও ইয়াকুবকে","audioUrl":"wbw/006_084_004.mp3","charTypeName":"word"},{"id":65905,"position":5,"arabic":"كُلًّا","translation":"প্রত্যেককে","audioUrl":"wbw/006_084_006.mp3","charTypeName":"word"},{"id":65906,"position":6,"arabic":"هَدَيْنَا ۚ","translation":"সৎপথ দেখিয়েছি আমরা","audioUrl":"wbw/006_084_007.mp3","charTypeName":"word"},{"id":65908,"position":7,"arabic":"وَنُوحًا","translation":"এবং নূহকেও","audioUrl":"wbw/006_084_009.mp3","charTypeName":"word"},{"id":65909,"position":8,"arabic":"هَدَيْنَا","translation":"সৎপথ দেখিয়েছি আমরা","audioUrl":"wbw/006_084_010.mp3","charTypeName":"word"},{"id":65910,"position":9,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/006_084_011.mp3","charTypeName":"word"},{"id":65911,"position":10,"arabic":"قَبْلُ ۖ","translation":"পূর্ব","audioUrl":"wbw/006_084_012.mp3","charTypeName":"word"},{"id":65913,"position":11,"arabic":"وَمِن","translation":"এবং মধ্যে থেকে","audioUrl":"wbw/006_084_014.mp3","charTypeName":"word"},{"id":65914,"position":12,"arabic":"ذُرِّيَّتِهِۦ","translation":"বংশধরদের তার","audioUrl":"wbw/006_084_015.mp3","charTypeName":"word"},{"id":65915,"position":13,"arabic":"دَاوُۥدَ","translation":"(যেমন) দাউদ","audioUrl":"wbw/006_084_016.mp3","charTypeName":"word"},{"id":65916,"position":14,"arabic":"وَسُلَيْمَـٰنَ","translation":"ও সুলায়মান","audioUrl":"wbw/006_084_017.mp3","charTypeName":"word"},{"id":65917,"position":15,"arabic":"وَأَيُّوبَ","translation":"ও আয়্যুব","audioUrl":"wbw/006_084_018.mp3","charTypeName":"word"},{"id":65918,"position":16,"arabic":"وَيُوسُفَ","translation":"ও ইউসুফ","audioUrl":"wbw/006_084_019.mp3","charTypeName":"word"},{"id":65919,"position":17,"arabic":"وَمُوسَىٰ","translation":"ও মূসা","audioUrl":"wbw/006_084_020.mp3","charTypeName":"word"},{"id":65920,"position":18,"arabic":"وَهَـٰرُونَ ۚ","translation":"এবং হারুনকে (সৎপথ দেখিয়েছি)","audioUrl":"wbw/006_084_021.mp3","charTypeName":"word"},{"id":65922,"position":19,"arabic":"وَكَذَٰلِكَ","translation":"এবং এভাবে","audioUrl":"wbw/006_084_023.mp3","charTypeName":"word"},{"id":65923,"position":20,"arabic":"نَجْزِى","translation":"পুরস্কার দিই আমরা","audioUrl":"wbw/006_084_024.mp3","charTypeName":"word"},{"id":65924,"position":21,"arabic":"ٱلْمُحْسِنِينَ","translation":"সৎকর্মপরায়ণদেরকে","audioUrl":"wbw/006_084_025.mp3","charTypeName":"word"},{"id":65925,"position":22,"arabic":"٨٤","translation":"(৮৪)","audioUrl":null,"charTypeName":"end"}]},{"number":85,"arabic":"وَزَكَرِيَّا وَيَحْيَىٰ وَعِيسَىٰ وَإِلْيَاسَ ۖ كُلٌّۭ مِّنَ ٱلصَّٰلِحِينَ","translation":"and [upon] Zachariah, and John, and Jesus, and Elijah: every one of them was of the righteous;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/874.mp3","surahId":6,"words":[{"id":66284,"position":1,"arabic":"وَزَكَرِيَّا","translation":"এবং যাকারিয়া","audioUrl":"wbw/006_085_001.mp3","charTypeName":"word"},{"id":66285,"position":2,"arabic":"وَيَحْيَىٰ","translation":"ও ইয়াহইয়া","audioUrl":"wbw/006_085_002.mp3","charTypeName":"word"},{"id":66286,"position":3,"arabic":"وَعِيسَىٰ","translation":"ও ঈসা","audioUrl":"wbw/006_085_003.mp3","charTypeName":"word"},{"id":66287,"position":4,"arabic":"وَإِلْيَاسَ ۖ","translation":"ও ইলয়াস","audioUrl":"wbw/006_085_004.mp3","charTypeName":"word"},{"id":66289,"position":5,"arabic":"كُلٌّۭ","translation":"প্রত্যেকেই ছিলো","audioUrl":"wbw/006_085_006.mp3","charTypeName":"word"},{"id":66290,"position":6,"arabic":"مِّنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/006_085_007.mp3","charTypeName":"word"},{"id":66291,"position":7,"arabic":"ٱلصَّـٰلِحِينَ","translation":"সৎলোকদের","audioUrl":"wbw/006_085_008.mp3","charTypeName":"word"},{"id":66292,"position":8,"arabic":"٨٥","translation":"(৮৫)","audioUrl":null,"charTypeName":"end"}]},{"number":86,"arabic":"وَإِسْمَٰعِيلَ وَٱلْيَسَعَ وَيُونُسَ وَلُوطًۭا ۚ وَكُلًّۭا فَضَّلْنَا عَلَى ٱلْعَٰلَمِينَ","translation":"and [upon] Ishmael, and Elisha, and Jonah, and Lot. And every one of them did We favour above other people;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/875.mp3","surahId":6,"words":[{"id":66687,"position":1,"arabic":"وَإِسْمَـٰعِيلَ","translation":"এবং ইসমাঈল","audioUrl":"wbw/006_086_001.mp3","charTypeName":"word"},{"id":66688,"position":2,"arabic":"وَٱلْيَسَعَ","translation":"ও আল-ইয়াসায়া","audioUrl":"wbw/006_086_002.mp3","charTypeName":"word"},{"id":66689,"position":3,"arabic":"وَيُونُسَ","translation":"ও ইউনুস","audioUrl":"wbw/006_086_003.mp3","charTypeName":"word"},{"id":66690,"position":4,"arabic":"وَلُوطًۭا ۚ","translation":"ও লুত","audioUrl":"wbw/006_086_004.mp3","charTypeName":"word"},{"id":66692,"position":5,"arabic":"وَكُلًّۭا","translation":"এবং প্রত্যেককে","audioUrl":"wbw/006_086_006.mp3","charTypeName":"word"},{"id":66693,"position":6,"arabic":"فَضَّلْنَا","translation":"শ্রেষ্ঠত্ব দিয়েছি আমরা","audioUrl":"wbw/006_086_007.mp3","charTypeName":"word"},{"id":66694,"position":7,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/006_086_008.mp3","charTypeName":"word"},{"id":66695,"position":8,"arabic":"ٱلْعَـٰلَمِينَ","translation":"বিশ্বজগতের (লোকদের)","audioUrl":"wbw/006_086_009.mp3","charTypeName":"word"},{"id":66696,"position":9,"arabic":"٨٦","translation":"(৮৬)","audioUrl":null,"charTypeName":"end"}]},{"number":87,"arabic":"وَمِنْ ءَابَآئِهِمْ وَذُرِّيَّٰتِهِمْ وَإِخْوَٰنِهِمْ ۖ وَٱجْتَبَيْنَٰهُمْ وَهَدَيْنَٰهُمْ إِلَىٰ صِرَٰطٍۢ مُّسْتَقِيمٍۢ","translation":"and [We exalted likewise] some of their forefathers and-their offspring and their brethren: We elected them [all], and guided them onto a straight way.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/876.mp3","surahId":6,"words":[{"id":66812,"position":1,"arabic":"وَمِنْ","translation":"এবং মধ্য হতে","audioUrl":"wbw/006_087_001.mp3","charTypeName":"word"},{"id":66813,"position":2,"arabic":"ءَابَآئِهِمْ","translation":"পিতৃপুরুষদের তাদের","audioUrl":"wbw/006_087_002.mp3","charTypeName":"word"},{"id":66814,"position":3,"arabic":"وَذُرِّيَّـٰتِهِمْ","translation":"ও বংশধরদের তাদের","audioUrl":"wbw/006_087_003.mp3","charTypeName":"word"},{"id":66815,"position":4,"arabic":"وَإِخْوَٰنِهِمْ ۖ","translation":"এবং ভ্রাতাদেরও তাদের","audioUrl":"wbw/006_087_004.mp3","charTypeName":"word"},{"id":66817,"position":5,"arabic":"وَٱجْتَبَيْنَـٰهُمْ","translation":"এবং আমরা মনোনীত করেছি তাদের","audioUrl":"wbw/006_087_006.mp3","charTypeName":"word"},{"id":66818,"position":6,"arabic":"وَهَدَيْنَـٰهُمْ","translation":"ও আমরা পথ দেখিয়েছি তাদের","audioUrl":"wbw/006_087_007.mp3","charTypeName":"word"},{"id":66819,"position":7,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/006_087_008.mp3","charTypeName":"word"},{"id":66820,"position":8,"arabic":"صِرَٰطٍۢ","translation":"পথের","audioUrl":"wbw/006_087_009.mp3","charTypeName":"word"},{"id":66821,"position":9,"arabic":"مُّسْتَقِيمٍۢ","translation":"সরলসোজা","audioUrl":"wbw/006_087_010.mp3","charTypeName":"word"},{"id":66822,"position":10,"arabic":"٨٧","translation":"(৮৭)","audioUrl":null,"charTypeName":"end"}]},{"number":88,"arabic":"ذَٰلِكَ هُدَى ٱللَّهِ يَهْدِى بِهِۦ مَن يَشَآءُ مِنْ عِبَادِهِۦ ۚ وَلَوْ أَشْرَكُوا۟ لَحَبِطَ عَنْهُم مَّا كَانُوا۟ يَعْمَلُونَ","translation":"Such is God's guidance: He guides therewith whomever He wills of His servants. And had they ascribed divinity to aught beside Him-in vain, indeed, would have been all [the good] that they ever did:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/877.mp3","surahId":6,"words":[{"id":67377,"position":1,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/006_088_001.mp3","charTypeName":"word"},{"id":67378,"position":2,"arabic":"هُدَى","translation":"সৎপথ","audioUrl":"wbw/006_088_002.mp3","charTypeName":"word"},{"id":67379,"position":3,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌র","audioUrl":"wbw/006_088_003.mp3","charTypeName":"word"},{"id":67380,"position":4,"arabic":"يَهْدِى","translation":"তিনি পরিচালনা করেন","audioUrl":"wbw/006_088_004.mp3","charTypeName":"word"},{"id":67381,"position":5,"arabic":"بِهِۦ","translation":"উপর তার","audioUrl":"wbw/006_088_005.mp3","charTypeName":"word"},{"id":67382,"position":6,"arabic":"مَن","translation":"যাকে","audioUrl":"wbw/006_088_006.mp3","charTypeName":"word"},{"id":67383,"position":7,"arabic":"يَشَآءُ","translation":"তিনি ইচ্ছে করেন","audioUrl":"wbw/006_088_007.mp3","charTypeName":"word"},{"id":67384,"position":8,"arabic":"مِنْ","translation":"মধ্য হতে","audioUrl":"wbw/006_088_008.mp3","charTypeName":"word"},{"id":67385,"position":9,"arabic":"عِبَادِهِۦ ۚ","translation":"দাসদের তাঁর","audioUrl":"wbw/006_088_009.mp3","charTypeName":"word"},{"id":67387,"position":10,"arabic":"وَلَوْ","translation":"এবং যদি",