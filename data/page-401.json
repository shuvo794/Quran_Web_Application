{"id":401,"ayahs":[{"number":39,"arabic":"وَقَٰرُونَ وَفِرْعَوْنَ وَهَٰمَٰنَ ۖ وَلَقَدْ جَآءَهُم مُّوسَىٰ بِٱلْبَيِّنَٰتِ فَٱسْتَكْبَرُوا۟ فِى ٱلْأَرْضِ وَمَا كَانُوا۟ سَٰبِقِينَ","translation":"And [thus, too, did We deal with] Qarun and Pharaoh, and Haman: to them had come Moses with all evidence of the truth, but they behaved arrogantly on earth [and rejected him]; and withal, they could not escape [Us].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3379.mp3","surahId":29,"words":[{"id":40652,"position":1,"arabic":"وَقَـٰرُونَ","translation":"এবং ক্বারুন","audioUrl":"wbw/029_039_001.mp3","charTypeName":"word"},{"id":40653,"position":2,"arabic":"وَفِرْعَوْنَ","translation":"ও ফিরআউন","audioUrl":"wbw/029_039_002.mp3","charTypeName":"word"},{"id":40654,"position":3,"arabic":"وَهَـٰمَـٰنَ ۖ","translation":"এবং হামানকেও (আমরা ধ্বংস করেছি)","audioUrl":"wbw/029_039_003.mp3","charTypeName":"word"},{"id":40656,"position":4,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/029_039_005.mp3","charTypeName":"word"},{"id":40657,"position":5,"arabic":"جَآءَهُم","translation":"কাছে এসেছিলো তাদের","audioUrl":"wbw/029_039_006.mp3","charTypeName":"word"},{"id":40658,"position":6,"arabic":"مُّوسَىٰ","translation":"মূসা","audioUrl":"wbw/029_039_007.mp3","charTypeName":"word"},{"id":40659,"position":7,"arabic":"بِٱلْبَيِّنَـٰتِ","translation":"নিয়ে সুস্পষ্ট প্রমাণাদি","audioUrl":"wbw/029_039_008.mp3","charTypeName":"word"},{"id":40660,"position":8,"arabic":"فَٱسْتَكْبَرُوا۟","translation":"তখন তারা দম্ভ করতো","audioUrl":"wbw/029_039_009.mp3","charTypeName":"word"},{"id":40661,"position":9,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/029_039_010.mp3","charTypeName":"word"},{"id":40662,"position":10,"arabic":"ٱلْأَرْضِ","translation":"দেশের","audioUrl":"wbw/029_039_011.mp3","charTypeName":"word"},{"id":40663,"position":11,"arabic":"وَمَا","translation":"কিন্তু না","audioUrl":"wbw/029_039_012.mp3","charTypeName":"word"},{"id":40664,"position":12,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/029_039_013.mp3","charTypeName":"word"},{"id":40665,"position":13,"arabic":"سَـٰبِقِينَ","translation":"অগ্রগামী","audioUrl":"wbw/029_039_014.mp3","charTypeName":"word"},{"id":40666,"position":14,"arabic":"٣٩","translation":"(৩৯)","audioUrl":null,"charTypeName":"end"}]},{"number":40,"arabic":"فَكُلًّا أَخَذْنَا بِذَنۢبِهِۦ ۖ فَمِنْهُم مَّنْ أَرْسَلْنَا عَلَيْهِ حَاصِبًۭا وَمِنْهُم مَّنْ أَخَذَتْهُ ٱلصَّيْحَةُ وَمِنْهُم مَّنْ خَسَفْنَا بِهِ ٱلْأَرْضَ وَمِنْهُم مَّنْ أَغْرَقْنَا ۚ وَمَا كَانَ ٱللَّهُ لِيَظْلِمَهُمْ وَلَٰكِن كَانُوٓا۟ أَنفُسَهُمْ يَظْلِمُونَ","translation":"For, every one of them, did We take to task for his sin: and so, upon some of them We let loose a deadly storm wind; and some of them were overtaken by a [sudden] blast; and some of them We caused to be swallowed by the earth: and some of them We caused to drown. And it was not God who wronged them, but it was they who had wronged themselves.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3380.mp3","surahId":29,"words":[{"id":41715,"position":1,"arabic":"فَكُلًّا","translation":"শেষ পর্যন্ত প্রত্যেককে","audioUrl":"wbw/029_040_001.mp3","charTypeName":"word"},{"id":41716,"position":2,"arabic":"أَخَذْنَا","translation":"পাকড়াও করেছি আমরা","audioUrl":"wbw/029_040_002.mp3","charTypeName":"word"},{"id":41717,"position":3,"arabic":"بِذَنۢبِهِۦ ۖ","translation":"কারণে তার অপরাধের","audioUrl":"wbw/029_040_003.mp3","charTypeName":"word"},{"id":41719,"position":4,"arabic":"فَمِنْهُم","translation":"অতঃপর মধ্য হ'তে তাদের","audioUrl":"wbw/029_040_005.mp3","charTypeName":"word"},{"id":41720,"position":5,"arabic":"مَّنْ","translation":"কারও (ক্ষেত্রে)","audioUrl":"wbw/029_040_006.mp3","charTypeName":"word"},{"id":41721,"position":6,"arabic":"أَرْسَلْنَا","translation":"আমরা প্রেরণ করেছি","audioUrl":"wbw/029_040_007.mp3","charTypeName":"word"},{"id":41722,"position":7,"arabic":"عَلَيْهِ","translation":"উপর তার","audioUrl":"wbw/029_040_008.mp3","charTypeName":"word"},{"id":41723,"position":8,"arabic":"حَاصِبًۭا","translation":"পাথর বর্ষণকারী ঝঞ্ঝা","audioUrl":"wbw/029_040_009.mp3","charTypeName":"word"},{"id":41724,"position":9,"arabic":"وَمِنْهُم","translation":"আর মধ্য হ'তে তাদের","audioUrl":"wbw/029_040_010.mp3","charTypeName":"word"},{"id":41725,"position":10,"arabic":"مَّنْ","translation":"কারও (অবস্থা ছিলো)","audioUrl":"wbw/029_040_011.mp3","charTypeName":"word"},{"id":41726,"position":11,"arabic":"أَخَذَتْهُ","translation":"ধরেছিলো তাকে","audioUrl":"wbw/029_040_012.mp3","charTypeName":"word"},{"id":41727,"position":12,"arabic":"ٱلصَّيْحَةُ","translation":"মহাগর্জন","audioUrl":"wbw/029_040_013.mp3","charTypeName":"word"},{"id":41728,"position":13,"arabic":"وَمِنْهُم","translation":"আবার মধ্য হ'তে তাদের","audioUrl":"wbw/029_040_014.mp3","charTypeName":"word"},{"id":41729,"position":14,"arabic":"مَّنْ","translation":"কাউকে","audioUrl":"wbw/029_040_015.mp3","charTypeName":"word"},{"id":41730,"position":15,"arabic":"خَسَفْنَا","translation":"আমরা ধসিয়ে দিয়েছি","audioUrl":"wbw/029_040_016.mp3","charTypeName":"word"},{"id":41731,"position":16,"arabic":"بِهِ","translation":"সহ তাকে","audioUrl":"wbw/029_040_017.mp3","charTypeName":"word"},{"id":41732,"position":17,"arabic":"ٱلْأَرْضَ","translation":"জমীনে","audioUrl":"wbw/029_040_018.mp3","charTypeName":"word"},{"id":41733,"position":18,"arabic":"وَمِنْهُم","translation":"আর মধ্য হ'তে তাদের","audioUrl":"wbw/029_040_019.mp3","charTypeName":"word"},{"id":41734,"position":19,"arabic":"مَّنْ","translation":"কাউকে","audioUrl":"wbw/029_040_020.mp3","charTypeName":"word"},{"id":41735,"position":20,"arabic":"أَغْرَقْنَا ۚ","translation":"আমরা ডুবিয়ে দিয়েছি (পানিতে)","audioUrl":"wbw/029_040_021.mp3","charTypeName":"word"},{"id":41737,"position":21,"arabic":"وَمَا","translation":"অথচ না","audioUrl":"wbw/029_040_023.mp3","charTypeName":"word"},{"id":41738,"position":22,"arabic":"كَانَ","translation":"ছিলেন","audioUrl":"wbw/029_040_024.mp3","charTypeName":"word"},{"id":41739,"position":23,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/029_040_025.mp3","charTypeName":"word"},{"id":41740,"position":24,"arabic":"لِيَظْلِمَهُمْ","translation":"যেন তিনি তাদের প্রতি অন্যায় করবেন","audioUrl":"wbw/029_040_026.mp3","charTypeName":"word"},{"id":41741,"position":25,"arabic":"وَلَـٰكِن","translation":"কিন্তু","audioUrl":"wbw/029_040_027.mp3","charTypeName":"word"},{"id":41742,"position":26,"arabic":"كَانُوٓا۟","translation":"তারা ছিলো","audioUrl":"wbw/029_040_028.mp3","charTypeName":"word"},{"id":41743,"position":27,"arabic":"أَنفُسَهُمْ","translation":"নিজেদের (উপর) তাদের","audioUrl":"wbw/029_040_029.mp3","charTypeName":"word"},{"id":41744,"position":28,"arabic":"يَظْلِمُونَ","translation":"তারা অন্যায় করতো","audioUrl":"wbw/029_040_030.mp3","charTypeName":"word"},{"id":41745,"position":29,"arabic":"٤٠","translation":"(৪০)","audioUrl":null,"charTypeName":"end"}]},{"number":41,"arabic":"مَثَلُ ٱلَّذِينَ ٱتَّخَذُوا۟ مِن دُونِ ٱللَّهِ أَوْلِيَآءَ كَمَثَلِ ٱلْعَنكَبُوتِ ٱتَّخَذَتْ بَيْتًۭا ۖ وَإِنَّ أَوْهَنَ ٱلْبُيُوتِ لَبَيْتُ ٱلْعَنكَبُوتِ ۖ لَوْ كَانُوا۟ يَعْلَمُونَ","translation":"The parable of those who take [beings or forces] other than God for their protectors is that of the spider which makes for itself a house: for, behold, the frailest of all houses is the spiders house. Could they but understand this!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3381.mp3","surahId":29,"words":[{"id":42389,"position":1,"arabic":"مَثَلُ","translation":"দৃষ্টান্ত","audioUrl":"wbw/029_041_001.mp3","charTypeName":"word"},{"id":42390,"position":2,"arabic":"ٱلَّذِينَ","translation":"(তাদের) যারা","audioUrl":"wbw/029_041_002.mp3","charTypeName":"word"},{"id":42391,"position":3,"arabic":"ٱتَّخَذُوا۟","translation":"গ্রহণ করেছে (অপরকে)","audioUrl":"wbw/029_041_003.mp3","charTypeName":"word"},{"id":42392,"position":4,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/029_041_004.mp3","charTypeName":"word"},{"id":42393,"position":5,"arabic":"دُونِ","translation":"ছাড়া","audioUrl":"wbw/029_041_005.mp3","charTypeName":"word"},{"id":42394,"position":6,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌","audioUrl":"wbw/029_041_006.mp3","charTypeName":"word"},{"id":42395,"position":7,"arabic":"أَوْلِيَآءَ","translation":"অভিভাবক হিসেবে","audioUrl":"wbw/029_041_007.mp3","charTypeName":"word"},{"id":42396,"position":8,"arabic":"كَمَثَلِ","translation":"মতো দৃষ্টান্তের","audioUrl":"wbw/029_041_008.mp3","charTypeName":"word"},{"id":42397,"position":9,"arabic":"ٱلْعَنكَبُوتِ","translation":"মাকড়শার","audioUrl":"wbw/029_041_009.mp3","charTypeName":"word"},{"id":42398,"position":10,"arabic":"ٱتَّخَذَتْ","translation":"সে বানিয়েছে","audioUrl":"wbw/029_041_010.mp3","charTypeName":"word"},{"id":42399,"position":11,"arabic":"بَيْتًۭا ۖ","translation":"(তার) ঘরকে (বড় অবলম্বন হিসেবে)","audioUrl":"wbw/029_041_011.mp3","charTypeName":"word"},{"id":42401,"position":12,"arabic":"وَإِنَّ","translation":"অথচ নিশ্চয়ই","audioUrl":"wbw/029_041_013.mp3","charTypeName":"word"},{"id":42402,"position":13,"arabic":"أَوْهَنَ","translation":"দুর্বলতম (ঘর)","audioUrl":"wbw/029_041_014.mp3","charTypeName":"word"},{"id":42403,"position":14,"arabic":"ٱلْبُيُوتِ","translation":"সব ঘরের (চেয়ে)","audioUrl":"wbw/029_041_015.mp3","charTypeName":"word"},{"id":42404,"position":15,"arabic":"لَبَيْتُ","translation":"অবশ্যই ঘর","audioUrl":"wbw/029_041_016.mp3","charTypeName":"word"},{"id":42405,"position":16,"arabic":"ٱلْعَنكَبُوتِ ۖ","translation":"মাকড়শার","audioUrl":"wbw/029_041_017.mp3","charTypeName":"word"},{"id":42407,"position":17,"arabic":"لَوْ","translation":"যদি","audioUrl":"wbw/029_041_019.mp3","charTypeName":"word"},{"id":42408,"position":18,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/029_041_020.mp3","charTypeName":"word"},{"id":42409,"position":19,"arabic":"يَعْلَمُونَ","translation":"তারা জানতো","audioUrl":"wbw/029_041_021.mp3","charTypeName":"word"},{"id":42410,"position":20,"arabic":"٤١","translation":"(৪১)","audioUrl":null,"charTypeName":"end"}]},{"number":42,"arabic":"إِنَّ ٱللَّهَ يَعْلَمُ مَا يَدْعُونَ مِن دُونِهِۦ مِن شَىْءٍۢ ۚ وَهُوَ ٱلْعَزِيزُ ٱلْحَكِيمُ","translation":"Verily, God knows whatever it is that men invoke instead of Him for He alone is almighty, truly wise.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3382.mp3","surahId":29,"words":[{"id":43190,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/029_042_001.mp3","charTypeName":"word"},{"id":43191,"position":2,"arabic":"ٱللَّهَ","translation":"আল্লাহ্‌","audioUrl":"wbw/029_042_002.mp3","charTypeName":"word"},{"id":43192,"position":3,"arabic":"يَعْلَمُ","translation":"জানেন","audioUrl":"wbw/029_042_003.mp3","charTypeName":"word"},{"id":43193,"position":4,"arabic":"مَا","translation":"যা","audioUrl":"wbw/029_042_004.mp3","charTypeName":"word"},{"id":43194,"position":5,"arabic":"يَدْعُونَ","translation":"তারা ডাকে","audioUrl":"wbw/029_042_005.mp3","charTypeName":"word"},{"id":43195,"position":6,"arabic":"مِن","translation":"ছাড়া","audioUrl":"wbw/029_042_006.mp3","charTypeName":"word"},{"id":43196,"position":7,"arabic":"دُونِهِۦ","translation":"তাঁর","audioUrl":"wbw/029_042_007.mp3","charTypeName":"word"},{"id":43197,"position":8,"arabic":"مِن","translation":"অন্য কোনো","audioUrl":"wbw/029_042_008.mp3","charTypeName":"word"},{"id":43198,"position":9,"arabic":"شَىْءٍۢ ۚ","translation":"কিছুকে","audioUrl":"wbw/029_042_009.mp3","charTypeName":"word"},{"id":43200,"position":10,"arabic":"وَهُوَ","translation":"এবং তিনি","audioUrl":"wbw/029_042_011.mp3","charTypeName":"word"},{"id":43201,"position":11,"arabic":"ٱلْعَزِيزُ","translation":"মহাপরাক্রমশালী","audioUrl":"wbw/029_042_012.mp3","charTypeName":"word"},{"id":43202,"position":12,"arabic":"ٱلْحَكِيمُ","translation":"প্রজ্ঞাময়","audioUrl":"wbw/029_042_013.mp3","charTypeName":"word"},{"id":43203,"position":13,"arabic":"٤٢","translation":"(৪২)","audioUrl":null,"charTypeName":"end"}]},{"number":43,"arabic":"وَتِلْكَ ٱلْأَمْثَٰلُ نَضْرِبُهَا لِلنَّاسِ ۖ وَمَا يَعْقِلُهَآ إِلَّا ٱلْعَٰلِمُونَ","translation":"And so We propound these parables unto man: but none can grasp their innermost meaning save those who [of Us] are aware","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3383.mp3","surahId":29,"words":[{"id":43924,"position":1,"arabic":"وَتِلْكَ","translation":"এবং এই","audioUrl":"wbw/029_043_001.mp3","charTypeName":"word"},{"id":43925,"position":2,"arabic":"ٱلْأَمْثَـٰلُ","translation":"দৃষ্টান্তসমূহ","audioUrl":"wbw/029_043_002.mp3","charTypeName":"word"},{"id":43926,"position":3,"arabic":"نَضْرِبُهَا","translation":"তা পেশ করি আমরা","audioUrl":"wbw/029_043_003.mp3","charTypeName":"word"},{"id":43927,"position":4,"arabic":"لِلنَّاسِ ۖ","translation":"জন্যে মানুষের","audioUrl":"wbw/029_043_004.mp3","charTypeName":"word"},{"id":43929,"position":5,"arabic":"وَمَا","translation":"আর না","audioUrl":"wbw/029_043_006.mp3","charTypeName":"word"},{"id":43930,"position":6,"arabic":"يَعْقِلُهَآ","translation":"বুঝতে পারে তা","audioUrl":"wbw/029_043_007.mp3","charTypeName":"word"},{"id":43931,"position":7,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/029_043_008.mp3","charTypeName":"word"},{"id":43932,"position":8,"arabic":"ٱلْعَـٰلِمُونَ","translation":"জ্ঞানীরা","audioUrl":"wbw/029_043_009.mp3","charTypeName":"word"},{"id":43933,"position":9,"arabic":"٤٣","translation":"(৪৩)","audioUrl":null,"charTypeName":"end"}]},{"number":44,"arabic":"خَلَقَ ٱللَّهُ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضَ بِٱلْحَقِّ ۚ إِنَّ فِى ذَٰلِكَ لَءَايَةًۭ لِّلْمُؤْمِنِينَ","translation":"[and hence are certain that] God has created the heavens and the earth in accordance with [an inner] truth: for, behold, in this [very creation] there is a message indeed for all who believe [in Him].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3384.mp3","surahId":29,"words":[{"id":44733,"position":1,"arabic":"خَلَقَ","translation":"সৃষ্টি করেছেন","audioUrl":"wbw/029_044_001.mp3","charTypeName":"word"},{"id":44734,"position":2,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌","audioUrl":"wbw/029_044_002.mp3","charTypeName":"word"},{"id":44735,"position":3,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশমণ্ডলী","audioUrl":"wbw/029_044_003.mp3","charTypeName":"word"},{"id":44736,"position":4,"arabic":"وَٱلْأَرْضَ","translation":"ও পৃথিবী","audioUrl":"wbw/029_044_004.mp3","charTypeName":"word"},{"id":44737,"position":5,"arabic":"بِٱلْحَقِّ ۚ","translation":"ভাবে যথাযথ","audioUrl":"wbw/029_044_005.mp3","charTypeName":"word"},{"id":44739,"position":6,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/029_044_007.mp3","charTypeName":"word"},{"id":44740,"position":7,"arabic":"فِى","translation":"(মধ্যে)রয়েছে","audioUrl":"wbw/029_044_008.mp3","charTypeName":"word"},{"id":44741,"position":8,"arabic":"ذَٰلِكَ","translation":"এর","audioUrl":"wbw/029_044_009.mp3","charTypeName":"word"},{"id":44742,"position":9,"arabic":"لَـَٔايَةًۭ","translation":"অবশ্যই নিদর্শন","audioUrl":"wbw/029_044_010.mp3","charTypeName":"word"},{"id":44743,"position":10,"arabic":"لِّلْمُؤْمِنِينَ","translation":"জন্যে মু'মিনদের","audioUrl":"wbw/029_044_011.mp3","charTypeName":"word"},{"id":44744,"position":11,"arabic":"٤٤","translation":"(৪৪)","audioUrl":null,"charTypeName":"end"}]},{"number":45,"arabic":"ٱتْلُ مَآ أُوحِىَ إِلَيْكَ مِنَ ٱلْكِتَٰبِ وَأَقِمِ ٱلصَّلَوٰةَ ۖ إِنَّ ٱلصَّلَوٰةَ تَنْهَىٰ عَنِ ٱلْفَحْشَآءِ وَٱلْمُنكَرِ ۗ وَلَذِكْرُ ٱللَّهِ أَكْبَرُ ۗ وَٱللَّهُ يَعْلَمُ مَا تَصْنَعُونَ","translation":"CONVEY [unto others] whatever of this divine writ has been revealed unto thee, and be constant in prayer: for, behold, prayer restrains [man] from loathsome deeds and from all that runs counter to reason; and remembrance of God is indeed the greatest [good]. And God knows all that you do.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3385.mp3","surahId":29,"words":[{"id":45377,"position":1,"arabic":"ٱتْلُ","translation":"(হে নাবী) তিলাওয়াত করো","audioUrl":"wbw/029_045_001.mp3","charTypeName":"word"},{"id":45378,"position":2,"arabic":"مَآ","translation":"যা","audioUrl":"wbw/029_045_002.mp3","charTypeName":"word"},{"id":45379,"position":3,"arabic":"أُوحِىَ","translation":"ওহী করা হয়েছে","audioUrl":"wbw/029_045_003.mp3","charTypeName":"word"},{"id":45380,"position":4,"arabic":"إِلَيْكَ","translation":"প্রতি তোমার","audioUrl":"wbw/029_045_004.mp3","charTypeName":"word"},{"id":45381,"position":5,"arabic":"مِنَ","translation":"থেকে","audioUrl":"wbw/029_045_005.mp3","charTypeName":"word"},{"id":45382,"position":6,"arabic":"ٱلْكِتَـٰبِ","translation":"কিতাব","audioUrl":"wbw/029_045_006.mp3","charTypeName":"word"},{"id":45383,"position":7,"arabic":"وَأَقِمِ","translation":"এবং প্রতিষ্ঠা করো","audioUrl":"wbw/029_045_007.mp3","charTypeName":"word"},{"id":45384,"position":8,"arabic":"ٱلصَّلَوٰةَ ۖ","translation":"সালাত","audioUrl":"wbw/029_045_008.mp3","charTypeName":"word"},{"id":45386,"position":9,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/029_045_010.mp3","charTypeName":"word"},{"id":45387,"position":10,"arabic":"ٱلصَّلَوٰةَ","translation":"সালাত","audioUrl":"wbw/029_045_011.mp3","charTypeName":"word"},{"id":45388,"position":11,"arabic":"تَنْهَىٰ","translation":"বিরত রাখে","audioUrl":"wbw/029_045_012.mp3","charTypeName":"word"},{"id":45389,"position":12,"arabic":"عَنِ","translation":"হ'তে","audioUrl":"wbw/029_045_013.mp3","charTypeName":"word"},{"id":45390,"position":13,"arabic":"ٱلْفَحْشَآءِ","translation":"অশ্লীলতা","audioUrl":"wbw/029_045_014.mp3","charTypeName":"word"},{"id":45391,"position":14,"arabic":"وَٱلْمُنكَرِ ۗ","translation":"এবং খারাপ কাজ (হ'তে)","audioUrl":"wbw/029_045_015.mp3","charTypeName":"word"},{"id":45393,"position":15,"arabic":"وَلَذِكْرُ","translation":"এবং অবশ্যই স্মরণ","audioUrl":"wbw/029_045_017.mp3","charTypeName":"word"},{"id":45394,"position":16,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌র","audioUrl":"wbw/029_045_018.mp3","charTypeName":"word"},{"id":45395,"position":1