d":22121,"position":12,"arabic":"يَعْمَلُونَ","translation":"তারা কাজ করতে","audioUrl":"wbw/032_019_012.mp3","charTypeName":"word"},{"id":22122,"position":13,"arabic":"١٩","translation":"(১৯)","audioUrl":null,"charTypeName":"end"}]},{"number":20,"arabic":"وَأَمَّا ٱلَّذِينَ فَسَقُوا۟ فَمَأْوَىٰهُمُ ٱلنَّارُ ۖ كُلَّمَآ أَرَادُوٓا۟ أَن يَخْرُجُوا۟ مِنْهَآ أُعِيدُوا۟ فِيهَا وَقِيلَ لَهُمْ ذُوقُوا۟ عَذَابَ ٱلنَّارِ ٱلَّذِى كُنتُم بِهِۦ تُكَذِّبُونَ","translation":"but as for those who are lost in iniquity - their goal is the fire: as oft as they will try to come out of it, they will be thrown back into it; and they will be told, “Taste [now] this suffering through fire which you were wont to call a lie!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3523.mp3","surahId":32,"words":[{"id":23166,"position":1,"arabic":"وَأَمَّا","translation":"আর(তাদের)ক্ষেত্রে","audioUrl":"wbw/032_020_001.mp3","charTypeName":"word"},{"id":23167,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/032_020_002.mp3","charTypeName":"word"},{"id":23168,"position":3,"arabic":"فَسَقُوا۟","translation":"সত্যত্যাগ করেছে","audioUrl":"wbw/032_020_003.mp3","charTypeName":"word"},{"id":23169,"position":4,"arabic":"فَمَأْوَىٰهُمُ","translation":"অতঃপর বাসস্থান হবে তাদের","audioUrl":"wbw/032_020_004.mp3","charTypeName":"word"},{"id":23170,"position":5,"arabic":"ٱلنَّارُ ۖ","translation":"আগুন","audioUrl":"wbw/032_020_005.mp3","charTypeName":"word"},{"id":23172,"position":6,"arabic":"كُلَّمَآ","translation":"যখনই","audioUrl":"wbw/032_020_007.mp3","charTypeName":"word"},{"id":23173,"position":7,"arabic":"أَرَادُوٓا۟","translation":"তারা ইচ্ছে করবে","audioUrl":"wbw/032_020_008.mp3","charTypeName":"word"},{"id":23174,"position":8,"arabic":"أَن","translation":"যে","audioUrl":"wbw/032_020_009.mp3","charTypeName":"word"},{"id":23175,"position":9,"arabic":"يَخْرُجُوا۟","translation":"তারা বের হবে","audioUrl":"wbw/032_020_010.mp3","charTypeName":"word"},{"id":23176,"positio