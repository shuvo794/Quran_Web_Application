{"id":416,"ayahs":[{"number":12,"arabic":"وَلَوْ تَرَىٰٓ إِذِ ٱلْمُجْرِمُونَ نَاكِسُوا۟ رُءُوسِهِمْ عِندَ رَبِّهِمْ رَبَّنَآ أَبْصَرْنَا وَسَمِعْنَا فَٱرْجِعْنَا نَعْمَلْ صَٰلِحًا إِنَّا مُوقِنُونَ","translation":"If thou couldst but see [how it will be on Judgment Day], when those who are lost in sin will hang their heads before their Sustainer, [saying:] “O our Sustainer! [Now] we have seen, and we have heard! Return us, then, [to our earthly life] that we may do good deeds: for [now], behold, we are certain [of the truth]!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3515.mp3","surahId":32,"words":[{"id":14464,"position":1,"arabic":"وَلَوْ","translation":"এবং যদি","audioUrl":"wbw/032_012_001.mp3","charTypeName":"word"},{"id":14465,"position":2,"arabic":"تَرَىٰٓ","translation":"তুমি দেখতে","audioUrl":"wbw/032_012_002.mp3","charTypeName":"word"},{"id":14466,"position":3,"arabic":"إِذِ","translation":"যখন","audioUrl":"wbw/032_012_003.mp3","charTypeName":"word"},{"id":14467,"position":4,"arabic":"ٱلْمُجْرِمُونَ","translation":"অপরাধীরা","audioUrl":"wbw/032_012_004.mp3","charTypeName":"word"},{"id":14468,"position":5,"arabic":"نَاكِسُوا۟","translation":"অবনতকারী (হবে)","audioUrl":"wbw/032_012_005.mp3","charTypeName":"word"},{"id":14469,"position":6,"arabic":"رُءُوسِهِمْ","translation":"মাথাসমূহ তাদের","audioUrl":"wbw/032_012_006.mp3","charTypeName":"word"},{"id":14470,"position":7,"arabic":"عِندَ","translation":"কাছে","audioUrl":"wbw/032_012_007.mp3","charTypeName":"word"},{"id":14471,"position":8,"arabic":"رَبِّهِمْ","translation":"রবের তাদের","audioUrl":"wbw/032_012_008.mp3","charTypeName":"word"},{"id":14472,"position":9,"arabic":"رَبَّنَآ","translation":"\"(বলবে) হে আমাদের রব","audioUrl":"wbw/032_012_009.mp3","charTypeName":"word"},{"id":14473,"position":10,"arabic":"أَبْصَرْنَا","translation":"দেখেছি আমরা","audioUrl":"wbw/032_012_010.mp3","charTypeName":"word"},{"id":14474,"position":11,"arabic":"وَسَمِعْنَا","translation":"ও শুনেছি আমরা","audioUrl":"wbw/032_012_011.mp3","charTypeName":"word"},{"id":14475,"position":12,"arabic":"فَٱرْجِعْنَا","translation":"এখন ফেরত পাঠান আমাদের","audioUrl":"wbw/032_012_012.mp3","charTypeName":"word"},{"id":14476,"position":13,"arabic":"نَعْمَلْ","translation":"কাজ করবো আমরা","audioUrl":"wbw/032_012_013.mp3","charTypeName":"word"},{"id":14477,"position":14,"arabic":"صَـٰلِحًا","translation":"সৎ","audioUrl":"wbw/032_012_014.mp3","charTypeName":"word"},{"id":14478,"position":15,"arabic":"إِنَّا","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/032_012_015.mp3","charTypeName":"word"},{"id":14479,"position":16,"arabic":"مُوقِنُونَ","translation":"দৃঢ়বিশ্বাসী\"","audioUrl":"wbw/032_012_016.mp3","charTypeName":"word"},{"id":14480,"position":17,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]},{"number":13,"arabic":"وَلَوْ شِئْنَا لَءَاتَيْنَا كُلَّ نَفْسٍ هُدَىٰهَا وَلَٰكِنْ حَقَّ ٱلْقَوْلُ مِنِّى لَأَمْلَأَنَّ جَهَنَّمَ مِنَ ٱلْجِنَّةِ وَٱلنَّاسِ أَجْمَعِينَ","translation":"Yet had We so willed, We could indeed have imposed Our guidance upon every human being: but [We have not willed it thus - and so] that word of Mine has come true: “Most certainly will I fill hell with invisible beings as well as with humans, all together!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3516.mp3","surahId":32,"words":[{"id":15570,"position":1,"arabic":"وَلَوْ","translation":"এবং যদি","audioUrl":"wbw/032_013_001.mp3","charTypeName":"word"},{"id":15571,"position":2,"arabic":"شِئْنَا","translation":"চাইতাম আমরা","audioUrl":"wbw/032_013_002.mp3","charTypeName":"word"},{"id":15572,"position":3,"arabic":"لَـَٔاتَيْنَا","translation":"অবশ্যই দিতাম আমরা","audioUrl":"wbw/032_013_003.mp3","charTypeName":"word"},{"id":15573,"position":4,"arabic":"كُلَّ","translation":"প্রত্যেক","audioUrl":"wbw/032_013_004.mp3","charTypeName":"word"},{"id":15574,"position":5,"arabic":"نَفْسٍ","translation":"ব্যক্তিকে","audioUrl":"wbw/032_013_005.mp3","charTypeName":"word"},{"id":15575,"position":6,"arabic":"هُدَىٰهَا","translation":"পথনির্দেশ তার","audioUrl":"wbw/032_013_006.mp3","charTypeName":"word"},{"id":15576,"position":7,"arabic":"وَلَـٰكِنْ","translation":"কিন্তু","audioUrl":"wbw/032_013_007.mp3","charTypeName":"word"},{"id":15577,"position":8,"arabic":"حَقَّ","translation":"অবধারিত হয়েছে","audioUrl":"wbw/032_013_008.mp3","charTypeName":"word"},{"id":15578,"position":9,"arabic":"ٱلْقَوْلُ","translation":"(শাস্তির)বাণী","audioUrl":"wbw/032_013_009.mp3","charTypeName":"word"},{"id":15579,"position":10,"arabic":"مِنِّى","translation":"পক্ষ হ'তে আমার","audioUrl":"wbw/032_013_010.mp3","charTypeName":"word"},{"id":15580,"position":11,"arabic":"لَأَمْلَأَنَّ","translation":"অবশ্যই (যে) পূর্ণ করবো আমি\"","audioUrl":"wbw/032_013_011.mp3","charTypeName":"word"},{"id":15581,"position":12,"arabic":"جَهَنَّمَ","translation":"জাহান্নামকে","audioUrl":"wbw/032_013_012.mp3","charTypeName":"word"},{"id":15582,"position":13,"arabic":"مِنَ","translation":"দিয়ে","audioUrl":"wbw/032_013_013.mp3","charTypeName":"word"},{"id":15583,"position":14,"arabic":"ٱلْجِنَّةِ","translation":"জিনদের","audioUrl":"wbw/032_013_014.mp3","charTypeName":"word"},{"id":15584,"position":15,"arabic":"وَٱلنَّاسِ","translation":"ও মানুষদের","audioUrl":"wbw/032_013_015.mp3","charTypeName":"word"},{"id":15585,"position":16,"arabic":"أَجْمَعِينَ","translation":"একসাথে","audioUrl":"wbw/032_013_016.mp3","charTypeName":"word"},{"id":15586,"position":17,"arabic":"١٣","translation":"(১৩)","audioUrl":null,"charTypeName":"end"}]},{"number":14,"arabic":"فَذُوقُوا۟ بِمَا نَسِيتُمْ لِقَآءَ يَوْمِكُمْ هَٰذَآ إِنَّا نَسِينَٰكُمْ ۖ وَذُوقُوا۟ عَذَابَ ٱلْخُلْدِ بِمَا كُنتُمْ تَعْمَلُونَ","translation":"[And He will say unto the sinners:] “Taste, then, [the recompense] for your having been obli­vious of the coming of this your Day [of Judgment] - for, verily, We are [now] oblivious of you: taste, then, [this] abiding suffering for all [the evil] that you were wont to do!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3517.mp3","surahId":32,"words":[{"id":16631,"position":1,"arabic":"فَذُوقُوا۟","translation":"সুতরাং স্বাদ নাও","audioUrl":"wbw/032_014_001.mp3","charTypeName":"word"},{"id":16632,"position":2,"arabic":"بِمَا","translation":"একারণে যা","audioUrl":"wbw/032_014_002.mp3","charTypeName":"word"},{"id":16633,"position":3,"arabic":"نَسِيتُمْ","translation":"ভুলে গিয়েছিলে তোমরা","audioUrl":"wbw/032_014_003.mp3","charTypeName":"word"},{"id":16634,"position":4,"arabic":"لِقَآءَ","translation":"সাক্ষাৎ","audioUrl":"wbw/032_014_004.mp3","charTypeName":"word"},{"id":16635,"position":5,"arabic":"يَوْمِكُمْ","translation":"দিনের তোমাদের","audioUrl":"wbw/032_014_005.mp3","charTypeName":"word"},{"id":16636,"position":6,"arabic":"هَـٰذَآ","translation":"এই","audioUrl":"wbw/032_014_006.mp3","charTypeName":"word"},{"id":16637,"position":7,"arabic":"إِنَّا","translation":"নিশ্চয়ই আমরাও","audioUrl":"wbw/032_014_007.mp3","charTypeName":"word"},{"id":16638,"position":8,"arabic":"نَسِينَـٰكُمْ ۖ","translation":"আমরা ভুলে গিয়েছি তোমাদের","audioUrl":"wbw/032_014_008.mp3","charTypeName":"word"},{"id":16640,"position":9,"arabic":"وَذُوقُوا۟","translation":"এবং তোমরা স্বাদ গ্রহণ করো","audioUrl":"wbw/032_014_010.mp3","charTypeName":"word"},{"id":16641,"position":10,"arabic":"عَذَابَ","translation":"শাস্তির","audioUrl":"wbw/032_014_011.mp3","charTypeName":"word"},{"id":16642,"position":11,"arabic":"ٱلْخُلْدِ","translation":"চিরকালীন","audioUrl":"wbw/032_014_012.mp3","charTypeName":"word"},{"id":16643,"position":12,"arabic":"بِمَا","translation":"বিনিময়ে যা","audioUrl":"wbw/032_014_013.mp3","charTypeName":"word"},{"id":16644,"position":13,"arabic":"كُنتُمْ","translation":"তোমরা ছিলে","audioUrl":"wbw/032_014_014.mp3","charTypeName":"word"},{"id":16645,"position":14,"arabic":"تَعْمَلُونَ","translation":"তোমরা  কাজ করতে\"","audioUrl":"wbw/032_014_015.mp3","charTypeName":"word"},{"id":16646,"position":15,"arabic":"١٤","translation":"(১৪)","audioUrl":null,"charTypeName":"end"}]},{"number":15,"arabic":"إِنَّمَا يُؤْمِنُ بِـَٔايَٰتِنَا ٱلَّذِينَ إِذَا ذُكِّرُوا۟ بِهَا خَرُّوا۟ سُجَّدًۭا وَسَبَّحُوا۟ بِحَمْدِ رَبِّهِمْ وَهُمْ لَا يَسْتَكْبِرُونَ ۩","translation":"ONLY THEY [truly] believe in Our messages who, whenever they are conveyed to them, fall down, prostrating themselves in adoration, and extol their Sustainer’s limitless glory and praise; and who are never filled with false pride;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3518.mp3","surahId":32,"words":[{"id":17811,"position":1,"arabic":"إِنَّمَا","translation":"কেবল","audioUrl":"wbw/032_015_001.mp3","charTypeName":"word"},{"id":17812,"position":2,"arabic":"يُؤْمِنُ","translation":"ঈমান আনে","audioUrl":"wbw/032_015_002.mp3","charTypeName":"word"},{"id":17813,"position":3,"arabic":"بِـَٔايَـٰتِنَا","translation":"প্রতি আমাদের নিদর্শনাবলীর","audioUrl":"wbw/032_015_003.mp3","charTypeName":"word"},{"id":17814,"position":4,"arabic":"ٱلَّذِينَ","translation":"(তারাই)যারা","audioUrl":"wbw/032_015_004.mp3","charTypeName":"word"},{"id":17815,"position":5,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/032_015_005.mp3","charTypeName":"word"},{"id":17816,"position":6,"arabic":"ذُكِّرُوا۟","translation":"তাদেরকে স্মরণ করিয়ে দেওয়া হয়","audioUrl":"wbw/032_015_006.mp3","charTypeName":"word"},{"id":17817,"position":7,"arabic":"بِهَا","translation":"দ্বারা এ","audioUrl":"wbw/032_015_007.mp3","charTypeName":"word"},{"id":17818,"position":8,"arabic":"خَرُّوا۟","translation":"লুটিয়ে পড়ে","audioUrl":"wbw/032_015_008.mp3","charTypeName":"word"},{"id":17819,"position":9,"arabic":"سُجَّدًۭا","translation":"সিজদায়","audioUrl":"wbw/032_015_009.mp3","charTypeName":"word"},{"id":17820,"position":10,"arabic":"وَسَبَّحُوا۟","translation":"ও পবিত্রতা ঘোষণা করে","audioUrl":"wbw/032_015_010.mp3","charTypeName":"word"},{"id":17821,"position":11,"arabic":"بِحَمْدِ","translation":"সহ প্রশংসা","audioUrl":"wbw/032_015_011.mp3","charTypeName":"word"},{"id":17822,"position":12,"arabic":"رَبِّهِمْ","translation":"রবের তাদের","audioUrl":"wbw/032_015_012.mp3","charTypeName":"word"},{"id":17823,"position":13,"arabic":"وَهُمْ","translation":"এবং তারা","audioUrl":"wbw/032_015_013.mp3","charTypeName":"word"},{"id":17824,"position":14,"arabic":"لَا","translation":"না","audioUrl":"wbw/032_015_014.mp3","charTypeName":"word"},{"id":17825,"position":15,"arabic":"يَسْتَكْبِرُونَ ۩","translation":"অহংকার করে","audioUrl":"wbw/032_015_015.mp3","charTypeName":"word"},{"id":17827,"position":16,"arabic":"١٥","translation":"(১৫)","audioUrl":null,"charTypeName":"end"}]},{"number":16,"arabic":"تَتَجَافَىٰ جُنُوبُهُمْ عَنِ ٱلْمَضَاجِعِ يَدْعُونَ رَبَّهُمْ خَوْفًۭا وَطَمَعًۭا وَمِمَّا رَزَقْنَٰهُمْ يُنفِقُونَ","translation":"[and] who are im­pelled to rise from their beds [at night] to call out to their Sustainer in fear and hope; and who spend on others out of what We provide for them as sus­tenance.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3519.mp3","surahId":32,"words":[{"id":18856,"position":1,"arabic":"تَتَجَافَىٰ","translation":"আলাদা থাকে","audioUrl":"wbw/032_016_001.mp3","charTypeName":"word"},{"id":18857,"position":2,"arabic":"جُنُوبُهُمْ","translation":"পাশগুলো তাদের","audioUrl":"wbw/032_016_002.mp3","charTypeName":"word"},{"id":18858,"position":3,"arabic":"عَنِ","translation":"থেকে","audioUrl":"wbw/032_016_003.mp3","charTypeName":"word"},{"id":18859,"position":4,"arabic":"ٱلْمَضَاجِعِ","translation":"শয্যাগুলো","audioUrl":"wbw/032_016_004.mp3","charTypeName":"word"},{"id":18860,"position":5,"arabic":"يَدْعُونَ","translation":"তারা ডাকে","audioUrl":"wbw/032_016_005.mp3","charTypeName":"word"},{"id":18861,"position":6,"arabic":"رَبَّهُمْ","translation":"রবকে তাদের","audioUrl":"wbw/032_016_006.mp3","charTypeName":"word"},{"id":18862,"position":7,"arabic":"خَوْفًۭا","translation":"ভয়ে","audioUrl":"wbw/032_016_007.mp3","charTypeName":"word"},{"id":18863,"position":8,"arabic":"وَطَمَعًۭا","translation":"ও আশায়","audioUrl":"wbw/032_016_008.mp3","charTypeName":"word"},{"id":18864,"position":9,"arabic":"وَمِمَّا","translation":"এবং তা হ'তে যা","audioUrl":"wbw/032_016_009.mp3","charTypeName":"word"},{"id":18865,"position":10,"arabic":"رَزَقْنَـٰهُمْ","translation":"আমরা জীবিকা দিয়েছি তাদেরকে","audioUrl":"wbw/032_016_010.mp3","charTypeName":"word"},{"id":18866,"position":11,"arabic":"يُنفِقُونَ","translation":"তারা ব্যয় করে","audioUrl":"wbw/032_016_011.mp3","charTypeName":"word"},{"id":18867,"position":12,"arabic":"١٦","translation":"(১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":17,"arabic":"فَلَا تَعْلَمُ نَفْسٌۭ مَّآ أُخْفِىَ لَهُم مِّن قُرَّةِ أَعْيُنٍۢ جَزَآءًۢ بِمَا كَانُوا۟ يَعْمَلُونَ","translation":"And [as for all such believers,] no human being can imagine what blissful delights, as yet hidden, await them [in the life to come] as a reward for all that they did.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3520.mp3","surahId":32,"words":[{"id":19947,"position":1,"arabic":"فَلَا","translation":"অতঃপর না","audioUrl":"wbw/032_017_001.mp3","charTypeName":"word"},{"id":19948,"position":2,"arabic":"تَعْلَمُ","translation":"জানে","audioUrl":"wbw/032_017_002.mp3","charTypeName":"word"},{"id":19949,"position":3,"arabic":"نَفْسٌۭ","translation":"কোনো ব্যক্তিই","audioUrl":"wbw/032_017_003.mp3","charTypeName":"word"},{"id":19950,"position":4,"arabic":"مَّآ","translation":"যা","audioUrl":"wbw/032_017_004.mp3","charTypeName":"word"},{"id":19951,"position":5,"arabic":"أُخْفِىَ","translation":"লুকিয়ে রাখা হয়েছে","audioUrl":"wbw/032_017_005.mp3","charTypeName":"word"},{"id":19952,"position":6,"arabic":"لَهُم","translation":"জন্যে তাদের","audioUrl":"wbw/032_017_006.mp3","charTypeName":"word"},{"id":19953,"position":7,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/032_017_007.mp3","charTypeName":"word"},{"id":19954,"position":8,"arabic":"قُرَّةِ","translation":"শীতলকারী (জিনিসসমূহ)","audioUrl":"wbw/032_017_008.mp3","charTypeName":"word"},{"id":19955,"position":9,"arabic":"أَعْيُنٍۢ","translation":"চোখসমূহের","audioUrl":"wbw/032_017_009.mp3","charTypeName":"word"},{"id":19956,"position":10,"arabic":"جَزَآءًۢ","translation":"প্রতিদান হিসেবে","audioUrl":"wbw/032_017_010.mp3","charTypeName":"word"},{"id":19957,"position":11,"arabic":"بِمَا","translation":"বিনিময়ে যা","audioUrl":"wbw/032_017_011.mp3","charTypeName":"word"},{"id":19958,"position":12,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/032_017_012.mp3","charTypeName":"word"},{"id":19959,"position":13,"arabic":"يَعْمَلُونَ","translation":"তারা কাজ করতে","audioUrl":"wbw/032_017_013.mp3","charTypeName":"word"},{"id":19960,"position":14,"arabic":"١٧","translation":"(১৭)","audioUrl":null,"charTypeName":"end"}]},{"number":18,"arabic":"أَفَمَن كَانَ مُؤْمِنًۭا كَمَن كَانَ فَاسِقًۭا ۚ لَّا يَسْتَوُۥنَ","translation":"Is, then, he who [in his earthly life] was a believer to be compared with one who was in­iquitous? [Nay,] these two are not equal!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3521.mp3","surahId":32,"words":[{"id":20954,"position":1,"arabic":"أَفَمَن","translation":"কি তবে যে","audioUrl":"wbw/032_018_001.mp3","charTypeName":"word"},{"id":20955,"position":2,"arabic":"كَانَ","translation":"হবে","audioUrl":"wbw/032_018_002.mp3","charTypeName":"word"},{"id":20956,"position":3,"arabic":"مُؤْمِنًۭا","translation":"মু'মিন","audioUrl":"wbw/032_018_003.mp3","charTypeName":"word"},{"id":20957,"position":4,"arabic":"كَمَن","translation":"(সে কি তার) মতো যে","audioUrl":"wbw/032_018_004.mp3","charTypeName":"word"},{"id":20958,"position":5,"arabic":"كَانَ","translation":"হয়","audioUrl":"wbw/032_018_005.mp3","charTypeName":"word"},{"id":20959,"position":6,"arabic":"فَاسِقًۭا ۚ","translation":"সত্যত্যাগী (দুষ্কৃতিকারী)","audioUrl":"wbw/032_018_006.mp3","charTypeName":"word"},{"id":20961,"position":7,"arabic":"لَّا","translation":"না","audioUrl":"wbw/032_018_008.mp3","charTypeName":"word"},{"id":20962,"position":8,"arabic":"يَسْتَوُۥنَ","translation":"