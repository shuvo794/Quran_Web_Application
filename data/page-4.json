25310,"position":21,"arabic":"أَندَادًۭا","translation":"সমতুল্য (অন্য কাউকে)","audioUrl":"wbw/002_022_022.mp3","charTypeName":"word"},{"id":25311,"position":22,"arabic":"وَأَنتُمْ","translation":"অথচ তোমরা","audioUrl":"wbw/002_022_023.mp3","charTypeName":"word"},{"id":25312,"position":23,"arabic":"تَعْلَمُونَ","translation":"জানো","audioUrl":"wbw/002_022_024.mp3","charTypeName":"word"},{"id":25313,"position":24,"arabic":"٢٢","translation":"(২২)","audioUrl":null,"charTypeName":"end"}]},{"number":23,"arabic":"وَإِن كُنتُمْ فِى رَيْبٍۢ مِّمَّا نَزَّلْنَا عَلَىٰ عَبْدِنَا فَأْتُوا۟ بِسُورَةٍۢ مِّن مِّثْلِهِۦ وَٱدْعُوا۟ شُهَدَآءَكُم مِّن دُونِ ٱللَّهِ إِن كُنتُمْ صَٰدِقِينَ","translation":"And if you doubt any part of what We have, bestowed from on high, step by step, upon Our servant [Muhammad], then produce a surah of similar merit, and call upon any other than God to bear witness for you -if what you say is true!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/30.mp3","surahId":2,"words":[{"id":26426,"position":1,"arabic":"وَإِن","translation":"এবং যদি","audioUrl":"wbw/002_023_001.mp3","charTypeName":"word"},{"id":26427,"position":2,"arabic":"كُنتُمْ","translation":"তোমরা থাক","audioUrl":"wbw/002_023_002.mp3","charTypeName":"word"},{"id":26428,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/002_023_003.mp3","charTypeName":"word"},{"id":26429,"position":4,"arabic":"رَيْبٍۢ","translation":"সন্দেহের","audioUrl":"wbw/002_023_004.mp3","charTypeName":"word"},{"id":26430,"position":5,"arabic":"مِّمَّا","translation":"তা হতে যা","audioUrl":"wbw/002_023_005.mp3","charTypeName":"word"},{"id":26431,"position":6,"arabic":"نَزَّلْنَا","translation":"আমরা অবতীর্ণ করেছি","audioUrl":"wbw/002_023_006.mp3","charTypeName":"word"},{"id":26432,"position":7,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/002_023_007.mp3","charTypeName":"word"},{"id":26433,"position":8,"arabic":"عَبْدِنَا","translation":"আমাদের দাসের,","audioUrl":"wbw/002_023_008.m