o":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/31.mp3","surahId":2,"words":[{"id":27434,"position":1,"arabic":"فَإِن","translation":"কিন্তু যদি","audioUrl":"wbw/002_024_001.mp3","charTypeName":"word"},{"id":27435,"position":2,"arabic":"لَّمْ","translation":"না","audioUrl":"wbw/002_024_002.mp3","charTypeName":"word"},{"id":27436,"position":3,"arabic":"تَفْعَلُوا۟","translation":"তোমরা করো","audioUrl":"wbw/002_024_003.mp3","charTypeName":"word"},{"id":27437,"position":4,"arabic":"وَلَن","translation":"এবং কখনও না","audioUrl":"wbw/002_024_004.mp3","charTypeName":"word"},{"id":27438,"position":5,"arabic":"تَفْعَلُوا۟","translation":"তোমরা করতে পারবে","audioUrl":"wbw/002_024_005.mp3","charTypeName":"word"},{"id":27439,"position":6,"arabic":"فَٱتَّقُوا۟","translation":"তোমরা ভয় করো","audioUrl":"wbw/002_024_006.mp3","charTypeName":"word"},{"id":27440,"position":7,"arabic":"ٱلنَّارَ","translation":"আগুনের","audioUrl":"wbw/002_024_007.mp3","charTypeName":"word"},{"id":27441,"position":8,"arabic":"ٱلَّتِى","translation":"যা (এমন যে)","audioUrl":"wbw/002_024_008.mp3","charTypeName":"word"},{"id":27442,"position":9,"arabic":"وَقُودُهَا","translation":"তার ইন্ধন (হবে)","audioUrl":"wbw/002_024_009.mp3","charTypeName":"word"},{"id":27443,"position":10,"arabic":"ٱلنَّاسُ","translation":"মানুষ","audioUrl":"wbw/002_024_010.mp3","charTypeName":"word"},{"id":27444,"position":11,"arabic":"وَٱلْحِجَارَةُ ۖ","translation":"ও পাথরসমূহ","audioUrl":"wbw/002_024_011.mp3","charTypeName":"word"},{"id":27446,"position":12,"arabic":"أُعِدَّتْ","translation":"যা প্রস্তুুত করা হয়েছে","audioUrl":"wbw/002_024_013.mp3","charTypeName":"word"},{"id":27447,"position":13,"arabic":"لِلْكَـٰفِرِينَ","translation":"কাফিরদের জন্য","audioUrl":"wbw/002_024_014.mp3","charTypeName":"word"},{"id":27448,"position":14,"arabic":"٢٤","translation":"(২৪)","audioUrl":null,"charTypeName":"end"}]}]}