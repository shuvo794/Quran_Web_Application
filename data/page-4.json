{"id":4,"ayahs":[{"number":17,"arabic":"مَثَلُهُمْ كَمَثَلِ ٱلَّذِى ٱسْتَوْقَدَ نَارًۭا فَلَمَّآ أَضَآءَتْ مَا حَوْلَهُۥ ذَهَبَ ٱللَّهُ بِنُورِهِمْ وَتَرَكَهُمْ فِى ظُلُمَٰتٍۢ لَّا يُبْصِرُونَ","translation":"Their parable is that of people who kindle a fire: but as soon as it has illumined all around them, God takes away their light and leaves them in utter darkness, wherein they cannot see:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/24.mp3","surahId":2,"words":[{"id":19766,"position":1,"arabic":"مَثَلُهُمْ","translation":"তাদের উপমা","audioUrl":"wbw/002_017_001.mp3","charTypeName":"word"},{"id":19767,"position":2,"arabic":"كَمَثَلِ","translation":"উপমা যেমন (এক ব্যক্তির)","audioUrl":"wbw/002_017_002.mp3","charTypeName":"word"},{"id":19768,"position":3,"arabic":"ٱلَّذِى","translation":"যে","audioUrl":"wbw/002_017_003.mp3","charTypeName":"word"},{"id":19769,"position":4,"arabic":"ٱسْتَوْقَدَ","translation":"জ্বালালো","audioUrl":"wbw/002_017_004.mp3","charTypeName":"word"},{"id":19770,"position":5,"arabic":"نَارًۭا","translation":"আগুন","audioUrl":"wbw/002_017_005.mp3","charTypeName":"word"},{"id":19771,"position":6,"arabic":"فَلَمَّآ","translation":"অতঃপর যখন","audioUrl":"wbw/002_017_006.mp3","charTypeName":"word"},{"id":19772,"position":7,"arabic":"أَضَآءَتْ","translation":"আলোকিত করলো","audioUrl":"wbw/002_017_007.mp3","charTypeName":"word"},{"id":19773,"position":8,"arabic":"مَا","translation":"যা","audioUrl":"wbw/002_017_008.mp3","charTypeName":"word"},{"id":19774,"position":9,"arabic":"حَوْلَهُۥ","translation":"তার চারপাশে","audioUrl":"wbw/002_017_009.mp3","charTypeName":"word"},{"id":19775,"position":10,"arabic":"ذَهَبَ","translation":"নিলেন","audioUrl":"wbw/002_017_010.mp3","charTypeName":"word"},{"id":19776,"position":11,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌","audioUrl":"wbw/002_017_011.mp3","charTypeName":"word"},{"id":19777,"position":12,"arabic":"بِنُورِهِمْ","translation":"তাদের আলো নিয়ে","audioUrl":"wbw/002_017_012.mp3","ch