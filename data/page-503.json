{"id":503,"ayahs":[{"number":6,"arabic":"وَإِذَا حُشِرَ ٱلنَّاسُ كَانُوا۟ لَهُمْ أَعْدَآءًۭ وَكَانُوا۟ بِعِبَادَتِهِمْ كَٰفِرِينَ","translation":"such as, when all mankind is gathered [for judgment], will be enemies unto those [who worshipped them], and will utterly reject their worship?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4516.mp3","surahId":46,"words":[{"id":6022,"position":1,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/046_006_001.mp3","charTypeName":"word"},{"id":6023,"position":2,"arabic":"حُشِرَ","translation":"একত্র করা হবে","audioUrl":"wbw/046_006_002.mp3","charTypeName":"word"},{"id":6024,"position":3,"arabic":"ٱلنَّاسُ","translation":"সব মানুষকে","audioUrl":"wbw/046_006_003.mp3","charTypeName":"word"},{"id":6025,"position":4,"arabic":"كَانُوا۟","translation":"তারা হবে","audioUrl":"wbw/046_006_004.mp3","charTypeName":"word"},{"id":6026,"position":5,"arabic":"لَهُمْ","translation":"তাদের জন্যে","audioUrl":"wbw/046_006_005.mp3","charTypeName":"word"},{"id":6027,"position":6,"arabic":"أَعْدَآءًۭ","translation":"শত্রু","audioUrl":"wbw/046_006_006.mp3","charTypeName":"word"},{"id":6028,"position":7,"arabic":"وَكَانُوا۟","translation":"এবং তারা হবে","audioUrl":"wbw/046_006_007.mp3","charTypeName":"word"},{"id":6029,"position":8,"arabic":"بِعِبَادَتِهِمْ","translation":"তাদের উপাসনা সম্বন্ধে","audioUrl":"wbw/046_006_008.mp3","charTypeName":"word"},{"id":6030,"position":9,"arabic":"كَـٰفِرِينَ","translation":"অস্বীকারকারী","audioUrl":"wbw/046_006_009.mp3","charTypeName":"word"},{"id":6031,"position":10,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"وَإِذَا تُتْلَىٰ عَلَيْهِمْ ءَايَٰتُنَا بَيِّنَٰتٍۢ قَالَ ٱلَّذِينَ كَفَرُوا۟ لِلْحَقِّ لَمَّا جَآءَهُمْ هَٰذَا سِحْرٌۭ مُّبِينٌ","translation":"But whenever Our messages are conveyed to them in all their clarity, they who are bent on denying the truth speak thus of the truth as soon as it is brought to them: “This is clearly nothing but spell­binding eloquence!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4517.mp3","surahId":46,"words":[{"id":7335,"position":1,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/046_007_001.mp3","charTypeName":"word"},{"id":7336,"position":2,"arabic":"تُتْلَىٰ","translation":"আবৃত্তি করা হয়","audioUrl":"wbw/046_007_002.mp3","charTypeName":"word"},{"id":7337,"position":3,"arabic":"عَلَيْهِمْ","translation":"তাদের নিকট","audioUrl":"wbw/046_007_003.mp3","charTypeName":"word"},{"id":7338,"position":4,"arabic":"ءَايَـٰتُنَا","translation":"আমাদের আয়াতগুলোকে","audioUrl":"wbw/046_007_004.mp3","charTypeName":"word"},{"id":7339,"position":5,"arabic":"بَيِّنَـٰتٍۢ","translation":"সুস্পষ্ট","audioUrl":"wbw/046_007_005.mp3","charTypeName":"word"},{"id":7340,"position":6,"arabic":"قَالَ","translation":"(তখন) বলে","audioUrl":"wbw/046_007_006.mp3","charTypeName":"word"},{"id":7341,"position":7,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/046_007_007.mp3","charTypeName":"word"},{"id":7342,"position":8,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/046_007_008.mp3","charTypeName":"word"},{"id":7343,"position":9,"arabic":"لِلْحَقِّ","translation":"মহাসত্যকে","audioUrl":"wbw/046_007_009.mp3","charTypeName":"word"},{"id":7344,"position":10,"arabic":"لَمَّا","translation":"যখন","audioUrl":"wbw/046_007_010.mp3","charTypeName":"word"},{"id":7345,"position":11,"arabic":"جَآءَهُمْ","translation":"তাদের কাছে এসেছে","audioUrl":"wbw/046_007_011.mp3","charTypeName":"word"},{"id":7346,"position":12,"arabic":"هَـٰذَا","translation":"\"এটা","audioUrl":"wbw/046_007_012.mp3","charTypeName":"word"},{"id":7347,"position":13,"arabic":"سِحْرٌۭ","translation":"জাদু","audioUrl":"wbw/046_007_013.mp3","charTypeName":"word"},{"id":7348,"position":14,"arabic":"مُّبِينٌ","translation":"সুস্পষ্ট\"","audioUrl":"wbw/046_007_014.mp3","charTypeName":"word"},{"id":7349,"position":15,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"أَمْ يَقُولُونَ ٱفْتَرَىٰهُ ۖ قُلْ إِنِ ٱفْتَرَيْتُهُۥ فَلَا تَمْلِكُونَ لِى مِنَ ٱللَّهِ شَيْـًٔا ۖ هُوَ أَعْلَمُ بِمَا تُفِيضُونَ فِيهِ ۖ كَفَىٰ بِهِۦ شَهِيدًۢا بَيْنِى وَبَيْنَكُمْ ۖ وَهُوَ ٱلْغَفُورُ ٱلرَّحِيمُ","translation":"Or do they say, “He has invented all this”? Say [O Muhammad]: “Had I invented it, you would not be of the least help to me against God. He is fully aware of that [slander] into which you so reck­lessly plunge: enough is He as a witness between me and you! And [withal,] He alone is truly-forgiving, a true dispenser of grace.”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4518.mp3","surahId":46,"words":[{"id":8615,"position":1,"arabic":"أَمْ","translation":"অথবা","audioUrl":"wbw/046_008_001.mp3","charTypeName":"word"},{"id":8616,"position":2,"arabic":"يَقُولُونَ","translation":"তারা বলে","audioUrl":"wbw/046_008_002.mp3","charTypeName":"word"},{"id":8617,"position":3,"arabic":"ٱفْتَرَىٰهُ ۖ","translation":"\"সে তা রচনা করেছে\"","audioUrl":"wbw/046_008_003.mp3","charTypeName":"word"},{"id":8619,"position":4,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/046_008_005.mp3","charTypeName":"word"},{"id":8620,"position":5,"arabic":"إِنِ","translation":"\"যদি","audioUrl":"wbw/046_008_006.mp3","charTypeName":"word"},{"id":8621,"position":6,"arabic":"ٱفْتَرَيْتُهُۥ","translation":"তা আমি রচনা করে থাকি","audioUrl":"wbw/046_008_007.mp3","charTypeName":"word"},{"id":8622,"position":7,"arabic":"فَلَا","translation":"না তবে","audioUrl":"wbw/046_008_008.mp3","charTypeName":"word"},{"id":8623,"position":8,"arabic":"تَمْلِكُونَ","translation":"তোমরা সক্ষম","audioUrl":"wbw/046_008_009.mp3","charTypeName":"word"},{"id":8624,"position":9,"arabic":"لِى","translation":"আমাকে (রক্ষা করতে)","audioUrl":"wbw/046_008_010.mp3","charTypeName":"word"},{"id":8625,"position":10,"arabic":"مِنَ","translation":"হতে","audioUrl":"wbw/046_008_011.mp3","charTypeName":"word"},{"id":8626,"position":11,"arabic":"ٱللَّهِ","translation":"আল্লাহ","audioUrl":"wbw/046_008_012.mp3","charTypeName":"word"},{"id":8627,"position":12,"arabic":"شَيْـًٔا ۖ","translation":"কিছুমাত্র","audioUrl":"wbw/046_008_013.mp3","charTypeName":"word"},{"id":8629,"position":13,"arabic":"هُوَ","translation":"তিনি","audioUrl":"wbw/046_008_015.mp3","charTypeName":"word"},{"id":8630,"position":14,"arabic":"أَعْلَمُ","translation":"খুব জানেন","audioUrl":"wbw/046_008_016.mp3","charTypeName":"word"},{"id":8631,"position":15,"arabic":"بِمَا","translation":"ঐ বিষয়ে","audioUrl":"wbw/046_008_017.mp3","charTypeName":"word"},{"id":8632,"position":16,"arabic":"تُفِيضُونَ","translation":"তোমরা আলোচনা করে বেড়াচ্ছ","audioUrl":"wbw/046_008_018.mp3","charTypeName":"word"},{"id":8633,"position":17,"arabic":"فِيهِ ۖ","translation":"যে সম্বন্ধে","audioUrl":"wbw/046_008_019.mp3","charTypeName":"word"},{"id":8635,"position":18,"arabic":"كَفَىٰ","translation":"(তিনিই) যথেষ্ট","audioUrl":"wbw/046_008_021.mp3","charTypeName":"word"},{"id":8636,"position":19,"arabic":"بِهِۦ","translation":"সে বিষয়ে","audioUrl":"wbw/046_008_022.mp3","charTypeName":"word"},{"id":8637,"position":20,"arabic":"شَهِيدًۢا","translation":"সাক্ষী (হিসাবে)","audioUrl":"wbw/046_008_023.mp3","charTypeName":"word"},{"id":8638,"position":21,"arabic":"بَيْنِى","translation":"আমার মাঝে","audioUrl":"wbw/046_008_024.mp3","charTypeName":"word"},{"id":8639,"position":22,"arabic":"وَبَيْنَكُمْ ۖ","translation":"ও তোমাদের মাঝে","audioUrl":"wbw/046_008_025.mp3","charTypeName":"word"},{"id":8641,"position":23,"arabic":"وَهُوَ","translation":"এবং তিনিই","audioUrl":"wbw/046_008_027.mp3","charTypeName":"word"},{"id":8642,"position":24,"arabic":"ٱلْغَفُورُ","translation":"ক্ষমাশীল","audioUrl":"wbw/046_008_028.mp3","charTypeName":"word"},{"id":8643,"position":25,"arabic":"ٱلرَّحِيمُ","translation":"দয়াময়","audioUrl":"wbw/046_008_029.mp3","charTypeName":"word"},{"id":8644,"position":26,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"قُلْ مَا كُنتُ بِدْعًۭا مِّنَ ٱلرُّسُلِ وَمَآ أَدْرِى مَا يُفْعَلُ بِى وَلَا بِكُمْ ۖ إِنْ أَتَّبِعُ إِلَّا مَا يُوحَىٰٓ إِلَىَّ وَمَآ أَنَا۠ إِلَّا نَذِيرٌۭ مُّبِينٌۭ","translation":"Say: “I am not the first of [God’s] apostles; and [like all of them,] I do not know what will be done with me or with you: for I am nothing but a plain warner.”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4519.mp3","surahId":46,"words":[{"id":9815,"position":1,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/046_009_001.mp3","charTypeName":"word"},{"id":9816,"position":2,"arabic":"مَا","translation":"\"নই","audioUrl":"wbw/046_009_002.mp3","charTypeName":"word"},{"id":9817,"position":3,"arabic":"كُنتُ","translation":"আমি (কোন রাসূল)","audioUrl":"wbw/046_009_003.mp3","charTypeName":"word"},{"id":9818,"position":4,"arabic":"بِدْعًۭا","translation":"অভিনব","audioUrl":"wbw/046_009_004.mp3","charTypeName":"word"},{"id":9819,"position":5,"arabic":"مِّنَ","translation":"মধ্য হতে","audioUrl":"wbw/046_009_005.mp3","charTypeName":"word"},{"id":9820,"position":6,"arabic":"ٱلرُّسُلِ","translation":"রাসূলগণের","audioUrl":"wbw/046_009_006.mp3","charTypeName":"word"},{"id":9821,"position":7,"arabic":"وَمَآ","translation":"এবং না","audioUrl":"wbw/046_009_007.mp3","charTypeName":"word"},{"id":9822,"position":8,"arabic":"أَدْرِى","translation":"আমি জানি","audioUrl":"wbw/046_009_008.mp3","charTypeName":"word"},{"id":9823,"position":9,"arabic":"مَا","translation":"কি","audioUrl":"wbw/046_009_009.mp3","charTypeName":"word"},{"id":9824,"position":10,"arabic":"يُفْعَلُ","translation":"(আচরণ) করা হবে","audioUrl":"wbw/046_009_010.mp3","charTypeName":"word"},{"id":9825,"position":11,"arabic":"بِى","translation":"আমার সাথে","audioUrl":"wbw/046_009_011.mp3","charTypeName":"word"},{"id":9826,"position":12,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/046_009_012.mp3","charTypeName":"word"},{"id":9827,"position":13,"arabic":"بِكُمْ ۖ","translation":"তোমাদের সাথে","audioUrl":"wbw/046_009_013.mp3","charTypeName":"word"},{"id":9829,"position":14,"arabic":"إِنْ","translation":"না","audioUrl":"wbw/046_009_015.mp3","charTypeName":"word"},{"id":9830,"position":15,"arabic":"أَتَّبِعُ","translation":"আমি অনুসরণ করি","audioUrl":"wbw/046_009_016.mp3","charTypeName":"word"},{"id":9831,"position":16,"arabic":"إِلَّا","translation":"এ ব্যতীত","audioUrl":"wbw/046_009_017.mp3","charTypeName":"word"},{"id":9832,"position":17,"arabic":"مَا","translation":"যা","audioUrl":"wbw/046_009_018.mp3","charTypeName":"word"},{"id":9833,"position":18,"arabic":"يُوحَىٰٓ","translation":"ওহী করা হয়","audioUrl":"wbw/046_009_019.mp3","charTypeName":"word"},{"id":9834,"position":19,"arabic":"إِلَىَّ","translation":"আমার প্রতি","audioUrl":"wbw/046_009_020.mp3","charTypeName":"word"},{"id":9835,"position":20,"arabic":"وَمَآ","translation":"এবং নই","audioUrl":"wbw/046_009_021.mp3","charTypeName":"word"},{"id":9836,"position":21,"arabic":"أَنَا۠","translation":"আমি (আর কিছু)","audioUrl":"wbw/046_009_022.mp3","charTypeName":"word"},{"id":9837,"position":22,"arabic":"إِلَّا","translation":"এ ব্যতীত","audioUrl":"wbw/046_009_023.mp3","charTypeName":"word"},{"id":9838,"position":23,"arabic":"نَذِيرٌۭ","translation":"একজন সতর্ককারী","audioUrl":"wbw/046_009_024.mp3","charTypeName":"word"},{"id":9839,"position":24,"arabic":"مُّبِينٌۭ","translation":"সুস্পষ্ট\"","audioUrl":"wbw/046_009_025.mp3","charTypeName":"word"},{"id":9840,"position":25,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"قُلْ أَرَءَيْتُمْ إِن كَانَ مِنْ عِندِ ٱللَّهِ وَكَفَرْتُم بِهِۦ وَشَهِدَ شَاهِدٌۭ مِّنۢ بَنِىٓ إِسْرَٰٓءِيلَ عَلَىٰ مِثْلِهِۦ فَـَٔامَنَ وَٱسْتَكْبَرْتُمْ ۖ إِنَّ ٱللَّهَ لَا يَهْدِى ٱلْقَوْمَ ٱلظَّٰلِمِينَ","translation":"Say: “Have you given thought [to how you will fare] if this be truly [a revelation] from God and yet you deny its truth? - even though a witness from among the children of Israel has already borne wit­ness to [the advent of] one like himself, and has believed [in him], the while you glory in your arro­gance [and reject his message]? Verily, God does not grace [such] evildoing folk with His guidance!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4520.mp3","surahId":46,"words":[{"id":10994,"position":1,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/046_010_001.mp3","charTypeName":"word"},{"id":10995,"position":2,"arabic":"أَرَءَيْتُمْ","translation":"\"তোমরা (ভেবে) দেখেছ কি","audioUrl":"wbw/046_010_002.mp3","charTypeName":"word"},{"id":10996,"position":3,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/046_010_003.mp3","charTypeName":"word"},{"id":10997,"position":4,"arabic":"كَانَ","translation":"হয় (এটা)","audioUrl":"wbw/046_010_004.mp3","charTypeName":"word"},{"id":10998,"position":5,"arabic":"مِنْ","translation":"হতে","audioUrl":"wbw/046_010_005.mp3","charTypeName":"word"},{"id":10999,"position":6,"arabic":"عِندِ","translation":"নিকট","audioUrl":"wbw/046_010_006.mp3","charTypeName":"word"},{"id":11000,"position":7,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/046_010_007.mp3","charTypeName":"word"},{"id":11001,"position":8,"arabic":"وَكَفَرْتُم","translation":"আর তোমরা অস্বীকার করছ (তবে কি পরিণতি হবে)","audioUrl":"wbw/046_010_008.mp3","charTypeName":"word"},{"id":11002,"position":9,"arabic":"بِهِۦ","translation":"তা","audioUrl":"wbw/046_010_009.mp3","charTypeName":"word"},{"id":11003,"position":10,"arabic":"وَشَهِدَ","translation":"এবং সাক্ষ্য দিয়েছে","audioUrl":"wbw/046_010_010.mp3","charTypeName":"word"},{"id":11004,"position":11,"arabic":"شَاهِدٌۭ","translation":"একজন সাক্ষী","audioUrl":"wbw/046_010_011.mp3","charTypeName":"word"},{"id":11005,"position":12,"arabic":"مِّنۢ","translation":"মধ্য হতে","audioUrl":"wbw/046_010_012.mp3","charTypeName":"word"},{"id":11006,"position":13,"arabic":"بَنِىٓ","translation":"বনী","audioUrl":"wbw/046_010_013.mp3","charTypeName":"word"},{"id":11007,"position":14,"arabic":"إِسْرَٰٓءِيلَ","translation":"ইসরাঈলের","audioUrl":"wbw/046_010_014.mp3","charTypeName":"word"},{"id":11008,"position":15,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/046_010_015.mp3","charTypeName":"word"},{"id":11009,"position":16,"arabic":"مِثْلِهِۦ","translation":"তার অনুরূপ (কালামের)","audioUrl":"wbw/046_010_016.mp3","charTypeName":"word"},{"id":11010,"position":17,"arabic":"فَـَٔامَنَ","translation":"এরপরে সে ঈমান আনল","audioUrl":"wbw/046_010_017.mp3","charTypeName":"word"},{"id":11011,"position":18,"arabic":"وَٱسْتَكْبَرْتُمْ ۖ","translation":"অথচ তোমরা অহংকার করলে\"","audioUrl":"wbw/046_010_018.mp3","charTypeName":"word"},{"id":11013,"position":19,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/046_010_020.mp3","charTypeName":"word"},{"id":11014,"position":20,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/046_010_021.mp3","charTypeName":"word"},{"id":11015,"position":21,"arabic":"لَا","translation":"না","audioUrl":"wbw/046_010_022.mp3","charTypeName":"word"},{"id":11016,"position":22,"arabic":"يَهْدِى","translation":"পথ দেখান","audioUrl":"wbw/046_010_023.mp3","charTypeName":"word"},{"id":11017,"position":23,"arabic":"ٱلْقَوْمَ","translation":"সম্প্রদায়কে","audioUrl":"wbw/046_010_024.mp3","charTypeName":"word"},{"id":11018,"position":24,"arabic":"ٱلظَّـٰلِمِينَ","translation":"সীমালঙ্ঘনকারী","audioUrl":"wbw/046_010_025.mp3","charTypeName":"word"},{"id":11019,"position":25,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"وَقَالَ ٱلَّذِينَ كَفَرُوا۟ لِلَّذِينَ ءَامَنُوا۟ لَوْ كَانَ خَيْرًۭا مَّا سَبَقُونَآ إِلَيْهِ ۚ وَإِذْ لَمْ يَهْتَدُوا۟ بِهِۦ فَسَيَقُولُونَ هَٰذَآ إِفْكٌۭ قَدِيمٌۭ","translation":"But they who are bent on denying the truth speak thus of those who have attained to faith: “If this [message] were any good, these [people] would not have preceded us in accepting it!” And since they refuse to be guided by it, they will always say, “This is [but] an ancient falsehood!”","audio":"https://cdn.islamic.network/quran/audio/12