Url":"wbw/006_047_002.mp3","charTypeName":"word"},{"id":46790,"position":3,"arabic":"إِنْ","translation":"যদি","audioUrl":"wbw/006_047_003.mp3","charTypeName":"word"},{"id":46791,"position":4,"arabic":"أَتَىٰكُمْ","translation":"কাছে এসে পড়ে তোমাদের","audioUrl":"wbw/006_047_004.mp3","charTypeName":"word"},{"id":46792,"position":5,"arabic":"عَذَابُ","translation":"শাস্তি","audioUrl":"wbw/006_047_005.mp3","charTypeName":"word"},{"id":46793,"position":6,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/006_047_006.mp3","charTypeName":"word"},{"id":46794,"position":7,"arabic":"بَغْتَةً","translation":"হঠাৎ","audioUrl":"wbw/006_047_007.mp3","charTypeName":"word"},{"id":46795,"position":8,"arabic":"أَوْ","translation":"বা","audioUrl":"wbw/006_047_008.mp3","charTypeName":"word"},{"id":46796,"position":9,"arabic":"جَهْرَةً","translation":"প্রকাশ্যে","audioUrl":"wbw/006_047_009.mp3","charTypeName":"word"},{"id":46797,"position":10,"arabic":"هَلْ","translation":"কি","audioUrl":"wbw/006_047_010.mp3","charTypeName":"word"},{"id":46798,"position":11,"arabic":"يُهْلَكُ","translation":"ধ্বংস করা হবে","audioUrl":"wbw/006_047_011.mp3","charTypeName":"word"},{"id":46799,"position":12,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/006_047_012.mp3","charTypeName":"word"},{"id":46800,"position":13,"arabic":"ٱلْقَوْمُ","translation":"(যারা)সম্প্রদায়","audioUrl":"wbw/006_047_013.mp3","charTypeName":"word"},{"id":46801,"position":14,"arabic":"ٱلظَّـٰلِمُونَ","translation":"সীমালঙ্ঘনকারী","audioUrl":"wbw/006_047_014.mp3","charTypeName":"word"},{"id":46802,"position":15,"arabic":"٤٧","translation":"(৪৭)","audioUrl":null,"charTypeName":"end"}]},{"number":48,"arabic":"وَمَا نُرْسِلُ ٱلْمُرْسَلِينَ إِلَّا مُبَشِّرِينَ وَمُنذِرِينَ ۖ فَمَنْ ءَامَنَ وَأَصْلَحَ فَلَا خَوْفٌ عَلَيْهِمْ وَلَا هُمْ يَحْزَنُونَ","translation":"And We send [Our] message-bearers only as heralds of glad tidings and as warners: hence, all who believe and live righteously -no fear need they have, and neither shall they grieve;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/837.mp3","surahId":6,"words":[{"id":47550,"position":1,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/006_048_001.mp3","charTypeName":"word"},{"id":47551,"position":2,"arabic":"نُرْسِلُ","translation":"আমরা পাঠিয়েছি","audioUrl":"wbw/006_048_002.mp3","charTypeName":"word"},{"id":47552,"position":3,"arabic":"ٱلْمُرْسَلِينَ","translation":"রাসূলগণকে","audioUrl":"wbw/006_048_003.mp3","charTypeName":"word"},{"id":47553,"position":4,"arabic":"إِلَّا","translation":"এ ছাড়া যে","audioUrl":"wbw/006_048_004.mp3","charTypeName":"word"},{"id":47554,"position":5,"arabic":"مُبَشِّرِينَ","translation":"সুসংবাদদাতা","audioUrl":"wbw/006_048_005.mp3","charTypeName":"word"},{"id":47555,"position":6,"arabic":"وَمُنذِرِينَ ۖ","translation":"ও সতর্ককারী (হিসেবে)","audioUrl":"wbw/006_048_006.mp3","charTypeName":"word"},{"id":47557,"position":7,"arabic":"فَمَنْ","translation":"অতএব যে","audioUrl":"wbw/006_048_008.mp3","charTypeName":"word"},{"id":47558,"position":8,"arabic":"ءَامَنَ","translation":"ঈমান আনবে","audioUrl":"wbw/006_048_009.mp3","charTypeName":"word"},{"id":47559,"position":9,"arabic":"وَأَصْلَحَ","translation":"ও সংশোধন করবে","audioUrl":"wbw/006_048_010.mp3","charTypeName":"word"},{"id":47560,"position":10,"arabic":"فَلَا","translation":"সেক্ষেত্রে নেই","audioUrl":"wbw/006_048_011.mp3","charTypeName":"word"},{"id":47561,"position":11,"arabic":"خَوْفٌ","translation":"কোনো ভয়","audioUrl":"wbw/006_048_012.mp3","charTypeName":"word"},{"id":47562,"position":12,"arabic":"عَلَيْهِمْ","translation":"উপর তাদের","audioUrl":"wbw/006_048_013.mp3","charTypeName":"word"},{"id":47563,"position":13,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/006_048_014.mp3","charTypeName":"word"},{"id":47564,"position":14,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/006_048_015.mp3","charTypeName":"word"},{"id":47565,"position":15,"arabic":"يَحْزَنُونَ","translation":"দুঃখিত হবে","audioUr