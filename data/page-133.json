{"id":133,"ayahs":[{"number":45,"arabic":"فَقُطِعَ دَابِرُ ٱلْقَوْمِ ٱلَّذِينَ ظَلَمُوا۟ ۚ وَٱلْحَمْدُ لِلَّهِ رَبِّ ٱلْعَٰلَمِينَ","translation":"and [in the end,] the last remnant of those folk who had been bent on evildoing was wiped out. For all praise is due to God, the Sustainer of all the worlds.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/834.mp3","surahId":6,"words":[{"id":45402,"position":1,"arabic":"فَقُطِعَ","translation":"অতঃপর উচ্ছেদ করা হলো","audioUrl":"wbw/006_045_001.mp3","charTypeName":"word"},{"id":45403,"position":2,"arabic":"دَابِرُ","translation":"মূল","audioUrl":"wbw/006_045_002.mp3","charTypeName":"word"},{"id":45404,"position":3,"arabic":"ٱلْقَوْمِ","translation":"(ঐ)সম্প্রদায়ের","audioUrl":"wbw/006_045_003.mp3","charTypeName":"word"},{"id":45405,"position":4,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/006_045_004.mp3","charTypeName":"word"},{"id":45406,"position":5,"arabic":"ظَلَمُوا۟ ۚ","translation":"সীমালঙ্ঘন করেছিলো","audioUrl":"wbw/006_045_005.mp3","charTypeName":"word"},{"id":45408,"position":6,"arabic":"وَٱلْحَمْدُ","translation":"আর সব প্রশংসা","audioUrl":"wbw/006_045_007.mp3","charTypeName":"word"},{"id":45409,"position":7,"arabic":"لِلَّهِ","translation":"জন্যে আল্লাহরই","audioUrl":"wbw/006_045_008.mp3","charTypeName":"word"},{"id":45410,"position":8,"arabic":"رَبِّ","translation":"(যিনি) রব","audioUrl":"wbw/006_045_009.mp3","charTypeName":"word"},{"id":45411,"position":9,"arabic":"ٱلْعَـٰلَمِينَ","translation":"বিশ্বজগতের","audioUrl":"wbw/006_045_010.mp3","charTypeName":"word"},{"id":45412,"position":10,"arabic":"٤٥","translation":"(৪৫)","audioUrl":null,"charTypeName":"end"}]},{"number":46,"arabic":"قُلْ أَرَءَيْتُمْ إِنْ أَخَذَ ٱللَّهُ سَمْعَكُمْ وَأَبْصَٰرَكُمْ وَخَتَمَ عَلَىٰ قُلُوبِكُم مَّنْ إِلَٰهٌ غَيْرُ ٱللَّهِ يَأْتِيكُم بِهِ ۗ ٱنظُرْ كَيْفَ نُصَرِّفُ ٱلْءَايَٰتِ ثُمَّ هُمْ يَصْدِفُونَ","translation":"Say: \"What do you think? If God should take away your hearing and your sight and seal 