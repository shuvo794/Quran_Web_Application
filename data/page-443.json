{"id":443,"ayahs":[{"number":41,"arabic":"وَءَايَةٌۭ لَّهُمْ أَنَّا حَمَلْنَا ذُرِّيَّتَهُمْ فِى ٱلْفُلْكِ ٱلْمَشْحُونِ","translation":"And [it ought to be] a sign for them that We bear their offspring [over the seas] in laden ships,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3746.mp3","surahId":36,"words":[{"id":42602,"position":1,"arabic":"وَءَايَةٌۭ","translation":"এবং একটি নিদর্শন","audioUrl":"wbw/036_041_001.mp3","charTypeName":"word"},{"id":42603,"position":2,"arabic":"لَّهُمْ","translation":"তাদের জন্যে","audioUrl":"wbw/036_041_002.mp3","charTypeName":"word"},{"id":42604,"position":3,"arabic":"أَنَّا","translation":"(এও) যে আমরা","audioUrl":"wbw/036_041_003.mp3","charTypeName":"word"},{"id":42605,"position":4,"arabic":"حَمَلْنَا","translation":"আমরা আরোহণ করিয়েছি","audioUrl":"wbw/036_041_004.mp3","charTypeName":"word"},{"id":42606,"position":5,"arabic":"ذُرِّيَّتَهُمْ","translation":"তাদের বংশধরদেরকে","audioUrl":"wbw/036_041_005.mp3","charTypeName":"word"},{"id":42607,"position":6,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/036_041_006.mp3","charTypeName":"word"},{"id":42608,"position":7,"arabic":"ٱلْفُلْكِ","translation":"জাহাজের","audioUrl":"wbw/036_041_007.mp3","charTypeName":"word"},{"id":42609,"position":8,"arabic":"ٱلْمَشْحُونِ","translation":"বোঝাই","audioUrl":"wbw/036_041_008.mp3","charTypeName":"word"},{"id":42610,"position":9,"arabic":"٤١","translation":"(৪১)","audioUrl":null,"charTypeName":"end"}]},{"number":42,"arabic":"وَخَلَقْنَا لَهُم مِّن مِّثْلِهِۦ مَا يَرْكَبُونَ","translation":"and [that] We create for them things of a similar kind, on which they may embark [in their travels];","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3747.mp3","surahId":36,"words":[{"id":43327,"position":1,"arabic":"وَخَلَقْنَا","translation":"এবং আমরা সৃষ্টি করেছি","audioUrl":"wbw/036_042_001.mp3","charTypeName":"word"},{"id":43328,"position":2,"arabic":"لَهُم","translation":"তাদের জন্যে","audioUrl":"wbw/036_042_002.m