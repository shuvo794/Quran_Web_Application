,"charTypeName":"word"},{"id":47057,"position":7,"arabic":"صَـٰدِقِينَ","translation":"সত্যবাদী\"","audioUrl":"wbw/036_048_007.mp3","charTypeName":"word"},{"id":47058,"position":8,"arabic":"٤٨","translation":"(৪৮)","audioUrl":null,"charTypeName":"end"}]},{"number":49,"arabic":"مَا يَنظُرُونَ إِلَّا صَيْحَةًۭ وَٰحِدَةًۭ تَأْخُذُهُمْ وَهُمْ يَخِصِّمُونَ","translation":"[And they are unaware that] nothing awaits them beyond a single blast [of God’s punishment], which will overtake them while they are still arguing - [against resurrection]:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3754.mp3","surahId":36,"words":[{"id":48297,"position":1,"arabic":"مَا","translation":"না","audioUrl":"wbw/036_049_001.mp3","charTypeName":"word"},{"id":48298,"position":2,"arabic":"يَنظُرُونَ","translation":"তারা অপেক্ষা করছে","audioUrl":"wbw/036_049_002.mp3","charTypeName":"word"},{"id":48299,"position":3,"arabic":"إِلَّا","translation":"এছাড়া","audioUrl":"wbw/036_049_003.mp3","charTypeName":"word"},{"id":48300,"position":4,"arabic":"صَيْحَةًۭ","translation":"মহাগর্জনের","audioUrl":"wbw/036_049_004.mp3","charTypeName":"word"},{"id":48301,"position":5,"arabic":"وَٰحِدَةًۭ","translation":"একটি মাত্র","audioUrl":"wbw/036_049_005.mp3","charTypeName":"word"},{"id":48302,"position":6,"arabic":"تَأْخُذُهُمْ","translation":"তাদেরকে আঘাত করবে","audioUrl":"wbw/036_049_006.mp3","charTypeName":"word"},{"id":48303,"position":7,"arabic":"وَهُمْ","translation":"এ অবস্থায় যে তারা","audioUrl":"wbw/036_049_007.mp3","charTypeName":"word"},{"id":48304,"position":8,"arabic":"يَخِصِّمُونَ","translation":"তর্কাতর্কি করতে থাকবে","audioUrl":"wbw/036_049_008.mp3","charTypeName":"word"},{"id":48305,"position":9,"arabic":"٤٩","translation":"(৪৯)","audioUrl":null,"charTypeName":"end"}]},{"number":50,"arabic":"فَلَا يَسْتَطِيعُونَ تَوْصِيَةًۭ وَلَآ إِلَىٰٓ أَهْلِهِمْ يَرْجِعُونَ","translation":"and so [sudden will be their end that] no testament will they be able to make, - nor to their own people will they return!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3755.mp3","surahId":36,"words":[{"id":48989,"position":1,"arabic":"فَلَا","translation":"না তখন","audioUrl":"wbw/036_050_001.mp3","charTypeName":"word"},{"id":48990,"position":2,"arabic":"يَسْتَطِيعُونَ","translation":"তারা সমর্থ হবে","audioUrl":"wbw/036_050_002.mp3","charTypeName":"word"},{"id":48991,"position":3,"arabic":"تَوْصِيَةًۭ","translation":"উপদেশ করতে","audioUrl":"wbw/036_050_003.mp3","charTypeName":"word"},{"id":48992,"position":4,"arabic":"وَلَآ","translation":"আর না","audioUrl":"wbw/036_050_004.mp3","charTypeName":"word"},{"id":48993,"position":5,"arabic":"إِلَىٰٓ","translation":"প্রতি","audioUrl":"wbw/036_050_005.mp3","charTypeName":"word"},{"id":48994,"position":6,"arabic":"أَهْلِهِمْ","translation":"তাদের পরিবারের","audioUrl":"wbw/036_050_006.mp3","charTypeName":"word"},{"id":48995,"position":7,"arabic":"يَرْجِعُونَ","translation":"তারা ফিরে যেতে পারবে","audioUrl":"wbw/036_050_007.mp3","charTypeName":"word"},{"id":48996,"position":8,"arabic":"٥٠","translation":"(৫০)","audioUrl":null,"charTypeName":"end"}]},{"number":51,"arabic":"وَنُفِخَ فِى ٱلصُّورِ فَإِذَا هُم مِّنَ ٱلْأَجْدَاثِ إِلَىٰ رَبِّهِمْ يَنسِلُونَ","translation":"And [then] the trumpet [of resurrection] will be blown - and lo! out of their graves towards their Sustainer will they all rush forth!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3756.mp3","surahId":36,"words":[{"id":49601,"position":1,"arabic":"وَنُفِخَ","translation":"এবং ফুঁ দেওয়া হবে","audioUrl":"wbw/036_051_001.mp3","charTypeName":"word"},{"id":49602,"position":2,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/036_051_002.mp3","charTypeName":"word"},{"id":49603,"position":3,"arabic":"ٱلصُّورِ","translation":"শিঙ্গার","audioUrl":"wbw/036_051_003.mp3","charTypeName":"word"},{"id":49604,"position":4,"arabic":"فَإِذَا","translation":"তখন অতঃপর","audioUrl":"wbw/036_051_004.mp3","charTypeName":"word"},{"id":49605,"position":5,"arabic":"هُم","translation":"তারা","audioUrl":"wbw/036_051_005.mp3","charTypeName":"word"},{"id":49606,"position":6,"arabic":"مِّنَ","translation":"হ'তে","audioUrl":"wbw/036_051_006.mp3","charTypeName":"word"},{"id":49607,"position":7,"arabic":"ٱلْأَجْدَاثِ","translation":"কবরসমূহ","audioUrl":"wbw/036_051_007.mp3","charTypeName":"word"},{"id":49608,"position":8,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/036_051_008.mp3","charTypeName":"word"},{"id":49609,"position":9,"arabic":"رَبِّهِمْ","translation":"তাদের রবের","audioUrl":"wbw/036_051_009.mp3","charTypeName":"word"},{"id":49610,"position":10,"arabic":"يَنسِلُونَ","translation":"ছুটে আসবে","audioUrl":"wbw/036_051_010.mp3","charTypeName":"word"},{"id":49611,"position":11,"arabic":"٥١","translation":"(৫১)","audioUrl":null,"charTypeName":"end"}]},{"number":52,"arabic":"قَالُوا۟ يَٰوَيْلَنَا مَنۢ بَعَثَنَا مِن مَّرْقَدِنَا ۜ ۗ هَٰذَا مَا وَعَدَ ٱلرَّحْمَٰنُ وَصَدَقَ ٱلْمُرْسَلُونَ","translation":"They will say: “Oh, woe unto us! Who has roused us from our sleep [of death]?” [Whereupon they will be told:] “This is what the Most Gracious has promised! And His message-bearers spoke the truth!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3757.mp3","surahId":36,"words":[{"id":50051,"position":1,"arabic":"قَالُوا۟","translation":"(ভীত হয়ে) তারা বলবে","audioUrl":"wbw/036_052_001.mp3","charTypeName":"word"},{"id":50052,"position":2,"arabic":"يَـٰوَيْلَنَا","translation":"\"আমাদের দুর্ভোগ হায়","audioUrl":"wbw/036_052_002.mp3","charTypeName":"word"},{"id":50053,"position":3,"arabic":"مَنۢ","translation":"কে","audioUrl":"wbw/036_052_003.mp3","charTypeName":"word"},{"id":50054,"position":4,"arabic":"بَعَثَنَا","translation":"আমাদেরকে উঠালো","audioUrl":"wbw/036_052_004.mp3","charTypeName":"word"},{"id":50055,"position":5,"arabic":"مِن","translation":"হ'তে","audioUrl":"wbw/036_052_005.mp3","charTypeName":"word"},{"id":50056,"position":6,"arabic":"مَّرْقَدِنَا ۜ ۗ","translation":"আমাদের ঘু