{"id":81,"ayahs":[{"number":20,"arabic":"وَإِنْ أَرَدتُّمُ ٱسْتِبْدَالَ زَوْجٍۢ مَّكَانَ زَوْجٍۢ وَءَاتَيْتُمْ إِحْدَىٰهُنَّ قِنطَارًۭا فَلَا تَأْخُذُوا۟ مِنْهُ شَيْـًٔا ۚ أَتَأْخُذُونَهُۥ بُهْتَٰنًۭا وَإِثْمًۭا مُّبِينًۭا","translation":"But if you desire to give up a wife and to take another in her stead, do not take away anything of what you have given the first one, however much it may have been. Would you, perchance, take it away by slandering her and thus committing a manifest sin?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/513.mp3","surahId":4,"words":[{"id":23284,"position":1,"arabic":"وَإِنْ","translation":"এবং যদি","audioUrl":"wbw/004_020_001.mp3","charTypeName":"word"},{"id":23285,"position":2,"arabic":"أَرَدتُّمُ","translation":"তোমরা ইচ্ছা করে থাক","audioUrl":"wbw/004_020_002.mp3","charTypeName":"word"},{"id":23286,"position":3,"arabic":"ٱسْتِبْدَالَ","translation":"পরিবর্তন করতে","audioUrl":"wbw/004_020_003.mp3","charTypeName":"word"},{"id":23287,"position":4,"arabic":"زَوْجٍۢ","translation":"এক স্ত্রী","audioUrl":"wbw/004_020_004.mp3","charTypeName":"word"},{"id":23288,"position":5,"arabic":"مَّكَانَ","translation":"জায়গায়","audioUrl":"wbw/004_020_005.mp3","charTypeName":"word"},{"id":23289,"position":6,"arabic":"زَوْجٍۢ","translation":"(অন্য) এক স্ত্রীর","audioUrl":"wbw/004_020_006.mp3","charTypeName":"word"},{"id":23290,"position":7,"arabic":"وَءَاتَيْتُمْ","translation":"এবং তোমরা দিয়েছ","audioUrl":"wbw/004_020_007.mp3","charTypeName":"word"},{"id":23291,"position":8,"arabic":"إِحْدَىٰهُنَّ","translation":"তাদের কাউকে","audioUrl":"wbw/004_020_008.mp3","charTypeName":"word"},{"id":23292,"position":9,"arabic":"قِنطَارًۭا","translation":"অগাধ সম্পদ","audioUrl":"wbw/004_020_009.mp3","charTypeName":"word"},{"id":23293,"position":10,"arabic":"فَلَا","translation":"না তবুও","audioUrl":"wbw/004_020_010.mp3","charTypeName":"word"},{"id":23294,"position":11,"arabic":"تَأْخُذُوا۟","translation":"তোমরা গ্রহণ করবে","audioUrl":"wbw/004_020_011.mp3","charTypeName":"word"},{"id":23295,"position":12,"arabic":"مِنْهُ","translation":"তা থেকে","audioUrl":"wbw/004_020_012.mp3","charTypeName":"word"},{"id":23296,"position":13,"arabic":"شَيْـًٔا ۚ","translation":"কোন কিছু","audioUrl":"wbw/004_020_013.mp3","charTypeName":"word"},{"id":23298,"position":14,"arabic":"أَتَأْخُذُونَهُۥ","translation":"কি তা তোমরা নিবে","audioUrl":"wbw/004_020_015.mp3","charTypeName":"word"},{"id":23299,"position":15,"arabic":"بُهْتَـٰنًۭا","translation":"দোষারোপ (করে)","audioUrl":"wbw/004_020_016.mp3","charTypeName":"word"},{"id":23300,"position":16,"arabic":"وَإِثْمًۭا","translation":"ও পাপ (করে)","audioUrl":"wbw/004_020_017.mp3","charTypeName":"word"},{"id":23301,"position":17,"arabic":"مُّبِينًۭا","translation":"সুস্পষ্ট","audioUrl":"wbw/004_020_018.mp3","charTypeName":"word"},{"id":23302,"position":18,"arabic":"٢٠","translation":"(২০)","audioUrl":null,"charTypeName":"end"}]},{"number":21,"arabic":"وَكَيْفَ تَأْخُذُونَهُۥ وَقَدْ أَفْضَىٰ بَعْضُكُمْ إِلَىٰ بَعْضٍۢ وَأَخَذْنَ مِنكُم مِّيثَٰقًا غَلِيظًۭا","translation":"And how could you take it away after you have given yourselves to one another, and she has received a most solemn pledge from you?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/514.mp3","surahId":4,"words":[{"id":24364,"position":1,"arabic":"وَكَيْفَ","translation":"এবং কিরূপে","audioUrl":"wbw/004_021_001.mp3","charTypeName":"word"},{"id":24365,"position":2,"arabic":"تَأْخُذُونَهُۥ","translation":"তা তোমরা গ্রহণ করবে","audioUrl":"wbw/004_021_002.mp3","charTypeName":"word"},{"id":24366,"position":3,"arabic":"وَقَدْ","translation":"অথচ নিশ্চয়","audioUrl":"wbw/004_021_003.mp3","charTypeName":"word"},{"id":24367,"position":4,"arabic":"أَفْضَىٰ","translation":"স্বাদ নিয়েছ (স্ত্রী মিলনের)","audioUrl":"wbw/004_021_004.mp3","charTypeName":"word"},{"id":24368,"position":5,"arabic":"بَعْضُكُمْ","translation":"তোমাদের একে","audioUrl":"wbw/004_021_005.mp3","charTypeName":"word"},{"id":24369,"position":6,"arabic":"إِلَىٰ","translation":"থেকে","audioUrl":"wbw/004_021_006.mp3","charTypeName":"word"},{"id":24370,"position":7,"arabic":"بَعْضٍۢ","translation":"অপরের","audioUrl":"wbw/004_021_007.mp3","charTypeName":"word"},{"id":24371,"position":8,"arabic":"وَأَخَذْنَ","translation":"এবং তারা নিয়েছে","audioUrl":"wbw/004_021_008.mp3","charTypeName":"word"},{"id":24372,"position":9,"arabic":"مِنكُم","translation":"তোমাদের থেকে","audioUrl":"wbw/004_021_009.mp3","charTypeName":"word"},{"id":24373,"position":10,"arabic":"مِّيثَـٰقًا","translation":"প্রতিশ্রুতি","audioUrl":"wbw/004_021_010.mp3","charTypeName":"word"},{"id":24374,"position":11,"arabic":"غَلِيظًۭا","translation":"দৃঢ়","audioUrl":"wbw/004_021_011.mp3","charTypeName":"word"},{"id":24375,"position":12,"arabic":"٢١","translation":"(২১)","audioUrl":null,"charTypeName":"end"}]},{"number":22,"arabic":"وَلَا تَنكِحُوا۟ مَا نَكَحَ ءَابَآؤُكُم مِّنَ ٱلنِّسَآءِ إِلَّا مَا قَدْ سَلَفَ ۚ إِنَّهُۥ كَانَ فَٰحِشَةًۭ وَمَقْتًۭا وَسَآءَ سَبِيلًا","translation":"AND DO NOT marry women whom your fathers have previously married - although what is past is past: this, verily, is a shameful deed, and a hateful thing, and an evil way.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/515.mp3","surahId":4,"words":[{"id":24449,"position":1,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/004_022_001.mp3","charTypeName":"word"},{"id":24450,"position":2,"arabic":"تَنكِحُوا۟","translation":"তোমরা বিবাহ করো","audioUrl":"wbw/004_022_002.mp3","charTypeName":"word"},{"id":24451,"position":3,"arabic":"مَا","translation":"যাদের","audioUrl":"wbw/004_022_003.mp3","charTypeName":"word"},{"id":24452,"position":4,"arabic":"نَكَحَ","translation":"বিবাহ করেছে","audioUrl":"wbw/004_022_004.mp3","charTypeName":"word"},{"id":24453,"position":5,"arabic":"ءَابَآؤُكُم","translation":"তোমাদের পিতা (পিতামহ ইত্যাদি)","audioUrl":"wbw/004_022_005.mp3","charTypeName":"word"},{"id":24454,"position":6,"arabic":"مِّنَ","translation":"মধ্য হতে","audioUrl":"wbw/004_022_006.mp3","charTypeName":"word"},{"id":24455,"position":7,"arabic":"ٱلنِّسَآءِ","translation":"স্ত্রীলোকদের","audioUrl":"wbw/004_022_007.mp3","charTypeName":"word"},{"id":24456,"position":8,"arabic":"إِلَّا","translation":"কিন্তু","audioUrl":"wbw/004_022_008.mp3","charTypeName":"word"},{"id":24457,"position":9,"arabic":"مَا","translation":"যা","audioUrl":"wbw/004_022_009.mp3","charTypeName":"word"},{"id":24458,"position":10,"arabic":"قَدْ","translation":"হয়েছে","audioUrl":"wbw/004_022_010.mp3","charTypeName":"word"},{"id":24459,"position":11,"arabic":"سَلَفَ ۚ","translation":"বিগত (সেটা ধর্তব্য নয়)","audioUrl":"wbw/004_022_011.mp3","charTypeName":"word"},{"id":24461,"position":12,"arabic":"إِنَّهُۥ","translation":"তা নিশ্চয়ই","audioUrl":"wbw/004_022_013.mp3","charTypeName":"word"},{"id":24462,"position":13,"arabic":"كَانَ","translation":"হল","audioUrl":"wbw/004_022_014.mp3","charTypeName":"word"},{"id":24463,"position":14,"arabic":"فَـٰحِشَةًۭ","translation":"অশ্লীল কাজ","audioUrl":"wbw/004_022_015.mp3","charTypeName":"word"},{"id":24464,"position":15,"arabic":"وَمَقْتًۭا","translation":"ও বড়ই অপছন্দনীয়","audioUrl":"wbw/004_022_016.mp3","charTypeName":"word"},{"id":24465,"position":16,"arabic":"وَسَآءَ","translation":"এবং নিকৃষ্ট","audioUrl":"wbw/004_022_017.mp3","charTypeName":"word"},{"id":24466,"position":17,"arabic":"سَبِيلًا","translation":"আচরণ","audioUrl":"wbw/004_022_018.mp3","charTypeName":"word"},{"id":24467,"position":18,"arabic":"٢٢","translation":"(২২)","audioUrl":null,"charTypeName":"end"}]},{"number":23,"arabic":"حُرِّمَتْ عَلَيْكُمْ أُمَّهَٰتُكُمْ وَبَنَاتُكُمْ وَأَخَوَٰتُكُمْ وَعَمَّٰتُكُمْ وَخَٰلَٰتُكُمْ وَبَنَاتُ ٱلْأَخِ وَبَنَاتُ ٱلْأُخْتِ وَأُمَّهَٰتُكُمُ ٱلَّٰتِىٓ أَرْضَعْنَكُمْ وَأَخَوَٰتُكُم مِّنَ ٱلرَّضَٰعَةِ وَأُمَّهَٰتُ نِسَآئِكُمْ وَرَبَٰٓئِبُكُمُ ٱلَّٰتِى فِى حُجُورِكُم مِّن نِّسَآئِكُمُ ٱلَّٰتِى دَخَلْتُم بِهِنَّ فَإِن لَّمْ تَكُونُوا۟ دَخَلْتُم بِهِنَّ فَلَا جُنَاحَ عَلَيْكُمْ وَحَلَٰٓئِلُ أَبْنَآئِكُمُ ٱلَّذِينَ مِنْ أَصْلَٰبِكُمْ وَأَن تَجْمَعُوا۟ بَيْنَ ٱلْأُخْتَيْنِ إِلَّا مَا قَدْ سَلَفَ ۗ إِنَّ ٱللَّهَ كَانَ غَفُورًۭا رَّحِيمًۭا","translation":"Forbidden to you are your mothers, and your daughters, and your sisters, and your aunts paternal and maternal, and a brother's daughters, and a sister's daughters; and your milk-mothers, and your milk-sisters; and the mothers of your wives; and your step-daughters - who are your foster children - born of your wives with whom you have consummated your marriage; but if you have not consummated your marriage, you will incur no sin [by marrying their daughters]; and [forbidden to you are] the spouses of the sons who have sprung from your loins; and [you are forbidden] to have two sisters [as your wives] at one and the same time - but what is past is past: for, behold, God is indeed much-forgiving, a dispenser of grace.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/516.mp3","surahId":4,"words":[{"id":25516,"position":1,"arabic":"حُرِّمَتْ","translation":"নিষিদ্ধ করা হয়েছে (বিবাহ)","audioUrl":"wbw/004_023_001.mp3","charTypeName":"word"},{"id":25517,"position":2,"arabic":"عَلَيْكُمْ","translation":"তোমাদের উপর","audioUrl":"wbw/004_023_002.mp3","charTypeName":"word"},{"id":25518,"position":3,"arabic":"أُمَّهَـٰتُكُمْ","translation":"তোমাদের মাতাদেরকে","audioUrl":"wbw/004_023_003.mp3","charTypeName":"word"},{"id":25519,"position":4,"arabic":"وَبَنَاتُكُمْ","translation":"ও তোমাদের কন্যাদেরকে","audioUrl":"wbw/004_023_004.mp3","charTypeName":"word"},{"id":25520,"position":5,"arabic":"وَأَخَوَٰتُكُمْ","translation":"ও তোমাদের বোনদেরকে","audioUrl":"wbw/004_023_005.mp3","charTypeName":"word"},{"id":25521,"position":6,"arabic":"وَعَمَّـٰتُكُمْ","translation":"ও তোমাদের ফুফুদেরকে","audioUrl":"wbw/004_023_006.mp3","charTypeName":"word"},{"id":25522,"position":7,"arabic":"وَخَـٰلَـٰتُكُمْ","translation":"ও তোমাদের খালাদেরকে","audioUrl":"wbw/004_023_007.mp3","charTypeName":"word"},{"id":25523,"position":8,"arabic":"وَبَنَاتُ","tr