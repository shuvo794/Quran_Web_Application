{"id":458,"ayahs":[{"number":84,"arabic":"قَالَ فَٱلْحَقُّ وَٱلْحَقَّ أَقُولُ","translation":"[And God] said: “This, then, is the truth! And this truth do I state:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4054.mp3","surahId":38,"words":[{"id":65797,"position":1,"arabic":"قَالَ","translation":"(আল্লাহ) বললেন","audioUrl":"wbw/038_084_001.mp3","charTypeName":"word"},{"id":65798,"position":2,"arabic":"فَٱلْحَقُّ","translation":"\"তবে (এটাই) সত্য","audioUrl":"wbw/038_084_002.mp3","charTypeName":"word"},{"id":65799,"position":3,"arabic":"وَٱلْحَقَّ","translation":"আর সত্যই","audioUrl":"wbw/038_084_003.mp3","charTypeName":"word"},{"id":65800,"position":4,"arabic":"أَقُولُ","translation":"আমি বলি","audioUrl":"wbw/038_084_004.mp3","charTypeName":"word"},{"id":65801,"position":5,"arabic":"٨٤","translation":"(৮৪)","audioUrl":null,"charTypeName":"end"}]},{"number":85,"arabic":"لَأَمْلَأَنَّ جَهَنَّمَ مِنكَ وَمِمَّن تَبِعَكَ مِنْهُمْ أَجْمَعِينَ","translation":"Most certainly will I fill hell with thee and such of them as shall follow thee, all together!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4055.mp3","surahId":38,"words":[{"id":66310,"position":1,"arabic":"لَأَمْلَأَنَّ","translation":"আমি অবশ্যই ভরিয়ে তুলবো","audioUrl":"wbw/038_085_001.mp3","charTypeName":"word"},{"id":66311,"position":2,"arabic":"جَهَنَّمَ","translation":"জাহান্নামকে","audioUrl":"wbw/038_085_002.mp3","charTypeName":"word"},{"id":66312,"position":3,"arabic":"مِنكَ","translation":"তোমার দ্বারা","audioUrl":"wbw/038_085_003.mp3","charTypeName":"word"},{"id":66313,"position":4,"arabic":"وَمِمَّن","translation":"ও তার দ্বারা যে","audioUrl":"wbw/038_085_004.mp3","charTypeName":"word"},{"id":66314,"position":5,"arabic":"تَبِعَكَ","translation":"তোমার অনুসরণ করবে","audioUrl":"wbw/038_085_005.mp3","charTypeName":"word"},{"id":66315,"position":6,"arabic":"مِنْهُمْ","translation":"তাদের মধ্যে হ'তে","audioUrl":"wbw/038_085_006.mp3","charTypeName":"word"},{"id":66316,"po