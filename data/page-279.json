{"id":279,"ayahs":[{"number":103,"arabic":"وَلَقَدْ نَعْلَمُ أَنَّهُمْ يَقُولُونَ إِنَّمَا يُعَلِّمُهُۥ بَشَرٌۭ ۗ لِّسَانُ ٱلَّذِى يُلْحِدُونَ إِلَيْهِ أَعْجَمِىٌّۭ وَهَٰذَا لِسَانٌ عَرَبِىٌّۭ مُّبِينٌ","translation":"And, indeed, full well do We know that they say, \"It is but a human being that imparts [all] this to him! -[notwithstanding that] the tongue of him to whom they so maliciously point is wholly outlandish, whereas this is Arabic speech, clear [in itself] and clearly showing the truth [of its source].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2004.mp3","surahId":16,"words":[{"id":72236,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/016_103_001.mp3","charTypeName":"word"},{"id":72237,"position":2,"arabic":"نَعْلَمُ","translation":"জানি আমরা","audioUrl":"wbw/016_103_002.mp3","charTypeName":"word"},{"id":72238,"position":3,"arabic":"أَنَّهُمْ","translation":"যে তারা","audioUrl":"wbw/016_103_003.mp3","charTypeName":"word"},{"id":72239,"position":4,"arabic":"يَقُولُونَ","translation":"বলে","audioUrl":"wbw/016_103_004.mp3","charTypeName":"word"},{"id":72240,"position":5,"arabic":"إِنَّمَا","translation":"\"প্রকৃতপক্ষে","audioUrl":"wbw/016_103_005.mp3","charTypeName":"word"},{"id":72241,"position":6,"arabic":"يُعَلِّمُهُۥ","translation":"তাকে শিখিয়েছে","audioUrl":"wbw/016_103_006.mp3","charTypeName":"word"},{"id":72242,"position":7,"arabic":"بَشَرٌۭ ۗ","translation":"এক মানুষ\"","audioUrl":"wbw/016_103_007.mp3","charTypeName":"word"},{"id":72244,"position":8,"arabic":"لِّسَانُ","translation":"ভাষা","audioUrl":"wbw/016_103_009.mp3","charTypeName":"word"},{"id":72245,"position":9,"arabic":"ٱلَّذِى","translation":"যার","audioUrl":"wbw/016_103_010.mp3","charTypeName":"word"},{"id":72246,"position":10,"arabic":"يُلْحِدُونَ","translation":"তারা ইঙ্গিত করে","audioUrl":"wbw/016_103_011.mp3","charTypeName":"word"},{"id":72247,"position":11,"arabic":"إِلَيْهِ","translation":"দিকে তার","audioUrl":"wbw/016_103_012.mp3","charTypeName":"word"},{"id":72248,"position":12,"arabic":"أَعْجَمِىٌّۭ","translation":"অ-আরবি","audioUrl":"wbw/016_103_013.mp3","charTypeName":"word"},{"id":72249,"position":13,"arabic":"وَهَـٰذَا","translation":"অথচ এটা","audioUrl":"wbw/016_103_014.mp3","charTypeName":"word"},{"id":72250,"position":14,"arabic":"لِسَانٌ","translation":"ভাষা","audioUrl":"wbw/016_103_015.mp3","charTypeName":"word"},{"id":72251,"position":15,"arabic":"عَرَبِىٌّۭ","translation":"আরবি","audioUrl":"wbw/016_103_016.mp3","charTypeName":"word"},{"id":72252,"position":16,"arabic":"مُّبِينٌ","translation":"স্পষ্ট","audioUrl":"wbw/016_103_017.mp3","charTypeName":"word"},{"id":72253,"position":17,"arabic":"١٠٣","translation":"(১০৩)","audioUrl":null,"charTypeName":"end"}]},{"number":104,"arabic":"إِنَّ ٱلَّذِينَ لَا يُؤْمِنُونَ بِـَٔايَٰتِ ٱللَّهِ لَا يَهْدِيهِمُ ٱللَّهُ وَلَهُمْ عَذَابٌ أَلِيمٌ","translation":"Verily, as for those who will not believe in God's messages, God does not guide them aright; and grievous suffering will be their lot [in the life to come].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2005.mp3","surahId":16,"words":[{"id":72605,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/016_104_001.mp3","charTypeName":"word"},{"id":72606,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/016_104_002.mp3","charTypeName":"word"},{"id":72607,"position":3,"arabic":"لَا","translation":"না","audioUrl":"wbw/016_104_003.mp3","charTypeName":"word"},{"id":72608,"position":4,"arabic":"يُؤْمِنُونَ","translation":"ঈমান আনে","audioUrl":"wbw/016_104_004.mp3","charTypeName":"word"},{"id":72609,"position":5,"arabic":"بِـَٔايَـٰتِ","translation":"প্রতি উপর নিদর্শনসমূহের","audioUrl":"wbw/016_104_005.mp3","charTypeName":"word"},{"id":72610,"position":6,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/016_104_006.mp3","charTypeName":"word"},{"id":72611,"position":7,"arabic":"لَا","translation":"না","audioUrl":"wbw/016_104_007.mp3","charTypeName":"word"},{"id":72612,"position":8,"arabic":"يَهْدِيهِمُ","translation":"পথ দেখান তাদের","audioUrl":"wbw/016_104_008.mp3","charTypeName":"word"},{"id":72613,"position":9,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌","audioUrl":"wbw/016_104_009.mp3","charTypeName":"word"},{"id":72614,"position":10,"arabic":"وَلَهُمْ","translation":"এবং জন্যে তাদের","audioUrl":"wbw/016_104_010.mp3","charTypeName":"word"},{"id":72615,"position":11,"arabic":"عَذَابٌ","translation":"শাস্তি","audioUrl":"wbw/016_104_011.mp3","charTypeName":"word"},{"id":72616,"position":12,"arabic":"أَلِيمٌ","translation":"নিদারুণ","audioUrl":"wbw/016_104_012.mp3","charTypeName":"word"},{"id":72617,"position":13,"arabic":"١٠٤","translation":"(১০৪)","audioUrl":null,"charTypeName":"end"}]},{"number":105,"arabic":"إِنَّمَا يَفْتَرِى ٱلْكَذِبَ ٱلَّذِينَ لَا يُؤْمِنُونَ بِـَٔايَٰتِ ٱللَّهِ ۖ وَأُو۟لَٰٓئِكَ هُمُ ٱلْكَٰذِبُونَ","translation":"It is but they who will not believe in God's messages that invent this falsehood; and it is they, they who are lying!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2006.mp3","surahId":16,"words":[{"id":72812,"position":1,"arabic":"إِنَّمَا","translation":"প্রকৃতপক্ষে","audioUrl":"wbw/016_105_001.mp3","charTypeName":"word"},{"id":72813,"position":2,"arabic":"يَفْتَرِى","translation":"রচনা করে","audioUrl":"wbw/016_105_002.mp3","charTypeName":"word"},{"id":72814,"position":3,"arabic":"ٱلْكَذِبَ","translation":"মিথ্যা","audioUrl":"wbw/016_105_003.mp3","charTypeName":"word"},{"id":72815,"position":4,"arabic":"ٱلَّذِينَ","translation":"(তারাই) যারা","audioUrl":"wbw/016_105_004.mp3","charTypeName":"word"},{"id":72816,"position":5,"arabic":"لَا","translation":"না","audioUrl":"wbw/016_105_005.mp3","charTypeName":"word"},{"id":72817,"position":6,"arabic":"يُؤْمِنُونَ","translation":"ঈমান আনে","audioUrl":"wbw/016_105_006.mp3","charTypeName":"word"},{"id":72818,"position":7,"arabic":"بِـَٔايَـٰتِ","translation":"প্রতি উপর নিদর্শনসমূহের","audioUrl":"wbw/016_105_007.mp3","charTypeName":"word"},{"id":72819,"position":8,"arabic":"ٱللَّهِ ۖ","translation":"আল্লাহর","audioUrl":"wbw/016_105_008.mp3","charTypeName":"word"},{"id":72821,"position":9,"arabic":"وَأُو۟لَـٰٓئِكَ","translation":"এবং ঐসব লোক","audioUrl":"wbw/016_105_010.mp3","charTypeName":"word"},{"id":72822,"position":10,"arabic":"هُمُ","translation":"তারাই","audioUrl":"wbw/016_105_011.mp3","charTypeName":"word"},{"id":72823,"position":11,"arabic":"ٱلْكَـٰذِبُونَ","translation":"মিথ্যাবাদী","audioUrl":"wbw/016_105_012.mp3","charTypeName":"word"},{"id":72824,"position":12,"arabic":"١٠٥","translation":"(১০৫)","audioUrl":null,"charTypeName":"end"}]},{"number":106,"arabic":"مَن كَفَرَ بِٱللَّهِ مِنۢ بَعْدِ إِيمَٰنِهِۦٓ إِلَّا مَنْ أُكْرِهَ وَقَلْبُهُۥ مُطْمَئِنٌّۢ بِٱلْإِيمَٰنِ وَلَٰكِن مَّن شَرَحَ بِٱلْكُفْرِ صَدْرًۭا فَعَلَيْهِمْ غَضَبٌۭ مِّنَ ٱللَّهِ وَلَهُمْ عَذَابٌ عَظِيمٌۭ","translation":"As for anyone who denies God after having once attained to faith-and this, to be sure, does not apply to one who does it under duress, the while his heart remains true to his faith, but [only, to] him who willingly opens up his heart to a denial of the truth-: upon all such [falls] God's condemnation, and tremendous suffering awaits them:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2007.mp3","surahId":16,"words":[{"id":73066,"position":1,"arabic":"مَن","translation":"যে","audioUrl":"wbw/016_106_001.mp3","charTypeName":"word"},{"id":73067,"position":2,"arabic":"كَفَرَ","translation":"অস্বীকার করে","audioUrl":"wbw/016_106_002.mp3","charTypeName":"word"},{"id":73068,"position":3,"arabic":"بِٱللَّهِ","translation":"সাথে আল্লাহর","audioUrl":"wbw/016_106_003.mp3","charTypeName":"word"},{"id":73069,"position":4,"arabic":"مِنۢ","translation":"থেকে","audioUrl":"wbw/016_106_004.mp3","charTypeName":"word"},{"id":73070,"position":5,"arabic":"بَعْدِ","translation":"পর","audioUrl":"wbw/016_106_005.mp3","charTypeName":"word"},{"id":73071,"position":6,"arabic":"إِيمَـٰنِهِۦٓ"