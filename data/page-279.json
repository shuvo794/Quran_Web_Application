:"word"},{"id":73087,"position":22,"arabic":"وَلَهُمْ","translation":"এবং জন্যে তাদের","audioUrl":"wbw/016_106_022.mp3","charTypeName":"word"},{"id":73088,"position":23,"arabic":"عَذَابٌ","translation":"শাস্তি","audioUrl":"wbw/016_106_023.mp3","charTypeName":"word"},{"id":73089,"position":24,"arabic":"عَظِيمٌۭ","translation":"মহা","audioUrl":"wbw/016_106_024.mp3","charTypeName":"word"},{"id":73090,"position":25,"arabic":"١٠٦","translation":"(১০৬)","audioUrl":null,"charTypeName":"end"}]},{"number":107,"arabic":"ذَٰلِكَ بِأَنَّهُمُ ٱسْتَحَبُّوا۟ ٱلْحَيَوٰةَ ٱلدُّنْيَا عَلَى ٱلْءَاخِرَةِ وَأَنَّ ٱللَّهَ لَا يَهْدِى ٱلْقَوْمَ ٱلْكَٰفِرِينَ","translation":"all this, because they hold this world's life in greater esteem than the life to come, and because God does not bestow His guidance upon people who deny the truth.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2008.mp3","surahId":16,"words":[{"id":73424,"position":1,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/016_107_001.mp3","charTypeName":"word"},{"id":73425,"position":2,"arabic":"بِأَنَّهُمُ","translation":"এজন্য যে তারা","audioUrl":"wbw/016_107_002.mp3","charTypeName":"word"},{"id":73426,"position":3,"arabic":"ٱسْتَحَبُّوا۟","translation":"প্রাধান্য দিয়েছে","audioUrl":"wbw/016_107_003.mp3","charTypeName":"word"},{"id":73427,"position":4,"arabic":"ٱلْحَيَوٰةَ","translation":"জীবনকে","audioUrl":"wbw/016_107_004.mp3","charTypeName":"word"},{"id":73428,"position":5,"arabic":"ٱلدُّنْيَا","translation":"পার্থিব","audioUrl":"wbw/016_107_005.mp3","charTypeName":"word"},{"id":73429,"position":6,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/016_107_006.mp3","charTypeName":"word"},{"id":73430,"position":7,"arabic":"ٱلْـَٔاخِرَةِ","translation":"আখেরাতের","audioUrl":"wbw/016_107_007.mp3","charTypeName":"word"},{"id":73431,"position":8,"arabic":"وَأَنَّ","translation":"এবং (এও) যে","audioUrl":"wbw/016_107_008.mp3","charTypeName":"word"},{"id":73432,"position":9,"arabic":"ٱللَّهَ","translation":"আল্লাহ্‌","audioUrl":"wbw/016_107_009.mp3","charTypeName":"word"},{"id":73433,"position":10,"arabic":"لَا","translation":"না","audioUrl":"wbw/016_107_010.mp3","charTypeName":"word"},{"id":73434,"position":11,"arabic":"يَهْدِى","translation":"পথ দেখান","audioUrl":"wbw/016_107_011.mp3","charTypeName":"word"},{"id":73435,"position":12,"arabic":"ٱلْقَوْمَ","translation":"সম্প্রদায়কে","audioUrl":"wbw/016_107_012.mp3","charTypeName":"word"},{"id":73436,"position":13,"arabic":"ٱلْكَـٰفِرِينَ","translation":"কাফের","audioUrl":"wbw/016_107_013.mp3","charTypeName":"word"},{"id":73437,"position":14,"arabic":"١٠٧","translation":"(১০৭)","audioUrl":null,"charTypeName":"end"}]},{"number":108,"arabic":"أُو۟لَٰٓئِكَ ٱلَّذِينَ طَبَعَ ٱللَّهُ عَلَىٰ قُلُوبِهِمْ وَسَمْعِهِمْ وَأَبْصَٰرِهِمْ ۖ وَأُو۟لَٰٓئِكَ هُمُ ٱلْغَٰفِلُونَ","translation":"They whose hearts and whose hearing and whose sight God has sealed -it is they, they who are heedless!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2009.mp3","surahId":16,"words":[{"id":73706,"position":1,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐসব লোক","audioUrl":"wbw/016_108_001.mp3","charTypeName":"word"},{"id":73707,"position":2,"arabic":"ٱلَّذِينَ","translation":"(তারাই) যাদের","audioUrl":"wbw/016_108_002.mp3","charTypeName":"word"},{"id":73708,"position":3,"arabic":"طَبَعَ","translation":"মোহর মেরে দিয়েছেন","audioUrl":"wbw/016_108_003.mp3","charTypeName":"word"},{"id":73709,"position":4,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌","audioUrl":"wbw/016_108_004.mp3","charTypeName":"word"},{"id":73710,"position":5,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/016_108_005.mp3","charTypeName":"word"},{"id":73711,"position":6,"arabic":"قُلُوبِهِمْ","translation":"অন্তরসমূহের তাদের","audioUrl":"wbw/016_108_006.mp3","charTypeName":"word"},{"id":73712,"position":7,"arabic":"وَسَمْعِهِمْ","translation":"ও শ্রবণশক্তিসমূহের তাদের","audioUrl":"wbw/016_108_007.mp3","charTypeName":"word"},{"id":73713,"position":8,"arabic":"وَأَ