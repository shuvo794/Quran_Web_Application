ٌۭ رَّحِيمٌۭ","translation":"And yet, behold, thy Sustainer [grants His forgiveness] unto those who forsake the domain of evil after having succumbed to its temptation, and who thenceforth strive hard [in God's cause] and are patient in adversity: behold, after such [repentance] thy Sustainer is indeed much-forgiving, a dispenser of grace!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2011.mp3","surahId":16,"words":[{"id":74050,"position":1,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/016_110_001.mp3","charTypeName":"word"},{"id":74051,"position":2,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/016_110_002.mp3","charTypeName":"word"},{"id":74052,"position":3,"arabic":"رَبَّكَ","translation":"তোমার রব","audioUrl":"wbw/016_110_003.mp3","charTypeName":"word"},{"id":74053,"position":4,"arabic":"لِلَّذِينَ","translation":"তাদের জন্যে যারা","audioUrl":"wbw/016_110_004.mp3","charTypeName":"word"},{"id":74054,"position":5,"arabic":"هَاجَرُوا۟","translation":"হিজরত করেছে","audioUrl":"wbw/016_110_005.mp3","charTypeName":"word"},{"id":74055,"position":6,"arabic":"مِنۢ","translation":"থেকে","audioUrl":"wbw/016_110_006.mp3","charTypeName":"word"},{"id":74056,"position":7,"arabic":"بَعْدِ","translation":"পর","audioUrl":"wbw/016_110_007.mp3","charTypeName":"word"},{"id":74057,"position":8,"arabic":"مَا","translation":"হওয়ার","audioUrl":"wbw/016_110_008.mp3","charTypeName":"word"},{"id":74058,"position":9,"arabic":"فُتِنُوا۟","translation":"নির্যাতিত","audioUrl":"wbw/016_110_009.mp3","charTypeName":"word"},{"id":74059,"position":10,"arabic":"ثُمَّ","translation":"অতঃপর","audioUrl":"wbw/016_110_010.mp3","charTypeName":"word"},{"id":74060,"position":11,"arabic":"جَـٰهَدُوا۟","translation":"জিহাদ করেছে","audioUrl":"wbw/016_110_011.mp3","charTypeName":"word"},{"id":74061,"position":12,"arabic":"وَصَبَرُوٓا۟","translation":"ও ধৈর্য ধরেছে","audioUrl":"wbw/016_110_012.mp3","charTypeName":"word"},{"id":74062,"position":13,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/016_110_013.mp3","charTypeName":"word"},{"id":74063,"position":14,"arabic":"رَبَّكَ","translation":"তোমার রব","audioUrl":"wbw/016_110_014.mp3","charTypeName":"word"},{"id":74064,"position":15,"arabic":"مِنۢ","translation":"থেকে","audioUrl":"wbw/016_110_015.mp3","charTypeName":"word"},{"id":74065,"position":16,"arabic":"بَعْدِهَا","translation":"এরপর (তাদের জন্যে)","audioUrl":"wbw/016_110_016.mp3","charTypeName":"word"},{"id":74066,"position":17,"arabic":"لَغَفُورٌۭ","translation":"অবশ্যই ক্ষমাশীল","audioUrl":"wbw/016_110_017.mp3","charTypeName":"word"},{"id":74067,"position":18,"arabic":"رَّحِيمٌۭ","translation":"পরম দয়ালু","audioUrl":"wbw/016_110_018.mp3","charTypeName":"word"},{"id":74068,"position":19,"arabic":"١١٠","translation":"(১১০)","audioUrl":null,"charTypeName":"end"}]}]}