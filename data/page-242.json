{"id":242,"ayahs":[{"number":53,"arabic":"۞ وَمَآ أُبَرِّئُ نَفْسِىٓ ۚ إِنَّ ٱلنَّفْسَ لَأَمَّارَةٌۢ بِٱلسُّوٓءِ إِلَّا مَا رَحِمَ رَبِّىٓ ۚ إِنَّ رَبِّى غَفُورٌۭ رَّحِيمٌۭ","translation":"And yet, I am not trying to absolve myself: for, verily, man's inner self does incite [him] to evil, and saved are only they upon whom my Sustainer bestows His grace. Behold, my Sustainer is much forgiving, a dispenser of grace!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1649.mp3","surahId":12,"words":[{"id":50700,"position":1,"arabic":"۞ وَمَآ","translation":"\"এবং না","audioUrl":"wbw/012_053_002.mp3","charTypeName":"word"},{"id":50701,"position":2,"arabic":"أُبَرِّئُ","translation":"নির্দোষ মনে করি","audioUrl":"wbw/012_053_003.mp3","charTypeName":"word"},{"id":50702,"position":3,"arabic":"نَفْسِىٓ ۚ","translation":"নিজেকে","audioUrl":"wbw/012_053_004.mp3","charTypeName":"word"},{"id":50704,"position":4,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/012_053_006.mp3","charTypeName":"word"},{"id":50705,"position":5,"arabic":"ٱلنَّفْسَ","translation":"মন (নফস)","audioUrl":"wbw/012_053_007.mp3","charTypeName":"word"},{"id":50706,"position":6,"arabic":"لَأَمَّارَةٌۢ","translation":"অবশ্যই নির্দেশ দিয়েই থাকে","audioUrl":"wbw/012_053_008.mp3","charTypeName":"word"},{"id":50707,"position":7,"arabic":"بِٱلسُّوٓءِ","translation":"মন্দের দিকে","audioUrl":"wbw/012_053_009.mp3","charTypeName":"word"},{"id":50708,"position":8,"arabic":"إِلَّا","translation":"তবে","audioUrl":"wbw/012_053_010.mp3","charTypeName":"word"},{"id":50709,"position":9,"arabic":"مَا","translation":"যাকে","audioUrl":"wbw/012_053_011.mp3","charTypeName":"word"},{"id":50710,"position":10,"arabic":"رَحِمَ","translation":"অনুগ্রহ করেন","audioUrl":"wbw/012_053_012.mp3","charTypeName":"word"},{"id":50711,"position":11,"arabic":"رَبِّىٓ ۚ","translation":"আমার রব (সেটা ভিন্ন কথা)","audioUrl":"wbw/012_053_013.mp3","charTypeName":"word"},{"id":50713,"position":12,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/012_053_015.mp3","charTypeName":"word"},{"id":50714,"position":13,"arabic":"رَبِّى","translation":"আমার রব","audioUrl":"wbw/012_053_016.mp3","charTypeName":"word"},{"id":50715,"position":14,"arabic":"غَفُورٌۭ","translation":"ক্ষমাশীল","audioUrl":"wbw/012_053_017.mp3","charTypeName":"word"},{"id":50716,"position":15,"arabic":"رَّحِيمٌۭ","translation":"পরম দয়ালু\"","audioUrl":"wbw/012_053_018.mp3","charTypeName":"word"},{"id":50717,"position":16,"arabic":"٥٣","translation":"(৫৩)","audioUrl":null,"charTypeName":"end"}]},{"number":54,"arabic":"وَقَالَ ٱلْمَلِكُ ٱئْتُونِى بِهِۦٓ أَسْتَخْلِصْهُ لِنَفْسِى ۖ فَلَمَّا كَلَّمَهُۥ قَالَ إِنَّكَ ٱلْيَوْمَ لَدَيْنَا مَكِينٌ أَمِينٌۭ","translation":"And the King said: \"Bring him unto me, so that I may attach him to my own person.\" And when he had spoken with him, [the King] said: \"Behold, [from] this day thou shalt be of high standing with us, invested with all trust!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1650.mp3","surahId":12,"words":[{"id":51362,"position":1,"arabic":"وَقَالَ","translation":"এবং বলল","audioUrl":"wbw/012_054_001.mp3","charTypeName":"word"},{"id":51363,"position":2,"arabic":"ٱلْمَلِكُ","translation":"রাজা","audioUrl":"wbw/012_054_002.mp3","charTypeName":"word"},{"id":51364,"position":3,"arabic":"ٱئْتُونِى","translation":"\"আমার কাছে আসো","audioUrl":"wbw/012_054_003.mp3","charTypeName":"word"},{"id":51365,"position":4,"arabic":"بِهِۦٓ","translation":"\"নিয়ে তাকে","audioUrl":"wbw/012_054_004.mp3","charTypeName":"word"},{"id":51366,"position":5,"arabic":"أَسْتَخْلِصْهُ","translation":"তাকে বিশেষভাবে আমি গ্রহণ করবো","audioUrl":"wbw/012_054_005.mp3","charTypeName":"word"},{"id":51367,"position":6,"arabic":"لِنَفْسِى ۖ","translation":"আমার নিজের জন্যে\"","audioUrl":"wbw/012_054_006.mp3","charTypeName":"word"},{"id":51369,"position":7,"arabic":"فَلَمَّا","translation":"অতঃপর যখন","audioUrl":"wbw/012_054_008.mp3","charTypeName":"word"},{"id":51370,"position":8,"arabic":"كَلَّمَهُۥ","translation":"তার সাথে কথা বললো","audioUrl":"wbw/012_054_009.mp3","charTypeName":"word"},{"id":51371,"position":9,"arabic":"قَالَ","translation":"(রাজা) বললো","audioUrl":"wbw/012_054_010.mp3","charTypeName":"word"},{"id":51372,"position":10,"arabic":"إِنَّكَ","translation":"\"তুমি নিশ্চয়ই","audioUrl":"wbw/012_054_011.mp3","charTypeName":"word"},{"id":51373,"position":11,"arabic":"ٱلْيَوْمَ","translation":"আজ","audioUrl":"wbw/012_054_012.mp3","charTypeName":"word"},{"id":51374,"position":12,"arabic":"لَدَيْنَا","translation":"আমাদের কাছে","audioUrl":"wbw/012_054_013.mp3","charTypeName":"word"},{"id":51375,"position":13,"arabic":"مَكِينٌ","translation":"মর্যাদাশালী","audioUrl":"wbw/012_054_014.mp3","charTypeName":"word"},{"id":51376,"position":14,"arabic":"أَمِينٌۭ","translation":"বিশ্বস্ত\"","audioUrl":"wbw/012_054_015.mp3","charTypeName":"word"},{"id":51377,"position":15,"arabic":"٥٤","translation":"(৫৪)","audioUrl":null,"charTypeName":"end"}]},{"number":55,"arabic":"قَالَ ٱجْعَلْنِى عَلَىٰ خَزَآئِنِ ٱلْأَرْضِ ۖ إِنِّى حَفِيظٌ عَلِيمٌۭ","translation":"[Joseph] replied: \"Place in my charge the store-houses of the land; behold, I shall be a good and knowing keeper.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1651.mp3","surahId":12,"words":[{"id":51928,"position":1,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/012_055_001.mp3","charTypeName":"word"},{"id":51929,"position":2,"arabic":"ٱجْعَلْنِى","translation":"\"আমাকে নিযুক্ত করুন","audioUrl":"wbw/012_055_002.mp3","charTypeName":"word"},{"id":51930,"position":3,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/012_055_003.mp3","charTypeName":"word"},{"id":51931,"position":4,"arabic":"خَزَآئِنِ","translation":"ধনভান্ডারের (দায়িত্বের)","audioUrl":"wbw/012_055_004.mp3","charTypeName":"word"},{"id":51932,"position":5,"arabic":"ٱلْأَرْضِ ۖ","translation":"দেশের","audioUrl":"wbw/012_055_005.mp3","charTypeName":"word"},{"id":51934,"position":6,"arabic":"إِنِّى","translation":"নিশ্চয়ই আমি","audioUrl":"wbw/012_055_007.mp3","charTypeName":"word"},{"id":51935,"position":7,"arabic":"حَفِيظٌ","translation":"বিশ্বস্তরক্ষক","audioUrl":"wbw/012_055_008.mp3","charTypeName":"word"},{"id":51936,"position":8,"arabic":"عَلِيمٌۭ","translation":"সুবিজ্ঞ\"","audioUrl":"wbw/012_055_009.mp3","charTypeName":"word"},{"id":51937,"position":9,"arabic":"٥٥","translation":"(৫৫)","audioUrl":null,"charTypeName":"end"}]},{"number":56,"arabic":"وَكَذَٰلِكَ مَكَّنَّا لِيُوسُفَ فِى ٱلْأَرْضِ يَتَبَوَّأُ مِنْهَا حَيْثُ يَشَآءُ ۚ نُصِيبُ بِرَحْمَتِنَا مَن نَّشَآءُ ۖ وَلَا نُضِيعُ أَجْرَ ٱلْمُحْسِنِينَ","translation":"And thus We established Joseph securely in the land [of Egypt]: he had full mastery over it, [doing] whatever he willed. [Thus do] We cause Our grace to alight upon whomever We will; and We do not fail to requite the doers of good.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1652.mp3","surahId":12,"words":[{"id":52410,"position":1,"arabic":"وَكَذَٰلِكَ","translation":"এবং এভাবে","audioUrl":"wbw/012_056_001.mp3","charTypeName":"word"},{"id":52411,"position":2,"arabic":"مَكَّنَّا","translation":"আমরা প্রতিষ্ঠিত করি","audioUrl":"wbw/012_056_002.mp3","charTypeName":"word"},{"id":52412,"position":3,"arabic":"لِيُوسُفَ","translation":"ইউসুফকে","audioUrl":"wbw/012_056_003.mp3","charTypeName":"word"},{"id":52413,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/012_056_004.mp3","charTypeName":"word"},{"id":52414,"position":5,"arabic":"ٱلْأَرْضِ","translation":"(সে) দেশের","audioUrl":"wbw/012_056_005.mp3","charTypeName":"word"},{"id":52415,"position":6,"arabic":"يَتَبَوَّأُ","translation":"সে বসবাস করতো","audioUrl":"wbw/012_056_006.mp3","charTypeName":"word"},{"id":52416,"position":7,"arabic":"مِنْهَا","translation":"তার মধ্যে","audioUrl":"wbw/012_056_007.mp3","charTypeName":"word"},{"id":52417,"position":8,"arabic":"حَيْثُ","translation":"যেখানে","audioUrl":"wbw/012_056_008.mp3","charTypeName":"word"},{"id":52418,"position":9,"arabic":"يَشَآءُ ۚ","translation":"সে চাইতো","audioUrl":"wbw/012_056_009.mp3","charTypeName":"word"},{"id":52420,"position":10,"arabic":"نُصِيبُ","translation":"ধন্য করি আমরা","audioUrl":"wbw/012_056_011.mp3","charTypeName":"word"},{"id":52421,"position":11,"arabic":"بِرَحْمَتِنَا","translation":"দিয়ে আমাদের দয়া","audioUrl":"wbw/012_056_012.mp3","charTypeName":"word"},{"id":52422,"position":12,"arabic":"مَن","translation":"যাকে","audioUrl":"wbw/012_056_013.mp3","charTypeName":"word"},{"id":52423,"position":13,"arabic":"نَّشَآءُ ۖ","translation":"আমরা চাই","audioUrl":"wbw/012_056_014.mp3","charTypeName":"word"},{"id":52425,"position":14,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/012_056_016.mp3","charTypeName":"word"},{"id":52426,"position":15,"arabic":"نُضِيعُ","translation":"নষ্ট করি আমরা","audioUrl":"wbw/012_056_017.mp3","charTypeName":"word"},{"id":52427,"position":16,"arabic":"أَجْرَ","translation":"কর্মফল","audioUrl":"wbw/012_056_018.mp3","charTypeName":"word"},{"id":52428,"position":17,"arabic":"ٱلْمُحْسِنِينَ","translation":"সৎকর্মশীলদের","audioUrl":"wbw/012_056_019.mp3","charTypeName":"word"},{"id":52429,"position":18,"arabic":"٥٦","translation":"(৫৬)","audioUrl":null,"charTypeName":"end"}]},{"number":57,"arabic":"وَلَأَجْرُ ٱلْءَاخِرَةِ خَيْرٌۭ لِّلَّذِينَ ءَامَنُوا۟ وَكَانُوا۟ يَتَّقُونَ","translation":"But in the eyes of those who have attained to faith and have always been conscious of Us, a reward in the life to come is a far greater good [than any reward in this world].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1653.mp3","surahId":12,"words":[{"id":52945,"position":1,"arabic":"وَلَأَجْرُ","translation":"এবং অবশ্যই পুরস্কার (রয়েছে)","audioUrl":"wbw/012_057_001.mp3","charTypeName":"word"},{"id":52946,"position":2,"arabic":"ٱلْـَٔاخِرَةِ","translation":"আখিরাতের","audioUrl":"wbw/012_057_002.mp3","charTypeName":"word"},{"id":52947,"position":3,"arabic":"خَيْرٌۭ","translation":"উত্তম","audioUrl":"wbw/012_057_003.mp3","charTypeName":"word"},{"id":52948,"position":4,"arabic":"لِّلَّذِينَ","translation":"(তাদের) জন্য যারা","audioUrl":"wbw/012_057_004.mp3","charTypeName":"word"},{"id":52949,"position":5,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/012_057_005.mp3","charTypeName":"word"},{"id":52950,"position":6,"arabic":"وَكَانُوا۟","translation":"ও তারা","audioUrl":"wbw/012_057_006.mp3","charTypeName":"word"},{"id":52951,"position":7,"arabic":"يَتَّقُونَ","translation":"ভয় করে চলতো","audioUrl":"wbw/012_057_007.mp3","charTypeName":"word"},{"id":52952,"position":8,"arabic":"٥٧","translation":"(৫৭)","audioUrl":null,"charTypeName":"end"}]},{"number":58,"arabic":"وَجَآءَ إِخْوَةُ يُوسُفَ فَدَخَلُوا۟ عَلَيْهِ فَعَرَفَهُمْ وَهُمْ لَهُۥ مُنكِرُونَ","translation":"AND [after some years,] Joseph's brothers came [to Egypt] and presented themselves before him: and he knew them [at once], whereas they did not recognize him.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1654.mp3","surahId":12,"words":[{"id":53465,"position":1,"arabic":"وَجَآءَ","translation":"এবং আসলো","audioUrl":"wbw/012_058_001.mp3","charTypeName":"word"},{"id":53466,"position":2,"arabic":"إِخْوَةُ","translation":"ভাইয়েরা","audioUrl":"wbw/012_058_002.mp3","charTypeName":"word"},{"id":53467,"position":3,"arabic":"يُوسُفَ","translation":"ইউসুফের","audioUrl":"wbw/012_058_003.mp3","charTypeName":"word"},{"id":53468,"position":4,"arabic":"فَدَخَلُوا۟","translation":"অতঃপর তারা প্রবেশ করলো","audioUrl":"wbw/012_058_004.mp3","charTypeName":"word"},{"id":53469,"position":5,"arabic":"عَلَيْهِ","translation":"তার কাছে","audioUrl":"wbw/012_058_005.mp3","charTypeName":"word"},{"id":53470,"position":6,"arabic":"فَعَرَفَهُمْ","translation":"অতঃপর তাদেরকে সে চিনলো","audioUrl":"wbw/012_058_006.mp3","charTypeName":"word"},{"id":53471,"position":7,"arabic":"وَهُمْ","translation":"অথচ তারা (ছিলো)","audioUrl":"wbw/012_058_007.mp3","charTypeName":"word"},{"id":53472,"position":8,"arabic":"لَهُۥ","translation":"তার সম্পর্কে","audioUrl":"wbw/012_058_008.mp3","charTypeName":"word"},{"id":53473,"position":9,"arabic":"مُنكِرُونَ","translation":"অপরিচিত-অজ্ঞাত","audioUrl":"wbw/012_058_009.mp3","charTypeName":"word"},{"id":53474,"position":10,"arabic":"٥٨","translation":"(৫৮)","audioUrl":null,"charTypeName":"end"}]},{"number":59,"arabic":"وَلَمَّا جَهَّزَهُم بِجَهَازِهِمْ قَالَ ٱئْتُونِى بِأَخٍۢ لَّكُم مِّنْ أَبِيكُمْ ۚ أَلَا تَرَوْنَ أَنِّىٓ أُوفِى ٱلْكَيْلَ وَأَنَا۠ خَيْرُ ٱلْمُنزِلِينَ","translation":"And when he had provided them with their provisions, he said: \"[When you come here next,] bring unto me that brother of yours from your father's side. Do you not see that I have given [you] full measure and have been the best of hosts?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1655.mp3","surahId":12,"words":[{"id":53950,"position":1,"arabic":"وَلَمَّا","translation":"এবং যখন","audioUrl":"wbw/012_059_001.mp3","charTypeName":"word"},{"id":53951,"position":2,"arabic":"جَهَّزَهُم","translation":"তাদের প্রস্তুত করলো","audioUrl":"wbw/012_059_002.mp3","charTypeName":"word"},{"id":53952,"position":3,"arabic":"بِجَهَازِهِمْ","translation":"দিয়ে তাদের খাদ্যসামগ্রী","audioUrl":"wbw/012_059_003.mp3","charTypeName":"word"},{"id":53953,"position":4,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/012_059_004.mp3","charTypeName":"word"},{"id":53954,"position":5,"arabic":"ٱئْتُونِى","translation":"\"আমার কাছে আসবে তোমরা","audioUrl":"wbw/012_059_005.mp3","charTypeName":"word"},{"id":53955,"position":6,"arabic":"بِأَخٍۢ","translation":"নিয়ে ভাইকে","audioUrl":"wbw/012_059_006.mp3","charTypeName":"word"},{"id":53956,"position":7,"arabic":"لَّكُم","translation":"তোমাদের","audioUrl":"wbw/012_059_007.mp3","charTypeName":"word"},{"id":53957,"position":8,"arabic":"مِّنْ","translation":"দিক থেকে","audioUrl":"wbw/012_059_008.mp3","charTypeName":"word"},{"id":53958,"position":9,"arabic":"أَبِيكُمْ ۚ","translation":"তোমাদের বাপের (অর্থাৎ বৈমাত্রেয় ভাই)","audioUrl":"wbw/012_059_009.mp3","charTypeName":"word"},{"id":53960,"position":10,"arabic":"أَلَا","translation":"না কি","audioUrl":"wbw/012_059_011.mp3","charTypeName":"word"},{"id":53961,"position":11,"arabic":"تَرَوْنَ","translation":"তোমরা দেখো","audioUrl":"wbw/012_059_012.mp3","charTypeName":"word"},{"id":53962,"position":12,"arabic":"أَنِّىٓ","translation":"যে আমি","audioUrl":"wbw/012_059_013.mp3","charTypeName":"word"},{"id":53963,"position":13,"arabic":"أُوفِى","translation":"পুরোপুরি দিই","audioUrl":"wbw/012_059_014.mp3","charTypeName":"word"},{"id":53964,"position":14,"arabic":"ٱلْكَيْلَ","translation":"মাপ","audioUrl":"wbw/012_059_015.mp3","charTypeName":"word"},{"id":53965,"position":15,"arabic":"وَأَنَا۠","translation":"এবং আমি","audioUrl":"wbw/012_059_016.mp3","charTypeName":"word"},{"id":53966,"position":16,"arabic":"خَيْرُ","translation":"উত্তম","audioUrl":"wbw/012_059_017.mp3","charTypeName":"word"},{"id":53967,"position":17,"arabic":"ٱلْمُنزِلِينَ","translation":"অতিথি সমাদরকারী","audioUrl":"wbw/012_059_018.mp3","charTypeName":"word"},{"id":53968,"position":18,"arabic":"٥٩","translation":"(৫৯)","audioUrl":null,"charTypeName":"end"}]},{"number":60,"arabic":"فَإِن لَّمْ تَأْتُونِى بِهِۦ فَلَا كَيْلَ لَكُمْ عِندِى وَلَا تَقْرَبُونِ","translation":"But if you do not bring him unto me, you shall never again receive a single measure [of grain] from me, nor shall you [be allowed to] come near me!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1656.mp3","surahId":12,"words":[{"id":54659,"position":1,"arabic":"فَإِن","translation":"অতঃপর যদি","audioUrl":"wbw/012_060_001.mp3","charTypeName":"word"},{"id":54660,"position":2,"arabic":"لَّمْ","translation":"না","audioUrl":"wbw/012_060_002.mp3","charTypeName":"word"},{"id":54661,"position":3,"arabic":"تَأْتُونِى","translation":"তোমরা আসো আমার কাছে","audioUrl":"wbw/012_060_003.mp3","charTypeName":"word"},{"id":54662,"position":4,"arabic":"بِهِۦ","translation":"নিয়ে তাকে","audioUrl":"wbw/012_060_004.mp3","charTypeName":"word"},{"id":54663,"position":5,"arabic":"فَلَا","translation":"তবে নেই","audioUrl":"wbw/012_060_005.mp3","charTypeName":"word"},{"id":54664,"position":6,"arabic":"كَيْلَ","translation":"মাপ (বরাদ্দ)","audioUrl":"wbw/012_060_006.mp3","charTypeName":"word"},{"id":54665,"position":7,"arabic":"لَكُمْ","translation":"জন্যে তোমাদের","audioUrl":"wbw/012_060_007.mp3","charTypeName":"word"},{"id":54666,"position":8,"arabic":"عِندِى","translation":"আমার কাছে","audioUrl":"wbw/012_060_008.mp3","charTypeName":"word"},{"id":54667,"position":9,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/012_060_009.mp3","charTypeName":"word"},{"id":54668,"position":10,"arabic":"تَقْرَبُونِ","translation":"তোমরা আমার কাছে আসবে\"","audioUrl":"wbw/012_060_010.mp3","charTypeName":"word"},{"id":54669,"position":11,"arabic":"٦٠","translation":"(৬০)","audioUrl":null,"charTypeName":"end"}]},{"number":61,"arabic":"قَالُوا۟ سَنُرَٰوِدُ عَنْهُ أَبَاهُ وَإِنَّا لَفَٰعِلُونَ","translation":"They answered: \"We shall try to persuade his father to part with him, and, verily, we shall do [our utmost]!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1657.mp3","surahId":12,"words":[{"id":55245,"position":1,"arabic":"قَالُوا۟","translation":"তারা বললো","audioUrl":"wbw/012_061_001.mp3","charTypeName":"word"},{"id":55246,"position":2,"arabic":"سَنُرَٰوِدُ","translation":"\"আমরা শীঘ্রই রাজি করাবো","audioUrl":"wbw/012_061_002.mp3","charTypeName":"word"},{"id":55247,"position":3,"arabic":"عَنْهُ","translation":"তার সম্পর্কে","audioUrl":"wbw/012_061_003.mp3","charTypeName":"word"},{"id":55248,"position":4,"arabic":"أَبَاهُ","translation":"তার পিতাকে","audioUrl":"wbw/012_061_004.mp3","charTypeName":"word"},{"id":55249,"position":5,"arabic":"وَإِنَّا","translation":"এবং নিশ্চয়ই আমরা","audioUrl":"wbw/012_061_005.mp3","charTypeName":"word"},{"id":55250,"position":6,"arabic":"لَفَـٰعِلُونَ","translation":"অবশ্যই করবো\"","audioUrl":"wbw/012_061_006.mp3","charTypeName":"word"},{"id":55251,"position":7,"arabic":"٦١","translation":"(৬১)","audioUrl":null,"charTypeName":"end"}]},{"number":62,"arabic":"وَقَالَ لِفِتْيَٰنِهِ ٱجْعَلُوا۟ بِضَٰعَتَهُمْ فِى رِحَالِهِمْ لَعَلَّهُمْ يَعْرِفُونَهَآ إِذَا ٱنقَلَبُوٓا۟ إِلَىٰٓ أَهْلِهِمْ لَعَلَّهُمْ يَرْجِعُونَ","translation":"And [Joseph] said to his servants: \"Place their merchandise in their camel-packs, so that they may find it there when they come home, and hence be the more eager to return.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1658.mp3","surahId":12,"words":[{"id":55770,"position":1,"arabic":"وَقَالَ","translation":"এবং (ইউসুফ) বললো","audioUrl":"wbw/012_062_001.mp3","charTypeName":"word"},{"id":55771,"position":2,"arabic":"لِفِتْيَـٰنِهِ","translation":"তার চাকরদেরকে","audioUrl":"wbw/012_062_002.mp3","charTypeName":"word"},{"id":55772,"position":3,"arabic":"ٱجْعَلُوا۟","translation":"\"তোমরা রেখে দাও","audioUrl":"wbw/012_062_003.mp3","charTypeName":"word"},{"id":55773,"position":4,"arabic":"بِضَـٰعَتَهُمْ","translation":"তাদের পণ্য (দাম)","audioUrl":"wbw/012_062_004.mp3","charTypeName":"word"},{"id":55774,"position":5,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/012_062_005.mp3","charTypeName":"word"},{"id":55775,"position":6,"arabic":"رِحَالِهِمْ","translation":"তাদের মালপত্রের","audioUrl":"wbw/012_062_006.mp3","charTypeName":"word"},{"id":55776,"position":7,"arabic":"لَعَلَّهُمْ","translation":"তারা যাতে","audioUrl":"wbw/012_062_007.mp3","charTypeName":"word"},{"id":55777,"position":8,"arabic":"يَعْرِفُونَهَآ","translation":"তা জানতে পারে","audioUrl":"wbw/012_062_008.mp3","charTypeName":"word"},{"id":55778,"position":9,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/012_062_009.mp3","charTypeName":"word"},{"id":55779,"position":10,"arabic":"ٱنقَلَبُوٓا۟","translation":"তারা ফিরবে","audioUrl":"wbw/012_062_010.mp3","charTypeName":"word"},{"id":55780,"position":11,"arabic":"إِلَىٰٓ","translation":"কাছে","audioUrl":"wbw/012_062_011.mp3","charTypeName":"word"},{"id":55781,"position":12,"arabic":"أَهْلِهِمْ","translation":"তার পরিবারের","audioUrl":"wbw/012_062_012.mp3","charTypeName":"word"},{"id":55782,"position":13,"arabic":"لَعَلَّهُمْ","translation":"তারা সম্ভবত","audioUrl":"wbw/012_062_013.mp3","charTypeName":"word"},{"id":55783,"position":14,"arabic":"يَرْجِعُونَ","translation":"ফিরে আসবে (আবার)\"","audioUrl":"wbw/012_062_014.mp3","charTypeName":"word"},{"id":55784,"position":15,"arabic":"٦٢","translation":"(৬২)","audioUrl":null,"charTypeName":"end"}]},{"number":63,"arabic":"فَلَمَّا رَجَعُوٓا۟ إِلَىٰٓ أَبِيهِمْ قَالُوا۟ يَٰٓأَبَانَا مُنِعَ مِنَّا ٱلْكَيْلُ فَأَرْسِلْ مَعَنَآ أَخَانَا نَكْتَلْ وَإِنَّا لَهُۥ لَحَٰفِظُونَ","translation":"And so, when they returned to their father, [Joseph's brothers] said: \"O our father! All grain is [to be] withheld from us [in the future unless we bring Benjamin with us]: send, therefore, our brother with us, so that we may obtain our measure (of grain]; and, verily, we shall guard him well!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1659.mp3","surahId":12,"words":[{"id":56308,"position":1,"arabic":"فَلَمَّا","translation":"অতঃপর যখন","audioUrl":"wbw/012_063_001.mp3","charTypeName":"word"},{"id":56309,"position":2,"arabic":"رَجَعُوٓا۟","translation":"তারা ফিরে গেলো","audioUrl":"wbw/012_063_002.mp3","charTypeName":"word"},{"id":56310,"position":3,"arabic":"إِلَىٰٓ","translation":"কাছে","audioUrl":"wbw/012_063_003.mp3","charTypeName":"word"},{"id":56311,"position":4,"arabic":"أَبِيهِمْ","translation":"তার পিতার","audioUrl":"wbw/012_063_004.mp3","charTypeName":"word"},{"id":56312,"position":5,"arabic":"قَالُوا۟","translation":"তারা বললো","audioUrl":"wbw/012_063_005.mp3","charTypeName":"word"},{"id":56313,"position":6,"arabic":"يَـٰٓأَبَانَا","translation":"\"হে আমাদের পিতা","audioUrl":"wbw/012_063_006.mp3","charTypeName":"word"},{"id":56314,"position":7,"arabic":"مُنِعَ","translation":"বন্ধ করা হয়েছে","audioUrl":"wbw/012_063_007.mp3","charTypeName":"word"},{"id":56315,"position":8,"arabic":"مِنَّا","translation":"আমাদের থেকে","audioUrl":"wbw/012_063_008.mp3","charTypeName":"word"},{"id":56316,"position":9,"arabic":"ٱلْكَيْلُ","translation":"মাপ (অর্থাৎ বরাদ্দ)","audioUrl":"wbw/012_063_009.mp3","charTypeName":"word"},{"id":56317,"position":10,"arabic":"فَأَرْسِلْ","translation":"অতএব পাঠান","audioUrl":"wbw/012_063_010.mp3","charTypeName":"word"},{"id":56318,"position":11,"arabic":"مَعَنَآ","translation":"আমাদের সাথে","audioUrl":"wbw/012_063_011.mp3","charTypeName":"word"},{"id":56319,"position":12,"arabic":"أَخَانَا","translation":"আমাদের ভাইকে (যেন)","audioUrl":"wbw/012_063_012.mp3","charTypeName":"word"},{"id":56320,"position":13,"arabic":"نَكْتَلْ","translation":"বরাদ্দ পাই (পূর্ণ)","audioUrl":"wbw/012_063_013.mp3","charTypeName":"word"},{"id":56321,"position":14,"arabic":"وَإِنَّا","translation":"এবং নিশ্চয়ই আমরা","audioUrl":"wbw/012_063_014.mp3","charTypeName":"word"},{"id":56322,"position":15,"arabic":"لَهُۥ","translation":"তার জন্যে","audioUrl":"wbw/012_063_015.mp3","charTypeName":"word"},{"id":56323,"position":16,"arabic":"لَحَـٰفِظُونَ","translation":"অবশ্যই (হবো) রক্ষাকারী\"","audioUrl":"wbw/012_063_016.mp3","charTypeName":"word"},{"id":56324,"position":17,"arabic":"٦٣","translation":"(৬৩)","audioUrl":null,"charTypeName":"end"}]}]}