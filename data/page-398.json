ْمُبِينُ","translation":"“And if you give [me] the lie - well, [other] communities have given the lie [to Gods prophets] before your time: but no more is an apostle bound to do than clearly deliver the message [entrusted to him].”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3358.mp3","surahId":29,"words":[{"id":20912,"position":1,"arabic":"وَإِن","translation":"আর যদি","audioUrl":"wbw/029_018_001.mp3","charTypeName":"word"},{"id":20913,"position":2,"arabic":"تُكَذِّبُوا۟","translation":"তোমরা মিথ্যা আরোপ করো","audioUrl":"wbw/029_018_002.mp3","charTypeName":"word"},{"id":20914,"position":3,"arabic":"فَقَدْ","translation":"নিশ্চয়ই তবে","audioUrl":"wbw/029_018_003.mp3","charTypeName":"word"},{"id":20915,"position":4,"arabic":"كَذَّبَ","translation":"মিথ্যারোপ করেছিলো","audioUrl":"wbw/029_018_004.mp3","charTypeName":"word"},{"id":20916,"position":5,"arabic":"أُمَمٌۭ","translation":"(অনেক) জাতি","audioUrl":"wbw/029_018_005.mp3","charTypeName":"word"},{"id":20917,"position":6,"arabic":"مِّن","translation":"থেকেও","audioUrl":"wbw/029_018_006.mp3","charTypeName":"word"},{"id":20918,"position":7,"arabic":"قَبْلِكُمْ ۖ","translation":"তোমাদের পূর্ব","audioUrl":"wbw/029_018_007.mp3","charTypeName":"word"},{"id":20920,"position":8,"arabic":"وَمَا","translation":"আর না","audioUrl":"wbw/029_018_009.mp3","charTypeName":"word"},{"id":20921,"position":9,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/029_018_010.mp3","charTypeName":"word"},{"id":20922,"position":10,"arabic":"ٱلرَّسُولِ","translation":"(দায়িত্ব) রাসূলের","audioUrl":"wbw/029_018_011.mp3","charTypeName":"word"},{"id":20923,"position":11,"arabic":"إِلَّا","translation":"এ ছাড়া যে","audioUrl":"wbw/029_018_012.mp3","charTypeName":"word"},{"id":20924,"position":12,"arabic":"ٱلْبَلَـٰغُ","translation":"পৌঁছানো","audioUrl":"wbw/029_018_013.mp3","charTypeName":"word"},{"id":20925,"position":13,"arabic":"ٱلْمُبِينُ","translation":"সুস্পষ্টভাবে\"","audioUrl":"wbw/029_018_014.mp3","charTypeName":"word"},{"id":20926,"position":14,"arabic":"١٨","translation":"(১৮)","audioUrl":null,"charTypeName":"end"}]},{"number":19,"arabic":"أَوَلَمْ يَرَوْا۟ كَيْفَ يُبْدِئُ ٱللَّهُ ٱلْخَلْقَ ثُمَّ يُعِيدُهُۥٓ ۚ إِنَّ ذَٰلِكَ عَلَى ٱللَّهِ يَسِيرٌۭ","translation":"Are then they [who deny the truth] not aware of how God creates [life] in the first instance, and then brings it forth anew? This, verily, is easy for God!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3359.mp3","surahId":29,"words":[{"id":22012,"position":1,"arabic":"أَوَلَمْ","translation":"কি না","audioUrl":"wbw/029_019_001.mp3","charTypeName":"word"},{"id":22013,"position":2,"arabic":"يَرَوْا۟","translation":"তারা লক্ষ্য করে","audioUrl":"wbw/029_019_002.mp3","charTypeName":"word"},{"id":22014,"position":3,"arabic":"كَيْفَ","translation":"কিভাবে","audioUrl":"wbw/029_019_003.mp3","charTypeName":"word"},{"id":22015,"position":4,"arabic":"يُبْدِئُ","translation":"অস্তিত্ব দেন","audioUrl":"wbw/029_019_004.mp3","charTypeName":"word"},{"id":22016,"position":5,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌","audioUrl":"wbw/029_019_005.mp3","charTypeName":"word"},{"id":22017,"position":6,"arabic":"ٱلْخَلْقَ","translation":"সৃষ্টিকে","audioUrl":"wbw/029_019_006.mp3","charTypeName":"word"},{"id":22018,"position":7,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/029_019_007.mp3","charTypeName":"word"},{"id":22019,"position":8,"arabic":"يُعِيدُهُۥٓ ۚ","translation":"পুনঃসৃষ্টি করবেন তা","audioUrl":"wbw/029_019_008.mp3","charTypeName":"word"},{"id":22021,"position":9,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/029_019_010.mp3","charTypeName":"word"},{"id":22022,"position":10,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/029_019_011.mp3","charTypeName":"word"},{"id":22023,"position":11,"arabic":"عَلَى","translation":"জন্যে","audioUrl":"wbw/029_019_012.mp3","charTypeName":"word"},{"id":22024,"position":12,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌র","audioUrl":"wbw/029_019_013.mp3","char