"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6187.mp3","surahId":104,"words":[{"id":8482,"position":1,"arabic":"إِنَّهَا","translation":"নিশ্চয়ই তা","audioUrl":"wbw/104_008_001.mp3","charTypeName":"word"},{"id":8483,"position":2,"arabic":"عَلَيْهِم","translation":"তাদের উপর","audioUrl":"wbw/104_008_002.mp3","charTypeName":"word"},{"id":8484,"position":3,"arabic":"مُّؤْصَدَةٌۭ","translation":"অবরুদ্ধ করে দেয়া হবে","audioUrl":"wbw/104_008_003.mp3","charTypeName":"word"},{"id":8485,"position":4,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"فِى عَمَدٍۢ مُّمَدَّدَةٍۭ","translation":"in endless columns!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6188.mp3","surahId":104,"words":[{"id":10159,"position":1,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/104_009_001.mp3","charTypeName":"word"},{"id":10160,"position":2,"arabic":"عَمَدٍۢ","translation":"স্তম্ভসমূহের","audioUrl":"wbw/104_009_002.mp3","charTypeName":"word"},{"id":10161,"position":3,"arabic":"مُّمَدَّدَةٍۭ","translation":"দীর্ঘায়িত","audioUrl":"wbw/104_009_003.mp3","charTypeName":"word"},{"id":10162,"position":4,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]}]}