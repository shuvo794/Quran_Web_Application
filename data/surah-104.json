{"id":104,"nameArabic":"سُورَةُ الهُمَزَةِ","nameEnglish":"Al-Humaza","nameTranslation":"The Traducer","revelationType":"Meccan","numberOfAyahs":9,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَيْلٌۭ لِّكُلِّ هُمَزَةٍۢ لُّمَزَةٍ","translation":"WOE unto every slanderer, fault-finder!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6180.mp3","surahId":104,"words":[{"id":108,"position":1,"arabic":"وَيْلٌۭ","translation":"দুর্ভোগ","audioUrl":"wbw/104_001_001.mp3","charTypeName":"word"},{"id":109,"position":2,"arabic":"لِّكُلِّ","translation":"প্রত্যেকের","audioUrl":"wbw/104_001_002.mp3","charTypeName":"word"},{"id":110,"position":3,"arabic":"هُمَزَةٍۢ","translation":"সামনে নিন্দাকারীর","audioUrl":"wbw/104_001_003.mp3","charTypeName":"word"},{"id":111,"position":4,"arabic":"لُّمَزَةٍ","translation":"পিছনে দোষ প্রচারকারীর","audioUrl":"wbw/104_001_004.mp3","charTypeName":"word"},{"id":112,"position":5,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"ٱلَّذِى جَمَعَ مَالًۭا وَعَدَّدَهُۥ","translation":"[Woe unto him who amasses wealth and counts it a safeguard,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6181.mp3","surahId":104,"words":[{"id":1031,"position":1,"arabic":"ٱلَّذِى","translation":"যে","audioUrl":"wbw/104_002_001.mp3","charTypeName":"word"},{"id":1032,"position":2,"arabic":"جَمَعَ","translation":"জমা করেছে","audioUrl":"wbw/104_002_002.mp3","charTypeName":"word"},{"id":1033,"position":3,"arabic":"مَالًۭا","translation":"অর্থ","audioUrl":"wbw/104_002_003.mp3","charTypeName":"word"},{"id":1034,"position":4,"arabic":"وَعَدَّدَهُۥ","translation":"এবং তা বারবার গণনা করে রেখেছে","audioUrl":"wbw/104_002_004.mp3","charTypeName":"word"},{"id":1035,"position":5,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"يَحْسَبُ أَنَّ مَالَهُۥٓ أَخْلَدَهُۥ","translation":"thinking that his wealth will make him live forever!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6182.mp3","surahId":104,"words":[{"id":2234,"position":1,"arabic":"يَحْسَبُ","translation":"সে ধারণা করে","audioUrl":"wbw/104_003_001.mp3","charTypeName":"word"},{"id":2235,"position":2,"arabic":"أَنَّ","translation":"যে","audioUrl":"wbw/104_003_002.mp3","charTypeName":"word"},{"id":2236,"position":3,"arabic":"مَالَهُۥٓ","translation":"তার অর্থ","audioUrl":"wbw/104_003_003.mp3","charTypeName":"word"},{"id":2237,"position":4,"arabic":"أَخْلَدَهُۥ","translation":"তাকে অমর করবে","audioUrl":"wbw/104_003_004.mp3","charTypeName":"word"},{"id":2238,"position":5,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"كَلَّا ۖ لَيُنۢبَذَنَّ فِى ٱلْحُطَمَةِ","translation":"Nay, but [in the life to come such as] he shall indeed be abandoned to crushing torment!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6183.mp3","surahId":104,"words":[{"id":3599,"position":1,"arabic":"كَلَّا ۖ","translation":"কখনও না","audioUrl":"wbw/104_004_001.mp3","charTypeName":"word"},{"id":3601,"position":2,"arabic":"لَيُنۢبَذَنَّ","translation":"সে নিক্ষিপ্ত হবে অবশ্যই","audioUrl":"wbw/104_004_003.mp3","charTypeName":"word"},{"id":3602,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/104_004_004.mp3","charTypeName":"word"},{"id":3603,"position":4,"arabic":"ٱلْحُطَمَةِ","translation":"বিচূর্ণকারী স্থানের","audioUrl":"wbw/104_004_005.mp3","charTypeName":"word"},{"id":3604,"position":5,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"وَمَآ أَدْرَىٰكَ مَا ٱلْحُطَمَةُ","translation":"And what could make thee conceive what that crushing torment will be?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6184.mp3","surahId":104,"words":[{"id":4913,"position":1,"arabic":"وَمَآ","translation":"এবং কি","audioUrl":"wbw/104_005_001.mp3","charTypeName":"word"},{"id":4914,"position":2,"arabic":"أَدْرَىٰكَ","translation":"