005.mp3","charTypeName":"word"},{"id":72327,"position":6,"arabic":"خَسِرُوٓا۟","translation":"ক্ষতিগ্রস্ত করেছে","audioUrl":"wbw/023_103_006.mp3","charTypeName":"word"},{"id":72328,"position":7,"arabic":"أَنفُسَهُمْ","translation":"তাদের নিজেদেরকে","audioUrl":"wbw/023_103_007.mp3","charTypeName":"word"},{"id":72329,"position":8,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/023_103_008.mp3","charTypeName":"word"},{"id":72330,"position":9,"arabic":"جَهَنَّمَ","translation":"জাহান্নামের","audioUrl":"wbw/023_103_009.mp3","charTypeName":"word"},{"id":72331,"position":10,"arabic":"خَـٰلِدُونَ","translation":"তারা চিরস্থায়ী হবে (সেখানে)","audioUrl":"wbw/023_103_010.mp3","charTypeName":"word"},{"id":72332,"position":11,"arabic":"١٠٣","translation":"(১০৩)","audioUrl":null,"charTypeName":"end"}]},{"number":104,"arabic":"تَلْفَحُ وُجُوهَهُمُ ٱلنَّارُ وَهُمْ فِيهَا كَٰلِحُونَ","translation":"the fire will scorch their faces, and they will abide therein with their lips distorted in pain.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2777.mp3","surahId":23,"words":[{"id":72570,"position":1,"arabic":"تَلْفَحُ","translation":"জ্বালিয়ে দিবে","audioUrl":"wbw/023_104_001.mp3","charTypeName":"word"},{"id":72571,"position":2,"arabic":"وُجُوهَهُمُ","translation":"তাদের মুখমন্ডলকে","audioUrl":"wbw/023_104_002.mp3","charTypeName":"word"},{"id":72572,"position":3,"arabic":"ٱلنَّارُ","translation":"আগুন","audioUrl":"wbw/023_104_003.mp3","charTypeName":"word"},{"id":72573,"position":4,"arabic":"وَهُمْ","translation":"আর তারা","audioUrl":"wbw/023_104_004.mp3","charTypeName":"word"},{"id":72574,"position":5,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/023_104_005.mp3","charTypeName":"word"},{"id":72575,"position":6,"arabic":"كَـٰلِحُونَ","translation":"বীভৎস হবে (চেহারায়)","audioUrl":"wbw/023_104_006.mp3","charTypeName":"word"},{"id":72576,"position":7,"arabic":"١٠٤","translation":"(১০৪)","audioUrl":null,"charTypeName":"end"}]}]}