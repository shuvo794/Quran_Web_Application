{"id":348,"ayahs":[{"number":90,"arabic":"بَلْ أَتَيْنَٰهُم بِٱلْحَقِّ وَإِنَّهُمْ لَكَٰذِبُونَ","translation":"Nay, We have conveyed unto them the truth: and yet, behold, they are intent on lying [to them­selves]!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2763.mp3","surahId":23,"words":[{"id":68087,"position":1,"arabic":"بَلْ","translation":"বরং","audioUrl":"wbw/023_090_001.mp3","charTypeName":"word"},{"id":68088,"position":2,"arabic":"أَتَيْنَـٰهُم","translation":"আমরা এসেছি তাদের কাছে","audioUrl":"wbw/023_090_002.mp3","charTypeName":"word"},{"id":68089,"position":3,"arabic":"بِٱلْحَقِّ","translation":"নিয়ে মহাসত্যকে","audioUrl":"wbw/023_090_003.mp3","charTypeName":"word"},{"id":68090,"position":4,"arabic":"وَإِنَّهُمْ","translation":"আর নিশ্চয়ই তারা","audioUrl":"wbw/023_090_004.mp3","charTypeName":"word"},{"id":68091,"position":5,"arabic":"لَكَـٰذِبُونَ","translation":"অবশ্যই মিথ্যাবাদী","audioUrl":"wbw/023_090_005.mp3","charTypeName":"word"},{"id":68092,"position":6,"arabic":"٩٠","translation":"(৯০)","audioUrl":null,"charTypeName":"end"}]},{"number":91,"arabic":"مَا ٱتَّخَذَ ٱللَّهُ مِن وَلَدٍۢ وَمَا كَانَ مَعَهُۥ مِنْ إِلَٰهٍ ۚ إِذًۭا لَّذَهَبَ كُلُّ إِلَٰهٍۭ بِمَا خَلَقَ وَلَعَلَا بَعْضُهُمْ عَلَىٰ بَعْضٍۢ ۚ سُبْحَٰنَ ٱللَّهِ عَمَّا يَصِفُونَ","translation":"Never did God take unto Himself any offspring, nor has there ever been any deity side by side with Him: [for, had there been any,] lo! each deity would surely have stood apart [from the others] in whatever it had created, and they would surely have [tried to] overcome one another! Limitless in His glory is God, [far] above anything that men may devise by way of definition,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2764.mp3","surahId":23,"words":[{"id":68409,"position":1,"arabic":"مَا","translation":"নি","audioUrl":"wbw/023_091_001.mp3","charTypeName":"word"},{"id":68410,"position":2,"arabic":"ٱتَّخَذَ","translation":"গ্রহণ করেন","audioUrl":"wbw/023_091_002.mp3","charTypeName":"word"},{"id":68411,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/023_091_003.mp3","charTypeName":"word"},{"id":68412,"position":4,"arabic":"مِن","translation":"(কাউকে) কোন","audioUrl":"wbw/023_091_004.mp3","charTypeName":"word"},{"id":68413,"position":5,"arabic":"وَلَدٍۢ","translation":"সন্তান (হিসেবে)","audioUrl":"wbw/023_091_005.mp3","charTypeName":"word"},{"id":68414,"position":6,"arabic":"وَمَا","translation":"আর না","audioUrl":"wbw/023_091_006.mp3","charTypeName":"word"},{"id":68415,"position":7,"arabic":"كَانَ","translation":"ছিলো (শরীক)","audioUrl":"wbw/023_091_007.mp3","charTypeName":"word"},{"id":68416,"position":8,"arabic":"مَعَهُۥ","translation":"তাঁর সাথে","audioUrl":"wbw/023_091_008.mp3","charTypeName":"word"},{"id":68417,"position":9,"arabic":"مِنْ","translation":"কোন","audioUrl":"wbw/023_091_009.mp3","charTypeName":"word"},{"id":68418,"position":10,"arabic":"إِلَـٰهٍ ۚ","translation":"ইলাহর","audioUrl":"wbw/023_091_010.mp3","charTypeName":"word"},{"id":68420,"position":11,"arabic":"إِذًۭا","translation":"যদি হতো (তবে)","audioUrl":"wbw/023_091_012.mp3","charTypeName":"word"},{"id":68421,"position":12,"arabic":"لَّذَهَبَ","translation":"অবশ্যই নিয়ে যেতো","audioUrl":"wbw/023_091_013.mp3","charTypeName":"word"},{"id":68422,"position":13,"arabic":"كُلُّ","translation":"প্রত্যেক","audioUrl":"wbw/023_091_014.mp3","charTypeName":"word"},{"id":68423,"position":14,"arabic":"إِلَـٰهٍۭ","translation":"ইলাহ","audioUrl":"wbw/023_091_015.mp3","charTypeName":"word"},{"id":68424,"position":15,"arabic":"بِمَا","translation":"ঐসব যা কিছু","audioUrl":"wbw/023_091_016.mp3","charTypeName":"word"},{"id":68425,"position":16,"arabic":"خَلَقَ","translation":"সে সৃষ্টি করেছে","audioUrl":"wbw/023_091_017.mp3","charTypeName":"word"},{"id":68426,"position":17,"arabic":"وَلَعَلَا","translation":"ও প্রাধান্য বিস্তার করতো","audioUrl":"wbw/023_091_018.mp3","charTypeName":"word"},{"id":68427,"position":18,"arabic":"بَعْضُهُمْ","translation":"তাদের একে","audioUrl":"wbw/023_091_019.mp3","charTypeName":"word"},{"id":68428,"position":19,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/023_091_020.mp3","charTypeName":"word"},{"id":68429,"position":20,"arabic":"بَعْضٍۢ ۚ","translation":"অপরের","audioUrl":"wbw/023_091_021.mp3","charTypeName":"word"},{"id":68431,"position":21,"arabic":"سُبْحَـٰنَ","translation":"পবিত্র","audioUrl":"wbw/023_091_023.mp3","charTypeName":"word"},{"id":68432,"position":22,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌","audioUrl":"wbw/023_091_024.mp3","charTypeName":"word"},{"id":68433,"position":23,"arabic":"عَمَّا","translation":"(তা) হ'তে যা","audioUrl":"wbw/023_091_025.mp3","charTypeName":"word"},{"id":68434,"position":24,"arabic":"يَصِفُونَ","translation":"তারা রচনা করে","audioUrl":"wbw/023_091_026.mp3","charTypeName":"word"},{"id":68435,"position":25,"arabic":"٩١","translation":"(৯১)","audioUrl":null,"charTypeName":"end"}]},{"number":92,"arabic":"عَٰلِمِ ٱلْغَيْبِ وَٱلشَّهَٰدَةِ فَتَعَٰلَىٰ عَمَّا يُشْرِكُونَ","translation":"knowing all that is beyond the reach of a created being’s perception as well as all that can be witnessed by a creature’s senses or mind and, hence, sublimely exalted is He above anything to which they may ascribe a share in His divinity!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2765.mp3","surahId":23,"words":[{"id":68787,"position":1,"arabic":"عَـٰلِمِ","translation":"অবহিত","audioUrl":"wbw/023_092_001.mp3","charTypeName":"word"},{"id":68788,"position":2,"arabic":"ٱلْغَيْبِ","translation":"অদৃশ্যের","audioUrl":"wbw/023_092_002.mp3","charTypeName":"word"},{"id":68789,"position":3,"arabic":"وَٱلشَّهَـٰدَةِ","translation":"ও দৃশ্যের","audioUrl":"wbw/023_092_003.mp3","charTypeName":"word"},{"id":68790,"position":4,"arabic":"فَتَعَـٰلَىٰ","translation":"অতএব তিনি উর্দ্ধে","audioUrl":"wbw/023_092_004.mp3","charTypeName":"word"},{"id":68791,"position":5,"arabic":"عَمَّا","translation":"তা হ'তে যা কিছু","audioUrl":"wbw/023_092_005.mp3","charTypeName":"word"},{"id":68792,"position":6,"arabic":"يُشْرِكُونَ","translation":"তারা শরীক করছে","audioUrl":"wbw/023_092_006.mp3","charTypeName":"word"},{"id":68793,"position":7,"arabic":"٩٢","translation":"(৯২)","audioUrl":null,"charTypeName":"end"}]},{"number":93,"arabic":"قُل رَّبِّ إِمَّا تُرِيَنِّى مَا يُوعَدُونَ","translation":"SAY: “O my Sustainer! If it be Thy will to let me witness [the fulfillment of] whatever they [who blaspheme against Thee] have been promised [to suffer] –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2766.mp3","surahId":23,"words":[{"id":69266,"position":1,"arabic":"قُل","translation":"বলো (দোয়া করো)","audioUrl":"wbw/023_093_001.mp3","charTypeName":"word"},{"id":69267,"position":2,"arabic":"رَّبِّ","translation":"\"হে আমার রব","audioUrl":"wbw/023_093_002.mp3","charTypeName":"word"},{"id":69268,"position":3,"arabic":"إِمَّا","translation":"যদি","audioUrl":"wbw/023_093_003.mp3","charTypeName":"word"},{"id":69269,"position":4,"arabic":"تُرِيَنِّى","translation":"আমাকে দেখাও","audioUrl":"wbw/023_093_004.mp3","charTypeName":"word"},{"id":69270,"position":5,"arabic":"مَا","translation":"যা","audioUrl":"wbw/023_093_005.mp3","charTypeName":"word"},{"id":69271,"position":6,"arabic":"يُوعَدُونَ","translation":"তাদের প্রতিশ্রুতি দেয়া হচ্ছে","audioUrl":"wbw/023_093_006.mp3","charTypeName":"word"},{"id":69272,"position":7,"arabic":"٩٣","translation":"(৯৩)","audioUrl":null,"charTypeName":"end"}]},{"number":94,"arabic":"رَبِّ فَلَا تَجْعَلْنِى فِى ٱلْقَوْمِ ٱلظَّٰلِمِينَ","translation":"do not, O my Sustainer, let me be one of those evildoing folk!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2767.mp3","surahId":23,"words":[{"id":69664,"position":1,"arabic":"رَبِّ","translation":"হে আমার রব","audioUrl":"wbw/023_094_001.mp3","charTypeName":"word"},{"id":69665,"position":2,"arabic":"فَلَا","translation":"তবে না","audioUrl":"wbw/023_094_002.mp3","charTypeName":"word"},{"id":69666,"position":3,"arabic":"تَجْعَلْنِى","translation":"আমাকে করো তুমি","audioUrl":"wbw/023_094_003.mp3","charTypeName":"word"},{"id":69667,"position":4,"arabic":"فِى","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/023_094_004.mp3","charTypeName":"word"},{"id":69668,"position":5,"arabic":"ٱلْقَوْمِ","translation":"সম্প্রদায়ের","audioUrl":"wbw/023_094_005.mp3","charTypeName":"word"},{"id":69669,"position":6,"arabic":"ٱلظَّـٰلِمِينَ","translation":"সীমালঙ্ঘনকারী\"","audioUrl":"wbw/023_094_006.mp3","charTypeName":"word"},{"id":69670,"position":7,"arabic":"٩٤","translation":"(৯৪)","audioUrl":null,"charTypeName":"end"}]},{"number":95,"arabic":"وَإِنَّا عَلَىٰٓ أَن نُّرِيَكَ مَا نَعِدُهُمْ لَقَٰدِرُونَ","translation":"[Pray thus] for, behold, We are most cer­tainly able to let thee witness [the fulfillment, even in this world, of] whatever We promise them!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2768.mp3","surahId":23,"words":[{"id":69963,"position":1,"arabic":"وَإِنَّا","translation":"এবং নিশ্চয়ই আমরা","audioUrl":"wbw/023_095_001.mp3","charTypeName":"word"},{"id":69964,"position":2,"arabic":"عَلَىٰٓ","translation":"এক্ষেত্রে","audioUrl":"wbw/023_095_002.mp3","charTypeName":"word"},{"id":69965,"position":3,"arabic":"أَن","translation":"যে","audioUrl":"wbw/023_095_003.mp3","charTypeName":"word"},{"id":69966,"position":4,"arabic":"نُّرِيَكَ","translation":"তোমাকে দেখাবো আমরা","audioUrl":"wbw/023_095_004.mp3","charTypeName":"word"},{"id":69967,"position":5,"arabic":"مَا","translation":"যা","audioUrl":"wbw/023_095_005.mp3","charTypeName":"word"},{"id":69968,"position":6,"arabic":"نَعِدُهُمْ","translation":"আমরা প্রতিশ্রুতি দিয়েছি তাদেরকে","audioUrl":"wbw/023_095_006.mp3","charTypeName":"word"},{"id":69969,"position":7,"arabic":"لَقَـٰدِرُونَ","translation":"অবশ্যই (তা দেখাতে) সক্ষম","audioUrl":"wbw/023_095_007.mp3","charTypeName":"word"},{"id":69970,"position":8,"arabic":"٩٥","translation":"(৯৫)","audioUrl":null,"charTypeName":"end"}]},{"number":96,"arabic":"ٱدْفَعْ بِٱلَّتِى هِىَ أَحْسَنُ ٱلسَّيِّئَةَ ۚ نَحْنُ أَعْلَمُ بِمَا يَصِفُونَ","translation":"[But whatever they may say or do,] repel the evil [which they commit] with something that is bet­ter: We are fully aware of what they attribute [to Us].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2769.mp3","surahId":23,"words":[{"id":70021,"position":1,"arabic":"ٱدْفَعْ","translation":"প্রতিহত করো","audioUrl":"wbw/023_096_001.mp3","charTypeName":"word"},{"id":70022,"position":2,"arabic":"بِٱلَّتِى","translation":"দিয়ে তা","audioUrl":"wbw/023_096_002.mp3","charTypeName":"word"},{"id":70023,"position":3,"arabic":"هِىَ","translation":"যা","audioUrl":"wbw/023_096_003.mp3","charTypeName":"word"},{"id":70024,"position":4,"arabic":"أَحْسَنُ","translation":"উত্তম","audioUrl":"wbw/023_096_004.mp3","charTypeName":"word"},{"id":70025,"position":5,"arabic":"ٱلسَّيِّئَةَ ۚ","translation":"মন্দের (মোকাবিলায়)","audioUrl":"wbw/023_096_005.mp3","charTypeName":"word"},{"id":70027,"position":6,"arabic":"نَحْنُ","translation":"আমরা","audioUrl":"wbw/023_096_007.mp3","charTypeName":"word"},{"id":70028,"position":7,"arabic":"أَعْلَمُ","translation":"খুব জানি","audioUrl":"wbw/023_096_008.mp3","charTypeName":"word"},{"id":70029,"position":8,"arabic":"بِمَا","translation":"ঐ বিষয় যা","audioUrl":"wbw/023_096_009.mp3","charTypeName":"word"},{"id":70030,"position":9,"arabic":"يَصِفُونَ","translation":"তারা বর্ণনা করে","audioUrl":"wbw/023_096_010.mp3","charTypeName":"word"},{"id":70031,"position":10,"arabic":"٩٦","translation":"(৯৬)","audioUrl":null,"charTypeName":"end"}]},{"number":97,"arabic":"وَقُل رَّبِّ أَعُوذُ بِكَ مِنْ هَمَزَٰتِ ٱلشَّيَٰطِينِ","translation":"And say: “O my Sustainer! I seek refuge with Thee from the promptings of all evil impulses;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2770.mp3","surahId":23,"words":[{"id":70334,"position":1,"arabic":"وَقُل","translation":"এবং বলো (দু'আ করো)","audioUrl":"wbw/023_097_001.mp3","charTypeName":"word"},{"id":70335,"position":2,"arabic":"رَّبِّ","translation":"\"হে আমার রব","audioUrl":"wbw/023_097_002.mp3","charTypeName":"word"},{"id":70336,"position":3,"arabic":"أَعُوذُ","translation":"আমি আশ্রয় চাই","audioUrl":"wbw/023_097_003.mp3","charTypeName":"word"},{"id":70337,"position":4,"arabic":"بِكَ","translation":"তোমার নিকট","audioUrl":"wbw/023_097_004.mp3","charTypeName":"word"},{"id":70338,"position":5,"arabic":"مِنْ","translation":"হ'তে","audioUrl":"wbw/023_097_005.mp3","charTypeName":"word"},{"id":70339,"position":6,"arabic":"هَمَزَٰتِ","translation":"প্ররোচনা","audioUrl":"wbw/023_097_006.mp3","charTypeName":"word"},{"id":70340,"position":7,"arabic":"ٱلشَّيَـٰطِينِ","translation":"শয়তানদের","audioUrl":"wbw/023_097_007.mp3","charTypeName":"word"},{"id":70341,"position":8,"arabic":"٩٧","translation":"(৯৭)","audioUrl":null,"charTypeName":"end"}]},{"number":98,"arabic":"وَأَعُوذُ بِكَ رَبِّ أَن يَحْضُرُونِ","translation":"and I seek refuge with Thee, O my Sustainer, lest they come near unto me!’","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2771.mp3","surahId":23,"words":[{"id":70737,"position":1,"arabic":"وَأَعُوذُ","translation":"ও আশ্রয় চাই আমি","audioUrl":"wbw/023_098_001.mp3","charTypeName":"word"},{"id":70738,"position":2,"arabic":"بِكَ","translation":"নিকট তোমার","audioUrl":"wbw/023_098_002.mp3","charTypeName":"word"},{"id":70739,"position":3,"arabic":"رَبِّ","translation":"হে আমার রব","audioUrl":"wbw/023_098_003.mp3","charTypeName":"word"},{"id":70740,"position":4,"arabic":"أَن","translation":"যে","audioUrl":"wbw/023_098_004.mp3","charTypeName":"word"},{"id":70741,"position":5,"arabic":"يَحْضُرُونِ","translation":"আমার নিকট (শয়তান) উপস্থিত হবে\"","audioUrl":"wbw/023_098_005.mp3","charTypeName":"word"},{"id":70742,"position":6,"arabic":"٩٨","translation":"(৯৮)","audioUrl":null,"charTypeName":"end"}]},{"number":99,"arabic":"حَتَّىٰٓ إِذَا جَآءَ أَحَدَهُمُ ٱلْمَوْتُ قَالَ رَبِّ ٱرْجِعُونِ","translation":"[AS FOR THOSE who will not believe in the life to come, they go on lying to themselves] until, when death approaches any of them, he prays: “O my Sustainer! Let me return, let me return [to life],","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2772.mp3","surahId":23,"words":[{"id":70925,"position":1,"arabic":"حَتَّىٰٓ","translation":"শেষ পর্যন্ত","audioUrl":"wbw/023_099_001.mp3","charTypeName":"word"},{"id":70926,"position":2,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/023_099_002.mp3","charTypeName":"word"},{"id":70927,"position":3,"arabic":"جَآءَ","translation":"আসবে","audioUrl":"wbw/023_099_003.mp3","charTypeName":"word"},{"id":70928,"position":4,"arabic":"أَحَدَهُمُ","translation":"কারো তাদের","audioUrl":"wbw/023_099_004.mp3","charTypeName":"word"},{"id":70929,"position":5,"arabic":"ٱلْمَوْتُ","translation":"মৃত্যু","audioUrl":"wbw/023_099_005.mp3","charTypeName":"word"},{"id":70930,"position":6,"arabic":"قَالَ","translation":"সে বলবে","audioUrl":"wbw/023_099_006.mp3","charTypeName":"word"},{"id":70931,"position":7,"arabic":"رَبِّ","translation":"\"হে আমার রব","audioUrl":"wbw/023_099_007.mp3","charTypeName":"word"},{"id":70932,"position":8,"arabic":"ٱرْجِعُونِ","translation":"আমাকে ফেরত পাঠাও","audioUrl":"wbw/023_099_008.mp3","charTypeName":"word"},{"id":70933,"position":9,"arabic":"٩٩","translation":"(৯৯)","audioUrl":null,"charTypeName":"end"}]},{"number":100,"arabic":"لَعَلِّىٓ أَعْمَلُ صَٰلِحًۭا فِيمَا تَرَكْتُ ۚ كَلَّآ ۚ إِنَّهَا كَلِمَةٌ هُوَ قَآئِلُهَا ۖ وَمِن وَرَآئِهِم بَرْزَخٌ إِلَىٰ يَوْمِ يُبْعَثُونَ","translation":"so that I might act righteously in whatever I have failed [aforetime]!” Nay, it is indeed but a [meaningless] word that he utters: for behind those [who leave the world] there is a barrier [of death] until the Day when all will be raised from the dead!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2773.mp3","surahId":23,"words":[{"id":71375,"position":1,"arabic":"لَعَلِّىٓ","translation":"যাতে আমি","audioUrl":"wbw/023_100_001.mp3","charTypeName":"word"},{"i