.mp3","surahId":7,"words":[{"id":64658,"position":1,"arabic":"إِنَّكُمْ","translation":"নিশ্চয়ই তোমরা","audioUrl":"wbw/007_081_001.mp3","charTypeName":"word"},{"id":64659,"position":2,"arabic":"لَتَأْتُونَ","translation":"অবশ্যই তোমরা আসো","audioUrl":"wbw/007_081_002.mp3","charTypeName":"word"},{"id":64660,"position":3,"arabic":"ٱلرِّجَالَ","translation":"পুরুষদের (কাছে)","audioUrl":"wbw/007_081_003.mp3","charTypeName":"word"},{"id":64661,"position":4,"arabic":"شَهْوَةًۭ","translation":"যৌন-তৃপ্তির জন্যে","audioUrl":"wbw/007_081_004.mp3","charTypeName":"word"},{"id":64662,"position":5,"arabic":"مِّن","translation":"দিয়ে","audioUrl":"wbw/007_081_005.mp3","charTypeName":"word"},{"id":64663,"position":6,"arabic":"دُونِ","translation":"বাদ","audioUrl":"wbw/007_081_006.mp3","charTypeName":"word"},{"id":64664,"position":7,"arabic":"ٱلنِّسَآءِ ۚ","translation":"স্ত্রীলোকদের","audioUrl":"wbw/007_081_007.mp3","charTypeName":"word"},{"id":64666,"position":8,"arabic":"بَلْ","translation":"বরং","audioUrl":"wbw/007_081_009.mp3","charTypeName":"word"},{"id":64667,"position":9,"arabic":"أَنتُمْ","translation":"তোমরা","audioUrl":"wbw/007_081_010.mp3","charTypeName":"word"},{"id":64668,"position":10,"arabic":"قَوْمٌۭ","translation":"সম্প্রদায়","audioUrl":"wbw/007_081_011.mp3","charTypeName":"word"},{"id":64669,"position":11,"arabic":"مُّسْرِفُونَ","translation":"সীমালঙ্ঘনকারী\"","audioUrl":"wbw/007_081_012.mp3","charTypeName":"word"},{"id":64670,"position":12,"arabic":"٨١","translation":"(৮১)","audioUrl":null,"charTypeName":"end"}]}]}