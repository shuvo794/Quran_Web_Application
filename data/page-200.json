{"id":200,"ayahs":[{"number":80,"arabic":"ٱسْتَغْفِرْ لَهُمْ أَوْ لَا تَسْتَغْفِرْ لَهُمْ إِن تَسْتَغْفِرْ لَهُمْ سَبْعِينَ مَرَّةًۭ فَلَن يَغْفِرَ ٱللَّهُ لَهُمْ ۚ ذَٰلِكَ بِأَنَّهُمْ كَفَرُوا۟ بِٱللَّهِ وَرَسُولِهِۦ ۗ وَٱللَّهُ لَا يَهْدِى ٱلْقَوْمَ ٱلْفَٰسِقِينَ","translation":"[And] whether thou dost pray [unto God] that they be forgiven or dost not pray for them - [it will all be the same: for even] if thou wert to pray seventy times that they be forgiven, God will not forgive them, seeing that they are bent on denying God and His Apostle. And God does not bestow His guidance upon such iniquitous folk.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1315.mp3","surahId":9,"words":[{"id":64390,"position":1,"arabic":"ٱسْتَغْفِرْ","translation":"ক্ষমা প্রার্থনা করো তুমি","audioUrl":"wbw/009_080_001.mp3","charTypeName":"word"},{"id":64391,"position":2,"arabic":"لَهُمْ","translation":"জন্যে তাদের","audioUrl":"wbw/009_080_002.mp3","charTypeName":"word"},{"id":64392,"position":3,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/009_080_003.mp3","charTypeName":"word"},{"id":64393,"position":4,"arabic":"لَا","translation":"না","audioUrl":"wbw/009_080_004.mp3","charTypeName":"word"},{"id":64394,"position":5,"arabic":"تَسْتَغْفِرْ","translation":"ক্ষমা প্রার্থনা করো","audioUrl":"wbw/009_080_005.mp3","charTypeName":"word"},{"id":64395,"position":6,"arabic":"لَهُمْ","translation":"জন্যে তাদের(একই কথা)","audioUrl":"wbw/009_080_006.mp3","charTypeName":"word"},{"id":64396,"position":7,"arabic":"إِن","translation":"(এমনকি) যদি","audioUrl":"wbw/009_080_007.mp3","charTypeName":"word"},{"id":64397,"position":8,"arabic":"تَسْتَغْفِرْ","translation":"ক্ষমা প্রার্থনা করো তুমি","audioUrl":"wbw/009_080_008.mp3","charTypeName":"word"},{"id":64398,"position":9,"arabic":"لَهُمْ","translation":"জন্যে তাদের","audioUrl":"wbw/009_080_009.mp3","charTypeName":"word"},{"id":64399,"position":10,"arabic":"سَبْعِينَ","translation":"সত্তর","audioUrl":"wbw/009_080_010.mp3","charTypeName":"word"},{"id":64400,"position":11,"arabic":"مَرَّةًۭ","translation":"বারও","audioUrl":"wbw/009_080_011.mp3","charTypeName":"word"},{"id":64401,"position":12,"arabic":"فَلَن","translation":"তারপরও কখনও না","audioUrl":"wbw/009_080_012.mp3","charTypeName":"word"},{"id":64402,"position":13,"arabic":"يَغْفِرَ","translation":"ক্ষমা করবেন","audioUrl":"wbw/009_080_013.mp3","charTypeName":"word"},{"id":64403,"position":14,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/009_080_014.mp3","charTypeName":"word"},{"id":64404,"position":15,"arabic":"لَهُمْ ۚ","translation":"প্রতি তাদের","audioUrl":"wbw/009_080_015.mp3","charTypeName":"word"},{"id":64406,"position":16,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/009_080_017.mp3","charTypeName":"word"},{"id":64407,"position":17,"arabic":"بِأَنَّهُمْ","translation":"এজন্যে যে তারা","audioUrl":"wbw/009_080_018.mp3","charTypeName":"word"},{"id":64408,"position":18,"arabic":"كَفَرُوا۟","translation":"অবিশ্বাস করেছে","audioUrl":"wbw/009_080_019.mp3","charTypeName":"word"},{"id":64409,"position":19,"arabic":"بِٱللَّهِ","translation":"প্রতি আল্লাহর","audioUrl":"wbw/009_080_020.mp3","charTypeName":"word"},{"id":64410,"position":20,"arabic":"وَرَسُولِهِۦ ۗ","translation":"ও তাঁর রাসূলের","audioUrl":"wbw/009_080_021.mp3","charTypeName":"word"},{"id":64412,"position":21,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/009_080_023.mp3","charTypeName":"word"},{"id":64413,"position":22,"arabic":"لَا","translation":"না","audioUrl":"wbw/009_080_024.mp3","charTypeName":"word"},{"id":64414,"position":23,"arabic":"يَهْدِى","translation":"সঠিক পথ দেখান","audioUrl":"wbw/009_080_025.mp3","charTypeName":"word"},{"id":64415,"position":24,"arabic":"ٱلْقَوْمَ","translation":"(এমন) সম্প্রদায়কে","audioUrl":"wbw/009_080_026.mp3","charTypeName":"word"},{"id":64416,"position":25,"arabic":"ٱلْفَـٰسِقِينَ","translation":"(যারা) সত্যত্যাগী","audioUrl":"wbw/009_080_027.mp3","charTypeName":"word"},{"id":64417,"position":26,"arabic":"٨٠","translation":"(৮০)","audioUrl":null,"charTypeName":"end"}]},{"number":81,"arabic":"فَرِحَ ٱلْمُخَلَّفُونَ بِمَقْعَدِهِمْ خِلَٰفَ رَسُولِ ٱللَّهِ وَكَرِهُوٓا۟ أَن يُجَٰهِدُوا۟ بِأَمْوَٰلِهِمْ وَأَنفُسِهِمْ فِى سَبِيلِ ٱللَّهِ وَقَالُوا۟ لَا تَنفِرُوا۟ فِى ٱلْحَرِّ ۗ قُلْ نَارُ جَهَنَّمَ أَشَدُّ حَرًّۭا ۚ لَّوْ كَانُوا۟ يَفْقَهُونَ","translation":"THOSE [hypocrites] who were left behind rejoiced in their staying away [from war] after [the departure of] God's Apostle, for they hated the thought of striving with their possessions and their lives in God's cause; and they had [even] said [to the others], \"Do not go forth to war in this heat!\" Say: \"The fire of hell is hotter by far!\" Had they but grasped this truth!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1316.mp3","surahId":9,"words":[{"id":64506,"position":1,"arabic":"فَرِحَ","translation":"খুশি হয়েছে","audioUrl":"wbw/009_081_001.mp3","charTypeName":"word"},{"id":64507,"position":2,"arabic":"ٱلْمُخَلَّفُونَ","translation":"পিছনে থাকা লোকেরা","audioUrl":"wbw/009_081_002.mp3","charTypeName":"word"},{"id":64508,"position":3,"arabic":"بِمَقْعَدِهِمْ","translation":"নিয়ে বসে থাকা তাদের","audioUrl":"wbw/009_081_003.mp3","charTypeName":"word"},{"id":64509,"position":4,"arabic":"خِلَـٰفَ","translation":"বিরোধিতা করে","audioUrl":"wbw/009_081_004.mp3","charTypeName":"word"},{"id":64510,"position":5,"arabic":"رَسُولِ","translation":"রাসূলের","audioUrl":"wbw/009_081_005.mp3","charTypeName":"word"},{"id":64511,"position":6,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/009_081_006.mp3","charTypeName":"word"},{"id":64512,"position":7,"arabic":"وَكَرِهُوٓا۟","translation":"এবং তারা অপছন্দ করেছে","audioUrl":"wbw/009_081_007.mp3","charTypeName":"word"},{"id":64513,"position":8,"arabic":"أَن","translation":"যে","audioUrl":"wbw/009_081_008.mp3","charTypeName":"word"},{"id":64514,"position":9,"arabic":"يُجَـٰهِدُوا۟","translation":"তারা জেহাদ করবে","audioUrl":"wbw/009_081_009.mp3","charTypeName":"word"},{"id":64515,"position":10,"arabic":"بِأَمْوَٰلِهِمْ","translation":"দিয়ে ধনসসম্পদ তাদের","audioUrl":"wbw/009_081_010.mp3","charTypeName":"word"},{"id":64516,"position":11,"arabic":"وَأَنفُسِهِمْ","translation":"ও প্রাণ(দিয়ে)তাদের","audioUrl":"wbw/009_081_011.mp3","charTypeName":"word"},{"id":64517,"position":12,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/009_081_012.mp3","charTypeName":"word"},{"id":64518,"position":13,"arabic":"سَبِيلِ","translation":"পথের","audioUrl":"wbw/009_081_013.mp3","charTypeName":"word"},{"id":64519,"position":14,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/009_081_014.mp3","charTypeName":"word"},{"id":64520,"position":15,"arabic":"وَقَالُوا۟","translation":"এবং তারা বললো","audioUrl":"wbw/009_081_015.mp3","charTypeName":"word"},{"id":64521,"position":16,"arabic":"لَا","translation":"\"না","audioUrl":"wbw/009_081_016.mp3","charTypeName":"word"},{"id":64522,"position":17,"arabic":"تَنفِرُوا۟","translation":"তোমরা অভিযানে যেও","audioUrl":"wbw/009_081_017.mp3","charTypeName":"word"},{"id":64523,"position":18,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/009_081_018.mp3","charTypeName":"word"},{"id":64524,"position":19,"arabic":"ٱلْحَرِّ ۗ","translation":"গরমের\"","audioUrl":"wbw/009_081_019.mp3","charTypeName":"word"},{"id":64526,"position":20,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/009_081_021.mp3","charTypeName":"word"},{"id":64527,"position":21,"arabic":"نَارُ","translation":"\"আগুন","audioUrl":"wbw/009_081_022.mp3","charTypeName":"word"},{"id":64528,"position":22,"arabic":"جَهَنَّمَ","translation":"জাহান্নামের","audioUrl":"wbw/009_081_023.mp3","charTypeName":"word"},{"id":64529,"position":23,"arabic":"أَشَدُّ","translation":"প্রচন্ডতম","audioUrl":"wbw/009_081_024.mp3","charTypeName":"word"},{"id":64530,"position":24,"arabic":"حَرًّۭا ۚ","translation":"গরম\"","audioUrl":"wbw/009_081_025.mp3","charTypeName":"word"},{"id":64532,"position":25,"arabic":"لَّوْ","translation":"যদি","audioUrl":"wbw/009_081_027.mp3","charTypeName":"word"},{"id":64533,"position":26,"arabic":"كَانُوا۟","translation":"তারা থাকতো","audioUrl":"wbw/009_081_028.mp3","charTypeName":"word"},{"id":64534,"position":27,"arabic":"يَفْقَهُونَ","translation":"তারা বুঝে","audioUrl":"wbw/009_081_029.mp3","charTypeName":"word"},{"id":64535,"position":28,"arabic":"٨١","translation":"(৮১)","audioUrl":null,"charTypeName":"end"}]},{"number":82,"arabic":"فَلْيَضْحَكُوا۟ قَلِيلًۭا وَلْيَبْكُوا۟ كَثِيرًۭا جَزَآءًۢ بِمَا كَانُوا۟ يَكْسِبُونَ","translation":"Let them, then, laugh a little - for they will weep a lot in return for what they have earned.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1317.mp3","surahId":9,"words":[{"id":65061,"position":1,"arabic":"فَلْيَضْحَكُوا۟","translation":"অতএব হাসা উচিৎ তাদের","audioUrl":"wbw/009_082_001.mp3","charTypeName":"word"},{"id":65062,"position":2,"arabic":"قَلِيلًۭا","translation":"অল্প","audioUrl":"wbw/009_082_002.mp3","charTypeName":"word"},{"id":65063,"position":3,"arabic":"وَلْيَبْكُوا۟","translation":"ও কাঁদা উচিৎ তাদের","audioUrl":"wbw/009_082_003.mp3","charTypeName":"word"},{"id":65064,"position":4,"arabic":"كَثِيرًۭا","translation":"বেশি","audioUrl":"wbw/009_082_004.mp3","charTypeName":"word"},{"id":65065,"position":5,"arabic":"جَزَآءًۢ","translation":"প্রতিফল","audioUrl":"wbw/009_082_005.mp3","charTypeName":"word"},{"id":65066,"position":6,"arabic":"بِمَا","translation":"পরিবর্তে যাকিছু","audioUrl":"wbw/009_082_006.mp3","charTypeName":"word"},{"id":65067,"position":7,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/009_082_007.mp3","charTypeName":"word"},{"id":65068,"position":8,"arabic":"يَكْسِبُونَ","translation":"অর্জন করে আসছে","audioUrl":"wbw/009_082_008.mp3","charTypeName":"word"},{"id":65069,"position":9,"arabic":"٨٢","translation":"(৮২)","audioUrl":null,"charTypeName":"end"}]},{"number":83,"arabic":"فَإِن رَّجَعَكَ ٱللَّهُ إِلَىٰ طَآئِفَةٍۢ مِّنْهُمْ فَٱسْتَـْٔذَنُوكَ لِلْخُرُوجِ فَقُل لَّن تَخْرُجُوا۟ مَعِىَ أَبَدًۭا وَلَن تُقَٰتِلُوا۟ مَعِىَ عَدُوًّا ۖ إِنَّكُمْ رَضِيتُم بِٱلْقُعُودِ أَوَّلَ مَرَّةٍۢ فَٱقْعُدُوا۟ مَعَ ٱلْخَٰلِفِينَ","translation":"Hence, [O Prophet,] if God brings thee again face to face with some of them,\" and then they ask thy leave to go forth [to war with thee], say: \"Never shall you go forth with me. nor shall you fight an enemy together with me! Behold, you were well-pleased to stay at home on that first occasion: stay at home, then, with, those who [are obliged to] remain behind!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1318.mp3","surahId":9,"words":[{"id":65480,"position":1,"arabic":"فَإِن","translation":"অতঃপর যদি","audioUrl":"wbw/009_083_001.mp3","charTypeName":"word"},{"id":65481,"position":2,"arabic":"رَّجَعَكَ","translation":"তোমাকে ফিরিয়ে আনেন","audioUrl":"wbw/009_083_002.mp3","charTypeName":"word"},{"id":65482,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/009_083_003.mp3","charTypeName":"word"},{"id":65483,"position":4,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/009_083_004.mp3","charTypeName":"word"},{"id":65484,"position":5,"arabic":"طَآئِفَةٍۢ","translation":"কোনো দলের","audioUrl":"wbw/009_083_005.mp3","charTypeName":"word"},{"id":65485,"position":6,"arabic":"مِّنْهُمْ","translation":"মধ্য থেকে তাদের","audioUrl":"wbw/009_083_006.mp3","charTypeName":"word"},{"id":65486,"position":7,"arabic":"فَٱسْتَـْٔذَنُوكَ","translation":"তবে তোমার কাছে তারা অনুমতি চাইবে","audioUrl":"wbw/009_083_007.mp3","charTypeName":"word"},{"id":65487,"position":8,"arabic":"لِلْخُرُوجِ","translation":"জন্যে বের হওয়ার","audioUrl":"wbw/009_083_008.mp3","charTypeName":"word"},{"id":65488,"position":9,"arabic":"فَقُل","translation":"তখন বলো","audioUrl":"wbw/009_083_009.mp3","charTypeName":"word"},{"id":65489,"position":10,"arabic":"لَّن","translation":"\"না কিছুতেই","audioUrl":"wbw/009_083_010.mp3","charTypeName":"word"},{"id":65490,"position":11,"arabic":"تَخْرُجُوا۟","translation":"তোমরা বের হবে","audioUrl":"wbw/009_083_011.mp3","charTypeName":"word"},{"id":65491,"position":12,"arabic":"مَعِىَ","translation":"আমার সাথে","audioUrl":"wbw/009_083_012.mp3","charTypeName":"word"},{"id":65492,"position":13,"arabic":"أَبَدًۭا","translation":"কখনও","audioUrl":"wbw/009_083_013.mp3","charTypeName":"word"},{"id":65493,"position":14,"arabic":"وَلَن","translation":"এবং কখনও না","audioUrl":"wbw/009_083_014.mp3","charTypeName":"word"},{"id":65494,"position":15,"arabic":"تُقَـٰتِلُوا۟","translation":"তোমরা যুদ্ধ করবে","audioUrl":"wbw/009_083_015.mp3","charTypeName":"word"},{"id":65495,"position":16,"arabic":"مَعِىَ","translation":"আমার সাথে","audioUrl":"wbw/009_083_016.mp3","charTypeName":"word"},{"id":65496,"position":17,"arabic":"عَدُوًّا ۖ","translation":"কোনো শত্রুর (বিরুদ্ধে)","audioUrl":"wbw/009_083_017.mp3","charTypeName":"word"},{"id":65498,"position":18,"arabic":"إِنَّكُمْ","translation":"নিশ্চয়ই তোমরা","audioUrl":"wbw/009_083_019.mp3","charTypeName":"word"},{"id":65499,"position":19,"arabic":"رَضِيتُم","translation":"তোমরাই পছন্দ করেছিলে","audioUrl":"wbw/009_083_020.mp3","charTypeName":"word"},{"id":65500,"position":20,"arabic":"بِٱلْقُعُودِ","translation":"বিষয়কে বসে থাকার","audioUrl":"wbw/009_083_021.mp3","charTypeName":"word"},{"id":65501,"position":21,"arabic":"أَوَّلَ","translation":"প্রথম","audioUrl":"wbw/009_083_022.mp3","charTypeName":"word"},{"id":65502,"position":22,"arabic":"مَرَّةٍۢ","translation":"বার","audioUrl":"wbw/009_083_023.mp3","charTypeName":"word"},{"id":65503,"position":23,"arabic":"فَٱقْعُدُوا۟","translation":"অতএব তোমরা বসে থাকো","audioUrl":"wbw/009_083_024.mp3","charTypeName":"word"},{"id":65504,"position":24,"arabic":"مَعَ","translation":"সাথে","audioUrl":"wbw/009_083_025.mp3","charTypeName":"word"},{"id":65505,"position":25,"arabic":"ٱلْخَـٰلِفِينَ","translation":"বসে থাকা লোকদের\"","audioUrl":"wbw/009_083_026.mp3","charTypeName":"word"},{"id":65506,"position":26,"arabic":"٨٣","translation":"(৮৩)","audioUrl":null,"charTypeName":"end"}]},{"number":84,"arabic":"وَلَا تُصَلِّ عَلَىٰٓ أَحَدٍۢ مِّنْهُم مَّاتَ أَبَدًۭا وَلَا تَقُمْ عَلَىٰ قَبْرِهِۦٓ ۖ إِنَّهُمْ كَفَرُوا۟ بِٱللَّهِ وَرَسُولِهِۦ وَمَاتُوا۟ وَهُمْ فَٰسِقُونَ","translation":"And never shalt thou pray over any of them that has died, and never shalt thou stand by his grave: for, behold, they were bent on denying God and His Apostle, and they died in this their iniquity.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1319.mp3","surahId":9,"words":[{"id":65698,"position":1,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/009_084_001.mp3","charTypeName":"word"},{"id":65699,"position":2,"arabic":"تُصَلِّ","translation":"তুমি সালাত পড়বে","audioUrl":"wbw/009_084_002.mp3","charTypeName":"word"},{"id":65700,"position":3,"arabic":"عَلَىٰٓ","translation":"উপর","audioUrl":"wbw/009_084_003.mp3","charTypeName":"word"},{"id":65701,"position":4,"arabic":"أَحَدٍۢ","translation":"কারও","audioUrl":"wbw/009_084_004.mp3","charTypeName":"word"},{"id":65702,"position":5,"arabic":"مِّنْهُم","translation":"মধ্য থেকে তাদের","audioUrl":"wbw/009_084_005.mp3","charTypeName":"word"},{"id":65703,"position":6,"arabic":"مَّاتَ","translation":"মরে গেলে","audioUrl":"wbw/009_084_006.mp3","charTypeName":"word"},{"id":65704,"position":7,"arabic":"أَبَدًۭا","translation":"কখনও","audioUrl":"wbw/009_084_007.mp3","charTypeName":"word"},{"id":65705,"position":8,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/009_084_008.mp3","charTypeName":"word"},{"id":65706,"position":9,"arabic":"تَقُمْ","translation":"দাঁড়াবে তুমি","audioUrl":"wbw/009_084_009.mp3","charTypeName":"word"},{"id":65707,"position":10,"arabic":"عَلَىٰ","translation":"পাশে","audioUrl":"wbw/009_084_010.mp3","charTypeName":"word"},{"id":65708,"position":11,"arabic":"قَبْرِهِۦٓ ۖ","translation":"কবরের তার","audioUrl":"wbw/009_084_011.mp3","charTypeName":"word"},{"id":65710,"position":12,"arabic":"إِنَّهُمْ","translation":"নিশ্চয়ই তারা","audioUrl":"wbw/009_084_013.mp3","charTypeName":"word"},{"id":65711,"position":13,"arabic":"كَفَرُوا۟","translation":"অবিশ্বাস করেছে","audioUrl":"wbw/009_084_014.mp3","charTypeName":"word"},{"id":65712,"position":14,"arabic":"بِٱللَّهِ","translation":"প্রতি আল্লাহর","audioUrl":"wbw/009_084_015.mp3","charTypeName":"word"},{"id":65713,"position":15,"arabic":"وَرَسُولِهِۦ","translation":"ও তাঁর রাসূলের","audioUrl":"wbw/009_084_016.mp3","charTypeName":"word"},{"id":65714,"position":16,"arabic":"وَمَاتُوا۟","translation":"এবং তারা মরে গেছে","audioUrl":"wbw/009_084_017.mp3","charTypeName":"word"},{"id":65715,"position":17,"arabic":"وَهُمْ","translation":"এ অবস্থায় যে তারা (ছিলো)","audioUrl":"wbw/009_084_018.mp3","charTypeName":"word"},{"id":65716,"position":18,"arabic":"فَـٰسِقُونَ","translation":"সত্যত্যাগী","audioUrl":"wbw/009_084_019.mp3","charTypeName":"word"},{"id":65717,"position":19,"arabic":"٨٤","translation":"(৮৪)","audioUrl":null,"charTypeName":"end"}]},{"number":85,"arabic":"وَلَا تُعْجِبْكَ أَمْوَٰلُهُمْ وَأَوْلَٰدُهُمْ ۚ إِنَّمَا يُرِيدُ ٱللَّهُ أَن يُعَذِّبَهُم بِهَا فِى ٱلدُّنْيَا وَتَزْهَقَ أَنفُسُهُمْ وَهُمْ كَٰفِرُونَ","translation":"And let not their worldly goods and [the happiness which they may derive from] their children excite thy admiration: God but wants to chastise them by these means in [the life of] this world, and [to cause] their souls to depart while they are [still] denying the truth.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1320.mp3","surahId":9,"words":[{"id":66342,"position":1,"arabic":"وَلَا","translation":"এবং না (যেন)","audioUrl":"wbw/009_085_001.mp3","charTypeName":"word"},{"id":66343,"position":2,"arabic":"تُعْجِبْكَ","translation":"তোমাকে বিস্মিত করে","audioUrl":"wbw/009_085_002.mp3","charTypeName":"word"},{"id":66344,"position":3,"arabic":"أَمْوَٰلُهُمْ","translation":"ধনসম্পদ তাদের","audioUrl":"wbw/009_085_003.mp3","charTypeName":"word"},{"id":66345,"position":4,"arabic":"وَأَوْلَـٰدُهُمْ ۚ","translation":"ও সন্তান-সন্তুতি তাদের","audioUrl":"wbw/009_085_004.mp3","charTypeName":"word"},{"id":66347,"position":5,"arabic":"إِنَّمَا","translation":"প্রকৃতপক্ষে","audioUrl":"wbw/009_085_006.mp3","charTypeName":"word"},{"id":66348,"position":6,"arabic":"يُرِيدُ","translation":"চান","audioUrl":"wbw/009_085_007.mp3","charTypeName":"word"},{"id":66349,"position":7,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/009_085_008.mp3","charTypeName":"word"},{"id":66350,"position":8,"arabic":"أَن","translation":"যে","audioUrl":"wbw/009_085_009.mp3","charTypeName":"word"},{"id":66351,"position":9,"arabic":"يُعَذِّبَهُم","translation":"শাস্তি দিবেন তাদেরকে","audioUrl":"wbw/009_085_010.mp3","charTypeName":"word"},{"id":66352,"position":10,"arabic":"بِهَا","translation":"দিয়ে তা","audioUrl":"wbw/009_085_011.mp3","charTypeName":"word"},{"id":66353,"position":11,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/009_085_012.mp3","charTypeName":"word"},{"id":66354,"position":12,"arabic":"ٱلدُّنْيَا","translation":"পৃথিবীর","audioUrl":"wbw/009_085_013.mp3","charTypeName":"word"},{"id":66355,"position":13,"arabic":"وَتَزْهَقَ","translation":"ও চলে যাবে","audioUrl":"wbw/009_085_014.mp3","charTypeName":"word"},{"id":66356,"position":14,"arabic":"أَنفُسُهُمْ","translation":"আত্মা তাদের","audioUrl":"wbw/009_085_015.mp3","charTypeName":"word"},{"id":66357,"position":15,"arabic":"وَهُمْ","translation":"এ অবস্থায় যে তারা","audioUrl":"wbw/009_085_016.mp3","charTypeName":"word"},{"id":66358,"position":16,"arabic":"كَـٰفِرُونَ","translation":"কাফের (থাকবে)","audioUrl":"wbw/009_085_017.mp3","charTypeName":"word"},{"id":66359,"position":17,"arabic":"٨٥","translation":"(৮৫)","audioUrl":null,"charTypeName":"end"}]},{"number":86,"arabic":"وَإِذَآ أُنزِلَتْ سُورَةٌ أَنْ ءَامِنُوا۟ بِٱللَّهِ وَجَٰهِدُوا۟ مَعَ رَسُولِهِ ٱسْتَـْٔذَنَكَ أُو۟لُوا۟ ٱلطَّوْلِ مِنْهُمْ وَقَالُوا۟ ذَرْنَا نَكُن مَّعَ ٱلْقَٰعِدِينَ","translation":"[They are indeed denying it:] for, when they were called upon through revelation, \"Believe in God, and strive 