":"يَقْتُلْ","translation":"হত্যা করবে","audioUrl":"wbw/004_093_002.mp3","charTypeName":"word"},{"id":69302,"position":3,"arabic":"مُؤْمِنًۭا","translation":"মু'মিনকে","audioUrl":"wbw/004_093_003.mp3","charTypeName":"word"},{"id":69303,"position":4,"arabic":"مُّتَعَمِّدًۭا","translation":"ইচ্ছাকৃত","audioUrl":"wbw/004_093_004.mp3","charTypeName":"word"},{"id":69304,"position":5,"arabic":"فَجَزَآؤُهُۥ","translation":"তার শাস্তি (হলো)","audioUrl":"wbw/004_093_005.mp3","charTypeName":"word"},{"id":69305,"position":6,"arabic":"جَهَنَّمُ","translation":"জাহান্নাম","audioUrl":"wbw/004_093_006.mp3","charTypeName":"word"},{"id":69306,"position":7,"arabic":"خَـٰلِدًۭا","translation":"সে স্থায়ী হবে","audioUrl":"wbw/004_093_007.mp3","charTypeName":"word"},{"id":69307,"position":8,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/004_093_008.mp3","charTypeName":"word"},{"id":69308,"position":9,"arabic":"وَغَضِبَ","translation":"ও ক্রুদ্ধ হয়েছেন","audioUrl":"wbw/004_093_009.mp3","charTypeName":"word"},{"id":69309,"position":10,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/004_093_010.mp3","charTypeName":"word"},{"id":69310,"position":11,"arabic":"عَلَيْهِ","translation":"তার উপর","audioUrl":"wbw/004_093_011.mp3","charTypeName":"word"},{"id":69311,"position":12,"arabic":"وَلَعَنَهُۥ","translation":"তাকে লা'নত করেছেন","audioUrl":"wbw/004_093_012.mp3","charTypeName":"word"},{"id":69312,"position":13,"arabic":"وَأَعَدَّ","translation":"ও প্রস্তুত করে রেখেছেন","audioUrl":"wbw/004_093_013.mp3","charTypeName":"word"},{"id":69313,"position":14,"arabic":"لَهُۥ","translation":"তার জন্য","audioUrl":"wbw/004_093_014.mp3","charTypeName":"word"},{"id":69314,"position":15,"arabic":"عَذَابًا","translation":"শাস্তি","audioUrl":"wbw/004_093_015.mp3","charTypeName":"word"},{"id":69315,"position":16,"arabic":"عَظِيمًۭا","translation":"বিরাট","audioUrl":"wbw/004_093_016.mp3","charTypeName":"word"},{"id":69316,"position":17,"arabic":"٩٣","translation":"(৯৩)","audioUrl":null,"charTypeName":"end"}]},{"number":94,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوٓا۟ إِذَا ضَرَبْتُمْ فِى سَبِيلِ ٱللَّهِ فَتَبَيَّنُوا۟ وَلَا تَقُولُوا۟ لِمَنْ أَلْقَىٰٓ إِلَيْكُمُ ٱلسَّلَٰمَ لَسْتَ مُؤْمِنًۭا تَبْتَغُونَ عَرَضَ ٱلْحَيَوٰةِ ٱلدُّنْيَا فَعِندَ ٱللَّهِ مَغَانِمُ كَثِيرَةٌۭ ۚ كَذَٰلِكَ كُنتُم مِّن قَبْلُ فَمَنَّ ٱللَّهُ عَلَيْكُمْ فَتَبَيَّنُوٓا۟ ۚ إِنَّ ٱللَّهَ كَانَ بِمَا تَعْمَلُونَ خَبِيرًۭا","translation":"[Hence,] O you who have attained to faith, when you go forth [to war] in God's cause, use your discernment, and do not - out of a desire for the fleeting gains of this worldly life - say unto anyone who offers you the greeting of peace, \"Thou art not a believer\" for with God there are gains abundant. You, too, were once in the same condition - but God has been gracious unto you. Use, therefore, your discernment: verily, God is always aware of what you do.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/587.mp3","surahId":4,"words":[{"id":69317,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"ওহে","audioUrl":"wbw/004_094_001.mp3","charTypeName":"word"},{"id":69318,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/004_094_002.mp3","charTypeName":"word"},{"id":69319,"position":3,"arabic":"ءَامَنُوٓا۟","translation":"ঈমান এনেছ","audioUrl":"wbw/004_094_003.mp3","charTypeName":"word"},{"id":69320,"position":4,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/004_094_004.mp3","charTypeName":"word"},{"id":69321,"position":5,"arabic":"ضَرَبْتُمْ","translation":"তোমরা যাত্রা কর","audioUrl":"wbw/004_094_005.mp3","charTypeName":"word"},{"id":69322,"position":6,"arabic":"فِى","translation":"(মধ্যে)","audioUrl":"wbw/004_094_006.mp3","charTypeName":"word"},{"id":69323,"position":7,"arabic":"سَبِيلِ","translation":"পথে","audioUrl":"wbw/004_094_007.mp3","charTypeName":"word"},{"id":69324,"position":8,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/004_094_008.mp3","charTypeName":"word"},{"id":69325,"position":