{"id":567,"ayahs":[{"number":9,"arabic":"وَجَآءَ فِرْعَوْنُ وَمَن قَبْلَهُۥ وَٱلْمُؤْتَفِكَٰتُ بِٱلْخَاطِئَةِ","translation":"And there was Pharaoh, too, and [many of] those who lived before him, and the cities that were overthrown - [all of them] indulged in sin upon sin","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5332.mp3","surahId":69,"words":[{"id":10288,"position":1,"arabic":"وَجَآءَ","translation":"এবং এসেছিল","audioUrl":"wbw/069_009_001.mp3","charTypeName":"word"},{"id":10289,"position":2,"arabic":"فِرْعَوْنُ","translation":"ফিরাউন","audioUrl":"wbw/069_009_002.mp3","charTypeName":"word"},{"id":10290,"position":3,"arabic":"وَمَن","translation":"ও যারা","audioUrl":"wbw/069_009_003.mp3","charTypeName":"word"},{"id":10291,"position":4,"arabic":"قَبْلَهُۥ","translation":"তার পূর্বে","audioUrl":"wbw/069_009_004.mp3","charTypeName":"word"},{"id":10292,"position":5,"arabic":"وَٱلْمُؤْتَفِكَـٰتُ","translation":"এবং উলটে দেয়া বস্তীবাসীদের","audioUrl":"wbw/069_009_005.mp3","charTypeName":"word"},{"id":10293,"position":6,"arabic":"بِٱلْخَاطِئَةِ","translation":"অপরাধের কারণে","audioUrl":"wbw/069_009_006.mp3","charTypeName":"word"},{"id":10294,"position":7,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"فَعَصَوْا۟ رَسُولَ رَبِّهِمْ فَأَخَذَهُمْ أَخْذَةًۭ رَّابِيَةً","translation":"and rebelled against their Sustainer's apostles: and so He took them to task with a punishing grasp exceedingly severe!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5333.mp3","surahId":69,"words":[{"id":11519,"position":1,"arabic":"فَعَصَوْا۟","translation":"অতঃপর তারা অমান্য করেছিল","audioUrl":"wbw/069_010_001.mp3","charTypeName":"word"},{"id":11520,"position":2,"arabic":"رَسُولَ","translation":"রাসূলকে","audioUrl":"wbw/069_010_002.mp3","charTypeName":"word"},{"id":11521,"position":3,"arabic":"رَبِّهِمْ","translation":"তাদের রবের","audioUrl":"wbw/069_010_003.mp3","charTypeName":"word"},{"id":11522,"position":4,"arabic":"فَأَخَذَهُمْ","translation":"ফলে তাদের ধরলেন","audioUrl":"wbw/069_010_004.mp3","charTypeName":"word"},{"id":11523,"position":5,"arabic":"أَخْذَةًۭ","translation":"ধরা","audioUrl":"wbw/069_010_005.mp3","charTypeName":"word"},{"id":11524,"position":6,"arabic":"رَّابِيَةً","translation":"শক্ত","audioUrl":"wbw/069_010_006.mp3","charTypeName":"word"},{"id":11525,"position":7,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"إِنَّا لَمَّا طَغَا ٱلْمَآءُ حَمَلْنَٰكُمْ فِى ٱلْجَارِيَةِ","translation":"[And] behold: when the waters [of Noah's flood] burst beyond all limits, it was We who caused you to be borne [to safety] in that floating ark,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5334.mp3","surahId":69,"words":[{"id":12835,"position":1,"arabic":"إِنَّا","translation":"আমরা নিশ্চয়ই","audioUrl":"wbw/069_011_001.mp3","charTypeName":"word"},{"id":12836,"position":2,"arabic":"لَمَّا","translation":"যখন","audioUrl":"wbw/069_011_002.mp3","charTypeName":"word"},{"id":12837,"position":3,"arabic":"طَغَا","translation":"জলোচ্ছ্বাস হয়েছিল","audioUrl":"wbw/069_011_003.mp3","charTypeName":"word"},{"id":12838,"position":4,"arabic":"ٱلْمَآءُ","translation":"(পানি)","audioUrl":"wbw/069_011_004.mp3","charTypeName":"word"},{"id":12839,"position":5,"arabic":"حَمَلْنَـٰكُمْ","translation":"তোমাদের আমরা আরোহী করেছিলাম","audioUrl":"wbw/069_011_005.mp3","charTypeName":"word"},{"id":12840,"position":6,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/069_011_006.mp3","charTypeName":"word"},{"id":12841,"position":7,"arabic":"ٱلْجَارِيَةِ","translation":"নৌযানের","audioUrl":"wbw/069_011_007.mp3","charTypeName":"word"},{"id":12842,"position":8,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]},{"number":12,"arabic":"لِنَجْعَلَهَا لَكُمْ تَذْكِرَةًۭ وَتَعِيَهَآ أُذُنٌۭ وَٰعِيَةٌۭ","translation":"so that We might make all this a [lasting] reminder to you all, and that every wide-awake ear might consciously take it in.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5335.mp3","surahId":69,"words":[{"id":14094,"position":1,"arabic":"لِنَجْعَلَهَا","translation":"তা বানাই আমরা যেন","audioUrl":"wbw/069_012_001.mp3","charTypeName":"word"},{"id":14095,"position":2,"arabic":"لَكُمْ","translation":"তোমাদের জন্যে","audioUrl":"wbw/069_012_002.mp3","charTypeName":"word"},{"id":14096,"position":3,"arabic":"تَذْكِرَةًۭ","translation":"শিক্ষা","audioUrl":"wbw/069_012_003.mp3","charTypeName":"word"},{"id":14097,"position":4,"arabic":"وَتَعِيَهَآ","translation":"এবং তার ষ্মৃতি বহন করে","audioUrl":"wbw/069_012_004.mp3","charTypeName":"word"},{"id":14098,"position":5,"arabic":"أُذُنٌۭ","translation":"কান","audioUrl":"wbw/069_012_005.mp3","charTypeName":"word"},{"id":14099,"position":6,"arabic":"وَٰعِيَةٌۭ","translation":"স্মরন বাহক","audioUrl":"wbw/069_012_006.mp3","charTypeName":"word"},{"id":14100,"position":7,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]},{"number":13,"arabic":"فَإِذَا نُفِخَ فِى ٱلصُّورِ نَفْخَةٌۭ وَٰحِدَةٌۭ","translation":"Hence, [bethink yourselves of the Last Hour,] when the trumpet [of judgment] shall be sounded with a single blast,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5336.mp3","surahId":69,"words":[{"id":15213,"position":1,"arabic":"فَإِذَا","translation":"যখন অতঃপর","audioUrl":"wbw/069_013_001.mp3","charTypeName":"word"},{"id":15214,"position":2,"arabic":"نُفِخَ","translation":"ফুক দেয়া হবে","audioUrl":"wbw/069_013_002.mp3","charTypeName":"word"},{"id":15215,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/069_013_003.mp3","charTypeName":"word"},{"id":15216,"position":4,"arabic":"ٱلصُّورِ","translation":"শিঙ্গায়","audioUrl":"wbw/069_013_004.mp3","charTypeName":"word"},{"id":15217,"position":5,"arabic":"نَفْخَةٌۭ","translation":"ফুক","audioUrl":"wbw/069_013_005.mp3","charTypeName":"word"},{"id":15218,"position":6,"arabic":"وَٰحِدَةٌۭ","translation":"একবার","audioUrl":"wbw/069_013_006.mp3","charTypeName":"word"},{"id":15219,"position":7,"arabic":"١٣","translation":"(১৩)","audioUrl":null,"charTypeName":"end"}]},{"number":14,"arabic":"وَحُمِلَتِ ٱلْأَرْضُ وَٱلْجِبَالُ فَدُكَّتَا دَكَّةًۭ وَٰحِدَةًۭ","translation":"and the earth and the mountains shall be lifted up and crushed with a single stroke!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5337.mp3","surahId":69,"words":[{"id":16249,"position":1,"arabic":"وَحُمِلَتِ","translation":"এবং উঠানো হবে","audioUrl":"wbw/069_014_001.mp3","charTypeName":"word"},{"id":16250,"position":2,"arabic":"ٱلْأَرْضُ","translation":"যমীন","audioUrl":"wbw/069_014_002.mp3","charTypeName":"word"},{"id":16251,"position":3,"arabic":"وَٱلْجِبَالُ","translation":"এবং পাহাড়গুলো","audioUrl":"wbw/069_014_003.mp3","charTypeName":"word"},{"id":16252,"position":4,"arabic":"فَدُكَّتَا","translation":"বিচূর্ণ করা হবে অতঃপর","audioUrl":"wbw/069_014_004.mp3","charTypeName":"word"},{"id":16253,"position":5,"arabic":"دَكَّةًۭ","translation":"চূর্ণ বিচূর্ণ","audioUrl":"wbw/069_014_005.mp3","charTypeName":"word"},{"id":16254,"position":6,"arabic":"وَٰحِدَةًۭ","translation":"একবার","audioUrl":"wbw/069_014_006.mp3","charTypeName":"word"},{"id":16255,"position":7,"arabic":"١٤","translation":"(১৪)","audioUrl":null,"charTypeName":"end"}]},{"number":15,"arabic":"فَيَوْمَئِذٍۢ وَقَعَتِ ٱلْوَاقِعَةُ","translation":"And so, that which must come to pass will on that day have come to pass;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5338.mp3","surahId":69,"words":[{"id":17436,"position":1,"arabic":"فَيَوْمَئِذٍۢ","translation":"সেদিন অতঃপর","audioUrl":"wbw/069_015_001.mp3","charTypeName":"word"},{"id":17437,"position":2,"arabic":"وَقَعَتِ","translation":"সংঘটিত হবে","audioUrl":"wbw/069_015_002.mp3","charTypeName":"word"},{"id":17438,"position":3,"arabic":"ٱلْوَاقِعَةُ","translation":"মহাপ্রলয়","audioUrl":"wbw/069_015_003.mp3","charTypeName":"word"},{"id":17439,"position":4,"arabic":"١٥","translation":"(১৫)","audioUrl":null,"charTypeName":"end"}]},{"number":16,"arabic":"وَٱنشَقَّتِ ٱلسَّمَآءُ فَهِىَ يَوْمَئِذٍۢ وَاهِيَةٌۭ","translation":"and the sky will be rent asunder - for, frail will it have become on that Day -;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5339.mp3","surahId":69,"words":[{"id":18425,"position":1,"arabic":"وَٱنشَقَّتِ","translation":"এবং বিদীর্ণ হবে","audioUrl":"wbw/069_016_001.mp3","charTypeName":"word"},{"id":18426,"position":2,"arabic":"ٱلسَّمَآءُ","translation":"আসমান","audioUrl":"wbw/069_016_002.mp3","charTypeName":"word"},{"id":18427,"position":3,"arabic":"فَهِىَ","translation":"তা অতঃপর","audioUrl":"wbw/069_016_003.mp3","charTypeName":"word"},{"id":18428,"position":4,"arabic":"يَوْمَئِذٍۢ","translation":"সেদিন","audioUrl":"wbw/069_016_004.mp3","charTypeName":"word"},{"id":18429,"position":5,"arabic":"وَاهِيَةٌۭ","translation":"বিশ্লিষ্ট হবে","audioUrl":"wbw/069_016_005.mp3","charTypeName":"word"},{"id":18430,"position":6,"arabic":"١٦","translation":"(১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":17,"arabic":"وَٱلْمَلَكُ عَلَىٰٓ أَرْجَآئِهَا ۚ وَيَحْمِلُ عَرْشَ رَبِّكَ فَوْقَهُمْ يَوْمَئِذٍۢ ثَمَٰنِيَةٌۭ","translation":"and the angels [will appear] at its ends, and, above them, eight will bear aloft on that Day the throne of thy Sustainer’s almightiness…","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5340.mp3","surahId":69,"words":[{"id":19493,"position":1,"arabic":"وَٱلْمَلَكُ","translation":"এবং ফেরেশতাগণ","audioUrl":"wbw/069_017_001.mp3","charTypeName":"word"},{"id":19494,"position":2,"arabic":"عَلَىٰٓ","translation":"উপর","audioUrl":"wbw/069_017_002.mp3","charTypeName":"word"},{"id":19495,"position":3,"arabic":"أَرْجَآئِهَا ۚ","translation":"(আসমানের) বিভিন্ন প্রান্তে থাকবে","audioUrl":"wbw/069_017_003.mp3","charTypeName":"word"},{"id":19497,"position":4,"arabic":"وَيَحْمِلُ","translation":"এবং বহন করবে","audioUrl":"wbw/069_017_005.mp3","charTypeName":"word"},{"id":19498,"position":5,"arabic":"عَرْشَ","translation":"আরশ","audioUrl":"wbw/069_017_006.mp3","charTypeName":"word"},{"id":19499,"position":6,"arabic":"رَبِّكَ","translation":"তোমার রবের","audioUrl":"wbw/069_017_007.mp3","charTypeName":"word"},{"id":19500,"position":7,"arabic":"فَوْقَهُمْ","translation":"তাদের উপরে,","audioUrl":"wbw/069_017_008.mp3","charTypeName":"word"},{"id":19501,"position":8,"arabic":"يَوْمَئِذٍۢ","translation":"সেদিন","audioUrl":"wbw/069_017_009.mp3","charTypeName":"word"},{"id":19502,"position":9,"arabic":"ثَمَـٰنِيَةٌۭ","translation":"আট (ফেরেশতা)","audioUrl":"wbw/069_017_010.mp3","charTypeName":"word"},{"id":19503,"position":10,"arabic":"١٧","translation":"(১৭)","audioUrl":null,"charTypeName":"end"}]},{"number":18,"arabic":"يَوْمَئِذٍۢ تُعْرَضُونَ لَا تَخْفَىٰ مِنكُمْ خَافِيَةٌۭ","translation":"On that Day you shall be brought to judgment: not [even] the most hidden of your deeds will remain hidden.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5341.mp3","surahId":69,"words":[{"id":20593,"position":1,"arabic":"يَوْمَئِذٍۢ","translation":"সেদিন","audioUrl":"wbw/069_018_001.mp3","charTypeName":"word"},{"id":20594,"position":2,"arabic":"تُعْرَضُونَ","translation":"পেশ করা হবে তোমাদের","audioUrl":"wbw/069_018_002.mp3","charTypeName":"word"},{"id":20595,"position":3,"arabic":"لَا","translation":"না","audioUrl":"wbw/069_018_003.mp3","charTypeName":"word"},{"id":20596,"position":4,"arabic":"تَخْفَىٰ","translation":"আড়াল করা হবে","audioUrl":"wbw/069_018_004.mp3","charTypeName":"word"},{"id":20597,"position":5,"arabic":"مِنكُمْ","translation":"তোমাদের মধ্যে","audioUrl":"wbw/069_018_005.mp3","charTypeName":"word"},{"id":20598,"position":6,"arabic":"خَافِيَةٌۭ","translation":"কোন গোপন কিছুই","audioUrl":"wbw/069_018_006.mp3","charTypeName":"word"},{"id":20599,"position":7,"arabic":"١٨","translation":"(১৮)","audioUrl":null,"charTypeName":"end"}]},{"number":19,"arabic":"فَأَمَّا مَنْ أُوتِىَ كِتَٰبَهُۥ بِيَمِينِهِۦ فَيَقُولُ 