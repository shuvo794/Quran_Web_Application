114_003.mp3","charTypeName":"word"},{"id":75139,"position":4,"arabic":"مَّنَعَ","translation":"বাধা দেয়","audioUrl":"wbw/002_114_004.mp3","charTypeName":"word"},{"id":75140,"position":5,"arabic":"مَسَـٰجِدَ","translation":"মাসজিদে","audioUrl":"wbw/002_114_005.mp3","charTypeName":"word"},{"id":75141,"position":6,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌র","audioUrl":"wbw/002_114_006.mp3","charTypeName":"word"},{"id":75142,"position":7,"arabic":"أَن","translation":"যে","audioUrl":"wbw/002_114_007.mp3","charTypeName":"word"},{"id":75143,"position":8,"arabic":"يُذْكَرَ","translation":"স্মরণ করা","audioUrl":"wbw/002_114_008.mp3","charTypeName":"word"},{"id":75144,"position":9,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/002_114_009.mp3","charTypeName":"word"},{"id":75145,"position":10,"arabic":"ٱسْمُهُۥ","translation":"তার নাম","audioUrl":"wbw/002_114_010.mp3","charTypeName":"word"},{"id":75146,"position":11,"arabic":"وَسَعَىٰ","translation":"এবং সে চেষ্টা করে","audioUrl":"wbw/002_114_011.mp3","charTypeName":"word"},{"id":75147,"position":12,"arabic":"فِى","translation":"ব্যাপারে","audioUrl":"wbw/002_114_012.mp3","charTypeName":"word"},{"id":75148,"position":13,"arabic":"خَرَابِهَآ ۚ","translation":"তার ধ্বংসের","audioUrl":"wbw/002_114_013.mp3","charTypeName":"word"},{"id":75150,"position":14,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐসব লোক","audioUrl":"wbw/002_114_015.mp3","charTypeName":"word"},{"id":75151,"position":15,"arabic":"مَا","translation":"নয়","audioUrl":"wbw/002_114_016.mp3","charTypeName":"word"},{"id":75152,"position":16,"arabic":"كَانَ","translation":"(সঙ্গত) ছিল","audioUrl":"wbw/002_114_017.mp3","charTypeName":"word"},{"id":75153,"position":17,"arabic":"لَهُمْ","translation":"তাদের জন্য","audioUrl":"wbw/002_114_018.mp3","charTypeName":"word"},{"id":75154,"position":18,"arabic":"أَن","translation":"যে","audioUrl":"wbw/002_114_019.mp3","charTypeName":"word"},{"id":75155,"position":19,"arabic":"يَدْخُلُوهَآ","translation":"তাতে প্রবেশ করবে"