{"id":187,"ayahs":[{"number":1,"arabic":"بَرَآءَةٌۭ مِّنَ ٱللَّهِ وَرَسُولِهِۦٓ إِلَى ٱلَّذِينَ عَٰهَدتُّم مِّنَ ٱلْمُشْرِكِينَ","translation":"DISAVOWAL by God and His Apostle [is herewith announced] unto those who ascribe divinity to aught beside God, [and] with whom you [O: believers] have made a covenant.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1236.mp3","surahId":9,"words":[{"id":60,"position":1,"arabic":"بَرَآءَةٌۭ","translation":"সম্পর্কচ্ছেদ (ঘোষণা)","audioUrl":"wbw/009_001_001.mp3","charTypeName":"word"},{"id":61,"position":2,"arabic":"مِّنَ","translation":"পক্ষ হতে","audioUrl":"wbw/009_001_002.mp3","charTypeName":"word"},{"id":62,"position":3,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/009_001_003.mp3","charTypeName":"word"},{"id":63,"position":4,"arabic":"وَرَسُولِهِۦٓ","translation":"ও রাসূলের তাঁর","audioUrl":"wbw/009_001_004.mp3","charTypeName":"word"},{"id":64,"position":5,"arabic":"إِلَى","translation":"প্রতি","audioUrl":"wbw/009_001_005.mp3","charTypeName":"word"},{"id":65,"position":6,"arabic":"ٱلَّذِينَ","translation":"তাদের (যাদের সাথে)","audioUrl":"wbw/009_001_006.mp3","charTypeName":"word"},{"id":66,"position":7,"arabic":"عَـٰهَدتُّم","translation":"চুক্তি করেছিলে তোমরা","audioUrl":"wbw/009_001_007.mp3","charTypeName":"word"},{"id":67,"position":8,"arabic":"مِّنَ","translation":"মধ্য হতে","audioUrl":"wbw/009_001_008.mp3","charTypeName":"word"},{"id":68,"position":9,"arabic":"ٱلْمُشْرِكِينَ","translation":"মুশরিকদের","audioUrl":"wbw/009_001_009.mp3","charTypeName":"word"},{"id":69,"position":10,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"فَسِيحُوا۟ فِى ٱلْأَرْضِ أَرْبَعَةَ أَشْهُرٍۢ وَٱعْلَمُوٓا۟ أَنَّكُمْ غَيْرُ مُعْجِزِى ٱللَّهِ ۙ وَأَنَّ ٱللَّهَ مُخْزِى ٱلْكَٰفِرِينَ","translation":"[Announce unto them:] \"Go, then, [freely] about the earth for four months -but know that you can never elude God, and that, verily, God shall bring disgrace upon all who refuse to acknowledge the truth!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1237.mp3","surahId":9,"words":[{"id":1205,"position":1,"arabic":"فَسِيحُوا۟","translation":"অতএব তোমরা চলাচল করো","audioUrl":"wbw/009_002_001.mp3","charTypeName":"word"},{"id":1206,"position":2,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/009_002_002.mp3","charTypeName":"word"},{"id":1207,"position":3,"arabic":"ٱلْأَرْضِ","translation":"দেশের","audioUrl":"wbw/009_002_003.mp3","charTypeName":"word"},{"id":1208,"position":4,"arabic":"أَرْبَعَةَ","translation":"চার","audioUrl":"wbw/009_002_004.mp3","charTypeName":"word"},{"id":1209,"position":5,"arabic":"أَشْهُرٍۢ","translation":"মাস (পর্যন্ত)","audioUrl":"wbw/009_002_005.mp3","charTypeName":"word"},{"id":1210,"position":6,"arabic":"وَٱعْلَمُوٓا۟","translation":"ও তোমরা জেনে রাখো","audioUrl":"wbw/009_002_006.mp3","charTypeName":"word"},{"id":1211,"position":7,"arabic":"أَنَّكُمْ","translation":"যে তোমরা","audioUrl":"wbw/009_002_007.mp3","charTypeName":"word"},{"id":1212,"position":8,"arabic":"غَيْرُ","translation":"নও","audioUrl":"wbw/009_002_008.mp3","charTypeName":"word"},{"id":1213,"position":9,"arabic":"مُعْجِزِى","translation":"অক্ষমকারী","audioUrl":"wbw/009_002_009.mp3","charTypeName":"word"},{"id":1214,"position":10,"arabic":"ٱللَّهِ ۙ","translation":"আল্লাহকে","audioUrl":"wbw/009_002_010.mp3","charTypeName":"word"},{"id":1216,"position":11,"arabic":"وَأَنَّ","translation":"ও নিশ্চয়ই","audioUrl":"wbw/009_002_012.mp3","charTypeName":"word"},{"id":1217,"position":12,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/009_002_013.mp3","charTypeName":"word"},{"id":1218,"position":13,"arabic":"مُخْزِى","translation":"লাঞ্ছনাকারী","audioUrl":"wbw/009_002_014.mp3","charTypeName":"word"},{"id":1219,"position":14,"arabic":"ٱلْكَـٰفِرِينَ","translation":"কাফেরদেরকে","audioUrl":"wbw/009_002_015.mp3","charTypeName":"word"},{"id":1220,"position":15,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"وَأَذَٰنٌۭ مِّنَ ٱللَّهِ وَرَسُولِهِۦٓ إِلَى ٱلنَّاسِ يَوْمَ ٱلْحَجِّ ٱلْأَكْبَرِ أَنَّ ٱللَّهَ بَرِىٓءٌۭ مِّنَ ٱلْمُشْرِكِينَ ۙ وَرَسُولُهُۥ ۚ فَإِن تُبْتُمْ فَهُوَ خَيْرٌۭ لَّكُمْ ۖ وَإِن تَوَلَّيْتُمْ فَٱعْلَمُوٓا۟ أَنَّكُمْ غَيْرُ مُعْجِزِى ٱللَّهِ ۗ وَبَشِّرِ ٱلَّذِينَ كَفَرُوا۟ بِعَذَابٍ أَلِيمٍ","translation":"And a proclamation from God and His Apostle [is herewith made] unto all mankind on this day of the Greatest Pilgrimage: \"God disavows all who ascribe divinity to aught beside Him, and [so does] His Apostle. Hence, if you repent, it shall be for your own good; and if you turn away, then know that you can never elude God!\" And unto those who are bent on denying the truth give thou [O Prophet] the tiding of grievous chastisement.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1238.mp3","surahId":9,"words":[{"id":2278,"position":1,"arabic":"وَأَذَٰنٌۭ","translation":"এবং সাধারণ ঘোষণা","audioUrl":"wbw/009_003_001.mp3","charTypeName":"word"},{"id":2279,"position":2,"arabic":"مِّنَ","translation":"পক্ষ হতে","audioUrl":"wbw/009_003_002.mp3","charTypeName":"word"},{"id":2280,"position":3,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/009_003_003.mp3","charTypeName":"word"},{"id":2281,"position":4,"arabic":"وَرَسُولِهِۦٓ","translation":"এবং রাসূলের তাঁর","audioUrl":"wbw/009_003_004.mp3","charTypeName":"word"},{"id":2282,"position":5,"arabic":"إِلَى","translation":"প্রতি","audioUrl":"wbw/009_003_005.mp3","charTypeName":"word"},{"id":2283,"position":6,"arabic":"ٱلنَّاسِ","translation":"জনসাধারণের","audioUrl":"wbw/009_003_006.mp3","charTypeName":"word"},{"id":2284,"position":7,"arabic":"يَوْمَ","translation":"দিনে","audioUrl":"wbw/009_003_007.mp3","charTypeName":"word"},{"id":2285,"position":8,"arabic":"ٱلْحَجِّ","translation":"হজ্জের","audioUrl":"wbw/009_003_008.mp3","charTypeName":"word"},{"id":2286,"position":9,"arabic":"ٱلْأَكْبَرِ","translation":"মহান","audioUrl":"wbw/009_003_009.mp3","charTypeName":"word"},{"id":2287,"position":10,"arabic":"أَنَّ","translation":"যে","audioUrl":"wbw/009_003_010.mp3","charTypeName":"word"},{"id":2288,"position":11,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/009_003_011.mp3","charTypeName":"word"},{"id":2289,"position":12,"arabic":"بَرِىٓءٌۭ","translation":"দায়মুক্ত","audioUrl":"wbw/009_003_012.mp3","charTypeName":"word"},{"id":2290,"position":13,"arabic":"مِّنَ","translation":"থেকে","audioUrl":"wbw/009_003_013.mp3","charTypeName":"word"},{"id":2291,"position":14,"arabic":"ٱلْمُشْرِكِينَ ۙ","translation":"মুশরিকদের","audioUrl":"wbw/009_003_014.mp3","charTypeName":"word"},{"id":2293,"position":15,"arabic":"وَرَسُولُهُۥ ۚ","translation":"এবং রাসূলও তাঁর (দ্বায়িত্বমুক্ত)","audioUrl":"wbw/009_003_016.mp3","charTypeName":"word"},{"id":2295,"position":16,"arabic":"فَإِن","translation":"অতএব যদি","audioUrl":"wbw/009_003_018.mp3","charTypeName":"word"},{"id":2296,"position":17,"arabic":"تُبْتُمْ","translation":"তোমরা তাওবা করো","audioUrl":"wbw/009_003_019.mp3","charTypeName":"word"},{"id":2297,"position":18,"arabic":"فَهُوَ","translation":"তবে তা","audioUrl":"wbw/009_003_020.mp3","charTypeName":"word"},{"id":2298,"position":19,"arabic":"خَيْرٌۭ","translation":"উত্তম","audioUrl":"wbw/009_003_021.mp3","charTypeName":"word"},{"id":2299,"position":20,"arabic":"لَّكُمْ ۖ","translation":"জন্যে তোমাদের","audioUrl":"wbw/009_003_022.mp3","charTypeName":"word"},{"id":2301,"position":21,"arabic":"وَإِن","translation":"আর যদি","audioUrl":"wbw/009_003_024.mp3","charTypeName":"word"},{"id":2302,"position":22,"arabic":"تَوَلَّيْتُمْ","translation":"ফিরে যাও তোমরা","audioUrl":"wbw/009_003_025.mp3","charTypeName":"word"},{"id":2303,"position":23,"arabic":"فَٱعْلَمُوٓا۟","translation":"তবে তোমরা জেনে রাখো","audioUrl":"wbw/009_003_026.mp3","charTypeName":"word"},{"id":2304,"position":24,"arabic":"أَنَّكُمْ","translation":"যে তোমরা","audioUrl":"wbw/009_003_027.mp3","charTypeName":"word"},{"id":2305,"position":25,"arabic":"غَيْرُ","translation":"নও","audioUrl":"wbw/009_003_028.mp3","charTypeName":"word"},{"id":2306,"position":26,"arabic":"مُعْجِزِى","translation":"অক্ষমকারী","audioUrl":"wbw/009_003_029.mp3","charTypeName":"word"},{"id":2307,"position":27,"arabic":"ٱللَّهِ ۗ","translation":"আল্লাহকে","audioUrl":"wbw/009_003_030.mp3","charTypeName":"word"},{"id":2309,"position":28,"arabic":"وَبَشِّرِ","translation":"এবং সুসংবাদ দাও","audioUrl":"wbw/009_003_032.mp3","charTypeName":"word"},{"id":2310,"position":29,"arabic":"ٱلَّذِينَ","translation":"(তাদেরকে) যারা","audioUrl":"wbw/009_003_033.mp3","charTypeName":"word"},{"id":2311,"position":30,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/009_003_034.mp3","charTypeName":"word"},{"id":2312,"position":31,"arabic":"بِعَذَابٍ","translation":"সম্পর্কে শাস্তির","audioUrl":"wbw/009_003_035.mp3","charTypeName":"word"},{"id":2313,"position":32,"arabic":"أَلِيمٍ","translation":"নিদারুণ","audioUrl":"wbw/009_003_036.mp3","charTypeName":"word"},{"id":2314,"position":33,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"إِلَّا ٱلَّذِينَ عَٰهَدتُّم مِّنَ ٱلْمُشْرِكِينَ ثُمَّ لَمْ يَنقُصُوكُمْ شَيْـًۭٔا وَلَمْ يُظَٰهِرُوا۟ عَلَيْكُمْ أَحَدًۭا فَأَتِمُّوٓا۟ إِلَيْهِمْ عَهْدَهُمْ إِلَىٰ مُدَّتِهِمْ ۚ إِنَّ ٱللَّهَ يُحِبُّ ٱلْمُتَّقِينَ","translation":"But excepted shall be -from among those who ascribe divinity to aught beside God - [people] with whom you [O believers] have made a covenant and who thereafter have in no wise failed to fulfil their obligations towards you, and neither have aided anyone against you: observe, then, your covenant with them until the end of the term agreed with them. Verily, God loves those who are conscious of Him.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1239.mp3","surahId":9,"words":[{"id":3614,"position":1,"arabic":"إِلَّا","translation":"তবে","audioUrl":"wbw/009_004_001.mp3","charTypeName":"word"},{"id":3615,"position":2,"arabic":"ٱلَّذِينَ","translation":"যাদের (সাথে)","audioUrl":"wbw/009_004_002.mp3","charTypeName":"word"},{"id":3616,"position":3,"arabic":"عَـٰهَدتُّم","translation":"চুক্তি করেছো তোমরা","audioUrl":"wbw/009_004_003.mp3","charTypeName":"word"},{"id":3617,"position":4,"arabic":"مِّنَ","translation":"মধ্য হতে","audioUrl":"wbw/009_004_004.mp3","charTypeName":"word"},{"id":3618,"position":5,"arabic":"ٱلْمُشْرِكِينَ","translation":"মুশরিকদের","audioUrl":"wbw/009_004_005.mp3","charTypeName":"word"},{"id":3619,"position":6,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/009_004_006.mp3","charTypeName":"word"},{"id":3620,"position":7,"arabic":"لَمْ","translation":"নি","audioUrl":"wbw/009_004_007.mp3","charTypeName":"word"},{"id":3621,"position":8,"arabic":"يَنقُصُوكُمْ","translation":"তোমাদের সাথে ত্রুটি করে(চুক্তি রক্ষায়)","audioUrl":"wbw/009_004_008.mp3","charTypeName":"word"},{"id":3622,"position":9,"arabic":"شَيْـًۭٔا","translation":"কিছুমাত্র","audioUrl":"wbw/009_004_009.mp3","charTypeName":"word"},{"id":3623,"position":10,"arabic":"وَلَمْ","translation":"এবং নি","audioUrl":"wbw/009_004_010.mp3","charTypeName":"word"},{"id":3624,"position":11,"arabic":"يُظَـٰهِرُوا۟","translation":"তারা সাহায্য করে","audioUrl":"wbw/009_004_011.mp3","charTypeName":"word"},{"id":3625,"position":12,"arabic":"عَلَيْكُمْ","translation":"বিরুদ্ধে তোমাদের","audioUrl":"wbw/009_004_012.mp3","charTypeName":"word"},{"id":3626,"position":13,"arabic":"أَحَدًۭا","translation":"কাউকে","audioUrl":"wbw/009_004_013.mp3","charTypeName":"word"},{"id":3627,"position":14,"arabic":"فَأَتِمُّوٓا۟","translation":"তাহ'লে তোমরা পূর্ণ করো","audioUrl":"wbw/009_004_014.mp3","charTypeName":"word"},{"id":3628,"position":15,"arabic":"إِلَيْهِمْ","translation":"সাথে তাদের","audioUrl":"wbw/009_004_015.mp3","charTypeName":"word"},{"id":3629,"position":16,"arabic":"عَهْدَهُمْ","translation":"চুক্তি তাদের","audioUrl":"wbw/009_004_016.mp3","charTypeName":"word"},{"id":3630,"position":17,"arabic":"إِلَىٰ","translation":"পর্যন্ত","audioUrl":"wbw/009_004_017.mp3","charTypeName":"word"},{"id":3631,"position":18,"arabic":"مُدَّتِهِمْ ۚ","translation":"মেয়াদ তাদের","audioUrl":"wbw/009_004_018.mp3","charTypeName":"word"},{"id":3633,"position":19,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/009_004_020.mp3","charTypeName":"word"},{"id":3634,"position":20,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/009_004_021.mp3","charTypeName":"word"},{"id":3635,"position":21,"arabic":"يُحِبُّ","translation":"ভালোবাসেন","audioUrl":"wbw/009_004_022.mp3","charTypeName":"word"},{"id":3636,"position":22,"arabic":"ٱلْمُتَّقِينَ","translation":"মুত্তাকীদেরকে","audioUrl":"wbw/009_004_023.mp3","charTypeName":"word"},{"id":3637,"position":23,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"فَإِذَا ٱنسَلَخَ ٱلْأَشْهُرُ ٱلْحُرُمُ فَٱقْتُلُوا۟ ٱلْمُشْرِكِينَ حَيْثُ وَجَدتُّمُوهُمْ وَخُذُوهُمْ وَٱحْصُرُوهُمْ وَٱقْعُدُوا۟ لَهُمْ كُلَّ مَرْصَدٍۢ ۚ فَإِن تَابُوا۟ وَأَقَامُوا۟ ٱلصَّلَوٰةَ وَءَاتَوُا۟ ٱلزَّكَوٰةَ فَخَلُّوا۟ سَبِيلَهُمْ ۚ إِنَّ ٱللَّهَ غَفُورٌۭ رَّحِيمٌۭ","translation":"And so, when the sacred months are over, slay those who ascribe divinity to aught beside God wherever you may come upon them, and take them captive, and besiege them, and lie in wait for them at every conceivable place! Yet if they repent, and take to prayer, and render the purifying dues, let them go their way: for, behold, God is much forgiving, a dispenser of grace.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1240.mp3","surahId":9,"words":[{"id":4945,"position":1,"arabic":"فَإِذَا","translation":"অতঃপর যখন","audioUrl":"wbw/009_005_001.mp3","charTypeName":"word"},{"id":4946,"position":2,"arabic":"ٱنسَلَخَ","translation":"অতিবাহিত হয়","audioUrl":"wbw/009_005_002.mp3","charTypeName":"word"},{"id":4947,"position":3,"arabic":"ٱلْأَشْهُرُ","translation":"মাসসমূহ","audioUrl":"wbw/009_005_003.mp3","charTypeName":"word"},{"id":4948,"position":4,"arabic":"ٱلْحُرُمُ","translation":"নিষিদ্ধ","audioUrl":"wbw/009_005_004.mp3","charTypeName":"word"},{"id":4949,"position":5,"arabic":"فَٱقْتُلُوا۟","translation":"তখন তোমরা হত্যা করো","audioUrl":"wbw/009_005_005.mp3","charTypeName":"word"},{"id":4950,"position":6,"arabic":"ٱلْمُشْرِكِينَ","translation":"মুশরিকদেরকে","audioUrl":"wbw/009_005_006.mp3","charTypeName":"word"},{"id":4951,"position":7,"arabic":"حَيْثُ","translation":"যেখানে","audioUrl":"wbw/009_005_007.mp3","charTypeName":"word"},{"id":4952,"position":8,"arabic":"وَجَدتُّمُوهُمْ","translation":"তোমরা পাও তাদেরকে","audioUrl":"wbw/009_005_008.mp3","charTypeName":"word"},{"id":4953,"position":9,"arabic":"وَخُذُوهُمْ","translation":"ও তোমরা ধরো তাদেরকে","audioUrl":"wbw/009_005_009.mp3","charTypeName":"word"},{"id":4954,"position":10,"arabic":"وَٱحْصُرُوهُمْ","translation":"ও তোমরা অবরোধ করো তাদেরকে","audioUrl":"wbw/009_005_010.mp3","charTypeName":"word"},{"id":4955,"position":11,"arabic":"وَٱقْعُدُوا۟","translation":"এবং তোমরা বসো","audioUrl":"wbw/009_005_011.mp3","charTypeName":"word"},{"id":4956,"position":12,"arabic":"لَهُمْ","translation":"জন্যে তাদের","audioUrl":"wbw/009_005_012.mp3","charTypeName":"word"},{"id":4957,"position":13,"arabic":"كُلَّ","translation":"প্রত্যেক","audioUrl":"wbw/009_005_013.mp3","charTypeName":"word"},{"id":4958,"position":14,"arabic":"مَرْصَدٍۢ ۚ","translation":"ঘাঁটিতে","audioUrl":"wbw/009_005_014.mp3","charTypeName":"word"},{"id":4960,"position":15,"arabic":"فَإِن","translation":"অতঃপর যদি","audioUrl":"wbw/009_005_016.mp3","charTypeName":"word"},{"id":4961,"position":16,"arabic":"تَابُوا۟","translation":"তারা তওবা করে","audioUrl":"wbw/009_005_017.mp3","charTypeName":"word"},{"id":4962,"position":17,"arabic":"وَأَقَامُوا۟","translation":"ও তারা প্রতিষ্ঠা করে","audioUrl":"wbw/009_005_018.mp3","charTypeName":"word"},{"id":4963,"position":18,"arabic":"ٱلصَّلَوٰةَ","translation":"সালাত","audioUrl":"wbw/009_005_019.mp3","charTypeName":"word"},{"id":4964,"position":19,"arabic":"وَءَاتَوُا۟","translation":"ও তারা দেয়","audioUrl":"wbw/009_005_020.mp3","charTypeName":"word"},{"id":4965,"position":20,"arabic":"ٱلزَّكَوٰةَ","translation":"যাকাত","audioUrl":"wbw/009_005_021.mp3","charTypeName":"word"},{"id":4966,"position":21,"arabic":"فَخَلُّوا۟","translation":"তবে তোমরা ছেড়ে দাও","audioUrl":"wbw/009_005_022.mp3","charTypeName":"word"},{"id":4967,"position":22,"arabic":"سَبِيلَهُمْ ۚ","translation":"রাস্তা তাদের","audioUrl":"wbw/009_005_023.mp3","charTypeName":"word"},{"id":4969,"position":23,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/009_005_025.mp3","charTypeName":"word"},{"id":4970,"position":24,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/009_005_026.mp3","charTypeName":"word"},{"id":4971,"position":25,"arabic":"غَفُورٌۭ","translation":"ক্ষমাশীল","audioUrl":"wbw/009_005_027.mp3","charTypeName":"word"},{"id":4972,"position":26,"arabic":"رَّحِيمٌۭ","translation":"পরম দয়ালু","audioUrl":"wbw/009_005_028.mp3","charTypeName":"word"},{"id":4973,"position":27,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"وَإِنْ أَحَدٌۭ مِّنَ ٱلْمُشْرِكِينَ ٱسْتَجَارَكَ فَأَجِرْهُ حَتَّىٰ يَسْمَعَ كَلَٰمَ ٱللَّهِ ثُمَّ أَبْلِغْهُ مَأْمَنَهُۥ ۚ ذَٰلِكَ بِأَنَّهُمْ قَوْمٌۭ لَّا يَعْلَمُونَ","translation":"And if any of those who ascribe divinity to aught beside God seeks thy protection, grant him protection, so that he might [be able to] hear the word of God [from thee]; and thereupon convey him to a place where he can feel secure: this, because they [may be] people who [sin only because they] do not know [the truth].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1241.mp3","surahId":9,"words":[{"id":6195,"position":1,"arabic":"وَإِنْ","translation":"এবং যদি","audioUrl":"wbw/009_006_001.mp3","charTypeName":"word"},{"id":6196,"position":2,"arabic":"أَحَدٌۭ","translation":"কেউ","audioUrl":"wbw/009_006_002.mp3","charTypeName":"word"},{"id":6197,"position":3,"arabic":"مِّنَ","translation":"মধ্য হতে","audioUrl":"wbw/009_006_003.mp3","charTypeName":"word"},{"id":6198,"position":4,"arabic":"ٱلْمُشْرِكِينَ","translation":"মুশরিকদের","audioUrl":"wbw/009_006_004.mp3","charTypeName":"word"},{"id":6199,"position":5,"arabic":"ٱسْتَجَارَكَ","translation":"তোমার আশ্রয় চায়","audioUrl":"wbw/009_006_005.mp3","charTypeName":"word"},{"id":6200,"position":6,"arabic":"فَأَجِرْهُ","translation":"তবে তাকে আশ্রয় দাও","audioUrl":"wbw/009_006_006.mp3","charTypeName":"word"},{"id":6201,"position":7,"arabic":"حَتَّىٰ","translation":"যতক্ষণ না","audioUrl":"wbw/009_006_007.mp3","charTypeName":"word"},{"id":6202,"position":8,"arabic":"يَسْمَعَ","translation":"সে শুনে","audioUrl":"wbw/009_006_008.mp3","charTypeName":"word"},{"id":6203,"position":9,"arabic":"كَلَـٰمَ","translation":"বাণী","audioUrl":"wbw/009_006_009.mp3","charTypeName":"word"},{"id":6204,"position":10,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/009_006_010.mp3","charTypeName":"word"},{"id":6205,"position":11,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/009_006_011.mp3","charTypeName":"word"},{"id":6206,"position":12,"arabic":"أَبْلِغْهُ","translation":"তাকে পৌঁছাও","audioUrl":"wbw/009_006_012.mp3","charTypeName":"word"},{"id":6207,"position":13,"arabic":"مَأْمَنَهُۥ ۚ","translation":"নিরাপদ স্থানে তার","audioUrl":"wbw/009_006_013.mp3","charTypeName":"word"},{"id":6209,"position":14,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/009_006_015.mp3","charTypeName":"word"},{"id":6210,"position":15,"arabic":"بِأَنَّهُمْ","translation":"এজন্যে যে তারা","audioUrl":"wbw/009_006_016.mp3","charTypeName":"word"},{"id":6211,"position":16,"arabic":"قَوْمٌۭ","translation":"(এমন)সম্প্রদায়","audioUrl":"wbw/009_006_017.mp3","charTypeName":"word"},{"id":6212,"position":17,"arabic":"لَّا","translation":"না","audioUrl":"wbw/009_006_018.mp3","charTypeName":"word"},{"id":6213,"position":18,"arabic":"يَعْلَمُونَ","translation":"তারা জানে","audioUrl":"wbw/009_006_019.mp3","charTypeName":"word"},{"id":6214,"position":19,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]}]}