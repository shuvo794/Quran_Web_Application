{"id":542,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ قَدْ سَمِعَ ٱللَّهُ قَوْلَ ٱلَّتِى تُجَٰدِلُكَ فِى زَوْجِهَا وَتَشْتَكِىٓ إِلَى ٱللَّهِ وَٱللَّهُ يَسْمَعُ تَحَاوُرَكُمَآ ۚ إِنَّ ٱللَّهَ سَمِيعٌۢ بَصِيرٌ","translation":"GOD has indeed heard the words of her who pleads with thee concerning her husband, and complains Unto God. And God does hear what you both have to say: verily, God is all-hearing, all-seeing.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5105.mp3","surahId":58,"words":[{"id":358,"position":1,"arabic":"قَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/058_001_001.mp3","charTypeName":"word"},{"id":359,"position":2,"arabic":"سَمِعَ","translation":"শুনেছেন","audioUrl":"wbw/058_001_002.mp3","charTypeName":"word"},{"id":360,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌","audioUrl":"wbw/058_001_003.mp3","charTypeName":"word"},{"id":361,"position":4,"arabic":"قَوْلَ","translation":"কথা","audioUrl":"wbw/058_001_004.mp3","charTypeName":"word"},{"id":362,"position":5,"arabic":"ٱلَّتِى","translation":"(সেই নারীর) যে","audioUrl":"wbw/058_001_005.mp3","charTypeName":"word"},{"id":363,"position":6,"arabic":"تُجَـٰدِلُكَ","translation":"তোমার সাথে তর্কবিতর্ক করছে","audioUrl":"wbw/058_001_006.mp3","charTypeName":"word"},{"id":364,"position":7,"arabic":"فِى","translation":"ব্যাপারে","audioUrl":"wbw/058_001_007.mp3","charTypeName":"word"},{"id":365,"position":8,"arabic":"زَوْجِهَا","translation":"তার স্বামীর","audioUrl":"wbw/058_001_008.mp3","charTypeName":"word"},{"id":366,"position":9,"arabic":"وَتَشْتَكِىٓ","translation":"এবং অভিযোগ করছে","audioUrl":"wbw/058_001_009.mp3","charTypeName":"word"},{"id":367,"position":10,"arabic":"إِلَى","translation":"কাছে","audioUrl":"wbw/058_001_010.mp3","charTypeName":"word"},{"id":368,"position":11,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌র","audioUrl":"wbw/058_001_011.mp3","charTypeName":"word"},{"id":369,"position":12,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ্‌","audioUrl":"wbw/058_001_012.mp3","charTypeName":"word"},{"id":370,"position":13,"arabic":"يَسْمَعُ","translation":"শুনছেন","audioUrl":"wbw/058_001_013.mp3","charTypeName":"word"},{"id":371,"position":14,"arabic":"تَحَاوُرَكُمَآ ۚ","translation":"তোমাদের দুজনের কথাবার্তা","audioUrl":"wbw/058_001_014.mp3","charTypeName":"word"},{"id":373,"position":15,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/058_001_016.mp3","charTypeName":"word"},{"id":374,"position":16,"arabic":"ٱللَّهَ","translation":"আল্লাহ্‌","audioUrl":"wbw/058_001_017.mp3","charTypeName":"word"},{"id":375,"position":17,"arabic":"سَمِيعٌۢ","translation":"সবকিছু শোনেন","audioUrl":"wbw/058_001_018.mp3","charTypeName":"word"},{"id":376,"position":18,"arabic":"بَصِيرٌ","translation":"সবকিছু দেখেন","audioUrl":"wbw/058_001_019.mp3","charTypeName":"word"},{"id":377,"position":19,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"ٱلَّذِينَ يُظَٰهِرُونَ مِنكُم مِّن نِّسَآئِهِم مَّا هُنَّ أُمَّهَٰتِهِمْ ۖ إِنْ أُمَّهَٰتُهُمْ إِلَّا ٱلَّٰٓـِٔى وَلَدْنَهُمْ ۚ وَإِنَّهُمْ لَيَقُولُونَ مُنكَرًۭا مِّنَ ٱلْقَوْلِ وَزُورًۭا ۚ وَإِنَّ ٱللَّهَ لَعَفُوٌّ غَفُورٌۭ","translation":"As for those of you who [henceforth] separate themselves from their wives by saying, “Thou art as unlawful to me as my mother”, [let them bear in mind that] they can never be [as] their mothers: none are their mothers save those who gave them birth: and so, behold, they but utter a saying that runs counter to reason, and is [therefore] false. But, behold, God is indeed an absolver of sins, much-forgiving:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5106.mp3","surahId":58,"words":[{"id":1632,"position":1,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/058_002_001.mp3","charTypeName":"word"},{"id":1633,"position":2,"arabic":"يُظَـٰهِرُونَ","translation":"যিহার করে","audioUrl":"wbw/058_002_002.mp3","charTypeName":"word"},{"id":1634,"position":3,"arabic":"مِنكُم","translation":"তোমাদের মধ্য থেকে","audioUrl":"wbw/058_002_003.mp3","charTypeName":"word"},{"id":1635,"position":4,"arabic":"مِّن","translation":"সাথে","audioUrl":"wbw/058_002_004.mp3","charTypeName":"word"},{"id":1636,"position":5,"arabic":"نِّسَآئِهِم","translation":"তাদের স্ত্রীদের","audioUrl":"wbw/058_002_005.mp3","charTypeName":"word"},{"id":1637,"position":6,"arabic":"مَّا","translation":"না","audioUrl":"wbw/058_002_006.mp3","charTypeName":"word"},{"id":1638,"position":7,"arabic":"هُنَّ","translation":"তারা","audioUrl":"wbw/058_002_007.mp3","charTypeName":"word"},{"id":1639,"position":8,"arabic":"أُمَّهَـٰتِهِمْ ۖ","translation":"তাদের মা (হয়ে যায়)","audioUrl":"wbw/058_002_008.mp3","charTypeName":"word"},{"id":1641,"position":9,"arabic":"إِنْ","translation":"নয় (অন্যরা)","audioUrl":"wbw/058_002_010.mp3","charTypeName":"word"},{"id":1642,"position":10,"arabic":"أُمَّهَـٰتُهُمْ","translation":"তাদের মা","audioUrl":"wbw/058_002_011.mp3","charTypeName":"word"},{"id":1643,"position":11,"arabic":"إِلَّا","translation":"এছাড়া","audioUrl":"wbw/058_002_012.mp3","charTypeName":"word"},{"id":1644,"position":12,"arabic":"ٱلَّـٰٓـِٔى","translation":"যারা","audioUrl":"wbw/058_002_013.mp3","charTypeName":"word"},{"id":1645,"position":13,"arabic":"وَلَدْنَهُمْ ۚ","translation":"তাদের জন্ম দিয়েছে","audioUrl":"wbw/058_002_014.mp3","charTypeName":"word"},{"id":1647,"position":14,"arabic":"وَإِنَّهُمْ","translation":"এবং তারা নিশ্চয়ই","audioUrl":"wbw/058_002_016.mp3","charTypeName":"word"},{"id":1648,"position":15,"arabic":"لَيَقُولُونَ","translation":"বলে অবশ্যই","audioUrl":"wbw/058_002_017.mp3","charTypeName":"word"},{"id":1649,"position":16,"arabic":"مُنكَرًۭا","translation":"অসঙ্গত","audioUrl":"wbw/058_002_018.mp3","charTypeName":"word"},{"id":1650,"position":17,"arabic":"مِّنَ","translation":"থেকে","audioUrl":"wbw/058_002_019.mp3","charTypeName":"word"},{"id":1651,"position":18,"arabic":"ٱلْقَوْلِ","translation":"কথা","audioUrl":"wbw/058_002_020.mp3","charTypeName":"word"},{"id":1652,"position":19,"arabic":"وَزُورًۭا ۚ","translation":"ও মিথ্যা","audioUrl":"wbw/058_002_021.mp3","charTypeName":"word"},{"id":1654,"position":20,"arabic":"وَإِنَّ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/058_002_023.mp3","charTypeName":"word"},{"id":1655,"position":21,"arabic":"ٱللَّهَ","translation":"আল্লাহ্‌","audioUrl":"wbw/058_002_024.mp3","charTypeName":"word"},{"id":1656,"position":22,"arabic":"لَعَفُوٌّ","translation":"অবশ্যই মার্জনাকারী","audioUrl":"wbw/058_002_025.mp3","charTypeName":"word"},{"id":1657,"position":23,"arabic":"غَفُورٌۭ","translation":"ক্ষমাশীল","audioUrl":"wbw/058_002_026.mp3","charTypeName":"word"},{"id":1658,"position":24,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"وَٱلَّذِينَ يُظَٰهِرُونَ مِن نِّسَآئِهِمْ ثُمَّ يَعُودُونَ لِمَا قَالُوا۟ فَتَحْرِيرُ رَقَبَةٍۢ مِّن قَبْلِ أَن يَتَمَآسَّا ۚ ذَٰلِكُمْ تُوعَظُونَ بِهِۦ ۚ وَٱللَّهُ بِمَا تَعْمَلُونَ خَبِيرٌۭ","translation":"hence, as for those who would separate themselves from their wives by saying, “Thou art as unlawful to me as my mother”, and thereafter would go back on what they have said, [their atonement] shall be the freeing of a human being from bondage before the couple may touch one another again: this you are [hereby] exhorted to do - for God is fully aware of all that you do.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5107.mp3","surahId":58,"words":[{"id":2337,"position":1,"arabic":"وَٱلَّذِينَ","translation":"এবং তারা যখন","audioUrl":"wbw/058_003_001.mp3","charTypeName":"word"},{"id":2338,"position":2,"arabic":"يُظَـٰهِرُونَ","translation":"যিহার করে","audioUrl":"wbw/058_003_002.mp3","charTypeName":"word"},{"id":2339,"position":3,"arabic":"مِن","translation":"সাথে","audioUrl":"wbw/058_003_003.mp3","charTypeName":"word"},{"id":2340,"position":4,"arabic":"نِّسَآئِهِمْ","translation":"তাদের স্ত্রীদের","audioUrl":"wbw/058_003_004.mp3","charTypeName":"word"},{"id":2341,"position":5,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/058_003_005.mp3","charTypeName":"word"},{"id":2342,"position":6,"arabic":"يَعُودُونَ","translation":"ফিরে যায়","audioUrl":"wbw/058_003_006.mp3","charTypeName":"word"},{"id":2343,"position":7,"arabic":"لِمَا","translation":"(তা হতে) যা","audioUrl":"wbw/058_003_007.mp3","charTypeName":"word"},{"id":2344,"position":8,"arabic":"قَالُوا۟","translation":"তারা বলেছিল","audioUrl":"wbw/058_003_008.mp3","charTypeName":"word"},{"id":2345,"position":9,"arabic":"فَتَحْرِيرُ","translation":"মুক্ত করতে হবে","audioUrl":"wbw/058_003_009.mp3","charTypeName":"word"},{"id":2346,"position":10,"arabic":"رَقَبَةٍۢ","translation":"একজন দাস","audioUrl":"wbw/058_003_010.mp3","charTypeName":"word"},{"id":2347,"position":11,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/058_003_011.mp3","charTypeName":"word"},{"id":2348,"position":12,"arabic":"قَبْلِ","translation":"পূর্বে","audioUrl":"wbw/058_003_012.mp3","charTypeName":"word"},{"id":2349,"position":13,"arabic":"أَن","translation":"যে","audioUrl":"wbw/058_003_013.mp3","charTypeName":"word"},{"id":2350,"position":14,"arabic":"يَتَمَآسَّا ۚ","translation":"পরস্পরকে স্পর্শ করার","audioUrl":"wbw/058_003_014.mp3","charTypeName":"word"},{"id":2352,"position":15,"arabic":"ذَٰلِكُمْ","translation":"এসব","audioUrl":"wbw/058_003_016.mp3","charTypeName":"word"},{"id":2353,"position":16,"arabic":"تُوعَظُونَ","translation":"তোমাদের উপদেশ দেয়া হচ্ছে","audioUrl":"wbw/058_003_017.mp3","charTypeName":"word"},{"id":2354,"position":17,"arabic":"بِهِۦ ۚ","translation":"এদ্বারা","audioUrl":"wbw/058_003_018.mp3","charTypeName":"word"},{"id":2356,"position":18,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ্‌","audioUrl":"wbw/058_003_020.mp3","charTypeName":"word"},{"id":2357,"position":19,"arabic":"بِمَا","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/058_003_021.mp3","charTypeName":"word"},{"id":2358,"position":20,"arabic":"تَعْمَلُونَ","translation":"তোমরা কাজ কর","audioUrl":"wbw/058_003_022.mp3","charTypeName":"word"},{"id":2359,"position":21,"arabic":"خَبِيرٌۭ","translation":"খুব অবহিত","audioUrl":"wbw/058_003_023.mp3","charTypeName":"word"},{"id":2360,"position":22,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"فَمَن لَّمْ يَجِدْ فَصِيَامُ شَهْرَيْنِ مُتَتَابِعَيْنِ مِن قَبْلِ أَن يَتَمَآسَّا ۖ فَمَن لَّمْ يَسْتَطِعْ فَإِطْعَامُ سِتِّينَ مِسْكِينًۭا ۚ ذَٰلِكَ لِتُؤْمِنُوا۟ بِٱللَّهِ وَرَسُولِهِۦ ۚ وَتِلْكَ حُدُودُ ٱللَّهِ ۗ وَلِلْكَٰفِرِينَ عَذَابٌ أَلِيمٌ","translation":"However, he who does not have the where­withal shall fast [instead] for two consecutive months before the couple may touch one another again; and he who is unable to do it shall feed sixty needy ones: this, so that you might prove your faith in God and His Apostle. Now these are the bounds set by God; and grievous suffering [in the life to come] awaits all who deny the truth.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5108.mp3","surahId":58,"words":[{"id":3692,"position":1,"arabic":"فَمَن","translation":"যে অতঃপর","audioUrl":"wbw/058_004_001.mp3","charTypeName":"word"},{"id":3693,"position":2,"arabic":"لَّمْ","translation":"না","audioUrl":"wbw/058_004_002.mp3","charTypeName":"word"},{"id":3694,"position":3,"arabic":"يَجِدْ","translation":"পায় (কোন দাস)","audioUrl":"wbw/058_004_003.mp3","charTypeName":"word"},{"id":3695,"position":4,"arabic":"فَصِيَامُ","translation":"তবে রোজা রাখবে","audioUrl":"wbw/058_004_004.mp3","charTypeName":"word"},{"id":3696,"position":5,"arabic":"شَهْرَيْنِ","translation":"দু'মাস","audioUrl":"wbw/058_004_005.mp3","charTypeName":"word"},{"id":3697,"position":6,"arabic":"مُتَتَابِعَيْنِ","translation":"একটানা","audioUrl":"wbw/058_004_006.mp3","charTypeName":"word"},{"id":3698,"position":7,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/058_004_007.mp3","charTypeName":"word"},{"id":3699,"position":8,"arabic":"قَبْلِ","translation":"পূর্বে","audioUrl":"wbw/058_004_008.mp3","charTypeName":"word"},{"id":3700,"position":9,"arabic":"أَن","translation":"যে","audioUrl":"wbw/058_004_009.mp3","charTypeName":"word"},{"id":3701,"position":10,"arabic":"يَتَمَآسَّا ۖ","translation":"পরস্পরে স্পর্শ করার","audioUrl":"wbw/058_004_010.mp3","charTypeName":"word"},{"id":3703,"position":11,"arabic":"فَمَن","translation":"যে অতঃপর","audioUrl":"wbw/058_004_012.mp3","charTypeName":"word"},{"id":3704,"position":12,"arabic":"لَّمْ","translation":"না","audioUrl":"wbw/058_004_013.mp3","charTypeName":"word"},{"id":3705,"position":13,"arabic":"يَسْتَطِعْ","translation":"সমর্থ হবে","audioUrl":"wbw/058_004_014.mp3","charTypeName":"word"},{"id":3706,"position":14,"arabic":"فَإِطْعَامُ","translation":"তবে খানা খাওয়াবে","audioUrl":"wbw/058_004_015.mp3","charTypeName":"word"},{"id":3707,"position":15,"arabic":"سِتِّينَ","translation":"ষাটজন","audioUrl":"wbw/058_004_016.mp3","charTypeName":"word"},{"id":3708,"position":16,"arabic":"مِسْكِينًۭا ۚ","translation":"নিঃস্বকে","audioUrl":"wbw/058_004_017.mp3","charTypeName":"word"},{"id":3710,"position":17,"arabic":"ذَٰلِكَ","translation":"এটা (এজন্যে)","audioUrl":"wbw/058_004_019.mp3","charTypeName":"word"},{"id":3711,"position":18,"arabic":"لِتُؤْمِنُوا۟","translation":"যেন তোমরা ঈমান আন","audioUrl":"wbw/058_004_020.mp3","charTypeName":"word"},{"id":3712,"position":19,"arabic":"بِٱللَّهِ","translation":"আল্লাহ্‌র উপর","audioUrl":"wbw/058_004_021.mp3","charTypeName":"word"},{"id":3713,"position":20,"arabic":"وَرَسُولِهِۦ ۚ","translation":"এবং তাঁর রাসূলের (উপর)","audioUrl":"wbw/058_004_022.mp3","charTypeName":"word"},{"id":3715,"position":21,"arabic":"وَتِلْكَ","translation":"এবং এটা","audioUrl":"wbw/058_004_024.mp3","charTypeName":"word"},{"id":3716,"position":22,"arabic":"حُدُودُ","translation":"নির্ধারিত সীমাসমূহ","audioUrl":"wbw/058_004_025.mp3","charTypeName":"word"},{"id":3717,"position":23,"arabic":"ٱللَّهِ ۗ","translation":"আল্লাহ্‌র","audioUrl":"wbw/058_004_026.mp3","charTypeName":"word"},{"id":3719,"position":24,"arabic":"وَلِلْكَـٰفِرِينَ","translation":"