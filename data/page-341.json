{"id":341,"ayahs":[{"number":73,"arabic":"يَٰٓأَيُّهَا ٱلنَّاسُ ضُرِبَ مَثَلٌۭ فَٱسْتَمِعُوا۟ لَهُۥٓ ۚ إِنَّ ٱلَّذِينَ تَدْعُونَ مِن دُونِ ٱللَّهِ لَن يَخْلُقُوا۟ ذُبَابًۭا وَلَوِ ٱجْتَمَعُوا۟ لَهُۥ ۖ وَإِن يَسْلُبْهُمُ ٱلذُّبَابُ شَيْـًۭٔا لَّا يَسْتَنقِذُوهُ مِنْهُ ۚ ضَعُفَ ٱلطَّالِبُ وَٱلْمَطْلُوبُ","translation":"O MEN! A parable is set forth [herewith]; hearken, then, to it! Behold, those beings whom you invoke instead of God cannot create [as much as] a fly, even were they to join all their forces to that end! And if a fly robs them of anything, they cannot [even] rescue it from him! Weak indeed is the seeker, and [weak] the sought!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2668.mp3","surahId":22,"words":[{"id":61244,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/022_073_001.mp3","charTypeName":"word"},{"id":61245,"position":2,"arabic":"ٱلنَّاسُ","translation":"মানুষ","audioUrl":"wbw/022_073_002.mp3","charTypeName":"word"},{"id":61246,"position":3,"arabic":"ضُرِبَ","translation":"পেশ করা হচ্ছে","audioUrl":"wbw/022_073_003.mp3","charTypeName":"word"},{"id":61247,"position":4,"arabic":"مَثَلٌۭ","translation":"একটি উপমা","audioUrl":"wbw/022_073_004.mp3","charTypeName":"word"},{"id":61248,"position":5,"arabic":"فَٱسْتَمِعُوا۟","translation":"তাই তোমরা মনযোগ দিয়ে শুনো","audioUrl":"wbw/022_073_005.mp3","charTypeName":"word"},{"id":61249,"position":6,"arabic":"لَهُۥٓ ۚ","translation":"প্রতি তার","audioUrl":"wbw/022_073_006.mp3","charTypeName":"word"},{"id":61251,"position":7,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/022_073_008.mp3","charTypeName":"word"},{"id":61252,"position":8,"arabic":"ٱلَّذِينَ","translation":"যাদেরকে","audioUrl":"wbw/022_073_009.mp3","charTypeName":"word"},{"id":61253,"position":9,"arabic":"تَدْعُونَ","translation":"ডাকছো তোমরা","audioUrl":"wbw/022_073_010.mp3","charTypeName":"word"},{"id":61254,"position":10,"arabic":"مِن","translation":"মধ্য হতে","audioUrl":"wbw/022_073_011.mp3","charTypeName":"word"},{"id":61255,"position":11,"arabic":"دُونِ","translation":"পরিবর্তে","audioUrl":"wbw/022_073_012.mp3","charTypeName":"word"},{"id":61256,"position":12,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/022_073_013.mp3","charTypeName":"word"},{"id":61257,"position":13,"arabic":"لَن","translation":"কখনও না","audioUrl":"wbw/022_073_014.mp3","charTypeName":"word"},{"id":61258,"position":14,"arabic":"يَخْلُقُوا۟","translation":"তারা সৃষ্টি করতে পারে","audioUrl":"wbw/022_073_015.mp3","charTypeName":"word"},{"id":61259,"position":15,"arabic":"ذُبَابًۭا","translation":"একটি মাছিও","audioUrl":"wbw/022_073_016.mp3","charTypeName":"word"},{"id":61260,"position":16,"arabic":"وَلَوِ","translation":"যদি","audioUrl":"wbw/022_073_017.mp3","charTypeName":"word"},{"id":61261,"position":17,"arabic":"ٱجْتَمَعُوا۟","translation":"তারা একত্র হয়","audioUrl":"wbw/022_073_018.mp3","charTypeName":"word"},{"id":61262,"position":18,"arabic":"لَهُۥ ۖ","translation":"সেজন্যে","audioUrl":"wbw/022_073_019.mp3","charTypeName":"word"},{"id":61264,"position":19,"arabic":"وَإِن","translation":"আর যদি","audioUrl":"wbw/022_073_021.mp3","charTypeName":"word"},{"id":61265,"position":20,"arabic":"يَسْلُبْهُمُ","translation":"তাদের থেকে ছিনিয়ে নেয়","audioUrl":"wbw/022_073_022.mp3","charTypeName":"word"},{"id":61266,"position":21,"arabic":"ٱلذُّبَابُ","translation":"মাছি","audioUrl":"wbw/022_073_023.mp3","charTypeName":"word"},{"id":61267,"position":22,"arabic":"شَيْـًۭٔا","translation":"কোন কিছুই","audioUrl":"wbw/022_073_024.mp3","charTypeName":"word"},{"id":61268,"position":23,"arabic":"لَّا","translation":"না","audioUrl":"wbw/022_073_025.mp3","charTypeName":"word"},{"id":61269,"position":24,"arabic":"يَسْتَنقِذُوهُ","translation":"তা উদ্ধার করতে পারে","audioUrl":"wbw/022_073_026.mp3","charTypeName":"word"},{"id":61270,"position":25,"arabic":"مِنْهُ ۚ","translation":"তা হ'তে","audioUrl":"wbw/022_073_027.mp3","charTypeName":"word"},{"id":61272,"position":26,"arabic":"ضَعُفَ","translation":"দুর্বল (কতই না)","audioUrl":"wbw/022_073_029.mp3","charTypeName":"word"},{"id":61273,"position":27,"arabic":"ٱلطَّالِبُ","translation":"(সাহায্য) অন্বেষণকারী","audioUrl":"wbw/022_073_030.mp3","charTypeName":"word"},{"id":61274,"position":28,"arabic":"وَٱلْمَطْلُوبُ","translation":"ও অন্বেষণকৃত (সেও দুর্বল)","audioUrl":"wbw/022_073_031.mp3","charTypeName":"word"},{"id":61275,"position":29,"arabic":"٧٣","translation":"(৭৩)","audioUrl":null,"charTypeName":"end"}]},{"number":74,"arabic":"مَا قَدَرُوا۟ ٱللَّهَ حَقَّ قَدْرِهِۦٓ ۗ إِنَّ ٱللَّهَ لَقَوِىٌّ عَزِيزٌ","translation":"No true understanding of God have they [who err in this way]: for, verily, God is most powerful, almighty!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2669.mp3","surahId":22,"words":[{"id":61760,"position":1,"arabic":"مَا","translation":"না","audioUrl":"wbw/022_074_001.mp3","charTypeName":"word"},{"id":61761,"position":2,"arabic":"قَدَرُوا۟","translation":"তারা মর্যাদা দিলো","audioUrl":"wbw/022_074_002.mp3","charTypeName":"word"},{"id":61762,"position":3,"arabic":"ٱللَّهَ","translation":"আল্লাহ্‌র","audioUrl":"wbw/022_074_003.mp3","charTypeName":"word"},{"id":61763,"position":4,"arabic":"حَقَّ","translation":"যথোচিত","audioUrl":"wbw/022_074_004.mp3","charTypeName":"word"},{"id":61764,"position":5,"arabic":"قَدْرِهِۦٓ ۗ","translation":"তাঁর মর্যাদা","audioUrl":"wbw/022_074_005.mp3","charTypeName":"word"},{"id":61766,"position":6,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/022_074_007.mp3","charTypeName":"word"},{"id":61767,"position":7,"arabic":"ٱللَّهَ","translation":"আল্লাহ্‌","audioUrl":"wbw/022_074_008.mp3","charTypeName":"word"},{"id":61768,"position":8,"arabic":"لَقَوِىٌّ","translation":"অবশ্যই শক্তিমান","audioUrl":"wbw/022_074_009.mp3","charTypeName":"word"},{"id":61769,"position":9,"arabic":"عَزِيزٌ","translation":"পরাক্রমশালী","audioUrl":"wbw/022_074_010.mp3","charTypeName":"word"},{"id":61770,"position":10,"arabic":"٧٤","translation":"(৭৪)","audioUrl":null,"charTypeName":"end"}]},{"number":75,"arabic":"ٱللَّهُ يَصْطَفِى مِنَ ٱلْمَلَٰٓئِكَةِ رُسُلًۭا وَمِنَ ٱلنَّاسِ ۚ إِنَّ ٱللَّهَ سَمِيعٌۢ بَصِيرٌۭ","translation":"[In His almightiness,] God chooses message-bearers from among the angels as well as from among men. But, behold, God [alone] is all-hearing, all-see­ing:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2670.mp3","surahId":22,"words":[{"id":62022,"position":1,"arabic":"ٱللَّهُ","translation":"(বস্তুতঃ) আল্লাহ্‌","audioUrl":"wbw/022_075_001.mp3","charTypeName":"word"},{"id":62023,"position":2,"arabic":"يَصْطَفِى","translation":"মনোনীত করেন","audioUrl":"wbw/022_075_002.mp3","charTypeName":"word"},{"id":62024,"position":3,"arabic":"مِنَ","translation":"মধ্য হ'তে","audioUrl":"wbw/022_075_003.mp3","charTypeName":"word"},{"id":62025,"position":4,"arabic":"ٱلْمَلَـٰٓئِكَةِ","translation":"ফেরেশতাদের","audioUrl":"wbw/022_075_004.mp3","charTypeName":"word"},{"id":62026,"position":5,"arabic":"رُسُلًۭا","translation":"বাণীবাহকরূপে","audioUrl":"wbw/022_075_005.mp3","charTypeName":"word"},{"id":62027,"position":6,"arabic":"وَمِنَ","translation":"আর মধ্য হ'তেও","audioUrl":"wbw/022_075_006.mp3","charTypeName":"word"},{"id":62028,"position":7,"arabic":"ٱلنَّاسِ ۚ","translation":"মানুষের","audioUrl":"wbw/022_075_007.mp3","charTypeName":"word"},{"id":62030,"position":8,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/022_075_009.mp3","charTypeName":"word"},{"id":62031,"position":9,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/022_075_010.mp3","charTypeName":"word"},{"id":62032,"position":10,"arabic":"سَمِيعٌۢ","translation":"সব শুনেন","audioUrl":"wbw/022_075_011.mp3","charTypeName":"word"},{"id":62033,"position":11,"arabic":"بَصِيرٌۭ","translation":"সব দেখেন","audioUrl":"wbw/022_075_012.mp3","charTypeName":"word"},{"id":62034,"position":12,"arabic":"٧٥","translation":"(৭৫)","audioUrl":null,"charTypeName":"end"}]},{"number":76,"arabic":"يَعْلَمُ مَا بَيْنَ أَيْدِيهِمْ وَمَا خَلْفَهُمْ ۗ وَإِلَى ٱللَّهِ تُرْجَعُ ٱلْأُمُورُ","translation":"[whereas their knowledge is limited,] He knows all that lies open before them and all that is hidden from them for all things go back to God [as their source].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2671.mp3","surahId":22,"words":[{"id":62521,"position":1,"arabic":"يَعْلَمُ","translation":"তিনি জানেন","audioUrl":"wbw/022_076_001.mp3","charTypeName":"word"},{"id":62522,"position":2,"arabic":"مَا","translation":"যা (আছে)","audioUrl":"wbw/022_076_002.mp3","charTypeName":"word"},{"id":62523,"position":3,"arabic":"بَيْنَ","translation":"মাঝে","audioUrl":"wbw/022_076_003.mp3","charTypeName":"word"},{"id":62524,"position":4,"arabic":"أَيْدِيهِمْ","translation":"হাতের তাদের (সম্মুখে)","audioUrl":"wbw/022_076_004.mp3","charTypeName":"word"},{"id":62525,"position":5,"arabic":"وَمَا","translation":"ও যা (আছে)","audioUrl":"wbw/022_076_005.mp3","charTypeName":"word"},{"id":62526,"position":6,"arabic":"خَلْفَهُمْ ۗ","translation":"তাদের পিছনে","audioUrl":"wbw/022_076_006.mp3","charTypeName":"word"},{"id":62528,"position":7,"arabic":"وَإِلَى","translation":"এবং দিকে","audioUrl":"wbw/022_076_008.mp3","charTypeName":"word"},{"id":62529,"position":8,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌রই","audioUrl":"wbw/022_076_009.mp3","charTypeName":"word"},{"id":62530,"position":9,"arabic":"تُرْجَعُ","translation":"প্রত্যাবর্তিত হয়","audioUrl":"wbw/022_076_010.mp3","charTypeName":"word"},{"id":62531,"position":10,"arabic":"ٱلْأُمُورُ","translation":"সব ব্যাপারে","audioUrl":"wbw/022_076_011.mp3","charTypeName":"word"},{"id":62532,"position":11,"arabic":"٧٦","translation":"(৭৬)","audioUrl":null,"charTypeName":"end"}]},{"number":77,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ ٱرْكَعُوا۟ وَٱسْجُدُوا۟ وَٱعْبُدُوا۟ رَبَّكُمْ وَٱفْعَلُوا۟ ٱلْخَيْرَ لَعَلَّكُمْ تُفْلِحُونَ ۩","translation":"O YOU who have attained to faith! Bow down and prostrate yourselves, and worship your Sustainer [alone], and do good, so that you might attain to a happy state!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2672.mp3","surahId":22,"words":[{"id":62748,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/022_077_001.mp3","charTypeName":"word"},{"id":62749,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/022_077_002.mp3","charTypeName":"word"},{"id":62750,"position":3,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছো","audioUrl":"wbw/022_077_003.mp3","charTypeName":"word"},{"id":62751,"position":4,"arabic":"ٱرْكَعُوا۟","translation":"তোমরা রূকূ করো","audioUrl":"wbw/022_077_004.mp3","charTypeName":"word"},{"id":62752,"position":5,"arabic":"وَٱسْجُدُوا۟","translation":"ও তোমরা সিজদা করো","audioUrl":"wbw/022_077_005.mp3","charTypeName":"word"},{"id":62753,"position":6,"arabic":"وَٱعْبُدُوا۟","translation":"ও তোমরা ইবাদাত করো","audioUrl":"wbw/022_077_006.mp3","charTypeName":"word"},{"id":62754,"position":7,"arabic":"رَبَّكُمْ","translation":"তোমাদের রবের","audioUrl":"wbw/022_077_007.mp3","charTypeName":"word"},{"id":62755,"position":8,"arabic":"وَٱفْعَلُوا۟","translation":"ও তোমরা করো","audioUrl":"wbw/022_077_008.mp3","charTypeName":"word"},{"id":62756,"position":9,"arabic":"ٱلْخَيْرَ","translation":"ভালো কাজ","audioUrl":"wbw/022_077_009.mp3","charTypeName":"word"},{"id":62757,"position":10,"arabic":"لَعَلَّكُمْ","translation":"যাতে তোমরা","audioUrl":"wbw/022_077_010.mp3","charTypeName":"word"},{"id":62758,"position":11,"arabic":"تُفْلِحُونَ ۩","translation":"সফলকাম হ'তে পারো","audioUrl":"wbw/022_077_011.mp3","charTypeName":"word"},{"id":62760,"position":12,"arabic":"٧٧","translation":"(৭৭)","audioUrl":null,"charTypeName":"end"}]},{"number":78,"arabic":"وَجَٰهِدُوا۟ فِى ٱللَّهِ حَقَّ جِهَادِهِۦ ۚ هُوَ ٱجْتَبَىٰكُمْ وَمَا جَعَلَ عَلَيْكُمْ فِى ٱلدِّينِ مِنْ حَرَجٍۢ ۚ مِّلَّةَ أَبِيكُمْ إِبْرَٰهِيمَ ۚ هُوَ سَمَّىٰكُمُ ٱلْمُسْلِمِينَ مِن قَبْلُ وَفِى هَٰذَا لِيَكُونَ ٱلرَّسُولُ شَهِيدًا عَلَيْكُمْ وَتَكُونُوا۟ شُهَدَآءَ عَلَى ٱلنَّاسِ ۚ فَأَقِيمُوا۟ ٱلصَّلَوٰةَ وَءَاتُوا۟ ٱلزَّكَوٰةَ وَٱعْتَصِمُوا۟ بِٱللَّهِ هُوَ مَوْلَىٰكُمْ ۖ فَنِعْمَ ٱلْمَوْلَىٰ وَنِعْمَ ٱلنَّصِيرُ","translation":"And strive hard in God’s cause with all the striving that is due to Him: it is He who has elected you [to carry His message], and has laid no hardship on you in [anything that pertains to religion, [and made you follow] the creed of your forefather Abraham. It is He who has named you in bygone times as well as in this [divine writ] – “those who have surrendered themselves to God”, so that the Apostle might bear witness to the truth before you, and that you might bear witness to it before all mankind. Thus, be constant in prayer, and render the purifying dues, and hold fast unto God. He is your Lord Supreme: and how excellent is this Lord Supreme, and how excellent this Giver of Succour!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2673.mp3","surahId":22,"words":[{"id":63294,"position":1,"arabic":"وَجَـٰهِدُوا۟","translation":"আর তোমরা জিহাদ করো","audioUrl":"wbw/022_078_001.mp3","charTypeName":"word"},{"id":63295,"position":2,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/022_078_002.mp3","charTypeName":"word"},{"id":63296,"position":3,"arabic":"ٱللَّهِ","translation":"আল্লাহর (পথে)","audioUrl":"wbw/022_078_003.mp3","charTypeName":"word"},{"id":63297,"position":4,"arabic":"حَقَّ","translation":"যথাযথ","audioUrl":"wbw/022_078_004.mp3","charTypeName":"word"},{"id":63298,"position":5,"arabic":"جِهَادِهِۦ ۚ","translation":"তাঁর জিহাদ","audioUrl":"wbw/022_078_005.mp3","charTypeName":"word"},{"id":63300,"position":6,"arabic":"هُوَ","translation":"তিনি","audioUrl":"wbw/022_078_007.mp3","charTypeName":"word"},{"id":63301,"position":7,"arabic":"ٱجْتَبَىٰكُمْ","translation":"তোমাদের মনোনীত  করেছেন","audioUrl":"wbw/022_078_008.mp3","charTypeName":"word"},{"id":63302,"position":8,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/022_078_009.mp3","charTypeName":"word"},{"id":63303,"position":9,"