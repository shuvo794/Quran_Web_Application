72_003.mp3","charTypeName":"word"},{"id":60455,"position":4,"arabic":"وَٱتَّقُوهُ ۚ","translation":"ও তোমরা ভয় করো তাঁকে","audioUrl":"wbw/006_072_004.mp3","charTypeName":"word"},{"id":60457,"position":5,"arabic":"وَهُوَ","translation":"এবং তিনিই","audioUrl":"wbw/006_072_006.mp3","charTypeName":"word"},{"id":60458,"position":6,"arabic":"ٱلَّذِىٓ","translation":"যিনি","audioUrl":"wbw/006_072_007.mp3","charTypeName":"word"},{"id":60459,"position":7,"arabic":"إِلَيْهِ","translation":"দিকে তাঁর","audioUrl":"wbw/006_072_008.mp3","charTypeName":"word"},{"id":60460,"position":8,"arabic":"تُحْشَرُونَ","translation":"তোমাদের একত্র করা হবে\"","audioUrl":"wbw/006_072_009.mp3","charTypeName":"word"},{"id":60461,"position":9,"arabic":"٧٢","translation":"(৭২)","audioUrl":null,"charTypeName":"end"}]},{"number":73,"arabic":"وَهُوَ ٱلَّذِى خَلَقَ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضَ بِٱلْحَقِّ ۖ وَيَوْمَ يَقُولُ كُن فَيَكُونُ ۚ قَوْلُهُ ٱلْحَقُّ ۚ وَلَهُ ٱلْمُلْكُ يَوْمَ يُنفَخُ فِى ٱلصُّورِ ۚ عَٰلِمُ ٱلْغَيْبِ وَٱلشَّهَٰدَةِ ۚ وَهُوَ ٱلْحَكِيمُ ٱلْخَبِيرُ","translation":"And He it is who has created the heavens and the earth in accordance with [an inner] truth - and whenever He says, \"Be,\" His word comes true; and His will be the dominion on the Day when the trumpet [of resurrection] is blown. He knows all that is beyond the reach of a created being's perception, as well as all that can be witnessed by a creature's senses or mind: for He alone is truly wise, all-aware.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/862.mp3","surahId":6,"words":[{"id":61291,"position":1,"arabic":"وَهُوَ","translation":"এবং তিনিই","audioUrl":"wbw/006_073_001.mp3","charTypeName":"word"},{"id":61292,"position":2,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/006_073_002.mp3","charTypeName":"word"},{"id":61293,"position":3,"arabic":"خَلَقَ","translation":"সৃষ্টি করেছেন","audioUrl":"wbw/006_073_003.mp3","charTypeName":"word"},{"id":61294,"position":4,"arabic":"ٱلسَّمَـٰوَٰتِ","translati