 unto the Sustainer of all the worlds,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/860.mp3","surahId":6,"words":[{"id":59913,"position":1,"arabic":"قُلْ","translation":"(হে নাবী) বলো","audioUrl":"wbw/006_071_001.mp3","charTypeName":"word"},{"id":59914,"position":2,"arabic":"أَنَدْعُوا۟","translation":"\"কি ডাকবো আমরা","audioUrl":"wbw/006_071_002.mp3","charTypeName":"word"},{"id":59915,"position":3,"arabic":"مِن","translation":"দিয়ে","audioUrl":"wbw/006_071_003.mp3","charTypeName":"word"},{"id":59916,"position":4,"arabic":"دُونِ","translation":"বাদ","audioUrl":"wbw/006_071_004.mp3","charTypeName":"word"},{"id":59917,"position":5,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌কে (অন্যদেরকে)","audioUrl":"wbw/006_071_005.mp3","charTypeName":"word"},{"id":59918,"position":6,"arabic":"مَا","translation":"যা","audioUrl":"wbw/006_071_006.mp3","charTypeName":"word"},{"id":59919,"position":7,"arabic":"لَا","translation":"না","audioUrl":"wbw/006_071_007.mp3","charTypeName":"word"},{"id":59920,"position":8,"arabic":"يَنفَعُنَا","translation":"উপকার করতে পারে আমাদের","audioUrl":"wbw/006_071_008.mp3","charTypeName":"word"},{"id":59921,"position":9,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/006_071_009.mp3","charTypeName":"word"},{"id":59922,"position":10,"arabic":"يَضُرُّنَا","translation":"ক্ষতি করতে পারে আমাদের","audioUrl":"wbw/006_071_010.mp3","charTypeName":"word"},{"id":59923,"position":11,"arabic":"وَنُرَدُّ","translation":"এবং (কি) ফিরে যাবো আমরা","audioUrl":"wbw/006_071_011.mp3","charTypeName":"word"},{"id":59924,"position":12,"arabic":"عَلَىٰٓ","translation":"উপর","audioUrl":"wbw/006_071_012.mp3","charTypeName":"word"},{"id":59925,"position":13,"arabic":"أَعْقَابِنَا","translation":"গোঁড়ালির আমাদের (অর্থাৎ পিছন দিকে)","audioUrl":"wbw/006_071_013.mp3","charTypeName":"word"},{"id":59926,"position":14,"arabic":"بَعْدَ","translation":"এরপরেও","audioUrl":"wbw/006_071_014.mp3","charTypeName":"word"},{"id":59927,"position":15,"arabic":"إِذْ","transla