{"id":17,"ayahs":[{"number":106,"arabic":"۞ مَا نَنسَخْ مِنْ ءَايَةٍ أَوْ نُنسِهَا نَأْتِ بِخَيْرٍۢ مِّنْهَآ أَوْ مِثْلِهَآ ۗ أَلَمْ تَعْلَمْ أَنَّ ٱللَّهَ عَلَىٰ كُلِّ شَىْءٍۢ قَدِيرٌ","translation":"Any message which, We annul or consign to oblivion We replace with a better or a similar one. Dost thou not know that God has the power to will anything?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/113.mp3","surahId":2,"words":[{"id":73092,"position":1,"arabic":"۞ مَا","translation":"যা","audioUrl":"wbw/002_106_002.mp3","charTypeName":"word"},{"id":73093,"position":2,"arabic":"نَنسَخْ","translation":"আমরা রহিত করি","audioUrl":"wbw/002_106_003.mp3","charTypeName":"word"},{"id":73094,"position":3,"arabic":"مِنْ","translation":"(অর্থাৎ) কোনো","audioUrl":"wbw/002_106_004.mp3","charTypeName":"word"},{"id":73095,"position":4,"arabic":"ءَايَةٍ","translation":"আয়াত","audioUrl":"wbw/002_106_005.mp3","charTypeName":"word"},{"id":73096,"position":5,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/002_106_006.mp3","charTypeName":"word"},{"id":73097,"position":6,"arabic":"نُنسِهَا","translation":"তা আমরা ভুলিয়ে দিই","audioUrl":"wbw/002_106_007.mp3","charTypeName":"word"},{"id":73098,"position":7,"arabic":"نَأْتِ","translation":"আনি আমরা","audioUrl":"wbw/002_106_008.mp3","charTypeName":"word"},{"id":73099,"position":8,"arabic":"بِخَيْرٍۢ","translation":"উত্তম","audioUrl":"wbw/002_106_009.mp3","charTypeName":"word"},{"id":73100,"position":9,"arabic":"مِّنْهَآ","translation":"তার চেয়ে","audioUrl":"wbw/002_106_010.mp3","charTypeName":"word"},{"id":73101,"position":10,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/002_106_011.mp3","charTypeName":"word"},{"id":73102,"position":11,"arabic":"مِثْلِهَآ ۗ","translation":"তার অনুরূপ","audioUrl":"wbw/002_106_012.mp3","charTypeName":"word"},{"id":73104,"position":12,"arabic":"أَلَمْ","translation":"নাকি","audioUrl":"wbw/002_106_014.mp3","charTypeName":"word"},{"id":73105,"position":13,"arabic":"تَعْلَمْ","tran