,{"id":74458,"position":11,"arabic":"تِلْكَ","translation":"এটা","audioUrl":"wbw/002_111_012.mp3","charTypeName":"word"},{"id":74459,"position":12,"arabic":"أَمَانِيُّهُمْ ۗ","translation":"তাদের মিথ্যাআসা মাত্র","audioUrl":"wbw/002_111_013.mp3","charTypeName":"word"},{"id":74461,"position":13,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/002_111_015.mp3","charTypeName":"word"},{"id":74462,"position":14,"arabic":"هَاتُوا۟","translation":"''তোমরা নিয়ে আস","audioUrl":"wbw/002_111_016.mp3","charTypeName":"word"},{"id":74463,"position":15,"arabic":"بُرْهَـٰنَكُمْ","translation":"তোমাদের প্রমাণ","audioUrl":"wbw/002_111_017.mp3","charTypeName":"word"},{"id":74464,"position":16,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/002_111_018.mp3","charTypeName":"word"},{"id":74465,"position":17,"arabic":"كُنتُمْ","translation":"তোমরা হও","audioUrl":"wbw/002_111_019.mp3","charTypeName":"word"},{"id":74466,"position":18,"arabic":"صَـٰدِقِينَ","translation":"সত্যবাদী''","audioUrl":"wbw/002_111_020.mp3","charTypeName":"word"},{"id":74467,"position":19,"arabic":"١١١","translation":"(১১১)","audioUrl":null,"charTypeName":"end"}]},{"number":112,"arabic":"بَلَىٰ مَنْ أَسْلَمَ وَجْهَهُۥ لِلَّهِ وَهُوَ مُحْسِنٌۭ فَلَهُۥٓ أَجْرُهُۥ عِندَ رَبِّهِۦ وَلَا خَوْفٌ عَلَيْهِمْ وَلَا هُمْ يَحْزَنُونَ","translation":"Yea, indeed: everyone who surrenders his whole being unto God, and is a doer of good withal, shall have his reward with his Sustainer; and all such need have no fear, and neither shall they grieve.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/119.mp3","surahId":2,"words":[{"id":74681,"position":1,"arabic":"بَلَىٰ","translation":"তবে হ্যাঁ","audioUrl":"wbw/002_112_001.mp3","charTypeName":"word"},{"id":74682,"position":2,"arabic":"مَنْ","translation":"যে","audioUrl":"wbw/002_112_002.mp3","charTypeName":"word"},{"id":74683,"position":3,"arabic":"أَسْلَمَ","translation":"সঁপে দিয়েছে","audioUrl":"wbw/002_112_003.mp3","charTypeName":"word"},{"id":74684,"position"