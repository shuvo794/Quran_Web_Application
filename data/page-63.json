,"translation":"(থেকে)","audioUrl":"wbw/003_105_006.mp3","charTypeName":"word"},{"id":72743,"position":7,"arabic":"بَعْدِ","translation":"এর পরেও","audioUrl":"wbw/003_105_007.mp3","charTypeName":"word"},{"id":72744,"position":8,"arabic":"مَا","translation":"যা","audioUrl":"wbw/003_105_008.mp3","charTypeName":"word"},{"id":72745,"position":9,"arabic":"جَآءَهُمُ","translation":"এসেছিল তাদের (কাছে)","audioUrl":"wbw/003_105_009.mp3","charTypeName":"word"},{"id":72746,"position":10,"arabic":"ٱلْبَيِّنَـٰتُ ۚ","translation":"স্পষ্ট নিদর্শনসমূহ","audioUrl":"wbw/003_105_010.mp3","charTypeName":"word"},{"id":72748,"position":11,"arabic":"وَأُو۟لَـٰٓئِكَ","translation":"এবং ঐসব লোক","audioUrl":"wbw/003_105_012.mp3","charTypeName":"word"},{"id":72749,"position":12,"arabic":"لَهُمْ","translation":"তাদের জন্য (রয়েছে)","audioUrl":"wbw/003_105_013.mp3","charTypeName":"word"},{"id":72750,"position":13,"arabic":"عَذَابٌ","translation":"আযাব","audioUrl":"wbw/003_105_014.mp3","charTypeName":"word"},{"id":72751,"position":14,"arabic":"عَظِيمٌۭ","translation":"কঠিন","audioUrl":"wbw/003_105_015.mp3","charTypeName":"word"},{"id":72752,"position":15,"arabic":"١٠٥","translation":"(১০৫)","audioUrl":null,"charTypeName":"end"}]},{"number":106,"arabic":"يَوْمَ تَبْيَضُّ وُجُوهٌۭ وَتَسْوَدُّ وُجُوهٌۭ ۚ فَأَمَّا ٱلَّذِينَ ٱسْوَدَّتْ وُجُوهُهُمْ أَكَفَرْتُم بَعْدَ إِيمَٰنِكُمْ فَذُوقُوا۟ ٱلْعَذَابَ بِمَا كُنتُمْ تَكْفُرُونَ","translation":"on the Day [of Judgment] when some faces will shine [with happiness] and some faces will be dark [with grief]. And as for those with faces darkened, [they shall be told:] \"Did you deny the truth after having attained to faith? Taste, then, this suffering for having denied the truth!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/399.mp3","surahId":3,"words":[{"id":72951,"position":1,"arabic":"يَوْمَ","translation":"সে দিন","audioUrl":"wbw/003_106_001.mp3","charTypeName":"word"},{"id":72952,"position":2,"arabic":"تَبْيَضُّ","translation":"উজ্জ্বল হবে","audioUrl":"wbw/003_106_002.mp3","charTypeName":"word"},{"id":72953,"position":3,"arabic":"وُجُوهٌۭ","translation":"(অনেক) চেহারা","audioUrl":"wbw/003_106_003.mp3","charTypeName":"word"},{"id":72954,"position":4,"arabic":"وَتَسْوَدُّ","translation":"ও মলিন হবে","audioUrl":"wbw/003_106_004.mp3","charTypeName":"word"},{"id":72955,"position":5,"arabic":"وُجُوهٌۭ ۚ","translation":"(অনেক) চেহারা","audioUrl":"wbw/003_106_005.mp3","charTypeName":"word"},{"id":72957,"position":6,"arabic":"فَأَمَّا","translation":"অতঃপর","audioUrl":"wbw/003_106_007.mp3","charTypeName":"word"},{"id":72958,"position":7,"arabic":"ٱلَّذِينَ","translation":"যাদের","audioUrl":"wbw/003_106_008.mp3","charTypeName":"word"},{"id":72959,"position":8,"arabic":"ٱسْوَدَّتْ","translation":"মলিন হবে","audioUrl":"wbw/003_106_009.mp3","charTypeName":"word"},{"id":72960,"position":9,"arabic":"وُجُوهُهُمْ","translation":"তাদের চেহারা","audioUrl":"wbw/003_106_010.mp3","charTypeName":"word"},{"id":72961,"position":10,"arabic":"أَكَفَرْتُم","translation":"''(তাদের বলা হবে) তোমরা কুফরী করেছ কি","audioUrl":"wbw/003_106_011.mp3","charTypeName":"word"},{"id":72962,"position":11,"arabic":"بَعْدَ","translation":"পরেও","audioUrl":"wbw/003_106_012.mp3","charTypeName":"word"},{"id":72963,"position":12,"arabic":"إِيمَـٰنِكُمْ","translation":"তোমাদের ঈমানের","audioUrl":"wbw/003_106_013.mp3","charTypeName":"word"},{"id":72964,"position":13,"arabic":"فَذُوقُوا۟","translation":"তোমরা তাই স্বাদ গ্রহণ কর","audioUrl":"wbw/003_106_014.mp3","charTypeName":"word"},{"id":72965,"position":14,"arabic":"ٱلْعَذَابَ","translation":"আযাবের","audioUrl":"wbw/003_106_015.mp3","charTypeName":"word"},{"id":72966,"position":15,"arabic":"بِمَا","translation":"একারণে যা","audioUrl":"wbw/003_106_016.mp3","charTypeName":"word"},{"id":72967,"position":16,"arabic":"كُنتُمْ","translation":"করতেছিলে","audioUrl":"wbw/003_106_017.mp3","charTypeName":"word"},{"id":72968,"position":17,"arabic":"تَكْفُرُونَ","translation":"তোমরা কুফরী''","audioUrl":"wbw/003_106_018.mp3","charTypeName":"word"},{"id":72969,"position":18,"arabic":"١٠٦","translation":"(১০৬)","audioUrl":null,"charTypeName":"end"}]},{"number":107,"arabic":"وَأَمَّا ٱلَّذِينَ ٱبْيَضَّتْ وُجُوهُهُمْ فَفِى رَحْمَةِ ٱللَّهِ هُمْ فِيهَا خَٰلِدُونَ","translation":"But as for those with faces shining, they shall be within God's grace, therein to abide.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/400.mp3","surahId":3,"words":[{"id":73195,"position":1,"arabic":"وَأَمَّا","translation":"আর","audioUrl":"wbw/003_107_001.mp3","charTypeName":"word"},{"id":73196,"position":2,"arabic":"ٱلَّذِينَ","translation":"যাদের","audioUrl":"wbw/003_107_002.mp3","charTypeName":"word"},{"id":73197,"position":3,"arabic":"ٱبْيَضَّتْ","translation":"উজ্জ্বল হবে","audioUrl":"wbw/003_107_003.mp3","charTypeName":"word"},{"id":73198,"position":4,"arabic":"وُجُوهُهُمْ","translation":"তাদের চেহারা","audioUrl":"wbw/003_107_004.mp3","charTypeName":"word"},{"id":73199,"position":5,"arabic":"فَفِى","translation":"অতঃপর মধ্যে","audioUrl":"wbw/003_107_005.mp3","charTypeName":"word"},{"id":73200,"position":6,"arabic":"رَحْمَةِ","translation":"রহমতে","audioUrl":"wbw/003_107_006.mp3","charTypeName":"word"},{"id":73201,"position":7,"arabic":"ٱللَّهِ","translation":"আল্লাহর (আশ্রয় পাবে)","audioUrl":"wbw/003_107_007.mp3","charTypeName":"word"},{"id":73202,"position":8,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/003_107_008.mp3","charTypeName":"word"},{"id":73203,"position":9,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/003_107_009.mp3","charTypeName":"word"},{"id":73204,"position":10,"arabic":"خَـٰلِدُونَ","translation":"চিরস্থায়ী হবে","audioUrl":"wbw/003_107_010.mp3","charTypeName":"word"},{"id":73205,"position":11,"arabic":"١٠٧","translation":"(১০৭)","audioUrl":null,"charTypeName":"end"}]},{"number":108,"arabic":"تِلْكَ ءَايَٰتُ ٱللَّهِ نَتْلُوهَا عَلَيْكَ بِٱلْحَقِّ ۗ وَمَا ٱللَّهُ يُرِيدُ ظُلْمًۭا لِّلْعَٰلَمِينَ","translation":"These are God's mess