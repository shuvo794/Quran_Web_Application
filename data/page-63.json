{"id":63,"ayahs":[{"number":101,"arabic":"وَكَيْفَ تَكْفُرُونَ وَأَنتُمْ تُتْلَىٰ عَلَيْكُمْ ءَايَٰتُ ٱللَّهِ وَفِيكُمْ رَسُولُهُۥ ۗ وَمَن يَعْتَصِم بِٱللَّهِ فَقَدْ هُدِىَ إِلَىٰ صِرَٰطٍۢ مُّسْتَقِيمٍۢ","translation":"And how could you deny the truth when it is unto you that God's messages are being conveyed, and it is in your midst that His Apostle lives? But he who holds fast unto God has already been guided onto a straight way.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/394.mp3","surahId":3,"words":[{"id":71682,"position":1,"arabic":"وَكَيْفَ","translation":"এবং কিরূপে","audioUrl":"wbw/003_101_001.mp3","charTypeName":"word"},{"id":71683,"position":2,"arabic":"تَكْفُرُونَ","translation":"তোমরা অস্বীকার করলে","audioUrl":"wbw/003_101_002.mp3","charTypeName":"word"},{"id":71684,"position":3,"arabic":"وَأَنتُمْ","translation":"অথচ তোমরা (এমন যে)","audioUrl":"wbw/003_101_003.mp3","charTypeName":"word"},{"id":71685,"position":4,"arabic":"تُتْلَىٰ","translation":"পাঠ করা হয়","audioUrl":"wbw/003_101_004.mp3","charTypeName":"word"},{"id":71686,"position":5,"arabic":"عَلَيْكُمْ","translation":"তোমাদের নিকট","audioUrl":"wbw/003_101_005.mp3","charTypeName":"word"},{"id":71687,"position":6,"arabic":"ءَايَـٰتُ","translation":"আয়াত সমূহকে","audioUrl":"wbw/003_101_006.mp3","charTypeName":"word"},{"id":71688,"position":7,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌র","audioUrl":"wbw/003_101_007.mp3","charTypeName":"word"},{"id":71689,"position":8,"arabic":"وَفِيكُمْ","translation":"এবং তোমাদের মধ্যে (আছেন)","audioUrl":"wbw/003_101_008.mp3","charTypeName":"word"},{"id":71690,"position":9,"arabic":"رَسُولُهُۥ ۗ","translation":"তাঁর রাসূল","audioUrl":"wbw/003_101_009.mp3","charTypeName":"word"},{"id":71692,"position":10,"arabic":"وَمَن","translation":"এবং যে কেউ","audioUrl":"wbw/003_101_011.mp3","charTypeName":"word"},{"id":71693,"position":11,"arabic":"يَعْتَصِم","translation":"দৃঢ়ভাবে ধারণ করবে","audioUrl":"wbw/003_101_012.mp3","charTypeName":"word"},{"id":71694,"position":12,"arabic":"بِٱللَّهِ","translation":"আল্লাহর (রজ্জুকে)","audioUrl":"wbw/003_101_013.mp3","charTypeName":"word"},{"id":71695,"position":13,"arabic":"فَقَدْ","translation":"তাহলে নিশ্চয়","audioUrl":"wbw/003_101_014.mp3","charTypeName":"word"},{"id":71696,"position":14,"arabic":"هُدِىَ","translation":"সে পরিচালিত হবে","audioUrl":"wbw/003_101_015.mp3","charTypeName":"word"},{"id":71697,"position":15,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/003_101_016.mp3","charTypeName":"word"},{"id":71698,"position":16,"arabic":"صِرَٰطٍۢ","translation":"পথের","audioUrl":"wbw/003_101_017.mp3","charTypeName":"word"},{"id":71699,"position":17,"arabic":"مُّسْتَقِيمٍۢ","translation":"সরল সঠিক","audioUrl":"wbw/003_101_018.mp3","charTypeName":"word"},{"id":71700,"position":18,"arabic":"١٠١","translation":"(১০১)","audioUrl":null,"charTypeName":"end"}]},{"number":102,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ ٱتَّقُوا۟ ٱللَّهَ حَقَّ تُقَاتِهِۦ وَلَا تَمُوتُنَّ إِلَّا وَأَنتُم مُّسْلِمُونَ","translation":"O you who have attained to faith! Be conscious of God with all the consciousness that is due to Him, and do not allow death to overtake you ere you have surrendered yourselves unto Him.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/395.mp3","surahId":3,"words":[{"id":71910,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"ওহে","audioUrl":"wbw/003_102_001.mp3","charTypeName":"word"},{"id":71911,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/003_102_002.mp3","charTypeName":"word"},{"id":71912,"position":3,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/003_102_003.mp3","charTypeName":"word"},{"id":71913,"position":4,"arabic":"ٱتَّقُوا۟","translation":"তোমরা ভয় কর","audioUrl":"wbw/003_102_004.mp3","charTypeName":"word"},{"id":71914,"position":5,"arabic":"ٱللَّهَ","translation":"আল্লাহকে","audioUrl":"wbw/003_102_005.mp3","charTypeName":"word"},{"id":71915,"position":6,"arabic":"حَقَّ","translation":"যথোপযুক্ত","audioUrl":"wbw/003_102_006.mp3","charTypeName":"word"},{"id":71916,"position":7,"arabic":"تُقَاتِهِۦ","translation":"তাঁর ভয়","audioUrl":"wbw/003_102_007.mp3","charTypeName":"word"},{"id":71917,"position":8,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/003_102_008.mp3","charTypeName":"word"},{"id":71918,"position":9,"arabic":"تَمُوتُنَّ","translation":"তোমরা মৃত্যু বরণ করো","audioUrl":"wbw/003_102_009.mp3","charTypeName":"word"},{"id":71919,"position":10,"arabic":"إِلَّا","translation":"এছাড়া","audioUrl":"wbw/003_102_010.mp3","charTypeName":"word"},{"id":71920,"position":11,"arabic":"وَأَنتُم","translation":"যখন তোমরা","audioUrl":"wbw/003_102_011.mp3","charTypeName":"word"},{"id":71921,"position":12,"arabic":"مُّسْلِمُونَ","translation":"মুসলমান","audioUrl":"wbw/003_102_012.mp3","charTypeName":"word"},{"id":71922,"position":13,"arabic":"١٠٢","translation":"(১০২)","audioUrl":null,"charTypeName":"end"}]},{"number":103,"arabic":"وَٱعْتَصِمُوا۟ بِحَبْلِ ٱللَّهِ جَمِيعًۭا وَلَا تَفَرَّقُوا۟ ۚ وَٱذْكُرُوا۟ نِعْمَتَ ٱللَّهِ عَلَيْكُمْ إِذْ كُنتُمْ أَعْدَآءًۭ فَأَلَّفَ بَيْنَ قُلُوبِكُمْ فَأَصْبَحْتُم بِنِعْمَتِهِۦٓ إِخْوَٰنًۭا وَكُنتُمْ عَلَىٰ شَفَا حُفْرَةٍۢ مِّنَ ٱلنَّارِ فَأَنقَذَكُم مِّنْهَا ۗ كَذَٰلِكَ يُبَيِّنُ ٱللَّهُ لَكُمْ ءَايَٰتِهِۦ لَعَلَّكُمْ تَهْتَدُونَ","translation":"And hold fast, all together, unto the bond with God, and do not draw apart from one another. And remember the blessings which God has bestowed upon you: how, when you were enemies, He brought your hearts together, so that through His blessing you became brethren; and [how, when] you were on the brink of a fiery abyss. He saved you from it. In this way God makes clear His messages unto you, so that you might find guidance,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/396.mp3","surahId":3,"words":[{"id":72333,"position":1,"arabic":"وَٱعْتَصِمُوا۟","translation":"এবং তোমরা শক্ত ভাবে ধর","audioUrl":"wbw/003_103_001.mp3","charTypeName":"word"},{"id":72334,"positi