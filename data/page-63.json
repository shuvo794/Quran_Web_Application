ে গেলে","audioUrl":"wbw/003_103_018.mp3","charTypeName":"word"},{"id":72351,"position":18,"arabic":"بِنِعْمَتِهِۦٓ","translation":"তাঁর অনুগ্রহে","audioUrl":"wbw/003_103_019.mp3","charTypeName":"word"},{"id":72352,"position":19,"arabic":"إِخْوَٰنًۭا","translation":"ভাই ভাই","audioUrl":"wbw/003_103_020.mp3","charTypeName":"word"},{"id":72353,"position":20,"arabic":"وَكُنتُمْ","translation":"এবং তোমরা ছিলে","audioUrl":"wbw/003_103_021.mp3","charTypeName":"word"},{"id":72354,"position":21,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/003_103_022.mp3","charTypeName":"word"},{"id":72355,"position":22,"arabic":"شَفَا","translation":"কিনারার","audioUrl":"wbw/003_103_023.mp3","charTypeName":"word"},{"id":72356,"position":23,"arabic":"حُفْرَةٍۢ","translation":"গর্তের","audioUrl":"wbw/003_103_024.mp3","charTypeName":"word"},{"id":72357,"position":24,"arabic":"مِّنَ","translation":"(থেকে)","audioUrl":"wbw/003_103_025.mp3","charTypeName":"word"},{"id":72358,"position":25,"arabic":"ٱلنَّارِ","translation":"আগুনের","audioUrl":"wbw/003_103_026.mp3","charTypeName":"word"},{"id":72359,"position":26,"arabic":"فَأَنقَذَكُم","translation":"তোমাদের অতঃপর উদ্ধার করলেন","audioUrl":"wbw/003_103_027.mp3","charTypeName":"word"},{"id":72360,"position":27,"arabic":"مِّنْهَا ۗ","translation":"তা হতে","audioUrl":"wbw/003_103_028.mp3","charTypeName":"word"},{"id":72362,"position":28,"arabic":"كَذَٰلِكَ","translation":"এভাবে","audioUrl":"wbw/003_103_030.mp3","charTypeName":"word"},{"id":72363,"position":29,"arabic":"يُبَيِّنُ","translation":"বর্ণনা করেন","audioUrl":"wbw/003_103_031.mp3","charTypeName":"word"},{"id":72364,"position":30,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/003_103_032.mp3","charTypeName":"word"},{"id":72365,"position":31,"arabic":"لَكُمْ","translation":"তোমাদের জন্য","audioUrl":"wbw/003_103_033.mp3","charTypeName":"word"},{"id":72366,"position":32,"arabic":"ءَايَـٰتِهِۦ","translation":"তাঁর আয়াত সমূহকে","audioUrl":"wbw/003_103_034.mp3","charTypeName":"word"},{"id":72367,"position":33,"arabic":"لَعَلَّكُمْ","translation":"তোমরা যাতে","audioUrl":"wbw/003_103_035.mp3","charTypeName":"word"},{"id":72368,"position":34,"arabic":"تَهْتَدُونَ","translation":"সঠিক পথ পাও","audioUrl":"wbw/003_103_036.mp3","charTypeName":"word"},{"id":72369,"position":35,"arabic":"١٠٣","translation":"(১০৩)","audioUrl":null,"charTypeName":"end"}]},{"number":104,"arabic":"وَلْتَكُن مِّنكُمْ أُمَّةٌۭ يَدْعُونَ إِلَى ٱلْخَيْرِ وَيَأْمُرُونَ بِٱلْمَعْرُوفِ وَيَنْهَوْنَ عَنِ ٱلْمُنكَرِ ۚ وَأُو۟لَٰٓئِكَ هُمُ ٱلْمُفْلِحُونَ","translation":"and that there might grow out of you a community [of people] who invite unto all that is good, and enjoin the doing of what is right and forbid the doing of what is wrong: and it is they, they who shall attain to a happy state!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/397.mp3","surahId":3,"words":[{"id":72536,"position":1,"arabic":"وَلْتَكُن","translation":"এবং অবশ্যই থাকবে","audioUrl":"wbw/003_104_001.mp3","charTypeName":"word"},{"id":72537,"position":2,"arabic":"مِّنكُمْ","translation":"তোমাদের মধ্যে","audioUrl":"wbw/003_104_002.mp3","charTypeName":"word"},{"id":72538,"position":3,"arabic":"أُمَّةٌۭ","translation":"(এমন) একদল","audioUrl":"wbw/003_104_003.mp3","charTypeName":"word"},{"id":72539,"position":4,"arabic":"يَدْعُونَ","translation":"(যারা) ডাকবে","audioUrl":"wbw/003_104_004.mp3","charTypeName":"word"},{"id":72540,"position":5,"arabic":"إِلَى","translation":"দিকে","audioUrl":"wbw/003_104_005.mp3","charTypeName":"word"},{"id":72541,"position":6,"arabic":"ٱلْخَيْرِ","translation":"কল্যাণের","audioUrl":"wbw/003_104_006.mp3","charTypeName":"word"},{"id":72542,"position":7,"arabic":"وَيَأْمُرُونَ","translation":"ও তারা নির্দেশ দিবে","audioUrl":"wbw/003_104_007.mp3","charTypeName":"word"},{"id":72543,"position":8,"arabic":"بِٱلْمَعْرُوفِ","translation":"ভাল (কাজের)","audioUrl":"wbw/003_104_008.mp3","charTypeName":"word"},{"id":72544,"position":9,"arabic":"وَيَنْهَوْنَ","translation":"এবং