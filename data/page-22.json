{"id":22,"ayahs":[{"number":142,"arabic":"۞ سَيَقُولُ ٱلسُّفَهَآءُ مِنَ ٱلنَّاسِ مَا وَلَّىٰهُمْ عَن قِبْلَتِهِمُ ٱلَّتِى كَانُوا۟ عَلَيْهَا ۚ قُل لِّلَّهِ ٱلْمَشْرِقُ وَٱلْمَغْرِبُ ۚ يَهْدِى مَن يَشَآءُ إِلَىٰ صِرَٰطٍۢ مُّسْتَقِيمٍۢ","translation":"THE WEAK-MINDED among people will say, \"What has turned them away from the direction of prayer which they have hitherto observed?\" Say: \"God's is the east and the west; He guides whom He wills onto a straight way.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/149.mp3","surahId":2,"words":[{"id":79368,"position":1,"arabic":"۞ سَيَقُولُ","translation":"বলবে অচিরেই","audioUrl":"wbw/002_142_002.mp3","charTypeName":"word"},{"id":79369,"position":2,"arabic":"ٱلسُّفَهَآءُ","translation":"নির্বোধরা","audioUrl":"wbw/002_142_003.mp3","charTypeName":"word"},{"id":79370,"position":3,"arabic":"مِنَ","translation":"মধ্য হতে","audioUrl":"wbw/002_142_004.mp3","charTypeName":"word"},{"id":79371,"position":4,"arabic":"ٱلنَّاسِ","translation":"মানুষদের","audioUrl":"wbw/002_142_005.mp3","charTypeName":"word"},{"id":79372,"position":5,"arabic":"مَا","translation":"''কিসে","audioUrl":"wbw/002_142_006.mp3","charTypeName":"word"},{"id":79373,"position":6,"arabic":"وَلَّىٰهُمْ","translation":"তাদের মুখ ফিরাল","audioUrl":"wbw/002_142_007.mp3","charTypeName":"word"},{"id":79374,"position":7,"arabic":"عَن","translation":"হতে","audioUrl":"wbw/002_142_008.mp3","charTypeName":"word"},{"id":79375,"position":8,"arabic":"قِبْلَتِهِمُ","translation":"তাদের কিবলা","audioUrl":"wbw/002_142_009.mp3","charTypeName":"word"},{"id":79376,"position":9,"arabic":"ٱلَّتِى","translation":"সেই (কিবলা হতে)","audioUrl":"wbw/002_142_010.mp3","charTypeName":"word"},{"id":79377,"position":10,"arabic":"كَانُوا۟","translation":"তারা ছিল","audioUrl":"wbw/002_142_011.mp3","charTypeName":"word"},{"id":79378,"position":11,"arabic":"عَلَيْهَا ۚ","translation":"যার দিকে (মুখ করত)''","audioUrl":"wbw/002_142_012.mp3","charTypeName":"word"},{"id":79380,"position":12,"arabic":"قُل","translation":"বলো","audioUrl":"wbw/002_142_014.mp3","charTypeName":"word"},{"id":79381,"position":13,"arabic":"لِّلَّهِ","translation":"''আল্লাহরই","audioUrl":"wbw/002_142_015.mp3","charTypeName":"word"},{"id":79382,"position":14,"arabic":"ٱلْمَشْرِقُ","translation":"পূর্ব","audioUrl":"wbw/002_142_016.mp3","charTypeName":"word"},{"id":79383,"position":15,"arabic":"وَٱلْمَغْرِبُ ۚ","translation":"ও পশ্চিম","audioUrl":"wbw/002_142_017.mp3","charTypeName":"word"},{"id":79385,"position":16,"arabic":"يَهْدِى","translation":"তিনি পথ দেখান","audioUrl":"wbw/002_142_019.mp3","charTypeName":"word"},{"id":79386,"position":17,"arabic":"مَن","translation":"যাকে","audioUrl":"wbw/002_142_020.mp3","charTypeName":"word"},{"id":79387,"position":18,"arabic":"يَشَآءُ","translation":"তিনি চান","audioUrl":"wbw/002_142_021.mp3","charTypeName":"word"},{"id":79388,"position":19,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/002_142_022.mp3","charTypeName":"word"},{"id":79389,"position":20,"arabic":"صِرَٰطٍۢ","translation":"পথের","audioUrl":"wbw/002_142_023.mp3","charTypeName":"word"},{"id":79390,"position":21,"arabic":"مُّسْتَقِيمٍۢ","translation":"সরলসোজা''","audioUrl":"wbw/002_142_024.mp3","charTypeName":"word"},{"id":79391,"position":22,"arabic":"١٤٢","translation":"(১৪২)","audioUrl":null,"charTypeName":"end"}]},{"number":143,"arabic":"وَكَذَٰلِكَ جَعَلْنَٰكُمْ أُمَّةًۭ وَسَطًۭا لِّتَكُونُوا۟ شُهَدَآءَ عَلَى ٱلنَّاسِ وَيَكُونَ ٱلرَّسُولُ عَلَيْكُمْ شَهِيدًۭا ۗ وَمَا جَعَلْنَا ٱلْقِبْلَةَ ٱلَّتِى كُنتَ عَلَيْهَآ إِلَّا لِنَعْلَمَ مَن يَتَّبِعُ ٱلرَّسُولَ مِمَّن يَنقَلِبُ عَلَىٰ عَقِبَيْهِ ۚ وَإِن كَانَتْ لَكَبِيرَةً إِلَّا عَلَى ٱلَّذِينَ هَدَى ٱللَّهُ ۗ وَمَا كَانَ ٱللَّهُ لِيُضِيعَ إِيمَٰنَكُمْ ۚ إِنَّ ٱللَّهَ بِٱلنَّاسِ لَرَءُوفٌۭ رَّحِيمٌۭ","translation":"And thus have We willed you to be a community of the middle way, so that [with your lives] you might bear witness to the truth before all mankind, and that the Apostle might bear witness to it before you. And it is only to the end that We might make a clear distinction between those who follow the Apostle and those who turn about on their heels that We have appointed [for this community] the direction of prayer which thou [O Prophet] hast formerly observed: for this was indeed a hard test for all but those whom God has guided aright. But God will surely not lose sight of your faith-for, behold, God is most compassionate towards man, a dispenser of grace.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/150.mp3","surahId":2,"words":[{"id":79459,"position":1,"arabic":"وَكَذَٰلِكَ","translation":"এবং এভাবে","audioUrl":"wbw/002_143_001.mp3","charTypeName":"word"},{"id":79460,"position":2,"arabic":"جَعَلْنَـٰكُمْ","translation":"তোমাদের আমরা বানিয়েছি","audioUrl":"wbw/002_143_002.mp3","charTypeName":"word"},{"id":79461,"position":3,"arabic":"أُمَّةًۭ","translation":"একটি জাতি","audioUrl":"wbw/002_143_003.mp3","charTypeName":"word"},{"id":79462,"position":4,"arabic":"وَسَطًۭا","translation":"মধ্যমপন্থী","audioUrl":"wbw/002_143_004.mp3","charTypeName":"word"},{"id":79463,"position":5,"arabic":"لِّتَكُونُوا۟","translation":"তোমরা হও যেন","audioUrl":"wbw/002_143_005.mp3","charTypeName":"word"},{"id":79464,"position":6,"arabic":"شُهَدَآءَ","translation":"সাক্ষী","audioUrl":"wbw/002_143_006.mp3","charTypeName":"word"},{"id":79465,"position":7,"arabic":"عَلَى","translation":"উপর(জন্য)","audioUrl":"wbw/002_143_007.mp3","charTypeName":"word"},{"id":79466,"position":8,"arabic":"ٱلنَّاسِ","translation":"(পৃথিবীর) মানুষের","audioUrl":"wbw/002_143_008.mp3","charTypeName":"word"},{"id":79467,"position":9,"arabic":"وَيَكُونَ","translation":"ও হয়","audioUrl":"wbw/002_143_009.mp3","charTypeName":"word"},{"id":79468,"position":10,"arabic":"ٱلرَّسُولُ","translation":"রাসূল","audioUrl":"wbw/002_143_010.mp3","charTypeName":"word"},{"id":79469,"position":11,"arabic":"عَلَيْكُمْ","translation":"তোমাদের উপর(জন্য)","audioUrl":"wbw/002_143_011.mp3","charTypeName":"word"},{"id":79470,"position":12,"arabic":"شَهِيدًۭا ۗ","translation":"সাক্ষী","audioUrl":"wbw/002_143_012.mp3","charTypeName":"word"},{"id":79472,"position":13,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/002_143_014.mp3","charTypeName":"word"},{"id":79473,"position":14,"arabic":"جَعَلْنَا","translation":"আমরা বানিয়েছিলাম","audioUrl":"wbw/002_143_015.mp3","charTypeName":"word"},{"id":79474,"position":15,"arabic":"ٱلْقِبْلَةَ","translation":"কিবলা","audioUrl":"wbw/002_143_016.mp3","charTypeName":"word"},{"id":79475,"position":16,"arabic":"ٱلَّتِى","translation":"সেটাকে","audioUrl":"wbw/002_143_017.mp3","charTypeName":"word"},{"id":79476,"position":17,"arabic":"كُنتَ","translation":"তুমি ছিলে","audioUrl":"wbw/002_143_018.mp3","charTypeName":"word"},{"id":79477,"position":18,"arabic":"عَلَيْهَآ","translation":"যার উপর","audioUrl":"wbw/002_143_019.mp3","charTypeName":"word"},{"id":79478,"position":19,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/002_143_020.mp3","charTypeName":"word"},{"id":79479,"position":20,"arabic":"لِنَعْلَمَ","translation":"আমরা যেন জানতে পারি","audioUrl":"wbw/002_143_021.mp3","charTypeName":"word"},{"id":79480,"position":21,"arabic":"مَن","translation":"কে","audioUrl":"wbw/002_143_022.mp3","charTypeName":"word"},{"id":79481,"position":22,"arabic":"يَتَّبِعُ","translation":"অনুসরণ করে","audioUrl":"wbw/002_143_023.mp3","charTypeName":"word"},{"id":79482,"position":23,"arabic":"ٱلرَّسُولَ","translation":"রাসূলকে (আর)","audioUrl":"wbw/002_143_024.mp3","charTypeName":"word"},{"id":79483,"position":24,"arabic":"مِمَّن","translation":"কে তাদের মধ্য হতে","audioUrl":"wbw/002_143_025.mp3","charTypeName":"word"},{"id":79484,"position":25,"arabic":"يَنقَلِبُ","translation":"ফিরে যায়","audioUrl":"wbw/002_143_026.mp3","charTypeName":"word"},{"id":79485,"position":26,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/002_143_027.mp3","charTypeName":"word"},{"id":79486,"position":27,"arabic":"عَقِبَيْهِ ۚ","translation":"তার দুই গোড়ালির (অর্থাৎ