d":79505,"position":43,"arabic":"بِٱلنَّاسِ","translation":"মানুষের উপর","audioUrl":"wbw/002_143_047.mp3","charTypeName":"word"},{"id":79506,"position":44,"arabic":"لَرَءُوفٌۭ","translation":"বড়ই দয়ালু","audioUrl":"wbw/002_143_048.mp3","charTypeName":"word"},{"id":79507,"position":45,"arabic":"رَّحِيمٌۭ","translation":"পরম দয়ালু","audioUrl":"wbw/002_143_049.mp3","charTypeName":"word"},{"id":79508,"position":46,"arabic":"١٤٣","translation":"(১৪৩)","audioUrl":null,"charTypeName":"end"}]},{"number":144,"arabic":"قَدْ نَرَىٰ تَقَلُّبَ وَجْهِكَ فِى ٱلسَّمَآءِ ۖ فَلَنُوَلِّيَنَّكَ قِبْلَةًۭ تَرْضَىٰهَا ۚ فَوَلِّ وَجْهَكَ شَطْرَ ٱلْمَسْجِدِ ٱلْحَرَامِ ۚ وَحَيْثُ مَا كُنتُمْ فَوَلُّوا۟ وُجُوهَكُمْ شَطْرَهُۥ ۗ وَإِنَّ ٱلَّذِينَ أُوتُوا۟ ٱلْكِتَٰبَ لَيَعْلَمُونَ أَنَّهُ ٱلْحَقُّ مِن رَّبِّهِمْ ۗ وَمَا ٱللَّهُ بِغَٰفِلٍ عَمَّا يَعْمَلُونَ","translation":"We have seen thee [O Prophet] often turn thy face towards heaven [for guidance]: and now We shall indeed make thee turn in prayer in a direction which will fulfil thy desire. Turn, then, thy face towards the Inviolable House of Worship; and wherever you all may be, turn your faces towards it [in prayer]. And, verily, those who have been vouchsafed revelation aforetime know well that this [commandment] comes in truth from their Sustainer; and God is not unaware of what they do.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/151.mp3","surahId":2,"words":[{"id":79706,"position":1,"arabic":"قَدْ","translation":"অবশ্যই","audioUrl":"wbw/002_144_001.mp3","charTypeName":"word"},{"id":79707,"position":2,"arabic":"نَرَىٰ","translation":"দেখেছি আমরা","audioUrl":"wbw/002_144_002.mp3","charTypeName":"word"},{"id":79708,"position":3,"arabic":"تَقَلُّبَ","translation":"বার বার ফিরাতে","audioUrl":"wbw/002_144_003.mp3","charTypeName":"word"},{"id":79709,"position":4,"arabic":"وَجْهِكَ","translation":"তোমার মুখ","audioUrl":"wbw/002_144_004.mp3","charTypeName":"word"},{"id":79710,"position":5,"arabic":"فِى","translation":"দিকে","audioUrl":"wbw/002_144_005.mp3","charTypeName":"word"},{"id":79711,"position":6,"arabic":"ٱلسَّمَآءِ ۖ","translation":"আকাশের","audioUrl":"wbw/002_144_006.mp3","charTypeName":"word"},{"id":79713,"position":7,"arabic":"فَلَنُوَلِّيَنَّكَ","translation":"তাই তোমাকে আমরা ঘুরিয়ে দিচ্ছি","audioUrl":"wbw/002_144_008.mp3","charTypeName":"word"},{"id":79714,"position":8,"arabic":"قِبْلَةًۭ","translation":"কিবলার (দিকে)","audioUrl":"wbw/002_144_009.mp3","charTypeName":"word"},{"id":79715,"position":9,"arabic":"تَرْضَىٰهَا ۚ","translation":"যা পছন্দ কর তুমি","audioUrl":"wbw/002_144_010.mp3","charTypeName":"word"},{"id":79717,"position":10,"arabic":"فَوَلِّ","translation":"ফিরাও তাই","audioUrl":"wbw/002_144_012.mp3","charTypeName":"word"},{"id":79718,"position":11,"arabic":"وَجْهَكَ","translation":"তোমার মুখ","audioUrl":"wbw/002_144_013.mp3","charTypeName":"word"},{"id":79719,"position":12,"arabic":"شَطْرَ","translation":"দিকে","audioUrl":"wbw/002_144_014.mp3","charTypeName":"word"},{"id":79720,"position":13,"arabic":"ٱلْمَسْجِدِ","translation":"মাসজিদে","audioUrl":"wbw/002_144_015.mp3","charTypeName":"word"},{"id":79721,"position":14,"arabic":"ٱلْحَرَامِ ۚ","translation":"হারামের","audioUrl":"wbw/002_144_016.mp3","charTypeName":"word"},{"id":79723,"position":15,"arabic":"وَحَيْثُ","translation":"এবং যেখানেই","audioUrl":"wbw/002_144_018.mp3","charTypeName":"word"},{"id":79724,"position":16,"arabic":"مَا","translation":"(কি)","audioUrl":"wbw/002_144_019.mp3","charTypeName":"word"},{"id":79725,"position":17,"arabic":"كُنتُمْ","translation":"তোমরা থাক","audioUrl":"wbw/002_144_020.mp3","charTypeName":"word"},{"id":79726,"position":18,"arabic":"فَوَلُّوا۟","translation":"ফিরাও তখন তোমরা","audioUrl":"wbw/002_144_021.mp3","charTypeName":"word"},{"id":79727,"position":19,"arabic":"وُجُوهَكُمْ","translation":"তোমাদের মুখ","audioUrl":"wbw/002_144_022.mp3","charTypeName":"word"},{"id":79728,"position":20,"arabic":"شَطْرَهُۥ ۗ","translation":"তার দিকে","audioUrl":"wbw/002_144_023.mp3","charTypeName":"word"},{"id":79730,"position":21,"arabic":"وَإِنَّ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/002_144_025.mp3","charTypeName":"word"},{"id":79731,"position":22,"arabic":"ٱلَّذِينَ","translation":"যাদের","audioUrl":"wbw/002_144_026.mp3","charTypeName":"word"},{"id":79732,"position":23,"arabic":"أُوتُوا۟","translation":"দেয়া হয়েছ","audioUrl":"wbw/002_144_027.mp3","charTypeName":"word"},{"id":79733,"position":24,"arabic":"ٱلْكِتَـٰبَ","translation":"কিতাব","audioUrl":"wbw/002_144_028.mp3","charTypeName":"word"},{"id":79734,"position":25,"arabic":"لَيَعْلَمُونَ","translation":"তারা জানে অবশ্যই","audioUrl":"wbw/002_144_029.mp3","charTypeName":"word"},{"id":79735,"position":26,"arabic":"أَنَّهُ","translation":"তা যে","audioUrl":"wbw/002_144_030.mp3","charTypeName":"word"},{"id":79736,"position":27,"arabic":"ٱلْحَقُّ","translation":"সত্য","audioUrl":"wbw/002_144_031.mp3","charTypeName":"word"},{"id":79737,"position":28,"arabic":"مِن","translation":"পক্ষ হতে","audioUrl":"wbw/002_144_032.mp3","charTypeName":"word"},{"id":79738,"position":29,"arabic":"رَّبِّهِمْ ۗ","translation":"তার রবের","audioUrl":"wbw/002_144_033.mp3","charTypeName":"word"},{"id":79740,"position":30,"arabic":"وَمَا","translation":"এবং নন","audioUrl":"wbw/002_144_035.mp3","charTypeName":"word"},{"id":79741,"position":31,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌","audioUrl":"wbw/002_144_036.mp3","charTypeName":"word"},{"id":79742,"position":32,"arabic":"بِغَـٰفِلٍ","translation":"উদাসীন","audioUrl":"wbw/002_144_037.mp3","charTypeName":"word"},{"id":79743,"position":33,"arabic":"عَمَّا","translation":"সে সমন্ধে যা","audioUrl":"wbw/002_144_038.mp3","charTypeName":"word"},{"id":79744,"position":34,"arabic":"يَعْمَلُونَ","translation":"তারা করছে","audioUrl":"wbw/002_144_039.mp3","charTypeName":"word"},{"id":79745,"position":35,"arabic":"١٤٤","translation":"(১৪৪)","audioUrl":null,"charTypeName":"end"}]},{"number":145,"arabic":"وَلَئِنْ أَتَيْتَ ٱلَّذِينَ أُوتُوا۟ ٱلْكِتَٰبَ بِكُلِّ ءَايَةٍۢ مَّا تَبِعُوا۟ قِبْلَتَكَ ۚ وَمَآ أَنتَ بِتَابِعٍۢ قِبْلَتَهُمْ ۚ وَمَا بَعْضُهُم بِتَابِعٍۢ قِبْلَةَ بَعْضٍۢ ۚ وَلَئِنِ ٱتَّبَعْتَ أَهْوَآءَهُم مِّنۢ بَعْدِ مَا جَآءَكَ مِنَ ٱلْعِلْمِ ۙ إِنَّكَ إِذًۭا لَّمِنَ ٱلظَّٰلِمِينَ","translation":"And yet, even if thou wert to place all evidence before those who have been vouchsafed earlier revelation, they would not follow thy direction of prayer; and neither mayest thou follow their direction of prayer, nor even do they follow one another's direction. And if thou shouldst follow their errant views after all the knowledge that has come unto thee thou wouldst surely be among the evildoers.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/152.mp3","surahId":2,"words":[{"id":79792,"position":1,"arabic":"وَلَئِنْ","translation":"এবং অবশ্যই যদি","audioUrl":"wbw/002_145_001.mp3","charTypeName":"word"},{"id":79793,"position":2,"arabic":"أَتَيْتَ","translation":"তুমি আস","audioUrl":"wbw/002_145_002.mp3","charTypeName":"word"},{"id":79794,"position":3,"arabic":"ٱلَّذِينَ","translation":"(তাদেরকে) যাদের","audioUrl":"wbw/002_145_003.mp3","charTypeName":"word"},{"id":79795,"position":4,"arabic":"أُوتُوا۟","translation":"দেয়া হয়েছে","audioUrl":"wbw/002_145_004.mp3","charTypeName":"word"},{"id":79796,"position":5,"arabic":"ٱلْكِتَـٰبَ","translation":"কিতাব","audioUrl":"wbw/002_145_005.mp3","charTypeName":"word"},{"id":79797,"position":6,"arabic":"بِكُلِّ","translation":"সব নিয়ে","audioUrl":"wbw/002_145_006.mp3","charTypeName":"word"},{"id":79798,"position":7,"arabic":"ءَايَةٍۢ","translation":"নিদর্শন","audioUrl":"wbw/002_145_007.mp3","charTypeName":"word"},{"id":79799,"position":8,"arabic":"مَّا","translation":"(তবুও) না","audioUrl":"wbw/002_145_008.mp3","charTypeName":"word"},{"id":79800,"position":9,"arabic":"تَبِعُوا۟","translation":"অনুসরণ করবে তারা","audioUrl":"wbw/002_145_009.mp3","charTypeName":"word"},{"id":79801,"position":10,"arabic":"قِبْلَتَكَ ۚ","translation":"তোমার কিবলার","audioUrl":"wbw/002_145_010.mp3","charTypeName":"word"},{"id":79803,"position":11,"arabic":"وَمَآ","translation":"এবং নও","audioUrl":"wbw/002_145_012.mp3","charTypeName":"word"},{"id":79804,"position":12,"arabic":"أَنتَ","translation":"তুমি","audioUrl":"wbw/002_145_013.mp3","charTypeName":"word"},{"id":79805,"position":13,"arabic":"بِتَابِعٍۢ","translation":"অনুসারী","audioUrl":"wbw/002_145_014.mp3","charTypeName":"word"},{"id":79806,"position":14,"arabic":"قِبْلَتَهُمْ ۚ","translation":"তাদের কিবলার","audioUrl":"wbw/002_145_015.mp3","charTypeName":"word"},{"id":79808,"position":15,"arabic":"وَمَا","translation":"এবং নয়","audioUrl":"wbw/002_145_017.mp3","charTypeName":"word"},{"id":79809,"position":16,"arabic":"بَعْضُهُم","translation":"তাদের কেউ","audioUrl":"wbw/002_145_018.mp3","charTypeName":"word"},{"id":79810,"position":17,"arabic":"بِتَابِعٍۢ","translation":"অনুসারী","audioUrl":"wbw/002_145_019.mp3","charTypeName":"word"},{"id":79811,"position":18,"arabic":"قِبْلَةَ","translation":"কিবলার","audioUrl":"wbw/002_145_020.mp3","charTypeName":"word"},{"id":79812,"position":19,"arabic":"بَعْضٍۢ ۚ","translation":"কারোর","audioUrl":"wbw/002_145_021.mp3","charTypeName":"word"},{"id":79814,"position":20,"arabic":"وَلَئِنِ","translation":"এবং অবশ্যই যদি","audioUrl":"wbw/002_145_023.mp3","charTypeName":"word"},{"id":79815,"position":21,"arabic":"ٱتَّبَعْتَ","translation":"তুমি অনুসরণ কর","audioUrl":"wbw/002_145_024.mp3","charTypeName":"word"},{"id":79816,"position":22,"arabic":"أَهْوَآءَهُم","translation":"তাদের খেয়াল খুশির","audioUrl":"wbw/002_145_025.mp3","charTypeName":"word"},{"id":79817,"position":23,"arabic":"مِّنۢ","translation":"থেকে","audioUrl":"wbw/002_145_026.mp3","charTypeName":"word"},{"id":79818,"position":24,"arabic":"بَعْدِ","translation":"এর পরও","audioUrl":"wbw/002_145_027.mp3","charTypeName":"word"},{"id":79819,"position":25,"arabic":"مَا","translation":"যা","audioUrl":"wbw/002_145_028.mp3","charTypeName":"word"},{"id":79820,"position":26,"arabic":"جَآءَكَ","translation":"তোমার কাছে