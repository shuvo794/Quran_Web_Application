word"},{"id":14089,"position":11,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/022_012_012.mp3","charTypeName":"word"},{"id":14090,"position":12,"arabic":"هُوَ","translation":"সেই","audioUrl":"wbw/022_012_013.mp3","charTypeName":"word"},{"id":14091,"position":13,"arabic":"ٱلضَّلَـٰلُ","translation":"পথভ্রষ্টতা","audioUrl":"wbw/022_012_014.mp3","charTypeName":"word"},{"id":14092,"position":14,"arabic":"ٱلْبَعِيدُ","translation":"সুদূর (চরম)","audioUrl":"wbw/022_012_015.mp3","charTypeName":"word"},{"id":14093,"position":15,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]},{"number":13,"arabic":"يَدْعُوا۟ لَمَن ضَرُّهُۥٓ أَقْرَبُ مِن نَّفْعِهِۦ ۚ لَبِئْسَ ٱلْمَوْلَىٰ وَلَبِئْسَ ٱلْعَشِيرُ","translation":"[And sometimes] he invokes [another human being] one that is far more likely to cause harm than benefit: vile, indeed, is such a patron and vile the follower!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2608.mp3","surahId":22,"words":[{"id":15201,"position":1,"arabic":"يَدْعُوا۟","translation":"তারা ডাকে","audioUrl":"wbw/022_013_001.mp3","charTypeName":"word"},{"id":15202,"position":2,"arabic":"لَمَن","translation":"অবশ্যই এমন কিছুকে","audioUrl":"wbw/022_013_002.mp3","charTypeName":"word"},{"id":15203,"position":3,"arabic":"ضَرُّهُۥٓ","translation":"যার ক্ষতি","audioUrl":"wbw/022_013_003.mp3","charTypeName":"word"},{"id":15204,"position":4,"arabic":"أَقْرَبُ","translation":"নিকটতর অধিকতর","audioUrl":"wbw/022_013_004.mp3","charTypeName":"word"},{"id":15205,"position":5,"arabic":"مِن","translation":"অপেক্ষা","audioUrl":"wbw/022_013_005.mp3","charTypeName":"word"},{"id":15206,"position":6,"arabic":"نَّفْعِهِۦ ۚ","translation":"তার উপকারিতা","audioUrl":"wbw/022_013_006.mp3","charTypeName":"word"},{"id":15208,"position":7,"arabic":"لَبِئْسَ","translation":"অবশ্যই কত নিকৃষ্ট","audioUrl":"wbw/022_013_008.mp3","charTypeName":"word"},{"id":15209,"position":8,"arabic":"ٱلْمَوْلَىٰ","translation":"অভিভাবক","audioUrl":"wbw/022_013_009.mp3","charTypeName":"word"},{"id":15210,"position":9,"arabic":"وَلَبِئْسَ","translation":"আর অবশ্যই কত নিকৃষ্ট","audioUrl":"wbw/022_013_010.mp3","charTypeName":"word"},{"id":15211,"position":10,"arabic":"ٱلْعَشِيرُ","translation":"সঙ্গী","audioUrl":"wbw/022_013_011.mp3","charTypeName":"word"},{"id":15212,"position":11,"arabic":"١٣","translation":"(১৩)","audioUrl":null,"charTypeName":"end"}]},{"number":14,"arabic":"إِنَّ ٱللَّهَ يُدْخِلُ ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ جَنَّٰتٍۢ تَجْرِى مِن تَحْتِهَا ٱلْأَنْهَٰرُ ۚ إِنَّ ٱللَّهَ يَفْعَلُ مَا يُرِيدُ","translation":"VERILY, God will admit those who have attained to faith and have done righteous deeds into gardens through which running waters flow: for, behold, God does whatever He wills.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2609.mp3","surahId":22,"words":[{"id":16230,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/022_014_001.mp3","charTypeName":"word"},{"id":16231,"position":2,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/022_014_002.mp3","charTypeName":"word"},{"id":16232,"position":3,"arabic":"يُدْخِلُ","translation":"প্রবেশ করাবেন","audioUrl":"wbw/022_014_003.mp3","charTypeName":"word"},{"id":16233,"position":4,"arabic":"ٱلَّذِينَ","translation":"(তাদেরকে) যারা","audioUrl":"wbw/022_014_004.mp3","charTypeName":"word"},{"id":16234,"position":5,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/022_014_005.mp3","charTypeName":"word"},{"id":16235,"position":6,"arabic":"وَعَمِلُوا۟","translation":"ও কাজ করেছে","audioUrl":"wbw/022_014_006.mp3","charTypeName":"word"},{"id":16236,"position":7,"arabic":"ٱلصَّـٰلِحَـٰتِ","translation":"সৎকাজসমূহের","audioUrl":"wbw/022_014_007.mp3","charTypeName":"word"},{"id":16237,"position":8,"arabic":"جَنَّـٰتٍۢ","translation":"(এমন) জান্নাতে","audioUrl":"wbw/022_014_008.mp3","charTypeName":"word"},{"id":16238,"position":9,"arabic":"تَجْرِى","translation":"প্রবাহিত হয়","audioUrl":"wbw/02