wbw/022_007_012.mp3","charTypeName":"word"},{"id":7875,"position":13,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"وَمِنَ ٱلنَّاسِ مَن يُجَٰدِلُ فِى ٱللَّهِ بِغَيْرِ عِلْمٍۢ وَلَا هُدًۭى وَلَا كِتَٰبٍۢ مُّنِيرٍۢ","translation":"And yet, among men there is many a one that argues about God without having any knowledge [of Him], without any guidance, and without any light-giving revelation –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2603.mp3","surahId":22,"words":[{"id":9053,"position":1,"arabic":"وَمِنَ","translation":"এবং কেউ কেউ (মধ্য হ'তে)","audioUrl":"wbw/022_008_001.mp3","charTypeName":"word"},{"id":9054,"position":2,"arabic":"ٱلنَّاسِ","translation":"লোকদের","audioUrl":"wbw/022_008_002.mp3","charTypeName":"word"},{"id":9055,"position":3,"arabic":"مَن","translation":"যে","audioUrl":"wbw/022_008_003.mp3","charTypeName":"word"},{"id":9056,"position":4,"arabic":"يُجَـٰدِلُ","translation":"ঝগড়া করে","audioUrl":"wbw/022_008_004.mp3","charTypeName":"word"},{"id":9057,"position":5,"arabic":"فِى","translation":"সম্বন্ধে","audioUrl":"wbw/022_008_005.mp3","charTypeName":"word"},{"id":9058,"position":6,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/022_008_006.mp3","charTypeName":"word"},{"id":9059,"position":7,"arabic":"بِغَيْرِ","translation":"ছাড়াই","audioUrl":"wbw/022_008_007.mp3","charTypeName":"word"},{"id":9060,"position":8,"arabic":"عِلْمٍۢ","translation":"কোন জ্ঞান","audioUrl":"wbw/022_008_008.mp3","charTypeName":"word"},{"id":9061,"position":9,"arabic":"وَلَا","translation":"এবং না (আছে)","audioUrl":"wbw/022_008_009.mp3","charTypeName":"word"},{"id":9062,"position":10,"arabic":"هُدًۭى","translation":"(তাদের কাছে) পথ নির্দেশনা","audioUrl":"wbw/022_008_010.mp3","charTypeName":"word"},{"id":9063,"position":11,"arabic":"وَلَا","translation":"আর না (আছে)","audioUrl":"wbw/022_008_011.mp3","charTypeName":"word"},{"id":9064,"position":12,"arabic":"كِتَـٰبٍۢ","translation":"কিতাব","audioU