anslation":"ধারণা করতো","audioUrl":"wbw/022_015_003.mp3","charTypeName":"word"},{"id":17408,"position":4,"arabic":"أَن","translation":"যে","audioUrl":"wbw/022_015_004.mp3","charTypeName":"word"},{"id":17409,"position":5,"arabic":"لَّن","translation":"কখনও না","audioUrl":"wbw/022_015_005.mp3","charTypeName":"word"},{"id":17410,"position":6,"arabic":"يَنصُرَهُ","translation":"তাকে (রাসূল সাল্লাল্লাহু 'আলাইহি ওয়া সাল্লাম-কে) সাহায্য করবেন","audioUrl":"wbw/022_015_006.mp3","charTypeName":"word"},{"id":17411,"position":7,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/022_015_007.mp3","charTypeName":"word"},{"id":17412,"position":8,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/022_015_008.mp3","charTypeName":"word"},{"id":17413,"position":9,"arabic":"ٱلدُّنْيَا","translation":"দুনিয়ার","audioUrl":"wbw/022_015_009.mp3","charTypeName":"word"},{"id":17414,"position":10,"arabic":"وَٱلْـَٔاخِرَةِ","translation":"ও আখিরাতে","audioUrl":"wbw/022_015_010.mp3","charTypeName":"word"},{"id":17415,"position":11,"arabic":"فَلْيَمْدُدْ","translation":"তাহ'লে সে লম্বা করুক","audioUrl":"wbw/022_015_011.mp3","charTypeName":"word"},{"id":17416,"position":12,"arabic":"بِسَبَبٍ","translation":"নিয়ে একটি রশিকে","audioUrl":"wbw/022_015_012.mp3","charTypeName":"word"},{"id":17417,"position":13,"arabic":"إِلَى","translation":"পর্যন্ত","audioUrl":"wbw/022_015_013.mp3","charTypeName":"word"},{"id":17418,"position":14,"arabic":"ٱلسَّمَآءِ","translation":"আকাশ","audioUrl":"wbw/022_015_014.mp3","charTypeName":"word"},{"id":17419,"position":15,"arabic":"ثُمَّ","translation":"এরপর (সেখানে পৌঁছে)","audioUrl":"wbw/022_015_015.mp3","charTypeName":"word"},{"id":17420,"position":16,"arabic":"لْيَقْطَعْ","translation":"যেন তা কেটে দেয় (ওহীর ধারা)","audioUrl":"wbw/022_015_016.mp3","charTypeName":"word"},{"id":17421,"position":17,"arabic":"فَلْيَنظُرْ","translation":"অতঃপর দেখুক","audioUrl":"wbw/022_015_017.mp3","charTypeName":"word"},{"id":17422,"position":18,"arabic":"هَلْ","translation":"