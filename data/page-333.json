p3","charTypeName":"word"},{"id":10271,"position":11,"arabic":"وَنُذِيقُهُۥ","translation":"আর তাকে আস্বাদন করাবো আমরা","audioUrl":"wbw/022_009_013.mp3","charTypeName":"word"},{"id":10272,"position":12,"arabic":"يَوْمَ","translation":"দিনে","audioUrl":"wbw/022_009_014.mp3","charTypeName":"word"},{"id":10273,"position":13,"arabic":"ٱلْقِيَـٰمَةِ","translation":"ক্বিয়ামাতের","audioUrl":"wbw/022_009_015.mp3","charTypeName":"word"},{"id":10274,"position":14,"arabic":"عَذَابَ","translation":"শাস্তি","audioUrl":"wbw/022_009_016.mp3","charTypeName":"word"},{"id":10275,"position":15,"arabic":"ٱلْحَرِيقِ","translation":"দহনের","audioUrl":"wbw/022_009_017.mp3","charTypeName":"word"},{"id":10276,"position":16,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"ذَٰلِكَ بِمَا قَدَّمَتْ يَدَاكَ وَأَنَّ ٱللَّهَ لَيْسَ بِظَلَّٰمٍۢ لِّلْعَبِيدِ","translation":"[and he shall be told:] “This is an outcome of what thine own hands have wrought - for, never does God do the least wrong to His creatures!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2605.mp3","surahId":22,"words":[{"id":11509,"position":1,"arabic":"ذَٰلِكَ","translation":"(বলা হবে) এটা","audioUrl":"wbw/022_010_001.mp3","charTypeName":"word"},{"id":11510,"position":2,"arabic":"بِمَا","translation":"এ কারণে যা","audioUrl":"wbw/022_010_002.mp3","charTypeName":"word"},{"id":11511,"position":3,"arabic":"قَدَّمَتْ","translation":"আগে পাঠিয়েছে","audioUrl":"wbw/022_010_003.mp3","charTypeName":"word"},{"id":11512,"position":4,"arabic":"يَدَاكَ","translation":"তোমার হাত","audioUrl":"wbw/022_010_004.mp3","charTypeName":"word"},{"id":11513,"position":5,"arabic":"وَأَنَّ","translation":"এবং (এও) যে","audioUrl":"wbw/022_010_005.mp3","charTypeName":"word"},{"id":11514,"position":6,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/022_010_006.mp3","charTypeName":"word"},{"id":11515,"position":7,"arabic":"لَيْسَ","translation":"নন","audioUrl":"wbw/022_010_007.mp3","charTypeName":"word"},{"id":11516,"position":8,"arabic":"بِظَلَّـٰمٍۢ","translation":"অত্যাচারী","audioUrl":"wbw/022_010_008.mp3","charTypeName":"word"},{"id":11517,"position":9,"arabic":"لِّلْعَبِيدِ","translation":"দাসদের প্রতি","audioUrl":"wbw/022_010_009.mp3","charTypeName":"word"},{"id":11518,"position":10,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"وَمِنَ ٱلنَّاسِ مَن يَعْبُدُ ٱللَّهَ عَلَىٰ حَرْفٍۢ ۖ فَإِنْ أَصَابَهُۥ خَيْرٌ ٱطْمَأَنَّ بِهِۦ ۖ وَإِنْ أَصَابَتْهُ فِتْنَةٌ ٱنقَلَبَ عَلَىٰ وَجْهِهِۦ خَسِرَ ٱلدُّنْيَا وَٱلْءَاخِرَةَ ۚ ذَٰلِكَ هُوَ ٱلْخُسْرَانُ ٱلْمُبِينُ","translation":"And there is, too, among men many a one who worships God on the border-line [of faith]: thus, if good befalls him, he is satisfied with Him; but if a trial assails him, he turns away utterly, losing [thereby both] this world and the life to come: [and] this, indeed, is a loss beyond compare!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2606.mp3","surahId":22,"words":[{"id":12801,"position":1,"arabic":"وَمِنَ","translation":"এবং কেউ কেউ (মধ্য হ'তে)","audioUrl":"wbw/022_011_001.mp3","charTypeName":"word"},{"id":12802,"position":2,"arabic":"ٱلنَّاسِ","translation":"লোকদের","audioUrl":"wbw/022_011_002.mp3","charTypeName":"word"},{"id":12803,"position":3,"arabic":"مَن","translation":"যে","audioUrl":"wbw/022_011_003.mp3","charTypeName":"word"},{"id":12804,"position":4,"arabic":"يَعْبُدُ","translation":"ইবাদাত করে","audioUrl":"wbw/022_011_004.mp3","charTypeName":"word"},{"id":12805,"position":5,"arabic":"ٱللَّهَ","translation":"আল্লাহর","audioUrl":"wbw/022_011_005.mp3","charTypeName":"word"},{"id":12806,"position":6,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/022_011_006.mp3","charTypeName":"word"},{"id":12807,"position":7,"arabic":"حَرْفٍۢ ۖ","translation":"এক প্রান্তে (দাঁড়িয়ে)","audioUrl":"wbw/022_011_007.mp3","charTypeName":"word"},{"id":12809,"position":8,"arabic":"فَإِنْ","translation":"অতঃপর যদি",