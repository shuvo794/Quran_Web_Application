{"id":333,"ayahs":[{"number":6,"arabic":"ذَٰلِكَ بِأَنَّ ٱللَّهَ هُوَ ٱلْحَقُّ وَأَنَّهُۥ يُحْىِ ٱلْمَوْتَىٰ وَأَنَّهُۥ عَلَىٰ كُلِّ شَىْءٍۢ قَدِيرٌۭ","translation":"All this [happens] because God alone is the Ultimate Truth, and because He alone brings the dead to life, and because He has the power to will anything.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2601.mp3","surahId":22,"words":[{"id":6470,"position":1,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/022_006_001.mp3","charTypeName":"word"},{"id":6471,"position":2,"arabic":"بِأَنَّ","translation":"এজন্যে যে","audioUrl":"wbw/022_006_002.mp3","charTypeName":"word"},{"id":6472,"position":3,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/022_006_003.mp3","charTypeName":"word"},{"id":6473,"position":4,"arabic":"هُوَ","translation":"তিনিই","audioUrl":"wbw/022_006_004.mp3","charTypeName":"word"},{"id":6474,"position":5,"arabic":"ٱلْحَقُّ","translation":"প্রকৃত সত্য","audioUrl":"wbw/022_006_005.mp3","charTypeName":"word"},{"id":6475,"position":6,"arabic":"وَأَنَّهُۥ","translation":"এবং এসব এজন্যে যে তিনিই","audioUrl":"wbw/022_006_006.mp3","charTypeName":"word"},{"id":6476,"position":7,"arabic":"يُحْىِ","translation":"জীবিত করেন","audioUrl":"wbw/022_006_007.mp3","charTypeName":"word"},{"id":6477,"position":8,"arabic":"ٱلْمَوْتَىٰ","translation":"মৃতদেরকে","audioUrl":"wbw/022_006_008.mp3","charTypeName":"word"},{"id":6478,"position":9,"arabic":"وَأَنَّهُۥ","translation":"এবং (এটা প্রমাণ করে যে) তিনিই","audioUrl":"wbw/022_006_009.mp3","charTypeName":"word"},{"id":6479,"position":10,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/022_006_010.mp3","charTypeName":"word"},{"id":6480,"position":11,"arabic":"كُلِّ","translation":"সব","audioUrl":"wbw/022_006_011.mp3","charTypeName":"word"},{"id":6481,"position":12,"arabic":"شَىْءٍۢ","translation":"কিছুর","audioUrl":"wbw/022_006_012.mp3","charTypeName":"word"},{"id":6482,"position":13,"arabic":"قَدِيرٌۭ","translation":"শক্তিমান","