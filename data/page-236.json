{"id":236,"ayahs":[{"number":5,"arabic":"قَالَ يَٰبُنَىَّ لَا تَقْصُصْ رُءْيَاكَ عَلَىٰٓ إِخْوَتِكَ فَيَكِيدُوا۟ لَكَ كَيْدًا ۖ إِنَّ ٱلشَّيْطَٰنَ لِلْإِنسَٰنِ عَدُوٌّۭ مُّبِينٌۭ","translation":"[Jacob] replied: \"O my dear son! Do not relate thy dream to thy brothers lest [out of envy] they devise an evil scheme against thee; verily, Satan is man's open foe!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1601.mp3","surahId":12,"words":[{"id":5554,"position":1,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/012_005_001.mp3","charTypeName":"word"},{"id":5555,"position":2,"arabic":"يَـٰبُنَىَّ","translation":"\"হে আমার পুত্র","audioUrl":"wbw/012_005_002.mp3","charTypeName":"word"},{"id":5556,"position":3,"arabic":"لَا","translation":"না","audioUrl":"wbw/012_005_003.mp3","charTypeName":"word"},{"id":5557,"position":4,"arabic":"تَقْصُصْ","translation":"বর্ণনা করো","audioUrl":"wbw/012_005_004.mp3","charTypeName":"word"},{"id":5558,"position":5,"arabic":"رُءْيَاكَ","translation":"তোমার স্বপ্ন","audioUrl":"wbw/012_005_005.mp3","charTypeName":"word"},{"id":5559,"position":6,"arabic":"عَلَىٰٓ","translation":"কাছে","audioUrl":"wbw/012_005_006.mp3","charTypeName":"word"},{"id":5560,"position":7,"arabic":"إِخْوَتِكَ","translation":"তোমার ভাইদের","audioUrl":"wbw/012_005_007.mp3","charTypeName":"word"},{"id":5561,"position":8,"arabic":"فَيَكِيدُوا۟","translation":"তাহ'লে তারা চক্রান্ত করবে","audioUrl":"wbw/012_005_008.mp3","charTypeName":"word"},{"id":5562,"position":9,"arabic":"لَكَ","translation":"তোমার বিরুদ্ধে","audioUrl":"wbw/012_005_009.mp3","charTypeName":"word"},{"id":5563,"position":10,"arabic":"كَيْدًا ۖ","translation":"(বড়) চক্রান্ত","audioUrl":"wbw/012_005_010.mp3","charTypeName":"word"},{"id":5565,"position":11,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/012_005_012.mp3","charTypeName":"word"},{"id":5566,"position":12,"arabic":"ٱلشَّيْطَـٰنَ","translation":"শয়তান","audioUrl":"wbw/012_005_013.mp3","charTypeName":"word"},{"id":5567,"position":13,"arabic":"لِلْإِنسَـٰنِ","translation":"মানুষের জন্যে","audioUrl":"wbw/012_005_014.mp3","charTypeName":"word"},{"id":5568,"position":14,"arabic":"عَدُوٌّۭ","translation":"শত্রু","audioUrl":"wbw/012_005_015.mp3","charTypeName":"word"},{"id":5569,"position":15,"arabic":"مُّبِينٌۭ","translation":"প্রকাশ্য","audioUrl":"wbw/012_005_016.mp3","charTypeName":"word"},{"id":5570,"position":16,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"وَكَذَٰلِكَ يَجْتَبِيكَ رَبُّكَ وَيُعَلِّمُكَ مِن تَأْوِيلِ ٱلْأَحَادِيثِ وَيُتِمُّ نِعْمَتَهُۥ عَلَيْكَ وَعَلَىٰٓ ءَالِ يَعْقُوبَ كَمَآ أَتَمَّهَا عَلَىٰٓ أَبَوَيْكَ مِن قَبْلُ إِبْرَٰهِيمَ وَإِسْحَٰقَ ۚ إِنَّ رَبَّكَ عَلِيمٌ حَكِيمٌۭ","translation":"For, [as thou hast been shown in thy dream,] even thus will thy Sustainer elect thee, and will impart unto thee some understanding of the inner meaning of happenings, and will bestow the full measure of His blessings upon thee and upon the House of Jacob -even as, aforetime, He bestowed it in full measure upon thy forefathers Abraham and Isaac. Verily, thy Sustainer is all-knowing, wise!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1602.mp3","surahId":12,"words":[{"id":6797,"position":1,"arabic":"وَكَذَٰلِكَ","translation":"এবং এভাবেই (হবে)","audioUrl":"wbw/012_006_001.mp3","charTypeName":"word"},{"id":6798,"position":2,"arabic":"يَجْتَبِيكَ","translation":"তোমাকে মনোনীত করবেন","audioUrl":"wbw/012_006_002.mp3","charTypeName":"word"},{"id":6799,"position":3,"arabic":"رَبُّكَ","translation":"তোমার রব","audioUrl":"wbw/012_006_003.mp3","charTypeName":"word"},{"id":6800,"position":4,"arabic":"وَيُعَلِّمُكَ","translation":"ও তোমাকে শিখাবেন","audioUrl":"wbw/012_006_004.mp3","charTypeName":"word"},{"id":6801,"position":5,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/012_006_005.mp3","charTypeName":"word"},{"id":6802,"position":6,"arabic":"تَأْوِيلِ","translation":"ব্যাখ্যা","audioUrl":"wbw/012_006_006.mp3","c