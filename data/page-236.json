:"নিশ্চয়ই","audioUrl":"wbw/012_006_023.mp3","charTypeName":"word"},{"id":6820,"position":23,"arabic":"رَبَّكَ","translation":"তোমার রব","audioUrl":"wbw/012_006_024.mp3","charTypeName":"word"},{"id":6821,"position":24,"arabic":"عَلِيمٌ","translation":"সর্বজ্ঞ","audioUrl":"wbw/012_006_025.mp3","charTypeName":"word"},{"id":6822,"position":25,"arabic":"حَكِيمٌۭ","translation":"প্রজ্ঞাময়\"","audioUrl":"wbw/012_006_026.mp3","charTypeName":"word"},{"id":6823,"position":26,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"۞ لَّقَدْ كَانَ فِى يُوسُفَ وَإِخْوَتِهِۦٓ ءَايَٰتٌۭ لِّلسَّآئِلِينَ","translation":"Indeed, in [the story of] Joseph and his brothers there are messages for all who search [after truth].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1603.mp3","surahId":12,"words":[{"id":8149,"position":1,"arabic":"۞ لَّقَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/012_007_002.mp3","charTypeName":"word"},{"id":8150,"position":2,"arabic":"كَانَ","translation":"ছিলো","audioUrl":"wbw/012_007_003.mp3","charTypeName":"word"},{"id":8151,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/012_007_004.mp3","charTypeName":"word"},{"id":8152,"position":4,"arabic":"يُوسُفَ","translation":"ইউসুফের (কাহিনীর)","audioUrl":"wbw/012_007_005.mp3","charTypeName":"word"},{"id":8153,"position":5,"arabic":"وَإِخْوَتِهِۦٓ","translation":"ও তার ভাইদের","audioUrl":"wbw/012_007_006.mp3","charTypeName":"word"},{"id":8154,"position":6,"arabic":"ءَايَـٰتٌۭ","translation":"নিদর্শনসমূহ","audioUrl":"wbw/012_007_007.mp3","charTypeName":"word"},{"id":8155,"position":7,"arabic":"لِّلسَّآئِلِينَ","translation":"জিজ্ঞাসাকারীদের জন্যে","audioUrl":"wbw/012_007_008.mp3","charTypeName":"word"},{"id":8156,"position":8,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"إِذْ قَالُوا۟ لَيُوسُفُ وَأَخُوهُ أَحَبُّ إِلَىٰٓ أَبِينَا مِنَّا وَنَحْنُ عُصْبَةٌ إِنَّ أَبَانَا لَفِى ضَلَٰلٍۢ مُّبِينٍ","translation":"NOW [Joseph's brothers] spoke [thus to one another:] \"Truly, Joseph and his brother [Benjamin] are dearer to our father than we, even though we are so many. Behold, our father is surely suffering from an aberration!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1604.mp3","surahId":12,"words":[{"id":9315,"position":1,"arabic":"إِذْ","translation":"যখন (স্মরণ করো)","audioUrl":"wbw/012_008_001.mp3","charTypeName":"word"},{"id":9316,"position":2,"arabic":"قَالُوا۟","translation":"(তারা ভাইয়েরা) বলেছিলো","audioUrl":"wbw/012_008_002.mp3","charTypeName":"word"},{"id":9317,"position":3,"arabic":"لَيُوسُفُ","translation":"\"অবশ্যই ইউসুফ","audioUrl":"wbw/012_008_003.mp3","charTypeName":"word"},{"id":9318,"position":4,"arabic":"وَأَخُوهُ","translation":"ও তার ভাই","audioUrl":"wbw/012_008_004.mp3","charTypeName":"word"},{"id":9319,"position":5,"arabic":"أَحَبُّ","translation":"অধিক প্রিয়","audioUrl":"wbw/012_008_005.mp3","charTypeName":"word"},{"id":9320,"position":6,"arabic":"إِلَىٰٓ","translation":"কাছে","audioUrl":"wbw/012_008_006.mp3","charTypeName":"word"},{"id":9321,"position":7,"arabic":"أَبِينَا","translation":"আমাদের পিতার","audioUrl":"wbw/012_008_007.mp3","charTypeName":"word"},{"id":9322,"position":8,"arabic":"مِنَّا","translation":"আমাদের চেয়ে","audioUrl":"wbw/012_008_008.mp3","charTypeName":"word"},{"id":9323,"position":9,"arabic":"وَنَحْنُ","translation":"অথচ আমরা","audioUrl":"wbw/012_008_009.mp3","charTypeName":"word"},{"id":9324,"position":10,"arabic":"عُصْبَةٌ","translation":"একটি ঐক্যবদ্ধ দল","audioUrl":"wbw/012_008_010.mp3","charTypeName":"word"},{"id":9325,"position":11,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/012_008_011.mp3","charTypeName":"word"},{"id":9326,"position":12,"arabic":"أَبَانَا","translation":"আমাদের পিতা","audioUrl":"wbw/012_008_012.mp3","charTypeName":"word"},{"id":9327,"position":13,"arabic":"لَفِى","translation":"অবশ্যই মধ্যে","audioUrl":"wbw/012_008_013.mp3","charTypeName":"word"},{"id":9328,"position":14,"arabic":"ضَلَـٰلٍۢ","translation":"বিভ্রান্তির","audioUrl":"wbw/012_008_014.mp3","charTypeName":"word"},{"id":9329,"position":15,"arabic":"مُّبِينٍ","translation":"প্রকাশ্য","audioUrl":"wbw/012_008_015.mp3","charTypeName":"word"},{"id":9330,"position":16,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"ٱقْتُلُوا۟ يُوسُفَ أَوِ ٱطْرَحُوهُ أَرْضًۭا يَخْلُ لَكُمْ وَجْهُ أَبِيكُمْ وَتَكُونُوا۟ مِنۢ بَعْدِهِۦ قَوْمًۭا صَٰلِحِينَ","translation":"[Said one of them:] \"Slay Joseph, or else drive him away to some [faraway] land, so that your father's regard may be for you alone: and after this is done, you will be [free to repent and to live once again as] righteous people!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1605.mp3","surahId":12,"words":[{"id":10497,"position":1,"arabic":"ٱقْتُلُوا۟","translation":"তোমরা হত্যা করো","audioUrl":"wbw/012_009_001.mp3","charTypeName":"word"},{"id":10498,"position":2,"arabic":"يُوسُفَ","translation":"ইউসুফকে","audioUrl":"wbw/012_009_002.mp3","charTypeName":"word"},{"id":10499,"position":3,"arabic":"أَوِ","translation":"বা","audioUrl":"wbw/012_009_003.mp3","charTypeName":"word"},{"id":10500,"position":4,"arabic":"ٱطْرَحُوهُ","translation":"তাকে ফেলে আসো","audioUrl":"wbw/012_009_004.mp3","charTypeName":"word"},{"id":10501,"position":5,"arabic":"أَرْضًۭا","translation":"কোন স্থানে","audioUrl":"wbw/012_009_005.mp3","charTypeName":"word"},{"id":10502,"position":6,"arabic":"يَخْلُ","translation":"নিবিষ্ট হবে","audioUrl":"wbw/012_009_006.mp3","charTypeName":"word"},{"id":10503,"position":7,"arabic":"لَكُمْ","translation":"তোমাদের দিকে","audioUrl":"wbw/012_009_007.mp3","charTypeName":"word"},{"id":10504,"position":8,"arabic":"وَجْهُ","translation":"দৃষ্টি","audioUrl":"wbw/012_009_008.mp3","charTypeName":"word"},{"id":10505,"position":9,"arabic":"أَبِيكُمْ","translation":"তোমাদের পিতার","audioUrl":"wbw/012_009_009.mp3","charTypeName":"word"},{"id":10506,"position":10,"arabic":"وَتَكُونُوا۟","translation":"ও তোমরা হয়ে যাবে","audioUrl":"wbw/012_009_010.mp3","charTypeName":"word"},{"id":10507,"position":11,"arabic":"مِنۢ","translation":"থেকে","audioUrl":"wbw/012_009_011.mp3","charTypeName":"word"},{"id":10508,"position":12,"arabic":"بَعْدِهِۦ","translation":"এরপর","audioUrl":"wbw/012_009_012.mp3","charTypeName":"word"},{"id":10509,"position":13,"arabic":"قَوْمًۭا","translation":"লোক","audioUrl":"wbw/012_009_013.mp3","charTypeName":"word"},{"id":10510,"position":14,"arabic":"صَـٰلِحِينَ","translation":"সৎকর্মশীল\"","audioUrl":"wbw/012_009_014.mp3","charTypeName":"word"},{"id":10511,"position":15,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"قَالَ قَآئِلٌۭ مِّنْهُمْ لَا تَقْتُلُوا۟ يُوسُفَ وَأَلْقُوهُ فِى غَيَٰبَتِ ٱلْجُبِّ يَلْتَقِطْهُ بَعْضُ ٱلسَّيَّارَةِ إِن كُنتُمْ فَٰعِلِينَ","translation":"Another of them said: \"Do not slay Joseph, but -rather - if you must do something - cast him into the dark depths of this well, [whence] some caravan may pick him up.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1606.mp3","surahId":12,"words":[{"id":11767,"position":1,"arabic":"قَالَ","translation":"বললো","audioUrl":"wbw/012_010_001.mp3","charTypeName":"word"},{"id":11768,"position":2,"arabic":"قَآئِلٌۭ","translation":"এক প্রবক্তা","audioUrl":"wbw/012_010_002.mp3","charTypeName":"word"},{"id":11769,"position":3,"arabic":"مِّنْهُمْ","translation":"তাদের মধ্য হ'তে","audioUrl":"wbw/012_010_003.mp3","charTypeName":"word"},{"id":11770,"position":4,"arabic":"لَا","translation":"\"না","audioUrl":"wbw/012_010_004.mp3","charTypeName":"word"},{"id":11771,"position":5,"arabic":"تَقْتُلُوا۟","translation":"তোমরা হত্যা করো","audioUrl":"wbw/012_010_005.mp3","charTypeName":"word"},{"id":11772,"position":6,"arabic":"يُوسُفَ","translation":"ইউসুফকে","audioUrl":"wbw/012_010_006.mp3","charTypeName":"word"},{"id":11773,"position":7,"arabic":"وَأَلْقُوهُ","translation":"বরং তাকে নিক্ষেপ করো","audioUrl":"wbw/012_010_007.mp3","charTypeName":"word"},{"id":11774,"position":8,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/012_010_008.mp3","charTypeName":"word"},{"id":11775,"position":9,"arabic":"غَيَـٰبَتِ","translation":"(অন্ধকার) গভীরে","audioUrl":"wbw/012_010_009.mp3","charTypeName":"word"},{"id":11776,"position":10,"arabic":"ٱلْجُبِّ","translation":"কূপের","audioUrl":"wbw/012_010_010.mp3","charTypeName":"word"},{"id":11777,"position":11,"arabic":"يَلْتَقِطْهُ","translation":"তাকে তুলে নিবে","audioUrl":"wbw/012_010_011.mp3","charTypeName":"word"},{"id":11778,"position":12,"arabic":"بَعْضُ","translation":"কেউ","audioUrl":"wbw/012_010_012.mp3","charTypeName":"word"},{"id":11779,"position":13,"arabic":"ٱلسَّيَّارَةِ","translation":"পথযাত্রীদলের","audioUrl":"wbw/012_010_013.mp3","charTypeName":"word"},{"id":11780,"position":14,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/012_010_014.mp3","charTypeName":"word"},{"id":11781,"position":15,"arabic":"كُنتُمْ","translation":"তোমরা হও","audioUrl":"wbw/012_010_015.mp3","charTypeName":"word"},{"id":11782,"position":16,"arabic":"فَـٰعِلِينَ","translation":"কর্মসম্পাদনকারী\"","audioUrl":"wbw/012_010_016.mp3","charTypeName":"word"},{"id":11783,"position":17,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"قَالُوا۟ يَٰٓأَبَانَا مَا لَكَ لَا تَأْمَ۫نَّا عَلَىٰ يُوسُفَ وَإِنَّا لَهُۥ لَنَٰصِحُونَ","translation":"[On this they agreed; and thereupon] they spoke [thus to their father]: \"O our father! Wherefore wilt thou not trust us with Joseph, seeing that we are indeed his well-wishers?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1607.mp3","surahId":12,"words":[{"id":13092,"position":1,"arabic":"قَالُوا۟","translation":"তারা বললো","audioUrl":"wbw/012_011_001.mp3","charTypeName":"word"},{"id":13093,"position":2,"arabic":"يَـٰٓأَبَانَا","translation":"\"হে আমাদের পিতা","audioUrl":"wbw/012_011_002.mp3","charTypeName":"word"},{"id":13094,"position":3,"arabic":"مَا","translation":"কি","audioUrl":"wbw/012_011_003.mp3","charTypeName":"word"},{"id":13095,"position":4,"arabic":"لَكَ","translation":"আপনার হয়েছে","audioUrl":"wbw/012_011_004.mp3","charTypeName":"word"},{"id":13096,"position":5,"arabic":"لَا","translation":"না","audioUrl":"wbw/012_011_005.mp3","charTypeName":"word"},{"id":13097,"position":6,"arabic":"تَأْمَ۫نَّا","translation":"আমাদের বিশ্বাস করেন","audioUrl":"wbw/012_011_006.mp3","charTypeName":"word"},{"id":13098,"position":7,"arabic":"عَلَىٰ","translation":"ব্যাপারে","audioUrl":"wbw/012_011_007.mp3","charTypeName":"word"},{"id":13099,"position":8,"arabic":"يُوسُفَ","translation":"ইউসুফের","audioUrl":"wbw/012_011_008.mp3","charTypeName":"word"},{"id":13100,"position":9,"arabic":"وَإِنَّا","translation":"অথচ নিশ্চয়ই আমরা","audioUrl":"wbw/012_011_009.mp3","charTypeName":"word"},{"id":13101,"position":10,"arabic":"لَهُۥ","translation":"জন্যে তার","audioUrl":"wbw/012_011_010.mp3","charTypeName":"word"},{"id":13102,"position":11,"arabic":"لَنَـٰصِحُونَ","translation":"অবশ্যই (সবাই) হিতাকাঙ্ক্ষী","audioUrl":"wbw/012_011_011.mp3","charTypeName":"word"},{"id":13103,"position":12,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]},{"number":12,"arabic":"أَرْسِلْهُ مَعَنَا غَدًۭا يَرْتَعْ وَيَلْعَبْ وَإِنَّا لَهُۥ لَحَٰفِظُونَ","translation":"Let him go out with us tomorrow, that he may enjoy himself and play: and, verily, we shall guard him well!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1608.mp3","surahId":12,"words":[{"id":14368,"position":1,"arabic":"أَرْسِلْهُ","translation":"তাকে পাঠান","audioUrl":"wbw/012_012_001.mp3","charTypeName":"word"},{"id":14369,"position":2,"arabic":"مَعَنَا","translation":"আমাদের সাথে","audioUrl":"wbw/012_012_002.mp3","charTypeName":"word"},{"id":14370,"position":3,"arabic":"غَدًۭا","translation":"আগামীকাল","audioUrl":"wbw/012_012_003.mp3","charTypeName":"word"},{"id":14371,"position":4,"arabic":"يَرْتَعْ","translation":"সে ফল খাবে","audioUrl":"wbw/012_012_004.mp3","charTypeName":"word"},{"id":14372,"position":5,"arabic":"وَيَلْعَبْ","translation":"ও খেলবে","audioUrl":"wbw/012_012_005.mp3","charTypeName":"word"},{"id":14373,"position":6,"arabic":"وَإِنَّا","translation":"এবং নিশ্চয়ই আমরা","audioUrl":"wbw/012_012_006.mp3","charTypeName":"word"},{"id":14374,"position":7,"arabic":"لَهُۥ","translation":"তার জন্যে\"","audioUrl":"wbw/012_012_007.mp3","charTypeName":"word"},{"id":14375,"position":8,"arabic":"لَحَـٰفِظُونَ","translation":"অবশ্যই (সবাই) সংরক্ষক\"","audioUrl":"wbw/012_012_008.mp3","charTypeName":"word"},{"id":14376,"position":9,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]},{"number":13,"arabic":"قَالَ إِنِّى لَيَحْزُنُنِىٓ أَن تَذْهَبُوا۟ بِهِۦ وَأَخَافُ أَن يَأْكُلَهُ ٱلذِّئْبُ وَأَنتُمْ عَنْهُ غَٰفِلُونَ","translation":"[Jacob] answered: \"Behold, it grieves me indeed [to think] that you might take him with you, for I dread lest the wolf devour him at a moment when you are heedless of him!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1609.mp3","surahId":12,"words":[{"id":15485,"position":1,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/012_013_001.mp3","charTypeName":"word"},{"id":15486,"position":2,"arabic":"إِنِّى","translation":"\"নিশ্চয়ই আমার","audioUrl":"wbw/012_013_002.mp3","charTypeName":"word"},{"id":15487,"position":3,"arabic":"لَيَحْزُنُنِىٓ","translation":"আমার অবশ্যই চিন্তা লাগে","audioUrl":"wbw/012_013_003.mp3","charTypeName":"word"},{"id":15488,"position":4,"arabic":"أَن","translation":"যে","audioUrl":"wbw/012_013_004.mp3","charTypeName":"word"},{"id":15489,"position":5,"arabic":"تَذْهَبُوا۟","translation":"তোমরা যাবে","audioUrl":"wbw/012_013_005.mp3","charTypeName":"word"},{"id":15490,"position":6,"arabic":"بِهِۦ","translation":"নিয়ে তাকে","audioUrl":"wbw/012_013_006.mp3","charTypeName":"word"},{"id":15491,"position":7,"arabic":"وَأَخَافُ","translation":"এবং আমি ভয় করি","audioUrl":"wbw/012_013_007.mp3","charTypeName":"word"},{"id":15492,"position":8,"arabic":"أَن","translation":"যে","audioUrl":"wbw/012_013_008.mp3","charTypeName":"word"},{"id":15493,"position":9,"arabic":"يَأْكُلَهُ","translation":"তাকে খেয়ে ফেলবে","audioUrl":"wbw/012_013_009.mp3","charTypeName":"word"},{"id":15494,"position":10,"arabic":"ٱلذِّئْبُ","translation":"নেকড়ে বাঘ","audioUrl":"wbw/012_013_010.mp3","charTypeName":"word"},{"id":15495,"position":11,"arabic":"وَأَنتُمْ","translation":"এ অবস্থায় যে তোমরা","audioUrl":"wbw/012_013_011.mp3","charTypeName":"word"},{"id":15496,"position":12,"arabic":"عَنْهُ","translation":"তার থেকে","audioUrl":"wbw/012_013_012.mp3","charTypeName":"word"},{"id":15497,"position":13,"arabic":"غَـٰفِلُونَ","translation":"অমনোযোগী হয়ে যাবে\"","audioUrl":"wbw/012_013_013.mp3","charTypeName":"word"},{"id":15498,"position":14,"arabic":"١٣","translation":"(১৩)","audioUrl":null,"charTypeName":"end"}]},{"number":14,"arabic":"قَالُوا۟ لَئِنْ أَكَلَهُ ٱلذِّئْبُ وَنَحْنُ عُصْبَةٌ إِنَّآ إِذًۭا لَّخَٰسِرُونَ","translation":"Said they: \"Surely, if the wolf were to devour him notwithstanding that we are so many-then, behold, we ought ourselves to perish!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1610.mp3","surahId":12,"words":[{"id":16517,"position":1,"arabic":"قَالُوا۟","translation":"তারা বললো","audioUrl":"wbw/012_014_001.mp3","charTypeName":"word"},{"id":16518,"position":2,"arabic":"لَئِنْ","translation":"\"অবশ্য যদি","audioUrl":"wbw/012_014_002.mp3","charTypeName":"word"},{"id":16519,"position":3,"arabic":"أَكَلَهُ","translation":"তাকে খায়","audioUrl":"wbw/012_014_003.mp3","charTypeName":"word"},{"id":16520,"position":4,"arabic":"ٱلذِّئْبُ","translation":"নেকড়ে বাঘ","audioUrl":"wbw/012_014_004.mp3","charTypeName":"word"},{"id":16521,"position":5,"arabic":"وَنَحْنُ","translation":"এ অবস্থায় যে আমরা","audioUrl":"wbw/012_014_005.mp3","charTypeName":"word"},{"id":16522,"position":6,"arabic":"عُصْبَةٌ","translation":"একটি ঐক্যবদ্ধ দল","audioUrl":"wbw/012_014_006.mp3","charTypeName":"word"},{"id":16523,"position":7,"arabic":"إِنَّآ","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/012_014_007.mp3","charTypeName":"word"},{"id":16524,"position":8,"arabic":"إِذًۭا","translation":"তাহ'লে","audioUrl":"wbw/012_014_008.mp3","charTypeName":"word"},{"id":16525,"position":9,"arabic":"لَّخَـٰسِرُونَ","translation":"অবশ্যই ক্ষতিগ্রস্ত হবো\"","audioUrl":"wbw/012_014_009.mp3","charTypeName":"word"},{"id":16526,"position":10,"arabic":"١٤","translation":"(১৪)","audioUrl":null,"charTypeName":"end"}]}]}