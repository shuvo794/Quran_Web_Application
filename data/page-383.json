sooth, be brought forth [from the dead]?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3226.mp3","surahId":27,"words":[{"id":58015,"position":1,"arabic":"وَقَالَ","translation":"এবং বলে","audioUrl":"wbw/027_067_001.mp3","charTypeName":"word"},{"id":58016,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/027_067_002.mp3","charTypeName":"word"},{"id":58017,"position":3,"arabic":"كَفَرُوٓا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/027_067_003.mp3","charTypeName":"word"},{"id":58018,"position":4,"arabic":"أَءِذَا","translation":"\"কি যখন","audioUrl":"wbw/027_067_004.mp3","charTypeName":"word"},{"id":58019,"position":5,"arabic":"كُنَّا","translation":"আমরা হবো","audioUrl":"wbw/027_067_005.mp3","charTypeName":"word"},{"id":58020,"position":6,"arabic":"تُرَٰبًۭا","translation":"মাটি","audioUrl":"wbw/027_067_006.mp3","charTypeName":"word"},{"id":58021,"position":7,"arabic":"وَءَابَآؤُنَآ","translation":"ও পিতৃ-পুরুষরা আমাদের","audioUrl":"wbw/027_067_007.mp3","charTypeName":"word"},{"id":58022,"position":8,"arabic":"أَئِنَّا","translation":"কি নিশ্চয়ই আমরা","audioUrl":"wbw/027_067_008.mp3","charTypeName":"word"},{"id":58023,"position":9,"arabic":"لَمُخْرَجُونَ","translation":"অবশ্যই উত্থিত হবো","audioUrl":"wbw/027_067_009.mp3","charTypeName":"word"},{"id":58024,"position":10,"arabic":"٦٧","translation":"(৬৭)","audioUrl":null,"charTypeName":"end"}]},{"number":68,"arabic":"لَقَدْ وُعِدْنَا هَٰذَا نَحْنُ وَءَابَآؤُنَا مِن قَبْلُ إِنْ هَٰذَآ إِلَّآ أَسَٰطِيرُ ٱلْأَوَّلِينَ","translation":"Indeed, we were promised this - we and our forefathers - in the past as well; it is nothing but fables of ancient times!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3227.mp3","surahId":27,"words":[{"id":58714,"position":1,"arabic":"لَقَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/027_068_001.mp3","charTypeName":"word"},{"id":58715,"position":2,"arabic":"وُعِدْنَا","translation":"প্রতিশ্রুতি দেয়া হয়েছে আমাদের","audioUrl