id":61639,"position":5,"arabic":"تُكِنُّ","translation":"গোপন করে","audioUrl":"wbw/027_074_005.mp3","charTypeName":"word"},{"id":61640,"position":6,"arabic":"صُدُورُهُمْ","translation":"তাদের অন্তরসমূহ","audioUrl":"wbw/027_074_006.mp3","charTypeName":"word"},{"id":61641,"position":7,"arabic":"وَمَا","translation":"আর যা","audioUrl":"wbw/027_074_007.mp3","charTypeName":"word"},{"id":61642,"position":8,"arabic":"يُعْلِنُونَ","translation":"তারা প্রকাশ করে","audioUrl":"wbw/027_074_008.mp3","charTypeName":"word"},{"id":61643,"position":9,"arabic":"٧٤","translation":"(৭৪)","audioUrl":null,"charTypeName":"end"}]},{"number":75,"arabic":"وَمَا مِنْ غَآئِبَةٍۢ فِى ٱلسَّمَآءِ وَٱلْأَرْضِ إِلَّا فِى كِتَٰبٍۢ مُّبِينٍ","translation":"for there is nothing [so deeply] hidden in the heavens or on earth but is recorded in [His] clear decree.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3234.mp3","surahId":27,"words":[{"id":61845,"position":1,"arabic":"وَمَا","translation":"আর নেই","audioUrl":"wbw/027_075_001.mp3","charTypeName":"word"},{"id":61846,"position":2,"arabic":"مِنْ","translation":"কোনো","audioUrl":"wbw/027_075_002.mp3","charTypeName":"word"},{"id":61847,"position":3,"arabic":"غَآئِبَةٍۢ","translation":"গোপন বিষয়","audioUrl":"wbw/027_075_003.mp3","charTypeName":"word"},{"id":61848,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/027_075_004.mp3","charTypeName":"word"},{"id":61849,"position":5,"arabic":"ٱلسَّمَآءِ","translation":"আকাশের","audioUrl":"wbw/027_075_005.mp3","charTypeName":"word"},{"id":61850,"position":6,"arabic":"وَٱلْأَرْضِ","translation":"আর (না) পৃথিবীতে","audioUrl":"wbw/027_075_006.mp3","charTypeName":"word"},{"id":61851,"position":7,"arabic":"إِلَّا","translation":"এ ছাড়া যে","audioUrl":"wbw/027_075_007.mp3","charTypeName":"word"},{"id":61852,"position":8,"arabic":"فِى","translation":"আছে (তা)","audioUrl":"wbw/027_075_008.mp3","charTypeName":"word"},{"id":61853,"position":9,"arabic":"كِتَـٰبٍۢ","translation":"কিতাব