{"id":383,"ayahs":[{"number":64,"arabic":"أَمَّن يَبْدَؤُا۟ ٱلْخَلْقَ ثُمَّ يُعِيدُهُۥ وَمَن يَرْزُقُكُم مِّنَ ٱلسَّمَآءِ وَٱلْأَرْضِ ۗ أَءِلَٰهٌۭ مَّعَ ٱللَّهِ ۚ قُلْ هَاتُوا۟ بُرْهَٰنَكُمْ إِن كُنتُمْ صَٰدِقِينَ","translation":"Nay - who is it that creates [all life] in the first instance, and then brings it forth anew? And who is it that provides you with sustenance out of heaven and earth? Could there be any divine power besides God? Say: “[If you think so,] produce your evidence - if you truly believe in your claim!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3223.mp3","surahId":27,"words":[{"id":56759,"position":1,"arabic":"أَمَّن","translation":"কে অথবা (এমন আছেন)","audioUrl":"wbw/027_064_001.mp3","charTypeName":"word"},{"id":56760,"position":2,"arabic":"يَبْدَؤُا۟","translation":"যিনি সূচনা করেন","audioUrl":"wbw/027_064_002.mp3","charTypeName":"word"},{"id":56761,"position":3,"arabic":"ٱلْخَلْقَ","translation":"সৃষ্টির","audioUrl":"wbw/027_064_003.mp3","charTypeName":"word"},{"id":56762,"position":4,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/027_064_004.mp3","charTypeName":"word"},{"id":56763,"position":5,"arabic":"يُعِيدُهُۥ","translation":"পুনরাবৃত্তি করবেন তার","audioUrl":"wbw/027_064_005.mp3","charTypeName":"word"},{"id":56764,"position":6,"arabic":"وَمَن","translation":"আর কে","audioUrl":"wbw/027_064_006.mp3","charTypeName":"word"},{"id":56765,"position":7,"arabic":"يَرْزُقُكُم","translation":"তোমাদেরকে জীবিকা দেন","audioUrl":"wbw/027_064_007.mp3","charTypeName":"word"},{"id":56766,"position":8,"arabic":"مِّنَ","translation":"হ'তে","audioUrl":"wbw/027_064_008.mp3","charTypeName":"word"},{"id":56767,"position":9,"arabic":"ٱلسَّمَآءِ","translation":"আকাশ","audioUrl":"wbw/027_064_009.mp3","charTypeName":"word"},{"id":56768,"position":10,"arabic":"وَٱلْأَرْضِ ۗ","translation":"ও পৃথিবী(হ'তে)","audioUrl":"wbw/027_064_010.mp3","charTypeName":"word"},{"id":56770,"position":11,"arabic":"أَءِلَـٰهٌۭ","translation":"কি (আছে) কোন