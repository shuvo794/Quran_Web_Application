n anyone in the world!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/784.mp3","surahId":5,"words":[{"id":75327,"position":1,"arabic":"قَالَ","translation":"বললেন","audioUrl":"wbw/005_115_001.mp3","charTypeName":"word"},{"id":75328,"position":2,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/005_115_002.mp3","charTypeName":"word"},{"id":75329,"position":3,"arabic":"إِنِّى","translation":"\"নিশ্চয়ই আমি","audioUrl":"wbw/005_115_003.mp3","charTypeName":"word"},{"id":75330,"position":4,"arabic":"مُنَزِّلُهَا","translation":"অবতীর্ণকারী তা","audioUrl":"wbw/005_115_004.mp3","charTypeName":"word"},{"id":75331,"position":5,"arabic":"عَلَيْكُمْ ۖ","translation":"উপর তোমাদের","audioUrl":"wbw/005_115_005.mp3","charTypeName":"word"},{"id":75333,"position":6,"arabic":"فَمَن","translation":"তবে যে","audioUrl":"wbw/005_115_007.mp3","charTypeName":"word"},{"id":75334,"position":7,"arabic":"يَكْفُرْ","translation":"অস্বীকার করবে","audioUrl":"wbw/005_115_008.mp3","charTypeName":"word"},{"id":75335,"position":8,"arabic":"بَعْدُ","translation":"এরপরেও","audioUrl":"wbw/005_115_009.mp3","charTypeName":"word"},{"id":75336,"position":9,"arabic":"مِنكُمْ","translation":"মধ্য হতে তোমাদের","audioUrl":"wbw/005_115_010.mp3","charTypeName":"word"},{"id":75337,"position":10,"arabic":"فَإِنِّىٓ","translation":"তখন নিশ্চয়ই আমি","audioUrl":"wbw/005_115_011.mp3","charTypeName":"word"},{"id":75338,"position":11,"arabic":"أُعَذِّبُهُۥ","translation":"শাস্তি দিবো আমি তাকে","audioUrl":"wbw/005_115_012.mp3","charTypeName":"word"},{"id":75339,"position":12,"arabic":"عَذَابًۭا","translation":"(এমন) শাস্তি","audioUrl":"wbw/005_115_013.mp3","charTypeName":"word"},{"id":75340,"position":13,"arabic":"لَّآ","translation":"(যা) না","audioUrl":"wbw/005_115_014.mp3","charTypeName":"word"},{"id":75341,"position":14,"arabic":"أُعَذِّبُهُۥٓ","translation":"আমি শাস্তি দিয়েছি তা","audioUrl":"wbw/005_115_015.mp3","charTypeName":"word"},{"id":75342,"position":15,"arabic":"أَحَدًۭا","translation":"কাউকে","audioUrl":"wbw/005_115_016.mp3","charTypeName":"word"},{"id":75343,"position":16,"arabic":"مِّنَ","translation":"মধ্যে","audioUrl":"wbw/005_115_017.mp3","charTypeName":"word"},{"id":75344,"position":17,"arabic":"ٱلْعَـٰلَمِينَ","translation":"বিশ্বজগতের\"","audioUrl":"wbw/005_115_018.mp3","charTypeName":"word"},{"id":75345,"position":18,"arabic":"١١٥","translation":"(১১৫)","audioUrl":null,"charTypeName":"end"}]},{"number":116,"arabic":"وَإِذْ قَالَ ٱللَّهُ يَٰعِيسَى ٱبْنَ مَرْيَمَ ءَأَنتَ قُلْتَ لِلنَّاسِ ٱتَّخِذُونِى وَأُمِّىَ إِلَٰهَيْنِ مِن دُونِ ٱللَّهِ ۖ قَالَ سُبْحَٰنَكَ مَا يَكُونُ لِىٓ أَنْ أَقُولَ مَا لَيْسَ لِى بِحَقٍّ ۚ إِن كُنتُ قُلْتُهُۥ فَقَدْ عَلِمْتَهُۥ ۚ تَعْلَمُ مَا فِى نَفْسِى وَلَآ أَعْلَمُ مَا فِى نَفْسِكَ ۚ إِنَّكَ أَنتَ عَلَّٰمُ ٱلْغُيُوبِ","translation":"AND LO! God said: O Jesus, son of Mary! Didst thou say unto men, `Worship me and my mother as deities beside God'?\" [Jesus] answered: \"Limitless art Thou in Thy glory! It would not have been possible for me to say what I had no right to [say]! Had I said this, Thou wouldst indeed have known it! Thou knowest all that is within myself, whereas I know not what is in Thy Self. Verily, it is Thou alone who fully knowest all the things that are beyond the reach of a created being's perception.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/785.mp3","surahId":5,"words":[{"id":75604,"position":1,"arabic":"وَإِذْ","translation":"এবং যখন","audioUrl":"wbw/005_116_001.mp3","charTypeName":"word"},{"id":75605,"position":2,"arabic":"قَالَ","translation":"বলবেন","audioUrl":"wbw/005_116_002.mp3","charTypeName":"word"},{"id":75606,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/005_116_003.mp3","charTypeName":"word"},{"id":75607,"position":4,"arabic":"يَـٰعِيسَى","translation":"\"হে ঈসা","audioUrl":"wbw/005_116_004.mp3","charTypeName":"word"},{"id":75608,"position":5,"arabic":"ٱبْنَ","translation":"পুত্র","audioUrl":"wbw/005_116_005.mp3","charTypeName":"word"},{"id":75609,"position":6,"arabic":"مَرْيَمَ","translation":"মারইয়ামের","audioUrl":"wbw/005_116_006.mp3","charTypeName":"word"},{"id":75610,"position":7,"arabic":"ءَأَنتَ","translation":"কি তুমি","audioUrl":"wbw/005_116_007.mp3","charTypeName":"word"},{"id":75611,"position":8,"arabic":"قُلْتَ","translation":"বলেছিলে","audioUrl":"wbw/005_116_008.mp3","charTypeName":"word"},{"id":75612,"position":9,"arabic":"لِلنَّاسِ","translation":"উদ্দেশ্যে লোকদের","audioUrl":"wbw/005_116_009.mp3","charTypeName":"word"},{"id":75613,"position":10,"arabic":"ٱتَّخِذُونِى","translation":"\"তোমরা গ্রহণ করো আমাকে","audioUrl":"wbw/005_116_010.mp3","charTypeName":"word"},{"id":75614,"position":11,"arabic":"وَأُمِّىَ","translation":"ও আমার মাকে","audioUrl":"wbw/005_116_011.mp3","charTypeName":"word"},{"id":75615,"position":12,"arabic":"إِلَـٰهَيْنِ","translation":"দুই ইলাহরূপে","audioUrl":"wbw/005_116_012.mp3","charTypeName":"word"},{"id":75616,"position":13,"arabic":"مِن","translation":"দিয়ে","audioUrl":"wbw/005_116_013.mp3","charTypeName":"word"},{"id":75617,"position":14,"arabic":"دُونِ","translation":"বাদ","audioUrl":"wbw/005_116_014.mp3","charTypeName":"word"},{"id":75618,"position":15,"arabic":"ٱللَّهِ ۖ","translation":"আল্লাহকে\"","audioUrl":"wbw/005_116_015.mp3","charTypeName":"word"},{"id":75620,"position":16,"arabic":"قَالَ","translation":"সে বলবে","audioUrl":"wbw/005_116_017.mp3","charTypeName":"word"},{"id":75621,"position":17,"arabic":"سُبْحَـٰنَكَ","translation":"\"মহিমাময় আপনি","audioUrl":"wbw/005_116_018.mp3","charTypeName":"word"},{"id":75622,"position":18,"arabic":"مَا","translation":"না","audioUrl":"wbw/005_116_019.mp3","charTypeName":"word"},{"id":75623,"position":19,"arabic":"يَكُونُ","translation":"সঙ্গত","audioUrl":"wbw/005_116_020.mp3","charTypeName":"word"},{"id":75624,"position":20,"arabic":"لِىٓ","translation":"জন্যে আমার","audioUrl":"wbw/005_116_021.mp3","charTypeName":"word"},{"id":75625,"position":21,"arabic":"أَنْ","translation":"যে","audioUrl":"wbw/005_116_022.mp3","charTypeName":"word"},{"id":75626,"position":22,"arabic":"أَقُولَ","translation":"বলবো আমি","audioUrl":"wbw/005_116_023.mp3","charTypeName":"word"},{"id":75627,"position":23,"arabic":"مَا","translation":"যা","audioUrl":"wbw/005_116_024.mp3","charTypeName":"word"},{"id":75628,"position":24,"arabic":"لَيْسَ","translation":"নয়","audioUrl":"wbw/005_116_025.mp3","charTypeName":"word"},{"id":75629,"position":25,"arabic":"لِى","translation":"আমার","audioUrl":"wbw/005_116_026.mp3","charTypeName":"word"},{"id":75630,"position":26,"arabic":"بِحَقٍّ ۚ","translation":"অধিকার","audioUrl":"wbw/005_116_027.mp3","charTypeName":"word"},{"id":75632,"position":27,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/005_116_029.mp3","charTypeName":"word"},{"id":75633,"position":28,"arabic":"كُنتُ","translation":"আমি বলে থাকি","audioUrl":"wbw/005_116_030.mp3","charTypeName":"word"},{"id":75634,"position":29,"arabic":"قُلْتُهُۥ","translation":"আমি তা","audioUrl":"wbw/005_116_031.mp3","charTypeName":"word"},{"id":75635,"position":30,"arabic":"فَقَدْ","translation":"তবে নিশ্চয়ই","audioUrl":"wbw/005_116_032.mp3","charTypeName":"word"},{"id":75636,"position":31,"arabic":"عَلِمْتَهُۥ ۚ","translation":"আপনি জানেন তা","audioUrl":"wbw/005_116_033.mp3","charTypeName":"word"},{"id":75638,"position":32,"arabic":"تَعْلَمُ","translation":"জানেন আপনি","audioUrl":"wbw/005_116_035.mp3","charTypeName":"word"},{"id":75639,"position":33,"arabic":"مَا","translation":"যা কিছু","audioUrl":"wbw/005_116_036.mp3","charTypeName":"word"},{"id":75640,"position":34,"arabic":"فِى","translation":"মধ্যে (আছে)","audioUrl":"wbw/005_116_037.mp3","charTypeName":"word"},{"id":75641,"position":35,"arabic":"نَفْسِى","translation":"আমার অন্তরের","audioUrl":"wbw/005_116_038.mp3","charTypeName":"word"},{"id":75642,"position":36,"arabic":"وَلَآ","translation":"এবং না","audioUrl":"wbw/005_116_039.mp3","charTypeName":"word"},{"id":75643,"position":37,"arabic":"أَعْلَمُ","translation":"জানি আমি","audioUrl":"wbw/0