{"id":127,"ayahs":[{"number":114,"arabic":"قَالَ عِيسَى ٱبْنُ مَرْيَمَ ٱللَّهُمَّ رَبَّنَآ أَنزِلْ عَلَيْنَا مَآئِدَةًۭ مِّنَ ٱلسَّمَآءِ تَكُونُ لَنَا عِيدًۭا لِّأَوَّلِنَا وَءَاخِرِنَا وَءَايَةًۭ مِّنكَ ۖ وَٱرْزُقْنَا وَأَنتَ خَيْرُ ٱلرَّٰزِقِينَ","translation":"Said Jesus, the son of Mary: \"O God, our Sustainer! Send down upon us a repast from heaven: it shall be an ever-recurring feast for us - for the first and the last of us -and a sign from Thee. And provide us our sustenance, for Thou art the best of providers!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/783.mp3","surahId":5,"words":[{"id":75087,"position":1,"arabic":"قَالَ","translation":"(তখন) বলেছিলো","audioUrl":"wbw/005_114_001.mp3","charTypeName":"word"},{"id":75088,"position":2,"arabic":"عِيسَى","translation":"ঈসা","audioUrl":"wbw/005_114_002.mp3","charTypeName":"word"},{"id":75089,"position":3,"arabic":"ٱبْنُ","translation":"পুত্র্র","audioUrl":"wbw/005_114_003.mp3","charTypeName":"word"},{"id":75090,"position":4,"arabic":"مَرْيَمَ","translation":"মারইয়ামের","audioUrl":"wbw/005_114_004.mp3","charTypeName":"word"},{"id":75091,"position":5,"arabic":"ٱللَّهُمَّ","translation":"\"হে আল্লাহ","audioUrl":"wbw/005_114_005.mp3","charTypeName":"word"},{"id":75092,"position":6,"arabic":"رَبَّنَآ","translation":"হে আমাদের রব","audioUrl":"wbw/005_114_006.mp3","charTypeName":"word"},{"id":75093,"position":7,"arabic":"أَنزِلْ","translation":"পাঠান","audioUrl":"wbw/005_114_007.mp3","charTypeName":"word"},{"id":75094,"position":8,"arabic":"عَلَيْنَا","translation":"জন্যে আমাদের","audioUrl":"wbw/005_114_008.mp3","charTypeName":"word"},{"id":75095,"position":9,"arabic":"مَآئِدَةًۭ","translation":"খাদ্যপূর্ণ পাত্র","audioUrl":"wbw/005_114_009.mp3","charTypeName":"word"},{"id":75096,"position":10,"arabic":"مِّنَ","translation":"থেকে","audioUrl":"wbw/005_114_010.mp3","charTypeName":"word"},{"id":75097,"position":11,"arabic":"ٱلسَّمَآءِ","translation":"আকাশ","audioUrl":"wbw/005_114_011.mp3","ch