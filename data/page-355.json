{"id":355,"ayahs":[{"number":37,"arabic":"رِجَالٌۭ لَّا تُلْهِيهِمْ تِجَٰرَةٌۭ وَلَا بَيْعٌ عَن ذِكْرِ ٱللَّهِ وَإِقَامِ ٱلصَّلَوٰةِ وَإِيتَآءِ ٱلزَّكَوٰةِ ۙ يَخَافُونَ يَوْمًۭا تَتَقَلَّبُ فِيهِ ٱلْقُلُوبُ وَٱلْأَبْصَٰرُ","translation":"people whom neither [worldly] commerce nor striving after gain can divert from the remembrance of God, and from con­stancy in prayer, and from charity: [people] who are filled with fear [at the thought] of the Day On which all hearts and eyes will be convulsed,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2828.mp3","surahId":24,"words":[{"id":39088,"position":1,"arabic":"رِجَالٌۭ","translation":"(তারা এমন) লোক","audioUrl":"wbw/024_037_001.mp3","charTypeName":"word"},{"id":39089,"position":2,"arabic":"لَّا","translation":"না","audioUrl":"wbw/024_037_002.mp3","charTypeName":"word"},{"id":39090,"position":3,"arabic":"تُلْهِيهِمْ","translation":"তাদেরকে বিরত করে","audioUrl":"wbw/024_037_003.mp3","charTypeName":"word"},{"id":39091,"position":4,"arabic":"تِجَـٰرَةٌۭ","translation":"ব্যবসায়","audioUrl":"wbw/024_037_004.mp3","charTypeName":"word"},{"id":39092,"position":5,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/024_037_005.mp3","charTypeName":"word"},{"id":39093,"position":6,"arabic":"بَيْعٌ","translation":"কেনাবেচায়","audioUrl":"wbw/024_037_006.mp3","charTypeName":"word"},{"id":39094,"position":7,"arabic":"عَن","translation":"হ'তে","audioUrl":"wbw/024_037_007.mp3","charTypeName":"word"},{"id":39095,"position":8,"arabic":"ذِكْرِ","translation":"স্মরণ","audioUrl":"wbw/024_037_008.mp3","charTypeName":"word"},{"id":39096,"position":9,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌র","audioUrl":"wbw/024_037_009.mp3","charTypeName":"word"},{"id":39097,"position":10,"arabic":"وَإِقَامِ","translation":"আর প্রতিষ্ঠা করতে","audioUrl":"wbw/024_037_010.mp3","charTypeName":"word"},{"id":39098,"position":11,"arabic":"ٱلصَّلَوٰةِ","translation":"সালাত","audioUrl":"wbw/024_037_011.mp3","charTypeName":"word"},{"id":39099,"position":12,"arabic":"وَإِيتَآءِ","translation":"ও আদায় করতে","audioUrl":"wbw/024_037_012.mp3","charTypeName":"word"},{"id":39100,"position":13,"arabic":"ٱلزَّكَوٰةِ ۙ","translation":"যাকাত","audioUrl":"wbw/024_037_013.mp3","charTypeName":"word"},{"id":39102,"position":14,"arabic":"يَخَافُونَ","translation":"তারা ভয় করে","audioUrl":"wbw/024_037_015.mp3","charTypeName":"word"},{"id":39103,"position":15,"arabic":"يَوْمًۭا","translation":"সেদিনের (যখন)","audioUrl":"wbw/024_037_016.mp3","charTypeName":"word"},{"id":39104,"position":16,"arabic":"تَتَقَلَّبُ","translation":"উল্টে যাবে","audioUrl":"wbw/024_037_017.mp3","charTypeName":"word"},{"id":39105,"position":17,"arabic":"فِيهِ","translation":"তার মধ্যে","audioUrl":"wbw/024_037_018.mp3","charTypeName":"word"},{"id":39106,"position":18,"arabic":"ٱلْقُلُوبُ","translation":"অন্তরসমূহ","audioUrl":"wbw/024_037_019.mp3","charTypeName":"word"},{"id":39107,"position":19,"arabic":"وَٱلْأَبْصَـٰرُ","translation":"ও দৃষ্টিসমূহ","audioUrl":"wbw/024_037_020.mp3","charTypeName":"word"},{"id":39108,"position":20,"arabic":"٣٧","translation":"(৩৭)","audioUrl":null,"charTypeName":"end"}]},{"number":38,"arabic":"لِيَجْزِيَهُمُ ٱللَّهُ أَحْسَنَ مَا عَمِلُوا۟ وَيَزِيدَهُم مِّن فَضْلِهِۦ ۗ وَٱللَّهُ يَرْزُقُ مَن يَشَآءُ بِغَيْرِ حِسَابٍۢ","translation":"[and who only hope] that God may reward them in accordance with the best that they ever did, and give them, out of His bounty, more [than they deserve]: for, God grants sustenance unto whom He wills, beyond all reckon­ing.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2829.mp3","surahId":24,"words":[{"id":39898,"position":1,"arabic":"لِيَجْزِيَهُمُ","translation":"(তারা এসব করে এজন্যে) যেন তাদেরকে প্রতিফল দেন","audioUrl":"wbw/024_038_001.mp3","charTypeName":"word"},{"id":39899,"position":2,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌","audioUrl":"wbw/024_038_002.mp3","charTypeName":"word"},{"id":39900,"position":3,"arabic":"أَحْسَنَ","translation":"উত্তম","audioUrl":"wbw/02