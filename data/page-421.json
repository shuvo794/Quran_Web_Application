{"id":421,"ayahs":[{"number":23,"arabic":"مِّنَ ٱلْمُؤْمِنِينَ رِجَالٌۭ صَدَقُوا۟ مَا عَٰهَدُوا۟ ٱللَّهَ عَلَيْهِ ۖ فَمِنْهُم مَّن قَضَىٰ نَحْبَهُۥ وَمِنْهُم مَّن يَنتَظِرُ ۖ وَمَا بَدَّلُوا۟ تَبْدِيلًۭا","translation":"Among the believers are men who have [always] been true to what they have vowed before God; and among them are such as have [already] redeemed their pledge by death, and such as yet await [its fulfillment] without having changed [their resolve] in the least.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3556.mp3","surahId":33,"words":[{"id":26297,"position":1,"arabic":"مِّنَ","translation":"মধ্য হ'তে","audioUrl":"wbw/033_023_001.mp3","charTypeName":"word"},{"id":26298,"position":2,"arabic":"ٱلْمُؤْمِنِينَ","translation":"মু'মিনদের","audioUrl":"wbw/033_023_002.mp3","charTypeName":"word"},{"id":26299,"position":3,"arabic":"رِجَالٌۭ","translation":"(কিছু) লোক","audioUrl":"wbw/033_023_003.mp3","charTypeName":"word"},{"id":26300,"position":4,"arabic":"صَدَقُوا۟","translation":"সত্য প্রমাণ করেছে","audioUrl":"wbw/033_023_004.mp3","charTypeName":"word"},{"id":26301,"position":5,"arabic":"مَا","translation":"যা","audioUrl":"wbw/033_023_005.mp3","charTypeName":"word"},{"id":26302,"position":6,"arabic":"عَـٰهَدُوا۟","translation":"তারা অঙ্গীকার করেছিলো","audioUrl":"wbw/033_023_006.mp3","charTypeName":"word"},{"id":26303,"position":7,"arabic":"ٱللَّهَ","translation":"আল্লাহকে","audioUrl":"wbw/033_023_007.mp3","charTypeName":"word"},{"id":26304,"position":8,"arabic":"عَلَيْهِ ۖ","translation":"উপর তার","audioUrl":"wbw/033_023_008.mp3","charTypeName":"word"},{"id":26306,"position":9,"arabic":"فَمِنْهُم","translation":"অতঃপর মধ্য থেকে তাদের","audioUrl":"wbw/033_023_010.mp3","charTypeName":"word"},{"id":26307,"position":10,"arabic":"مَّن","translation":"কেউ","audioUrl":"wbw/033_023_011.mp3","charTypeName":"word"},{"id":26308,"position":11,"arabic":"قَضَىٰ","translation":"পূর্ণ করেছে","audioUrl":"wbw/033_023_012.mp3","charTypeName":"word"},{"id":26309,"position":12,"arabic":"نَحْبَهُۥ","translation":"ব্রত তার (শহীদ হয়েছে)","audioUrl":"wbw/033_023_013.mp3","charTypeName":"word"},{"id":26310,"position":13,"arabic":"وَمِنْهُم","translation":"আবার মধ্যে হ'তে তাদের","audioUrl":"wbw/033_023_014.mp3","charTypeName":"word"},{"id":26311,"position":14,"arabic":"مَّن","translation":"কেউ","audioUrl":"wbw/033_023_015.mp3","charTypeName":"word"},{"id":26312,"position":15,"arabic":"يَنتَظِرُ ۖ","translation":"অপেক্ষায় আছে","audioUrl":"wbw/033_023_016.mp3","charTypeName":"word"},{"id":26314,"position":16,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/033_023_018.mp3","charTypeName":"word"},{"id":26315,"position":17,"arabic":"بَدَّلُوا۟","translation":"তারা পরিবর্তন করেছে","audioUrl":"wbw/033_023_019.mp3","charTypeName":"word"},{"id":26316,"position":18,"arabic":"تَبْدِيلًۭا","translation":"কোনো পরিবর্তন","audioUrl":"wbw/033_023_020.mp3","charTypeName":"word"},{"id":26317,"position":19,"arabic":"٢٣","translation":"(২৩)","audioUrl":null,"charTypeName":"end"}]},{"number":24,"arabic":"لِّيَجْزِىَ ٱللَّهُ ٱلصَّٰدِقِينَ بِصِدْقِهِمْ وَيُعَذِّبَ ٱلْمُنَٰفِقِينَ إِن شَآءَ أَوْ يَتُوبَ عَلَيْهِمْ ۚ إِنَّ ٱللَّهَ كَانَ غَفُورًۭا رَّحِيمًۭا","translation":"[Such trials are imposed upon man] so that God may reward the truthful for having been true to their word, and cause the hypocrites to suffer - if that be His will - or [if they repent,] accept their repen­tance: for, verily, God is indeed much-forgiving, a dispenser of grace!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3557.mp3","surahId":33,"words":[{"id":27331,"position":1,"arabic":"لِّيَجْزِىَ","translation":"যেন পুরস্কার দেন","audioUrl":"wbw/033_024_001.mp3","charTypeName":"word"},{"id":27332,"position":2,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/033_024_002.mp3","charTypeName":"word"},{"id":27333,"position":3,"arabic":"ٱلصَّـٰدِقِينَ","translation":"সত্যবাদীদেরকে","audioUrl":"wbw/033_024_003.mp3","charTypeName":"word"},{"id":27334,"position":4,"arabic":"بِصِدْقِهِمْ","translation":"কারণে সত্যবাদীতার তাদের","audioUrl":"wbw/033_024_004.mp3","charTypeName":"word"},{"id":27335,"position":5,"arabic":"وَيُعَذِّبَ","translation":"এবং শাস্তি দেন","audioUrl":"wbw/033_024_005.mp3","charTypeName":"word"},{"id":27336,"position":6,"arabic":"ٱلْمُنَـٰفِقِينَ","translation":"মুনাফিকদেরকে","audioUrl":"wbw/033_024_006.mp3","charTypeName":"word"},{"id":27337,"position":7,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/033_024_007.mp3","charTypeName":"word"},{"id":27338,"position":8,"arabic":"شَآءَ","translation":"তিনি ইচ্ছে করেন","audioUrl":"wbw/033_024_008.mp3","charTypeName":"word"},{"id":27339,"position":9,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/033_024_009.mp3","charTypeName":"word"},{"id":27340,"position":10,"arabic":"يَتُوبَ","translation":"ক্ষমা করে দিবেন","audioUrl":"wbw/033_024_010.mp3","charTypeName":"word"},{"id":27341,"position":11,"arabic":"عَلَيْهِمْ ۚ","translation":"প্রতি তাদের","audioUrl":"wbw/033_024_011.mp3","charTypeName":"word"},{"id":27343,"position":12,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/033_024_013.mp3","charTypeName":"word"},{"id":27344,"position":13,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/033_024_014.mp3","charTypeName":"word"},{"id":27345,"position":14,"arabic":"كَانَ","translation":"হলেন","audioUrl":"wbw/033_024_015.mp3","charTypeName":"word"},{"id":27346,"position":15,"arabic":"غَفُورًۭا","translation":"ক্ষমাশীল","audioUrl":"wbw/033_024_016.mp3","charTypeName":"word"},{"id":27347,"position":16,"arabic":"رَّحِيمًۭا","translation":"পরম দয়ালু","audioUrl":"wbw/033_024_017.mp3","charTypeName":"word"},{"id":27348,"position":17,"arabic":"٢٤","translation":"(২৪)","audioUrl":null,"charTypeName":"end"}]},{"number":25,"arabic":"وَرَدَّ ٱللَّهُ ٱلَّذِينَ كَفَرُوا۟ بِغَيْظِهِمْ لَمْ يَنَالُوا۟ خَيْرًۭا ۚ وَكَفَى ٱللَّهُ ٱلْمُؤْمِنِينَ ٱلْقِتَالَ ۚ وَكَانَ ٱللَّهُ قَوِيًّا عَزِيزًۭا","translation":"Thus, for all their fury, God repulsed those who were bent on denying the truth; no advantage did they gain, since God was enough to [protect] the believers in battle - seeing that God is most powerful, almighty;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3558.mp3","surahId":33,"words":[{"id":28402,"position":1,"arabic":"وَرَدَّ","translation":"এবং ফিরিয়ে দিলেন","audioUrl":"wbw/033_025_001.mp3","charTypeName":"word"},{"id":28403,"position":2,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/033_025_002.mp3","charTypeName":"word"},{"id":28404,"position":3,"arabic":"ٱلَّذِينَ","translation":"(তাদেরকে) যারা","audioUrl":"wbw/033_025_003.mp3","charTypeName":"word"},{"id":28405,"position":4,"arabic":"كَفَرُوا۟","translation":"অবিশ্বাস করেছে","audioUrl":"wbw/033_025_004.mp3","charTypeName":"word"},{"id":28406,"position":5,"arabic":"بِغَيْظِهِمْ","translation":"সহ মনের জ্বালা তাদের","audioUrl":"wbw/033_025_005.mp3","charTypeName":"word"},{"id":28407,"position":6,"arabic":"لَمْ","translation":"নি","audioUrl":"wbw/033_025_006.mp3","charTypeName":"word"},{"id":28408,"position":7,"arabic":"يَنَالُوا۟","translation":"তারা পায়","audioUrl":"wbw/033_025_007.mp3","charTypeName":"word"},{"id":28409,"position":8,"arabic":"خَيْرًۭا ۚ","translation":"কল্যাণ","audioUrl":"wbw/033_025_008.mp3","charTypeName":"word"},{"id":28411,"position":9,"arabic":"وَكَفَى","translation":"এবং যথেষ্ট","audioUrl":"wbw/033_025_010.mp3","charTypeName":"word"},{"id":28412,"position":10,"arabic":"ٱللَّهُ","translation":"আল্লাহই","audioUrl":"wbw/033_025_011.mp3","charTypeName":"word"},{"id":28413,"position":11,"arabic":"ٱلْمُؤْمِنِينَ","translation":"মু'মিনদের (জন্যে)","audioUrl":"wbw/033_025_012.mp3","charTypeName":"word"},{"id":28414,"position":12,"arabic":"ٱلْقِتَالَ ۚ","translation":"যুদ্ধে","audioUrl":"wbw/033_025_013.mp3","charTypeName":"word"},{"id":28416,"position":13,"arabic":"وَكَانَ","translation":"এবং হলেন","audioUrl":"wbw/033_025_015.mp3","charTypeName":"word"},{"id":28417,"position":14,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/033_025_016.mp3","charTypeName":"word"},{"id":28418,"position":15,"arabic":"قَوِيًّا","translation":"শক্তিমান","audioUrl":"wbw/033_025_017.mp3","charTypeName":"word"},{"id":28419,"position":16,"arabic":"عَزِيزًۭا","translation":"মহাপরাক্রমশালী","audioUrl":"wbw/033_025_018.mp3","charTypeName":"word"},{"id":28420,"position":17,"arabic":"٢٥","translation":"(২৫)","audioUrl":null,"charTypeName":"end"}]},{"number":26,"arabic":"وَأَنزَلَ ٱلَّذِينَ ظَٰهَرُوهُم مِّنْ أَهْلِ ٱلْكِتَٰبِ مِن صَيَاصِيهِمْ وَقَذَفَ فِى قُلُوبِهِمُ ٱلرُّعْبَ فَرِيقًۭا تَقْتُلُونَ وَتَأْسِرُونَ فَرِيقًۭا","translation":"and He brought down from their strongholds those of the followers of earlier reve­lation who had aided the aggressors, and cast terror into their hearts: some you slew, and some you made captive;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3559.mp3","surahId":33,"words":[{"id":29303,"position":1,"arabic":"وَأَنزَلَ","translation":"এবং নামিয়ে দিলেন","audioUrl":"wbw/033_026_001.mp3","charTypeName":"word"},{"id":29304,"position":2,"arabic":"ٱلَّذِينَ","translation":"(তাদেরকে) যারা","audioUrl":"wbw/033_026_002.mp3","charTypeName":"word"},{"id":29305,"position":3,"arabic":"ظَـٰهَرُوهُم","translation":"সাহায্য করেছিলো তাদের","audioUrl":"wbw/033_026_003.mp3","charTypeName":"word"},{"id":29306,"position":4,"arabic":"مِّنْ","translation":"মধ্য হ'তে","audioUrl":"wbw/033_026_004.mp3","charTypeName":"word"},{"id":29307,"position":5,"arabic":"أَهْلِ","translation":"অধিকারীদের","audioUrl":"wbw/033_026_005.mp3","charTypeName":"word"},{"id":29308,"position":6,"arabic":"ٱلْكِتَـٰبِ","translation":"কিতাবের","audioUrl":"wbw/033_026_006.mp3","charTypeName":"word"},{"id":29309,"position":7,"arabic":"مِن","translation":"হ'তে","audioUrl":"wbw/033_026_007.mp3","charTypeName":"word"},{"id":29310,"position":8,"arabic":"صَيَاصِيهِمْ","translation":"দূর্গসমূহ তাদের","audioUrl":"wbw/033_026_008.mp3","charTypeName":"word"},{"id":29311,"position":9,"arabic":"وَقَذَفَ","translation":"এবং সঞ্চার করলেন","audioUrl":"wbw/033_026_009.mp3","charTypeName":"word"},{"id":29312,"position":10,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/033_026_010.mp3","charTypeName":"word"},{"id":29313,"position":11,"arabic":"قُلُوبِهِمُ","translation":"অন্তসমূহের তাদের","audioUrl":"wbw/033_026_011.mp3","charTypeName":"word"},{"id":29314,"position":12,"arabic":"ٱلرُّعْبَ","translation":"ভয়","audioUrl":"wbw/033_026_012.mp3","charTypeName":"word"},{"id":29315,"position":13,"arabic":"فَرِيقًۭا","translation":"(এখন) এক দলকে","audioUrl":"wbw/033_026_013.mp3","charTypeName":"word"},{"id":29316,"position":14,"arabic":"تَقْتُلُونَ","translation":"তোমরা হত্যা করছো","audioUrl":"wbw/033_026_014.mp3","charTypeName":"word"},{"id":29317,"position":15,"arabic":"وَتَأْسِرُونَ","translation":"এবং তোমরা বন্দী করছো","audioUrl":"wbw/033_026_015.mp3","charTypeName":"word"},{"id":29318,"position":16,"arabic":"فَرِيقًۭا","translation":"(অপর) দলকে","audioUrl":"wbw/033_026_016.mp3","charTypeName":"word"},{"id":29319,"position":17,"arabic":"٢٦","translation":"(২৬)","audioUrl":null,"charTypeName":"end"}]},{"number":27,"arabic":"وَأَوْرَثَكُمْ أَرْضَهُمْ وَدِيَٰرَهُمْ وَأَمْوَٰلَهُمْ وَأَرْضًۭا لَّمْ تَطَـُٔوهَا ۚ وَكَانَ ٱللَّهُ عَلَىٰ كُلِّ شَىْءٍۢ قَدِيرًۭا","translation":"and He made you heirs to their lands, and their houses, and their goods - and [promised you] lands on which you had never yet set foot: for God has indeed the power to will anything.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3560.mp3","surahId":33,"words":[{"id":30282,"position":1,"arabic":"وَأَوْرَثَكُمْ","translation":"এবং উত্তরাধিকারী বানালেন তোমাদেরকে","audioUrl":"wbw/033_027_001.mp3","charTypeName":"word"},{"id":30283,"position":2,"arabic":"أَرْضَهُمْ","translation":"জায়গা জমির তাদের","audioUrl":"wbw/033_027_002.mp3","charTypeName":"word"},{"id":30284,"position":3,"arabic":"وَدِيَـٰرَهُمْ","translation":"ও ঘর বাড়িসমূহের তাদের","audioUrl":"wbw/033_027_003.mp3","charTypeName":"word"},{"id":30285,"position":4,"arabic":"وَأَمْوَٰلَهُمْ","translation":"ও ধনসম্পদের তাদের","audioUrl":"wbw/033_027_004.mp3","charTypeName":"word"},{"id":30286,"position":5,"arabic":"وَأَرْضًۭا","translation":"এবং (এমন)এক দেশের","audioUrl":"wbw/033_027_005.mp3","charTypeName":"word"},{"id":30287,"position":6,"arabic":"لَّمْ","translation":"(যা) নি","audioUrl":"wbw/033_027_006.mp3","charTypeName":"word"},{"id":30288,"position":7,"arabic":"تَطَـُٔوهَا ۚ","translation":"তোমরা পা রাখো তাতে","audioUrl":"wbw/033_027_007.mp3","charTypeName":"word"},{"id":30290,"position":8,"arabic":"وَكَانَ","translation":"এবং হলেন","audioUrl":"wbw/033_027_009.mp3","charTypeName":"word"},{"id":30291,"position":9,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/033_027_010.mp3","charTypeName":"word"},{"id":30292,"position":10,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/033_027_011.mp3","charTypeName":"word"},{"id":30293,"position":11,"arabic":"كُلِّ","translation":"সব","audioUrl":"wbw/033_027_012.mp3","charTypeName":"word"},{"id":30294,"position":12,"arabic":"شَىْءٍۢ","translation":"কিছুর","audioUrl":"wbw/033_027_013.mp3","charTypeName":"word"},{"id":30295,"position":13,"arabic":"قَدِيرًۭا","translation":"সর্বশক্তিমান","audioUrl":"wbw/033_027_014.mp3","charTypeName":"word"},{"id":30296,"position":14,"arabic":"٢٧","translation":"(২৭)","audioUrl":null,"charTypeName":"end"}]},{"number":28,"arabic":"يَٰٓأَيُّهَا ٱلنَّبِىُّ قُل لِّأَزْوَٰجِكَ إِن كُنتُنَّ تُرِدْنَ ٱلْحَيَوٰةَ ٱلدُّنْيَا وَزِينَتَهَا فَتَعَالَيْنَ أُمَتِّعْكُنَّ وَأُسَرِّحْكُنَّ سَرَاحًۭا جَمِيلًۭا","translation":"O PROPHET! Say unto thy wives: “If you desire [but] the life of this world and its charms - well, then, I shall provide for you and release you in a becoming manner;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3561.mp3","surahId":33,"words":[{"id":31282,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/033_028_001.mp3","charTypeName":"word"},{"id"