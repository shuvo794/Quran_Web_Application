{"id":151,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ الٓمٓصٓ","translation":"Alif. Lam. Mim. Sad.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/955.mp3","surahId":7,"words":[{"id":813,"position":1,"arabic":"الٓمٓصٓ","translation":"আলীফ-লাম-মীম-সাদ","audioUrl":"wbw/007_001_001.mp3","charTypeName":"word"},{"id":814,"position":2,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"كِتَٰبٌ أُنزِلَ إِلَيْكَ فَلَا يَكُن فِى صَدْرِكَ حَرَجٌۭ مِّنْهُ لِتُنذِرَ بِهِۦ وَذِكْرَىٰ لِلْمُؤْمِنِينَ","translation":"A DIVINE WRIT has been bestowed from on high upon thee -and let there be no doubt about this in thy heart-in order that thou mayest warn [the erring] thereby, and [thus] admonish the believers:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/956.mp3","surahId":7,"words":[{"id":1980,"position":1,"arabic":"كِتَـٰبٌ","translation":"(এই) কিতাব","audioUrl":"wbw/007_002_001.mp3","charTypeName":"word"},{"id":1981,"position":2,"arabic":"أُنزِلَ","translation":"অবতীর্ণ হয়েছে","audioUrl":"wbw/007_002_002.mp3","charTypeName":"word"},{"id":1982,"position":3,"arabic":"إِلَيْكَ","translation":"তোমার প্রতি","audioUrl":"wbw/007_002_003.mp3","charTypeName":"word"},{"id":1983,"position":4,"arabic":"فَلَا","translation":"অতএব না (যেন)","audioUrl":"wbw/007_002_004.mp3","charTypeName":"word"},{"id":1984,"position":5,"arabic":"يَكُن","translation":"হয়","audioUrl":"wbw/007_002_005.mp3","charTypeName":"word"},{"id":1985,"position":6,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/007_002_006.mp3","charTypeName":"word"},{"id":1986,"position":7,"arabic":"صَدْرِكَ","translation":"তোমার মনের","audioUrl":"wbw/007_002_007.mp3","charTypeName":"word"},{"id":1987,"position":8,"arabic":"حَرَجٌۭ","translation":"কোনো সংকোচ","audioUrl":"wbw/007_002_008.mp3","charTypeName":"word"},{"id":1988,"position":9,"arabic":"مِّنْهُ","translation":"হতে তা","audioUrl":"wbw/007_002_009.mp3","charTypeName":"word"},{"id":1989,"position":10,"arabic":"لِتُنذِرَ","translation":"যেন তুমি সতর্ক করো","audioUrl":"wbw/007_002_010.mp3","charTypeName":"word"},{"id":1990,"position":11,"arabic":"بِهِۦ","translation":"দিয়ে তা","audioUrl":"wbw/007_002_011.mp3","charTypeName":"word"},{"id":1991,"position":12,"arabic":"وَذِكْرَىٰ","translation":"এবং (এই কিতাব) উপদেশ","audioUrl":"wbw/007_002_012.mp3","charTypeName":"word"},{"id":1992,"position":13,"arabic":"لِلْمُؤْمِنِينَ","translation":"জন্যে মু`মিনদের","audioUrl":"wbw/007_002_013.mp3","charTypeName":"word"},{"id":1993,"position":14,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"ٱتَّبِعُوا۟ مَآ أُنزِلَ إِلَيْكُم مِّن رَّبِّكُمْ وَلَا تَتَّبِعُوا۟ مِن دُونِهِۦٓ أَوْلِيَآءَ ۗ قَلِيلًۭا مَّا تَذَكَّرُونَ","translation":"\"Follow what has been sent down unto you by your Sustainer, and follow no masters other than Him. How seldom do you keep this in mind!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/957.mp3","surahId":7,"words":[{"id":3176,"position":1,"arabic":"ٱتَّبِعُوا۟","translation":"তোমরা অনুসরন করো","audioUrl":"wbw/007_003_001.mp3","charTypeName":"word"},{"id":3177,"position":2,"arabic":"مَآ","translation":"যা","audioUrl":"wbw/007_003_002.mp3","charTypeName":"word"},{"id":3178,"position":3,"arabic":"أُنزِلَ","translation":"অবতীর্ণ হয়েছে","audioUrl":"wbw/007_003_003.mp3","charTypeName":"word"},{"id":3179,"position":4,"arabic":"إِلَيْكُم","translation":"প্রতি তোমাদের প","audioUrl":"wbw/007_003_004.mp3","charTypeName":"word"},{"id":3180,"position":5,"arabic":"مِّن","translation":"পক্ষ হতে","audioUrl":"wbw/007_003_005.mp3","charTypeName":"word"},{"id":3181,"position":6,"arabic":"رَّبِّكُمْ","translation":"রবের তোমাদের","audioUrl":"wbw/007_003_006.mp3","charTypeName":"word"},{"id":3182,"position":7,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/007_003_007.mp3","charTypeName":"word"},{"id":3183,"position":8,"arabic":"تَتَّبِعُوا۟","translation":"তোমরা অনুসরণ করো","audioUrl":"wbw/007_003_008.mp3","charTypeName":"word"},{"id":3184,"position":9,"arabic":"مِن","translation":"ছাড়া","audioUrl":"wbw/007_003_009.mp3","charTypeName":"word"},{"id":3185,"position":10,"arabic":"دُونِهِۦٓ","translation":"তাকে","audioUrl":"wbw/007_003_010.mp3","charTypeName":"word"},{"id":3186,"position":11,"arabic":"أَوْلِيَآءَ ۗ","translation":"(অন্যান্যদেরকে) অভিভাবকরূপে","audioUrl":"wbw/007_003_011.mp3","charTypeName":"word"},{"id":3188,"position":12,"arabic":"قَلِيلًۭا","translation":"(কিন্তু) অল্পই","audioUrl":"wbw/007_003_013.mp3","charTypeName":"word"},{"id":3189,"position":13,"arabic":"مَّا","translation":"যা","audioUrl":"wbw/007_003_014.mp3","charTypeName":"word"},{"id":3190,"position":14,"arabic":"تَذَكَّرُونَ","translation":"তোমরা উপদেশ গ্রহণ করো","audioUrl":"wbw/007_003_015.mp3","charTypeName":"word"},{"id":3191,"position":15,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"وَكَم مِّن قَرْيَةٍ أَهْلَكْنَٰهَا فَجَآءَهَا بَأْسُنَا بَيَٰتًا أَوْ هُمْ قَآئِلُونَ","translation":"And how many a [rebellious] community have We destroyed, with Our punishment coming upon it by night, or while they were resting at noontide!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/958.mp3","surahId":7,"words":[{"id":4532,"position":1,"arabic":"وَكَم","translation":"এবং কত (সব)","audioUrl":"wbw/007_004_001.mp3","charTypeName":"word"},{"id":4533,"position":2,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/007_004_002.mp3","charTypeName":"word"},{"id":4534,"position":3,"arabic":"قَرْيَةٍ","translation":"জনপদ","audioUrl":"wbw/007_004_003.mp3","charTypeName":"word"},{"id":4535,"position":4,"arabic":"أَهْلَكْنَـٰهَا","translation":"ধ্বংস করেছি আমরা তা","audioUrl":"wbw/007_004_004.mp3","charTypeName":"word"},{"id":4536,"position":5,"arabic":"فَجَآءَهَا","translation":"তখন উপর এসেছিলো তার","audioUrl":"wbw/007_004_005.mp3","charTypeName":"word"},{"id":4537,"position":6,"arabic":"بَأْسُنَا","translation":"শাস্তি আমাদের","audioUrl":"wbw/007_004_006.mp3","charTypeName":"word"},{"id":4538,"position":7,"arabic":"بَيَـٰتًا","translation":"রাতের বেলায়","audioUrl":"wbw/007_004_007.mp3","charTypeName":"word"},{"id":4539,"position":8,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/007_004_008.mp3","charTypeName":"word"},{"id":4540,"position":9,"arabic":"هُمْ","translation":"তারা (ছিলো)","audioUrl":"wbw/007_004_009.mp3","charTypeName":"word"},{"id":4541,"position":10,"arabic":"قَآئِلُونَ","translation":"দুপুরে বিশ্রাম গ্রহণকারী","audioUrl":"wbw/007_004_010.mp3","charTypeName":"word"},{"id":4542,"position":11,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"فَمَا كَانَ دَعْوَىٰهُمْ إِذْ جَآءَهُم بَأْسُنَآ إِلَّآ أَن قَالُوٓا۟ إِنَّا كُنَّا ظَٰلِمِينَ","translation":"And when Our punishment came upon them, they had nothing to say for themselves, and could only cry, \"Verily, we were wrongdoers!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/959.mp3","surahId":7,"words":[{"id":5808,"position":1,"arabic":"فَمَا","translation":"অতঃপর না","audioUrl":"wbw/007_005_001.mp3","charTypeName":"word"},{"id":5809,"position":2,"arabic":"كَانَ","translation":"ছিলো","audioUrl":"wbw/007_005_002.mp3","charTypeName":"word"},{"id":5810,"position":3,"arabic":"دَعْوَىٰهُمْ","translation":"দাবি তাদের(কথা)","audioUrl":"wbw/007_005_003.mp3","charTypeName":"word"},{"id":5811,"position":4,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/007_005_004.mp3","charTypeName":"word"},{"id":5812,"position":5,"arabic":"جَآءَهُم","translation":"তাদের (কাছে) এসেছিলো","audioUrl":"wbw/007_005_005.mp3","charTypeName":"word"},{"id":5813,"position":6,"arabic":"بَأْسُنَآ","translation":"শাস্তি আমাদের","audioUrl":"wbw/007_005_006.mp3","charTypeName":"word"},{"id":5814,"position":7,"arabic":"إِلَّآ","translation":"এ ছাড়া","audioUrl":"wbw/007_005_007.mp3","charTypeName":"word"},{"id":5815,"position":8,"arabic":"أَن","translation":"যে","audioUrl":"wbw/007_005_008.mp3","charTypeName":"word"},{"id":5816,"position":9,"arabic":"قَالُوٓا۟","translation":"তারা বলেছিলো","audioUrl":"wbw/007_005_009.mp3","charTypeName":"word"},{"id":5817,"position":10,"arabic":"إِنَّا","translation":"\"নিশ্চয়ই আমরা","audioUrl":"wbw/007_005_010.mp3","charTypeName":"word"},{"id":5818,"position":11,"arabic":"كُنَّا","translation":"আমরা ছিলাম","audioUrl":"wbw/007_005_011.mp3","charTypeName":"word"},{"id":5819,"position":12,"arabic":"ظَـٰلِمِينَ","translation":"সীমালঙ্ঘনকারী\"","audioUrl":"wbw/007_005_012.mp3","charTypeName":"word"},{"id":5820,"position":13,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"فَلَنَسْـَٔلَنَّ ٱلَّذِينَ أُرْسِلَ إِلَيْهِمْ وَلَنَسْـَٔلَنَّ ٱلْمُرْسَلِينَ","translation":"Thus, [on Judgment Day] We shall most certainly call to account all those unto whom a [divine] message was sent, and We shall most certainly call to account the message-bearers [themselves];","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/960.mp3","surahId":7,"words":[{"id":7096,"position":1,"arabic":"فَلَنَسْـَٔلَنَّ","translation":"অতএব জিজ্ঞাসা করবোই আমরা","audioUrl":"wbw/007_006_001.mp3","charTypeName":"word"},{"id":7097,"position":2,"arabic":"ٱلَّذِينَ","translation":"তাদেরকে","audioUrl":"wbw/007_006_002.mp3","charTypeName":"word"},{"id":7098,"position":3,"arabic":"أُرْسِلَ","translation":"পাঠান হয়েছিলো","audioUrl":"wbw/007_006_003.mp3","charTypeName":"word"},{"id":7099,"position":4,"arabic":"إِلَيْهِمْ","translation":"প্রতি যাদের","audioUrl":"wbw/007_006_004.mp3","charTypeName":"word"},{"id":7100,"position":5,"arabic":"وَلَنَسْـَٔلَنَّ","translation":"ও অবশ্যই জিজ্ঞাসা করবো আমরা","audioUrl":"wbw/007_006_005.mp3","charTypeName":"word"},{"id":7101,"position":6,"arabic":"ٱلْمُرْسَلِينَ","translation":"রাসূলদেরকেও","audioUrl":"wbw/007_006_006.mp3","charTypeName":"word"},{"id":7102,"position":7,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"فَلَنَقُصَّنَّ عَلَيْهِم بِعِلْمٍۢ ۖ وَمَا كُنَّا غَآئِبِينَ","translation":"and thereupon We shall most certainly reveal unto them Our knowledge [of their doings]: for never have We been absent [from them].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/961.mp3","surahId":7,"words":[{"id":8421,"position":1,"arabic":"فَلَنَقُصَّنَّ","translation":"অতঃপর ঘটনা বর্ণনা করবোই আমরা","audioUrl":"wbw/007_007_001.mp3","charTypeName":"word"},{"id":8422,"position":2,"arabic":"عَلَيْهِم","translation":"কাছে তাদের","audioUrl":"wbw/007_007_002.mp3","charTypeName":"word"},{"id":8423,"position":3,"arabic":"بِعِلْمٍۢ ۖ","translation":"ভিত্তিতে জ্ঞানের","audioUrl":"wbw/007_007_003.mp3","charTypeName":"word"},{"id":8425,"position":4,"arabic":"وَمَا","translation":"আর না","audioUrl":"wbw/007_007_005.mp3","charTypeName":"word"},{"id":8426,"position":5,"arabic":"كُنَّا","translation":"আমরা ছিলাম","audioUrl":"wbw/007_007_006.mp3","charTypeName":"word"},{"id":8427,"position":6,"arabic":"غَآئِبِينَ","translation":"অনুপস্থিত","audioUrl":"wbw/007_007_007.mp3","charTypeName":"word"},{"id":8428,"position":7,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"وَٱلْوَزْنُ يَوْمَئِذٍ ٱلْحَقُّ ۚ فَمَن ثَقُلَتْ مَوَٰزِينُهُۥ فَأُو۟لَٰٓئِكَ هُمُ ٱلْمُفْلِحُونَ","translation":"And true will be the weighing on that Day; and those whose weight [of good deeds] is heavy in the balance -it is they, they who shall attain to a happy state;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/962.mp3","surahId":7,"words":[{"id":9610,"position":1,"arabic":"وَٱلْوَزْنُ","translation":"এবং ওজন","audioUrl":"wbw/007_008_001.mp3","charTypeName":"word"},{"id":9611,"position":2,"arabic":"يَوْمَئِذٍ","translation":"সেদিন (হবে)","audioUrl":"wbw/007_008_002.mp3","charTypeName":"word"},{"id":9612,"position":3,"arabic":"ٱلْحَقُّ ۚ","translation":"যথার্থই","audioUrl":"wbw/007_008_003.mp3","charTypeName":"word"},{"id":9614,"position":4,"arabic":"فَمَن","translation":"অতঃপর যার","audioUrl":"wbw/007_008_005.mp3","charTypeName":"word"},{"id":9615,"position":5,"arabic":"ثَقُلَتْ","translation":"ভারী হবে","audioUrl":"wbw/007_008_006.mp3","charTypeName":"word"},{"id":9616,"position":6,"arabic":"مَوَٰزِينُهُۥ","translation":"পাল্লাসমূহ তার","audioUrl":"wbw/007_008_007.mp3","charTypeName":"word"},{"id":9617,"position":7,"arabic":"فَأُو۟لَـٰٓئِكَ","translation":"অতঃপর ঐসব লোক","audioUrl":"wbw/007_008_008.mp3","charTypeName":"word"},{"id":9618,"position":8,"arabic":"هُمُ","translation":"তারাই","audioUrl":"wbw/007_008_009.mp3","charTypeName":"word"},{"id":9619,"position":9,"arabic":"ٱلْمُفْلِحُونَ","translation":"সফলকাম (হবে)","audioUrl":"wbw/007_008_010.mp3","charTypeName":"word"},{"id":9620,"position":10,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"وَمَنْ خَفَّتْ مَوَٰزِينُهُۥ فَأُو۟لَٰٓئِكَ ٱلَّذِينَ خَسِرُوٓا۟ أَنفُسَهُم بِمَا كَانُوا۟ بِـَٔايَٰتِنَا يَظْلِمُونَ","translation":"whereas those whose weight is light in the balance - it is they who will have squandered their own selves by their wilful rejection of Our messages.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/963.mp3","surahId":7,"words":[{"id":10772,"position":1,"arabic":"وَمَنْ","translation":"এবং যার","audioUrl":"wbw/007_009_001.mp3","charTypeName":"word"},{"id":10773,"position":2,"arabic":"خَفَّتْ","translation":"হালকা হবে","audioUrl":"wbw/007_009_002.mp3","charTypeName":"word"},{"id":10774,"position":3,"arabic":"مَوَٰزِينُهُۥ","translation":"পাল্লাসমূহ তার","audioUrl":"wbw/007_009_003.mp3","charTypeName":"word"},{"id":10775,"position":4,"arabic":"فَأُو۟لَـٰٓئِكَ","translation":"অতঃপর ঐসবলোক","audioUrl":"wbw/007_009_004.mp3","charTypeName":"word"},{"id":10776,"position":5,"arabic":"ٱلَّذِينَ","translation":"(তারাই) যারা","audioUrl":"wbw/007_009_005.mp3","charTypeName":"word"},{"id":10777,"position":6,"arabic":"خَسِرُوٓا۟","translation":"ক্ষতি করেছে","audioUrl":"wbw/007_009_006.mp3","charTypeName":"word"},{"id":10778,"position":7,"arabic":"أَنفُسَهُم","translation":"নিজেদেরকে তাদের","audioUrl":"wbw/007_009_007.mp3","charTypeName":"word"},{"id":10779,"position":8,"arabic":"بِمَا","translation":"একারণে যা","audioUrl":"wbw/007_009_008.mp3","charTypeName":"word"},{"id":10780,"position":9,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/007_009_009.mp3","charTypeName":"word"},{"id":10781,"position":10,"arabic":"بِـَٔايَـٰتِنَا","translation":"সাথে আমাদের নির্দশনাদির","audioUrl":"wbw/007_009_010.mp3","charTypeName":"word"},{"id":10782,"position":11,"arabic":"يَظْلِمُونَ","translation":"সীমালঙ্ঘন করতো","audioUrl":"wbw/007_009_011.mp3","charTypeName":"word"},{"id":10783,"position":12,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"وَلَقَدْ مَكَّنَّٰكُمْ فِى ٱلْأَرْضِ وَجَعَلْنَا لَكُمْ فِيهَا مَعَٰيِشَ ۗ قَلِيلًۭا مَّا تَشْكُرُونَ","translation":"YEA, INDEED, [O men,] We have given you a [bountiful] place on earth, and appointed thereon means of livelihood for you: [yet] how seldom are you grateful!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/964.mp3","surahId":7,"words":[{"id":12026,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/007_010_001.mp3","charTypeName":"word"},{"id":12027,"position":2,"arabic":"مَكَّنَّـٰكُمْ","translation":"আমরা প্রতিষ্ঠিত করেছি তোমাদেরকে","audioUrl":"wbw/007_010_002.mp3","charTypeName":"word"},{"id":12028,"position":3,"arabic":"فِى","translation":"উপর","audioUrl":"wbw/007_010_003.mp3","charTypeName":"word"},{"id":12029,"position":4,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/007_010_004.mp3","charTypeName":"word"},{"id":12030,"position":5,"arabic":"وَجَعَلْنَا","translation":"এবং ব্যবস্হা করেছি আমরা","audioUrl":"wbw/007_010_005.mp3","charTypeName":"word"},{"id":12031,"position":6,"arabic":"لَكُمْ","translation":"জন্যে তোমাদের","audioUrl":"wbw/007_010_006.mp3","charTypeName":"word"},{"id":12032,"position":7,"arabic":"فِيهَا","translation":"মধ্যে তার","audioUrl":"wbw/007_010_007.mp3","charTypeName":"word"},{"id":12033,"position":8,"arabic":"مَعَـٰيِشَ ۗ","translation":"জীবিকার","audioUrl":"wbw/007_010_008.mp3","charTypeName":"word"},{"id":12035,"position":9,"arabic":"قَلِيلًۭا","translation":"(কিন্তু) অল্পই","audioUrl":"wbw/007_010_010.mp3","charTypeName":"word"},{"id":12036,"position":10,"arabic":"مَّا","translation":"যা","audioUrl":"wbw/007_010_011.mp3","charTypeName":"word"},{"id":12037,"position":11,"arabic":"تَشْكُرُونَ","translation":"তোমরা কৃতজ্ঞতা জ্ঞাপন করো","audioUrl":"wbw/007_010_012.mp3","charTypeName":"word"},{"id":12038,"position":12,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"وَلَقَدْ خَلَقْنَٰكُمْ ثُمَّ صَوَّرْنَٰكُمْ ثُمَّ قُلْنَا لِلْمَلَٰٓئِكَةِ ٱسْجُدُوا۟ لِءَادَمَ فَسَجَدُوٓا۟ إِلَّآ إِبْلِيسَ لَمْ يَكُن مِّنَ ٱلسَّٰجِدِينَ","translation":"Yea, indeed, We have created you, and then formed you; and then We said unto the angels, \"Prostrate yourselves before Adam!\" - whereupon they [all] prostrated themselves, save Iblis: he was not among those who prostrated themselves.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/965.mp3","surahId":7,"words":[{"id":13350,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/007_011_001.mp3","charTypeName":"word"},{"id":13351,"position":2,"arabic":"خَلَقْنَـٰكُمْ","translation":"সৃষ্টি করেছি আমরা তোমাদের","audioUrl":"wbw/007_011_002.mp3","charTypeName":"word"},{"id":13352,"position":3,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/007_011_003.mp3","charTypeName":"word"},{"id":13353,"position":4,"arabic":"صَوَّرْنَـٰكُمْ","translation":"রূপদান করেছি আমরা তোমাদেরকে","audioUrl":"wbw/007_011_004.mp3","charTypeName":"word"},{"id":13354,"position":5,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/007_011_005.mp3","charTypeName":"word"},{"id":13355,"position":6,"arabic":"قُلْنَا","translation":"বলেছিলাম আমরা","audioUrl":"wbw/007_011_006.mp3","charTypeName":"word"},{"id":13356,"position":7,"arabic":"لِلْمَلَـٰٓئِكَةِ","translation":"উদ্দেশ্যে ফেরেশতাদের","audioUrl":"wbw/007_011_007.mp3","charTypeName":"word"},{"id":13357,"position":8,"arabic":"ٱسْجُدُوا۟","translation":"\"তোমরা সিজদা করো","audioUrl":"wbw/007_011_008.mp3","charTypeName":"word"},{"id":13358,"position":9,"arabic":"لِـَٔادَمَ","translation":"উদ্দেশ্যে আদমের\"","audioUrl":"wbw/007_011_009.mp3","charTypeName":"word"},{"id":13359,"position":10,"arabic":"فَسَجَدُوٓا۟","translation":"অতঃপর তারা সিজদা করলো","audioUrl":"wbw/007_011_010.mp3","charTypeName":"word"},{"id":13360,"position":11,"arabic":"إِلَّآ","translation":"ছাড়া","audioUrl":"wbw/007_011_011.mp3","charTypeName":"word"},{"id":13361,"position":12,"arabic":"إِبْلِيسَ","translation":"ইবলীস","audioUrl":"wbw/007_011_012.mp3","charTypeName":"word"},{"id":13362,"position":13,"arabic":"لَمْ","translation":"নি","audioUrl":"wbw/007_011_013.mp3","charTypeName":"word"},{"id":13363,"position":14,"arabic":"يَكُن","translation":"সে হয়","audioUrl":"wbw/007_011_014.mp3","charTypeName":"word"},{"id":13364,"position":15,"arabic":"مِّنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/007_011_015.mp3","charTypeName":"word"},{"id":13365,"position":16,"arabic":"ٱلسَّـٰجِدِينَ","translation":"সিজদাকারীদের","audioUrl":"wbw/007_011_016.mp3","charTypeName":"word"},{"id":13366,"position":17,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]}]}