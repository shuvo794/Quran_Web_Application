{"id":472,"ayahs":[{"number":41,"arabic":"۞ وَيَٰقَوْمِ مَا لِىٓ أَدْعُوكُمْ إِلَى ٱلنَّجَوٰةِ وَتَدْعُونَنِىٓ إِلَى ٱلنَّارِ","translation":"“And, O my people, how is it that I summon you to salvation, the while you summon me to the fire?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4174.mp3","surahId":40,"words":[{"id":41949,"position":1,"arabic":"۞ وَيَـٰقَوْمِ","translation":"এবং (সে বললো) হে আমার জাতি","audioUrl":"wbw/040_041_002.mp3","charTypeName":"word"},{"id":41950,"position":2,"arabic":"مَا","translation":"(এটা)","audioUrl":"wbw/040_041_003.mp3","charTypeName":"word"},{"id":41951,"position":3,"arabic":"لِىٓ","translation":"আমার সাথে কেমন আচরণ","audioUrl":"wbw/040_041_004.mp3","charTypeName":"word"},{"id":41952,"position":4,"arabic":"أَدْعُوكُمْ","translation":"আমি তোমাদের ডাকছি","audioUrl":"wbw/040_041_005.mp3","charTypeName":"word"},{"id":41953,"position":5,"arabic":"إِلَى","translation":"দিকে","audioUrl":"wbw/040_041_006.mp3","charTypeName":"word"},{"id":41954,"position":6,"arabic":"ٱلنَّجَوٰةِ","translation":"পরিত্রাণের","audioUrl":"wbw/040_041_007.mp3","charTypeName":"word"},{"id":41955,"position":7,"arabic":"وَتَدْعُونَنِىٓ","translation":"অথচ আমাকে তোমরা ডাকছো","audioUrl":"wbw/040_041_008.mp3","charTypeName":"word"},{"id":41956,"position":8,"arabic":"إِلَى","translation":"দিকে","audioUrl":"wbw/040_041_009.mp3","charTypeName":"word"},{"id":41957,"position":9,"arabic":"ٱلنَّارِ","translation":"জাহান্নামের","audioUrl":"wbw/040_041_010.mp3","charTypeName":"word"},{"id":41958,"position":10,"arabic":"٤١","translation":"(৪১)","audioUrl":null,"charTypeName":"end"}]},{"number":42,"arabic":"تَدْعُونَنِى لِأَكْفُرَ بِٱللَّهِ وَأُشْرِكَ بِهِۦ مَا لَيْسَ لِى بِهِۦ عِلْمٌۭ وَأَنَا۠ أَدْعُوكُمْ إِلَى ٱلْعَزِيزِ ٱلْغَفَّٰرِ","translation":"- [for] you call upon me to deny [the one­ness of] God and to ascribe a share in His divinity to aught of which I cannot [possibly] have any knowl­edge the while I summon you to [a cognition of] the Almighty, the All-Forgiving!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4175.mp3","surahId":40,"words":[{"id":42714,"position":1,"arabic":"تَدْعُونَنِى","translation":"আমাকে তোমরা ডাকছো","audioUrl":"wbw/040_042_001.mp3","charTypeName":"word"},{"id":42715,"position":2,"arabic":"لِأَكْفُرَ","translation":"যেন আমি অস্বীকার করি","audioUrl":"wbw/040_042_002.mp3","charTypeName":"word"},{"id":42716,"position":3,"arabic":"بِٱللَّهِ","translation":"প্রতি আল্লাহর","audioUrl":"wbw/040_042_003.mp3","charTypeName":"word"},{"id":42717,"position":4,"arabic":"وَأُشْرِكَ","translation":"ও  শরিক করি (যেন) আমি","audioUrl":"wbw/040_042_004.mp3","charTypeName":"word"},{"id":42718,"position":5,"arabic":"بِهِۦ","translation":"তাঁর সাথে","audioUrl":"wbw/040_042_005.mp3","charTypeName":"word"},{"id":42719,"position":6,"arabic":"مَا","translation":"যা","audioUrl":"wbw/040_042_006.mp3","charTypeName":"word"},{"id":42720,"position":7,"arabic":"لَيْسَ","translation":"নেই","audioUrl":"wbw/040_042_007.mp3","charTypeName":"word"},{"id":42721,"position":8,"arabic":"لِى","translation":"আমার কাছে","audioUrl":"wbw/040_042_008.mp3","charTypeName":"word"},{"id":42722,"position":9,"arabic":"بِهِۦ","translation":"সে সম্পর্কে","audioUrl":"wbw/040_042_009.mp3","charTypeName":"word"},{"id":42723,"position":10,"arabic":"عِلْمٌۭ","translation":"কোনো জ্ঞান","audioUrl":"wbw/040_042_010.mp3","charTypeName":"word"},{"id":42724,"position":11,"arabic":"وَأَنَا۠","translation":"এবং আমি","audioUrl":"wbw/040_042_011.mp3","charTypeName":"word"},{"id":42725,"position":12,"arabic":"أَدْعُوكُمْ","translation":"ডাকছি তোমাদেরকে","audioUrl":"wbw/040_042_012.mp3","charTypeName":"word"},{"id":42726,"position":13,"arabic":"إِلَى","translation":"দিকে","audioUrl":"wbw/040_042_013.mp3","charTypeName":"word"},{"id":42727,"position":14,"arabic":"ٱلْعَزِيزِ","translation":"পরাক্রমশালীর","audioUrl":"wbw/040_042_014.mp3","charTypeName":"word"},{"id":42728,"position":15,"arabic":"ٱلْغَفَّـٰرِ","translation":"(যিনি) পরম ক্ষমাশ