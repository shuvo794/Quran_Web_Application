:"word"},{"id":43461,"position":11,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/040_043_011.mp3","charTypeName":"word"},{"id":43462,"position":12,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/040_043_012.mp3","charTypeName":"word"},{"id":43463,"position":13,"arabic":"ٱلْـَٔاخِرَةِ","translation":"পরকালের","audioUrl":"wbw/040_043_013.mp3","charTypeName":"word"},{"id":43464,"position":14,"arabic":"وَأَنَّ","translation":"এবং (এও) যে","audioUrl":"wbw/040_043_014.mp3","charTypeName":"word"},{"id":43465,"position":15,"arabic":"مَرَدَّنَآ","translation":"আমাদের প্রত্যাবর্তন হবে","audioUrl":"wbw/040_043_015.mp3","charTypeName":"word"},{"id":43466,"position":16,"arabic":"إِلَى","translation":"দিকে","audioUrl":"wbw/040_043_016.mp3","charTypeName":"word"},{"id":43467,"position":17,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/040_043_017.mp3","charTypeName":"word"},{"id":43468,"position":18,"arabic":"وَأَنَّ","translation":"এবং (এও সত্য) যে","audioUrl":"wbw/040_043_018.mp3","charTypeName":"word"},{"id":43469,"position":19,"arabic":"ٱلْمُسْرِفِينَ","translation":"সীমালংঘনকারী","audioUrl":"wbw/040_043_019.mp3","charTypeName":"word"},{"id":43470,"position":20,"arabic":"هُمْ","translation":"তারাই","audioUrl":"wbw/040_043_020.mp3","charTypeName":"word"},{"id":43471,"position":21,"arabic":"أَصْحَـٰبُ","translation":"অধিবাসী","audioUrl":"wbw/040_043_021.mp3","charTypeName":"word"},{"id":43472,"position":22,"arabic":"ٱلنَّارِ","translation":"জাহান্নামের","audioUrl":"wbw/040_043_022.mp3","charTypeName":"word"},{"id":43473,"position":23,"arabic":"٤٣","translation":"(৪৩)","audioUrl":null,"charTypeName":"end"}]},{"number":44,"arabic":"فَسَتَذْكُرُونَ مَآ أَقُولُ لَكُمْ ۚ وَأُفَوِّضُ أَمْرِىٓ إِلَى ٱللَّهِ ۚ إِنَّ ٱللَّهَ بَصِيرٌۢ بِٱلْعِبَادِ","translation":"and at that time you will [have cause to] remember what I am telling you [now]. “But [as for me,] I commit myself unto God: for, verily, God sees all that is in [the hearts of] His servants.”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4177.mp3","surahId":40,"words":[{"id":44172,"position":1,"arabic":"فَسَتَذْكُرُونَ","translation":"তোমরা অতঃপর শীঘ্রই স্মরণ করবে","audioUrl":"wbw/040_044_001.mp3","charTypeName":"word"},{"id":44173,"position":2,"arabic":"مَآ","translation":"যা","audioUrl":"wbw/040_044_002.mp3","charTypeName":"word"},{"id":44174,"position":3,"arabic":"أَقُولُ","translation":"আমি বলছি","audioUrl":"wbw/040_044_003.mp3","charTypeName":"word"},{"id":44175,"position":4,"arabic":"لَكُمْ ۚ","translation":"তোমাদেরকে","audioUrl":"wbw/040_044_004.mp3","charTypeName":"word"},{"id":44177,"position":5,"arabic":"وَأُفَوِّضُ","translation":"এবং সমর্পণ করছি আমি","audioUrl":"wbw/040_044_006.mp3","charTypeName":"word"},{"id":44178,"position":6,"arabic":"أَمْرِىٓ","translation":"আমার ব্যাপারে","audioUrl":"wbw/040_044_007.mp3","charTypeName":"word"},{"id":44179,"position":7,"arabic":"إِلَى","translation":"কাছে","audioUrl":"wbw/040_044_008.mp3","charTypeName":"word"},{"id":44180,"position":8,"arabic":"ٱللَّهِ ۚ","translation":"আল্লাহর","audioUrl":"wbw/040_044_009.mp3","charTypeName":"word"},{"id":44182,"position":9,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/040_044_011.mp3","charTypeName":"word"},{"id":44183,"position":10,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/040_044_012.mp3","charTypeName":"word"},{"id":44184,"position":11,"arabic":"بَصِيرٌۢ","translation":"সবিশেষ দৃষ্টি রাখেন","audioUrl":"wbw/040_044_013.mp3","charTypeName":"word"},{"id":44185,"position":12,"arabic":"بِٱلْعِبَادِ","translation":"প্রতি দাসদের\"","audioUrl":"wbw/040_044_014.mp3","charTypeName":"word"},{"id":44186,"position":13,"arabic":"٤٤","translation":"(৪৪)","audioUrl":null,"charTypeName":"end"}]},{"number":45,"arabic":"فَوَقَىٰهُ ٱللَّهُ سَيِّـَٔاتِ مَا مَكَرُوا۟ ۖ وَحَاقَ بِـَٔالِ فِرْعَوْنَ سُوٓءُ ٱلْعَذَابِ","translation":"And God preserved him from the evil of their scheming, whereas suffering vile was to encompass Pharaoh’s folk:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4178.mp3","surahId":40,"words":[{"id":45568,"position":1,"arabic":"فَوَقَىٰهُ","translation":"অতঃপর তাকে বাঁচালেন","audioUrl":"wbw/040_045_001.mp3","charTypeName":"word"},{"id":45569,"position":2,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/040_045_002.mp3","charTypeName":"word"},{"id":45570,"position":3,"arabic":"سَيِّـَٔاتِ","translation":"অনিষ্টসমূহ হ'তে","audioUrl":"wbw/040_045_003.mp3","charTypeName":"word"},{"id":45571,"position":4,"arabic":"مَا","translation":"যা","audioUrl":"wbw/040_045_004.mp3","charTypeName":"word"},{"id":45572,"position":5,"arabic":"مَكَرُوا۟ ۖ","translation":"তারা চক্রান্ত করেছিলো","audioUrl":"wbw/040_045_005.mp3","charTypeName":"word"},{"id":45574,"position":6,"arabic":"وَحَاقَ","translation":"এবং ঘিরে ফেললো","audioUrl":"wbw/040_045_007.mp3","charTypeName":"word"},{"id":45575,"position":7,"arabic":"بِـَٔالِ","translation":"সম্প্রদায়কে","audioUrl":"wbw/040_045_008.mp3","charTypeName":"word"},{"id":45576,"position":8,"arabic":"فِرْعَوْنَ","translation":"ফিরআউনের","audioUrl":"wbw/040_045_009.mp3","charTypeName":"word"},{"id":45577,"position":9,"arabic":"سُوٓءُ","translation":"কঠিন","audioUrl":"wbw/040_045_010.mp3","charTypeName":"word"},{"id":45578,"position":10,"arabic":"ٱلْعَذَابِ","translation":"শাস্তিতে","audioUrl":"wbw/040_045_011.mp3","charTypeName":"word"},{"id":45579,"position":11,"arabic":"٤٥","translation":"(৪৫)","audioUrl":null,"charTypeName":"end"}]},{"number":46,"arabic":"ٱلنَّارُ يُعْرَضُونَ عَلَيْهَا غُدُوًّۭا وَعَشِيًّۭا ۖ وَيَوْمَ تَقُومُ ٱلسَّاعَةُ أَدْخِلُوٓا۟ ءَالَ فِرْعَوْنَ أَشَدَّ ٱلْعَذَابِ","translation":"the fire [of the hereafter - that fire] which they had been made to contemplate [in vain], morning and evening: for on the Day when the Last Hour dawns [God will say], “Make Phar­aoh’s folk enter upon suffering most severe!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4179.mp3","surahId":40,"words":[{"id":45651,"position":1,"arabic":"ٱلنَّارُ","translation":"(দোজখের) আগুন","audioUrl":"wbw/040_046_001.mp3","charTypeName":"word"},{"id":45652,"position":2,"arabic":"يُعْرَضُونَ","translation":"তাদের পেশ করা হয়","audioUrl":"wbw/040_046_002.mp3","charTypeName":"word"},{"id":45653,"position":3,"arabic":"عَلَيْهَا","translation":"তার উপর","audioUrl":"wbw/040_046_003.mp3","charTypeName":"word"},{"id":45654,"position":4,"arabic":"غُدُوًّۭا","translation":"সকালে","audioUrl":"wbw/040_046_004.mp3","charTypeName":"word"},{"id":45655,"position":5,"arabic":"وَعَشِيًّۭا ۖ","translation":"ও সন্ধ্যায়","audioUrl":"wbw/040_046_005.mp3","charTypeName":"word"},{"id":45657,"position":6,"arabic":"وَيَوْمَ","translation":"এবং যে দিন","audioUrl":"wbw/040_046_007.mp3","charTypeName":"word"},{"id":45658,"position":7,"arabic":"تَقُومُ","translation":"ঘটবে","audioUrl":"wbw/040_046_008.mp3","charTypeName":"word"},{"id":45659,"position":8,"arabic":"ٱلسَّاعَةُ","translation":"ক্বিয়ামাত","audioUrl":"wbw/040_046_009.mp3","charTypeName":"word"},{"id":45660,"position":9,"arabic":"أَدْخِلُوٓا۟","translation":"\"(তখন বলা হবে) প্রবেশ করাও","audioUrl":"wbw/040_046_010.mp3","charTypeName":"word"},{"id":45661,"position":10,"arabic":"ءَالَ","translation":"সম্প্রদায়কে","audioUrl":"wbw/040_046_011.mp3","charTypeName":"word"},{"id":45662,"position":11,"arabic":"فِرْعَوْنَ","translation":"ফিরআউনের","audioUrl":"wbw/040_046_012.mp3","charTypeName":"word"},{"id":45663,"position":12,"arabic":"أَشَدَّ","translation":"কঠিন","audioUrl":"wbw/040_046_013.mp3","charTypeName":"word"},{"id":45664,"position":13,"arabic":"ٱلْعَذَابِ","translation":"শাস্তিতে\"","audioUrl":"wbw/040_046_014.mp3","charTypeName":"word"},{"id":45665,"position":14,"arabic":"٤٦","translation":"(৪৬)","audioUrl":null,"charTypeName":"end"}]},{"number":47,"arabic":"وَإِذْ يَتَحَآجُّونَ فِى ٱلنَّارِ فَيَقُولُ ٱلضُّعَفَٰٓؤُا۟ لِلَّذِينَ ٱسْتَكْبَرُوٓا۟ إِنَّا كُنَّا لَكُمْ تَبَعًۭا فَهَلْ أَنتُم مُّغْنُونَ عَنَّا نَصِيبًۭا مِّنَ ٱلنَّارِ","translation":"AND LO! They [who in life were wont to deny the truth] will contend with one another in the fire [of the hereafter]; and then the weak will say unto those who had gloried in their arrogance, “Behold, we were but your followers: can you, then, relieve us of some [of our] share of this fire?”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4180.mp3","surahId":40,"words":[{"id":46947,"position":1,"arabic":"وَإِذْ","translation":"এবং (ভেবে দেখো) যখন","audioUrl":"wbw/040_047_001.mp3","charTypeName":"word"},{"id":46948,"position":2,"arabic":"يَتَحَآجُّونَ","translation":"তারা তর্কাতর্কি করবে","audioUrl":"wbw/040_047_002.mp3","charTypeName":"word"},{"id":46949,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/040_047_003.mp3","charTypeName":"word"},{"id":46950,"position":4,"arabic":"ٱلنَّارِ","translation":"আগুনের","audioUrl":"wbw/040_047_004.mp3","charTypeName":"word"},{"id":46951,"position":5,"arabic":"فَيَقُولُ","translation":"তখন বলবে","audioUrl":"wbw/040_047_005.mp3","charTypeName":"word"},{"id":46952,"position":6,"arabic":"ٱلضُّعَفَـٰٓؤُا۟","translation":"দুর্বলেরা","audioUrl":"wbw/040_047_006.mp3","charTypeName":"word"},{"id":46953,"position":7,"arabic":"لِلَّذِينَ","translation":"(তাদের)-কে যারা","audioUrl":"wbw/040_047_007.mp3","charTypeName":"word"},{"id":46954,"position":8,"arabic":"ٱسْتَكْبَرُوٓا۟","translation":"অহংকার করে (বড় বনে) ছিলো","audioUrl":"wbw/040_047_008.mp3","charTypeName":"word"},{"id":46955,"position":9,"arabic":"إِنَّا","translation":"\"নিশ্চয়ই আমরা","audioUrl":"wbw/040_047_009.mp3","charTypeName":"word"},{"id":46956,"position":10,"arabic":"كُنَّا","translation":"ছিলাম","audioUrl":"wbw/040_047_010.mp3","charTypeName":"word"},{"id":46957,"position":11,"arabic":"لَكُمْ","translation":"তোমাদের","audioUrl":"wbw/040_047_011.mp3","charTypeName":"word"},{"id":46958,"position":12,"arabic":"تَبَعًۭا","translation":"অনুসারী","audioUrl":"wbw/040_047_012.mp3","charTypeName":"word"},{"id":46959,"position":13,"arabic":"فَهَلْ","translation":"কি এখন","audioUrl":"wbw/040_047_013.mp3","charTypeName":"word"},{"id":46960,"position":14,"arabic":"أَنتُم","translation":"তোমরা","audioUrl":"wbw/040_047_014.mp3","charTypeName":"word"},{"id":46961,"position":15,"arabic":"مُّغْنُونَ","translation":"কাজে আসবে","audioUrl":"wbw/040_047_015.mp3","charTypeName":"word"},{"id":46962,"position":16,"arabic":"عَنَّا","translation":"আমাদের জন্যে","audioUrl":"wbw/040_047_016.mp3","charTypeName":"word"},{"id":46963,"position":17,"arabic":"نَصِيبًۭا","translation":"কিছু অংশ (কমাতে)","audioUrl":"wbw/040_047_017.mp3","charTypeName":"word"},{"id":46964,"position":18,"arabic":"مِّنَ","translation":"হ'তে","audioUrl":"wbw/040_047_018.mp3","charTypeName":"word"},{"id":46965,"position":19,"arabic":"ٱلنَّارِ","translation":"(দোযখের) আগুনের\"","audioUrl":"wbw/040_047_019.mp3","charTypeName":"word"},{"id":46966,"position":20,"arabic":"٤٧","translation":"(৪৭)","audioUrl":null,"charTypeName":"end"}]},{"number":48,"arabic":"قَالَ ٱلَّذِينَ ٱسْتَكْبَرُوٓا۟ إِنَّا كُلٌّۭ فِيهَآ إِنَّ ٱللَّهَ قَدْ حَكَمَ بَيْنَ ٱلْعِبَادِ","translation":"[to which] they who had [once] been arrogant will reply, “Behold, we are all in it [together]! Verily, God has judged between His creatures!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4181.mp3","surahId":40,"words":[{"id":47028,"position":1,"arabic":"قَالَ","translation":"বলবে","audioUrl":"wbw/040_048_001.mp3","charTypeName":"word"},{"id":47029,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/040_048_002.mp3","charTypeName":"word"},{"id":47030,"position":3,"arabic":"ٱسْتَكْبَرُوٓا۟","translation":"অহংকার করে (বড় বনে) ছিলো","audioUrl":"wbw/040_048_003.mp3","charTypeName":"word"},{"id":47031,"position":4,"arabic":"إِنَّا","translation":"\"নিশ্চয়ই আমরা","audioUrl":"wbw/040_048_004.mp3","charTypeName":"word"},{"id":47032,"position":5,"arabic":"كُلٌّۭ","translation":"সবাই","audioUrl":"wbw/040_048_005.mp3","charTypeName":"word"},{"id":47033,"position":6,"arabic":"فِيهَآ","translation":"তার মধ্যে (একই অবস্থায়)","audioUrl":"wbw/040_048_006.mp3","charTypeName":"word"},{"id":47034,"position":7,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/040_048_007.mp3","charTypeName":"word"},{"id":47035,"position":8,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/040_048_008.mp3","charTypeName":"word"},{"id":47036,"position":9,"arabic":"قَدْ","translation":"নিশ্চয়","audioUrl":"wbw/040_048_009.mp3","charTypeName":"word"},{"id":47037,"position":10,"arabic":"حَكَمَ","translation":"মীমাংসা করে দিয়েছেন","audioUrl":"wbw/040_048_010.mp3","charTypeName":"word"},{"id":47038,"position":11,"arabic":"بَيْنَ","translation":"মাঝে","audioUrl":"wbw/040_048_011.mp3","charTypeName":"word"},{"id":47039,"position":12,"arabic":"ٱلْعِبَادِ","translation":"দাসদের\"","audioUrl":"wbw/040_048_012.mp3","charTypeName":"word"},{"id":47040,"position":13,"arabic":"٤٨","translation":"(৪৮)","audioUrl":null,"charTypeName":"end"}]},{"number":49,"arabic":"وَقَالَ ٱلَّذِينَ فِى ٱلنَّارِ لِخَزَنَةِ جَهَنَّمَ ٱدْعُوا۟ رَبَّكُمْ يُخَفِّفْ عَنَّا يَوْمًۭا مِّنَ ٱلْعَذَابِ","translation":"And they who are in the fire will say to the keepers of hell, “Pray unto your Sustainer that He lighten, [though it be] for one day [only], this suffering of ours!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4182.mp3","surahId":40,"words":[{"id":48247,"position":1,"arabic":"وَقَالَ","translation":"এবং বলবে","audioUrl":"wbw/040_049_001.mp3","charTypeName":"word"},{"id":48248,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/040_049_002.mp3","charTypeName":"word"},{"id":48249,"position":3,"arabic":"فِى","translation":"মধ্যে (থাকবে)","audioUrl":"wbw/040_049_003.mp3","charTypeName":"word"},{"id":48250,"position":4,"arabic":"ٱلنَّارِ","translation":"আগুনের","audioUrl":"wbw/040_049_004.mp3","charTypeName":"word"},{"id":48251,"position":5,"arabic":"لِخَزَنَةِ","translation":"প্রহরীদেরকে","audioUrl":"wbw/040_049_005.mp3","charTypeName":"word"},{"id":48252,"position":6,"arabic":"جَهَنَّمَ","translation":"জাহান্নামের","audioUrl":"wbw/040_049_006.mp3","charTypeName":"word"},{"id":48253,"position":7,"arabic":"ٱدْعُوا۟","translation":"\"তোমরা প্রার্থনা করো","audioUrl":"wbw/040_049_007.mp3","charTypeName":"word"},{"id":48254,"position":8,"arabic":"رَبَّكُمْ","translation":"তোমাদের রবের কাছে","audioUrl":"wbw/040_049_008.mp3","charTypeName":"word"},{"id":48255,"position":9,"arabic":"يُخَفِّفْ","translation":"কমিয়ে দেন (যেন)","audioUrl":"wbw/040_049_009.mp3","charTypeName":"word"},{"id":48256,"position":10,"arabic":"عَنَّا","translation":"আমাদের থেকে","audioUrl":"wbw/040_049_010.mp3","charTypeName":"word"},{"id":48257,"position":11,"arabic":"يَوْمًۭا","translation":"একদিন","audioUrl":"wbw/040_049_011.mp3","charTypeName":"word"},{"id":48258,"position":12,"arabic":"مِّنَ","translation":"থেকে","audioUrl":"wbw/040_049_012.mp3","charTypeName":"word"},{"id":48259,"position":13,"arabic":"ٱلْعَذَابِ","translation":"শাস্তির\"","audioUrl":"wbw/040_049_013.mp3","charTypeName":"word"},{"id":48260,"position":14,"arabic":"٤٩","translation":"(৪৯)","audioUrl":null,"charTypeName":"end"}]}]}