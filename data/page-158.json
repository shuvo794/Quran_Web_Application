peName":"word"},{"id":57556,"position":10,"arabic":"سَفَاهَةٍۢ","translation":"নির্বুদ্ধিতার","audioUrl":"wbw/007_066_010.mp3","charTypeName":"word"},{"id":57557,"position":11,"arabic":"وَإِنَّا","translation":"এবং  নিশ্চয়ই আমরা","audioUrl":"wbw/007_066_011.mp3","charTypeName":"word"},{"id":57558,"position":12,"arabic":"لَنَظُنُّكَ","translation":"অবশ্যই আমরা তোমাকে মনে করি","audioUrl":"wbw/007_066_012.mp3","charTypeName":"word"},{"id":57559,"position":13,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/007_066_013.mp3","charTypeName":"word"},{"id":57560,"position":14,"arabic":"ٱلْكَـٰذِبِينَ","translation":"মিথ্যাবাদীদের\"","audioUrl":"wbw/007_066_014.mp3","charTypeName":"word"},{"id":57561,"position":15,"arabic":"٦٦","translation":"(৬৬)","audioUrl":null,"charTypeName":"end"}]},{"number":67,"arabic":"قَالَ يَٰقَوْمِ لَيْسَ بِى سَفَاهَةٌۭ وَلَٰكِنِّى رَسُولٌۭ مِّن رَّبِّ ٱلْعَٰلَمِينَ","translation":"Said [Hud]: \"O my people! There is no weak-mindedness in me, but I am an apostle from the Sustainer of all the worlds.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1021.mp3","surahId":7,"words":[{"id":57993,"position":1,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/007_067_001.mp3","charTypeName":"word"},{"id":57994,"position":2,"arabic":"يَـٰقَوْمِ","translation":"\"হে আমার জাতি","audioUrl":"wbw/007_067_002.mp3","charTypeName":"word"},{"id":57995,"position":3,"arabic":"لَيْسَ","translation":"নেই","audioUrl":"wbw/007_067_003.mp3","charTypeName":"word"},{"id":57996,"position":4,"arabic":"بِى","translation":"মধ্যে আমার","audioUrl":"wbw/007_067_004.mp3","charTypeName":"word"},{"id":57997,"position":5,"arabic":"سَفَاهَةٌۭ","translation":"কোন নির্বুদ্ধিতা","audioUrl":"wbw/007_067_005.mp3","charTypeName":"word"},{"id":57998,"position":6,"arabic":"وَلَـٰكِنِّى","translation":"বরং আমি","audioUrl":"wbw/007_067_006.mp3","charTypeName":"word"},{"id":57999,"position":7,"arabic":"رَسُولٌۭ","translation":"একজন রাসূল","audioUrl":"wbw/007_067_007.mp3","charTypeName":"word"},{"id":58000,"position":8,"arabic":"مِّن","translation":"পক্ষ হতে","audioUrl":"wbw/007_067_008.mp3","charTypeName":"word"},{"id":58001,"position":9,"arabic":"رَّبِّ","translation":"রবের","audioUrl":"wbw/007_067_009.mp3","charTypeName":"word"},{"id":58002,"position":10,"arabic":"ٱلْعَـٰلَمِينَ","translation":"বিশ্বজগতের","audioUrl":"wbw/007_067_010.mp3","charTypeName":"word"},{"id":58003,"position":11,"arabic":"٦٧","translation":"(৬৭)","audioUrl":null,"charTypeName":"end"}]}]}