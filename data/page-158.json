{"id":158,"ayahs":[{"number":58,"arabic":"وَٱلْبَلَدُ ٱلطَّيِّبُ يَخْرُجُ نَبَاتُهُۥ بِإِذْنِ رَبِّهِۦ ۖ وَٱلَّذِى خَبُثَ لَا يَخْرُجُ إِلَّا نَكِدًۭا ۚ كَذَٰلِكَ نُصَرِّفُ ٱلْءَايَٰتِ لِقَوْمٍۢ يَشْكُرُونَ","translation":"As for the good land, its vegetation comes forth [in abundance] by its Sustainer's leave, whereas from the bad it comes forth but poorly. Thus do We give many facets to Our messages for [the benefit of] people who are grateful!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1012.mp3","surahId":7,"words":[{"id":53060,"position":1,"arabic":"وَٱلْبَلَدُ","translation":"এবং ভূখন্ড","audioUrl":"wbw/007_058_001.mp3","charTypeName":"word"},{"id":53061,"position":2,"arabic":"ٱلطَّيِّبُ","translation":"উৎকৃষ্ট","audioUrl":"wbw/007_058_002.mp3","charTypeName":"word"},{"id":53062,"position":3,"arabic":"يَخْرُجُ","translation":"উৎপন্ন করে","audioUrl":"wbw/007_058_003.mp3","charTypeName":"word"},{"id":53063,"position":4,"arabic":"نَبَاتُهُۥ","translation":"ফসল তার (উৎকৃষ্ট)","audioUrl":"wbw/007_058_004.mp3","charTypeName":"word"},{"id":53064,"position":5,"arabic":"بِإِذْنِ","translation":"মাধ্যমে আদেশের","audioUrl":"wbw/007_058_005.mp3","charTypeName":"word"},{"id":53065,"position":6,"arabic":"رَبِّهِۦ ۖ","translation":"রবের তার","audioUrl":"wbw/007_058_006.mp3","charTypeName":"word"},{"id":53067,"position":7,"arabic":"وَٱلَّذِى","translation":"এবং যা","audioUrl":"wbw/007_058_008.mp3","charTypeName":"word"},{"id":53068,"position":8,"arabic":"خَبُثَ","translation":"নিকৃষ্ট","audioUrl":"wbw/007_058_009.mp3","charTypeName":"word"},{"id":53069,"position":9,"arabic":"لَا","translation":"না","audioUrl":"wbw/007_058_010.mp3","charTypeName":"word"},{"id":53070,"position":10,"arabic":"يَخْرُجُ","translation":"উৎপন্ন করে","audioUrl":"wbw/007_058_011.mp3","charTypeName":"word"},{"id":53071,"position":11,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/007_058_012.mp3","charTypeName":"word"},{"id":53072,"position":12,"arabic":"نَكِدًۭا ۚ","translation":"কঠোর পরিশ্রম","audioUrl":"wbw/007_058_013.mp3","charTypeName":"word"},{"id":53074,"position":13,"arabic":"كَذَٰلِكَ","translation":"এভাবে","audioUrl":"wbw/007_058_015.mp3","charTypeName":"word"},{"id":53075,"position":14,"arabic":"نُصَرِّفُ","translation":"বারবার পেশ করি আমরা","audioUrl":"wbw/007_058_016.mp3","charTypeName":"word"},{"id":53076,"position":15,"arabic":"ٱلْـَٔايَـٰتِ","translation":"নিদর্শনগুলোকে","audioUrl":"wbw/007_058_017.mp3","charTypeName":"word"},{"id":53077,"position":16,"arabic":"لِقَوْمٍۢ","translation":"জন্যে সম্প্রদায়ের","audioUrl":"wbw/007_058_018.mp3","charTypeName":"word"},{"id":53078,"position":17,"arabic":"يَشْكُرُونَ","translation":"(যারা)কৃতজ্ঞতা প্রকাশ করে","audioUrl":"wbw/007_058_019.mp3","charTypeName":"word"},{"id":53079,"position":18,"arabic":"٥٨","translation":"(৫৮)","audioUrl":null,"charTypeName":"end"}]},{"number":59,"arabic":"لَقَدْ أَرْسَلْنَا نُوحًا إِلَىٰ قَوْمِهِۦ فَقَالَ يَٰقَوْمِ ٱعْبُدُوا۟ ٱللَّهَ مَا لَكُم مِّنْ إِلَٰهٍ غَيْرُهُۥٓ إِنِّىٓ أَخَافُ عَلَيْكُمْ عَذَابَ يَوْمٍ عَظِيمٍۢ","translation":"INDEED, We sent forth Noah unto his people, and he said: \"O my people! Worship God alone: you have no deity other than Him. Verily, I fear lest suffering befall you on an awesome Day!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1013.mp3","surahId":7,"words":[{"id":53654,"position":1,"arabic":"لَقَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/007_059_001.mp3","charTypeName":"word"},{"id":53655,"position":2,"arabic":"أَرْسَلْنَا","translation":"আমরা পাঠিয়েছি","audioUrl":"wbw/007_059_002.mp3","charTypeName":"word"},{"id":53656,"position":3,"arabic":"نُوحًا","translation":"নূহকে","audioUrl":"wbw/007_059_003.mp3","charTypeName":"word"},{"id":53657,"position":4,"arabic":"إِلَىٰ","translation":"প্রতি","audioUrl":"wbw/007_059_004.mp3","charTypeName":"word"},{"id":53658,"position":5,"arabic":"قَوْمِهِۦ","translation":"জাতির তার","audioUrl":"wbw/007_059_005.mp3","charTypeName":"word"},{"id":53659,"position":6,"arabic":"فَقَالَ","translation":"অতঃপর সে বললো","audioUrl":"wbw/007_059_006.mp3","charTypeName":"word"},{"id":53660,"position":7,"arabic":"يَـٰقَوْمِ","translation":"\"হে আমার জাতি","audioUrl":"wbw/007_059_007.mp3","charTypeName":"word"},{"id":53661,"position":8,"arabic":"ٱعْبُدُوا۟","translation":"তোমরা ইবাদত করো","audioUrl":"wbw/007_059_008.mp3","charTypeName":"word"},{"id":53662,"position":9,"arabic":"ٱللَّهَ","translation":"আল্লাহর","audioUrl":"wbw/007_059_009.mp3","charTypeName":"word"},{"id":53663,"position":10,"arabic":"مَا","translation":"নেই","audioUrl":"wbw/007_059_010.mp3","charTypeName":"word"},{"id":53664,"position":11,"arabic":"لَكُم","translation":"জন্যে তোমাদের","audioUrl":"wbw/007_059_011.mp3","charTypeName":"word"},{"id":53665,"position":12,"arabic":"مِّنْ","translation":"(অন্য) কোনো","audioUrl":"wbw/007_059_012.mp3","charTypeName":"word"},{"id":53666,"position":13,"arabic":"إِلَـٰهٍ","translation":"ইলাহ","audioUrl":"wbw/007_059_013.mp3","charTypeName":"word"},{"id":53667,"position":14,"arabic":"غَيْرُهُۥٓ","translation":"ছাড়া তিনি","audioUrl":"wbw/007_059_014.mp3","charTypeName":"word"},{"id":53668,"position":15,"arabic":"إِنِّىٓ","translation":"নিশ্চয়ই আমি","audioUrl":"wbw/007_059_015.mp3","charTypeName":"word"},{"id":53669,"position":16,"arabic":"أَخَافُ","translation":"আশঙ্কা করি আমি","audioUrl":"wbw/007_059_016.mp3","charTypeName":"word"},{"id":53670,"position":17,"arabic":"عَلَيْكُمْ","translation":"উপর তোমাদের","audioUrl":"wbw/007_059_017.mp3","charTypeName":"word"},{"id":53671,"position":18,"arabic":"عَذَابَ","translation":"শাস্তির","audioUrl":"wbw/007_059_018.mp3","charTypeName":"word"},{"id":53672,"position":19,"arabic":"يَوْمٍ","translation":"দিনের","audioUrl":"wbw/007_059_019.mp3","charTypeName":"word"},{"id":53673,"position":20,"arabic":"عَظِيمٍۢ","translation":"মহা\"","audioUrl":"wbw/007_059_020.mp3","charTypeName":"word"},{"id":53674,"position":21,"arabic":"٥٩","translation":"(৫৯)","audioUrl":null,"charTypeName":"end"}]},{"number":60,"arabic":"قَالَ ٱلْمَلَأُ مِن قَوْمِهِۦٓ إِنَّا لَنَرَىٰكَ فِى ضَلَٰلٍۢ مُّبِينٍۢ","translation":"The great ones among his people replied: \"Verily, we see that thou art obviously lost in error!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1014.mp3","surahId":7,"words":[{"id":54223,"position":1,"arabic":"قَالَ","translation":"বললো","audioUrl":"wbw/007_060_001.mp3","charTypeName":"word"},{"id":54224,"position":2,"arabic":"ٱلْمَلَأُ","translation":"প্রধানগণ","audioUrl":"wbw/007_060_002.mp3","charTypeName":"word"},{"id":54225,"position":3,"arabic":"مِن","translation":"মধ্যকার","audioUrl":"wbw/007_060_003.mp3","charTypeName":"word"},{"id":54226,"position":4,"arabic":"قَوْمِهِۦٓ","translation":"জাতির তার","audioUrl":"wbw/007_060_004.mp3","charTypeName":"word"},{"id":54227,"position":5,"arabic":"إِنَّا","translation":"\"নিশ্চয়ই আমরা","audioUrl":"wbw/007_060_005.mp3","charTypeName":"word"},{"id":54228,"position":6,"arabic":"لَنَرَىٰكَ","translation":"অবশ্যই আমরা তোমাকে দেখছি","audioUrl":"wbw/007_060_006.mp3","charTypeName":"word"},{"id":54229,"position":7,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/007_060_007.mp3","charTypeName":"word"},{"id":54230,"position":8,"arabic":"ضَلَـٰلٍۢ","translation":"ভ্রান্তির\"","audioUrl":"wbw/007_060_008.mp3","charTypeName":"word"},{"id":54231,"position":9,"arabic":"مُّبِينٍۢ","translation":"প্রকাশ্য\"","audioUrl":"wbw/007_060_009.mp3","charTypeName":"word"},{"id":54232,"position":10,"arabic":"٦٠","translation":"(৬০)","audioUrl":null,"charTypeName":"end"}]},{"number":61,"arabic":"قَالَ يَٰقَوْمِ لَيْسَ بِى ضَلَٰلَةٌۭ وَلَٰكِنِّى رَسُولٌۭ مِّن رَّبِّ ٱلْعَٰلَمِينَ","translation":"Said [Noah]: \"O my people! There is no error in me, but I am an apostle from the Sustainer of all the worlds.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1015.mp3","surahId":7,"words":[{"id":55026,"position":1,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/007_061_001.mp3","charTypeName":"word"},{"id":55027,"position":2,"arabic":"يَـٰقَوْمِ","translation":"\"হে আমার জাতি","audioUrl":"wbw/007_061_002.mp3","charTypeName":"word"},{"id":55028,"position":3,"arabic":"لَيْسَ","translation":"নেই","audioUrl":"wbw/007_061_003.mp3","charTypeName":"word"},{"id":55029,"position":4,"arabic":"بِى","translation":"মধ্যে আমার","audioUrl":"wbw/007_061_004.mp3","charTypeName":"word"},{"id":55030,"position":5,"arabic":"ضَلَـٰلَةٌۭ","translation":"কোনো ভ্রষ্টতা","audioUrl":"wbw/007_061_005.mp3","charTypeName":"word"},{"id":55031,"position":6,"arabic":"وَلَـٰكِنِّى","translation":"বরং আমি","audioUrl":"wbw/007_061_006.mp3","charTypeName":"word"},{"id":55032,"position":7,"arabic":"رَسُولٌۭ","translation":"রাসূল","audioUrl":"wbw/007_061_007.mp3","charTypeName":"word"},{"id":55033,"position":8,"arabic":"مِّن","translation":"পক্ষ হতে","audioUrl":"wbw/007_061_008.mp3","charTypeName":"word"},{"id":55034,"position":9,"arabic":"رَّبِّ","translation":"রবের","audioUrl":"wbw/007_061_009.mp3","charTypeName":"word"},{"id":55035,"position":10,"arabic":"ٱلْعَـٰلَمِينَ","translation":"বিশ্বজগতের","audioUrl":"wbw/007_061_010.mp3","charTypeName":"word"},{"id":55036,"position":11,"arabic":"٦١","translation":"(৬১)","audioUrl":null,"charTypeName":"end"}]},{"number":62,"arabic":"أُبَلِّغُكُمْ رِسَٰلَٰتِ رَبِّى وَأَنصَحُ لَكُمْ وَأَعْلَمُ مِنَ ٱللَّهِ مَا لَا تَعْلَمُونَ","translation":"I am delivering unto you my Sustainer's messages and giving you good advice: for I know [through revelation] from God what you do not know.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1016.mp3","surahId":7,"words":[{"id":55442,"position":1,"arabic":"أُبَلِّغُكُمْ","translation":"আমি পৌঁছাই তোমাদেরকে","audioUrl":"wbw/007_062_001.mp3","charTypeName":"word"},{"id":55443,"position":2,"arabic":"رِسَـٰلَـٰتِ","translation":"রিসালাত (বাণীগুলো)","audioUrl":"wbw/007_062_002.mp3","charTypeName":"word"},{"id":55444,"position":3,"arabic":"رَبِّى","translation":"আমার রবের","audioUrl":"wbw/007_062_003.mp3","charTypeName":"word"},{"id":55445,"position":4,"arabic":"وَأَنصَحُ","translation":"এবং হিতোপদেশ দিই আমি","audioUrl":"wbw/007_062_004.mp3","charTypeName":"word"},{"id":55446,"position":5,"arabic":"لَكُمْ","translation":"প্রতি তোমাদের","audioUrl":"wbw/007_062_005.mp3","charTypeName":"word"},{"id":55447,"position":6,"arabic":"وَأَعْلَمُ","translation":"ও আমি জানি","audioUrl":"wbw/007_062_006.mp3","charTypeName":"word"},{"id":55448,"position":7,"arabic":"مِنَ","translation":"পক্ষ হতে","audioUrl":"wbw/007_062_007.mp3","charTypeName":"word"},{"id":55449,"position":8,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/007_062_008.mp3","charTypeName":"word"},{"id":55450,"position":9,"arabic":"مَا","translation":"যা","audioUrl":"wbw/007_062_009.mp3","charTypeName":"word"},{"id":55451,"position":10,"arabic":"لَا","translation":"না","audioUrl":"wbw/007_062_010.mp3","charTypeName":"word"},{"id":55452,"position":11,"arabic":"تَعْلَمُونَ","translation":"তোমরা জানো","audioUrl":"wbw/007_062_011.mp3","charTypeName":"word"},{"id":55453,"position":12,"arabic":"٦٢","translation":"(৬২)","audioUrl":null,"charTypeName":"end"}]},{"number":63,"arabic":"أَوَعَجِبْتُمْ أَن جَآءَكُمْ ذِكْرٌۭ مِّن رَّبِّكُمْ عَلَىٰ رَجُلٍۢ مِّنكُمْ لِيُنذِرَكُمْ وَلِتَتَّقُوا۟ وَلَعَلَّكُمْ تُرْحَمُونَ","translation":"Why, do you deem it strange that a tiding from your Sustainer should have come unto you through a man from among yourselves, so that he might warn you, and that you might become conscious of God, and that you might be graced with His mercy?\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1017.mp3","surahId":7,"words":[{"id":55932,"position":1,"arabic":"أَوَعَجِبْتُمْ","translation":"কি তোমরা অবাক হয়েছো","audioUrl":"wbw/007_063_001.mp3","charTypeName":"word"},{"id":55933,"position":2,"arabic":"أَن","translation":"যে","audioUrl":"wbw/007_063_002.mp3","charTypeName":"word"},{"id":55934,"position":3,"arabic":"جَآءَكُمْ","translation":"তোমাদের (কাছে) এসেছে","audioUrl":"wbw/007_063_003.mp3","charTypeName":"word"},{"id":55935,"position":4,"arabic":"ذِكْرٌۭ","translation":"উপদেশ","audioUrl":"wbw/007_063_004.mp3","charTypeName":"word"},{"id":55936,"position":5,"arabic":"مِّن","translation":"পক্ষ হতে","audioUrl":"wbw/007_063_005.mp3","charTypeName":"word"},{"id":55937,"position":6,"arabic":"رَّبِّكُمْ","translation":"রবের তোমাদের","audioUrl":"wbw/007_063_006.mp3","charTypeName":"word"},{"id":55938,"position":7,"arabic":"عَلَىٰ","translation":"মাধ্যমে","audioUrl":"wbw/007_063_007.mp3","charTypeName":"word"},{"id":55939,"position":8,"arabic":"رَجُلٍۢ","translation":"একজন ব্যক্তির","audioUrl":"wbw/007_063_008.mp3","charTypeName":"word"},{"id":55940,"position":9,"arabic":"مِّنكُمْ","translation":"মধ্যকার তোমাদেরই","audioUrl":"wbw/007_063_009.mp3","charTypeName":"word"},{"id":55941,"position":10,"arabic":"لِيُنذِرَكُمْ","translation":"যেন সতর্ক করে তোমাদের","audioUrl":"wbw/007_063_010.mp3","charTypeName":"word"},{"id":55942,"position":11,"arabic":"وَلِتَتَّقُوا۟","translation":"এবং যেন তোমরা সংযত হও","audioUrl":"wbw/007_063_011.mp3","charTypeName":"word"},{"id":55943,"position":12,"arabic":"وَلَعَلَّكُمْ","translation":"এবং যাতে তোমরা","audioUrl":"wbw/007_063_012.mp3","charTypeName":"word"},{"id":55944,"position":13,"arabic":"تُرْحَمُونَ","translation":"অনুগ্রহপ্রাপ্ত হও\"","audioUrl":"wbw/007_063_013.mp3","charTypeName":"word"},{"id":55945,"position":14,"arabic":"٦٣","translation":"(৬৩)","audioUrl":null,"charTypeName":"end"}]},{"number":64,"arabic":"فَكَذَّبُوهُ فَأَنجَيْنَٰهُ وَٱلَّذِينَ مَعَهُۥ فِى ٱلْفُلْكِ وَأَغْرَقْنَا ٱلَّذِينَ كَذَّبُوا۟ بِـَٔايَٰتِنَآ ۚ إِنَّهُمْ كَانُوا۟ قَوْمًا عَمِينَ","translation":"And yet they gave him the lie! And so We saved him and those who stood by him, in the ark, the while We caused those who had given the lie to Our messages to drown: verily, they were blind folk!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1018.mp3","surahId":7,"words":[{"id":56443,"position":1,"arabic":"فَكَذَّبُوهُ","translation":"অতঃপর মিথ্যাবাদী বললো তারা তাকে","audioUrl":"wbw/007_064_001.mp3","charTypeName":"word"},{"id":56444,"position":2,"arabic":"فَأَنجَيْنَـٰهُ","translation":"তখন আমরা উদ্ধার করলাম তাকে","audioUrl":"wbw/007_064_002.mp3","charTypeName":"word"},{"id":56445,"position":3,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা (ছিলো)","audioUrl":"wbw/007_064_003.mp3","charTypeName":"word"},{"id":56446,"position":4,"arabic":"مَعَهُۥ","translation":"সাথে তার","audioUrl":"wbw/007_064_004.mp3","charTypeName":"word"},{"id":56447,"position":5,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/007_064_005.mp3","charTypeName":"word"},{"id":56448,"position":6,"arabic":"ٱلْفُلْكِ","translation":"নৌকার (তাদেরকেও উদ্ধার করলাম)","audioUrl":"wbw/007_064_006.mp3","charTypeName":"word"},{"id":56449,"position":7,"arabic":"وَأَغْرَقْنَا","translation":"এবং আমরা ডুবিয়ে দিলাম","audioUrl":"wbw/007_064_007.mp3","charTypeName":"word"},{"id":56450,"position":8,"arabic":"ٱلَّذِينَ","translation":"(তাদেরকে) যারা","audioUrl":"wbw/007_064_008.mp3","charTypeName":"word"},{"id":56451,"position":9,"arabic":"كَذَّبُوا۟","translation":"মিথ্যারোপ করেছিলো","audioUrl":"wbw/007_064_009.mp3","charTypeName":"word"},{"id":56452,"position":10,"arabic":"بِـَٔايَـٰتِنَآ ۚ","translation":"প্রতি আয়াতগুলোর আমাদের","audioUrl":"wbw/007_064_010.mp3","charTypeName":"word"},{"id":56454,"position":11,"arabic":"إِنَّهُمْ","translation":"নিশ্চয়ই তারা","audioUrl":"wbw/007_064_012.mp3","charTypeName":"word"},{"id":56455,"position":12,"arabic":"كَانُوا۟","translation":"ছিলো","audioUrl":"wbw/007_064_013.mp3","charTypeName":"word"},{"id":56456,"position":13,"arabic":"قَوْمًا","translation":"সম্প্রদায়","audioUrl":"wbw/007_064_014.mp3","charTypeName":"word"},{"id":56457,"position":14,"arabic":"عَمِينَ","translation":"(যারা) অন্ধ","audioUrl":"wbw/007_064_015.mp3","charTypeName":"word"},{"id":56458,"position":15,"arabic":"٦٤","translation":"(৬৪)","audioUrl":null,"charTypeName":"end"}]},{"number":65,"arabic":"۞ وَإِلَىٰ عَادٍ أَخَاهُمْ هُودًۭا ۗ قَالَ يَٰقَوْمِ ٱعْبُدُوا۟ ٱللَّهَ مَا لَكُم مِّنْ إِلَٰهٍ غَيْرُهُۥٓ ۚ أَفَلَا تَتَّقُونَ","translation":"AND UNTO [the tribe of] `Ad [We sent] their brother Hud. He said: \"O my people! Worship God alone: you have no deity other than Him. Will you not, then, be conscious of Him?\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1019.mp3","surahId":7,"words":[{"id":56999,"position":1,"arabic":"۞ وَإِلَىٰ","translation":"এবং প্রতি","audioUrl":"wbw/007_065_002.mp3","charTypeName":"word"},{"id":57000,"position":2,"arabic":"عَادٍ","translation":"আ'দ জাতির","audioUrl":"wbw/007_065_003.mp3","charTypeName":"word"},{"id":57001,"position":3,"arabic":"أَخَاهُمْ","translation":"তাদেরই ভাই","audioUrl":"wbw/007_065_004.mp3","charTypeName":"word"},{"id":57002,"position":4,"arabic":"هُودًۭا ۗ","translation":"হুদকে (প্রেরণ করি)","audioUrl":"wbw/007_065_005.mp3","charTypeName":"word"},{"id":57004,"position":5,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/007_065_007.mp3","charTypeName":"word"},{"id":57005,"position":6,"arabic":"يَـٰقَوْمِ","translation":"\"হে আমার জাতি","audioUrl":"wbw/007_065_008.mp3","charTypeName":"word"},{"id":57006,"position":7,"arabic":"ٱعْبُدُوا۟","translation":"তোমরা ইবাদত করো","audioUrl":"wbw/007_065_009.mp3","charTypeName":"word"},{"id":57007,"position":8,"arabic":"ٱللَّهَ","translation":"আল্লাহর","audioUrl":"wbw/007_065_010.mp3","charTypeName":"word"},{"id":57008,"position":9,"arabic":"مَا","translation":"নেই","audioUrl":"wbw/007_065_011.mp3","charTypeName":"word"},{"id":57009,"position":10,"arabic":"لَكُم","translation":"জন্যে তোমাদের","audioUrl":"wbw/007_065_012.mp3","charTypeName":"word"},{"id":57010,"position":11,"arabic":"مِّنْ","translation":"কোনো","audioUrl":"wbw/007_065_013.mp3","charTypeName":"word"},{"id":57011,"position":12,"arabic":"إِلَـٰهٍ","translation":"ইলাহ","audioUrl":"wbw/007_065_014.mp3","charTypeName":"word"},{"id":57012,"position":13,"arabic":"غَيْرُهُۥٓ ۚ","translation":"ছাড়া তিনি