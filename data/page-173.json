{"id":173,"ayahs":[{"number":171,"arabic":"۞ وَإِذْ نَتَقْنَا ٱلْجَبَلَ فَوْقَهُمْ كَأَنَّهُۥ ظُلَّةٌۭ وَظَنُّوٓا۟ أَنَّهُۥ وَاقِعٌۢ بِهِمْ خُذُوا۟ مَآ ءَاتَيْنَٰكُم بِقُوَّةٍۢ وَٱذْكُرُوا۟ مَا فِيهِ لَعَلَّكُمْ تَتَّقُونَ","translation":"And [did We not say,] when We caused Mount Sinai to quake above the children of Israel as though it were a [mere] shadow, and they thought that it would fall upon them, \"Hold fast with [all your] strength unto what We have vouchsafed you, and bear in mind all that is therein, so that you might remain conscious of God\"?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1125.mp3","surahId":7,"words":[{"id":83006,"position":1,"arabic":"۞ وَإِذْ","translation":"এবং যখন","audioUrl":"wbw/007_171_002.mp3","charTypeName":"word"},{"id":83007,"position":2,"arabic":"نَتَقْنَا","translation":"উপরে তুলে ধরেছিলাম আমরা","audioUrl":"wbw/007_171_003.mp3","charTypeName":"word"},{"id":83008,"position":3,"arabic":"ٱلْجَبَلَ","translation":"পাহাড়কে","audioUrl":"wbw/007_171_004.mp3","charTypeName":"word"},{"id":83009,"position":4,"arabic":"فَوْقَهُمْ","translation":"উপর তাদের","audioUrl":"wbw/007_171_005.mp3","charTypeName":"word"},{"id":83010,"position":5,"arabic":"كَأَنَّهُۥ","translation":"যেন তা (হলো)","audioUrl":"wbw/007_171_006.mp3","charTypeName":"word"},{"id":83011,"position":6,"arabic":"ظُلَّةٌۭ","translation":"(সামিয়ানা) ছায়া","audioUrl":"wbw/007_171_007.mp3","charTypeName":"word"},{"id":83012,"position":7,"arabic":"وَظَنُّوٓا۟","translation":"ও তারা মনে করলো","audioUrl":"wbw/007_171_008.mp3","charTypeName":"word"},{"id":83013,"position":8,"arabic":"أَنَّهُۥ","translation":"যেন তা","audioUrl":"wbw/007_171_009.mp3","charTypeName":"word"},{"id":83014,"position":9,"arabic":"وَاقِعٌۢ","translation":"পড়বে","audioUrl":"wbw/007_171_010.mp3","charTypeName":"word"},{"id":83015,"position":10,"arabic":"بِهِمْ","translation":"উপর তাদের","audioUrl":"wbw/007_171_011.mp3","charTypeName":"word"},{"id":83016,"position":11,"arabic":"خُذُوا۟","translation":"(বললাম) তোমরা আঁকড়ে ধরো","audioUrl":"wbw/007_171_012.mp3","charTypeName":"word"},{"id":83017,"position":12,"arabic":"مَآ","translation":"যা","audioUrl":"wbw/007_171_013.mp3","charTypeName":"word"},{"id":83018,"position":13,"arabic":"ءَاتَيْنَـٰكُم","translation":"আমরা দিয়েছি তোমাদের","audioUrl":"wbw/007_171_014.mp3","charTypeName":"word"},{"id":83019,"position":14,"arabic":"بِقُوَّةٍۢ","translation":"ভাবে দৃঢ়","audioUrl":"wbw/007_171_015.mp3","charTypeName":"word"},{"id":83020,"position":15,"arabic":"وَٱذْكُرُوا۟","translation":"এবং তোমরা স্মরণ রাখো","audioUrl":"wbw/007_171_016.mp3","charTypeName":"word"},{"id":83021,"position":16,"arabic":"مَا","translation":"যা","audioUrl":"wbw/007_171_017.mp3","charTypeName":"word"},{"id":83022,"position":17,"arabic":"فِيهِ","translation":"মধ্যে তার (আছে)","audioUrl":"wbw/007_171_018.mp3","charTypeName":"word"},{"id":83023,"position":18,"arabic":"لَعَلَّكُمْ","translation":"যাতে তোমরা","audioUrl":"wbw/007_171_019.mp3","charTypeName":"word"},{"id":83024,"position":19,"arabic":"تَتَّقُونَ","translation":"(ভুল আচরণ হতে) বেঁচে চলতে পারো\"","audioUrl":"wbw/007_171_020.mp3","charTypeName":"word"},{"id":83025,"position":20,"arabic":"١٧١","translation":"(১৭১)","audioUrl":null,"charTypeName":"end"}]},{"number":172,"arabic":"وَإِذْ أَخَذَ رَبُّكَ مِنۢ بَنِىٓ ءَادَمَ مِن ظُهُورِهِمْ ذُرِّيَّتَهُمْ وَأَشْهَدَهُمْ عَلَىٰٓ أَنفُسِهِمْ أَلَسْتُ بِرَبِّكُمْ ۖ قَالُوا۟ بَلَىٰ ۛ شَهِدْنَآ ۛ أَن تَقُولُوا۟ يَوْمَ ٱلْقِيَٰمَةِ إِنَّا كُنَّا عَنْ هَٰذَا غَٰفِلِينَ","translation":"AND WHENEVER thy Sustainer brings forth their offspring from the loins of the children of Adam, He [thus] calls upon them to bear witness about themselves: \"Am I not your Sustainer?\" - to which they answer: \"Yea, indeed, we do bear witness thereto!\" [Of this We remind you,] lest you say on the Day of Resurrection, \"Verily, we were unaware of this\";","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1126.mp3","surahId":7,"words":[{"id":83030,"position":1,"arabic":"وَإِذْ","translation":"এবং (স্মরণ করিয়ে দাও) যখন","audioUrl":"wbw/007_172_001.mp3","charTypeName":"word"},{"id":83031,"position":2,"arabic":"أَخَذَ","translation":"বের করেন","audioUrl":"wbw/007_172_002.mp3","charTypeName":"word"},{"id":83032,"position":3,"arabic":"رَبُّكَ","translation":"তোমার রব","audioUrl":"wbw/007_172_003.mp3","charTypeName":"word"},{"id":83033,"position":4,"arabic":"مِنۢ","translation":"থেকে","audioUrl":"wbw/007_172_004.mp3","charTypeName":"word"},{"id":83034,"position":5,"arabic":"بَنِىٓ","translation":"সন্তানদের","audioUrl":"wbw/007_172_005.mp3","charTypeName":"word"},{"id":83035,"position":6,"arabic":"ءَادَمَ","translation":"আদমের","audioUrl":"wbw/007_172_006.mp3","charTypeName":"word"},{"id":83036,"position":7,"arabic":"مِن","translation":"হতে","audioUrl":"wbw/007_172_007.mp3","charTypeName":"word"},{"id":83037,"position":8,"arabic":"ظُهُورِهِمْ","translation":"পিঠসমূহ তাদের","audioUrl":"wbw/007_172_008.mp3","charTypeName":"word"},{"id":83038,"position":9,"arabic":"ذُرِّيَّتَهُمْ","translation":"বংশধরদেরকে তাদের","audioUrl":"wbw/007_172_009.mp3","charTypeName":"word"},{"id":83039,"position":10,"arabic":"وَأَشْهَدَهُمْ","translation":"ও স্বাক্ষ্য নিলেন তাদের","audioUrl":"wbw/007_172_010.mp3","charTypeName":"word"},{"id":83040,"position":11,"arabic":"عَلَىٰٓ","translation":"সম্পর্কে","audioUrl":"wbw/007_172_011.mp3","charTypeName":"word"},{"id":83041,"position":12,"arabic":"أَنفُسِهِمْ","translation":"নিজেদের তাদের","audioUrl":"wbw/007_172_012.mp3","charTypeName":"word"},{"id":83042,"position":13,"arabic":"أَلَسْتُ","translation":"\"(আল্লাহ বলেছিলেন) কি আমি নই","audioUrl":"wbw/007_172_013.mp3","charTypeName":"word"},{"id":83043,"position":14,"arabic":"بِرَبِّكُمْ ۖ","translation":"রব তোমাদের\"","audioUrl":"wbw/007_172_014.mp3","charTypeName":"word"},{"id":83045,"position":15,"arabic":"قَالُوا۟","translation":"তারা বলেছিলো","audioUrl":"wbw/007_172_016.mp3","charTypeName":"word"},{"id":83046,"position":16,"arabic":"بَلَىٰ ۛ","translation":"\"নিশ্চয়ই","audioUrl":"wbw/007_172_017.mp3","charTypeName":"word"},{"id":83048,"position":17,"arabic":"شَهِدْنَآ ۛ","translation":"সাক্ষ্য দিলাম আমরা (এ কথার)\"","audioUrl":"wbw/007_172_019.mp3","charTypeName":"word"},{"id":83050,"position":18,"arabic":"أَن","translation":"যেন","audioUrl":"wbw/007_172_021.mp3","charTypeName":"word"},{"id":83051,"position":19,"arabic":"تَقُولُوا۟","translation":"(না) বলো তোমরা","audioUrl":"wbw/007_172_022.mp3","charTypeName":"word"},{"id":83052,"position":20,"arabic":"يَوْمَ","translation":"দিনে","audioUrl":"wbw/007_172_023.mp3","charTypeName":"word"},{"id":83053,"position":21,"arabic":"ٱلْقِيَـٰمَةِ","translation":"ক্বিয়ামাতের","audioUrl":"wbw/007_172_024.mp3","charTypeName":"word"},{"id":83054,"position":22,"arabic":"إِنَّا","translation":"\"নিশ্চয়ই আমরা","audioUrl":"wbw/007_172_025.mp3","charTypeName":"word"},{"id":83055,"position":23,"arabic":"كُنَّا","translation":"আমরা ছিলাম","audioUrl":"wbw/007_172_026.mp3","charTypeName":"word"},{"id":83056,"position":24,"arabic":"عَنْ","translation":"হতে","audioUrl":"wbw/007_172_027.mp3","charTypeName":"word"},{"id":83057,"position":25,"arabic":"هَـٰذَا","translation":"এটা","audioUrl":"wbw/007_172_028.mp3","charTypeName":"word"},{"id":83058,"position":26,"arabic":"غَـٰفِلِينَ","translation":"অমনোযোগী\"","audioUrl":"wbw/007_172_029.mp3","charTypeName":"word"},{"id":83059,"position":27,"arabic":"١٧٢","translation":"(১৭২)","audioUrl":null,"charTypeName":"end"}]},{"number":173,"arabic":"أَوْ تَقُولُوٓا۟ إِنَّمَآ أَشْرَكَ ءَابَآؤُنَا مِن قَبْلُ وَكُنَّا ذُرِّيَّةًۭ مِّنۢ بَعْدِهِمْ ۖ أَفَتُهْلِكُنَا بِمَا فَعَلَ ٱلْمُبْطِلُونَ","translation":"or lest you say, \"Verily, it was but our forefathers who, in times gone by, began to ascribe divinity to other beings beside God; and we were but their late offspring: wilt Thou, then, destroy us for the doings of those inventors of falsehoods?\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1127.mp3","surahId":7,"words":[{"id":83144,"position":1,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/007_173_001.mp3","charTypeName":"word"},{"id":83145,"position":2,"arabic":"تَقُولُوٓا۟","translation":"তোমরা বলবে","audioUrl":"wbw/007_173_002.mp3","charTypeName":"word"},{"id":83146,"position":3,"arabic":"إِنَّمَآ","translation":"\"মূলতঃ","audioUrl":"wbw/007_173_003.mp3","charTypeName":"word"},{"id":83147,"position":4,"arabic":"أَشْرَكَ","translation":"শিরক করেছিলো","audioUrl":"wbw/007_173_004.mp3","charTypeName":"word"},{"id":83148,"position":5,"arabic":"ءَابَآؤُنَا","translation":"পিতৃপুরুষরা আমাদের","audioUrl":"wbw/007_173_005.mp3","charTypeName":"word"},{"id":83149,"position":6,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/007_173_006.mp3","charTypeName":"word"},{"id":83150,"position":7,"arabic":"قَبْلُ","translation":"(আমাদের) পূর্ব","audioUrl":"wbw/007_173_007.mp3","charTypeName":"word"},{"id":83151,"position":8,"arabic":"وَكُنَّا","translation":"এবং আমরা ছিলাম","audioUrl":"wbw/007_173_008.mp3","charTypeName":"word"},{"id":83152,"position":9,"arabic":"ذُرِّيَّةًۭ","translation":"বংশধর","audioUrl":"wbw/007_173_009.mp3","charTypeName":"word"},{"id":83153,"position":10,"arabic":"مِّنۢ","translation":"থেকে","audioUrl":"wbw/007_173_010.mp3","charTypeName":"word"},{"id":83154,"position":11,"arabic":"بَعْدِهِمْ ۖ","translation":"পর তাদের","audioUrl":"wbw/007_173_011.mp3","charTypeName":"word"},{"id":83156,"position":12,"arabic":"أَفَتُهْلِكُنَا","translation":"কি তবে আপনি ধ্বংস করবেন আমাদেরকে","audioUrl":"wbw/007_173_013.mp3","charTypeName":"word"},{"id":83157,"position":13,"arabic":"بِمَا","translation":"এ কারণে যা","audioUrl":"wbw/007_173_014.mp3","charTypeName":"word"},{"id":83158,"position":14,"arabic":"فَعَلَ","translation":"করেছে","audioUrl":"wbw/007_173_015.mp3","charTypeName":"word"},{"id":83159,"position":15,"arabic":"ٱلْمُبْطِلُونَ","translation":"মিথ্যাশ্রয়ীরা\"","audioUrl":"wbw/007_173_016.mp3","charTypeName":"word"},{"id":83160,"position":16,"arabic":"١٧٣","translation":"(১৭৩)","audioUrl":null,"charTypeName":"end"}]},{"number":174,"arabic":"وَكَذَٰلِكَ نُفَصِّلُ ٱلْءَايَٰتِ وَلَعَلَّهُمْ يَرْجِعُونَ","translation":"And thus clearly do We spell out these messages; and [We do it] so that they [who have sinned] might return [unto Us].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1128.mp3","surahId":7,"words":[{"id":83220,"position":1,"arabic":"وَكَذَٰلِكَ","translation":"এবং এভাবে","audioUrl":"wbw/007_174_001.mp3","charTypeName":"word"},{"id":83221,"position":2,"arabic":"نُفَصِّلُ","translation":"বিস্তারিত বর্ণনা করি আমরা","audioUrl":"wbw/007_174_002.mp3","charTypeName":"word"},{"id":83222,"position":3,"arabic":"ٱلْـَٔايَـٰتِ","translation":"নিদর্শনগুলোকে","audioUrl":"wbw/007_174_003.mp3","charTypeName":"word"},{"id":83223,"position":4,"arabic":"وَلَعَلَّهُمْ","translation":"এবং যাতে তারা","audioUrl":"wbw/007_174_004.mp3","charTypeName":"word"},{"id":83224,"position":5,"arabic":"يَرْجِعُونَ","translation":"ফিরে আসে","audioUrl":"wbw/007_174_005.mp3","charTypeName":"word"},{"id":83225,"position":6,"arabic":"١٧٤","translation":"(১৭৪)","audioUrl":null,"charTypeName":"end"}]},{"number":175,"arabic":"وَٱتْلُ عَلَيْهِمْ نَبَأَ ٱلَّذِىٓ ءَاتَيْنَٰهُ ءَايَٰتِنَا فَٱنسَلَخَ مِنْهَا فَأَتْبَعَهُ ٱلشَّيْطَٰنُ فَكَانَ مِنَ ٱلْغَاوِينَ","translation":"And tell them what happens to him to whom We vouchsafe Our messages and who then discards them: Satan catches up with him, and he strays, like so many others, into grievous error.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1129.mp3","surahId":7,"words":[{"id":83323,"position":1,"arabic":"وَٱتْلُ","translation":"এবং (হে নাবী) তিলাওয়াত করো","audioUrl":"wbw/007_175_001.mp3","charTypeName":"word"},{"id":83324,"position":2,"arabic":"عَلَيْهِمْ","translation":"নিকট তাদের","audioUrl":"wbw/007_175_002.mp3","charTypeName":"word"},{"id":83325,"position":3,"arabic":"نَبَأَ","translation":"বৃত্তান্ত","audioUrl":"wbw/007_175_003.mp3","charTypeName":"word"},{"id":83326,"position":4,"arabic":"ٱلَّذِىٓ","translation":"(ঐ ব্যক্তির) যে","audioUrl":"wbw/007_175_004.mp3","charTypeName":"word"},{"id":83327,"position":5,"arabic":"ءَاتَيْنَـٰهُ","translation":"আমরা দিয়েছিলাম তাকে","audioUrl":"wbw/007_175_005.mp3","charTypeName":"word"},{"id":83328,"position":6,"arabic":"ءَايَـٰتِنَا","translation":"নিদর্শনগুলো আমাদের","audioUrl":"wbw/007_175_006.mp3","charTypeName":"word"},{"id":83329,"position":7,"arabic":"فَٱنسَلَخَ","translation":"কিন্তু সে এড়িয়ে যায়","audioUrl":"wbw/007_175_007.mp3","charTypeName":"word"},{"id":83330,"position":8,"arabic":"مِنْهَا","translation":"থেকে তা","audioUrl":"wbw/007_175_008.mp3","charTypeName":"word"},{"id":83331,"position":9,"arabic":"فَأَتْبَعَهُ","translation":"ফলে পিছনে লাগে তার","audioUrl":"wbw/007_175_009.mp3","charTypeName":"word"},{"id":83332,"position":10,"arabic":"ٱلشَّيْطَـٰنُ","translation":"শয়তান","audioUrl":"wbw/007_175_010.mp3","charTypeName":"word"},{"id":83333,"position":11,"arabic":"فَكَانَ","translation":"অতঃপর সে হয়","audioUrl":"wbw/007_175_011.mp3","charTypeName":"word"},{"id":83334,"position":12,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/007_175_012.mp3","charTypeName":"word"},{"id":83335,"position":13,"arabic":"ٱلْغَاوِينَ","translation":"পথভ্রষ্টদের","audioUrl":"wbw/007_175_013.mp3","charTypeName":"word"},{"id":83336,"position":14,"arabic":"١٧٥","translation":"(১৭৫)","audioUrl":null,"charTypeName":"end"}]},{"number":176,"arabic":"وَلَوْ شِئْنَا لَرَفَعْنَٰهُ بِهَا وَلَٰكِنَّهُۥٓ أَخْلَدَ إِلَى ٱلْأَرْضِ وَٱتَّبَعَ هَوَىٰهُ ۚ فَمَثَلُهُۥ كَمَثَلِ ٱلْكَلْبِ إِن تَحْمِلْ عَلَيْهِ يَلْهَثْ أَوْ تَتْرُكْهُ يَلْهَث ۚ ذَّٰلِكَ مَثَلُ ٱلْقَوْمِ ٱلَّذِينَ كَذَّبُوا۟ بِـَٔايَٰتِنَا ۚ فَٱقْصُصِ ٱلْقَصَصَ لَعَلَّهُمْ يَتَفَكَّرُونَ","translation":"Now had We so willed, We could indeed have exalted him by means of those [messages]: but he always clung to the earth and followed but his own desires. Thus, his parable is that of an [excited] dog: if thou approach him threateningly, he will pant with his tongue lolling; and. if thou leave him alone, he will pant with his tongue lolling. Such is the parable of those who are bent on giving the lie to Our messages. Tell [them], then, this story, so that they might take thought.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1130.mp3","surahId":7,"words":[{"id":83442,"position":1,"arabic":"وَلَوْ","translation":"এবং যদি","audioUrl":"wbw/007_176_001.mp3","charTypeName":"word"},{"id":83443,"position":2,"arabic":"شِئْنَا","translation":"ইচ্ছে করতাম আমরা","audioUrl":"wbw/007_176_002.mp3","charTypeName":"word"},{"id":83444,"position":3,"arabic":"لَرَفَعْنَـٰهُ","translation":"অবশ্যই আমরা মর্যাদা দিতাম তাকে","audioUrl":"wbw/007_176_003.mp3","charTypeName":"word"},{"id":83445,"position":4,"arabic":"بِهَا","translation":"দিয়ে তা","audioUrl":"wbw/007_176_004.mp3","charTypeName":"word"},{"id":83446,"position":5,"arabic":"وَلَـٰكِنَّهُۥٓ","translation":"কিন্তু সে","audioUrl":"wbw/007_176_005.mp3","charTypeName":"word"},{"id":83447,"position":6,"arabic":"أَخْلَدَ","translation":"ঝুঁকে পড়লো","audioUrl":"wbw/007_176_006.mp3","charTypeName":"word"},{"id":83448,"position":7,"arabic":"إِلَى","translation":"প্রতি","audioUrl":"wbw/007_176_007.mp3","charTypeName":"word"},{"id":83449,"position":8,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/007_176_008.mp3","charTypeName":"word"},{"id":83450,"position":9,"arabic":"وَٱتَّبَعَ","translation":"এবং অনুসরণ করলো","audioUrl":"wbw/007_176_009.mp3","charTypeName":"word"},{"id":83451,"position":10,"arabic":"هَوَىٰهُ ۚ","translation":"প্রবৃত্তির তার","audioUrl":"wbw/007_176_010.mp3","charTypeName":"word"},{"id":83453,"position":11,"arabic":"فَمَثَلُهُۥ","translation":"অতএব তাদের দৃষ্টান্ত","audioUrl":"wbw/007_176_012.mp3","charTypeName":"word"},{"id":83454,"position":12,"arabic":"كَمَثَلِ","translation":"যেমন দৃষ্টান্ত","audioUrl":"wbw/007_176_013.mp3","charTypeName":"word"},{"id":83455,"position":13,"arabic":"ٱلْكَلْبِ","translation":"কুকুরের","audioUrl":"wbw/007_176_014.mp3","charTypeName":"word"},{"id":83456,"position":14,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/007_176_015.mp3","charTypeName":"word"},{"id":83457,"position":15,"arabic":"تَحْمِلْ","translation":"বোঝা চাপাও তুমি","audioUrl":"wbw/007_176_016.mp3","charTypeName":"word"},{"id":83458,"position":16,"arabic":"عَلَيْهِ","translation":"উপর তার","audioUrl":"wbw/007_176_017.mp3","charTypeName":"word"},{"id":83459,"position":17,"arabic":"يَلْهَثْ","translation":"(জিহ্বা বের করে) হাঁপাতে থাকে","audioUrl":"wbw/007_176_018.mp3","charTypeName":"word"},{"id":83460,"position":18,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/007_176_019.mp3","charTypeName":"word"},{"id":83461,"position":19,"arabic":"تَتْرُكْهُ","translation":"ছেড়ে দাও তাকে","audioUrl":"wbw/007_176_020.mp3","charTypeName":"word"},{"id":83462,"position":20,"arabic":"يَلْهَث ۚ","translation":"(তবুও জিহ্বা বের করে) হাঁপাতে থাকে","audioUrl":"wbw/007_176_021.mp3","charTypeName":"word"},{"id":83464,"position":21,"arabic":"ذَّٰلِكَ","translation":"এটা","audioUrl":"wbw/007_176_023.mp3","charTypeName":"word"},{"id":83465,"position":22,"arabic":"مَثَلُ","translation":"দৃষ্টান্ত","audioUrl":"wbw/007_176_024.mp3","charTypeName":"word"},{"id":83466,"position":23,"arabic":"ٱلْقَوْمِ","translation":"(ঐ)সম্প্রদায়ের","audioUrl":"wbw/007_176_025.mp3","charTypeName":"word"},{"id":83467,"position":24,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/007_176_026.mp3","charTypeName":"word"},{"id":83468,"position":25,"arabic":"كَذَّبُوا۟","translation":"মিথ্যারোপ করেছে","audioUrl":"wbw/007_176_027.mp3","charTypeName":"word"},{"id":83469,"position":26,"arabic":"بِـَٔايَـٰتِنَا ۚ","translation":"প্রতি নিদর্শনগুলোর আমাদের","audioUrl":"wbw/007_176_028.mp3","charTypeName":"word"},{"id":83471,"position":27,"arabic":"فَٱقْصُصِ","translation":"সুতরাং বর্ণনা করো","audioUrl":"wbw/007_176_030.mp3","charTypeName":"word"},{"id":83472,"position":28,"arabic":"ٱلْقَصَصَ","translation":"এই কাহিনীগুলোকে","audioUrl":"wbw/007_176_031.mp3","charTypeName":"word"},{"id":83473,"position":29,"arabic":"لَعَلَّهُمْ","translation":"যাতে তারা","audioUrl":"wbw/007_176_032.mp3","charTypeName":"word"},{"id":83474,"position":30,"arabic":"يَتَفَكَّرُونَ","translation":"চিন্তা করে","audioUrl":"wbw/007_176_033.mp3","charTypeName":"word"},{"id":83475,"position":31,"arabic":"١٧٦","translation":"(১৭৬)","audioUrl":null,"charTypeName":"end"}]},{"number":177,"arabic":"سَآءَ مَثَلًا ٱلْقَوْمُ ٱلَّذِينَ كَذَّبُوا۟ بِـَٔايَٰتِنَا وَأَنفُسَهُمْ كَانُوا۟ يَظْلِمُونَ","translation":"Evil is the example of people who are bent on giving the lie to Our messages: for it is against their own selves that they are sinning!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1131.mp3","surahId":7,"words":[{"id":83590,"position":1,"arabic":"سَآءَ","translation":"বড়ই খারাপ","audioUrl":"wbw/007_177_001.mp3","charTypeName":"word"},{"id":83591,"position":2,"arabic":"مَثَلًا","translation":"দৃষ্টান্ত","audioUrl":"wbw/007_177_002.mp3","charTypeName":"word"},{"id":83592,"position":3,"arabic":"ٱلْقَوْمُ","translation":"(ঐ) সম্প্রদায়ের","audioUrl":"wbw/007_177_003.mp3","charTypeName":"word"},{"id":83593,"position":4,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/007_177_004.mp3","charTypeName":"word"},{"id":83594,"position":5,"arabic":"كَذَّبُوا۟","translation":"মিথ্যারোপ করেছে","audioUrl":"wbw/007_177_005.mp3","charTypeName":"word"},{"id":83595,"position":6,"arabic":"بِـَٔايَـٰتِنَا","translation":"প্রতি আয়াতগুলোর আমাদের","audioUrl":"wbw/007_177_006.mp3","charTypeName":"word"},{"id":83596,"position":7,"arabic":"وَأَنفُسَهُمْ","translation":"ও নিজেদের তাদের(উপর)","audioUrl":"wbw/007_177_007.mp3","charTypeName":"word"},{"id":83597,"position":8,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/007_177_008.mp3","charTypeName":"word"},{"id":83598,"position":9,"arabic":"يَظْلِمُونَ","translation":"অনাচার করে চলেছে","audioUrl":"wbw/007_177_009.mp3","charTypeName":"word"},{"id":83599,"position":10,"arabic":"١٧٧","translation":"(১৭৭)","audioUrl":null,"charTypeName":"end"}]},{"number":178,"arabic":"مَن يَهْدِ ٱللَّهُ فَهُوَ ٱلْمُهْتَدِى ۖ وَمَن يُضْلِلْ فَأُو۟لَٰٓئِكَ هُمُ ٱلْخَٰسِرُونَ","translation":"He whom God guides, he alone is truly guided; whereas those whom He lets go astray-it is they, they who are the losers!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1132.mp3","surahId":7,"words":[{"id":83652,"position":1,"arabic":"مَن","translation":"যাকে","audioUrl":"wbw/007_178_001.mp3","charTypeName":"word"},{"id":83653,"position":2,"arabic":"يَهْدِ","translation":"পথ দেখান","audioUrl":"wbw/007_178_002.mp3","charTypeName":"word"},{"id":83654,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/007_178_003.mp3","charTypeName":"word"},{"id":83655,"position":4,"arabic":"فَهُوَ","translation":"তখন সেই","audioUrl":"wbw/007_178_004.mp3","charTypeName":"word"},{"id":83656,"position":5,"arabic":"ٱلْمُهْتَدِى ۖ","translation":"পথপ্রাপ্ত","audioUrl":"wbw/007_178_005.mp3","charTypeName":"word"},{"id":83658,"position":6,"arabic":"وَمَن","translation":"এবং যাদের","audioUrl":"wbw/007_178_007.mp3","charTypeName":"word"},{"id":83659,"position":7,"arabic":"يُضْلِلْ","translation":"পথভ্রষ্ট করেন","audioUrl":"wbw/007_178_008.mp3","charTypeName":"word"},{"id":83660,"position":8,"arabic":"فَأُو۟لَـٰٓئِكَ","translation":"অতঃপর ঐসব (লোক)","audioUrl":"wbw/007_178_009.mp3","charTypeName":"word"},{"id":83661,"position":9,"arabic":"هُمُ","translation":"তারাই","audioUrl":"wbw/007_178_010.mp3","charTypeName":"word"},{"id":83662,"position":10,"arabic":"ٱلْخَـٰسِرُونَ","translation":"ক্ষতিগ্রস্ত","audioUrl":"wbw/007_178_011.mp3","charTypeName":"word"},{"id":83663,"position":11,"arabic":"١٧٨","translation":"(১৭৮)","audioUrl":null,"charTypeName":"end"}]}]}