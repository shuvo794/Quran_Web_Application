{"id":444,"ayahs":[{"number":55,"arabic":"إِنَّ أَصْحَٰبَ ٱلْجَنَّةِ ٱلْيَوْمَ فِى شُغُلٍۢ فَٰكِهُونَ","translation":"“Behold, those who are destined for paradise shall today have joy in whatever they do:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3760.mp3","surahId":36,"words":[{"id":51981,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/036_055_001.mp3","charTypeName":"word"},{"id":51982,"position":2,"arabic":"أَصْحَـٰبَ","translation":"অধিবাসীরা","audioUrl":"wbw/036_055_002.mp3","charTypeName":"word"},{"id":51983,"position":3,"arabic":"ٱلْجَنَّةِ","translation":"জান্নাতের","audioUrl":"wbw/036_055_003.mp3","charTypeName":"word"},{"id":51984,"position":4,"arabic":"ٱلْيَوْمَ","translation":"আজ","audioUrl":"wbw/036_055_004.mp3","charTypeName":"word"},{"id":51985,"position":5,"arabic":"فِى","translation":"থাকবে","audioUrl":"wbw/036_055_005.mp3","charTypeName":"word"},{"id":51986,"position":6,"arabic":"شُغُلٍۢ","translation":"(মজার) মগ্ন","audioUrl":"wbw/036_055_006.mp3","charTypeName":"word"},{"id":51987,"position":7,"arabic":"فَـٰكِهُونَ","translation":"আনন্দে","audioUrl":"wbw/036_055_007.mp3","charTypeName":"word"},{"id":51988,"position":8,"arabic":"٥٥","translation":"(৫৫)","audioUrl":null,"charTypeName":"end"}]},{"number":56,"arabic":"هُمْ وَأَزْوَٰجُهُمْ فِى ظِلَٰلٍ عَلَى ٱلْأَرَآئِكِ مُتَّكِـُٔونَ","translation":"in happiness will they and their spouses on couches recline;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3761.mp3","surahId":36,"words":[{"id":52528,"position":1,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/036_056_001.mp3","charTypeName":"word"},{"id":52529,"position":2,"arabic":"وَأَزْوَٰجُهُمْ","translation":"ও তাদের স্ত্রীরা (হবে)","audioUrl":"wbw/036_056_002.mp3","charTypeName":"word"},{"id":52530,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/036_056_003.mp3","charTypeName":"word"},{"id":52531,"position":4,"arabic":"ظِلَـٰلٍ","translation":"ছায়ার","audioUrl":"wbw/036_056_004.mp3","charTypeName":"word"},{"id":52532,"position":5,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/036_056_005.mp3","charTypeName":"word"},{"id":52533,"position":6,"arabic":"ٱلْأَرَآئِكِ","translation":"সুসজ্জিত আসনে","audioUrl":"wbw/036_056_006.mp3","charTypeName":"word"},{"id":52534,"position":7,"arabic":"مُتَّكِـُٔونَ","translation":"হেলান দিয়ে বসবে","audioUrl":"wbw/036_056_007.mp3","charTypeName":"word"},{"id":52535,"position":8,"arabic":"٥٦","translation":"(৫৬)","audioUrl":null,"charTypeName":"end"}]},{"number":57,"arabic":"لَهُمْ فِيهَا فَٰكِهَةٌۭ وَلَهُم مَّا يَدَّعُونَ","translation":"[only] delight will there be for them, and theirs shall be all that they could ask for:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3762.mp3","surahId":36,"words":[{"id":53032,"position":1,"arabic":"لَهُمْ","translation":"তাদের জন্যে (থাকবে)","audioUrl":"wbw/036_057_001.mp3","charTypeName":"word"},{"id":53033,"position":2,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/036_057_002.mp3","charTypeName":"word"},{"id":53034,"position":3,"arabic":"فَـٰكِهَةٌۭ","translation":"ফলমূল","audioUrl":"wbw/036_057_003.mp3","charTypeName":"word"},{"id":53035,"position":4,"arabic":"وَلَهُم","translation":"ও তাদের জন্যে (থাকবে)","audioUrl":"wbw/036_057_004.mp3","charTypeName":"word"},{"id":53036,"position":5,"arabic":"مَّا","translation":"যা","audioUrl":"wbw/036_057_005.mp3","charTypeName":"word"},{"id":53037,"position":6,"arabic":"يَدَّعُونَ","translation":"তারা চাইবে","audioUrl":"wbw/036_057_006.mp3","charTypeName":"word"},{"id":53038,"position":7,"arabic":"٥٧","translation":"(৫৭)","audioUrl":null,"charTypeName":"end"}]},{"number":58,"arabic":"سَلَٰمٌۭ قَوْلًۭا مِّن رَّبٍّۢ رَّحِيمٍۢ","translation":"peace and fulfillment through the word of a Sustainer who dispenses all grace.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3763.mp3","surahId":36,"words":[{"id":53573,"position":1,"arabic":"سَلَـٰمٌۭ","translation":"\"সালাম\"","audioUrl":"wbw/036_058_001.mp3","charTypeName":"word"},{"id":53574,"position":2,"arabic":"قَوْلًۭا","translation":"বলা (হবে)","audioUrl":"wbw/036_058_002.mp3","charTypeName":"word"},{"id":53575,"position":3,"arabic":"مِّن","translation":"পক্ষ হ'তে","audioUrl":"wbw/036_058_003.mp3","charTypeName":"word"},{"id":53576,"position":4,"arabic":"رَّبٍّۢ","translation":"রবের","audioUrl":"wbw/036_058_004.mp3","charTypeName":"word"},{"id":53577,"position":5,"arabic":"رَّحِيمٍۢ","translation":"(যিনি) পরম দয়ালু","audioUrl":"wbw/036_058_005.mp3","charTypeName":"word"},{"id":53578,"position":6,"arabic":"٥٨","translation":"(৫৮)","audioUrl":null,"charTypeName":"end"}]},{"number":59,"arabic":"وَٱمْتَٰزُوا۟ ٱلْيَوْمَ أَيُّهَا ٱلْمُجْرِمُونَ","translation":"“But stand aside today, O you who were lost in sin!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3764.mp3","surahId":36,"words":[{"id":54137,"position":1,"arabic":"وَٱمْتَـٰزُوا۟","translation":"\"এবং (বলা হবে) তোমারা আলাদা হয়ে যাও","audioUrl":"wbw/036_059_001.mp3","charTypeName":"word"},{"id":54138,"position":2,"arabic":"ٱلْيَوْمَ","translation":"আজ","audioUrl":"wbw/036_059_002.mp3","charTypeName":"word"},{"id":54139,"position":3,"arabic":"أَيُّهَا","translation":"হে","audioUrl":"wbw/036_059_003.mp3","charTypeName":"word"},{"id":54140,"position":4,"arabic":"ٱلْمُجْرِمُونَ","translation":"অপরাধীরা","audioUrl":"wbw/036_059_004.mp3","charTypeName":"word"},{"id":54141,"position":5,"arabic":"٥٩","translation":"(৫৯)","audioUrl":null,"charTypeName":"end"}]},{"number":60,"arabic":"۞ أَلَمْ أَعْهَدْ إِلَيْكُمْ يَٰبَنِىٓ ءَادَمَ أَن لَّا تَعْبُدُوا۟ ٱلشَّيْطَٰنَ ۖ إِنَّهُۥ لَكُمْ عَدُوٌّۭ مُّبِينٌۭ","translation":"Did I not enjoin on you, O you children of Adam, that you should not worship Satan – since, verily, he is your open foe","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3765.mp3","surahId":36,"words":[{"id":54448,"position":1,"arabic":"۞ أَلَمْ","translation":"দিই নি কি","audioUrl":"wbw/036_060_002.mp3","charTypeName":"word"},{"id":54449,"position":2,"arabic":"أَعْهَدْ","translation":"আমি নির্দেশ","audioUrl":"wbw/036_060_003.mp3","charTypeName":"word"},{"id":54450,"position":3,"arabic":"إِلَيْكُمْ","translation":"তোমাদের প্রতি","audioUrl":"wbw/036_060_004.mp3","charTypeName":"word"},{"id":54451,"position":4,"arabic":"يَـٰبَنِىٓ","translation":"হে সন্তান","audioUrl":"wbw/036_060_005.mp3","charTypeName":"word"},{"id":54452,"position":5,"arabic":"ءَادَمَ","translation":"আদমের","audioUrl":"wbw/036_060_006.mp3","charTypeName":"word"},{"id":54453,"position":6,"arabic":"أَن","translation":"যে","audioUrl":"wbw/036_060_007.mp3","charTypeName":"word"},{"id":54454,"position":7,"arabic":"لَّا","translation":"না","audioUrl":"wbw/036_060_008.mp3","charTypeName":"word"},{"id":54455,"position":8,"arabic":"تَعْبُدُوا۟","translation":"তোমরা দাসত্ব করো","audioUrl":"wbw/036_060_009.mp3","charTypeName":"word"},{"id":54456,"position":9,"arabic":"ٱلشَّيْطَـٰنَ ۖ","translation":"শয়তানের","audioUrl":"wbw/036_060_010.mp3","charTypeName":"word"},{"id":54458,"position":10,"arabic":"إِنَّهُۥ","translation":"সে নিশ্চয়ই","audioUrl":"wbw/036_060_012.mp3","charTypeName":"word"},{"id":54459,"position":11,"arabic":"لَكُمْ","translation":"তোমাদের জন্যে","audioUrl":"wbw/036_060_013.mp3","charTypeName":"word"},{"id":54460,"position":12,"arabic":"عَدُوٌّۭ","translation":"শত্রু","audioUrl":"wbw/036_060_014.mp3","charTypeName":"word"},{"id":54461,"position":13,"arabic":"مُّبِينٌۭ","translation":"প্রকাশ্য","audioUrl":"wbw/036_060_015.mp3","charTypeName":"word"},{"id":54462,"position":14,"arabic":"٦٠","translation":"(৬০)","audioUrl":null,"charTypeName":"end"}]},{"number":61,"arabic":"وَأَنِ ٱعْبُدُونِى ۚ هَٰذَا صِرَٰطٌۭ مُّسْتَقِيمٌۭ","translation":"and that you should worship Me [alone]? This would have been a straight way!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3766.mp3","surahId":36,"words":[{"id":55338,"position":1,"arabic":"وَأَنِ","translation":"এবং (এও) যে","audioUrl":"wbw/036_061_001.mp3","charTypeName":"word"},{"id":55339,"position":2,"arabic":"ٱعْبُدُونِى ۚ","translation":"আমারই তোমরা ইবাদত করো","audioUrl":"wbw/036_061_002.mp3","charTypeName":"word"},{"id":55341,"position":3,"arabic":"هَـٰذَا","translation":"এটাই","audioUrl":"wbw/036_061_004.mp3","charTypeName":"word"},{"id":55342,"position":4,"arabic":"صِرَٰطٌۭ","translation":"পথ","audioUrl":"wbw/036_061_005.mp3","charTypeName":"word"},{"id":55343,"position":5,"arabic":"مُّسْتَقِيمٌۭ","translation":"সরল সঠিক","audioUrl":"wbw/036_061_006.mp3","charTypeName":"word"},{"id":55344,"position":6,"arabic":"٦١","translation":"(৬১)","audioUrl":null,"charTypeName":"end"}]},{"number":62,"arabic":"وَلَقَدْ أَضَلَّ مِنكُمْ جِبِلًّۭا كَثِيرًا ۖ أَفَلَمْ تَكُونُوا۟ تَعْقِلُونَ","translation":"And [as for Satan -] he had already led astray a great many of you: could you not, then, use your reason?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3767.mp3","surahId":36,"words":[{"id":55858,"position":1,"arabic":"وَلَقَدْ","translation":"এবং (এ সত্ত্বেও) নিশ্চয়ই","audioUrl":"wbw/036_062_001.mp3","charTypeName":"word"},{"id":55859,"position":2,"arabic":"أَضَلَّ","translation":"সে পথ ভ্রষ্ট করেছে","audioUrl":"wbw/036_062_002.mp3","charTypeName":"word"},{"id":55860,"position":3,"arabic":"مِنكُمْ","translation":"তোমাদের মধ্য হ'তে","audioUrl":"wbw/036_062_003.mp3","charTypeName":"word"},{"id":55861,"position":4,"arabic":"جِبِلًّۭا","translation":"বড় দলকে","audioUrl":"wbw/036_062_004.mp3","charTypeName":"word"},{"id":55862,"position":5,"arabic":"كَثِيرًا ۖ","translation":"অনেক","audioUrl":"wbw/036_062_005.mp3","charTypeName":"word"},{"id":55864,"position":6,"arabic":"أَفَلَمْ","translation":"তবুও কি না","audioUrl":"wbw/036_062_007.mp3","charTypeName":"word"},{"id":55865,"position":7,"arabic":"تَكُونُوا۟","translation":"হবে","audioUrl":"wbw/036_062_008.mp3","charTypeName":"word"},{"id":55866,"position":8,"arabic":"تَعْقِلُونَ","translation":"তোমরা বুঝতে","audioUrl":"wbw/036_062_009.mp3","charTypeName":"word"},{"id":55867,"position":9,"arabic":"٦٢","translation":"(৬২)","audioUrl":null,"charTypeName":"end"}]},{"number":63,"arabic":"هَٰذِهِۦ جَهَنَّمُ ٱلَّتِى كُنتُمْ تُوعَدُونَ","translation":"“This, then, is the hell of which you were warned again and again:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3768.mp3","surahId":36,"words":[{"id":56417,"position":1,"arabic":"هَـٰذِهِۦ","translation":"এই সেই","audioUrl":"wbw/036_063_001.mp3","charTypeName":"word"},{"id":56418,"position":2,"arabic":"جَهَنَّمُ","translation":"জাহান্নাম","audioUrl":"wbw/036_063_002.mp3","charTypeName":"word"},{"id":56419,"position":3,"arabic":"ٱلَّتِى","translation":"যার","audioUrl":"wbw/036_063_003.mp3","charTypeName":"word"},{"id":56420,"position":4,"arabic":"كُنتُمْ","translation":"তোমাদের","audioUrl":"wbw/036_063_004.mp3","charTypeName":"word"},{"id":56421,"position":5,"arabic":"تُوعَدُونَ","translation":"প্রতিশ্রুতি দেয়া হয়েছিলো","audioUrl":"wbw/036_063_005.mp3","charTypeName":"word"},{"id":56422,"position":6,"arabic":"٦٣","translation":"(৬৩)","audioUrl":null,"charTypeName":"end"}]},{"number":64,"arabic":"ٱصْلَوْهَا ٱلْيَوْمَ بِمَا كُنتُمْ تَكْفُرُونَ","translation":"endure it today as an outcome of your persistent denial of the truth!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3769.mp3","surahId":36,"words":[{"id":56645,"position":1,"arabic":"ٱصْلَوْهَا","translation":"তাতে তোমরা প্রবেশ করো","audioUrl":"wbw/036_064_001.mp3","charTypeName":"word"},{"id":56646,"position":2,"arabic":"ٱلْيَوْمَ","translation":"আজ","audioUrl":"wbw/036_064_002.mp3","charTypeName":"word"},{"id":56647,"position":3,"arabic":"بِمَا","translation":"বিনিময়ে যা","audioUrl":"wbw/036_064_003.mp3","charTypeName":"word"},{"id":56648,"position":4,"arabic":"كُنتُمْ","translation":"তোমরা","audioUrl":"wbw/036_064_004.mp3","charTypeName":"word"},{"id":56649,"position":5,"arabic":"تَكْفُرُونَ","translation":"অস্বীকার করছিলে\"","audioUrl":"wbw/036_064_005.mp3","charTypeName":"word"},{"id":56650,"position":6,"arabic":"٦٤","translation":"(৬৪)","audioUrl":null,"charTypeName":"end"}]},{"number":65,"arabic":"ٱلْيَوْمَ نَخْتِمُ عَلَىٰٓ أَفْوَٰهِهِمْ وَتُكَلِّمُنَآ أَيْدِيهِمْ وَتَشْهَدُ أَرْجُلُهُم بِمَا كَانُوا۟ يَكْسِبُونَ","translation":"On that Day We shall set a seal on their mouths but their hands will speak unto Us, and their feet will bear witness to whatever they have earned [in life].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3770.mp3","surahId":36,"words":[{"id":57166,"position":1,"arabic":"ٱلْيَوْمَ","translation":"আজ","audioUrl":"wbw/036_065_001.mp3","charTypeName":"word"},{"id":57167,"position":2,"arabic":"نَخْتِمُ","translation":"সীল করে দিবো আমরা","audioUrl":"wbw/036_065_002.mp3","charTypeName":"word"},{"id":57168,"position":3,"arabic":"عَلَىٰٓ","translation":"উপর","audioUrl":"wbw/036_065_003.mp3","charTypeName":"word"},{"id":57169,"position":4,"arabic":"أَفْوَٰهِهِمْ","translation":"তাদের মুখগুলোর","audioUrl":"wbw/036_065_004.mp3","charTypeName":"word"},{"id":57170,"position":5,"arabic":"وَتُكَلِّمُنَآ","translation":"এবং আমাদের সাথে কথা বলবে","audioUrl":"wbw/036_065_005.mp3","charTypeName":"word"},{"id":57171,"position":6,"arabic":"أَيْدِيهِمْ","translation":"তাদের হাতগুলো","audioUrl":"wbw/036_065_006.mp3","charTypeName":"word"},{"id":57172,"position":7,"arabic":"وَتَشْهَدُ","translation":"এবং সাক্ষ্য দিবে","audioUrl":"wbw/036_065_007.mp3","charTypeName":"word"},{"id":57173,"position":8,"arabic":"أَرْجُلُهُم","translation":"তাদের পাগুলো","audioUrl":"wbw/036_065_008.mp3","charTypeName":"word"},{"id":57174,"position":9,"arabic":"بِمَا","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/036_065_009.mp3","charTypeName":"word"},{"id":57175,"position":10,"arabic":"كَانُوا۟","translation":"করেছিলো","audioUrl":"wbw/036_065_010.mp3","charTypeName":"word"},{"id":57176,"position":11,"arabic":"يَكْسِبُونَ","translation":"তারা কামাই","audioUrl":"wbw/036_065_011.mp3","charTypeName":"word"},{"id":57177,"position":12,"arabic":"٦٥","translation":"(৬৫)","audioUrl":null,"charTypeName":"end"}]},{"number":66,"arabic":"وَلَوْ نَشَآءُ لَطَمَسْنَا عَلَىٰٓ أَعْيُنِهِمْ فَٱسْتَبَقُوا۟ ٱلصِّرَٰطَ فَأَنَّىٰ يُبْصِرُونَ","translation":"NOW HAD IT BEEN Our will [that men should not be able to discern between right and wrong], We could surely have deprived them of their sight, so that they would stray forever from the [right] way: for how could they have had insight [into what is true]?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3771.mp3","surahId":36,"words":[{"id":57692,"position":1,"arabic":"وَلَوْ","translation":"এবং যদি","audioUrl":"wbw/036_066_001.mp3","charTypeName":"word"},{"id":57693,"position":2,"arabic":"نَشَآءُ","translation":"চাই আমরা","audioUrl":"wbw/036_066_002.mp3","charTypeName":"word"},{"id":57694,"position":3,"arabic":"لَطَمَسْنَا","translation":"দিতে পারি অবশ্যই","audioUrl":"wbw/036_066_003.mp3","charTypeName":"word"},{"id":57695,"position":4,"arabic":"عَلَىٰٓ","translation":"আমরা আলো নিভিয়ে","audioUrl":"wbw/036_066_004.mp3","charTypeName":"word"},{"id":57696,"position":5,"arabic":"أَعْيُنِهِمْ","translation":"তাদের চোখের","audioUrl":"wbw/036_066_005.mp3","charTypeName":"word"},{"id":57697,"position":6,"arabic":"فَٱسْتَبَقُوا۟","translation":"তারা অতঃপর চলতে চাইতো","audioUrl":"wbw/036_066_006.mp3","charTypeName":"word"},{"id":57698,"position":7,"arabic":"ٱلصِّرَٰطَ","translation":"পথে","audioUrl":"wbw/036_066_007.mp3","charTypeName":"word"},{"id":57699,"position":8,"arabic":"فَأَنَّىٰ","translation":"তখন কেমন করে","audioUrl":"wbw/036_066_008.mp3","charTypeName":"word"},{"id":57700,"position":9,"arabic":"يُبْصِرُونَ","translation":"তারা দেখতে পাবে","audioUrl":"wbw/036_066_009.mp3","charTypeName":"word"},{"id":57701,"position":10,"arabic":"٦٦","translation":"(৬৬)","audioUrl":null,"charTypeName":"end"}]},{"number":67,"arabic":"وَلَوْ نَشَآءُ لَمَسَخْنَٰهُمْ عَلَىٰ مَكَانَتِهِمْ فَمَا ٱسْتَطَٰعُوا۟ مُضِيًّۭا وَلَا يَرْجِعُونَ","translation":"And had it been Our will [that they should not be free to choose between right and wrong], We could surely have given them a different nature [and created them as beings rooted] in their places, so that they would not be able to move forward, and could not turn back.]","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3772.mp3","surahId":36,"words":[{"id":58055,"position":1,"arabic":"وَلَوْ","translation":"এবং যদি","audioUrl":"wbw/036_067_001.mp3","charTypeName":"word"},{"id":58056,"position":2,"arabic":"نَشَآءُ","translation":"চাই আমরা","audioUrl":"wbw/036_067_002.mp3","charTypeName":"word"},{"id":58057,"position":3,"arabic":"لَمَسَخْنَـٰهُمْ","translation":"তাদেরকে আমরা অবশ্যই বিকৃত করে দিতে পারি","audioUrl":"wbw/036_067_003.mp3","charTypeName":"word"},{"id":58058,"position":4,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/036_067_004.mp3","charTypeName":"word"},{"id":58059,"position":5,"arabic":"مَكَانَتِهِمْ","translation":"তাদের (নিজ নিজ) অবস্থানেই","audioUrl":"wbw/036_067_005.mp3","charTypeName":"word"},{"id":58060,"position":6,"arabic":"فَمَا","translation":"অতঃপর না","audioUrl":"wbw/036_067_006.mp3","charTypeName":"word"},{"id":58061,"position":7,"arabic":"ٱسْتَطَـٰعُوا۟","translation":"তারা সমর্থ হবে","audioUrl":"wbw/036_067_007.mp3","charTypeName":"word"},{"id":58062,"position":8,"arabic":"مُضِيًّۭا","translation":"আগে যেতে","audioUrl":"wbw/036_067_008.mp3","charTypeName":"word"},{"id":58063,"position":9,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/036_067_009.mp3","charTypeName":"word"},{"id":58064,"position":10,"arabic":"يَرْجِعُونَ","translation":"পিছনে ফিরতে","audioUrl":"wbw/036_067_010.mp3","charTypeName":"word"},{"id":58065,"position":11,"arabic":"٦٧","translation":"(৬৭)","audioUrl":null,"charTypeName":"end"}]},{"number":68,"arabic":"وَمَن نُّعَمِّرْهُ نُنَكِّسْهُ فِى ٱلْخَلْقِ ۖ أَفَلَا يَعْقِلُونَ","translation":"But [let them always remember that] if We lengthen a human being’s days, We also cause him to decline in his powers [when he grows old]: will they not, then, use their reason?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3773.mp3","surahId":36,"words":[{"id":58816,"position":1,"arabic":"وَمَن","translation":"এবং কোনো ব্যক্তি","audioUrl":"wbw/036_068_001.mp3","charTypeName":"word"},{"id":58817,"position":2,"arabic":"نُّعَمِّرْهُ","translation":"যাকে দীর্ঘায়ু দিই আমরা","audioUrl":"wbw/036_068_002.mp3","charTypeName":"word"},{"id":58818,"position":3,"arabic":"نُنَكِّسْهُ","translation":"উল্টিয়ে দিই আমরা তার","audioUrl":"wbw/036_068_003.mp3","charTypeName":"word"},{"id":58819,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/036_068_004.mp3","charTypeName":"word"},{"id":58820,"position":5,"arabic":"ٱلْخَلْقِ ۖ","translation":"আকৃতি-প্রকৃতির (বুদ্ধি ও যোগ্যতার)","audioUrl":"wbw/036_068_005.mp3","charTypeName":"word"},{"id":58822,"position":6,"arabic":"أَفَلَا","translation":"তবুও কি না","audioUrl":"wbw/036_068_007.mp3","charTypeName":"word"},{"id":58823,"position":7,"arabic":"يَعْقِلُونَ","translation":"তারা জ্ঞানবুদ্ধি কাজে লাগায়","audioUrl":"wbw/036_068_008.mp3","charTypeName":"word"},{"id":58824,"position":8,"arabic":"٦٨","translation":"(৬৮)","audioUrl":null,"charTypeName":"end"}]},{"number":69,"arabic":"وَمَا عَلَّمْنَٰهُ ٱلشِّعْرَ وَمَا يَنۢبَغِى لَهُۥٓ ۚ إِنْ هُوَ إِلَّا ذِكْرٌۭ وَقُرْءَانٌۭ مُّبِينٌۭ","translation":"AND [thus it is:] We have not imparted to this [Prophet the gift of] poetry, nor would [poetry] have suited this [message]: it is but a reminder and a [divine] discourse, clear in itself and clearly showing the truth,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3774.mp3","surahId":36,"words":[{"id":59315,"position":1,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/036_069_001.mp3","charTypeName":"word"},{"id":59316,"position":2,"arabic":"عَلَّمْنَـٰهُ","translation":"তাকে আমরা শিখিয়েছি","audioUrl":"wbw/036_069_002.mp3","charTypeName":"word"},{"id":59317,"position":3,"arabic":"ٱلشِّعْرَ","translation":"কবিতা","audioUrl":"wbw/036_069_003.mp3","charTypeName":"word"},{"id":59318,"position":4,"arabic":"وَمَا","translation":"আর না","audioUrl":"wbw/036_069_004.mp3","charTypeName":"word"},{"id":59319,"position":5,"arabic":"يَنۢبَغِى","translation":"শোভা পায় (এটা)","audioUrl":"wbw/036_069_005.mp3","charTypeName":"word"},{"id":59320,"position":6,"arabic":"لَهُۥٓ ۚ","translation":"তার জন্যে","audioUrl":"wbw/036_069_006.mp3","charTypeName":"word"},{"id":59322,"position":7,"arabic":"إِنْ","translation":"না","audioUrl":"wbw/036_069_008.mp3","charTypeName":"word"},{"id":59323,"position":8,"arabic":"هُوَ","translation":"তা","audioUrl":"wbw/036_069_009.mp3","charTypeName":"word"},{"id":59324,"position":9,"arabic":"إِلَّا","translation":"এছাড়া","audioUrl":"wbw/036_069_010.mp3","charTypeName":"word"},{"id":59325,"position":10,"arabic":"ذِكْرٌۭ","translation":"উপদেশ","audioUrl":"wbw/036_069_011.mp3","charTypeName":"word"},{"id":59326,"position":11,"arabic":"وَقُرْءَانٌۭ","translation":"ও (পাঠযোগ্য কিতাব) কোরআন","audioUrl":"wbw/036_069_012.mp3","charTypeName":"word"},{"id":59327,"position":12,"arabic":"مُّبِينٌۭ","translation":"সুস্পষ্ট","audioUrl":"wbw/036_069_013.mp3","charTypeName":"word"},{"id":59328,"position":13,"arabic":"٦٩","translation":"(৬৯)","audioUrl":null,"charTypeName":"end"}]},{"number":70,"arabic":"لِّيُنذِرَ مَن كَانَ حَيًّۭا وَيَحِقَّ ٱلْقَوْلُ عَلَى ٱلْكَٰفِرِينَ","translation":"to the end that it may warn everyone who is alive [of heart], and that the word [of God] may bear witness against all who deny the truth.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3775.mp3","surahId":36,"words":[{"id":59753,"position":1,"arabic":"لِّيُنذِرَ","translation":"সতর্ক করে যেন","audioUrl":"wbw/036_070_001.mp3","charTypeName":"word"},{"id":59754,"position":2,"arabic":"مَن","translation":"(এমন প্রত্যেককে) যে","audioUrl":"wbw/036_070_002.mp3","charTypeName":"word"},{"id":59755,"position":3,"arabic":"كَانَ","translation":"হলো","audioUrl":"wbw/036_070_003.mp3","charTypeName":"word"},{"id":59756,"position":4,"arabic":"حَيًّۭا","translation":"জীবিত","audioUrl":"wbw/036_070_004.mp3","charTypeName":"word"},{"id":59757,"position":5,"arabic":"وَيَحِقَّ","translation":"এবং প্রতিষ্ঠিত হতে পারে (যেন)","audioUrl":"wbw/036_070_005.mp3","charTypeName":"word"},{"id":59758,"position":6,"arabic":"ٱلْقَوْلُ","translation":"(শাস্তির) বাণী","audioUrl":"wbw/036_070_006.mp3","charTypeName":"word"},{"id":59759,"position":7,"arabic":"عَلَى","translation":"বিরুদ্ধে","audioUrl":"wbw/036_070_007.mp3","charTypeName":"word"},{"id":59760,"position":8,"arabic":"ٱلْكَـٰفِرِينَ","translation":"কাফিরদের","audioUrl":"wbw/036_070_008.mp3","charTypeName":"word"},{"id":59761,"position":9,"arabic":"٧٠","translation":"(৭০)","audioUrl":null,"charTypeName":"end"}]}]}