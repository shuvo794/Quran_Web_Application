{"id":359,"ayahs":[{"number":62,"arabic":"إِنَّمَا ٱلْمُؤْمِنُونَ ٱلَّذِينَ ءَامَنُوا۟ بِٱللَّهِ وَرَسُولِهِۦ وَإِذَا كَانُوا۟ مَعَهُۥ عَلَىٰٓ أَمْرٍۢ جَامِعٍۢ لَّمْ يَذْهَبُوا۟ حَتَّىٰ يَسْتَـْٔذِنُوهُ ۚ إِنَّ ٱلَّذِينَ يَسْتَـْٔذِنُونَكَ أُو۟لَٰٓئِكَ ٱلَّذِينَ يُؤْمِنُونَ بِٱللَّهِ وَرَسُولِهِۦ ۚ فَإِذَا ٱسْتَـْٔذَنُوكَ لِبَعْضِ شَأْنِهِمْ فَأْذَن لِّمَن شِئْتَ مِنْهُمْ وَٱسْتَغْفِرْ لَهُمُ ٱللَّهَ ۚ إِنَّ ٱللَّهَ غَفُورٌۭ رَّحِيمٌۭ","translation":"[TRUE BELIEVERS are only they who have attained to faith in God and His Apostle, and who, whenever they are [engaged] with him upon a matter of concern to the whole community do not depart [from whatever has been decided upon] unless they have sought [and obtained] his leave. Verily, those who [do not abstain from the agreed ­upon action unless they] ask leave of thee - it is [only] they who [truly] believe in God and His Apostle! Hence, when they ask leave of thee for some [valid] reason of their own, grant thou this leave to whomsoever of them thou choose [to grant it], and ask God to forgive them: for, behold, God is much-forgiving, a dispenser of grace!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2853.mp3","surahId":24,"words":[{"id":55573,"position":1,"arabic":"إِنَّمَا","translation":"মূলতঃ","audioUrl":"wbw/024_062_001.mp3","charTypeName":"word"},{"id":55574,"position":2,"arabic":"ٱلْمُؤْمِنُونَ","translation":"মু'মিন (তারাই)","audioUrl":"wbw/024_062_002.mp3","charTypeName":"word"},{"id":55575,"position":3,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/024_062_003.mp3","charTypeName":"word"},{"id":55576,"position":4,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/024_062_004.mp3","charTypeName":"word"},{"id":55577,"position":5,"arabic":"بِٱللَّهِ","translation":"উপর আল্লাহ্‌র","audioUrl":"wbw/024_062_005.mp3","charTypeName":"word"},{"id":55578,"position":6,"arabic":"وَرَسُولِهِۦ","translation":"ও তাঁর রাসূলের (উপর)","audioUrl":"wbw/024_062_006.mp3","charTypeName":"word"},{"id":55579,"position":7,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/024_062_007.mp3","charTypeName":"word"},{"id":55580,"position":8,"arabic":"كَانُوا۟","translation":"তারা হয়","audioUrl":"wbw/024_062_008.mp3","charTypeName":"word"},{"id":55581,"position":9,"arabic":"مَعَهُۥ","translation":"তার সাথে","audioUrl":"wbw/024_062_009.mp3","charTypeName":"word"},{"id":55582,"position":10,"arabic":"عَلَىٰٓ","translation":"উপর","audioUrl":"wbw/024_062_010.mp3","charTypeName":"word"},{"id":55583,"position":11,"arabic":"أَمْرٍۢ","translation":"কোন কাজের","audioUrl":"wbw/024_062_011.mp3","charTypeName":"word"},{"id":55584,"position":12,"arabic":"جَامِعٍۢ","translation":"সমষ্টিগত ভাবে","audioUrl":"wbw/024_062_012.mp3","charTypeName":"word"},{"id":55585,"position":13,"arabic":"لَّمْ","translation":"না","audioUrl":"wbw/024_062_013.mp3","charTypeName":"word"},{"id":55586,"position":14,"arabic":"يَذْهَبُوا۟","translation":"তারা চলে যায়","audioUrl":"wbw/024_062_014.mp3","charTypeName":"word"},{"id":55587,"position":15,"arabic":"حَتَّىٰ","translation":"যতক্ষণ না","audioUrl":"wbw/024_062_015.mp3","charTypeName":"word"},{"id":55588,"position":16,"arabic":"يَسْتَـْٔذِنُوهُ ۚ","translation":"তার (হ'তে) অনুমতি নেয়","audioUrl":"wbw/024_062_016.mp3","charTypeName":"word"},{"id":55590,"position":17,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/024_062_018.mp3","charTypeName":"word"},{"id":55591,"position":18,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/024_062_019.mp3","charTypeName":"word"},{"id":55592,"position":19,"arabic":"يَسْتَـْٔذِنُونَكَ","translation":"তোমার (হ'তে) অনুমতি চায়","audioUrl":"wbw/024_062_020.mp3","charTypeName":"word"},{"id":55593,"position":20,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐসব লোক","audioUrl":"wbw/024_062_021.mp3","charTypeName":"word"},{"id":55594,"position":21,"arabic":"ٱلَّذِينَ","translation":"তারাই","audioUrl":"wbw/024_062_022.mp3","charTypeName":"word"},{"id":55595,"position":22,"arabic":"يُؤْمِنُونَ","trans