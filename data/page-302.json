{"id":302,"ayahs":[{"number":75,"arabic":"۞ قَالَ أَلَمْ أَقُل لَّكَ إِنَّكَ لَن تَسْتَطِيعَ مَعِىَ صَبْرًۭا","translation":"He replied: \"Did I not tell thee that thou wilt never be able to have patience with me?\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2215.mp3","surahId":18,"words":[{"id":62314,"position":1,"arabic":"۞ قَالَ","translation":"সে বললো","audioUrl":"wbw/018_075_002.mp3","charTypeName":"word"},{"id":62315,"position":2,"arabic":"أَلَمْ","translation":"\"কি নি","audioUrl":"wbw/018_075_003.mp3","charTypeName":"word"},{"id":62316,"position":3,"arabic":"أَقُل","translation":"আমি বলি","audioUrl":"wbw/018_075_004.mp3","charTypeName":"word"},{"id":62317,"position":4,"arabic":"لَّكَ","translation":"আপনাকে","audioUrl":"wbw/018_075_005.mp3","charTypeName":"word"},{"id":62318,"position":5,"arabic":"إِنَّكَ","translation":"নিশ্চয়ই আপনি","audioUrl":"wbw/018_075_006.mp3","charTypeName":"word"},{"id":62319,"position":6,"arabic":"لَن","translation":"কখনও না","audioUrl":"wbw/018_075_007.mp3","charTypeName":"word"},{"id":62320,"position":7,"arabic":"تَسْتَطِيعَ","translation":"পারবেন","audioUrl":"wbw/018_075_008.mp3","charTypeName":"word"},{"id":62321,"position":8,"arabic":"مَعِىَ","translation":"আমার সাথে","audioUrl":"wbw/018_075_009.mp3","charTypeName":"word"},{"id":62322,"position":9,"arabic":"صَبْرًۭا","translation":"ধৈর্য ধরতে\"","audioUrl":"wbw/018_075_010.mp3","charTypeName":"word"},{"id":62323,"position":10,"arabic":"٧٥","translation":"(৭৫)","audioUrl":null,"charTypeName":"end"}]},{"number":76,"arabic":"قَالَ إِن سَأَلْتُكَ عَن شَىْءٍۭ بَعْدَهَا فَلَا تُصَٰحِبْنِى ۖ قَدْ بَلَغْتَ مِن لَّدُنِّى عُذْرًۭا","translation":"Said [Moses]: \"If, after this, I should ever question thee, keep me not in thy company: [for by] now thou hast heard enough excuses from me.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2216.mp3","surahId":18,"words":[{"id":62733,"position":1,"arabic":"قَالَ","translation":"(মূসা) বললো","audioUrl":"wbw/018_076_001.mp3","charTypeName":"word"},{"id":62734,"position":2,"arabic":"إِن","translation":"\"যদি","audioUrl":"wbw/018_076_002.mp3","charTypeName":"word"},{"id":62735,"position":3,"arabic":"سَأَلْتُكَ","translation":"আপনাকে আমি প্রশ্ন করি","audioUrl":"wbw/018_076_003.mp3","charTypeName":"word"},{"id":62736,"position":4,"arabic":"عَن","translation":"সম্বন্ধে","audioUrl":"wbw/018_076_004.mp3","charTypeName":"word"},{"id":62737,"position":5,"arabic":"شَىْءٍۭ","translation":"কোনো কিছু","audioUrl":"wbw/018_076_005.mp3","charTypeName":"word"},{"id":62738,"position":6,"arabic":"بَعْدَهَا","translation":"এরপর","audioUrl":"wbw/018_076_006.mp3","charTypeName":"word"},{"id":62739,"position":7,"arabic":"فَلَا","translation":"তাহ'লে না","audioUrl":"wbw/018_076_007.mp3","charTypeName":"word"},{"id":62740,"position":8,"arabic":"تُصَـٰحِبْنِى ۖ","translation":"আমাকে আপনি সঙ্গে রাখবেন","audioUrl":"wbw/018_076_008.mp3","charTypeName":"word"},{"id":62742,"position":9,"arabic":"قَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/018_076_010.mp3","charTypeName":"word"},{"id":62743,"position":10,"arabic":"بَلَغْتَ","translation":"আপনি পৌঁছে গেছেন","audioUrl":"wbw/018_076_011.mp3","charTypeName":"word"},{"id":62744,"position":11,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/018_076_012.mp3","charTypeName":"word"},{"id":62745,"position":12,"arabic":"لَّدُنِّى","translation":"আমার পক্ষ","audioUrl":"wbw/018_076_013.mp3","charTypeName":"word"},{"id":62746,"position":13,"arabic":"عُذْرًۭا","translation":"অজুহাতের শেষ সীমায়\"","audioUrl":"wbw/018_076_014.mp3","charTypeName":"word"},{"id":62747,"position":14,"arabic":"٧٦","translation":"(৭৬)","audioUrl":null,"charTypeName":"end"}]},{"number":77,"arabic":"فَٱنطَلَقَا حَتَّىٰٓ إِذَآ أَتَيَآ أَهْلَ قَرْيَةٍ ٱسْتَطْعَمَآ أَهْلَهَا فَأَبَوْا۟ أَن يُضَيِّفُوهُمَا فَوَجَدَا فِيهَا جِدَارًۭا يُرِيدُ أَن يَنقَضَّ فَأَقَامَهُۥ ۖ قَالَ لَوْ شِئْتَ لَتَّخَذْتَ عَلَيْهِ أَجْرًۭا","translation":"And so the two went on, till, when they came upon some village people, they asked them for food; but those [people] refused them all hospitality. And they saw in that (village] a wall which was on the point of tumbling down, and [the sage] rebuilt it [whereupon Moses] said: \"Hadst thou so wished, surely thou couldst [at least] have obtained some payment for it?\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2217.mp3","surahId":18,"words":[{"id":63010,"position":1,"arabic":"فَٱنطَلَقَا","translation":"অতঃপর দু'জনে চললো","audioUrl":"wbw/018_077_001.mp3","charTypeName":"word"},{"id":63011,"position":2,"arabic":"حَتَّىٰٓ","translation":"এমনকি","audioUrl":"wbw/018_077_002.mp3","charTypeName":"word"},{"id":63012,"position":3,"arabic":"إِذَآ","translation":"যখন","audioUrl":"wbw/018_077_003.mp3","charTypeName":"word"},{"id":63013,"position":4,"arabic":"أَتَيَآ","translation":"দু'জনে আসলো","audioUrl":"wbw/018_077_004.mp3","charTypeName":"word"},{"id":63014,"position":5,"arabic":"أَهْلَ","translation":"আধিবাসীদের কাছে","audioUrl":"wbw/018_077_005.mp3","charTypeName":"word"},{"id":63015,"position":6,"arabic":"قَرْيَةٍ","translation":"এক জনপদের","audioUrl":"wbw/018_077_006.mp3","charTypeName":"word"},{"id":63016,"position":7,"arabic":"ٱسْتَطْعَمَآ","translation":"দু'জনে খাদ্য চাইলো","audioUrl":"wbw/018_077_007.mp3","charTypeName":"word"},{"id":63017,"position":8,"arabic":"أَهْلَهَا","translation":"তার অধিবাসীদের কাছে","audioUrl":"wbw/018_077_008.mp3","charTypeName":"word"},{"id":63018,"position":9,"arabic":"فَأَبَوْا۟","translation":"কিন্তু তারা অস্বীকার করলো","audioUrl":"wbw/018_077_009.mp3","charTypeName":"word"},{"id":63019,"position":10,"arabic":"أَن","translation":"যে","audioUrl":"wbw/018_077_010.mp3","charTypeName":"word"},{"id":63020,"position":11,"arabic":"يُضَيِّفُوهُمَا","translation":"তারা আতিথেয়তা করবে তাদের দু'জনকে","audioUrl":"wbw/018_077_011.mp3","charTypeName":"word"},{"id":63021,"position":12,"arabic":"فَوَجَدَا","translation":"অতঃপর দু'জন পেলো","audioUrl":"wbw/018_077_012.mp3","charTypeName":"word"},{"id":63022,"position":13,"arabic":"فِيهَا","translation":"মধ্যে তার","audioUrl":"wbw/018_077_013.mp3","charTypeName":"word"},{"id":63023,"position":14,"arabic":"جِدَارًۭا","translation":"একটি দেয়াল","audioUrl":"wbw/018_077_014.mp3","charTypeName":"word"},{"id":63024,"position":15,"arabic":"يُرِيدُ","translation":"চাচ্ছিলো","audioUrl":"wbw/018_077_015.mp3","charTypeName":"word"},{"id":63025,"position":16,"arabic":"أَن","translation":"যে","audioUrl":"wbw/018_077_016.mp3","charTypeName":"word"},{"id":63026,"position":17,"arabic":"يَنقَضَّ","translation":"ভেঙ্গে পড়বে","audioUrl":"wbw/018_077_017.mp3","charTypeName":"word"},{"id":63027,"position":18,"arabic":"فَأَقَامَهُۥ ۖ","translation":"অতঃপর তা সে দাঁড় করিয়ে দিলো","audioUrl":"wbw/018_077_018.mp3","charTypeName":"word"},{"id":63029,"position":19,"arabic":"قَالَ","translation":"(মূসা) বললো","audioUrl":"wbw/018_077_020.mp3","charTypeName":"word"},{"id":63030,"position":20,"arabic":"لَوْ","translation":"\"যদি","audioUrl":"wbw/018_077_021.mp3","charTypeName":"word"},{"id":63031,"position":21,"arabic":"شِئْتَ","translation":"আপনি চাইতেন","audioUrl":"wbw/018_077_022.mp3","charTypeName":"word"},{"id":63032,"position":22,"arabic":"لَتَّخَذْتَ","translation":"অবশ্যই আপনি নিতে পারতেন","audioUrl":"wbw/018_077_023.mp3","charTypeName":"word"},{"id":63033,"position":23,"arabic":"عَلَيْهِ","translation":"এর বিনিময়ে","audioUrl":"wbw/018_077_024.mp3","charTypeName":"word"},{"id":63034,"position":24,"arabic":"أَجْرًۭا","translation":"পারিশ্রমিক\"","audioUrl":"wbw/018_077_025.mp3","charTypeName":"word"},{"id":63035,"position":25,"arabic":"٧٧","translation":"(৭৭)","audioUrl":null,"charTypeName":"end"}]},{"number":78,"arabic":"قَالَ هَٰذَا فِرَاقُ بَيْنِى وَبَيْنِكَ ۚ سَأُنَبِّئُكَ بِتَأْوِيلِ مَا لَمْ تَسْتَطِع عَّلَيْهِ صَبْرًا","translation":"[The sage] replied: \"This is the parting of ways between me and thee. [And now] I shall let thee know the real meaning of all [those events] that thou wert unable to bear with patience:,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2218.mp3","surahId":18,"words":[{"id":63491,"position":1,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/018_078_001.mp3","charTypeName":"word"},{"id":63492,"position":2,"arabic":"هَـٰذَا","translation":"\"এটাই","audioUrl":"wbw/018_078_002.mp3","charTypeName":"word"},{"id":63493,"position":3,"arabic":"فِرَاقُ","translation":"(যাত্রা শেষ) বিচ্ছেদ","audioUrl":"wbw/018_078_003.mp3","charTypeName":"word"},{"id":63494,"position":4,"arabic":"بَيْنِى","translation":"মাঝে আমার","audioUrl":"wbw/018_078_004.mp3","charTypeName":"word"},{"id":63495,"position":5,"arabic":"وَبَيْنِكَ ۚ","translation":"ও মাঝে আপনার","audioUrl":"wbw/018_078_005.mp3","charTypeName":"word"},{"id":63497,"position":6,"arabic":"سَأُنَبِّئُكَ","translation":"শীঘ্রই আপনাকে জানিয়ে দিবো","audioUrl":"wbw/018_078_007.mp3","charTypeName":"word"},{"id":63498,"position":7,"arabic":"بِتَأْوِيلِ","translation":"সম্পর্কে তাৎপর্য","audioUrl":"wbw/018_078_008.mp3","charTypeName":"word"},{"id":63499,"position":8,"arabic":"مَا","translation":"যে বিষয়ে","audioUrl":"wbw/018_078_009.mp3","charTypeName":"word"},{"id":63500,"position":9,"arabic":"لَمْ","translation":"নি","audioUrl":"wbw/018_078_010.mp3","charTypeName":"word"},{"id":63501,"position":10,"arabic":"تَسْتَطِع","translation":"পারেন","audioUrl":"wbw/018_078_011.mp3","charTypeName":"word"},{"id":63502,"position":11,"arabic":"عَّلَيْهِ","translation":"উপর তার","audioUrl":"wbw/018_078_012.mp3","charTypeName":"word"},{"id":63503,"position":12,"arabic":"صَبْرًا","translation":"ধৈর্য ধরতে","audioUrl":"wbw/018_078_013.mp3","charTypeName":"word"},{"id":63504,"position":13,"arabic":"٧٨","translation":"(৭৮)","audioUrl":null,"charTypeName":"end"}]},{"number":79,"arabic":"أَمَّا ٱلسَّفِينَةُ فَكَانَتْ لِمَسَٰكِينَ يَعْمَلُونَ فِى ٱلْبَحْرِ فَأَرَدتُّ أَنْ أَعِيبَهَا وَكَانَ وَرَآءَهُم مَّلِكٌۭ يَأْخُذُ كُلَّ سَفِينَةٍ غَصْبًۭا","translation":"\"As for that boat, it belonged to some needy people who toiled upon the sea -and I desired to damage it because (I knew that] behind them was a king who is wont to seize every boat by brute force.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2219.mp3","surahId":18,"words":[{"id":64004,"position":1,"arabic":"أَمَّا","translation":"ব্যাপার হলো","audioUrl":"wbw/018_079_001.mp3","charTypeName":"word"},{"id":64005,"position":2,"arabic":"ٱلسَّفِينَةُ","translation":"নৌকাটির","audioUrl":"wbw/018_079_002.mp3","charTypeName":"word"},{"id":64006,"position":3,"arabic":"فَكَانَتْ","translation":"অতঃপর সেটা ছিলো","audioUrl":"wbw/018_079_003.mp3","charTypeName":"word"},{"id":64007,"position":4,"arabic":"لِمَسَـٰكِينَ","translation":"ক'জন গরীব ব্যক্তির","audioUrl":"wbw/018_079_004.mp3","charTypeName":"word"},{"id":64008,"position":5,"arabic":"يَعْمَلُونَ","translation":"পরিশ্রম করতো","audioUrl":"wbw/018_079_005.mp3","charTypeName":"word"},{"id":64009,"position":6,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/018_079_006.mp3","charTypeName":"word"},{"id":64010,"position":7,"arabic":"ٱلْبَحْرِ","translation":"সমুদ্রের","audioUrl":"wbw/018_079_007.mp3","charTypeName":"word"},{"id":64011,"position":8,"arabic":"فَأَرَدتُّ","translation":"সুতরাং আমি চেয়েছি","audioUrl":"wbw/018_079_008.mp3","charTypeName":"word"},{"id":64012,"position":9,"arabic":"أَنْ","translation":"যে","audioUrl":"wbw/018_079_009.mp3","charTypeName":"word"},{"id":64013,"position":10,"arabic":"أَعِيبَهَا","translation":"তা ত্রুটিযুক্ত করি","audioUrl":"wbw/018_079_010.mp3","charTypeName":"word"},{"id":64014,"position":11,"arabic":"وَكَانَ","translation":"এবং ছিলো","audioUrl":"wbw/018_079_011.mp3","charTypeName":"word"},{"id":64015,"position":12,"arabic":"وَرَآءَهُم","translation":"পিছনে তাদের","audioUrl":"wbw/018_079_012.mp3","charTypeName":"word"},{"id":64016,"position":13,"arabic":"مَّلِكٌۭ","translation":"এক রাজা","audioUrl":"wbw/018_079_013.mp3","charTypeName":"word"},{"id":64017,"position":14,"arabic":"يَأْخُذُ","translation":"নিয়ে নিতো","audioUrl":"wbw/018_079_014.mp3","charTypeName":"word"},{"id":64018,"position":15,"arabic":"كُلَّ","translation":"প্রত্যেক","audioUrl":"wbw/018_079_015.mp3","charTypeName":"word"},{"id":64019,"position":16,"arabic":"سَفِينَةٍ","translation":"নৌকা","audioUrl":"wbw/018_079_016.mp3","charTypeName":"word"},{"id":64020,"position":17,"arabic":"غَصْبًۭا","translation":"জোর করে","audioUrl":"wbw/018_079_017.mp3","charTypeName":"word"},{"id":64021,"position":18,"arabic":"٧٩","translation":"(৭৯)","audioUrl":null,"charTypeName":"end"}]},{"number":80,"arabic":"وَأَمَّا ٱلْغُلَٰمُ فَكَانَ أَبَوَاهُ مُؤْمِنَيْنِ فَخَشِينَآ أَن يُرْهِقَهُمَا طُغْيَٰنًۭا وَكُفْرًۭا","translation":"\"And as for that young man, his parents were [true] believers - whereas we had every reason to fear that he would bring bitter grief upon them by [his] overweening wickedness and denial of all truth:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2220.mp3","surahId":18,"words":[{"id":64305,"position":1,"arabic":"وَأَمَّا","translation":"আর ব্যাপার হলো","audioUrl":"wbw/018_080_001.mp3","charTypeName":"word"},{"id":64306,"position":2,"arabic":"ٱلْغُلَـٰمُ","translation":"ছেলেটির","audioUrl":"wbw/018_080_002.mp3","charTypeName":"word"},{"id":64307,"position":3,"arabic":"فَكَانَ","translation":"অতঃপর ছিলো","audioUrl":"wbw/018_080_003.mp3","charTypeName":"word"},{"id":64308,"position":4,"arabic":"أَبَوَاهُ","translation":"তার পিতামাতা","audioUrl":"wbw/018_080_004.mp3","charTypeName":"word"},{"id":64309,"position":5,"arabic":"مُؤْمِنَيْنِ","translation":"দু'জন মু'মিন","audioUrl":"wbw/018_080_005.mp3","charTypeName":"word"},{"id":64310,"position":6,"arabic":"فَخَشِينَآ","translation":"তখন আমরা আশঙ্কা করলাম","audioUrl":"wbw/018_080_006.mp3","charTypeName":"word"},{"id":64311,"position":7,"arabic":"أَن","translation":"যে","audioUrl":"wbw/018_080_007.mp3","charTypeName":"word"},{"id":64312,"position":8,"arabic":"يُرْهِقَهُمَا","translation":"তাদের দু'জনকে সে কষ্ট দিবে","audioUrl":"wbw/018_080_008.mp3","charTypeName":"word"},{"id":64313,"position":9,"arabic":"طُغْيَـٰنًۭا","translation":"অবাধ্যতা করে","audioUrl":"wbw/018_080_009.mp3","charTypeName":"word"},{"id":64314,"position":10,"arabic":"وَكُفْرًۭا","translation":"ও অবিশ্বাস (পথে চলে)","audioUrl":"wbw/018_080_010.mp3","charTypeName":"word"},{"id":64315,"position":11,"arabic":"٨٠","translation":"(৮০)","audioUrl":null,"charTypeName":"end"}]},{"number":81,"arabic":"فَأَرَدْنَآ أَن يُبْدِلَهُمَا رَبُّهُمَا خَيْرًۭا مِّنْهُ زَكَوٰةًۭ وَأَقْرَبَ رُحْمًۭا","translation":"and so we desired that their Sustainer grant them in his stead [a child] of greater purity than him, and closer [to them] in loving tenderness.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2221.mp3","surahId":18,"words":[{"id":64872,"position":1,"arabic":"فَأَرَدْنَآ","translation":"সুতরাং আমরা চাইলাম","audioUrl":"wbw/018_081_001.mp3","charTypeName":"word"},{"id":64873,"position":2,"arabic":"أَن","translation":"যে","audioUrl":"wbw/018_081_002.mp3","charTypeName":"word"},{"id":64874,"position":3,"arabic":"يُبْدِلَهُمَا","translation":"দু'জনকে পরিবর্তে দিবেন","audioUrl":"wbw/018_081_003.mp3","charTypeName":"word"},{"id":64875,"position":4,"arabic":"رَبُّهُمَا","translation":"দু'জনের রব","audioUrl":"wbw/018_081_004.mp3","charTypeName":"word"},{"id":64876,"position":5,"arabic":"خَيْرًۭا","translation":"উত্তম","audioUrl":"wbw/018_081_005.mp3","charTypeName":"word"},{"id":64877,"position":6,"arabic":"مِّنْهُ","translation":"তার চেয়ে","audioUrl":"wbw/018_081_006.mp3","charTypeName":"word"},{"id":64878,"position":7,"arabic":"زَكَوٰةًۭ","translation":"পবিত্রতায়","audioUrl":"wbw/018_081_007.mp3","charTypeName":"word"},{"id":64879,"position":8,"arabic":"وَأَقْرَبَ","translation":"এবং ঘনিষ্টতর","audioUrl":"wbw/018_081_008.mp3","charTypeName":"word"},{"id":64880,"position":9,"arabic":"رُحْمًۭا","translation":"দয়ার দিক থেকে","audioUrl":"wbw/018_081_009.mp3","charTypeName":"word"},{"id":64881,"position":10,"arabic":"٨١","translation":"(৮১)","audioUrl":null,"charTypeName":"end"}]},{"number":82,"arabic":"وَأَمَّا ٱلْجِدَارُ فَكَانَ لِغُلَٰمَيْنِ يَتِيمَيْنِ فِى ٱلْمَدِينَةِ وَكَانَ تَحْتَهُۥ كَنزٌۭ لَّهُمَا وَكَانَ أَبُوهُمَا صَٰلِحًۭا فَأَرَادَ رَبُّكَ أَن يَبْلُغَآ أَشُدَّهُمَا وَيَسْتَخْرِجَا كَنزَهُمَا رَحْمَةًۭ مِّن رَّبِّكَ ۚ وَمَا فَعَلْتُهُۥ عَنْ أَمْرِى ۚ ذَٰلِكَ تَأْوِيلُ مَا لَمْ تَسْطِع عَّلَيْهِ صَبْرًۭا","translation":"\"And as for that wall, it belonged to two orphan boys [living] in the town, and beneath it was [buried] a treasure belonging to them [by right]. Now their father had been a righteous man, and so thy Sustainer willed it that when they come of age they should bring forth their treasure by thy Sustainer's grace. \"And I did not do (any of] this of my own accord: this is the real meaning of all [those events] that thou wert unable to bear with patience.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2222.mp3","surahId":18,"words":[{"id":64977,"position":1,"arabic":"وَأَمَّا","translation":"আর ব্যাপার (হলো)","audioUrl":"wbw/018_082_001.mp3","charTypeName":"word"},{"id":64978,"position":2,"arabic":"ٱلْجِدَارُ","translation":"দেয়ালটির (এই যে)","audioUrl":"wbw/018_082_002.mp3","charTypeName":"word"},{"id":64979,"position":3,"arabic":"فَكَانَ","translation":"অতঃপর সেটা ছিলো","audioUrl":"wbw/018_082_003.mp3","charTypeName":"word"},{"id":64980,"position":4,"arabic":"لِغُلَـٰمَيْنِ","translation":"দু'টি ছেলের","audioUrl":"wbw/018_082_004.mp3","charTypeName":"word"},{"id":64981,"position":5,"arabic":"يَتِيمَيْنِ","translation":"পিতৃহীন","audioUrl":"wbw/018_082_005.mp3","charTypeName":"word"},{"id":64982,"position":6,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/018_082_006.mp3","charTypeName":"word"},{"id":64983,"position":7,"arabic":"ٱلْمَدِينَةِ","translation":"শহরটির","audioUrl":"wbw/018_082_007.mp3","charTypeName":"word"},{"id":64984,"position":8,"arabic":"وَكَانَ","translation":"এবং ছিলো","audioUrl":"wbw/018_082_008.mp3","charTypeName":"word"},{"id":64985