5_003.mp3","charTypeName":"word"},{"id":17603,"position":4,"arabic":"يَنتَهِ","translation":"সে বিরত হয়","audioUrl":"wbw/096_015_004.mp3","charTypeName":"word"},{"id":17604,"position":5,"arabic":"لَنَسْفَعًۢا","translation":"আমরা অবশ্যই টানবো","audioUrl":"wbw/096_015_005.mp3","charTypeName":"word"},{"id":17605,"position":6,"arabic":"بِٱلنَّاصِيَةِ","translation":"মাথার সামনের চুল ধরে","audioUrl":"wbw/096_015_006.mp3","charTypeName":"word"},{"id":17606,"position":7,"arabic":"١٥","translation":"(১৫)","audioUrl":null,"charTypeName":"end"}]},{"number":16,"arabic":"نَاصِيَةٍۢ كَٰذِبَةٍ خَاطِئَةٍۢ","translation":"the lying, rebellious forehead! –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6122.mp3","surahId":96,"words":[{"id":18642,"position":1,"arabic":"نَاصِيَةٍۢ","translation":"সামনের চুল (টানবো)","audioUrl":"wbw/096_016_001.mp3","charTypeName":"word"},{"id":18643,"position":2,"arabic":"كَـٰذِبَةٍ","translation":"মিথ্যুকের","audioUrl":"wbw/096_016_002.mp3","charTypeName":"word"},{"id":18644,"position":3,"arabic":"خَاطِئَةٍۢ","translation":"পাপীর","audioUrl":"wbw/096_016_003.mp3","charTypeName":"word"},{"id":18645,"position":4,"arabic":"١٦","translation":"(১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":17,"arabic":"فَلْيَدْعُ نَادِيَهُۥ","translation":"and then let him summon [to his aid] the counsels of his own [spurious] wisdom,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6123.mp3","surahId":96,"words":[{"id":19699,"position":1,"arabic":"فَلْيَدْعُ","translation":"অতএব সে যেন ডাকে","audioUrl":"wbw/096_017_001.mp3","charTypeName":"word"},{"id":19700,"position":2,"arabic":"نَادِيَهُۥ","translation":"তার দোসরদেরকে","audioUrl":"wbw/096_017_002.mp3","charTypeName":"word"},{"id":19701,"position":3,"arabic":"١٧","translation":"(১৭)","audioUrl":null,"charTypeName":"end"}]},{"number":18,"arabic":"سَنَدْعُ ٱلزَّبَانِيَةَ","translation":"[the while] We shall summon the forces of heavenly chastisement!","audio":"https://cdn.isla