nd down from the skies, and which is absorbed by the plants of the earth: but [in time] they turn into dry. stubble which the winds blow freely about. And it is God [alone] who determines all things.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2185.mp3","surahId":18,"words":[{"id":45041,"position":1,"arabic":"وَٱضْرِبْ","translation":"এবং পেশ করো","audioUrl":"wbw/018_045_001.mp3","charTypeName":"word"},{"id":45042,"position":2,"arabic":"لَهُم","translation":"জন্যে তাদের","audioUrl":"wbw/018_045_002.mp3","charTypeName":"word"},{"id":45043,"position":3,"arabic":"مَّثَلَ","translation":"একটি দৃষ্টান্ত","audioUrl":"wbw/018_045_003.mp3","charTypeName":"word"},{"id":45044,"position":4,"arabic":"ٱلْحَيَوٰةِ","translation":"জীবনের","audioUrl":"wbw/018_045_004.mp3","charTypeName":"word"},{"id":45045,"position":5,"arabic":"ٱلدُّنْيَا","translation":"পার্থিব","audioUrl":"wbw/018_045_005.mp3","charTypeName":"word"},{"id":45046,"position":6,"arabic":"كَمَآءٍ","translation":"মতো পানির","audioUrl":"wbw/018_045_006.mp3","charTypeName":"word"},{"id":45047,"position":7,"arabic":"أَنزَلْنَـٰهُ","translation":"তা আমরা বর্ষণ করি","audioUrl":"wbw/018_045_007.mp3","charTypeName":"word"},{"id":45048,"position":8,"arabic":"مِنَ","translation":"থেকে","audioUrl":"wbw/018_045_008.mp3","charTypeName":"word"},{"id":45049,"position":9,"arabic":"ٱلسَّمَآءِ","translation":"আকাশ","audioUrl":"wbw/018_045_009.mp3","charTypeName":"word"},{"id":45050,"position":10,"arabic":"فَٱخْتَلَطَ","translation":"তখন ঘন হয়ে উঠে","audioUrl":"wbw/018_045_010.mp3","charTypeName":"word"},{"id":45051,"position":11,"arabic":"بِهِۦ","translation":"দিয়ে তা","audioUrl":"wbw/018_045_011.mp3","charTypeName":"word"},{"id":45052,"position":12,"arabic":"نَبَاتُ","translation":"উদ্ভিদ","audioUrl":"wbw/018_045_012.mp3","charTypeName":"word"},{"id":45053,"position":13,"arabic":"ٱلْأَرْضِ","translation":"মাটির","audioUrl":"wbw/018_045_013.mp3","charTypeName":"word"},{"id":45054,"position":14,"arabic":"فَأَصْبَ