{"id":298,"ayahs":[{"number":35,"arabic":"وَدَخَلَ جَنَّتَهُۥ وَهُوَ ظَالِمٌۭ لِّنَفْسِهِۦ قَالَ مَآ أَظُنُّ أَن تَبِيدَ هَٰذِهِۦٓ أَبَدًۭا","translation":"And having [thus] sinned against himself, he entered his garden, saying, \"I do not think that this will ever perish!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2175.mp3","surahId":18,"words":[{"id":37000,"position":1,"arabic":"وَدَخَلَ","translation":"এবং প্রবেশ করলো","audioUrl":"wbw/018_035_001.mp3","charTypeName":"word"},{"id":37001,"position":2,"arabic":"جَنَّتَهُۥ","translation":"তার বাগানে","audioUrl":"wbw/018_035_002.mp3","charTypeName":"word"},{"id":37002,"position":3,"arabic":"وَهُوَ","translation":"এবং এ অবস্থায় যে সে ছিলো","audioUrl":"wbw/018_035_003.mp3","charTypeName":"word"},{"id":37003,"position":4,"arabic":"ظَالِمٌۭ","translation":"সীমালঙ্ঘনকারী","audioUrl":"wbw/018_035_004.mp3","charTypeName":"word"},{"id":37004,"position":5,"arabic":"لِّنَفْسِهِۦ","translation":"উপর তার নিজের","audioUrl":"wbw/018_035_005.mp3","charTypeName":"word"},{"id":37005,"position":6,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/018_035_006.mp3","charTypeName":"word"},{"id":37006,"position":7,"arabic":"مَآ","translation":"\"না","audioUrl":"wbw/018_035_007.mp3","charTypeName":"word"},{"id":37007,"position":8,"arabic":"أَظُنُّ","translation":"আমি মনে করি","audioUrl":"wbw/018_035_008.mp3","charTypeName":"word"},{"id":37008,"position":9,"arabic":"أَن","translation":"যে","audioUrl":"wbw/018_035_009.mp3","charTypeName":"word"},{"id":37009,"position":10,"arabic":"تَبِيدَ","translation":"ধ্বংস হবে","audioUrl":"wbw/018_035_010.mp3","charTypeName":"word"},{"id":37010,"position":11,"arabic":"هَـٰذِهِۦٓ","translation":"এই (সম্পদ)","audioUrl":"wbw/018_035_011.mp3","charTypeName":"word"},{"id":37011,"position":12,"arabic":"أَبَدًۭا","translation":"কখনও","audioUrl":"wbw/018_035_012.mp3","charTypeName":"word"},{"id":37012,"position":13,"arabic":"٣٥","translation":"(৩৫)","audioUrl":null,"charTypeName":"end"}]},{"number":36,"arabic":"وَمَآ أَظُنُّ ٱلسَّاعَةَ قَآئِمَةًۭ وَلَئِن رُّدِدتُّ إِلَىٰ رَبِّى لَأَجِدَنَّ خَيْرًۭا مِّنْهَا مُنقَلَبًۭا","translation":"And neither do I think that the Last Hour will ever come. But even if [it should come, and] I am brought before my Sustainer, I will surely find something even better than this as [my last] resort!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2176.mp3","surahId":18,"words":[{"id":37847,"position":1,"arabic":"وَمَآ","translation":"এবং না","audioUrl":"wbw/018_036_001.mp3","charTypeName":"word"},{"id":37848,"position":2,"arabic":"أَظُنُّ","translation":"আমি মনে করি","audioUrl":"wbw/018_036_002.mp3","charTypeName":"word"},{"id":37849,"position":3,"arabic":"ٱلسَّاعَةَ","translation":"ক্বিয়ামাত","audioUrl":"wbw/018_036_003.mp3","charTypeName":"word"},{"id":37850,"position":4,"arabic":"قَآئِمَةًۭ","translation":"সংঘটিত হবে","audioUrl":"wbw/018_036_004.mp3","charTypeName":"word"},{"id":37851,"position":5,"arabic":"وَلَئِن","translation":"এবং অবশ্যই যদি","audioUrl":"wbw/018_036_005.mp3","charTypeName":"word"},{"id":37852,"position":6,"arabic":"رُّدِدتُّ","translation":"আমি প্রত্যাবর্তিত হই","audioUrl":"wbw/018_036_006.mp3","charTypeName":"word"},{"id":37853,"position":7,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/018_036_007.mp3","charTypeName":"word"},{"id":37854,"position":8,"arabic":"رَبِّى","translation":"আমার রবের","audioUrl":"wbw/018_036_008.mp3","charTypeName":"word"},{"id":37855,"position":9,"arabic":"لَأَجِدَنَّ","translation":"অবশ্যই আমি পাবো","audioUrl":"wbw/018_036_009.mp3","charTypeName":"word"},{"id":37856,"position":10,"arabic":"خَيْرًۭا","translation":"উত্তম","audioUrl":"wbw/018_036_010.mp3","charTypeName":"word"},{"id":37857,"position":11,"arabic":"مِّنْهَا","translation":"তাদের দু'টির চেয়েও","audioUrl":"wbw/018_036_011.mp3","charTypeName":"word"},{"id":37858,"position":12,"arabic":"مُنقَلَبًۭا","translation":"প্রত্যাবর্তনস্থান\"","audioUrl":"wbw/018_036_012.mp3","charTypeName":"word"},{"id":37859,"position":13,"arabic":"٣٦","translation":"(৩৬)","audioUrl":null,"charTypeName":"end"}]},{"number":37,"arabic":"قَالَ لَهُۥ صَاحِبُهُۥ وَهُوَ يُحَاوِرُهُۥٓ أَكَفَرْتَ بِٱلَّذِى خَلَقَكَ مِن تُرَابٍۢ ثُمَّ مِن نُّطْفَةٍۢ ثُمَّ سَوَّىٰكَ رَجُلًۭا","translation":"And his friend answered him in the course of their argument: \"Wilt thou blaspheme against Him who has created thee out of dust, and then out of a drop of sperm, and in the end has fashioned thee into a [complete] man?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2177.mp3","surahId":18,"words":[{"id":38710,"position":1,"arabic":"قَالَ","translation":"বললো","audioUrl":"wbw/018_037_001.mp3","charTypeName":"word"},{"id":38711,"position":2,"arabic":"لَهُۥ","translation":"তাকে","audioUrl":"wbw/018_037_002.mp3","charTypeName":"word"},{"id":38712,"position":3,"arabic":"صَاحِبُهُۥ","translation":"তার সাথী","audioUrl":"wbw/018_037_003.mp3","charTypeName":"word"},{"id":38713,"position":4,"arabic":"وَهُوَ","translation":"এমতাবস্হায় যে সে","audioUrl":"wbw/018_037_004.mp3","charTypeName":"word"},{"id":38714,"position":5,"arabic":"يُحَاوِرُهُۥٓ","translation":"তার সাথে আলোচনা করেছিলো","audioUrl":"wbw/018_037_005.mp3","charTypeName":"word"},{"id":38715,"position":6,"arabic":"أَكَفَرْتَ","translation":"\"কি তুমি অস্বীকার করছো","audioUrl":"wbw/018_037_006.mp3","charTypeName":"word"},{"id":38716,"position":7,"arabic":"بِٱلَّذِى","translation":"(ঐ সত্ত্বা) কে যিনি","audioUrl":"wbw/018_037_007.mp3","charTypeName":"word"},{"id":38717,"position":8,"arabic":"خَلَقَكَ","translation":"তোমাকে সৃষ্টি করেছেন","audioUrl":"wbw/018_037_008.mp3","charTypeName":"word"},{"id":38718,"position":9,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/018_037_009.mp3","charTypeName":"word"},{"id":38719,"position":10,"arabic":"تُرَابٍۢ","translation":"মাটি","audioUrl":"wbw/018_037_010.mp3","charTypeName":"word"},{"id":38720,"position":11,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/018_037_011.mp3","charTypeName":"word"},{"id":38721,"position":12,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/018_037_012.mp3","charTypeName":"word"},{"id":38722,"position":13,"arabic":"نُّطْفَةٍۢ","translation":"শুক্র","audioUrl":"wbw/018_037_013.mp3","charTypeName":"word"},{"id":38723,"position":14,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/018_037_014.mp3","charTypeName":"word"},{"id":38724,"position":15,"arabic":"سَوَّىٰكَ","translation":"তোমাকে সম্পূর্ণ করেছেন","audioUrl":"wbw/018_037_015.mp3","charTypeName":"word"},{"id":38725,"position":16,"arabic":"رَجُلًۭا","translation":"মানুষে","audioUrl":"wbw/018_037_016.mp3","charTypeName":"word"},{"id":38726,"position":17,"arabic":"٣٧","translation":"(৩৭)","audioUrl":null,"charTypeName":"end"}]},{"number":38,"arabic":"لَّٰكِنَّا۠ هُوَ ٱللَّهُ رَبِّى وَلَآ أُشْرِكُ بِرَبِّىٓ أَحَدًۭا","translation":"But as for myself, [I. know that] He is God, my Sustainer; and I cannot attribute divine powers to any but my Sustainer.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2178.mp3","surahId":18,"words":[{"id":40212,"position":1,"arabic":"لَّـٰكِنَّا۠","translation":"কিন্তু (আমি বলি)","audioUrl":"wbw/018_038_001.mp3","charTypeName":"word"},{"id":40213,"position":2,"arabic":"هُوَ","translation":"তিনি","audioUrl":"wbw/018_038_002.mp3","charTypeName":"word"},{"id":40214,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌","audioUrl":"wbw/018_038_003.mp3","charTypeName":"word"},{"id":40215,"position":4,"arabic":"رَبِّى","translation":"আমার রব","audioUrl":"wbw/018_038_004.mp3","charTypeName":"word"},{"id":40216,"position":5,"arabic":"وَلَآ","translation":"এবং না","audioUrl":"wbw/018_038_005.mp3","charTypeName":"word"},{"id":40217,"position":6,"arabic":"أُشْرِكُ","translation":"শরিক করি আমি","audioUrl":"wbw/018_038_006.mp3","charTypeName":"word"},{"id":40218,"position":7,"arabic":"بِرَبِّىٓ","translation":"সাথে আমার রবের","audioUrl":"wbw/018_038_007.mp3","charTypeName":"word"},{"id":40219,"position":8,"arabic":"أَحَدًۭا","translation":"কাউকে","audioUrl":"wbw/018_038_008.mp3","charTypeName":"word"},{"id":40220,"position":9,"arabic":"٣٨","translation":"(৩৮)","audioUrl":null,"charTypeName":"end"}]},{"number":39,"arabic":"وَلَوْلَآ إِذْ دَخَلْتَ جَنَّتَكَ قُلْتَ مَا شَآءَ ٱللَّهُ لَا قُوَّةَ إِلَّا بِٱللَّهِ ۚ إِن تَرَنِ أَنَا۠ أَقَلَّ مِنكَ مَالًۭا وَوَلَدًۭا","translation":"And [he continued:] \"Alas, if thou hadst but said, on entering thy garden, `Whatever God wills [shall come to pass, for] there is no power save with God!' Although, as thou seest, I have less wealth and offspring than thou,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2179.mp3","surahId":18,"words":[{"id":40398,"position":1,"arabic":"وَلَوْلَآ","translation":"এবং কেন না","audioUrl":"wbw/018_039_001.mp3","charTypeName":"word"},{"id":40399,"position":2,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/018_039_002.mp3","charTypeName":"word"},{"id":40400,"position":3,"arabic":"دَخَلْتَ","translation":"তুমি প্রবেশ করছিলে","audioUrl":"wbw/018_039_003.mp3","charTypeName":"word"},{"id":40401,"position":4,"arabic":"جَنَّتَكَ","translation":"তোমার বাগানে","audioUrl":"wbw/018_039_004.mp3","charTypeName":"word"},{"id":40402,"position":5,"arabic":"قُلْتَ","translation":"তুমি বলেছিলে","audioUrl":"wbw/018_039_005.mp3","charTypeName":"word"},{"id":40403,"position":6,"arabic":"مَا","translation":"\"যা","audioUrl":"wbw/018_039_006.mp3","charTypeName":"word"},{"id":40404,"position":7,"arabic":"شَآءَ","translation":"চেয়েছেন","audioUrl":"wbw/018_039_007.mp3","charTypeName":"word"},{"id":40405,"position":8,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌ (তাই হয়েছে)","audioUrl":"wbw/018_039_008.mp3","charTypeName":"word"},{"id":40406,"position":9,"arabic":"لَا","translation":"নেই","audioUrl":"wbw/018_039_009.mp3","charTypeName":"word"},{"id":40407,"position":10,"arabic":"قُوَّةَ","translation":"কোনো শক্তি","audioUrl":"wbw/018_039_010.mp3","charTypeName":"word"},{"id":40408,"position":11,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/018_039_011.mp3","charTypeName":"word"},{"id":40409,"position":12,"arabic":"بِٱللَّهِ ۚ","translation":"আল্লাহ্‌\"","audioUrl":"wbw/018_039_012.mp3","charTypeName":"word"},{"id":40411,"position":13,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/018_039_014.mp3","charTypeName":"word"},{"id":40412,"position":14,"arabic":"تَرَنِ","translation":"আমাকে দেখো","audioUrl":"wbw/018_039_015.mp3","charTypeName":"word"},{"id":40413,"position":15,"arabic":"أَنَا۠","translation":"আমি","audioUrl":"wbw/018_039_016.mp3","charTypeName":"word"},{"id":40414,"position":16,"arabic":"أَقَلَّ","translation":"স্বল্পতর","audioUrl":"wbw/018_039_017.mp3","charTypeName":"word"},{"id":40415,"position":17,"arabic":"مِنكَ","translation":"তোমার চেয়ে","audioUrl":"wbw/018_039_018.mp3","charTypeName":"word"},{"id":40416,"position":18,"arabic":"مَالًۭا","translation":"সম্পদে","audioUrl":"wbw/018_039_019.mp3","charTypeName":"word"},{"id":40417,"position":19,"arabic":"وَوَلَدًۭا","translation":"এবং সন্তানে","audioUrl":"wbw/018_039_020.mp3","charTypeName":"word"},{"id":40418,"position":20,"arabic":"٣٩","translation":"(৩৯)","audioUrl":null,"charTypeName":"end"}]},{"number":40,"arabic":"فَعَسَىٰ رَبِّىٓ أَن يُؤْتِيَنِ خَيْرًۭا مِّن جَنَّتِكَ وَيُرْسِلَ عَلَيْهَا حُسْبَانًۭا مِّنَ ٱلسَّمَآءِ فَتُصْبِحَ صَعِيدًۭا زَلَقًا","translation":"yet it may well be that my Sustainer will give me something better than thy garden -just as He may let loose a calamity out of heaven upon this [thy garden], so that it becomes a heap of barren dust","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2180.mp3","surahId":18,"words":[{"id":41663,"position":1,"arabic":"فَعَسَىٰ","translation":"তবে হয়তো","audioUrl":"wbw/018_040_001.mp3","charTypeName":"word"},{"id":41664,"position":2,"arabic":"رَبِّىٓ","translation":"আমার রব","audioUrl":"wbw/018_040_002.mp3","charTypeName":"word"},{"id":41665,"position":3,"arabic":"أَن","translation":"যে","audioUrl":"wbw/018_040_003.mp3","charTypeName":"word"},{"id":41666,"position":4,"arabic":"يُؤْتِيَنِ","translation":"আমাকে দান করবেন","audioUrl":"wbw/018_040_004.mp3","charTypeName":"word"},{"id":41667,"position":5,"arabic":"خَيْرًۭا","translation":"উত্তম","audioUrl":"wbw/018_040_005.mp3","charTypeName":"word"},{"id":41668,"position":6,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/018_040_006.mp3","charTypeName":"word"},{"id":41669,"position":7,"arabic":"جَنَّتِكَ","translation":"তোমার বাগান","audioUrl":"wbw/018_040_007.mp3","charTypeName":"word"},{"id":41670,"position":8,"arabic":"وَيُرْسِلَ","translation":"এবং প্রেরণ করবেন","audioUrl":"wbw/018_040_008.mp3","charTypeName":"word"},{"id":41671,"position":9,"arabic":"عَلَيْهَا","translation":"উপর তার","audioUrl":"wbw/018_040_009.mp3","charTypeName":"word"},{"id":41672,"position":10,"arabic":"حُسْبَانًۭا","translation":"বিপর্যয়","audioUrl":"wbw/018_040_010.mp3","charTypeName":"word"},{"id":41673,"position":11,"arabic":"مِّنَ","translation":"থেকে","audioUrl":"wbw/018_040_011.mp3","charTypeName":"word"},{"id":41674,"position":12,"arabic":"ٱلسَّمَآءِ","translation":"আকাশ","audioUrl":"wbw/018_040_012.mp3","charTypeName":"word"},{"id":41675,"position":13,"arabic":"فَتُصْبِحَ","translation":"অতঃপর তা হয়ে যাবে","audioUrl":"wbw/018_040_013.mp3","charTypeName":"word"},{"id":41676,"position":14,"arabic":"صَعِيدًۭا","translation":"মাটি","audioUrl":"wbw/018_040_014.mp3","charTypeName":"word"},{"id":41677,"position":15,"arabic":"زَلَقًا","translation":"উদ্ভিদশূন্য","audioUrl":"wbw/018_040_015.mp3","charTypeName":"word"},{"id":41678,"position":16,"arabic":"٤٠","translation":"(৪০)","audioUrl":null,"charTypeName":"end"}]},{"number":41,"arabic":"أَوْ يُصْبِحَ مَآؤُهَا غَوْرًۭا فَلَن تَسْتَطِيعَ لَهُۥ طَلَبًۭا","translation":"or its water sinks deep into the ground, so that thou wilt never be able to find it again!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2181.mp3","surahId":18,"words":[{"id":42027,"position":1,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/018_041_001.mp3","charTypeName":"word"},{"id":42028,"position":2,"arabic":"يُصْبِحَ","translation":"হয়ে যাবে","audioUrl":"wbw/018_041_002.mp3","charTypeName":"word"},{"id":42029,"position":3,"arabic":"مَآؤُهَا","translation":"তার পানি","audioUrl":"wbw/018_041_003.mp3","charTypeName":"word"},{"id":42030,"position":4,"arabic":"غَوْرًۭا","translation":"শুষ্ক","audioUrl":"wbw/018_041_004.mp3","charTypeName":"word"},{"id":42031,"position":5,"arabic":"فَلَن","translation":"অতঃপর কখনও না","audioUrl":"wbw/018_041_005.mp3","charTypeName":"word"},{"id":42032,"position":6,"arabic":"تَسْتَطِيعَ","translation":"তুমি সক্ষম হবে","audioUrl":"wbw/018_041_006.mp3","charTypeName":"word"},{"id":42033,"position":7,"arabic":"لَهُۥ","translation":"জন্যে তার\"","audioUrl":"wbw/018_041_007.mp3","charTypeName":"word"},{"id":42034,"position":8,"arabic":"طَلَبًۭا","translation":"খুঁজে বের করতে\"","audioUrl":"wbw/018_041_008.mp3","charTypeName":"word"},{"id":42035,"position":9,"arabic":"٤١","translation":"(৪১)","audioUrl":null,"charTypeName":"end"}]},{"number":42,"arabic":"وَأُحِيطَ بِثَمَرِهِۦ فَأَصْبَحَ يُقَلِّبُ كَفَّيْهِ عَلَىٰ مَآ أَنفَقَ فِيهَا وَهِىَ خَاوِيَةٌ عَلَىٰ عُرُوشِهَا وَيَقُولُ يَٰلَيْتَنِى لَمْ أُشْرِكْ بِرَبِّىٓ أَحَدًۭا","translation":"And [thus it happened:] his fruitful gardens were encompassed [by ruin], and there he was, wringing his hands over all that he had spent on that which now lay waste, with its trellises caved in; and he could but say, \"Oh, would that I had not attributed divine powers to any but my Sustainer!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2182.mp3","surahId":18,"words":[{"id":42762,"position":1,"arabic":"وَأُحِيطَ","translation":"এবং (বিপর্যয়ে) পরিবেষ্টিত হলো","audioUrl":"wbw/018_042_001.mp3","charTypeName":"word"},{"id":42763,"position":2,"arabic":"بِثَمَرِهِۦ","translation":"সহ তার ফল","audioUrl":"wbw/018_042_002.mp3","charTypeName":"word"},{"id":42764,"position":3,"arabic":"فَأَصْبَ