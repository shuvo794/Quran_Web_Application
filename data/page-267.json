{"id":267,"ayahs":[{"number":91,"arabic":"ٱلَّذِينَ جَعَلُوا۟ ٱلْقُرْءَانَ عِضِينَ","translation":"[and] who [now] declare this Qur'an to be [a tissue of] falsehoods!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1893.mp3","surahId":15,"words":[{"id":68582,"position":1,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/015_091_001.mp3","charTypeName":"word"},{"id":68583,"position":2,"arabic":"جَعَلُوا۟","translation":"করেছে","audioUrl":"wbw/015_091_002.mp3","charTypeName":"word"},{"id":68584,"position":3,"arabic":"ٱلْقُرْءَانَ","translation":"কুরআনকে","audioUrl":"wbw/015_091_003.mp3","charTypeName":"word"},{"id":68585,"position":4,"arabic":"عِضِينَ","translation":"টুকরো টুকরো","audioUrl":"wbw/015_091_004.mp3","charTypeName":"word"},{"id":68586,"position":5,"arabic":"٩١","translation":"(৯১)","audioUrl":null,"charTypeName":"end"}]},{"number":92,"arabic":"فَوَرَبِّكَ لَنَسْـَٔلَنَّهُمْ أَجْمَعِينَ","translation":"But, by thy Sustainer! [On the Day of Judgment] We shall indeed call them to account, one and all,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1894.mp3","surahId":15,"words":[{"id":68618,"position":1,"arabic":"فَوَرَبِّكَ","translation":"সুতরাং তোমার রবের শপথ","audioUrl":"wbw/015_092_001.mp3","charTypeName":"word"},{"id":68619,"position":2,"arabic":"لَنَسْـَٔلَنَّهُمْ","translation":"অবশ্যই আমরা জিজ্ঞাসা করবো তাদের","audioUrl":"wbw/015_092_002.mp3","charTypeName":"word"},{"id":68620,"position":3,"arabic":"أَجْمَعِينَ","translation":"সকলকে","audioUrl":"wbw/015_092_003.mp3","charTypeName":"word"},{"id":68621,"position":4,"arabic":"٩٢","translation":"(৯২)","audioUrl":null,"charTypeName":"end"}]},{"number":93,"arabic":"عَمَّا كَانُوا۟ يَعْمَلُونَ","translation":"for whatever they have done!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1895.mp3","surahId":15,"words":[{"id":69141,"position":1,"arabic":"عَمَّا","translation":"যা থেকে","audioUrl":"wbw/015_093_001.mp3","charTypeName":"word"},{"id":69142,"position":2,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/015_093_002.mp3","charTypeName":"word"},{"id":69143,"position":3,"arabic":"يَعْمَلُونَ","translation":"তারা  কাজ করতো","audioUrl":"wbw/015_093_003.mp3","charTypeName":"word"},{"id":69144,"position":4,"arabic":"٩٣","translation":"(৯৩)","audioUrl":null,"charTypeName":"end"}]},{"number":94,"arabic":"فَٱصْدَعْ بِمَا تُؤْمَرُ وَأَعْرِضْ عَنِ ٱلْمُشْرِكِينَ","translation":"Hence, proclaim openly all that thou hast been bidden [to say], and leave alone all those who ascribe divinity to aught beside God:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1896.mp3","surahId":15,"words":[{"id":69653,"position":1,"arabic":"فَٱصْدَعْ","translation":"সুতরাং প্রকাশ্যে প্রচার করো","audioUrl":"wbw/015_094_001.mp3","charTypeName":"word"},{"id":69654,"position":2,"arabic":"بِمَا","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/015_094_002.mp3","charTypeName":"word"},{"id":69655,"position":3,"arabic":"تُؤْمَرُ","translation":"তোমাকে আদেশ করা হয়েছে","audioUrl":"wbw/015_094_003.mp3","charTypeName":"word"},{"id":69656,"position":4,"arabic":"وَأَعْرِضْ","translation":"ও উপেক্ষা করো","audioUrl":"wbw/015_094_004.mp3","charTypeName":"word"},{"id":69657,"position":5,"arabic":"عَنِ","translation":"থেকে","audioUrl":"wbw/015_094_005.mp3","charTypeName":"word"},{"id":69658,"position":6,"arabic":"ٱلْمُشْرِكِينَ","translation":"মুশরিকদের","audioUrl":"wbw/015_094_006.mp3","charTypeName":"word"},{"id":69659,"position":7,"arabic":"٩٤","translation":"(৯৪)","audioUrl":null,"charTypeName":"end"}]},{"number":95,"arabic":"إِنَّا كَفَيْنَٰكَ ٱلْمُسْتَهْزِءِينَ","translation":"verily, We shall suffice thee against all who [now] deride [this message - all]","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1897.mp3","surahId":15,"words":[{"id":69693,"position":1,"arabic":"إِنَّا","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/015_095_001.mp3","charTypeName":"word"},{"id":69694,"position":2,"arabic":"كَفَيْنَـٰكَ",