/cdn.islamic.network/quran/audio/128/ar.alafasy/1899.mp3","surahId":15,"words":[{"id":70391,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/015_097_001.mp3","charTypeName":"word"},{"id":70392,"position":2,"arabic":"نَعْلَمُ","translation":"আমরা জানি","audioUrl":"wbw/015_097_002.mp3","charTypeName":"word"},{"id":70393,"position":3,"arabic":"أَنَّكَ","translation":"তুমি যে","audioUrl":"wbw/015_097_003.mp3","charTypeName":"word"},{"id":70394,"position":4,"arabic":"يَضِيقُ","translation":"সংকুচিত হয়","audioUrl":"wbw/015_097_004.mp3","charTypeName":"word"},{"id":70395,"position":5,"arabic":"صَدْرُكَ","translation":"তোমার অন্তর","audioUrl":"wbw/015_097_005.mp3","charTypeName":"word"},{"id":70396,"position":6,"arabic":"بِمَا","translation":"এ কারণে যা","audioUrl":"wbw/015_097_006.mp3","charTypeName":"word"},{"id":70397,"position":7,"arabic":"يَقُولُونَ","translation":"তারা বলে","audioUrl":"wbw/015_097_007.mp3","charTypeName":"word"},{"id":70398,"position":8,"arabic":"٩٧","translation":"(৯৭)","audioUrl":null,"charTypeName":"end"}]},{"number":98,"arabic":"فَسَبِّحْ بِحَمْدِ رَبِّكَ وَكُن مِّنَ ٱلسَّٰجِدِينَ","translation":"but extol thou thy Sustainer's limitless glory and praise Him, and be of those who prostrate themselves [before Him] in adoration,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1900.mp3","surahId":15,"words":[{"id":70814,"position":1,"arabic":"فَسَبِّحْ","translation":"সুতরাং পবিত্রতা ঘোষণা করো","audioUrl":"wbw/015_098_001.mp3","charTypeName":"word"},{"id":70815,"position":2,"arabic":"بِحَمْدِ","translation":"সহ প্রশংসা","audioUrl":"wbw/015_098_002.mp3","charTypeName":"word"},{"id":70816,"position":3,"arabic":"رَبِّكَ","translation":"তোমার রবের","audioUrl":"wbw/015_098_003.mp3","charTypeName":"word"},{"id":70817,"position":4,"arabic":"وَكُن","translation":"এবং হও","audioUrl":"wbw/015_098_004.mp3","charTypeName":"word"},{"id":70818,"position":5,"arabic":"مِّنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/015_098_005.mp3","charTypeName":"word"},{"id":70819,"position":6,"arabic":"ٱلسَّـٰجِدِينَ","translation":"সিজদাকারীদের","audioUrl":"wbw/015_098_006.mp3","charTypeName":"word"},{"id":70820,"position":7,"arabic":"٩٨","translation":"(৯৮)","audioUrl":null,"charTypeName":"end"}]},{"number":99,"arabic":"وَٱعْبُدْ رَبَّكَ حَتَّىٰ يَأْتِيَكَ ٱلْيَقِينُ","translation":"and worship thy Sustainer till death comes to thee.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1901.mp3","surahId":15,"words":[{"id":70959,"position":1,"arabic":"وَٱعْبُدْ","translation":"ও ইবাদত করো","audioUrl":"wbw/015_099_001.mp3","charTypeName":"word"},{"id":70960,"position":2,"arabic":"رَبَّكَ","translation":"তোমার রবের","audioUrl":"wbw/015_099_002.mp3","charTypeName":"word"},{"id":70961,"position":3,"arabic":"حَتَّىٰ","translation":"যতক্ষণ না","audioUrl":"wbw/015_099_003.mp3","charTypeName":"word"},{"id":70962,"position":4,"arabic":"يَأْتِيَكَ","translation":"তোমার কাছে আসে","audioUrl":"wbw/015_099_004.mp3","charTypeName":"word"},{"id":70963,"position":5,"arabic":"ٱلْيَقِينُ","translation":"মৃত্যু","audioUrl":"wbw/015_099_005.mp3","charTypeName":"word"},{"id":70964,"position":6,"arabic":"٩٩","translation":"(৯৯)","audioUrl":null,"charTypeName":"end"}]},{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ أَتَىٰٓ أَمْرُ ٱللَّهِ فَلَا تَسْتَعْجِلُوهُ ۚ سُبْحَٰنَهُۥ وَتَعَٰلَىٰ عَمَّا يُشْرِكُونَ","translation":"GOD'S JUDGMENT is [bound to] come: do not, therefore, call for its speedy advent! Limitless is He in His glory and sublimely exalted above anything to which men may ascribe a share in His divinity!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1902.mp3","surahId":16,"words":[{"id":892,"position":1,"arabic":"أَتَىٰٓ","translation":"এসেছে","audioUrl":"wbw/016_001_001.mp3","charTypeName":"word"},{"id":893,"position":2,"arabic":"أَمْرُ","translation":"আদেশ","audioUrl":"wbw/016_001_002.mp3","charTypeName":"word"},{"id":894,"position":3,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌র","audioUrl":"wbw/016_001_003.mp3","charTypeName":"word"},{"id":895,"position":4,"arabic":"فَلَا","translation":"সুতরাং না","audioUrl":"wbw/016_001_004.mp3","charTypeName":"word"},{"id":896,"position":5,"arabic":"تَسْتَعْجِلُوهُ ۚ","translation":"তা তোমরা তাড়াহুড়া করতে চেয়ো","audioUrl":"wbw/016_001_005.mp3","charTypeName":"word"},{"id":898,"position":6,"arabic":"سُبْحَـٰنَهُۥ","translation":"তিনি পবিত্র","audioUrl":"wbw/016_001_007.mp3","charTypeName":"word"},{"id":899,"position":7,"arabic":"وَتَعَـٰلَىٰ","translation":"ও বহু ঊর্দ্ধে","audioUrl":"wbw/016_001_008.mp3","charTypeName":"word"},{"id":900,"position":8,"arabic":"عَمَّا","translation":"তা থেকে যা","audioUrl":"wbw/016_001_009.mp3","charTypeName":"word"},{"id":901,"position":9,"arabic":"يُشْرِكُونَ","translation":"তারা শরীক করে","audioUrl":"wbw/016_001_010.mp3","charTypeName":"word"},{"id":902,"position":10,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"يُنَزِّلُ ٱلْمَلَٰٓئِكَةَ بِٱلرُّوحِ مِنْ أَمْرِهِۦ عَلَىٰ مَن يَشَآءُ مِنْ عِبَادِهِۦٓ أَنْ أَنذِرُوٓا۟ أَنَّهُۥ لَآ إِلَٰهَ إِلَّآ أَنَا۠ فَٱتَّقُونِ","translation":"He causes the angels to descend with this divine inspiration, [bestowed] at His behest upon whomever He wills of His servants: \"Warn [all human beings] that there is no deity save Me: be, therefore, conscious of Me!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1903.mp3","surahId":16,"words":[{"id":1994,"position":1,"arabic":"يُنَزِّلُ","translation":"অবতীর্ণ করেন","audioUrl":"wbw/016_002_001.mp3","charTypeName":"word"},{"id":1995,"position":2,"arabic":"ٱلْمَلَـٰٓئِكَةَ","translation":"ফেরেশতাদেরকে","audioUrl":"wbw/016_002_002.mp3","charTypeName":"word"},{"id":1996,"position":3,"arabic":"بِٱلرُّوحِ","translation":"দিয়ে ওহী","audioUrl":"wbw/016_002_003.mp3","charTypeName":"word"},{"id":1997,"position":4,"arabic":"مِنْ","translation":"থেকে","audioUrl":"wbw/016_002_004.mp3","charTypeName":"word"},{"id":1998,"position":5,"arabic":"أَمْرِهِۦ","translation":"তাঁর নির্দেশের","audioUrl":"wbw/016_002_005.mp3","charTypeName":"word"},{"id":1999,"position":6,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/016_002_006.mp3","charTypeName":"word"},{"id":2000,"position":7,"arabic":"مَن","translation":"(তার) যাকে","audioUrl":"wbw/016_002_007.mp3","charTypeName":"word"},{"id":2001,"position":8,"arabic":"يَشَآءُ","translation":"ইচ্ছে করেন","audioUrl":"wbw/016_002_008.mp3","charTypeName":"word"},{"id":2002,"position":9,"arabic":"مِنْ","translation":"মধ্য হ'তে","audioUrl":"wbw/016_002_009.mp3","charTypeName":"word"},{"id":2003,"position":10,"arabic":"عِبَادِهِۦٓ","translation":"তাঁর দাসদের","audioUrl":"wbw/016_002_010.mp3","charTypeName":"word"},{"id":2004,"position":11,"arabic":"أَنْ","translation":"যে","audioUrl":"wbw/016_002_011.mp3","charTypeName":"word"},{"id":2005,"position":12,"arabic":"أَنذِرُوٓا۟","translation":"\"তোমরা সতর্ক করো","audioUrl":"wbw/016_002_012.mp3","charTypeName":"word"},{"id":2006,"position":13,"arabic":"أَنَّهُۥ","translation":"এই মর্মে যে","audioUrl":"wbw/016_002_013.mp3","charTypeName":"word"},{"id":2007,"position":14,"arabic":"لَآ","translation":"নেই","audioUrl":"wbw/016_002_014.mp3","charTypeName":"word"},{"id":2008,"position":15,"arabic":"إِلَـٰهَ","translation":"কোন ইলাহ","audioUrl":"wbw/016_002_015.mp3","charTypeName":"word"},{"id":2009,"position":16,"arabic":"إِلَّآ","translation":"ছাড়া","audioUrl":"wbw/016_002_016.mp3","charTypeName":"word"},{"id":2010,"position":17,"arabic":"أَنَا۠","translation":"আমি","audioUrl":"wbw/016_002_017.mp3","charTypeName":"word"},{"id":2011,"position":18,"arabic":"فَٱتَّقُونِ","translation":"সুতরাং তোমরা আমাকে ভয় করো\"","audioUrl":"wbw/016_002_018.mp3","charTypeName":"word"},{"id":2012,"position":19,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"خَلَقَ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضَ بِٱلْحَقِّ ۚ تَعَٰلَىٰ عَمَّا يُشْرِكُونَ","translation":"He has created the heavens and the earth in accordance with [an inner] truth; sublimely exalted is He above anything to which men may ascribe a share in His divinity!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1904.mp3","surahId":16,"words":[{"id":3192,"position":1,"arabic":"خَلَقَ","translation":"তিনি সৃষ্টি করেছেন","audioUrl":"wbw/016_003_001.mp3","charTypeName":"word"},{"id":3193,"position":2,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশমন্ডলী","audioUrl":"wbw/016_003_002.mp3","charTypeName":"word"},{"id":3194,"position":3,"arabic":"وَٱلْأَرْضَ","translation":"ও পৃথিবী","audioUrl":"wbw/016_003_003.mp3","charTypeName":"word"},{"id":3195,"position":4,"arabic":"بِٱلْحَقِّ ۚ","translation":"দিয়ে মহাসত্য","audioUrl":"wbw/016_003_004.mp3","charTypeName":"word"},{"id":3197,"position":5,"arabic":"تَعَـٰلَىٰ","translation":"বহু ঊর্দ্ধে","audioUrl":"wbw/016_003_006.mp3","charTypeName":"word"},{"id":3198,"position":6,"arabic":"عَمَّا","translation":"তা থেকে যা","audioUrl":"wbw/016_003_007.mp3","charTypeName":"word"},{"id":3199,"position":7,"arabic":"يُشْرِكُونَ","translation":"তারা শরীক করে","audioUrl":"wbw/016_003_008.mp3","charTypeName":"word"},{"id":3200,"position":8,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"خَلَقَ ٱلْإِنسَٰنَ مِن نُّطْفَةٍۢ فَإِذَا هُوَ خَصِيمٌۭ مُّبِينٌۭ","translation":"He creates man out of a [mere] drop of sperm: and lo! this same being shows himself endowed with the power to think and to argue!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1905.mp3","surahId":16,"words":[{"id":4166,"position":1,"arabic":"خَلَقَ","translation":"তিনি সৃষ্টি করেছেন","audioUrl":"wbw/016_004_001.mp3","charTypeName":"word"},{"id":4167,"position":2,"arabic":"ٱلْإِنسَـٰنَ","translation":"মানুষকে","audioUrl":"wbw/016_004_002.mp3","charTypeName":"word"},{"id":4168,"position":3,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/016_004_003.mp3","charTypeName":"word"},{"id":4169,"position":4,"arabic":"نُّطْفَةٍۢ","tra