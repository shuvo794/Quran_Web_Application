"audioUrl":"wbw/008_028_003.mp3","charTypeName":"word"},{"id":30741,"position":4,"arabic":"وَأَوْلَـٰدُكُمْ","translation":"ও সন্তানেরা তোমাদের","audioUrl":"wbw/008_028_004.mp3","charTypeName":"word"},{"id":30742,"position":5,"arabic":"فِتْنَةٌۭ","translation":"পরীক্ষা (মাত্র)","audioUrl":"wbw/008_028_005.mp3","charTypeName":"word"},{"id":30743,"position":6,"arabic":"وَأَنَّ","translation":"এবং বাস্তবিকই","audioUrl":"wbw/008_028_006.mp3","charTypeName":"word"},{"id":30744,"position":7,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/008_028_007.mp3","charTypeName":"word"},{"id":30745,"position":8,"arabic":"عِندَهُۥٓ","translation":"কাছে তাঁরই (আছে)","audioUrl":"wbw/008_028_008.mp3","charTypeName":"word"},{"id":30746,"position":9,"arabic":"أَجْرٌ","translation":"পুরস্কার","audioUrl":"wbw/008_028_009.mp3","charTypeName":"word"},{"id":30747,"position":10,"arabic":"عَظِيمٌۭ","translation":"বিরাট","audioUrl":"wbw/008_028_010.mp3","charTypeName":"word"},{"id":30748,"position":11,"arabic":"٢٨","translation":"(২৮)","audioUrl":null,"charTypeName":"end"}]},{"number":29,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوٓا۟ إِن تَتَّقُوا۟ ٱللَّهَ يَجْعَل لَّكُمْ فُرْقَانًۭا وَيُكَفِّرْ عَنكُمْ سَيِّـَٔاتِكُمْ وَيَغْفِرْ لَكُمْ ۗ وَٱللَّهُ ذُو ٱلْفَضْلِ ٱلْعَظِيمِ","translation":"O you who have attained to faith! If you remain conscious of God. He will endow you with a standard by which to discern the true from the false, and will efface your bad deeds, and will forgive you your sins: for God is limitless in His great bounty.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1189.mp3","surahId":8,"words":[{"id":31810,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/008_029_001.mp3","charTypeName":"word"},{"id":31811,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/008_029_002.mp3","charTypeName":"word"},{"id":31812,"position":3,"arabic":"ءَامَنُوٓا۟","translation":"ঈমান এনেছো","audioUrl":"wbw/008_029_003.mp3","charTypeName":"word"},{"id":31813,"position":4,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/008_029_004.mp3","charTypeName":"word"},{"id":31814,"position":5,"arabic":"تَتَّقُوا۟","translation":"তোমরা ভয় করো","audioUrl":"wbw/008_029_005.mp3","charTypeName":"word"},{"id":31815,"position":6,"arabic":"ٱللَّهَ","translation":"আল্লাহকে","audioUrl":"wbw/008_029_006.mp3","charTypeName":"word"},{"id":31816,"position":7,"arabic":"يَجْعَل","translation":"তিনি দিবেন","audioUrl":"wbw/008_029_007.mp3","charTypeName":"word"},{"id":31817,"position":8,"arabic":"لَّكُمْ","translation":"জন্যে তোমাদের","audioUrl":"wbw/008_029_008.mp3","charTypeName":"word"},{"id":31818,"position":9,"arabic":"فُرْقَانًۭا","translation":"ন্যায়-অন্যায় পার্থক্যের কষ্টিপাথর","audioUrl":"wbw/008_029_009.mp3","charTypeName":"word"},{"id":31819,"position":10,"arabic":"وَيُكَفِّرْ","translation":"এবং মোচন করবেন","audioUrl":"wbw/008_029_010.mp3","charTypeName":"word"},{"id":31820,"position":11,"arabic":"عَنكُمْ","translation":"হতে তোমাদের","audioUrl":"wbw/008_029_011.mp3","charTypeName":"word"},{"id":31821,"position":12,"arabic":"سَيِّـَٔاتِكُمْ","translation":"পাপগুলো তোমাদের","audioUrl":"wbw/008_029_012.mp3","charTypeName":"word"},{"id":31822,"position":13,"arabic":"وَيَغْفِرْ","translation":"এবং ক্ষমা করবেন","audioUrl":"wbw/008_029_013.mp3","charTypeName":"word"},{"id":31823,"position":14,"arabic":"لَكُمْ ۗ","translation":"প্রতি তোমাদের","audioUrl":"wbw/008_029_014.mp3","charTypeName":"word"},{"id":31825,"position":15,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/008_029_016.mp3","charTypeName":"word"},{"id":31826,"position":16,"arabic":"ذُو","translation":"সম্পন্ন","audioUrl":"wbw/008_029_017.mp3","charTypeName":"word"},{"id":31827,"position":17,"arabic":"ٱلْفَضْلِ","translation":"অনুগ্রহ","audioUrl":"wbw/008_029_018.mp3","charTypeName":"word"},{"id":31828,"position":18,"arabic":"ٱلْعَظِيمِ","translation":"মহান","audioUrl":"wbw/008_029_019.mp3","charTypeName":"word"},{"id":31829,"position":19,"arabic":"٢٩","translation":"(২৯)","audioUrl":null,"charTypeName":"end"}]},{"number":30,"arabic":"وَإِذْ يَمْكُرُ بِكَ ٱلَّذِينَ كَفَرُوا۟ لِيُثْبِتُوكَ أَوْ يَقْتُلُوكَ أَوْ يُخْرِجُوكَ ۚ وَيَمْكُرُونَ وَيَمْكُرُ ٱللَّهُ ۖ وَٱللَّهُ خَيْرُ ٱلْمَٰكِرِينَ","translation":"AND [remember, O Prophet,] how those who were bent on denying the truth were scheming against thee, in order to restrain thee [from preaching], or to slay thee, or to drive thee away: thus have they [always] schemed: but God brought their scheming to nought-for God is above all schemers.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1190.mp3","surahId":8,"words":[{"id":32662,"position":1,"arabic":"وَإِذْ","translation":"এবং (স্বরণ করো) যখন","audioUrl":"wbw/008_030_001.mp3","charTypeName":"word"},{"id":32663,"position":2,"arabic":"يَمْكُرُ","translation":"ষড়যন্ত্র করেছিলো","audioUrl":"wbw/008_030_002.mp3","charTypeName":"word"},{"id":32664,"position":3,"arabic":"بِكَ","translation":"বিরুদ্ধে তোমার","audioUrl":"wbw/008_030_003.mp3","charTypeName":"word"},{"id":32665,"position":4,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/008_030_004.mp3","charTypeName":"word"},{"id":32666,"position":5,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/008_030_005.mp3","charTypeName":"word"},{"id":32667,"position":6,"arabic":"لِيُثْبِتُوكَ","translation":"জন্যে তোমাকে তারা বন্দি করার","audioUrl":"wbw/008_030_006.mp3","charTypeName":"word"},{"id":32668,"position":7,"arabic":"أَوْ","translation":"বা","audioUrl":"wbw/008_030_007.mp3","charTypeName":"word"},{"id":32669,"position":8,"arabic":"يَقْتُلُوكَ","translation":"তোমাকে তারা হত্যা করবে","audioUrl":"wbw/008_030_008.mp3","charTypeName":"word"},{"id":32670,"position":9,"arabic":"أَوْ","translation":"বা","audioUrl":"wbw/008_030_009.mp3","charTypeName":"word"},{"id":32671,"position":10,"arabic":"يُخْرِجُوكَ ۚ","translation":"তোমাকে তারা নির্বাসিত করবে","audioUrl":"wbw/008_030_010.mp3","charTypeName":"word"},{"id":3267