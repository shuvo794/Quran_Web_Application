{"id":180,"ayahs":[{"number":26,"arabic":"وَٱذْكُرُوٓا۟ إِذْ أَنتُمْ قَلِيلٌۭ مُّسْتَضْعَفُونَ فِى ٱلْأَرْضِ تَخَافُونَ أَن يَتَخَطَّفَكُمُ ٱلنَّاسُ فَـَٔاوَىٰكُمْ وَأَيَّدَكُم بِنَصْرِهِۦ وَرَزَقَكُم مِّنَ ٱلطَّيِّبَٰتِ لَعَلَّكُمْ تَشْكُرُونَ","translation":"And remember the time when you were few [and] helpless on earth, fearful lest people do away with you - whereupon He sheltered you, and strengthened you with His succour, and provided for you sustenance out of the good things of life, so that you might have cause to be grateful.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1186.mp3","surahId":8,"words":[{"id":28848,"position":1,"arabic":"وَٱذْكُرُوٓا۟","translation":"এবং তোমরা স্বরণ করো","audioUrl":"wbw/008_026_001.mp3","charTypeName":"word"},{"id":28849,"position":2,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/008_026_002.mp3","charTypeName":"word"},{"id":28850,"position":3,"arabic":"أَنتُمْ","translation":"তোমরা (ছিলে)","audioUrl":"wbw/008_026_003.mp3","charTypeName":"word"},{"id":28851,"position":4,"arabic":"قَلِيلٌۭ","translation":"স্বল্প (সংখ্যক)","audioUrl":"wbw/008_026_004.mp3","charTypeName":"word"},{"id":28852,"position":5,"arabic":"مُّسْتَضْعَفُونَ","translation":"তোমাদেরকে দুর্বল মনে করে হতো","audioUrl":"wbw/008_026_005.mp3","charTypeName":"word"},{"id":28853,"position":6,"arabic":"فِى","translation":"উপর","audioUrl":"wbw/008_026_006.mp3","charTypeName":"word"},{"id":28854,"position":7,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/008_026_007.mp3","charTypeName":"word"},{"id":28855,"position":8,"arabic":"تَخَافُونَ","translation":"তোমরা ভয় করতে","audioUrl":"wbw/008_026_008.mp3","charTypeName":"word"},{"id":28856,"position":9,"arabic":"أَن","translation":"যে","audioUrl":"wbw/008_026_009.mp3","charTypeName":"word"},{"id":28857,"position":10,"arabic":"يَتَخَطَّفَكُمُ","translation":"নিশ্চিহ্ন করে ফেলবে তোমাদেরকে","audioUrl":"wbw/008_026_010.mp3","charTypeName":"word"},{"id":28858,"position":11,"arabic":"ٱلنَّاسُ","translation":"মানুষেরা","audioUrl":"wbw/008_026_011.mp3","charTypeName":"word"},{"id":28859,"position":12,"arabic":"فَـَٔاوَىٰكُمْ","translation":"তখন তিনি আশ্রয় দেন তোমাদেরকে","audioUrl":"wbw/008_026_012.mp3","charTypeName":"word"},{"id":28860,"position":13,"arabic":"وَأَيَّدَكُم","translation":"ও শক্তিশালী করেন তোমাদের","audioUrl":"wbw/008_026_013.mp3","charTypeName":"word"},{"id":28861,"position":14,"arabic":"بِنَصْرِهِۦ","translation":"দিয়ে সাহায্য তাঁর","audioUrl":"wbw/008_026_014.mp3","charTypeName":"word"},{"id":28862,"position":15,"arabic":"وَرَزَقَكُم","translation":"ও জীবিকা দেন তোমাদেরকে","audioUrl":"wbw/008_026_015.mp3","charTypeName":"word"},{"id":28863,"position":16,"arabic":"مِّنَ","translation":"হতে","audioUrl":"wbw/008_026_016.mp3","charTypeName":"word"},{"id":28864,"position":17,"arabic":"ٱلطَّيِّبَـٰتِ","translation":"পবিত্র জিনিসগুলো","audioUrl":"wbw/008_026_017.mp3","charTypeName":"word"},{"id":28865,"position":18,"arabic":"لَعَلَّكُمْ","translation":"যাতে তোমরা","audioUrl":"wbw/008_026_018.mp3","charTypeName":"word"},{"id":28866,"position":19,"arabic":"تَشْكُرُونَ","translation":"কৃতজ্ঞতা প্রকাশ করো","audioUrl":"wbw/008_026_019.mp3","charTypeName":"word"},{"id":28867,"position":20,"arabic":"٢٦","translation":"(২৬)","audioUrl":null,"charTypeName":"end"}]},{"number":27,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ لَا تَخُونُوا۟ ٱللَّهَ وَٱلرَّسُولَ وَتَخُونُوٓا۟ أَمَٰنَٰتِكُمْ وَأَنتُمْ تَعْلَمُونَ","translation":"[Hence,] O you who have attained to faith, do not be false to God and the Apostle, and do not knowingly be false to the trust that has been reposed in you;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1187.mp3","surahId":8,"words":[{"id":29652,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/008_027_001.mp3","charTypeName":"word"},{"id":29653,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/008_027_002.mp3","charTypeName":"word"},{"id":29654,"position":3,"arabic":"ءَ