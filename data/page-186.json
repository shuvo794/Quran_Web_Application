{"id":186,"ayahs":[{"number":70,"arabic":"يَٰٓأَيُّهَا ٱلنَّبِىُّ قُل لِّمَن فِىٓ أَيْدِيكُم مِّنَ ٱلْأَسْرَىٰٓ إِن يَعْلَمِ ٱللَّهُ فِى قُلُوبِكُمْ خَيْرًۭا يُؤْتِكُمْ خَيْرًۭا مِّمَّآ أُخِذَ مِنكُمْ وَيَغْفِرْ لَكُمْ ۗ وَٱللَّهُ غَفُورٌۭ رَّحِيمٌۭ","translation":"[Hence,] O Prophet, say unto the captives who are in your hands: \"If God finds any good in your hearts, He will give you something better than all that has been taken from you, and will forgive you your sins: for God is much-forgiving, a dispenser of grace.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1230.mp3","surahId":8,"words":[{"id":59697,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/008_070_001.mp3","charTypeName":"word"},{"id":59698,"position":2,"arabic":"ٱلنَّبِىُّ","translation":"নাবী","audioUrl":"wbw/008_070_002.mp3","charTypeName":"word"},{"id":59699,"position":3,"arabic":"قُل","translation":"বলো","audioUrl":"wbw/008_070_003.mp3","charTypeName":"word"},{"id":59700,"position":4,"arabic":"لِّمَن","translation":"উদ্দেশ্যে (তাদের) যারা","audioUrl":"wbw/008_070_004.mp3","charTypeName":"word"},{"id":59701,"position":5,"arabic":"فِىٓ","translation":"মধ্যে (আছে)","audioUrl":"wbw/008_070_005.mp3","charTypeName":"word"},{"id":59702,"position":6,"arabic":"أَيْدِيكُم","translation":"হাতে তোমাদের","audioUrl":"wbw/008_070_006.mp3","charTypeName":"word"},{"id":59703,"position":7,"arabic":"مِّنَ","translation":"মধ্য হতে","audioUrl":"wbw/008_070_007.mp3","charTypeName":"word"},{"id":59704,"position":8,"arabic":"ٱلْأَسْرَىٰٓ","translation":"বন্দিদের","audioUrl":"wbw/008_070_008.mp3","charTypeName":"word"},{"id":59705,"position":9,"arabic":"إِن","translation":"\"যদি","audioUrl":"wbw/008_070_009.mp3","charTypeName":"word"},{"id":59706,"position":10,"arabic":"يَعْلَمِ","translation":"জানেন (দেখেন)","audioUrl":"wbw/008_070_010.mp3","charTypeName":"word"},{"id":59707,"position":11,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/008_070_011.mp3","charTypeNam