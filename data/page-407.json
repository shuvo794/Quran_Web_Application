{"id":407,"ayahs":[{"number":25,"arabic":"وَمِنْ ءَايَٰتِهِۦٓ أَن تَقُومَ ٱلسَّمَآءُ وَٱلْأَرْضُ بِأَمْرِهِۦ ۚ ثُمَّ إِذَا دَعَاكُمْ دَعْوَةًۭ مِّنَ ٱلْأَرْضِ إِذَآ أَنتُمْ تَخْرُجُونَ","translation":"And among His wonders is this: the skies and the earth stand firm at His behest. [Remember all this: for] in the end, when He will call you forth from the earth with a single call - lo! you will [all] emerge [for judgment].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3434.mp3","surahId":30,"words":[{"id":28329,"position":1,"arabic":"وَمِنْ","translation":"এবং মধ্যে হ'তে","audioUrl":"wbw/030_025_001.mp3","charTypeName":"word"},{"id":28330,"position":2,"arabic":"ءَايَـٰتِهِۦٓ","translation":"নিদর্শনসমূহের তাঁর","audioUrl":"wbw/030_025_002.mp3","charTypeName":"word"},{"id":28331,"position":3,"arabic":"أَن","translation":"(এও) যে","audioUrl":"wbw/030_025_003.mp3","charTypeName":"word"},{"id":28332,"position":4,"arabic":"تَقُومَ","translation":"প্রতিষ্ঠিত  রয়েছে","audioUrl":"wbw/030_025_004.mp3","charTypeName":"word"},{"id":28333,"position":5,"arabic":"ٱلسَّمَآءُ","translation":"আকাশ","audioUrl":"wbw/030_025_005.mp3","charTypeName":"word"},{"id":28334,"position":6,"arabic":"وَٱلْأَرْضُ","translation":"ও পৃথিবী","audioUrl":"wbw/030_025_006.mp3","charTypeName":"word"},{"id":28335,"position":7,"arabic":"بِأَمْرِهِۦ ۚ","translation":"নির্দেশক্রমে তাঁরই","audioUrl":"wbw/030_025_007.mp3","charTypeName":"word"},{"id":28337,"position":8,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/030_025_009.mp3","charTypeName":"word"},{"id":28338,"position":9,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/030_025_010.mp3","charTypeName":"word"},{"id":28339,"position":10,"arabic":"دَعَاكُمْ","translation":"তিনি ডাক দিবেন তোমাদের","audioUrl":"wbw/030_025_011.mp3","charTypeName":"word"},{"id":28340,"position":11,"arabic":"دَعْوَةًۭ","translation":"একটি ডাক","audioUrl":"wbw/030_025_012.mp3","charTypeName":"word"},{"id":28341,"position":12,"arabic":"مِّنَ","translation":"হ'তে","audioUrl":"wbw/030_025_013.mp3","charTypeName":"word"},{"id":28342,"position":13,"arabic":"ٱلْأَرْضِ","translation":"জমিন","audioUrl":"wbw/030_025_014.mp3","charTypeName":"word"},{"id":28343,"position":14,"arabic":"إِذَآ","translation":"তখন","audioUrl":"wbw/030_025_015.mp3","charTypeName":"word"},{"id":28344,"position":15,"arabic":"أَنتُمْ","translation":"তোমরা","audioUrl":"wbw/030_025_016.mp3","charTypeName":"word"},{"id":28345,"position":16,"arabic":"تَخْرُجُونَ","translation":"বের হয়ে আসবে","audioUrl":"wbw/030_025_017.mp3","charTypeName":"word"},{"id":28346,"position":17,"arabic":"٢٥","translation":"(২৫)","audioUrl":null,"charTypeName":"end"}]},{"number":26,"arabic":"وَلَهُۥ مَن فِى ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ ۖ كُلٌّۭ لَّهُۥ قَٰنِتُونَ","translation":"For, unto Him belongs every being that is in the heavens and on earth; all things devoutly obey His will.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3435.mp3","surahId":30,"words":[{"id":29242,"position":1,"arabic":"وَلَهُۥ","translation":"এবং জন্যে তাঁরই","audioUrl":"wbw/030_026_001.mp3","charTypeName":"word"},{"id":29243,"position":2,"arabic":"مَن","translation":"যা কিছু","audioUrl":"wbw/030_026_002.mp3","charTypeName":"word"},{"id":29244,"position":3,"arabic":"فِى","translation":"মধ্যে (আছে)","audioUrl":"wbw/030_026_003.mp3","charTypeName":"word"},{"id":29245,"position":4,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশমন্ডলীর","audioUrl":"wbw/030_026_004.mp3","charTypeName":"word"},{"id":29246,"position":5,"arabic":"وَٱلْأَرْضِ ۖ","translation":"ও পৃথিবীর","audioUrl":"wbw/030_026_005.mp3","charTypeName":"word"},{"id":29248,"position":6,"arabic":"كُلٌّۭ","translation":"সবকিছু","audioUrl":"wbw/030_026_007.mp3","charTypeName":"word"},{"id":29249,"position":7,"arabic":"لَّهُۥ","translation":"প্রতি তাঁরই","audioUrl":"wbw/030_026_008.mp3","charTypeName":"word"},{"id":29250,"position":8,"arabic":"قَـٰنِتُونَ","translation":"অনুগত","audioUrl":"wbw/030_026_009.mp3","charTypeName":"word"},{"id":29251,"position":9,"arabic":"٢٦","translation":"(২৬)","audioUrl":null,"charTypeName":"end"}]},{"number":27,"arabic":"وَهُوَ ٱلَّذِى يَبْدَؤُا۟ ٱلْخَلْقَ ثُمَّ يُعِيدُهُۥ وَهُوَ أَهْوَنُ عَلَيْهِ ۚ وَلَهُ ٱلْمَثَلُ ٱلْأَعْلَىٰ فِى ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ ۚ وَهُوَ ٱلْعَزِيزُ ٱلْحَكِيمُ","translation":"And He it is who creates [all life] in the first instance, and then brings it forth anew: and most easy is this for Him, since His is the essence of all that is most sublime in the heavens and on earth, and He alone is almighty, truly wise.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3436.mp3","surahId":30,"words":[{"id":30162,"position":1,"arabic":"وَهُوَ","translation":"এবং তিনিই (আল্লাহ)","audioUrl":"wbw/030_027_001.mp3","charTypeName":"word"},{"id":30163,"position":2,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/030_027_002.mp3","charTypeName":"word"},{"id":30164,"position":3,"arabic":"يَبْدَؤُا۟","translation":"সূচনা করেন","audioUrl":"wbw/030_027_003.mp3","charTypeName":"word"},{"id":30165,"position":4,"arabic":"ٱلْخَلْقَ","translation":"সৃষ্টির","audioUrl":"wbw/030_027_004.mp3","charTypeName":"word"},{"id":30166,"position":5,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/030_027_005.mp3","charTypeName":"word"},{"id":30167,"position":6,"arabic":"يُعِيدُهُۥ","translation":"পুনরাবৃত্তি করবেন তার","audioUrl":"wbw/030_027_006.mp3","charTypeName":"word"},{"id":30168,"position":7,"arabic":"وَهُوَ","translation":"এবং তা","audioUrl":"wbw/030_027_007.mp3","charTypeName":"word"},{"id":30169,"position":8,"arabic":"أَهْوَنُ","translation":"সহজতর","audioUrl":"wbw/030_027_008.mp3","charTypeName":"word"},{"id":30170,"position":9,"arabic":"عَلَيْهِ ۚ","translation":"কাছে তাঁর","audioUrl":"wbw/030_027_009.mp3","charTypeName":"word"},{"id":30172,"position":10,"arabic":"وَلَهُ","translation":"এবং জন্যে তাঁরই","audioUrl":"wbw/030_027_011.mp3","charTypeName":"word"},{"id":30173,"position":11,"arabic":"ٱلْمَثَلُ","translation":"গুণাবলী (মর্যাদা)","audioUrl":"wbw/030_027_012.mp3","charTypeName":"word"},{"id":30174,"position":12,"arabic":"ٱلْأَعْلَىٰ","translation":"সর্বোত্তম","audioUrl":"wbw/030_027_013.mp3","charTypeName":"word"},{"id":30175,"position":13,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/030_027_014.mp3","charTypeName":"word"},{"id":30176,"position":14,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশসমূহের","audioUrl":"wbw/030_027_015.mp3","charTypeName":"word"},{"id":30177,"position":15,"arabic":"وَٱلْأَرْضِ ۚ","translation":"এবং পৃথিবীতে","audioUrl":"wbw/030_027_016.mp3","charTypeName":"word"},{"id":30179,"position":16,"arabic":"وَهُوَ","translation":"এবং তিনি","audioUrl":"wbw/030_027_018.mp3","charTypeName":"word"},{"id":30180,"position":17,"arabic":"ٱلْعَزِيزُ","translation":"পরাক্রমশালী","audioUrl":"wbw/030_027_019.mp3","charTypeName":"word"},{"id":30181,"position":18,"arabic":"ٱلْحَكِيمُ","translation":"প্রজ্ঞাময়","audioUrl":"wbw/030_027_020.mp3","charTypeName":"word"},{"id":30182,"position":19,"arabic":"٢٧","translation":"(২৭)","audioUrl":null,"charTypeName":"end"}]},{"number":28,"arabic":"ضَرَبَ لَكُم مَّثَلًۭا مِّنْ أَنفُسِكُمْ ۖ هَل لَّكُم مِّن مَّا مَلَكَتْ أَيْمَٰنُكُم مِّن شُرَكَآءَ فِى مَا رَزَقْنَٰكُمْ فَأَنتُمْ فِيهِ سَوَآءٌۭ تَخَافُونَهُمْ كَخِيفَتِكُمْ أَنفُسَكُمْ ۚ كَذَٰلِكَ نُفَصِّلُ ٱلْءَايَٰتِ لِقَوْمٍۢ يَعْقِلُونَ","translation":"He propounds unto you a parable drawn from your own life: Would you [agree to] have some of those whom your right hands possess as [full-fledged] partners in whatever We may have bestowed upon you as sustenance, so that you [and they] would have equal shares in it, and you would fear [to make use of it without consulting] them, just as you might fear [the more powerful of] your equals? Thus clearly do We spell out these messages unto people who use their reason.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3437.mp3","surahId":30,"words":[{"id":31218,"position":1,"arabic":"ضَرَبَ","translation":"পেশ করেন (আল্লাহ)","audioUrl":"wbw/030_028_001.mp3","charTypeName":"word"},{"id":31219,"position":2,"arabic":"لَكُم","translation":"জন্যে তোমাদের","audioUrl":"wbw/030_028_002.mp3","charTypeName":"word"},{"id":31220,"position":3,"arabic":"مَّثَلًۭا","translation":"একটি দৃষ্টান্ত","audioUrl":"wbw/030_028_003.mp3","charTypeName":"word"},{"id":31221,"position":4,"arabic":"مِّنْ","translation":"মধ্য হ'তে","audioUrl":"wbw/030_028_004.mp3","charTypeName":"word"},{"id":31222,"position":5,"arabic":"أَنفُسِكُمْ ۖ","translation":"নিজেদের তোমাদের","audioUrl":"wbw/030_028_005.mp3","charTypeName":"word"},{"id":31224,"position":6,"arabic":"هَل","translation":"(আছে) কি","audioUrl":"wbw/030_028_007.mp3","charTypeName":"word"},{"id":31225,"position":7,"arabic":"لَّكُم","translation":"জন্যে তোমাদের","audioUrl":"wbw/030_028_008.mp3","charTypeName":"word"},{"id":31226,"position":8,"arabic":"مِّن","translation":"মধ্য হ'তে","audioUrl":"wbw/030_028_009.mp3","charTypeName":"word"},{"id":31227,"position":9,"arabic":"مَّا","translation":"যাকে","audioUrl":"wbw/030_028_010.mp3","charTypeName":"word"},{"id":31228,"position":10,"arabic":"مَلَكَتْ","translation":"মালিক করেছে","audioUrl":"wbw/030_028_011.mp3","charTypeName":"word"},{"id":31229,"position":11,"arabic":"أَيْمَـٰنُكُم","translation":"ডানহাত তোমাদের (অর্থাৎ তোমাদের দাসদাসী)","audioUrl":"wbw/030_028_012.mp3","charTypeName":"word"},{"id":31230,"position":12,"arabic":"مِّن","translation":"কিছু (সংখ্যক)","audioUrl":"wbw/030_028_013.mp3","charTypeName":"word"},{"id":31231,"position":13,"arabic":"شُرَكَآءَ","translation":"অংশীদার","audioUrl":"wbw/030_028_014.mp3","charTypeName":"word"},{"id":31232,"position":14,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/030_028_015.mp3","charTypeName":"word"},{"id":31233,"position":15,"arabic":"مَا","translation":"(তার) যা","audioUrl":"wbw/030_028_016.mp3","charTypeName":"word"},{"id":31234,"position":16,"arabic":"رَزَقْنَـٰكُمْ","translation":"আমরা জীবিকা দিয়েছি তোমাদেরকে","audioUrl":"wbw/030_028_017.mp3","charTypeName":"word"},{"id":31235,"position":17,"arabic":"فَأَنتُمْ","translation":"অতঃপর তোমরা","audioUrl":"wbw/030_028_018.mp3","charTypeName":"word"},{"id":31236,"position":18,"arabic":"فِيهِ","translation":"মধ্যে তার","audioUrl":"wbw/030_028_019.mp3","charTypeName":"word"},{"id":31237,"position":19,"arabic":"سَوَآءٌۭ","translation":"সমান (অংশীদারিত্বে)","audioUrl":"wbw/030_028_020.mp3","charTypeName":"word"},{"id":31238,"position":20,"arabic":"تَخَافُونَهُمْ","translation":"তোমরা ভয় করবে তাদেরকে (কি?)","audioUrl":"wbw/030_028_021.mp3","charTypeName":"word"},{"id":31239,"position":21,"arabic":"كَخِيفَتِكُمْ","translation":"যেমন ভয় তোমাদের","audioUrl":"wbw/030_028_022.mp3","charTypeName":"word"},{"id":31240,"position":22,"arabic":"أَنفُسَكُمْ ۚ","translation":"নিজেদের তোমাদের (সমান লোকদের ক্ষেত্রে)","audioUrl":"wbw/030_028_023.mp3","charTypeName":"word"},{"id":31242,"position":23,"arabic":"كَذَٰلِكَ","translation":"এরূপে","audioUrl":"wbw/030_028_025.mp3","charTypeName":"word"},{"id":31243,"position":24,"arabic":"نُفَصِّلُ","translation":"আমরা বর্ণনা করি বিশদভাবে","audioUrl":"wbw/030_028_026.mp3","charTypeName":"word"},{"id":31244,"position":25,"arabic":"ٱلْـَٔايَـٰتِ","translation":"নিদর্শনাবলী","audioUrl":"wbw/030_028_027.mp3","charTypeName":"word"},{"id":31245,"position":26,"arabic":"لِقَوْمٍۢ","translation":"জন্যে সম্প্রদায়ের","audioUrl":"wbw/030_028_028.mp3","charTypeName":"word"},{"id":31246,"position":27,"arabic":"يَعْقِلُونَ","translation":"(যারা) বুদ্ধি কাজে লাগায়","audioUrl":"wbw/030_028_029.mp3","charTypeName":"word"},{"id":31247,"position":28,"arabic":"٢٨","translation":"(২৮)","audioUrl":null,"charTypeName":"end"}]},{"number":29,"arabic":"بَلِ ٱتَّبَعَ ٱلَّذِينَ ظَلَمُوٓا۟ أَهْوَآءَهُم بِغَيْرِ عِلْمٍۢ ۖ فَمَن يَهْدِى مَنْ أَضَلَّ ٱللَّهُ ۖ وَمَا لَهُم مِّن نَّٰصِرِينَ","translation":"But nay - they who are bent on evildoing fol­low but their own desires, without having any knowl­edge (of the truth). And who could guide those whom God has [thus] let go astray, 