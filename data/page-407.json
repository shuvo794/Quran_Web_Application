/030_029_017.mp3","charTypeName":"word"},{"id":32222,"position":16,"arabic":"نَّـٰصِرِينَ","translation":"সাহায্যকারী","audioUrl":"wbw/030_029_018.mp3","charTypeName":"word"},{"id":32223,"position":17,"arabic":"٢٩","translation":"(২৯)","audioUrl":null,"charTypeName":"end"}]},{"number":30,"arabic":"فَأَقِمْ وَجْهَكَ لِلدِّينِ حَنِيفًۭا ۚ فِطْرَتَ ٱللَّهِ ٱلَّتِى فَطَرَ ٱلنَّاسَ عَلَيْهَا ۚ لَا تَبْدِيلَ لِخَلْقِ ٱللَّهِ ۚ ذَٰلِكَ ٱلدِّينُ ٱلْقَيِّمُ وَلَٰكِنَّ أَكْثَرَ ٱلنَّاسِ لَا يَعْلَمُونَ","translation":"AND SO, set thy face steadfastly towards the [one ever-true] faith, turning away from all that is false, in accordance with the natural disposition which God has instilled into man: [for,] not to allow any change to corrupt what God has thus created this is the [purpose of the one] ever-true faith; but most people know it not.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3439.mp3","surahId":30,"words":[{"id":33035,"position":1,"arabic":"فَأَقِمْ","translation":"অতএব (হে নাবী) প্রতিষ্ঠিত করো","audioUrl":"wbw/030_030_001.mp3","charTypeName":"word"},{"id":33036,"position":2,"arabic":"وَجْهَكَ","translation":"তোমার চেহারা (লক্ষ্য)কে","audioUrl":"wbw/030_030_002.mp3","charTypeName":"word"},{"id":33037,"position":3,"arabic":"لِلدِّينِ","translation":"জন্যে দ্বীনের","audioUrl":"wbw/030_030_003.mp3","charTypeName":"word"},{"id":33038,"position":4,"arabic":"حَنِيفًۭا ۚ","translation":"একনিষ্ঠভাবে","audioUrl":"wbw/030_030_004.mp3","charTypeName":"word"},{"id":33040,"position":5,"arabic":"فِطْرَتَ","translation":"(সেই দ্বীন) প্রকৃতির","audioUrl":"wbw/030_030_006.mp3","charTypeName":"word"},{"id":33041,"position":6,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/030_030_007.mp3","charTypeName":"word"},{"id":33042,"position":7,"arabic":"ٱلَّتِى","translation":"যা","audioUrl":"wbw/030_030_008.mp3","charTypeName":"word"},{"id":33043,"position":8,"arabic":"فَطَرَ","translation":"তিনি সৃষ্টি করেছেন","audioUrl":"wbw/030_030_009.mp3","charTypeName":"word"},{"id":33044,"position":9,"arabic":"ٱلنَّاسَ","translation":"মানুষকে","audioUrl":"wbw/030_030_010.mp3","charTypeName":"word"},{"id":33045,"position":10,"arabic":"عَلَيْهَا ۚ","translation":"উপর তার","audioUrl":"wbw/030_030_011.mp3","charTypeName":"word"},{"id":33047,"position":11,"arabic":"لَا","translation":"না (হ'তে পারে)","audioUrl":"wbw/030_030_013.mp3","charTypeName":"word"},{"id":33048,"position":12,"arabic":"تَبْدِيلَ","translation":"কোনো  পরিবর্তন","audioUrl":"wbw/030_030_014.mp3","charTypeName":"word"},{"id":33049,"position":13,"arabic":"لِخَلْقِ","translation":"জন্যে সৃষ্টির","audioUrl":"wbw/030_030_015.mp3","charTypeName":"word"},{"id":33050,"position":14,"arabic":"ٱللَّهِ ۚ","translation":"আল্লাহর","audioUrl":"wbw/030_030_016.mp3","charTypeName":"word"},{"id":33052,"position":15,"arabic":"ذَٰلِكَ","translation":"এটাই","audioUrl":"wbw/030_030_018.mp3","charTypeName":"word"},{"id":33053,"position":16,"arabic":"ٱلدِّينُ","translation":"দীন","audioUrl":"wbw/030_030_019.mp3","charTypeName":"word"},{"id":33054,"position":17,"arabic":"ٱلْقَيِّمُ","translation":"প্রতিষ্ঠিত","audioUrl":"wbw/030_030_020.mp3","charTypeName":"word"},{"id":33055,"position":18,"arabic":"وَلَـٰكِنَّ","translation":"কিন্তু","audioUrl":"wbw/030_030_021.mp3","charTypeName":"word"},{"id":33056,"position":19,"arabic":"أَكْثَرَ","translation":"অধিকাংশ","audioUrl":"wbw/030_030_022.mp3","charTypeName":"word"},{"id":33057,"position":20,"arabic":"ٱلنَّاسِ","translation":"মানুষ","audioUrl":"wbw/030_030_023.mp3","charTypeName":"word"},{"id":33058,"position":21,"arabic":"لَا","translation":"না","audioUrl":"wbw/030_030_024.mp3","charTypeName":"word"},{"id":33059,"position":22,"arabic":"يَعْلَمُونَ","translation":"তারা জানে","audioUrl":"wbw/030_030_025.mp3","charTypeName":"word"},{"id":33060,"position":23,"arabic":"٣٠","translation":"(৩০)","audioUrl":null,"charTypeName":"end"}]},{"number":31,"arabic":"۞ مُنِيبِينَ إِلَيْهِ وَٱتَّقُوهُ وَأَقِيمُوا۟ ٱلصَّلَوٰةَ وَلَا تَكُونُوا۟ مِنَ ٱلْمُشْرِكِين