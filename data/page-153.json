":"دُونِ","translation":"বাদ","audioUrl":"wbw/007_030_013.mp3","charTypeName":"word"},{"id":33264,"position":13,"arabic":"ٱللَّهِ","translation":"আল্লাহকে","audioUrl":"wbw/007_030_014.mp3","charTypeName":"word"},{"id":33265,"position":14,"arabic":"وَيَحْسَبُونَ","translation":"এবং তারা মনে করে","audioUrl":"wbw/007_030_015.mp3","charTypeName":"word"},{"id":33266,"position":15,"arabic":"أَنَّهُم","translation":"যে তারা","audioUrl":"wbw/007_030_016.mp3","charTypeName":"word"},{"id":33267,"position":16,"arabic":"مُّهْتَدُونَ","translation":"সঠিক-পথপ্রাপ্ত","audioUrl":"wbw/007_030_017.mp3","charTypeName":"word"},{"id":33268,"position":17,"arabic":"٣٠","translation":"(৩০)","audioUrl":null,"charTypeName":"end"}]}]}