ব","audioUrl":"wbw/007_029_003.mp3","charTypeName":"word"},{"id":32409,"position":4,"arabic":"بِٱلْقِسْطِ ۖ","translation":"ব্যাপারে ন্যায়ের","audioUrl":"wbw/007_029_004.mp3","charTypeName":"word"},{"id":32411,"position":5,"arabic":"وَأَقِيمُوا۟","translation":"এবং তোমরা স্থির রাখো","audioUrl":"wbw/007_029_006.mp3","charTypeName":"word"},{"id":32412,"position":6,"arabic":"وُجُوهَكُمْ","translation":"লক্ষ্য তোমাদের","audioUrl":"wbw/007_029_007.mp3","charTypeName":"word"},{"id":32413,"position":7,"arabic":"عِندَ","translation":"সময়","audioUrl":"wbw/007_029_008.mp3","charTypeName":"word"},{"id":32414,"position":8,"arabic":"كُلِّ","translation":"প্রত্যেক","audioUrl":"wbw/007_029_009.mp3","charTypeName":"word"},{"id":32415,"position":9,"arabic":"مَسْجِدٍۢ","translation":"মাসজীদের (সালাতের)","audioUrl":"wbw/007_029_010.mp3","charTypeName":"word"},{"id":32416,"position":10,"arabic":"وَٱدْعُوهُ","translation":"এবং তোমরা ডাকো তাঁকে","audioUrl":"wbw/007_029_011.mp3","charTypeName":"word"},{"id":32417,"position":11,"arabic":"مُخْلِصِينَ","translation":"তোমরা একনিষ্ঠভাবে","audioUrl":"wbw/007_029_012.mp3","charTypeName":"word"},{"id":32418,"position":12,"arabic":"لَهُ","translation":"জন্যে তাঁরই","audioUrl":"wbw/007_029_013.mp3","charTypeName":"word"},{"id":32419,"position":13,"arabic":"ٱلدِّينَ ۚ","translation":"আনুগত্যকে (নিষ্ঠাপূর্ণ করে)","audioUrl":"wbw/007_029_014.mp3","charTypeName":"word"},{"id":32421,"position":14,"arabic":"كَمَا","translation":"যেমন","audioUrl":"wbw/007_029_016.mp3","charTypeName":"word"},{"id":32422,"position":15,"arabic":"بَدَأَكُمْ","translation":"প্রথম সৃষ্টি করেছেন তোমাদের","audioUrl":"wbw/007_029_017.mp3","charTypeName":"word"},{"id":32423,"position":16,"arabic":"تَعُودُونَ","translation":"তোমরা (তেমনি) ফিরে আসবে\"","audioUrl":"wbw/007_029_018.mp3","charTypeName":"word"},{"id":32424,"position":17,"arabic":"٢٩","translation":"(২৯)","audioUrl":null,"charTypeName":"end"}]},{"number":30,"arabic":"فَرِيقًا هَدَىٰ وَفَرِيقًا حَقَّ عَلَيْهِمُ ٱلضَّلَٰل