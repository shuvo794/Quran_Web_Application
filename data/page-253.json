{"id":253,"ayahs":[{"number":29,"arabic":"ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ طُوبَىٰ لَهُمْ وَحُسْنُ مَـَٔابٍۢ","translation":"[and so it is that] they who attain to faith and do righteous deeds are destined for happiness [in this world] and the most beauteous of all goals [in the life to come]!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1736.mp3","surahId":13,"words":[{"id":32250,"position":1,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/013_029_001.mp3","charTypeName":"word"},{"id":32251,"position":2,"arabic":"ءَامَنُوا۟","translation":"ঈমান এসেছে","audioUrl":"wbw/013_029_002.mp3","charTypeName":"word"},{"id":32252,"position":3,"arabic":"وَعَمِلُوا۟","translation":"ও কাজ করেছে","audioUrl":"wbw/013_029_003.mp3","charTypeName":"word"},{"id":32253,"position":4,"arabic":"ٱلصَّـٰلِحَـٰتِ","translation":"সৎ","audioUrl":"wbw/013_029_004.mp3","charTypeName":"word"},{"id":32254,"position":5,"arabic":"طُوبَىٰ","translation":"সুসংবাদ","audioUrl":"wbw/013_029_005.mp3","charTypeName":"word"},{"id":32255,"position":6,"arabic":"لَهُمْ","translation":"তাদের জন্যে রয়েছে","audioUrl":"wbw/013_029_006.mp3","charTypeName":"word"},{"id":32256,"position":7,"arabic":"وَحُسْنُ","translation":"ও উত্তম","audioUrl":"wbw/013_029_007.mp3","charTypeName":"word"},{"id":32257,"position":8,"arabic":"مَـَٔابٍۢ","translation":"পরিণাম","audioUrl":"wbw/013_029_008.mp3","charTypeName":"word"},{"id":32258,"position":9,"arabic":"٢٩","translation":"(২৯)","audioUrl":null,"charTypeName":"end"}]},{"number":30,"arabic":"كَذَٰلِكَ أَرْسَلْنَٰكَ فِىٓ أُمَّةٍۢ قَدْ خَلَتْ مِن قَبْلِهَآ أُمَمٌۭ لِّتَتْلُوَا۟ عَلَيْهِمُ ٱلَّذِىٓ أَوْحَيْنَآ إِلَيْكَ وَهُمْ يَكْفُرُونَ بِٱلرَّحْمَٰنِ ۚ قُلْ هُوَ رَبِّى لَآ إِلَٰهَ إِلَّا هُوَ عَلَيْهِ تَوَكَّلْتُ وَإِلَيْهِ مَتَابِ","translation":"Thus have We raised thee [O Muhammad] as Our Apostle amidst a community [of unbelievers] before whose time [similar] communities have come and gone, so that thou might propound to them what We have revealed unto thee: for [in their ignorance] they deny the Most Gracious! Say: \"He is my Sustainer. There is no deity save Him. In Him have I placed my trust, and unto Him is my recourse!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1737.mp3","surahId":13,"words":[{"id":33078,"position":1,"arabic":"كَذَٰلِكَ","translation":"(হে মুহাম্মাদ) এভাবে","audioUrl":"wbw/013_030_001.mp3","charTypeName":"word"},{"id":33079,"position":2,"arabic":"أَرْسَلْنَـٰكَ","translation":"তোমাকে আমরা পাঠিয়েছি (রাসূলরূপে)","audioUrl":"wbw/013_030_002.mp3","charTypeName":"word"},{"id":33080,"position":3,"arabic":"فِىٓ","translation":"মধ্যে","audioUrl":"wbw/013_030_003.mp3","charTypeName":"word"},{"id":33081,"position":4,"arabic":"أُمَّةٍۢ","translation":"এক জাতির","audioUrl":"wbw/013_030_004.mp3","charTypeName":"word"},{"id":33082,"position":5,"arabic":"قَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/013_030_005.mp3","charTypeName":"word"},{"id":33083,"position":6,"arabic":"خَلَتْ","translation":"অতীত হয়েছে","audioUrl":"wbw/013_030_006.mp3","charTypeName":"word"},{"id":33084,"position":7,"arabic":"مِن","translation":"থেকেই","audioUrl":"wbw/013_030_007.mp3","charTypeName":"word"},{"id":33085,"position":8,"arabic":"قَبْلِهَآ","translation":"তার পূর্ব","audioUrl":"wbw/013_030_008.mp3","charTypeName":"word"},{"id":33086,"position":9,"arabic":"أُمَمٌۭ","translation":"বহু জাতি","audioUrl":"wbw/013_030_009.mp3","charTypeName":"word"},{"id":33087,"position":10,"arabic":"لِّتَتْلُوَا۟","translation":"যাতে তুমি পাঠ করো","audioUrl":"wbw/013_030_010.mp3","charTypeName":"word"},{"id":33088,"position":11,"arabic":"عَلَيْهِمُ","translation":"কাছে তাদের","audioUrl":"wbw/013_030_011.mp3","charTypeName":"word"},{"id":33089,"position":12,"arabic":"ٱلَّذِىٓ","translation":"যা","audioUrl":"wbw/013_030_012.mp3","charTypeName":"word"},{"id":33090,"position":13,"arabic":"أَوْحَيْنَآ","translation":"আমরা ওহী করেছি","audioUrl":"wbw/013_030_013.mp3","charTypeName":"word"},{"id":33091,