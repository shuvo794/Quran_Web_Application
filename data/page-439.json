f olden times? Thus [it is]: no change wilt thou ever find in God’s way; yea, no deviation wilt thou ever find in God’s way!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3703.mp3","surahId":35,"words":[{"id":43420,"position":1,"arabic":"ٱسْتِكْبَارًۭا","translation":"ঔদ্ধত্য প্রকাশ করে","audioUrl":"wbw/035_043_001.mp3","charTypeName":"word"},{"id":43421,"position":2,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/035_043_002.mp3","charTypeName":"word"},{"id":43422,"position":3,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/035_043_003.mp3","charTypeName":"word"},{"id":43423,"position":4,"arabic":"وَمَكْرَ","translation":"ও ষড়যন্ত্র (এঁটে)","audioUrl":"wbw/035_043_004.mp3","charTypeName":"word"},{"id":43424,"position":5,"arabic":"ٱلسَّيِّئِ ۚ","translation":"নিকৃষ্ট","audioUrl":"wbw/035_043_005.mp3","charTypeName":"word"},{"id":43426,"position":6,"arabic":"وَلَا","translation":"অথচ না","audioUrl":"wbw/035_043_007.mp3","charTypeName":"word"},{"id":43427,"position":7,"arabic":"يَحِيقُ","translation":"ঘিরে ধরে","audioUrl":"wbw/035_043_008.mp3","charTypeName":"word"},{"id":43428,"position":8,"arabic":"ٱلْمَكْرُ","translation":"ষড়যন্ত্র","audioUrl":"wbw/035_043_009.mp3","charTypeName":"word"},{"id":43429,"position":9,"arabic":"ٱلسَّيِّئُ","translation":"নিকৃষ্ট","audioUrl":"wbw/035_043_010.mp3","charTypeName":"word"},{"id":43430,"position":10,"arabic":"إِلَّا","translation":"কিন্তু","audioUrl":"wbw/035_043_011.mp3","charTypeName":"word"},{"id":43431,"position":11,"arabic":"بِأَهْلِهِۦ ۚ","translation":"তার উদ্যোক্তাদেরই","audioUrl":"wbw/035_043_012.mp3","charTypeName":"word"},{"id":43433,"position":12,"arabic":"فَهَلْ","translation":"তবে কি","audioUrl":"wbw/035_043_014.mp3","charTypeName":"word"},{"id":43434,"position":13,"arabic":"يَنظُرُونَ","translation":"তারা অপেক্ষা করছে","audioUrl":"wbw/035_043_015.mp3","charTypeName":"word"},{"id":43435,"position":14,"arabic":"إِلَّا","translation":"এ ছাড়া যে","audioUrl":"wbw/035_043_016.mp3","charTypeName":"word"},{"id":43436,"position":15,"arabic":"سُنَّتَ","translation":"বিধানের","audioUrl":"wbw/035_043_017.mp3","charTypeName":"word"},{"id":43437,"position":16,"arabic":"ٱلْأَوَّلِينَ ۚ","translation":"পূর্ববর্তীদের (ক্ষেত্রে গৃহীত)","audioUrl":"wbw/035_043_018.mp3","charTypeName":"word"},{"id":43439,"position":17,"arabic":"فَلَن","translation":"তখন কখনও না","audioUrl":"wbw/035_043_020.mp3","charTypeName":"word"},{"id":43440,"position":18,"arabic":"تَجِدَ","translation":"পাবে তুমি","audioUrl":"wbw/035_043_021.mp3","charTypeName":"word"},{"id":43441,"position":19,"arabic":"لِسُنَّتِ","translation":"বিধানের ক্ষেত্রে","audioUrl":"wbw/035_043_022.mp3","charTypeName":"word"},{"id":43442,"position":20,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/035_043_023.mp3","charTypeName":"word"},{"id":43443,"position":21,"arabic":"تَبْدِيلًۭا ۖ","translation":"কোনো পরিবর্তন","audioUrl":"wbw/035_043_024.mp3","charTypeName":"word"},{"id":43445,"position":22,"arabic":"وَلَن","translation":"এবং কখনও না","audioUrl":"wbw/035_043_026.mp3","charTypeName":"word"},{"id":43446,"position":23,"arabic":"تَجِدَ","translation":"পাবে তুমি","audioUrl":"wbw/035_043_027.mp3","charTypeName":"word"},{"id":43447,"position":24,"arabic":"لِسُنَّتِ","translation":"বিধানে","audioUrl":"wbw/035_043_028.mp3","charTypeName":"word"},{"id":43448,"position":25,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/035_043_029.mp3","charTypeName":"word"},{"id":43449,"position":26,"arabic":"تَحْوِيلًا","translation":"ব্যতিক্রম","audioUrl":"wbw/035_043_030.mp3","charTypeName":"word"},{"id":43450,"position":27,"arabic":"٤٣","translation":"(৪৩)","audioUrl":null,"charTypeName":"end"}]},{"number":44,"arabic":"أَوَلَمْ يَسِيرُوا۟ فِى ٱلْأَرْضِ فَيَنظُرُوا۟ كَيْفَ كَانَ عَٰقِبَةُ ٱلَّذِينَ مِن قَبْلِهِمْ وَكَانُوٓا۟ أَشَدَّ مِنْهُمْ قُوَّةًۭ ۚ وَمَا كَانَ ٱللَّهُ لِيُعْجِزَهُۥ مِن شَىْءٍۢ فِى ٱلسَّمَٰوَٰتِ وَلَا فِى ٱلْأَرْضِ ۚ إِنَّهُۥ كَانَ عَلِيمًۭا قَدِيرًۭا","translation":"Have they never journeyed about the earth and beheld what happened in the end to those [deniers of the truth] who lived before their time and were [so much] greater than they in power? And [do they not see that the will of] God can never be foiled by anything whatever in the heavens or on earth, since, verily, He is all-knowing, infinite in His power?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3704.mp3","surahId":35,"words":[{"id":44845,"position":1,"arabic":"أَوَلَمْ","translation":"নি কি","audioUrl":"wbw/035_044_001.mp3","charTypeName":"word"},{"id":44846,"position":2,"arabic":"يَسِيرُوا۟","translation":"তারা ভ্রমণ করে","audioUrl":"wbw/035_044_002.mp3","charTypeName":"word"},{"id":44847,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/035_044_003.mp3","charTypeName":"word"},{"id":44848,"position":4,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/035_044_004.mp3","charTypeName":"word"},{"id":44849,"position":5,"arabic":"فَيَنظُرُوا۟","translation":"তারা তখন দেখে (নাই কি)","audioUrl":"wbw/035_044_005.mp3","charTypeName":"word"},{"id":44850,"position":6,"arabic":"كَيْفَ","translation":"কেমন","audioUrl":"wbw/035_044_006.mp3","charTypeName":"word"},{"id":44851,"position":7,"arabic":"كَانَ","translation":"ছিলো","audioUrl":"wbw/035_044_007.mp3","charTypeName":"word"},{"id":44852,"position":8,"arabic":"عَـٰقِبَةُ","translation":"পরিণাম","audioUrl":"wbw/035_044_008.mp3","charTypeName":"word"},{"id":44853,"position":9,"arabic":"ٱلَّذِينَ","translation":"তাদের (যারা)","audioUrl":"wbw/035_044_009.mp3","charTypeName":"word"},{"id":44854,"position":10,"arabic":"مِن","translation":"পূর্বে ছিলো","audioUrl":"wbw/035_044_010.mp3","charTypeName":"word"},{"id":44855,"position":11,"arabic":"قَبْلِهِمْ","translation":"তাদের","audioUrl":"wbw/035_044_011.mp3","charTypeName":"word"},{"id":44856,"position":12,"arabic":"وَكَانُوٓا۟","translation":"অথচ তারা ছিলো","audioUrl":"wbw/035_044_012.mp3","charTypeName":"word"},{"id":44857,"position":13,"arabic"