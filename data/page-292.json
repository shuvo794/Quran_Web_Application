{"id":292,"ayahs":[{"number":97,"arabic":"وَمَن يَهْدِ ٱللَّهُ فَهُوَ ٱلْمُهْتَدِ ۖ وَمَن يُضْلِلْ فَلَن تَجِدَ لَهُمْ أَوْلِيَآءَ مِن دُونِهِۦ ۖ وَنَحْشُرُهُمْ يَوْمَ ٱلْقِيَٰمَةِ عَلَىٰ وُجُوهِهِمْ عُمْيًۭا وَبُكْمًۭا وَصُمًّۭا ۖ مَّأْوَىٰهُمْ جَهَنَّمُ ۖ كُلَّمَا خَبَتْ زِدْنَٰهُمْ سَعِيرًۭا","translation":"And he whom God guides, he alone has found the right way; whereas for those whom He lets go astray thou canst never find anyone to protect them from Him: and [so, when] We shall gather them together on the Day of Resurrection, [they will lie] prone upon their faces, blind and dumb and deaf, with hell as their goal; [and] every time [the fire] abates, We shall increase for them [its] blazing flame.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2126.mp3","surahId":17,"words":[{"id":70302,"position":1,"arabic":"وَمَن","translation":"এবং যাকে","audioUrl":"wbw/017_097_001.mp3","charTypeName":"word"},{"id":70303,"position":2,"arabic":"يَهْدِ","translation":"পথ দেখান","audioUrl":"wbw/017_097_002.mp3","charTypeName":"word"},{"id":70304,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/017_097_003.mp3","charTypeName":"word"},{"id":70305,"position":4,"arabic":"فَهُوَ","translation":"অতঃপর সেই","audioUrl":"wbw/017_097_004.mp3","charTypeName":"word"},{"id":70306,"position":5,"arabic":"ٱلْمُهْتَدِ ۖ","translation":"সঠিক পথপ্রাপ্ত","audioUrl":"wbw/017_097_005.mp3","charTypeName":"word"},{"id":70308,"position":6,"arabic":"وَمَن","translation":"এবং যাকে","audioUrl":"wbw/017_097_007.mp3","charTypeName":"word"},{"id":70309,"position":7,"arabic":"يُضْلِلْ","translation":"তিনি পথভ্রষ্ট করেন","audioUrl":"wbw/017_097_008.mp3","charTypeName":"word"},{"id":70310,"position":8,"arabic":"فَلَن","translation":"অতঃপর কখনও না","audioUrl":"wbw/017_097_009.mp3","charTypeName":"word"},{"id":70311,"position":9,"arabic":"تَجِدَ","translation":"তুমি পাবে","audioUrl":"wbw/017_097_010.mp3","charTypeName":"word"},{"id":70312,"position":10,"arabic":"لَهُمْ","translation":"জন্যে তাদের","audioUrl":"wbw/017_097_011.mp3","charTypeName":"word"},{"id":70313,"position":11,"arabic":"أَوْلِيَآءَ","translation":"অভিভাবকসমূহ","audioUrl":"wbw/017_097_012.mp3","charTypeName":"word"},{"id":70314,"position":12,"arabic":"مِن","translation":"ছাড়া","audioUrl":"wbw/017_097_013.mp3","charTypeName":"word"},{"id":70315,"position":13,"arabic":"دُونِهِۦ ۖ","translation":"তাঁকে","audioUrl":"wbw/017_097_014.mp3","charTypeName":"word"},{"id":70317,"position":14,"arabic":"وَنَحْشُرُهُمْ","translation":"এবং আমরা সমবেত করবো তাদেরকে","audioUrl":"wbw/017_097_016.mp3","charTypeName":"word"},{"id":70318,"position":15,"arabic":"يَوْمَ","translation":"দিনে","audioUrl":"wbw/017_097_017.mp3","charTypeName":"word"},{"id":70319,"position":16,"arabic":"ٱلْقِيَـٰمَةِ","translation":"ক্বিয়ামাতের","audioUrl":"wbw/017_097_018.mp3","charTypeName":"word"},{"id":70320,"position":17,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/017_097_019.mp3","charTypeName":"word"},{"id":70321,"position":18,"arabic":"وُجُوهِهِمْ","translation":"মুখগুলোর তাদের","audioUrl":"wbw/017_097_020.mp3","charTypeName":"word"},{"id":70322,"position":19,"arabic":"عُمْيًۭا","translation":"অন্ধ অবস্থায়","audioUrl":"wbw/017_097_021.mp3","charTypeName":"word"},{"id":70323,"position":20,"arabic":"وَبُكْمًۭا","translation":"ও বোবা অবস্থায়","audioUrl":"wbw/017_097_022.mp3","charTypeName":"word"},{"id":70324,"position":21,"arabic":"وَصُمًّۭا ۖ","translation":"ও বধির অবস্হায়","audioUrl":"wbw/017_097_023.mp3","charTypeName":"word"},{"id":70326,"position":22,"arabic":"مَّأْوَىٰهُمْ","translation":"আবাসস্থল তাদের","audioUrl":"wbw/017_097_025.mp3","charTypeName":"word"},{"id":70327,"position":23,"arabic":"جَهَنَّمُ ۖ","translation":"জাহান্নাম","audioUrl":"wbw/017_097_026.mp3","charTypeName":"word"},{"id":70329,"position":24,"arabic":"كُلَّمَا","translation":"যখনই","audioUrl":"wbw/017_097_028.mp3","charTypeName":"word"},{"id":70330,"position":25,"arabic":"خَبَتْ","translation":"তেজ কমে আসবে","audioUrl":"wbw/017_097_029.mp3","charTypeName":"word"},{"id":70331,"position":26,"arabic":"زِدْنَـٰهُمْ","translation":"আমরা বাড়িয়ে দিবো তাদের","audioUrl":"wbw/017_097_030.mp3","charTypeName":"word"},{"id":70332,"position":27,"arabic":"سَعِيرًۭا","translation":"আগুন","audioUrl":"wbw/017_097_031.mp3","charTypeName":"word"},{"id":70333,"position":28,"arabic":"٩٧","translation":"(৯৭)","audioUrl":null,"charTypeName":"end"}]},{"number":98,"arabic":"ذَٰلِكَ جَزَآؤُهُم بِأَنَّهُمْ كَفَرُوا۟ بِـَٔايَٰتِنَا وَقَالُوٓا۟ أَءِذَا كُنَّا عِظَٰمًۭا وَرُفَٰتًا أَءِنَّا لَمَبْعُوثُونَ خَلْقًۭا جَدِيدًا","translation":"Such will be their requital for having rejected Our messages and having said, \"After we will have become bones and dust, shall we, forsooth, be raised from the dead in a new act of creation?\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2127.mp3","surahId":17,"words":[{"id":70777,"position":1,"arabic":"ذَٰلِكَ","translation":"এটাই","audioUrl":"wbw/017_098_001.mp3","charTypeName":"word"},{"id":70778,"position":2,"arabic":"جَزَآؤُهُم","translation":"তাদের প্রতিফল","audioUrl":"wbw/017_098_002.mp3","charTypeName":"word"},{"id":70779,"position":3,"arabic":"بِأَنَّهُمْ","translation":"এ কারণে যে তারা","audioUrl":"wbw/017_098_003.mp3","charTypeName":"word"},{"id":70780,"position":4,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/017_098_004.mp3","charTypeName":"word"},{"id":70781,"position":5,"arabic":"بِـَٔايَـٰتِنَا","translation":"সহ আমাদের নিদর্শনাদি","audioUrl":"wbw/017_098_005.mp3","charTypeName":"word"},{"id":70782,"position":6,"arabic":"وَقَالُوٓا۟","translation":"এবং তারা বলেছে","audioUrl":"wbw/017_098_006.mp3","charTypeName":"word"},{"id":70783,"position":7,"arabic":"أَءِذَا","translation":"\"কি যখন","audioUrl":"wbw/017_098_007.mp3","charTypeName":"word"},{"id":70784,"position":8,"arabic":"كُنَّا","translation":"আমরা হবো","audioUrl":"wbw/017_098_008.mp3","charTypeName":"word"},{"id":70785,"position":9,"arabic":"عِظَـٰمًۭا","translation":"হাড়","audioUrl":"wbw/017_098_009.mp3","charTypeName":"word"},{"id":70786,"position":10,"arabic":"وَرُفَـٰتًا","translation":"ও চূর্ণ-বিচূর্ণ","audioUrl":"wbw/017_098_010.mp3","charTypeName":"word"},{"id":70787,"position":11,"arabic":"أَءِنَّا","translation":"কি নিশ্চয়ই আমরা","audioUrl":"wbw/017_098_011.mp3","charTypeName":"word"},{"id":70788,"position":12,"arabic":"لَمَبْعُوثُونَ","translation":"অবশ্যই উত্থিত হবো","audioUrl":"wbw/017_098_012.mp3","charTypeName":"word"},{"id":70789,"position":13,"arabic":"خَلْقًۭا","translation":"সৃষ্টিতে","audioUrl":"wbw/017_098_013.mp3","charTypeName":"word"},{"id":70790,"position":14,"arabic":"جَدِيدًا","translation":"নতুন\"","audioUrl":"wbw/017_098_014.mp3","charTypeName":"word"},{"id":70791,"position":15,"arabic":"٩٨","translation":"(৯৮)","audioUrl":null,"charTypeName":"end"}]},{"number":99,"arabic":"۞ أَوَلَمْ يَرَوْا۟ أَنَّ ٱللَّهَ ٱلَّذِى خَلَقَ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضَ قَادِرٌ عَلَىٰٓ أَن يَخْلُقَ مِثْلَهُمْ وَجَعَلَ لَهُمْ أَجَلًۭا لَّا رَيْبَ فِيهِ فَأَبَى ٱلظَّٰلِمُونَ إِلَّا كُفُورًۭا","translation":"Are they, then, not aware that God, who has created the heavens and the earth, has the power to create them anew in their own likeness, having, beyond any doubt, set a term for their resurrection? However, all [such] evildoers are unwilling to accept anything but blasphemy!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2128.mp3","surahId":17,"words":[{"id":70886,"position":1,"arabic":"۞ أَوَلَمْ","translation":"কি না","audioUrl":"wbw/017_099_002.mp3","charTypeName":"word"},{"id":70887,"position":2,"arabic":"يَرَوْا۟","translation":"তারা লক্ষ্য করে","audioUrl":"wbw/017_099_003.mp3","charTypeName":"word"},{"id":70888,"position":3,"arabic":"أَنَّ","translation":"যে","audioUrl":"wbw/017_099_004.mp3","charTypeName":"word"},{"id":70889,"position":4,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/017_099_005.mp3","charTypeName":"word"},{"id":70890,"position":5,"arabic":"ٱلَّذِى","translation":"(তিনি) যিনি","audioUrl":"wbw/017_099_006.mp3","charTypeName":"word"},{"id":70891,"position":6,"arabic":"خَلَقَ","translation":"সৃষ্টি করেছেন","audioUrl":"wbw/017_099_007.mp3","charTypeName":"word"},{"id":70892,"position":7,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশসমূহকে","audioUrl":"wbw/017_099_008.mp3","charTypeName":"word"},{"id":70893,"position":8,"arabic":"وَٱلْأَرْضَ","translation":"ও পৃথিবীকে","audioUrl":"wbw/017_099_009.mp3","charTypeName":"word"},{"id":70894,"position":9,"arabic":"قَادِرٌ","translation":"সক্ষম (নন কি)","audioUrl":"wbw/017_099_010.mp3","charTypeName":"word"},{"id":70895,"position":10,"arabic":"عَلَىٰٓ","translation":"উপর","audioUrl":"wbw/017_099_011.mp3","charTypeName":"word"},{"id":70896,"position":11,"arabic":"أَن","translation":"যে","audioUrl":"wbw/017_099_012.mp3","charTypeName":"word"},{"id":70897,"position":12,"arabic":"يَخْلُقَ","translation":"সৃষ্টি করবেন","audioUrl":"wbw/017_099_013.mp3","charTypeName":"word"},{"id":70898,"position":13,"arabic":"مِثْلَهُمْ","translation":"তাদের অনুরূপ","audioUrl":"wbw/017_099_014.mp3","charTypeName":"word"},{"id":70899,"position":14,"arabic":"وَجَعَلَ","translation":"এবং স্থির করে রেখেছেন","audioUrl":"wbw/017_099_015.mp3","charTypeName":"word"},{"id":70900,"position":15,"arabic":"لَهُمْ","translation":"জন্যে তাদের","audioUrl":"wbw/017_099_016.mp3","charTypeName":"word"},{"id":70901,"position":16,"arabic":"أَجَلًۭا","translation":"নির্দিষ্টকাল","audioUrl":"wbw/017_099_017.mp3","charTypeName":"word"},{"id":70902,"position":17,"arabic":"لَّا","translation":"নেই","audioUrl":"wbw/017_099_018.mp3","charTypeName":"word"},{"id":70903,"position":18,"arabic":"رَيْبَ","translation":"কোনো সন্দেহ","audioUrl":"wbw/017_099_019.mp3","charTypeName":"word"},{"id":70904,"position":19,"arabic":"فِيهِ","translation":"মধ্যে তার","audioUrl":"wbw/017_099_020.mp3","charTypeName":"word"},{"id":70905,"position":20,"arabic":"فَأَبَى","translation":"তবুও অস্বীকার করলো","audioUrl":"wbw/017_099_021.mp3","charTypeName":"word"},{"id":70906,"position":21,"arabic":"ٱلظَّـٰلِمُونَ","translation":"সীমালঙ্ঘনকারীরা","audioUrl":"wbw/017_099_022.mp3","charTypeName":"word"},{"id":70907,"position":22,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/017_099_023.mp3","charTypeName":"word"},{"id":70908,"position":23,"arabic":"كُفُورًۭا","translation":"অস্বীকৃতি","audioUrl":"wbw/017_099_024.mp3","charTypeName":"word"},{"id":70909,"position":24,"arabic":"٩٩","translation":"(৯৯)","audioUrl":null,"charTypeName":"end"}]},{"number":100,"arabic":"قُل لَّوْ أَنتُمْ تَمْلِكُونَ خَزَآئِنَ رَحْمَةِ رَبِّىٓ إِذًۭا لَّأَمْسَكْتُمْ خَشْيَةَ ٱلْإِنفَاقِ ۚ وَكَانَ ٱلْإِنسَٰنُ قَتُورًۭا","translation":"Say: \"If you were to own' all the treasure-houses of my Sustainer's bounty, lo! you would still try to hold on [to them] tightly for fear of spending [too much]: for man has always been avaricious [whereas God is limitless in His bounty].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2129.mp3","surahId":17,"words":[{"id":71151,"position":1,"arabic":"قُل","translation":"বলো","audioUrl":"wbw/017_100_001.mp3","charTypeName":"word"},{"id":71152,"position":2,"arabic":"لَّوْ","translation":"\"যদি","audioUrl":"wbw/017_100_002.mp3","charTypeName":"word"},{"id":71153,"position":3,"arabic":"أَنتُمْ","translation":"তোমরা","audioUrl":"wbw/017_100_003.mp3","charTypeName":"word"},{"id":71154,"position":4,"arabic":"تَمْلِكُونَ","translation":"অধিকারী হ'তে","audioUrl":"wbw/017_100_004.mp3","charTypeName":"word"},{"id":71155,"position":5,"arabic":"خَزَآئِنَ","translation":"ভান্ডারসমূহের","audioUrl":"wbw/017_100_005.mp3","charTypeName":"word"},{"id":71156,"position":6,"arabic":"رَحْمَةِ","translation":"অনুগ্রহের","audioUrl":"wbw/017_100_006.mp3","charTypeName":"word"},{"id":71157,"position":7,"arabic":"رَبِّىٓ","translation":"আমার রবের","audioUrl":"wbw/017_100_007.mp3","charTypeName":"word"},{"id":71158,"position":8,"arabic":"إِذًۭا","translation":"তাহ'লে","audioUrl":"wbw/017_100_008.mp3","charTypeName":"word"},{"id":71159,"position":9,"arabic":"لَّأَمْسَكْتُمْ","translation":"অবশ্যই তোমরা ধরে রাখতে","audioUrl":"wbw/017_100_009.mp3","charTypeName":"word"},{"id":71160,"position":10,"arabic":"خَشْيَةَ","translation":"ভয়ে","audioUrl":"wbw/017_100_010.mp3","charTypeName":"word"},{"id":71161,"position":11,"arabic":"ٱلْإِنفَاقِ ۚ","translation":"খরচ হওয়ার\"","audioUrl":"wbw/017_100_011.mp3","charTypeName":"word"},{"id":71163,"position":12,"arabic":"وَكَانَ","translation":"এবং হলো","audioUrl":"wbw/017_100_013.mp3","charTypeName":"word"},{"id":71164,"position":13,"arabic":"ٱلْإِنسَـٰنُ","translation":"মানুষ","audioUrl":"wbw/017_100_014.mp3","charTypeName":"word"},{"id":71165,"position":14,"arabic":"قَتُورًۭا","translation":"বড়ই কৃপণ","audioUrl":"wbw/017_100_015.mp3","charTypeName":"word"},{"id":71166,"position":15,"arabic":"١٠٠","translation":"(১০০)","audioUrl":null,"charTypeName":"end"}]},{"number":101,"arabic":"وَلَقَدْ ءَاتَيْنَا مُوسَىٰ تِسْعَ ءَايَٰتٍۭ بَيِّنَٰتٍۢ ۖ فَسْـَٔلْ بَنِىٓ إِسْرَٰٓءِيلَ إِذْ جَآءَهُمْ فَقَالَ لَهُۥ فِرْعَوْنُ إِنِّى لَأَظُنُّكَ يَٰمُوسَىٰ مَسْحُورًۭا","translation":"AND, INDEED, We gave unto Moses nine clear messages. Ask, then, the children of Israel [to tell thee what happened] when he came unto them, [and appealed to Pharaoh,] and Pharaoh said unto him, \"Verily, O Moses, I think that thou art full of sorcery!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2130.mp3","surahId":17,"words":[{"id":71500,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/017_101_001.mp3","charTypeName":"word"},{"id":71501,"position":2,"arabic":"ءَاتَيْنَا","translation":"আমরা দিয়েছিলাম","audioUrl":"wbw/017_101_002.mp3","charTypeName":"word"},{"id":71502,"position":3,"arabic":"مُوسَىٰ","translation":"মূসাকে","audioUrl":"wbw/017_101_003.mp3","charTypeName":"word"},{"id":71503,"position":4,"arabic":"تِسْعَ","translation":"নয়টি","audioUrl":"wbw/017_101_004.mp3","charTypeName":"word"},{"id":71504,"position":5,"arabic":"ءَ