{"id":317,"ayahs":[{"number":77,"arabic":"وَلَقَدْ أَوْحَيْنَآ إِلَىٰ مُوسَىٰٓ أَنْ أَسْرِ بِعِبَادِى فَٱضْرِبْ لَهُمْ طَرِيقًۭا فِى ٱلْبَحْرِ يَبَسًۭا لَّا تَخَٰفُ دَرَكًۭا وَلَا تَخْشَىٰ","translation":"AND, INDEED, [a time came when] We thus inspired Moses: \"Go forth with My servants by night, and strike out for them a dry path through the sea; [and] fear not of being overtaken, and dread not [the sea].\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2425.mp3","surahId":20,"words":[{"id":62824,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/020_077_001.mp3","charTypeName":"word"},{"id":62825,"position":2,"arabic":"أَوْحَيْنَآ","translation":"আমরা ওহী করেছিলাম","audioUrl":"wbw/020_077_002.mp3","charTypeName":"word"},{"id":62826,"position":3,"arabic":"إِلَىٰ","translation":"প্রতি","audioUrl":"wbw/020_077_003.mp3","charTypeName":"word"},{"id":62827,"position":4,"arabic":"مُوسَىٰٓ","translation":"মূসার","audioUrl":"wbw/020_077_004.mp3","charTypeName":"word"},{"id":62828,"position":5,"arabic":"أَنْ","translation":"যে","audioUrl":"wbw/020_077_005.mp3","charTypeName":"word"},{"id":62829,"position":6,"arabic":"أَسْرِ","translation":"\"রাতে বেরিয়ে পড়ো","audioUrl":"wbw/020_077_006.mp3","charTypeName":"word"},{"id":62830,"position":7,"arabic":"بِعِبَادِى","translation":"নিয়ে আমার দাসদের","audioUrl":"wbw/020_077_007.mp3","charTypeName":"word"},{"id":62831,"position":8,"arabic":"فَٱضْرِبْ","translation":"অতঃপর (লাঠির) আঘাত করো (অবলম্বন করো)","audioUrl":"wbw/020_077_008.mp3","charTypeName":"word"},{"id":62832,"position":9,"arabic":"لَهُمْ","translation":"তাদের জন্যে","audioUrl":"wbw/020_077_009.mp3","charTypeName":"word"},{"id":62833,"position":10,"arabic":"طَرِيقًۭا","translation":"পথ","audioUrl":"wbw/020_077_010.mp3","charTypeName":"word"},{"id":62834,"position":11,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/020_077_011.mp3","charTypeName":"word"},{"id":62835,"position":12,"arabic":"ٱلْبَحْرِ","translation":"সাগরের","audioUrl":"wbw/020_077_012.mp3","charTypeName":"word"},{"id":62836,"position":13,"arabic":"يَبَسًۭا","translation":"শুকনো","audioUrl":"wbw/020_077_013.mp3","charTypeName":"word"},{"id":62837,"position":14,"arabic":"لَّا","translation":"না","audioUrl":"wbw/020_077_014.mp3","charTypeName":"word"},{"id":62838,"position":15,"arabic":"تَخَـٰفُ","translation":"ভয় করো তুমি","audioUrl":"wbw/020_077_015.mp3","charTypeName":"word"},{"id":62839,"position":16,"arabic":"دَرَكًۭا","translation":"ধরা পড়ার","audioUrl":"wbw/020_077_016.mp3","charTypeName":"word"},{"id":62840,"position":17,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/020_077_017.mp3","charTypeName":"word"},{"id":62841,"position":18,"arabic":"تَخْشَىٰ","translation":"ঘাবড়ে যাও তুমি (ডুবে যাওয়ার)\"","audioUrl":"wbw/020_077_018.mp3","charTypeName":"word"},{"id":62842,"position":19,"arabic":"٧٧","translation":"(৭৭)","audioUrl":null,"charTypeName":"end"}]},{"number":78,"arabic":"فَأَتْبَعَهُمْ فِرْعَوْنُ بِجُنُودِهِۦ فَغَشِيَهُم مِّنَ ٱلْيَمِّ مَا غَشِيَهُمْ","translation":"And Pharaoh pursued them with his hosts: and they were overwhelmed by the sea which was destined to overwhelm them.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2426.mp3","surahId":20,"words":[{"id":63361,"position":1,"arabic":"فَأَتْبَعَهُمْ","translation":"অতঃপর তাদের পিছনে তাড়া করলো","audioUrl":"wbw/020_078_001.mp3","charTypeName":"word"},{"id":63362,"position":2,"arabic":"فِرْعَوْنُ","translation":"ফিরআউন","audioUrl":"wbw/020_078_002.mp3","charTypeName":"word"},{"id":63363,"position":3,"arabic":"بِجُنُودِهِۦ","translation":"নিয়ে তার সৈন্যবাহিনী","audioUrl":"wbw/020_078_003.mp3","charTypeName":"word"},{"id":63364,"position":4,"arabic":"فَغَشِيَهُم","translation":"অতঃপর তাদেরকে ছেয়ে ফেললো","audioUrl":"wbw/020_078_004.mp3","charTypeName":"word"},{"id":63365,"position":5,"arabic":"مِّنَ","translation":"(তার) ভিতরে","audioUrl":"wbw/020_078_005.mp3","charTypeName":"word"},{"id":63366,"position":6,"arabic":"ٱلْيَمِّ","translation":"সাগর","audioUrl":"wbw/020_078_006.mp3","charTypeName":"word"},{"id":63367,"position":7,"arabic":"مَا","translation":"যা","audioUrl":"wbw/020_078_007.mp3","charTypeName":"word"},{"id":63368,"position":8,"arabic":"غَشِيَهُمْ","translation":"তাদেরকে ছেয়ে নিয়েছিলো","audioUrl":"wbw/020_078_008.mp3","charTypeName":"word"},{"id":63369,"position":9,"arabic":"٧٨","translation":"(৭৮)","audioUrl":null,"charTypeName":"end"}]},{"number":79,"arabic":"وَأَضَلَّ فِرْعَوْنُ قَوْمَهُۥ وَمَا هَدَىٰ","translation":"because Pharaoh had led his people astray and had not guided [them] aright.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2427.mp3","surahId":20,"words":[{"id":63846,"position":1,"arabic":"وَأَضَلَّ","translation":"এবং পথভ্রষ্ট করেছিলো","audioUrl":"wbw/020_079_001.mp3","charTypeName":"word"},{"id":63847,"position":2,"arabic":"فِرْعَوْنُ","translation":"ফিরআউন","audioUrl":"wbw/020_079_002.mp3","charTypeName":"word"},{"id":63848,"position":3,"arabic":"قَوْمَهُۥ","translation":"তার জাতিকে","audioUrl":"wbw/020_079_003.mp3","charTypeName":"word"},{"id":63849,"position":4,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/020_079_004.mp3","charTypeName":"word"},{"id":63850,"position":5,"arabic":"هَدَىٰ","translation":"সৎপথ দেখিয়েছিলো","audioUrl":"wbw/020_079_005.mp3","charTypeName":"word"},{"id":63851,"position":6,"arabic":"٧٩","translation":"(৭৯)","audioUrl":null,"charTypeName":"end"}]},{"number":80,"arabic":"يَٰبَنِىٓ إِسْرَٰٓءِيلَ قَدْ أَنجَيْنَٰكُم مِّنْ عَدُوِّكُمْ وَوَٰعَدْنَٰكُمْ جَانِبَ ٱلطُّورِ ٱلْأَيْمَنَ وَنَزَّلْنَا عَلَيْكُمُ ٱلْمَنَّ وَٱلسَّلْوَىٰ","translation":"O children of Israel! [Thus] We saved you from your enemy, and [then] We made a covenant with you on the right-hand slope of Mount Sinai, and repeatedly sent down manna and quails unto you, [saying,]","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2428.mp3","surahId":20,"words":[{"id":64065,"position":1,"arabic":"يَـٰبَنِىٓ","translation":"হে সন্তানগণ","audioUrl":"wbw/020_080_001.mp3","charTypeName":"word"},{"id":64066,"position":2,"arabic":"إِسْرَٰٓءِيلَ","translation":"ইসরাঈলের","audioUrl":"wbw/020_080_002.mp3","charTypeName":"word"},{"id":64067,"position":3,"arabic":"قَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/020_080_003.mp3","charTypeName":"word"},{"id":64068,"position":4,"arabic":"أَنجَيْنَـٰكُم","translation":"তোমাদেরকে আমরা উদ্ধার করেছি","audioUrl":"wbw/020_080_004.mp3","charTypeName":"word"},{"id":64069,"position":5,"arabic":"مِّنْ","translation":"থেকে","audioUrl":"wbw/020_080_005.mp3","charTypeName":"word"},{"id":64070,"position":6,"arabic":"عَدُوِّكُمْ","translation":"তোমাদের শত্রু","audioUrl":"wbw/020_080_006.mp3","charTypeName":"word"},{"id":64071,"position":7,"arabic":"وَوَٰعَدْنَـٰكُمْ","translation":"ও তোমাদেরকে আমরা ( উপস্থিতির) প্রতিশ্রুতি দিয়েছি","audioUrl":"wbw/020_080_007.mp3","charTypeName":"word"},{"id":64072,"position":8,"arabic":"جَانِبَ","translation":"পাশে","audioUrl":"wbw/020_080_008.mp3","charTypeName":"word"},{"id":64073,"position":9,"arabic":"ٱلطُّورِ","translation":"তূর পাহাড়ের","audioUrl":"wbw/020_080_009.mp3","charTypeName":"word"},{"id":64074,"position":10,"arabic":"ٱلْأَيْمَنَ","translation":"ডানদিকের","audioUrl":"wbw/020_080_010.mp3","charTypeName":"word"},{"id":64075,"position":11,"arabic":"وَنَزَّلْنَا","translation":"এবং আমরা পাঠিয়েছি","audioUrl":"wbw/020_080_011.mp3","charTypeName":"word"},{"id":64076,"position":12,"arabic":"عَلَيْكُمُ","translation":"তোমাদের উপর","audioUrl":"wbw/020_080_012.mp3","charTypeName":"word"},{"id":64077,"position":13,"arabic":"ٱلْمَنَّ","translation":"মান্না","audioUrl":"wbw/020_080_013.mp3","charTypeName":"word"},{"id":64078,"position":14,"arabic":"وَٱلسَّلْوَىٰ","translation":"ও সালওয়া","audioUrl":"wbw/020_080_014.mp3","charTypeName":"word"},{"id":64079,"position":15,"arabic":"٨٠","translation":"(৮০)","audioUrl":null,"charTypeName":"end"}]},{"number":81,"arabic":"كُلُوا۟ مِن طَيِّبَٰتِ مَا رَزَقْنَٰكُمْ وَلَا تَطْغَوْا۟ فِيهِ فَيَحِلَّ عَلَيْكُمْ غَضَبِى ۖ وَمَن يَحْلِلْ عَلَيْهِ غَضَبِى فَقَدْ هَوَىٰ","translation":"\"Partake of the good things which We have provided for you as sustenance, but do not transgress therein the bounds of equity lest My condemnation fall upon you: for, he upon whom My condemnation falls has indeed thrown himself into utter ruin!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2429.mp3","surahId":20,"words":[{"id":64639,"position":1,"arabic":"كُلُوا۟","translation":"তোমরা খাও","audioUrl":"wbw/020_081_001.mp3","charTypeName":"word"},{"id":64640,"position":2,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/020_081_002.mp3","charTypeName":"word"},{"id":64641,"position":3,"arabic":"طَيِّبَـٰتِ","translation":"পবিত্র বস্তুসমূহ","audioUrl":"wbw/020_081_003.mp3","charTypeName":"word"},{"id":64642,"position":4,"arabic":"مَا","translation":"যা","audioUrl":"wbw/020_081_004.mp3","charTypeName":"word"},{"id":64643,"position":5,"arabic":"رَزَقْنَـٰكُمْ","translation":"তোমাদেরকে আমরা জীবনোপকরণ দিয়েছি","audioUrl":"wbw/020_081_005.mp3","charTypeName":"word"},{"id":64644,"position":6,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/020_081_006.mp3","charTypeName":"word"},{"id":64645,"position":7,"arabic":"تَطْغَوْا۟","translation":"সীমালঙ্ঘন করো","audioUrl":"wbw/020_081_007.mp3","charTypeName":"word"},{"id":64646,"position":8,"arabic":"فِيهِ","translation":"এর মধ্যে","audioUrl":"wbw/020_081_008.mp3","charTypeName":"word"},{"id":64647,"position":9,"arabic":"فَيَحِلَّ","translation":"তাহ'লে অবধারিত হবে","audioUrl":"wbw/020_081_009.mp3","charTypeName":"word"},{"id":64648,"position":10,"arabic":"عَلَيْكُمْ","translation":"তোমাদের উপর","audioUrl":"wbw/020_081_010.mp3","charTypeName":"word"},{"id":64649,"position":11,"arabic":"غَضَبِى ۖ","translation":"আমার রাগ","audioUrl":"wbw/020_081_011.mp3","charTypeName":"word"},{"id":64651,"position":12,"arabic":"وَمَن","translation":"এবং যার (এমন)","audioUrl":"wbw/020_081_013.mp3","charTypeName":"word"},{"id":64652,"position":13,"arabic":"يَحْلِلْ","translation":"অবধারিত হবে","audioUrl":"wbw/020_081_014.mp3","charTypeName":"word"},{"id":64653,"position":14,"arabic":"عَلَيْهِ","translation":"তার উপর","audioUrl":"wbw/020_081_015.mp3","charTypeName":"word"},{"id":64654,"position":15,"arabic":"غَضَبِى","translation":"আমার রাগ","audioUrl":"wbw/020_081_016.mp3","charTypeName":"word"},{"id":64655,"position":16,"arabic":"فَقَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/020_081_017.mp3","charTypeName":"word"},{"id":64656,"position":17,"arabic":"هَوَىٰ","translation":"সে ধ্বংস হয়ে যাবে","audioUrl":"wbw/020_081_018.mp3","charTypeName":"word"},{"id":64657,"position":18,"arabic":"٨١","translation":"(৮১)","audioUrl":null,"charTypeName":"end"}]},{"number":82,"arabic":"وَإِنِّى لَغَفَّارٌۭ لِّمَن تَابَ وَءَامَنَ وَعَمِلَ صَٰلِحًۭا ثُمَّ ٱهْتَدَىٰ","translation":"Yet withal, behold, I forgive all sins unto any who repents and attains to faith and does righteous deeds, and thereafter keeps to the right path.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2430.mp3","surahId":20,"words":[{"id":65156,"position":1,"arabic":"وَإِنِّى","translation":"এবং আমি নিশ্চয়ই","audioUrl":"wbw/020_082_001.mp3","charTypeName":"word"},{"id":65157,"position":2,"arabic":"لَغَفَّارٌۭ","translation":"অবশ্যই ক্ষমাশীল","audioUrl":"wbw/020_082_002.mp3","charTypeName":"word"},{"id":65158,"position":3,"arabic":"لِّمَن","translation":"(তার) জন্য যে","audioUrl":"wbw/020_082_003.mp3","charTypeName":"word"},{"id":65159,"position":4,"arabic":"تَابَ","translation":"তওবা করলো","audioUrl":"wbw/020_082_004.mp3","charTypeName":"word"},{"id":65160,"position":5,"arabic":"وَءَامَنَ","translation":"ও ঈমান আনলো","audioUrl":"wbw/020_082_005.mp3","charTypeName":"word"},{"id":65161,"position":6,"arabic":"وَعَمِلَ","translation":"এবং কাজ করলো","audioUrl":"wbw/020_082_006.mp3","charTypeName":"word"},{"id":65162,"position":7,"arabic":"صَـٰلِحًۭا","translation":"সৎ","audioUrl":"wbw/020_082_007.mp3","charTypeName":"word"},{"id":65163,"position":8,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/020_082_008.mp3","charTypeName":"word"},{"id":65164,"position":9,"arabic":"ٱهْتَدَىٰ","translation":"সৎপথে অবিচলিত থাকলো","audioUrl":"wbw/020_082_009.mp3","charTypeName":"word"},{"id":65165,"position":10,"arabic":"٨٢","translation":"(৮২)","audioUrl":null,"charTypeName":"end"}]},{"number":83,"arabic":"۞ وَمَآ أَعْجَلَكَ عَن قَوْمِكَ يَٰمُوسَىٰ","translation":"[AND GOD SAID:] \"Now what has caused thee, O Moses, to leave thy people behind in so great a haste?\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2431.mp3","surahId":20,"words":[{"id":65306,"position":1,"arabic":"۞ وَمَآ","translation":"\"এবং কিসে","audioUrl":"wbw/020_083_002.mp3","charTypeName":"word"},{"id":65307,"position":2,"arabic":"أَعْجَلَكَ","translation":"তোমাকে তাড়াহুড়া করালো","audioUrl":"wbw/020_083_003.mp3","charTypeName":"word"},{"id":65308,"position":3,"arabic":"عَن","translation":"থেকে","audioUrl":"wbw/020_083_004.mp3","charTypeName":"word"},{"id":65309,"position":4,"arabic":"قَوْمِكَ","translation":"তোমার জাতি","audioUrl":"wbw/020_083_005.mp3","charTypeName":"word"},{"id":65310,"position":5,"arabic":"يَـٰمُوسَىٰ","translation":"হে মূসা\"","audioUrl":"wbw/020_083_006.mp3","charTypeName":"word"},{"id":65311,"position":6,"arabic":"٨٣","translation":"(৮৩)","audioUrl":null,"charTypeName":"end"}]},{"number":84,"arabic":"قَالَ هُمْ أُو۟لَآءِ عَلَىٰٓ أَثَرِى وَعَجِلْتُ إِلَيْكَ رَبِّ لِتَرْضَىٰ","translation":"He answered: \"They are treading in my footsteps while I have hastened unto Thee, O my Sustainer, so that Thou might be well-pleased [with me].\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2432.mp3","surahId":20,"words":[{"id":65688,"position":1,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/020_084_001.mp3","charTypeName":"word"},{"id":65689,"position":2,"arabic":"هُمْ","translation":"\"তারা","audioUrl":"wbw/020_084_002.mp3","charTypeName":"word"},{"id":65690,"position":3,"arabic":"أُو۟لَآءِ","translation":"ঐ তো","audioUrl":"wbw/020_084_003.mp3","charTypeName":"word"},{"id":65691,"position":4,"arabic":"عَلَىٰٓ","translation":"উপর","audioUrl":"wbw/020_084_004.mp3","charTypeName":"word"},{"id":65692,"position":5,"arabic":"أَثَرِى","translation":"আমার চিহ্নের","audioUrl":"wbw/020_084_005.mp3","charTypeName":"word"},{"id":65693,"position":6,"arabic":"وَعَجِلْتُ","translation":"এবং আমি তাড়াহুড়া করেছি","audioUrl":"wbw/020_084_006.mp3","charTypeName":"word"},{"id":65694,"position":7,"arabic":"إِلَيْكَ","translation":"তোমার দিকে","audioUrl":"wbw/020_084_007.mp3","charTypeName":"word"},{"id":65695,"position":8,"arabic":"رَبِّ","translation":"হে আমার রব","audioUrl":"wbw/020_084_008.mp3","charTypeName":"word"},{"id":65696,"position":9,"arabic":"لِتَرْضَىٰ","translation":"যেন তুমি সন্তুষ্ট হও\"","audioUrl":"wbw/020_084_009.mp3","charTypeName":"word"},{"id":65697,"position":10,"arabic":"٨٤","translation":"(৮৪)","audioUrl":null,"charTypeName":"end"}]},{"number":85,"arabic":"قَالَ فَإِنَّا قَدْ فَتَنَّا قَوْمَكَ مِنۢ بَعْدِكَ وَأَضَلَّهُمُ ٱلسَّامِرِىُّ","translation":"Said He: \"Then [know that], verily, in thy absence We have put thy people to a test, and the Samaritan has led them astray.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2433.mp3","surahId":20,"words":[{"id":66239,"position":1,"arabic":"قَالَ","translation":"(আল্লাহ) বললেন","audioUrl":"wbw/020_085_001.mp3","charTypeName":"word"},{"id":66240,"position":2,"arabic":"فَإِنَّا","translation":"\"অতঃপর নিশ্চয়ই আমরা","audioUrl":"wbw/020_085_002.mp3","charTypeName":"word"},{"id":66241,"position":3,"arabic":"قَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/020_085_003.mp3","charTypeName":"word"},{"id":66242,"position":4,"arabic":"فَتَنَّا","translation":"আমরা পরীক্ষায় ফেলেছি","audioUrl":"wbw/020_085_004.mp3","charTypeName":"word"},{"id":66243,"position":5,"arabic":"قَوْمَكَ","translation":"তোমার জাতিকে","audioUrl":"wbw/020_085_005.mp3","charTypeName":"word"},{"id":66244,"position":6,"arabic":"مِنۢ","translation":"থেকে","audioUrl":"wbw/020_085_006.mp3","charTypeName":"word"},{"id":66245,"position":7,"arabic":"بَعْدِكَ","translation":"তোমার পর","audioUrl":"wbw/020_085_007.mp3","charTypeName":"word"},{"id":66246,"position":8,"arabic":"وَأَضَلَّهُمُ","translation":"এবং তাদেরকে পথভ্রষ্ট করেছে","audioUrl":"wbw/020_085_008.mp3","charTypeName":"word"},{"id":66247,"position":9,"arabic":"ٱلسَّامِرِىُّ","translation":"সামেরী\"","audioUrl":"wbw/020_085_009.mp3","charTypeName":"word"},{"id":66248,"position":10,"arabic":"٨٥","translation":"(৮৫)","audioUrl":null,"charTypeName":"end"}]},{"number":86,"arabic":"فَرَجَعَ مُوسَىٰٓ إِلَىٰ قَوْمِهِۦ غَضْبَٰنَ أَسِفًۭا ۚ قَالَ يَٰقَوْمِ أَلَمْ يَعِدْكُمْ رَبُّكُمْ وَعْدًا حَسَنًا ۚ أَفَطَالَ عَلَيْكُمُ ٱلْعَهْدُ أَمْ أَرَدتُّمْ أَن يَحِلَّ عَلَيْكُمْ غَضَبٌۭ مِّن رَّبِّكُمْ فَأَخْلَفْتُم مَّوْعِدِى","translation":"Thereupon Moses returned to his people full of wrath and sorrow, [and] exclaimed: \"O my people! Did not your Sustainer hold out [many] a goodly promise to you? bid, then, [the fulfilment of] this promise seem to you too long in coming? Or are you, perchance, determined to see your Sustainer's condemnation fall upon you, and so you broke your promise to me?\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2434.mp3","surahId":20,"words":[{"id":66522,"position":1,"arabic":"فَرَجَعَ","translation":"অতঃপর ফিরে আসলো","audioUrl":"wbw/020_086_001.mp3","charTypeName":"word"},{"id":66523,"position":2,"arabic":"مُوسَىٰٓ","translation":"মূসা","audioUrl":"wbw/020_086_002.mp3","charTypeName":"word"},{"id":66524,"position":3,"arabic":"إِلَىٰ","translation":"কাছে","audioUrl":"wbw/020_086_003.mp3","charTypeName":"word"},{"id":66525,"position":4,"arabic":"قَوْمِهِۦ","translation":"তার লোকদের","audioUrl":"wbw/020_086_004.mp3","charTypeName":"word"},{"id":66526,"position":5,"arabic":"غَضْبَـٰنَ","translation":"রাগান্বিত হয়ে","audioUrl":"wbw/020_086_005.mp3","charTypeName":"word"},{"id":66527,"position":6,"arabi