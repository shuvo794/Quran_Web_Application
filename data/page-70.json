ily, God is much-forgiving, forbearing.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/448.mp3","surahId":3,"words":[{"id":81095,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়","audioUrl":"wbw/003_155_001.mp3","charTypeName":"word"},{"id":81096,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/003_155_002.mp3","charTypeName":"word"},{"id":81097,"position":3,"arabic":"تَوَلَّوْا۟","translation":"পিঠটান দিয়েছে","audioUrl":"wbw/003_155_003.mp3","charTypeName":"word"},{"id":81098,"position":4,"arabic":"مِنكُمْ","translation":"তোমাদের মধ্য হতে","audioUrl":"wbw/003_155_004.mp3","charTypeName":"word"},{"id":81099,"position":5,"arabic":"يَوْمَ","translation":"দিনে","audioUrl":"wbw/003_155_005.mp3","charTypeName":"word"},{"id":81100,"position":6,"arabic":"ٱلْتَقَى","translation":"মুকাবিলার","audioUrl":"wbw/003_155_006.mp3","charTypeName":"word"},{"id":81101,"position":7,"arabic":"ٱلْجَمْعَانِ","translation":"দুই দলের","audioUrl":"wbw/003_155_007.mp3","charTypeName":"word"},{"id":81102,"position":8,"arabic":"إِنَّمَا","translation":"মূলত","audioUrl":"wbw/003_155_008.mp3","charTypeName":"word"},{"id":81103,"position":9,"arabic":"ٱسْتَزَلَّهُمُ","translation":"তাদেরকে পদস্খলন ঘটিয়েছিল","audioUrl":"wbw/003_155_009.mp3","charTypeName":"word"},{"id":81104,"position":10,"arabic":"ٱلشَّيْطَـٰنُ","translation":"শয়তান","audioUrl":"wbw/003_155_010.mp3","charTypeName":"word"},{"id":81105,"position":11,"arabic":"بِبَعْضِ","translation":"কিছু জিনিসের কারণে","audioUrl":"wbw/003_155_011.mp3","charTypeName":"word"},{"id":81106,"position":12,"arabic":"مَا","translation":"যা","audioUrl":"wbw/003_155_012.mp3","charTypeName":"word"},{"id":81107,"position":13,"arabic":"كَسَبُوا۟ ۖ","translation":"তারা উপার্জন করেছিল","audioUrl":"wbw/003_155_013.mp3","charTypeName":"word"},{"id":81109,"position":14,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়","audioUrl":"wbw/003_155_015.mp3","charTypeName":"word"},{"id":81110,"position":15,"arabic":"عَفَا","translation