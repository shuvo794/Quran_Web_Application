{"id":420,"ayahs":[{"number":16,"arabic":"قُل لَّن يَنفَعَكُمُ ٱلْفِرَارُ إِن فَرَرْتُم مِّنَ ٱلْمَوْتِ أَوِ ٱلْقَتْلِ وَإِذًۭا لَّا تُمَتَّعُونَ إِلَّا قَلِيلًۭا","translation":"Say: “Whether you flee from [natural] death or from being slain [in battle], flight will not profit you - for, however you fare, you are not [allowed] to enjoy life for more than a little while!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3549.mp3","surahId":33,"words":[{"id":18868,"position":1,"arabic":"قُل","translation":"বলো","audioUrl":"wbw/033_016_001.mp3","charTypeName":"word"},{"id":18869,"position":2,"arabic":"لَّن","translation":"\"কখনও না","audioUrl":"wbw/033_016_002.mp3","charTypeName":"word"},{"id":18870,"position":3,"arabic":"يَنفَعَكُمُ","translation":"উপকার দিবে তোমাদের","audioUrl":"wbw/033_016_003.mp3","charTypeName":"word"},{"id":18871,"position":4,"arabic":"ٱلْفِرَارُ","translation":"পালিয়ে যাওয়া","audioUrl":"wbw/033_016_004.mp3","charTypeName":"word"},{"id":18872,"position":5,"arabic":"إِن","translation":"যদিও","audioUrl":"wbw/033_016_005.mp3","charTypeName":"word"},{"id":18873,"position":6,"arabic":"فَرَرْتُم","translation":"তোমরা পালাও","audioUrl":"wbw/033_016_006.mp3","charTypeName":"word"},{"id":18874,"position":7,"arabic":"مِّنَ","translation":"হ'তে","audioUrl":"wbw/033_016_007.mp3","charTypeName":"word"},{"id":18875,"position":8,"arabic":"ٱلْمَوْتِ","translation":"মৃত্যু","audioUrl":"wbw/033_016_008.mp3","charTypeName":"word"},{"id":18876,"position":9,"arabic":"أَوِ","translation":"অথবা","audioUrl":"wbw/033_016_009.mp3","charTypeName":"word"},{"id":18877,"position":10,"arabic":"ٱلْقَتْلِ","translation":"হত্যা (হ'তে)","audioUrl":"wbw/033_016_010.mp3","charTypeName":"word"},{"id":18878,"position":11,"arabic":"وَإِذًۭا","translation":"এবং তখন","audioUrl":"wbw/033_016_011.mp3","charTypeName":"word"},{"id":18879,"position":12,"arabic":"لَّا","translation":"না","audioUrl":"wbw/033_016_012.mp3","charTypeName":"word"},{"id":18880,"position":13,"arabic":"تُمَتَّعُونَ","translation":"তোমাদের ভোগ করতে দেয়া হবে","audioUrl":"wbw/033_016_013.mp3","charTypeName":"word"},{"id":18881,"position":14,"arabic":"إِلَّا","translation":"কিন্তু","audioUrl":"wbw/033_016_014.mp3","charTypeName":"word"},{"id":18882,"position":15,"arabic":"قَلِيلًۭا","translation":"অতি সামান্য\"","audioUrl":"wbw/033_016_015.mp3","charTypeName":"word"},{"id":18883,"position":16,"arabic":"١٦","translation":"(১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":17,"arabic":"قُلْ مَن ذَا ٱلَّذِى يَعْصِمُكُم مِّنَ ٱللَّهِ إِنْ أَرَادَ بِكُمْ سُوٓءًا أَوْ أَرَادَ بِكُمْ رَحْمَةًۭ ۚ وَلَا يَجِدُونَ لَهُم مِّن دُونِ ٱللَّهِ وَلِيًّۭا وَلَا نَصِيرًۭا","translation":"Say: “Who is there that could keep you away from God if it be His will to harm you, or if it be His will to show you mercy?” For, [do they not know that] besides God they can find none to protect them, and none to bring them succour?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3550.mp3","surahId":33,"words":[{"id":19971,"position":1,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/033_017_001.mp3","charTypeName":"word"},{"id":19972,"position":2,"arabic":"مَن","translation":"\"কে","audioUrl":"wbw/033_017_002.mp3","charTypeName":"word"},{"id":19973,"position":3,"arabic":"ذَا","translation":"এমন","audioUrl":"wbw/033_017_003.mp3","charTypeName":"word"},{"id":19974,"position":4,"arabic":"ٱلَّذِى","translation":"যে","audioUrl":"wbw/033_017_004.mp3","charTypeName":"word"},{"id":19975,"position":5,"arabic":"يَعْصِمُكُم","translation":"রক্ষা করবে তোমাদেরকে","audioUrl":"wbw/033_017_005.mp3","charTypeName":"word"},{"id":19976,"position":6,"arabic":"مِّنَ","translation":"হ'তে","audioUrl":"wbw/033_017_006.mp3","charTypeName":"word"},{"id":19977,"position":7,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌","audioUrl":"wbw/033_017_007.mp3","charTypeName":"word"},{"id":19978,"position":8,"arabic":"إِنْ","translation":"যদি","audioUrl":"wbw/033_017_008.mp3","charTypeName":"word"},{"id":19979,"p