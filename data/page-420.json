":"wbw/033_017_025.mp3","charTypeName":"word"},{"id":19996,"position":25,"arabic":"١٧","translation":"(১৭)","audioUrl":null,"charTypeName":"end"}]},{"number":18,"arabic":"۞ قَدْ يَعْلَمُ ٱللَّهُ ٱلْمُعَوِّقِينَ مِنكُمْ وَٱلْقَآئِلِينَ لِإِخْوَٰنِهِمْ هَلُمَّ إِلَيْنَا ۖ وَلَا يَأْتُونَ ٱلْبَأْسَ إِلَّا قَلِيلًا","translation":"God is indeed aware of those of you who would divert others [from fighting in His cause], as well as of those who say to their brethren, “Come hither to us [and face the enemy]!” — The while they [themselves] join battle but seldom,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3551.mp3","surahId":33,"words":[{"id":21000,"position":1,"arabic":"۞ قَدْ","translation":"অবশ্যই","audioUrl":"wbw/033_018_002.mp3","charTypeName":"word"},{"id":21001,"position":2,"arabic":"يَعْلَمُ","translation":"জানেন","audioUrl":"wbw/033_018_003.mp3","charTypeName":"word"},{"id":21002,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/033_018_004.mp3","charTypeName":"word"},{"id":21003,"position":4,"arabic":"ٱلْمُعَوِّقِينَ","translation":"বাধাদানকারীদেরকে","audioUrl":"wbw/033_018_005.mp3","charTypeName":"word"},{"id":21004,"position":5,"arabic":"مِنكُمْ","translation":"মধ্য হ'তে তোমাদের","audioUrl":"wbw/033_018_006.mp3","charTypeName":"word"},{"id":21005,"position":6,"arabic":"وَٱلْقَآئِلِينَ","translation":"কথকদেরকে (যারা বলে)","audioUrl":"wbw/033_018_007.mp3","charTypeName":"word"},{"id":21006,"position":7,"arabic":"لِإِخْوَٰنِهِمْ","translation":"উদ্দেশ্যে ভাইদের তাদের","audioUrl":"wbw/033_018_008.mp3","charTypeName":"word"},{"id":21007,"position":8,"arabic":"هَلُمَّ","translation":"\"চলে এসো","audioUrl":"wbw/033_018_009.mp3","charTypeName":"word"},{"id":21008,"position":9,"arabic":"إِلَيْنَا ۖ","translation":"দিকে আমাদের\"","audioUrl":"wbw/033_018_010.mp3","charTypeName":"word"},{"id":21010,"position":10,"arabic":"وَلَا","translation":"কিন্তু না","audioUrl":"wbw/033_018_012.mp3","charTypeName":"word"},{"id":21011,"position":11,"arabic":"يَأْتُونَ","translation":"তারা আসে","audioUrl":"wbw/033_018_013.mp3","charTypeName":"word"},{"id":21012,"position":12,"arabic":"ٱلْبَأْسَ","translation":"যুদ্ধে","audioUrl":"wbw/033_018_014.mp3","charTypeName":"word"},{"id":21013,"position":13,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/033_018_015.mp3","charTypeName":"word"},{"id":21014,"position":14,"arabic":"قَلِيلًا","translation":"অল্পই","audioUrl":"wbw/033_018_016.mp3","charTypeName":"word"},{"id":21015,"position":15,"arabic":"١٨","translation":"(১৮)","audioUrl":null,"charTypeName":"end"}]},{"number":19,"arabic":"أَشِحَّةً عَلَيْكُمْ ۖ فَإِذَا جَآءَ ٱلْخَوْفُ رَأَيْتَهُمْ يَنظُرُونَ إِلَيْكَ تَدُورُ أَعْيُنُهُمْ كَٱلَّذِى يُغْشَىٰ عَلَيْهِ مِنَ ٱلْمَوْتِ ۖ فَإِذَا ذَهَبَ ٱلْخَوْفُ سَلَقُوكُم بِأَلْسِنَةٍ حِدَادٍ أَشِحَّةً عَلَى ٱلْخَيْرِ ۚ أُو۟لَٰٓئِكَ لَمْ يُؤْمِنُوا۟ فَأَحْبَطَ ٱللَّهُ أَعْمَٰلَهُمْ ۚ وَكَانَ ذَٰلِكَ عَلَى ٱللَّهِ يَسِيرًۭا","translation":"begrudging you all help. But then, when danger threatens, thou canst see them looking to thee [for help, O Prophet], their eyes rolling [in terror] like [the eyes of] one who is overshadowed by death: yet as soon as the danger has passed, they will assail you [believers] with sharp tongues, begrudging you all that is good! [People like] these have never known faith - and therefore God will cause all their works to come to nought: for this is indeed easy for God.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3552.mp3","surahId":33,"words":[{"id":22129,"position":1,"arabic":"أَشِحَّةً","translation":"কৃপণতাবশত","audioUrl":"wbw/033_019_001.mp3","charTypeName":"word"},{"id":22130,"position":2,"arabic":"عَلَيْكُمْ ۖ","translation":"ব্যাপারে তোমাদের","audioUrl":"wbw/033_019_002.mp3","charTypeName":"word"},{"id":22132,"position":3,"arabic":"فَإِذَا","translation":"অতঃপর যখন","audioUrl":"wbw/033_019_004.mp3","charTypeName":"word"},{"id":22133,"position":4,"arabic":"جَآءَ","translation":"আসে","audioUrl":"wbw/033_019_005.mp3","charTypeName":"word"},{"id":22134,"position":5,"arabic":"ٱلْخَوْفُ","translation":"ভয় (বিপদ)","audioUrl":"wbw/033_019_006.mp3","charTypeName":"word"},{"id":22135,"position":6,"arabic":"رَأَيْتَهُمْ","translation":"তুমি দেখবে তাদেরকে","audioUrl":"wbw/033_019_007.mp3","charTypeName":"word"},{"id":22136,"position":7,"arabic":"يَنظُرُونَ","translation":"তারা তাকাচ্ছে","audioUrl":"wbw/033_019_008.mp3","charTypeName":"word"},{"id":22137,"position":8,"arabic":"إِلَيْكَ","translation":"প্রতি তোমার","audioUrl":"wbw/033_019_009.mp3","charTypeName":"word"},{"id":22138,"position":9,"arabic":"تَدُورُ","translation":"ঘুরছে","audioUrl":"wbw/033_019_010.mp3","charTypeName":"word"},{"id":22139,"position":10,"arabic":"أَعْيُنُهُمْ","translation":"চোখগুলো তাদের","audioUrl":"wbw/033_019_011.mp3","charTypeName":"word"},{"id":22140,"position":11,"arabic":"كَٱلَّذِى","translation":"(তার) মতো যাকে","audioUrl":"wbw/033_019_012.mp3","charTypeName":"word"},{"id":22141,"position":12,"arabic":"يُغْشَىٰ","translation":"অচেতনতা চেপে বসেছে","audioUrl":"wbw/033_019_013.mp3","charTypeName":"word"},{"id":22142,"position":13,"arabic":"عَلَيْهِ","translation":"উপর তার","audioUrl":"wbw/033_019_014.mp3","charTypeName":"word"},{"id":22143,"position":14,"arabic":"مِنَ","translation":"ভয়ে","audioUrl":"wbw/033_019_015.mp3","charTypeName":"word"},{"id":22144,"position":15,"arabic":"ٱلْمَوْتِ ۖ","translation":"মৃত্যু","audioUrl":"wbw/033_019_016.mp3","charTypeName":"word"},{"id":22146,"position":16,"arabic":"فَإِذَا","translation":"কিন্তু যখন","audioUrl":"wbw/033_019_018.mp3","charTypeName":"word"},{"id":22147,"position":17,"arabic":"ذَهَبَ","translation":"চলে যায়","audioUrl":"wbw/033_019_019.mp3","charTypeName":"word"},{"id":22148,"position":18,"arabic":"ٱلْخَوْفُ","translation":"ভয় (বিপদ)","audioUrl":"wbw/033_019_020.mp3","charTypeName":"word"},{"id":22149,"position":19,"arabic":"سَلَقُوكُم","translation":"শীঘ্রই সাথে মিলবে তোমাদের","audioUrl":"wbw/033_019_021.mp3","charTypeName":"word"},{"id":22150,"position":20,"arabic":"بِأَلْسِنَةٍ","translation":"নিয়ে ভাষা","audioUrl":"wbw/033_019_022.mp3","charTypeName":"word"},{"id":22151,"position":21,"arabic":"حِدَادٍ","translation":"তীক্ষ্ণ","audioUrl":"wbw/033_019_023.mp3","charTypeName":"word"},{"id":22152,"position":22,"arabic":"أَشِحَّةً","translation":"লোভবশত","audioUrl":"wbw/033_019_024.mp3","charTypeName":"word"},{"id":22153,"position":23,"arabic":"عَلَى","translation":"ক্ষেত্রে","audioUrl":"wbw/033_019_025.mp3","charTypeName":"word"},{"id":22154,"position":24,"arabic":"ٱلْخَيْرِ ۚ","translation":"ধনমালের (বা স্বার্থ সুযোগের)","audioUrl":"wbw/033_019_026.mp3","charTypeName":"word"},{"id":22156,"position":25,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐ সব (লোক)","audioUrl":"wbw/033_019_028.mp3","charTypeName":"word"},{"id":22157,"position":26,"arabic":"لَمْ","translation":"না","audioUrl":"wbw/033_019_029.mp3","charTypeName":"word"},{"id":22158,"position":27,"arabic":"يُؤْمِنُوا۟","translation":"ঈমান আনে","audioUrl":"wbw/033_019_030.mp3","charTypeName":"word"},{"id":22159,"position":28,"arabic":"فَأَحْبَطَ","translation":"সুতরাং নষ্ট করে দিয়েছেন","audioUrl":"wbw/033_019_031.mp3","charTypeName":"word"},{"id":22160,"position":29,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/033_019_032.mp3","charTypeName":"word"},{"id":22161,"position":30,"arabic":"أَعْمَـٰلَهُمْ ۚ","translation":"কর্মসমূহ তাদের","audioUrl":"wbw/033_019_033.mp3","charTypeName":"word"},{"id":22163,"position":31,"arabic":"وَكَانَ","translation":"এবং হলো","audioUrl":"wbw/033_019_035.mp3","charTypeName":"word"},{"id":22164,"position":32,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/033_019_036.mp3","charTypeName":"word"},{"id":22165,"position":33,"arabic":"عَلَى","translation":"পক্ষে","audioUrl":"wbw/033_019_037.mp3","charTypeName":"word"},{"id":22166,"position":34,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/033_019_038.mp3","charTypeName":"word"},{"id":22167,"position":35,"arabic":"يَسِيرًۭا","translation":"সহজ","audioUrl":"wbw/033_019_039.mp3","charTypeName":"word"},{"id":22168,"position":36,"arabic":"١٩","translation":"(১৯)","audioUrl":null,"charTypeName":"end"}]},{"number":20,"arabic":"يَحْسَبُونَ ٱلْأَحْزَابَ لَمْ يَذْهَبُوا۟ ۖ وَإِن يَأْتِ ٱلْأَحْزَابُ يَوَدُّوا۟ لَوْ أَنَّهُم بَادُونَ فِى ٱلْأَعْرَابِ يَسْـَٔلُونَ عَنْ أَنۢبَآئِكُمْ ۖ وَلَوْ كَانُوا۟ فِيكُم مَّا قَٰتَلُوٓا۟ إِلَّا قَلِيلًۭا","translation":"They think that the Confederates have not [really] withdrawn; and should the Confederates return, these [hypocrites] would prefer to be in the desert, among the bedouin, asking for news about you, [O believers, from far away;] and even were they to find themselves in your midst, they would but make a pretence at fighting [by your side].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3553.mp3","surahId":33,"words":[{"id":23189,"position":1,"arabic":"يَحْسَبُونَ","translation":"তারা মনে করে","audioUrl":"wbw/033_020_001.mp3","charTypeName":"word"},{"id":23190,"position":2,"arabic":"ٱلْأَحْزَابَ","translation":"(আক্রমণকারী) দলসমূহ","audioUrl":"wbw/033_020_002.mp3","charTypeName":"word"},{"id":23191,"position":3,"arabic":"لَمْ","translation":"না","audioUrl":"wbw/033_020_003.mp3","charTypeName":"word"},{"id":23192,"position":4,"arabic":"يَذْهَبُوا۟ ۖ","translation":"চলে যায়","audioUrl":"wbw/033_020_004.mp3","charTypeName":"word"},{"id":23194,"position":5,"arabic":"وَإِن","translation":"এবং যদি","audioUrl":"wbw/033_020_006.mp3","charTypeName":"word"},{"id":23195,"position":6,"arabic":"يَأْتِ","translation":"(ফিরে) আসে","audioUrl":"wbw/033_020_007.mp3","charTypeName":"word"},{"id":23196,"position":7,"arabic":"ٱلْأَحْزَابُ","translation":"দলসমূহ","audioUrl":"wbw/033_020_008.mp3","charTypeName":"word"},{"id":23197,"position":8,"arabic":"يَوَدُّوا۟","translation":"তারা কামনা করবে","audioUrl":"wbw/033_020_009.mp3","charTypeName":"word"},{"id":23198,"position":9,"arabic":"لَوْ","translation":"যদি","audioUrl":"wbw/033_020_010.mp3","charTypeName":"word"},{"id":23199,