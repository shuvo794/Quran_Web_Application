{"id":487,"ayahs":[{"number":32,"arabic":"وَمِنْ ءَايَٰتِهِ ٱلْجَوَارِ فِى ٱلْبَحْرِ كَٱلْأَعْلَٰمِ","translation":"And among His signs are the ships that sail like [floating] mountains through the seas:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4304.mp3","surahId":42,"words":[{"id":34647,"position":1,"arabic":"وَمِنْ","translation":"এবং মধ্যে রয়েছে","audioUrl":"wbw/042_032_001.mp3","charTypeName":"word"},{"id":34648,"position":2,"arabic":"ءَايَـٰتِهِ","translation":"তাঁর নিদর্শনাবলী","audioUrl":"wbw/042_032_002.mp3","charTypeName":"word"},{"id":34649,"position":3,"arabic":"ٱلْجَوَارِ","translation":"নৌযানসমূহ","audioUrl":"wbw/042_032_003.mp3","charTypeName":"word"},{"id":34650,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/042_032_004.mp3","charTypeName":"word"},{"id":34651,"position":5,"arabic":"ٱلْبَحْرِ","translation":"সাগরের","audioUrl":"wbw/042_032_005.mp3","charTypeName":"word"},{"id":34652,"position":6,"arabic":"كَٱلْأَعْلَـٰمِ","translation":"পাহাড়ের মতো","audioUrl":"wbw/042_032_006.mp3","charTypeName":"word"},{"id":34653,"position":7,"arabic":"٣٢","translation":"(৩২)","audioUrl":null,"charTypeName":"end"}]},{"number":33,"arabic":"إِن يَشَأْ يُسْكِنِ ٱلرِّيحَ فَيَظْلَلْنَ رَوَاكِدَ عَلَىٰ ظَهْرِهِۦٓ ۚ إِنَّ فِى ذَٰلِكَ لَءَايَٰتٍۢ لِّكُلِّ صَبَّارٍۢ شَكُورٍ","translation":"if He so wills, He stills the wind, and then they lie motion­less on the sea’s surface - [and] herein, behold, there are messages indeed for all who are wholly patient in adversity and deeply grateful [to God];","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4305.mp3","surahId":42,"words":[{"id":35258,"position":1,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/042_033_001.mp3","charTypeName":"word"},{"id":35259,"position":2,"arabic":"يَشَأْ","translation":"ইচ্ছে করেন তিনি","audioUrl":"wbw/042_033_002.mp3","charTypeName":"word"},{"id":35260,"position":3,"arabic":"يُسْكِنِ","translation":"(থামিয়ে দিবেন) ধরে রাখবেন","audioUrl":"wbw/042_033_003.mp3","charTypeName":"word"},{"id":35261,"position":4,"arabic":"ٱلرِّيحَ","translation":"বাতাসকে","audioUrl":"wbw/042_033_004.mp3","charTypeName":"word"},{"id":35262,"position":5,"arabic":"فَيَظْلَلْنَ","translation":"ফলে তা হয়ে যাবে","audioUrl":"wbw/042_033_005.mp3","charTypeName":"word"},{"id":35263,"position":6,"arabic":"رَوَاكِدَ","translation":"নিশ্চল","audioUrl":"wbw/042_033_006.mp3","charTypeName":"word"},{"id":35264,"position":7,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/042_033_007.mp3","charTypeName":"word"},{"id":35265,"position":8,"arabic":"ظَهْرِهِۦٓ ۚ","translation":"তার উপরিভাগের","audioUrl":"wbw/042_033_008.mp3","charTypeName":"word"},{"id":35267,"position":9,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/042_033_010.mp3","charTypeName":"word"},{"id":35268,"position":10,"arabic":"فِى","translation":"মধ্যে রয়েছে","audioUrl":"wbw/042_033_011.mp3","charTypeName":"word"},{"id":35269,"position":11,"arabic":"ذَٰلِكَ","translation":"এর","audioUrl":"wbw/042_033_012.mp3","charTypeName":"word"},{"id":35270,"position":12,"arabic":"لَـَٔايَـٰتٍۢ","translation":"অবশ্যই নিদর্শনাবলী","audioUrl":"wbw/042_033_013.mp3","charTypeName":"word"},{"id":35271,"position":13,"arabic":"لِّكُلِّ","translation":"জন্যে প্রত্যেক","audioUrl":"wbw/042_033_014.mp3","charTypeName":"word"},{"id":35272,"position":14,"arabic":"صَبَّارٍۢ","translation":"পূর্ণ ধৈর্য্যশীলের","audioUrl":"wbw/042_033_015.mp3","charTypeName":"word"},{"id":35273,"position":15,"arabic":"شَكُورٍ","translation":"কৃতজ্ঞতা প্রকাশকারীর","audioUrl":"wbw/042_033_016.mp3","charTypeName":"word"},{"id":35274,"position":16,"arabic":"٣٣","translation":"(৩৩)","audioUrl":null,"charTypeName":"end"}]},{"number":34,"arabic":"أَوْ يُوبِقْهُنَّ بِمَا كَسَبُوا۟ وَيَعْفُ عَن كَثِيرٍۢ","translation":"or else He may cause them to perish because of what they have wrought; and [withal,] He pardons much.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4306.mp3","surahId":42,"words":[{"id":36150,"position":1,"arabic":"أَوْ","translation":"বা","audioUrl":"wbw/042_034_001.mp3","charTypeName":"word"},{"id":36151,"position":2,"arabic":"يُوبِقْهُنَّ","translation":"সেগুলো (ডুবিয়ে দিতে) ধ্বংস করতে পারেন","audioUrl":"wbw/042_034_002.mp3","charTypeName":"word"},{"id":36152,"position":3,"arabic":"بِمَا","translation":"এ কারণে যা","audioUrl":"wbw/042_034_003.mp3","charTypeName":"word"},{"id":36153,"position":4,"arabic":"كَسَبُوا۟","translation":"তারা কামাই করেছে","audioUrl":"wbw/042_034_004.mp3","charTypeName":"word"},{"id":36154,"position":5,"arabic":"وَيَعْفُ","translation":"এ অবস্থায় যখন মাফ করেও দেন","audioUrl":"wbw/042_034_005.mp3","charTypeName":"word"},{"id":36155,"position":6,"arabic":"عَن","translation":"থেকে","audioUrl":"wbw/042_034_006.mp3","charTypeName":"word"},{"id":36156,"position":7,"arabic":"كَثِيرٍۢ","translation":"অনেক কিছু","audioUrl":"wbw/042_034_007.mp3","charTypeName":"word"},{"id":36157,"position":8,"arabic":"٣٤","translation":"(৩৪)","audioUrl":null,"charTypeName":"end"}]},{"number":35,"arabic":"وَيَعْلَمَ ٱلَّذِينَ يُجَٰدِلُونَ فِىٓ ءَايَٰتِنَا مَا لَهُم مِّن مَّحِيصٍۢ","translation":"And let them know, those who call Our mes­sages in question, that for them there is no escape.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4307.mp3","surahId":42,"words":[{"id":36945,"position":1,"arabic":"وَيَعْلَمَ","translation":"এবং (তখন) জানতে পারবে","audioUrl":"wbw/042_035_001.mp3","charTypeName":"word"},{"id":36946,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/042_035_002.mp3","charTypeName":"word"},{"id":36947,"position":3,"arabic":"يُجَـٰدِلُونَ","translation":"বিতর্ক করে","audioUrl":"wbw/042_035_003.mp3","charTypeName":"word"},{"id":36948,"position":4,"arabic":"فِىٓ","translation":"সম্পর্কে","audioUrl":"wbw/042_035_004.mp3","charTypeName":"word"},{"id":36949,"position":5,"arabic":"ءَايَـٰتِنَا","translation":"আমাদের নিদর্শনাবলী","audioUrl":"wbw/042_035_005.mp3","charTypeName":"word"},{"id":36950,"position":6,"arabic":"مَا","translation":"নেই","audioUrl":"wbw/042_035_006.mp3","charTypeName":"word"},{"id":36951,"position":7,"arabic":"لَهُم","translation":"তাদের জন্যে","audioUrl":"wbw/042_035_007.mp3","charTypeName":"word"},{"id":36952,"position":8,"arabic":"مِّن","translation":"কোনো","audioUrl":"wbw/042_035_008.mp3","charTypeName":"word"},{"id":36953,"position":9,"arabic":"مَّحِيصٍۢ","translation":"আশ্রয়স্থল","audioUrl":"wbw/042_035_009.mp3","charTypeName":"word"},{"id":36954,"position":10,"arabic":"٣٥","translation":"(৩৫)","audioUrl":null,"charTypeName":"end"}]},{"number":36,"arabic":"فَمَآ أُوتِيتُم مِّن شَىْءٍۢ فَمَتَٰعُ ٱلْحَيَوٰةِ ٱلدُّنْيَا ۖ وَمَا عِندَ ٱللَّهِ خَيْرٌۭ وَأَبْقَىٰ لِلَّذِينَ ءَامَنُوا۟ وَعَلَىٰ رَبِّهِمْ يَتَوَكَّلُونَ","translation":"AND [remember that] whatever you are given [now] is but for the [passing] enjoyment of life in this world - whereas that which is with God is far better and more enduring. [It shall be given] to all who attain to faith and in their Sustainer place their trust;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4308.mp3","surahId":42,"words":[{"id":38002,"position":1,"arabic":"فَمَآ","translation":"বস্তুতঃ যা","audioUrl":"wbw/042_036_001.mp3","charTypeName":"word"},{"id":38003,"position":2,"arabic":"أُوتِيتُم","translation":"তোমাদের দেওয়া হয়েছে","audioUrl":"wbw/042_036_002.mp3","charTypeName":"word"},{"id":38004,"position":3,"arabic":"مِّن","translation":"কোনো","audioUrl":"wbw/042_036_003.mp3","charTypeName":"word"},{"id":38005,"position":4,"arabic":"شَىْءٍۢ","translation":"কিছু","audioUrl":"wbw/042_036_004.mp3","charTypeName":"word"},{"id":38006,"position":5,"arabic":"فَمَتَـٰعُ","translation":"তা ভোগসামগ্রী","audioUrl":"wbw/042_036_005.mp3","charTypeName":"word"},{"id":38007,"position":6,"arabic":"ٱلْحَيَوٰةِ","translation":"জীবনের","audioUrl":"wbw/042_036_006.mp3","charTypeName":"word"},{"id":38008,"position":7,"arabic":"ٱلدُّنْيَا ۖ","translation":"পার্থিব","audioUrl":"wbw/042_036_007.mp3","charTypeName":"word"},{"id":38010,"position":8,"arabic":"وَمَا","translation":"এবং যা কিছূ","audioUrl":"wbw/042_036_009.mp3","charTypeName":"word"},{"id":38011,"position":9,"arabic":"عِندَ","translation":"কাছে আছে","audioUrl":"wbw/042_036_010.mp3","charTypeName":"word"},{"id":38012,"position":10,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/042_036_011.mp3","charTypeName":"word"},{"id":38013,"position":11,"arabic":"خَيْرٌۭ","translation":"(তাই) উত্তম","audioUrl":"wbw/042_036_012.mp3","charTypeName":"word"},{"id":38014,"position":12,"arabic":"وَأَبْقَىٰ","translation":"এবং অধিক স্থায়ী","audioUrl":"wbw/042_036_013.mp3","charTypeName":"word"},{"id":38015,"position":13,"arabic":"لِلَّذِينَ","translation":"(তাদের) জন্যে যারা","audioUrl":"wbw/042_036_014.mp3","charTypeName":"word"},{"id":38016,"position":14,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/042_036_015.mp3","charTypeName":"word"},{"id":38017,"position":15,"arabic":"وَعَلَىٰ","translation":"এবং উপর","audioUrl":"wbw/042_036_016.mp3","charTypeName":"word"},{"id":38018,"position":16,"arabic":"رَبِّهِمْ","translation":"তাদের রবের","audioUrl":"wbw/042_036_017.mp3","charTypeName":"word"},{"id":38019,"position":17,"arabic":"يَتَوَكَّلُونَ","translation":"তারা নির্ভর করে","audioUrl":"wbw/042_036_018.mp3","charTypeName":"word"},{"id":38020,"position":18,"arabic":"٣٦","translation":"(৩৬)","audioUrl":null,"charTypeName":"end"}]},{"number":37,"arabic":"وَٱلَّذِينَ يَجْتَنِبُونَ كَبَٰٓئِرَ ٱلْإِثْمِ وَٱلْفَوَٰحِشَ وَإِذَا مَا غَضِبُوا۟ هُمْ يَغْفِرُونَ","translation":"and who shun the more heinous sins and abominations; and who, whenever they are moved to anger, readily forgive;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4309.mp3","surahId":42,"words":[{"id":38674,"position":1,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/042_037_001.mp3","charTypeName":"word"},{"id":38675,"position":2,"arabic":"يَجْتَنِبُونَ","translation":"বেঁচে থাকে","audioUrl":"wbw/042_037_002.mp3","charTypeName":"word"},{"id":38676,"position":3,"arabic":"كَبَـٰٓئِرَ","translation":"গুরুতর","audioUrl":"wbw/042_037_003.mp3","charTypeName":"word"},{"id":38677,"position":4,"arabic":"ٱلْإِثْمِ","translation":"পাপ","audioUrl":"wbw/042_037_004.mp3","charTypeName":"word"},{"id":38678,"position":5,"arabic":"وَٱلْفَوَٰحِشَ","translation":"ও অশ্লীল কার্য সমূহ (হ'তে)","audioUrl":"wbw/042_037_005.mp3","charTypeName":"word"},{"id":38679,"position":6,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/042_037_006.mp3","charTypeName":"word"},{"id":38680,"position":7,"arabic":"مَا","translation":"যা","audioUrl":"wbw/042_037_007.mp3","charTypeName":"word"},{"id":38681,"position":8,"arabic":"غَضِبُوا۟","translation":"তারা রাগান্বিত হয়","audioUrl":"wbw/042_037_008.mp3","charTypeName":"word"},{"id":38682,"position":9,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/042_037_009.mp3","charTypeName":"word"},{"id":38683,"position":10,"arabic":"يَغْفِرُونَ","translation":"মাফ করে দেয়","audioUrl":"wbw/042_037_010.mp3","charTypeName":"word"},{"id":38684,"position":11,"arabic":"٣٧","translation":"(৩৭)","audioUrl":null,"charTypeName":"end"}]},{"number":38,"arabic":"وَٱلَّذِينَ ٱسْتَجَابُوا۟ لِرَبِّهِمْ وَأَقَامُوا۟ ٱلصَّلَوٰةَ وَأَمْرُهُمْ شُورَىٰ بَيْنَهُمْ وَمِمَّا رَزَقْنَٰهُمْ يُنفِقُونَ","translation":"and who respond to [the call of] their Sustainer and are constant in prayer; and whose rule [in all matters of common concern] is consultation among themselves; and who spend on others out of what We provide for them as sustenance;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4310.mp3","surahId":42,"words":[{"id":39554,"position":1,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/042_038_001.mp3","charTypeName":"word"},{"id":39555,"position":2,"arabic":"ٱسْتَجَابُوا۟","translation":"সাড়া দেয় ডাকে","audioUrl":"wbw/042_038_002.mp3","charTypeName":"word"},{"id":39556,"position":3,"arabic":"لِرَبِّهِمْ","transl