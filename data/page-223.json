{"id":223,"ayahs":[{"number":13,"arabic":"أَمْ يَقُولُونَ ٱفْتَرَىٰهُ ۖ قُلْ فَأْتُوا۟ بِعَشْرِ سُوَرٍۢ مِّثْلِهِۦ مُفْتَرَيَٰتٍۢ وَٱدْعُوا۟ مَنِ ٱسْتَطَعْتُم مِّن دُونِ ٱللَّهِ إِن كُنتُمْ صَٰدِقِينَ","translation":"and so they assert, \"[Muhammad himself] has invented this [Qur'an)!\" Say [unto them]: \"Produce, then, ten surahs of similar merit, invented [by yourselves], and [to this end] call to your aid whomever you can, other than, God, if what you say is true!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1486.mp3","surahId":11,"words":[{"id":15422,"position":1,"arabic":"أَمْ","translation":"অথবা","audioUrl":"wbw/011_013_001.mp3","charTypeName":"word"},{"id":15423,"position":2,"arabic":"يَقُولُونَ","translation":"তারা বলে","audioUrl":"wbw/011_013_002.mp3","charTypeName":"word"},{"id":15424,"position":3,"arabic":"افْتَرَاهُ ۖ","translation":"\"তা সে রচনা করেছে\"","audioUrl":"wbw/011_013_003.mp3","charTypeName":"word"},{"id":15426,"position":4,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/011_013_005.mp3","charTypeName":"word"},{"id":15427,"position":5,"arabic":"فَأْتُوا۟","translation":"\"তবে তোমরা আনো","audioUrl":"wbw/011_013_006.mp3","charTypeName":"word"},{"id":15428,"position":6,"arabic":"بِعَشْرِ","translation":"নিয়ে দশটি","audioUrl":"wbw/011_013_007.mp3","charTypeName":"word"},{"id":15429,"position":7,"arabic":"سُوَرٍۢ","translation":"সূরা","audioUrl":"wbw/011_013_008.mp3","charTypeName":"word"},{"id":15430,"position":8,"arabic":"مِّثْلِهِۦ","translation":"তার মতো","audioUrl":"wbw/011_013_009.mp3","charTypeName":"word"},{"id":15431,"position":9,"arabic":"مُفْتَرَيَـٰتٍۢ","translation":"স্বরচিত","audioUrl":"wbw/011_013_010.mp3","charTypeName":"word"},{"id":15432,"position":10,"arabic":"وَٱدْعُوا۟","translation":"এবং তোমরা ডাকো","audioUrl":"wbw/011_013_011.mp3","charTypeName":"word"},{"id":15433,"position":11,"arabic":"مَنِ","translation":"যাকে","audioUrl":"wbw/011_013_012.mp3","charTypeName":"word"},{"id":15434,"position":12,"arab