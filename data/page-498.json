.alafasy/4462.mp3","surahId":44,"words":[{"id":47096,"position":1,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/044_048_001.mp3","charTypeName":"word"},{"id":47097,"position":2,"arabic":"صُبُّوا۟","translation":"তোমরা ঢালো","audioUrl":"wbw/044_048_002.mp3","charTypeName":"word"},{"id":47098,"position":3,"arabic":"فَوْقَ","translation":"উপর","audioUrl":"wbw/044_048_003.mp3","charTypeName":"word"},{"id":47099,"position":4,"arabic":"رَأْسِهِۦ","translation":"তার মাথায়","audioUrl":"wbw/044_048_004.mp3","charTypeName":"word"},{"id":47100,"position":5,"arabic":"مِنْ","translation":"থেকে","audioUrl":"wbw/044_048_005.mp3","charTypeName":"word"},{"id":47101,"position":6,"arabic":"عَذَابِ","translation":"শাস্তি","audioUrl":"wbw/044_048_006.mp3","charTypeName":"word"},{"id":47102,"position":7,"arabic":"ٱلْحَمِيمِ","translation":"ফুটন্ত পানির","audioUrl":"wbw/044_048_007.mp3","charTypeName":"word"},{"id":47103,"position":8,"arabic":"٤٨","translation":"(৪৮)","audioUrl":null,"charTypeName":"end"}]},{"number":49,"arabic":"ذُقْ إِنَّكَ أَنتَ ٱلْعَزِيزُ ٱلْكَرِيمُ","translation":"Taste it - thou who [on earth] hast considered thyself so mighty, so noble!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4463.mp3","surahId":44,"words":[{"id":47928,"position":1,"arabic":"ذُقْ","translation":"(বলা হবে) স্বাদ নাও","audioUrl":"wbw/044_049_001.mp3","charTypeName":"word"},{"id":47929,"position":2,"arabic":"إِنَّكَ","translation":"তুমি নিশ্চয়ই","audioUrl":"wbw/044_049_002.mp3","charTypeName":"word"},{"id":47930,"position":3,"arabic":"أَنتَ","translation":"তুমিই (ছিলে)","audioUrl":"wbw/044_049_003.mp3","charTypeName":"word"},{"id":47931,"position":4,"arabic":"ٱلْعَزِيزُ","translation":"পরাক্রমশালী(?)","audioUrl":"wbw/044_049_004.mp3","charTypeName":"word"},{"id":47932,"position":5,"arabic":"ٱلْكَرِيمُ","translation":"সম্মানিত","audioUrl":"wbw/044_049_005.mp3","charTypeName":"word"},{"id":47933,"position":6,"arabic":"٤٩","translation":"(৪৯)","audioUrl":null,"charTypeN