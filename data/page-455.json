{"id":455,"ayahs":[{"number":27,"arabic":"وَمَا خَلَقْنَا ٱلسَّمَآءَ وَٱلْأَرْضَ وَمَا بَيْنَهُمَا بَٰطِلًۭا ۚ ذَٰلِكَ ظَنُّ ٱلَّذِينَ كَفَرُوا۟ ۚ فَوَيْلٌۭ لِّلَّذِينَ كَفَرُوا۟ مِنَ ٱلنَّارِ","translation":"AND [thus it is:] We have not created heaven and earth and all that is between them without meaning and purpose, as is the surmise of those who are bent on denying the truth: but then, woe from the fire [of hell] unto all who are bent on denying the truth!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3997.mp3","surahId":38,"words":[{"id":30424,"position":1,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/038_027_001.mp3","charTypeName":"word"},{"id":30425,"position":2,"arabic":"خَلَقْنَا","translation":"আমরা সৃষ্টি করেছি","audioUrl":"wbw/038_027_002.mp3","charTypeName":"word"},{"id":30426,"position":3,"arabic":"ٱلسَّمَآءَ","translation":"আকাশকে","audioUrl":"wbw/038_027_003.mp3","charTypeName":"word"},{"id":30427,"position":4,"arabic":"وَٱلْأَرْضَ","translation":"ও পৃৃথিবীকে","audioUrl":"wbw/038_027_004.mp3","charTypeName":"word"},{"id":30428,"position":5,"arabic":"وَمَا","translation":"এবং যা (আছে)","audioUrl":"wbw/038_027_005.mp3","charTypeName":"word"},{"id":30429,"position":6,"arabic":"بَيْنَهُمَا","translation":"উভয়ের মাঝে","audioUrl":"wbw/038_027_006.mp3","charTypeName":"word"},{"id":30430,"position":7,"arabic":"بَـٰطِلًۭا ۚ","translation":"অনর্থক","audioUrl":"wbw/038_027_007.mp3","charTypeName":"word"},{"id":30432,"position":8,"arabic":"ذَٰلِكَ","translation":"সেটা","audioUrl":"wbw/038_027_009.mp3","charTypeName":"word"},{"id":30433,"position":9,"arabic":"ظَنُّ","translation":"ধারণা","audioUrl":"wbw/038_027_010.mp3","charTypeName":"word"},{"id":30434,"position":10,"arabic":"ٱلَّذِينَ","translation":"(তাদের) যারা","audioUrl":"wbw/038_027_011.mp3","charTypeName":"word"},{"id":30435,"position":11,"arabic":"كَفَرُوا۟ ۚ","translation":"অস্বীকার করেছে","audioUrl":"wbw/038_027_012.mp3","charTypeName":"word"},{"id":30437,"position":12,"arabic":"فَوَيْلٌۭ","translation":"দুর্ভোগ সুতরাং","audioUrl":"wbw/038_027_014.mp3","charTypeName":"word"},{"id":30438,"position":13,"arabic":"لِّلَّذِينَ","translation":"(তাদের) জন্যে যারা","audioUrl":"wbw/038_027_015.mp3","charTypeName":"word"},{"id":30439,"position":14,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/038_027_016.mp3","charTypeName":"word"},{"id":30440,"position":15,"arabic":"مِنَ","translation":"হ'তে","audioUrl":"wbw/038_027_017.mp3","charTypeName":"word"},{"id":30441,"position":16,"arabic":"ٱلنَّارِ","translation":"(জাহান্নামের) আগুনের","audioUrl":"wbw/038_027_018.mp3","charTypeName":"word"},{"id":30442,"position":17,"arabic":"٢٧","translation":"(২৭)","audioUrl":null,"charTypeName":"end"}]},{"number":28,"arabic":"أَمْ نَجْعَلُ ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ كَٱلْمُفْسِدِينَ فِى ٱلْأَرْضِ أَمْ نَجْعَلُ ٱلْمُتَّقِينَ كَٱلْفُجَّارِ","translation":"[For,] would We treat those who have attained to faith and do righteous deeds in the same manner as [We shall treat] those who spread corruption on earth? Would We treat the God-conscious in the same manner as the wicked?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3998.mp3","surahId":38,"words":[{"id":31424,"position":1,"arabic":"أَمْ","translation":"কি","audioUrl":"wbw/038_028_001.mp3","charTypeName":"word"},{"id":31425,"position":2,"arabic":"نَجْعَلُ","translation":"গণ্য করবো আমরা","audioUrl":"wbw/038_028_002.mp3","charTypeName":"word"},{"id":31426,"position":3,"arabic":"ٱلَّذِينَ","translation":"(তাদেরকে) যারা","audioUrl":"wbw/038_028_003.mp3","charTypeName":"word"},{"id":31427,"position":4,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/038_028_004.mp3","charTypeName":"word"},{"id":31428,"position":5,"arabic":"وَعَمِلُوا۟","translation":"ও কাজ করেছে","audioUrl":"wbw/038_028_005.mp3","charTypeName":"word"},{"id":31429,"position":6,"arabic":"ٱلصَّـٰلِحَـٰتِ","translation":"সৎকর্মসমূহ","audioUrl":"wbw/038_028_006.mp3","charTypeName":"word"},{"id":31430,"position":7,"arabic":"كَٱلْمُفْسِدِينَ","translation":"মতো বিপর্যয় সৃষ্টিকারীদের","audioUrl":"wbw/038_028_007.mp3","charTypeName":"word"},{"id":31431,"position":8,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/038_028_008.mp3","charTypeName":"word"},{"id":31432,"position":9,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/038_028_009.mp3","charTypeName":"word"},{"id":31433,"position":10,"arabic":"أَمْ","translation":"কি","audioUrl":"wbw/038_028_010.mp3","charTypeName":"word"},{"id":31434,"position":11,"arabic":"نَجْعَلُ","translation":"গণ্য করবো আমরা","audioUrl":"wbw/038_028_011.mp3","charTypeName":"word"},{"id":31435,"position":12,"arabic":"ٱلْمُتَّقِينَ","translation":"মুত্তাকীদেরকে","audioUrl":"wbw/038_028_012.mp3","charTypeName":"word"},{"id":31436,"position":13,"arabic":"كَٱلْفُجَّارِ","translation":"পাপাচারীদের মতো","audioUrl":"wbw/038_028_013.mp3","charTypeName":"word"},{"id":31437,"position":14,"arabic":"٢٨","translation":"(২৮)","audioUrl":null,"charTypeName":"end"}]},{"number":29,"arabic":"كِتَٰبٌ أَنزَلْنَٰهُ إِلَيْكَ مُبَٰرَكٌۭ لِّيَدَّبَّرُوٓا۟ ءَايَٰتِهِۦ وَلِيَتَذَكَّرَ أُو۟لُوا۟ ٱلْأَلْبَٰبِ","translation":"[All this have We expounded in this] blessed divine writ which We have revealed unto thee, [O Muhammad,] so that men may ponder over its mes­sages, and that those who are endowed with insight may take them to heart.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3999.mp3","surahId":38,"words":[{"id":32396,"position":1,"arabic":"كِتَـٰبٌ","translation":"(হে নাবী) এই কিতাব","audioUrl":"wbw/038_029_001.mp3","charTypeName":"word"},{"id":32397,"position":2,"arabic":"أَنزَلْنَـٰهُ","translation":"তা আমরা অবতীর্ণ করেছি","audioUrl":"wbw/038_029_002.mp3","charTypeName":"word"},{"id":32398,"position":3,"arabic":"إِلَيْكَ","translation":"তোমার প্রতি","audioUrl":"wbw/038_029_003.mp3","charTypeName":"word"},{"id":32399,"position":4,"arabic":"مُبَـٰرَكٌۭ","translation":"কল্যাণকর (কিতাব)","audioUrl":"wbw/038_029_004.mp3","charTypeName":"word"},{"id":32400,"position":5,"arabic":"لِّيَدَّبَّرُوٓا۟","translation":"তারা চিন্তাভাবনা করে যেন","audioUrl":"wbw/038_029_005.mp3","charTypeName":"word"},{"id":32401,"position":6,"arabic":"ءَايَـٰتِهِۦ","translation":"তাঁর আয়াতসমূহকে","audioUrl":"wbw/038_029_006.mp3","charTypeName":"word"},{"id":32402,"position":7,"arabic":"وَلِيَتَذَكَّرَ","translation":"এবং উপদেশ নেয় যেন","audioUrl":"wbw/038_029_007.mp3","charTypeName":"word"},{"id":32403,"position":8,"arabic":"أُو۟لُوا۟","translation":"সম্পন্নরা","audioUrl":"wbw/038_029_008.mp3","charTypeName":"word"},{"id":32404,"position":9,"arabic":"ٱلْأَلْبَـٰبِ","translation":"বুদ্ধি-জ্ঞান","audioUrl":"wbw/038_029_009.mp3","charTypeName":"word"},{"id":32405,"position":10,"arabic":"٢٩","translation":"(২৯)","audioUrl":null,"charTypeName":"end"}]},{"number":30,"arabic":"وَوَهَبْنَا لِدَاوُۥدَ سُلَيْمَٰنَ ۚ نِعْمَ ٱلْعَبْدُ ۖ إِنَّهُۥٓ أَوَّابٌ","translation":"AND UNTO DAVID We granted Solomon [as a son - and] how excellent a servant [of Ours he grew up to be]! Behold, he would always turn unto Us -","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4000.mp3","surahId":38,"words":[{"id":33241,"position":1,"arabic":"وَوَهَبْنَا","translation":"এবং আমরা দান করেছিলাম","audioUrl":"wbw/038_030_001.mp3","charTypeName":"word"},{"id":33242,"position":2,"arabic":"لِدَاوُۥدَ","translation":"দাউদের জন্য","audioUrl":"wbw/038_030_002.mp3","charTypeName":"word"},{"id":33243,"position":3,"arabic":"سُلَيْمَـٰنَ ۚ","translation":"(তার পুত্র) সুলায়মানকে","audioUrl":"wbw/038_030_003.mp3","charTypeName":"word"},{"id":33245,"position":4,"arabic":"نِعْمَ","translation":"অতি উত্তম","audioUrl":"wbw/038_030_005.mp3","charTypeName":"word"},{"id":33246,"position":5,"arabic":"ٱلْعَبْدُ ۖ","translation":"দাস","audioUrl":"wbw/038_030_006.mp3","charTypeName":"word"},{"id":33248,"position":6,"arabic":"إِنَّهُۥٓ","translation":"সে নিশ্চযই় (ছিলো)","audioUrl":"wbw/038_030_008.mp3","charTypeName":"word"},{"id":33249,"position":7,"arabic":"أَوَّابٌ","translation":"অতিশয় (আল্লাহ) অভিমুখী","audioUrl":"wbw/038_030_009.mp3","charTypeName":"word"},{"id":33250,"position":8,"arabic":"٣٠","translation":"(৩০)","audioUrl":null,"charTypeName":"end"}]},{"number":31,"arabic":"إِذْ عُرِضَ عَلَيْهِ بِٱلْعَشِىِّ ٱلصَّٰفِنَٰتُ ٱلْجِيَادُ","translation":"[and even] when, towards the close of day, nobly-bred, swift-footed steeds were brought before him,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4001.mp3","surahId":38,"words":[{"id":34288,"position":1,"arabic":"إِذْ","translation":"(স্মরণ করো) যখন","audioUrl":"wbw/038_031_001.mp3","charTypeName":"word"},{"id":34289,"position":2,"arabic":"عُرِضَ","translation":"উপস্হিত করা হলো","audioUrl":"wbw/038_031_002.mp3","charTypeName":"word"},{"id":34290,"position":3,"arabic":"عَلَيْهِ","translation":"তার সামনে","audioUrl":"wbw/038_031_003.mp3","charTypeName":"word"},{"id":34291,"position":4,"arabic":"بِٱلْعَشِىِّ","translation":"সন্ধ্যায়","audioUrl":"wbw/038_031_004.mp3","charTypeName":"word"},{"id":34292,"position":5,"arabic":"ٱلصَّـٰفِنَـٰتُ","translation":"দ্রুতগামী ঘোড়াসমূহ","audioUrl":"wbw/038_031_005.mp3","charTypeName":"word"},{"id":34293,"position":6,"arabic":"ٱلْجِيَادُ","translation":"উৎকৃষ্টমানের (ঘোড়া)","audioUrl":"wbw/038_031_006.mp3","charTypeName":"word"},{"id":34294,"position":7,"arabic":"٣١","translation":"(৩১)","audioUrl":null,"charTypeName":"end"}]},{"number":32,"arabic":"فَقَالَ إِنِّىٓ أَحْبَبْتُ حُبَّ ٱلْخَيْرِ عَن ذِكْرِ رَبِّى حَتَّىٰ تَوَارَتْ بِٱلْحِجَابِ","translation":"he would say, “Verily, I have come to love the love of all that is good because I bear my Sustainer in mind!” [repeating these words as the steeds raced away,] until they were hidden by the veil [of distance - whereupon he would command],","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4002.mp3","surahId":38,"words":[{"id":35139,"position":1,"arabic":"فَقَالَ","translation":"তখন সে বললো","audioUrl":"wbw/038_032_0