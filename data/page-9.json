{"id":9,"ayahs":[{"number":58,"arabic":"وَإِذْ قُلْنَا ٱدْخُلُوا۟ هَٰذِهِ ٱلْقَرْيَةَ فَكُلُوا۟ مِنْهَا حَيْثُ شِئْتُمْ رَغَدًۭا وَٱدْخُلُوا۟ ٱلْبَابَ سُجَّدًۭا وَقُولُوا۟ حِطَّةٌۭ نَّغْفِرْ لَكُمْ خَطَٰيَٰكُمْ ۚ وَسَنَزِيدُ ٱلْمُحْسِنِينَ","translation":"And [remember the time] when We said: \"Enter this land, and eat of its food as you may desire. abundantly; but enter the gate humbly and say, `Remove Thou from us the burden of our sins', [whereupon] We shall forgive you your sins, and shall amply reward the doers of good.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/65.mp3","surahId":2,"words":[{"id":53080,"position":1,"arabic":"وَإِذْ","translation":"এবং স্মরণ করো যখন","audioUrl":"wbw/002_058_001.mp3","charTypeName":"word"},{"id":53081,"position":2,"arabic":"قُلْنَا","translation":"আমরা বলেছিলাম","audioUrl":"wbw/002_058_002.mp3","charTypeName":"word"},{"id":53082,"position":3,"arabic":"ٱدْخُلُوا۟","translation":"''তোমরা প্রবেশ কর","audioUrl":"wbw/002_058_003.mp3","charTypeName":"word"},{"id":53083,"position":4,"arabic":"هَـٰذِهِ","translation":"এই","audioUrl":"wbw/002_058_004.mp3","charTypeName":"word"},{"id":53084,"position":5,"arabic":"ٱلْقَرْيَةَ","translation":"নগরীতে","audioUrl":"wbw/002_058_005.mp3","charTypeName":"word"},{"id":53085,"position":6,"arabic":"فَكُلُوا۟","translation":"তোমরা খাও","audioUrl":"wbw/002_058_006.mp3","charTypeName":"word"},{"id":53086,"position":7,"arabic":"مِنْهَا","translation":"তা হতে","audioUrl":"wbw/002_058_007.mp3","charTypeName":"word"},{"id":53087,"position":8,"arabic":"حَيْثُ","translation":"যেভাবে","audioUrl":"wbw/002_058_008.mp3","charTypeName":"word"},{"id":53088,"position":9,"arabic":"شِئْتُمْ","translation":"তোমরা যাও","audioUrl":"wbw/002_058_009.mp3","charTypeName":"word"},{"id":53089,"position":10,"arabic":"رَغَدًۭا","translation":"স্বানন্দে","audioUrl":"wbw/002_058_010.mp3","charTypeName":"word"},{"id":53090,"position":11,"arabic":"وَٱدْخُلُوا۟","translation":"এবং তোমরা প্রবেশ করো","audioUrl":"wbw/002_058_011.mp3","charTypeName":"word"},{"id":53091,"position":12,"arabic":"ٱلْبَابَ","translation":"(নগর) দরজায়","audioUrl":"wbw/002_058_012.mp3","charTypeName":"word"},{"id":53092,"position":13,"arabic":"سُجَّدًۭا","translation":"সিজদা অবনত হয়ে","audioUrl":"wbw/002_058_013.mp3","charTypeName":"word"},{"id":53093,"position":14,"arabic":"وَقُولُوا۟","translation":"এবং তোমরা বলো","audioUrl":"wbw/002_058_014.mp3","charTypeName":"word"},{"id":53094,"position":15,"arabic":"حِطَّةٌۭ","translation":"''ক্ষমার কথা","audioUrl":"wbw/002_058_015.mp3","charTypeName":"word"},{"id":53095,"position":16,"arabic":"نَّغْفِرْ","translation":"ক্ষমা করবো আমরা","audioUrl":"wbw/002_058_016.mp3","charTypeName":"word"},{"id":53096,"position":17,"arabic":"لَكُمْ","translation":"তোমাদের প্রতি","audioUrl":"wbw/002_058_017.mp3","charTypeName":"word"},{"id":53097,"position":18,"arabic":"خَطَـٰيَـٰكُمْ ۚ","translation":"তোমাদের ত্রুটিগুলোকে","audioUrl":"wbw/002_058_018.mp3","charTypeName":"word"},{"id":53099,"position":19,"arabic":"وَسَنَزِيدُ","translation":"এবং অচিরেই (অনুগ্রহ) বাড়িয়ে দিব","audioUrl":"wbw/002_058_020.mp3","charTypeName":"word"},{"id":53100,"position":20,"arabic":"ٱلْمُحْسِنِينَ","translation":"সৎকর্মশীলদেরকে''","audioUrl":"wbw/002_058_021.mp3","charTypeName":"word"},{"id":53101,"position":21,"arabic":"٥٨","translation":"(৫৮)","audioUrl":null,"charTypeName":"end"}]},{"number":59,"arabic":"فَبَدَّلَ ٱلَّذِينَ ظَلَمُوا۟ قَوْلًا غَيْرَ ٱلَّذِى قِيلَ لَهُمْ فَأَنزَلْنَا عَلَى ٱلَّذِينَ ظَلَمُوا۟ رِجْزًۭا مِّنَ ٱلسَّمَآءِ بِمَا كَانُوا۟ يَفْسُقُونَ","translation":"But those who were bent on evildoing substituted another saying for that which had been given them: and so We sent down upon those evildoers a plague from heaven in requital for all their iniquity.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/66.mp3","surahId":2,"words":[{"id":54041,"position":1,"arabic":"فَبَدَّلَ","translation":"কিন্তু পরিবর্তন করল","audioUrl":"wbw/002_059_001.mp3","charTypeName":"word"},{"id":54042,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/002_059_002.mp3","charTypeName":"word"},{"id":54043,"position":3,"arabic":"ظَلَمُوا۟","translation":"সীমালঙ্ঘন করেছিল","audioUrl":"wbw/002_059_003.mp3","charTypeName":"word"},{"id":54044,"position":4,"arabic":"قَوْلًا","translation":"কথা","audioUrl":"wbw/002_059_004.mp3","charTypeName":"word"},{"id":54045,"position":5,"arabic":"غَيْرَ","translation":"অন্য কিছু","audioUrl":"wbw/002_059_005.mp3","charTypeName":"word"},{"id":54046,"position":6,"arabic":"ٱلَّذِى","translation":"(তা হতে) যা","audioUrl":"wbw/002_059_006.mp3","charTypeName":"word"},{"id":54047,"position":7,"arabic":"قِيلَ","translation":"বলা হয়েছিল","audioUrl":"wbw/002_059_007.mp3","charTypeName":"word"},{"id":54048,"position":8,"arabic":"لَهُمْ","translation":"তাদের উদ্দেশ্যে","audioUrl":"wbw/002_059_008.mp3","charTypeName":"word"},{"id":54049,"position":9,"arabic":"فَأَنزَلْنَا","translation":"আমরা তাই অবতীর্ণ করলাম","audioUrl":"wbw/002_059_009.mp3","charTypeName":"word"},{"id":54050,"position":10,"arabic":"عَلَى","translation":"(তাদের) উপর","audioUrl":"wbw/002_059_010.mp3","charTypeName":"word"},{"id":54051,"position":11,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/002_059_011.mp3","charTypeName":"word"},{"id":54052,"position":12,"arabic":"ظَلَمُوا۟","translation":"সীমালঙ্ঘন করেছিল","audioUrl":"wbw/002_059_012.mp3","charTypeName":"word"},{"id":54053,"position":13,"arabic":"رِجْزًۭا","translation":"শাস্তি","audioUrl":"wbw/002_059_013.mp3","charTypeName":"word"},{"id":54054,"position":14,"arabic":"مِّنَ","translation":"থেকে","audioUrl":"wbw/002_059_014.mp3","charTypeName":"word"},{"id":54055,"position":15,"arabic":"ٱلسَّمَآءِ","translation":"আকাশ","audioUrl":"wbw/002_059_015.mp3","charTypeName":"word"},{"id":54056,"position":16,"arabic":"بِمَا","translation":"এ কারণে যা","audioUrl":"wbw/002_059_016.mp3","charTypeName":"word"},{"id":54057,"position":17,"arabic":"كَانُوا۟","translation":"তারা ছিল","audioUrl":"wbw/002_059_017.mp3","charTypeName":"word"},{"id":54058,"position":18,"arabic":"يَفْسُقُونَ","translation":"তারা সত্যত্যাগ করে","audioUrl":"wbw/002_059_018.mp3","charTypeName":"word"},{"id":54059,"position":19,"arabic":"٥٩","translation":"(৫৯)","audioUrl":null,"charTypeName":"end"}]},{"number":60,"arabic":"۞ وَإِذِ ٱسْتَسْقَىٰ مُوسَىٰ لِقَوْمِهِۦ فَقُلْنَا ٱضْرِب بِّعَصَاكَ ٱلْحَجَرَ ۖ فَٱنفَجَرَتْ مِنْهُ ٱثْنَتَا عَشْرَةَ عَيْنًۭا ۖ قَدْ عَلِمَ كُلُّ أُنَاسٍۢ مَّشْرَبَهُمْ ۖ كُلُوا۟ وَٱشْرَبُوا۟ مِن رِّزْقِ ٱللَّهِ وَلَا تَعْثَوْا۟ فِى ٱلْأَرْضِ مُفْسِدِينَ","translation":"And [remember] when Moses prayed for water for his people and We replied, \"Strike the rock with thy staff!\"-whereupon twelve springs gushed forth from it, so that all the people knew whence to drink. [And Moses said:] \"Eat and drink the sustenance provided by God, and do not act wickedly on earth by spreading corruption.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/67.mp3","surahId":2,"words":[{"id":54472,"position":1,"arabic":"۞ وَإِذِ","translation":"এবং স্মরণ করো যখন","audioUrl":"wbw/002_060_002.mp3","charTypeName":"word"},{"id":54473,"position":2,"arabic":"ٱسْتَسْقَىٰ","translation":"পানি চাইল","audioUrl":"wbw/002_060_003.mp3","charTypeName":"word"},{"id":54474,"position":3,"arabic":"مُوسَىٰ","translation":"মুসা","audioUrl":"wbw/002_060_004.mp3","charTypeName":"word"},{"id":54475,"position":4,"arabic":"لِقَوْمِهِۦ","translation":"তার জাতির জন্য","audioUrl":"wbw/002_060_005.mp3","charTypeName":"word"},{"id":54476,"position":5,"arabic":"فَقُلْنَا","translation":"তখন আমরা বলেছিলাম","audioUrl":"wbw/002_060_006.mp3","charTypeName":"word"},{"id":54477,"position":6,"arabic":"ٱضْرِب","translation":"''আঘাত কর","audioUrl":"wbw/002_060_007.mp3","charTypeName":"word"},{"id":54478,"position":7,"arabic":"بِّعَصَاكَ","translation":"তোমার লাঠি দিয়ে","audioUrl":"wbw/002_060_008.mp3","charTypeName":"word"},{"id":54479,"position":8,"arabic":"ٱلْحَجَرَ ۖ","translation":"পাথরে''","audioUrl":"wbw/002_060_009.mp3","charTypeName":"word"},{"id":54481,"position":9,"arabic":"فَٱنفَجَرَتْ","translation":"ফলে ফেটে বের হল","audioUrl":"wbw/002_060_011.mp3","charTypeName":"word"},{"id":54482,"position":10,"arabic":"مِنْهُ","translation":"তা থেকে","audioUrl":"wbw/002_060_012.mp3","charTypeName":"word"},{"id":54483,"position":11,"arabic":"ٱثْنَتَا","translation":"বারটি","audioUrl":"wbw/002_060_013.mp3","charTypeName":"word"},{"id":54484,"position":12,"arabic":"عَشْرَةَ","translation":"(দশ)","audioUrl":"wbw/002_060_014.mp3","charTypeName":"word"},{"id":54485,"position":13,"arabic":"عَيْنًۭا ۖ","translation":"ঝর্ণা","audioUrl":"wbw/002_060_015.mp3","charTypeName":"word"},{"id":54487,"position":14,"arabic":"قَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/002_060_017.mp3","charTypeName":"word"},{"id":54488,"position":15,"arabic":"عَلِمَ","translation":"চিনে নিল","audioUrl":"wbw/002_060_018.mp3","charTypeName":"word"},{"id":54489,"position":16,"arabic":"كُلُّ","translation":"প্রত্যেক","audioUrl":"wbw/002_060_019.mp3","charTypeName":"word"},{"id":54490,"position":17,"arabic":"أُنَاسٍۢ","translation":"(গোত্রের) মানুষ","audioUrl":"wbw/002_060_020.mp3","charTypeName":"word"},{"id":54491,"position":18,"arabic":"مَّشْرَبَهُمْ ۖ","translation":"তাদের পানি পানের স্থান","audioUrl":"wbw/002_060_021.mp3","charTypeName":"word"},{"id":54493,"position":19,"arabic":"كُلُوا۟","translation":"''(বলা হল) তোমরা খাও","audioUrl":"wbw/002_060_023.mp3","charTypeName":"word"},{"id":54494,"position":20,"arabic":"وَٱشْرَبُوا۟","translation":"ও তোমরা পান করো","audioUrl":"wbw/002_060_024.mp3","charTypeName":"word"},{"id":54495,"position":21,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/002_060_025.mp3","charTypeName":"word"},{"id":54496,"position":22,"arabic":"رِّزْقِ","translation":"জীবিকা","audioUrl":"wbw/002_060_026.mp3","charTypeName":"word"},{"id":54497,"position":23,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌র (দেয়া)","audioUrl":"wbw/002_060_027.mp3","charTypeName":"word"},{"id":54498,"position":24,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/002_060_028.mp3","charTypeName":"word"},{"id":54499,"position":25,"arabic":"تَعْثَوْا۟","translation":"তোমরা বিপর্যয় সৃষ্টি করো","audioUrl":"wbw/002_060_029.mp3","charTypeName":"word"},{"id":54500,"position":26,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/002_060_030.mp3","charTypeName":"word"},{"id":54501,"position":27,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/002_060_031.mp3","charTypeName":"word"},{"id":54502,"position":28,"arabic":"مُفْسِدِينَ","translation":"বিপর্যয় সৃষ্টিকারী হয়ে''","audioUrl":"wbw/002_060_032.mp3","charTypeName":"word"},{"id":54503,"position":29,"arabic":"٦٠","translation":"(৬০)","audioUrl":null,"charTypeName":"end"}]},{"number":61,"arabic":"وَإِذْ قُلْتُمْ يَٰمُوسَىٰ لَن نَّصْبِرَ عَلَىٰ طَعَامٍۢ وَٰحِدٍۢ فَٱدْعُ لَنَا رَبَّكَ يُخْرِجْ لَنَا مِمَّا تُنۢبِتُ ٱلْأَرْضُ مِنۢ بَقْلِهَا وَقِثَّآئِهَا وَفُومِهَا وَعَدَسِهَا وَبَصَلِهَا ۖ قَالَ أَتَسْتَبْدِلُونَ ٱلَّذِى هُوَ أَدْنَىٰ بِٱلَّذِى هُوَ خَيْرٌ ۚ ٱهْبِطُوا۟ مِصْرًۭا فَإِنَّ لَكُم مَّا سَأَلْتُمْ ۗ وَضُرِبَتْ عَلَيْهِمُ ٱلذِّلَّةُ وَٱلْمَسْكَنَةُ وَبَآءُو بِغَضَبٍۢ مِّنَ ٱللَّهِ ۗ ذَٰلِكَ بِأَنَّهُمْ كَانُوا۟ يَكْفُرُونَ بِـَٔايَٰتِ ٱللَّهِ وَيَقْتُلُونَ ٱلنَّبِيِّۦنَ بِغَيْرِ ٱلْحَقِّ ۗ ذَٰلِكَ بِمَا عَصَوا۟ وَّكَانُوا۟ يَعْتَدُونَ","translation":"And [remember] when you said: \"O Moses, indeed we cannot endure but one kind of food; pray, then, to thy Sustainer that He bring forth for us aught of what grows from the earth - of its herbs, its cucumbers, its garlic, its lentils, its onions.\" Said [Moses]: \"Would you take a lesser thing in exchange for what is [so much] better? Go back in shame to Egypt, and then you can have what you are asking for!\" And so, ignominy and humiliation overshadowed them, and they earned the burden of God's condemnation: all this, because they persisted in denying the truth of God's messages and in slaying the prophets against all right: all this, because they rebelled [against God], and persisted in transgressing the bounds of what is right.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/68.mp3","surahId":2,"words":[{"id":54817,"position":1,"arabic":"وَإِذْ","translation":"এবং (স্মরণ করো)","audioUrl":"wbw/002_061_001.mp3","charTypeName":"word"},{"id":54818,"position":2,"arabic":"قُلْتُمْ","translation":"বলেছিলে তোমরা","audioUrl":"wbw/002_061_002.mp3","charTypeName":"word"},{"id":54819,"position":3,"arabic":"يَـٰمُوسَىٰ","translation":"''হে মুসা","audioUrl":"wbw/002_061_003.mp3","charTypeName":"word"},{"id":54820,"position":4,"arabic":"لَن","translation":"কখনও না","audioUrl":"wbw/002_061_004.mp3","charTypeName":"word"},{"id":54821,"position":5,"arabic":"نَّصْبِرَ","translation":"আমরা ধৈর্য ধরতে পারব","audioUrl":"wbw/002_061_005.mp3","charTypeName":"word"},{"id":54822,"position":6,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/002_061_006.mp3","charTypeName":"word"},{"id":54823,"position":7,"arabic":"طَعَامٍۢ","translation":"খানার","audioUrl":"wbw/002_061_007.mp3","charTypeName":"word"},{"id":54824,"position":8,"arabic":"وَٰحِدٍۢ","translation":"একই (ধরণের)","audioUrl":"wbw/002_061_008.mp3","charTypeName":"word"},{"id":54825,"position":9,"arabic":"فَٱدْعُ","translation":"তাই দুআ করো","audioUrl":"wbw/002_061_009.mp3","charTypeName":"word"},{"id":54826,"position":10,"arabic":"لَنَا","translation":"আমাদের জন্য","audioUrl":"wbw/002_061_010.mp3","charTypeName":"word"},{"id":54827,"position":11,"arabic":"رَبَّكَ","translation":"তোমার রবের কাছে","audioUrl":"wbw/002_061_011.mp3","charTypeName":"word"},{"id":54828,"position":12,"arabic":"يُخْرِجْ","translation":"(যেন) বের করেন তিনি","audioUrl":"wbw/002_061_012.mp3","charTypeName":"word"},{"id":54829,"position":13,"arabic":"لَنَا","translation":"আমাদের জন্য","audioUrl":"wbw/002_061_013.mp3","charTypeName":"word"},{"id":54830,"position":14,"arabic":"مِمَّا","translation":"তাহতে যা","audioUrl":"wbw/002_061_014.mp3","charTypeName":"word"},{"id":54831,"po