{"id":67,"ayahs":[{"number":133,"arabic":"۞ وَسَارِعُوٓا۟ إِلَىٰ مَغْفِرَةٍۢ مِّن رَّبِّكُمْ وَجَنَّةٍ عَرْضُهَا ٱلسَّمَٰوَٰتُ وَٱلْأَرْضُ أُعِدَّتْ لِلْمُتَّقِينَ","translation":"And vie with one another to attain to your Sustainer's forgiveness and to a paradise as vast as the heavens and the earth, which has been readied for the God-conscious","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/426.mp3","surahId":3,"words":[{"id":78285,"position":1,"arabic":"۞ وَسَارِعُوٓا۟","translation":"এবং তোমরা দ্রুত আস","audioUrl":"wbw/003_133_002.mp3","charTypeName":"word"},{"id":78286,"position":2,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/003_133_003.mp3","charTypeName":"word"},{"id":78287,"position":3,"arabic":"مَغْفِرَةٍۢ","translation":"ক্ষমার","audioUrl":"wbw/003_133_004.mp3","charTypeName":"word"},{"id":78288,"position":4,"arabic":"مِّن","translation":"পক্ষ হতে","audioUrl":"wbw/003_133_005.mp3","charTypeName":"word"},{"id":78289,"position":5,"arabic":"رَّبِّكُمْ","translation":"তোমাদের রবের","audioUrl":"wbw/003_133_006.mp3","charTypeName":"word"},{"id":78290,"position":6,"arabic":"وَجَنَّةٍ","translation":"ও জান্নাতের","audioUrl":"wbw/003_133_007.mp3","charTypeName":"word"},{"id":78291,"position":7,"arabic":"عَرْضُهَا","translation":"যার প্রশস্ততা","audioUrl":"wbw/003_133_008.mp3","charTypeName":"word"},{"id":78292,"position":8,"arabic":"ٱلسَّمَـٰوَٰتُ","translation":"আসমান সমূহের","audioUrl":"wbw/003_133_009.mp3","charTypeName":"word"},{"id":78293,"position":9,"arabic":"وَٱلْأَرْضُ","translation":"ও জমিনের (সমান)","audioUrl":"wbw/003_133_010.mp3","charTypeName":"word"},{"id":78294,"position":10,"arabic":"أُعِدَّتْ","translation":"তৈরী করা হয়েছে","audioUrl":"wbw/003_133_011.mp3","charTypeName":"word"},{"id":78295,"position":11,"arabic":"لِلْمُتَّقِينَ","translation":"মুত্তাকীদের জন্য","audioUrl":"wbw/003_133_012.mp3","charTypeName":"word"},{"id":78296,"position":12,"arabic":"١٣٣","translation":"(১৩৩)","audioUrl":null,"charTypeName":"end"}]},{"number":134,"arabic":"ٱلَّذِينَ يُنفِقُونَ فِى ٱلسَّرَّآءِ وَٱلضَّرَّآءِ وَٱلْكَٰظِمِينَ ٱلْغَيْظَ وَٱلْعَافِينَ عَنِ ٱلنَّاسِ ۗ وَٱللَّهُ يُحِبُّ ٱلْمُحْسِنِينَ","translation":"who spend [in His way] in time of plenty and in time of hardship, and hold in check their anger, and pardon their fellow-men because God loves the doers of good;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/427.mp3","surahId":3,"words":[{"id":78360,"position":1,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/003_134_001.mp3","charTypeName":"word"},{"id":78361,"position":2,"arabic":"يُنفِقُونَ","translation":"খরচ করে","audioUrl":"wbw/003_134_002.mp3","charTypeName":"word"},{"id":78362,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/003_134_003.mp3","charTypeName":"word"},{"id":78363,"position":4,"arabic":"ٱلسَّرَّآءِ","translation":"খুশীর (স্বচ্ছল অবস্থায়)","audioUrl":"wbw/003_134_004.mp3","charTypeName":"word"},{"id":78364,"position":5,"arabic":"وَٱلضَّرَّآءِ","translation":"ও কষ্টে (দুরাবস্থায়)","audioUrl":"wbw/003_134_005.mp3","charTypeName":"word"},{"id":78365,"position":6,"arabic":"وَٱلْكَـٰظِمِينَ","translation":"এবং দমনকারী","audioUrl":"wbw/003_134_006.mp3","charTypeName":"word"},{"id":78366,"position":7,"arabic":"ٱلْغَيْظَ","translation":"রাগ","audioUrl":"wbw/003_134_007.mp3","charTypeName":"word"},{"id":78367,"position":8,"arabic":"وَٱلْعَافِينَ","translation":"ও মাফকারী","audioUrl":"wbw/003_134_008.mp3","charTypeName":"word"},{"id":78368,"position":9,"arabic":"عَنِ","translation":"(প্রায়)","audioUrl":"wbw/003_134_009.mp3","charTypeName":"word"},{"id":78369,"position":10,"arabic":"ٱلنَّاسِ ۗ","translation":"লোকদের","audioUrl":"wbw/003_134_010.mp3","charTypeName":"word"},{"id":78371,"position":11,"arabic":"وَٱللَّهُ","translation":"আর আল্লাহ","audioUrl":"wbw/003_134_012.mp3","charTypeName":"word"},{"id":78372,"position":12,"arabic":"يُحِبُّ","translation":"ভালোবাসেন","audioUrl":"wbw/003_134_013.mp3","charTypeName":"word"},{"id":78373,"position":13,"arabic":"ٱلْمُحْسِنِينَ","translation":"নেক লোকদেরকে","audioUrl":"wbw/003_134_014.mp3","charTypeName":"word"},{"id":78374,"position":14,"arabic":"١٣٤","translation":"(১৩৪)","audioUrl":null,"charTypeName":"end"}]},{"number":135,"arabic":"وَٱلَّذِينَ إِذَا فَعَلُوا۟ فَٰحِشَةً أَوْ ظَلَمُوٓا۟ أَنفُسَهُمْ ذَكَرُوا۟ ٱللَّهَ فَٱسْتَغْفَرُوا۟ لِذُنُوبِهِمْ وَمَن يَغْفِرُ ٱلذُّنُوبَ إِلَّا ٱللَّهُ وَلَمْ يُصِرُّوا۟ عَلَىٰ مَا فَعَلُوا۟ وَهُمْ يَعْلَمُونَ","translation":"and who, when they have committed a shameful deed or have [otherwise] sinned against themselves, remember God and pray that their sins be forgiven - for who but God could forgive sins? - and do not knowingly persist in doing whatever [wrong] they may have done.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/428.mp3","surahId":3,"words":[{"id":78456,"position":1,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা (এমন যে)","audioUrl":"wbw/003_135_001.mp3","charTypeName":"word"},{"id":78457,"position":2,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/003_135_002.mp3","charTypeName":"word"},{"id":78458,"position":3,"arabic":"فَعَلُوا۟","translation":"তারা করে ফেলে","audioUrl":"wbw/003_135_003.mp3","charTypeName":"word"},{"id":78459,"position":4,"arabic":"فَـٰحِشَةً","translation":"অশ্লীলতা","audioUrl":"wbw/003_135_004.mp3","charTypeName":"word"},{"id":78460,"position":5,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/003_135_005.mp3","charTypeName":"word"},{"id":78461,"position":6,"arabic":"ظَلَمُوٓا۟","translation":"যুলুম করে ফেলে","audioUrl":"wbw/003_135_006.mp3","charTypeName":"word"},{"id":78462,"position":7,"arabic":"أَنفُسَهُمْ","translation":"তাদের নিজেদের (উপর)","audioUrl":"wbw/003_135_007.mp3","charTypeName":"word"},{"id":78463,"position":8,"arabic":"ذَكَرُوا۟","translation":"স্মরণ করে (তৎক্ষণাৎ)","audioUrl":"wbw/003_135_008.mp3","charTypeName":"word"},{"id":78464,"position":9,"arabic":"ٱللَّهَ","translation":"আল্লাহকে","audioUrl":"wbw/003_135_009.mp3","charTypeName":"word"},{"id":78465,"position":10,"arabic":"فَٱسْتَغْفَرُوا۟","translation":"অতঃপর তারা মাফ চায়","audioUrl":"wbw/003_135_010.mp3","charTypeName":"word"},{"id":78466,"position":11,"arabic":"لِذُنُوبِهِمْ","translation":"তাদের গুনাহর জন্য","audioUrl":"wbw/003_135_011.mp3","charTypeName":"word"},{"id":78467,"position":12,"arabic":"وَمَن","translation":"আর কে (আছে)","audioUrl":"wbw/003_135_012.mp3","charTypeName":"word"},{"id":78468,"position":13,"arabic":"يَغْفِرُ","translation":"(এমন যে) মাফ করতে পারে","audioUrl":"wbw/003_135_013.mp3","charTypeName":"word"},{"id":78469,"position":14,"arabic":"ٱلذُّنُوبَ","translation":"গুনাহ সমূহকে","audioUrl":"wbw/003_135_014.mp3","charTypeName":"word"},{"id":78470,"position":15,"arabic":"إِلَّا","translation":"ব্যতীত","audioUrl":"wbw/003_135_015.mp3","charTypeName":"word"},{"id":78471,"position":16,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/003_135_016.mp3","charTypeName":"word"},{"id":78472,"position":17,"arabic":"وَلَمْ","translation":"এবং না","audioUrl":"wbw/003_135_017.mp3","charTypeName":"word"},{"id":78473,"position":18,"arabic":"يُصِرُّوا۟","translation":"বাড়া বাড়ি করে","audioUrl":"wbw/003_135_018.mp3","charTypeName":"word"},{"id":78474,"position":19,"arabic":"عَلَىٰ","translation":"(তার) উপর","audioUrl":"wbw/003_135_019.mp3","charTypeName":"word"},{"id":78475,"position":20,"arabic":"مَا","translation":"যা","audioUrl":"wbw/003_135_020.mp3","charTypeName":"word"},{"id":78476,"position":21,"arabic":"فَعَلُوا۟","translation":"তারা করে ফেলেছে","audioUrl":"wbw/003_135_021.mp3","charTypeName":"word"},{"id":78477,"position":22,"arabic":"وَهُمْ","translation":"যখন তারা","audioUrl":"wbw/003_135_022.mp3","charTypeName":"word"},{"id":78478,"position":23,"arabic":"يَعْلَمُونَ","translation":"জানেও","audioUrl":"wbw/003_135_023.mp3","charTypeName":"word"},{"id":78479,"position":24,"arabic":"١٣٥","translation":"(১৩৫)","audioUrl":null,"charTypeName":"end"}]},{"number":136,"arabic":"أُو۟لَٰٓئِكَ جَزَآؤُهُم مَّغْفِرَةٌۭ مِّن رَّبِّهِمْ وَجَنَّٰتٌۭ تَجْرِى مِن تَحْتِهَا ٱلْأَنْهَٰرُ خَٰلِدِينَ فِيهَا ۚ وَنِعْمَ أَجْرُ ٱلْعَٰمِلِينَ","translation":"These it is who shall have as their reward forgiveness from their Sustainer, and gardens through which running waters flow, therein to abide: and how excellent a reward for those who labour!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/429.mp3","surahId":3,"words":[{"id":78598,"position":1,"arabic":"أُو۟لَـٰٓئِكَ","translation":"(তারা) ঐসব লোক","audioUrl":"wbw/003_136_001.mp3","charTypeName":"word"},{"id":78599,"position":2,"arabic":"جَزَآؤُهُم","translation":"যাদেরে প্রতিফল (হলো)","audioUrl":"wbw/003_136_002.mp3","charTypeName":"word"},{"id":78600,"position":3,"arabic":"مَّغْفِرَةٌۭ","translation":"ক্ষমা","audioUrl":"wbw/003_136_003.mp3","charTypeName":"word"},{"id":78601,"position":4,"arabic":"مِّن","translation":"পক্ষ হতে","audioUrl":"wbw/003_136_004.mp3","charTypeName":"word"},{"id":78602,"position":5,"arabic":"رَّبِّهِمْ","translation":"তাদের রবের","audioUrl":"wbw/003_136_005.mp3","charTypeName":"word"},{"id":78603,"position":6,"arabic":"وَجَنَّـٰتٌۭ","translation":"ও জান্নাত","audioUrl":"wbw/003_136_006.mp3","charTypeName":"word"},{"id":78604,"position":7,"arabic":"تَجْرِى","translation":"প্রবাহিত হয়","audioUrl":"wbw/003_136_007.mp3","charTypeName":"word"},{"id":78605,"position":8,"arabic":"مِن","translation":"(থেকে)","audioUrl":"wbw/003_136_008.mp3","charTypeName":"word"},{"id":78606,"position":9,"arabic":"تَحْتِهَا","translation":"তার তলদেশে","audioUrl":"wbw/003_136_009.mp3","charTypeName":"word"},{"id":78607,"position":10,"arabic":"ٱلْأَنْهَـٰرُ","translation":"ঝর্ণা সমূহ","audioUrl":"wbw/003_136_010.mp3","charTypeName":"word"},{"id":78608,"position":11,"arabic":"خَـٰلِدِينَ","translation":"তারা চিরস্থায়ী হবে","audioUrl":"wbw/003_136_011.mp3","charTypeName":"word"},{"id":78609,"position":12,"arabic":"فِيهَا ۚ","translation":"তার মধ্যে","audioUrl":"wbw/003_136_012.mp3","charTypeName":"word"},{"id":78611,"position":13,"arabic":"وَنِعْمَ","translation":"এবং কত উত্তম","audioUrl":"wbw/003_136_014.mp3","charTypeName":"word"},{"id":78612,"position":14,"arabic":"أَجْرُ","translation":"পুরস্কার (রয়েছে)","audioUrl":"wbw/003_136_015.mp3","charTypeName":"word"},{"id":78613,"position":15,"arabic":"ٱلْعَـٰمِلِينَ","translation":"(সৎ) কর্মশীলদের (জন্য)","audioUrl":"wbw/003_136_016.mp3","charTypeName":"word"},{"id":78614,"position":16,"arabic":"١٣٦","translation":"(১৩৬)","audioUrl":null,"charTypeName":"end"}]},{"number":137,"arabic":"قَدْ خَلَتْ مِن قَبْلِكُمْ سُنَنٌۭ فَسِيرُوا۟ فِى ٱلْأَرْضِ فَٱنظُرُوا۟ كَيْفَ كَانَ عَٰقِبَةُ ٱلْمُكَذِّبِينَ","translation":"[MANY] WAYS of life have passed away before your time. Go, then, about the earth and behold what happened in the end to those who gave the lie to the truth:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/430.mp3","surahId":3,"words":[{"id":78848,"position":1,"arabic":"قَدْ","translation":"নিশ্চয়","audioUrl":"wbw/003_137_001.mp3","charTypeName":"word"},{"id":78849,"position":2,"arabic":"خَلَتْ","translation":"অতীত হয়েছে","audioUrl":"wbw/003_137_002.mp3","charTypeName":"word"},{"id":78850,"position":3,"arabic":"مِن","translation":"(থেকে)","audioUrl":"wbw/003_137_003.mp3","charTypeName":"word"},{"id":78851,"position":4,"arabic":"قَبْلِكُمْ","translation":"তোমাদের পূর্বে","audioUrl":"wbw/003_137_004.mp3","charTypeName":"word"},{"id":78852,"position":5,"arabic":"سُنَنٌۭ","translation":"বহুযুগ","audioUrl":"wbw/003_137_005.mp3","charTypeName":"word"},{"id":78853,"position":6,"arabic":"فَسِيرُوا۟","translation":"তোমরা তাই ভ্রমণ কর","audioUrl":"wbw/003_137_006.mp3","charTypeName":"word"},{"id":78854,"position":7,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/003_137_007.mp3","charTypeName":"word"},{"id":78855,"position":8,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/003_137_008.mp3","charTypeName":"word"},{"id":78856,"position":9,"arabic":"فَٱنظُرُوا۟","translation":"অতঃপর তোমরা দেখ","audioUrl":"wbw/003_137_009.mp3","charTypeName":"word"},{"id":78857,"position":10,"arabic":"كَيْفَ","translation":"কেমন","audioUrl":"wbw/003_137_010.mp3","charTypeName":"word"},{"id":78858,"position":11,"arabic":"كَانَ","translation":"ছিল","audioUrl":"wbw/003_137_011.mp3","charTypeName":"word"},{"id":78859,"position":12,"arabic":"عَـٰقِبَةُ","translation":"পরিণতি","audioUrl":"wbw/003_137_012.mp3","charTypeName":"word"},{"id":78860,"position":13,"arabic":"ٱلْمُكَذِّبِينَ","translation":"সত্য প্রত্যাখ্যানকারীদের","audioUrl":"wbw/003_137_013.mp3","charTypeName":"word"},{"id":78861,"position":14,"arabic":"١٣٧","translation":"(১৩৭)","audioUrl":null,"charTypeName":"end"}]},{"number":138,"arabic":"هَٰذَا بَيَانٌۭ لِّلنَّاسِ وَهُدًۭى وَمَوْعِظَةٌۭ لِّلْمُتَّقِينَ","translation":"this [should be] a clear lesson unto all men, and a guidance and an admonition unto the God-conscious.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/431.mp3","surahId":3,"words":[{"id":78938,"position":1,"arabic":"هَـٰذَا","translation":"এটা","audioUrl":"wbw/003_138_001.mp3","charTypeName":"word"},{"id":78939,"position":2,"arabic":"بَيَانٌۭ","translation":"সুস্পষ্ট বাণী","audioUrl":"wbw/003_138_002.mp3","charTypeName":"word"},{"id":78940,"position":3,"arabic":"لِّلنَّاسِ","translation":"লোকদের জন্য","audioUrl":"wbw/003_138_003.mp3","charTypeName":"word"},{"id":78941,"position":4,"arabic":"وَهُدًۭى","translation":"ও পথনির্দেশিকা","audioUrl":"wbw/003_138_004.mp3","charTypeName":"word"},{"id":78942,"position":5,"arabic":"وَمَوْعِظَةٌۭ","translation":"ও উপদেশ","audioUrl":"wbw/003_138_005.mp3","charTypeName":"word"},{"id":78943,"position":6,"arabic":"لِّلْمُتَّقِينَ","translation":"মুত্তাকীদের জন্য","audioUrl":"wbw/003_138_006.mp3","charTypeName":"word"},{"id":78944,"position":7,"arabic":"١٣٨","translation":"(১৩৮)","audioUrl":null,"charTypeName":"end"}]},{"number":139,"arabic":"وَلَا تَهِنُوا۟ وَلَا تَحْزَنُوا۟ وَأَنتُمُ ٱلْأَعْلَوْنَ إِن كُنتُم مُّؤْمِنِينَ","translation":"Be not, then, faint of heart, 