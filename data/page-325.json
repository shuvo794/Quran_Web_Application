{"id":325,"ayahs":[{"number":36,"arabic":"وَإِذَا رَءَاكَ ٱلَّذِينَ كَفَرُوٓا۟ إِن يَتَّخِذُونَكَ إِلَّا هُزُوًا أَهَٰذَا ٱلَّذِى يَذْكُرُ ءَالِهَتَكُمْ وَهُم بِذِكْرِ ٱلرَّحْمَٰنِ هُمْ كَٰفِرُونَ","translation":"But [thus it is:] whenever they who are bent on denying the truth consider thee, they make thee but a target of their mockery, [saying to one another,] “Is this the one who speaks [so contemptuously] of your gods?” and yet, it is they themselves who, at [every] mention of the Most Gracious, are wont to deny the truth!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2519.mp3","surahId":21,"words":[{"id":37781,"position":1,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/021_036_001.mp3","charTypeName":"word"},{"id":37782,"position":2,"arabic":"رَءَاكَ","translation":"তোমাকে দেখে","audioUrl":"wbw/021_036_002.mp3","charTypeName":"word"},{"id":37783,"position":3,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/021_036_003.mp3","charTypeName":"word"},{"id":37784,"position":4,"arabic":"كَفَرُوٓا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/021_036_004.mp3","charTypeName":"word"},{"id":37785,"position":5,"arabic":"إِن","translation":"না","audioUrl":"wbw/021_036_005.mp3","charTypeName":"word"},{"id":37786,"position":6,"arabic":"يَتَّخِذُونَكَ","translation":"তোমাকে তারা গ্রহণ করবে","audioUrl":"wbw/021_036_006.mp3","charTypeName":"word"},{"id":37787,"position":7,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/021_036_007.mp3","charTypeName":"word"},{"id":37788,"position":8,"arabic":"هُزُوًا","translation":"বিদ্রুপের পাত্র রূপে","audioUrl":"wbw/021_036_008.mp3","charTypeName":"word"},{"id":37789,"position":9,"arabic":"أَهَـٰذَا","translation":"\"(এবং বলে) এই কি","audioUrl":"wbw/021_036_009.mp3","charTypeName":"word"},{"id":37790,"position":10,"arabic":"ٱلَّذِى","translation":"(সেই ব্যক্তি) যে","audioUrl":"wbw/021_036_010.mp3","charTypeName":"word"},{"id":37791,"position":11,"arabic":"يَذْكُرُ","translation":"সমালোচনা করে","audioUrl":"wbw/021_036_011.mp3","charTypeName":"word"},{"id":37792,"position":12,"arabic":"ءَالِهَتَكُمْ","translation":"তোমাদের দেবদেবীদেরকে\"","audioUrl":"wbw/021_036_012.mp3","charTypeName":"word"},{"id":37793,"position":13,"arabic":"وَهُم","translation":"অথচ তারা","audioUrl":"wbw/021_036_013.mp3","charTypeName":"word"},{"id":37794,"position":14,"arabic":"بِذِكْرِ","translation":"নিয়ে আলোচনা","audioUrl":"wbw/021_036_014.mp3","charTypeName":"word"},{"id":37795,"position":15,"arabic":"ٱلرَّحْمَـٰنِ","translation":"রাহমানের","audioUrl":"wbw/021_036_015.mp3","charTypeName":"word"},{"id":37796,"position":16,"arabic":"هُمْ","translation":"তারাই","audioUrl":"wbw/021_036_016.mp3","charTypeName":"word"},{"id":37797,"position":17,"arabic":"كَـٰفِرُونَ","translation":"অস্বীকারকারী","audioUrl":"wbw/021_036_017.mp3","charTypeName":"word"},{"id":37798,"position":18,"arabic":"٣٦","translation":"(৩৬)","audioUrl":null,"charTypeName":"end"}]},{"number":37,"arabic":"خُلِقَ ٱلْإِنسَٰنُ مِنْ عَجَلٍۢ ۚ سَأُو۟رِيكُمْ ءَايَٰتِى فَلَا تَسْتَعْجِلُونِ","translation":"Man is a creature of haste; [but in time] I shall make obvious to you [the truth of] My mes­sages: do not, then, ask Me to hasten [it]!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2520.mp3","surahId":21,"words":[{"id":39160,"position":1,"arabic":"خُلِقَ","translation":"সৃষ্টি করা হয়েছে","audioUrl":"wbw/021_037_001.mp3","charTypeName":"word"},{"id":39161,"position":2,"arabic":"ٱلْإِنسَـٰنُ","translation":"মানুষকে","audioUrl":"wbw/021_037_002.mp3","charTypeName":"word"},{"id":39162,"position":3,"arabic":"مِنْ","translation":"দিয়ে","audioUrl":"wbw/021_037_003.mp3","charTypeName":"word"},{"id":39163,"position":4,"arabic":"عَجَلٍۢ ۚ","translation":"তাড়াহুড়া প্রবৃত্তি","audioUrl":"wbw/021_037_004.mp3","charTypeName":"word"},{"id":39165,"position":5,"arabic":"سَأُو۟رِيكُمْ","translation":"শীঘ্রই তোমাদেরকে আমি দেখাবো","audioUrl":"wbw/021_037_006.mp3","charTypeName":"word"},{"id":39166,"position":6,"arabic":"ءَايَـٰتِى","translation":"আমার নিদর্শনাবলী","audioUrl":"wbw/021_037_007.mp3","charTypeName":"word"},{"id":39167,"position":7,"arabic":"فَلَا","translation":"সুতরাং না","audioUrl":"wbw/021_037_008.mp3","charTypeName":"word"},{"id":39168,"position":8,"arabic":"تَسْتَعْجِلُونِ","translation":"আমার কাছে তোমরা তাড়াহুড়া করো","audioUrl":"wbw/021_037_009.mp3","charTypeName":"word"},{"id":39169,"position":9,"arabic":"٣٧","translation":"(৩৭)","audioUrl":null,"charTypeName":"end"}]},{"number":38,"arabic":"وَيَقُولُونَ مَتَىٰ هَٰذَا ٱلْوَعْدُ إِن كُنتُمْ صَٰدِقِينَ","translation":"But they [who reject My messages are wont to] ask, “When is that promise [of God’s judgment] to be fulfilled? [Answer this, O you who believe in it,] if you are men of truth!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2521.mp3","surahId":21,"words":[{"id":39730,"position":1,"arabic":"وَيَقُولُونَ","translation":"এবং তারা বলে","audioUrl":"wbw/021_038_001.mp3","charTypeName":"word"},{"id":39731,"position":2,"arabic":"مَتَىٰ","translation":"\"কখন (পূর্ণ হবে)","audioUrl":"wbw/021_038_002.mp3","charTypeName":"word"},{"id":39732,"position":3,"arabic":"هَـٰذَا","translation":"এই","audioUrl":"wbw/021_038_003.mp3","charTypeName":"word"},{"id":39733,"position":4,"arabic":"ٱلْوَعْدُ","translation":"(হুমকির) প্রতিশ্রুতি","audioUrl":"wbw/021_038_004.mp3","charTypeName":"word"},{"id":39734,"position":5,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/021_038_005.mp3","charTypeName":"word"},{"id":39735,"position":6,"arabic":"كُنتُمْ","translation":"তোমরা হও","audioUrl":"wbw/021_038_006.mp3","charTypeName":"word"},{"id":39736,"position":7,"arabic":"صَـٰدِقِينَ","translation":"সত্যবাদী\"","audioUrl":"wbw/021_038_007.mp3","charTypeName":"word"},{"id":39737,"position":8,"arabic":"٣٨","translation":"(৩৮)","audioUrl":null,"charTypeName":"end"}]},{"number":39,"arabic":"لَوْ يَعْلَمُ ٱلَّذِينَ كَفَرُوا۟ حِينَ لَا يَكُفُّونَ عَن وُجُوهِهِمُ ٱلنَّارَ وَلَا عَن ظُهُورِهِمْ وَلَا هُمْ يُنصَرُونَ","translation":"If they but knew - they who are bent on deny­ing the truth - [that there will come] a time when they will not be able to ward off the fire from their faces, nor from their backs, and will not find any succour!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2522.mp3","surahId":21,"words":[{"id":40978,"position":1,"arabic":"لَوْ","translation":"(হায়) যদি","audioUrl":"wbw/021_039_001.mp3","charTypeName":"word"},{"id":40979,"position":2,"arabic":"يَعْلَمُ","translation":"জানতো","audioUrl":"wbw/021_039_002.mp3","charTypeName":"word"},{"id":40980,"position":3,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/021_039_003.mp3","charTypeName":"word"},{"id":40981,"position":4,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/021_039_004.mp3","charTypeName":"word"},{"id":40982,"position":5,"arabic":"حِينَ","translation":"সে সময়ে (যখন)","audioUrl":"wbw/021_039_005.mp3","charTypeName":"word"},{"id":40983,"position":6,"arabic":"لَا","translation":"না","audioUrl":"wbw/021_039_006.mp3","charTypeName":"word"},{"id":40984,"position":7,"arabic":"يَكُفُّونَ","translation":"তারা প্রতিরোধ করতে পারবে","audioUrl":"wbw/021_039_007.mp3","charTypeName":"word"},{"id":40985,"position":8,"arabic":"عَن","translation":"হ'তে","audioUrl":"wbw/021_039_008.mp3","charTypeName":"word"},{"id":40986,"position":9,"arabic":"وُجُوهِهِمُ","translation":"তাদের মুখমন্ডলগুলো (সামনের দিক)","audioUrl":"wbw/021_039_009.mp3","charTypeName":"word"},{"id":40987,"position":10,"arabic":"ٱلنَّارَ","translation":"আগুনকে","audioUrl":"wbw/021_039_010.mp3","charTypeName":"word"},{"id":40988,"position":11,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/021_039_011.mp3","charTypeName":"word"},{"id":40989,"position":12,"arabic":"عَن","translation":"হ'তে","audioUrl":"wbw/021_039_012.mp3","charTypeName":"word"},{"id":40990,"position":13,"arabic":"ظُهُورِهِمْ","translation":"তাদের পৃষ্ঠসমূহ (পিছনেরর দিক)","audioUrl":"wbw/021_039_013.mp3","charTypeName":"word"},{"id":40991,"position":14,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/021_039_014.mp3","charTypeName":"word"},{"id":40992,"position":15,"arabic":"هُمْ","translation":"তাদের","audioUrl":"wbw/021_039_015.mp3","charTypeName":"word"},{"id":40993,"position":16,"arabic":"يُنصَرُونَ","translation":"সাহায্য করা হবে","audioUrl":"wbw/021_039_016.mp3","charTypeName":"word"},{"id":40994,"position":17,"arabic":"٣٩","translation":"(৩৯)","audioUrl":null,"charTypeName":"end"}]},{"number":40,"arabic":"بَلْ تَأْتِيهِم بَغْتَةًۭ فَتَبْهَتُهُمْ فَلَا يَسْتَطِيعُونَ رَدَّهَا وَلَا هُمْ يُنظَرُونَ","translation":"Nay, but [the Last Hour] will come upon them of a sudden, and will stupefy them: and they will be unable to avert it, and neither wilt they be allowed any respite.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2523.mp3","surahId":21,"words":[{"id":41273,"position":1,"arabic":"بَلْ","translation":"বরং","audioUrl":"wbw/021_040_001.mp3","charTypeName":"word"},{"id":41274,"position":2,"arabic":"تَأْتِيهِم","translation":"তাদের কাছে আসবে","audioUrl":"wbw/021_040_002.mp3","charTypeName":"word"},{"id":41275,"position":3,"arabic":"بَغْتَةًۭ","translation":"হঠাৎ করে","audioUrl":"wbw/021_040_003.mp3","charTypeName":"word"},{"id":41276,"position":4,"arabic":"فَتَبْهَتُهُمْ","translation":"অতঃপর তাদেরকে হতভম্ব করে দিবে","audioUrl":"wbw/021_040_004.mp3","charTypeName":"word"},{"id":41277,"position":5,"arabic":"فَلَا","translation":"তখন না","audioUrl":"wbw/021_040_005.mp3","charTypeName":"word"},{"id":41278,"position":6,"arabic":"يَسْتَطِيعُونَ","translation":"তারা সক্ষম হবে","audioUrl":"wbw/021_040_006.mp3","charTypeName":"word"},{"id":41279,"position":7,"arabic":"رَدَّهَا","translation":"তা রোধ করতে","audioUrl":"wbw/021_040_007.mp3","charTypeName":"word"},{"id":41280,"position":8,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/021_040_008.mp3","charTypeName":"word"},{"id":41281,"position":9,"arabic":"هُمْ","translation":"তাদের","audioUrl":"wbw/021_040_009.mp3","charTypeName":"word"},{"id":41282,"position":10,"arabic":"يُنظَرُونَ","translation":"অবকাশ দেয়া হবে","audioUrl":"wbw/021_040_010.mp3","charTypeName":"word"},{"id":41283,"position":11,"arabic":"٤٠","translation":"(৪০)","audioUrl":null,"charTypeName":"end"}]},{"number":41,"arabic":"وَلَقَدِ ٱسْتُهْزِئَ بِرُسُلٍۢ مِّن قَبْلِكَ فَحَاقَ بِٱلَّذِينَ سَخِرُوا۟ مِنْهُم مَّا كَانُوا۟ بِهِۦ يَسْتَهْزِءُونَ","translation":"And, indeed, [O Muhammad, even] before thy time have [God’s] apostles been derided - but those who scoffed at them were [in the end] overwhelmed by the very thing which they had been wont to deride.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2524.mp3","surahId":21,"words":[{"id":41995,"position":1,"arabic":"وَلَقَدِ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/021_041_001.mp3","charTypeName":"word"},{"id":41996,"position":2,"arabic":"ٱسْتُهْزِئَ","translation":"বিদ্রুপ করা হয়েছে","audioUrl":"wbw/021_041_002.mp3","charTypeName":"word"},{"id":41997,"position":3,"arabic":"بِرُسُلٍۢ","translation":"নিয়ে রাসূলদেরকে","audioUrl":"wbw/021_041_003.mp3","charTypeName":"word"},{"id":41998,"position":4,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/021_041_004.mp3","charTypeName":"word"},{"id":41999,"position":5,"arabic":"قَبْلِكَ","translation":"তোমার পূর্ব","audioUrl":"wbw/021_041_005.mp3","charTypeName":"word"},{"id":42000,"position":6,"arabic":"فَحَاقَ","translation":"অতঃপর ঘিরে নিয়েছিলো","audioUrl":"wbw/021_041_006.mp3","charTypeName":"word"},{"id":42001,"position":7,"arabic":"بِٱلَّذِينَ","translation":"সহ তাদেরকে","audioUrl":"wbw/021_041_007.mp3","charTypeName":"word"},{"id":42002,"position":8,"arabic":"سَخِرُوا۟","translation":"ঠাট্টা করেছিল (যারা)","audioUrl":"wbw/021_041_008.mp3","charTypeName":"word"},{"id":42003,"position":9,"arabic":"مِنْهُم","translation":"তাদের মধ্য হ'তে","audioUrl":"wbw/021_041_009.mp3","charTypeName":"word"},{"id":42004,"position":10,"arabic":"مَّا","translation":"ঐ জিনিস","audioUrl":"wbw/021_041_010.mp3","charTypeName":"word"},{"id":42005,"position":11,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/021_041_011.mp3","charTypeName":"word"},{"id":42006,"position":12,"arabic":"بِهِۦ","translation":"যা নিয়ে","audioUrl":"wbw/021_041_012.mp3","charTypeName":"word"},{"id":42007,"position":13,"arabic":"يَسْتَهْزِءُونَ","translation":"বিদ্রুত করত","audioUrl":"wbw/021_041_013.mp3","charTypeName":"word"},{"id":42008,"position":14,"arabic":"٤١","translation":"(৪১)","audioUrl":null,"charTypeName":"end"}]},{"number":42,"arabic":"قُلْ مَن يَكْلَؤُكُم بِٱلَّيْلِ وَٱلنَّهَارِ مِنَ ٱلرَّحْمَٰنِ ۗ بَلْ هُمْ عَن ذِكْرِ رَبِّهِم مُّعْرِضُونَ","translation":"Say: “Who could protect you, by night or by day, from the Most Gracious?” And yet, from a remembrance of their Sustainer do they stubbornly turn away!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2525.mp3","surahId":21,"words":[{"id":42957,"position":1,"arabic":"قُلْ","translation":"(হে নাবী) বলো","audioUrl":"wbw/021_042_001.mp3","charTypeName":"word"},{"id":42958,"position":2,"arabic":"مَن","translation":"\"কে","audioUrl":"wbw/021_042_002.mp3","charTypeName":"word"},{"id":42959,"position":3,"arabic":"يَكْلَؤُكُم","translation":"তোমাদেরকে রক্ষা করতে পারে","audioUrl":"wbw/021_042_003.mp3","charTypeName":"word"},{"id":42960,"position":4,"arabic":"بِٱلَّيْلِ","translation":"বেলায় রাতের","audioUrl":"wbw/021_042_004.mp3","charTypeName":"word"},{"id":42961,"position":5,"arabic":"وَٱلنَّهَارِ","translation":"বা দিনের","audioUrl":"wbw/021_042_005.mp3","charTypeName":"word"},{"id":42962,"position":6,"arabic":"مِنَ","translation":"থেকে","audioUrl":"wbw/021_042_006.mp3","charTypeName":"word"},{"id":42963,"position":7,"arabic":"ٱلرَّحْمَـٰنِ ۗ","translation":"রাহমান\"","audioUrl":"wbw/021_042_007.mp3","charTypeName":"word"},{"id":42965,"position":8,"arabic":"بَلْ","translation":"বরং","audioUrl":"wbw/021_042_009.mp3","charTypeName":"word"},{"id":42966,"position":9,"arabic":"هُمْ","translation":"তারাই","audioUrl":"wbw/021_042_010.mp3","charTypeName":"word"},{"id":42967,"position":10,"arabic":"عَن","translation":"হ'তে","audioUrl":"wbw/021_042_011.mp3","charTypeName":"word"},{"id":42968,"position":11,"arabic":"ذِكْرِ","translation":"স্বরণ","audioUrl":"wbw/021_042_012.mp3","charTypeName":"word"},{"id":42969,"position":12,"arabic":"رَبِّهِم","translation":"তাদের রবের","audioUrl":"wbw/021_042_013.mp3","charTypeName":"word"},{"id":42970,"position":13,"arabic":"مُّعْرِضُونَ","translation":"মুখ ফিরিয়ে নেয়","audioUrl":"wbw/021_042_014.mp3","charTypeName":"word"},{"id":42971,"position":14,"arabic":"٤٢","translation":"(৪২)","audioUrl":null,"charTypeName":"end"}]},{"number":43,"arabic":"أَمْ لَهُمْ ءَالِهَةٌۭ تَمْنَعُهُم مِّن دُونِنَا ۚ لَا يَسْتَطِيعُونَ نَصْرَ أَنفُسِهِمْ وَلَا هُم مِّنَّا يُصْحَبُونَ","translation":"Do they [really think that they] have deities that could shield them from Us? Those [alleged dei­ties] are not [even] able to succour themselves: hence, neither can they [who worship them hope to] be aided [by them] against Us.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2526.mp3","surahId":21,"words":[{"id":43648,"position":1,"arabic":"أَمْ","translation":"কি","audioUrl":"wbw/021_043_001.mp3","charTypeName":"word"},{"id":43649,"position":2,"arabic":"لَهُمْ","translation":"তাদের জন্যে (আছে)","audioUrl":"wbw/021_043_002.mp3","charTypeName":"word"},{"id":43650,"position":3,"arabic":"ءَالِهَةٌۭ","translation":"দেবদেবী","audioUrl":"wbw/021_043_003.mp3","charTypeName":"word"},{"id":43651,"position":4,"arabic":"تَمْنَعُهُم","translation":"তাদের রক্ষা করতে পারে","audioUrl":"wbw/021_043_004.mp3","charTypeName":"word"},{"id":43652,"position":5,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/021_043_005.mp3","charTypeName":"word"},{"id":43653,"position":6,"arabic":"دُونِنَا ۚ","translation":"আমাদের ছাড়া","audioUrl":"wbw/021_043_006.mp3","charTypeName":"word"},{"id":43655,"position":7,"arabic":"لَا","translation":"না","audioUrl":"wbw/021_043_008.mp3","charTypeName":"word"},{"id":43656,"position":8,"arabic":"يَسْتَطِيعُونَ","translation":"তারা সক্ষম","audioUrl":"wbw/021_043_009.mp3","charTypeName":"word"},{"id":43657,"position":9,"arabic":"نَصْرَ","translation":"সাহায্য করতে","audioUrl":"wbw/021_043_010.mp3","charTypeName":"word"},{"id":43658,"position":10,"arabic":"أَنفُسِهِمْ","translation":"তাদের নিজেদের","audioUrl":"wbw/021_043_011.mp3","charTypeName":"word"},{"id":43659,"position":11,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/021_043_012.mp3","charTypeName":"word"},{"id":43660,"position":12,"arabic":"هُم","translation":"তাদেরকে","audioUrl":"wbw/021_043_013.mp3","charTypeName":"word"},{"id":43661,"position":13,"arabic":"مِّنَّا","translation":"আমাদের বিরুদ্ধে","audioUrl":"wbw/021_043_014.mp3","charTypeName":"word"},{"id":43662,"position":14,"arabic":"يُصْحَبُونَ","translation":"সহযোগিতা দেয়া হবে","audioUrl":"wbw/021_043_015.mp3","charTypeName":"word"},{"id":43663,"position":15,"arabic":"٤٣","translation":"(৪৩)","audioUrl":null,"charTypeName":"end"}]},{"number":44,"arabic":"بَلْ مَتَّعْنَا هَٰٓؤُلَآءِ وَءَابَآءَهُمْ حَتَّىٰ طَالَ عَلَيْهِمُ ٱلْعُمُرُ ۗ أَفَلَا يَرَوْنَ أَنَّا نَأْتِى ٱلْأَرْضَ نَنقُصُهَا مِنْ أَطْرَافِهَآ ۚ أَفَهُمُ ٱلْغَٰلِبُونَ","translation":"Nay, We have allowed these [sinners] – as [We allowed] their forebears – to enjoy the good things of life for a great length of time: but then – have they never yet seen how We visit the earth [with Our punishment], gradually depriving it of all that is best thereon? Can they, then, [hope to] be the winners?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2527.mp3","surahId":21,"words":[{"id":44405,"position":1,"arabic":"بَلْ","translation":"বরং","audioUrl":"wbw/021_044_001.mp3","charTypeName":"word"},{"id":44406,"position":2,"arabic":"مَتَّعْنَا","translation":"আমরা ভোগসামগ্রী দিয়েছি","audioUrl":"wbw/021_044_002.mp3","charTypeName":"word"},{"id":44407,"position":3,"arabic":"هَـٰٓؤُلَآءِ","translation":"তাদেরকে","au