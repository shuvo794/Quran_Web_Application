{"id":346,"ayahs":[{"number":60,"arabic":"وَٱلَّذِينَ يُؤْتُونَ مَآ ءَاتَوا۟ وَّقُلُوبُهُمْ وَجِلَةٌ أَنَّهُمْ إِلَىٰ رَبِّهِمْ رَٰجِعُونَ","translation":"and who give whatever they [have to] give with their hearts trembling at the thought that unto their Sustainer they must return:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2733.mp3","surahId":23,"words":[{"id":54510,"position":1,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা (এমন যে)","audioUrl":"wbw/023_060_001.mp3","charTypeName":"word"},{"id":54511,"position":2,"arabic":"يُؤْتُونَ","translation":"(যখন) দান করে","audioUrl":"wbw/023_060_002.mp3","charTypeName":"word"},{"id":54512,"position":3,"arabic":"مَآ","translation":"যা কিছু","audioUrl":"wbw/023_060_003.mp3","charTypeName":"word"},{"id":54513,"position":4,"arabic":"ءَاتَوا۟","translation":"দান করার","audioUrl":"wbw/023_060_004.mp3","charTypeName":"word"},{"id":54514,"position":5,"arabic":"وَّقُلُوبُهُمْ","translation":"এ অবস্থায় যে তাদের অন্তর","audioUrl":"wbw/023_060_005.mp3","charTypeName":"word"},{"id":54515,"position":6,"arabic":"وَجِلَةٌ","translation":"কম্পিত থাকে","audioUrl":"wbw/023_060_006.mp3","charTypeName":"word"},{"id":54516,"position":7,"arabic":"أَنَّهُمْ","translation":"(এ ভেবে) যে তারা","audioUrl":"wbw/023_060_007.mp3","charTypeName":"word"},{"id":54517,"position":8,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/023_060_008.mp3","charTypeName":"word"},{"id":54518,"position":9,"arabic":"رَبِّهِمْ","translation":"তাদের রবের","audioUrl":"wbw/023_060_009.mp3","charTypeName":"word"},{"id":54519,"position":10,"arabic":"رَٰجِعُونَ","translation":"প্রত্যাবর্তনকারী","audioUrl":"wbw/023_060_010.mp3","charTypeName":"word"},{"id":54520,"position":11,"arabic":"٦٠","translation":"(৬০)","audioUrl":null,"charTypeName":"end"}]},{"number":61,"arabic":"أُو۟لَٰٓئِكَ يُسَٰرِعُونَ فِى ٱلْخَيْرَٰتِ وَهُمْ لَهَا سَٰبِقُونَ","translation":"it is they who vie with one another in doing good works, and it is they who outrun [all others] in attaining to them!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2734.mp3","surahId":23,"words":[{"id":55089,"position":1,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐসবলোক","audioUrl":"wbw/023_061_001.mp3","charTypeName":"word"},{"id":55090,"position":2,"arabic":"يُسَـٰرِعُونَ","translation":"দ্রুত সম্পাদন করে","audioUrl":"wbw/023_061_002.mp3","charTypeName":"word"},{"id":55091,"position":3,"arabic":"فِى","translation":"দিকে","audioUrl":"wbw/023_061_003.mp3","charTypeName":"word"},{"id":55092,"position":4,"arabic":"ٱلْخَيْرَٰتِ","translation":"কল্যাণের","audioUrl":"wbw/023_061_004.mp3","charTypeName":"word"},{"id":55093,"position":5,"arabic":"وَهُمْ","translation":"আর তারাই","audioUrl":"wbw/023_061_005.mp3","charTypeName":"word"},{"id":55094,"position":6,"arabic":"لَهَا","translation":"জন্যে তার","audioUrl":"wbw/023_061_006.mp3","charTypeName":"word"},{"id":55095,"position":7,"arabic":"سَـٰبِقُونَ","translation":"অগ্রগামী হয়","audioUrl":"wbw/023_061_007.mp3","charTypeName":"word"},{"id":55096,"position":8,"arabic":"٦١","translation":"(৬১)","audioUrl":null,"charTypeName":"end"}]},{"number":62,"arabic":"وَلَا نُكَلِّفُ نَفْسًا إِلَّا وُسْعَهَا ۖ وَلَدَيْنَا كِتَٰبٌۭ يَنطِقُ بِٱلْحَقِّ ۚ وَهُمْ لَا يُظْلَمُونَ","translation":"And [withal.] We do not burden any human being with more than he is well able to bear: for with Us is a record that speaks the truth [about what men do and can do]; and none shall be wronged.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2735.mp3","surahId":23,"words":[{"id":55655,"position":1,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/023_062_001.mp3","charTypeName":"word"},{"id":55656,"position":2,"arabic":"نُكَلِّفُ","translation":"দায়িত্ব দিই আমরা","audioUrl":"wbw/023_062_002.mp3","charTypeName":"word"},{"id":55657,"position":3,"arabic":"نَفْسًا","translation":"কাউকে","audioUrl":"wbw/023_062_003.mp3","charTypeName":"word"},{"id":55658,"position":4,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/023_062_004.mp3","charTypeName":"word"},{"id":55659,"position":5,"arabic":"وُسْعَهَا ۖ","translation":"তার সাধ্য","audioUrl":"wbw/023_062_005.mp3","charTypeName":"word"},{"id":55661,"position":6,"arabic":"وَلَدَيْنَا","translation":"আর আমাদের কাছে (আছে)","audioUrl":"wbw/023_062_007.mp3","charTypeName":"word"},{"id":55662,"position":7,"arabic":"كِتَـٰبٌۭ","translation":"এক কিতাব (আমলনামা)","audioUrl":"wbw/023_062_008.mp3","charTypeName":"word"},{"id":55663,"position":8,"arabic":"يَنطِقُ","translation":"ব্যক্ত করে (যা)","audioUrl":"wbw/023_062_009.mp3","charTypeName":"word"},{"id":55664,"position":9,"arabic":"بِٱلْحَقِّ ۚ","translation":"ভাবে যথাযথ","audioUrl":"wbw/023_062_010.mp3","charTypeName":"word"},{"id":55666,"position":10,"arabic":"وَهُمْ","translation":"এবং তাদেরকে","audioUrl":"wbw/023_062_012.mp3","charTypeName":"word"},{"id":55667,"position":11,"arabic":"لَا","translation":"না","audioUrl":"wbw/023_062_013.mp3","charTypeName":"word"},{"id":55668,"position":12,"arabic":"يُظْلَمُونَ","translation":"অত্যাচার করা হবে","audioUrl":"wbw/023_062_014.mp3","charTypeName":"word"},{"id":55669,"position":13,"arabic":"٦٢","translation":"(৬২)","audioUrl":null,"charTypeName":"end"}]},{"number":63,"arabic":"بَلْ قُلُوبُهُمْ فِى غَمْرَةٍۢ مِّنْ هَٰذَا وَلَهُمْ أَعْمَٰلٌۭ مِّن دُونِ ذَٰلِكَ هُمْ لَهَا عَٰمِلُونَ","translation":"NAY, [as for those who have torn asunder the unity of faith] - their hearts are lost in ignorance of all this! But apart from that [breach of unity] they have [on their conscience even worse] deeds; and they will [continue to] commit them","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2736.mp3","surahId":23,"words":[{"id":56172,"position":1,"arabic":"بَلْ","translation":"বরং","audioUrl":"wbw/023_063_001.mp3","charTypeName":"word"},{"id":56173,"position":2,"arabic":"قُلُوبُهُمْ","translation":"তাদের অন্তর (রয়েছে)","audioUrl":"wbw/023_063_002.mp3","charTypeName":"word"},{"id":56174,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/023_063_003.mp3","charTypeName":"word"},{"id":56175,"position":4,"arabic":"غَمْرَةٍۢ","translation":"অজ্ঞানতার","audioUrl":"wbw/023_063_004.mp3","charTypeName":"word"},{"id":56176,"position":5,"arabic":"مِّنْ","translation":"হ'তে","audioUrl":"wbw/023_063_005.mp3","charTypeName":"word"},{"id":56177,"position":6,"arabic":"هَـٰذَا","translation":"এ (বিষয়ে)","audioUrl":"wbw/023_063_006.mp3","charTypeName":"word"},{"id":56178,"position":7,"arabic":"وَلَهُمْ","translation":"আর রয়েছে তাদের","audioUrl":"wbw/023_063_007.mp3","charTypeName":"word"},{"id":56179,"position":8,"arabic":"أَعْمَـٰلٌۭ","translation":"অনেক কাজ","audioUrl":"wbw/023_063_008.mp3","charTypeName":"word"},{"id":56180,"position":9,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/023_063_009.mp3","charTypeName":"word"},{"id":56181,"position":10,"arabic":"دُونِ","translation":"ছাড়া","audioUrl":"wbw/023_063_010.mp3","charTypeName":"word"},{"id":56182,"position":11,"arabic":"ذَٰلِكَ","translation":"এই (পূর্ব বর্ণিত নিয়মের)","audioUrl":"wbw/023_063_011.mp3","charTypeName":"word"},{"id":56183,"position":12,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/023_063_012.mp3","charTypeName":"word"},{"id":56184,"position":13,"arabic":"لَهَا","translation":"জন্যে যার","audioUrl":"wbw/023_063_013.mp3","charTypeName":"word"},{"id":56185,"position":14,"arabic":"عَـٰمِلُونَ","translation":"করে যাচ্ছে","audioUrl":"wbw/023_063_014.mp3","charTypeName":"word"},{"id":56186,"position":15,"arabic":"٦٣","translation":"(৬৩)","audioUrl":null,"charTypeName":"end"}]},{"number":64,"arabic":"حَتَّىٰٓ إِذَآ أَخَذْنَا مُتْرَفِيهِم بِٱلْعَذَابِ إِذَا هُمْ يَجْـَٔرُونَ","translation":"until - after We shall have taken to task, through suffering, those from among them who [now] are lost in the pursuit of pleasures - they cry out in [belated] supplication.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2737.mp3","surahId":23,"words":[{"id":56636,"position":1,"arabic":"حَتَّىٰٓ","translation":"শেষ পর্যন্ত","audioUrl":"wbw/023_064_001.mp3","charTypeName":"word"},{"id":56637,"position":2,"arabic":"إِذَآ","translation":"যখন","audioUrl":"wbw/023_064_002.mp3","charTypeName":"word"},{"id":56638,"position":3,"arabic":"أَخَذْنَا","translation":"আমরা পাকড়াও করবো","audioUrl":"wbw/023_064_003.mp3","charTypeName":"word"},{"id":56639,"position":4,"arabic":"مُتْرَفِيهِم","translation":"তাদের ঐশ্বর্যশালীদেরকে","audioUrl":"wbw/023_064_004.mp3","charTypeName":"word"},{"id":56640,"position":5,"arabic":"بِٱلْعَذَابِ","translation":"দিয়ে শাস্তি","audioUrl":"wbw/023_064_005.mp3","charTypeName":"word"},{"id":56641,"position":6,"arabic":"إِذَا","translation":"তখন","audioUrl":"wbw/023_064_006.mp3","charTypeName":"word"},{"id":56642,"position":7,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/023_064_007.mp3","charTypeName":"word"},{"id":56643,"position":8,"arabic":"يَجْـَٔرُونَ","translation":"চিৎকার করে উঠবে","audioUrl":"wbw/023_064_008.mp3","charTypeName":"word"},{"id":56644,"position":9,"arabic":"٦٤","translation":"(৬৪)","audioUrl":null,"charTypeName":"end"}]},{"number":65,"arabic":"لَا تَجْـَٔرُوا۟ ٱلْيَوْمَ ۖ إِنَّكُم مِّنَّا لَا تُنصَرُونَ","translation":"[But they will be told:] “Cry not in supplication today: for, behold, you shall not he succoured by Us!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2738.mp3","surahId":23,"words":[{"id":57210,"position":1,"arabic":"لَا","translation":"\"না","audioUrl":"wbw/023_065_001.mp3","charTypeName":"word"},{"id":57211,"position":2,"arabic":"تَجْـَٔرُوا۟","translation":"(বলা হবে) চিৎকার করো","audioUrl":"wbw/023_065_002.mp3","charTypeName":"word"},{"id":57212,"position":3,"arabic":"ٱلْيَوْمَ ۖ","translation":"আজ","audioUrl":"wbw/023_065_003.mp3","charTypeName":"word"},{"id":57214,"position":4,"arabic":"إِنَّكُم","translation":"নিশ্চয়ই তোমাদেরকে","audioUrl":"wbw/023_065_005.mp3","charTypeName":"word"},{"id":57215,"position":5,"arabic":"مِّنَّا","translation":"আমাদের হ'তে","audioUrl":"wbw/023_065_006.mp3","charTypeName":"word"},{"id":57216,"position":6,"arabic":"لَا","translation":"না","audioUrl":"wbw/023_065_007.mp3","charTypeName":"word"},{"id":57217,"position":7,"arabic":"تُنصَرُونَ","translation":"সাহায্য করা হবে","audioUrl":"wbw/023_065_008.mp3","charTypeName":"word"},{"id":57218,"position":8,"arabic":"٦٥","translation":"(৬৫)","audioUrl":null,"charTypeName":"end"}]},{"number":66,"arabic":"قَدْ كَانَتْ ءَايَٰتِى تُتْلَىٰ عَلَيْكُمْ فَكُنتُمْ عَلَىٰٓ أَعْقَٰبِكُمْ تَنكِصُونَ","translation":"Time and again were My messages conveyed unto you, but [every time] you would turn about on your heels","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2739.mp3","surahId":23,"words":[{"id":57712,"position":1,"arabic":"قَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/023_066_001.mp3","charTypeName":"word"},{"id":57713,"position":2,"arabic":"كَانَتْ","translation":"হতো","audioUrl":"wbw/023_066_002.mp3","charTypeName":"word"},{"id":57714,"position":3,"arabic":"ءَايَـٰتِى","translation":"আমার আয়াতগুলোকে","audioUrl":"wbw/023_066_003.mp3","charTypeName":"word"},{"id":57715,"position":4,"arabic":"تُتْلَىٰ","translation":"তিলাওয়াত করা হতো","audioUrl":"wbw/023_066_004.mp3","charTypeName":"word"},{"id":57716,"position":5,"arabic":"عَلَيْكُمْ","translation":"তোমাদের কাছে","audioUrl":"wbw/023_066_005.mp3","charTypeName":"word"},{"id":57717,"position":6,"arabic":"فَكُنتُمْ","translation":"তখন তোমরা ছিলে","audioUrl":"wbw/023_066_006.mp3","charTypeName":"word"},{"id":57718,"position":7,"arabic":"عَلَىٰٓ","translation":"উপর","audioUrl":"wbw/023_066_007.mp3","charTypeName":"word"},{"id":57719,"position":8,"arabic":"أَعْقَـٰبِكُمْ","translation":"তোমাদের গোড়ালির (পিছনে)","audioUrl":"wbw/023_066_008.mp3","charTypeName":"word"},{"id":57720,"position":9,"arabic":"تَنكِصُونَ","translation":"পিছিয়ে আসতে","audioUrl":"wbw/023_066_009.mp3","charTypeName":"word"},{"id":57721,"position":10,"arabic":"٦٦","translation":"(৬৬)","audioUrl":null,"charTypeName":"end"}]},{"number":67,"arabic":"مُسْتَكْبِرِينَ بِهِۦ سَٰمِرًۭا تَهْجُرُونَ","translation":"[and,] impelled by your arrogance, you would talk senselessly far into the night.”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2740.mp3","surahId":23,"words":[{"id":58128,"position":1,"arabic":"مُسْتَكْبِرِينَ","translation":"অহংকারী হয়ে (গুরুত্ব দিতে না)","audioUrl":"wbw/023_067_001.mp3","charTypeName":"word"},{"id":58129,"position":2,"arabic":"بِهِۦ","translation":"সম্পর্কে এ","audioUrl":"wbw/023_067_002.mp3","charTypeName":"word"},{"id":58130,"position":3,"arabic":"سَـٰمِرًۭا","translation":"গল্পগুজবে মেতে","audioUrl":"wbw/023_067_003.mp3","charTypeName":"word"},{"id":58131,"position":4,"arabic":"تَهْجُرُونَ","translation":"তোমরা অর্থহীন কথা বলতে\"","audioUrl":"wbw/023_067_004.mp3","charTypeName":"word"},{"id":58132,"position":5,"arabic":"٦٧","translation":"(৬৭)","audioUrl":null,"charTypeName":"end"}]},{"number":68,"arabic":"أَفَلَمْ يَدَّبَّرُوا۟ ٱلْقَوْلَ أَمْ جَآءَهُم مَّا لَمْ يَأْتِ ءَابَآءَهُمُ ٱلْأَوَّلِينَ","translation":"Have they, then, never tried to understand this word [of God]? Or has there [now] come to them something that never came to their forefathers of old?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2741.mp3","surahId":23,"words":[{"id":58703,"position":1,"arabic":"أَفَلَمْ","translation":"কি তবে না","audioUrl":"wbw/023_068_001.mp3","charTypeName":"word"},{"id":58704,"position":2,"arabic":"يَدَّبَّرُوا۟","translation":"তারা চিন্তা ভাবনা করে","audioUrl":"wbw/023_068_002.mp3","charTypeName":"word"},{"id":58705,"position":3,"arabic":"ٱلْقَوْلَ","translation":"(এই) বাণী (সম্পর্কে)","audioUrl":"wbw/023_068_003.mp3","charTypeName":"word"},{"id":58706,"position":4,"arabic":"أَمْ","translation":"অথবা","audioUrl":"wbw/023_068_004.mp3","charTypeName":"word"},{"id":58707,"position":5,"arabic":"جَآءَهُم","translation":"(সে) এসেছে তাদের (কাছে)","audioUrl":"wbw/023_068_005.mp3","charTypeName":"word"},{"id":58708,"position":6,"arabic":"مَّا","translation":"(এমন কিছু নিয়ে) যা","audioUrl":"wbw/023_068_006.mp3","charTypeName":"word"},{"id":58709,"position":7,"arabic":"لَمْ","translation":"নি","audioUrl":"wbw/023_068_007.mp3","charTypeName":"word"},{"id":58710,"position":8,"arabic":"يَأْتِ","translation":"আসে","audioUrl":"wbw/023_068_008.mp3","charTypeName":"word"},{"id":58711,"position":9,"arabic":"ءَابَآءَهُمُ","translation":"তাদের পিতৃপুরুষদের (কাছে)","audioUrl":"wbw/023_068_009.mp3","charTypeName":"word"},{"id":58712,"position":10,"arabic":"ٱلْأَوَّلِينَ","translation":"পূর্বেকার","audioUrl":"wbw/023_068_010.mp3","charTypeName":"word"},{"id":58713,"position":11,"arabic":"٦٨","translation":"(৬৮)","audioUrl":null,"charTypeName":"end"}]},{"number":69,"arabic":"أَمْ لَمْ يَعْرِفُوا۟ رَسُولَهُمْ فَهُمْ لَهُۥ مُنكِرُونَ","translation":"Or is it, perchance, that they have not recog­nized their Apostle, and so they disavow him?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2742.mp3","surahId":23,"words":[{"id":59119,"position":1,"arabic":"أَمْ","translation":"অথবা","audioUrl":"wbw/023_069_001.mp3","charTypeName":"word"},{"id":59120,"position":2,"arabic":"لَمْ","translation":"না","audioUrl":"wbw/023_069_002.mp3","charTypeName":"word"},{"id":59121,"position":3,"arabic":"يَعْرِفُوا۟","translation":"তারা চিনে","audioUrl":"wbw/023_069_003.mp3","charTypeName":"word"},{"id":59122,"position":4,"arabic":"رَسُولَهُمْ","translation":"তাদের রাসূলকে","audioUrl":"wbw/023_069_004.mp3","charTypeName":"word"},{"id":59123,"position":5,"arabic":"فَهُمْ","translation":"তাই তারা","audioUrl":"wbw/023_069_005.mp3","charTypeName":"word"},{"id":59124,"position":6,"arabic":"لَهُۥ","translation":"প্রতি তার","audioUrl":"wbw/023_069_006.mp3","charTypeName":"word"},{"id":59125,"position":7,"arabic":"مُنكِرُونَ","translation":"অস্বীকারকারী হয়েছে","audioUrl":"wbw/023_069_007.mp3","charTypeName":"word"},{"id":59126,"position":8,"arabic":"٦٩","translation":"(৬৯)","audioUrl":null,"charTypeName":"end"}]},{"number":70,"arabic":"أَمْ يَقُولُونَ بِهِۦ جِنَّةٌۢ ۚ بَلْ جَآءَهُم بِٱلْحَقِّ وَأَكْثَرُهُمْ لِلْحَقِّ كَٰرِهُونَ","translation":"Or do they say. “There is madness in him”? Nay, he has brought them the truth - and the truth do most of them detest!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2743.mp3","surahId":23,"words":[{"id":59541,"position":1,"arabic":"أَمْ","translation":"অথবা","audioUrl":"wbw/023_070_001.mp3","charTypeName":"word"},{"id":59542,"position":2,"arabic":"يَقُولُونَ","translation":"তারা বলে","audioUrl":"wbw/023_070_002.mp3","charTypeName":"word"},{"id":59543,"position":3,"arabic":"بِهِۦ","translation":"\"তার সাথে (আছে)","audioUrl":"wbw/023_070_003.mp3","charTypeName":"word"},{"id":59544,"position":4,"arabic":"جِنَّةٌۢ ۚ","translation":"জ্বিন\"","audioUrl":"wbw/023_070_004.mp3","charTypeName":"word"},{"id":59546,"position":5,"arabic":"بَلْ","translation":"বরং","audioUrl":"wbw/023_070_006.mp3","charTypeName":"word"},{"id":59547,"position":6,"arabic":"جَآءَهُم","translation":"সে এসেছে তাদের (নিকট)","audioUrl":"wbw/023_070_007.mp3","charTypeName":"word"},{"id":59548,"position":7,"arabic":"بِٱلْحَقِّ","translation":"নিয়ে সত্যকে","audioUrl":"wbw/023_070_008.mp3","charTypeName":"word"},{"id":59549,"position":8,"arabic":"وَأَكْثَرُهُمْ","translation":"অথচ অধিকাংশ তাদের","audioUrl":"wbw/023_070_009.mp3","charTypeName":"word"},{"id":59550,"position":9,"arabic":"لِلْحَقِّ","translation":"প্রতি সত্যের","audioUrl":"wbw/023_070_010.mp3","charTypeName":"word"},{"id":59551,"position":10,"arabic":"كَـٰرِهُونَ","translation":"অপছন্দকারী","audioUrl":"wbw/023_070_011.mp3","charTypeName":"word"},{"id":59552,"position":11,"arabic":"٧٠","translation":"(৭০)","audioUrl":null,"charTypeName":"end"}]},{"number":71,"arabic":"وَلَوِ ٱتَّبَعَ ٱلْحَقُّ أَهْوَآءَهُمْ لَفَسَدَتِ ٱلسَّمَٰوَٰتُ وَٱلْأَرْضُ وَمَن فِيهِنَّ ۚ بَلْ أَتَيْنَٰهُم بِذِكْرِهِمْ فَهُمْ عَن ذِكْرِهِم مُّعْرِضُونَ","translation":"But if the truth were in accord with their own likes and dislikes, the heavens and the earth would surely have fallen into ruin, and all that lives in them [would long ago have perished]! Nay, [in this divine writ] We have conveyed unto them all that they ought to bear in mind: and from this their reminder they [heedlessly] turn away!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2744.mp3","surahId":23,"words":[{"id":59998,"position":1,"arabic":"وَلَوِ","translation":"আর যদি","audioUrl":"wbw/023_071_001.mp3","charTypeName":"word"},{"id":59999,"position":2,"arabic":"ٱتَّبَعَ","translation":"অনুসরণ করতো","audioUrl":"wbw/023_071_002.mp3","charTypeName":"word"},{"id":60000,"position":3,"arabic":"ٱلْحَقُّ","translation":"সত্য্","audioUrl":"wbw/023_071_003.mp3","charTypeName":"word"},{"id":60001,"position":4,"arabic":"أَهْوَآءَهُمْ","translation":"কামনা-বাসনার তাদের","audioUrl":"wbw/023_071_004.mp3","charTypeName":"word"},{"id":60002,"position":5,"arabic":"لَفَسَدَتِ","translation":"অবশ্যই বিশৃঙ্খল হয়ে পড়তো","audioUrl":"wbw/023_071_005.mp3","charTypeName":"word"},{"id":60003,"position":6,"arabic":"ٱلسَّمَـٰوَٰتُ","translation":"আকাশমন্ডলি","audioUrl":"wbw/023_071_006.mp3","charTypeName":"word"},{"id":60004,"position":7,"arabic":"وَٱلْأَرْضُ","translation":"ও পৃথিবী","audioUrl":"wbw/023_071_007.mp3","charTypeName":"word"},{"id":60005,"position":8,"arabic":"وَمَن","translation":"আর যাকিছু (আছে)","audioUrl":"wbw/023_071_008.mp3","charTypeName":"word"},{"id":60006,"position":9,"arabic":"فِيهِنَّ ۚ","translation":"তাদের মাঝে","audioUrl":"wbw/023_071_009.mp3","charTypeName":"word"},{"id":60008,"position":10,"arabic":"بَلْ","translation":"বরং","audioUrl":"wbw/023_071_011.mp3","charTypeName":"word"},{"id":60009,"position":11,"arabic":"أَتَيْنَـٰهُم","translation":"তাদেরকে আমরা দিয়েছি","audioUrl":"wbw/023_071_012.mp3","charTypeName":"word"},{"id":60010,"position":12,"arabic":"بِذِكْرِهِمْ","translation":"বিষয়কে তাদের উপদেশের (অর্থাৎ কুরআন)","audioUrl":"wbw/023_071_013.mp3","charTypeName":"word"},{"id":60011,"position":13,"arabic":"فَهُمْ","translation":"কিন্তু তারা","audioUrl":"wbw/023_071_014.mp3","charTypeName":"word"},{"id":60012,"position":14,"arabic":"عَن","translation":"হ'তে","audioUrl":"wbw/023_071_015.mp3","charTypeName":"word"},{"id":60013,"position":15,"arabic":"ذِكْرِهِم","translation":"উপদেশ তাদের","audioUrl":"wbw/023_071_016.mp3","charTypeName":"word"},{"id":60014,"position":16,"arabic":"مُّعْرِضُونَ","translation":"মুখ ফিরিয়ে নিচ্ছে","audioUrl":"wbw/023_071_017.mp3","charTypeName":"word"},{"id":60015,"position":17,"arabic":"٧١","translation":"(৭১)","audioUrl":null,"charTypeName":"end"}]},{"number":72,"arabic":"أَمْ تَسْـَٔلُهُمْ خَرْجًۭا فَخَرَاجُ رَبِّكَ خَيْرٌۭ ۖ وَهُوَ خَيْرُ ٱلرَّٰزِقِينَ","translation":"Or dost thou [O Muhammad] ask of them any worldly recompense? But [they ought to know that] recompense from thy Sustainer is best, since He is the best of providers!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2745.mp3","surahId":23,"words":[{"id":60441,"position":1,"arabic":"أَمْ","translation":"অথবা কি","audioUrl":"wbw/023_072_001.mp3","charTypeName":"word"},{"id":60442,"position":2,"arabic":"تَسْـَٔلُهُمْ","translation":"তাদের (নিকট) তুমি চাচ্ছো","audioUrl":"wbw/023_072_002.mp3","charTypeName":"word"},{"id":60443,"position":3,"arabic":"خَرْجًۭا","translation":"কোন প্রতিদান","audioUrl":"wbw/023_072_003.mp3","charTypeName":"word"},{"id":60444,"position":4,"arabic":"فَخَرَاجُ","translation":"অথচ প্রতিদান","audioUrl":"wbw/023_072_004.mp3","charTypeName":"word"},{"id":60445,"position":5,"arabic":"رَبِّكَ","translation":"তোমার রবেরই","audioUrl":"wbw/023_072_005.mp3","charTypeName":"word"},{"id":60446,"position":6,"arabic":"خَيْرٌۭ ۖ","translation":"উত্তম","audioUrl":"wbw/023_072_006.mp3","charTypeName":"word"},{"id":60448,"position":7,"arabic":"وَهُوَ","translation":"আর তিনিই","audioUrl":"wbw/023_072_008.mp3","charTypeName":"word"},{"id":60449,"position":8,"arabic":"خَيْرُ","translation":"উত্তম","audioUrl":"wbw/023_072_009.mp3","charTypeName":"word"},{"id":60450,"position":9,"arabic":"ٱلرَّٰزِقِينَ","translation":"জীবিকাদাতাদের","audioUrl":"wbw/023_072_010.mp3","charTypeName":"word"},{"id":60451,"position":10,"arabic":"٧٢","translation":"(৭২)","audioUrl":null,"charTypeName":"end"}]},{"number":73,"arabic":"وَإِنَّكَ لَتَدْعُوهُمْ إِلَىٰ صِرَٰطٍۢ مُّسْتَقِيمٍۢ","translation":"And, verily, thou callest them onto a straight way –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2746.mp3","surahId":23,"words":[{"id":60888,"position":1,"arabic":"وَإِنَّكَ","translation":"আর তুমি নিশ্চয়ই","audioUrl":"wbw/023_073_001.mp3","charTypeName":"word"},{"id":60889,"position":2,"arabic":"لَتَدْعُوهُمْ","translation":"অবশ্যই ডাকছো তাদেরকে","audioUrl":"wbw/023_073_002.mp3","charTypeName":"word"},{"id":60890,"position":3,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/023_073_003.mp3","charTypeName":"word"},{"id":60891,"position":4,"arabic":"صِرَٰطٍۢ","translation":"পথের","audioUrl":"wbw/023_073_004.mp3","charTypeName":"word"},{"id":60892,"position":5,"arabic":"مُّسْتَقِيمٍۢ","translation":"সরল-সোজা","audioUrl":"wbw/023_073_005.mp3","charTypeName":"word"},{"id":60893,"position":6,"arabic":"٧٣","translation":"(৭৩)","audioUrl":null,"charTypeName":"end"}]},{"number":74,"arabic":"وَإِنَّ ٱلَّذِينَ لَا يُؤْمِنُونَ بِٱلْءَاخِرَةِ عَنِ ٱلصِّرَٰطِ لَنَٰكِبُونَ","translation":"but, behold, those who will not believe in the life to come are bound to deviate from that way.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2747.mp3","surahId":23,"words":[{"id":61479,"position":1,"arabic":"وَإِنَّ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/023_074_001.mp3","charTypeName":"word"},{"id":61480,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/023_074_002.mp3","charTypeName":"word"},{"id":61481,"position":3,"arabic":"لَا","translation":"না","audioUrl":"wbw/023_074_003.mp3","charTypeName":"word"},{"id":61482,"position":4,"arabic":"يُؤْمِنُونَ","translation":"ঈমান আনে","audioUrl":"wbw/023_074_004.mp3","charTypeName":"word"},{"id":61483,"position":5,"arabic":"بِٱلْـَٔاخِرَةِ","translation":"প্রতি আখিরাতের","audioUrl":"wbw/023_074_005.mp3","charTypeName":"word"},{"id":61484,"position":6,"arabic":"عَنِ","translation":"(তারাই) হ'তে","audioUrl":"wbw/023_074_006.mp3","charTypeName":"word"},{"id":61485,"position":7,"arabic":"ٱلصِّرَٰطِ","translation":"সরল সঠিক পথ","audioUrl":"wbw/023_074_007.mp3","charTypeName":"word"},{"id":61486,"position":8,"arabic":"لَنَـٰكِبُونَ","translation":"অবশ্যই বিচ্যুত","audioUrl":"wbw/023_074_008.mp3","charTypeName":"word"},{"id":61487,"position":9,"arabic":"٧٤","translation":"(৭৪)","audioUrl":null,"charTypeName":"end"}]}]}