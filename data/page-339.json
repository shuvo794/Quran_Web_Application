{"id":339,"ayahs":[{"number":56,"arabic":"ٱلْمُلْكُ يَوْمَئِذٍۢ لِّلَّهِ يَحْكُمُ بَيْنَهُمْ ۚ فَٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ فِى جَنَّٰتِ ٱلنَّعِيمِ","translation":"On that Day, all dominion shall [visibly] belong to God, He shall judge [all men and make a distinction] between them: thus, all who had attained to faith and did righteous deeds shall find themselves in gardens of bliss,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2651.mp3","surahId":22,"words":[{"id":52067,"position":1,"arabic":"ٱلْمُلْكُ","translation":"চূড়ান্ত কর্তৃত্ব","audioUrl":"wbw/022_056_001.mp3","charTypeName":"word"},{"id":52068,"position":2,"arabic":"يَوْمَئِذٍۢ","translation":"সেদিন হবে","audioUrl":"wbw/022_056_002.mp3","charTypeName":"word"},{"id":52069,"position":3,"arabic":"لِّلَّهِ","translation":"জন্যে আল্লাহরই","audioUrl":"wbw/022_056_003.mp3","charTypeName":"word"},{"id":52070,"position":4,"arabic":"يَحْكُمُ","translation":"তিনি বিচার করবেন","audioUrl":"wbw/022_056_004.mp3","charTypeName":"word"},{"id":52071,"position":5,"arabic":"بَيْنَهُمْ ۚ","translation":"তাদের মাঝে","audioUrl":"wbw/022_056_005.mp3","charTypeName":"word"},{"id":52073,"position":6,"arabic":"فَٱلَّذِينَ","translation":"সুতরাং যারা","audioUrl":"wbw/022_056_007.mp3","charTypeName":"word"},{"id":52074,"position":7,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/022_056_008.mp3","charTypeName":"word"},{"id":52075,"position":8,"arabic":"وَعَمِلُوا۟","translation":"ও কাজ করেছে","audioUrl":"wbw/022_056_009.mp3","charTypeName":"word"},{"id":52076,"position":9,"arabic":"ٱلصَّـٰلِحَـٰتِ","translation":"সৎকাজসমূহের","audioUrl":"wbw/022_056_010.mp3","charTypeName":"word"},{"id":52077,"position":10,"arabic":"فِى","translation":"(তারা থাকবে) মধ্যে","audioUrl":"wbw/022_056_011.mp3","charTypeName":"word"},{"id":52078,"position":11,"arabic":"جَنَّـٰتِ","translation":"জান্নাতসমূহের","audioUrl":"wbw/022_056_012.mp3","charTypeName":"word"},{"id":52079,"position":12,"arabic":"ٱلن