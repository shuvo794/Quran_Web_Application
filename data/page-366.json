abic":"لَهُ","translation":"তার জন্যই","audioUrl":"wbw/025_069_002.mp3","charTypeName":"word"},{"id":59341,"position":3,"arabic":"ٱلْعَذَابُ","translation":"শাস্তি","audioUrl":"wbw/025_069_003.mp3","charTypeName":"word"},{"id":59342,"position":4,"arabic":"يَوْمَ","translation":"দিনে","audioUrl":"wbw/025_069_004.mp3","charTypeName":"word"},{"id":59343,"position":5,"arabic":"ٱلْقِيَـٰمَةِ","translation":"ক্বিয়ামাতের","audioUrl":"wbw/025_069_005.mp3","charTypeName":"word"},{"id":59344,"position":6,"arabic":"وَيَخْلُدْ","translation":"এবং স্থায়ী হবে","audioUrl":"wbw/025_069_006.mp3","charTypeName":"word"},{"id":59345,"position":7,"arabic":"فِيهِۦ","translation":"তার মধ্যে","audioUrl":"wbw/025_069_007.mp3","charTypeName":"word"},{"id":59346,"position":8,"arabic":"مُهَانًا","translation":"হীন অবস্থায়","audioUrl":"wbw/025_069_008.mp3","charTypeName":"word"},{"id":59347,"position":9,"arabic":"٦٩","translation":"(৬৯)","audioUrl":null,"charTypeName":"end"}]},{"number":70,"arabic":"إِلَّا مَن تَابَ وَءَامَنَ وَعَمِلَ عَمَلًۭا صَٰلِحًۭا فَأُو۟لَٰٓئِكَ يُبَدِّلُ ٱللَّهُ سَيِّـَٔاتِهِمْ حَسَنَٰتٍۢ ۗ وَكَانَ ٱللَّهُ غَفُورًۭا رَّحِيمًۭا","translation":"Excepted, however, shall be they who repent and attain to faith and do righteous deeds: for it is they whose [erstwhile] bad deeds God will transform into good ones - seeing that God is indeed much-forgiving, a dispenser of grace,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2925.mp3","surahId":25,"words":[{"id":59792,"position":1,"arabic":"إِلَّا","translation":"তবেে","audioUrl":"wbw/025_070_001.mp3","charTypeName":"word"},{"id":59793,"position":2,"arabic":"مَن","translation":"যে","audioUrl":"wbw/025_070_002.mp3","charTypeName":"word"},{"id":59794,"position":3,"arabic":"تَابَ","translation":"তওবা করবে","audioUrl":"wbw/025_070_003.mp3","charTypeName":"word"},{"id":59795,"position":4,"arabic":"وَءَامَنَ","translation":"ও ঈমান আনবে","audioUrl":"wbw/025_070_004.mp3","charTypeName":"word"},{"id":59796,"position":5,"arabic":"وَعَمِلَ","translation":"ও কাজ করবে","audioUrl":"wbw/025_070_005.mp3","charTypeName":"word"},{"id":59797,"position":6,"arabic":"عَمَلًۭا","translation":"কর্ম","audioUrl":"wbw/025_070_006.mp3","charTypeName":"word"},{"id":59798,"position":7,"arabic":"صَـٰلِحًۭا","translation":"সৎ","audioUrl":"wbw/025_070_007.mp3","charTypeName":"word"},{"id":59799,"position":8,"arabic":"فَأُو۟لَـٰٓئِكَ","translation":"তখন ঐসব লোকদেরকে","audioUrl":"wbw/025_070_008.mp3","charTypeName":"word"},{"id":59800,"position":9,"arabic":"يُبَدِّلُ","translation":"পরিবর্তন করে দিবেন","audioUrl":"wbw/025_070_009.mp3","charTypeName":"word"},{"id":59801,"position":10,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/025_070_010.mp3","charTypeName":"word"},{"id":59802,"position":11,"arabic":"سَيِّـَٔاتِهِمْ","translation":"তাদের অন্যায়কে","audioUrl":"wbw/025_070_011.mp3","charTypeName":"word"},{"id":59803,"position":12,"arabic":"حَسَنَـٰتٍۢ ۗ","translation":"ভালোয়","audioUrl":"wbw/025_070_012.mp3","charTypeName":"word"},{"id":59805,"position":13,"arabic":"وَكَانَ","translation":"আর হলেন","audioUrl":"wbw/025_070_014.mp3","charTypeName":"word"},{"id":59806,"position":14,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/025_070_015.mp3","charTypeName":"word"},{"id":59807,"position":15,"arabic":"غَفُورًۭا","translation":"ক্ষমাশীল","audioUrl":"wbw/025_070_016.mp3","charTypeName":"word"},{"id":59808,"position":16,"arabic":"رَّحِيمًۭا","translation":"পরম দয়ালু","audioUrl":"wbw/025_070_017.mp3","charTypeName":"word"},{"id":59809,"position":17,"arabic":"٧٠","translation":"(৭০)","audioUrl":null,"charTypeName":"end"}]},{"number":71,"arabic":"وَمَن تَابَ وَعَمِلَ صَٰلِحًۭا فَإِنَّهُۥ يَتُوبُ إِلَى ٱللَّهِ مَتَابًۭا","translation":"and seeing that he who repents and [thenceforth] does what is right has truly turned unto God by [this very act of] repent­ance.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2926.mp3","surahId":25,"words":[{"id":60250,"position":1,"arabic":"وَمَن","translation":"এবং যে","audioUrl":"wbw/025_071_001.mp3","charTypeName":"word"},{"id":60251,"position":2,"arabic":"تَابَ","translation":"তওবা করে","audioUrl":"wbw/025_071_002.mp3","charTypeName":"word"},{"id":60252,"position":3,"arabic":"وَعَمِلَ","translation":"ও কাজ করে","audioUrl":"wbw/025_071_003.mp3","charTypeName":"word"},{"id":60253,"position":4,"arabic":"صَـٰلِحًۭا","translation":"সৎ","audioUrl":"wbw/025_071_004.mp3","charTypeName":"word"},{"id":60254,"position":5,"arabic":"فَإِنَّهُۥ","translation":"তখন নিশ্চয়ই সে","audioUrl":"wbw/025_071_005.mp3","charTypeName":"word"},{"id":60255,"position":6,"arabic":"يَتُوبُ","translation":"ফিরে আসে","audioUrl":"wbw/025_071_006.mp3","charTypeName":"word"},{"id":60256,"position":7,"arabic":"إِلَى","translation":"দিকে","audioUrl":"wbw/025_071_007.mp3","charTypeName":"word"},{"id":60257,"position":8,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/025_071_008.mp3","charTypeName":"word"},{"id":60258,"position":9,"arabic":"مَتَابًۭا","translation":"অনুতপ্ত হয়ে","audioUrl":"wbw/025_071_009.mp3","charTypeName":"word"},{"id":60259,"position":10,"arabic":"٧١","translation":"(৭১)","audioUrl":null,"charTypeName":"end"}]},{"number":72,"arabic":"وَٱلَّذِينَ لَا يَشْهَدُونَ ٱلزُّورَ وَإِذَا مَرُّوا۟ بِٱللَّغْوِ مَرُّوا۟ كِرَامًۭا","translation":"And [know that true servants of God are only] those who never bear witness to what is false, and [who], whenever they pass by [people engaged in] frivolity, pass on with dignity;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2927.mp3","surahId":25,"words":[{"id":60830,"position":1,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/025_072_001.mp3","charTypeName":"word"},{"id":60831,"position":2,"arabic":"لَا","translation":"না","audioUrl":"wbw/025_072_002.mp3","charTypeName":"word"},{"id":60832,"position":3,"arabic":"يَشْهَدُونَ","translation":"সাক্ষ্য দেয়","audioUrl":"wbw/025_072_003.mp3","charTypeName":"word"},{"id":60833,"position":4,"arabic":"ٱلزُّورَ","translation":"মিথ্যার","audioUrl":"wbw/025_072_004.mp3","charTypeName":"word"},{"id":60834,"position":5,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/025_072_005.mp3","charTypeName":"word"},{"id":60835,"position":6,"arabic":"مَرُّوا۟","translation":"অতিক্রম করে","audioUrl":"wbw/025_072_006.mp3","charTypeName":"word"},{"id":60836,"position":7,"arabic":"بِٱللَّغْوِ","translation":"পাশ দিয়ে কোন অর্থহীন বিষয়কে","audioUrl":"wbw/025_072_007.mp3","charTypeName":"word"},{"id":60837,"position":8,"arabic":"مَرُّوا۟","translation":"তারা অতিক্রম করে","audioUrl":"wbw/025_072_008.mp3","charTypeName":"word"},{"id":60838,"position":9,"arabic":"كِرَامًۭا","translation":"ভদ্রভাবে","audioUrl":"wbw/025_072_009.mp3","charTypeName":"word"},{"id":60839,"position":10,"arabic":"٧٢","translation":"(৭২)","audioUrl":null,"charTypeName":"end"}]},{"number":73,"arabic":"وَٱلَّذِينَ إِذَا ذُكِّرُوا۟ بِـَٔايَٰتِ رَبِّهِمْ لَمْ يَخِرُّوا۟ عَلَيْهَا صُمًّۭا وَعُمْيَانًۭا","translation":"and who, whenever they are reminded of their Sustainer’s messages, do not throw themselves upon them [as if] deaf and blind;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2928.mp3","surahId":25,"words":[{"id":61051,"position":1,"arabic":"وَٱلَّذِينَ","translation":"এবং তাদেরকে","audioUrl":"wbw/025_073_001.mp3","charTypeName":"word"},{"id":61052,"position":2,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/025_073_002.mp3","charTypeName":"word"},{"id":61053,"position":3,"arabic":"ذُكِّرُوا۟","translation":"স্মরণ করানো হয়","audioUrl":"wbw/025_073_003.mp3","charTypeName":"word"},{"id":61054,"position":4,"arabic":"بِـَٔايَـٰتِ","translation":"প্রতি আয়াতগুলোর","audioUrl":"wbw/025_073_004.mp3","charTypeName":"word"},{"id":61055,"position":5,"arabic":"رَبِّهِمْ","translation":"তাদের রবের","audioUrl":"wbw/025_073_005.mp3","charTypeName":"word"},{"id":61056,"position":6,"arabic":"لَمْ","translation":"না","audioUrl":"wbw/025_073_006.mp3","charTypeName":"word"},{"id":61057,"position":7,"arabic":"يَخِرُّوا۟","translation":"তারা পড়ে থাকে","audioUrl":"wbw/025_073_007.mp3","charTypeName":"word"},{"id":61058,"position":8,"arabic":"عَلَيْهَا","translation":"তার উপর","audioUrl":"wbw/025_073_008.mp3","charTypeName":"word"},{"id":61059,"position":9,"arabic":"صُمًّۭا","translation":"অন্ধ","audioUrl":"wbw/025_073_009.mp3","charTypeName":"word"},{"id":61060,"position":10,"arabic":"وَعُمْيَانًۭا","translation":"ও বধির হয়ে","audioUrl":"wbw/025_073_010.mp3","charTypeName":"word"},{"id":61061,"position":11,"arabic":"٧٣","translation":"(৭৩)","audioUrl":null,"charTypeName":"end"}]},{"number":74,"arabic":"وَٱلَّذِينَ يَقُولُونَ رَبَّنَا هَبْ لَنَا مِنْ أَزْوَٰجِنَا وَذُرِّيَّٰتِنَا قُرَّةَ أَعْيُنٍۢ وَٱجْعَلْنَا لِلْمُتَّقِينَ إِمَامًا","translation":"and who pray “O our Sustainer! Grant that our spouses and our offspring be a joy to our eyes, and cause us to be foremost among those who are conscious of Thee!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2929.mp3","surahId":25,"words":[{"id":61746,"position":1,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/025_074_001.mp3","charTypeName":"word"},{"id":61747,"position":2,"arabic":"يَقُولُونَ","translation":"বলে","audioUrl":"wbw/025_074_002.mp3","charTypeName":"word"},{"id":61748,"position":3,"arabic":"رَبَّنَا","translation":"\"হে আমাদের রব","audioUrl":"wbw/025_074_003.mp3","charTypeName":"word"},{"id":61749,"position":4,"arabic":"هَبْ","translation":"তুমি দাও","audioUrl":"wbw/025_074_004.mp3","charTypeName":"word"},{"id":61750,"position":5,"arabic":"لَنَا","translation":"জন্যে আমাদের","audioUrl":"wbw/025_074_005.mp3","charTypeName":"word"},{"id":61751,"position":6,"arabic":"مِنْ","translation":"থেকে","audioUrl":"wbw/025_074_006.mp3","charTypeName":"word"},{"id":61752,"position":7,"arabic":"أَزْوَٰجِنَا","translation":"আমাদের স্ত্রীদেরকে","audioUrl":"wbw/025_074_007.mp3","charTypeName":"word"},{"id":61753,"position":8,"arabic":"وَذُرِّيَّـٰتِنَا","translation":"এবং আমাদের বংশধ