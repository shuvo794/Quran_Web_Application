:"wbw/025_075_006.mp3","charTypeName":"word"},{"id":62296,"position":7,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/025_075_007.mp3","charTypeName":"word"},{"id":62297,"position":8,"arabic":"تَحِيَّةًۭ","translation":"অভিবাদন","audioUrl":"wbw/025_075_008.mp3","charTypeName":"word"},{"id":62298,"position":9,"arabic":"وَسَلَـٰمًا","translation":"ও সালাম","audioUrl":"wbw/025_075_009.mp3","charTypeName":"word"},{"id":62299,"position":10,"arabic":"٧٥","translation":"(৭৫)","audioUrl":null,"charTypeName":"end"}]},{"number":76,"arabic":"خَٰلِدِينَ فِيهَا ۚ حَسُنَتْ مُسْتَقَرًّۭا وَمُقَامًۭا","translation":"therein to abide: [and] how goodly an abode and [how high] a station!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2931.mp3","surahId":25,"words":[{"id":62339,"position":1,"arabic":"خَـٰلِدِينَ","translation":"চিরস্থায়ী হবে","audioUrl":"wbw/025_076_001.mp3","charTypeName":"word"},{"id":62340,"position":2,"arabic":"فِيهَا ۚ","translation":"তার মধ্যে","audioUrl":"wbw/025_076_002.mp3","charTypeName":"word"},{"id":62342,"position":3,"arabic":"حَسُنَتْ","translation":"কত উত্তম হবে","audioUrl":"wbw/025_076_004.mp3","charTypeName":"word"},{"id":62343,"position":4,"arabic":"مُسْتَقَرًّۭا","translation":"বিশ্রামাগার","audioUrl":"wbw/025_076_005.mp3","charTypeName":"word"},{"id":62344,"position":5,"arabic":"وَمُقَامًۭا","translation":"আর (কত উত্তম) বাসস্থান","audioUrl":"wbw/025_076_006.mp3","charTypeName":"word"},{"id":62345,"position":6,"arabic":"٧٦","translation":"(৭৬)","audioUrl":null,"charTypeName":"end"}]},{"number":77,"arabic":"قُلْ مَا يَعْبَؤُا۟ بِكُمْ رَبِّى لَوْلَا دُعَآؤُكُمْ ۖ فَقَدْ كَذَّبْتُمْ فَسَوْفَ يَكُونُ لِزَامًۢا","translation":"SAY [unto those who believe]: “No weight or value would my Sustainer attach to you were it not for your faith [in Him]!” And say unto those who deny the truth:] “You have indeed given the lie [to God’s message], and in time this [sin] will cleave unto you!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2932.mp3","surahId":25,"words":[{"id":62804,"position":1,"arabic":"قُلْ","translation":"(হে নাবী) বলো","audioUrl":"wbw/025_077_001.mp3","charTypeName":"word"},{"id":62805,"position":2,"arabic":"مَا","translation":"\"না","audioUrl":"wbw/025_077_002.mp3","charTypeName":"word"},{"id":62806,"position":3,"arabic":"يَعْبَؤُا۟","translation":"ভ্রুক্ষেপ করেন তিনি","audioUrl":"wbw/025_077_003.mp3","charTypeName":"word"},{"id":62807,"position":4,"arabic":"بِكُمْ","translation":"প্রতি তোমাদের","audioUrl":"wbw/025_077_004.mp3","charTypeName":"word"},{"id":62808,"position":5,"arabic":"رَبِّى","translation":"আমার রব","audioUrl":"wbw/025_077_005.mp3","charTypeName":"word"},{"id":62809,"position":6,"arabic":"لَوْلَا","translation":"যদি না","audioUrl":"wbw/025_077_006.mp3","charTypeName":"word"},{"id":62810,"position":7,"arabic":"دُعَآؤُكُمْ ۖ","translation":"তোমাদের প্রার্থনা (হয় তাঁর কাছে)","audioUrl":"wbw/025_077_007.mp3","charTypeName":"word"},{"id":62812,"position":8,"arabic":"فَقَدْ","translation":"নিশ্চয়ই (এখন)","audioUrl":"wbw/025_077_009.mp3","charTypeName":"word"},{"id":62813,"position":9,"arabic":"كَذَّبْتُمْ","translation":"তোমরা অস্বীকার করেছো","audioUrl":"wbw/025_077_010.mp3","charTypeName":"word"},{"id":62814,"position":10,"arabic":"فَسَوْفَ","translation":"ফলে অতিশীঘ্রই","audioUrl":"wbw/025_077_011.mp3","charTypeName":"word"},{"id":62815,"position":11,"arabic":"يَكُونُ","translation":"হবে","audioUrl":"wbw/025_077_012.mp3","charTypeName":"word"},{"id":62816,"position":12,"arabic":"لِزَامًۢا","translation":"স্থায়ী অনিবার্য (শাস্তি)\"","audioUrl":"wbw/025_077_013.mp3","charTypeName":"word"},{"id":62817,"position":13,"arabic":"٧٧","translation":"(৭৭)","audioUrl":null,"charTypeName":"end"}]}]}