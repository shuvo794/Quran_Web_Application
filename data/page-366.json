{"id":366,"ayahs":[{"number":68,"arabic":"وَٱلَّذِينَ لَا يَدْعُونَ مَعَ ٱللَّهِ إِلَٰهًا ءَاخَرَ وَلَا يَقْتُلُونَ ٱلنَّفْسَ ٱلَّتِى حَرَّمَ ٱللَّهُ إِلَّا بِٱلْحَقِّ وَلَا يَزْنُونَ ۚ وَمَن يَفْعَلْ ذَٰلِكَ يَلْقَ أَثَامًۭا","translation":"and who never invoke any [imaginary] deity side by side with God, and do not take any human beings life - [the life] which God has willed to be sacred - otherwise than in [the pursuit of] justice, and do not commit adultery. And [know that] he who commits aught thereof shall [not only] meet with a full requital","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2923.mp3","surahId":25,"words":[{"id":58555,"position":1,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/025_068_001.mp3","charTypeName":"word"},{"id":58556,"position":2,"arabic":"لَا","translation":"না","audioUrl":"wbw/025_068_002.mp3","charTypeName":"word"},{"id":58557,"position":3,"arabic":"يَدْعُونَ","translation":"তারা ডাকে","audioUrl":"wbw/025_068_003.mp3","charTypeName":"word"},{"id":58558,"position":4,"arabic":"مَعَ","translation":"সাথে","audioUrl":"wbw/025_068_004.mp3","charTypeName":"word"},{"id":58559,"position":5,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/025_068_005.mp3","charTypeName":"word"},{"id":58560,"position":6,"arabic":"إِلَـٰهًا","translation":"উপাস্য","audioUrl":"wbw/025_068_006.mp3","charTypeName":"word"},{"id":58561,"position":7,"arabic":"ءَاخَرَ","translation":"অন্যকে","audioUrl":"wbw/025_068_007.mp3","charTypeName":"word"},{"id":58562,"position":8,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/025_068_008.mp3","charTypeName":"word"},{"id":58563,"position":9,"arabic":"يَقْتُلُونَ","translation":"হত্যা করে তারা","audioUrl":"wbw/025_068_009.mp3","charTypeName":"word"},{"id":58564,"position":10,"arabic":"ٱلنَّفْسَ","translation":"কোন প্রাণকে","audioUrl":"wbw/025_068_010.mp3","charTypeName":"word"},{"id":58565,"position":11,"arabic":"ٱلَّتِى","translation":"যাকে","audioUrl":"wbw/025_068_011.mp3","