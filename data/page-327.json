,{"id":58770,"position":8,"arabic":"٦٨","translation":"(৬৮)","audioUrl":null,"charTypeName":"end"}]},{"number":69,"arabic":"قُلْنَا يَٰنَارُ كُونِى بَرْدًۭا وَسَلَٰمًا عَلَىٰٓ إِبْرَٰهِيمَ","translation":"[But] We said: O fire! Be thou cool, and [a source of] inner peace for Abraham!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2552.mp3","surahId":21,"words":[{"id":58989,"position":1,"arabic":"قُلْنَا","translation":"আমরা বললাম","audioUrl":"wbw/021_069_001.mp3","charTypeName":"word"},{"id":58990,"position":2,"arabic":"يَـٰنَارُ","translation":"\"হে আগুন","audioUrl":"wbw/021_069_002.mp3","charTypeName":"word"},{"id":58991,"position":3,"arabic":"كُونِى","translation":"হয়ে যাও","audioUrl":"wbw/021_069_003.mp3","charTypeName":"word"},{"id":58992,"position":4,"arabic":"بَرْدًۭا","translation":"শীতল","audioUrl":"wbw/021_069_004.mp3","charTypeName":"word"},{"id":58993,"position":5,"arabic":"وَسَلَـٰمًا","translation":"ও নিরাপদ","audioUrl":"wbw/021_069_005.mp3","charTypeName":"word"},{"id":58994,"position":6,"arabic":"عَلَىٰٓ","translation":"জন্যে","audioUrl":"wbw/021_069_006.mp3","charTypeName":"word"},{"id":58995,"position":7,"arabic":"إِبْرَٰهِيمَ","translation":"ইবরাহীমের\"","audioUrl":"wbw/021_069_007.mp3","charTypeName":"word"},{"id":58996,"position":8,"arabic":"٦٩","translation":"(৬৯)","audioUrl":null,"charTypeName":"end"}]},{"number":70,"arabic":"وَأَرَادُوا۟ بِهِۦ كَيْدًۭا فَجَعَلْنَٰهُمُ ٱلْأَخْسَرِينَ","translation":"and whereas they sought to do evil unto him, We caused them to suffer the greatest loss:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2553.mp3","surahId":21,"words":[{"id":59450,"position":1,"arabic":"وَأَرَادُوا۟","translation":"এবং তারা চেয়েছিলো","audioUrl":"wbw/021_070_001.mp3","charTypeName":"word"},{"id":59451,"position":2,"arabic":"بِهِۦ","translation":"সাথে তার","audioUrl":"wbw/021_070_002.mp3","charTypeName":"word"},{"id":59452,"position":3,"arabic":"كَيْدًۭا","translation":"এক ফন্দি আঁটতে","audioUrl":"wbw/021_070_003.mp3","charTypeName":"word"},{"id":59453,"position":4,"arabic":"فَجَعَلْنَـٰهُمُ","translation":"কিন্তু তাদেরকে আমরা করে দিয়েছিলাম","audioUrl":"wbw/021_070_004.mp3","charTypeName":"word"},{"id":59454,"position":5,"arabic":"ٱلْأَخْسَرِينَ","translation":"সর্বাধিক ক্ষতিগ্রস্ত","audioUrl":"wbw/021_070_005.mp3","charTypeName":"word"},{"id":59455,"position":6,"arabic":"٧٠","translation":"(৭০)","audioUrl":null,"charTypeName":"end"}]},{"number":71,"arabic":"وَنَجَّيْنَٰهُ وَلُوطًا إِلَى ٱلْأَرْضِ ٱلَّتِى بَٰرَكْنَا فِيهَا لِلْعَٰلَمِينَ","translation":"for We saved him and Lot, [his brother’s son, by guiding them] to the land which We have blessed for all times to come.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2554.mp3","surahId":21,"words":[{"id":59955,"position":1,"arabic":"وَنَجَّيْنَـٰهُ","translation":"এবং তাকে আমরা উদ্ধার করলাম","audioUrl":"wbw/021_071_001.mp3","charTypeName":"word"},{"id":59956,"position":2,"arabic":"وَلُوطًا","translation":"ও লূতকে","audioUrl":"wbw/021_071_002.mp3","charTypeName":"word"},{"id":59957,"position":3,"arabic":"إِلَى","translation":"দিকে","audioUrl":"wbw/021_071_003.mp3","charTypeName":"word"},{"id":59958,"position":4,"arabic":"ٱلْأَرْضِ","translation":"(সেই) দেশের","audioUrl":"wbw/021_071_004.mp3","charTypeName":"word"},{"id":59959,"position":5,"arabic":"ٱلَّتِى","translation":"যা","audioUrl":"wbw/021_071_005.mp3","charTypeName":"word"},{"id":59960,"position":6,"arabic":"بَـٰرَكْنَا","translation":"আমরা কল্যাণ দিয়েছি","audioUrl":"wbw/021_071_006.mp3","charTypeName":"word"},{"id":59961,"position":7,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/021_071_007.mp3","charTypeName":"word"},{"id":59962,"position":8,"arabic":"لِلْعَـٰلَمِينَ","translation":"জন্যে বিশ্ববাসীর","audioUrl":"wbw/021_071_008.mp3","charTypeName":"word"},{"id":59963,"position":9,"arabic":"٧١","translation":"(৭১)","audioUrl":null,"charTypeName":"end"}]},{"number":72,"arabic":"وَوَهَبْنَا لَهُۥٓ إِسْحَٰقَ وَيَعْقُوب