{"id":327,"ayahs":[{"number":58,"arabic":"فَجَعَلَهُمْ جُذَٰذًا إِلَّا كَبِيرًۭا لَّهُمْ لَعَلَّهُمْ إِلَيْهِ يَرْجِعُونَ","translation":"And then he broke those [idols] to pieces, [all] save the biggest of them, so that they might [be able to] turn to it.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2541.mp3","surahId":21,"words":[{"id":53371,"position":1,"arabic":"فَجَعَلَهُمْ","translation":"অতঃপর তাদেরকে সে করে দিলো","audioUrl":"wbw/021_058_001.mp3","charTypeName":"word"},{"id":53372,"position":2,"arabic":"جُذَٰذًا","translation":"টুকরো টুকরো","audioUrl":"wbw/021_058_002.mp3","charTypeName":"word"},{"id":53373,"position":3,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/021_058_003.mp3","charTypeName":"word"},{"id":53374,"position":4,"arabic":"كَبِيرًۭا","translation":"বড়টা","audioUrl":"wbw/021_058_004.mp3","charTypeName":"word"},{"id":53375,"position":5,"arabic":"لَّهُمْ","translation":"তাদের","audioUrl":"wbw/021_058_005.mp3","charTypeName":"word"},{"id":53376,"position":6,"arabic":"لَعَلَّهُمْ","translation":"যাতে তারা","audioUrl":"wbw/021_058_006.mp3","charTypeName":"word"},{"id":53377,"position":7,"arabic":"إِلَيْهِ","translation":"তার দিকে","audioUrl":"wbw/021_058_007.mp3","charTypeName":"word"},{"id":53378,"position":8,"arabic":"يَرْجِعُونَ","translation":"ফিরে আসে","audioUrl":"wbw/021_058_008.mp3","charTypeName":"word"},{"id":53379,"position":9,"arabic":"٥٨","translation":"(৫৮)","audioUrl":null,"charTypeName":"end"}]},{"number":59,"arabic":"قَالُوا۟ مَن فَعَلَ هَٰذَا بِـَٔالِهَتِنَآ إِنَّهُۥ لَمِنَ ٱلظَّٰلِمِينَ","translation":"[When they saw what had happened,] they said: “Who has done this to our gods? Verily, one of the worst wrongdoers is he!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2542.mp3","surahId":21,"words":[{"id":53843,"position":1,"arabic":"قَالُوا۟","translation":"তারা বললো","audioUrl":"wbw/021_059_001.mp3","charTypeName":"word"},{"id":53844,"position":2,"arabic":"مَن","translation":"\"কে","audioUrl":"wbw/021_059_002.mp3","charTypeName":"word"},{"id":53845,"position":3,"arabic":"فَعَلَ","translation":"করেছে","audioUrl":"wbw/021_059_003.mp3","charTypeName":"word"},{"id":53846,"position":4,"arabic":"هَـٰذَا","translation":"এটা","audioUrl":"wbw/021_059_004.mp3","charTypeName":"word"},{"id":53847,"position":5,"arabic":"بِـَٔالِهَتِنَآ","translation":"সাথে আমাদের ইলাহগুলোর","audioUrl":"wbw/021_059_005.mp3","charTypeName":"word"},{"id":53848,"position":6,"arabic":"إِنَّهُۥ","translation":"সে নিশ্চয়ই","audioUrl":"wbw/021_059_006.mp3","charTypeName":"word"},{"id":53849,"position":7,"arabic":"لَمِنَ","translation":"অবশ্যই অন্তর্ভুক্ত","audioUrl":"wbw/021_059_007.mp3","charTypeName":"word"},{"id":53850,"position":8,"arabic":"ٱلظَّـٰلِمِينَ","translation":"সীমালঙ্ঘনকারীদের\"","audioUrl":"wbw/021_059_008.mp3","charTypeName":"word"},{"id":53851,"position":9,"arabic":"٥٩","translation":"(৫৯)","audioUrl":null,"charTypeName":"end"}]},{"number":60,"arabic":"قَالُوا۟ سَمِعْنَا فَتًۭى يَذْكُرُهُمْ يُقَالُ لَهُۥٓ إِبْرَٰهِيمُ","translation":"Said some [of them]: “We heard a youth speak of these [gods with scorn]: he is called Abraham.”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2543.mp3","surahId":21,"words":[{"id":54463,"position":1,"arabic":"قَالُوا۟","translation":"তারা বললো","audioUrl":"wbw/021_060_001.mp3","charTypeName":"word"},{"id":54464,"position":2,"arabic":"سَمِعْنَا","translation":"\"আমরা শুনেছি","audioUrl":"wbw/021_060_002.mp3","charTypeName":"word"},{"id":54465,"position":3,"arabic":"فَتًۭى","translation":"এক যুবককেকে","audioUrl":"wbw/021_060_003.mp3","charTypeName":"word"},{"id":54466,"position":4,"arabic":"يَذْكُرُهُمْ","translation":"সমালোচনা করতে তাদের ব্যাপারে","audioUrl":"wbw/021_060_004.mp3","charTypeName":"word"},{"id":54467,"position":5,"arabic":"يُقَالُ","translation":"বলা হয়","audioUrl":"wbw/021_060_005.mp3","charTypeName":"word"},{"id":54468,"position":6,"arabic":"لَهُۥٓ","translation":"তার (নাম)","audioUrl":"wbw/021_060_006.mp3","charTypeName":"word"},{"id":54469,"position":7,"arabic":"إِبْرَٰهِيمُ","translation":"ইবরাহীম\"","audioUrl":"wbw/021_060_007.mp3","charTypeName":"word"},{"id":54470,"position":8,"arabic":"٦٠","translation":"(৬০)","audioUrl":null,"charTypeName":"end"}]},{"number":61,"arabic":"قَالُوا۟ فَأْتُوا۟ بِهِۦ عَلَىٰٓ أَعْيُنِ ٱلنَّاسِ لَعَلَّهُمْ يَشْهَدُونَ","translation":"[The others] said: “Then bring him before the peoples eyes, so that they might bear witness [against him]!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2544.mp3","surahId":21,"words":[{"id":55037,"position":1,"arabic":"قَالُوا۟","translation":"তারা বললো","audioUrl":"wbw/021_061_001.mp3","charTypeName":"word"},{"id":55038,"position":2,"arabic":"فَأْتُوا۟","translation":"\"তাহ'লে আসো","audioUrl":"wbw/021_061_002.mp3","charTypeName":"word"},{"id":55039,"position":3,"arabic":"بِهِۦ","translation":"নিয়ে তাকে","audioUrl":"wbw/021_061_003.mp3","charTypeName":"word"},{"id":55040,"position":4,"arabic":"عَلَىٰٓ","translation":"সামনে","audioUrl":"wbw/021_061_004.mp3","charTypeName":"word"},{"id":55041,"position":5,"arabic":"أَعْيُنِ","translation":"চোখের","audioUrl":"wbw/021_061_005.mp3","charTypeName":"word"},{"id":55042,"position":6,"arabic":"ٱلنَّاسِ","translation":"লোকদের","audioUrl":"wbw/021_061_006.mp3","charTypeName":"word"},{"id":55043,"position":7,"arabic":"لَعَلَّهُمْ","translation":"যাতে তারা","audioUrl":"wbw/021_061_007.mp3","charTypeName":"word"},{"id":55044,"position":8,"arabic":"يَشْهَدُونَ","translation":"সাক্ষ্য দিতে পারে\"","audioUrl":"wbw/021_061_008.mp3","charTypeName":"word"},{"id":55045,"position":9,"arabic":"٦١","translation":"(৬১)","audioUrl":null,"charTypeName":"end"}]},{"number":62,"arabic":"قَالُوٓا۟ ءَأَنتَ فَعَلْتَ هَٰذَا بِـَٔالِهَتِنَا يَٰٓإِبْرَٰهِيمُ","translation":"[And when he came.] they asked: “Hast thou done this to our gods, O Abraham?”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2545.mp3","surahId":21,"words":[{"id":55648,"