it be]? -since, if they [who are hostile to you] were to overcome you, they would not respect any tie [with you,] nor any obligation to protect [you]. They seek to please you with their mouths, the while their hearts remain averse [to you]; and most of them are iniquitous.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1243.mp3","surahId":9,"words":[{"id":8779,"position":1,"arabic":"كَيْفَ","translation":"কেমন করে (চুক্তি বহাল) থাকবে","audioUrl":"wbw/009_008_001.mp3","charTypeName":"word"},{"id":8780,"position":2,"arabic":"وَإِن","translation":"অথচ যদি","audioUrl":"wbw/009_008_002.mp3","charTypeName":"word"},{"id":8781,"position":3,"arabic":"يَظْهَرُوا۟","translation":"তারা বিজয়ী হয়","audioUrl":"wbw/009_008_003.mp3","charTypeName":"word"},{"id":8782,"position":4,"arabic":"عَلَيْكُمْ","translation":"উপর তোমাদের","audioUrl":"wbw/009_008_004.mp3","charTypeName":"word"},{"id":8783,"position":5,"arabic":"لَا","translation":"না","audioUrl":"wbw/009_008_005.mp3","charTypeName":"word"},{"id":8784,"position":6,"arabic":"يَرْقُبُوا۟","translation":"তারা সম্মান করে","audioUrl":"wbw/009_008_006.mp3","charTypeName":"word"},{"id":8785,"position":7,"arabic":"فِيكُمْ","translation":"ব্যাপারে তোমাদের","audioUrl":"wbw/009_008_007.mp3","charTypeName":"word"},{"id":8786,"position":8,"arabic":"إِلًّۭا","translation":"আত্মীয়তার","audioUrl":"wbw/009_008_008.mp3","charTypeName":"word"},{"id":8787,"position":9,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/009_008_009.mp3","charTypeName":"word"},{"id":8788,"position":10,"arabic":"ذِمَّةًۭ ۚ","translation":"প্রতিশ্রুতির (দায়িত্ব)","audioUrl":"wbw/009_008_010.mp3","charTypeName":"word"},{"id":8790,"position":11,"arabic":"يُرْضُونَكُم","translation":"খুশী করে তোমাদের","audioUrl":"wbw/009_008_012.mp3","charTypeName":"word"},{"id":8791,"position":12,"arabic":"بِأَفْوَٰهِهِمْ","translation":"দিয়ে মুখের কথা তাদের","audioUrl":"wbw/009_008_013.mp3","charTypeName":"word"},{"id":8792,"position":13,"arabic":"وَتَأْبَىٰ","translation":"ও অস্বীকার করে","audioUrl":"wbw/009_008_014.mp3","charTypeName":"word"},{"id":8793,"position":14,"arabic":"قُلُوبُهُمْ","translation":"অন্তর তাদের","audioUrl":"wbw/009_008_015.mp3","charTypeName":"word"},{"id":8794,"position":15,"arabic":"وَأَكْثَرُهُمْ","translation":"এবং অধিকাংশই তাদের","audioUrl":"wbw/009_008_016.mp3","charTypeName":"word"},{"id":8795,"position":16,"arabic":"فَـٰسِقُونَ","translation":"সত্যত্যাগী","audioUrl":"wbw/009_008_017.mp3","charTypeName":"word"},{"id":8796,"position":17,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"ٱشْتَرَوْا۟ بِـَٔايَٰتِ ٱللَّهِ ثَمَنًۭا قَلِيلًۭا فَصَدُّوا۟ عَن سَبِيلِهِۦٓ ۚ إِنَّهُمْ سَآءَ مَا كَانُوا۟ يَعْمَلُونَ","translation":"God's messages have they bartered away for a trifling gain, and have thus turned away from His path: evil, behold, is all that they are wont to do,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1244.mp3","surahId":9,"words":[{"id":10006,"position":1,"arabic":"ٱشْتَرَوْا۟","translation":"তারা কিনেছে","audioUrl":"wbw/009_009_001.mp3","charTypeName":"word"},{"id":10007,"position":2,"arabic":"بِـَٔايَـٰتِ","translation":"বিনিময়ে আয়াতের","audioUrl":"wbw/009_009_002.mp3","charTypeName":"word"},{"id":10008,"position":3,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/009_009_003.mp3","charTypeName":"word"},{"id":10009,"position":4,"arabic":"ثَمَنًۭا","translation":"মূল্য","audioUrl":"wbw/009_009_004.mp3","charTypeName":"word"},{"id":10010,"position":5,"arabic":"قَلِيلًۭا","translation":"সামান্য","audioUrl":"wbw/009_009_005.mp3","charTypeName":"word"},{"id":10011,"position":6,"arabic":"فَصَدُّوا۟","translation":"অতঃপর তারা বাধা দেয় (লোকদেরকে)","audioUrl":"wbw/009_009_006.mp3","charTypeName":"word"},{"id":10012,"position":7,"arabic":"عَن","translation":"হতে","audioUrl":"wbw/009_009_007.mp3","charTypeName":"word"},{"id":10013,"position":8,"arabic":"سَبِيلِهِۦٓ ۚ","translation":"তাঁর পথ","audioUrl":"wbw/009_009_008.mp3","charTypeName":"word"},{"id":10015,"position":9,"arabic":"إِنَّهُمْ","translation":"নিশ্চয়ই তারা","audioUrl":"wbw/009_009_010.mp3","charTypeName":"word"},{"id":10016,"position":10,"arabic":"سَآءَ","translation":"অতি নিকৃষ্ট","audioUrl":"wbw/009_009_011.mp3","charTypeName":"word"},{"id":10017,"position":11,"arabic":"مَا","translation":"যা","audioUrl":"wbw/009_009_012.mp3","charTypeName":"word"},{"id":10018,"position":12,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/009_009_013.mp3","charTypeName":"word"},{"id":10019,"position":13,"arabic":"يَعْمَلُونَ","translation":"তারা কাজ করে আসছে","audioUrl":"wbw/009_009_014.mp3","charTypeName":"word"},{"id":10020,"position":14,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"لَا يَرْقُبُونَ فِى مُؤْمِنٍ إِلًّۭا وَلَا ذِمَّةًۭ ۚ وَأُو۟لَٰٓئِكَ هُمُ ٱلْمُعْتَدُونَ","translation":"respecting no tie and no protective obligation with regard to a believer; and it is they, they who transgress the bounds of what is right!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1245.mp3","surahId":9,"words":[{"id":11202,"position":1,"arabic":"لَا","translation":"না","audioUrl":"wbw/009_010_001.mp3","charTypeName":"word"},{"id":11203,"position":2,"arabic":"يَرْقُبُونَ","translation":"তারা সম্মান করে","audioUrl":"wbw/009_010_002.mp3","charTypeName":"word"},{"id":11204,"position":3,"arabic":"فِى","translation":"ব্যাপারে","audioUrl":"wbw/009_010_003.mp3","charTypeName":"word"},{"id":11205,"position":4,"arabic":"مُؤْمِنٍ","translation":"মু'মিনের","audioUrl":"wbw/009_010_004.mp3","charTypeName":"word"},{"id":11206,"position":5,"arabic":"إِلًّۭا","translation":"আত্মীয়তার","audioUrl":"wbw/009_010_005.mp3","charTypeName":"word"},{"id":11207,"position":6,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/009_010_006.mp3","charTypeName":"word"},{"id":11208,"position":7,"arabic":"ذِمَّةًۭ ۚ","translation":"প্রতিশ্রুতির (দায়িত্ব)","audioUrl":"wbw/009_010_007.mp3","charTypeName":"word"},{"id":11210,"position":8,"arabic":"وَأُو۟لَـٰٓئِكَ","translation":"এবং ঐসব লোক","audioUrl":"wbw/009_010_009.mp3","charTypeName":"word"},{"id":11211,"position":9,"arabic":"هُمُ","translation":"তারা","audioUrl":"wbw/009_010_010.mp3","charTypeName":"word"},{"id":11212,"position":10,"arabic":"ٱلْمُعْتَدُونَ","translation":"সীমালঙ্ঘনকারী","audioUrl":"wbw/009_010_011.mp3","charTypeName":"word"},{"id":11213,"position":11,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"فَإِن تَابُوا۟ وَأَقَامُوا۟ ٱلصَّلَوٰةَ وَءَاتَوُا۟ ٱلزَّكَوٰةَ فَإِخْوَٰنُكُمْ فِى ٱلدِّينِ ۗ وَنُفَصِّلُ ٱلْءَايَٰتِ لِقَوْمٍۢ يَعْلَمُونَ","translation":"Yet if they repent, and take to prayer, and render the purifying dues, they become your brethren in faith: and clearly do We spell out these messages unto people of [innate] knowledge!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1246.mp3","surahId":9,"words":[{"id":12543,"position":1,"arabic":"فَإِن","translation":"অতঃপর যদি","audioUrl":"wbw/009_011_001.mp3","charTypeName":"word"},{"id":12544,"position":2,"arabic":"تَابُوا۟","translation":"তারা তওবা করে","audioUrl":"wbw/009_011_002.mp3","charTypeName":"word"},{"id":12545,"position":3,"arabic":"وَأَقَامُوا۟","translation":"ও প্রতিষ্ঠা করে","audioUrl":"wbw/009_011_003.mp3","charTypeName":"word"},{"id":12546,"position":4,"arabic":"ٱلصَّلَوٰةَ","translation":"সালাত","audioUrl":"wbw/009_011_004.mp3","charTypeName":"word"},{"id":12547,"position":5,"arabic":"وَءَاتَوُا۟","translation":"ও আদায় করে","audioUrl":"wbw/009_011_005.mp3","charTypeName":"word"},{"id":12548,"position":6,"arabic":"ٱلزَّكَوٰةَ","translation":"যাকাত","audioUrl":"wbw/009_011_006.mp3","charTypeName":"word"},{"id":12549,"position":7,"arabic":"فَإِخْوَٰنُكُمْ","translation":"তবে ভাই তোমাদের","audioUrl":"wbw/009_011_007.mp3","charTypeName":"word"},{"id":12550,"position":8,"arabic":"فِى","translation":"ভিত্তিতে","audioUrl":"wbw/009_011_008.mp3","charTypeName":"word"},{"id":12551,"position":9,"arabic":"ٱلدِّينِ ۗ","translation":"দীনের","audioUrl":"wbw/009_011_009.mp3","charTypeName":"word"},{"id":12553,"position":10,"arabic":"وَنُفَصِّلُ","translation":"এবং বিস্তারিত বর্ণনা করছি আমরা","audioUrl":"wbw/009_011_011.mp3","charTypeName":"word"},{"id":12554,"position":11,"arabic":"ٱلْـَٔايَـٰتِ","translation":"বিধানাবলী","audioUrl":"wbw/009_011_012.mp3","charTypeName":"word"},{"id":12555,"position":12,"arabic":"لِقَوْمٍۢ","translation":"জন্যে সম্প্রদায়ের","audioUrl":"wbw/009_011_013.mp3","charTypeName":"word"},{"id":12556,"position":13,"arabic":"يَعْلَمُونَ","translation":"(যারা) জ্ঞান রাখে","audioUrl":"wbw/009_011_014.mp3","charTypeName":"word"},{"id":12557,"position":14,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]},{"number":12,"arabic":"وَإِن نَّكَثُوٓا۟ أَيْمَٰنَهُم مِّنۢ بَعْدِ عَهْدِهِمْ وَطَعَنُوا۟ فِى دِينِكُمْ فَقَٰتِلُوٓا۟ أَئِمَّةَ ٱلْكُفْرِ ۙ إِنَّهُمْ لَآ أَيْمَٰنَ لَهُمْ لَعَلَّهُمْ يَنتَهُونَ","translation":"But if they break their solemn pledges after having concluded a covenant, and revile your religion, then fight against these archetypes of faithlessness who, behold, have no [regard for their own] pledges, so that they might desist [from aggression].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1247.mp3","surahId":9,"words":[{"id":13872,"position":1,"arabic":"وَإِن","translation":"আর যদি","audioUrl":"wbw/009_012_001.mp3","charTypeName":"word"},{"id":13873,"position":2,"arabic":"نَّكَثُوٓا۟","translation":"তারা ভঙ্গ করে","audioUrl":"wbw/009_012_002.mp3","charTypeName":"word"},{"id":13874,"position":3,"arabic":"أَيْمَـٰنَهُم","translation":"শপথ তাদের","audioUrl":"wbw/009_012_003.mp3","charTypeName":"word"},{"id":13875,"position":4,"arabic":"مِّنۢ","translation":"থেকে","audioUrl":"wbw/009_012_004.mp3","charTypeName":"word"},{"id":13876,"position":5,"arabic":"بَعْدِ","translation":"পর","audioUrl":"wbw/009_012_005.mp3","charTypeName":"word"},{"id":13877,"position":6,"arabic":"عَهْدِهِمْ","translation":"চুক্তির তাদের","audioUrl":"wbw/009_012_006.mp3","charTypeName":"word"},{"id":13878,"position":7,"arabic":"وَطَعَنُوا۟","translation":"ও বিদ্রূপ করে","audioUrl":"wbw/009_012_007.mp3","charTypeName":"word"},{"id":13879,"position":8,"arabic":"فِى","translation":"সম্পর্কে","audioUrl":"wbw/009_012_008.mp3","charTypeName":"word"},{"id":13880,"position":9,"arabic":"دِينِكُمْ","translation":"দীনের তোমাদের","audioUrl":"wbw/009_012_009.mp3","charTypeName":"word"},{"id":13881,"position":10,"arabic":"فَقَـٰتِلُوٓا۟","translation":"তখন তোমরা লড়াই করো","audioUrl":"wbw/009_012_010.mp3","charTypeName":"word"},{"id":13882,"position":11,"arabic":"أَئِمَّةَ","translation":"নেতৃবৃন্দের (বিরুদ্ধে)","audioUrl":"wbw/009_012_011.mp3","charTypeName":"word"},{"id":13883,"position":12,"arabic":"ٱلْكُفْرِ ۙ","translation":"অবিশ্বাসের","audioUrl":"wbw/009_012_012.mp3","charTypeName":"word"},{"id":13885,"position":13,"arabic":"إِنَّهُمْ","translation":"নিশ্চয়ই তারা (এমন যে)","audioUrl":"wbw/009_012_014.mp3","charTypeName":"word"},{"id":13886,"position":14,"arabic":"لَآ","translation":"নেই(বিশ্বাস)","audioUrl":"wbw/009_012_015.mp3","charTypeName":"word"},{"id":13887,"position":15,"arabic":"أَيْمَـٰنَ","translation":"শপথ","audioUrl":"wbw/009_012_016.mp3","charTypeName":"word"},{"id":13888,"position":16,"arabic":"لَهُمْ","translation":"কাছে তাদের","audioUrl":"wbw/009_012_017.mp3","charTypeName":"word"},{"id":13889,"position":17,"arabic":"لَعَلَّهُمْ","translation":"(এরূপ আচরণে)সম্ভবতঃ তারা","audioUrl":"wbw/009_012_018.mp3","charTypeName":"word"},{"id":13890,"position":18,"arabic":"يَنتَهُونَ","translation":"বিরত হবে","audioUrl":"wbw/009_012_019.mp3","charTypeName":"word"},{"id":13891,"position":19,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]},{"number":13,"arabic":"أَلَا تُقَٰتِلُونَ قَوْمًۭا نَّكَثُوٓا۟ أَيْمَٰنَهُمْ وَهَمُّوا۟ بِإِخْرَاجِ ٱلرَّسُولِ وَهُم بَدَءُوكُمْ أَوَّلَ مَرَّةٍ ۚ أَتَخْشَوْنَهُمْ ۚ فَٱللَّهُ أَحَقُّ أَن تَخْشَوْهُ إِن كُنتُم مُّؤْمِنِينَ","translation":"Would you, perchance, fail to fight against people who have broken their solemn pledges, and have done all that they could to drive the Apostle away, and have been first to attack you? Do you hold them in awe? Nay, it is God alone of whom you ought to stand in awe, if you are [truly] believers!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1248.mp3","surahId":9,"words":[{"id":15018,"position":1,"arabic":"أَلَا","translation":"কি না","audioUrl":"wbw/009_013_001.mp3","charTypeName":"word"},{"id":15019,"position":2,"arabic":"تُقَـٰتِلُونَ","translation":"তোমরা যুদ্ধ করবে","audioUrl":"wbw/009_013_002.mp3","charTypeName":"word"},{"id":15020,"position":3,"arabic":"قَوْمًۭا","translation":"সম্প্রদায়ের(বিরুদ্ধে)","audioUrl":"wbw/009_013_003.mp3","charTypeName":"word"},{"id":15021,"position":4,"arabic":"نَّكَثُوٓا۟","translation":"(যারা) ভঙ্গ করেছে","audioUrl":"wbw/009_013_004.mp3","charTypeName":"word"},{"id":15022,"position":5,"arabic":"أَيْمَـٰنَهُمْ","translation":"শপথ তাদের","audioUrl":"wbw/009_013_005.mp3","charTypeName":"word"},{"id":15023,"position":6,"arabic":"وَهَمُّوا۟","translation":"এবং সংকল্প করেছিলো","audioUrl":"wbw/009_013_006.mp3","charTypeName":"word"},{"id":15024,"position":7,"arabic":"بِإِخْرَاجِ","translation":"ব্যাপারে বহিষ্কার করার","audioUrl":"wbw/009_013_007.mp3","charTypeName":"word"},{"id":15025,"position":8,"arabic":"ٱلرَّسُولِ","translation":"রাসূলকে","audioUrl":"wbw/009_013_008.mp3","charTypeName":"word"},{"id":15026,"position":9,"arabic":"وَهُم","translation":"ও তারা","audioUrl":"wbw/009_013_009.mp3","charTypeName":"word"},{"id":15027,"position":10,"arabic":"بَدَءُوكُمْ","translation":"তোমাদের সাথে শুরু করেছিলো (বাড়াবাড়ি)","audioUrl":"wbw/009_013_010.mp3","charTypeName":"word"},{"id":15028,"position":11,"arabic":"أَوَّلَ","translation":"প্রথম","audioUrl":"wbw/009_013_011.mp3","charTypeName":"word"},{"id":15029,"position":12,"arabic":"مَرَّةٍ ۚ","translation":"বারেই","audioUrl":"wbw/009_013_012.mp3","charTypeName":"word"},{"id":15031,"position":13,"arabic":"أَتَخْشَوْنَهُمْ ۚ","translation":"কি তোমরা ভয় করো তাদেরকে","audioUrl":"wbw/009_013_014.mp3","charTypeName":"word"},{"id":15033,"position":14,"arabic":"فَٱللَّهُ","translation":"অথচ আল্লাহই","audioUrl":"wbw/009_013_016.mp3","charTypeName":"word"},{"id":15034,"position":15,"arabic":"أَحَقُّ","translation":"অধিক অধিকারী","audioUrl":"wbw/009_013_017.mp3","charTypeName":"word"},{"id":15035,"position":16,"arabic":"أَن","translation":"যে","audioUrl":"wbw/009_013_018.mp3","charTypeName":"word"},{"id":15036,"position":17,"arabic":"تَخْشَوْهُ","translation":"তোমরা ভয় করো তাঁকে","audioUrl":"wbw/009_013_019.mp3","charTypeName":"word"},{"id":15037,"position":18,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/009_013_020.mp3","charTypeName":"word"},{"id":15038,"position":19,"arabic":"كُنتُم","translation":"হয়ে থাকো তোমরা","audioUrl":"wbw/009_013_021.mp3","charTypeName":"word"},{"id":15039,"position":20,"arabic":"مُّؤْمِنِينَ","translation":"মু'মিন","audioUrl":"wbw/009_013_022.mp3","charTypeName":"word"},{"id":15040,"position":21,"arabic":"١٣","translation":"(১৩)","audioUrl":null,"charTypeName":"end"}]}]}