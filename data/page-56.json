{"id":56,"ayahs":[{"number":46,"arabic":"وَيُكَلِّمُ ٱلنَّاسَ فِى ٱلْمَهْدِ وَكَهْلًۭا وَمِنَ ٱلصَّٰلِحِينَ","translation":"And he shall speak unto men in his cradle, and as a grown man, and shall be of the righteous.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/339.mp3","surahId":3,"words":[{"id":45766,"position":1,"arabic":"وَيُكَلِّمُ","translation":"এবং সে কথা বলবে","audioUrl":"wbw/003_046_001.mp3","charTypeName":"word"},{"id":45767,"position":2,"arabic":"ٱلنَّاسَ","translation":"মানুষের (সাথে)","audioUrl":"wbw/003_046_002.mp3","charTypeName":"word"},{"id":45768,"position":3,"arabic":"فِى","translation":"(মধ্যে)","audioUrl":"wbw/003_046_003.mp3","charTypeName":"word"},{"id":45769,"position":4,"arabic":"ٱلْمَهْدِ","translation":"দোলনায়","audioUrl":"wbw/003_046_004.mp3","charTypeName":"word"},{"id":45770,"position":5,"arabic":"وَكَهْلًۭا","translation":"ও পরিণত বয়সে","audioUrl":"wbw/003_046_005.mp3","charTypeName":"word"},{"id":45771,"position":6,"arabic":"وَمِنَ","translation":"এবং অন্যতম হবে","audioUrl":"wbw/003_046_006.mp3","charTypeName":"word"},{"id":45772,"position":7,"arabic":"ٱلصَّـٰلِحِينَ","translation":"সৎকর্মশীলদের''","audioUrl":"wbw/003_046_007.mp3","charTypeName":"word"},{"id":45773,"position":8,"arabic":"٤٦","translation":"(৪৬)","audioUrl":null,"charTypeName":"end"}]},{"number":47,"arabic":"قَالَتْ رَبِّ أَنَّىٰ يَكُونُ لِى وَلَدٌۭ وَلَمْ يَمْسَسْنِى بَشَرٌۭ ۖ قَالَ كَذَٰلِكِ ٱللَّهُ يَخْلُقُ مَا يَشَآءُ ۚ إِذَا قَضَىٰٓ أَمْرًۭا فَإِنَّمَا يَقُولُ لَهُۥ كُن فَيَكُونُ","translation":"Said she: \"O my Sustainer! How can I have a son when no man has ever touched me?\" [The angel] answered: \"Thus it is: God creates what He wills when He wills a thing to be, He but says unto it, 'Be' - and it is.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/340.mp3","surahId":3,"words":[{"id":46852,"position":1,"arabic":"قَالَتْ","translation":"সে বলল","audioUrl":"wbw/003_047_001.mp3","charTypeName":"word"},{"id":46853,"position":2,"arabic":"رَبِّ","translation":"''হে আমার রব","audioUrl":"wbw/003_047_002.mp3","charTypeName":"word"},{"id":46854,"position":3,"arabic":"أَنَّىٰ","translation":"কিরূপে","audioUrl":"wbw/003_047_003.mp3","charTypeName":"word"},{"id":46855,"position":4,"arabic":"يَكُونُ","translation":"হবে","audioUrl":"wbw/003_047_004.mp3","charTypeName":"word"},{"id":46856,"position":5,"arabic":"لِى","translation":"আমার","audioUrl":"wbw/003_047_005.mp3","charTypeName":"word"},{"id":46857,"position":6,"arabic":"وَلَدٌۭ","translation":"ছেলে","audioUrl":"wbw/003_047_006.mp3","charTypeName":"word"},{"id":46858,"position":7,"arabic":"وَلَمْ","translation":"অথচ নাই","audioUrl":"wbw/003_047_007.mp3","charTypeName":"word"},{"id":46859,"position":8,"arabic":"يَمْسَسْنِى","translation":"আমাকে স্পর্শ করে","audioUrl":"wbw/003_047_008.mp3","charTypeName":"word"},{"id":46860,"position":9,"arabic":"بَشَرٌۭ ۖ","translation":"(কোন) মানুষ''","audioUrl":"wbw/003_047_009.mp3","charTypeName":"word"},{"id":46862,"position":10,"arabic":"قَالَ","translation":"তিনি বললেন","audioUrl":"wbw/003_047_011.mp3","charTypeName":"word"},{"id":46863,"position":11,"arabic":"كَذَٰلِكِ","translation":"''এভাবেই","audioUrl":"wbw/003_047_012.mp3","charTypeName":"word"},{"id":46864,"position":12,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/003_047_013.mp3","charTypeName":"word"},{"id":46865,"position":13,"arabic":"يَخْلُقُ","translation":"সৃষ্টি করেন","audioUrl":"wbw/003_047_014.mp3","charTypeName":"word"},{"id":46866,"position":14,"arabic":"مَا","translation":"যা","audioUrl":"wbw/003_047_015.mp3","charTypeName":"word"},{"id":46867,"position":15,"arabic":"يَشَآءُ ۚ","translation":"তিনি ইচ্ছে করেন","audioUrl":"wbw/003_047_016.mp3","charTypeName":"word"},{"id":46869,"position":16,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/003_047_018.mp3","charTypeName":"word"},{"id":46870,"position":17,"arabic":"قَضَىٰٓ","translation":"সিদ্ধান্ত নেন","audioUrl":"wbw/003_047_019.mp3","charTypeName":"word"},{"id":46871,"position":18,"arabic":"أَمْرًۭا","translation":"কোন কাজের","audioUrl":"wbw/003_047_020.mp3","charTypeName":"word"},{"id":46872,"position":19,"arabic":"فَإِنَّمَا","translation":"মূলত","audioUrl":"wbw/003_047_021.mp3","charTypeName":"word"},{"id":46873,"position":20,"arabic":"يَقُولُ","translation":"বলেন","audioUrl":"wbw/003_047_022.mp3","charTypeName":"word"},{"id":46874,"position":21,"arabic":"لَهُۥ","translation":"তাকে","audioUrl":"wbw/003_047_023.mp3","charTypeName":"word"},{"id":46875,"position":22,"arabic":"كُن","translation":"''হও''","audioUrl":"wbw/003_047_024.mp3","charTypeName":"word"},{"id":46876,"position":23,"arabic":"فَيَكُونُ","translation":"অতঃপর হয়ে যায়","audioUrl":"wbw/003_047_025.mp3","charTypeName":"word"},{"id":46877,"position":24,"arabic":"٤٧","translation":"(৪৭)","audioUrl":null,"charTypeName":"end"}]},{"number":48,"arabic":"وَيُعَلِّمُهُ ٱلْكِتَٰبَ وَٱلْحِكْمَةَ وَٱلتَّوْرَىٰةَ وَٱلْإِنجِيلَ","translation":"And he will impart unto thy son revelation, and wisdom, and the Torah, and the Gospel,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/341.mp3","surahId":3,"words":[{"id":47382,"position":1,"arabic":"وَيُعَلِّمُهُ","translation":"এবং তাকে শিক্ষা দিবেন","audioUrl":"wbw/003_048_001.mp3","charTypeName":"word"},{"id":47383,"position":2,"arabic":"ٱلْكِتَـٰبَ","translation":"কিতাব","audioUrl":"wbw/003_048_002.mp3","charTypeName":"word"},{"id":47384,"position":3,"arabic":"وَٱلْحِكْمَةَ","translation":"ও হিকমত","audioUrl":"wbw/003_048_003.mp3","charTypeName":"word"},{"id":47385,"position":4,"arabic":"وَٱلتَّوْرَىٰةَ","translation":"ও তাওরাত","audioUrl":"wbw/003_048_004.mp3","charTypeName":"word"},{"id":47386,"position":5,"arabic":"وَٱلْإِنجِيلَ","translation":"ও ইনজীল","audioUrl":"wbw/003_048_005.mp3","charTypeName":"word"},{"id":47387,"position":6,"arabic":"٤٨","translation":"(৪৮)","audioUrl":null,"charTypeName":"end"}]},{"number":49,"arabic":"وَرَسُولًا إِلَىٰ بَنِىٓ إِسْرَٰٓءِيلَ أَنِّى قَدْ جِئْتُكُم بِـَٔايَةٍۢ مِّن رَّبِّكُمْ ۖ أَنِّىٓ أَخْلُقُ لَكُم مِّنَ ٱلطِّينِ كَهَيْـَٔةِ ٱلطَّيْرِ فَأَنفُخُ فِيهِ فَيَكُونُ طَيْرًۢا بِإِذْنِ ٱللَّهِ ۖ وَأُبْرِئُ ٱلْأَكْمَهَ وَٱلْأَبْرَصَ وَأُحْىِ ٱلْمَوْتَىٰ بِإِذْنِ ٱللَّهِ ۖ وَأُنَبِّئُكُم بِمَا تَأْكُلُونَ وَمَا تَدَّخِرُونَ فِى بُيُوتِكُمْ ۚ إِنَّ فِى ذَٰلِكَ لَءَايَةًۭ لَّكُمْ إِن كُنتُم مُّؤْمِنِينَ","translation":"and [will make him] an apostle unto the children of Israel.” \"I HAVE COME unto you with a message from your Sustainer. I shall create for you out of clay, as it were, the shape of [your] destiny, and then breathe into it, so that it might become [your] destiny by God's leave; and I shall heal the blind and the leper, and bring the dead back to life by God's leave; and I shall let you know what you may eat and what you should store up in your houses. Behold, in all this there is indeed a message for you, if you are [truly] believers.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/342.mp3","surahId":3,"words":[{"id":47953,"position":1,"arabic":"وَرَسُولًا","translation":"এবং (নিযুক্ত করবেন) রাসূল","audioUrl":"wbw/003_049_001.mp3","charTypeName":"word"},{"id":47954,"position":2,"arabic":"إِلَىٰ","translation":"প্রতি","audioUrl":"wbw/003_049_002.mp3","charTypeName":"word"},{"id":47955,"position":3,"arabic":"بَنِىٓ","translation":"বনী","audioUrl":"wbw/003_049_003.mp3","charTypeName":"word"},{"id":47956,"position":4,"arabic":"إِسْرَٰٓءِيلَ","translation":"ইসরাঈলের","audioUrl":"wbw/003_049_004.mp3","charTypeName":"word"},{"id":47957,"position":5,"arabic":"أَنِّى","translation":"''(সে বলবে) যে আমি","audioUrl":"wbw/003_049_005.mp3","charTypeName":"word"},{"id":47958,"position":6,"arabic":"قَدْ","translation":"নিশ্চয়","audioUrl":"wbw/003_049_006.mp3","charTypeName":"word"},{"id":47959,"position":7,"arabic":"جِئْتُكُم","translation":"তোমাদের কাছে এসেছি","audioUrl":"wbw/003_049_007.mp3","charTypeName":"word"},{"id":47960,"position":8,"arabic":"بِـَٔايَةٍۢ","translation":"একটি নিদর্শন সহকারে","audioUrl":"wbw/003_049_008.mp3","charTypeName":"word"},{"id":47961,"position":9,"arabic":"مِّن","translation":"পক্ষ হতে","audioUrl":"wbw/003_049_009.mp3","charTypeName":"word"},{"id":47962,"position":10,"arabic":"رَّبِّكُمْ ۖ","translation":"তোমাদের রবের","audioUrl":"wbw/003_049_010.mp3","charTypeName":"word"},{"id":47964,"position":11,"arabic":"أَنِّىٓ","translation":"(তা) এই যে আমি","audioUrl":"wbw/003_049_012.mp3","charTypeName":"word"},{"id":47965,"position":12,"arabic":"أَخْلُقُ","translation":"আমি বানাই","audioUrl":"wbw/003_049_013.mp3","charTypeName":"word"},{"id":47966,"position":13,"arabic":"لَكُم","translation":"তোমাদের জন্যে","audioUrl":"wbw/003_049_014.mp3","charTypeName":"word"},{"id":47967,"position":14,"arabic":"مِّنَ","translation":"থেকে","audioUrl":"wbw/003_049_015.mp3","charTypeName":"word"},{"id":47968,"position":15,"arabic":"ٱلطِّينِ","translation":"মাটি","audioUrl":"wbw/003_049_016.mp3","charTypeName":"word"},{"id":47969,"position":16,"arabic":"كَهَيْـَٔةِ","translation":"আকৃতির মতো","audioUrl":"wbw/003_049_017.mp3","charTypeName":"word"},{"id":47970,"position":17,"arabic":"ٱلطَّيْرِ","translation":"পাখির","audioUrl":"wbw/003_049_018.mp3","charTypeName":"word"},{"id":47971,"position":18,"arabic":"فَأَنفُخُ","translation":"আমি অতঃপর ফুঁক দিই","audioUrl":"wbw/003_049_019.mp3","charTypeName":"word"},{"id":47972,"position":19,"arabic":"فِيهِ","translation":"তার মধ্যে","audioUrl":"wbw/003_049_020.mp3","charTypeName":"word"},{"id":47973,"position":20,"arabic":"فَيَكُونُ","translation":"হয়ে যায় তখন","audioUrl":"wbw/003_049_021.mp3","charTypeName":"word"},{"id":47974,"position":21,"arabic":"طَيْرًۢا","translation":"পাখি","audioUrl":"wbw/003_049_022.mp3","charTypeName":"word"},{"id":47975,"position":22,"arabic":"بِإِذْنِ","translation":"হুকুমে","audioUrl":"wbw/003_049_023.mp3","charTypeName":"word"},{"id":47976,"position":23,"arabic":"ٱللَّهِ ۖ","translation":"আল্লাহর","audioUrl":"wbw/003_049_024.mp3","charTypeName":"word"},{"id":47978,"position":24,"arabic":"وَأُبْرِئُ","translatio