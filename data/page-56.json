/003_049_043.mp3","charTypeName":"word"},{"id":47996,"position":40,"arabic":"ذَٰلِكَ","translation":"এর","audioUrl":"wbw/003_049_044.mp3","charTypeName":"word"},{"id":47997,"position":41,"arabic":"لَـَٔايَةًۭ","translation":"অবশ্যই নিদর্শন","audioUrl":"wbw/003_049_045.mp3","charTypeName":"word"},{"id":47998,"position":42,"arabic":"لَّكُمْ","translation":"তোমাদের জন্যে","audioUrl":"wbw/003_049_046.mp3","charTypeName":"word"},{"id":47999,"position":43,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/003_049_047.mp3","charTypeName":"word"},{"id":48000,"position":44,"arabic":"كُنتُم","translation":"তোমরা হও","audioUrl":"wbw/003_049_048.mp3","charTypeName":"word"},{"id":48001,"position":45,"arabic":"مُّؤْمِنِينَ","translation":"মু'মিন","audioUrl":"wbw/003_049_049.mp3","charTypeName":"word"},{"id":48002,"position":46,"arabic":"٤٩","translation":"(৪৯)","audioUrl":null,"charTypeName":"end"}]},{"number":50,"arabic":"وَمُصَدِّقًۭا لِّمَا بَيْنَ يَدَىَّ مِنَ ٱلتَّوْرَىٰةِ وَلِأُحِلَّ لَكُم بَعْضَ ٱلَّذِى حُرِّمَ عَلَيْكُمْ ۚ وَجِئْتُكُم بِـَٔايَةٍۢ مِّن رَّبِّكُمْ فَٱتَّقُوا۟ ٱللَّهَ وَأَطِيعُونِ","translation":"\"And [I have come] to confirm the truth of whatever there still remains of the Torah, and to make lawful unto you some of the things which [aforetime] were forbidden to you. And I have come unto you with a message from your Sustainer; remain, then, conscious of God, and pay heed unto me.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/343.mp3","surahId":3,"words":[{"id":48755,"position":1,"arabic":"وَمُصَدِّقًۭا","translation":"এবং সত্যায়নকারী","audioUrl":"wbw/003_050_001.mp3","charTypeName":"word"},{"id":48756,"position":2,"arabic":"لِّمَا","translation":"(তার) যা","audioUrl":"wbw/003_050_002.mp3","charTypeName":"word"},{"id":48757,"position":3,"arabic":"بَيْنَ","translation":"(মধ্যে)","audioUrl":"wbw/003_050_003.mp3","charTypeName":"word"},{"id":48758,"position":4,"arabic":"يَدَىَّ","translation":"আমার সামনে আছে","audioUrl":"wbw/003_050_004.mp3","