"},{"id":48775,"position":20,"arabic":"٥٠","translation":"(৫০)","audioUrl":null,"charTypeName":"end"}]},{"number":51,"arabic":"إِنَّ ٱللَّهَ رَبِّى وَرَبُّكُمْ فَٱعْبُدُوهُ ۗ هَٰذَا صِرَٰطٌۭ مُّسْتَقِيمٌۭ","translation":"\"Verily, God is my Sustainer as well as your Sustainer; so worship Him [alone]: this is a straight way.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/344.mp3","surahId":3,"words":[{"id":49258,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়","audioUrl":"wbw/003_051_001.mp3","charTypeName":"word"},{"id":49259,"position":2,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/003_051_002.mp3","charTypeName":"word"},{"id":49260,"position":3,"arabic":"رَبِّى","translation":"আমার রব","audioUrl":"wbw/003_051_003.mp3","charTypeName":"word"},{"id":49261,"position":4,"arabic":"وَرَبُّكُمْ","translation":"এবং তোমাদেরও রব","audioUrl":"wbw/003_051_004.mp3","charTypeName":"word"},{"id":49262,"position":5,"arabic":"فَٱعْبُدُوهُ ۗ","translation":"অতএব তোমরা ইবাদত কর তাঁর","audioUrl":"wbw/003_051_005.mp3","charTypeName":"word"},{"id":49264,"position":6,"arabic":"هَـٰذَا","translation":"এটাই","audioUrl":"wbw/003_051_007.mp3","charTypeName":"word"},{"id":49265,"position":7,"arabic":"صِرَٰطٌۭ","translation":"পথ''","audioUrl":"wbw/003_051_008.mp3","charTypeName":"word"},{"id":49266,"position":8,"arabic":"مُّسْتَقِيمٌۭ","translation":"সরল সঠিক''","audioUrl":"wbw/003_051_009.mp3","charTypeName":"word"},{"id":49267,"position":9,"arabic":"٥١","translation":"(৫১)","audioUrl":null,"charTypeName":"end"}]},{"number":52,"arabic":"۞ فَلَمَّآ أَحَسَّ عِيسَىٰ مِنْهُمُ ٱلْكُفْرَ قَالَ مَنْ أَنصَارِىٓ إِلَى ٱللَّهِ ۖ قَالَ ٱلْحَوَارِيُّونَ نَحْنُ أَنصَارُ ٱللَّهِ ءَامَنَّا بِٱللَّهِ وَٱشْهَدْ بِأَنَّا مُسْلِمُونَ","translation":"And when Jesus became aware of their refusal to acknowledge the truth, he asked: \"Who will be my helpers in God's cause?\" The white-garbed ones replied: \"We shall be [thy] helpers [in the cause] of God! We believe in God: and bear thou witness that we have surrendered ourselves unto Him!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/345.mp3","surahId":3,"words":[{"id":49706,"position":1,"arabic":"۞ فَلَمَّآ","translation":"অতঃপর যখন","audioUrl":"wbw/003_052_002.mp3","charTypeName":"word"},{"id":49707,"position":2,"arabic":"أَحَسَّ","translation":"অনুভব করল","audioUrl":"wbw/003_052_003.mp3","charTypeName":"word"},{"id":49708,"position":3,"arabic":"عِيسَىٰ","translation":"ঈসা","audioUrl":"wbw/003_052_004.mp3","charTypeName":"word"},{"id":49709,"position":4,"arabic":"مِنْهُمُ","translation":"তাদের হতে","audioUrl":"wbw/003_052_005.mp3","charTypeName":"word"},{"id":49710,"position":5,"arabic":"ٱلْكُفْرَ","translation":"কুফরীর (প্রতি অবিচলতা)","audioUrl":"wbw/003_052_006.mp3","charTypeName":"word"},{"id":49711,"position":6,"arabic":"قَالَ","translation":"সে বলল","audioUrl":"wbw/003_052_007.mp3","charTypeName":"word"},{"id":49712,"position":7,"arabic":"مَنْ","translation":"''কে (আছ)","audioUrl":"wbw/003_052_008.mp3","charTypeName":"word"},{"id":49713,"position":8,"arabic":"أَنصَارِىٓ","translation":"আমার সাহায্যকারী","audioUrl":"wbw/003_052_009.mp3","charTypeName":"word"},{"id":49714,"position":9,"arabic":"إِلَى","translation":"দিকে","audioUrl":"wbw/003_052_010.mp3","charTypeName":"word"},{"id":49715,"position":10,"arabic":"ٱللَّهِ ۖ","translation":"আল্লাহর (পথে)''","audioUrl":"wbw/003_052_011.mp3","charTypeName":"word"},{"id":49717,"position":11,"arabic":"قَالَ","translation":"বলল","audioUrl":"wbw/003_052_013.mp3","charTypeName":"word"},{"id":49718,"position":12,"arabic":"ٱلْحَوَارِيُّونَ","translation":"হাওয়ারীরা","audioUrl":"wbw/003_052_014.mp3","charTypeName":"word"},{"id":49719,"position":13,"arabic":"نَحْنُ","translation":"''আমরা","audioUrl":"wbw/003_052_015.mp3","charTypeName":"word"},{"id":49720,"position":14,"arabic":"أَنصَارُ","translation":"সাহায্যকারী","audioUrl":"wbw/003_052_016.mp3","charTypeName":"word"},{"id":49721,"position":15,"arabic":"ٱللَّهِ","translati