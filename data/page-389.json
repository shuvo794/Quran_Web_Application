tion":"এবং (বলা হলো) যে","audioUrl":"wbw/028_031_001.mp3","charTypeName":"word"},{"id":33873,"position":2,"arabic":"أَلْقِ","translation":"ছোঁড়ো","audioUrl":"wbw/028_031_002.mp3","charTypeName":"word"},{"id":33874,"position":3,"arabic":"عَصَاكَ ۖ","translation":"তোমার লাঠিকে\"","audioUrl":"wbw/028_031_003.mp3","charTypeName":"word"},{"id":33876,"position":4,"arabic":"فَلَمَّا","translation":"অতঃপর যখন","audioUrl":"wbw/028_031_005.mp3","charTypeName":"word"},{"id":33877,"position":5,"arabic":"رَءَاهَا","translation":"সে দেখলো তা","audioUrl":"wbw/028_031_006.mp3","charTypeName":"word"},{"id":33878,"position":6,"arabic":"تَهْتَزُّ","translation":"হামাগুড়ি দিয়ে চলছে","audioUrl":"wbw/028_031_007.mp3","charTypeName":"word"},{"id":33879,"position":7,"arabic":"كَأَنَّهَا","translation":"যেন তা","audioUrl":"wbw/028_031_008.mp3","charTypeName":"word"},{"id":33880,"position":8,"arabic":"جَآنٌّۭ","translation":"সাপ","audioUrl":"wbw/028_031_009.mp3","charTypeName":"word"},{"id":33881,"position":9,"arabic":"وَلَّىٰ","translation":"(তখন) সে ফিরে পালালো","audioUrl":"wbw/028_031_010.mp3","charTypeName":"word"},{"id":33882,"position":10,"arabic":"مُدْبِرًۭا","translation":"পিছন দিকে","audioUrl":"wbw/028_031_011.mp3","charTypeName":"word"},{"id":33883,"position":11,"arabic":"وَلَمْ","translation":"এবং না","audioUrl":"wbw/028_031_012.mp3","charTypeName":"word"},{"id":33884,"position":12,"arabic":"يُعَقِّبْ ۚ","translation":"মুখ ফিরে দেখলো","audioUrl":"wbw/028_031_013.mp3","charTypeName":"word"},{"id":33886,"position":13,"arabic":"يَـٰمُوسَىٰٓ","translation":"\"(বলা হলো) হে মূসা","audioUrl":"wbw/028_031_015.mp3","charTypeName":"word"},{"id":33887,"position":14,"arabic":"أَقْبِلْ","translation":"সামনে এসো","audioUrl":"wbw/028_031_016.mp3","charTypeName":"word"},{"id":33888,"position":15,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/028_031_017.mp3","charTypeName":"word"},{"id":33889,"position":16,"arabic":"تَخَفْ ۖ","translation":"ভয় করো","audioUrl":"wbw/028_031_018.mp3","c