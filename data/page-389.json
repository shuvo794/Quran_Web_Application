{"id":389,"ayahs":[{"number":29,"arabic":"۞ فَلَمَّا قَضَىٰ مُوسَى ٱلْأَجَلَ وَسَارَ بِأَهْلِهِۦٓ ءَانَسَ مِن جَانِبِ ٱلطُّورِ نَارًۭا قَالَ لِأَهْلِهِ ٱمْكُثُوٓا۟ إِنِّىٓ ءَانَسْتُ نَارًۭا لَّعَلِّىٓ ءَاتِيكُم مِّنْهَا بِخَبَرٍ أَوْ جَذْوَةٍۢ مِّنَ ٱلنَّارِ لَعَلَّكُمْ تَصْطَلُونَ","translation":"And when Moses had fulfilled his term and was wandering with his family [in the desert], he per­ceived a fire on the slope of Mount Sinai; [and so] he said to his family: “Wait here. Behold, I perceive a fire [far away]; perhaps I may bring you from there some tiding, or [at least] a burning brand from the fire, so that you might warm yourselves.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3281.mp3","surahId":28,"words":[{"id":32129,"position":1,"arabic":"۞ فَلَمَّا","translation":"অতঃপর যখন","audioUrl":"wbw/028_029_002.mp3","charTypeName":"word"},{"id":32130,"position":2,"arabic":"قَضَىٰ","translation":"পূর্ণ করলো","audioUrl":"wbw/028_029_003.mp3","charTypeName":"word"},{"id":32131,"position":3,"arabic":"مُوسَى","translation":"মূসা","audioUrl":"wbw/028_029_004.mp3","charTypeName":"word"},{"id":32132,"position":4,"arabic":"ٱلْأَجَلَ","translation":"নির্দিষ্ট মেয়াদ","audioUrl":"wbw/028_029_005.mp3","charTypeName":"word"},{"id":32133,"position":5,"arabic":"وَسَارَ","translation":"ও যাত্রা করলো","audioUrl":"wbw/028_029_006.mp3","charTypeName":"word"},{"id":32134,"position":6,"arabic":"بِأَهْلِهِۦٓ","translation":"নিয়ে তার পরিবার","audioUrl":"wbw/028_029_007.mp3","charTypeName":"word"},{"id":32135,"position":7,"arabic":"ءَانَسَ","translation":"সে দেখলো","audioUrl":"wbw/028_029_008.mp3","charTypeName":"word"},{"id":32136,"position":8,"arabic":"مِن","translation":"হ'তে","audioUrl":"wbw/028_029_009.mp3","charTypeName":"word"},{"id":32137,"position":9,"arabic":"جَانِبِ","translation":"দিক","audioUrl":"wbw/028_029_010.mp3","charTypeName":"word"},{"id":32138,"position":10,"arabic":"ٱلطُّورِ","translation":"তুর পাহাড়ের","audioUrl":"wbw/028_029_011.mp3","charTypeName":"word"},{"id":32139,"position":11,"arabic":"نَارًۭا","translation":"আগুন","audioUrl":"wbw/028_029_012.mp3","charTypeName":"word"},{"id":32140,"position":12,"arabic":"قَالَ","translation":"(তখন) সে বললো","audioUrl":"wbw/028_029_013.mp3","charTypeName":"word"},{"id":32141,"position":13,"arabic":"لِأَهْلِهِ","translation":"উদ্দেশ্যে তার পরিবারের","audioUrl":"wbw/028_029_014.mp3","charTypeName":"word"},{"id":32142,"position":14,"arabic":"ٱمْكُثُوٓا۟","translation":"\"তোমরা অপেক্ষা করো","audioUrl":"wbw/028_029_015.mp3","charTypeName":"word"},{"id":32143,"position":15,"arabic":"إِنِّىٓ","translation":"নিশ্চয়ই আমি","audioUrl":"wbw/028_029_016.mp3","charTypeName":"word"},{"id":32144,"position":16,"arabic":"ءَانَسْتُ","translation":"আমি দেখেছি","audioUrl":"wbw/028_029_017.mp3","charTypeName":"word"},{"id":32145,"position":17,"arabic":"نَارًۭا","translation":"আগুন","audioUrl":"wbw/028_029_018.mp3","charTypeName":"word"},{"id":32146,"position":18,"arabic":"لَّعَلِّىٓ","translation":"সম্ভবতঃ আমি","audioUrl":"wbw/028_029_019.mp3","charTypeName":"word"},{"id":32147,"position":19,"arabic":"ءَاتِيكُم","translation":"তোমাদের কাছে আমি আসবো","audioUrl":"wbw/028_029_020.mp3","charTypeName":"word"},{"id":32148,"position":20,"arabic":"مِّنْهَا","translation":"হ'তে সেখান","audioUrl":"wbw/028_029_021.mp3","charTypeName":"word"},{"id":32149,"position":21,"arabic":"بِخَبَرٍ","translation":"নিয়ে কোন তথ্য","audioUrl":"wbw/028_029_022.mp3","charTypeName":"word"},{"id":32150,"position":22,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/028_029_023.mp3","charTypeName":"word"},{"id":32151,"position":23,"arabic":"جَذْوَةٍۢ","translation":"জ্বলন্ত অঙ্গার","audioUrl":"wbw/028_029_024.mp3","charTypeName":"word"},{"id":32152,"position":24,"arabic":"مِّنَ","translation":"হ'তে","audioUrl":"wbw/028_029_025.mp3","charTypeName":"word"},{"id":32153,"position":25,"arabic":"ٱلنَّارِ","translation":"আগুন","audioUrl":"wbw/028_029_026.mp3","charTypeName":"word"},{"id":32154,"position":26,"arabic":"لَ