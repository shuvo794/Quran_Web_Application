":"wbw/028_032_024.mp3","charTypeName":"word"},{"id":34846,"position":23,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/028_032_025.mp3","charTypeName":"word"},{"id":34847,"position":24,"arabic":"قَوْمًۭا","translation":"সম্প্রদায়","audioUrl":"wbw/028_032_026.mp3","charTypeName":"word"},{"id":34848,"position":25,"arabic":"فَـٰسِقِينَ","translation":"সত্যত্যাগী\"","audioUrl":"wbw/028_032_027.mp3","charTypeName":"word"},{"id":34849,"position":26,"arabic":"٣٢","translation":"(৩২)","audioUrl":null,"charTypeName":"end"}]},{"number":33,"arabic":"قَالَ رَبِّ إِنِّى قَتَلْتُ مِنْهُمْ نَفْسًۭا فَأَخَافُ أَن يَقْتُلُونِ","translation":"Said [Moses] “O my Sustainer! I have slain one of them, and so I fear that they will slay me.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3285.mp3","surahId":28,"words":[{"id":35639,"position":1,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/028_033_001.mp3","charTypeName":"word"},{"id":35640,"position":2,"arabic":"رَبِّ","translation":"\"হে আমার রব","audioUrl":"wbw/028_033_002.mp3","charTypeName":"word"},{"id":35641,"position":3,"arabic":"إِنِّى","translation":"নিশ্চয়ই আমি","audioUrl":"wbw/028_033_003.mp3","charTypeName":"word"},{"id":35642,"position":4,"arabic":"قَتَلْتُ","translation":"আমি হত্যা করেছি","audioUrl":"wbw/028_033_004.mp3","charTypeName":"word"},{"id":35643,"position":5,"arabic":"مِنْهُمْ","translation":"মধ্য হ'তে তাদের","audioUrl":"wbw/028_033_005.mp3","charTypeName":"word"},{"id":35644,"position":6,"arabic":"نَفْسًۭا","translation":"এক ব্যক্তিকে","audioUrl":"wbw/028_033_006.mp3","charTypeName":"word"},{"id":35645,"position":7,"arabic":"فَأَخَافُ","translation":"অতএব আমি ভয় করি","audioUrl":"wbw/028_033_007.mp3","charTypeName":"word"},{"id":35646,"position":8,"arabic":"أَن","translation":"যে","audioUrl":"wbw/028_033_008.mp3","charTypeName":"word"},{"id":35647,"position":9,"arabic":"يَقْتُلُونِ","translation":"আমাকে তারা হত্যা করবে","audioUrl":"wbw/028_033_009.mp3","charTypeName":"word"},{"id":35648,"position":10,"arabic":"٣٣","translation":"(৩৩)","audioUrl":null,"charTypeName":"end"}]},{"number":34,"arabic":"وَأَخِى هَٰرُونُ هُوَ أَفْصَحُ مِنِّى لِسَانًۭا فَأَرْسِلْهُ مَعِىَ رِدْءًۭا يُصَدِّقُنِىٓ ۖ إِنِّىٓ أَخَافُ أَن يُكَذِّبُونِ","translation":"And my brother Aaron - he is far better in speech than I am. Send him, therefore, as a helper, so that he might [more eloquently] bear witness to my speaking the truth: for I fear indeed that they will give me the lie.”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3286.mp3","surahId":28,"words":[{"id":36589,"position":1,"arabic":"وَأَخِى","translation":"এবং আমার ভাই","audioUrl":"wbw/028_034_001.mp3","charTypeName":"word"},{"id":36590,"position":2,"arabic":"هَـٰرُونُ","translation":"হারুন","audioUrl":"wbw/028_034_002.mp3","charTypeName":"word"},{"id":36591,"position":3,"arabic":"هُوَ","translation":"সে","audioUrl":"wbw/028_034_003.mp3","charTypeName":"word"},{"id":36592,"position":4,"arabic":"أَفْصَحُ","translation":"অধিক বাকপটু","audioUrl":"wbw/028_034_004.mp3","charTypeName":"word"},{"id":36593,"position":5,"arabic":"مِنِّى","translation":"আমার চেয়ে","audioUrl":"wbw/028_034_005.mp3","charTypeName":"word"},{"id":36594,"position":6,"arabic":"لِسَانًۭا","translation":"ভাষায়","audioUrl":"wbw/028_034_006.mp3","charTypeName":"word"},{"id":36595,"position":7,"arabic":"فَأَرْسِلْهُ","translation":"সুতরাং তাকে পাঠাও","audioUrl":"wbw/028_034_007.mp3","charTypeName":"word"},{"id":36596,"position":8,"arabic":"مَعِىَ","translation":"আমার সাথে","audioUrl":"wbw/028_034_008.mp3","charTypeName":"word"},{"id":36597,"position":9,"arabic":"رِدْءًۭا","translation":"সহায়ক হিসেবে","audioUrl":"wbw/028_034_009.mp3","charTypeName":"word"},{"id":36598,"position":10,"arabic":"يُصَدِّقُنِىٓ ۖ","translation":"আমাকে সে সমর্থন করবে","audioUrl":"wbw/028_034_010.mp3","charTypeName":"word"},{"id":36600,"position":11,"arabic":"إِنِّىٓ","translation":"নিশ্চয়ই আমি","audioUrl":"wbw/028_034_012.mp3","charTypeName":"word"},{"id":36601,"position":12,"arabic":"أَخَافُ","translation":"আশংকা করি","audioUrl":"wbw/028_034_013.mp3","charTypeName":"word"},{"id":36602,"position":13,"arabic":"أَن","translation":"যে","audioUrl":"wbw/028_034_014.mp3","charTypeName":"word"},{"id":36603,"position":14,"arabic":"يُكَذِّبُونِ","translation":"আমাকে তারা মিথ্যাবাদী বলবে\"","audioUrl":"wbw/028_034_015.mp3","charTypeName":"word"},{"id":36604,"position":15,"arabic":"٣٤","translation":"(৩৪)","audioUrl":null,"charTypeName":"end"}]},{"number":35,"arabic":"قَالَ سَنَشُدُّ عَضُدَكَ بِأَخِيكَ وَنَجْعَلُ لَكُمَا سُلْطَٰنًۭا فَلَا يَصِلُونَ إِلَيْكُمَا ۚ بِـَٔايَٰتِنَآ أَنتُمَا وَمَنِ ٱتَّبَعَكُمَا ٱلْغَٰلِبُونَ","translation":"Said He: “We shall strengthen thine arm through thy brother, and endow both of you with power, so that they will not be able to touch you: by virtue of Our messages shall you two, and all who follow you, prevail!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3287.mp3","surahId":28,"words":[{"id":37434,"position":1,"arabic":"قَالَ","translation":"আল্লাহ (বলেন)","audioUrl":"wbw/028_035_001.mp3","charTypeName":"word"},{"id":37435,"position":2,"arabic":"سَنَشُدُّ","translation":"\"অচিরেই আমরা শক্ত করবো","audioUrl":"wbw/028_035_002.mp3","charTypeName":"word"},{"id":37436,"position":3,"arabic":"عَضُدَكَ","translation":"তোমার বাহুকে","audioUrl":"wbw/028_035_003.mp3","charTypeName":"word"},{"id":37437,"position":4,"arabic":"بِأَخِيكَ","translation":"দ্বারা তোমার ভাই","audioUrl":"wbw/028_035_004.mp3","charTypeName":"word"},{"id":37438,"position":5,"arabic":"وَنَجْعَلُ","translation":"এবং আমরা দিবো","audioUrl":"wbw/028_035_005.mp3","charTypeName":"word"},{"id":37439,"position":6,"arabic":"لَكُمَا","translation":"জন্যে তোমাদের দু'জনের","audioUrl":"wbw/028_035_006.mp3","charTypeName":"word"},{"id":37440,"position":7,"arabic":"سُلْطَـٰنًۭا","translation":"প্রাধান্য","audioUrl":"wbw/028_035_007.mp3","charTypeName":"word"},{"id":37441,"position":8,"arabic":"فَلَا","translation":"সুতরাং না","audioUrl":"wbw/028_035_008.mp3","charTypeName":"word"},{"id":37442,"position":9,"arabic":"يَصِلُونَ","translation":"তারা পৌঁছুতে পারবে (কষ্ট দিতে)","audioUrl":"wbw/028_035_009.mp3","charTypeName":"word"},{"id":37443,"position":10,"arabic":"إِلَيْكُمَا ۚ","translation":"নিকটে তোমাদের দু'জনের","audioUrl":"wbw/028_035_010.mp3","charTypeName":"word"},{"id":37445,"position":11,"arabic":"بِـَٔايَـٰتِنَآ","translation":"মাধ্যমে আমাদের নিদর্শনগুলোর","audioUrl":"wbw/028_035_012.mp3","charTypeName":"word"},{"id":37446,"position":12,"arabic":"أَنتُمَا","translation":"তোমরা দু'জন","audioUrl":"wbw/028_035_013.mp3","charTypeName":"word"},{"id":37447,"position":13,"arabic":"وَمَنِ","translation":"এবং যারা","audioUrl":"wbw/028_035_014.mp3","charTypeName":"word"},{"id":37448,"position":14,"arabic":"ٱتَّبَعَكُمَا","translation":"অনুসরণ করবে তোমাদের দু'জনকে","audioUrl":"wbw/028_035_015.mp3","charTypeName":"word"},{"id":37449,"position":15,"arabic":"ٱلْغَـٰلِبُونَ","translation":"বিজয়ী হবে\"","audioUrl":"wbw/028_035_016.mp3","charTypeName":"word"},{"id":37450,"position":16,"arabic":"٣٥","translation":"(৩৫)","audioUrl":null,"charTypeName":"end"}]}]}