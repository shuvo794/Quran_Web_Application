{"id":393,"ayahs":[{"number":60,"arabic":"وَمَآ أُوتِيتُم مِّن شَىْءٍۢ فَمَتَٰعُ ٱلْحَيَوٰةِ ٱلدُّنْيَا وَزِينَتُهَا ۚ وَمَا عِندَ ٱللَّهِ خَيْرٌۭ وَأَبْقَىٰٓ ۚ أَفَلَا تَعْقِلُونَ","translation":"And [remember:] whatever you are given [now] is but for the [passing] enjoyment of life in this world, and for its embellishment - whereas that which is with God is [so much] better and more enduring. Will you not, then, use your reason?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3312.mp3","surahId":28,"words":[{"id":54641,"position":1,"arabic":"وَمَآ","translation":"আর যা কিছু","audioUrl":"wbw/028_060_001.mp3","charTypeName":"word"},{"id":54642,"position":2,"arabic":"أُوتِيتُم","translation":"দেয়া হয়েছে তোমাদের","audioUrl":"wbw/028_060_002.mp3","charTypeName":"word"},{"id":54643,"position":3,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/028_060_003.mp3","charTypeName":"word"},{"id":54644,"position":4,"arabic":"شَىْءٍۢ","translation":"বস্তু","audioUrl":"wbw/028_060_004.mp3","charTypeName":"word"},{"id":54645,"position":5,"arabic":"فَمَتَـٰعُ","translation":"তা হলো ভোগসামগ্রী","audioUrl":"wbw/028_060_005.mp3","charTypeName":"word"},{"id":54646,"position":6,"arabic":"ٱلْحَيَوٰةِ","translation":"জীবনের","audioUrl":"wbw/028_060_006.mp3","charTypeName":"word"},{"id":54647,"position":7,"arabic":"ٱلدُّنْيَا","translation":"পার্থিব","audioUrl":"wbw/028_060_007.mp3","charTypeName":"word"},{"id":54648,"position":8,"arabic":"وَزِينَتُهَا ۚ","translation":"ও তার চাকচিক্য (মাত্র)","audioUrl":"wbw/028_060_008.mp3","charTypeName":"word"},{"id":54650,"position":9,"arabic":"وَمَا","translation":"আর যা (আছে)","audioUrl":"wbw/028_060_010.mp3","charTypeName":"word"},{"id":54651,"position":10,"arabic":"عِندَ","translation":"নিকট","audioUrl":"wbw/028_060_011.mp3","charTypeName":"word"},{"id":54652,"position":11,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/028_060_012.mp3","charTypeName":"word"},{"id":54653,"position":12,"arabic":"خَيْرٌۭ","translation":"(তাই) উত্তম","audioUrl":"wbw/028_060_013.mp3","charTypeName":"word"},{"id":54654,"position":13,"arabic":"وَأَبْقَىٰٓ ۚ","translation":"ও অধিক স্থায়ী","audioUrl":"wbw/028_060_014.mp3","charTypeName":"word"},{"id":54656,"position":14,"arabic":"أَفَلَا","translation":"কি তবে না","audioUrl":"wbw/028_060_016.mp3","charTypeName":"word"},{"id":54657,"position":15,"arabic":"تَعْقِلُونَ","translation":"তোমরা বুঝবে","audioUrl":"wbw/028_060_017.mp3","charTypeName":"word"},{"id":54658,"position":16,"arabic":"٦٠","translation":"(৬০)","audioUrl":null,"charTypeName":"end"}]},{"number":61,"arabic":"أَفَمَن وَعَدْنَٰهُ وَعْدًا حَسَنًۭا فَهُوَ لَٰقِيهِ كَمَن مَّتَّعْنَٰهُ مَتَٰعَ ٱلْحَيَوٰةِ ٱلدُّنْيَا ثُمَّ هُوَ يَوْمَ ٱلْقِيَٰمَةِ مِنَ ٱلْمُحْضَرِينَ","translation":"Is, then, he to whom We have given that goodly promise which he shall see fulfilled [on his resurrection] comparable to one on whom We have bestowed [all] the enjoyments of this worldly life but who, on Resurrection Day, will find himself among those that shall be arraigned [before Us]?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3313.mp3","surahId":28,"words":[{"id":55227,"position":1,"arabic":"أَفَمَن","translation":"কি তবে সে","audioUrl":"wbw/028_061_001.mp3","charTypeName":"word"},{"id":55228,"position":2,"arabic":"وَعَدْنَـٰهُ","translation":"আমরা প্রতিশ্রুতি দিয়েছি যাকে","audioUrl":"wbw/028_061_002.mp3","charTypeName":"word"},{"id":55229,"position":3,"arabic":"وَعْدًا","translation":"প্রতিশ্রুতি","audioUrl":"wbw/028_061_003.mp3","charTypeName":"word"},{"id":55230,"position":4,"arabic":"حَسَنًۭا","translation":"উত্তম","audioUrl":"wbw/028_061_004.mp3","charTypeName":"word"},{"id":55231,"position":5,"arabic":"فَهُوَ","translation":"অতঃপর সে","audioUrl":"wbw/028_061_005.mp3","charTypeName":"word"},{"id":55232,"position":6,"arabic":"لَـٰقِيهِ","translation":"লাভ করবে তা","audioUrl":"wbw/028_061_006.mp3","charTypeName":"word"},{"id":55233,"position":7,"arabic":"كَمَن","translation":"(সে কি) তার মতো","audioUrl":"wbw/028_061_007.mp3","charTypeName":"word"},{"id":55234,"position":8,"arabic":"مَّتَّعْنَـٰهُ","translation":"আমরা ভোগ করতে দিয়েছি যাকে","audioUrl":"wbw/028_061_008.mp3","charTypeName":"word"},{"id":55235,"position":9,"arabic":"مَتَـٰعَ","translation":"ভোগসামগ্রী","audioUrl":"wbw/028_061_009.mp3","charTypeName":"word"},{"id":55236,"position":10,"arabic":"ٱلْحَيَوٰةِ","translation":"জীবনের","audioUrl":"wbw/028_061_010.mp3","charTypeName":"word"},{"id":55237,"position":11,"arabic":"ٱلدُّنْيَا","translation":"পার্থিব","audioUrl":"wbw/028_061_011.mp3","charTypeName":"word"},{"id":55238,"position":12,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/028_061_012.mp3","charTypeName":"word"},{"id":55239,"position":13,"arabic":"هُوَ","translation":"সে (হবে)","audioUrl":"wbw/028_061_013.mp3","charTypeName":"word"},{"id":55240,"position":14,"arabic":"يَوْمَ","translation":"দিনে","audioUrl":"wbw/028_061_014.mp3","charTypeName":"word"},{"id":55241,"position":15,"arabic":"ٱلْقِيَـٰمَةِ","translation":"ক্বিয়ামাতের","audioUrl":"wbw/028_061_015.mp3","charTypeName":"word"},{"id":55242,"position":16,"arabic":"مِنَ","translation":"অন্তর্ভূক্ত","audioUrl":"wbw/028_061_016.mp3","charTypeName":"word"},{"id":55243,"position":17,"arabic":"ٱلْمُحْضَرِينَ","translation":"উপস্থিতদের (অপরাধীদের)","audioUrl":"wbw/028_061_017.mp3","charTypeName":"word"},{"id":55244,"position":18,"arabic":"٦١","translation":"(৬১)","audioUrl":null,"charTypeName":"end"}]},{"number":62,"arabic":"وَيَوْمَ يُنَادِيهِمْ فَيَقُولُ أَيْنَ شُرَكَآءِىَ ٱلَّذِينَ كُنتُمْ تَزْعُمُونَ","translation":"For, on that Day He will call unto them, and will ask: “Where, now, are those [beings or powers] whom you imagined to have a share in My divinity?”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3314.mp3","surahId":28,"words":[{"id":55761,"position":1,"arabic":"وَيَوْمَ","translation":"এবং সেদিন","audioUrl":"wbw/028_062_001.mp3","charTypeName":"word"},{"id":55762,"position":2,"arabic":"يُنَادِيهِمْ","translation":"তিনি ডাকবেন তাদেরকে","audioUrl":"wbw/028_062_002.mp3","charTypeName":"word"},{"id":55763,"position":3,"arabic":"فَيَقُولُ","translation":"অতঃপর বলবেন","audioUrl":"wbw/028_062_003.mp3","charTypeName":"word"},{"id":55764,"position":4,"arabic":"أَيْنَ","translation":"\"কোথায়","audioUrl":"wbw/028_062_004.mp3","charTypeName":"word"},{"id":55765,"position":5,"arabic":"شُرَكَآءِىَ","translation":"আমার শরিকেরা","audioUrl":"wbw/028_062_005.mp3","charTypeName":"word"},{"id":55766,"position":6,"arabic":"ٱلَّذِينَ","translation":"যাদেরকে","audioUrl":"wbw/028_062_006.mp3","charTypeName":"word"},{"id":55767,"position":7,"arabic":"كُنتُمْ","translation":"তোমরা ছিলে","audioUrl":"wbw/028_062_007.mp3","charTypeName":"word"},{"id":55768,"position":8,"arabic":"تَزْعُمُونَ","translation":"ধারণা করতে (শরিক হিসেবে)\"","audioUrl":"wbw/028_062_008.mp3","charTypeName":"word"},{"id":55769,"position":9,"arabic":"٦٢","translation":"(৬২)","audioUrl":null,"charTypeName":"end"}]},{"number":63,"arabic":"قَالَ ٱلَّذِينَ حَقَّ عَلَيْهِمُ ٱلْقَوْلُ رَبَّنَا هَٰٓؤُلَآءِ ٱلَّذِينَ أَغْوَيْنَآ أَغْوَيْنَٰهُمْ كَمَا غَوَيْنَا ۖ تَبَرَّأْنَآ إِلَيْكَ ۖ مَا كَانُوٓا۟ إِيَّانَا يَعْبُدُونَ","translation":"[whereupon] they against whom the word [of truth] shall thus stand revealed will exclaim: O our Sustainer! Those whom we caused to err so grievously, we but caused to err as we our­selves had been erring. We [now] disavow them before Thee: it was not us that they worshipped!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3315.mp3","surahId":28,"words":[{"id":56325,"position":1,"arabic":"قَالَ","translation":"বলবে","audioUrl":"wbw/028_063_001.mp3","charTypeName":"word"},{"id":56326,"position":2,"arabic":"ٱلَّذِينَ","translation":"তারা","audioUrl":"wbw/028_063_002.mp3","charTypeName":"word"},{"id":56327,"position":3,"arabic":"حَقَّ","translation":"অবধারিত হয়েছে","audioUrl":"wbw/028_063_003.mp3","charTypeName":"word"},{"id":56328,"position":4,"arabic":"عَلَيْهِمُ","translation":"উপর যাদের","audioUrl":"wbw/028_063_004.mp3","charTypeName":"word"},{"id":56329,"position":5,"arabic":"ٱلْقَوْلُ","translation":"(এই) কথাটি","audioUrl":"wbw/028_063_005.mp3","charTypeName":"word"},{"id":56330,"position":6,"arabic":"رَبَّنَا","translation":"\"হে আমার রব","audioUrl":"wbw/028_063_006.mp3","charTypeName":"word"},{"id":56331,"position":7,"arabic":"هَـٰٓؤُلَآءِ","translation":"এরাই","audioUrl":"wbw/028_063_007.mp3","charTypeName":"word"},{"id":56332,"position":8,"arabic":"ٱلَّذِينَ","translation":"(তারা) যাদেরকে","audioUrl":"wbw/028_063_008.mp3","charTypeName":"word"},{"id":56333,"position":9,"arabic":"أَغْوَيْنَآ","translation":"পথভ্রষ্ট করেছিলাম আমরা","audioUrl":"wbw/028_063_009.mp3","charTypeName":"word"},{"id":56334,"position":10,"arabic":"أَغْوَيْنَـٰهُمْ","translation":"পথভ্রষ্ট করেছিলাম আমরা তাদেরকে","audioUrl":"wbw/028_063_010.mp3","charTypeName":"word"},{"id":56335,"position":11,"arabic":"كَمَا","translation":"যেমন","audioUrl":"wbw/028_063_011.mp3","charTypeName":"word"},{"id":56336,"position":12,"arabic":"غَوَيْنَا ۖ","translation":"পথভ্রষ্ট হয়েছিলাম আমরা","audioUrl":"wbw/028_063_012.mp3","charTypeName":"word"},{"id":56338,"position":13,"arabic":"تَبَرَّأْنَآ","translation":"দায়মুক্ত বলে ঘোষণা করছি আমরা","audioUrl":"wbw/028_063_014.mp3","charTypeName":"word"},{"id":56339,"position":14,"arabic":"إِلَيْكَ ۖ","translation":"আপনার কাছে","audioUrl":"wbw/028_063_015.mp3","charTypeName":"word"},{"id":56341,"position":15,"arabic":"مَا","translation":"না","audioUrl":"wbw/028_063_017.mp3","charTypeName":"word"},{"id":56342,"position":16,"arabic":"كَانُوٓا۟","translation":"তারা ছিলো","audioUrl":"wbw/028_063_018.mp3","charTypeName":"word"},{"id":56343,"position":17,"arabic":"إِيَّانَا","translation":"আমাদের\"","audioUrl":"wbw/028_063_019.mp3","charTypeName":"word"},{"id":56344,"position":18,"arabic":"يَعْبُدُونَ","translation":"ইবাদাত করতো\"","audioUrl":"wbw/028_063_020.mp3","charTypeName":"word"},{"id":56345,"position":19,"arabic":"٦٣","translation":"(৬৩)","audioUrl":null,"charTypeName":"end"}]},{"number":64,"arabic":"وَقِيلَ ٱدْعُوا۟ شُرَكَآءَكُمْ فَدَعَوْهُمْ فَلَمْ يَسْتَجِيبُوا۟ لَهُمْ وَرَأَوُا۟ ٱلْعَذَابَ ۚ لَوْ أَنَّهُمْ كَانُوا۟ يَهْتَدُونَ","translation":"And [they] will be told: “Call [now] unto those [beings or powers] to whom you were wont to ascribe a share in God’s divinity!” and they will call unto them [for help], but those [fake objects of worship] will not respond to them: whereupon they will see the suffering [that awaits them - the suffering which could have been avoided] if only they had allowed them­selves to be guided!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3316.mp3","surahId":28,"words":[{"id":56806,"position":1,"arabic":"وَقِيلَ","translation":"এবং বলা হবে","audioUrl":"wbw/028_064_001.mp3","charTypeName":"word"},{"id":56807,"position":2,"arabic":"ٱدْعُوا۟","translation":"\"তোমরা ডাকো","audioUrl":"wbw/028_064_002.mp3","charTypeName":"word"},{"id":56808,"position":3,"arabic":"شُرَكَآءَكُمْ","translation":"শরিকদেরকে তোমাদের (বানানো)\"","audioUrl":"wbw/028_064_003.mp3","charTypeName":"word"},{"id":56809,"position":4,"arabic":"فَدَعَوْهُمْ","translation":"তখন তারা ডাকবে তাদেরকে","audioUrl":"wbw/028_064_004.mp3","charTypeName":"word"},{"id":56810,"position":5,"arabic":"فَلَمْ","translation":"কিন্তু না","audioUrl":"wbw/028_064_005.mp3","charTypeName":"word"},{"id":56811,"position":6,"arabic":"يَسْتَجِيبُوا۟","translation":"তারা ডাকে সাড়া দিবে","audioUrl":"wbw/028_064_006.mp3","charTypeName":"word"},{"id":56812,"position":7,"arabic":"لَهُمْ","translation":"উদ্দেশ্যে তাদের","audioUrl":"wbw/028_064_007.mp3","charTypeName":"word"},{"id":56813,"position":8,"arabic":"وَرَأَوُا۟","translation":"এবং তারা দেখবে","audioUrl":"wbw/028_064_008.mp3","charTypeName":"word"},{"id":56814,"position":9,"arabic":"ٱلْعَذَابَ ۚ","translation":"শাস্তি","audioUrl":"wbw/028_064_009.mp3","charTypeName":"word"},{"id":56816,"position":10,"arabic":"لَوْ","translation":"(হায়!) যদি","audioUrl":"wbw/028_064_011.mp3","charTypeName":"word"},{"id":56817,"position":11,"arabic":"أَنَّهُمْ","translation":"(এমন হতো) যে তারা","audioUrl":"wbw/028_064_012.mp3","charTypeName":"word"},{"id":56818,"position":12,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/028_064_013.mp3","charTypeName":"word"},{"id":56819,"position":13,"arabic":"يَهْتَدُونَ","translation":"সঠিকপথ পেতো","audioUrl":"wbw/028_064_014.mp3","charTypeName":"word"},{"id":56820,"position":14,"arabic":"٦٤","translation":"(৬৪)","audioUrl":null,"charTypeName":"end"}]},{"number":65,"arabic":"وَيَوْمَ يُنَادِيهِمْ فَيَقُولُ مَاذَآ أَجَبْتُمُ ٱلْمُرْسَلِينَ","translation":"And on that Day He will call unto them, and will ask: “How did you respond to My message­ bearers?”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3317.mp3","surahId":28,"words":[{"id":57322,"position":1,"arabic":"وَيَوْمَ","translation":"এবং সেদিন","audioUrl":"wbw/028_065_001.mp3","charTypeName":"word"},{"id":57323,"position":2,"arabic":"يُنَادِيهِمْ","translation":"তিনি ডাকবেন তাদেরকে","audioUrl":"wbw/028_065_002.mp3","charTypeName":"word"},{"id":57324,"position":3,"arabic":"فَيَقُولُ","translation":"অতঃপর বলবেন","audioUrl":"wbw/028_065_003.mp3","charTypeName":"word"},{"id":57325,"position":4,"arabic":"مَاذَآ","translation":"\"কি","audioUrl":"wbw/028_065_004.mp3","charTypeName":"word"},{"id":57326,"position":5,"arabic":"أَجَبْتُمُ","translation":"জবাব দিয়েছিলে তোমরা","audioUrl":"wbw/028_065_005.mp3","charTypeName":"word"},{"id":57327,"position":6,"arabic":"ٱلْمُرْسَلِينَ","translation":"রাসূলদেরকে\"","audioUrl":"wbw/028_065_006.mp3","charTypeName":"word"},{"id":57328,"position":7,"arabic":"٦٥","translation":"(৬৫)","audioUrl":null,"charTypeName":"end"}]},{"number":66,"arabic":"فَعَمِيَتْ عَلَيْهِمُ ٱلْأَنۢبَآءُ يَوْمَئِذٍۢ فَهُمْ لَا يَتَسَآءَلُونَ","translation":"but all arguments and excuses will by then have been erased from their minds, and they will not [be able to] obtain any [helpful] answer from one another.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3318.mp3","surahId":28,"words":[{"id":57838,"position":1,"arabic":"فَعَمِيَتْ","translation":"তখন বিলুপ্ত হবে","audioUrl":"wbw/028_066_001.mp3","charTypeName":"word"},{"id":57839,"position":2,"arabic":"عَلَيْهِمُ","translation":"থেকে তাদের","audioUrl":"wbw/028_066_002.mp3","charTypeName":"word"},{"id":57840,"position":3,"arabic":"ٱلْأَنۢبَآءُ","translation":"তথ্যাদি","audioUrl":"wbw/028_066_003.mp3","charTypeName":"word"},{"id":57841,"position":4,"arabic":"يَوْمَئِذٍۢ","translation":"সেদিন","audioUrl":"wbw/028_066_004.mp3","charTypeName":"word"},{"id":57842,"position":5,"arabic":"فَهُمْ","translation":"তখন তারা","audioUrl":"wbw/028_066_005.mp3","charTypeName":"word"},{"id":57843,"position":6,"arabic":"لَا","translation":"না","audioUrl":"wbw/028_066_006.mp3","charTypeName":"word"},{"id":57844,"position":7,"arabic":"يَتَسَآءَلُونَ","translation":"পরস্পরকে জিজ্ঞেসও করতে পারবে","audioUrl":"wbw/028_066_007.mp3","charTypeName":"word"},{"id":57845,"position":8,"arabic":"٦٦","translation":"(৬৬)","audioUrl":null,"charTypeName":"end"}]},{"number":67,"arabic":"فَأَمَّا مَن تَابَ وَءَامَنَ وَعَمِلَ صَٰلِحًۭا فَعَسَىٰٓ أَن يَكُونَ مِنَ ٱلْمُفْلِحِينَ","translation":"But as against this - anyone who repents and attains to faith and does righteous deeds may well [hope to] find himself among those who achieve a happy state [in the life to come].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3319.mp3","surahId":28,"words":[{"id":58189,"position":1,"arabic":"فَأَمَّا","translation":"তবে অবশ্য","audioUrl":"wbw/028_067_001.mp3","charTypeName":"word"},{"id":58190,"position":2,"arabic":"مَن","translation":"যে","audioUrl":"wbw/028_067_002.mp3","charTypeName":"word"},{"id":58191,"position":3,"arabic":"تَابَ","translation":"তওবা করলো","audioUrl":"wbw/028_067_003.mp3","charTypeName":"word"},{"id":58192,"position":4,"arabic":"وَءَامَنَ","translation":"ও ঈমান আনলো","audioUrl":"wbw/028_067_004.mp3","charTypeName":"word"},{"id":58193,"position":5,"arabic":"وَعَمِلَ","translation":"ও কাজ করলো","audioUrl":"wbw/028_067_005.mp3","charTypeName":"word"},{"id":58194,"position":6,"arabic":"صَـٰلِحًۭا","translation":"সৎ","audioUrl":"wbw/028_067_006.mp3","charTypeName":"word"},{"id":58195,"position":7,"arabic":"فَعَسَىٰٓ","translation":"সেক্ষেত্রে আশা করা যায়","audioUrl":"wbw/028_067_007.mp3","charTypeName":"word"},{"id":58196,"position":8,"arabic":"أَن","translation":"যে","audioUrl":"wbw/028_067_008.mp3","charTypeName":"word"},{"id":58197,"position":9,"arabic":"يَكُونَ","translation":"সে হবে","audioUrl":"wbw/028_067_009.mp3","charTypeName":"word"},{"id":58198,"position":10,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/028_067_010.mp3","charTypeName":"word"},{"id":58199,"position":11,"arabic":"ٱلْمُفْلِحِينَ","translation":"সফলকামদের","audioUrl":"wbw/028_067_011.mp3","charTypeName":"word"},{"id":58200,"position":12,"arabic":"٦٧","translation":"(৬৭)","audioUrl":null,"charTypeName":"end"}]},{"number":68,"arabic":"وَرَبُّكَ يَخْلُقُ مَا يَشَآءُ وَيَخْتَارُ ۗ مَا كَانَ لَهُمُ ٱلْخِيَرَةُ ۚ سُبْحَٰنَ ٱللَّهِ وَتَعَٰلَىٰ عَمَّا يُشْرِكُونَ","translation":"AND [thus it is:] thy Sustainer creates whatever He wills; and He chooses [for mankind] whatever is best for them. Limitless is God in His glory, and sub­limely exalted above anything to which they may ascribe a share in His divinity!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3320.mp3","surahId":28,"words":[{"id":58727,"position":1,"arabic":"وَرَبُّكَ","translation":"এবং তোমার রব","audioUrl":"wbw/028_068_001.mp3","charTypeName":"word"},{"id":58728,"position":2,"arabic":"يَخْلُقُ","translation":"সৃষ্টি করেন","audioUrl":"wbw/028_068_002.mp3","charTypeName":"word"},{"id":58729,"position":3,"arabic":"مَا","translation":"যা কিছু","audioUrl":"wbw/028_068_003.mp3","charTypeName":"word"},{"id":58730,"position":4,"arabic":"يَشَآءُ","translation":"তিনি চান","audioUrl":"wbw/028_068_004.mp3","charTypeName":"word"},{"id":58731,"position":5,"arabic":"وَيَخْتَارُ ۗ","translation":"এবং মনোনীত করেন (নিজের কাজে যাকে চান)","audioUrl":"wbw/028_068_005.mp3","charTypeName":"word"},{"id":58733,"position":6,"arabic":"مَا","translation":"না","audioUrl":"wbw/028_068_007.mp3","charTypeName":"word"},{"id":58734,"position":7,"arabic":"كَانَ","translation":"আছে","audioUrl":"wbw/028_068_008.mp3","charTypeName":"word"},{"id":58735,"position":8,"arabic":"لَهُمُ","translation":"জন্যে তাদের(এ ব্যাপারে)","audioUrl":"wbw/028_068_009.mp3","charTypeName":"word"},{"id":58736,"position":9,"arabic":"ٱلْخِيَرَةُ ۚ","translation":"বেছে নেয়ার স্বাধীনতা","audioUrl":"wbw/028_068_010.mp3","charTypeName":"word"},{"id":58738,"position":10,"arabic":"سُبْحَـٰنَ","translation":"পবিত্র মহান","audioUrl":"wbw/028_068_012.mp3","charTypeName":"word"},{"id":58739,"position":11,"arabic":"ٱللَّهِ","translation":"আল্লাহ","audioUrl":"wbw/028_068_013.mp3","charTypeName":"word"},{"id":58740,"position":12,"arabic":"وَتَعَـٰلَىٰ","translation":"এবং বহু উর্দ্ধে","audioUrl":"wbw/028_068_014.mp3","charTypeName":"word"},{"id":58741,"position":13,"arabic":"عَمَّا","translation":"(তা) হ'তে যা","audioUrl":"wbw/028_068_015.mp3","charTypeName":"word"},{"id":58742,"position":14,"arabic":"يُشْرِكُونَ","translation":"তারা শরিক করছে","audioUrl":"wbw/028_068_016.mp3","charTypeName":"word"},{"id":58743,"position":15,"arabic":"٦٨","translation":"(৬৮)","audioUrl":null,"charTypeName":"end"}]},{"number":69,"arabic":"وَرَبُّكَ يَعْلَمُ مَا تُكِنُّ صُدُورُهُمْ وَمَا يُعْلِنُونَ","translation":"And thy Sustainer knows all that their hearts conceal as well as all that they bring into the open:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3321.mp3","surahId":28,"words":[{"id":59111,"position":1,"arabic":"وَرَبُّكَ","translation":"এবং তোমার রব","audioUrl":"wbw/028_069_001.mp3","charTypeName":"word"},{"id":59112,"position":2,"arabic":"يَعْلَمُ","translation":"জানেন","audioUrl":"wbw/028_069_002.mp3","charTypeName":"word"},{"id":59113,"position":3,"arabic":"مَا","translation":"যা কিছু","audioUrl":"wbw/028_069_003.mp3","charTypeName":"word"},{"id":59114,"position":4,"arabic":"تُكِنُّ","translation":"লুকিয়ে রাখে","audioUrl":"wbw/028_069_004.mp3","charTypeName":"word"},{"id":59115,"position":5,"arabic":"صُدُورُهُمْ","translation":"অন্তরসমূহ তাদের","audioUrl":"wbw/028_069_005.mp3","charTypeName":"word"},{"id":59116,"position":6,"arabic":"وَمَا","translation":"এবং যা কিছু","audioUrl":"wbw/028_069_006.mp3","charTypeName":"word"},{"id":59117,"position":7,"arabic":"يُعْلِنُونَ","translation":"তারা প্রকাশ করে","audioUrl":"wbw/028_069_007.mp3","charTypeName":"word"},{"id":59118,"position":8,"arabic":"٦٩","translation":"(৬৯)","audioUrl":null,"charTypeName":"end"}]},{"number":70,"arabic":"وَهُوَ ٱللَّهُ لَآ إِلَٰهَ إِلَّا هُوَ ۖ لَهُ ٱلْحَمْدُ فِى ٱلْأُولَىٰ وَٱلْءَاخِرَةِ ۖ وَلَهُ ٱلْحُكْمُ وَإِلَيْهِ تُرْجَعُونَ","translation":"for He is God, save whom there is no deity. Unto Him all praise is due, at the beginning and at the end [of time]; and with Him rests all judgment; and unto Him shall you all be brought back.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3322.mp3","surahId":28,"words":[{"id":59665,"position":1,"arabic":"وَهُوَ","translation":"এবং তিনিই","audioUrl":"wbw/028_070_001.mp3","charTypeName":"word"},{"id":59666,"position":2,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/028_070_002.mp3","charTypeName":"word"},{"id":59667,"position":3,"arabic":"لَآ","translation":"নেই","audioUrl":"wbw/028_070_003.mp3","charTypeName":"word"},{"id":59668,"position":4,"arabic":"إِلَـٰهَ","translation":"কোন ইলাহ","audioUrl":"wbw/028_070_004.mp3","charTypeName":"word"},{"id":59669,"position":5,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/028_070_005.mp3","charTypeName":"word"},{"id":59670,"position":6,"arabic":"هُوَ ۖ","translation":"তিনি","audioUrl":"wbw/028_070_006.mp3","charTypeName":"word"},{"id":59672,"position":7,"arabic":"لَهُ","translation":"জন্যে তাঁরই","audioUrl":"wbw/028_070_008.mp3","charTypeName":"word"},{"id":59673,"position":8,"arabic":"ٱلْحَمْدُ","translation":"সব প্রশংসা","audioUrl":"wbw/028_070_009.mp3","charTypeName":"word"},{"id":59674,"position":9,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/028_070_010.mp3","charTypeName":"word"},{"id":59675,"position":10,"arabic":"ٱلْأُولَىٰ","translation":"দুনিয়ার","audioUrl":"wbw/028_070_011.mp3","charTypeName":"word"},{"id":59676,"position":11,"arabic":"وَٱلْـَٔاخِرَةِ ۖ","translation":"ও আখেরাতে","audioUrl":"wbw/028_070_012.mp3","charTypeName":"word"},{"id":59678,"position":12,"arabic":"وَلَهُ","translation":"এবং জন্যে তাঁরই","audioUrl":"wbw/028_070_014.mp3","charTypeName":"word"},{"id":59679,"position":13,"arabic":"ٱلْحُكْمُ","translation":"বিধান","audioUrl":"wbw/028_070_015.mp3","charTypeName":"word"},{"id":59680,"position":14,"arabic":"وَإِلَيْهِ","translation":"এবং দিকে তাঁরই","audioUrl":"wbw/028_070_016.mp3","charTypeName":"word"},{"id":59681,"position":15,"arabic":"تُرْجَعُونَ","translation":"প্রত্যাবর্তিত হবে তোমরা","audioUrl":"wbw/028_070_017.mp3","charTypeName":"word"},{"id":59682,"position":16,"arabic":"٧٠","translation":"(৭০)","audioUrl":null,"charTypeName":"end"}]}]}