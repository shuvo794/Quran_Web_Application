{"id":248,"ayahs":[{"number":104,"arabic":"وَمَا تَسْـَٔلُهُمْ عَلَيْهِ مِنْ أَجْرٍ ۚ إِنْ هُوَ إِلَّا ذِكْرٌۭ لِّلْعَٰلَمِينَ","translation":"although thou dost not ask of them any reward for it: it is but [God's] reminder unto all mankind.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1700.mp3","surahId":12,"words":[{"id":72558,"position":1,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/012_104_001.mp3","charTypeName":"word"},{"id":72559,"position":2,"arabic":"تَسْـَٔلُهُمْ","translation":"তাদের কাছে তুমি চাচ্ছো","audioUrl":"wbw/012_104_002.mp3","charTypeName":"word"},{"id":72560,"position":3,"arabic":"عَلَيْهِ","translation":"এ জন্যে","audioUrl":"wbw/012_104_003.mp3","charTypeName":"word"},{"id":72561,"position":4,"arabic":"مِنْ","translation":"কোন","audioUrl":"wbw/012_104_004.mp3","charTypeName":"word"},{"id":72562,"position":5,"arabic":"أَجْرٍ ۚ","translation":"পারিশ্রমিক","audioUrl":"wbw/012_104_005.mp3","charTypeName":"word"},{"id":72564,"position":6,"arabic":"إِنْ","translation":"নয়","audioUrl":"wbw/012_104_007.mp3","charTypeName":"word"},{"id":72565,"position":7,"arabic":"هُوَ","translation":"তা","audioUrl":"wbw/012_104_008.mp3","charTypeName":"word"},{"id":72566,"position":8,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/012_104_009.mp3","charTypeName":"word"},{"id":72567,"position":9,"arabic":"ذِكْرٌۭ","translation":"উপদেশ","audioUrl":"wbw/012_104_010.mp3","charTypeName":"word"},{"id":72568,"position":10,"arabic":"لِّلْعَـٰلَمِينَ","translation":"বিশ্বজগতের জন্যে","audioUrl":"wbw/012_104_011.mp3","charTypeName":"word"},{"id":72569,"position":11,"arabic":"١٠٤","translation":"(১০৪)","audioUrl":null,"charTypeName":"end"}]},{"number":105,"arabic":"وَكَأَيِّن مِّنْ ءَايَةٍۢ فِى ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ يَمُرُّونَ عَلَيْهَا وَهُمْ عَنْهَا مُعْرِضُونَ","translation":"But [then] -how many a sign is there in the heavens and on earth which they pass by [unthinkingly], and on which they turn their backs!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1701.mp3","surahId":12,"words":[{"id":72800,"position":1,"arabic":"وَكَأَيِّن","translation":"এবং কতইনা","audioUrl":"wbw/012_105_001.mp3","charTypeName":"word"},{"id":72801,"position":2,"arabic":"مِّنْ","translation":"থেকে","audioUrl":"wbw/012_105_002.mp3","charTypeName":"word"},{"id":72802,"position":3,"arabic":"ءَايَةٍۢ","translation":"নিদর্শন (রয়েছে)","audioUrl":"wbw/012_105_003.mp3","charTypeName":"word"},{"id":72803,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/012_105_004.mp3","charTypeName":"word"},{"id":72804,"position":5,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশের","audioUrl":"wbw/012_105_005.mp3","charTypeName":"word"},{"id":72805,"position":6,"arabic":"وَٱلْأَرْضِ","translation":"এবং পৃথিবীর","audioUrl":"wbw/012_105_006.mp3","charTypeName":"word"},{"id":72806,"position":7,"arabic":"يَمُرُّونَ","translation":"তারা অতিক্রম করে","audioUrl":"wbw/012_105_007.mp3","charTypeName":"word"},{"id":72807,"position":8,"arabic":"عَلَيْهَا","translation":"তার উপর (দিয়ে)","audioUrl":"wbw/012_105_008.mp3","charTypeName":"word"},{"id":72808,"position":9,"arabic":"وَهُمْ","translation":"অথচ তারা","audioUrl":"wbw/012_105_009.mp3","charTypeName":"word"},{"id":72809,"position":10,"arabic":"عَنْهَا","translation":"তা থেকে","audioUrl":"wbw/012_105_010.mp3","charTypeName":"word"},{"id":72810,"position":11,"arabic":"مُعْرِضُونَ","translation":"উপেক্ষাকারী","audioUrl":"wbw/012_105_011.mp3","charTypeName":"word"},{"id":72811,"position":12,"arabic":"١٠٥","translation":"(১০৫)","audioUrl":null,"charTypeName":"end"}]},{"number":106,"arabic":"وَمَا يُؤْمِنُ أَكْثَرُهُم بِٱللَّهِ إِلَّا وَهُم مُّشْرِكُونَ","translation":"And most of them do not even believe in God without [also] ascribing divine powers to other beings beside Him.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1702.mp3","surahId":12,"words":[{"id":72933,"position":1,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/012_106_001.mp3","charTypeName":"word"},{"id":72934,"position":2,"arabic":"يُؤْمِنُ","translation":"বিশ্বাস করে","audioUrl":"wbw/012_106_002.mp3","charTypeName":"word"},{"id":72935,"position":3,"arabic":"أَكْثَرُهُم","translation":"তাদের অধিকাংশ","audioUrl":"wbw/012_106_003.mp3","charTypeName":"word"},{"id":72936,"position":4,"arabic":"بِٱللَّهِ","translation":"উপর আল্লাহর","audioUrl":"wbw/012_106_004.mp3","charTypeName":"word"},{"id":72937,"position":5,"arabic":"إِلَّا","translation":"ছাড়া যে","audioUrl":"wbw/012_106_005.mp3","charTypeName":"word"},{"id":72938,"position":6,"arabic":"وَهُم","translation":"তখন তারা (বিশ্বাস করলেও)","audioUrl":"wbw/012_106_006.mp3","charTypeName":"word"},{"id":72939,"position":7,"arabic":"مُّشْرِكُونَ","translation":"শিরক করে","audioUrl":"wbw/012_106_007.mp3","charTypeName":"word"},{"id":72940,"position":8,"arabic":"١٠٦","translation":"(১০৬)","audioUrl":null,"charTypeName":"end"}]},{"number":107,"arabic":"أَفَأَمِنُوٓا۟ أَن تَأْتِيَهُمْ غَٰشِيَةٌۭ مِّنْ عَذَابِ ٱللَّهِ أَوْ تَأْتِيَهُمُ ٱلسَّاعَةُ بَغْتَةًۭ وَهُمْ لَا يَشْعُرُونَ","translation":"Do they, then, feel free from the fear that there might fall upon them the overwhelming terror of God's chastisement, or that the Last Hour might come upon them of a sudden, without their being aware [of its approach]?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1703.mp3","surahId":12,"words":[{"id":73321,"position":1,"arabic":"أَفَأَمِنُوٓا۟","translation":"তবে কি তারা নিরাপদ হয়েছে","audioUrl":"wbw/012_107_001.mp3","charTypeName":"word"},{"id":73322,"position":2,"arabic":"أَن","translation":"যে","audioUrl":"wbw/012_107_002.mp3","charTypeName":"word"},{"id":73323,"position":3,"arabic":"تَأْتِيَهُمْ","translation":"তাদের উপর আসবে","audioUrl":"wbw/012_107_003.mp3","charTypeName":"word"},{"id":73324,"position":4,"arabic":"غَـٰشِيَةٌۭ","translation":"আচ্ছন্নকারী","audioUrl":"wbw/012_107_004.mp3","charTypeName":"word"},{"id":73325,"position":5,"arabic":"مِّنْ","translation":"কোন","audioUrl":"wbw/012_107_005.mp3","charTypeName":"word"},{"id":73326,"position":6,"arabic":"عَذَابِ","translation":"শাস্তি","audioUrl":"wbw/012_107_006.mp3","charTypeName":"word"},{"id":73327,"position":7,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌র","audioUrl":"wbw/012_107_007.mp3","charTypeName":"word"},{"id":73328,"position":8,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/012_107_008.mp3","charTypeName":"word"},{"id":73329,"position":9,"arabic":"تَأْتِيَهُمُ","translation":"তাদের উপর আসবে","audioUrl":"wbw/012_107_009.mp3","charTypeName":"word"},{"id":73330,"position":10,"arabic":"ٱلسَّاعَةُ","translation":"ক্বিয়ামাত","audioUrl":"wbw/012_107_010.mp3","charTypeName":"word"},{"id":73331,"position":11,"arabic":"بَغْتَةًۭ","translation":"হঠাৎ করে","audioUrl":"wbw/012_107_011.mp3","charTypeName":"word"},{"id":73332,"position":12,"arabic":"وَهُمْ","translation":"এমতাবস্হায় যে তারা","audioUrl":"wbw/012_107_012.mp3","charTypeName":"word"},{"id":73333,"position":13,"arabic":"لَا","translation":"না","audioUrl":"wbw/012_107_013.mp3","charTypeName":"word"},{"id":73334,"position":14,"arabic":"يَشْعُرُونَ","translation":"টেরও পাবে","audioUrl":"wbw/012_107_014.mp3","charTypeName":"word"},{"id":73335,"position":15,"arabic":"١٠٧","translation":"(১০৭)","audioUrl":null,"charTypeName":"end"}]},{"number":108,"arabic":"قُلْ هَٰذِهِۦ سَبِيلِىٓ أَدْعُوٓا۟ إِلَى ٱللَّهِ ۚ عَلَىٰ بَصِيرَةٍ أَنَا۠ وَمَنِ ٱتَّبَعَنِى ۖ وَسُبْحَٰنَ ٱللَّهِ وَمَآ أَنَا۠ مِنَ ٱلْمُشْرِكِينَ","translation":"Say [O Prophet]: \"This is my way: Resting upon conscious insight accessible to reason, I am calling [you all] unto God - I and they who follow me.\" And [say:] \"Limitless is God in His glory; and I am not one of those who ascribe divinity to aught beside Him!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1704.mp3","surahId":12,"words":[{"id":73535,"position":1,"arabic":"قُلْ","translation":"(হে নাবী) বলো","audioUrl":"wbw/012_108_001.mp3","charTypeName":"word"},{"id":73536,"position":2,"arabic":"هَـٰذِهِۦ","translation":"\"এই","audioUrl":"wbw/012_108_002.mp3","charTypeName":"word"},{"id":73537,"position":3,"arabic":"سَبِيلِىٓ","translation":"আমার পথ","audioUrl":"wbw/012_108_003.mp3","charTypeName":"word"},{"id":73538,"position":4,"arabic":"أَدْعُوٓا۟","translation":"ডাকি আমি","audioUrl":"wbw/012_108_004.mp3","charTypeName":"word"},{"id":73539,"position":5,"arabic":"إِلَى","translation":"দিকে","audioUrl":"wbw/012_108_005.mp3","charTypeName":"word"},{"id":73540,"position":6,"arabic":"ٱللَّهِ ۚ","translation":"আল্লাহ্‌র","audioUrl":"wbw/012_108_006.mp3","charTypeName":"word"},{"id":73542,"position":7,"arabic":"عَلَىٰ","translation":"ভিত্তিতে","audioUrl":"wbw/012_108_008.mp3","charTypeName":"word"},{"id":73543,"position":8,"arabic":"بَصِيرَةٍ","translation":"জ্ঞানের","audioUrl":"wbw/012_108_009.mp3","charTypeName":"word"},{"id":73544,"position":9,"arabic":"أَنَا۠","translation":"আমি","audioUrl":"wbw/012_108_010.mp3","charTypeName":"word"},{"id":73545,"position":10,"arabic":"وَمَنِ","translation":"এবং যে","audioUrl":"wbw/012_108_011.mp3","charTypeName":"word"},{"id":73546,"position":11,"arabic":"ٱتَّبَعَنِى ۖ","translation":"আমার অনুসরণ করে","audioUrl":"wbw/012_108_012.mp3","charTypeName":"word"},{"id":73548,"position":12,"arabic":"وَسُبْحَـٰنَ","translation":"এবং মহান পবিত্র","audioUrl":"wbw/012_108_014.mp3","charTypeName":"word"},{"id":73549,"position":13,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌","audioUrl":"wbw/012_108_015.mp3","charTypeName":"word"},{"id":73550,"position":14,"arabic":"وَمَآ","translation":"এবং নই","audioUrl":"wbw/012_108_016.mp3","charTypeName":"word"},{"id":73551,"position":15,"arabic":"أَنَا۠","translation":"আমি","audioUrl":"wbw/012_108_017.mp3","charTypeName":"word"},{"id":73552,"position":16,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/012_108_018.mp3","charTypeName":"word"},{"id":73553,"position":17,"arabic":"ٱلْمُشْرِكِينَ","translation":"মুশরিকদের\"","audioUrl":"wbw/012_108_019.mp3","charTypeName":"word"},{"id":73554,"position":18,"arabic":"١٠٨","translation":"(১০৮)","audioUrl":null,"charTypeName":"end"}]},{"number":109,"arabic":"وَمَآ أَرْسَلْنَا مِن قَبْلِكَ إِلَّا رِجَالًۭا نُّوحِىٓ إِلَيْهِم مِّنْ أَهْلِ ٱلْقُرَىٰٓ ۗ أَفَلَمْ يَسِيرُوا۟ فِى ٱلْأَرْضِ فَيَنظُرُوا۟ كَيْفَ كَانَ عَٰقِبَةُ ٱلَّذِينَ مِن قَبْلِهِمْ ۗ وَلَدَارُ ٱلْءَاخِرَةِ خَيْرٌۭ لِّلَّذِينَ ٱتَّقَوْا۟ ۗ أَفَلَا تَعْقِلُونَ","translation":"And [even] before thy time, We never sent [as Our apostles] any but [mortal] men, whom We inspired, [and whom We always chose] from among the people of the [very] communities [to whom the message was to be brought]. Have, then, they [who reject this divine writ] never journeyed about the earth and beheld what happened in the end to those [deniers of the truth] who lived before them?-and [do they not know that] to those who are conscious of God the life in the hereafter is indeed better [than this world]? Will they not, then, use their reason?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1705.mp3","surahId":12,"words":[{"id":73812,"position":1,"arabic":"وَمَآ","translation":"এবং না","audioUrl":"wbw/012_109_001.mp3","charTypeName":"word"},{"id":73813,"position":2,"arabic":"أَرْسَلْنَا","translation":"আমরা পাঠিয়েছি","audioUrl":"wbw/012_109_002.mp3","charTypeName":"word"},{"id":73814,"position":3,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/012_109_003.mp3","charTypeName":"word"},{"id":73815,"position":4,"arabic":"قَبْلِكَ","translation":"আগে তোমার (রাসূলদেরকে)","audioUrl":"wbw/012_109_004.mp3","charTypeName":"word"},{"id":73816,"position":5,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/012_109_005.mp3","charTypeName":"word"},{"id":73817,"position":6,"arabic":"رِجَالًۭا","translation":"পুরুষদেরকে","audioUrl":"wbw/012_109_006.mp3","charTypeName":"word"},{"id":73818,"position":7,"arabic":"نُّوحِىٓ","translation":"আমরা ওহী করেছি","audioUrl":"wbw/012_109_007.mp3","charTypeName":"word"},{"id":73819,"position":8,"arabic":"إِلَيْهِم","translation":"তাদ