{"id":555,"ayahs":[{"number":5,"arabic":"وَإِذَا قِيلَ لَهُمْ تَعَالَوْا۟ يَسْتَغْفِرْ لَكُمْ رَسُولُ ٱللَّهِ لَوَّوْا۟ رُءُوسَهُمْ وَرَأَيْتَهُمْ يَصُدُّونَ وَهُم مُّسْتَكْبِرُونَ","translation":"for, when they are told, \"Come, the Apostle of God will pray [unto God] that you be forgiven\", they turn their heads away, and thou canst see how they draw back in their false pride.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5193.mp3","surahId":63,"words":[{"id":5096,"position":1,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/063_005_001.mp3","charTypeName":"word"},{"id":5097,"position":2,"arabic":"قِيلَ","translation":"বলা হয়","audioUrl":"wbw/063_005_002.mp3","charTypeName":"word"},{"id":5098,"position":3,"arabic":"لَهُمْ","translation":"তাদেরকে","audioUrl":"wbw/063_005_003.mp3","charTypeName":"word"},{"id":5099,"position":4,"arabic":"تَعَالَوْا۟","translation":"\"তোমরা আসো","audioUrl":"wbw/063_005_004.mp3","charTypeName":"word"},{"id":5100,"position":5,"arabic":"يَسْتَغْفِرْ","translation":"ক্ষমা প্রার্থনা করবেন","audioUrl":"wbw/063_005_005.mp3","charTypeName":"word"},{"id":5101,"position":6,"arabic":"لَكُمْ","translation":"তোমাদের জন্যে","audioUrl":"wbw/063_005_006.mp3","charTypeName":"word"},{"id":5102,"position":7,"arabic":"رَسُولُ","translation":"রাসূূল\"","audioUrl":"wbw/063_005_007.mp3","charTypeName":"word"},{"id":5103,"position":8,"arabic":"ٱللَّهِ","translation":"আল্লাহর\"","audioUrl":"wbw/063_005_008.mp3","charTypeName":"word"},{"id":5104,"position":9,"arabic":"لَوَّوْا۟","translation":"তারা ফিরিয়ে নেয়","audioUrl":"wbw/063_005_009.mp3","charTypeName":"word"},{"id":5105,"position":10,"arabic":"رُءُوسَهُمْ","translation":"তাদের মাথাগুলো","audioUrl":"wbw/063_005_010.mp3","charTypeName":"word"},{"id":5106,"position":11,"arabic":"وَرَأَيْتَهُمْ","translation":"এবং তুমি তাদের দেখো","audioUrl":"wbw/063_005_011.mp3","charTypeName":"word"},{"id":5107,"position":12,"arabic":"يَصُدُّونَ","translation":"বিরত থাকে (আসা থেকে)","audioUrl":"wbw/063_005_012.mp3","charTypeName":"word"},{"id":5108,"position":13,"arabic":"وَهُم","translation":"এবং তারা","audioUrl":"wbw/063_005_013.mp3","charTypeName":"word"},{"id":5109,"position":14,"arabic":"مُّسْتَكْبِرُونَ","translation":"অহংকারী","audioUrl":"wbw/063_005_014.mp3","charTypeName":"word"},{"id":5110,"position":15,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"سَوَآءٌ عَلَيْهِمْ أَسْتَغْفَرْتَ لَهُمْ أَمْ لَمْ تَسْتَغْفِرْ لَهُمْ لَن يَغْفِرَ ٱللَّهُ لَهُمْ ۚ إِنَّ ٱللَّهَ لَا يَهْدِى ٱلْقَوْمَ ٱلْفَٰسِقِينَ","translation":"As for them it is all the same whether thou dost pray that they be forgiven or dost not pray for them: God will nor forgive them - for, behold, God does not bestow His guidance upon such iniquitous folk.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5194.mp3","surahId":63,"words":[{"id":6353,"position":1,"arabic":"سَوَآءٌ","translation":"সমান","audioUrl":"wbw/063_006_001.mp3","charTypeName":"word"},{"id":6354,"position":2,"arabic":"عَلَيْهِمْ","translation":"তাদের জন্যে","audioUrl":"wbw/063_006_002.mp3","charTypeName":"word"},{"id":6355,"position":3,"arabic":"أَسْتَغْفَرْتَ","translation":"তুমি ক্ষমা প্রার্থনা কর","audioUrl":"wbw/063_006_003.mp3","charTypeName":"word"},{"id":6356,"position":4,"arabic":"لَهُمْ","translation":"তাদের জন্য","audioUrl":"wbw/063_006_004.mp3","charTypeName":"word"},{"id":6357,"position":5,"arabic":"أَمْ","translation":"অথবা","audioUrl":"wbw/063_006_005.mp3","charTypeName":"word"},{"id":6358,"position":6,"arabic":"لَمْ","translation":"প্রার্থনা নাই করো","audioUrl":"wbw/063_006_006.mp3","charTypeName":"word"},{"id":6359,"position":7,"arabic":"تَسْتَغْفِرْ","translation":"তুমি ক্ষমা","audioUrl":"wbw/063_006_007.mp3","charTypeName":"word"},{"id":6360,"position":8,"arabic":"لَهُمْ","translation":"তাদের জন্যে","audioUrl":"wbw/063_006_008.mp3","charTypeName":"word"},{"id":6361,"position":9,"arabic":"لَن","translation":"কক্ষনো না","audioUrl":"wbw/063_006_009.mp3","charTypeName":"word"},{"id":6362,"position":10,"arabic":"يَغْفِرَ","translation":"ক্ষমা করবেন","audioUrl":"wbw/063_006_010.mp3","charTypeName":"word"},{"id":6363,"position":11,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/063_006_011.mp3","charTypeName":"word"},{"id":6364,"position":12,"arabic":"لَهُمْ ۚ","translation":"তাদেরকে","audioUrl":"wbw/063_006_012.mp3","charTypeName":"word"},{"id":6366,"position":13,"arabic":"إِنَّ","translation":"নিশ্চয়","audioUrl":"wbw/063_006_014.mp3","charTypeName":"word"},{"id":6367,"position":14,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/063_006_015.mp3","charTypeName":"word"},{"id":6368,"position":15,"arabic":"لَا","translation":"না","audioUrl":"wbw/063_006_016.mp3","charTypeName":"word"},{"id":6369,"position":16,"arabic":"يَهْدِى","translation":"পথ দেখান","audioUrl":"wbw/063_006_017.mp3","charTypeName":"word"},{"id":6370,"position":17,"arabic":"ٱلْقَوْمَ","translation":"লোকদের","audioUrl":"wbw/063_006_018.mp3","charTypeName":"word"},{"id":6371,"position":18,"arabic":"ٱلْفَـٰسِقِينَ","translation":"ফাসেক","audioUrl":"wbw/063_006_019.mp3","charTypeName":"word"},{"id":6372,"position":19,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"هُمُ ٱلَّذِينَ يَقُولُونَ لَا تُنفِقُوا۟ عَلَىٰ مَنْ عِندَ رَسُولِ ٱللَّهِ حَتَّىٰ يَنفَضُّوا۟ ۗ وَلِلَّهِ خَزَآئِنُ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ وَلَٰكِنَّ ٱلْمُنَٰفِقِينَ لَا يَفْقَهُونَ","translation":"It is they who say [to their compatriots], \"Do not spend anything on those who are with God's Apostle, so that they [may be forced to] leave.\" However, unto God belong the treasures of the heavens and the earth: but this truth the hypocrites cannot grasp.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5195.mp3","surahId":63,"words":[{"id":7769,"position":1,"arabic":"هُمُ","translation":"তারা (ঐ লোক)","audioUrl":"wbw/063_007_001.mp3","charTypeName":"word"},{"id":7770,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/063_007_002.mp3","charTypeName":"word"},{"id":7771,"position":3,"arabic":"يَقُولُونَ","translation":"বলে","audioUrl":"wbw/063_007_003.mp3","charTypeName":"word"},{"id":7772,"position":4,"arabic":"لَا","translation":"\"না","audioUrl":"wbw/063_007_004.mp3","charTypeName":"word"},{"id":7773,"position":5,"arabic":"تُنفِقُوا۟","translation":"তোমরা খরচ করো","audioUrl":"wbw/063_007_005.mp3","charTypeName":"word"},{"id":7774,"position":6,"arabic":"عَلَىٰ","translation":"(তাদের) জন্য","audioUrl":"wbw/063_007_006.mp3","charTypeName":"word"},{"id":7775,"position":7,"arabic":"مَنْ","translation":"যারা (আছে)","audioUrl":"wbw/063_007_007.mp3","charTypeName":"word"},{"id":7776,"position":8,"arabic":"عِندَ","translation":"কাছে","audioUrl":"wbw/063_007_008.mp3","charTypeName":"word"},{"id":7777,"position":9,"arabic":"رَسُولِ","translation":"রাসূলের","audioUrl":"wbw/063_007_009.mp3","charTypeName":"word"},{"id":7778,"position":10,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/063_007_010.mp3","charTypeName":"word"},{"id":7779,"position":11,"arabic":"حَتَّىٰ","translation":"যতক্ষণ না","audioUrl":"wbw/063_007_011.mp3","charTypeName":"word"},{"id":7780,"position":12,"arabic":"يَنفَضُّوا۟ ۗ","translation":"তারা ছিন্নভিন্ন হয়ে যায়\"","audioUrl":"wbw/063_007_012.mp3","charTypeName":"word"},{"id":7782,"position":13,"arabic":"وَلِلَّهِ","translation":"অথচ আল্লাহরই","audioUrl":"wbw/063_007_014.mp3","charTypeName":"word"},{"id":7783,"position":14,"arabic":"خَزَآئِنُ","translation":"ধনভাণ্ডারসমূহ","audioUrl":"wbw/063_007_015.mp3","charTypeName":"word"},{"id":7784,"position":15,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আসমানসমূহের","audioUrl":"wbw/063_007_016.mp3","charTypeName":"word"},{"id":7785,"position":16,"arabic":"وَٱلْأَرْضِ","translation":"ও যমীনের","audioUrl":"wbw/063_007_017.mp3","charTypeName":"word"},{"id":7786,"position":17,"arabic":"وَلَـٰكِنَّ","translation":"কিন্তু","audioUrl":"wbw/063_007_018.mp3","charTypeName":"word"},{"id":7787,"position":18,"arabic":"ٱلْمُنَـٰفِقِينَ","translation":"মুনাফিকরা","audioUrl":"wbw/063_007_019.mp3","charTypeName":"word"},{"id":7788,"position":19,"arabic":"لَا","translation":"না","audioUrl":"wbw/063_007_020.mp3","charTypeName":"word"},{"id":7789,"position":20,"arabic":"يَفْقَهُونَ","translation":"তারা বুঝে","audioUrl":"wbw/063_007_021.mp3","charTypeName":"word"},{"id":7790,"position":21,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"يَقُولُونَ لَئِن رَّجَعْنَآ إِلَى ٱلْمَدِينَةِ لَيُخْرِجَنَّ ٱلْأَعَزُّ مِنْهَا ٱلْأَذَلَّ ۚ وَلِلَّهِ ٱلْعِزَّةُ وَلِرَسُولِهِۦ وَلِلْمُؤْمِنِينَ وَلَٰكِنَّ ٱلْمُنَٰفِقِينَ لَا يَعْلَمُونَ","translation":"[And] they say, \"Indeed, when we return to the City [we,] the ones most worthy of honour will surely drive out therefrom those most contemptible ones!\" However, all honour belongs to God, and [thus] to His Apostle and those who believe [in God]: but of this the hypocrites are not aware.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5196.mp3","surahId":63,"words":[{"id":8940,"position":1,"arabic":"يَقُولُونَ","translation":"তারা বলে","audioUrl":"wbw/063_008_001.mp3","charTypeName":"word"},{"id":8941,"position":2,"arabic":"لَئِن","translation":"\"অবশ্যই যদি","audioUrl":"wbw/063_008_002.mp3","charTypeName":"word"},{"id":8942,"position":3,"arabic":"رَّجَعْنَآ","translation":"আমরা ফিরে যেতে পারি","audioUrl":"wbw/063_008_003.mp3","charTypeName":"word"},{"id":8943,"position":4,"arabic":"إِلَى","translation":"দিকে","audioUrl":"wbw/063_008_004.mp3","charTypeName":"word"},{"id":8944,"position":5,"arabic":"ٱلْمَدِينَةِ","translation":"মদীনার","audioUrl":"wbw/063_008_005.mp3","charTypeName":"word"},{"id":8945,"position":6,"arabic":"لَيُخْرِجَنَّ","translation":"বহিস্কার করবেই","audioUrl":"wbw/063_008_006.mp3","charTypeName":"word"},{"id":8946,"position":7,"arabic":"ٱلْأَعَزُّ","translation":"অধিক সম্মানিত","audioUrl":"wbw/063_008_007.mp3","charTypeName":"word"},{"id":8947,"position":8,"arabic":"مِنْهَا","translation":"তা থেকে","audioUrl":"wbw/063_008_008.mp3","charTypeName":"word"},{"id":8948,"position":9,"arabic":"ٱلْأَذَلَّ ۚ","translation":"হীনতরকে\"","audioUrl":"wbw/063_008_009.mp3","charTypeName":"word"},{"id":8950,"position":10,"arabic":"وَلِلَّهِ","translation":"অথচ আল্লাহরই জন্যে","audioUrl":"wbw/063_008_011.mp3","charTypeName":"word"},{"id":8951,"position":11,"arabic":"ٱلْعِزَّةُ","translation":"সম্মান","audioUrl":"wbw/063_008_012.mp3","charTypeName":"word"},{"id":8952,"position":12,"arabic":"وَلِرَسُولِهِۦ","translation":"ও তাঁর রাসূলের","audioUrl":"wbw/063_008_013.mp3","charTypeName":"word"},{"id":8953,"position":13,"arabic":"وَلِلْمُؤْمِنِينَ","translation":"ও মু'মিনদের","audioUrl":"wbw/063_008_014.mp3","charTypeName":"word"},{"id":8954,"position":14,"arabic":"وَلَـٰكِنَّ","translation":"কিন্তু","audioUrl":"wbw/063_008_015.mp3","charTypeName":"word"},{"id":8955,"position":15,"arabic":"ٱلْمُنَـٰفِقِينَ","translation":"মুনাফিকরা","audioUrl":"wbw/063_008_016.mp3","charTypeName":"word"},{"id":8956,"position":16,"arabic":"لَا","translation":"না","audioUrl":"wbw/063_008_017.mp3","charTypeName":"word"},{"id":8957,"position":17,"arabic":"يَعْلَمُونَ","translation":"তারা জানে","audioUrl":"wbw/063_008_018.mp3","charTypeName":"word"},{"id":8958,"position":18,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ لَا تُلْهِكُمْ أَمْوَٰلُكُمْ وَلَآ أَوْلَٰدُكُمْ عَن ذِكْرِ ٱللَّهِ ۚ وَمَن يَفْعَلْ ذَٰلِكَ فَأُو۟لَٰٓئِكَ هُمُ ٱلْخَٰسِرُونَ","translation":"O YOU who have attained to faith! Let not your worldly goods or your children make you oblivious of the remembrance of God: for If any behave thus - it is they, they who are the losers!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5197.mp3","surahId":63,"words":[{"id":10163,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"ওহে","audioUrl":"wbw/063_009_001.mp3","charTypeName":"word"},{"id":10164,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/063_009_002.mp3","charTypeName":"word"},{"id":10165,"position":3,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছো","audioUrl":"wbw/063_009_003.mp3","charTypeName":"word"},{"id":10166,"position":4,"arabic":"لَا","translation":"না","audioUrl":"wbw/063_009_004.mp3","charTypeName":"word"},{"id":10167,"position":5,"arabic":"تُلْهِكُمْ","translation":"তোমাদের (যেন) গাফিল করে","audioUrl":"wbw/063_009_005.mp3","charTypeName":"word"},{"id":10168,"position":6,"arabic":"أَمْوَٰلُكُمْ","translation":"তোমাদের সম্পদগুলো","audioUrl":"wbw/063_009_006.mp3","charTypeName":"word"},{"id":10169,"position":7,"arabic":"وَلَآ","translation":"ও না","audioUrl":"wbw/063_009_007.mp3","charTypeName":"word"},{"id":10170,"position":8,"arabic":"أَوْلَـٰدُكُمْ","translation":"তোমাদের সন্তানরা","audioUrl":"wbw/063_009_008.mp3","charTypeName":"word"},{"id":10171,"position":9,"arabic":"عَن","translation":"থেকে","audioUrl":"wbw/063_009_009.mp3","charTypeName":"word"},{"id":10172,"position":10,"arabic":"ذِكْرِ","translation":"স্মরণ","audioUrl":"wbw/063_009_010.mp3","charTypeName":"word"},{"id":10173,"position":11,"arabic":"ٱللَّهِ ۚ","translation":"আল্লাহর","audioUrl":"wbw/063_009_011.mp3","charTypeName":"word"},{"id":10175,"position":12,"arabic":"وَمَن","translation":"এবং যে","audioUrl":"wbw/063_009_013.mp3","charTypeName":"word"},{"id":10176,"position":13,"arabic":"يَفْعَلْ","translation":"করবে","audioUrl":"wbw/063_009_014.mp3","charTypeName":"word"},{"id":10177,"position":14,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/063_009_015.mp3","charTypeName":"word"},{"id":10178,"position":15,"arabic":"فَأُو۟لَـٰٓئِكَ","translation":"অতঃপর ঐসব লোক","audioUrl":"wbw/063_009_016.mp3","charTypeName":"word"},{"id":10179,"position":16,"arabic":"هُمُ","translation":"তারাই","audioUrl":"wbw/063_009_017.mp3","charTypeName":"word"},{"id":10180,"position":17,"arabic":"ٱلْخَـٰسِرُونَ","translation":"ক্ষতিগ্রস্ত","audioUrl":"wbw/063_009_018.mp3","charTypeName":"word"},{"id":10181,"position":18,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"وَأَنفِقُوا۟ مِن مَّا رَزَقْنَٰكُم مِّن قَبْلِ أَن يَأْتِىَ أَحَدَكُمُ ٱلْمَوْتُ فَيَقُولَ رَبِّ لَوْلَآ أَخَّرْتَنِىٓ إِلَىٰٓ أَجَلٍۢ قَرِيبٍۢ فَأَصَّدَّقَ وَأَكُن مِّنَ ٱلصَّٰلِحِينَ","translation":"And spend on others out of what We have provided for you as sustenance, ere there come a time when death approaches any of you, and he then says, \"O my Sustainer! If only Thou wouldst grant me a delay for a short while, so that I could give in charity and be among the righteous!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5198.mp3","surahId":63,"words":[{"id":11404,"position":1,"arabic":"وَأَنفِقُوا۟","translation":"এবং তোমরা খরচ করো","audioUrl":"wbw/063_010_001.mp3","charTypeName":"word"},{"id":11405,"position":2,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/063_010_002.mp3","charTypeName":"word"},{"id":11406,"position":3,"arabic":"مَّا","translation":"তা (যা)","audioUrl":"wbw/063_010_003.mp3","charTypeName":"word"},{"id":11407,"position":4,"arabic":"رَزَقْنَـٰكُم","translation":"তোমাদের আমরা রিজিক দিয়েছি","audioUrl":"wbw/063_010_004.mp3","charTypeName":"word"},{"id":11408,"position":5,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/063_010_005.mp3","charTypeName":"word"},{"id":11409,"position":6,"arabic":"قَبْلِ","translation":"পূর্বে","audioUrl":"wbw/063_010_006.mp3","charTypeName":"word"},{"id":11410,"position":7,"arabic":"أَن","translation":"যে","audioUrl":"wbw/063_010_007.mp3","charTypeName":"word"},{"id":11411,"position":8,"arabic":"يَأْتِىَ","translation":"আসে","audioUrl":"wbw/063_010_008.mp3","charTypeName":"word"},{"id":11412,"position":9,"arabic":"أَحَدَكُمُ","translation":"তোমাদের কারও","audioUrl":"wbw/063_010_009.mp3","charTypeName":"word"},{"id":11413,"position":10,"arabic":"ٱلْمَوْتُ","translation":"মৃত্যু","audioUrl":"wbw/063_010_010.mp3","charTypeName":"word"},{"i