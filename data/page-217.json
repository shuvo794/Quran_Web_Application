{"id":217,"ayahs":[{"number":71,"arabic":"۞ وَٱتْلُ عَلَيْهِمْ نَبَأَ نُوحٍ إِذْ قَالَ لِقَوْمِهِۦ يَٰقَوْمِ إِن كَانَ كَبُرَ عَلَيْكُم مَّقَامِى وَتَذْكِيرِى بِـَٔايَٰتِ ٱللَّهِ فَعَلَى ٱللَّهِ تَوَكَّلْتُ فَأَجْمِعُوٓا۟ أَمْرَكُمْ وَشُرَكَآءَكُمْ ثُمَّ لَا يَكُنْ أَمْرُكُمْ عَلَيْكُمْ غُمَّةًۭ ثُمَّ ٱقْضُوٓا۟ إِلَىَّ وَلَا تُنظِرُونِ","translation":"AND CONVEY unto them the story of Noah-when he said unto his people: \"O my people! If my presence [among you] and my announcement of God's messages are repugnant to you -well, in God have I placed my trust. Decide, then, upon what you are going to do [against me], and [call to your aid] those beings to whom you ascribe a share in God's divinity; and once you have chosen your course of action, let no hesitation deflect you from it; and then carry out against me [whatever you may have decided], and give me no respite!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1435.mp3","surahId":10,"words":[{"id":60116,"position":1,"arabic":"۞ وَٱتْلُ","translation":"এবং তিলাওয়াত করো","audioUrl":"wbw/010_071_002.mp3","charTypeName":"word"},{"id":60117,"position":2,"arabic":"عَلَيْهِمْ","translation":"কাছে তাদের","audioUrl":"wbw/010_071_003.mp3","charTypeName":"word"},{"id":60118,"position":3,"arabic":"نَبَأَ","translation":"সংবাদ","audioUrl":"wbw/010_071_004.mp3","charTypeName":"word"},{"id":60119,"position":4,"arabic":"نُوحٍ","translation":"নূহের","audioUrl":"wbw/010_071_005.mp3","charTypeName":"word"},{"id":60120,"position":5,"arabic":"إِذْ","translation":"(সেই সময়ের) যখন","audioUrl":"wbw/010_071_006.mp3","charTypeName":"word"},{"id":60121,"position":6,"arabic":"قَالَ","translation":"সে বলেছিলো","audioUrl":"wbw/010_071_007.mp3","charTypeName":"word"},{"id":60122,"position":7,"arabic":"لِقَوْمِهِۦ","translation":"উদ্দেশ্যে তার জাতির","audioUrl":"wbw/010_071_008.mp3","charTypeName":"word"},{"id":60123,"position":8,"arabic":"يَـٰقَوْمِ","translation":"\"হে আমার জাতি","audioUrl":"wbw/010_071_009.mp3","charTypeName":"word"},{"id":60124,"position":9,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/010_071_010.mp3","charTypeName":"word"},{"id":60125,"position":10,"arabic":"كَانَ","translation":"হয়","audioUrl":"wbw/010_071_011.mp3","charTypeName":"word"},{"id":60126,"position":11,"arabic":"كَبُرَ","translation":"দুঃসহ","audioUrl":"wbw/010_071_012.mp3","charTypeName":"word"},{"id":60127,"position":12,"arabic":"عَلَيْكُم","translation":"উপর তোমাদের","audioUrl":"wbw/010_071_013.mp3","charTypeName":"word"},{"id":60128,"position":13,"arabic":"مَّقَامِى","translation":"আমার অবস্থান","audioUrl":"wbw/010_071_014.mp3","charTypeName":"word"},{"id":60129,"position":14,"arabic":"وَتَذْكِيرِى","translation":"ও আমার উপদেশ","audioUrl":"wbw/010_071_015.mp3","charTypeName":"word"},{"id":60130,"position":15,"arabic":"بِـَٔايَـٰتِ","translation":"দ্বারা নিদর্শনাবলী","audioUrl":"wbw/010_071_016.mp3","charTypeName":"word"},{"id":60131,"position":16,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/010_071_017.mp3","charTypeName":"word"},{"id":60132,"position":17,"arabic":"فَعَلَى","translation":"তবে উপর","audioUrl":"wbw/010_071_018.mp3","charTypeName":"word"},{"id":60133,"position":18,"arabic":"ٱللَّهِ","translation":"আল্লাহরই","audioUrl":"wbw/010_071_019.mp3","charTypeName":"word"},{"id":60134,"position":19,"arabic":"تَوَكَّلْتُ","translation":"আমি নির্ভর করছি","audioUrl":"wbw/010_071_020.mp3","charTypeName":"word"},{"id":60135,"position":20,"arabic":"فَأَجْمِعُوٓا۟","translation":"সুতরাং তোমরা সমবেত (হয়ে সম্পন্ন) করো","audioUrl":"wbw/010_071_021.mp3","charTypeName":"word"},{"id":60136,"position":21,"arabic":"أَمْرَكُمْ","translation":"(করণীয়)কর্তব্য তোমাদের","audioUrl":"wbw/010_071_022.mp3","charTypeName":"word"},{"id":60137,"position":22,"arabic":"وَشُرَكَآءَكُمْ","translation":"ও শরীকদেরকেও তোমাদের  (সমবেত করো)","audioUrl":"wbw/010_071_023.mp3","charTypeName":"word"},{"id":60138,"position":23,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/010_071_024.mp3","charTypeName":"word"},{"id":60139,"position":24,"arabic":"لَا","translation":"না","audioUrl":"wbw/010_071_025.mp3","charTypeName":"word"},{"id":60140,"position":25,"arabic":"يَكُنْ","translation":"হয় (যেন)","audioUrl":"wbw/010_071_026.mp3","charTypeName":"word"},{"id":60141,"position":26,"arabic":"أَمْرُكُمْ","translation":"কর্তব্য তোমাদের","audioUrl":"wbw/010_071_027.mp3","charTypeName":"word"},{"id":60142,"position":27,"arabic":"عَلَيْكُمْ","translation":"কাছে তোমাদের","audioUrl":"wbw/010_071_028.mp3","charTypeName":"word"},{"id":60143,"position":28,"arabic":"غُمَّةًۭ","translation":"সংশয়পূর্ণ","audioUrl":"wbw/010_071_029.mp3","charTypeName":"word"},{"id":60144,"position":29,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/010_071_030.mp3","charTypeName":"word"},{"id":60145,"position":30,"arabic":"ٱقْضُوٓا۟","translation":"তোমরা সিদ্ধান্ত  নিষ্পন্ন করো","audioUrl":"wbw/010_071_031.mp3","charTypeName":"word"},{"id":60146,"position":31,"arabic":"إِلَىَّ","translation":"আমার প্রতি","audioUrl":"wbw/010_071_032.mp3","charTypeName":"word"},{"id":60147,"position":32,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/010_071_033.mp3","charTypeName":"word"},{"id":60148,"position":33,"arabic":"تُنظِرُونِ","translation":"আমাকে তোমরা অবকাশ দিও","audioUrl":"wbw/010_071_034.mp3","charTypeName":"word"},{"id":60149,"position":34,"arabic":"٧١","translation":"(৭১)","audioUrl":null,"charTypeName":"end"}]},{"number":72,"arabic":"فَإِن تَوَلَّيْتُمْ فَمَا سَأَلْتُكُم مِّنْ أَجْرٍ ۖ إِنْ أَجْرِىَ إِلَّا عَلَى ٱللَّهِ ۖ وَأُمِرْتُ أَنْ أَكُونَ مِنَ ٱلْمُسْلِمِينَ","translation":"But if you turn away [from the message which I bear, remember that] I have asked no reward whatever of you: my reward rests with none but God, for I have been bidden to be among those who have surrendered themselves unto Him.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1436.mp3","surahId":10,"words":[{"id":60369,"position":1,"arabic":"فَإِن","translation":"এরপরও যদি","audioUrl":"wbw/010_072_001.mp3","charTypeName":"word"},{"id":60370,"position":2,"arabic":"تَوَلَّيْتُمْ","translation":"তোমরা মুখ ফিরাও","audioUrl":"wbw/010_072_002.mp3","charTypeName":"word"},{"id":60371,"position":3,"arabic":"فَمَا","translation":"তবে না","audioUrl":"wbw/010_072_003.mp3","charTypeName":"word"},{"id":60372,"position":4,"arabic":"سَأَلْتُكُم","translation":"তোমাদের কাছে আমি চাই","audioUrl":"wbw/010_072_004.mp3","charTypeName":"word"},{"id":60373,"position":5,"arabic":"مِّنْ","translation":"কোনো","audioUrl":"wbw/010_072_005.mp3","charTypeName":"word"},{"id":60374,"position":6,"arabic":"أَجْرٍ ۖ","translation":"পারিশ্রমিক","audioUrl":"wbw/010_072_006.mp3","charTypeName":"word"},{"id":60376,"position":7,"arabic":"إِنْ","translation":"নেই","audioUrl":"wbw/010_072_008.mp3","charTypeName":"word"},{"id":60377,"position":8,"arabic":"أَجْرِىَ","translation":"প্রতিদান আমার","audioUrl":"wbw/010_072_009.mp3","charTypeName":"word"},{"id":60378,"position":9,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/010_072_010.mp3","charTypeName":"word"},{"id":60379,"position":10,"arabic":"عَلَى","translation":"নিকট","audioUrl":"wbw/010_072_011.mp3","charTypeName":"word"},{"id":60380,"position":11,"arabic":"ٱللَّهِ ۖ","translation":"আল্লাহর","audioUrl":"wbw/010_072_012.mp3","charTypeName":"word"},{"id":60382,"position":12,"arabic":"وَأُمِرْتُ","translation":"এবং আমাকে আদেশ করা হয়েছে","audioUrl":"wbw/010_072_014.mp3","charTypeName":"word"},{"id":60383,"position":13,"arabic":"أَنْ","translation":"যে","audioUrl":"wbw/010_072_015.mp3","charTypeName":"word"},{"id":60384,"position":14,"arabic":"أَكُونَ","translation":"আমি হই (যেন)","audioUrl":"wbw/010_072_016.mp3","charTypeName":"word"},{"id":60385,"position":15,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/010_072_017.mp3","charTypeName":"word"},{"id":60386,"position":16,"arabic":"ٱلْمُسْلِمِينَ","translation":"আত্মসমর্পণকারীদের\"","audioUrl":"wbw/010_072_018.mp3","charTypeName":"word"},{"id":60387,"position":17,"arabic":"٧٢","translation":"(৭২)","audioUrl":null,"charTypeName":"end"}]},{"number":73,"arabic":"فَكَذَّبُوهُ فَنَجَّيْنَٰهُ وَمَن مَّعَهُۥ فِى ٱلْفُلْكِ وَجَعَلْنَٰهُمْ خَلَٰٓئِفَ وَأَغْرَقْنَا ٱلَّذِينَ كَذَّبُوا۟ بِـَٔايَٰتِنَا ۖ فَٱنظُرْ كَيْفَ كَانَ عَٰقِبَةُ ٱلْمُنذَرِينَ","translation":"And yet they gave him the lie! And so We saved him and all who stood by him, in the ark, and made them inherit [the earth], the while We caused those who gave the lie to Our messages to drown: behold, then, what happened in the end to those people who had been warned [in vain]!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1437.mp3","surahId":10,"words":[{"id":60989,"position":1,"arabic":"فَكَذَّبُوهُ","translation":"অতঃপর তাঁর প্রতি তারা মিথ্যারোপ করলো","audioUrl":"wbw/010_073_001.mp3","charTypeName":"word"},{"id":60990,"position":2,"arabic":"فَنَجَّيْنَـٰهُ","translation":"তখন আমরা উদ্ধার করলাম তাঁকে","audioUrl":"wbw/010_073_002.mp3","charTypeName":"word"},{"id":60991,"position":3,"arabic":"وَمَن","translation":"এবং যারা","audioUrl":"wbw/010_073_003.mp3","charTypeName":"word"},{"id":60992,"position":4,"arabic":"مَّعَهُۥ","translation":"সাথে তাঁর(ছিলো)","audioUrl":"wbw/010_073_004.mp3","charTypeName":"word"},{"id":60993,"position":5,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/010_073_005.mp3","charTypeName":"word"},{"id":60994,"position":6,"arabic":"ٱلْفُلْكِ","translation":"নৌকার","audioUrl":"wbw/010_073_006.mp3","charTypeName":"word"},{"id":60995,"position":7,"arabic":"وَجَعَلْنَـٰهُمْ","translation":"এবং আমরা বানালাম তাদেরকে","audioUrl":"wbw/010_073_007.mp3","charTypeName":"word"},{"id":60996,"position":8,"arabic":"خَلَـٰٓئِفَ","translation":"প্রতিনিধি","audioUrl":"wbw/010_073_008.mp3","charTypeName":"word"},{"id":60997,"position":9,"arabic":"وَأَغْرَقْنَا","translation":"এবং ডুবিয়ে দিলাম আমরা","audioUrl":"wbw/010_073_009.mp3","charTypeName":"word"},{"id":60998,"position":10,"arabic":"ٱلَّذِينَ","translation":"(তাদেরকে) যারা","audioUrl":"wbw/010_073_010.mp3","charTypeName":"word"},{"id":60999,"position":11,"arabic":"كَذَّبُوا۟","translation":"মিথ্যারোপ করেছিলো","audioUrl":"wbw/010_073_011.mp3","charTypeName":"word"},{"id":61000,"position":12,"arabic":"بِـَٔايَـٰتِنَا ۖ","translation":"প্রতি নিদর্শনাবলীর আমাদের","audioUrl":"wbw/010_073_012.mp3","charTypeName":"word"},{"id":61002,"position":13,"arabic":"فَٱنظُرْ","translation":"সুতরাং দেখো","audioUrl":"wbw/010_073_014.mp3","charTypeName":"word"},{"id":61003,"position":14,"arabic":"كَيْفَ","translation":"কেমন","audioUrl":"wbw/010_073_015.mp3","charTypeName":"word"},{"id":61004,"position":15,"arabic":"كَانَ","translation":"হয়েছিলো","audioUrl":"wbw/010_073_016.mp3","charTypeName":"word"},{"id":61005,"position":16,"arabic":"عَـٰقِبَةُ","translation":"পরিণাম","audioUrl":"wbw/010_073_017.mp3","charTypeName":"word"},{"id":61006,"position":17,"arabic":"ٱلْمُنذَرِينَ","translation":"যাদের সতর্ক করা হয়েছিলো","audioUrl":"wbw/010_073_018.mp3","charTypeName":"word"},{"id":61007,"position":18,"arabic":"٧٣","translation":"(৭৩)","audioUrl":null,"charTypeName":"end"}]},{"number":74,"arabic":"ثُمَّ بَعَثْنَا مِنۢ بَعْدِهِۦ رُسُلًا إِلَىٰ قَوْمِهِمْ فَجَآءُوهُم بِٱلْبَيِّنَٰتِ فَمَا كَانُوا۟ لِيُؤْمِنُوا۟ بِمَا كَذَّبُوا۟ بِهِۦ مِن قَبْلُ ۚ كَذَٰلِكَ نَطْبَعُ عَلَىٰ قُلُوبِ ٱلْمُعْتَدِينَ","translation":"AND THEN, after him, We sent forth [other] apostles-each one unto his own people -and they brought them all evidence of the truth; but they would not believe in anything to which they had once given the lie: thus it is that We seal the hearts of such as [are wont to] transgress the bounds of what is right.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1438.mp3","surahId":10,"words":[{"id":61722,"position":1,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/010_074_001.mp3","charTypeName":"word"},{"id":61723,"position":2,"arabic":"بَعَثْنَا","translation":"পাঠালাম আমরা","audioUrl":"wbw/010_074_002.mp3","charTypeName":"word"},{"id":61724,"position":3,"arabic":"مِنۢ","translation":"থেকে","audioUrl":"wbw/010_074_003.mp3","charTypeName":"word"},{"id":61725,"position":4,"arabic":"بَعْدِهِۦ","translation":"পর তার","audioUrl":"wbw/010_074_004.mp3","charTypeName":"word"},{"id":61726,"position":5,"arabic":"رُسُلًا","translation":"রাসূলদেরকে","audioUrl":"wbw/010_074_005.mp3","charTypeName":"word"},{"id":61727,"position":6,"arabic":"إِلَىٰ","translation":"প্রতি","audioUrl":"wbw/010_074_006.mp3","charTypeName":"word"},{"id":61728,"position":7,"arabic":"قَوْمِهِمْ","translation":"জাতির তাদের","audioUrl":"wbw/010_074_007.mp3","charTypeName":"word"},{"id":61729,"position":8,"arabic":"فَجَآءُوهُم","translation":"অতঃপর তারা কাছে এসেছিলো তাদের","audioUrl":"wbw/010_074_008.mp3","charTypeName":"word"},{"id":61730,"position":9,"arabic":"بِٱلْبَيِّنَـٰتِ","translation":"নিয়ে স্পষ্ট নিদর্শনাবলী","audioUrl":"wbw/010_074_009.mp3","charTypeName":"word"},{"id":61731,"position":10,"arabic":"فَمَا","translation":"কিন্তু না","audioUrl":"wbw/010_074_010.mp3","charTypeName":"word"},{"id":61732,"position":11,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/010_074_011.mp3","charTypeName":"word"},{"id":61733,"position":12,"arabic":"لِيُؤْمِنُوا۟","translation":"জন্যে (প্রস্তুত) ঈমান আনার","audioUrl":"wbw/010_074_012.mp3","charTypeName":"word"},{"id":61734,"position":13,"arabic":"بِمَا","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/010_074_013.mp3","charTypeName":"word"},{"id":61735,"position":14,"arabic":"كَذَّبُوا۟","translation":"তারা মিথ্যারোপ করেছিলো","audioUrl":"wbw/010_074_014.mp3","charTypeName":"word"},{"id":61736,"position":15,"arabic":"بِهِۦ","translation":"উপর তার","audioUrl":"wbw/010_074_015.mp3","charTypeName":"word"},{"id":61737,"position":16,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/010_074_016.mp3","charTypeName":"word"},{"id":61738,"position":17,"arabic":"قَبْلُ ۚ","translation":"পূর্ব","audioUrl":"wbw/010_074_017.mp3","charTypeName":"word"},{"id":61740,"position":18,"arabic":"كَذَٰلِكَ","translation":"এভাবে","audioUrl":"wbw/010_074_0