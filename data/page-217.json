62042,"position":8,"arabic":"فِرْعَوْنَ","translation":"ফিরাউনের","audioUrl":"wbw/010_075_008.mp3","charTypeName":"word"},{"id":62043,"position":9,"arabic":"وَمَلَإِي۟هِۦ","translation":"এবং তার পরিষদবর্গের (প্রতি)","audioUrl":"wbw/010_075_009.mp3","charTypeName":"word"},{"id":62044,"position":10,"arabic":"بِـَٔايَـٰتِنَا","translation":"সহ আমাদের নিদর্শনাবলী","audioUrl":"wbw/010_075_010.mp3","charTypeName":"word"},{"id":62045,"position":11,"arabic":"فَٱسْتَكْبَرُوا۟","translation":"কিন্তু তারা অহংকার করেছিলো","audioUrl":"wbw/010_075_011.mp3","charTypeName":"word"},{"id":62046,"position":12,"arabic":"وَكَانُوا۟","translation":"এবং তারা ছিলো","audioUrl":"wbw/010_075_012.mp3","charTypeName":"word"},{"id":62047,"position":13,"arabic":"قَوْمًۭا","translation":"জাতি","audioUrl":"wbw/010_075_013.mp3","charTypeName":"word"},{"id":62048,"position":14,"arabic":"مُّجْرِمِينَ","translation":"অপরাধী","audioUrl":"wbw/010_075_014.mp3","charTypeName":"word"},{"id":62049,"position":15,"arabic":"٧٥","translation":"(৭৫)","audioUrl":null,"charTypeName":"end"}]},{"number":76,"arabic":"فَلَمَّا جَآءَهُمُ ٱلْحَقُّ مِنْ عِندِنَا قَالُوٓا۟ إِنَّ هَٰذَا لَسِحْرٌۭ مُّبِينٌۭ","translation":"And so, when the truth came to them from Us, they said, \"Behold, this is clearly nothing but sorcery!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1440.mp3","surahId":10,"words":[{"id":62359,"position":1,"arabic":"فَلَمَّا","translation":"অতঃপর যখন","audioUrl":"wbw/010_076_001.mp3","charTypeName":"word"},{"id":62360,"position":2,"arabic":"جَآءَهُمُ","translation":"কাছে আসলো তাদের","audioUrl":"wbw/010_076_002.mp3","charTypeName":"word"},{"id":62361,"position":3,"arabic":"ٱلْحَقُّ","translation":"প্রকৃত সত্য","audioUrl":"wbw/010_076_003.mp3","charTypeName":"word"},{"id":62362,"position":4,"arabic":"مِنْ","translation":"হতে","audioUrl":"wbw/010_076_004.mp3","charTypeName":"word"},{"id":62363,"position":5,"arabic":"عِندِنَا","translation":"নিকট আমাদের","audioUrl":"wbw/010_076_005.mp3","charTypeName":"word"},{"id":62364,"position":6,"arabic":"قَالُوٓا۟","translation":"তারা বললো","audioUrl":"wbw/010_076_006.mp3","charTypeName":"word"},{"id":62365,"position":7,"arabic":"إِنَّ","translation":"\"নিশ্চয়ই","audioUrl":"wbw/010_076_007.mp3","charTypeName":"word"},{"id":62366,"position":8,"arabic":"هَـٰذَا","translation":"এটা","audioUrl":"wbw/010_076_008.mp3","charTypeName":"word"},{"id":62367,"position":9,"arabic":"لَسِحْرٌۭ","translation":"অবশ্যই জাদু","audioUrl":"wbw/010_076_009.mp3","charTypeName":"word"},{"id":62368,"position":10,"arabic":"مُّبِينٌۭ","translation":"সুস্পষ্ট\"","audioUrl":"wbw/010_076_010.mp3","charTypeName":"word"},{"id":62369,"position":11,"arabic":"٧٦","translation":"(৭৬)","audioUrl":null,"charTypeName":"end"}]},{"number":77,"arabic":"قَالَ مُوسَىٰٓ أَتَقُولُونَ لِلْحَقِّ لَمَّا جَآءَكُمْ ۖ أَسِحْرٌ هَٰذَا وَلَا يُفْلِحُ ٱلسَّٰحِرُونَ","translation":"Said Moses: \"Do you speak thus of the truth after it has been brought to you? Can this be sorcery? But sorcerers can never come to a happy end!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1441.mp3","surahId":10,"words":[{"id":63043,"position":1,"arabic":"قَالَ","translation":"বললো","audioUrl":"wbw/010_077_001.mp3","charTypeName":"word"},{"id":63044,"position":2,"arabic":"مُوسَىٰٓ","translation":"মূসা","audioUrl":"wbw/010_077_002.mp3","charTypeName":"word"},{"id":63045,"position":3,"arabic":"أَتَقُولُونَ","translation":"\"কি তোমরা বলছো","audioUrl":"wbw/010_077_003.mp3","charTypeName":"word"},{"id":63046,"position":4,"arabic":"لِلْحَقِّ","translation":"সম্পর্কে সত্য (এরূপ কথা)","audioUrl":"wbw/010_077_004.mp3","charTypeName":"word"},{"id":63047,"position":5,"arabic":"لَمَّا","translation":"যখন","audioUrl":"wbw/010_077_005.mp3","charTypeName":"word"},{"id":63048,"position":6,"arabic":"جَآءَكُمْ ۖ","translation":"তোমাদের কাছে (তা) এসেছে","audioUrl":"wbw/010_077_006.mp3","charTypeName":"word"},{"id":63050,"position":7,"arabic":"أَسِحْرٌ","translation":"কি জাদু","audioUrl":"wbw/010_077_008.mp3","charTypeName":"word"},{"id":63051,"position":8,"arabic":"هَـٰذَا","translation":"এটা","audioUrl":"wbw/010_077_009.mp3","charTypeName":"word"},{"id":63052,"position":9,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/010_077_010.mp3","charTypeName":"word"},{"id":63053,"position":10,"arabic":"يُفْلِحُ","translation":"সফলকাম হয়","audioUrl":"wbw/010_077_011.mp3","charTypeName":"word"},{"id":63054,"position":11,"arabic":"ٱلسَّـٰحِرُونَ","translation":"জাদুকররা\"","audioUrl":"wbw/010_077_012.mp3","charTypeName":"word"},{"id":63055,"position":12,"arabic":"٧٧","translation":"(৭৭)","audioUrl":null,"charTypeName":"end"}]},{"number":78,"arabic":"قَالُوٓا۟ أَجِئْتَنَا لِتَلْفِتَنَا عَمَّا وَجَدْنَا عَلَيْهِ ءَابَآءَنَا وَتَكُونَ لَكُمَا ٱلْكِبْرِيَآءُ فِى ٱلْأَرْضِ وَمَا نَحْنُ لَكُمَا بِمُؤْمِنِينَ","translation":"[The great ones] replied: \"Hast thou come to turn us away from what we found our forefathers believing in and doing, so that the two of you might become supreme in this land? However, we do not believe in you two!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1442.mp3","surahId":10,"words":[{"id":63344,"position":1,"arabic":"قَالُوٓا۟","translation":"তারা বলেছিলো","audioUrl":"wbw/010_078_001.mp3","charTypeName":"word"},{"id":63345,"position":2,"arabic":"أَجِئْتَنَا","translation":"\"কি আমাদের কাছে তুমি এসেছো","audioUrl":"wbw/010_078_002.mp3","charTypeName":"word"},{"id":63346,"position":3,"arabic":"لِتَلْفِتَنَا","translation":"যাতে তুমি আমাদেরকে সরিয়ে দিবে","audioUrl":"wbw/010_078_003.mp3","charTypeName":"word"},{"id":63347,"position":4,"arabic":"عَمَّا","translation":"তা হতে যা","audioUrl":"wbw/010_078_004.mp3","charTypeName":"word"},{"id":63348,"position":5,"arabic":"وَجَدْنَا","translation":"পেয়েছি আমরা","audioUrl":"wbw/010_078_005.mp3","charTypeName":"word"},{"id":63349,"position":6,"arabic":"عَلَيْهِ","translation":"উপর তার","audioUrl":"wbw/010_078_006.mp3","charTypeName":"word"},{"id":63350,"position"