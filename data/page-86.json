{"id":86,"ayahs":[{"number":45,"arabic":"وَٱللَّهُ أَعْلَمُ بِأَعْدَآئِكُمْ ۚ وَكَفَىٰ بِٱللَّهِ وَلِيًّۭا وَكَفَىٰ بِٱللَّهِ نَصِيرًۭا","translation":"But God knows best who are your enemies: and none can befriend as God does, and none can give succour as God does.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/538.mp3","surahId":4,"words":[{"id":45066,"position":1,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/004_045_001.mp3","charTypeName":"word"},{"id":45067,"position":2,"arabic":"أَعْلَمُ","translation":"খুব জানেন","audioUrl":"wbw/004_045_002.mp3","charTypeName":"word"},{"id":45068,"position":3,"arabic":"بِأَعْدَآئِكُمْ ۚ","translation":"তোমাদের শত্রুদের সম্পর্কে","audioUrl":"wbw/004_045_003.mp3","charTypeName":"word"},{"id":45070,"position":4,"arabic":"وَكَفَىٰ","translation":"এবং যথেষ্ট","audioUrl":"wbw/004_045_005.mp3","charTypeName":"word"},{"id":45071,"position":5,"arabic":"بِٱللَّهِ","translation":"আল্লাহই","audioUrl":"wbw/004_045_006.mp3","charTypeName":"word"},{"id":45072,"position":6,"arabic":"وَلِيًّۭا","translation":"অভিভাবক হিসেবে","audioUrl":"wbw/004_045_007.mp3","charTypeName":"word"},{"id":45073,"position":7,"arabic":"وَكَفَىٰ","translation":"ও যথেষ্ট","audioUrl":"wbw/004_045_008.mp3","charTypeName":"word"},{"id":45074,"position":8,"arabic":"بِٱللَّهِ","translation":"আল্লাহই","audioUrl":"wbw/004_045_009.mp3","charTypeName":"word"},{"id":45075,"position":9,"arabic":"نَصِيرًۭا","translation":"সাহায্যকারী হিসেবে","audioUrl":"wbw/004_045_010.mp3","charTypeName":"word"},{"id":45076,"position":10,"arabic":"٤٥","translation":"(৪৫)","audioUrl":null,"charTypeName":"end"}]},{"number":46,"arabic":"مِّنَ ٱلَّذِينَ هَادُوا۟ يُحَرِّفُونَ ٱلْكَلِمَ عَن مَّوَاضِعِهِۦ وَيَقُولُونَ سَمِعْنَا وَعَصَيْنَا وَٱسْمَعْ غَيْرَ مُسْمَعٍۢ وَرَٰعِنَا لَيًّۢا بِأَلْسِنَتِهِمْ وَطَعْنًۭا فِى ٱلدِّينِ ۚ وَلَوْ أَنَّهُمْ قَالُوا۟ سَمِعْنَا وَأَطَعْنَا وَٱسْمَعْ وَٱنظُرْنَا لَكَانَ خَيْرًۭا لَّهُمْ وَأَقْوَمَ وَلَٰكِن لَّعَنَهُمُ ٱللَّهُ بِكُفْرِهِمْ فَلَا يُؤْمِنُونَ إِلَّا قَلِيلًۭا","translation":"Among those of the Jewish faith there are some who distort the meaning of the [revealed] words, taking them out of their context and saying, [as it were,] \"We have heard, but we disobey,\" and, \"Hear without hearkening,” and, “Hearken thou unto us, (O Muhammad)” - thus making a play with their tongues, and implying that the [true] Faith is false. And had they but said, \"We have heard, and we pay heed,\" and \"Hear [us], and have patience with us,\" it would indeed have been for their own good, and more upright: but God has rejected them because of their refusal to acknowledge the truth - for it is in but few things that they believe.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/539.mp3","surahId":4,"words":[{"id":45774,"position":1,"arabic":"مِّنَ","translation":"(তাদের) মধ্য হতে","audioUrl":"wbw/004_046_001.mp3","charTypeName":"word"},{"id":45775,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/004_046_002.mp3","charTypeName":"word"},{"id":45776,"position":3,"arabic":"هَادُوا۟","translation":"ইহুদী হয়েছে","audioUrl":"wbw/004_046_003.mp3","charTypeName":"word"},{"id":45777,"position":4,"arabic":"يُحَرِّفُونَ","translation":"তারা বিকৃত করে","audioUrl":"wbw/004_046_004.mp3","charTypeName":"word"},{"id":45778,"position":5,"arabic":"ٱلْكَلِمَ","translation":"শব্দগুলোকে","audioUrl":"wbw/004_046_005.mp3","charTypeName":"word"},{"id":45779,"position":6,"arabic":"عَن","translation":"হতে","audioUrl":"wbw/004_046_006.mp3","charTypeName":"word"},{"id":45780,"position":7,"arabic":"مَّوَاضِعِهِۦ","translation":"তাঁর জায়গাগুলো (অর্থ মূলঅর্থ হতে)","audioUrl":"wbw/004_046_007.mp3","charTypeName":"word"},{"id":45781,"position":8,"arabic":"وَيَقُولُونَ","translation":"এবং তারা বলে","audioUrl":"wbw/004_046_008.mp3","charTypeName":"word"},{"id":45782,"position":9,"arabic":"سَمِعْنَا","translation":"''আমরা শুনলাম","audioUrl":"wbw/004_046_009.mp3","charTypeName":"word"},{"id":45783,"position":10,"arabic":"وَعَصَيْنَا","translation":"কিন্তু আমরা অমান্য করলাম''","audioUrl":"wbw/004_046_010.mp3","charTypeName":"word"},{"id":45784,"position":11,"arabic":"وَٱسْمَعْ","translation":"ও শুনুন","audioUrl":"wbw/004_046_011.mp3","charTypeName":"word"},{"id":45785,"position":12,"arabic":"غَيْرَ","translation":"ব্যতীত","audioUrl":"wbw/004_046_012.mp3","charTypeName":"word"},{"id":45786,"position":13,"arabic":"مُسْمَعٍۢ","translation":"শুনা","audioUrl":"wbw/004_046_013.mp3","charTypeName":"word"},{"id":45787,"position":14,"arabic":"وَرَٰعِنَا","translation":"এবং (বলে) 'রাইনা'''","audioUrl":"wbw/004_046_014.mp3","charTypeName":"word"},{"id":45788,"position":15,"arabic":"لَيًّۢا","translation":"মুড়া দিয়ে","audioUrl":"wbw/004_046_015.mp3","charTypeName":"word"},{"id":45789,"position":16,"arabic":"بِأَلْسِنَتِهِمْ","translation":"তাদের জিহ্বাগুলো (অর্থ বিকৃত করার জন্য)","audioUrl":"wbw/004_046_016.mp3","charTypeName":"word"},{"id":45790,"position":17,"arabic":"وَطَعْنًۭا","translation":"ও তাচ্ছিল্য করে","audioUrl":"wbw/004_046_017.mp3","charTypeName":"word"},{"id":45791,"position":18,"arabic":"فِى","translation":"ক্ষেত্রে","audioUrl":"wbw/004_046_018.mp3","charTypeName":"word"},{"id":45792,"position":19,"arabic":"ٱلدِّينِ ۚ","translation":"দ্বীনের","audioUrl":"wbw/004_046_019.mp3","charTypeName":"word"},{"id":45794,"position":20,"arabic":"وَلَوْ","translation":"এবং যদি","audioUrl":"wbw/004_046_021.mp3","charTypeName":"word"},{"id":45795,"position":21,"arabic":"أَنَّهُمْ","translation":"তারা বাস্তবিক","audioUrl":"wbw/004_046_022.mp3","charTypeName":"word"},{"id":45796,"position":22,"arabic":"قَالُوا۟","translation":"বলত","audioUrl":"wbw/004_046_023.mp3","charTypeName":"word"},{"id":45797,"position":23,"arabic":"سَمِعْنَا","translation":"''আমরা শুনলাম","audioUrl":"wbw/004_046_024.mp3","charTypeName":"word"},{"id":45798,"position":24,"arabic":"وَأَطَعْنَا","translation":"এবং আমরা মানলাম''","audioUrl":"wbw/004_046_025.mp3","charTypeName":"word"},{"id":45799,"position":25,"arabic":"وَٱسْمَعْ","translation":"ও শুনুন","audioUrl":"wbw/004_046_026.mp3","charTypeName":"word"},{"id":45800,"position":26,"arabic":"وَٱنظُرْنَا","translation":"ও আমাদের প্রতি লক্ষ্য করুন","audioUrl":"wbw/004_046_027.mp3","charTypeName":"word"},{"id":45801,"position":27,"arabic":"لَكَانَ","translation":"হত নিশ্চয়","audioUrl":"wbw/004_046_028.mp3","charTypeName":"word"},{"id":45802,"position":28,"arabic":"خَيْرًۭا","translation":"উত্তম","audioUrl":"wbw/004_046_029.mp3","charTypeName":"word"},{"id":45803,"position":29,"arabic":"لَّهُمْ","translation":"তাদের জন্য","audioUrl":"wbw/004_046_030.mp3","charTypeName":"word"},{"id":45804,"position":30,"arabic":"وَأَقْوَمَ","translation":"ও সংগত (হত)","audioUrl":"wbw/004_046_031.mp3","charTypeName":"word"},{"id":45805,"position":31,"arabic":"وَلَـٰكِن","translation":"কিন্তু","audioUrl":"wbw/004_046_032.mp3","charTypeName":"word"},{"id":45806,"position":32,"arabic":"لَّعَنَهُمُ","translation":"তাদের অভিশাপ দিয়েছেন","audioUrl":"wbw/004_046_033.mp3","charTypeName":"word"},{"id":45807,"position":33,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/004_046_034.mp3","charTypeName":"word"},{"id":45808,"position":34,"arabic":"بِكُفْرِهِمْ","translation":"কুফরীর কারণে তাদের","audioUrl":"wbw/004_046_035.mp3","charTypeName":"word"},{"id":45809,"position":35,"arabic":"فَلَا","translation":"অতএব না","audioUrl":"wbw/004_046_036.mp3","charTypeName":"word"},{"id":45810,"position":36,"arabic":"يُؤْمِنُونَ","translation":"তারা ঈমান আনবে","audioUrl":"wbw/004_046_037.mp3","charTypeName":"word"},{"id":45811,"position":37,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/004_046_038.mp3","charTypeName":"word"},{"id":45812,"position":38,"arabic":"قَلِيلًۭا","translation":"অল্প সংখ্যক","audioUrl":"wbw/004_046_039.mp3","charTypeName":"word"},{"id":45813,"position":39,"arabic":"٤٦","translation":"(৪৬)","audioUrl":null,"charTypeName":"end"}]},{"number":47,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ أُوتُوا۟ ٱلْكِتَٰبَ ءَامِنُوا۟ بِمَا نَزَّلْنَا مُصَدِّقًۭا لِّمَا مَعَكُم مِّن قَبْلِ أَن نَّطْمِسَ وُجُوهًۭا فَنَرُدَّهَا عَلَىٰٓ أَدْبَارِهَآ أَوْ نَلْعَنَهُمْ كَمَا لَعَنَّآ أَصْحَٰبَ ٱلسَّبْتِ ۚ وَكَانَ أَمْرُ ٱللَّهِ مَفْعُولًا","translation":"O you who have been granted revelation [aforetime]! Believe in what We have [now] bestowed from on high in confirmation of whatever [of the truth] you already possess, lest We efface your hopes and bring them to an end - just as We rejected those people who broke the Sabbath: for God's will is always done.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/540.mp3","surahId":4,"words":[{"id":46445,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"ওহে","audioUrl":"wbw/004_047_001.mp3","charTypeName":"word"},{"id":46446,"position":2,"arabic":"ٱلَّذِينَ","translation":"যাদের","audioUrl":"wbw/004_047_002.mp3","charTypeName":"word"},{"id":46447,"position":3,"arabic":"أُوتُوا۟","translation":"দেয়া হয়েছে","audioUrl":"wbw/004_047_003.mp3","charTypeName":"word"},{"id":46448,"position":4,"arabic":"ٱلْكِتَـٰبَ","translation":"কিতাব","audioUrl":"wbw/004_047_004.mp3","charTypeName":"word"},{"id":46449,"position":5,"arabic":"ءَامِنُوا۟","translation":"তোমরা ঈমান আন","audioUrl":"wbw/004_047_005.mp3","charTypeName":"word"},{"id":46450,"position":6,"arabic":"بِمَا","translation":"ঐবিষয়ে যা","audioUrl":"wbw/004_047_006.mp3","charTypeName":"word"},{"id":46451,"position":7,"arabic":"نَزَّلْنَا","translation":"আমরা নাযিল করেছি","audioUrl":"wbw/004_047_007.mp3","charTypeName":"word"},{"id":46452,"position":8,"arabic":"مُصَدِّقًۭا","translation":"সত্যায়নকারী","audioUrl":"wbw/004_047_008.mp3","charTypeName":"word"},{"id":46453,"position":9,"arabic":"لِّمَا","translation":"সেটারও যা","audioUrl":"wbw/004_047_009.mp3","charTypeName":"word"},{"id":46454,"position":10,"arabic":"مَعَكُم","translation":"তোমাদের (আছে)","audioUrl":"wbw/004_047_010.mp3","charTypeName":"word"},{"id":46455,"position":11,"arabic":"مِّن","translation":"(থেকে)","audioUrl":"wbw/004_047_011.mp3","charTypeName":"word"},{"id":46456,"position":12,"arabic":"قَبْلِ","translation":"ইতিপূর্বে","audioUrl":"wbw/004_047_012.mp3","charTypeName":"word"},{"id":46457,"position":13,"arabic":"أَن","translation":"যে","audioUrl":"wbw/004_047_013.mp3","charTypeName":"word"},{"id":46458,"position":14,"arabic":"نَّطْمِسَ","translation":"বিকৃত করব আমরা","audioUrl":"wbw/004_047_014.mp3","charTypeName":"word"},{"id":46459,"position":15,"arabic":"وُجُوهًۭا","translation":"মুখের আকৃতি","audioUrl":"wbw/004_047_015.mp3","charTypeName":"word"},{"id":46460,"position":16,"arabic":"فَنَرُدَّهَا","translation":"অতঃপর ফিরাবো আমরা তা","audioUrl":"wbw/004_047_016.mp3","charTypeName":"word"},{"id":46461,"position":17,"arabic":"عَلَىٰٓ","translation":"উপর","audioUrl":"wbw/004_047_017.mp3","charTypeName":"word"},{"id":46462,"position":18,"arabic":"أَدْبَارِهَآ","translation":"তার পিছন দিয়ে","audioUrl":"wbw/004_047_018.mp3","charTypeName":"word"},{"id":46463,"position":19,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/004_047_019.mp3","charTypeName":"word"},{"id":46464,"position":20,"arabic":"نَلْعَنَهُمْ","translation":"তাদের অভিশাপ দেব আমরা","audioUrl":"wbw/004_047_020.mp3","charTypeName":"word"},{"id":46465,"position":21,"arabic":"كَمَا","translation":"যেমন","audioUrl":"wbw/004_047_021.mp3","charTypeName":"word"},{"id":46466,"position":22,"arabic":"لَعَنَّآ","translation":"আমরা অভিশাপ দিয়েছিলাম","audioUrl":"wbw/004_047_022.mp3","charTypeName":"word"},{"id":46467,"position":23,"arabic":"أَصْحَـٰبَ","translation":"ওয়ালাদেরকে","audioUrl":"wbw/004_047_023.mp3","charTypeName":"word"},{"id":46468,"position":24,"arabic":"ٱلسَّبْتِ ۚ","translation":"শনিবার","audioUrl":"wbw/004_047_024.mp3","charTypeName":"word"},{"id":46470,"position":25,"arabic":"وَكَانَ","translation":"এবং হয় ই","audioUrl":"wbw/004_047_026.mp3","charTypeName":"word"},{"id":46471,"position":26,"arabic":"أَمْرُ","translation":"আদেশ","audioUrl":"wbw/004_047_027.mp3","charTypeName":"word"},{"id":46472,"position":27,"arabic":"ٱللَّهِ","translation":"আল্লাহ","audioUrl":"wbw/004_047_028.mp3","charTypeName":"word"},{"id":46473,"position":28,"arabic":"مَفْعُولًا","translation":"কার্যকরী","audioUrl":"wbw/004_047_029.mp3","charTypeName":"word"},{"id":46474,"position":29,"arabic":"٤٧","translation":"(৪৭)","audioUrl":null,"charTypeName":"end"}]},{"number":48,"arabic":"إِنَّ ٱللَّهَ لَا يَغْفِرُ أَن يُشْرَكَ بِهِۦ وَيَغْفِرُ مَا دُونَ ذَٰلِكَ لِمَن يَشَآءُ ۚ وَمَن يُشْرِكْ بِٱللَّهِ فَقَدِ ٱفْتَرَىٰٓ إِثْمًا عَظِيمًا","translation":"VERILY, God does not forgive the ascribing of divinity to aught beside Him, although He forgives any lesser sin unto whomever He wills: for he who ascribes divinity to aught beside God has indeed contrived an awesome sin.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/541.mp3","surahId":4,"words":[{"id":47143,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়","audioUrl":"wbw/004_048_001.mp3","charTypeName":"word"},{"id":47144,"position":2,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/004_048_002.mp3","charTypeName":"word"},{"id":47145,"position":3,"arabic":"لَا","translation":"না","audioUrl":"wbw/004_048_003.mp3","charTypeName":"word"},{"id":47146,"position":4,"arabic":"يَغْفِرُ","translation":"মাফ করেন","audioUrl":"wbw/004_048_004.mp3","charTypeName":"word"},{"id":47147,"position":5,"arabic":"أَن","translation":"(যে)","audioUrl":"wbw/004_048_005.mp3","charTypeName":"word"},{"id":47148,"position":6,"arabic":"يُشْرَكَ","translation":"শিরক করাকে","audioUrl":"wbw/004_048_006.mp3","charTypeName":"word"},{"id":47149,"position":7,"arabic":"بِهِۦ","translation":"তার সাথে","audioUrl":"wbw/004_048_007.mp3","charTypeName":"word"},{"id":47150,"position":8,"arabic":"وَيَغْفِرُ","translation":"কিন্তু মাফ করেন","audioUrl":"wbw/004_048_008.mp3","charTypeName":"word"},{"id":47151,"position":9,"arabic":"مَا","translation":"যা (আছে)","audioUrl":"wbw/004_048_009.mp3","charTypeName":"word"},{"id":47152,"position":10,"arabic":"دُونَ","translation":"ছাড়া","audioUrl":"wbw/004_048_010.mp3","charTypeName":"word"},{"id":47153,"position":11,"arabic":"ذَٰلِكَ","translation":"এটা (অর্থাৎ শিরক)","audioUrl":"wbw/004_048_011.mp3","charTypeName":"word"},{"id":47154,"position":12,"arabic":"لِمَن","translation":"যাকে","audioUrl":"wbw/004_048_012.mp3","charTypeName":"word"},{"id":47155,"position":13,"arabic":"يَشَآءُ ۚ","translation":"তিনি ইচ্ছা করেন","audioUrl":"wbw/004_048_013.mp3","charTypeName":"word"},{"id":47157,"position":14,"arabic":"وَمَن","translation":"এবং যে কেউ","audioUrl":"wbw/004_048_015.mp3","charTypeName":"word"},{"id":47158,"position":15,"arabic":"يُشْرِكْ","translation":"শিরক করে","audioUrl":"wbw/004_048_016.mp3","charTypeName":"word"},{"id":47159,"position":16,"arabic":"بِٱللَّهِ","translation":"আল্লাহর সাথে","audioUrl":"wbw/004_048_017.mp3","charTypeName":"word"},{"id":47160,"position":17,"arabic":"فَقَدِ","translation":"নিশ্চয়ই তবে","audioUrl":"wbw/004_048_018.mp3","charTypeName":"word"},{"id":47161,"position":18,"arabic":"ٱفْتَرَىٰٓ","translation":"সে রচনা করল","audioUrl":"wbw/004_048_019.mp3","charTypeName":"word"},{"id":47162,"position":19,"arabic":"إِثْمًا","translation":"গুনাহ","audioUrl":"wbw/004_048_020.mp3","charTypeName":"word"},{"id":47163,"position":20,"arabic":"عَظِيمًا","translation":"বিরাট","audioUrl":"wbw/004_048_021.mp3","charTypeName":"word"},{"id":47164,"position":21,"arabic":"٤٨","translation":"(৪৮)","audioUrl":null,"charTypeName":"end"}]},{"number":49,"arabic":"أَلَمْ تَرَ إِلَى ٱلَّذِينَ يُزَكُّونَ أَنفُسَهُم ۚ بَلِ ٱللَّهُ يُزَكِّى مَن يَشَآءُ وَلَا يُظْلَمُونَ فَتِيلًا","translation":"Art thou not aware of those who consider themselves pure? Nay, but it is God who causes whomever He wills to grow in purity; and none shall be wronged by as much as a hair's breadth.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/542.mp3","surahId":4,"words":[{"id":47801,"position":1,"arabic":"أَلَمْ","translation":"নাই কি","audioUrl":"wbw/004_049_001.mp3","charTypeName":"word"},{"id":47802,"position":2,"arabic":"تَرَ","translation":"তুমি দেখ","audioUrl":"wbw/004_049_002.mp3","charTypeName":"word"},{"id":47803,"position":3,"arabic":"إِلَى","translation":"প্রতি","audioUrl":"wbw/004_049_003.mp3","charTypeName":"word"},{"id":47804,"position":4,"arabic":"ٱلَّذِينَ","translation":"(তাদের) যারা","audioUrl":"wbw/004_049_004.mp3","charTypeName":"word"},{"id":47805,"position":5,"arabic":"يُزَكُّونَ","translation":"পবিত্র করেছে (বলে দাবী করে)","audioUrl":"wbw/004_049_005.mp3","charTypeName":"word"},{"id":47806,"position":6,"arabic":"أَنفُسَهُم ۚ","translation":"তাদের নিজেদেরকে","audioUrl":"wbw/004_049_006.mp3","charTypeName":"word"},{"id":47808,"position":7,"arabic":"بَلِ","translation":"বরং","audioUrl":"wbw/004_049_008.mp3","charTypeName":"word"},{"id":47809,"position":8,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌ই","audioUrl":"wbw/004_049_009.mp3","charTypeName":"word"},{"id":47810,"position":9,"arabic":"يُزَكِّى","translation":"পবিত্র করেন","audioUrl":"wbw/004_049_010.mp3","charTypeName":"word"},{"id":47811,"position":10,"arabic":"مَن","translation":"যাকে","audioUrl":"wbw/004_049_011.mp3","charTypeName":"word"},{"id":47812,"position":11,"arabic":"يَشَآءُ","translation":"তিনি ইচ্ছে করেন","audioUrl":"wbw/004_049_012.mp3","charTypeName":"word"},{"id":47813,"position":12,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/004_049_013.mp3","charTypeName":"word"},{"id":47814,"position":13,"arabic":"يُظْلَمُونَ","translation":"জুলুম করা হয় (কারও প্রতি)","audioUrl":"wbw/004_049_014.mp3","charTypeName":"word"},{"id":47815,"position":14,"arabic":"فَتِيلًا","translation":"সুতা পরিমাণও","audioUrl":"wbw/004_049_015.mp3","charTypeName":"word"},{"id":47816,"position":15,"arabic":"٤٩","translation":"(৪৯)","audioUrl":null,"charTypeName":"end"}]},{"number":50,"arabic":"ٱنظُرْ كَيْفَ يَفْتَرُونَ عَلَى ٱللَّهِ ٱلْكَذِبَ ۖ وَكَفَىٰ بِهِۦٓ إِثْمًۭا مُّبِينًا","translation":"Behold how they attribute their own lying inventions to God - than which there is no sin