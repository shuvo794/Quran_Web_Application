{"id":94,"ayahs":[{"number":95,"arabic":"لَّا يَسْتَوِى ٱلْقَٰعِدُونَ مِنَ ٱلْمُؤْمِنِينَ غَيْرُ أُو۟لِى ٱلضَّرَرِ وَٱلْمُجَٰهِدُونَ فِى سَبِيلِ ٱللَّهِ بِأَمْوَٰلِهِمْ وَأَنفُسِهِمْ ۚ فَضَّلَ ٱللَّهُ ٱلْمُجَٰهِدِينَ بِأَمْوَٰلِهِمْ وَأَنفُسِهِمْ عَلَى ٱلْقَٰعِدِينَ دَرَجَةًۭ ۚ وَكُلًّۭا وَعَدَ ٱللَّهُ ٱلْحُسْنَىٰ ۚ وَفَضَّلَ ٱللَّهُ ٱلْمُجَٰهِدِينَ عَلَى ٱلْقَٰعِدِينَ أَجْرًا عَظِيمًۭا","translation":"SUCH of the believers as remain passive - other than the disabled - cannot be deemed equal to those who strive hard in God's cause with their possessions and their lives: God has exalted those who strive hard with their possessions and their lives far above those who remain passive. Although God has promised the ultimate good unto all [believers], yet has God exalted those who strive hard above those who remain passive by [promising them] a mighty reward -","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/588.mp3","surahId":4,"words":[{"id":69746,"position":1,"arabic":"لَّا","translation":"না","audioUrl":"wbw/004_095_001.mp3","charTypeName":"word"},{"id":69747,"position":2,"arabic":"يَسْتَوِى","translation":"সমান হয়","audioUrl":"wbw/004_095_002.mp3","charTypeName":"word"},{"id":69748,"position":3,"arabic":"ٱلْقَـٰعِدُونَ","translation":"(গৃহে) উপবেশনকারী (ঐসব লোক)","audioUrl":"wbw/004_095_003.mp3","charTypeName":"word"},{"id":69749,"position":4,"arabic":"مِنَ","translation":"মধ্য হতে","audioUrl":"wbw/004_095_004.mp3","charTypeName":"word"},{"id":69750,"position":5,"arabic":"ٱلْمُؤْمِنِينَ","translation":"মু'মিনদের","audioUrl":"wbw/004_095_005.mp3","charTypeName":"word"},{"id":69751,"position":6,"arabic":"غَيْرُ","translation":"এব্যতীত","audioUrl":"wbw/004_095_006.mp3","charTypeName":"word"},{"id":69752,"position":7,"arabic":"أُو۟لِى","translation":"(প্রথম)","audioUrl":"wbw/004_095_007.mp3","charTypeName":"word"},{"id":69753,"position":8,"arabic":"ٱلضَّرَرِ","translation":"অক্ষমতাশীলরা","audioUrl":"wbw/004_095_008.mp3","charTypeName":"word"},{"id":69754,"position":9,"arabic":"وَٱلْمُجَـٰهِدُونَ","translation":"ও মুজাহিদরা (যারা জিহাদ করে)","audioUrl":"wbw/004_095_009.mp3","charTypeName":"word"},{"id":69755,"position":10,"arabic":"فِى","translation":"(মধ্যে)","audioUrl":"wbw/004_095_010.mp3","charTypeName":"word"},{"id":69756,"position":11,"arabic":"سَبِيلِ","translation":"পথে","audioUrl":"wbw/004_095_011.mp3","charTypeName":"word"},{"id":69757,"position":12,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/004_095_012.mp3","charTypeName":"word"},{"id":69758,"position":13,"arabic":"بِأَمْوَٰلِهِمْ","translation":"তাদের মাল-সম্পদ দিয়ে","audioUrl":"wbw/004_095_013.mp3","charTypeName":"word"},{"id":69759,"position":14,"arabic":"وَأَنفُسِهِمْ ۚ","translation":"ও তাদের জান (দিয়ে)","audioUrl":"wbw/004_095_014.mp3","charTypeName":"word"},{"id":69761,"position":15,"arabic":"فَضَّلَ","translation":"শ্রেষ্ঠত্ব দিয়েছেন","audioUrl":"wbw/004_095_016.mp3","charTypeName":"word"},{"id":69762,"position":16,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/004_095_017.mp3","charTypeName":"word"},{"id":69763,"position":17,"arabic":"ٱلْمُجَـٰهِدِينَ","translation":"জিহাদকারীদেরকে","audioUrl":"wbw/004_095_018.mp3","charTypeName":"word"},{"id":69764,"position":18,"arabic":"بِأَمْوَٰلِهِمْ","translation":"তাদের মাল-সম্পদ দিয়ে","audioUrl":"wbw/004_095_019.mp3","charTypeName":"word"},{"id":69765,"position":19,"arabic":"وَأَنفُسِهِمْ","translation":"ও তাদের জান (দিয়ে)","audioUrl":"wbw/004_095_020.mp3","charTypeName":"word"},{"id":69766,"position":20,"arabic":"عَلَى","translation":"(তাদের) উপর","audioUrl":"wbw/004_095_021.mp3","charTypeName":"word"},{"id":69767,"position":21,"arabic":"ٱلْقَـٰعِدِينَ","translation":"(যারা) (গৃহে) উপবেশনকারী","audioUrl":"wbw/004_095_022.mp3","charTypeName":"word"},{"id":69768,"position":22,"arabic":"دَرَجَةًۭ ۚ","translation":"মর্যাদায়","audioUrl":"wbw/004_095_023.mp3","charTypeName":"word"},{"id":69770,"position":23,"arabic":"وَكُلًّۭا","translation":"এবং প্রত্যেকেরই","audioUrl":"wbw/004_095_025.mp3","charTypeName":"word"},{"id":69771,"position":24,"arabic":"وَعَدَ","translation":"ওয়াদা দিয়েছেন","audioUrl":"wbw/004_095_026.mp3","charTypeName":"word"},{"id":69772,"position":25,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/004_095_027.mp3","charTypeName":"word"},{"id":69773,"position":26,"arabic":"ٱلْحُسْنَىٰ ۚ","translation":"কল্যাণের","audioUrl":"wbw/004_095_028.mp3","charTypeName":"word"},{"id":69775,"position":27,"arabic":"وَفَضَّلَ","translation":"কিন্তু শ্রেষ্ঠত্ব দিয়েছেন","audioUrl":"wbw/004_095_030.mp3","charTypeName":"word"},{"id":69776,"position":28,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/004_095_031.mp3","charTypeName":"word"},{"id":69777,"position":29,"arabic":"ٱلْمُجَـٰهِدِينَ","translation":"জিহাদকারীদেরকে","audioUrl":"wbw/004_095_032.mp3","charTypeName":"word"},{"id":69778,"position":30,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/004_095_033.mp3","charTypeName":"word"},{"id":69779,"position":31,"arabic":"ٱلْقَـٰعِدِينَ","translation":"উপবিষ্টদের","audioUrl":"wbw/004_095_034.mp3","charTypeName":"word"},{"id":69780,"position":32,"arabic":"أَجْرًا","translation":"পুরস্কারের (ক্ষেত্রে)","audioUrl":"wbw/004_095_035.mp3","charTypeName":"word"},{"id":69781,"position":33,"arabic":"عَظِيمًۭا","translation":"বিরাট","audioUrl":"wbw/004_095_036.mp3","charTypeName":"word"},{"id":69782,"position":34,"arabic":"٩٥","translation":"(৯৫)","audioUrl":null,"charTypeName":"end"}]},{"number":96,"arabic":"دَرَجَٰتٍۢ مِّنْهُ وَمَغْفِرَةًۭ وَرَحْمَةًۭ ۚ وَكَانَ ٱللَّهُ غَفُورًۭا رَّحِيمًا","translation":"[many] degrees thereof - and for­giveness of sins, and His grace; for God is indeed much-forgiving, a dispenser of grace.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/589.mp3","surahId":4,"words":[{"id":70100,"position":1,"arabic":"دَرَجَـٰتٍۢ","translation":"মর্যাদায়","audioUrl":"wbw/004_096_001.mp3","charTypeName":"word"},{"id":70101,"position":2,"arabic":"مِّنْهُ","translation":"তাঁর পক্ষ হতে","audioUrl":"wbw/004_096_002.mp3","charTypeName":"word"},{"id":70102,"position":3,"arabic":"وَمَغْفِرَةًۭ","translation":"ও ক্ষমা","audioUrl":"wbw/004_096_003.mp3","charTypeName":"word"},{"id":70103,"position":4,"arabic":"وَرَحْمَةًۭ ۚ","translation":"ও রহমত (রয়েছে)","audioUrl":"wbw/004_096_004.mp3","charTypeName":"word"},{"id":70105,"position":5,"arabic":"وَكَانَ","translation":"এবং হলেন","audioUrl":"wbw/004_096_006.mp3","charTypeName":"word"},{"id":70106,"position":6,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/004_096_007.mp3","charTypeName":"word"},{"id":70107,"position":7,"arabic":"غَفُورًۭا","translation":"ক্ষমাশীল","audioUrl":"wbw/004_096_008.mp3","charTypeName":"word"},{"id":70108,"position":8,"arabic":"رَّحِيمًا","translation":"মেহেরবান","audioUrl":"wbw/004_096_009.mp3","charTypeName":"word"},{"id":70109,"position":9,"arabic":"٩٦","translation":"(৯৬)","audioUrl":null,"charTypeName":"end"}]},{"number":97,"arabic":"إِنَّ ٱلَّذِينَ تَوَفَّىٰهُمُ ٱلْمَلَٰٓئِكَةُ ظَالِمِىٓ أَنفُسِهِمْ قَالُوا۟ فِيمَ كُنتُمْ ۖ قَالُوا۟ كُنَّا مُسْتَضْعَفِينَ فِى ٱلْأَرْضِ ۚ قَالُوٓا۟ أَلَمْ تَكُنْ أَرْضُ ٱللَّهِ وَٰسِعَةًۭ فَتُهَاجِرُوا۟ فِيهَا ۚ فَأُو۟لَٰٓئِكَ مَأْوَىٰهُمْ جَهَنَّمُ ۖ وَسَآءَتْ مَصِيرًا","translation":"Behold, those whom the angels gather in death while they are still sinning against themselves, [the angels] will ask, \"What was wrong with you?'' They will answer: \"We were too weak on earth.\" [The angels] will say: \"Was, then, God's earth not wide enough for you to forsake the domain of evil?\" For such, then, the goal is hell - and how evil a journey's end!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/590.mp3","surahId":4,"words":[{"id":70399,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়","audioUrl":"wbw/004_097_001.mp3","charTypeName":"word"},{"id":70400,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/004_097_002.mp3","charTypeName":"word"},{"id":70401,"position":3,"arabic":"تَوَفَّىٰهُمُ","translation":"তাদ