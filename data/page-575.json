ْمُدَّثِّرُ","translation":"O THOU [in thy solitude] enfolded!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5496.mp3","surahId":74,"words":[{"id":631,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/074_001_001.mp3","charTypeName":"word"},{"id":632,"position":2,"arabic":"ٱلْمُدَّثِّرُ","translation":"চাদরাবৃত","audioUrl":"wbw/074_001_002.mp3","charTypeName":"word"},{"id":633,"position":3,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"قُمْ فَأَنذِرْ","translation":"Arise and warn!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5497.mp3","surahId":74,"words":[{"id":1613,"position":1,"arabic":"قُمْ","translation":"উঠ","audioUrl":"wbw/074_002_001.mp3","charTypeName":"word"},{"id":1614,"position":2,"arabic":"فَأَنذِرْ","translation":"সতর্ক কর অতঃপর","audioUrl":"wbw/074_002_002.mp3","charTypeName":"word"},{"id":1615,"position":3,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"وَرَبَّكَ فَكَبِّرْ","translation":"And thy Sustainer's greatness glorify!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5498.mp3","surahId":74,"words":[{"id":2622,"position":1,"arabic":"وَرَبَّكَ","translation":"ও তোমার রবের","audioUrl":"wbw/074_003_001.mp3","charTypeName":"word"},{"id":2623,"position":2,"arabic":"فَكَبِّرْ","translation":"অতঃপর শ্রেষ্ঠত্ব ঘোষণা কর","audioUrl":"wbw/074_003_002.mp3","charTypeName":"word"},{"id":2624,"position":3,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"وَثِيَابَكَ فَطَهِّرْ","translation":"And thine inner self purify!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5499.mp3","surahId":74,"words":[{"id":4045,"position":1,"arabic":"وَثِيَابَكَ","translation":"এবং তোমার কাপড়","audioUrl":"wbw/074_004_001.mp3","charTypeName":"word"},{"id":4046,"position":2,"arabic":"فَطَهِّرْ","translation":"অতঃপর পবিত্র কর","audioUrl":"wbw/074_004_002.mp3","charTypeName":"word"},{"id":4047,"position":3,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"وَٱلرُّجْزَ فَٱهْجُرْ","translation":"And all defilement shun!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5500.mp3","surahId":74,"words":[{"id":5331,"position":1,"arabic":"وَٱلرُّجْزَ","translation":"এবং অপবিত্রতা","audioUrl":"wbw/074_005_001.mp3","charTypeName":"word"},{"id":5332,"position":2,"arabic":"فَٱهْجُرْ","translation":"অতএব দূরে থাক","audioUrl":"wbw/074_005_002.mp3","charTypeName":"word"},{"id":5333,"position":3,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"وَلَا تَمْنُن تَسْتَكْثِرُ","translation":"And do not through giving seek thyself to gain,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5501.mp3","surahId":74,"words":[{"id":6546,"position":1,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/074_006_001.mp3","charTypeName":"word"},{"id":6547,"position":2,"arabic":"تَمْنُن","translation":"অনুগ্রহ করো","audioUrl":"wbw/074_006_002.mp3","charTypeName":"word"},{"id":6548,"position":3,"arabic":"تَسْتَكْثِرُ","translation":"বেশী পাওয়ার আশায়","audioUrl":"wbw/074_006_003.mp3","charTypeName":"word"},{"id":6549,"position":4,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"وَلِرَبِّكَ فَٱصْبِرْ","translation":"but unto thy Sustainer turn in patience.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5502.mp3","surahId":74,"words":[{"id":7947,"position":1,"arabic":"وَلِرَبِّكَ","translation":"এবং তোমার রবের জন্যে","audioUrl":"wbw/074_007_001.mp3","charTypeName":"word"},{"id":7948,"position":2,"arabic":"فَٱصْبِرْ","translation":"অতএব সবর কর","audioUrl":"wbw/074_007_002.mp3","charTypeName":"word"},{"id":7949,"position":3,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"فَإِذَا نُقِرَ فِى ٱلنَّاقُورِ","translation":"A