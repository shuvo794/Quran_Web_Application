w/074_010_002.mp3","charTypeName":"word"},{"id":11572,"position":3,"arabic":"غَيْرُ","translation":"নয়","audioUrl":"wbw/074_010_003.mp3","charTypeName":"word"},{"id":11573,"position":4,"arabic":"يَسِيرٍۢ","translation":"সহজ","audioUrl":"wbw/074_010_004.mp3","charTypeName":"word"},{"id":11574,"position":5,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"ذَرْنِى وَمَنْ خَلَقْتُ وَحِيدًۭا","translation":"LEAVE Me alone [to deal] with him whom I have created alone,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5506.mp3","surahId":74,"words":[{"id":12881,"position":1,"arabic":"ذَرْنِى","translation":"আমাকে ছাড়","audioUrl":"wbw/074_011_001.mp3","charTypeName":"word"},{"id":12882,"position":2,"arabic":"وَمَنْ","translation":"আর যাকে","audioUrl":"wbw/074_011_002.mp3","charTypeName":"word"},{"id":12883,"position":3,"arabic":"خَلَقْتُ","translation":"আমি সৃষ্টি করেছি","audioUrl":"wbw/074_011_003.mp3","charTypeName":"word"},{"id":12884,"position":4,"arabic":"وَحِيدًۭا","translation":"একেলা","audioUrl":"wbw/074_011_004.mp3","charTypeName":"word"},{"id":12885,"position":5,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]},{"number":12,"arabic":"وَجَعَلْتُ لَهُۥ مَالًۭا مَّمْدُودًۭا","translation":"and to whom I have granted resources vast,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5507.mp3","surahId":74,"words":[{"id":14136,"position":1,"arabic":"وَجَعَلْتُ","translation":"এবং আমি বানিয়েছি","audioUrl":"wbw/074_012_001.mp3","charTypeName":"word"},{"id":14137,"position":2,"arabic":"لَهُۥ","translation":"তার জন্যে","audioUrl":"wbw/074_012_002.mp3","charTypeName":"word"},{"id":14138,"position":3,"arabic":"مَالًۭا","translation":"সম্পদ","audioUrl":"wbw/074_012_003.mp3","charTypeName":"word"},{"id":14139,"position":4,"arabic":"مَّمْدُودًۭا","translation":"বিপুল","audioUrl":"wbw/074_012_004.mp3","charTypeName":"word"},{"id":14140,"position":5,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]},{"number":13,"arabic":"وَبَنِينَ شُهُودًۭا","translation":"and children as [love's] witnesses,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5508.mp3","surahId":74,"words":[{"id":15267,"position":1,"arabic":"وَبَنِينَ","translation":"এবং সন্তানাদি","audioUrl":"wbw/074_013_001.mp3","charTypeName":"word"},{"id":15268,"position":2,"arabic":"شُهُودًۭا","translation":"সদা উপস্থিত","audioUrl":"wbw/074_013_002.mp3","charTypeName":"word"},{"id":15269,"position":3,"arabic":"١٣","translation":"(১৩)","audioUrl":null,"charTypeName":"end"}]},{"number":14,"arabic":"وَمَهَّدتُّ لَهُۥ تَمْهِيدًۭا","translation":"and to whose life I gave so wide a scope:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5509.mp3","surahId":74,"words":[{"id":16463,"position":1,"arabic":"وَمَهَّدتُّ","translation":"এবং আমি সুগম করেছি","audioUrl":"wbw/074_014_001.mp3","charTypeName":"word"},{"id":16464,"position":2,"arabic":"لَهُۥ","translation":"তার জন্যে","audioUrl":"wbw/074_014_002.mp3","charTypeName":"word"},{"id":16465,"position":3,"arabic":"تَمْهِيدًۭا","translation":"প্রচুর স্বচ্ছলতা","audioUrl":"wbw/074_014_003.mp3","charTypeName":"word"},{"id":16466,"position":4,"arabic":"١٤","translation":"(১৪)","audioUrl":null,"charTypeName":"end"}]},{"number":15,"arabic":"ثُمَّ يَطْمَعُ أَنْ أَزِيدَ","translation":"and yet, he greedily desires that I give yet more!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5510.mp3","surahId":74,"words":[{"id":17466,"position":1,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/074_015_001.mp3","charTypeName":"word"},{"id":17467,"position":2,"arabic":"يَطْمَعُ","translation":"লালসা সে করে","audioUrl":"wbw/074_015_002.mp3","charTypeName":"word"},{"id":17468,"position":3,"arabic":"أَنْ","translation":"যে","audioUrl":"wbw/074_015_003.mp3","charTypeName":"word"},{"id":17469,"position":4,"arabic":"أَزِيدَ","translation":"অধিক দিব আমি","audioUrl":"wbw/074_015_004.mp3","charTypeName":"word"},{"id":17470,"position":5,"arabic":"١٥","translation":"(১৫)","audioUrl":null,"charTypeName":"end"}]},{"number":16,"arabic":"كَلَّآ ۖ إِنَّهُۥ كَانَ لِءَايَٰتِنَا عَنِيدًۭا","translation":"Nay, verily, it is against Our messages that he knowingly, stubbornly sets himself","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5511.mp3","surahId":74,"words":[{"id":18548,"position":1,"arabic":"كَلَّآ ۖ","translation":"কক্ষণও না","audioUrl":"wbw/074_016_001.mp3","charTypeName":"word"},{"id":18550,"position":2,"arabic":"إِنَّهُۥ","translation":"সে নিশ্চয়","audioUrl":"wbw/074_016_003.mp3","charTypeName":"word"},{"id":18551,"position":3,"arabic":"كَانَ","translation":"হল","audioUrl":"wbw/074_016_004.mp3","charTypeName":"word"},{"id":18552,"position":4,"arabic":"لِـَٔايَـٰتِنَا","translation":"আমাদের নিদর্শনাদির প্রতি","audioUrl":"wbw/074_016_005.mp3","charTypeName":"word"},{"id":18553,"position":5,"arabic":"عَنِيدًۭا","translation":"শত্রুতা ভাবাপন্ন","audioUrl":"wbw/074_016_006.mp3","charTypeName":"word"},{"id":18554,"position":6,"arabic":"١٦","translation":"(১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":17,"arabic":"سَأُرْهِقُهُۥ صَعُودًا","translation":"[and so] I shall constrain him to endure a painful uphill climb!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5512.mp3","surahId":74,"words":[{"id":19554,"position":1,"arabic":"سَأُرْهِقُهُۥ","translation":"তাকে চড়াব আমি শীঘ্রই","audioUrl":"wbw/074_017_001.mp3","charTypeName":"word"},{"id":19555,"position":2,"arabic":"صَعُودًا","translation":"কঠিন চড়াইয়ে","audioUrl":"wbw/074_017_002.mp3","charTypeName":"word"},{"id":19556,"position":3,"arabic":"١٧","translation":"(১৭)","audioUrl":null,"charTypeName":"end"}]}]}