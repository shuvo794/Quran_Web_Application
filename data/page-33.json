5686,"position":18,"arabic":"يَشَآءُ","translation":"তিনি চান","audioUrl":"wbw/002_212_020.mp3","charTypeName":"word"},{"id":85687,"position":19,"arabic":"بِغَيْرِ","translation":"ছাড়া","audioUrl":"wbw/002_212_021.mp3","charTypeName":"word"},{"id":85688,"position":20,"arabic":"حِسَابٍۢ","translation":"কোনো হিসাব","audioUrl":"wbw/002_212_022.mp3","charTypeName":"word"},{"id":85689,"position":21,"arabic":"٢١٢","translation":"(২১২)","audioUrl":null,"charTypeName":"end"}]},{"number":213,"arabic":"كَانَ ٱلنَّاسُ أُمَّةًۭ وَٰحِدَةًۭ فَبَعَثَ ٱللَّهُ ٱلنَّبِيِّۦنَ مُبَشِّرِينَ وَمُنذِرِينَ وَأَنزَلَ مَعَهُمُ ٱلْكِتَٰبَ بِٱلْحَقِّ لِيَحْكُمَ بَيْنَ ٱلنَّاسِ فِيمَا ٱخْتَلَفُوا۟ فِيهِ ۚ وَمَا ٱخْتَلَفَ فِيهِ إِلَّا ٱلَّذِينَ أُوتُوهُ مِنۢ بَعْدِ مَا جَآءَتْهُمُ ٱلْبَيِّنَٰتُ بَغْيًۢا بَيْنَهُمْ ۖ فَهَدَى ٱللَّهُ ٱلَّذِينَ ءَامَنُوا۟ لِمَا ٱخْتَلَفُوا۟ فِيهِ مِنَ ٱلْحَقِّ بِإِذْنِهِۦ ۗ وَٱللَّهُ يَهْدِى مَن يَشَآءُ إِلَىٰ صِرَٰطٍۢ مُّسْتَقِيمٍ","translation":"ALL MANKIND were once one single community; [then they began to differ -] whereupon God raised up the prophets as heralds of glad tidings and as warners, and through them bestowed revelation from on high, setting forth the truth, so that it might decide between people with regard to all on which they had come to hold divergent views. Yet none other than the selfsame people who had been granted this [revelation] began, out of mutual jealousy, to disagree about its meaning after all evidence of the truth had come unto them. But God guided the believers unto the truth about which, by His leave, they had disagreed: for God guides onto a straight way him that wills [to be guided].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/220.mp3","surahId":2,"words":[{"id":85690,"position":1,"arabic":"كَانَ","translation":"ছিল","audioUrl":"wbw/002_213_001.mp3","charTypeName":"word"},{"id":85691,"position":2,"arabic":"ٱلنَّاسُ","translation":"সব মানুষ","audioUrl":"wbw/002_213_002.mp3","charTypeName":"word"},{"id":85692,"position":3,"arabic":"أُمَّةًۭ","translation":"জাতি","audioUrl":"wbw/002_213_003.mp3","charTypeName":"word"},{"id":85693,"position":4,"arabic":"وَٰحِدَةًۭ","translation":"একই","audioUrl":"wbw/002_213_004.mp3","charTypeName":"word"},{"id":85694,"position":5,"arabic":"فَبَعَثَ","translation":"(তাদের পথভ্রষ্টতার) পাঠালেন","audioUrl":"wbw/002_213_005.mp3","charTypeName":"word"},{"id":85695,"position":6,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/002_213_006.mp3","charTypeName":"word"},{"id":85696,"position":7,"arabic":"ٱلنَّبِيِّـۧنَ","translation":"নবীদেরকে","audioUrl":"wbw/002_213_007.mp3","charTypeName":"word"},{"id":85697,"position":8,"arabic":"مُبَشِّرِينَ","translation":"সুসংবাদদাতা","audioUrl":"wbw/002_213_008.mp3","charTypeName":"word"},{"id":85698,"position":9,"arabic":"وَمُنذِرِينَ","translation":"ও সতর্ককারী (হিসেবে)","audioUrl":"wbw/002_213_009.mp3","charTypeName":"word"},{"id":85699,"position":10,"arabic":"وَأَنزَلَ","translation":"এবং অবতীর্ণ করলেন","audioUrl":"wbw/002_213_010.mp3","charTypeName":"word"},{"id":85700,"position":11,"arabic":"مَعَهُمُ","translation":"তাদের সাথে","audioUrl":"wbw/002_213_011.mp3","charTypeName":"word"},{"id":85701,"position":12,"arabic":"ٱلْكِتَـٰبَ","translation":"কিতাব","audioUrl":"wbw/002_213_012.mp3","charTypeName":"word"},{"id":85702,"position":13,"arabic":"بِٱلْحَقِّ","translation":"সত্য সহ","audioUrl":"wbw/002_213_013.mp3","charTypeName":"word"},{"id":85703,"position":14,"arabic":"لِيَحْكُمَ","translation":"তিনি মীমাংসা করতে পারেন যাতে","audioUrl":"wbw/002_213_014.mp3","charTypeName":"word"},{"id":85704,"position":15,"arabic":"بَيْنَ","translation":"মাঝে","audioUrl":"wbw/002_213_015.mp3","charTypeName":"word"},{"id":85705,"position":16,"arabic":"ٱلنَّاسِ","translation":"মানুষের","audioUrl":"wbw/002_213_016.mp3","charTypeName":"word"},{"id":85706,"position":17,"arabic":"فِيمَا","translation":"সে বিষয়ে যা","audioUrl":"wbw/002_213_017.mp3","charTypeName":"word"},{"id":85707,"position":18,"arabic":"ٱخْتَلَفُ