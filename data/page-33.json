{"id":33,"ayahs":[{"number":211,"arabic":"سَلْ بَنِىٓ إِسْرَٰٓءِيلَ كَمْ ءَاتَيْنَٰهُم مِّنْ ءَايَةٍۭ بَيِّنَةٍۢ ۗ وَمَن يُبَدِّلْ نِعْمَةَ ٱللَّهِ مِنۢ بَعْدِ مَا جَآءَتْهُ فَإِنَّ ٱللَّهَ شَدِيدُ ٱلْعِقَابِ","translation":"Ask the children of Israel how many a clear message We have given them! And if one alters God's blessed message after it has reached him - verily, God is severe in retribution!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/218.mp3","surahId":2,"words":[{"id":85634,"position":1,"arabic":"سَلْ","translation":"জিজ্ঞাসা করো","audioUrl":"wbw/002_211_001.mp3","charTypeName":"word"},{"id":85635,"position":2,"arabic":"بَنِىٓ","translation":"বনী","audioUrl":"wbw/002_211_002.mp3","charTypeName":"word"},{"id":85636,"position":3,"arabic":"إِسْرَٰٓءِيلَ","translation":"ইসরাঈলদেরকে","audioUrl":"wbw/002_211_003.mp3","charTypeName":"word"},{"id":85637,"position":4,"arabic":"كَمْ","translation":"কত","audioUrl":"wbw/002_211_004.mp3","charTypeName":"word"},{"id":85638,"position":5,"arabic":"ءَاتَيْنَـٰهُم","translation":"তাদেরকে দিয়েছি আমরা","audioUrl":"wbw/002_211_005.mp3","charTypeName":"word"},{"id":85639,"position":6,"arabic":"مِّنْ","translation":"থেকে","audioUrl":"wbw/002_211_006.mp3","charTypeName":"word"},{"id":85640,"position":7,"arabic":"ءَايَةٍۭ","translation":"নিদর্শন","audioUrl":"wbw/002_211_007.mp3","charTypeName":"word"},{"id":85641,"position":8,"arabic":"بَيِّنَةٍۢ ۗ","translation":"সুস্পষ্ট","audioUrl":"wbw/002_211_008.mp3","charTypeName":"word"},{"id":85643,"position":9,"arabic":"وَمَن","translation":"এবং যে","audioUrl":"wbw/002_211_010.mp3","charTypeName":"word"},{"id":85644,"position":10,"arabic":"يُبَدِّلْ","translation":"পরিবর্তন করে","audioUrl":"wbw/002_211_011.mp3","charTypeName":"word"},{"id":85645,"position":11,"arabic":"نِعْمَةَ","translation":"অনুগ্রহ","audioUrl":"wbw/002_211_012.mp3","charTypeName":"word"},{"id":85646,"position":12,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/002_211_013.mp3","charTypeName":"word"},{"id":85647,"position":13,"arabic":"مِنۢ","translation":"(এর)","audioUrl":"wbw/002_211_014.mp3","charTypeName":"word"},{"id":85648,"position":14,"arabic":"بَعْدِ","translation":"পর থেকে","audioUrl":"wbw/002_211_015.mp3","charTypeName":"word"},{"id":85649,"position":15,"arabic":"مَا","translation":"যা","audioUrl":"wbw/002_211_016.mp3","charTypeName":"word"},{"id":85650,"position":16,"arabic":"جَآءَتْهُ","translation":"তার কাছে এসেছে","audioUrl":"wbw/002_211_017.mp3","charTypeName":"word"},{"id":85651,"position":17,"arabic":"فَإِنَّ","translation":"তাহলে নিশ্চয়ই","audioUrl":"wbw/002_211_018.mp3","charTypeName":"word"},{"id":85652,"position":18,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/002_211_019.mp3","charTypeName":"word"},{"id":85653,"position":19,"arabic":"شَدِيدُ","translation":"কঠোর","audioUrl":"wbw/002_211_020.mp3","charTypeName":"word"},{"id":85654,"position":20,"arabic":"ٱلْعِقَابِ","translation":"(অন্যায়ের) শাস্তিদানে","audioUrl":"wbw/002_211_021.mp3","charTypeName":"word"},{"id":85655,"position":21,"arabic":"٢١١","translation":"(২১১)","audioUrl":null,"charTypeName":"end"}]},{"number":212,"arabic":"زُيِّنَ لِلَّذِينَ كَفَرُوا۟ ٱلْحَيَوٰةُ ٱلدُّنْيَا وَيَسْخَرُونَ مِنَ ٱلَّذِينَ ءَامَنُوا۟ ۘ وَٱلَّذِينَ ٱتَّقَوْا۟ فَوْقَهُمْ يَوْمَ ٱلْقِيَٰمَةِ ۗ وَٱللَّهُ يَرْزُقُ مَن يَشَآءُ بِغَيْرِ حِسَابٍۢ","translation":"Unto those who are bent on denying the truth the life of this world [alone] seems goodly; hence, they scoff at those who have attained to faith: but they who are conscious of God shall be above them on Resurrection Day. And God grants sustenance unto whom He wills, beyond all reckoning.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/219.mp3","surahId":2,"words":[{"id":85667,"position":1,"arabic":"زُيِّنَ","translation":"সুশোভিত করা হয়েছে","audioUrl":"wbw/002_212_001.mp3","charTypeName":"word"},{"id":85668,"position":2,"arabic":"لِلَّذِينَ","translation":"তাদের জন্যে","audioUrl":"wbw/002_212_002.mp3","char