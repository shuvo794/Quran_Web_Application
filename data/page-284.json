"id":28565,"position":8,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/017_026_008.mp3","charTypeName":"word"},{"id":28566,"position":9,"arabic":"تُبَذِّرْ","translation":"অপব্যয় করো","audioUrl":"wbw/017_026_009.mp3","charTypeName":"word"},{"id":28567,"position":10,"arabic":"تَبْذِيرًا","translation":"কোনো অপব্যয়","audioUrl":"wbw/017_026_010.mp3","charTypeName":"word"},{"id":28568,"position":11,"arabic":"٢٦","translation":"(২৬)","audioUrl":null,"charTypeName":"end"}]},{"number":27,"arabic":"إِنَّ ٱلْمُبَذِّرِينَ كَانُوٓا۟ إِخْوَٰنَ ٱلشَّيَٰطِينِ ۖ وَكَانَ ٱلشَّيْطَٰنُ لِرَبِّهِۦ كَفُورًۭا","translation":"Behold, the squanderers are, indeed, of the ilk of the satans - inasmuch as Satan has indeed proved most ungrateful to his Sustainer.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2056.mp3","surahId":17,"words":[{"id":29497,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/017_027_001.mp3","charTypeName":"word"},{"id":29498,"position":2,"arabic":"ٱلْمُبَذِّرِينَ","translation":"অপব্যয়কারীরা","audioUrl":"wbw/017_027_002.mp3","charTypeName":"word"},{"id":29499,"position":3,"arabic":"كَانُوٓا۟","translation":"হলো","audioUrl":"wbw/017_027_003.mp3","charTypeName":"word"},{"id":29500,"position":4,"arabic":"إِخْوَٰنَ","translation":"ভাই","audioUrl":"wbw/017_027_004.mp3","charTypeName":"word"},{"id":29501,"position":5,"arabic":"ٱلشَّيَـٰطِينِ ۖ","translation":"শয়তানদের","audioUrl":"wbw/017_027_005.mp3","charTypeName":"word"},{"id":29503,"position":6,"arabic":"وَكَانَ","translation":"এবং হলো","audioUrl":"wbw/017_027_007.mp3","charTypeName":"word"},{"id":29504,"position":7,"arabic":"ٱلشَّيْطَـٰنُ","translation":"শয়তান","audioUrl":"wbw/017_027_008.mp3","charTypeName":"word"},{"id":29505,"position":8,"arabic":"لِرَبِّهِۦ","translation":"প্রতি রবের তার","audioUrl":"wbw/017_027_009.mp3","charTypeName":"word"},{"id":29506,"position":9,"arabic":"كَفُورًۭا","translation":"বড়ই অকৃতজ্ঞ","audioUrl":"wbw/017_027_010.mp3","charTypeName":"w