{"id":284,"ayahs":[{"number":18,"arabic":"مَّن كَانَ يُرِيدُ ٱلْعَاجِلَةَ عَجَّلْنَا لَهُۥ فِيهَا مَا نَشَآءُ لِمَن نُّرِيدُ ثُمَّ جَعَلْنَا لَهُۥ جَهَنَّمَ يَصْلَىٰهَا مَذْمُومًۭا مَّدْحُورًۭا","translation":"Unto him who cares for [no more than the enjoyment of] this fleeting life We readily grant thereof as much as We please, [giving] to whomever it is Our will [to give]; but in the end We consign him to [the suffering of] hell; which he will have to endure disgraced and disowned!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2047.mp3","surahId":17,"words":[{"id":20102,"position":1,"arabic":"مَّن","translation":"যে","audioUrl":"wbw/017_018_001.mp3","charTypeName":"word"},{"id":20103,"position":2,"arabic":"كَانَ","translation":"ছিলো","audioUrl":"wbw/017_018_002.mp3","charTypeName":"word"},{"id":20104,"position":3,"arabic":"يُرِيدُ","translation":"চায়","audioUrl":"wbw/017_018_003.mp3","charTypeName":"word"},{"id":20105,"position":4,"arabic":"ٱلْعَاجِلَةَ","translation":"(সুখসম্ভোগ) পার্থিব","audioUrl":"wbw/017_018_004.mp3","charTypeName":"word"},{"id":20106,"position":5,"arabic":"عَجَّلْنَا","translation":"তাড়াতাড়ি দিই আমরা","audioUrl":"wbw/017_018_005.mp3","charTypeName":"word"},{"id":20107,"position":6,"arabic":"لَهُۥ","translation":"তাকে","audioUrl":"wbw/017_018_006.mp3","charTypeName":"word"},{"id":20108,"position":7,"arabic":"فِيهَا","translation":"মধ্যে তার","audioUrl":"wbw/017_018_007.mp3","charTypeName":"word"},{"id":20109,"position":8,"arabic":"مَا","translation":"যা","audioUrl":"wbw/017_018_008.mp3","charTypeName":"word"},{"id":20110,"position":9,"arabic":"نَشَآءُ","translation":"ইচ্ছে করি আমরা","audioUrl":"wbw/017_018_009.mp3","charTypeName":"word"},{"id":20111,"position":10,"arabic":"لِمَن","translation":"জন্যে যার","audioUrl":"wbw/017_018_010.mp3","charTypeName":"word"},{"id":20112,"position":11,"arabic":"نُّرِيدُ","translation":"আমরা চাই","audioUrl":"wbw/017_018_011.mp3","charTypeName":"word"},{"id":20113,"position":12,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/017_018_012.mp3","charTypeName":"word"},{"id":20114,"position":13,"arabic":"جَعَلْنَا","translation":"আমরা নির্ধারণ করি","audioUrl":"wbw/017_018_013.mp3","charTypeName":"word"},{"id":20115,"position":14,"arabic":"لَهُۥ","translation":"জন্যে তার","audioUrl":"wbw/017_018_014.mp3","charTypeName":"word"},{"id":20116,"position":15,"arabic":"جَهَنَّمَ","translation":"জাহান্নাম","audioUrl":"wbw/017_018_015.mp3","charTypeName":"word"},{"id":20117,"position":16,"arabic":"يَصْلَىٰهَا","translation":"সে উত্তপ্ত হবে","audioUrl":"wbw/017_018_016.mp3","charTypeName":"word"},{"id":20118,"position":17,"arabic":"مَذْمُومًۭا","translation":"নিন্দিত অবস্হায়","audioUrl":"wbw/017_018_017.mp3","charTypeName":"word"},{"id":20119,"position":18,"arabic":"مَّدْحُورًۭا","translation":"(অনুগ্রহ থেকে) বিতাড়িত হয়ে","audioUrl":"wbw/017_018_018.mp3","charTypeName":"word"},{"id":20120,"position":19,"arabic":"١٨","translation":"(১৮)","audioUrl":null,"charTypeName":"end"}]},{"number":19,"arabic":"وَمَنْ أَرَادَ ٱلْءَاخِرَةَ وَسَعَىٰ لَهَا سَعْيَهَا وَهُوَ مُؤْمِنٌۭ فَأُو۟لَٰٓئِكَ كَانَ سَعْيُهُم مَّشْكُورًۭا","translation":"But as for those who care for the [good of the] life to come, and strive for it as it ought to be striven for, and are [true] believers withal -they are the ones whose striving finds favour [with God]!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2048.mp3","surahId":17,"words":[{"id":21196,"position":1,"arabic":"وَمَنْ","translation":"এবং যে","audioUrl":"wbw/017_019_001.mp3","charTypeName":"word"},{"id":21197,"position":2,"arabic":"أَرَادَ","translation":"চেয়েছে","audioUrl":"wbw/017_019_002.mp3","charTypeName":"word"},{"id":21198,"position":3,"arabic":"ٱلْـَٔاخِرَةَ","translation":"আখিরাত","audioUrl":"wbw/017_019_003.mp3","charTypeName":"word"},{"id":21199,"position":4,"arabic":"وَسَعَىٰ","translation":"ও চেষ্টা করেছে","audioUrl":"wbw/017_019_004.mp3","charTypeName":"word"},{"id":21200,"position":5,"arabic":"لَهَا","translation":"জন্যে তার","audioUrl":"wbw/017_019_005.mp3","charTypeName":"word"},{"id":21201,"position":6,"arabic":"سَعْيَهَا","translation":"তার চেষ্টা","audioUrl":"wbw/017_019_006.mp3","charTypeName":"word"},{"id":21202,"position":7,"arabic":"وَهُوَ","translation":"যখন সে","audioUrl":"wbw/017_019_007.mp3","charTypeName":"word"},{"id":21203,"position":8,"arabic":"مُؤْمِنٌۭ","translation":"মু'মিনও","audioUrl":"wbw/017_019_008.mp3","charTypeName":"word"},{"id":21204,"position":9,"arabic":"فَأُو۟لَـٰٓئِكَ","translation":"সে ক্ষেত্রে ঐসব লোকদের","audioUrl":"wbw/017_019_009.mp3","charTypeName":"word"},{"id":21205,"position":10,"arabic":"كَانَ","translation":"হলো","audioUrl":"wbw/017_019_010.mp3","charTypeName":"word"},{"id":21206,"position":11,"arabic":"سَعْيُهُم","translation":"তাদের প্রচেষ্টা","audioUrl":"wbw/017_019_011.mp3","charTypeName":"word"},{"id":21207,"position":12,"arabic":"مَّشْكُورًۭا","translation":"স্বীকৃত","audioUrl":"wbw/017_019_012.mp3","charTypeName":"word"},{"id":21208,"position":13,"arabic":"١٩","translation":"(১৯)","audioUrl":null,"charTypeName":"end"}]},{"number":20,"arabic":"كُلًّۭا نُّمِدُّ هَٰٓؤُلَآءِ وَهَٰٓؤُلَآءِ مِنْ عَطَآءِ رَبِّكَ ۚ وَمَا كَانَ عَطَآءُ رَبِّكَ مَحْظُورًا","translation":"All [of them] -these as well as those -do We freely endow with some of thy Sustainer's gifts, since thy Sustainer's giving is never confined [to one kind of man].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2049.mp3","surahId":17,"words":[{"id":22311,"position":1,"arabic":"كُلًّۭا","translation":"আমরা প্রত্যেককে","audioUrl":"wbw/017_020_001.mp3","charTypeName":"word"},{"id":22312,"position":2,"arabic":"نُّمِدُّ","translation":"সাহায্য করি","audioUrl":"wbw/017_020_002.mp3","charTypeName":"word"},{"id":22313,"position":3,"arabic":"هَـٰٓؤُلَآءِ","translation":"এদেরকে","audioUrl":"wbw/017_020_003.mp3","charTypeName":"word"},{"id":22314,"position":4,"arabic":"وَهَـٰٓؤُلَآءِ","translation":"ও ওদেরকে","audioUrl":"wbw/017_020_004.mp3","charTypeName":"word"},{"id":22315,"position":5,"arabic":"مِنْ","translation":"থেকে","audioUrl":"wbw/017_020_005.mp3","charTypeName":"word"},{"id":22316,"position":6,"arabic":"عَطَآءِ","translation":"দান","audioUrl":"wbw/017_020_006.mp3","charTypeName":"word"},{"id":22317,"position":7,"arabic":"رَبِّكَ ۚ","translation":"তোমার রবের","audioUrl":"wbw/017_020_007.mp3","charTypeName":"word"},{"id":22319,"position":8,"arabic":"وَمَا","translation":"এবং নয়","audioUrl":"wbw/017_020_009.mp3","charTypeName":"word"},{"id":22320,"position":9,"arabic":"كَانَ","translation":"হলো","audioUrl":"wbw/017_020_010.mp3","charTypeName":"word"},{"id":22321,"position":10,"arabic":"عَطَآءُ","translation":"দান","audioUrl":"wbw/017_020_011.mp3","charTypeName":"word"},{"id":22322,"position":11,"arabic":"رَبِّكَ","translation":"তোমার রবের","audioUrl":"wbw/017_020_012.mp3","charTypeName":"word"},{"id":22323,"position":12,"arabic":"مَحْظُورًا","translation":"বারিত","audioUrl":"wbw/017_020_013.mp3","charTypeName":"word"},{"id":22324,"position":13,"arabic":"٢٠","translation":"(২০)","audioUrl":null,"charTypeName":"end"}]},{"number":21,"arabic":"ٱنظُرْ كَيْفَ فَضَّلْنَا بَعْضَهُمْ عَلَىٰ بَعْضٍۢ ۚ وَلَلْءَاخِرَةُ أَكْبَرُ دَرَجَٰتٍۢ وَأَكْبَرُ تَفْضِيلًۭا","translation":"Behold how We bestow [on earth) more bounty on some of them than on others: but [remember that] the life to come will be far higher in degree and far greater in merit and bounty.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2050.mp3","surahId":17,"words":[{"id":23430,"position":1,"arabic":"ٱنظُرْ","translation":"লক্ষ্য করো","audioUrl":"wbw/017_021_001.mp3","charTypeName":"word"},{"id":23431,"position":2,"arabic":"كَيْفَ","translation":"কিভাবে","audioUrl":"wbw/017_021_002.mp3","charTypeName":"word"},{"id":23432,"position":3,"arabic":"فَضَّلْنَا","translation":"শ্রেষ্ঠত্ব দিয়েছি আমরা","audioUrl":"wbw/017_021_003.mp3","charTypeName":"word"},{"id":23433,"position":4,"arabic":"بَعْضَهُمْ","translation":"কাউকে তাদেন","audioUrl":"wbw/017_021_004.mp3","charTypeName":"word"},{"id":23434,"position":5,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/017_021_005.mp3","charTypeName":"word"},{"id":23435,"position":6,"arabic":"بَعْضٍۢ ۚ","translation":"কারও","audioUrl":"wbw/017_021_006.mp3","charTypeName":"word"},{"id":23437,"position":7,"arabic":"وَلَلْـَٔاخِرَةُ","translation":"এবং অবশ্যই আখিরাত","audioUrl":"wbw/017_021_008.mp3","charTypeName":"word"},{"id":23438,"position":8,"arabic":"أَكْبَرُ","translation":"শ্রেষ্ঠ","audioUrl":"wbw/017_021_009.mp3","charTypeName":"word"},{"id":23439,"position":9,"arabic":"دَرَجَـٰتٍۢ","translation":"মর্যাদায়","audioUrl":"wbw/017_021_010.mp3","charTypeName":"word"},{"id":23440,"position":10,"arabic":"وَأَكْبَرُ","translation":"এবং শ্রেষ্ঠতর","audioUrl":"wbw/017_021_011.mp3","charTypeName":"word"},{"id":23441,"position":11,"arabic":"تَفْضِيلًۭا","translation":"শ্রেষ্ঠত্বেও","audioUrl":"wbw/017_021_012.mp3","charTypeName":"word"},{"id":23442,"position":12,"arabic":"٢١","translation":"(২১)","audioUrl":null,"charTypeName":"end"}]},{"number":22,"arabic":"لَّا تَجْعَلْ مَعَ ٱللَّهِ إِلَٰهًا ءَاخَرَ فَتَقْعُدَ مَذْمُومًۭا مَّخْذُولًۭا","translation":"DO NOT set up any other deity side by side with God, lest thou find thyself disgraced and forsaken:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2051.mp3","surahId":17,"words":[{"id":24414,"position":1,"arabic":"لَّا","translation":"না","audioUrl":"wbw/017_022_001.mp3","charTypeName":"word"},{"id":24415,"position":2,"arabic":"تَجْعَلْ","translation":"বানিয়ো","audioUrl":"wbw/017_022_002.mp3","charTypeName":"word"},{"id":24416,"position":3,"arabic":"مَعَ","translation":"সাথে","audioUrl":"wbw/017_022_003.mp3","charTypeName":"word"},{"id":24417,"position":4,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/017_022_004.mp3","charTypeName":"word"},{"id":24418,"position":5,"arabic":"إِلَـٰهًا","translation":"ইলাহ","audioUrl":"wbw/017_022_005.mp3","charTypeName":"word"},{"id":24419,"position":6,"arabic":"ءَاخَرَ","translation":"অন্য কাউকে","audioUrl":"wbw/017_022_006.mp3","charTypeName":"word"},{"id":24420,"position":7,"arabic":"فَتَقْعُدَ","translation":"তাহ'লে বসে পড়বে","audioUrl":"wbw/017_022_007.mp3","charTypeName":"word"},{"id":24421,"position":8,"arabic":"مَذْمُومًۭا","translation":"নিন্দিত অবস্হায়","audioUrl":"wbw/017_022_008.mp3","charTypeName":"word"},{"id":24422,"position":9,"arabic":"مَّخْذُولًۭا","translation":"অসহায়","audioUrl":"wbw/017_022_009.mp3","charTypeName":"word"},{"id":24423,"position":10,"arabic":"٢٢","translation":"(২২)","audioUrl":null,"charTypeName":"end"}]},{"number":23,"arabic":"۞ وَقَضَىٰ رَبُّكَ أَلَّا تَعْبُدُوٓا۟ إِلَّآ إِيَّاهُ وَبِٱلْوَٰلِدَيْنِ إِحْسَٰنًا ۚ إِمَّا يَبْلُغَنَّ عِندَكَ ٱلْكِبَرَ أَحَدُهُمَآ أَوْ كِلَاهُمَا فَلَا تَقُل لَّهُمَآ أُفٍّۢ وَلَا تَنْهَرْهُمَا وَقُل لَّهُمَا قَوْلًۭا كَرِيمًۭا","translation":"for thy Sustainer has ordained that you shall worship none but Him. And do good unto [thy] parents. Should one of them, or both, attain to old age in thy care, never say \"Ugh\" to them or scold them, but [always] speak unto them with reverent speech,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2052.mp3","surahId":17,"words":[{"id":25479,"position":1,"arabic":"۞ وَقَضَىٰ","translation":"এবং সিদ্ধান্ত দিয়েছেন","audioUrl":"wbw/017_023_002.mp3","charTypeName":"word"},{"id":25480,"position":2,"arabic":"رَبُّكَ","translation":"তোমার রব","audioUrl":"wbw/017_023_003.mp3","charTypeName":"word"},{"id":25481,"position":3,"arabic":"أَلَّا","translation":"যে না","audioUrl":"wbw/017_023_004.mp3","charTypeName":"word"},{"id":25482,"position":4,"arabic":"تَعْبُدُوٓا۟","translation":"তোমরা ইবাদাত করো","audioUrl":"wbw/017_023_005.mp3","charTypeName":"word"},{"id":25483,"position":5,"arabic":"إِلَّآ","translation":"ছাড়া","audioUrl":"wbw/017_023_006.mp3","charTypeName":"word"},{"id":25484,"position":6,"arabic":"إِيَّاهُ","translation":"শুধু তাঁকেই","audioUrl":"wbw/017_023_007.mp3","charTypeName":"word"},{"id":25485,"position":7,"arabic":"وَبِٱلْوَٰلِدَيْنِ","translation":"ও সাথে পিতা-মাতার","audioUrl":"wbw/017_023_008.mp3","charTypeName":"word"},{"id":25486,"position":8,"arabic":"إِحْسَـٰنًا ۚ","translation":"উত্তম ব্যবহারের","audioUrl":"wbw/017_023_009.mp3","charTypeName":"word"},{"id":25488,"position":9,"arabic":"إِمَّا","translation":"যদি","audioUrl":"wbw/017_023_011.mp3","charTypeName":"word"},{"id":25489,"position":10,"arabic":"يَبْلُغَنَّ","translation":"তারা পৌঁছে","audioUrl":"wbw/017_023_012.mp3","charTypeName":"word"},{"id":25490,"position":11,"arabic":"عِندَكَ","translation":"তোমার কাছে","audioUrl":"wbw/017_023_013.mp3","charTypeName":"word"},{"id":25491,"position":12,"arabic":"ٱلْكِبَرَ","translation":"বার্ধক্যে","audioUrl":"wbw/017_023_014.mp3","charTypeName":"word"},{"id":25492,"position":13,"arabic":"أَحَدُهُمَآ","translation":"তাদের দু'জনের একজন","audioUrl":"wbw/017_023_015.mp3","charTypeName":"word"},{"id":25493,"position":14,"arabic":"أَوْ","translation":"বা","audioUrl":"wbw/017_023_016.mp3","charTypeName":"word"},{"id":25494,"position":15,"arabic":"كِلَاهُمَا","translation":"তাদের উভয়ে","audioUrl":"wbw/017_023_017.mp3","charTypeName":"word"},{"id":25495,"position":16,"arabic":"فَلَا","translation":"তবে না","audioUrl":"wbw/017_023_018.mp3","charTypeName":"word"},{"id":25496,"position":17,"arabic":"تَقُل","translation":"তুমি বলবে","audioUrl":"wbw/017_023_019.mp3","charTypeName":"word"},{"id":25497,"position":18,"arabic":"لَّهُمَآ","translation":"তাদের দু'জনকে","audioUrl":"wbw/017_023_020.mp3","charTypeName":"word"},{"id":25498,"position":19,"arabic":"أُفٍّۢ","translation":"উহ","audioUrl":"wbw/017_023_021.mp3","charTypeName":"word"},{"id":25499,"position":20,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/017_023_022.mp3","charTypeName":"word"},{"id":25500,"position":21,"arabic":"تَنْهَرْهُمَا","translation":"তাদের দু'জনকে ধমক দিবে","audioUrl":"wbw/017_023_023.mp3","charTypeName":"word"},{"id":25501,"position":22,"arabic":"وَقُل","translation":"এবং বলবে","audioUrl":"wbw/017_023_024.mp3","charTypeName":"word"},{"id":25502,"position":23,"arabic":"لَّهُمَا","translation":"তাদের দু'জনকে","audioUrl":"wbw/017_023_025.mp3","charTypeName":"word"},{"id":25503,"position":24,"arabic":"قَوْلًۭا","translation":"কথা","audioUrl":"wbw/017_023_026.mp3","charTypeName":"word"},{"id":25504,"position":25,"arabic":"كَرِيمًۭا","translation":"সম্মানসূচক","audioUrl":"wbw/017_023_027.mp3","charTypeName":"word"},{"id":25505,"position":26,"arabic":"٢٣","translation":"(২৩)","audioUrl":null,"charTypeName":"end"}]},{"number":24,"arabic":"وَٱخْفِضْ لَهُمَا جَنَاحَ ٱلذُّلِّ مِنَ ٱلرَّحْمَةِ وَقُل رَّبِّ ٱرْحَمْهُمَا كَمَا رَبَّيَانِى صَغِيرًۭا","translation":"and spread over them humbly the wings of thy tenderness, and say: \"O my Sustainer! Bestow Thy grace upon them, even as they cherished and reared me when I was a child!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2053.mp3","surahId":17,"words":[{"id":26563,"position":1,"arabic":"وَٱخْفِضْ","translation":"নত করবে","audioUrl":"wbw/017_024_001.mp3","charTypeName":"word"},{"id":26564,"position":2,"arabic":"لَهُمَا","translation":"জন্যে তাদের দু'জনের","audioUrl":"wbw/017_024_002.mp3","charTypeName":"word"},{"id":26565,"position":3,"arabic":"جَنَاحَ","translation":"ডানা","audioUrl":"wbw/017_024_003.mp3","charTypeName":"word"},{"id":26566,"position":4,"arabic":"ٱلذُّلِّ","translation":"বিনয়ের","audioUrl":"wbw/017_024_004.mp3","charTypeName":"word"},{"id":26567,"position":5,"arabic":"مِنَ","translation":"সঙ্গে","audioUrl":"wbw/017_024_005.mp3","charTypeName":"word"},{"id":26568,"position":6,"arabic":"ٱلرَّحْمَةِ","translation":"অনুকম্পার","audioUrl":"wbw/017_024_006.mp3","charTypeName":"word"},{"id":26569,"position":7,"arabic":"وَقُل","translation":"এবং বলবে","audioUrl":"wbw/017_024_007.mp3","charTypeName":"word"},{"id":26570,"position":8,"arabic":"رَّبِّ","translation":"\"হে আমার রব","audioUrl":"wbw/017_024_008.mp3","charTypeName":"word"},{"id":26571,"position":9,"arabic":"ٱرْحَمْهُمَا","translation":"দু'জনকে দয়া করো তাদের","audioUrl":"wbw/017_024_009.mp3","charTypeName":"word"},{"id":26572,"position":10,"arabic":"كَمَا","translation":"যেমন","audioUrl":"wbw/017_024_010.mp3","charTypeName":"word"},{"id":26573,"position":11,"arabic":"رَبَّيَانِى","translation":"আমাকে দু'জনে পালন করেছে","audioUrl":"wbw/017_024_011.mp3","charTypeName":"word"},{"id":26574,"position":12,"arabic":"صَغِيرًۭا","translation":"ছেলেবেলায়\"","audioUrl":"wbw/017_024_012.mp3","charTypeName":"word"},{"id":26575,"position":13,"arabic":"٢٤","translation":"(২৪)","audioUrl":null,"charTypeName":"end"}]},{"number":25,"arabic":"رَّبُّكُمْ أَعْلَمُ بِمَا فِى نُفُوسِكُمْ ۚ إِن تَكُونُوا۟ صَٰلِحِينَ فَإِنَّهُۥ كَانَ لِلْأَوَّٰبِينَ غَفُورًۭا","translation":"Your Sustainer is fully aware of what is in your hearts. If you are righteous, [He will forgive you your errors]: for, behold, He is much-forgiving to those who turn unto Him again and again.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2054.mp3","surahId":17,"words":[{"id":27571,"position":1,"arabic":"رَّبُّكُمْ","translation":"তোমাদের রব","audioUrl":"wbw/017_025_001.mp3","charTypeName":"word"},{"id":27572,"position":2,"arabic":"أَعْلَمُ","translation":"খুব জানেন","audioUrl":"wbw/017_025_002.mp3","charTypeName":"word"},{"id":27573,"position":3,"arabic":"بِمَا","translation":"ঐ সম্বন্ধে যা","audioUrl":"wbw/017_025_003.mp3","charTypeName":"word"},{"id":27574,"position":4,"arabic":"فِى","translation":"মধ্যে আছে","audioUrl":"wbw/017_025_004.mp3","charTypeName":"word"},{"id":27575,"position":5,"arabic":"نُفُوسِكُمْ ۚ","translation":"তোমাদের অন্তরসমূহের","audioUrl":"wbw/017_025_005.mp3","charTypeName":"word"},{"id":27577,"position":6,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/017_025_007.mp3","charTypeName":"word"},{"id":27578,"position":7,"arabic":"تَكُونُوا۟","translation":"তোমরা হও","audioUrl":"wbw/017_025_008.mp3","charTypeName":"word"},{"id":27579,"position":8,"arabic":"صَـٰلِحِ