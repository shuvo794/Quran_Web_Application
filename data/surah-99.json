{"id":99,"nameArabic":"سُورَةُ الزَّلۡزَلَةِ","nameEnglish":"Az-Zalzala","nameTranslation":"The Earthquake","revelationType":"Medinan","numberOfAyahs":8,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ إِذَا زُلْزِلَتِ ٱلْأَرْضُ زِلْزَالَهَا","translation":"WHEN THE EARTH quakes with her [last] mighty quaking,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6139.mp3","surahId":99,"words":[{"id":55,"position":1,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/099_001_001.mp3","charTypeName":"word"},{"id":56,"position":2,"arabic":"زُلْزِلَتِ","translation":"প্রকম্পিত হবে","audioUrl":"wbw/099_001_002.mp3","charTypeName":"word"},{"id":57,"position":3,"arabic":"ٱلْأَرْضُ","translation":"পৃথিবী","audioUrl":"wbw/099_001_003.mp3","charTypeName":"word"},{"id":58,"position":4,"arabic":"زِلْزَالَهَا","translation":"তার (ভীষণ) কম্পনে","audioUrl":"wbw/099_001_004.mp3","charTypeName":"word"},{"id":59,"position":5,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"وَأَخْرَجَتِ ٱلْأَرْضُ أَثْقَالَهَا","translation":"and [when] the earth yields up her burdens,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6140.mp3","surahId":99,"words":[{"id":1839,"position":1,"arabic":"وَأَخْرَجَتِ","translation":"এবং বের করবে","audioUrl":"wbw/099_002_001.mp3","charTypeName":"word"},{"id":1840,"position":2,"arabic":"ٱلْأَرْضُ","translation":"পৃথিবী","audioUrl":"wbw/099_002_002.mp3","charTypeName":"word"},{"id":1841,"position":3,"arabic":"أَثْقَالَهَا","translation":"বোঝাগুলোকে তার","audioUrl":"wbw/099_002_003.mp3","charTypeName":"word"},{"id":1842,"position":4,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"وَقَالَ ٱلْإِنسَٰنُ مَا لَهَا","translation":"and man cries out, \"What has happened to her?\" -","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6141.mp3","surahId":99,"words":[{"id":2911,"position":1,"arabic":"وَقَالَ","translat