ic":"خَيْرًۭا","translation":"সৎকর্ম","audioUrl":"wbw/099_007_005.mp3","charTypeName":"word"},{"id":8359,"position":6,"arabic":"يَرَهُۥ","translation":"সে তা দেখবে","audioUrl":"wbw/099_007_006.mp3","charTypeName":"word"},{"id":8360,"position":7,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"وَمَن يَعْمَلْ مِثْقَالَ ذَرَّةٍۢ شَرًّۭا يَرَهُۥ","translation":"and he who shall have done an atom's weight of evil, shall behold it.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6146.mp3","surahId":99,"words":[{"id":9503,"position":1,"arabic":"وَمَن","translation":"এবং যে","audioUrl":"wbw/099_008_001.mp3","charTypeName":"word"},{"id":9504,"position":2,"arabic":"يَعْمَلْ","translation":"করবে","audioUrl":"wbw/099_008_002.mp3","charTypeName":"word"},{"id":9505,"position":3,"arabic":"مِثْقَالَ","translation":"পরিমাণ","audioUrl":"wbw/099_008_003.mp3","charTypeName":"word"},{"id":9506,"position":4,"arabic":"ذَرَّةٍۢ","translation":"অণু","audioUrl":"wbw/099_008_004.mp3","charTypeName":"word"},{"id":9507,"position":5,"arabic":"شَرًّۭا","translation":"অসৎকর্ম","audioUrl":"wbw/099_008_005.mp3","charTypeName":"word"},{"id":9508,"position":6,"arabic":"يَرَهُۥ","translation":"সে তা  দেখবে","audioUrl":"wbw/099_008_006.mp3","charTypeName":"word"},{"id":9509,"position":7,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]}]}