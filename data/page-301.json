TypeName":"word"},{"id":59851,"position":4,"arabic":"رَكِبَا","translation":"দু'জন চড়লো","audioUrl":"wbw/018_071_004.mp3","charTypeName":"word"},{"id":59852,"position":5,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/018_071_005.mp3","charTypeName":"word"},{"id":59853,"position":6,"arabic":"ٱلسَّفِينَةِ","translation":"একটি নৌকার","audioUrl":"wbw/018_071_006.mp3","charTypeName":"word"},{"id":59854,"position":7,"arabic":"خَرَقَهَا ۖ","translation":"তা সে ফুটো করে দিলো","audioUrl":"wbw/018_071_007.mp3","charTypeName":"word"},{"id":59856,"position":8,"arabic":"قَالَ","translation":"(মূসা) বললো","audioUrl":"wbw/018_071_009.mp3","charTypeName":"word"},{"id":59857,"position":9,"arabic":"أَخَرَقْتَهَا","translation":"\"তা আপনি কি ফুটো করে দিলেন","audioUrl":"wbw/018_071_010.mp3","charTypeName":"word"},{"id":59858,"position":10,"arabic":"لِتُغْرِقَ","translation":"জন্যে ডুবানোর","audioUrl":"wbw/018_071_011.mp3","charTypeName":"word"},{"id":59859,"position":11,"arabic":"أَهْلَهَا","translation":"তার আরোহীদেরকে","audioUrl":"wbw/018_071_012.mp3","charTypeName":"word"},{"id":59860,"position":12,"arabic":"لَقَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/018_071_013.mp3","charTypeName":"word"},{"id":59861,"position":13,"arabic":"جِئْتَ","translation":"আপনি করে এসেছেন","audioUrl":"wbw/018_071_014.mp3","charTypeName":"word"},{"id":59862,"position":14,"arabic":"شَيْـًٔا","translation":"কাজ","audioUrl":"wbw/018_071_015.mp3","charTypeName":"word"},{"id":59863,"position":15,"arabic":"إِمْرًۭا","translation":"গুরুতর\"","audioUrl":"wbw/018_071_016.mp3","charTypeName":"word"},{"id":59864,"position":16,"arabic":"٧١","translation":"(৭১)","audioUrl":null,"charTypeName":"end"}]},{"number":72,"arabic":"قَالَ أَلَمْ أَقُلْ إِنَّكَ لَن تَسْتَطِيعَ مَعِىَ صَبْرًۭا","translation":"He replied: \"Did I not tell thee that thou wilt never be able to have patience with me?\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2212.mp3","surahId":18,"words":[{"id":60847,"position":1,"ar