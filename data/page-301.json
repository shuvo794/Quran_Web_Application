":"তখন সে হত্যা করলো তাকে","audioUrl":"wbw/018_074_006.mp3","charTypeName":"word"},{"id":61650,"position":7,"arabic":"قَالَ","translation":"(মূসা) বললো","audioUrl":"wbw/018_074_007.mp3","charTypeName":"word"},{"id":61651,"position":8,"arabic":"أَقَتَلْتَ","translation":"\"কি আপনি হত্যা করলেন","audioUrl":"wbw/018_074_008.mp3","charTypeName":"word"},{"id":61652,"position":9,"arabic":"نَفْسًۭا","translation":"একটি জীবনকে","audioUrl":"wbw/018_074_009.mp3","charTypeName":"word"},{"id":61653,"position":10,"arabic":"زَكِيَّةًۢ","translation":"নিষ্পাপ","audioUrl":"wbw/018_074_010.mp3","charTypeName":"word"},{"id":61654,"position":11,"arabic":"بِغَيْرِ","translation":"ছাড়া (হত্যা)","audioUrl":"wbw/018_074_011.mp3","charTypeName":"word"},{"id":61655,"position":12,"arabic":"نَفْسٍۢ","translation":"কোনো জীবন","audioUrl":"wbw/018_074_012.mp3","charTypeName":"word"},{"id":61656,"position":13,"arabic":"لَّقَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/018_074_013.mp3","charTypeName":"word"},{"id":61657,"position":14,"arabic":"جِئْتَ","translation":"করে এসেছেন","audioUrl":"wbw/018_074_014.mp3","charTypeName":"word"},{"id":61658,"position":15,"arabic":"شَيْـًۭٔا","translation":"কাজ","audioUrl":"wbw/018_074_015.mp3","charTypeName":"word"},{"id":61659,"position":16,"arabic":"نُّكْرًۭا","translation":"গুরুতর অন্যায়\"","audioUrl":"wbw/018_074_016.mp3","charTypeName":"word"},{"id":61660,"position":17,"arabic":"٧٤","translation":"(৭৪)","audioUrl":null,"charTypeName":"end"}]}]}