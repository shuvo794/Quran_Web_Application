bic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/037_171_001.mp3","charTypeName":"word"},{"id":82987,"position":2,"arabic":"سَبَقَتْ","translation":"পূর্বে স্থির হয়েছে","audioUrl":"wbw/037_171_002.mp3","charTypeName":"word"},{"id":82988,"position":3,"arabic":"كَلِمَتُنَا","translation":"আমাদের বাণী (ওয়াদা)","audioUrl":"wbw/037_171_003.mp3","charTypeName":"word"},{"id":82989,"position":4,"arabic":"لِعِبَادِنَا","translation":"আমাদের দাসদের জন্যে","audioUrl":"wbw/037_171_004.mp3","charTypeName":"word"},{"id":82990,"position":5,"arabic":"ٱلْمُرْسَلِينَ","translation":"যারা প্রেরিত রাসূল","audioUrl":"wbw/037_171_005.mp3","charTypeName":"word"},{"id":82991,"position":6,"arabic":"١٧١","translation":"(১৭১)","audioUrl":null,"charTypeName":"end"}]},{"number":172,"arabic":"إِنَّهُمْ لَهُمُ ٱلْمَنصُورُونَ","translation":"that, verily, they - they indeed - would be succoured,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3960.mp3","surahId":37,"words":[{"id":83026,"position":1,"arabic":"إِنَّهُمْ","translation":"(ঐ বিষয়ে যে) তারা নিশ্চয়ই","audioUrl":"wbw/037_172_001.mp3","charTypeName":"word"},{"id":83027,"position":2,"arabic":"لَهُمُ","translation":"তারাই","audioUrl":"wbw/037_172_002.mp3","charTypeName":"word"},{"id":83028,"position":3,"arabic":"ٱلْمَنصُورُونَ","translation":"সাহায্যপ্রাপ্ত হবে","audioUrl":"wbw/037_172_003.mp3","charTypeName":"word"},{"id":83029,"position":4,"arabic":"١٧٢","translation":"(১৭২)","audioUrl":null,"charTypeName":"end"}]},{"number":173,"arabic":"وَإِنَّ جُندَنَا لَهُمُ ٱلْغَٰلِبُونَ","translation":"and that, verily, Our hosts - they indeed - would [in the end] be victorious!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3961.mp3","surahId":37,"words":[{"id":83215,"position":1,"arabic":"وَإِنَّ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/037_173_001.mp3","charTypeName":"word"},{"id":83216,"position":2,"arabic":"جُندَنَا","translation":"আমাদের সৈন্যরা","audioUrl":"wbw/037_173_002.mp3","charTypeName":"word"},{"id":83217,"position":3,"arabic":"لَهُمُ","translation":"তারাই","audioUrl":"wbw/037_173_003.mp3","charTypeName":"word"},{"id":83218,"position":4,"arabic":"ٱلْغَـٰلِبُونَ","translation":"বিজয়ী হবে","audioUrl":"wbw/037_173_004.mp3","charTypeName":"word"},{"id":83219,"position":5,"arabic":"١٧٣","translation":"(১৭৩)","audioUrl":null,"charTypeName":"end"}]},{"number":174,"arabic":"فَتَوَلَّ عَنْهُمْ حَتَّىٰ حِينٍۢ","translation":"Hence, turn thou aside for a while from those [who deny the truth],","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3962.mp3","surahId":37,"words":[{"id":83296,"position":1,"arabic":"فَتَوَلَّ","translation":"সুতরাং উপেক্ষা করো","audioUrl":"wbw/037_174_001.mp3","charTypeName":"word"},{"id":83297,"position":2,"arabic":"عَنْهُمْ","translation":"তাদেরকে","audioUrl":"wbw/037_174_002.mp3","charTypeName":"word"},{"id":83298,"position":3,"arabic":"حَتَّىٰ","translation":"পর্যন্ত","audioUrl":"wbw/037_174_003.mp3","charTypeName":"word"},{"id":83299,"position":4,"arabic":"حِينٍۢ","translation":"কিছুকাল","audioUrl":"wbw/037_174_004.mp3","charTypeName":"word"},{"id":83300,"position":5,"arabic":"١٧٤","translation":"(১৭৪)","audioUrl":null,"charTypeName":"end"}]},{"number":175,"arabic":"وَأَبْصِرْهُمْ فَسَوْفَ يُبْصِرُونَ","translation":"and see them [for what they are]; and in time they [too] will come to see [what they do not see now].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3963.mp3","surahId":37,"words":[{"id":83301,"position":1,"arabic":"وَأَبْصِرْهُمْ","translation":"এবং দেখতে থাকো তাদেরকে","audioUrl":"wbw/037_175_001.mp3","charTypeName":"word"},{"id":83302,"position":2,"arabic":"فَسَوْفَ","translation":"অতঃপর শীঘ্রই","audioUrl":"wbw/037_175_002.mp3","charTypeName":"word"},{"id":83303,"position":3,"arabic":"يُبْصِرُونَ","translation":"তারাই দেখবে","audioUrl":"wbw/037_175_003.mp3","charTypeName":"word"},{"id":83304,"position":4,"arabic":"١٧٥","translation":"(১৭৫)","audioUrl":null,"charTypeName":"end"}]},{"number":176,"arabic":"أَفَبِعَذَابِنَا يَسْتَعْجِلُونَ","translation":"Do they, then, [really] wish that Our chas­tisement be hastened on?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3964.mp3","surahId":37,"words":[{"id":83382,"position":1,"arabic":"أَفَبِعَذَابِنَا","translation":"আমাদের শাস্তি সম্পর্কে তবে কি","audioUrl":"wbw/037_176_001.mp3","charTypeName":"word"},{"id":83383,"position":2,"arabic":"يَسْتَعْجِلُونَ","translation":"তারা তাড়াহুড়া করছে","audioUrl":"wbw/037_176_002.mp3","charTypeName":"word"},{"id":83384,"position":3,"arabic":"١٧٦","translation":"(১৭৬)","audioUrl":null,"charTypeName":"end"}]},{"number":177,"arabic":"فَإِذَا نَزَلَ بِسَاحَتِهِمْ فَسَآءَ صَبَاحُ ٱلْمُنذَرِينَ","translation":"But then, once it alights upon them, hapless will be the awakening of those who were warned [to no avail]!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3965.mp3","surahId":37,"words":[{"id":83583,"position":1,"arabic":"فَإِذَا","translation":"অতঃপর যখন","audioUrl":"wbw/037_177_001.mp3","charTypeName":"word"},{"id":83584,"position":2,"arabic":"نَزَلَ","translation":"নেমে আসবে (তা)","audioUrl":"wbw/037_177_002.mp3","charTypeName":"word"},{"id":83585,"position":3,"arabic":"بِسَاحَتِهِمْ","translation":"তাদের আঙ্গিনায়","audioUrl":"wbw/037_177_003.mp3","charTypeName":"word"},{"id":83586,"position":4,"arabic":"فَسَآءَ","translation":"কত মন্দ হবে তখন","audioUrl":"wbw/037_177_004.mp3","charTypeName":"word"},{"id":83587,"position":5,"arabic":"صَبَاحُ","translation":"প্রভাত","audioUrl":"wbw/037_177_005.mp3","charTypeName":"word"},{"id":83588,"position":6,"arabic":"ٱلْمُنذَرِينَ","translation":"সতর্কীকৃতদের","audioUrl":"wbw/037_177_006.mp3","charTypeName":"word"},{"id":83589,"position":7,"arabic":"١٧٧","translation":"(১৭৭)","audioUrl":null,"charTypeName":"end"}]},{"number":178,"arabic":"وَتَوَلَّ عَنْهُمْ حَتَّىٰ حِينٍۢ","translation":"Hence, turn thou aside for a while from them,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3966.mp3","surahId":37,"words":[{"id":83605,"position":1,"arabic":"وَتَوَلَّ","translation":"উপেক্ষা করো এবং","audioUrl":"wbw/037_178_001.mp3","charTypeName":"word"},{"id":83606,"position":2,"arabic":"عَنْهُمْ","translation":"তাদেরকে","audioUrl":"wbw/037_178_002.mp3","charTypeName":"word"},{"id":83607,"position":3,"arabic":"حَتَّىٰ","translation":"পর্যন্ত","audioUrl":"wbw/037_178_003.mp3","charTypeName":"word"},{"id":83608,"position":4,"arabic":"حِينٍۢ","translation":"কিছুুকাল","audioUrl":"wbw/037_178_004.mp3","charTypeName":"word"},{"id":83609,"position":5,"arabic":"١٧٨","translation":"(১৭৮)","audioUrl":null,"charTypeName":"end"}]},{"number":179,"arabic":"وَأَبْصِرْ فَسَوْفَ يُبْصِرُونَ","translation":"and see [them for what they are]; and n time they [too] will come to see [what they do not see now].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3967.mp3","surahId":37,"words":[{"id":83771,"position":1,"arabic":"وَأَبْصِرْ","translation":"আর দেখতে থাকো","audioUrl":"wbw/037_179_001.mp3","charTypeName":"word"},{"id":83772,"position":2,"arabic":"فَسَوْفَ","translation":"শীঘ্র্রই","audioUrl":"wbw/037_179_002.mp3","charTypeName":"word"},{"id":83773,"position":3,"arabic":"يُبْصِرُونَ","translation":"তারাও দেখতে পাবে","audioUrl":"wbw/037_179_003.mp3","charTypeName":"word"},{"id":83774,"position":4,"arabic":"١٧٩","translation":"(১৭৯)","audioUrl":null,"charTypeName":"end"}]},{"number":180,"arabic":"سُبْحَٰنَ رَبِّكَ رَبِّ ٱلْعِزَّةِ عَمَّا يَصِفُونَ","translation":"LIMITLESS in His glory is thy Sustainer, the Lord of almightiness, [exalted] above anything that men may devise by way of definition!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3968.mp3","surahId":37,"words":[{"id":83805,"position":1,"arabic":"سُبْحَـٰنَ","translation":"পবিত্র","audioUrl":"wbw/037_180_001.mp3","charTypeName":"word"},{"id":83806,"position":2,"arabic":"رَبِّكَ","translation":"তোমার রব","audioUrl":"wbw/037_180_002.mp3","charTypeName":"word"},{"i