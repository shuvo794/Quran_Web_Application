{"id":452,"ayahs":[{"number":154,"arabic":"مَا لَكُمْ كَيْفَ تَحْكُمُونَ","translation":"What is amiss with you and your judgment?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3942.mp3","surahId":37,"words":[{"id":80946,"position":1,"arabic":"مَا","translation":"কি","audioUrl":"wbw/037_154_001.mp3","charTypeName":"word"},{"id":80947,"position":2,"arabic":"لَكُمْ","translation":"তোমাদের হয়েছে","audioUrl":"wbw/037_154_002.mp3","charTypeName":"word"},{"id":80948,"position":3,"arabic":"كَيْفَ","translation":"কেমন","audioUrl":"wbw/037_154_003.mp3","charTypeName":"word"},{"id":80949,"position":4,"arabic":"تَحْكُمُونَ","translation":"তোমরা বিচার করো","audioUrl":"wbw/037_154_004.mp3","charTypeName":"word"},{"id":80950,"position":5,"arabic":"١٥٤","translation":"(১৫৪)","audioUrl":null,"charTypeName":"end"}]},{"number":155,"arabic":"أَفَلَا تَذَكَّرُونَ","translation":"Will you not, then, bethink yourselves?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3943.mp3","surahId":37,"words":[{"id":81176,"position":1,"arabic":"أَفَلَا","translation":"তবে কি না","audioUrl":"wbw/037_155_001.mp3","charTypeName":"word"},{"id":81177,"position":2,"arabic":"تَذَكَّرُونَ","translation":"তোমরা উপদেশ গ্রহণ করবে","audioUrl":"wbw/037_155_002.mp3","charTypeName":"word"},{"id":81178,"position":3,"arabic":"١٥٥","translation":"(১৫৫)","audioUrl":null,"charTypeName":"end"}]},{"number":156,"arabic":"أَمْ لَكُمْ سُلْطَٰنٌۭ مُّبِينٌۭ","translation":"Or have you, perchance, a clear evidence [for your assertions]?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3944.mp3","surahId":37,"words":[{"id":81214,"position":1,"arabic":"أَمْ","translation":"অথবা","audioUrl":"wbw/037_156_001.mp3","charTypeName":"word"},{"id":81215,"position":2,"arabic":"لَكُمْ","translation":"তোমাদের (আছে)","audioUrl":"wbw/037_156_002.mp3","charTypeName":"word"},{"id":81216,"position":3,"arabic":"سُلْطَـٰنٌۭ","translation":"প্রমাণ","audioUrl":"wbw/037_156_003.mp3","charTypeName"