{"id":81617,"position":3,"arabic":"وَبَيْنَ","translation":"ও মাঝে","audioUrl":"wbw/037_158_003.mp3","charTypeName":"word"},{"id":81618,"position":4,"arabic":"ٱلْجِنَّةِ","translation":"জিনদের","audioUrl":"wbw/037_158_004.mp3","charTypeName":"word"},{"id":81619,"position":5,"arabic":"نَسَبًۭا ۚ","translation":"বংশীয় সম্পর্ক","audioUrl":"wbw/037_158_005.mp3","charTypeName":"word"},{"id":81621,"position":6,"arabic":"وَلَقَدْ","translation":"অথচ নিশ্চয়ই","audioUrl":"wbw/037_158_007.mp3","charTypeName":"word"},{"id":81622,"position":7,"arabic":"عَلِمَتِ","translation":"জেনেছে","audioUrl":"wbw/037_158_008.mp3","charTypeName":"word"},{"id":81623,"position":8,"arabic":"ٱلْجِنَّةُ","translation":"জিনরা","audioUrl":"wbw/037_158_009.mp3","charTypeName":"word"},{"id":81624,"position":9,"arabic":"إِنَّهُمْ","translation":"নিশ্চয়ই তাদেরকে","audioUrl":"wbw/037_158_010.mp3","charTypeName":"word"},{"id":81625,"position":10,"arabic":"لَمُحْضَرُونَ","translation":"অবশ্যই উপস্থিত করা হবে","audioUrl":"wbw/037_158_011.mp3","charTypeName":"word"},{"id":81626,"position":11,"arabic":"١٥٨","translation":"(১৫৮)","audioUrl":null,"charTypeName":"end"}]},{"number":159,"arabic":"سُبْحَٰنَ ٱللَّهِ عَمَّا يَصِفُونَ","translation":"limitless is God in His glory, above anything that men may devise by way of definition!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3947.mp3","surahId":37,"words":[{"id":81701,"position":1,"arabic":"سُبْحَـٰنَ","translation":"পবিত্র","audioUrl":"wbw/037_159_001.mp3","charTypeName":"word"},{"id":81702,"position":2,"arabic":"ٱللَّهِ","translation":"আল্লাহ","audioUrl":"wbw/037_159_002.mp3","charTypeName":"word"},{"id":81703,"position":3,"arabic":"عَمَّا","translation":"তা হ'তে যা","audioUrl":"wbw/037_159_003.mp3","charTypeName":"word"},{"id":81704,"position":4,"arabic":"يَصِفُونَ","translation":"তারা আরোপ করে","audioUrl":"wbw/037_159_004.mp3","charTypeName":"word"},{"id":81705,"position":5,"arabic":"١٥٩","translation":"(১৫৯)","audioUrl":null,"charTypeName":"end"}]},{"number":160,"arabic":"إِلَّا عِبَادَ ٱللَّهِ ٱلْمُخْلَصِينَ","translation":"Not thus, however, [behave] God’s true ser­vants:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3948.mp3","surahId":37,"words":[{"id":81741,"position":1,"arabic":"إِلَّا","translation":"তবে ব্যতিক্রম","audioUrl":"wbw/037_160_001.mp3","charTypeName":"word"},{"id":81742,"position":2,"arabic":"عِبَادَ","translation":"(ঐসব) দাস","audioUrl":"wbw/037_160_002.mp3","charTypeName":"word"},{"id":81743,"position":3,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/037_160_003.mp3","charTypeName":"word"},{"id":81744,"position":4,"arabic":"ٱلْمُخْلَصِينَ","translation":"(যারা) একনিষ্ঠ","audioUrl":"wbw/037_160_004.mp3","charTypeName":"word"},{"id":81745,"position":5,"arabic":"١٦٠","translation":"(১৬০)","audioUrl":null,"charTypeName":"end"}]},{"number":161,"arabic":"فَإِنَّكُمْ وَمَا تَعْبُدُونَ","translation":"for, verily, neither you [blasphemers] nor the objects of your worship","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3949.mp3","surahId":37,"words":[{"id":81884,"position":1,"arabic":"فَإِنَّكُمْ","translation":"সুতরাং তোমরা নিশ্চয়ই","audioUrl":"wbw/037_161_001.mp3","charTypeName":"word"},{"id":81885,"position":2,"arabic":"وَمَا","translation":"এবং যাদেরকে","audioUrl":"wbw/037_161_002.mp3","charTypeName":"word"},{"id":81886,"position":3,"arabic":"تَعْبُدُونَ","translation":"তোমরা উপাসনা করো","audioUrl":"wbw/037_161_003.mp3","charTypeName":"word"},{"id":81887,"position":4,"arabic":"١٦١","translation":"(১৬১)","audioUrl":null,"charTypeName":"end"}]},{"number":162,"arabic":"مَآ أَنتُمْ عَلَيْهِ بِفَٰتِنِينَ","translation":"can cause anyone to fall prey to your temptation","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3950.mp3","surahId":37,"words":[{"id":82062,"position":1,"arabic":"مَآ","translation":"না","audioUrl":"wbw/037_162_001.mp3","charTypeName":"word"},{"id":82063,"position":2,"arabic":"أَنتُمْ","translation":"তোমরা","audioUrl":"wbw/037_162_002.mp3","charTypeName":"word"},{"id":82064,"position":3,"arabic":"عَلَيْهِ","translation":"তাঁর সম্বন্ধে (কাউকে)","audioUrl":"wbw/037_162_003.mp3","charTypeName":"word"},{"id":82065,"position":4,"arabic":"بِفَـٰتِنِينَ","translation":"বিভ্রান্ত করতে পারবে","audioUrl":"wbw/037_162_004.mp3","charTypeName":"word"},{"id":82066,"position":5,"arabic":"١٦٢","translation":"(১৬২)","audioUrl":null,"charTypeName":"end"}]},{"number":163,"arabic":"إِلَّا مَنْ هُوَ صَالِ ٱلْجَحِيمِ","translation":"unless it be such as rushes towards the blazing fire [of his own accord]!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3951.mp3","surahId":37,"words":[{"id":82100,"position":1,"arabic":"إِلَّا","translation":"তবে (পারবে)","audioUrl":"wbw/037_163_001.mp3","charTypeName":"word"},{"id":82101,"position":2,"arabic":"مَنْ","translation":"তাকে","audioUrl":"wbw/037_163_002.mp3","charTypeName":"word"},{"id":82102,"position":3,"arabic":"هُوَ","translation":"যে","audioUrl":"wbw/037_163_003.mp3","charTypeName":"word"},{"id":82103,"position":4,"arabic":"صَالِ","translation":"প্রবেশকারী","audioUrl":"wbw/037_163_004.mp3","charTypeName":"word"},{"id":82104,"position":5,"arabic":"ٱلْجَحِيمِ","translation":"প্রজ্জ্বলিত আগুনে","audioUrl":"wbw/037_163_005.mp3","charTypeName":"word"},{"id":82105,"position":6,"arabic":"١٦٣","translation":"(১৬৩)","audioUrl":null,"charTypeName":"end"}]},{"number":164,"arabic":"وَمَا مِنَّآ إِلَّا لَهُۥ مَقَامٌۭ مَّعْلُومٌۭ","translation":"[All forces of nature praise God and say:] “Among us, too, there is none but has a place assigned to it [by Him];","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3952.mp3","surahId":37,"words":[{"id":82229,"position":1,"arabic":"وَمَا","translation":"\"এবং নাই","audioUrl":"wbw/037_164_001.mp3","charTypeName":"word"},{"id":82230,"position":2,"arabic":"مِنَّآ","translation":"আমাদের মধ্য কেউ","audioUrl":"wbw/037_164_002.mp3","charTypeName":"word"},{"id":82231,"position":3,"arabic":"إِلَّا","translation":"এ ব্যতীত যে","audioUrl":"wbw/037_164_003.mp3","charTypeName":"word"},{"id":82232,"position":4,"arabic":"لَهُۥ","translation":"তার জন্যে","audioUrl":"wbw/037_164_004.mp3","charTypeName":"word"},{"id":82233,"position":5,"arabic":"مَقَامٌۭ","translation":"স্থান","audioUrl":"wbw/037_164_005.mp3","charTypeName":"word"},{"id":82234,"position":6,"arabic":"مَّعْلُومٌۭ","translation":"নির্দিষ্ট (রয়েছে)","audioUrl":"wbw/037_164_006.mp3","charTypeName":"word"},{"id":82235,"position":7,"arabic":"١٦٤","translation":"(১৬৪)","audioUrl":null,"charTypeName":"end"}]},{"number":165,"arabic":"وَإِنَّا لَنَحْنُ ٱلصَّآفُّونَ","translation":"and, verily, we too are ranged [before Him in worship];","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3953.mp3","surahId":37,"words":[{"id":82426,"position":1,"arabic":"وَإِنَّا","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/037_165_001.mp3","charTypeName":"word"},{"id":82427,"position":2,"arabic":"لَنَحْنُ","translation":"আমরা অবশ্যই","audioUrl":"wbw/037_165_002.mp3","charTypeName":"word"},{"id":82428,"position":3,"arabic":"ٱلصَّآفُّونَ","translation":"সারি বেঁধে দাঁড়িয়ে আছি","audioUrl":"wbw/037_165_003.mp3","charTypeName":"word"},{"id":82429,"position":4,"arabic":"١٦٥","translation":"(১৬৫)","audioUrl":null,"charTypeName":"end"}]},{"number":166,"arabic":"وَإِنَّا لَنَحْنُ ٱلْمُسَبِّحُونَ","translation":"and, verily, we too extol His limitless glory!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3954.mp3","surahId":37,"words":[{"id":82489,"position":1,"arabic":"وَإِنَّا","translation":"এবং নিশ্চয়ই আমরা","audioUrl":"wbw/037_166_001.mp3","charTypeName":"word"},{"id":82490,"position":2,"arabic":"لَنَحْنُ","translation":"আমরা অবশ্যই","audioUrl":"wbw/037_166_002.mp3","charTypeName":"word"},{"id":82491,"position":3,"arabic":"ٱلْمُسَبِّحُونَ","translation":"মহিমা ঘোষণাকারী\"","audioUrl":"wbw/037_166_003.mp3","charTypeName":"word"},{"id":82492,"position":4,"arabic":"١٦٦","translation":"(১৬৬)","audioUrl":null,"charTypeName":"end"}]},{"number":167,"arabic":"وَإِن كَانُوا۟ لَيَقُولُونَ","translation":"AND, INDEED, they [who deny the truth] have always been wont to say,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3955.mp3","surahId":37,"words":[{"id":82543,"position":1,"arabic":"وَإِن","translation":"এবং যদিও","audioUrl":"wbw/037_167_001.mp3","charTypeName":"word"},{"id":82544,"position":2,"arabic":"كَانُوا۟","translation":"(তারা)","audioUrl":"wbw/037_167_002.mp3","charTypeName":"word"},{"id":82545,"position":3,"arabic":"لَيَقُولُونَ","translation":"তারা বলেই আসছে","audioUrl":"wbw/037_167_003.mp3","charTypeName":"word"},{"id":82546,"position":4,"arabic":"١٦٧","translation":"(১৬৭)","audioUrl":null,"charTypeName":"end"}]},{"number":168,"arabic":"لَوْ أَنَّ عِندَنَا ذِكْرًۭا مِّنَ ٱلْأَوَّلِينَ","translation":"“If only we had a tradition [to this effect] from our forebears,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3956.mp3","surahId":37,"words":[{"id":82634,"position":1,"arabic":"لَوْ","translation":"\"যদি","audioUrl":"wbw/037_168_001.mp3","charTypeName":"word"},{"id":82635,"position":2,"arabic":"أَنَّ","translation":"নিশ্চিত","audioUrl":"wbw/037_168_002.mp3","charTypeName":"word"},{"id":82636,"position":3,"arabic":"عِندَنَا","translation":"আমাদের কাছে","audioUrl":"wbw/037_168_003.mp3","charTypeName":"word"},{"id":82637,"position":4,"arabic":"ذِكْرًۭا","translation":"কোনো কিতাব","audioUrl":"wbw/037_168_004.mp3","charTypeName":"word"},{"id":82638,"position":5,"arabic":"مِّنَ","translation":"মতো","audioUrl":"wbw/037_168_005.mp3","charTypeName":"word"},{"id":82639,"position":6,"arabic":"ٱلْأَوَّلِينَ","translation":"পূর্ববর্তীদের","audioUrl":"wbw/037_168_006.mp3","charTypeName":"word"},{"id":82640,"position":7,"arabic":"١٦٨","translation":"(১৬৮)","audioUrl":null,"charTypeName":"end"}]},{"number":169,"arabic":"لَكُنَّا عِبَادَ ٱللَّهِ ٱلْمُخْلَصِينَ","translation":"we would certainly be true servants of God.”","audio":"h