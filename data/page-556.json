{"id":556,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ يُسَبِّحُ لِلَّهِ مَا فِى ٱلسَّمَٰوَٰتِ وَمَا فِى ٱلْأَرْضِ ۖ لَهُ ٱلْمُلْكُ وَلَهُ ٱلْحَمْدُ ۖ وَهُوَ عَلَىٰ كُلِّ شَىْءٍۢ قَدِيرٌ","translation":"ALL THAT IS in the heavens and all that is on earth extols God's limitless glory: His is all dominion, and to Him all praise is due; and He has the power to will anything.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5200.mp3","surahId":64,"words":[{"id":488,"position":1,"arabic":"يُسَبِّحُ","translation":"মহিমা ঘোষণা করে","audioUrl":"wbw/064_001_001.mp3","charTypeName":"word"},{"id":489,"position":2,"arabic":"لِلَّهِ","translation":"আল্লাহ্‌র জন্যে","audioUrl":"wbw/064_001_002.mp3","charTypeName":"word"},{"id":490,"position":3,"arabic":"مَا","translation":"যা","audioUrl":"wbw/064_001_003.mp3","charTypeName":"word"},{"id":491,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/064_001_004.mp3","charTypeName":"word"},{"id":492,"position":5,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আসমানসমূহের","audioUrl":"wbw/064_001_005.mp3","charTypeName":"word"},{"id":493,"position":6,"arabic":"وَمَا","translation":"ও যা","audioUrl":"wbw/064_001_006.mp3","charTypeName":"word"},{"id":494,"position":7,"arabic":"فِى","translation":"মধ্যে (আছে)","audioUrl":"wbw/064_001_007.mp3","charTypeName":"word"},{"id":495,"position":8,"arabic":"ٱلْأَرْضِ ۖ","translation":"পৃথিবীর","audioUrl":"wbw/064_001_008.mp3","charTypeName":"word"},{"id":497,"position":9,"arabic":"لَهُ","translation":"তাঁরই জন্যে","audioUrl":"wbw/064_001_010.mp3","charTypeName":"word"},{"id":498,"position":10,"arabic":"ٱلْمُلْكُ","translation":"সার্বভৌমত্ব","audioUrl":"wbw/064_001_011.mp3","charTypeName":"word"},{"id":499,"position":11,"arabic":"وَلَهُ","translation":"ও তাঁর জন্যেই","audioUrl":"wbw/064_001_012.mp3","charTypeName":"word"},{"id":500,"position":12,"arabic":"ٱلْحَمْدُ ۖ","translation":"সব প্রশংসা","audioUrl":"wbw/064_001_013.mp3","charTypeName":"word"},{"id":502,"position":13,"arabic":"وَهُوَ","translation":"ও তিনিই","audioUrl":"wbw/064_001_015.mp3","charTypeName":"word"},{"id":503,"position":14,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/064_001_016.mp3","charTypeName":"word"},{"id":504,"position":15,"arabic":"كُلِّ","translation":"সব","audioUrl":"wbw/064_001_017.mp3","charTypeName":"word"},{"id":505,"position":16,"arabic":"شَىْءٍۢ","translation":"কিছুর","audioUrl":"wbw/064_001_018.mp3","charTypeName":"word"},{"id":506,"position":17,"arabic":"قَدِيرٌ","translation":"ক্ষমতাবান","audioUrl":"wbw/064_001_019.mp3","charTypeName":"word"},{"id":507,"position":18,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"هُوَ ٱلَّذِى خَلَقَكُمْ فَمِنكُمْ كَافِرٌۭ وَمِنكُم مُّؤْمِنٌۭ ۚ وَٱللَّهُ بِمَا تَعْمَلُونَ بَصِيرٌ","translation":"He it is who has created you: and among you are such as deny this truth, and among you are such as believe [in it]. And God sees all that you do.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5201.mp3","surahId":64,"words":[{"id":1379,"position":1,"arabic":"هُوَ","translation":"তিনিই","audioUrl":"wbw/064_002_001.mp3","charTypeName":"word"},{"id":1380,"position":2,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/064_002_002.mp3","charTypeName":"word"},{"id":1381,"position":3,"arabic":"خَلَقَكُمْ","translation":"তোমাদের সৃষ্টি করেছেন","audioUrl":"wbw/064_002_003.mp3","charTypeName":"word"},{"id":1382,"position":4,"arabic":"فَمِنكُمْ","translation":"অতঃপর তোমাদের  মধ্যে","audioUrl":"wbw/064_002_004.mp3","charTypeName":"word"},{"id":1383,"position":5,"arabic":"كَافِرٌۭ","translation":"(কেউ) কাফির","audioUrl":"wbw/064_002_005.mp3","charTypeName":"word"},{"id":1384,"position":6,"arabic":"وَمِنكُم","translation":"আবার তোমাদের মধ্যে","audioUrl":"wbw/064_002_006.mp3","charTypeName":"word"},{"id":1385,"position":7,"arabic":"مُّؤْمِنٌۭ ۚ","translation":"(কেউ) মু'মিন","audioUrl":"wbw/064_002_007.mp3","charTypeName":"word"},{"id":1387,"position":8,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ্‌","audioUrl":"wbw/064_002_009.mp3","charTypeName":"word"},{"id":1388,"position":9,"arabic":"بِمَا","translation":"যা কিছু","audioUrl":"wbw/064_002_010.mp3","charTypeName":"word"},{"id":1389,"position":10,"arabic":"تَعْمَلُونَ","translation":"তোমরা কাজ কর","audioUrl":"wbw/064_002_011.mp3","charTypeName":"word"},{"id":1390,"position":11,"arabic":"بَصِيرٌ","translation":"সব দেখেন","audioUrl":"wbw/064_002_012.mp3","charTypeName":"word"},{"id":1391,"position":12,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"خَلَقَ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضَ بِٱلْحَقِّ وَصَوَّرَكُمْ فَأَحْسَنَ صُوَرَكُمْ ۖ وَإِلَيْهِ ٱلْمَصِيرُ","translation":"He has created the heavens and the earth in accordance with [an inner] truth, and has formed you - and formed you so well; and with Him is your journey's end.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5202.mp3","surahId":64,"words":[{"id":2438,"position":1,"arabic":"خَلَقَ","translation":"তিনি সৃষ্টি করেছেন","audioUrl":"wbw/064_003_001.mp3","charTypeName":"word"},{"id":2439,"position":2,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশসমূহ","audioUrl":"wbw/064_003_002.mp3","charTypeName":"word"},{"id":2440,"position":3,"arabic":"وَٱلْأَرْضَ","translation":"ও পৃথিবীকে","audioUrl":"wbw/064_003_003.mp3","charTypeName":"word"},{"id":2441,"position":4,"arabic":"بِٱلْحَقِّ","translation":"যথাযথভাবে","audioUrl":"wbw/064_003_004.mp3","charTypeName":"word"},{"id":2442,"position":5,"arabic":"وَصَوَّرَكُمْ","translation":"ও তোমাদের আকৃতি দিয়েছেন","audioUrl":"wbw/064_003_005.mp3","charTypeName":"word"},{"id":2443,"position":6,"arabic":"فَأَحْسَنَ","translation":"অতঃপর অতি উত্তম  করেছেন","audioUrl":"wbw/064_003_006.mp3","charTypeName":"word"},{"id":2444,"position":7,"arabic":"صُوَرَكُمْ ۖ","translation":"তোমাদের আকৃতি গুলো","audioUrl":"wbw/064_003_007.mp3","charTypeName":"word"},{"id":2446,"position":8,"arabic":"وَإِلَيْهِ","translation":"এবং তাঁরই নিকট","audioUrl":"wbw/064_003_009.mp3","charTypeName":"word"},{"id":2447,"position":9,"arabic":"ٱلْمَصِيرُ","translation":"প্রত্যাবর্তন স্থল","audioUrl":"wbw/064_003_010.mp3","charTypeName":"word"},{"id":2448,"position":10,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"يَعْلَمُ مَا فِى ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ وَيَعْلَمُ مَا تُسِرُّونَ وَمَا تُعْلِنُونَ ۚ وَٱللَّهُ عَلِيمٌۢ بِذَاتِ ٱلصُّدُورِ","translation":"He knows all that is in the heavens and on earth; and He knows all that you keep secret as well as all that you bring into the open: for God has full knowledge of what is in the hearts [of men].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5203.mp3","surahId":64,"words":[{"id":3851,"position":1,"arabic":"يَعْلَمُ","translation":"তিনি জানেন","audioUrl":"wbw/064_004_001.mp3","charTypeName":"word"},{"id":3852,"position":2,"arabic":"مَا","translation":"যা","audioUrl":"wbw/064_004_002.mp3","charTypeName":"word"},{"id":3853,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/064_004_003.mp3","charTypeName":"word"},{"id":3854,"position":4,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশ জগতের","audioUrl":"wbw/064_004_004.mp3","charTypeName":"word"},{"id":3855,"position":5,"arabic":"وَٱلْأَرْضِ","translation":"ও পৃৃথিবীর","audioUrl":"wbw/064_004_005.mp3","charTypeName":"word"},{"id":3856,"position":6,"arabic":"وَيَعْلَمُ","translation":"ও তিনি জানেন","audioUrl":"wbw/064_004_006.mp3","charTypeName":"word"},{"id":3857,"position":7,"arabic":"مَا","translation":"যা","audioUrl":"wbw/064_004_007.mp3","charTypeName":"word"},{"id":3858,"position":8,"arabic":"تُسِرُّونَ","translation":"তোমরা গোপন","audioUrl":"wbw/064_004_008.mp3","charTypeName":"word"},{"id":3859,"position":9,"arabic":"وَمَا","translation":"ও যা","audioUrl":"wbw/064_004_009.mp3","charTypeName":"word"},{"id":3860,"position":10,"arabic":"تُعْلِنُونَ ۚ","translation":"তোমরা প্রকাশ কর","audioUrl":"wbw/064_004_010.mp3","charTypeName":"word"},{"id":3862,"position":11,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ্‌","audioUrl":"wbw/064_004_012.mp3","charTypeName":"word"},{"id":3863,"position":12,"arabic":"عَلِيمٌۢ","translation":"খুব জানেন","audioUrl":"wbw/064_004_013.mp3","charTypeName":"word"},{"id":3864,"position":13,"arabic":"بِذَاتِ","translation":"অবস্থা সম্পর্কে","audioUrl":"wbw/064_004_014.mp3","charTypeName":"word"},{"id":3865,"position":14,"arabic":"ٱلصُّدُورِ","translation":"অন্তরসমূহের","audioUrl":"wbw/064_004_015.mp3","charTypeName":"word"},{"id":3866,"position":15,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"أَلَمْ يَأْتِكُمْ نَبَؤُا۟ ٱلَّذِينَ كَفَرُوا۟ مِن قَبْلُ فَذَاقُوا۟ وَبَالَ أَمْرِهِمْ وَلَهُمْ عَذَابٌ أَلِيمٌۭ","translation":"HAVE THE STORIES of those who, in earlier times, refused to acknowledge the truth never yet come within your ken? [They denied it -] and so they had to taste the evil outcome of their own doings, with [more] grievous suffering awaiting them [in the life to come]:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5204.mp3","surahId":64,"words":[{"id":5111,"position":1,"arabic":"أَلَمْ","translation":"নাই কি","audioUrl":"wbw/064_005_001.mp3","charTypeName":"word"},{"id":5112,"position":2,"arabic":"يَأْتِكُمْ","translation":"তোমাদের কাছে আসে","audioUrl":"wbw/064_005_002.mp3","charTypeName":"word"},{"id":5113,"position":3,"arabic":"نَبَؤُا۟","translation":"খবর","audioUrl":"wbw/064_005_003.mp3","charTypeName":"word"},{"id":5114,"position":4,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/064_005_004.mp3","charTypeName":"word"},{"id":5115,"position":5,"arabic":"كَفَرُوا۟","translation":"কুফরি করেছিল","audioUrl":"wbw/064_005_005.mp3","charTypeName":"word"},{"id":5116,"position":6,"arabic":"مِن","translation":"মধ্য হতে","audioUrl":"wbw/064_005_006.mp3","charTypeName":"word"},{"id":5117,"position":7,"arabic":"قَبْلُ","translation":"ইতিপূর্বে","audioUrl":"wbw/064_005_007.mp3","charTypeName":"word"},{"id":5118,"position":8,"arabic":"فَذَاقُوا۟","translation":"অতঃপর তারা স্বাদ নিয়েছে","audioUrl":"wbw/064_005_008.mp3","charTypeName":"word"},{"id":5119,"position":9,"arabic":"وَبَالَ","translation":"কুফল","audioUrl":"wbw/064_005_009.mp3","charTypeName":"word"},{"id":5120,"position":10,"arabic":"أَمْرِهِمْ","translation":"তাদের কাজের","audioUrl":"wbw/064_005_010.mp3","charTypeName":"word"},{"id":5121,"position":11,"arabic":"وَلَهُمْ","translation":"এবং তাদের জন্যে","audioUrl":"wbw/064_005_011.mp3","charTypeName":"word"},{"id":5122,"position":12,"arabic":"عَذَابٌ","translation":"আযাব","audioUrl":"wbw/064_005_012.mp3","charTypeName":"word"},{"id":5123,"position":13,"arabic":"أَلِيمٌۭ","translation":"যন্ত্রনাদায়ক","audioUrl":"wbw/064_005_013.mp3","charTypeName":"word"},{"id":5124,"position":14,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"ذَٰلِكَ بِأَنَّهُۥ كَانَت تَّأْتِيهِمْ رُسُلُهُم بِٱلْبَيِّنَٰتِ فَقَالُوٓا۟ أَبَشَرٌۭ يَهْدُونَنَا فَكَفَرُوا۟ وَتَوَلَّوا۟ ۚ وَّٱسْتَغْنَى ٱللَّهُ ۚ وَٱللَّهُ غَنِىٌّ حَمِيدٌۭ","translation":"this, because time and again there came unto them their apostles with all evidence of the truth, but they [always] replied, \"Shall mere mortal men be our guides?\" And so they. denied the truth and turned away. But God was not in need [of them]: for God is self-sufficient, ever to be praised.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5205.mp3","surahId":64,"words":[{"id":6373,"position":1,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/064_006_001.mp3","charTypeName":"word"},{"id":6374,"position":2,"arabic":"بِأَنَّهُۥ","translation":"এ জন্যে যে","audioUrl":"wbw/064_006_002.mp3","charTypeName":"word"},{"id":6375,"position":3,"arabic":"كَانَت","translation":"(ছিল)","audioUrl":"wbw/064_006_003.mp3","charTypeName":"word"},{"id":6376,"position":4,"arabic":"تَّأْتِيهِمْ","translation":"তাদের কাছে আসতো","audioUrl":"wbw/064_006_004.mp3","charTypeName":"word"},{"id":6377,"position":5,"arabic":"رُسُلُهُم","translation":"তাদের রাসূলগণ","audioUrl":"wbw/064_006_005.mp3","charTypeName":"word"},{"id":6378,"position":6,"arabic":"بِٱلْبَيِّنَـٰتِ","translation":"স্পষ্ট নিদর্শনাদিসহ","audioUrl":"wbw/064_006_006.mp3","charTypeName":"word"},{"id":6379,"position":7,"arabic":"فَقَالُوٓا۟","translation":"অতঃপর তারা বলেছিল","audioUrl":"wbw/064_006_007.mp3","charTypeName":"word"},{"id":6380,"position":8,"arabic":"أَبَشَرٌۭ","translation":"\"মানুষই কি","audioUrl":"wbw/064_006_008.mp3","charTypeName":"word"},{"id":6381,"position":9,"arabic":"يَهْدُونَنَا","translation":"আমাদেরকে পথ দেখাবে\"","audioUrl":"wbw/064_006_009.mp3","charTypeName":"word"},{"id":6382,"position":10,"arabic":"فَكَفَرُوا۟","translation":"এভাবে তারা কুফরি  করল","audioUrl":"wbw/064_006_010.mp3","charTypeName":"word"},{"id":6383,"position":11,"arabic":"وَتَوَلَّوا۟ ۚ","translation":"ও তারা মুখ ফিরালো","audioUrl":"wbw/064_006_011.mp3","charTypeName":"word"},{"id":6385,"position":12,"arabic":"وَّٱسْتَغْنَى","translation":"ও বেপরোয়া হলেন","audioUrl":"wbw/064_006_013.mp3","charTypeName":"word"},{"id":6386,"position":13,"arabic":"ٱللَّهُ ۚ","translation":"আল্লাহ্‌","audioUrl":"wbw/064_006_014.mp3","charTypeName":"word"},{"id":6388,"position":14,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ্‌","audioUrl":"wbw/064_006_016.mp3","charTypeName":"word"},{"id":6389,"position":15,"arabic":"غَنِىٌّ","translation":"পরোয়াহীন","audioUrl":"wbw/064_006_017.mp3","charTypeName":"word"},{"id":6390,"position":16,"arabic":"حَمِيدٌۭ","translation":"সুপ্রশংসিত","audioUrl":"wbw/064_006_018.mp3","charTypeName":"word"},{"id":6391,"position":17,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"زَعَمَ ٱلَّذِينَ كَفَرُوٓا۟ أَن لَّن يُبْعَثُوا۟ ۚ قُلْ بَلَىٰ وَرَبِّى لَتُبْعَثُنَّ ثُمَّ لَتُنَبَّؤُنَّ بِمَا عَمِلْتُمْ ۚ وَذَٰلِكَ عَلَى ٱللَّهِ يَسِيرٌۭ","translation":"They who are bent on denying the truth claim that they will never be raised from the dead! Say: \"Yea, by my Sustainer! Most surely will you be raised from the dead, and then, most surely, will you be made to understand what you did [in life]! For, easy is this for God!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5206.mp3","surahId":64,"words":[{"id":7791,"position":1,"arabic":"زَعَمَ","translation":"দাবী করে","audioUrl":"wbw/064_007_001.mp3","charTypeName":"word"},{"id":7792,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/064_007_002.mp3","charTypeName":"word"},{"id":7793,"position":3,"arabic":"كَفَرُوٓا۟","translation":"কুফরি করেছে","audioUrl":"wbw/064_007_003.mp3","charTypeName":"word"},{"id":7794,"position":4,"arabic":"أَن","translation":"যে","audioUrl":"wbw/064_007_004.mp3","charTypeName":"word"},{"id":7795,"position":5,"arabic":"لَّن","translation":"কক্ষনো না","audioUrl":"wbw/064_007_005.mp3","charTypeName":"word"},{"id":7796,"position":6,"arabic":"يُبْعَثُوا۟ ۚ","translation":"তাদের পুনরায় উঠানো হবে","audioUrl":"wbw/064_007_006.mp3","charTypeName":"word"},{"id":7798,"position":7,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/064_007_008.mp3","charTypeName":"word"},{"id":7799,"position":8,"arabic":"بَلَىٰ","translation":"\"অবশ্যই হবে","audioUrl":"wbw/064_007_009.mp3","charTypeName":"word"},{"id":7800,"position":9,"arabic":"وَرَبِّى","translation":"কসম আমার রবের","audioUrl":"wbw/064_007_010.mp3","charTypeName":"word"},{"id":7801,"position":10,"arabic":"لَتُبْعَثُنَّ","translation":"অবশ্যই তোমাদের  উঠানো হবে","audioUrl":"wbw/064_007_011.mp3","charTypeName":"word"},{"id":7802,"position":11,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/064_007_012.mp3","charTypeName":"word"},{"id":7803,"position":12,"arabic":"لَتُنَبَّؤُنَّ","translation":"অবশ্যই তোমাদের খবর দেয়া হবে","audioUrl":"wbw/064_007_013.mp3","charTypeName":"word"},{"id":7804,"position":13,"arabic":"بِمَا","translation":"যা কিছুু","audioUrl":"wbw/064_007_014.mp3","charTypeName":"word"},{"id":7805,"position":14,"arabic":"عَمِلْتُمْ