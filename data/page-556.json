","charTypeName":"word"},{"id":8967,"position":8,"arabic":"بِمَا","translation":"যা কিছু","audioUrl":"wbw/064_008_009.mp3","charTypeName":"word"},{"id":8968,"position":9,"arabic":"تَعْمَلُونَ","translation":"তোমরা কাজ করছ","audioUrl":"wbw/064_008_010.mp3","charTypeName":"word"},{"id":8969,"position":10,"arabic":"خَبِيرٌۭ","translation":"খুব অবহিত","audioUrl":"wbw/064_008_011.mp3","charTypeName":"word"},{"id":8970,"position":11,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"يَوْمَ يَجْمَعُكُمْ لِيَوْمِ ٱلْجَمْعِ ۖ ذَٰلِكَ يَوْمُ ٱلتَّغَابُنِ ۗ وَمَن يُؤْمِنۢ بِٱللَّهِ وَيَعْمَلْ صَٰلِحًۭا يُكَفِّرْ عَنْهُ سَيِّـَٔاتِهِۦ وَيُدْخِلْهُ جَنَّٰتٍۢ تَجْرِى مِن تَحْتِهَا ٱلْأَنْهَٰرُ خَٰلِدِينَ فِيهَآ أَبَدًۭا ۚ ذَٰلِكَ ٱلْفَوْزُ ٱلْعَظِيمُ","translation":"[Think of] the time when He shall gather you all together unto the Day of the [Last] Gathering - that Day of Loss and Gain! For, as for him who shall have believed in God and done what is just and right, He will [on that Day] efface his bad deeds, and will admit him into gardens through which running waters flow, therein to abide beyond the count of time: that will be a triumph supreme!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5208.mp3","surahId":64,"words":[{"id":10187,"position":1,"arabic":"يَوْمَ","translation":"যেদিন","audioUrl":"wbw/064_009_001.mp3","charTypeName":"word"},{"id":10188,"position":2,"arabic":"يَجْمَعُكُمْ","translation":"তোমাদের একত্রিত করবেন","audioUrl":"wbw/064_009_002.mp3","charTypeName":"word"},{"id":10189,"position":3,"arabic":"لِيَوْمِ","translation":"দিনের জন্যে","audioUrl":"wbw/064_009_003.mp3","charTypeName":"word"},{"id":10190,"position":4,"arabic":"ٱلْجَمْعِ ۖ","translation":"সমাবেশের","audioUrl":"wbw/064_009_004.mp3","charTypeName":"word"},{"id":10192,"position":5,"arabic":"ذَٰلِكَ","translation":"সেই","audioUrl":"wbw/064_009_006.mp3","charTypeName":"word"},{"id":10193,"position":6,"arabic":"يَوْمُ","translation":"দিন",