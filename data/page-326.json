{"id":326,"ayahs":[{"number":45,"arabic":"قُلْ إِنَّمَآ أُنذِرُكُم بِٱلْوَحْىِ ۚ وَلَا يَسْمَعُ ٱلصُّمُّ ٱلدُّعَآءَ إِذَا مَا يُنذَرُونَ","translation":"SAY [unto all men]: “I but warn you on the strength of divine revelation!” But the deaf [of heart] will not hearken to this call, however often they are warned.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2528.mp3","surahId":21,"words":[{"id":45436,"position":1,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/021_045_001.mp3","charTypeName":"word"},{"id":45437,"position":2,"arabic":"إِنَّمَآ","translation":"\"মূলতঃ","audioUrl":"wbw/021_045_002.mp3","charTypeName":"word"},{"id":45438,"position":3,"arabic":"أُنذِرُكُم","translation":"তোমাদের সতর্ক করছি আমি","audioUrl":"wbw/021_045_003.mp3","charTypeName":"word"},{"id":45439,"position":4,"arabic":"بِٱلْوَحْىِ ۚ","translation":"দ্বারা ওহী\"","audioUrl":"wbw/021_045_004.mp3","charTypeName":"word"},{"id":45441,"position":5,"arabic":"وَلَا","translation":"কিন্তু না","audioUrl":"wbw/021_045_006.mp3","charTypeName":"word"},{"id":45442,"position":6,"arabic":"يَسْمَعُ","translation":"শুনে","audioUrl":"wbw/021_045_007.mp3","charTypeName":"word"},{"id":45443,"position":7,"arabic":"ٱلصُّمُّ","translation":"বধির","audioUrl":"wbw/021_045_008.mp3","charTypeName":"word"},{"id":45444,"position":8,"arabic":"ٱلدُّعَآءَ","translation":"কোন আহ্বান","audioUrl":"wbw/021_045_009.mp3","charTypeName":"word"},{"id":45445,"position":9,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/021_045_010.mp3","charTypeName":"word"},{"id":45446,"position":10,"arabic":"مَا","translation":"যা","audioUrl":"wbw/021_045_011.mp3","charTypeName":"word"},{"id":45447,"position":11,"arabic":"يُنذَرُونَ","translation":"তাদের সতর্ক করা হয়","audioUrl":"wbw/021_045_012.mp3","charTypeName":"word"},{"id":45448,"position":12,"arabic":"٤٥","translation":"(৪৫)","audioUrl":null,"charTypeName":"end"}]},{"number":46,"arabic":"وَلَئِن مَّسَّتْهُمْ نَفْحَةٌۭ مِّنْ عَذَابِ رَبِّكَ لَيَقُولُنَّ يَٰوَيْلَنَآ إِنَّا كُنَّا ظَٰلِمِينَ","translation":"And yet, if but a breath of thy Sustainer’s chastisement touches them, they are sure to cry, “Oh, woe unto us! Verily, we were evildoers!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2529.mp3","surahId":21,"words":[{"id":46193,"position":1,"arabic":"وَلَئِن","translation":"আর যদি অবশ্যই","audioUrl":"wbw/021_046_001.mp3","charTypeName":"word"},{"id":46194,"position":2,"arabic":"مَّسَّتْهُمْ","translation":"তাদের স্পর্শ করে","audioUrl":"wbw/021_046_002.mp3","charTypeName":"word"},{"id":46195,"position":3,"arabic":"نَفْحَةٌۭ","translation":"একটা ঝাপটাও","audioUrl":"wbw/021_046_003.mp3","charTypeName":"word"},{"id":46196,"position":4,"arabic":"مِّنْ","translation":"থেকে","audioUrl":"wbw/021_046_004.mp3","charTypeName":"word"},{"id":46197,"position":5,"arabic":"عَذَابِ","translation":"শাস্তি","audioUrl":"wbw/021_046_005.mp3","charTypeName":"word"},{"id":46198,"position":6,"arabic":"رَبِّكَ","translation":"তোমার রবের","audioUrl":"wbw/021_046_006.mp3","charTypeName":"word"},{"id":46199,"position":7,"arabic":"لَيَقُولُنَّ","translation":"অবশ্যই তারা বলবে","audioUrl":"wbw/021_046_007.mp3","charTypeName":"word"},{"id":46200,"position":8,"arabic":"يَـٰوَيْلَنَآ","translation":"\"হায়! আমাদের দুর্ভোগ","audioUrl":"wbw/021_046_008.mp3","charTypeName":"word"},{"id":46201,"position":9,"arabic":"إِنَّا","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/021_046_009.mp3","charTypeName":"word"},{"id":46202,"position":10,"arabic":"كُنَّا","translation":"ছিলাম আমরা","audioUrl":"wbw/021_046_010.mp3","charTypeName":"word"},{"id":46203,"position":11,"arabic":"ظَـٰلِمِينَ","translation":"সীমালঙ্ঘনকারী\"","audioUrl":"wbw/021_046_011.mp3","charTypeName":"word"},{"id":46204,"position":12,"arabic":"٤٦","translation":"(৪৬)","audioUrl":null,"charTypeName":"end"}]},{"number":47,"arabic":"وَنَضَعُ ٱلْمَوَٰزِينَ ٱلْقِسْطَ لِيَوْمِ ٱلْقِيَٰمَةِ فَلَا تُظْلَمُ نَفْسٌۭ شَيْـًۭٔا ۖ وَإِن كَانَ مِثْقَالَ حَبَّةٍۢ مِّنْ خَرْدَلٍ أَتَيْنَا بِهَا ۗ وَكَفَىٰ بِنَا حَٰسِبِينَ","translation":"But We shall set up just balance-scales on Resurrection Day, and no human being shall be wrong­ed in the least: for though there be [in him but] the weight of a mustard-seed [of good or evil], We shall bring it forth; and none can take count as We do!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2530.mp3","surahId":21,"words":[{"id":46529,"position":1,"arabic":"وَنَضَعُ","translation":"এবং স্থাপন করবো আমরা","audioUrl":"wbw/021_047_001.mp3","charTypeName":"word"},{"id":46530,"position":2,"arabic":"ٱلْمَوَٰزِينَ","translation":"মানদন্ডসমূহ","audioUrl":"wbw/021_047_002.mp3","charTypeName":"word"},{"id":46531,"position":3,"arabic":"ٱلْقِسْطَ","translation":"ন্যায়ের","audioUrl":"wbw/021_047_003.mp3","charTypeName":"word"},{"id":46532,"position":4,"arabic":"لِيَوْمِ","translation":"জন্য দিনের","audioUrl":"wbw/021_047_004.mp3","charTypeName":"word"},{"id":46533,"position":5,"arabic":"ٱلْقِيَـٰمَةِ","translation":"ক্বিয়ামাতের","audioUrl":"wbw/021_047_005.mp3","charTypeName":"word"},{"id":46534,"position":6,"arabic":"فَلَا","translation":"ফলে না","audioUrl":"wbw/021_047_006.mp3","charTypeName":"word"},{"id":46535,"position":7,"arabic":"تُظْلَمُ","translation":"অবিচার করা হবে","audioUrl":"wbw/021_047_007.mp3","charTypeName":"word"},{"id":46536,"position":8,"arabic":"نَفْسٌۭ","translation":"কাউকে","audioUrl":"wbw/021_047_008.mp3","charTypeName":"word"},{"id":46537,"position":9,"arabic":"شَيْـًۭٔا ۖ","translation":"কিছুমাত্রও","audioUrl":"wbw/021_047_009.mp3","charTypeName":"word"},{"id":46539,"position":10,"arabic":"وَإِن","translation":"এবং যদি","audioUrl":"wbw/021_047_011.mp3","charTypeName":"word"},{"id":46540,"position":11,"arabic":"كَانَ","translation":"হয় (কৃতকর্ম)","audioUrl":"wbw/021_047_012.mp3","charTypeName":"word"},{"id":46541,"position":12,"arabic":"مِثْقَالَ","translation":"পরিমাণও","audioUrl":"wbw/021_047_013.mp3","charTypeName":"word"},{"id":46542,"position":13,"arabic":"حَبَّةٍۢ","translation":"একদানা","audioUrl":"wbw/021_047_014.mp3","charTypeName":"word"},{"id":46543,"position":14,"arabic":"مِّنْ","translation":"থেকে","audioUrl":"wbw/021_047_015.mp3","charTypeName":"word"},{"id":46544,"position":15,"arabic":"خَرْدَلٍ","translation":"সরিষার","audioUrl":"wbw/021_047_016.mp3","charTypeName":"word"},{"id":46545,"position":16,"arabic":"أَتَيْنَا","translation":"আমরা আসবো","audioUrl":"wbw/021_047_017.mp3","charTypeName":"word"},{"id":46546,"position":17,"arabic":"بِهَا ۗ","translation":"নিয়ে তাকে (সামনে)","audioUrl":"wbw/021_047_018.mp3","charTypeName":"word"},{"id":46548,"position":18,"arabic":"وَكَفَىٰ","translation":"এবং যথেষ্ট","audioUrl":"wbw/021_047_020.mp3","charTypeName":"word"},{"id":46549,"position":19,"arabic":"بِنَا","translation":"আমরাই","audioUrl":"wbw/021_047_021.mp3","charTypeName":"word"},{"id":46550,"position":20,"arabic":"حَـٰسِبِينَ","translation":"হিসাবগ্রহণকারীরূপে","audioUrl":"wbw/021_047_022.mp3","charTypeName":"word"},{"id":46551,"position":21,"arabic":"٤٧","translation":"(৪৭)","audioUrl":null,"charTypeName":"end"}]},{"number":48,"arabic":"وَلَقَدْ ءَاتَيْنَا مُوسَىٰ وَهَٰرُونَ ٱلْفُرْقَانَ وَضِيَآءًۭ وَذِكْرًۭا لِّلْمُتَّقِينَ","translation":"AND, INDEED, We vouchsafed unto Moses and Aaron [Our revelation as] the standard by which to discern the true from the false, and as a [guiding] light and a reminder for the God-conscious","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2531.mp3","surahId":21,"words":[{"id":47445,"position":1,"arabic":"وَلَقَدْ","translation":"এবং অবশ্যই","audioUrl":"wbw/021_048_001.mp3","charTypeName":"word"},{"id":47446,"position":2,"arabic":"ءَاتَيْنَا","translation":"আমরা দিয়েছি","audioUrl":"wbw/021_048_002.mp3","charTypeName":"word"},{"id":47447,"position":3,"arabic":"مُوسَىٰ","translation":"মূসাকে","audioUrl":"wbw/021_048_003.mp3","charTypeName":"word"},{"id":47448,"position":4,"arabic":"وَهَـٰرُونَ","translation":"ও হারূনকে","audioUrl":"wbw/021_048_004.mp3","charTypeName":"word"},{"id":47449,"position":5,"arabic":"ٱلْفُرْقَانَ","translation":"ফুরকান","audioUrl":"wbw/021_048_005.mp3","charTypeName":"word"},{"id":47450,"position":6,"arabic":"وَضِيَآءًۭ","translation":"এবং আলো","audioUrl":"wbw/021_048_006.mp3","charTypeName":"word"},{"id":47451,"position":7,"arabic":"وَذِكْرًۭا","translation":"ও উপদেশ","audioUrl":"wbw/021_048_007.mp3","charTypeName":"word"},{"id":47452,"position":8,"arabic":"لِّلْمُتَّقِينَ","translation":"জন্যে মুত্তাক্বীদের","audioUrl":"wbw/021_048_008.mp3","charTypeName":"word"},{"id":47453,"position":9,"arabic":"٤٨","translation":"(৪৮)","audioUrl":null,"charTypeName":"end"}]},{"number":49,"arabic":"ٱلَّذِينَ يَخْشَوْنَ رَبَّهُم بِٱلْغَيْبِ وَهُم مِّنَ ٱلسَّاعَةِ مُشْفِقُونَ","translation":"who stand in awe of their Sustainer although He is beyond the reach of human perception, and who tremble at the thought of the Last Hour.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2532.mp3","surahId":21,"words":[{"id":48003,"position":1,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/021_049_001.mp3","charTypeName":"word"},{"id":48004,"position":2,"arabic":"يَخْشَوْنَ","translation":"ভয় করে","audioUrl":"wbw/021_049_002.mp3","charTypeName":"word"},{"id":48005,"position":3,"arabic":"رَبَّهُم","translation":"তাদের রবকে","audioUrl":"wbw/021_049_003.mp3","charTypeName":"word"},{"id":48006,"position":4,"arabic":"بِٱلْغَيْبِ","translation":"অবস্থায় অদৃশ্য","audioUrl":"wbw/021_049_004.mp3","charTypeName":"word"},{"id":48007,"position":5,"arabic":"وَهُم","translation":"এবং তারাই","audioUrl":"wbw/021_049_005.mp3","charTypeName":"word"},{"id":48008,"position":6,"arabic":"مِّنَ","translation":"সম্পর্কে","audioUrl":"wbw/021_049_006.mp3","charTypeName":"word"},{"id":48009,"position":7,"arabic":"ٱلسَّاعَةِ","translation":"ক্বিয়ামাহ","audioUrl":"wbw/021_049_007.mp3","charTypeName":"word"},{"id":48010,"position":8,"arabic":"مُشْفِقُونَ","translation":"ভীতসন্ত্রস্ত","audioUrl":"wbw/021_049_008.mp3","charTypeName":"word"},{"id":48011,"position":9,"arabic":"٤٩","translation":"(৪৯)","audioUrl":null,"charTypeName":"end"}]},{"number":50,"arabic":"وَهَٰذَا ذِكْرٌۭ مُّبَارَكٌ أَنزَلْنَٰهُ ۚ أَفَأَنتُمْ لَهُۥ مُنكِرُونَ","translation":"And [like those earlier revelations,] this one, too, is a blessed reminder which We have bestowed from on high: will you, then, disavow it?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2533.mp3","surahId":21,"words":[{"id":48797,"position":1,"arabic":"وَهَـٰذَا","translation":"আর এই","audioUrl":"wbw/021_050_001.mp3","charTypeName":"word"},{"id":48798,"position":2,"arabic":"ذِكْرٌۭ","translation":"উপদেশ (ক্বুর'আন)","audioUrl":"wbw/021_050_002.mp3","charTypeName":"word"},{"id":48799,"position":3,"arabic":"مُّبَارَكٌ","translation":"কল্যাণময়","audioUrl":"wbw/021_050_003.mp3","charTypeName":"word"},{"id":48800,"position":4,"arabic":"أَنزَلْنَـٰهُ ۚ","translation":"তা আমরা অবতীর্ণ করেছি","audioUrl":"wbw/021_050_004.mp3","charTypeName":"word"},{"id":48802,"position":5,"arabic":"أَفَأَنتُمْ","translation":"কি তোমরা তবুও","audioUrl":"wbw/021_050_006.mp3","charTypeName":"word"},{"id":48803,"position":6,"arabic":"لَهُۥ","translation":"জন্যে তার","audioUrl":"wbw/021_050_007.mp3","charTypeName":"word"},{"id":48804,"position":7,"arabic":"مُنكِرُونَ","translation":"অস্বীকারকারী হবে","audioUrl":"wbw/021_050_008.mp3","charTypeName":"word"},{"id":48805,"position":8,"arabic":"٥٠","translation":"(৫০)","audioUrl":null,"charTypeName":"end"}]},{"number":51,"arabic":"۞ وَلَقَدْ ءَاتَيْنَآ إِبْرَٰهِيمَ رُشْدَهُۥ مِن قَبْلُ وَكُنَّا بِهِۦ عَٰلِمِينَ","translation":"AND, INDEED, long before [the time of Moses] We vouchsafed unto Abraham his consciousness of what is right; and We were aware of [what moved] him","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2534.mp3","surahId":21,"words":[{"id":49309,"position":1,"arabic":"۞ وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/021_051_002.mp3","charTypeName":"word"},{"id":49310,"position":2,"arabic":"ءَاتَيْنَآ","translation":"আমরা দিয়েছি","audioUrl":"wbw/021_051_003.mp3","charTypeName":"word"},{"id":49311,"position":3,"arabic":"إِبْرَٰهِيمَ","translation":"ইবরাহীম কে","audioUrl":"wbw/021_051_004.mp3","charTypeName":"word"},{"id":49312,"position":4,"arabic":"رُشْدَهُۥ","translation":"তার সৎপথের বুদ্ধি জ্ঞান","audioUrl":"wbw/021_051_005.mp3","charTypeName":"word"},{"id":49313,"position":5,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/021_051_006.mp3","charTypeName":"word"},{"id":49314,"position":6,"arabic":"قَبْلُ","translation":"ইতিপূর্ব","audioUrl":"wbw/021_051_007.mp3","charTypeName":"word"},{"id":49315,"position":7,"arabic":"وَكُنَّا","translation":"এবং আমরা ছিলাম","audioUrl":"wbw/021_051_008.mp3","charTypeName":"word"},{"id":49316,"position":8,"arabic":"بِهِۦ","translation":"সম্পর্কে তার","audioUrl":"wbw/021_051_009.mp3","charTypeName":"word"},{"id":49317,"position":9,"arabic":"عَـٰلِمِينَ","translation":"খুব অবহিত","audioUrl":"wbw/021_051_010.mp3","charTypeName":"word"},{"id":49318,"position":10,"arabic":"٥١","translation":"(৫১)","audioUrl":null,"charTypeName":"end"}]},{"number":52,"arabic":"إِذْ قَالَ لِأَبِيهِ وَقَوْمِهِۦ مَا هَٰذِهِ ٱلتَّمَاثِيلُ ٱلَّتِىٓ أَنتُمْ لَهَا عَٰكِفُونَ","translation":"when he said unto his father and his people, “What are these images to which you are so intensely devoted?”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2535.mp3","surahId":21,"words":[{"id":50009,"position":1,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/021_052_001.mp3","charTypeName":"word"},{"id":50010,"position":2,"arabic":"قَالَ","translation":"সে বলেছিলো","audioUrl":"wbw/021_052_002.mp3","charTypeName":"word"},{"id":50011,"position":3,"arabic":"لِأَبِيهِ","translation":"তার পিতাকে","audioUrl":"wbw/021_052_003.mp3","charTypeName":"word"},{"id":50012,"position":4,"arabic":"وَقَوْمِهِۦ","translation":"ও তার জাতিকে","audioUrl":"wbw/021_052_004.mp3","charTypeName":"word"},{"id":50013,"position":5,"arabic":"مَا","transla