{"id":88,"ayahs":[{"number":60,"arabic":"أَلَمْ تَرَ إِلَى ٱلَّذِينَ يَزْعُمُونَ أَنَّهُمْ ءَامَنُوا۟ بِمَآ أُنزِلَ إِلَيْكَ وَمَآ أُنزِلَ مِن قَبْلِكَ يُرِيدُونَ أَن يَتَحَاكَمُوٓا۟ إِلَى ٱلطَّٰغُوتِ وَقَدْ أُمِرُوٓا۟ أَن يَكْفُرُوا۟ بِهِۦ وَيُرِيدُ ٱلشَّيْطَٰنُ أَن يُضِلَّهُمْ ضَلَٰلًۢا بَعِيدًۭا","translation":"ART THOU NOT aware of those who claim that they believe in what has been bestowed from on high upon thee, [O Prophet,] as well as in what was bestowed from on high before thee, [and yet] are willing to defer to the rule of the powers of evil - although they were bidden to deny it, seeing that Satan but wants to lead them far astray?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/553.mp3","surahId":4,"words":[{"id":54326,"position":1,"arabic":"أَلَمْ","translation":"নাই কি","audioUrl":"wbw/004_060_001.mp3","charTypeName":"word"},{"id":54327,"position":2,"arabic":"تَرَ","translation":"তুমি দেখ","audioUrl":"wbw/004_060_002.mp3","charTypeName":"word"},{"id":54328,"position":3,"arabic":"إِلَى","translation":"(তাদের) প্রতি","audioUrl":"wbw/004_060_003.mp3","charTypeName":"word"},{"id":54329,"position":4,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/004_060_004.mp3","charTypeName":"word"},{"id":54330,"position":5,"arabic":"يَزْعُمُونَ","translation":"দাবী করে","audioUrl":"wbw/004_060_005.mp3","charTypeName":"word"},{"id":54331,"position":6,"arabic":"أَنَّهُمْ","translation":"যে তারা","audioUrl":"wbw/004_060_006.mp3","charTypeName":"word"},{"id":54332,"position":7,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/004_060_007.mp3","charTypeName":"word"},{"id":54333,"position":8,"arabic":"بِمَآ","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/004_060_008.mp3","charTypeName":"word"},{"id":54334,"position":9,"arabic":"أُنزِلَ","translation":"নাযিল হয়েছে","audioUrl":"wbw/004_060_009.mp3","charTypeName":"word"},{"id":54335,"position":10,"arabic":"إِلَيْكَ","translation":"তোমার প্রতি","audioUrl":"wbw/004_060_010.mp3","charTypeName":"word"},{"id":54336,"position":11,"arabic":"وَمَآ","translation":"এবং যা","audioUrl":"wbw/004_060_011.mp3","charTypeName":"word"},{"id":54337,"position":12,"arabic":"أُنزِلَ","translation":"নাযিল হয়েছে","audioUrl":"wbw/004_060_012.mp3","charTypeName":"word"},{"id":54338,"position":13,"arabic":"مِن","translation":"(থেকে)","audioUrl":"wbw/004_060_013.mp3","charTypeName":"word"},{"id":54339,"position":14,"arabic":"قَبْلِكَ","translation":"তোমার পূর্বে","audioUrl":"wbw/004_060_014.mp3","charTypeName":"word"},{"id":54340,"position":15,"arabic":"يُرِيدُونَ","translation":"তারা চায়","audioUrl":"wbw/004_060_015.mp3","charTypeName":"word"},{"id":54341,"position":16,"arabic":"أَن","translation":"যে","audioUrl":"wbw/004_060_016.mp3","charTypeName":"word"},{"id":54342,"position":17,"arabic":"يَتَحَاكَمُوٓا۟","translation":"তারা বিচার প্রার্থী হবে","audioUrl":"wbw/004_060_017.mp3","charTypeName":"word"},{"id":54343,"position":18,"arabic":"إِلَى","translation":"কাছে","audioUrl":"wbw/004_060_018.mp3","charTypeName":"word"},{"id":54344,"position":19,"arabic":"ٱلطَّـٰغُوتِ","translation":"তাগুতের'","audioUrl":"wbw/004_060_019.mp3","charTypeName":"word"},{"id":54345,"position":20,"arabic":"وَقَدْ","translation":"অথচ নিশ্চয়","audioUrl":"wbw/004_060_020.mp3","charTypeName":"word"},{"id":54346,"position":21,"arabic":"أُمِرُوٓا۟","translation":"তারা নির্দেশিত হয়েছে","audioUrl":"wbw/004_060_021.mp3","charTypeName":"word"},{"id":54347,"position":22,"arabic":"أَن","translation":"যে","audioUrl":"wbw/004_060_022.mp3","charTypeName":"word"},{"id":54348,"position":23,"arabic":"يَكْفُرُوا۟","translation":"তারা অস্বীকার করবে","audioUrl":"wbw/004_060_023.mp3","charTypeName":"word"},{"id":54349,"position":24,"arabic":"بِهِۦ","translation":"তাকে","audioUrl":"wbw/004_060_024.mp3","charTypeName":"word"},{"id":54350,"position":25,"arabic":"وَيُرِيدُ","translation":"কিন্তু চায়","audioUrl":"wbw/004_060_025.mp3","charTypeName":"word"},{"id":54351,"position":26,"arabic":"ٱلشَّيْطَـٰنُ","transla