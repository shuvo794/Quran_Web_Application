ُسِهِمْ قَوْلًۢا بَلِيغًۭا","translation":"As for them - God knows all that is in their hearts; so leave them alone, and admonish them, and speak unto them about themselves in a gravely search­ing manner:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/556.mp3","surahId":4,"words":[{"id":56014,"position":1,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐসব লোক","audioUrl":"wbw/004_063_001.mp3","charTypeName":"word"},{"id":56015,"position":2,"arabic":"ٱلَّذِينَ","translation":"যাদেরকে","audioUrl":"wbw/004_063_002.mp3","charTypeName":"word"},{"id":56016,"position":3,"arabic":"يَعْلَمُ","translation":"জানেন","audioUrl":"wbw/004_063_003.mp3","charTypeName":"word"},{"id":56017,"position":4,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/004_063_004.mp3","charTypeName":"word"},{"id":56018,"position":5,"arabic":"مَا","translation":"যা কিছু (আছে)","audioUrl":"wbw/004_063_005.mp3","charTypeName":"word"},{"id":56019,"position":6,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/004_063_006.mp3","charTypeName":"word"},{"id":56020,"position":7,"arabic":"قُلُوبِهِمْ","translation":"তাদের অন্তরগুলোর","audioUrl":"wbw/004_063_007.mp3","charTypeName":"word"},{"id":56021,"position":8,"arabic":"فَأَعْرِضْ","translation":"অতএব উপেক্ষা কর","audioUrl":"wbw/004_063_008.mp3","charTypeName":"word"},{"id":56022,"position":9,"arabic":"عَنْهُمْ","translation":"তাদেরকে","audioUrl":"wbw/004_063_009.mp3","charTypeName":"word"},{"id":56023,"position":10,"arabic":"وَعِظْهُمْ","translation":"ও তাদের উপদেশ দাও","audioUrl":"wbw/004_063_010.mp3","charTypeName":"word"},{"id":56024,"position":11,"arabic":"وَقُل","translation":"এবং বল","audioUrl":"wbw/004_063_011.mp3","charTypeName":"word"},{"id":56025,"position":12,"arabic":"لَّهُمْ","translation":"তাদেরকে (যেন)","audioUrl":"wbw/004_063_012.mp3","charTypeName":"word"},{"id":56026,"position":13,"arabic":"فِىٓ","translation":"মধ্যে","audioUrl":"wbw/004_063_013.mp3","charTypeName":"word"},{"id":56027,"position":14,"arabic":"أَنفُسِهِم