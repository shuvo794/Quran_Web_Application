{"id":364,"ayahs":[{"number":44,"arabic":"أَمْ تَحْسَبُ أَنَّ أَكْثَرَهُمْ يَسْمَعُونَ أَوْ يَعْقِلُونَ ۚ إِنْ هُمْ إِلَّا كَٱلْأَنْعَٰمِ ۖ بَلْ هُمْ أَضَلُّ سَبِيلًا","translation":"Or dost thou think that most of them listen [to thy message] and use their reason? Nay, they are but like cattle - nay, they are even less conscious of the right way!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2899.mp3","surahId":25,"words":[{"id":44442,"position":1,"arabic":"أَمْ","translation":"অথবা কি","audioUrl":"wbw/025_044_001.mp3","charTypeName":"word"},{"id":44443,"position":2,"arabic":"تَحْسَبُ","translation":"মনে করো তুমি","audioUrl":"wbw/025_044_002.mp3","charTypeName":"word"},{"id":44444,"position":3,"arabic":"أَنَّ","translation":"যে","audioUrl":"wbw/025_044_003.mp3","charTypeName":"word"},{"id":44445,"position":4,"arabic":"أَكْثَرَهُمْ","translation":"অধিকাংশ তাদের","audioUrl":"wbw/025_044_004.mp3","charTypeName":"word"},{"id":44446,"position":5,"arabic":"يَسْمَعُونَ","translation":"শূনতে পায়","audioUrl":"wbw/025_044_005.mp3","charTypeName":"word"},{"id":44447,"position":6,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/025_044_006.mp3","charTypeName":"word"},{"id":44448,"position":7,"arabic":"يَعْقِلُونَ ۚ","translation":"বুঝতে পারে","audioUrl":"wbw/025_044_007.mp3","charTypeName":"word"},{"id":44450,"position":8,"arabic":"إِنْ","translation":"নয়","audioUrl":"wbw/025_044_009.mp3","charTypeName":"word"},{"id":44451,"position":9,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/025_044_010.mp3","charTypeName":"word"},{"id":44452,"position":10,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/025_044_011.mp3","charTypeName":"word"},{"id":44453,"position":11,"arabic":"كَٱلْأَنْعَـٰمِ ۖ","translation":"মতো চতুষ্পদ পশুর","audioUrl":"wbw/025_044_012.mp3","charTypeName":"word"},{"id":44455,"position":12,"arabic":"بَلْ","translation":"বরং","audioUrl":"wbw/025_044_014.mp3","charTypeName":"word"},{"id":44456,"position":13,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/025_044_015.mp3","charTypeName":"word"},{"id":44457,"position":14,"arabic":"أَضَلُّ","translation":"অধিকতর ভ্রষ্ট হয়েছে","audioUrl":"wbw/025_044_016.mp3","charTypeName":"word"},{"id":44458,"position":15,"arabic":"سَبِيلًا","translation":"পথ","audioUrl":"wbw/025_044_017.mp3","charTypeName":"word"},{"id":44459,"position":16,"arabic":"٤٤","translation":"(৪৪)","audioUrl":null,"charTypeName":"end"}]},{"number":45,"arabic":"أَلَمْ تَرَ إِلَىٰ رَبِّكَ كَيْفَ مَدَّ ٱلظِّلَّ وَلَوْ شَآءَ لَجَعَلَهُۥ سَاكِنًۭا ثُمَّ جَعَلْنَا ٱلشَّمْسَ عَلَيْهِ دَلِيلًۭا","translation":"Art thou not aware of thy Sustainer [through His works]? - how He causes the shadow to lengthen [towards the night] when, had He so willed, He could indeed have made it stand still: but then, We have made the sun its guide;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2900.mp3","surahId":25,"words":[{"id":45195,"position":1,"arabic":"أَلَمْ","translation":"কি নি","audioUrl":"wbw/025_045_001.mp3","charTypeName":"word"},{"id":45196,"position":2,"arabic":"تَرَ","translation":"তুমি (ভেবে) দেখো","audioUrl":"wbw/025_045_002.mp3","charTypeName":"word"},{"id":45197,"position":3,"arabic":"إِلَىٰ","translation":"প্রতি","audioUrl":"wbw/025_045_003.mp3","charTypeName":"word"},{"id":45198,"position":4,"arabic":"رَبِّكَ","translation":"তোমার রবের","audioUrl":"wbw/025_045_004.mp3","charTypeName":"word"},{"id":45199,"position":5,"arabic":"كَيْفَ","translation":"কিভাবে","audioUrl":"wbw/025_045_005.mp3","charTypeName":"word"},{"id":45200,"position":6,"arabic":"مَدَّ","translation":"তিনি বিস্তার করেছেন","audioUrl":"wbw/025_045_006.mp3","charTypeName":"word"},{"id":45201,"position":7,"arabic":"ٱلظِّلَّ","translation":"ছায়া","audioUrl":"wbw/025_045_007.mp3","charTypeName":"word"},{"id":45202,"position":8,"arabic":"وَلَوْ","translation":"এবং যদি","audioUrl":"wbw/025_045_008.mp3","charTypeName":"word"},{"id":45203,"position":9,"arabic":"شَآءَ","translation":"তিনি চাইতেন","audioUrl":"wbw/025_045_009.mp3","charTypeName":"word"},{"id":45204,"position":10,"arabic":"لَجَعَلَهُۥ","translation":"অবশ্যই তাকে করতে পারতেন","audioUrl":"wbw/025_045_010.mp3","charTypeName":"word"},{"id":45205,"position":11,"arabic":"سَاكِنًۭا","translation":"স্থির","audioUrl":"wbw/025_045_011.mp3","charTypeName":"word"},{"id":45206,"position":12,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/025_045_012.mp3","charTypeName":"word"},{"id":45207,"position":13,"arabic":"جَعَلْنَا","translation":"আমরা করেছি","audioUrl":"wbw/025_045_013.mp3","charTypeName":"word"},{"id":45208,"position":14,"arabic":"ٱلشَّمْسَ","translation":"সূর্যকে","audioUrl":"wbw/025_045_014.mp3","charTypeName":"word"},{"id":45209,"position":15,"arabic":"عَلَيْهِ","translation":"তার উপর","audioUrl":"wbw/025_045_015.mp3","charTypeName":"word"},{"id":45210,"position":16,"arabic":"دَلِيلًۭا","translation":"প্রমাণ","audioUrl":"wbw/025_045_016.mp3","charTypeName":"word"},{"id":45211,"position":17,"arabic":"٤٥","translation":"(৪৫)","audioUrl":null,"charTypeName":"end"}]},{"number":46,"arabic":"ثُمَّ قَبَضْنَٰهُ إِلَيْنَا قَبْضًۭا يَسِيرًۭا","translation":"and then, [after having caused it to lengthen,] We draw it in towards Our­selves with a gradual drawing-in.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2901.mp3","surahId":25,"words":[{"id":45983,"position":1,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/025_046_001.mp3","charTypeName":"word"},{"id":45984,"position":2,"arabic":"قَبَضْنَـٰهُ","translation":"তাকে আমরা গুটিয়ে আনি","audioUrl":"wbw/025_046_002.mp3","charTypeName":"word"},{"id":45985,"position":3,"arabic":"إِلَيْنَا","translation":"আমাদের দিকে","audioUrl":"wbw/025_046_003.mp3","charTypeName":"word"},{"id":45986,"position":4,"arabic":"قَبْضًۭا","translation":"গুটিয়ে","audioUrl":"wbw/025_046_004.mp3","charTypeName":"word"},{"id":45987,"position":5,"arabic":"يَسِيرًۭا","translation":"ধীর ভাবে","audioUrl":"wbw/025_046_005.mp3","charTypeName":"word"},{"id":45988,"position":6,"arabic":"٤٦","translation":"(৪৬)","audioUrl":null,"charTypeName":"end"}]},{"number":47,"arabic":"وَهُوَ ٱلَّذِى جَعَلَ لَكُمُ ٱلَّيْلَ لِبَاسًۭا وَٱلنَّوْمَ سُبَاتًۭا وَجَعَلَ ٱلنَّهَارَ نُشُورًۭا","translation":"And He it is who makes the night a garment for you, and [your] sleep a rest, and causes every [new] day to be a resurrection.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2902.mp3","surahId":25,"words":[{"id":46615,"position":1,"arabic":"وَهُوَ","translation":"এবং তিনিই (আল্লাহ)","audioUrl":"wbw/025_047_001.mp3","charTypeName":"word"},{"id":46616,"position":2,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/025_047_002.mp3","charTypeName":"word"},{"id":46617,"position":3,"arabic":"جَعَلَ","translation":"করেছেন","audioUrl":"wbw/025_047_003.mp3","charTypeName":"word"},{"id":46618,"position":4,"arabic":"لَكُمُ","translation":"জন্যে তোমাদের","audioUrl":"wbw/025_047_004.mp3","charTypeName":"word"},{"id":46619,"position":5,"arabic":"ٱلَّيْلَ","translation":"রাতকে","audioUrl":"wbw/025_047_005.mp3","charTypeName":"word"},{"id":46620,"position":6,"arabic":"لِبَاسًۭا","translation":"(আবরণ ও) পোশাকস্বরূপ","audioUrl":"wbw/025_047_006.mp3","charTypeName":"word"},{"id":46621,"position":7,"arabic":"وَٱلنَّوْمَ","translation":"ও ঘুমকে (করেছেন)","audioUrl":"wbw/025_047_007.mp3","charTypeName":"word"},{"id":46622,"position":8,"arabic":"سُبَاتًۭا","translation":"(মৃত্যুর সম) বিশ্রামস্বরূপ","audioUrl":"wbw/025_047_008.mp3","charTypeName":"word"},{"id":46623,"position":9,"arabic":"وَجَعَلَ","translation":"ও তিনি করেছেন","audioUrl":"wbw/025_047_009.mp3","charTypeName":"word"},{"id":46624,"position":10,"arabic":"ٱلنَّهَارَ","translation":"দিনকে","audioUrl":"wbw/025_047_010.mp3","charTypeName":"word"},{"id":46625,"position":11,"arabic":"نُشُورًۭا","translation":"(জীবন্ত করে) উত্থানস্বরূপ","audioUrl":"wbw/025_047_011.mp3","charTypeName":"word"},{"id":46626,"position":12,"arabic":"٤٧","translation":"(৪৭)","audioUrl":null,"charTypeName":"end"}]},{"number":48,"arabic":"وَهُوَ ٱلَّذِىٓ أَرْسَلَ ٱلرِّيَٰحَ بُشْرًۢا بَيْنَ يَدَىْ رَحْمَتِهِۦ ۚ وَأَنزَلْنَا مِنَ ٱلسَّمَآءِ مَآءًۭ طَهُورًۭا","translation":"And He it is who sends forth the winds as a glad tiding of His coming grace; and [thus, too,] We cause pure water to descend from the skies,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2903.mp3","surahId":25,"words":[{"id":47330,"position":1,"arabic":"وَهُوَ","translation":"এবং তিনিই","audioUrl":"wbw/025_048_001.mp3","charTypeName":"word"},{"id":47331,"position":2,"arabic":"ٱلَّذِىٓ","translation":"যিনি","audioUrl":"wbw/025_048_002.mp3","charTypeName":"word"},{"id":47332,"position":3,"arabic":"أَرْسَلَ","translation":"প্রেরণ করেন","audioUrl":"wbw/025_048_003.mp3","charTypeName":"word"},{"id":47333,"position":4,"arabic":"ٱلرِّيَـٰحَ","translation":"বাতাসকে","audioUrl":"wbw/025_048_004.mp3","charTypeName":"word"},{"id":47334,"position":5,"arabic":"بُشْرًۢا","translation":"সুসংবাদরূপে","audioUrl":"wbw/025_048_005.mp3","charTypeName":"word"},{"id":47335,"position":6,"arabic":"بَيْنَ","translation":"মাঝে","audioUrl":"wbw/025_048_006.mp3","charTypeName":"word"},{"id":47336,"position":7,"arabic":"يَدَىْ","translation":"হাতের (প্রাক্কালে)","audioUrl":"wbw/025_048_007.mp3","charTypeName":"word"},{"id":47337,"position":8,"arabic":"رَحْمَتِهِۦ ۚ","translation":"তাঁর অনুগ্রহের","audioUrl":"wbw/025_048_008.mp3","charTypeName":"word"},{"id":47339,"position":9,"arabic":"وَأَنزَلْنَا","translation":"এবং আমরা বর্ষণ করি","audioUrl":"wbw/025_048_010.mp3","charTypeName":"word"},{"id":47340,"position":10,"arabic":"مِنَ","translation":"হ'তে","audioUrl":"wbw/025_048_011.mp3","charTypeName":"word"},{"id":47341,"position":11,"arabic":"ٱلسَّمَآءِ","translation":"আকাশ","audioUrl":"wbw/025_048_012.mp3","charTypeName":"word"},{"id":47342,"position":12,"arabic":"مَآءًۭ","translation":"পানি","audioUrl":"wbw/025_048_013.mp3","charTypeName":"word"},{"id":47343,"position":13,"arabic":"طَهُورًۭا","translation":"বিশুদ্ধ","audioUrl":"wbw/025_048_014.mp3","charTypeName":"word"},{"id":47344,"position":14,"arabic":"٤٨","translation":"(৪৮)","audioUrl":null,"charTypeName":"end"}]},{"number":49,"arabic":"لِّنُحْۦِىَ بِهِۦ بَلْدَةًۭ مَّيْتًۭا وَنُسْقِيَهُۥ مِمَّا خَلَقْنَآ أَنْعَٰمًۭا وَأَنَاسِىَّ كَثِيرًۭا","translation":"so that We may bring dead land to life thereby, and give to drink thereof to many [beings] of Our creation, beasts as well as humans.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2904.mp3","surahId":25,"words":[{"id":48048,"position":1,"arabic":"لِّنُحْـِۧىَ","translation":"যেন জীবিত করি আমরা","audioUrl":"wbw/025_049_001.mp3","charTypeName":"word"},{"id":48049,"position":2,"arabic":"بِهِۦ","translation":"দ্বারা তা","audioUrl":"wbw/025_049_002.mp3","charTypeName":"word"},{"id":48050,"position":3,"arabic":"بَلْدَةًۭ","translation":"ভূখণ্ডকে","audioUrl":"wbw/025_049_003.mp3","charTypeName":"word"},{"id":48051,"position":4,"arabic":"مَّيْتًۭا","translation":"মৃত","audioUrl":"wbw/025_049_004.mp3","charTypeName":"word"},{"id":48052,"position":5,"arabic":"وَنُسْقِيَهُۥ","translation":"ও তা পান করাই আমরা","audioUrl":"wbw/025_049_005.mp3","charTypeName":"word"},{"id":48053,"position":6,"arabic":"مِمَّا","translation":"মধ্যে যাদের","audioUrl":"wbw/025_049_006.mp3","charTypeName":"word"},{"id":48054,"position":7,"arabic":"خَلَقْنَآ","translation":"আমরা সৃষ্টি করেছি","audioUrl":"wbw/025_049_007.mp3","charTypeName":"word"},{"id":48055,"position":8,"arabic":"أَنْعَـٰمًۭا","translation":"জীবজন্তু","audioUrl":"wbw/025_049_008.mp3","charTypeName":"word"},{"id":48056,"position":9,"arabic":"وَأَنَاسِىَّ","translation":"ও মানুষ","audioUrl":"wbw/025_049_009.mp3","charTypeName":"word"},{"id":48057,"position":10,"arabic":"كَثِيرًۭا","translation":"বহু","audioUrl":"wbw/025_049_010.mp3","charTypeName":"word"},{"id":48058,"position":11,"arabic":"٤٩","translation":"(৪৯)","audioUrl":null,"charTypeName":"end"}]},{"number":50,"arabic":"وَلَقَدْ صَرَّفْنَٰهُ بَيْنَهُمْ لِيَذَّكَّرُوا۟ فَأَبَىٰٓ أَكْثَرُ ٱلنَّاسِ إِلَّا كُفُورًۭا","translation":"And, indeed, many times have We repeated [all] this unto men, so that they might take it to heart: but most men refuse to be aught but ingrate.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2905.mp3","surahId":25,"words":[{"id":48687,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/025_050_001.mp3","charTypeName":"word"},{"id":48688,"position":2,"arabic":"صَرَّفْنَـٰهُ","translation":"তা আমরা বারবার পেশ করি","audioUrl":"wbw/025_050_002.mp3","charTypeName":"word"},{"id":48689,"position":3,"arabic":"بَيْنَهُمْ","translation":"তাদের মাঝে","audioUrl":"wbw/025_050_003.mp3","charTypeName":"word"},{"id":48690,"position":4,"arabic":"لِيَذَّكَّرُوا۟","translation":"যেন তারা শিক্ষা নেয়","audioUrl":"wbw/025_050_004.mp3","charTypeName":"word"},{"id":48691,"position":5,"arabic":"فَأَبَىٰٓ","translation":"কিন্তু অস্বীকার করে","audioUrl":"wbw/025_050_005.mp3","charTypeName":"word"},{"id":48692,"position":6,"arabic":"أَكْثَرُ","translation":"অধিকাংশ","audioUrl":"wbw/025_050_006.mp3","charTypeName":"word"},{"id":48693,"position":7,"arabic":"ٱلنَّاسِ","translation":"মানুষ","audioUrl":"wbw/025_050_007.mp3","charTypeName":"word"},{"id":48694,"position":8,"arabic":"إِلَّا","translation":"(আর) কেবল","audioUrl":"wbw/025_050_008.mp3","charTypeName":"word"},{"id":48695,"position":9,"arabic":"كُفُورًۭا","translation":"অকৃতজ্ঞতা প্রকাশ করে","audioUrl":"wbw/025_050_009.mp3","charTypeName":"word"},{"id":48696,"position":10,"arabic":"٥٠","translation":"(৫০)","audioUrl":null,"charTypeName":"end"}]},{"number":51,"arabic":"وَلَوْ شِئْنَا لَبَعَثْنَا فِى كُلِّ قَرْيَةٍۢ نَّذِيرًۭا","translation":"Now had We so willed. We could have [con­tinued as before and] raised up a [separate] warner in every single community:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2906.mp3","surahId":25,"words":[{"id":49206,"position":1,"arabic":"وَلَوْ","translation":"আর যদি","audioUrl":"wbw/025_051_001.mp3","charTypeName":"word"},{"id":49207,"position":2,"arabic":"شِئْنَا","translation":"আমরা চাইতাম","audioUrl":"wbw/025_051_002.mp3","charTypeName":"word"},{"id":49208,"position":3,"arabic":"لَبَعَثْنَا","translation":"অবশ্যই আমরাপাঠাতাম","audioUrl":"wbw/025_051_003.mp3","charTypeName":"word"},{"id":49209,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/025_051_004.mp3","charTypeName":"word"},{"id":49210,"position":5,"arabic":"كُلِّ","translation":"প্রত্যেক","audioUrl":"wbw/025_051_005.mp3","charTypeName":"word"},{"id":49211,"position":6,"arabic":"قَرْيَةٍۢ","translation":"জনপদের","audioUrl":"wbw/025_051_006.mp3","charTypeName":"word"},{"id":49212,"position":7,"arabic":"نَّذِيرًۭا","translation":"একজন  সতর্ককারী","audioUrl":"wbw/025_051_007.mp3","charTypeName":"word"},{"id":49213,"position":8,"arabic":"٥١","translation":"(৫১)","audioUrl":null,"charTypeName":"end"}]},{"number":52,"arabic":"فَلَا تُطِعِ ٱلْكَٰفِرِينَ وَجَٰهِدْهُم بِهِۦ جِهَادًۭا كَبِيرًۭا","translation":"hence, do not defer to [the likes and dislikes of] those who deny the truth, but strive hard against them, by means of this [divine writ], with utmost striving.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2907.mp3","surahId":25,"words":[{"id":49943,"position":1,"arabic":"فَلَا","translation":"সুতরাং না","audioUrl":"wbw/025_052_001.mp3","charTypeName":"word"},{"id":49944,"position":2,"arabic":"تُطِعِ","translation":"তুমি অনুসরণ করো","audioUrl":"wbw/025_052_002.mp3","charTypeName":"word"},{"id":49945,"position":3,"arabic":"ٱلْكَـٰفِرِينَ","translation":"কাফিরদেরকে","audioUrl":"wbw/025_052_003.mp3","charTypeName":"word"},{"id":49946,"position":4,"arabic":"وَجَـٰهِدْهُم","translation":"এবং জিহাদ করো তাদের সাথে","audioUrl":"wbw/025_052_004.mp3","charTypeName":"word"},{"id":49947,"position":5,"arabic":"بِهِۦ","translation":"দ্বারা এ","audioUrl":"wbw/025_052_005.mp3","charTypeName":"word"},{"id":49948,"position":6,"arabic":"جِهَادًۭا","translation":"জিহাদ","audioUrl":"wbw/025_052_006.mp3","charTypeName":"word"},{"id":49949,"position":7,"arabic":"كَبِيرًۭا","translation":"বড়","audioUrl":"wbw/025_052_007.mp3","charTypeName":"word"},{"id":49950,"position":8,"arabic":"٥٢","translation":"(৫২)","audioUrl":null,"charTypeName":"end"}]},{"number":53,"arabic":"۞ وَهُوَ ٱلَّذِى مَرَجَ ٱلْبَحْرَيْنِ هَٰذَا عَذْبٌۭ فُرَاتٌۭ وَهَٰذَا مِلْحٌ أُجَاجٌۭ وَجَعَلَ بَيْنَهُمَا بَرْزَخًۭا وَحِجْرًۭا مَّحْجُورًۭا","translation":"AND HE it is who has given freedom of movement to the two great bodies of water – the one sweet and thirst-allaying, and the other salty and bitter - and yet has wrought between them a barrier and a forbidding ban.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2908.mp3","surahId":25,"words":[{"id":50599,"position":1,"arabic":"۞ وَهُوَ","translation":"এবং তিনি (আল্লাহ)","audioUrl":"wbw/025_053_002.mp3","charTypeName":"word"},{"id":50600,"position":2,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/025_053_003.mp3","charTypeName":"word"},{"id":50601,"position":3,"arabic":"مَرَجَ","translation":"মিলিয়ে প্রবাহিত করেছেন","audioUrl":"wbw/025_053_004.mp3","charTypeName":"word"},{"id":50602,"position":4,"arabic":"ٱلْبَحْرَيْنِ","translation":"দুই সমুদ্রকে","audioUrl":"wbw/025_053_005.mp3","charTypeName":"word"},{"id":50603,"position":5,"arabic":"هَـٰذَا","translation":"এটা","audioUrl":"wbw/025_053_006.mp3","charTypeName":"word"},{"id":50604,"position":6,"arabic":"عَذْبٌۭ","translation":"সুমিষ্ট","audioUrl":"wbw/025_053_007.mp3","charTypeName":"word"},{"id":50605,"position":7,"arabic":"فُرَاتٌۭ","translation":"সুপেয়","audioUrl":"wbw/025_053_008.mp3","charTypeName":"word"},{"id":50606,"position":8,"arabic":"وَهَـٰذَا","translation":"এবং ওটা","audioUrl":"wbw/025_053_009.mp3","charTypeName":"word"},{"id":50607,"position":9,"arabic":"مِلْحٌ","translation":"লোনা","audioUrl":"wbw/025_053_010.mp3","charTypeName":"word"},{"id":50608,"position":10,"arabic":"أُجَاجٌۭ","translation":"বিস্বাদ","audioUrl":"wbw/025_053_011.mp3","charTypeName":"word"},{"id":50609,"position":11,"arabic":"وَجَعَلَ","translation":"এবং তিনি করেছেন","audioUrl":"wbw/025_053_012.mp3","charTypeName":"word"},{"id":50610,"position":12,"arabic":"بَيْنَهُمَا","translation":"উভয়ের মাঝে","audioUrl":"wbw/025_053_013.mp3","charTypeName":"word"},{"id":50611,"position":13,"arabic":"بَرْزَخًۭا","translation":"অন্তরায়","audioUrl":"wbw/025_053_014.mp3","charTypeName":"word"},{"id":50612,"position":14,"arabic":"وَحِجْرًۭا","translation":"ও আড়াল","audioUrl":"wbw/025_053_015.mp3","charTypeName":"word"},{"id":50613,"position":15,"arabic":"مَّحْجُورًۭا","translation":"দুর্ভেদ্য","audioUrl":"wbw/025_053_016.mp3","charTypeName":"word"},{"id":50614,"position":16,"arabic":"٥٣","translation":"(৫৩)","audioUrl":null,"charTypeName":"end"}]},{"number":54,"arabic":"وَهُوَ ٱلَّذِى خَلَقَ مِنَ ٱلْمَآءِ بَشَرًۭا فَجَعَلَهُۥ نَسَبًۭا وَصِهْرًۭا ۗ وَكَانَ رَبُّكَ قَدِيرًۭا","translation":"And He it is who out of this [very] water has created man, and has endowed him with [the con­sciousness of] descent and marriage-tie: for thy Sustainer is ever infinite in His power.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2909.mp3","surahId":25,"words":[{"id":51085,"position":1,"arabic":"وَهُوَ","translation":"এবং তিনিই","audioUrl":"wbw/025_054_001.mp3","charTypeName":"word"},{"id":51086,"position":2,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/025_054_002.mp3","charTypeName":"word"},{"id":51087,"position":3,"arabic":"خَلَقَ","translation":"সৃষ্টি করেছেন","audioUrl":"wbw/025_054_003.mp3","charTypeName":"word"},{"id":51088,"position":4,"arabic":"مِنَ","translation":"হ'তে","audioUrl":"wbw/025_054_004.mp3","charTypeName":"word"},{"id":51089,"position":5,"arabic":"ٱلْمَآءِ","translation":"পানি","audioUrl":"wbw/025_054_005.mp3","charTypeName":"word"},{"id":51090,"position":6,"arabic":"بَشَرًۭا","translation":"মানুষকে","audioUrl":"wbw/025_054_006.mp3","charTypeName":"word"},{"id":51091,"position":7,"arabic":"فَجَعَلَهُۥ","translation":"অতঃপর তা স্থাপন করেছেন","audioUrl":"wbw/025_054_007.mp3","charTypeName":"word"},{"id":51092,"position":8,"arabic":"نَسَبًۭا","translation":"বংশগত সম্পর্ক","audioUrl":"wbw/025_054_008.mp3","charTypeName":"word"},{"id":51093,"position":9,"arabic":"وَصِهْرًۭا ۗ","translation":"ও বৈবাহিক সম্পর্ক","audioUrl":"wbw/025_054_009.mp3","charTypeName":"word"},{"id":51095,"position":10,"arabic":"وَكَانَ","translation":"আর হলেন","audioUrl":"wbw/025_054_011.mp3","charTypeName":"word"},{"id":51096,"position":11,"arabic":"رَبُّكَ","translation":"তোমার রব","audioUrl":"wbw/025_054_012.mp3","charTypeName":"word"},{"id":51097,"position":12,"arabic":"قَدِيرًۭا","translation":"(সবকিছুর উপর) শক্তিমান","audioUrl":"wbw/025_054_013.mp3","charTypeName":"word"},{"id":51098,"position":13,"arabic":"٥٤","translation":"(৫৪)","audioUrl":null,"charTypeName":"end"}]},{"number":55,"arabic":"وَيَعْبُدُونَ مِن دُونِ ٱللَّهِ مَا لَا يَنفَعُهُمْ وَلَا يَضُرُّهُمْ ۗ وَكَانَ ٱلْكَافِرُ عَلَىٰ رَبِّهِۦ ظَهِيرًۭا","translation":"And yet, some people worship, instead of God, things that can neither benefit them nor harm them: thus, he who denies the truth does indeed turn his back on his Sustainer!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2910.mp3","surahId":25,"words":[{"id":51647,"position":1,"arabic":"وَيَعْبُدُونَ","translation":"ও তারা ইবাদাত করে","audioUrl":"wbw/025_055_001.mp3","charTypeName":"word"},{"id":51648,"position":2,"arabic":"مِن","translation":"মধ্য হতে","audioUrl":"wbw/025_055_002.mp3","charTypeName":"word"},{"id":51649,"position":3,"arabic":"دُونِ","translation":"পরিবর্তে","audioUrl":"wbw/025_055_003.mp3","charTypeName":"word"},{"id":51650,"position":4,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/025_055_004.mp3","charTypeName":"word"},{"id":51651,"position":5,"arabic":"مَا","translation":"(এমন কিছুর) যা","audioUrl":"wbw/025_055_005.mp3","charTypeName":"word"},{"id":51652,"position":6,"arabic":"لَا","translation":"না","audioUrl":"wbw/025_055_006.mp3","charTypeName":"word"},{"id":51653,"position":7,"arabic":"يَنفَعُهُمْ","translation":"তাদের উপকার করতে পারে","audioUrl":"wbw/025_055_007.mp3","charTypeName":"word"},{"id":51654,"position":8,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/025_055_008.mp3","charTypeName":"word"},{"id":51655,"position":9,"arabic":"يَضُرُّهُمْ ۗ","translation":"তাদের ক্ষতি করতে পারে","audioUrl":"wbw/025_055_009.mp3","charTypeName":"word"},{"id":51657,"position":10,"arabic":"وَكَانَ","translation":"আর হলো","audioUrl":"wbw/025_055_011.mp3","charTypeName":"word"},{"id":51658,"position":11,"arabic":"ٱلْكَافِرُ","translation":"কাফিররা","audioUrl":"wbw/025_055_012.mp3","charTypeName":"word"},{"id":51659,"position":12,"arabic":"عَلَىٰ","translation":"বিরুদ্ধে","audioUrl":"wbw/025_055_013.mp3","charTypeName":"word"},{"id":51660,"position":13,"arabic":"رَبِّهِۦ","translation":"তার রবের","audioUrl":"wbw/025_055_014.mp3","charTypeName":"word"},{"id":51661,"position":14,"arabic":"ظَهِيرًۭا","translation":"সাহায্যকারী (প্রত্যেক বিদ্রোহীর)","audioUrl":"wbw/025_055_015.mp3","charTypeName":"word"},{"id":51662,"position":15,"arabic":"٥٥","translation":"(৫৫)","audioUrl":null,"charTypeName":"end"}]}]}