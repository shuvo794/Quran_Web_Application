{"id":358,"ayahs":[{"number":59,"arabic":"وَإِذَا بَلَغَ ٱلْأَطْفَٰلُ مِنكُمُ ٱلْحُلُمَ فَلْيَسْتَـْٔذِنُوا۟ كَمَا ٱسْتَـْٔذَنَ ٱلَّذِينَ مِن قَبْلِهِمْ ۚ كَذَٰلِكَ يُبَيِّنُ ٱللَّهُ لَكُمْ ءَايَٰتِهِۦ ۗ وَٱللَّهُ عَلِيمٌ حَكِيمٌۭ","translation":"Yet when the children among you attain to puberty, let them ask leave of you [at all times], even as those [who have reached maturity] before them have been enjoined to ask it. In this way God makes clear unto you His mes­sages: for God is all-knowing, wise!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2850.mp3","surahId":24,"words":[{"id":53714,"position":1,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/024_059_001.mp3","charTypeName":"word"},{"id":53715,"position":2,"arabic":"بَلَغَ","translation":"পৌঁছে","audioUrl":"wbw/024_059_002.mp3","charTypeName":"word"},{"id":53716,"position":3,"arabic":"ٱلْأَطْفَـٰلُ","translation":"ছেলেমেয়েরা","audioUrl":"wbw/024_059_003.mp3","charTypeName":"word"},{"id":53717,"position":4,"arabic":"مِنكُمُ","translation":"তোমাদের মধ্য থেকে","audioUrl":"wbw/024_059_004.mp3","charTypeName":"word"},{"id":53718,"position":5,"arabic":"ٱلْحُلُمَ","translation":"প্রাপ্ত বয়সে","audioUrl":"wbw/024_059_005.mp3","charTypeName":"word"},{"id":53719,"position":6,"arabic":"فَلْيَسْتَـْٔذِنُوا۟","translation":"তখন যেন তারা অনুমতি নেয়","audioUrl":"wbw/024_059_006.mp3","charTypeName":"word"},{"id":53720,"position":7,"arabic":"كَمَا","translation":"যেমন","audioUrl":"wbw/024_059_007.mp3","charTypeName":"word"},{"id":53721,"position":8,"arabic":"ٱسْتَـْٔذَنَ","translation":"অনুমতি নেয়","audioUrl":"wbw/024_059_008.mp3","charTypeName":"word"},{"id":53722,"position":9,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/024_059_009.mp3","charTypeName":"word"},{"id":53723,"position":10,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/024_059_010.mp3","charTypeName":"word"},{"id":53724,"position":11,"arabic":"قَبْلِهِمْ ۚ","translation":"পূর্ব তাদের (বয়োপ্রাপ্ত হয়েছে)","audioUrl":"wbw/024_059_011.mp3","charTypeName":"word"},{"id":53726,"position":12,"arabic":"كَذَٰلِكَ","translation":"এভাবে","audioUrl":"wbw/024_059_013.mp3","charTypeName":"word"},{"id":53727,"position":13,"arabic":"يُبَيِّنُ","translation":"বর্ণনা করেন","audioUrl":"wbw/024_059_014.mp3","charTypeName":"word"},{"id":53728,"position":14,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/024_059_015.mp3","charTypeName":"word"},{"id":53729,"position":15,"arabic":"لَكُمْ","translation":"জন্যে তোমাদের","audioUrl":"wbw/024_059_016.mp3","charTypeName":"word"},{"id":53730,"position":16,"arabic":"ءَايَـٰتِهِۦ ۗ","translation":"তাঁর নিদর্শনাবলী","audioUrl":"wbw/024_059_017.mp3","charTypeName":"word"},{"id":53732,"position":17,"arabic":"وَٱللَّهُ","translation":"আর আল্লাহ্‌","audioUrl":"wbw/024_059_019.mp3","charTypeName":"word"},{"id":53733,"position":18,"arabic":"عَلِيمٌ","translation":"সর্বজ্ঞ","audioUrl":"wbw/024_059_020.mp3","charTypeName":"word"},{"id":53734,"position":19,"arabic":"حَكِيمٌۭ","translation":"প্রজ্ঞাময়","audioUrl":"wbw/024_059_021.mp3","charTypeName":"word"},{"id":53735,"position":20,"arabic":"٥٩","translation":"(৫৯)","audioUrl":null,"charTypeName":"end"}]},{"number":60,"arabic":"وَٱلْقَوَٰعِدُ مِنَ ٱلنِّسَآءِ ٱلَّٰتِى لَا يَرْجُونَ نِكَاحًۭا فَلَيْسَ عَلَيْهِنَّ جُنَاحٌ أَن يَضَعْنَ ثِيَابَهُنَّ غَيْرَ مُتَبَرِّجَٰتٍۭ بِزِينَةٍۢ ۖ وَأَن يَسْتَعْفِفْنَ خَيْرٌۭ لَّهُنَّ ۗ وَٱللَّهُ سَمِيعٌ عَلِيمٌۭ","translation":"AND [know that] women advanced in years, who no longer feel any sexual desire, incur no sin if they discard their [outer] garments, provided they do not aim at a showy display of [their] charms. But [even so,] it is better for them to abstain [from this]: and God is all-hearing, all-knowing.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2851.mp3","surahId":24,"words":[{"id":54521,"position":1,"arabic":"وَٱلْقَوَٰعِدُ","translation":"এবং (যৌবন) অতিক্রমকারিনী","audioUrl":"wbw/024_060_001.mp3","charTypeName":"word"},{"id":54522,"position":2,"arabic":"مِنَ","translation":"মধ্য হ'তে","audioUrl":"wbw/024_060_002.mp3","charTypeName":"word"},{"id":54523,"position":3,"arabic":"ٱلنِّسَآءِ","translation":"স্ত্রীলোকদের","audioUrl":"wbw/024_060_003.mp3","charTypeName":"word"},{"id":54524,"position":4,"arabic":"ٱلَّـٰتِى","translation":"যারা","audioUrl":"wbw/024_060_004.mp3","charTypeName":"word"},{"id":54525,"position":5,"arabic":"لَا","translation":"না","audioUrl":"wbw/024_060_005.mp3","charTypeName":"word"},{"id":54526,"position":6,"arabic":"يَرْجُونَ","translation":"তারা আশা রাখে","audioUrl":"wbw/024_060_006.mp3","charTypeName":"word"},{"id":54527,"position":7,"arabic":"نِكَاحًۭا","translation":"বিয়ের","audioUrl":"wbw/024_060_007.mp3","charTypeName":"word"},{"id":54528,"position":8,"arabic":"فَلَيْسَ","translation":"সেক্ষেত্রে নেই","audioUrl":"wbw/024_060_008.mp3","charTypeName":"word"},{"id":54529,"position":9,"arabic":"عَلَيْهِنَّ","translation":"জন্যে তাদের","audioUrl":"wbw/024_060_009.mp3","charTypeName":"word"},{"id":54530,"position":10,"arabic":"جُنَاحٌ","translation":"কোন পাপ","audioUrl":"wbw/024_060_010.mp3","charTypeName":"word"},{"id":54531,"position":11,"arabic":"أَن","translation":"যে","audioUrl":"wbw/024_060_011.mp3","charTypeName":"word"},{"id":54532,"position":12,"arabic":"يَضَعْنَ","translation":"তারা খুলে রাখে","audioUrl":"wbw/024_060_012.mp3","charTypeName":"word"},{"id":54533,"position":13,"arabic":"ثِيَابَهُنَّ","translation":"তাদের পোষাক (অতিরিক্ত)","audioUrl":"wbw/024_060_013.mp3","charTypeName":"word"},{"id":54534,"position":14,"arabic":"غَيْرَ","translation":"না","audioUrl":"wbw/024_060_014.mp3","charTypeName":"word"},{"id":54535,"position":15,"arabic":"مُتَبَرِّجَـٰتٍۭ","translation":"প্রদর্শনকারিনীরূপে","audioUrl":"wbw/024_060_015.mp3","charTypeName":"word"},{"id":54536,"position":16,"arabic":"بِزِينَةٍۢ ۖ","translation":"ব্যাপারে রূপসৌন্দর্যের","audioUrl":"wbw/024_060_016.mp3","charTypeName":"word"},{"id":54538,"position":17,"arabic":"وَأَن","translation":"আর যে","audioUrl":"wbw/024_060_018.mp3","charTypeName":"word"},{"id":54539,"position":18,"arabic":"يَسْتَعْفِفْنَ","translation":"বিরত থাকে তারা","audioUrl":"wbw/024_060_019.mp3","charTypeName":"word"},{"id":54540,"position":19,"arabic":"خَيْرٌۭ","translation":"উত্তম","audioUrl":"wbw/024_060_020.mp3","charTypeName":"word"},{"id":54541,"position":20,"arabic":"لَّهُنَّ ۗ","translation":"জন্যে তাদের","audioUrl":"wbw/024_060_021.mp3","charTypeName":"word"},{"id":54543,"position":21,"arabic":"وَٱللَّهُ","translation":"আর আল্লাহ","audioUrl":"wbw/024_060_023.mp3","charTypeName":"word"},{"id":54544,"position":22,"arabic":"سَمِيعٌ","translation":"সবকিছু শুনেন","audioUrl":"wbw/024_060_024.mp3","charTypeName":"word"},{"id":54545,"position":23,"arabic":"عَلِيمٌۭ","translation":"সবকিছুু জানেন","audioUrl":"wbw/024_060_025.mp3","charTypeName":"word"},{"id":54546,"position":24,"arabic":"٦٠","translation":"(৬০)","audioUrl":null,"charTypeName":"end"}]},{"number":61,"arabic":"لَّيْسَ عَلَى ٱلْأَعْمَىٰ حَرَجٌۭ وَلَا عَلَى ٱلْأَعْرَجِ حَرَجٌۭ وَلَا عَلَى ٱلْمَرِيضِ حَرَجٌۭ وَلَا عَلَىٰٓ أَنفُسِكُمْ أَن تَأْكُلُوا۟ مِنۢ بُيُوتِكُمْ أَوْ بُيُوتِ ءَابَآئِكُمْ أَوْ بُيُوتِ أُمَّهَٰتِكُمْ أَوْ بُيُوتِ إِخْوَٰنِكُمْ أَوْ بُيُوتِ أَخَوَٰتِكُمْ أَوْ بُيُوتِ أَعْمَٰمِكُمْ أَوْ بُيُوتِ عَمَّٰتِكُمْ أَوْ بُيُوتِ أَخْوَٰلِكُمْ أَوْ بُيُوتِ خَٰلَٰتِكُمْ أَوْ مَا مَلَكْتُم مَّفَاتِحَهُۥٓ أَوْ صَدِيقِكُمْ ۚ لَيْسَ عَلَيْكُمْ جُنَاحٌ أَن تَأْكُلُوا۟ جَمِيعًا أَوْ أَشْتَاتًۭا ۚ فَإِذَا دَخَلْتُم بُيُوتًۭا فَسَلِّمُوا۟ عَلَىٰٓ أَنفُسِكُمْ تَحِيَّةًۭ مِّنْ عِندِ ٱللَّهِ مُبَٰرَكَةًۭ طَيِّبَةًۭ ۚ كَذَٰلِكَ يُبَيِّنُ ٱللَّهُ لَكُمُ ٱلْءَايَٰتِ لَعَلَّكُمْ تَعْقِلُونَ","translation":"[ALL OF YOU, O believers, are brethren: hence.] no blame attaches to the blind, nor does blame attach to the lame, nor does blame attach to the sick [for accepting charity from the hale], and neither to your­selves for eating [whatever is offered to you by others, whether it be food obtained] from your [chil­dren’s] houses, or your fathers’ houses, or your mothers’ houses, or your brothers’ houses, or your sisters’ houses, or your paternal uncles’ houses, or your paternal aunts’ houses, or your maternal uncles’ houses, or your maternal aunts’ houses, or [houses] the keys whereof are in your charge! or [the house] of any of your friends; nor will you incur any sin by eating in company or separately. But whenever you enter [any of these] houses, greet one another with a blessed, goodly greeting, as enjoined by God. In this way God makes clear unto you His mes­sages, so that you might [learn to] use your reason.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2852.mp3","surahId":24,"words":[{"id":54882,"position":1,"arabic":"لَّيْسَ","translation":"নেই","audioUrl":"wbw/024_061_001.mp3","charTypeName":"word"},{"id":54883,"position":2,"arabic":"عَلَى","translation":"জন্য","audioUrl":"wbw/024_061_002.mp3","charTypeName":"word"},{"id":54884,"position":3,"arabic":"ٱلْأَعْمَىٰ","translation":"অন্ধের","audioUrl":"wbw/024_061_003.mp3","charTypeName":"word"},{"id":54885,"position":4,"arabic":"حَرَجٌۭ","translation":"কোন দোষ","audioUrl":"wbw/024_061_004.mp3","charTypeName":"word"},{"id":54886,"position":5,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/024_061_005.mp3","charTypeName":"word"},{"id":54887,"position":6,"arabic":"عَلَى","translation":"জন্যে","audioUrl":"wbw/024_061_006.mp3","charTypeName":"word"},{"id":54888,"position":7,"arabic":"ٱلْأَعْرَجِ","translation":"পঙ্গুর","audioUrl":"wbw/024_061_007.mp3","charTypeName":"word"},{"id":54889,"position":8,"arabic":"حَرَجٌۭ","translation":"কোন দোষ","audioUrl":"wbw/024_061_008.mp3","charTypeName":"word"},{"id":54890,"position":9,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/024_061_009.mp3","charTypeName":"word"},{"id":54891,"position":10,"arabic":"عَلَى","translation":"জন্যে","audioUrl":"wbw/024_061_010.mp3","charTypeName":"word"},{"id":54892,"position":11,"arabic":"ٱلْمَرِيضِ","translation":"রোগীর","audioUrl":"wbw/024_061_011.mp3","cha