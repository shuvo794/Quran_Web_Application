wbw/009_116_006.mp3","charTypeName":"word"},{"id":75550,"position":7,"arabic":"يُحْىِۦ","translation":"তিনি জীবিত করেন","audioUrl":"wbw/009_116_008.mp3","charTypeName":"word"},{"id":75551,"position":8,"arabic":"وَيُمِيتُ ۚ","translation":"এবং তিনি মৃত্যু ঘটান","audioUrl":"wbw/009_116_009.mp3","charTypeName":"word"},{"id":75553,"position":9,"arabic":"وَمَا","translation":"এবং নেই","audioUrl":"wbw/009_116_011.mp3","charTypeName":"word"},{"id":75554,"position":10,"arabic":"لَكُم","translation":"জন্যে তোমাদের","audioUrl":"wbw/009_116_012.mp3","charTypeName":"word"},{"id":75555,"position":11,"arabic":"مِّن","translation":"দিয়ে","audioUrl":"wbw/009_116_013.mp3","charTypeName":"word"},{"id":75556,"position":12,"arabic":"دُونِ","translation":"ছেড়ে","audioUrl":"wbw/009_116_014.mp3","charTypeName":"word"},{"id":75557,"position":13,"arabic":"ٱللَّهِ","translation":"আল্লাহ","audioUrl":"wbw/009_116_015.mp3","charTypeName":"word"},{"id":75558,"position":14,"arabic":"مِن","translation":"কোনো","audioUrl":"wbw/009_116_016.mp3","charTypeName":"word"},{"id":75559,"position":15,"arabic":"وَلِىٍّۢ","translation":"অভিভাবক","audioUrl":"wbw/009_116_017.mp3","charTypeName":"word"},{"id":75560,"position":16,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/009_116_018.mp3","charTypeName":"word"},{"id":75561,"position":17,"arabic":"نَصِيرٍۢ","translation":"সাহায্যকারী","audioUrl":"wbw/009_116_019.mp3","charTypeName":"word"},{"id":75562,"position":18,"arabic":"١١٦","translation":"(১১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":117,"arabic":"لَّقَد تَّابَ ٱللَّهُ عَلَى ٱلنَّبِىِّ وَٱلْمُهَٰجِرِينَ وَٱلْأَنصَارِ ٱلَّذِينَ ٱتَّبَعُوهُ فِى سَاعَةِ ٱلْعُسْرَةِ مِنۢ بَعْدِ مَا كَادَ يَزِيغُ قُلُوبُ فَرِيقٍۢ مِّنْهُمْ ثُمَّ تَابَ عَلَيْهِمْ ۚ إِنَّهُۥ بِهِمْ رَءُوفٌۭ رَّحِيمٌۭ","translation":"INDEED, God has turned in His mercy unto the Prophet, as well as unto those who have forsaken the domain of evil and those who have sheltered and succoured the Faiths - [all] those who followed him in the hour of distress, when the hearts of some of the other believers had well-nigh swerved from faith. And once again: He has turned unto them in His mercy - for, behold, He is compassionate towards them, a dispenser of grace.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1352.mp3","surahId":9,"words":[{"id":75766,"position":1,"arabic":"لَّقَد","translation":"নিশ্চয়ই","audioUrl":"wbw/009_117_001.mp3","charTypeName":"word"},{"id":75767,"position":2,"arabic":"تَّابَ","translation":"ক্ষমা করলেন","audioUrl":"wbw/009_117_002.mp3","charTypeName":"word"},{"id":75768,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/009_117_003.mp3","charTypeName":"word"},{"id":75769,"position":4,"arabic":"عَلَى","translation":"প্রতি","audioUrl":"wbw/009_117_004.mp3","charTypeName":"word"},{"id":75770,"position":5,"arabic":"ٱلنَّبِىِّ","translation":"নাবীর","audioUrl":"wbw/009_117_005.mp3","charTypeName":"word"},{"id":75771,"position":6,"arabic":"وَٱلْمُهَـٰجِرِينَ","translation":"এবং মুহাজিরদের","audioUrl":"wbw/009_117_006.mp3","charTypeName":"word"},{"id":75772,"position":7,"arabic":"وَٱلْأَنصَارِ","translation":"ও আনসারদের (প্রতি)","audioUrl":"wbw/009_117_007.mp3","charTypeName":"word"},{"id":75773,"position":8,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/009_117_008.mp3","charTypeName":"word"},{"id":75774,"position":9,"arabic":"ٱتَّبَعُوهُ","translation":"অনুসরণ করেছে তাকে","audioUrl":"wbw/009_117_009.mp3","charTypeName":"word"},{"id":75775,"position":10,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/009_117_010.mp3","charTypeName":"word"},{"id":75776,"position":11,"arabic":"سَاعَةِ","translation":"সময়ের","audioUrl":"wbw/009_117_011.mp3","charTypeName":"word"},{"id":75777,"position":12,"arabic":"ٱلْعُسْرَةِ","translation":"কঠিন","audioUrl":"wbw/009_117_012.mp3","charTypeName":"word"},{"id":75778,"position":13,"arabic":"مِنۢ","translation":"থেকে","audioUrl":"wbw/009_117_013.mp3","charTypeName":"word"},{"id":75779,"position"