{"id":205,"ayahs":[{"number":112,"arabic":"ٱلتَّٰٓئِبُونَ ٱلْعَٰبِدُونَ ٱلْحَٰمِدُونَ ٱلسَّٰٓئِحُونَ ٱلرَّٰكِعُونَ ٱلسَّٰجِدُونَ ٱلْءَامِرُونَ بِٱلْمَعْرُوفِ وَٱلنَّاهُونَ عَنِ ٱلْمُنكَرِ وَٱلْحَٰفِظُونَ لِحُدُودِ ٱللَّهِ ۗ وَبَشِّرِ ٱلْمُؤْمِنِينَ","translation":"[It is a triumph of] those who turn [unto God] in repentance [whenever they have sinned], and who worship and praise [Him], and go on and on [seeking His goodly acceptance], and bow down [before Him] and prostrate themselves in adoration, and enjoin the doing of what is right and forbid the doing of what is wrong, and keep to the bounds set by God. And give thou [O Prophet] the glad tiding [of God's promise] to all believers.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1347.mp3","surahId":9,"words":[{"id":74807,"position":1,"arabic":"ٱلتَّـٰٓئِبُونَ","translation":"(তারা) তওবাকারী","audioUrl":"wbw/009_112_001.mp3","charTypeName":"word"},{"id":74808,"position":2,"arabic":"ٱلْعَـٰبِدُونَ","translation":"ইবাদতকারী","audioUrl":"wbw/009_112_002.mp3","charTypeName":"word"},{"id":74809,"position":3,"arabic":"ٱلْحَـٰمِدُونَ","translation":"(আল্লাহর) প্রশংসাকারী","audioUrl":"wbw/009_112_003.mp3","charTypeName":"word"},{"id":74810,"position":4,"arabic":"ٱلسَّـٰٓئِحُونَ","translation":"সিয়াম পালনকারী","audioUrl":"wbw/009_112_004.mp3","charTypeName":"word"},{"id":74811,"position":5,"arabic":"ٱلرَّٰكِعُونَ","translation":"রুকুকারী","audioUrl":"wbw/009_112_005.mp3","charTypeName":"word"},{"id":74812,"position":6,"arabic":"ٱلسَّـٰجِدُونَ","translation":"সিজদাকারী","audioUrl":"wbw/009_112_006.mp3","charTypeName":"word"},{"id":74813,"position":7,"arabic":"ٱلْـَٔامِرُونَ","translation":"নির্দেশদানকারী","audioUrl":"wbw/009_112_007.mp3","charTypeName":"word"},{"id":74814,"position":8,"arabic":"بِٱلْمَعْرُوفِ","translation":"ব্যাপারে ভালো কাজের","audioUrl":"wbw/009_112_008.mp3","charTypeName":"word"},{"id":74815,"position":9,"arabic":"وَٱلنَّاهُونَ","translation":"ও নিষেধকারী","audioUrl":"wbw/009_112_009.mp3","charTypeName":"word"},{"id":74816,"position":10,"arabic":"عَنِ","translation":"হতে","audioUrl":"wbw/009_112_010.mp3","charTypeName":"word"},{"id":74817,"position":11,"arabic":"ٱلْمُنكَرِ","translation":"মন্দকাজ","audioUrl":"wbw/009_112_011.mp3","charTypeName":"word"},{"id":74818,"position":12,"arabic":"وَٱلْحَـٰفِظُونَ","translation":"এবং সংরক্ষণকারী","audioUrl":"wbw/009_112_012.mp3","charTypeName":"word"},{"id":74819,"position":13,"arabic":"لِحُدُودِ","translation":"প্রতি সীমারেখার","audioUrl":"wbw/009_112_013.mp3","charTypeName":"word"},{"id":74820,"position":14,"arabic":"ٱللَّهِ ۗ","translation":"আল্লাহর","audioUrl":"wbw/009_112_014.mp3","charTypeName":"word"},{"id":74822,"position":15,"arabic":"وَبَشِّرِ","translation":"আর তুমি সুসংবাদ দাও","audioUrl":"wbw/009_112_016.mp3","charTypeName":"word"},{"id":74823,"position":16,"arabic":"ٱلْمُؤْمِنِينَ","translation":"(ঐসব) মু'মিনদেরকে","audioUrl":"wbw/009_112_017.mp3","charTypeName":"word"},{"id":74824,"position":17,"arabic":"١١٢","translation":"(১১২)","audioUrl":null,"charTypeName":"end"}]},{"number":113,"arabic":"مَا كَانَ لِلنَّبِىِّ وَٱلَّذِينَ ءَامَنُوٓا۟ أَن يَسْتَغْفِرُوا۟ لِلْمُشْرِكِينَ وَلَوْ كَانُوٓا۟ أُو۟لِى قُرْبَىٰ مِنۢ بَعْدِ مَا تَبَيَّنَ لَهُمْ أَنَّهُمْ أَصْحَٰبُ ٱلْجَحِيمِ","translation":"IT DOES NOT behove the Prophet and those who have attained to faith to pray that they who ascribed divinity to aught beside God be forgiven [by Him] even though they happened to be [their] near of kin -after it has been made clear unto them that those [dead sinners] are destined for. the blazing fire.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1348.mp3","surahId":9,"words":[{"id":74983,"position":1,"arabic":"مَا","translation":"নয়","audioUrl":"wbw/009_113_001.mp3","charTypeName":"word"},{"id":74984,"position":2,"arabic":"كَانَ","translation":"শোভনীয়","audioUrl":"wbw/009_113_002.mp3","charTypeName":"word"},{"id":74985,"position":3,"arabic":"لِلنَّبِىِّ","translation":"জন্যে নাবীর","audioUrl":"wbw/009_113_003.mp3","charTypeName":"word"},{"id":74986,"position":4,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/009_113_004.mp3","charTypeName":"word"},{"id":74987,"position":5,"arabic":"ءَامَنُوٓا۟","translation":"ঈমান এনেছে (তাদের জন্যে)","audioUrl":"wbw/009_113_005.mp3","charTypeName":"word"},{"id":74988,"position":6,"arabic":"أَن","translation":"যে","audioUrl":"wbw/009_113_006.mp3","charTypeName":"word"},{"id":74989,"position":7,"arabic":"يَسْتَغْفِرُوا۟","translation":"তারা ক্ষমা চাইবে (আল্লাহর কাছে)","audioUrl":"wbw/009_113_007.mp3","charTypeName":"word"},{"id":74990,"position":8,"arabic":"لِلْمُشْرِكِينَ","translation":"জন্যে মুশরিকদের","audioUrl":"wbw/009_113_008.mp3","charTypeName":"word"},{"id":74991,"position":9,"arabic":"وَلَوْ","translation":"এবং যদিও","audioUrl":"wbw/009_113_009.mp3","charTypeName":"word"},{"id":74992,"position":10,"arabic":"كَانُوٓا۟","translation":"তারা হয়","audioUrl":"wbw/009_113_010.mp3","charTypeName":"word"},{"id":74993,"position":11,"arabic":"أُو۟لِى","translation":"সম্পন্নরা","audioUrl":"wbw/009_113_011.mp3","charTypeName":"word"},{"id":74994,"position":12,"arabic":"قُرْبَىٰ","translation":"নৈকট্য","audioUrl":"wbw/009_113_012.mp3","charTypeName":"word"},{"id":74995,"position":13,"arabic":"مِنۢ","translation":"থেকেও","audioUrl":"wbw/009_113_013.mp3","charTypeName":"word"},{"id":74996,"position":14,"arabic":"بَعْدِ","translation":"পর","audioUrl":"wbw/009_113_014.mp3","charTypeName":"word"},{"id":74997,"position":15,"arabic":"مَا","translation":"যা","audioUrl":"wbw/009_113_015.mp3","charTypeName":"word"},{"id":74998,"position":16,"arabic":"تَبَيَّنَ","translation":"স্পষ্ট হয়েছে","audioUrl":"wbw/009_113_016.mp3","charTypeName":"word"},{"id":74999,"position":17,"arabic":"لَهُمْ","translation":"কাছে তাদের","audioUrl":"wbw/009_113_017.mp3","charTypeName":"word"},{"id":75000,"position":18,"arabic":"أَنَّهُمْ","translation":"যে তারা","audioUrl":"wbw/009_113_018.mp3","charTypeName":"word"},{"id":75001,"position":19,"arabic":"أَصْحَـٰبُ","translation":"অধিবাসী","audioUrl":"wbw/009_113_019.mp3","charTypeName":"word"},{"id":75002,"position":20,"arabic":"ٱلْجَحِيمِ","translation":"জাহান্নামের","audioUrl":"wbw/009_113_020.mp3","charTypeName":"word"},{"id":75003,"position":21,"arabic":"١١٣","translation":"(১১৩)","audioUrl":null,"charTypeName":"end"}]},{"number":114,"arabic":"وَمَا كَانَ ٱسْتِغْفَارُ إِبْرَٰهِيمَ لِأَبِيهِ إِلَّا عَن مَّوْعِدَةٍۢ وَعَدَهَآ إِيَّاهُ فَلَمَّا تَبَيَّنَ لَهُۥٓ أَنَّهُۥ عَدُوٌّۭ لِّلَّهِ تَبَرَّأَ مِنْهُ ۚ إِنَّ إِبْرَٰهِيمَ لَأَوَّٰهٌ حَلِيمٌۭ","translation":"And Abraham's prayer that his father be forgiven was but due to a promise which he had given the latter [in his lifetime]; but when it was made clear unto him that he had been God's enemy, [Abraham] disavowed him - [although;] behold, Abraham was most tender-hearted. most clement.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1349.mp3","surahId":9,"words":[{"id":75231,"position":1,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/009_114_001.mp3","charTypeName":"word"},{"id":75232,"position":2,"arabic":"كَانَ","translation":"ছিলো","audioUrl":"wbw/009_114_002.mp3","charTypeName":"word"},{"id":75233,"position":3,"arabic":"ٱسْتِغْفَارُ","translation":"ক্ষমা চাওয়া","audioUrl":"wbw/009_114_003.mp3","charTypeName":"word"},{"id":75234,"position":4,"arabic":"إِبْرَٰهِيمَ","translation":"ইবরাহীমের","audioUrl":"wbw/009_114_004.mp3","charTypeName":"word"},{"id":75235,"position":5,"arabic":"لِأَبِيهِ","translation":"জন্যে পিতার তার","audioUrl":"wbw/009_114_005.mp3","charTypeName":"word"},{"id":75236,"position":6,"arabic":"إِلَّا","translation":"এ ছাড়া যে","audioUrl":"wbw/009_114_006.mp3","charTypeName":"word"},{"id":75237,"position":7,"arabic":"عَن","translation":"জন্যে","audioUrl":"wbw/009_114_007.mp3","charTypeName":"word"},{"id":75238,"position":8,"arabic":"مَّوْعِدَةٍۢ","translation":"প্রতিশ্রুতির","audioUrl":"wbw/009_114_008.mp3","charTypeName":"word"},{"id":75239,"position":9,"arabic":"وَعَدَهَآ","translation":"যা সে প্রতিশ্রুতি দিয়েছিলো","audioUrl":"wbw/009_114_009.mp3","charTypeName":"word"},{"id":75240,"position":10,"arabic":"إِيَّاهُ","translation":"কাছে তার","audioUrl":"wbw/009_114_010.mp3","charTypeName":"word"},{"id":75241,"position":11,"arabic":"فَلَمَّا","translation":"অতঃপর যখন","audioUrl":"wbw/009_114_011.mp3","charTypeName":"word"},{"id":75242,"position":12,"arabic":"تَبَيَّنَ","translation":"প্রকাশ হলো","audioUrl":"wbw/009_114_012.mp3","charTypeName":"word"},{"id":75243,"position":13,"arabic":"لَهُۥٓ","translation":"কাছে তার","audioUrl":"wbw/009_114_013.mp3","charTypeName":"word"},{"id":75244,"position":14,"arabic":"أَنَّهُۥ","translation":"যে সে","audioUrl":"wbw/009_114_014.mp3","charTypeName":"word"},{"id":75245,"position":15,"arabic":"عَدُوٌّۭ","translation":"শত্রু","audioUrl":"wbw/009_114_015.mp3","charTypeName":"word"},{"id":75246,"position":16,"arabic":"لِّلَّهِ","translation":"জন্যে আল্লাহর","audioUrl":"wbw/009_114_016.mp3","charTypeName":"word"},{"id":75247,"position":17,"arabic":"تَبَرَّأَ","translation":"সে সম্পর্ক ছিন্ন করলো","audioUrl":"wbw/009_114_017.mp3","charTypeName":"word"},{"id":75248,"position":18,"arabic":"مِنْهُ ۚ","translation":"থেকে তার","audioUrl":"wbw/009_114_018.mp3","charTypeName":"word"},{"id":75250,"position":19,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/009_114_020.mp3","charTypeName":"word"},{"id":75251,"position":20,"arabic":"إِبْرَٰهِيمَ","translation":"ইবরাহীম (ছিলো)","audioUrl":"wbw/009_114_021.mp3","charTypeName":"word"},{"id":75252,"position":21,"arabic":"لَأَوَّٰهٌ","translation":"অবশ্যই কোমল হৃদয়ের","audioUrl":"wbw/009_114_022.mp3","charTypeName":"word"},{"id":75253,"position":22,"arabic":"حَلِيمٌۭ","translation":"সহনশীল (মানুষ)","audioUrl":"wbw/009_114_023.mp3","charTypeName":"word"},{"id":75254,"position":23,"arabic":"١١٤","translation":"(১১৪)","audioUrl":null,"charTypeName":"end"}]},{"number":115,"arabic":"وَمَا كَانَ ٱللَّهُ لِيُضِلَّ قَوْمًۢا بَعْدَ إِذْ هَدَىٰهُمْ حَتَّىٰ يُبَيِّنَ لَهُم مَّا يَتَّقُونَ ۚ إِنَّ ٱللَّهَ بِكُلِّ شَىْءٍ عَلِيمٌ","translation":"And God would never-after having invited them to His guidance -condemn people for going astray ere He has made [entirely] clear unto them of what they should beware. Verily, God has full knowledge of everything.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1350.mp3","surahId":9,"words":[{"id":75363,"position":1,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/009_115_001.mp3","charTypeName":"word"},{"id":75364,"position":2,"arabic":"كَانَ","translation":"এমন হোন যে","audioUrl":"wbw/009_115_002.mp3","charTypeName":"word"},{"id":75365,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/009_115_003.mp3","charTypeName":"word"},{"id":75366,"position":4,"arabic":"لِيُضِلَّ","translation":"যেন তিনি পথভ্রষ্ট করেন","audioUrl":"wbw/009_115_004.mp3","charTypeName":"word"},{"id":75367,"position":5,"arabic":"قَوْمًۢا","translation":"সম্প্রদায়কে","audioUrl":"wbw/009_115_005.mp3","charTypeName":"word"},{"id":75368,"position":6,"arabic":"بَعْدَ","translation":"এরপরও","audioUrl":"wbw/009_115_006.mp3","charTypeName":"word"},{"id":75369,"position":7,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/009_115_007.mp3","charTypeName":"word"},{"id":75370,"position":8,"arabic":"هَدَىٰهُمْ","translation":"পথ প্রদর্শন করেছেন তাদেরকে","audioUrl":"wbw/009_115_008.mp3","charTypeName":"word"},{"id":75371,"position":9,"arabic":"حَتَّىٰ","translation":"যতক্ষণ না","audioUrl":"wbw/009_115_009.mp3","charTypeName":"word"},{"id":75372,"position":10,"arabic":"يُبَيِّنَ","translation":"স্পষ্ট বলে দেন","audioUrl":"wbw/009_115_010.mp3","charTypeName":"word"},{"id":75373,"position":11,"arabic":"لَهُم","translation":"কাছে তাদের","audioUrl":"wbw/009_115_011.mp3","charTypeName":"word"},{"id":75374,"position":12,"arabic":"مَّا","translation":"কি (থেকে)","audioUrl":"wbw/009_115_012.mp3","charTypeName":"word"},{"id":75375,"position":13,"arabic":"يَتَّقُونَ ۚ","trans