004_007.mp3","charTypeName":"word"},{"id":3982,"position":8,"arabic":"مِقْدَارُهُۥ","translation":"তার পরিমাপ","audioUrl":"wbw/070_004_008.mp3","charTypeName":"word"},{"id":3983,"position":9,"arabic":"خَمْسِينَ","translation":"পঞ্চাশ (হয়)","audioUrl":"wbw/070_004_009.mp3","charTypeName":"word"},{"id":3984,"position":10,"arabic":"أَلْفَ","translation":"হাজার","audioUrl":"wbw/070_004_010.mp3","charTypeName":"word"},{"id":3985,"position":11,"arabic":"سَنَةٍۢ","translation":"বছর","audioUrl":"wbw/070_004_011.mp3","charTypeName":"word"},{"id":3986,"position":12,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"فَٱصْبِرْ صَبْرًۭا جَمِيلًا","translation":"Therefore, [O believer,] endure all adversity with goodly patience:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5380.mp3","surahId":70,"words":[{"id":5286,"position":1,"arabic":"فَٱصْبِرْ","translation":"সুতরাং, ধৈর্য ধরুন","audioUrl":"wbw/070_005_001.mp3","charTypeName":"word"},{"id":5287,"position":2,"arabic":"صَبْرًۭا","translation":"ধৈর্য","audioUrl":"wbw/070_005_002.mp3","charTypeName":"word"},{"id":5288,"position":3,"arabic":"جَمِيلًا","translation":"উত্তম","audioUrl":"wbw/070_005_003.mp3","charTypeName":"word"},{"id":5289,"position":4,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"إِنَّهُمْ يَرَوْنَهُۥ بَعِيدًۭا","translation":"behold, men look upon that [reckoning] as something far away –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5381.mp3","surahId":70,"words":[{"id":6494,"position":1,"arabic":"إِنَّهُمْ","translation":"তারা নিশ্চয়","audioUrl":"wbw/070_006_001.mp3","charTypeName":"word"},{"id":6495,"position":2,"arabic":"يَرَوْنَهُۥ","translation":"তা দেখে","audioUrl":"wbw/070_006_002.mp3","charTypeName":"word"},{"id":6496,"position":3,"arabic":"بَعِيدًۭا","translation":"বহুদূরে","audioUrl":"wbw/070_006_003.mp3","charTypeName":"word"},{"id":6497,"position":4,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"وَنَرَىٰهُ قَرِيبًۭا","translation":"but, We see it as near!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5382.mp3","surahId":70,"words":[{"id":7904,"position":1,"arabic":"وَنَرَىٰهُ","translation":"কিন্তু আমরা তা দেখেছি","audioUrl":"wbw/070_007_001.mp3","charTypeName":"word"},{"id":7905,"position":2,"arabic":"قَرِيبًۭا","translation":"নিকটে","audioUrl":"wbw/070_007_002.mp3","charTypeName":"word"},{"id":7906,"position":3,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"يَوْمَ تَكُونُ ٱلسَّمَآءُ كَٱلْمُهْلِ","translation":"[It will take place] on a Day when the sky will be like molten lead,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5383.mp3","surahId":70,"words":[{"id":9081,"position":1,"arabic":"يَوْمَ","translation":"সেদিন","audioUrl":"wbw/070_008_001.mp3","charTypeName":"word"},{"id":9082,"position":2,"arabic":"تَكُونُ","translation":"হবে","audioUrl":"wbw/070_008_002.mp3","charTypeName":"word"},{"id":9083,"position":3,"arabic":"ٱلسَّمَآءُ","translation":"আকাশ","audioUrl":"wbw/070_008_003.mp3","charTypeName":"word"},{"id":9084,"position":4,"arabic":"كَٱلْمُهْلِ","translation":"গলিত ধাতুর মত,","audioUrl":"wbw/070_008_004.mp3","charTypeName":"word"},{"id":9085,"position":5,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"وَتَكُونُ ٱلْجِبَالُ كَٱلْعِهْنِ","translation":"and the mountains will be like tufts of wool,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5384.mp3","surahId":70,"words":[{"id":10295,"position":1,"arabic":"وَتَكُونُ","translation":"এবং হবে","audioUrl":"wbw/070_009_001.mp3","charTypeName":"word"},{"id":10296,"position":2,"arabic":"ٱلْجِبَالُ","translation":"পর্বতসমূহ","audioUrl":"wbw/070_009_002.mp3","charTypeName":"word"},{"id":10297,"position":3,"arabic":"كَٱلْعِهْنِ","translation":"রঙিন পশমের মত,","audioUrl":"wbw/070_009