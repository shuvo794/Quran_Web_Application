word"},{"id":12849,"position":6,"arabic":"مِنْ","translation":"থেকে","audioUrl":"wbw/070_011_007.mp3","charTypeName":"word"},{"id":12850,"position":7,"arabic":"عَذَابِ","translation":"আযাব","audioUrl":"wbw/070_011_008.mp3","charTypeName":"word"},{"id":12851,"position":8,"arabic":"يَوْمِئِذٍۭ","translation":"সেদিন","audioUrl":"wbw/070_011_009.mp3","charTypeName":"word"},{"id":12852,"position":9,"arabic":"بِبَنِيهِ","translation":"তার সন্তানদের দ্বারা","audioUrl":"wbw/070_011_010.mp3","charTypeName":"word"},{"id":12853,"position":10,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]},{"number":12,"arabic":"وَصَٰحِبَتِهِۦ وَأَخِيهِ","translation":"and of his spouse, and of his brother,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5387.mp3","surahId":70,"words":[{"id":14101,"position":1,"arabic":"وَصَـٰحِبَتِهِۦ","translation":"এবং তার স্ত্রী","audioUrl":"wbw/070_012_001.mp3","charTypeName":"word"},{"id":14102,"position":2,"arabic":"وَأَخِيهِ","translation":"এবং তার ভাই,","audioUrl":"wbw/070_012_002.mp3","charTypeName":"word"},{"id":14103,"position":3,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]},{"number":13,"arabic":"وَفَصِيلَتِهِ ٱلَّتِى تُـْٔوِيهِ","translation":"and of all the kinsfolk who ever sheltered him,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5388.mp3","surahId":70,"words":[{"id":15220,"position":1,"arabic":"وَفَصِيلَتِهِ","translation":"আর তার জ্ঞাতি-গোষ্ঠীকে","audioUrl":"wbw/070_013_001.mp3","charTypeName":"word"},{"id":15221,"position":2,"arabic":"ٱلَّتِى","translation":"যা","audioUrl":"wbw/070_013_002.mp3","charTypeName":"word"},{"id":15222,"position":3,"arabic":"تُـْٔوِيهِ","translation":"তাকে আশ্রয় দেয়","audioUrl":"wbw/070_013_003.mp3","charTypeName":"word"},{"id":15223,"position":4,"arabic":"١٣","translation":"(১৩)","audioUrl":null,"charTypeName":"end"}]},{"number":14,"arabic":"وَمَن فِى ٱلْأَرْضِ جَمِيعًۭا ثُمَّ يُنجِيهِ","translation":"and of whoever [el