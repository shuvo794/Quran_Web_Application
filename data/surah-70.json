p3","charTypeName":"word"},{"id":18506,"position":2,"arabic":"لِّلشَّوَىٰ","translation":"চামড়াকে","audioUrl":"wbw/070_016_002.mp3","charTypeName":"word"},{"id":18507,"position":3,"arabic":"١٦","translation":"(১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":17,"arabic":"تَدْعُوا۟ مَنْ أَدْبَرَ وَتَوَلَّىٰ","translation":"It will claim all such as turn their backs [on what is right], and turn away [from the truth],","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5392.mp3","surahId":70,"words":[{"id":19511,"position":1,"arabic":"تَدْعُوا۟","translation":"আহবান করে","audioUrl":"wbw/070_017_001.mp3","charTypeName":"word"},{"id":19512,"position":2,"arabic":"مَنْ","translation":"যে","audioUrl":"wbw/070_017_002.mp3","charTypeName":"word"},{"id":19513,"position":3,"arabic":"أَدْبَرَ","translation":"পিঠ প্রদর্শন করে","audioUrl":"wbw/070_017_003.mp3","charTypeName":"word"},{"id":19514,"position":4,"arabic":"وَتَوَلَّىٰ","translation":"ও মুখ ফিরিয়ে","audioUrl":"wbw/070_017_004.mp3","charTypeName":"word"},{"id":19515,"position":5,"arabic":"١٧","translation":"(১৭)","audioUrl":null,"charTypeName":"end"}]},{"number":18,"arabic":"وَجَمَعَ فَأَوْعَىٰٓ","translation":"and amass [wealth] and thereupon withhold [it from their fellow-men].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5393.mp3","surahId":70,"words":[{"id":20600,"position":1,"arabic":"وَجَمَعَ","translation":"এবং জমা করেছে","audioUrl":"wbw/070_018_001.mp3","charTypeName":"word"},{"id":20601,"position":2,"arabic":"فَأَوْعَىٰٓ","translation":"অতঃপর তা সংরক্ষিত রেখেছে","audioUrl":"wbw/070_018_002.mp3","charTypeName":"word"},{"id":20602,"position":3,"arabic":"١٨","translation":"(১৮)","audioUrl":null,"charTypeName":"end"}]},{"number":19,"arabic":"۞ إِنَّ ٱلْإِنسَٰنَ خُلِقَ هَلُوعًا","translation":"VERILY, man is born with a restless disposition.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5394.mp3","surahId":70,"words":[{"id":22124,"position":1,"arabic":"۞ إِنَّ","translation":"নিশ্চয়","audioUrl":"wbw/070_019_002.mp3","charTypeName":"word"},{"id":22125,"position":2,"arabic":"ٱلْإِنسَـٰنَ","translation":"মানুষকে","audioUrl":"wbw/070_019_003.mp3","charTypeName":"word"},{"id":22126,"position":3,"arabic":"خُلِقَ","translation":"সৃষ্টি করা হয়েছে","audioUrl":"wbw/070_019_004.mp3","charTypeName":"word"},{"id":22127,"position":4,"arabic":"هَلُوعًا","translation":"অস্থির","audioUrl":"wbw/070_019_005.mp3","charTypeName":"word"},{"id":22128,"position":5,"arabic":"١٩","translation":"(১৯)","audioUrl":null,"charTypeName":"end"}]},{"number":20,"arabic":"إِذَا مَسَّهُ ٱلشَّرُّ جَزُوعًۭا","translation":"[As a rule,] whenever misfortune touches him, he is filled with self-pity;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5395.mp3","surahId":70,"words":[{"id":22746,"position":1,"arabic":"إِذَا","translation":"কখন","audioUrl":"wbw/070_020_001.mp3","charTypeName":"word"},{"id":22747,"position":2,"arabic":"مَسَّهُ","translation":"তাকে স্পর্শ করে","audioUrl":"wbw/070_020_002.mp3","charTypeName":"word"},{"id":22748,"position":3,"arabic":"ٱلشَّرُّ","translation":"মন্দ,","audioUrl":"wbw/070_020_003.mp3","charTypeName":"word"},{"id":22749,"position":4,"arabic":"جَزُوعًۭا","translation":"দুর্দশাগ্রস্ত.","audioUrl":"wbw/070_020_004.mp3","charTypeName":"word"},{"id":22750,"position":5,"arabic":"٢٠","translation":"(২০)","audioUrl":null,"charTypeName":"end"}]},{"number":21,"arabic":"وَإِذَا مَسَّهُ ٱلْخَيْرُ مَنُوعًا","translation":"and whenever good fortune comes to him, he selfishly withholds it [from others].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5396.mp3","surahId":70,"words":[{"id":23903,"position":1,"arabic":"وَإِذَا","translation":"এবং কখন","audioUrl":"wbw/070_021_001.mp3","charTypeName":"word"},{"id":23904,"position":2,"arabic":"مَسَّهُ","translation":"তাকে স্পর্শ করে","audioUrl":"wbw/070_021_002.mp3","charTypeName":"word"},{"id":23905,"position":3,"arabic":"ٱلْخَيْرُ","translation":"কল্যাণ","audioU