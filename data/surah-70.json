26_003.mp3","charTypeName":"word"},{"id":28998,"position":4,"arabic":"ٱلدِّينِ","translation":"বিচার","audioUrl":"wbw/070_026_004.mp3","charTypeName":"word"},{"id":28999,"position":5,"arabic":"٢٦","translation":"(২৬)","audioUrl":null,"charTypeName":"end"}]},{"number":27,"arabic":"وَٱلَّذِينَ هُم مِّنْ عَذَابِ رَبِّهِم مُّشْفِقُونَ","translation":"and who stand in dread of their Sustainer's chastisement –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5402.mp3","surahId":70,"words":[{"id":30268,"position":1,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/070_027_001.mp3","charTypeName":"word"},{"id":30269,"position":2,"arabic":"هُم","translation":"[তারা]","audioUrl":"wbw/070_027_002.mp3","charTypeName":"word"},{"id":30270,"position":3,"arabic":"مِّنْ","translation":"থেকে","audioUrl":"wbw/070_027_003.mp3","charTypeName":"word"},{"id":30271,"position":4,"arabic":"عَذَابِ","translation":"আযাব","audioUrl":"wbw/070_027_004.mp3","charTypeName":"word"},{"id":30272,"position":5,"arabic":"رَبِّهِم","translation":"তাদের রবের","audioUrl":"wbw/070_027_005.mp3","charTypeName":"word"},{"id":30273,"position":6,"arabic":"مُّشْفِقُونَ","translation":"ভয়কারী","audioUrl":"wbw/070_027_006.mp3","charTypeName":"word"},{"id":30274,"position":7,"arabic":"٢٧","translation":"(২৭)","audioUrl":null,"charTypeName":"end"}]},{"number":28,"arabic":"إِنَّ عَذَابَ رَبِّهِمْ غَيْرُ مَأْمُونٍۢ","translation":"for, behold, of their Sustainer's chastisement none may ever feel [wholly] secure;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5403.mp3","surahId":70,"words":[{"id":30935,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়","audioUrl":"wbw/070_028_001.mp3","charTypeName":"word"},{"id":30936,"position":2,"arabic":"عَذَابَ","translation":"আযাব","audioUrl":"wbw/070_028_002.mp3","charTypeName":"word"},{"id":30937,"position":3,"arabic":"رَبِّهِمْ","translation":"তাদের রবের","audioUrl":"wbw/070_028_003.mp3","charTypeName":"word"},{"id":30938,"positi