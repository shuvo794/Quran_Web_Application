{"id":70,"nameArabic":"سُورَةُ المَعَارِجِ","nameEnglish":"Al-Ma'aarij","nameTranslation":"The Ascending Stairways","revelationType":"Meccan","numberOfAyahs":44,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ سَأَلَ سَآئِلٌۢ بِعَذَابٍۢ وَاقِعٍۢ","translation":"ONE who is minded to ask might ask about the suffering which [in the hereafter] is bound to befall","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5376.mp3","surahId":70,"words":[{"id":594,"position":1,"arabic":"سَأَلَ","translation":"জিজ্ঞাসা করল","audioUrl":"wbw/070_001_001.mp3","charTypeName":"word"},{"id":595,"position":2,"arabic":"سَآئِلٌۢ","translation":"এক প্রশ্নকারী","audioUrl":"wbw/070_001_002.mp3","charTypeName":"word"},{"id":596,"position":3,"arabic":"بِعَذَابٍۢ","translation":"এমন আযাব সম্পর্কে","audioUrl":"wbw/070_001_003.mp3","charTypeName":"word"},{"id":597,"position":4,"arabic":"وَاقِعٍۢ","translation":"যা আপতিত হবে","audioUrl":"wbw/070_001_004.mp3","charTypeName":"word"},{"id":598,"position":5,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"لِّلْكَٰفِرِينَ لَيْسَ لَهُۥ دَافِعٌۭ","translation":"those who deny the truth. [Know, then, that] nothing can ward it off,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5377.mp3","surahId":70,"words":[{"id":1552,"position":1,"arabic":"لِّلْكَـٰفِرِينَ","translation":"কাফিরদের উপর,","audioUrl":"wbw/070_002_001.mp3","charTypeName":"word"},{"id":1553,"position":2,"arabic":"لَيْسَ","translation":"নেই","audioUrl":"wbw/070_002_002.mp3","charTypeName":"word"},{"id":1554,"position":3,"arabic":"لَهُۥ","translation":"তার","audioUrl":"wbw/070_002_003.mp3","charTypeName":"word"},{"id":1555,"position":4,"arabic":"دَافِعٌۭ","translation":"কোন প্রতিরোধকারী","audioUrl":"wbw/070_002_004.mp3","charTypeName":"word"},{"id":1556,"position":5,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"مِّنَ ٱللَّهِ ذِى ٱلْمَعَارِجِ","trans