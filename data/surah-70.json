া","audioUrl":"wbw/070_030_004.mp3","charTypeName":"word"},{"id":32826,"position":5,"arabic":"مَا","translation":"যা","audioUrl":"wbw/070_030_005.mp3","charTypeName":"word"},{"id":32827,"position":6,"arabic":"مَلَكَتْ","translation":"মালিক হয়েছে","audioUrl":"wbw/070_030_006.mp3","charTypeName":"word"},{"id":32828,"position":7,"arabic":"أَيْمَـٰنُهُمْ","translation":"তাদের ডান হাতসমূহ","audioUrl":"wbw/070_030_007.mp3","charTypeName":"word"},{"id":32829,"position":8,"arabic":"فَإِنَّهُمْ","translation":"তারপর নিশ্চয় তারা","audioUrl":"wbw/070_030_008.mp3","charTypeName":"word"},{"id":32830,"position":9,"arabic":"غَيْرُ","translation":"নয়","audioUrl":"wbw/070_030_009.mp3","charTypeName":"word"},{"id":32831,"position":10,"arabic":"مَلُومِينَ","translation":"নিন্দনীয়","audioUrl":"wbw/070_030_010.mp3","charTypeName":"word"},{"id":32832,"position":11,"arabic":"٣٠","translation":"(৩০)","audioUrl":null,"charTypeName":"end"}]},{"number":31,"arabic":"فَمَنِ ٱبْتَغَىٰ وَرَآءَ ذَٰلِكَ فَأُو۟لَٰٓئِكَ هُمُ ٱلْعَادُونَ","translation":"whereas such as seek to go beyond that [limit] are truly transgressors;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5406.mp3","surahId":70,"words":[{"id":33853,"position":1,"arabic":"فَمَنِ","translation":"তবে যে কেউ","audioUrl":"wbw/070_031_001.mp3","charTypeName":"word"},{"id":33854,"position":2,"arabic":"ٱبْتَغَىٰ","translation":"চায়","audioUrl":"wbw/070_031_002.mp3","charTypeName":"word"},{"id":33855,"position":3,"arabic":"وَرَآءَ","translation":"ছাড়া","audioUrl":"wbw/070_031_003.mp3","charTypeName":"word"},{"id":33856,"position":4,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/070_031_004.mp3","charTypeName":"word"},{"id":33857,"position":5,"arabic":"فَأُو۟لَـٰٓئِكَ","translation":"অতএব ঐসব লোক","audioUrl":"wbw/070_031_005.mp3","charTypeName":"word"},{"id":33858,"position":6,"arabic":"هُمُ","translation":"[তারাই]","audioUrl":"wbw/070_031_006.mp3","charTypeName":"word"},{"id":33859,"position":7,"arabic":"ٱلْعَادُونَ