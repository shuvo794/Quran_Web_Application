,{"id":19303,"position":5,"arabic":"وَنَعِيمٍۢ","translation":"ও আরাম আয়েশে","audioUrl":"wbw/052_017_005.mp3","charTypeName":"word"},{"id":19304,"position":6,"arabic":"١٧","translation":"(১৭)","audioUrl":null,"charTypeName":"end"}]},{"number":18,"arabic":"فَٰكِهِينَ بِمَآ ءَاتَىٰهُمْ رَبُّهُمْ وَوَقَىٰهُمْ رَبُّهُمْ عَذَابَ ٱلْجَحِيمِ","translation":"rejoicing in all that their Sustainer will have granted them: for their Sustainer will have warded off from them all suffering through the blazing fire.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4753.mp3","surahId":52,"words":[{"id":20366,"position":1,"arabic":"فَـٰكِهِينَ","translation":"সানন্দে উপভোগকারী হবে তারা","audioUrl":"wbw/052_018_001.mp3","charTypeName":"word"},{"id":20367,"position":2,"arabic":"بِمَآ","translation":"ঐ জিনিসের যা","audioUrl":"wbw/052_018_002.mp3","charTypeName":"word"},{"id":20368,"position":3,"arabic":"ءَاتَىٰهُمْ","translation":"তাদের দান করবেন","audioUrl":"wbw/052_018_003.mp3","charTypeName":"word"},{"id":20369,"position":4,"arabic":"رَبُّهُمْ","translation":"তাদের রব","audioUrl":"wbw/052_018_004.mp3","charTypeName":"word"},{"id":20370,"position":5,"arabic":"وَوَقَىٰهُمْ","translation":"এবং তাদের রক্ষা করবেন","audioUrl":"wbw/052_018_005.mp3","charTypeName":"word"},{"id":20371,"position":6,"arabic":"رَبُّهُمْ","translation":"তাদের রব","audioUrl":"wbw/052_018_006.mp3","charTypeName":"word"},{"id":20372,"position":7,"arabic":"عَذَابَ","translation":"শাস্তি (হতে)","audioUrl":"wbw/052_018_007.mp3","charTypeName":"word"},{"id":20373,"position":8,"arabic":"ٱلْجَحِيمِ","translation":"জাহান্নামের","audioUrl":"wbw/052_018_008.mp3","charTypeName":"word"},{"id":20374,"position":9,"arabic":"١٨","translation":"(১৮)","audioUrl":null,"charTypeName":"end"}]},{"number":19,"arabic":"كُلُوا۟ وَٱشْرَبُوا۟ هَنِيٓـًٔۢا بِمَا كُنتُمْ تَعْمَلُونَ","translation":"[And they will be told:] “Eat and drink with good cheer as an outcome of what you were wont to do,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4754.mp3","surahId":52,"words":[{"id":21444,"position":1,"arabic":"كُلُوا۟","translation":"\"(বলা হবে) তোমরা খাও","audioUrl":"wbw/052_019_001.mp3","charTypeName":"word"},{"id":21445,"position":2,"arabic":"وَٱشْرَبُوا۟","translation":"ও তোমরা পান করো","audioUrl":"wbw/052_019_002.mp3","charTypeName":"word"},{"id":21446,"position":3,"arabic":"هَنِيٓـًٔۢا","translation":"তৃপ্তির সাথে","audioUrl":"wbw/052_019_003.mp3","charTypeName":"word"},{"id":21447,"position":4,"arabic":"بِمَا","translation":"তার বদলে যা","audioUrl":"wbw/052_019_004.mp3","charTypeName":"word"},{"id":21448,"position":5,"arabic":"كُنتُمْ","translation":"তোমরা করছিলে","audioUrl":"wbw/052_019_005.mp3","charTypeName":"word"},{"id":21449,"position":6,"arabic":"تَعْمَلُونَ","translation":"তোমরা কাজ করছিলে\"","audioUrl":"wbw/052_019_006.mp3","charTypeName":"word"},{"id":21450,"position":7,"arabic":"١٩","translation":"(১৯)","audioUrl":null,"charTypeName":"end"}]},{"number":20,"arabic":"مُتَّكِـِٔينَ عَلَىٰ سُرُرٍۢ مَّصْفُوفَةٍۢ ۖ وَزَوَّجْنَٰهُم بِحُورٍ عِينٍۢ","translation":"reclining on couches [of happiness] ranged in rows!” And [in that paradise] We shall mate them with companions pure, most beautiful of eye.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4755.mp3","surahId":52,"words":[{"id":22539,"position":1,"arabic":"مُتَّكِـِٔينَ","translation":"তারা হেলান দিয়ে বসবে","audioUrl":"wbw/052_020_001.mp3","charTypeName":"word"},{"id":22540,"position":2,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/052_020_002.mp3","charTypeName":"word"},{"id":22541,"position":3,"arabic":"سُرُرٍۢ","translation":"আসনসমূহের","audioUrl":"wbw/052_020_003.mp3","charTypeName":"word"},{"id":22542,"position":4,"arabic":"مَّصْفُوفَةٍۢ ۖ","translation":"সারিবদ্ধভাবে","audioUrl":"wbw/052_020_004.mp3","charTypeName":"word"},{"id":22544,"position":5,"arabic":"وَزَوَّجْنَـٰهُم","translation":"এবং তাদেরকে আমরা বিয়ে দিব","audioUrl":"wbw/052_020_006.mp3","charTypeName":"word"},{"id":22545,"position":6,"arabic":"بِحُورٍ","translation":"হূরদের সাথে","audioUrl":"wbw/052_020_007.mp3","charTypeName":"word"},{"id":22546,"position":7,"arabic":"عِينٍۢ","translation":"(যারা হবে) আয়তলোচনা","audioUrl":"wbw/052_020_008.mp3","charTypeName":"word"},{"id":22547,"position":8,"arabic":"٢٠","translation":"(২০)","audioUrl":null,"charTypeName":"end"}]},{"number":21,"arabic":"وَٱلَّذِينَ ءَامَنُوا۟ وَٱتَّبَعَتْهُمْ ذُرِّيَّتُهُم بِإِيمَٰنٍ أَلْحَقْنَا بِهِمْ ذُرِّيَّتَهُمْ وَمَآ أَلَتْنَٰهُم مِّنْ عَمَلِهِم مِّن شَىْءٍۢ ۚ كُلُّ ٱمْرِئٍۭ بِمَا كَسَبَ رَهِينٌۭ","translation":"And as for those who have attained to faith and whose offspring will have followed them in faith, We shall unite them with their offspring; and We shall not let aught of their deeds go to waste: [but] every human being will be held in pledge for whatever he has earned.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4756.mp3","surahId":52,"words":[{"id":23690,"position":1,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/052_021_001.mp3","charTypeName":"word"},{"id":23691,"position":2,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/052_021_002.mp3","charTypeName":"word"},{"id":23692,"position":3,"arabic":"وَٱتَّبَعَتْهُمْ","translation":"ও তাদেরকে অনুসরণ করেছে","audioUrl":"wbw/052_021_003.mp3","charTypeName":"word"},{"id":23693,"position":4,"arabic":"ذُرِّيَّتُهُم","translation":"তাদের সন্তানরা","audioUrl":"wbw/052_021_004.mp3","charTypeName":"word"},{"id":23694,"position":5,"arabic":"بِإِيمَـٰنٍ","translation":"ঈমানসহ","audioUrl":"wbw/052_021_005.mp3","charTypeName":"word"},{"id":23695,"position":6,"arabic":"أَلْحَقْنَا","translation":"আমরা মিলিত করব","audioUrl":"wbw/052_021_006.mp3","charTypeName":"word"},{"id":23696,"position":7,"arabic":"بِهِمْ","translation":"তাদের সাথে","audioUrl":"wbw/052_021_007.mp3","charTypeName":"word"},{"id":23697,"position":8,"arabic":"ذُرِّيَّتَهُمْ","translation":"তাদের সন্তানদেরকে","audioUrl":"wbw/052_021_008.mp3","charTypeName":"word"},{"id":23698,"position":9,"arabic":"وَمَآ","translation":"এবং না","audioUrl":"wbw/052_021_009.mp3","charTypeName":"word"},{"id":23699,"position":10,"arabic":"أَلَتْنَـٰهُم","translation":"তাদের আমরা কম করব","audioUrl":"wbw/052_021_010.mp3","charTypeName":"word"},{"id":23700,"position":11,"arabic":"مِّنْ","translation":"হতে","audioUrl":"wbw/052_021_011.mp3","charTypeName":"word"},{"id":23701,"position":12,"arabic":"عَمَلِهِم","translation":"তাদের আমল","audioUrl":"wbw/052_021_012.mp3","charTypeName":"word"},{"id":23702,"position":13,"arabic":"مِّن","translation":"কোনো","audioUrl":"wbw/052_021_013.mp3","charTypeName":"word"},{"id":23703,"position":14,"arabic":"شَىْءٍۢ ۚ","translation":"কিছুই","audioUrl":"wbw/052_021_014.mp3","charTypeName":"word"},{"id":23705,"position":15,"arabic":"كُلُّ","translation":"প্রত্যেক","audioUrl":"wbw/052_021_016.mp3","charTypeName":"word"},{"id":23706,"position":16,"arabic":"ٱمْرِئٍۭ","translation":"ব্যক্তি","audioUrl":"wbw/052_021_017.mp3","charTypeName":"word"},{"id":23707,"position":17,"arabic":"بِمَا","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/052_021_018.mp3","charTypeName":"word"},{"id":23708,"position":18,"arabic":"كَسَبَ","translation":"সে অর্জন করেছে","audioUrl":"wbw/052_021_019.mp3","charTypeName":"word"},{"id":23709,"position":19,"arabic":"رَهِينٌۭ","translation":"দায়ী/ বন্ধক (আছে)","audioUrl":"wbw/052_021_020.mp3","charTypeName":"word"},{"id":23710,"position":20,"arabic":"٢١","translation":"(২১)","audioUrl":null,"charTypeName":"end"}]},{"number":22,"arabic":"وَأَمْدَدْنَٰهُم بِفَٰكِهَةٍۢ وَلَحْمٍۢ مِّمَّا يَشْتَهُونَ","translation":"And We shall bestow on them fruit and meat in abundance - whatever they may desire:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4757.mp3","surahId":52,"words":[{"id":24664,"position":1,"arabic":"وَأَمْدَدْنَـٰهُم","translation":"এবং তাদেরকে আমরা বেশি করে দেব","audioUrl":"wbw/052_022_001.mp3","charTypeName":"word"},{"id":24665,"position":2,"arabic":"بِفَـٰكِهَةٍۢ","translation":"ফল মূল","audioUrl":"wbw/052_022_002.mp3","charTypeName":"word"},{"id":24666,"position":3,"arabic":"وَلَحْمٍۢ","translation":"ও গোশত","audioUrl":"wbw/052_022_003.mp3","charTypeName":"word"},{"id":24667,"position":4,"arabic":"مِّمَّا","translation":"তা হতে যা","audioUrl":"wbw/052_022_004.mp3","charTypeName":"word"},{"id":24668,"position":5,"arabic":"يَشْتَهُونَ","translation":"তারা পছন্দ করবে","audioUrl":"wbw/052_022_005.mp3","charTypeName":"word"},{"id":24669,"position":6,"arabic":"٢٢","translation":"(২২)","audioUrl":null,"charTypeName":"end"}]},{"number":23,"arabic":"يَتَنَٰزَعُونَ فِيهَا كَأْسًۭا لَّا لَغْوٌۭ فِيهَا وَلَا تَأْثِيمٌۭ","translation":"and in that [paradise] they shall pass on to one another a cup which will not give rise to empty talk, and neither incite to sin.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4758.mp3","surahId":52,"words":[{"id":26136,"position":1,"arabic":"يَتَنَـٰزَعُونَ","translation":"তারা পরস্পরে নেবে","audioUrl":"wbw/052_023_001.mp3","charTypeName":"word"},{"id":26137,"position":2,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/052_023_002.mp3","charTypeName":"word"},{"id":26138,"position":3,"arabic":"كَأْسًۭا","translation":"পানপাত্র","audioUrl":"wbw/052_023_003.mp3","charTypeName":"word"},{"id":26139,"position":4,"arabic":"لَّا","translation":"না","audioUrl":"wbw/052_023_004.mp3","charTypeName":"word"},{"id":26140,"position":5,"arabic":"لَغْوٌۭ","translation":"অসার কথা (হবে)","audioUrl":"wbw/052_023_005.mp3","charTypeName":"word"},{"id":26141,"position":6,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/052_023_006.mp3","charTypeName":"word"},{"id":26142,"position":7,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/052_023_007.mp3","charTypeName":"word"},{"id":26143,"position":8,"arabic":"تَأْثِيمٌۭ","translation":"পাপকর্ম","audioUrl":"wbw/052_023_008.mp3","charTypeName":"word"},{"id":26144,"position":9,"arabic":"٢٣","translation":"(২৩)","audioUrl":null,"charTypeName":"end"}]},{"number":24,"arabic":"۞ وَيَطُوفُ عَلَيْهِمْ غِلْمَانٌۭ لَّهُمْ كَأَنَّهُمْ لُؤْلُؤٌۭ مَّكْنُونٌۭ","translation":"And they will be waited upon by [immortal] youths, [as if they were children] of their own, [as pure] as if they were pearls hidden in their shells.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4759.mp3","surahId":52,"words":[{"id":26808,"position":1,"arabic":"۞ وَيَطُوفُ","translation":"এবং ঘুরতে থাকবে","audioUrl":"wbw/052_024_002.mp3","charTypeName":"word"},{"id":26809,"position":2,"arabic":"عَلَيْهِمْ","translation":"তাদের কাছে","audioUrl":"wbw/052_024_003.mp3","charTypeName":"word"},{"id":26810,"position":3,"arabic":"غِلْمَانٌۭ","translation":"কিশোরেরা (সেবা করতে)","audioUrl":"wbw/052_024_004.mp3","charTypeName":"word"},{"id":26811,"position":4,"arabic":"لَّهُمْ","translation":"তাদের জন্যে","audioUrl":"wbw/052_024_005.mp3","charTypeName":"word"},{"id":26812,"position":5,"arabic":"كَأَنَّهُمْ","translation":"(এত সুন্দর হবে) তারা যেন","audioUrl":"wbw/052_024_006.mp3","charTypeName":"word"},{"id":26813,"position":6,"arabic":"لُؤْلُؤٌۭ","translation":"মুক্তা","audioUrl":"wbw/052_024_007.mp3","charTypeName":"word"},{"id":26814,"position":7,"arabic":"مَّكْنُونٌۭ","translation":"লুকিয়ে রাখা","audioUrl":"wbw/052_024_008.mp3","charTypeName":"word"},{"id":26815,"position":8,"arabic":"٢٤","translation":"(২৪)","audioUrl":null,"charTypeName":"end"}]},{"number":25,"arabic":"وَأَقْبَلَ بَعْضُهُمْ عَلَىٰ بَعْضٍۢ يَتَسَآءَلُونَ","translation":"And they [who are thus blest] will turn to one another, asking each other [about their past lives].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4760.mp3","surahId":52,"words":[{"id":27863,"position":1,"arabic":"وَأَقْبَلَ","translation":"এবং সামনাসামনি হয়ে","audioUrl":"wbw/052_025_001.mp3","charTypeName":"word"},{"id":27864,"position":2,"arabic":"بَعْضُهُمْ","translation":"তাদের একে","audioUrl":"wbw/052_025_002.mp3","charTypeName":"word"},{"id":27865,"position":3,"arabic":"عَلَىٰ","translation":"কাছে","audioUrl":"wbw/052_025_003.mp3","charTypeName":"word"},{"id":27866,"position":4,"arabic":"بَعْضٍۢ","translation":"অপরের","audioUrl":"wbw/052_025_004.mp3","charTypeName":"word"},{"id":27867,"position":5,"arabic":"يَتَسَآءَلُونَ","translation":"পরস্পরের জিজ্ঞাসাবাদ করবে (অতীত সম্পর্কে)","audioUrl":"wbw/052_025_005.mp3","charTypeName":"word"},{"id":27868,"position":6,"arabic":"٢٥","translation":"(২৫)","audioUrl":null,"charTypeName":"end"}]},{"number":26,"arabic":"قَالُوٓا۟ إِنَّا كُنَّا قَبْلُ فِىٓ أَهْلِنَا مُشْفِقِينَ","translation":"They will say: “Behold, aforetime - when we were [still living] in the midst of our kith and kin - we were full of fear [at the thought of God’s dis­pleasure]:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4761.mp3","surahId":52,"words":[{"id":28820,"position":1,"arabic":"قَالُوٓا۟","translation":"তারা বলবে","audioUrl":"wbw/052_026_001.mp3","charTypeName":"word"},{"id":28821,"position":2,"arabic":"إِنَّا","translation":"\"নিশ্চয়ই আমরা","audioUrl":"wbw/052_026_002.mp3","charTypeName":"word"},{"id":28822,"position":3,"arabic":"كُنَّا","translation":"ছিলাম","audioUrl":"wbw/052_026_003.mp3","charTypeName":"word"},{"id":28823,"position":4,"arabic":"قَبْلُ","translation":"পূর্বে","audioUrl":"wbw/052_026_004.mp3","charTypeName":"word"},{"id":28824,"position":5,"arabic":"فِىٓ","translation":"মধ্যে","audioUrl":"wbw/052_026_005.mp3","charTypeName":"word"},{"id":28825,"position":6,"arabic":"أَهْلِنَا","translation":"আমাদের পরিবারের","audioUrl":"wbw/052_026_006.mp3","charTypeName":"word"},{"id":28826,"position":7,"arabic":"مُشْفِقِينَ","translation":"শঙ্কিত অবস্থায়","audioUrl":"wbw/052_026_007.mp3","charTypeName":"word"},{"id":28827,"position":8,"arabic":"٢٦","translation":"(২৬)","audioUrl":null,"charTypeName":"end"}]},{"number":27,"arabic":"فَمَنَّ ٱللَّهُ عَلَيْنَا وَوَقَىٰنَا عَذَابَ ٱلسَّمُومِ","translation":"and so God has graced us with His favour, and has warded off from us all suffering through the scorching winds [of frustration].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4762.mp3","surahId":52,"words":[{"id":30275,"position":1,"arabic":"فَمَنَّ","translation":"অবশেষে অনুগ্রহ করেছেন","audioUrl":"wbw/052_027_001.mp3","charTypeName":"word"},{"id":30276,"position":2,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/052_027_002.mp3","charTypeName":"word"},{"id":30277,"position":3,"arabic":"عَلَيْنَا","translation":"আমাদের উপর","audioUrl":"wbw/052_027_003.mp3","charTypeName":"word"},{"id":30278,"position":4,"arabic":"وَوَقَىٰنَا","translation":"এবং আমাদেরকে রক্ষা করেছেন","audioUrl":"wbw/052_027_004.mp3","charTypeName":"word"},{"id":30279,"position":5,"arabic":"عَذَابَ","translation":"শাস্তি (হতে)","audioUrl":"wbw/052_027_005.mp3","charTypeName":"word"},{"id":30280,"position":6,"arabic":"ٱلسَّمُومِ","translation":"দগ্ধকারী হাওয়ার (যা ঝলসে দেয়)","audioUrl":"wbw/052_027_006.mp3","charTypeName":"word"},{"id":30281,"position":7,"arabic":"٢٧","translation":"(২৭)","audioUrl":null,"charTypeName":"end"}]},{"number":28,"arabic":"إِنَّا كُنَّا مِن قَبْلُ نَدْعُوهُ ۖ إِنَّهُۥ هُوَ ٱلْبَرُّ ٱلرَّحِيمُ","translation":"Verily, we did invoke Him [alone] ere this: [and now He has shown us] that He alone is truly benign, a true dispenser of grace!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4763.mp3","surahId":52,"words":[{"id":30704,"position":1,"arabic":"إِنَّا","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/052_028_001.mp3","charTypeName":"word"},{"id":30705,"position":2,"arabic":"كُنَّا","translation":"ছিলাম","audioUrl":"wbw/052_028_002.mp3","charTypeName":"word"},{"id":30706,"position":3,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/052_028_003.mp3","charTypeName":"word"},{"id":30707,"position":4,"arabic":"قَبْلُ","translation":"পূর্বেও","audioUrl":"wbw/052_028_004.mp3","charTypeName":"word"},{"id":30708,"position":5,"arabic":"نَدْعُوهُ ۖ","translation":"তাঁকে ডাকতাম আমরা","audioUrl":"wbw/052_028_005.mp3","charTypeName":"word"},{"id":30710,"position":6,"arabic":"إِنَّهُۥ","translation":"নিশ্চয়ই তিনি","audioUrl":"wbw/052_028_007.mp3","charTypeName":"word"},{"id":30711,"position":7,"arabic":"هُوَ","translation":"তিনিই","audioUrl":"wbw/052_028_008.mp3","charTypeName":"word"},{"id":30712,"position":8,"arabic":"ٱلْبَرُّ","translation":"বড় অনুগ্রহকারী","audioUrl":"wbw/052_028_009.mp3","charTypeName":"word"},{"id":30713,"position":9,"arabic":"ٱلرَّحِيمُ","translation":"পরম দয়ালু\"","audioUrl":"wbw/052_028_010.mp3","charTypeName":"word"},{"id":30714,"position":10,"arabic":"٢٨","translation":"(২৮)","audioUrl":null,"charTypeName":"end"}]},{"number":29,"arabic":"فَذَكِّرْ فَمَآ أَنتَ بِنِعْمَتِ رَبِّكَ بِكَاهِنٍۢ وَلَا مَجْنُونٍ","translation":"EXHORT, then, [O Prophet, all men:] for, by thy Sustainer’s grace, thou art neither a soothsayer nor a madman.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4764.mp3","surahId":52,"words":[{"id":31795,"position":1,"arabic":"فَذَكِّرْ","translation":"(হে নবী) তাই উপদেশ দাও","audioUrl":"wbw/052_029_001.mp3","charTypeName":"word"},{"id":31796,"position":2,"arabic":"فَمَآ","translation":"না আর","audioUrl":"wbw/052_029_002.mp3","charTypeName":"word"},{"id":31797,"position":3,"arabic":"أَنتَ","translation":"তুমি","audioUrl":"wbw/052_029_003.mp3","charTypeName":"word"},{"id":31798,"position":4,"arabic":"بِنِعْمَتِ","translation":"অনুগ্রহের কারণে","audioUrl":"wbw/052_029_004.mp3","charTypeName":"word"},{"id":31799,"position":5,"arabic":"رَبِّكَ","translation":"তোমার রবের","audioUrl":"wbw/052_029_005.mp3","charTypeName":"word"},{"id":31800,"position":6,"arabic":"بِكَاهِنٍۢ","translation":"কোনো গণক","audioUrl":"wbw/052_029_006.mp3","charTypeName":"word"},{"id":31801,"position":7,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/052_029_007.mp3","charTypeName":"word"},{"id":31802,"position":8,"arabic":"مَجْنُونٍ","translation":"পাগল","audioUrl":"wbw/052_029_008.mp3","charTypeName":"word"},{"id":31803,"position":9,"arabic":"٢٩","translation":"(২৯)","audioUrl":null,"charTypeName":"end"}]},{"number":30,"arabic":"أَمْ يَقُولُونَ شَاعِرٌۭ نَّتَرَبَّصُ بِهِۦ رَيْبَ ٱلْمَنُونِ","translation":"Or do they say, “[He is but] a poet - let us wait what time will do unto him”?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4765.mp3","surahId":52,"words":[{"id":32628,"position":1,"arabic":"أَمْ","translation":"কি","audioUrl":"wbw/052_030_001.mp3","charTypeName":"word"},{"id":32629,"position":2,"arabic":"يَقُولُونَ","translation":"তারা বলে","audioUrl":"wbw/052_030_002.mp3","charTypeName":"word"},{"id":32630,"position":3,"arabic":"شَاعِرٌۭ","translation":"\"(সে) একজন কবি","audioUrl":"wbw/052_030_003.mp3","charTypeName":"word"},{"id":32631,"position":4,"arabic":"نَّتَرَبَّصُ","translation":"অপেক্ষা করছি আমরা","audioUrl":"wbw/052_030_004.mp3","charTypeName":"word"},{"id":32632,"position":5,"arabic":"بِهِۦ","translation":"এ ব্যাপারে","audioUrl":"wbw/052_030_005.mp3","charTypeName":"word"},{"id":32633,"position":6,"arabic":"رَيْبَ","translation":"বিপর্যয়ের\"","audioUrl":"wbw/052_030_006.mp3","charTypeName":"word"},{"id":32634,"position":7,"arabic":"ٱلْمَنُونِ","translation":"মৃত্যুর\"","audioUrl":"wbw/052_030_007.mp3","charTypeName":"word"},{"id":32635,"position":8,"arabic":"٣٠","translation":"(৩০)","audioUrl":null,"charTypeName":"end"}]},{"number":31,"arabic":"قُلْ تَرَبَّصُوا۟ فَإِنِّى مَعَكُم مِّنَ ٱلْمُتَرَبِّصِينَ","translation":"Say thou: “Wait, [then,] hopefully; behold, I, too, shall hopefully wait with you!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4766.mp3","surahId":52,"words":[{"id":33502,"position":1,"arabic":"قُلْ","translation":"(তুমি) বলো","audioUrl":"wbw/052_031_001.mp3","charTypeName":"word"},{"id":33503,"position":2,"arabic":"تَرَبَّصُوا۟","translation":"\"তোমরা অপেক্ষা করো","audioUrl":"wbw/052_031_002.mp3","charTypeName":"word"},{"id":33504,"position":3,"arabic":"فَإِنِّى","translation":"আর নিশ্চয়ই আমি","audioUrl":"wbw/052_031_003.mp3","charTypeName":"word"},{"id":33505,"position":4,"arabic":"مَعَكُم","translation":"তোমাদের সাথে","audioUrl":"wbw/052_031_004.mp3","charTypeName":"word"},{"id":33506,"position":5,"arabic":"مِّنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/052_031_005.mp3","charTypeName":"word"},{"id":33507,"position":6,"arabic":"ٱلْمُتَرَبِّصِينَ","translation":"অপেক্ষাকারীদের\"","audioUrl":"wbw/052_031_006.mp3","charTypeName":"word"},{"id":33508,"position":7,"arabic":"٣١","translation":"(৩১)","audioUrl":null,"charTypeName":"end"}]}]}