{"id":524,"ayahs":[{"number":15,"arabic":"أَفَسِحْرٌ هَٰذَآ أَمْ أَنتُمْ لَا تُبْصِرُونَ","translation":"Was it, then, a delusion or is it that you failed to see [its truth]?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4750.mp3","surahId":52,"words":[{"id":17222,"position":1,"arabic":"أَفَسِحْرٌ","translation":"জাদু তবে কি","audioUrl":"wbw/052_015_001.mp3","charTypeName":"word"},{"id":17223,"position":2,"arabic":"هَـٰذَآ","translation":"এটা","audioUrl":"wbw/052_015_002.mp3","charTypeName":"word"},{"id":17224,"position":3,"arabic":"أَمْ","translation":"নাকি","audioUrl":"wbw/052_015_003.mp3","charTypeName":"word"},{"id":17225,"position":4,"arabic":"أَنتُمْ","translation":"তোমরা","audioUrl":"wbw/052_015_004.mp3","charTypeName":"word"},{"id":17226,"position":5,"arabic":"لَا","translation":"না","audioUrl":"wbw/052_015_005.mp3","charTypeName":"word"},{"id":17227,"position":6,"arabic":"تُبْصِرُونَ","translation":"চোখে দেখছ","audioUrl":"wbw/052_015_006.mp3","charTypeName":"word"},{"id":17228,"position":7,"arabic":"١٥","translation":"(১৫)","audioUrl":null,"charTypeName":"end"}]},{"number":16,"arabic":"ٱصْلَوْهَا فَٱصْبِرُوٓا۟ أَوْ لَا تَصْبِرُوا۟ سَوَآءٌ عَلَيْكُمْ ۖ إِنَّمَا تُجْزَوْنَ مَا كُنتُمْ تَعْمَلُونَ","translation":"Endure it [now]! But [whether you] bear yourselves with patience or without patience, it will be the same to you: you are but being requited for what you were wont to do.”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4751.mp3","surahId":52,"words":[{"id":18267,"position":1,"arabic":"ٱصْلَوْهَا","translation":"তাতে তোমরা প্রবেশ করো","audioUrl":"wbw/052_016_001.mp3","charTypeName":"word"},{"id":18268,"position":2,"arabic":"فَٱصْبِرُوٓا۟","translation":"অতঃপর তোমরা সহ্য করতে পার","audioUrl":"wbw/052_016_002.mp3","charTypeName":"word"},{"id":18269,"position":3,"arabic":"أَوْ","translation":"বা","audioUrl":"wbw/052_016_003.mp3","charTypeName":"word"},{"id":18270,"position":4,"arabic":"لَا","translation":"না","audio