{"id":482,"ayahs":[{"number":47,"arabic":"۞ إِلَيْهِ يُرَدُّ عِلْمُ ٱلسَّاعَةِ ۚ وَمَا تَخْرُجُ مِن ثَمَرَٰتٍۢ مِّنْ أَكْمَامِهَا وَمَا تَحْمِلُ مِنْ أُنثَىٰ وَلَا تَضَعُ إِلَّا بِعِلْمِهِۦ ۚ وَيَوْمَ يُنَادِيهِمْ أَيْنَ شُرَكَآءِى قَالُوٓا۟ ءَاذَنَّٰكَ مَا مِنَّا مِن شَهِيدٍۢ","translation":"In Him alone is vested the knowledge of when the Last Hour will come. And no fruit bursts forth from its calyx, and no female ever conceives, nor ever gives birth, save with His knowledge. And so, on the Day when He shall call out to them, “Where, now, are those [alleged] partners of Mine?” - they will [surely] answer, “We confess unto Thee that none of us can bear witness [to anyone’s having a share in Thy divinity]!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4265.mp3","surahId":41,"words":[{"id":46309,"position":1,"arabic":"۞ إِلَيْهِ","translation":"তাঁরই কাছে","audioUrl":"wbw/041_047_002.mp3","charTypeName":"word"},{"id":46310,"position":2,"arabic":"يُرَدُّ","translation":"ন্যস্ত রয়েছে","audioUrl":"wbw/041_047_003.mp3","charTypeName":"word"},{"id":46311,"position":3,"arabic":"عِلْمُ","translation":"জ্ঞান","audioUrl":"wbw/041_047_004.mp3","charTypeName":"word"},{"id":46312,"position":4,"arabic":"ٱلسَّاعَةِ ۚ","translation":"ক্বিয়ামাতের (অর্থাৎ তিনিই জানেন কখন তা হবে)","audioUrl":"wbw/041_047_005.mp3","charTypeName":"word"},{"id":46314,"position":5,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/041_047_007.mp3","charTypeName":"word"},{"id":46315,"position":6,"arabic":"تَخْرُجُ","translation":"বের হয়","audioUrl":"wbw/041_047_008.mp3","charTypeName":"word"},{"id":46316,"position":7,"arabic":"مِن","translation":"কোনো","audioUrl":"wbw/041_047_009.mp3","charTypeName":"word"},{"id":46317,"position":8,"arabic":"ثَمَرَٰتٍۢ","translation":"ফলসমূহ","audioUrl":"wbw/041_047_010.mp3","charTypeName":"word"},{"id":46318,"position":9,"arabic":"مِّنْ","translation":"হ'তে","audioUrl":"wbw/041_047_011.mp3","charTypeName":"word"},{"id":46319,"position":10,"arabic":"أَكْمَامِهَا","translation":"তার আবরণ","audioUrl":"wbw/041_047_012.mp3","charTypeName":"word"},{"id":46320,"position":11,"arabic":"وَمَا","translation":"আর না","audioUrl":"wbw/041_047_013.mp3","charTypeName":"word"},{"id":46321,"position":12,"arabic":"تَحْمِلُ","translation":"গর্ভধারণ করে","audioUrl":"wbw/041_047_014.mp3","charTypeName":"word"},{"id":46322,"position":13,"arabic":"مِنْ","translation":"কোন","audioUrl":"wbw/041_047_015.mp3","charTypeName":"word"},{"id":46323,"position":14,"arabic":"أُنثَىٰ","translation":"নারী","audioUrl":"wbw/041_047_016.mp3","charTypeName":"word"},{"id":46324,"position":15,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/041_047_017.mp3","charTypeName":"word"},{"id":46325,"position":16,"arabic":"تَضَعُ","translation":"প্রসব করে সে","audioUrl":"wbw/041_047_018.mp3","charTypeName":"word"},{"id":46326,"position":17,"arabic":"إِلَّا","translation":"এ ব্যতীত","audioUrl":"wbw/041_047_019.mp3","charTypeName":"word"},{"id":46327,"position":18,"arabic":"بِعِلْمِهِۦ ۚ","translation":"তাঁর জানা (আছে)","audioUrl":"wbw/041_047_020.mp3","charTypeName":"word"},{"id":46329,"position":19,"arabic":"وَيَوْمَ","translation":"এবং যে দিন","audioUrl":"wbw/041_047_022.mp3","charTypeName":"word"},{"id":46330,"position":20,"arabic":"يُنَادِيهِمْ","translation":"তাদের তিনি ডেকে বলবেন","audioUrl":"wbw/041_047_023.mp3","charTypeName":"word"},{"id":46331,"position":21,"arabic":"أَيْنَ","translation":"\"কোথায়","audioUrl":"wbw/041_047_024.mp3","charTypeName":"word"},{"id":46332,"position":22,"arabic":"شُرَكَآءِى","translation":"আমার শরিকরা","audioUrl":"wbw/041_047_025.mp3","charTypeName":"word"},{"id":46333,"position":23,"arabic":"قَالُوٓا۟","translation":"তারা বলবে","audioUrl":"wbw/041_047_026.mp3","charTypeName":"word"},{"id":46334,"position":24,"arabic":"ءَاذَنَّـٰكَ","translation":"\"আপনাকে নিবেদন করছি","audioUrl":"wbw/041_047_027.mp3","charTypeName":"word"},{"id":46335,"position":25,"arabic":"مَا","translation":"(আজ) নেই","audioUrl":"wbw/041_047_028.mp3","charTypeName":"word"},{"id":46336,"position":26,"arabic":"مِنَّا","translation":"আমাদের মধ্যে","audioUrl":"wbw/041_047_029.mp3","charTypeName":"word"},{"id":46337,"position":27,"arabic":"مِن","translation":"কোনো","audioUrl":"wbw/041_047_030.mp3","charTypeName":"word"},{"id":46338,"position":28,"arabic":"شَهِيدٍۢ","translation":"সাক্ষী (শরিকের পক্ষে)\"","audioUrl":"wbw/041_047_031.mp3","charTypeName":"word"},{"id":46339,"position":29,"arabic":"٤٧","translation":"(৪৭)","audioUrl":null,"charTypeName":"end"}]},{"number":48,"arabic":"وَضَلَّ عَنْهُم مَّا كَانُوا۟ يَدْعُونَ مِن قَبْلُ ۖ وَظَنُّوا۟ مَا لَهُم مِّن مَّحِيصٍۢ","translation":"And so, all that they were wont to invoke aforetime will have forsaken them; and they shall know for certain that there is no escape for them.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4266.mp3","surahId":41,"words":[{"id":47059,"position":1,"arabic":"وَضَلَّ","translation":"এবং হারিয়ে যাবে","audioUrl":"wbw/041_048_001.mp3","charTypeName":"word"},{"id":47060,"position":2,"arabic":"عَنْهُم","translation":"তাদের থেকে","audioUrl":"wbw/041_048_002.mp3","charTypeName":"word"},{"id":47061,"position":3,"arabic":"مَّا","translation":"(ঐসব ইলাহ) যাদেরকে","audioUrl":"wbw/041_048_003.mp3","charTypeName":"word"},{"id":47062,"position":4,"arabic":"كَانُوا۟","translation":"তারা","audioUrl":"wbw/041_048_004.mp3","charTypeName":"word"},{"id":47063,"position":5,"arabic":"يَدْعُونَ","translation":"ডাকতে থাকতো","audioUrl":"wbw/041_048_005.mp3","charTypeName":"word"},{"id":47064,"position":6,"arabic":"مِن","translation":"পূর্বে","audioUrl":"wbw/041_048_006.mp3","charTypeName":"word"},{"id":47065,"position":7,"arabic":"قَبْلُ ۖ","translation":"ইতি","audioUrl":"wbw/041_048_007.mp3","charTypeName":"word"},{"id":47067,"position":8,"arabic":"وَظَنُّوا۟","translation":"এবং তারা ভাববে","audioUrl":"wbw/041_048_009.mp3","charTypeName":"word"},{"id":47068,"position":9,"arabic":"مَا","translation":"নেই","audioUrl":"wbw/041_048_010.mp3","charTypeName":"word"},{"id":47069,"position":10,"arabic":"لَهُم","translation":"তাদের জন্যে (আছে)","audioUrl":"wbw/041_048_011.mp3","charTypeName":"word"},{"id":47070,"position":11,"arabic":"مِّن","translation":"কোনো","audioUrl":"wbw/041_048_012.mp3","charTypeName":"word"},{"id":47071,"position":12,"arabic":"مَّحِيصٍۢ","translation":"নিষ্কৃতি","audioUrl":"wbw/041_048_013.mp3","charTypeName":"word"},{"id":47072,"position":13,"arabic":"٤٨","translation":"(৪৮)","audioUrl":null,"charTypeName":"end"}]},{"number":49,"arabic":"لَّا يَسْـَٔمُ ٱلْإِنسَٰنُ مِن دُعَآءِ ٱلْخَيْرِ وَإِن مَّسَّهُ ٱلشَّرُّ فَيَـُٔوسٌۭ قَنُوطٌۭ","translation":"MAN NEVER TIRES of asking for the good [things of life]; and if evil fortune touches him, he abandons all hope, giving himself up to despair.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4267.mp3","surahId":41,"words":[{"id":47739,"position":1,"arabic":"لَّا","translation":"না","audioUrl":"wbw/041_049_001.mp3","charTypeName":"word"},{"id":47740,"position":2,"arabic":"يَسْـَٔمُ","translation":"ক্লান্ত হয়","audioUrl":"wbw/041_049_002.mp3","charTypeName":"word"},{"id":47741,"position":3,"arabic":"ٱلْإِنسَـٰنُ","translation":"মানুষ","audioUrl":"wbw/041_049_003.mp3","charTypeName":"word"},{"id":47742,"position":4,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/041_049_004.mp3","charTypeName":"word"},{"id":47743,"position":5,"arabic":"دُعَآءِ","translation":"দুআ","audioUrl":"wbw/041_049_005.mp3","charTypeName":"word"},{"id":47744,"position":6,"arabic":"ٱلْخَيْرِ","translation":"ধন-সম্পদের (অথবা কল্যাণের)","audioUrl":"wbw/041_049_006.mp3","charTypeName":"word"},{"id":47745,"position":7,"arabic":"وَإِن","translation":"আর যদি","audioUrl":"wbw/041_049_007.mp3","charTypeName":"word"},{"id":47746,"position":8,"arabic":"مَّسَّهُ","translation":"তাকে স্পর্শ করে","audioUrl":"wbw/041_049_008.mp3","charTypeName":"word"},{"id":47747,"position":9,"arabic":"ٱلشَّرُّ","translation":"দুঃখদৈন্য","audioUrl":"wbw/041_049_009.mp3","charTypeName":"word"},{"id":47748,"position":10,"arabic":"فَيَـُٔوسٌۭ","translation":"তখন হতাশ হয়","audioUrl":"wbw/041_049_010.mp3","charTypeName":"word"},{"id":47749,"position":11,"arabic":"قَنُوطٌۭ","translation":"নিরাশ (হয়)","audioUrl":"wbw/041_049_011.mp3","charTypeName":"word"},{"id":47750,"position":12,"arabic":"٤٩","translation":"(৪৯)","audioUrl":null,"charTypeName":"end"}]},{"number":50,"arabic":"وَلَئِنْ أَذَقْنَٰهُ رَحْمَةًۭ مِّنَّا مِنۢ بَعْدِ ضَرَّآءَ مَسَّتْهُ لَيَقُولَنَّ هَٰذَا لِى وَمَآ أَظُنُّ ٱلسَّاعَةَ قَآئِمَةًۭ وَلَئِن رُّجِعْتُ إِلَىٰ رَبِّىٓ إِنَّ لِى عِندَهُۥ لَلْحُسْنَىٰ ۚ فَلَنُنَبِّئَنَّ ٱلَّذِينَ كَفَرُوا۟ بِمَا عَمِلُوا۟ وَلَنُذِيقَنَّهُم مِّنْ عَذَابٍ غَلِيظٍۢ","translation":"Yet whenever We let him taste some of Our grace after hardship has visited him, he is sure to say, “This is but my due!” - and, “I do not think that the Last Hour will ever come: but if [it should come, and] I should indeed be brought back unto my Sus­tainer, then, behold, the ultimate good awaits me with Him! But [on the Day of Judgment] We shall most cer­tainly give those who were bent on denying the truth full understanding of all that they ever did, and shall most certainly give them [thereby] a taste of suffering severe.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4268.mp3","surahId":41,"words":[{"id":48392,"position":1,"arabic":"وَلَئِنْ","translation":"কিন্তু অবশ্য যদি","audioUrl":"wbw/041_050_001.mp3","charTypeName":"word"},{"id":48393,"position":2,"arabic":"أَذَقْنَـٰهُ","translation":"আমরা তাকে আস্বাদন করাই","audioUrl":"wbw/041_050_002.mp3","charTypeName":"word"},{"id":48394,"position":3,"arabic":"رَحْمَةًۭ","translation":"অনুগ্রহের","audioUrl":"wbw/041_050_003.mp3","charTypeName":"word"},{"id":48395,"position":4,"arabic":"مِّنَّا","translation":"আমাদের পক্ষ হতে","audioUrl":"wbw/041_050_004.mp3","charTypeName":"word"},{"id":48396,"position":5,"arabic":"مِنۢ","translation":"মধ্য হতে","audioUrl":"wbw/041_050_005.mp3","charTypeName":"word"},{"id":48397,"position":6,"arabic":"بَعْدِ","translation":"পরে","audioUrl":"wbw/041_050_006.mp3","charTypeName":"word"},{"id":48398,"position":7,"arabic":"ضَرَّآءَ","translation":"বিপদাপদের","audioUrl":"wbw/041_050_007.mp3","charTypeName":"word"},{"id":48399,"position":8,"arabic":"مَسَّتْهُ","translation":"(যা) তাকে স্পর্শ করেছিলো","audioUrl":"wbw/041_050_008.mp3","charTypeName":"word"},{"id":48400,"position":9,"arabic":"لَيَقُولَنَّ","translation":"সে বলে অবশ্যই","audioUrl":"wbw/041_050_009.mp3","charTypeName":"word"},{"id":48401,"position":10,"arabic":"هَـٰذَا","translation":"\"এটা","audioUrl":"wbw/041_050_010.mp3","charTypeName":"word"},{"id":48402,"position":11,"arabic":"لِى","translation":"আমারই (প্রাপ্য)","audioUrl":"wbw/041_050_011.mp3","charTypeName":"word"},{"id":48403,"position":12,"arabic":"وَمَآ","translation":"এবং (বলে) না","audioUrl":"wbw/041_050_012.mp3","charTypeName":"word"},{"id":48404,"position":13,"arabic":"أَظُنُّ","translation":"মনে করি আমি","audioUrl":"wbw/041_050_013.mp3","charTypeName":"word"},{"id":48405,"position":14,"arabic":"ٱلسَّاعَةَ","translation":"ক্বিয়ামাত","audioUrl":"wbw/041_050_014.mp3","charTypeName":"word"},{"id":48406,"position":15,"arabic":"قَآئِمَةًۭ","translation":"ঘটবে","audioUrl":"wbw/041_050_015.mp3","charTypeName":"word"},{"id":48407,"position":16,"arabic":"وَلَئِن","translation":"এবং অবশ্যই যদি","audioUrl":"wbw/041_050_016.mp3","charTypeName":"word"},{"id":48408,"position":17,"arabic":"رُّجِعْتُ","translation":"প্রত্যাবর্তিত হই আমি","audioUrl":"wbw/041_050_017.mp3","charTypeName":"word"},{"id":48409,"position":18,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/041_050_018.mp3","charTypeName":"word"},{"id":48410,"position":19,"arabic":"رَبِّىٓ","translation":"আমার রবের","audioUrl":"wbw/041_050_019.mp3","charTypeName":"word"},{"id":48411,"position":20,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/041_050_020.mp3","charTypeName":"word"},{"id":48412,"position":21,"arabic":"لِى","translation":"আমার জন্যে","audioUrl":"wbw/041_050_021.mp3","charTypeName":"word"},{"id":48413,"position":22,"arabic":"عِندَهُۥ","translation":"তাঁর কাছে (থাকবে)","audioUrl":"wbw/041_050_022.mp3","charTypeName":"word"},{"id":48414,"position":23,"arabic":"لَلْحُسْنَىٰ ۚ","translation":"অবশ্যই খুব কল্যাণ\"","audioUrl":"wbw/041_050_023.mp3","charTypeName":"word"},{"id":48416,"position":24,"arabic":"فَلَنُنَبِّئَنَّ","translation":"আমরা অথচ জানিয়ে দিবোই","audioUrl":"wbw/041_050_025.mp3","charTypeName":"word"},{"id":48417,"position":25,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/041_050_026.mp3","charTypeName":"word"},{"id":48418,"position":26,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/041_050_027.mp3","charTypeName":"word"},{"id":48419,"position":27,"arabic":"بِمَا","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/041_050_028.mp3","charTypeName":"word"},{"id":48420,"position":28,"arabic":"عَمِلُوا۟","translation":"তারা কাজ করেছিলো","audioUrl":"wbw/041_050_029.mp3","charTypeName":"word"},{"id":48421,"position":29,"arabic":"وَلَنُذِيقَنَّهُم","translation":"এবং তাদেরকে আমরা অবশ্যই আস্বাদন করাবোই","audioUrl":"wbw/041_050_030.mp3","charTypeName":"word"},{"id":48422,"position":30,"arabic":"مِّنْ","translation":"থেকে","audioUrl":"wbw/041_050_031.mp3","charTypeName":"word"},{"id":48423,"position":31,"arabic":"عَذَابٍ","translation":"শাস্তি","audioUrl":"wbw/041_050_032.mp3","charTypeName":"word"},{"id":48424,"position":32,"arabic":"غَلِيظٍۢ","translation":"কঠিন","audioUrl":"wbw/041_050_033.mp3","charTypeName":"word"},{"id":48425,"position":33,"arabic":"٥٠","translation":"(৫০)","audioUrl":null,"charTypeName":"end"}]},{"number":51,"arabic":"وَإِذَآ أَنْعَمْنَا عَلَى ٱلْإِنسَٰنِ أَعْرَضَ وَنَـَٔا بِجَانِبِهِۦ وَإِذَا مَسَّهُ ٱلشَّرُّ فَذُو دُعَآءٍ عَرِيضٍۢ","translation":"And, too, when We bestow Our blessings upon man, he tends to turn aside and keep aloof [from remembering Us]; but as soon as evil fortune touches him, he is full of wordy prayers!","audio":"https:/