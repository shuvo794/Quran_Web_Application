{"id":126,"ayahs":[{"number":109,"arabic":"۞ يَوْمَ يَجْمَعُ ٱللَّهُ ٱلرُّسُلَ فَيَقُولُ مَاذَآ أُجِبْتُمْ ۖ قَالُوا۟ لَا عِلْمَ لَنَآ ۖ إِنَّكَ أَنتَ عَلَّٰمُ ٱلْغُيُوبِ","translation":"ON THE DAY when God shall assemble all the apostles and shall ask, \"What response did you receive?\" -they will answer, \"We have no knowledge; verily, it is Thou alone who fully knowest all the things that are beyond the reach of a created being's perception.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/778.mp3","surahId":5,"words":[{"id":73720,"position":1,"arabic":"۞ يَوْمَ","translation":"যে দিন","audioUrl":"wbw/005_109_002.mp3","charTypeName":"word"},{"id":73721,"position":2,"arabic":"يَجْمَعُ","translation":"একত্র করবেন","audioUrl":"wbw/005_109_003.mp3","charTypeName":"word"},{"id":73722,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/005_109_004.mp3","charTypeName":"word"},{"id":73723,"position":4,"arabic":"ٱلرُّسُلَ","translation":"রাসূলেদেরকে","audioUrl":"wbw/005_109_005.mp3","charTypeName":"word"},{"id":73724,"position":5,"arabic":"فَيَقُولُ","translation":"অতঃপর তিনি বলবেন","audioUrl":"wbw/005_109_006.mp3","charTypeName":"word"},{"id":73725,"position":6,"arabic":"مَاذَآ","translation":"\"কি","audioUrl":"wbw/005_109_007.mp3","charTypeName":"word"},{"id":73726,"position":7,"arabic":"أُجِبْتُمْ ۖ","translation":"উত্তর দেয়া হয়েছিলো তোমাদেরকে\"","audioUrl":"wbw/005_109_008.mp3","charTypeName":"word"},{"id":73728,"position":8,"arabic":"قَالُوا۟","translation":"তারা বলবে","audioUrl":"wbw/005_109_010.mp3","charTypeName":"word"},{"id":73729,"position":9,"arabic":"لَا","translation":"\"নেই","audioUrl":"wbw/005_109_011.mp3","charTypeName":"word"},{"id":73730,"position":10,"arabic":"عِلْمَ","translation":"কোনো জ্ঞান","audioUrl":"wbw/005_109_012.mp3","charTypeName":"word"},{"id":73731,"position":11,"arabic":"لَنَآ ۖ","translation":"কাছে আমাদের","audioUrl":"wbw/005_109_013.mp3","charTypeName":"word"},{"id":73733,"position":12,"arabic":"إِنَّكَ","translation":"নিশ্চয়ই আপনি","audioUrl":"wbw/005_109_015.mp3","charTypeName":"word"},{"id":73734,"position":13,"arabic":"أَنتَ","translation":"আপনিই","audioUrl":"wbw/005_109_016.mp3","charTypeName":"word"},{"id":73735,"position":14,"arabic":"عَلَّـٰمُ","translation":"মহাজ্ঞানী","audioUrl":"wbw/005_109_017.mp3","charTypeName":"word"},{"id":73736,"position":15,"arabic":"ٱلْغُيُوبِ","translation":"অদৃশ্যসমূহের অবস্থা\"","audioUrl":"wbw/005_109_018.mp3","charTypeName":"word"},{"id":73737,"position":16,"arabic":"١٠٩","translation":"(১০৯)","audioUrl":null,"charTypeName":"end"}]},{"number":110,"arabic":"إِذْ قَالَ ٱللَّهُ يَٰعِيسَى ٱبْنَ مَرْيَمَ ٱذْكُرْ نِعْمَتِى عَلَيْكَ وَعَلَىٰ وَٰلِدَتِكَ إِذْ أَيَّدتُّكَ بِرُوحِ ٱلْقُدُسِ تُكَلِّمُ ٱلنَّاسَ فِى ٱلْمَهْدِ وَكَهْلًۭا ۖ وَإِذْ عَلَّمْتُكَ ٱلْكِتَٰبَ وَٱلْحِكْمَةَ وَٱلتَّوْرَىٰةَ وَٱلْإِنجِيلَ ۖ وَإِذْ تَخْلُقُ مِنَ ٱلطِّينِ كَهَيْـَٔةِ ٱلطَّيْرِ بِإِذْنِى فَتَنفُخُ فِيهَا فَتَكُونُ طَيْرًۢا بِإِذْنِى ۖ وَتُبْرِئُ ٱلْأَكْمَهَ وَٱلْأَبْرَصَ بِإِذْنِى ۖ وَإِذْ تُخْرِجُ ٱلْمَوْتَىٰ بِإِذْنِى ۖ وَإِذْ كَفَفْتُ بَنِىٓ إِسْرَٰٓءِيلَ عَنكَ إِذْ جِئْتَهُم بِٱلْبَيِّنَٰتِ فَقَالَ ٱلَّذِينَ كَفَرُوا۟ مِنْهُمْ إِنْ هَٰذَآ إِلَّا سِحْرٌۭ مُّبِينٌۭ","translation":"Lo! God will say: \"O Jesus, son of Mary! Remember the blessings which I bestowed upon thee and thy mother-how I strengthened thee with holy inspiration, so that thou couldst speak unto men in thy cradle, and as a grown man; and how I imparted unto thee revelation and wisdom, including the Torah and the Gospel; and how by My leave thou didst create out of clay, as it were, the shape of [thy followers'] destiny, and then didst breathe into it, so that it might become, by My leave, [their] destiny; and how thou didst heal the blind and the leper by My leave, and how thou didst raise the dead by My leave; and how I prevented the children of Israel from harming thee when thou camest unto them with all evidence of the truth, and [when] those of them who were bent on denying the truth were saying, `This is clearly nothing but deception!\"'","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/779.mp3","surahId":5,"words":[{"id":74247,"position":1,"arabic":"إِذْ","translation":"(স্মরণ করো) যখন","audioUrl":"wbw/005_110_001.mp3","charTypeName":"word"},{"id":74248,"position":2,"arabic":"قَالَ","translation":"বলেছিলেন","audioUrl":"wbw/005_110_002.mp3","charTypeName":"word"},{"id":74249,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/005_110_003.mp3","charTypeName":"word"},{"id":74250,"position":4,"arabic":"يَـٰعِيسَى","translation":"\"হে ঈসা","audioUrl":"wbw/005_110_004.mp3","charTypeName":"word"},{"id":74251,"position":5,"arabic":"ٱبْنَ","translation":"পূত্র","audioUrl":"wbw/005_110_005.mp3","charTypeName":"word"},{"id":74252,"position":6,"arabic":"مَرْيَمَ","translation":"মারইয়ামের","audioUrl":"wbw/005_110_006.mp3","charTypeName":"word"},{"id":74253,"position":7,"arabic":"ٱذْكُرْ","translation":"তুমি স্মরণ করো","audioUrl":"wbw/005_110_007.mp3","charTypeName":"word"},{"id":74254,"position":8,"arabic":"نِعْمَتِى","translation":"আমার অনুগ্রহ","audioUrl":"wbw/005_110_008.mp3","charTypeName":"word"},{"id":74255,"position":9,"arabic":"عَلَيْكَ","translation":"উপর তোমার","audioUrl":"wbw/005_110_009.mp3","charTypeName":"word"},{"id":74256,"position":10,"arabic":"وَعَلَىٰ","translation":"ও উপর","audioUrl":"wbw/005_110_010.mp3","charTypeName":"word"},{"id":74257,"position":11,"arabic":"وَٰلِدَتِكَ","translation":"তোমার মাতার","audioUrl":"wbw/005_110_011.mp3","charTypeName":"word"},{"id":74258,"position":12,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/005_110_012.mp3","charTypeName":"word"},{"id":74259,"position":13,"arabic":"أَيَّدتُّكَ","translation":"তোমাকে শক্তিশালী করেছিলাম","audioUrl":"wbw/005_110_013.mp3","charTypeName":"word"},{"id":74260,"position":14,"arabic":"بِرُوحِ","translation":"দিয়ে আত্মা","audioUrl":"wbw/005_110_014.mp3","charTypeName":"word"},{"id":74261,"position":15,"arabic":"ٱلْق