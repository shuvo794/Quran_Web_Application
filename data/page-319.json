eName":"word"},{"id":71578,"position":2,"arabic":"فِيهِ ۖ","translation":"তার মধ্যে","audioUrl":"wbw/020_101_002.mp3","charTypeName":"word"},{"id":71580,"position":3,"arabic":"وَسَآءَ","translation":"এবং কত মন্দ হবে","audioUrl":"wbw/020_101_004.mp3","charTypeName":"word"},{"id":71581,"position":4,"arabic":"لَهُمْ","translation":"তাদের জন্যে","audioUrl":"wbw/020_101_005.mp3","charTypeName":"word"},{"id":71582,"position":5,"arabic":"يَوْمَ","translation":"দিনে","audioUrl":"wbw/020_101_006.mp3","charTypeName":"word"},{"id":71583,"position":6,"arabic":"ٱلْقِيَـٰمَةِ","translation":"ক্বিয়ামাতের","audioUrl":"wbw/020_101_007.mp3","charTypeName":"word"},{"id":71584,"position":7,"arabic":"حِمْلًۭا","translation":"বোঝা","audioUrl":"wbw/020_101_008.mp3","charTypeName":"word"},{"id":71585,"position":8,"arabic":"١٠١","translation":"(১০১)","audioUrl":null,"charTypeName":"end"}]},{"number":102,"arabic":"يَوْمَ يُنفَخُ فِى ٱلصُّورِ ۚ وَنَحْشُرُ ٱلْمُجْرِمِينَ يَوْمَئِذٍۢ زُرْقًۭا","translation":"on the Day when the trumpet is blown: for on that Day We will assemble all such as had been lost in sin, their eyes dimmed [by terror],","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2450.mp3","surahId":20,"words":[{"id":71827,"position":1,"arabic":"يَوْمَ","translation":"যেদিন","audioUrl":"wbw/020_102_001.mp3","charTypeName":"word"},{"id":71828,"position":2,"arabic":"يُنفَخُ","translation":"ফুঁ দেয়া হবে","audioUrl":"wbw/020_102_002.mp3","charTypeName":"word"},{"id":71829,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/020_102_003.mp3","charTypeName":"word"},{"id":71830,"position":4,"arabic":"ٱلصُّورِ ۚ","translation":"শিঙ্গার","audioUrl":"wbw/020_102_004.mp3","charTypeName":"word"},{"id":71832,"position":5,"arabic":"وَنَحْشُرُ","translation":"এবং সমবেত করবো আমরা","audioUrl":"wbw/020_102_006.mp3","charTypeName":"word"},{"id":71833,"position":6,"arabic":"ٱلْمُجْرِمِينَ","translation":"অপরাধীদেরকে","audioUrl":"wbw/020_102_007.mp3","charTypeName":"word"},{"