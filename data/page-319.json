{"id":319,"ayahs":[{"number":99,"arabic":"كَذَٰلِكَ نَقُصُّ عَلَيْكَ مِنْ أَنۢبَآءِ مَا قَدْ سَبَقَ ۚ وَقَدْ ءَاتَيْنَٰكَ مِن لَّدُنَّا ذِكْرًۭا","translation":"THUS DO WE relate unto thee some of the stories of what happened in the past; and [thus] have We vouchsafed unto thee, out of Our grace, a reminder.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2447.mp3","surahId":20,"words":[{"id":70910,"position":1,"arabic":"كَذَٰلِكَ","translation":"এরূপে","audioUrl":"wbw/020_099_001.mp3","charTypeName":"word"},{"id":70911,"position":2,"arabic":"نَقُصُّ","translation":"বর্ণনা করছি আমরা","audioUrl":"wbw/020_099_002.mp3","charTypeName":"word"},{"id":70912,"position":3,"arabic":"عَلَيْكَ","translation":"তোমার কাছে","audioUrl":"wbw/020_099_003.mp3","charTypeName":"word"},{"id":70913,"position":4,"arabic":"مِنْ","translation":"হ'তে","audioUrl":"wbw/020_099_004.mp3","charTypeName":"word"},{"id":70914,"position":5,"arabic":"أَنۢبَآءِ","translation":"সংবাদ","audioUrl":"wbw/020_099_005.mp3","charTypeName":"word"},{"id":70915,"position":6,"arabic":"مَا","translation":"যা","audioUrl":"wbw/020_099_006.mp3","charTypeName":"word"},{"id":70916,"position":7,"arabic":"قَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/020_099_007.mp3","charTypeName":"word"},{"id":70917,"position":8,"arabic":"سَبَقَ ۚ","translation":"আগে ঘটেছে","audioUrl":"wbw/020_099_008.mp3","charTypeName":"word"},{"id":70919,"position":9,"arabic":"وَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/020_099_010.mp3","charTypeName":"word"},{"id":70920,"position":10,"arabic":"ءَاتَيْنَـٰكَ","translation":"তোমাকে আমরা দিয়েছি","audioUrl":"wbw/020_099_011.mp3","charTypeName":"word"},{"id":70921,"position":11,"arabic":"مِن","translation":"হ'তে","audioUrl":"wbw/020_099_012.mp3","charTypeName":"word"},{"id":70922,"position":12,"arabic":"لَّدُنَّا","translation":"আমার নিকট","audioUrl":"wbw/020_099_013.mp3","charTypeName":"word"},{"id":70923,"position":13,"arabic":"ذِكْرًۭا","translation":"উপদেশ","audioUrl":"wbw/0