","charTypeName":"word"},{"id":72410,"position":2,"arabic":"أَعْلَمُ","translation":"খুব জানি","audioUrl":"wbw/020_104_002.mp3","charTypeName":"word"},{"id":72411,"position":3,"arabic":"بِمَا","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/020_104_003.mp3","charTypeName":"word"},{"id":72412,"position":4,"arabic":"يَقُولُونَ","translation":"তারা বলবে","audioUrl":"wbw/020_104_004.mp3","charTypeName":"word"},{"id":72413,"position":5,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/020_104_005.mp3","charTypeName":"word"},{"id":72414,"position":6,"arabic":"يَقُولُ","translation":"বলবে","audioUrl":"wbw/020_104_006.mp3","charTypeName":"word"},{"id":72415,"position":7,"arabic":"أَمْثَلُهُمْ","translation":"তাদের মধ্যকার অপেক্ষাকৃত উত্তম ব্যক্তি","audioUrl":"wbw/020_104_007.mp3","charTypeName":"word"},{"id":72416,"position":8,"arabic":"طَرِيقَةً","translation":"বুদ্ধিমত্তায়","audioUrl":"wbw/020_104_008.mp3","charTypeName":"word"},{"id":72417,"position":9,"arabic":"إِن","translation":"\"না","audioUrl":"wbw/020_104_009.mp3","charTypeName":"word"},{"id":72418,"position":10,"arabic":"لَّبِثْتُمْ","translation":"তোমরা অবস্থান করেছিলে","audioUrl":"wbw/020_104_010.mp3","charTypeName":"word"},{"id":72419,"position":11,"arabic":"إِلَّا","translation":"এছাড়া","audioUrl":"wbw/020_104_011.mp3","charTypeName":"word"},{"id":72420,"position":12,"arabic":"يَوْمًۭا","translation":"একদিন\"","audioUrl":"wbw/020_104_012.mp3","charTypeName":"word"},{"id":72421,"position":13,"arabic":"١٠٤","translation":"(১০৪)","audioUrl":null,"charTypeName":"end"}]},{"number":105,"arabic":"وَيَسْـَٔلُونَكَ عَنِ ٱلْجِبَالِ فَقُلْ يَنسِفُهَا رَبِّى نَسْفًۭا","translation":"AND THEY WILL ask thee about [what will happen to] the mountains [when this world comes to an end]. Say, then: \"My Sustainer will scatter them far and wide,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2453.mp3","surahId":20,"words":[{"id":72856,"position":1,"arabic":"وَيَسْـَٔلُونَكَ","translation":"এবং তোমাকে তারা প্রশ্ন করে","audioUrl":"wbw/020_105_001.mp3","charTypeName":"word"},{"id":72857,"position":2,"arabic":"عَنِ","translation":"সম্পর্কে","audioUrl":"wbw/020_105_002.mp3","charTypeName":"word"},{"id":72858,"position":3,"arabic":"ٱلْجِبَالِ","translation":"পর্বতসমূহ","audioUrl":"wbw/020_105_003.mp3","charTypeName":"word"},{"id":72859,"position":4,"arabic":"فَقُلْ","translation":"অতঃপর বলো","audioUrl":"wbw/020_105_004.mp3","charTypeName":"word"},{"id":72860,"position":5,"arabic":"يَنسِفُهَا","translation":"\"তা উড়িয়ে দিবেন ধুলো করে","audioUrl":"wbw/020_105_005.mp3","charTypeName":"word"},{"id":72861,"position":6,"arabic":"رَبِّى","translation":"আমার রব","audioUrl":"wbw/020_105_006.mp3","charTypeName":"word"},{"id":72862,"position":7,"arabic":"نَسْفًۭا","translation":"(খুব করে) উড়িয়ে দেয়া","audioUrl":"wbw/020_105_007.mp3","charTypeName":"word"},{"id":72863,"position":8,"arabic":"١٠٥","translation":"(১০৫)","audioUrl":null,"charTypeName":"end"}]},{"number":106,"arabic":"فَيَذَرُهَا قَاعًۭا صَفْصَفًۭا","translation":"and leave the earths level and bare,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2454.mp3","surahId":20,"words":[{"id":73035,"position":1,"arabic":"فَيَذَرُهَا","translation":"অতঃপর তা পরিণত করবেন","audioUrl":"wbw/020_106_001.mp3","charTypeName":"word"},{"id":73036,"position":2,"arabic":"قَاعًۭا","translation":"সমতল","audioUrl":"wbw/020_106_002.mp3","charTypeName":"word"},{"id":73037,"position":3,"arabic":"صَفْصَفًۭا","translation":"মসৃণ ময়দানে","audioUrl":"wbw/020_106_003.mp3","charTypeName":"word"},{"id":73038,"position":4,"arabic":"١٠٦","translation":"(১০৬)","audioUrl":null,"charTypeName":"end"}]},{"number":107,"arabic":"لَّا تَرَىٰ فِيهَا عِوَجًۭا وَلَآ أَمْتًۭا","translation":"[so that] thou wilt see no curve thereon, and no ruggedness.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2455.mp3","surahId":20,"words":[{"id":73413,"position":1,"arabic":"لَّا","translation":"না","audioUrl":"wbw/020_107_001.mp3","charTypeName":"word"