{"id":454,"ayahs":[{"number":17,"arabic":"ٱصْبِرْ عَلَىٰ مَا يَقُولُونَ وَٱذْكُرْ عَبْدَنَا دَاوُۥدَ ذَا ٱلْأَيْدِ ۖ إِنَّهُۥٓ أَوَّابٌ","translation":"[But] bear thou with patience whatever they may say, and remember Our servant David, him who was endowed with [so much] inner strength! He, verily, would always turn unto Us:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3987.mp3","surahId":38,"words":[{"id":20072,"position":1,"arabic":"ٱصْبِرْ","translation":"(হে নাবী) ধৈর্য্য ধরো","audioUrl":"wbw/038_017_001.mp3","charTypeName":"word"},{"id":20073,"position":2,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/038_017_002.mp3","charTypeName":"word"},{"id":20074,"position":3,"arabic":"مَا","translation":"যা","audioUrl":"wbw/038_017_003.mp3","charTypeName":"word"},{"id":20075,"position":4,"arabic":"يَقُولُونَ","translation":"তারা বলছে","audioUrl":"wbw/038_017_004.mp3","charTypeName":"word"},{"id":20076,"position":5,"arabic":"وَٱذْكُرْ","translation":"এবং স্মরণ করো","audioUrl":"wbw/038_017_005.mp3","charTypeName":"word"},{"id":20077,"position":6,"arabic":"عَبْدَنَا","translation":"আমাদের দাস","audioUrl":"wbw/038_017_006.mp3","charTypeName":"word"},{"id":20078,"position":7,"arabic":"دَاوُۥدَ","translation":"দাউদের (ঘটনা)","audioUrl":"wbw/038_017_007.mp3","charTypeName":"word"},{"id":20079,"position":8,"arabic":"ذَا","translation":"অধিকারী","audioUrl":"wbw/038_017_008.mp3","charTypeName":"word"},{"id":20080,"position":9,"arabic":"ٱلْأَيْدِ ۖ","translation":"(যে ছিলো) শক্তির","audioUrl":"wbw/038_017_009.mp3","charTypeName":"word"},{"id":20082,"position":10,"arabic":"إِنَّهُۥٓ","translation":"নিশ্চয়ই সে (ছিলো)","audioUrl":"wbw/038_017_011.mp3","charTypeName":"word"},{"id":20083,"position":11,"arabic":"أَوَّابٌ","translation":"(আল্লাহ) অভিমুখী","audioUrl":"wbw/038_017_012.mp3","charTypeName":"word"},{"id":20084,"position":12,"arabic":"١٧","translation":"(১৭)","audioUrl":null,"charTypeName":"end"}]},{"number":18,"arabic":"إِنَّا سَخَّرْنَا ٱلْجِبَالَ مَعَهُۥ يُسَبِّحْنَ بِٱلْعَشِىِّ وَٱلْإِشْرَاقِ","translation":"[and for this,] behold, We caused the mountains to join him in extolling Our limitless glory at eventide and at sun­rise,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3988.mp3","surahId":38,"words":[{"id":21161,"position":1,"arabic":"إِنَّا","translation":"নিশ্চযই় আমরা","audioUrl":"wbw/038_018_001.mp3","charTypeName":"word"},{"id":21162,"position":2,"arabic":"سَخَّرْنَا","translation":"আমরা বশ করে দিয়েছিলাম","audioUrl":"wbw/038_018_002.mp3","charTypeName":"word"},{"id":21163,"position":3,"arabic":"ٱلْجِبَالَ","translation":"পাহাড়সমূহকে","audioUrl":"wbw/038_018_003.mp3","charTypeName":"word"},{"id":21164,"position":4,"arabic":"مَعَهُۥ","translation":"তার সাথে","audioUrl":"wbw/038_018_004.mp3","charTypeName":"word"},{"id":21165,"position":5,"arabic":"يُسَبِّحْنَ","translation":"তারা পবিত্র মহিমা ঘোষণা করতো","audioUrl":"wbw/038_018_005.mp3","charTypeName":"word"},{"id":21166,"position":6,"arabic":"بِٱلْعَشِىِّ","translation":"সন্ধ্যায়","audioUrl":"wbw/038_018_006.mp3","charTypeName":"word"},{"id":21167,"position":7,"arabic":"وَٱلْإِشْرَاقِ","translation":"ও সকালে","audioUrl":"wbw/038_018_007.mp3","charTypeName":"word"},{"id":21168,"position":8,"arabic":"١٨","translation":"(১৮)","audioUrl":null,"charTypeName":"end"}]},{"number":19,"arabic":"وَٱلطَّيْرَ مَحْشُورَةًۭ ۖ كُلٌّۭ لَّهُۥٓ أَوَّابٌۭ","translation":"and [likewise] the birds in their assemblies: [together] they all Would turn again and again unto Him [who had created them].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3989.mp3","surahId":38,"words":[{"id":22275,"position":1,"arabic":"وَٱلطَّيْرَ","translation":"এবং পাখিগুলো","audioUrl":"wbw/038_019_001.mp3","charTypeName":"word"},{"id":22276,"position":2,"arabic":"مَحْشُورَةًۭ ۖ","translation":"সমবেত হতো","audioUrl":"wbw/038_019_002.mp3","charTypeName":"word"},{"id":22278,"position":3,"arabic":"كُلٌّۭ","translation":"প্রত্যেকে (ছিলো)","audioUrl":"wbw/038_019_004.mp3","charTypeName":"word"},{"id":22279,"position":4,"arabic":"لَّهُۥٓ","translation":"তাঁরই","audioUrl":"wbw/038_019_005.mp3","charTypeName":"word"},{"id":22280,"position":5,"arabic":"أَوَّابٌۭ","translation":"অভিমুখী (ও অনুগত)","audioUrl":"wbw/038_019_006.mp3","charTypeName":"word"},{"id":22281,"position":6,"arabic":"١٩","translation":"(১৯)","audioUrl":null,"charTypeName":"end"}]},{"number":20,"arabic":"وَشَدَدْنَا مُلْكَهُۥ وَءَاتَيْنَٰهُ ٱلْحِكْمَةَ وَفَصْلَ ٱلْخِطَابِ","translation":"And We streng­thened his dominion, and bestowed upon him wisdom and sagacity in judgment.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3990.mp3","surahId":38,"words":[{"id":23329,"position":1,"arabic":"وَشَدَدْنَا","translation":"এবং আমরা সুদৃঢ় করেছিলাম","audioUrl":"wbw/038_020_001.mp3","charTypeName":"word"},{"id":23330,"position":2,"arabic":"مُلْكَهُۥ","translation":"তার রাজত্বকে","audioUrl":"wbw/038_020_002.mp3","charTypeName":"word"},{"id":23331,"position":3,"arabic":"وَءَاتَيْنَـٰهُ","translation":"এবং তাকে আমরা দিয়েছিলাম","audioUrl":"wbw/038_020_003.mp3","charTypeName":"word"},{"id":23332,"position":4,"arabic":"ٱلْحِكْمَةَ","translation":"প্রজ্ঞা","audioUrl":"wbw/038_020_004.mp3","charTypeName":"word"},{"id":23333,"position":5,"arabic":"وَفَصْلَ","translation":"ও চূড়ান্তকারী","audioUrl":"wbw/038_020_005.mp3","charTypeName":"word"},{"id":23334,"position":6,"arabic":"ٱلْخِطَابِ","translation":"বাগ্মিতা","audioUrl":"wbw/038_020_006.mp3","charTypeName":"word"},{"id":23335,"position":7,"arabic":"٢٠","translation":"(২০)","audioUrl":null,"charTypeName":"end"}]},{"number":21,"arabic":"۞ وَهَلْ أَتَىٰكَ نَبَؤُا۟ ٱلْخَصْمِ إِذْ تَسَوَّرُوا۟ ٱلْمِحْرَابَ","translation":"AND YET, has the story of the litigants come within thy ken - [the story of the two] who surmounted the walls of the sanctuary [in which David prayed]?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3991.mp3","surahId":38,"words":[{"id":24356,"position":1,"arabic":"۞ وَهَلْ","translation":"এবং কি","audioUrl":"wbw/038_021_002.mp3","charTypeName":"word"},{"id":24357,"position":2,"arabic":"أَتَىٰكَ","translation":"তোমার কাছে পৌঁছেছে","audioUrl":"wbw/038_021_003.mp3","charTypeName":"word"},{"id":24358,"position":3,"arabic":"نَبَؤُا۟","translation":"খবর","audioUrl":"wbw/038_021_004.mp3","charTypeName":"word"},{"id":24359,"position":4,"arabic":"ٱلْخَصْمِ","translation":"বিবদমান লোকদের","audioUrl":"wbw/038_021_005.mp3","charTypeName":"word"},{"id":24360,"position":5,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/038_021_006.mp3","charTypeName":"word"},{"id":24361,"position":6,"arabic":"تَسَوَّرُوا۟","translation":"তারা দেয়াল টপকে ঢুকে পড়লো","audioUrl":"wbw/038_021_007.mp3","charTypeName":"word"},{"id":24362,"position":7,"arabic":"ٱلْمِحْرَابَ","translation":"খাসকামরায়","audioUrl":"wbw/038_021_008.mp3","charTypeName":"word"},{"id":24363,"position":8,"arabic":"٢١","translation":"(২১)","audioUrl":null,"charTypeName":"end"}]},{"number":22,"arabic":"إِذْ دَخَلُوا۟ عَلَىٰ دَاوُۥدَ فَفَزِعَ مِنْهُمْ ۖ قَالُوا۟ لَا تَخَفْ ۖ خَصْمَانِ بَغَىٰ بَعْضُنَا عَلَىٰ بَعْضٍۢ فَٱحْكُم بَيْنَنَا بِٱلْحَقِّ وَلَا تُشْطِطْ وَٱهْدِنَآ إِلَىٰ سَوَآءِ ٱلصِّرَٰطِ","translation":"As they came upon David, and he shrank back in fear from them, they said: “Fear not! [We are but] two litigants. One of us has wronged the other: so judge thou between us with justice, and deviate not from what is right, and show [both of] us the way to rectitude.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3992.mp3","surahId":38,"words":[{"id":25408,"position":1,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/038_022_001.mp3","charTypeName":"word"},{"id":25409,"position":2,"arabic":"دَخَلُوا۟","translation":"তারা প্রবেশ করেছিলো","audioUrl":"wbw/038_022_002.mp3","charTypeName":"word"},{"id":25410,"position":3,"arabic":"عَلَىٰ","translation":"কাছে","audioUrl":"wbw/038_022_003.mp3","charTypeName":"word"},{"id":25411,"position":4,"arabic":"دَاوُۥدَ","translation":"দাউদের","audioUrl":"wbw/038_022_004.mp3","charTypeName":"word"},{"id":25412,"position":5,"arabic":"فَفَزِعَ","translation":"সে তখন ভয় পেলো","audioUrl":"wbw/038_022_005.mp3","charTypeName":"word"},{"id":25413,"position":6,"arabic":"مِنْهُمْ ۖ","translation":"তাদের থেকে","audioUrl":"wbw/038_022_006.mp3","charTypeName":"word"},{"id":25415,"position":7,"arabic":"قَالُوا۟","translation":"তারা বললো","audioUrl":"wbw/038_022_008.mp3","charTypeName":"word"},{"id":25416,"position":8,"arabic":"لَا","translation":"\"না","audioUrl":"wbw/038_022_009.mp3","charTypeName":"word"},{"id":25417,"position":9,"arabic":"تَخَفْ ۖ","translation":"ভয় পাবেন","audioUrl":"wbw/038_022_010.mp3","charTypeName":"word"},{"id":25419,"position":10,"arabic":"خَصْمَانِ","translation":"(আমরা) বিবদমান  দু'পক্ষ","audioUrl":"wbw/038_022_012.mp3","charTypeName":"word"},{"id":25420,"position":11,"arabic":"بَغَىٰ","translation":"বাড়াবাড়ি করেছে","audioUrl":"wbw/038_022_013.mp3","charTypeName":"word"},{"id":25421,"position":12,"arabic":"بَعْضُنَا","translation":"আমাদের একজন","audioUrl":"wbw/038_022_014.mp3","charTypeName":"word"},{"id":25422,"position":13,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/038_022_015.mp3","charTypeName":"word"},{"id":25423,"position":14,"arabic":"بَعْضٍۢ","translation":"অপরজনের","audioUrl":"wbw/038_022_016.mp3","charTypeName":"word"},{"id":25424,"position":15,"arabic":"فَٱحْكُم","translation":"সুতরাং বিচার করে দিন","audioUrl":"wbw/038_022_017.mp3","charTypeName":"word"},{"id":25425,"position":16,"arabic":"بَيْنَنَا","translation":"আমাদের মাঝে","audioUrl":"wbw/038_022_018.mp3","charTypeName":"word"},{"id":25426,"position":17,"arabic":"بِٱلْحَقِّ","translation":"ন্যায়ভাবে","audioUrl":"wbw/038_022_019.mp3","charTypeName":"word"},{"id":25427,"position":18,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/038_022_020.mp3","charTypeName":"word"},{"id":25428,"position":19,"arabic":"تُشْطِطْ","translation":"অবিচার করবেন","audioUrl":"wbw/038_022_021.mp3","charTypeName":"word"},{"id":25429,"position":20,"arabic":"وَٱهْدِنَآ","translation":"এবং আমাদের পরিচালনা করবেন","audioUrl":"wbw/038_022_022.mp3","charTypeName":"word"},{"id":25430,"position":21,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/038_022_023.mp3","charTypeName":"word"},{"id":25431,"position":22,"arabic":"سَوَآءِ","translation":"সরল সঠিক","audioUrl":"wbw/038_022_024.mp3","charTypeName":"word"},{"id":25432,"position":23,"arabic":"ٱلصِّرَٰطِ","translation":"পথের","audioUrl":"wbw/038_022_025.mp3","charTypeName":"word"},{"id":25433,"position":24,"arabic":"٢٢","translation":"(২২)","audioUrl":null,"charTypeName":"end"}]},{"number":23,"arabic":"إِنَّ هَٰذَآ أَخِى لَهُۥ تِسْعٌۭ وَتِسْعُونَ نَعْجَةًۭ وَلِىَ نَعْجَةٌۭ وَٰحِدَةٌۭ فَقَالَ أَكْفِلْنِيهَا وَعَزَّنِى فِى ٱلْخِطَابِ","translation":"“Behold, this is my brother: he has ninety-nine ewes, whereas I have [only] one ewe - and yet he said, ‘Make her over to me,’ and forcibly prevailed against me in this [our] dispute.”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3993.mp3","surahId":38,"words":[{"id":26465,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/038_023_001.mp3","charTypeName":"word"},{"id":26466,"position":2,"arabic":"هَـٰذَآ","translation":"এই","audioUrl":"wbw/038_023_002.mp3","charTypeName":"word"},{"id":26467,"position":3,"arabic":"أَخِى","translation":"আমার ভাই","audioUrl":"wbw/038_023_003.mp3","charTypeName":"word"},{"id":26468,"position":4,"arabic":"لَهُۥ","translation":"তার আছে","audioUrl":"wbw/038_023_004.mp3","charTypeName":"word"},{"id":26469,"position":5,"arabic":"تِسْعٌۭ","translation":"নয়","audioUrl":"wbw/038_023_005.mp3","charTypeName":"word"},{"id":26470,"position":6,"arabic":"وَتِسْعُونَ","translation":"এবং নব্বই (অর্থাৎ নিরানব্বইটি)","audioUrl":"wbw/038_023_006.mp3","charTypeName":"word"},{"id":26471,"position":7,"arabic":"نَعْجَةًۭ","translation":"দুম্বী","audioUrl":"wbw/038_023_007.mp3","charTypeName":"word"},{"id":26472,"position":8,"arabic":"وَلِىَ","translation":"ও আমার আছে","audioUrl":"wbw/038_023_008.mp3","charTypeName":"word"},{"id":26473,"position":9,"arabic":"نَعْجَةٌۭ","translation":"দুম্বী","audioUrl":"wbw/038_023_009.mp3","charTypeName":"word"},{"id":26474,"position":10,"arabic":"وَٰحِدَةٌۭ","translation":"একটি","audioUrl":"wbw/038_023_010.mp3","charTypeName":"word"},{"id":26475,"position":11,"arabic":"فَقَالَ","translation":"তবুও সে বললো","audioUrl":"wbw/038_023_011.mp3","charTypeName":"word"},{"id":26476,"position":12,"arabic":"أَكْفِلْنِيهَا","translation":"\"তা আমার দায়িত্বে দাও\"","audioUrl":"wbw/038_023_012.mp3","charTypeName":"word"},{"id":26477,"position":13,"arabic":"وَعَزَّنِى","translation":"এবং সে আমাকে পরাস্ত করে ফেললো","audioUrl":"wbw/038_023_013.mp3","charTypeName":"word"},{"id":26478,"position":14,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/038_023_014.mp3","charTypeName":"word"},{"id":26479,"position":15,"arabic":"ٱلْخِطَابِ","translation":"কথাবার্তার\"","audioUrl":"wbw/038_023_015.mp3","charTypeName":"word"},{"id":26480,"position":16,"arabic":"٢٣","translation":"(২৩)","audioUrl":null,"charTypeName":"end"}]},{"number":24,"arabic":"قَالَ لَقَدْ ظَلَمَكَ بِسُؤَالِ نَعْجَتِكَ إِلَىٰ نِعَاجِهِۦ ۖ وَإِنَّ كَثِيرًۭا مِّنَ ٱلْخُلَطَآءِ لَيَبْغِى بَعْضُهُمْ عَلَىٰ بَعْضٍ إِلَّا ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ وَقَلِيلٌۭ مَّا هُمْ ۗ وَظَنَّ دَاوُۥدُ أَنَّمَا فَتَنَّٰهُ فَٱسْتَغْفَرَ رَبَّهُۥ وَخَرَّ رَاكِعًۭا وَأَنَابَ ۩","translation":"Said [David]: “He has certainly wronged thee by demanding that thy ewe be added to his ewes! Thus, behold, do many kinsmen wrong one another [all] save those who believe [in God] and do righteous deeds: but how few are they!” And [suddenly] David understood that We had tried him: and so he asked his Sustainer to forgive him his sin, and fell down in prostration, and turned unto Him in repentance.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3994.mp3","surahId":38,"words":[{"id":27463,"position":1,"arabic":"قَالَ"