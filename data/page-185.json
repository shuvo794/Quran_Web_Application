/008_064_003.mp3","charTypeName":"word"},{"id":56507,"position":4,"arabic":"ٱللَّهُ","translation":"আল্লাহই","audioUrl":"wbw/008_064_004.mp3","charTypeName":"word"},{"id":56508,"position":5,"arabic":"وَمَنِ","translation":"এবং (তাদের জন্যে) যারা","audioUrl":"wbw/008_064_005.mp3","charTypeName":"word"},{"id":56509,"position":6,"arabic":"ٱتَّبَعَكَ","translation":"তোমাকে অনুসরণ করে","audioUrl":"wbw/008_064_006.mp3","charTypeName":"word"},{"id":56510,"position":7,"arabic":"مِنَ","translation":"মধ্যে","audioUrl":"wbw/008_064_007.mp3","charTypeName":"word"},{"id":56511,"position":8,"arabic":"ٱلْمُؤْمِنِينَ","translation":"মু'মিনদের (জন্যে)","audioUrl":"wbw/008_064_008.mp3","charTypeName":"word"},{"id":56512,"position":9,"arabic":"٦٤","translation":"(৬৪)","audioUrl":null,"charTypeName":"end"}]},{"number":65,"arabic":"يَٰٓأَيُّهَا ٱلنَّبِىُّ حَرِّضِ ٱلْمُؤْمِنِينَ عَلَى ٱلْقِتَالِ ۚ إِن يَكُن مِّنكُمْ عِشْرُونَ صَٰبِرُونَ يَغْلِبُوا۟ مِا۟ئَتَيْنِ ۚ وَإِن يَكُن مِّنكُم مِّا۟ئَةٌۭ يَغْلِبُوٓا۟ أَلْفًۭا مِّنَ ٱلَّذِينَ كَفَرُوا۟ بِأَنَّهُمْ قَوْمٌۭ لَّا يَفْقَهُونَ","translation":"O Prophet! Inspire the believers to conquer all fear of death when fighting, [so that,] if there be twenty of you who are patient in adversity, they might overcome two hundred; and [that,] if there be one hundred of you, they might overcome one thousand of those who are bent on denying the truth, because they are people who cannot grasp it.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1225.mp3","surahId":8,"words":[{"id":57097,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/008_065_001.mp3","charTypeName":"word"},{"id":57098,"position":2,"arabic":"ٱلنَّبِىُّ","translation":"নাবী","audioUrl":"wbw/008_065_002.mp3","charTypeName":"word"},{"id":57099,"position":3,"arabic":"حَرِّضِ","translation":"উদ্বুদ্ধ করো","audioUrl":"wbw/008_065_003.mp3","charTypeName":"word"},{"id":57100,"position":4,"arabic":"ٱلْمُؤْمِنِينَ","translation":"মু'মিনদেরকে","audioUrl":"wbw/008_065_004.mp3","charTypeName":"word"},{"id":57101,"position":5,"arabic":"عَلَى","translation":"জন্যে","audioUrl":"wbw/008_065_005.mp3","charTypeName":"word"},{"id":57102,"position":6,"arabic":"ٱلْقِتَالِ ۚ","translation":"যুদ্ধের","audioUrl":"wbw/008_065_006.mp3","charTypeName":"word"},{"id":57104,"position":7,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/008_065_008.mp3","charTypeName":"word"},{"id":57105,"position":8,"arabic":"يَكُن","translation":"হয়","audioUrl":"wbw/008_065_009.mp3","charTypeName":"word"},{"id":57106,"position":9,"arabic":"مِّنكُمْ","translation":"মধ্য হতে তোমাদের","audioUrl":"wbw/008_065_010.mp3","charTypeName":"word"},{"id":57107,"position":10,"arabic":"عِشْرُونَ","translation":"বিশজন","audioUrl":"wbw/008_065_011.mp3","charTypeName":"word"},{"id":57108,"position":11,"arabic":"صَـٰبِرُونَ","translation":"ধৈর্যশীল","audioUrl":"wbw/008_065_012.mp3","charTypeName":"word"},{"id":57109,"position":12,"arabic":"يَغْلِبُوا۟","translation":"তারা বিজয়ী হবে","audioUrl":"wbw/008_065_013.mp3","charTypeName":"word"},{"id":57110,"position":13,"arabic":"مِا۟ئَتَيْنِ ۚ","translation":"দু'শতের (উপর)","audioUrl":"wbw/008_065_014.mp3","charTypeName":"word"},{"id":57112,"position":14,"arabic":"وَإِن","translation":"এবং যদি","audioUrl":"wbw/008_065_016.mp3","charTypeName":"word"},{"id":57113,"position":15,"arabic":"يَكُن","translation":"হয়","audioUrl":"wbw/008_065_017.mp3","charTypeName":"word"},{"id":57114,"position":16,"arabic":"مِّنكُم","translation":"মধ্য হতে তোমাদের","audioUrl":"wbw/008_065_018.mp3","charTypeName":"word"},{"id":57115,"position":17,"arabic":"مِّا۟ئَةٌۭ","translation":"একশত","audioUrl":"wbw/008_065_019.mp3","charTypeName":"word"},{"id":57116,"position":18,"arabic":"يَغْلِبُوٓا۟","translation":"তারা বিজয়ী হবে","audioUrl":"wbw/008_065_020.mp3","charTypeName":"word"},{"id":57117,"position":19,"arabic":"أَلْفًۭا","translation":"এক হাজারের (উপর)","audioUrl":"wbw/008_065_021.mp3","charTypeName":"word"},{"id":57118,"position":20,"arabic":"مِّنَ","translation":"(তাদের) হতে","audioUrl":"wbw/008_065_022.mp3","charTypeName":"word"},{"id":57119,"position":21,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/008_065_023.mp3","charTypeName":"word"},{"id":57120,"position":22,"arabic":"كَفَرُوا۟","translation":"অবিশ্বাস করেছে","audioUrl":"wbw/008_065_024.mp3","charTypeName":"word"},{"id":57121,"position":23,"arabic":"بِأَنَّهُمْ","translation":"একারণে যে তারা","audioUrl":"wbw/008_065_025.mp3","charTypeName":"word"},{"id":57122,"position":24,"arabic":"قَوْمٌۭ","translation":"(এমন)সম্প্রদায়","audioUrl":"wbw/008_065_026.mp3","charTypeName":"word"},{"id":57123,"position":25,"arabic":"لَّا","translation":"(যারা) না","audioUrl":"wbw/008_065_027.mp3","charTypeName":"word"},{"id":57124,"position":26,"arabic":"يَفْقَهُونَ","translation":"তারা বুঝে","audioUrl":"wbw/008_065_028.mp3","charTypeName":"word"},{"id":57125,"position":27,"arabic":"٦٥","translation":"(৬৫)","audioUrl":null,"charTypeName":"end"}]},{"number":66,"arabic":"ٱلْـَٰٔنَ خَفَّفَ ٱللَّهُ عَنكُمْ وَعَلِمَ أَنَّ فِيكُمْ ضَعْفًۭا ۚ فَإِن يَكُن مِّنكُم مِّا۟ئَةٌۭ صَابِرَةٌۭ يَغْلِبُوا۟ مِا۟ئَتَيْنِ ۚ وَإِن يَكُن مِّنكُمْ أَلْفٌۭ يَغْلِبُوٓا۟ أَلْفَيْنِ بِإِذْنِ ٱللَّهِ ۗ وَٱللَّهُ مَعَ ٱلصَّٰبِرِينَ","translation":"For the time being, [however,] God has lightened your burden. for He knows that you are weak: and so, if there be one hundred of you who are patient in adversity, they should [be able to]' overcome two hundred; and if there be one thousand of you, they should [be able to] overcome two thousand by God's leave: for God is with those who are patient in adversity.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1226.mp3","surahId":8,"words":[{"id":57574,"position":1,"arabic":"ٱلْـَٔـٰنَ","translation":"এখন","audioUrl":"wbw/008_066_001.mp3","charTypeName":"word"},{"id":57575,"position":2,"arabic":"خَفَّفَ","translation":"(বোঝা) হালকা করেছেন","audioUrl":"wbw/008_066_002.mp3","charTypeName":"word"},{"id":57576,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/008_066_003.mp3","charTypeName":"word"},{"id":57577,"position":4,"arabic":"عَنكُمْ","translation":"হতে তোমাদের","audioUrl":"wbw/008_066_004.mp3","charTypeName":"word"},{"id":57578,"position":5,"arabic":"وَعَلِمَ","translation":"এবং তিনি জানেন","audioUrl":"wbw/008_066_005.mp3","charTypeName":"word"},{"id":57579,"position":6,"arabic":"أَنَّ","translation":"যে","audioUrl":"wbw/008_066_006.mp3","charTypeName":"word"},{"id":57580,"position":7,"arabic":"فِيكُمْ","translation":"মধ্যে (আছে) তোমাদের","audioUrl":"wbw/008_066_007.mp3","charTypeName":"word"},{"id":57581,"position":8,"arabic":"ضَعْفًۭا ۚ","translation":"দুর্বলতা","audioUrl":"wbw/008_066_008.mp3","charTypeName":"word"},{"id":57583,"position":9,"arabic":"فَإِن","translation":"অতএব যদি","audioUrl":"wbw/008_066_010.mp3","charTypeName":"word"},{"id":57584,"position":10,"arabic":"يَكُن","translation":"হয়","audioUrl":"wbw/008_066_011.mp3","charTypeName":"word"},{"id":57585,"position":11,"arabic":"مِّنكُم","translation":"মধ্য হতে তোমাদের","audioUrl":"wbw/008_066_012.mp3","charTypeName":"word"},{"id":57586,"position":12,"arabic":"مِّا۟ئَةٌۭ","translation":"একশত (জন)","audioUrl":"wbw/008_066_013.mp3","charTypeName":"word"},{"id":57587,"position":13,"arabic":"صَابِرَةٌۭ","translation":"ধৈর্যশীল","audioUrl":"wbw/008_066_014.mp3","charTypeName":"word"},{"id":57588,"position":14,"arabic":"يَغْلِبُوا۟","translation":"তারা বিজয়ী হবে","audioUrl":"wbw/008_066_015.mp3","charTypeName":"word"},{"id":57589,"position":15,"arabic":"مِا۟ئَتَيْنِ ۚ","translation":"দু'শতের (উপর)","audioUrl":"wbw/008_066_016.mp3","charTypeName":"word"},{"id":57591,"position":16,"arabic":"وَإِن","translation":"এবং যদি","audioUrl":"wbw/008_066_018.mp3","charTypeName":"word"},{"id":57592,"position":17,"arabic":"يَكُن","translation":"হয়","audioUrl":"wbw/008_066_019.mp3","charTypeName":"word"},{"id":57593,"position":18,"arabic":"مِّنكُمْ","translation":"মধ্য হতে তোমাদের","audioUrl":"wbw/008_066_020.mp3","charTypeName":"word"},{"id":57594,"position":19,"arabic":"أَلْفٌۭ","translation":"এক হাজার (জন)","audioUrl":"wbw/008_066_021.mp3","charTypeName":"word"},{"id":57595,"position":20,"arabic":"يَغْلِبُوٓا۟","translation":"তারা বিজয়ী হবে","audioUrl":"wbw/008_066_022.mp3","charTypeName":"word"},{"id":57596,"position":21,"arabic":"أَلْفَيْنِ","translation":"দু'হাজারের (উপর)","audioUrl":"wbw/008_066_023.mp3","charTypeName":"word"},{"id":57597,"position":22,"arabic":"بِإِذْنِ","translation":"সাহায্যে অনুমতির","audioUrl":"wbw/008_066_024.mp3","charTypeName":"word"},{"id":57598,"position":23,"arabic":"ٱللَّهِ ۗ","translation":"আল্লাহর","audioUrl":"wbw/008_066_025.mp3","charTypeName":"word"},{"id":57600,"position":24,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/008_066_027.mp3","charTypeName":"word"},{"id":57601,"position":25,"arabic":"مَعَ","translation":"সাথে (আছেন)","audioUrl":"wbw/008_066_028.mp3","charTypeName":"word"},{"id":57602,"position":26,"arabic":"ٱلصَّـٰبِرِينَ","translation":"ধৈর্যশীলদের","audioUrl":"wbw/008_066_029.mp3","charTypeName":"word"},{"id":57603,"position":27,"arabic":"٦٦","translation":"(৬৬)","audioUrl":null,"charTypeName":"end"}]},{"number":67,"arabic":"مَا كَانَ لِنَبِىٍّ أَن يَكُونَ لَهُۥٓ أَسْرَىٰ حَتَّىٰ يُثْخِنَ فِى ٱلْأَرْضِ ۚ تُرِيدُونَ عَرَضَ ٱلدُّنْيَا وَٱللَّهُ يُرِيدُ ٱلْءَاخِرَةَ ۗ وَٱللَّهُ عَزِيزٌ حَكِيمٌۭ","translation":"IT DOES NOT behove a prophet to keep captives unless he has battled strenuously on earth. You may desire the fleeting gains of this world-but God desires [for you the good of] the life to come: and God is almighty, wise.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1227.mp3","surahId":8,"words":[{"id":58358,"position":1,"arabic":"مَا","translation":"না","audioUrl":"wbw/008_067_001.mp3","charTypeName":"word"},{"id":58359,"position":2,"arabic":"كَانَ","translation":"শোভা পায়","audioUrl":"wbw/008_067_002.mp3","charTypeName":"word"},{"id":58360,"position":3,"arabic":"لِنَبِىٍّ","translation":"জন্যে নাবীর","audioUrl":"wbw/008_067_003.mp3","charTypeName":"word"},{"id":58361,"position":4,"arabic":"أَن","translation":"যে","audioUrl":"wbw/008_067_004.mp3","charTypeName":"word"},{"id":58362,"position":5,"arabic":"يَكُونَ","translation":"হবে","audioUrl":"wbw/008_067_005.mp3","charTypeName":"word"},{"id":58363,"position":6,"arabic":"لَهُۥٓ","translation":"কাছে তার","audioUrl":"wbw/008_067_006.mp3","charTypeName":"word"},{"id":58364,"position":7,"arabic":"أَسْرَىٰ","translation":"কোনো বন্দি","audioUrl":"wbw/008_067_007.mp3","charTypeName":"word"},{"id":58365,"position":8,"arabic":"حَتَّىٰ","translation":"যতক্ষণ না","audioUrl":"wbw/008_067_008.mp3","charTypeName":"word"},{"id":58366,"position":9,"arabic":"يُثْخِنَ","translation":"(শত্রুবাহিনীকে)সম্পূর্ণরূপে নিঃশেষ করবে","audioUrl":"wbw/008_067_009.mp3","charTypeName":"word"},{"id":58367,"position":10,"arabic":"فِى","translation":"উপর","audioUrl":"wbw/008_067_010.mp3","charTypeName":"word"},{"id":58368,"position":11,"arabic":"ٱلْأَرْضِ ۚ","translation":"জমিনের","audioUrl":"wbw/008_067_011.mp3","charTypeName":"word"},{"id":58370,"position":12,"arabic":"تُرِيدُونَ","translation":"তোমরা চাও","audioUrl":"wbw/008_067_013.mp3","charTypeName":"word"},{"id":58371,"position":13,"arabic":"عَرَضَ","translation":"সম্পদ","audioUrl":"wbw/008_067_014.mp3","charTypeName":"word"},{"id":58372,"position":14,"arabic":"ٱلدُّنْيَا","translation":"পার্থিব","audioUrl":"wbw/008_067_015.mp3","charTypeName":"word"},{"id":58373,"position":15,"arabic":"وَٱللَّهُ","translation":"আর আল্লাহ","audioUrl":"wbw/008_067_016.mp3","charTypeName":"word"},{"id":58374,"position":16,"arabic":"يُرِيدُ","translation":"চান","audioUrl":"wbw/008_067_017.mp3","charTypeName":"word"},{"id":58375,"position":17,"arabic":"ٱلْـَٔاخِرَةَ ۗ","translation":"আখেরাত","audioUrl":"wbw/008_067_018.mp3","charTypeName":"word"},{"id":58377,"position":18,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/008_067_020.mp3","charTypeName":"word"},{"id":58378,"position