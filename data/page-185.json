audioUrl":"wbw/008_068_010.mp3","charTypeName":"word"},{"id":58806,"position":11,"arabic":"٦٨","translation":"(৬৮)","audioUrl":null,"charTypeName":"end"}]},{"number":69,"arabic":"فَكُلُوا۟ مِمَّا غَنِمْتُمْ حَلَٰلًۭا طَيِّبًۭا ۚ وَٱتَّقُوا۟ ٱللَّهَ ۚ إِنَّ ٱللَّهَ غَفُورٌۭ رَّحِيمٌۭ","translation":"Enjoy, then, all that is lawful and good among the things which you have gained in war, and remain conscious of God: verily, God is much-forgiving, a dispenser of grace.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1229.mp3","surahId":8,"words":[{"id":59017,"position":1,"arabic":"فَكُلُوا۟","translation":"অতএব তোমরা খাও","audioUrl":"wbw/008_069_001.mp3","charTypeName":"word"},{"id":59018,"position":2,"arabic":"مِمَّا","translation":"(তা) হতে যা","audioUrl":"wbw/008_069_002.mp3","charTypeName":"word"},{"id":59019,"position":3,"arabic":"غَنِمْتُمْ","translation":"তোমরা গণীমত পেয়েছো","audioUrl":"wbw/008_069_003.mp3","charTypeName":"word"},{"id":59020,"position":4,"arabic":"حَلَـٰلًۭا","translation":"হালাল","audioUrl":"wbw/008_069_004.mp3","charTypeName":"word"},{"id":59021,"position":5,"arabic":"طَيِّبًۭا ۚ","translation":"পবিত্র (হিসেবে)","audioUrl":"wbw/008_069_005.mp3","charTypeName":"word"},{"id":59023,"position":6,"arabic":"وَٱتَّقُوا۟","translation":"এবং তোমরা ভয় করো","audioUrl":"wbw/008_069_007.mp3","charTypeName":"word"},{"id":59024,"position":7,"arabic":"ٱللَّهَ ۚ","translation":"আল্লাহকে","audioUrl":"wbw/008_069_008.mp3","charTypeName":"word"},{"id":59026,"position":8,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/008_069_010.mp3","charTypeName":"word"},{"id":59027,"position":9,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/008_069_011.mp3","charTypeName":"word"},{"id":59028,"position":10,"arabic":"غَفُورٌۭ","translation":"ক্ষমাশীল","audioUrl":"wbw/008_069_012.mp3","charTypeName":"word"},{"id":59029,"position":11,"arabic":"رَّحِيمٌۭ","translation":"পরম দয়ালু","audioUrl":"wbw/008_069_013.mp3","charTypeName":"word"},{"id":5