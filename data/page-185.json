{"id":185,"ayahs":[{"number":62,"arabic":"وَإِن يُرِيدُوٓا۟ أَن يَخْدَعُوكَ فَإِنَّ حَسْبَكَ ٱللَّهُ ۚ هُوَ ٱلَّذِىٓ أَيَّدَكَ بِنَصْرِهِۦ وَبِٱلْمُؤْمِنِينَ","translation":"And should they seek but to deceive thee [by their show of peace] - behold, God is enough for thee! He it is who has strengthened thee with His succour, and by giving thee believing followers","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1222.mp3","surahId":8,"words":[{"id":55470,"position":1,"arabic":"وَإِن","translation":"এবং যদি","audioUrl":"wbw/008_062_001.mp3","charTypeName":"word"},{"id":55471,"position":2,"arabic":"يُرِيدُوٓا۟","translation":"তারা চায়","audioUrl":"wbw/008_062_002.mp3","charTypeName":"word"},{"id":55472,"position":3,"arabic":"أَن","translation":"যে","audioUrl":"wbw/008_062_003.mp3","charTypeName":"word"},{"id":55473,"position":4,"arabic":"يَخْدَعُوكَ","translation":"তোমাকে তারা ধোঁকা দিবে","audioUrl":"wbw/008_062_004.mp3","charTypeName":"word"},{"id":55474,"position":5,"arabic":"فَإِنَّ","translation":"তবে বিশ্চয়ই","audioUrl":"wbw/008_062_005.mp3","charTypeName":"word"},{"id":55475,"position":6,"arabic":"حَسْبَكَ","translation":"তোমার জন্যে যথেষ্ট","audioUrl":"wbw/008_062_006.mp3","charTypeName":"word"},{"id":55476,"position":7,"arabic":"ٱللَّهُ ۚ","translation":"আল্লাহ","audioUrl":"wbw/008_062_007.mp3","charTypeName":"word"},{"id":55478,"position":8,"arabic":"هُوَ","translation":"তিনিই","audioUrl":"wbw/008_062_009.mp3","charTypeName":"word"},{"id":55479,"position":9,"arabic":"ٱلَّذِىٓ","translation":"যিনি","audioUrl":"wbw/008_062_010.mp3","charTypeName":"word"},{"id":55480,"position":10,"arabic":"أَيَّدَكَ","translation":"তোমাকে শক্তিশালী করেছেন","audioUrl":"wbw/008_062_011.mp3","charTypeName":"word"},{"id":55481,"position":11,"arabic":"بِنَصْرِهِۦ","translation":"দিয়ে তাঁর সাহায্য","audioUrl":"wbw/008_062_012.mp3","charTypeName":"word"},{"id":55482,"position":12,"arabic":"وَبِٱلْمُؤْمِنِينَ","translation":"ও দিয়ে মু'মিনদের","audioUrl":"wbw/008_062_013.mp3","charTypeName":"word"},{"id":55483,"position":13,"arabic":"٦٢","translation":"(৬২)","audioUrl":null,"charTypeName":"end"}]},{"number":63,"arabic":"وَأَلَّفَ بَيْنَ قُلُوبِهِمْ ۚ لَوْ أَنفَقْتَ مَا فِى ٱلْأَرْضِ جَمِيعًۭا مَّآ أَلَّفْتَ بَيْنَ قُلُوبِهِمْ وَلَٰكِنَّ ٱللَّهَ أَلَّفَ بَيْنَهُمْ ۚ إِنَّهُۥ عَزِيزٌ حَكِيمٌۭ","translation":"whose hearts He has brought together: [for,] if thou hadst expended all that is on earth, thou couldst not have brought their hearts together [by thyself]: but God did bring them together. Verily, He is almighty, wise.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1223.mp3","surahId":8,"words":[{"id":56093,"position":1,"arabic":"وَأَلَّفَ","translation":"এবং সম্প্রীতি স্থাপন করেছেন","audioUrl":"wbw/008_063_001.mp3","charTypeName":"word"},{"id":56094,"position":2,"arabic":"بَيْنَ","translation":"মাঝে","audioUrl":"wbw/008_063_002.mp3","charTypeName":"word"},{"id":56095,"position":3,"arabic":"قُلُوبِهِمْ ۚ","translation":"অন্তরগুলোর তাদের","audioUrl":"wbw/008_063_003.mp3","charTypeName":"word"},{"id":56097,"position":4,"arabic":"لَوْ","translation":"যদি","audioUrl":"wbw/008_063_005.mp3","charTypeName":"word"},{"id":56098,"position":5,"arabic":"أَنفَقْتَ","translation":"তুমি ব্যয় করতে","audioUrl":"wbw/008_063_006.mp3","charTypeName":"word"},{"id":56099,"position":6,"arabic":"مَا","translation":"যা কিছু","audioUrl":"wbw/008_063_007.mp3","charTypeName":"word"},{"id":56100,"position":7,"arabic":"فِى","translation":"মধ্যে (আছে)","audioUrl":"wbw/008_063_008.mp3","charTypeName":"word"},{"id":56101,"position":8,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/008_063_009.mp3","charTypeName":"word"},{"id":56102,"position":9,"arabic":"جَمِيعًۭا","translation":"সব কিছুই","audioUrl":"wbw/008_063_010.mp3","charTypeName":"word"},{"id":56103,"position":10,"arabic":"مَّآ","translation":"(তবুও) না","audioUrl":"wbw/008_063_011.mp3","charTypeName":"word"},{"id":56104,"position":11,"arabic":"أَلَّفْتَ","translation":"ত