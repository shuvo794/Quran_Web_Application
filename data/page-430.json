{"id":430,"ayahs":[{"number":15,"arabic":"لَقَدْ كَانَ لِسَبَإٍۢ فِى مَسْكَنِهِمْ ءَايَةٌۭ ۖ جَنَّتَانِ عَن يَمِينٍۢ وَشِمَالٍۢ ۖ كُلُوا۟ مِن رِّزْقِ رَبِّكُمْ وَٱشْكُرُوا۟ لَهُۥ ۚ بَلْدَةٌۭ طَيِّبَةٌۭ وَرَبٌّ غَفُورٌۭ","translation":"INDEED, in [the luxuriant beauty of] their homeland, the people of Sheba had an evidence [of God’s grace] two [vast expanses of] gardens, to the right and to the left, [calling out to them, as it were:] “Eat of what your Sustainer has provided for you, and render thanks unto Him: a land most goodly, and a Sustainer much-forgiving!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3621.mp3","surahId":34,"words":[{"id":17849,"position":1,"arabic":"لَقَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/034_015_001.mp3","charTypeName":"word"},{"id":17850,"position":2,"arabic":"كَانَ","translation":"ছিলো","audioUrl":"wbw/034_015_002.mp3","charTypeName":"word"},{"id":17851,"position":3,"arabic":"لِسَبَإٍۢ","translation":"জন্যে সাবা (জাতির)","audioUrl":"wbw/034_015_003.mp3","charTypeName":"word"},{"id":17852,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/034_015_004.mp3","charTypeName":"word"},{"id":17853,"position":5,"arabic":"مَسْكَنِهِمْ","translation":"বাসভূমির তাদের","audioUrl":"wbw/034_015_005.mp3","charTypeName":"word"},{"id":17854,"position":6,"arabic":"ءَايَةٌۭ ۖ","translation":"একটি নিদর্শন","audioUrl":"wbw/034_015_006.mp3","charTypeName":"word"},{"id":17856,"position":7,"arabic":"جَنَّتَانِ","translation":"দু'টি বাগান","audioUrl":"wbw/034_015_008.mp3","charTypeName":"word"},{"id":17857,"position":8,"arabic":"عَن","translation":"থেকে","audioUrl":"wbw/034_015_009.mp3","charTypeName":"word"},{"id":17858,"position":9,"arabic":"يَمِينٍۢ","translation":"ডানদিক","audioUrl":"wbw/034_015_010.mp3","charTypeName":"word"},{"id":17859,"position":10,"arabic":"وَشِمَالٍۢ ۖ","translation":"ও বামদিকে","audioUrl":"wbw/034_015_011.mp3","charTypeName":"word"},{"id":17861,"position":11,"arabic":"كُلُوا۟","translation":"\"(ব