1.mp3","charTypeName":"word"},{"id":18899,"position":2,"arabic":"فَأَرْسَلْنَا","translation":"তাই পাঠালাম আমরা","audioUrl":"wbw/034_016_002.mp3","charTypeName":"word"},{"id":18900,"position":3,"arabic":"عَلَيْهِمْ","translation":"উপর তাদের","audioUrl":"wbw/034_016_003.mp3","charTypeName":"word"},{"id":18901,"position":4,"arabic":"سَيْلَ","translation":"বন্যা","audioUrl":"wbw/034_016_004.mp3","charTypeName":"word"},{"id":18902,"position":5,"arabic":"ٱلْعَرِمِ","translation":"বাঁধ-ভাঙ্গা","audioUrl":"wbw/034_016_005.mp3","charTypeName":"word"},{"id":18903,"position":6,"arabic":"وَبَدَّلْنَـٰهُم","translation":"এবং আমরা পাল্টে দিলাম তাদের","audioUrl":"wbw/034_016_006.mp3","charTypeName":"word"},{"id":18904,"position":7,"arabic":"بِجَنَّتَيْهِمْ","translation":"বিনিময়ে দু'টি বাগানের তাদের","audioUrl":"wbw/034_016_007.mp3","charTypeName":"word"},{"id":18905,"position":8,"arabic":"جَنَّتَيْنِ","translation":"দু'টি বাগান","audioUrl":"wbw/034_016_008.mp3","charTypeName":"word"},{"id":18906,"position":9,"arabic":"ذَوَاتَىْ","translation":"সম্পন্ন","audioUrl":"wbw/034_016_009.mp3","charTypeName":"word"},{"id":18907,"position":10,"arabic":"أُكُلٍ","translation":"ফল-মূল","audioUrl":"wbw/034_016_010.mp3","charTypeName":"word"},{"id":18908,"position":11,"arabic":"خَمْطٍۢ","translation":"বিস্বাদ","audioUrl":"wbw/034_016_011.mp3","charTypeName":"word"},{"id":18909,"position":12,"arabic":"وَأَثْلٍۢ","translation":"এবং ঝাউগাছ","audioUrl":"wbw/034_016_012.mp3","charTypeName":"word"},{"id":18910,"position":13,"arabic":"وَشَىْءٍۢ","translation":"ও কিছু","audioUrl":"wbw/034_016_013.mp3","charTypeName":"word"},{"id":18911,"position":14,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/034_016_014.mp3","charTypeName":"word"},{"id":18912,"position":15,"arabic":"سِدْرٍۢ","translation":"কুলগাছ","audioUrl":"wbw/034_016_015.mp3","charTypeName":"word"},{"id":18913,"position":16,"arabic":"قَلِيلٍۢ","translation":"সামান্য","audioUrl":"wbw/034_016_016.mp3","charTypeName":"word"},{"id":18914,"position":17,"arabic":"١٦","translation":"(১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":17,"arabic":"ذَٰلِكَ جَزَيْنَٰهُم بِمَا كَفَرُوا۟ ۖ وَهَلْ نُجَٰزِىٓ إِلَّا ٱلْكَفُورَ","translation":"thus We requited them for their having denied the truth. But do We ever requite [thus] any but the utterly ingrate?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3623.mp3","surahId":34,"words":[{"id":20015,"position":1,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/034_017_001.mp3","charTypeName":"word"},{"id":20016,"position":2,"arabic":"جَزَيْنَـٰهُم","translation":"আমরা প্রতিফল দিই তাদের","audioUrl":"wbw/034_017_002.mp3","charTypeName":"word"},{"id":20017,"position":3,"arabic":"بِمَا","translation":"এ কারণ","audioUrl":"wbw/034_017_003.mp3","charTypeName":"word"},{"id":20018,"position":4,"arabic":"كَفَرُوا۟ ۖ","translation":"তারা অবিশ্বাস করেছিলো","audioUrl":"wbw/034_017_004.mp3","charTypeName":"word"},{"id":20020,"position":5,"arabic":"وَهَلْ","translation":"এবং না","audioUrl":"wbw/034_017_006.mp3","charTypeName":"word"},{"id":20021,"position":6,"arabic":"نُجَـٰزِىٓ","translation":"আমরা দেই (এমন) প্রতিফল","audioUrl":"wbw/034_017_007.mp3","charTypeName":"word"},{"id":20022,"position":7,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/034_017_008.mp3","charTypeName":"word"},{"id":20023,"position":8,"arabic":"ٱلْكَفُورَ","translation":"অকৃতজ্ঞকে","audioUrl":"wbw/034_017_009.mp3","charTypeName":"word"},{"id":20024,"position":9,"arabic":"١٧","translation":"(১৭)","audioUrl":null,"charTypeName":"end"}]},{"number":18,"arabic":"وَجَعَلْنَا بَيْنَهُمْ وَبَيْنَ ٱلْقُرَى ٱلَّتِى بَٰرَكْنَا فِيهَا قُرًۭى ظَٰهِرَةًۭ وَقَدَّرْنَا فِيهَا ٱلسَّيْرَ ۖ سِيرُوا۟ فِيهَا لَيَالِىَ وَأَيَّامًا ءَامِنِينَ","translation":"Now [before their downfall,] We had placed between them and the cities which We had blessed [many] towns within sight of one another; and thus We had made traveling easy [for them, as if to say]: “Travel safely in this [land], by night or by day!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3624.mp3","surahId":34,"words":[{"id":21042,"position":1,"arabic":"وَجَعَلْنَا","translation":"এবং স্থাপন করেছিলাম আমরা","audioUrl":"wbw/034_018_001.mp3","charTypeName":"word"},{"id":21043,"position":2,"arabic":"بَيْنَهُمْ","translation":"মাঝে তাদের","audioUrl":"wbw/034_018_002.mp3","charTypeName":"word"},{"id":21044,"position":3,"arabic":"وَبَيْنَ","translation":"ও মাঝে","audioUrl":"wbw/034_018_003.mp3","charTypeName":"word"},{"id":21045,"position":4,"arabic":"ٱلْقُرَى","translation":"জনবসতিগুলোর","audioUrl":"wbw/034_018_004.mp3","charTypeName":"word"},{"id":21046,"position":5,"arabic":"ٱلَّتِى","translation":"যাতে","audioUrl":"wbw/034_018_005.mp3","charTypeName":"word"},{"id":21047,"position":6,"arabic":"بَـٰرَكْنَا","translation":"কল্যাণ দিয়েছিলাম আমরা","audioUrl":"wbw/034_018_006.mp3","charTypeName":"word"},{"id":21048,"position":7,"arabic":"فِيهَا","translation":"মধ্যে তার","audioUrl":"wbw/034_018_007.mp3","charTypeName":"word"},{"id":21049,"position":8,"arabic":"قُرًۭى","translation":"(বহু) জনপদ","audioUrl":"wbw/034_018_008.mp3","charTypeName":"word"},{"id":21050,"position":9,"arabic":"ظَـٰهِرَةًۭ","translation":"দৃশ্যমান","audioUrl":"wbw/034_018_009.mp3","charTypeName":"word"},{"id":21051,"position":10,"arabic":"وَقَدَّرْنَا","translation":"এবং পরিমাণ মতো রেখেছিলাম আমরা","audioUrl":"wbw/034_018_010.mp3","charTypeName":"word"},{"id":21052,"position":11,"arabic":"فِيهَا","translation":"মধ্যে তার","audioUrl":"wbw/034_018_011.mp3","charTypeName":"word"},{"id":21053,"position":12,"arabic":"ٱلسَّيْرَ ۖ","translation":"সফরের (দুরত্ব)","audioUrl":"wbw/034_018_012.mp3","charTypeName":"word"},{"id":21055,"position":13,"arabic":"سِيرُوا۟","translation":"\"(বলেছিলাম) তোমরা ভ্রমণ করো","audioUrl":"wbw/034_018_014.mp3","charTypeName":"word"},{"id":21056,"position":14,"arabic":"فِيهَا","translation":"মধ্যে তার","audioUrl":"wbw/034_018_015.mp3","charTypeName":"word"},{"id":21057,"position":15,"arabic":"لَيَالِىَ","translation":"রাতগুলোতে","audioUrl":"wbw/034_018_016.mp3","charTypeName":"word"},{"id":21058,"position":16,"arabic":"وَأَيَّامًا","translation":"ও দিনগুলোতে","audioUrl":"wbw/034_018_017.mp3","charTypeName":"word"},{"id":21059,"position":17,"arabic":"ءَامِنِينَ","translation":"নিরাপদে\"","audioUrl":"wbw/034_018_018.mp3","charTypeName":"word"},{"id":21060,"position":18,"arabic":"١٨","translation":"(১৮)","audioUrl":null,"charTypeName":"end"}]},{"number":19,"arabic":"فَقَالُوا۟ رَبَّنَا بَٰعِدْ بَيْنَ أَسْفَارِنَا وَظَلَمُوٓا۟ أَنفُسَهُمْ فَجَعَلْنَٰهُمْ أَحَادِيثَ وَمَزَّقْنَٰهُمْ كُلَّ مُمَزَّقٍ ۚ إِنَّ فِى ذَٰلِكَ لَءَايَٰتٍۢ لِّكُلِّ صَبَّارٍۢ شَكُورٍۢ","translation":"But now they would say, “Long has our Sus­tainer made the distance between our journey- stages!” - for they had sinned against themselves. And in the end We caused them to become [one of those] tales [of things long past], and scattered them in countless fragments. Herein, behold, there are messages indeed for all who are wholly patient in adversity and deeply grate­ful [to God].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3625.mp3","surahId":34,"words":[{"id":22193,"position":1,"arabic":"فَقَالُوا۟","translation":"কিন্তু তারা বলেছিলো","audioUrl":"wbw/034_019_001.mp3","charTypeName":"word"},{"id":22194,"position":2,"arabic":"رَبَّنَا","translation":"\"হে আমাদের রব","audioUrl":"wbw/034_019_002.mp3","charTypeName":"word"},{"id":22195,"position":3,"arabic":"بَـٰعِدْ","translation":"দূরত্ব বাড়াও","audioUrl":"wbw/034_019_003.mp3","charTypeName":"word"},{"id":22196,"position":4,"arabic":"بَيْنَ","translation":"মাঝে","audioUrl":"wbw/034_019_004.mp3","charTypeName":"word"},{"id":22197,"position":5,"arabic":"أَسْفَارِنَا","translation":"সফরসমূহের আমাদের\"","audioUrl":"wbw/034_019_005.mp3","charTypeName":"word"},{"id":22198,"position":6,"arabic":"وَظَلَمُوٓا۟","translation":"এবং তারা সীমালঙ্ঘন করেছিলো","audioUrl":"wbw/034_019_006.mp3","charTypeName":"word"},{"id":22199,"position":