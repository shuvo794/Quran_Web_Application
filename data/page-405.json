{"id":405,"ayahs":[{"number":6,"arabic":"وَعْدَ ٱللَّهِ ۖ لَا يُخْلِفُ ٱللَّهُ وَعْدَهُۥ وَلَٰكِنَّ أَكْثَرَ ٱلنَّاسِ لَا يَعْلَمُونَ","translation":"[This is] God’s promise. Never does God fail to fulfill His promise - but most people know [it] not:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3415.mp3","surahId":30,"words":[{"id":6892,"position":1,"arabic":"وَعْدَ","translation":"(এটা)প্রতিশ্রুতি","audioUrl":"wbw/030_006_001.mp3","charTypeName":"word"},{"id":6893,"position":2,"arabic":"ٱللَّهِ ۖ","translation":"আল্লাহর","audioUrl":"wbw/030_006_002.mp3","charTypeName":"word"},{"id":6895,"position":3,"arabic":"لَا","translation":"না","audioUrl":"wbw/030_006_004.mp3","charTypeName":"word"},{"id":6896,"position":4,"arabic":"يُخْلِفُ","translation":"ভঙ্গ করেন","audioUrl":"wbw/030_006_005.mp3","charTypeName":"word"},{"id":6897,"position":5,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/030_006_006.mp3","charTypeName":"word"},{"id":6898,"position":6,"arabic":"وَعْدَهُۥ","translation":"প্রতিশ্রুতি তাঁর","audioUrl":"wbw/030_006_007.mp3","charTypeName":"word"},{"id":6899,"position":7,"arabic":"وَلَـٰكِنَّ","translation":"কিন্তু","audioUrl":"wbw/030_006_008.mp3","charTypeName":"word"},{"id":6900,"position":8,"arabic":"أَكْثَرَ","translation":"অধিকাংশ","audioUrl":"wbw/030_006_009.mp3","charTypeName":"word"},{"id":6901,"position":9,"arabic":"ٱلنَّاسِ","translation":"মানুষ","audioUrl":"wbw/030_006_010.mp3","charTypeName":"word"},{"id":6902,"position":10,"arabic":"لَا","translation":"না","audioUrl":"wbw/030_006_011.mp3","charTypeName":"word"},{"id":6903,"position":11,"arabic":"يَعْلَمُونَ","translation":"তারা জানে","audioUrl":"wbw/030_006_012.mp3","charTypeName":"word"},{"id":6904,"position":12,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"يَعْلَمُونَ ظَٰهِرًۭا مِّنَ ٱلْحَيَوٰةِ ٱلدُّنْيَا وَهُمْ عَنِ ٱلْءَاخِرَةِ هُمْ غَٰفِلُونَ","translation":"they know but the outer surface of this world’s life, whereas of the ultimate things they are utterly un­aware.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3416.mp3","surahId":30,"words":[{"id":8222,"position":1,"arabic":"يَعْلَمُونَ","translation":"(কেবল) তারা জানে","audioUrl":"wbw/030_007_001.mp3","charTypeName":"word"},{"id":8223,"position":2,"arabic":"ظَـٰهِرًۭا","translation":"বাহ্যিক দিক","audioUrl":"wbw/030_007_002.mp3","charTypeName":"word"},{"id":8224,"position":3,"arabic":"مِّنَ","translation":"থেকে","audioUrl":"wbw/030_007_003.mp3","charTypeName":"word"},{"id":8225,"position":4,"arabic":"ٱلْحَيَوٰةِ","translation":"জীবনের","audioUrl":"wbw/030_007_004.mp3","charTypeName":"word"},{"id":8226,"position":5,"arabic":"ٱلدُّنْيَا","translation":"পার্থিব","audioUrl":"wbw/030_007_005.mp3","charTypeName":"word"},{"id":8227,"position":6,"arabic":"وَهُمْ","translation":"আর তারা","audioUrl":"wbw/030_007_006.mp3","charTypeName":"word"},{"id":8228,"position":7,"arabic":"عَنِ","translation":"সম্পর্কে","audioUrl":"wbw/030_007_007.mp3","charTypeName":"word"},{"id":8229,"position":8,"arabic":"ٱلْـَٔاخِرَةِ","translation":"আখেরাত","audioUrl":"wbw/030_007_008.mp3","charTypeName":"word"},{"id":8230,"position":9,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/030_007_009.mp3","charTypeName":"word"},{"id":8231,"position":10,"arabic":"غَـٰفِلُونَ","translation":"অমনোযোগী","audioUrl":"wbw/030_007_010.mp3","charTypeName":"word"},{"id":8232,"position":11,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"أَوَلَمْ يَتَفَكَّرُوا۟ فِىٓ أَنفُسِهِم ۗ مَّا خَلَقَ ٱللَّهُ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضَ وَمَا بَيْنَهُمَآ إِلَّا بِٱلْحَقِّ وَأَجَلٍۢ مُّسَمًّۭى ۗ وَإِنَّ كَثِيرًۭا مِّنَ ٱلنَّاسِ بِلِقَآئِ رَبِّهِمْ لَكَٰفِرُونَ","translation":"Have they never learned to think for them­selves? God has not created the heavens and the earth and all that is between them without [an inner] truth and a term set [by Him]: and yet, behold, there are many people who stubbornly deny the truth that they are destined to meet their Sustainer!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3417.mp3","surahId":30,"words":[{"id":9385,"position":1,"arabic":"أَوَلَمْ","translation":"কি না","audioUrl":"wbw/030_008_001.mp3","charTypeName":"word"},{"id":9386,"position":2,"arabic":"يَتَفَكَّرُوا۟","translation":"তারা চিন্তা করে (মনের)","audioUrl":"wbw/030_008_002.mp3","charTypeName":"word"},{"id":9387,"position":3,"arabic":"فِىٓ","translation":"মধ্যে","audioUrl":"wbw/030_008_003.mp3","charTypeName":"word"},{"id":9388,"position":4,"arabic":"أَنفُسِهِم ۗ","translation":"নিজেদের তাদের","audioUrl":"wbw/030_008_004.mp3","charTypeName":"word"},{"id":9390,"position":5,"arabic":"مَّا","translation":"না","audioUrl":"wbw/030_008_006.mp3","charTypeName":"word"},{"id":9391,"position":6,"arabic":"خَلَقَ","translation":"সৃষ্টি করেছেন","audioUrl":"wbw/030_008_007.mp3","charTypeName":"word"},{"id":9392,"position":7,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌","audioUrl":"wbw/030_008_008.mp3","charTypeName":"word"},{"id":9393,"position":8,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশমন্ডলী","audioUrl":"wbw/030_008_009.mp3","charTypeName":"word"},{"id":9394,"position":9,"arabic":"وَٱلْأَرْضَ","translation":"ও পৃথিবী","audioUrl":"wbw/030_008_010.mp3","charTypeName":"word"},{"id":9395,"position":10,"arabic":"وَمَا","translation":"এবং যা (আছে)","audioUrl":"wbw/030_008_011.mp3","charTypeName":"word"},{"id":9396,"position":11,"arabic":"بَيْنَهُمَآ","translation":"দু'য়ের মাঝে তাদের","audioUrl":"wbw/030_008_012.mp3","charTypeName":"word"},{"id":9397,"position":12,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/030_008_013.mp3","charTypeName":"word"},{"id":9398,"position":13,"arabic":"بِٱلْحَقِّ","translation":"ভাবে যথাযথ","audioUrl":"wbw/030_008_014.mp3","charTypeName":"word"},{"id":9399,"position":14,"arabic":"وَأَجَلٍۢ","translation":"এবং একটি কালের (জন্যে)","audioUrl":"wbw/030_008_015.mp3","charTypeName":"word"},{"id":9400,"position":15,"arabic":"مُّسَمًّۭى ۗ","translation":"নির্দিষ্ট","audioUrl":"wbw/030_008_016.mp3","charTypeName":"word"},{"id":9402,"position":16,"arabic":"وَإِنَّ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/030_008_018.mp3","charTypeName":"word"},{"id":9403,"position":17,"arabic":"كَثِيرًۭا","translation":"অধিকাংশ","audioUrl":"wbw/030_008_019.mp3","charTypeName":"word"},{"id":9404,"position":18,"arabic":"مِّنَ","translation":"মধ্যে","audioUrl":"wbw/030_008_020.mp3","charTypeName":"word"},{"id":9405,"position":19,"arabic":"ٱلنَّاسِ","translation":"মানুষের","audioUrl":"wbw/030_008_021.mp3","charTypeName":"word"},{"id":9406,"position":20,"arabic":"بِلِقَآئِ","translation":"সম্পর্কে সাক্ষাৎ","audioUrl":"wbw/030_008_022.mp3","charTypeName":"word"},{"id":9407,"position":21,"arabic":"رَبِّهِمْ","translation":"রবের তাদের","audioUrl":"wbw/030_008_023.mp3","charTypeName":"word"},{"id":9408,"position":22,"arabic":"لَكَـٰفِرُونَ","translation":"অবশ্যই অস্বীকারকারী","audioUrl":"wbw/030_008_024.mp3","charTypeName":"word"},{"id":9409,"position":23,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"أَوَلَمْ يَسِيرُوا۟ فِى ٱلْأَرْضِ فَيَنظُرُوا۟ كَيْفَ كَانَ عَٰقِبَةُ ٱلَّذِينَ مِن قَبْلِهِمْ ۚ كَانُوٓا۟ أَشَدَّ مِنْهُمْ قُوَّةًۭ وَأَثَارُوا۟ ٱلْأَرْضَ وَعَمَرُوهَآ أَكْثَرَ مِمَّا عَمَرُوهَا وَجَآءَتْهُمْ رُسُلُهُم بِٱلْبَيِّنَٰتِ ۖ فَمَا كَانَ ٱللَّهُ لِيَظْلِمَهُمْ وَلَٰكِن كَانُوٓا۟ أَنفُسَهُمْ يَظْلِمُونَ","translation":"Have they, then, never journeyed about the earth and beheld what happened in the end to those [deniers of the truth] who lived before their time? Greater were they in power than they are; and they left a stronger impact on the earth, and built it up even better than these [are doing]; and to them [too] came their apostles with all evidence of the truth: and so, [when they rejected the truth and thereupon perished,] it was not God who wronged them, but it was they who had wronged themselves.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3418.mp3","surahId":30,"words":[{"id":10540,"position":1,"arabic":"أَوَلَمْ","translation":"কি না","audioUrl":"wbw/030_009_001.mp3","charTypeName":"word"},{"id":10541,"position":2,"arabic":"يَسِيرُوا۟","translation":"তারা ভ্রমণ করে","audioUrl":"wbw/030_009_002.mp3","charTypeName":"word"},{"id":10542,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/030_009_003.mp3","charTypeName":"word"},{"id":10543,"position":4,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/030_009_004.mp3","charTypeName":"word"},{"id":10544,"position":5,"arabic":"فَيَنظُرُوا۟","translation":"তাহ'লে তারা দেখতে পেতো","audioUrl":"wbw/030_009_005.mp3","charTypeName":"word"},{"id":10545,"position":6,"arabic":"كَيْفَ","translation":"কেমন","audioUrl":"wbw/030_009_006.mp3","charTypeName":"word"},{"id":10546,"position":7,"arabic":"كَانَ","translation":"ছিলো","audioUrl":"wbw/030_009_007.mp3","charTypeName":"word"},{"id":10547,"position":8,"arabic":"عَـٰقِبَةُ","translation":"পরিণাম","audioUrl":"wbw/030_009_008.mp3","charTypeName":"word"},{"id":10548,"position":9,"arabic":"ٱلَّذِينَ","translation":"(তাদের) যারা","audioUrl":"wbw/030_009_009.mp3","charTypeName":"word"},{"id":10549,"position":10,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/030_009_010.mp3","charTypeName":"word"},{"id":10550,"position":11,"arabic":"قَبْلِهِمْ ۚ","translation":"পূর্ব তাদের (ছিলো)","audioUrl":"wbw/030_009_011.mp3","charTypeName":"word"},{"id":10552,"position":12,"arabic":"كَانُوٓا۟","translation":"তারা ছিলো","audioUrl":"wbw/030_009_013.mp3","charTypeName":"word"},{"id":10553,"position":13,"arabic":"أَشَدَّ","translation":"প্রবলতর","audioUrl":"wbw/030_009_014.mp3","charTypeName":"word"},{"id":10554,"position":14,"arabic":"مِنْهُمْ","translation":"চেয়ে এদের","audioUrl":"wbw/030_009_015.mp3","charTypeName":"word"},{"id":10555,"position":15,"arabic":"قُوَّةًۭ","translation":"শক্তিতে","audioUrl":"wbw/030_009_016.mp3","charTypeName":"word"},{"id":10556,"position":16,"arabic":"وَأَثَارُوا۟","transl