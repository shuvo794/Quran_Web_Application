m God - whereas God will requite all who are grateful [to Him].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/437.mp3","surahId":3,"words":[{"id":79664,"position":1,"arabic":"وَمَا","translation":"এবং নয়","audioUrl":"wbw/003_144_001.mp3","charTypeName":"word"},{"id":79665,"position":2,"arabic":"مُحَمَّدٌ","translation":"মুহাম্মদ (সাঃ)","audioUrl":"wbw/003_144_002.mp3","charTypeName":"word"},{"id":79666,"position":3,"arabic":"إِلَّا","translation":"এছাড়া","audioUrl":"wbw/003_144_003.mp3","charTypeName":"word"},{"id":79667,"position":4,"arabic":"رَسُولٌۭ","translation":"একজন রাসূল","audioUrl":"wbw/003_144_004.mp3","charTypeName":"word"},{"id":79668,"position":5,"arabic":"قَدْ","translation":"নিশ্চয়","audioUrl":"wbw/003_144_005.mp3","charTypeName":"word"},{"id":79669,"position":6,"arabic":"خَلَتْ","translation":"অতীত হয়েছে","audioUrl":"wbw/003_144_006.mp3","charTypeName":"word"},{"id":79670,"position":7,"arabic":"مِن","translation":"(থেকে)","audioUrl":"wbw/003_144_007.mp3","charTypeName":"word"},{"id":79671,"position":8,"arabic":"قَبْلِهِ","translation":"তাঁর পূর্বে","audioUrl":"wbw/003_144_008.mp3","charTypeName":"word"},{"id":79672,"position":9,"arabic":"ٱلرُّسُلُ ۚ","translation":"(অনেক) রাসূল","audioUrl":"wbw/003_144_009.mp3","charTypeName":"word"},{"id":79674,"position":10,"arabic":"أَفَإِي۟ن","translation":"কি তবে যদি","audioUrl":"wbw/003_144_011.mp3","charTypeName":"word"},{"id":79675,"position":11,"arabic":"مَّاتَ","translation":"সে মারা যায়","audioUrl":"wbw/003_144_012.mp3","charTypeName":"word"},{"id":79676,"position":12,"arabic":"أَوْ","translation":"বা","audioUrl":"wbw/003_144_013.mp3","charTypeName":"word"},{"id":79677,"position":13,"arabic":"قُتِلَ","translation":"নিহত হয়","audioUrl":"wbw/003_144_014.mp3","charTypeName":"word"},{"id":79678,"position":14,"arabic":"ٱنقَلَبْتُمْ","translation":"তোমরা ফিরে যাবে","audioUrl":"wbw/003_144_015.mp3","charTypeName":"word"},{"id":79679,"position":15,"arabic":"عَلَىٰٓ","translation":"উপর","audioUrl":"wbw/003_144_016.mp3","charTypeName":"word"},{"id":79680,"position":16,"arabic":"أَعْقَـٰبِكُمْ ۚ","translation":"তোমাদের গোড়ালির (অর্থাৎ পিছন দিকে)","audioUrl":"wbw/003_144_017.mp3","charTypeName":"word"},{"id":79682,"position":17,"arabic":"وَمَن","translation":"আর যে","audioUrl":"wbw/003_144_019.mp3","charTypeName":"word"},{"id":79683,"position":18,"arabic":"يَنقَلِبْ","translation":"ফিরে যাবে","audioUrl":"wbw/003_144_020.mp3","charTypeName":"word"},{"id":79684,"position":19,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/003_144_021.mp3","charTypeName":"word"},{"id":79685,"position":20,"arabic":"عَقِبَيْهِ","translation":"তার দুই গোড়ালির","audioUrl":"wbw/003_144_022.mp3","charTypeName":"word"},{"id":79686,"position":21,"arabic":"فَلَن","translation":"তাহলে কক্ষনো না","audioUrl":"wbw/003_144_023.mp3","charTypeName":"word"},{"id":79687,"position":22,"arabic":"يَضُرَّ","translation":"ক্ষতি করতে পারবে","audioUrl":"wbw/003_144_024.mp3","charTypeName":"word"},{"id":79688,"position":23,"arabic":"ٱللَّهَ","translation":"আল্লাহর","audioUrl":"wbw/003_144_025.mp3","charTypeName":"word"},{"id":79689,"position":24,"arabic":"شَيْـًۭٔا ۗ","translation":"কিছুই","audioUrl":"wbw/003_144_026.mp3","charTypeName":"word"},{"id":79691,"position":25,"arabic":"وَسَيَجْزِى","translation":"এবং প্রতিফল দিবেন","audioUrl":"wbw/003_144_028.mp3","charTypeName":"word"},{"id":79692,"position":26,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/003_144_029.mp3","charTypeName":"word"},{"id":79693,"position":27,"arabic":"ٱلشَّـٰكِرِينَ","translation":"শোকরকারীদেরকে","audioUrl":"wbw/003_144_030.mp3","charTypeName":"word"},{"id":79694,"position":28,"arabic":"١٤٤","translation":"(১৪৪)","audioUrl":null,"charTypeName":"end"}]},{"number":145,"arabic":"وَمَا كَانَ لِنَفْسٍ أَن تَمُوتَ إِلَّا بِإِذْنِ ٱللَّهِ كِتَٰبًۭا مُّؤَجَّلًۭا ۗ وَمَن يُرِدْ ثَوَابَ ٱلدُّنْيَا نُؤْتِهِۦ مِنْهَا وَمَن يُرِدْ ثَوَابَ ٱلْءَاخِرَةِ نُؤْتِهِۦ مِنْهَا ۚ وَسَنَجْزِى ٱلشَّٰكِرِينَ","translation":"And no human being can die save by God's leave, at a term pre-ordained. And if one desires the rewards of this world, We shall grant him thereof; and if one desires the rewards of the life to come, We shall grant him thereof; and We shall requite those who are grateful [to Us].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/438.mp3","surahId":3,"words":[{"id":79892,"position":1,"arabic":"وَمَا","translation":"এবং নয়","audioUrl":"wbw/003_145_001.mp3","charTypeName":"word"},{"id":79893,"position":2,"arabic":"كَانَ","translation":"(সম্ভব)","audioUrl":"wbw/003_145_002.mp3","charTypeName":"word"},{"id":79894,"position":3,"arabic":"لِنَفْسٍ","translation":"জন্য কোন প্রাণীর","audioUrl":"wbw/003_145_003.mp3","charTypeName":"word"},{"id":79895,"position":4,"arabic":"أَن","translation":"যে","audioUrl":"wbw/003_145_004.mp3","charTypeName":"word"},{"id":79896,"position":5,"arabic":"تَمُوتَ","translation":"সে মরবে","audioUrl":"wbw/003_145_005.mp3","charTypeName":"word"},{"id":79897,"position":6,"arabic":"إِلَّا","translation":"এছাড়া","audioUrl":"wbw/003_145_006.mp3","charTypeName":"word"},{"id":79898,"position":7,"arabic":"بِإِذْنِ","translation":"অনুমতিক্রমে","audioUrl":"wbw/003_145_007.mp3","charTypeName":"word"},{"id":79899,"position":8,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/003_145_008.mp3","charTypeName":"word"},{"id":79900,"position":9,"arabic":"كِتَـٰبًۭا","translation":"লিখিত","audioUrl":"wbw/003_145_009.mp3","charTypeName":"word"},{"id":79901,"position":10,"arabic":"مُّؤَجَّلًۭا ۗ","translation":"নির্দিষ্ট সময়","audioUrl":"wbw/003_145_010.mp3","charTypeName":"word"},{"id":79903,"position":11,"arabic":"وَمَن","translation":"এবং যে","audioUrl":"wbw/003_145_012.mp3","charTypeName":"word"},{"id":79904,"position":12,"arabic":"يُرِدْ","translation":"চায়","audioUrl":"wbw/003_145_013.mp3","charTypeName":"word"},{"id":79905,"position":13,"arabic":"ثَوَابَ","translation":"সওয়াব","audioUrl":"wbw/003_145_014.mp3","charTypeName":"word"},{"id":79906,"position":14,"arabic":"ٱلدُّنْيَا","translation":"দুনিয়ার","audioUrl":"wbw/003_145_015.mp3","charTypeName":"word"},{"id":79907,"position":15,"arabic":"نُؤْتِهِۦ","translation":"তাকে দিব আমরা","audioUrl":"wbw/003_145_016.mp3","charTypeName":"word"},{"id":79908,"position":16,"arabic":"مِنْهَا","translation":"তা হতে","audioUrl":"wbw/003_145_017.mp3","charTypeName":"word"},{"id":79909,"position":17,"arabic":"وَمَن","translation":"আর যে","audioUrl":"wbw/003_145_018.mp3","charTypeName":"word"},{"id":79910,"position":18,"arabic":"يُرِدْ","translation":"চায়","audioUrl":"wbw/003_145_019.mp3","charTypeName":"word"},{"id":79911,"position":19,"arabic":"ثَوَابَ","translation":"সওয়াব","audioUrl":"wbw/003_145_020.mp3","charTypeName":"word"},{"id":79912,"position":20,"arabic":"ٱلْـَٔاخِرَةِ","translation":"আখিরাতের","audioUrl":"wbw/003_145_021.mp3","charTypeName":"word"},{"id":79913,"position":21,"arabic":"نُؤْتِهِۦ","translation":"তাকে দিব আমরা","audioUrl":"wbw/003_145_022.mp3","charTypeName":"word"},{"id":79914,"position":22,"arabic":"مِنْهَا ۚ","translation":"তা হতে","audioUrl":"wbw/003_145_023.mp3","charTypeName":"word"},{"id":79916,"position":23,"arabic":"وَسَنَجْزِى","translation":"এবং আমরা শিগগীর প্রতিফল দিব","audioUrl":"wbw/003_145_025.mp3","charTypeName":"word"},{"id":79917,"position":24,"arabic":"ٱلشَّـٰكِرِينَ","translation":"শোকরকারীদেরকে","audioUrl":"wbw/003_145_026.mp3","charTypeName":"word"},{"id":79918,"position":25,"arabic":"١٤٥","translation":"(১৪৫)","audioUrl":null,"charTypeName":"end"}]},{"number":146,"arabic":"وَكَأَيِّن مِّن نَّبِىٍّۢ قَٰتَلَ مَعَهُۥ رِبِّيُّونَ كَثِيرٌۭ فَمَا وَهَنُوا۟ لِمَآ أَصَابَهُمْ فِى سَبِيلِ ٱللَّهِ وَمَا ضَعُفُوا۟ وَمَا ٱسْتَكَانُوا۟ ۗ وَٱللَّهُ يُحِبُّ ٱلصَّٰبِرِينَ","translation":"And how many a prophet has had to fight [in God's cause], followed by many God-devoted men: and they did not become faint of heart for all that they had to suffer in God's cause, and neither did they weaken, nor did they abase themselves [before the enemy], since