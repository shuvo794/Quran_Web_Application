{"id":68,"ayahs":[{"number":141,"arabic":"وَلِيُمَحِّصَ ٱللَّهُ ٱلَّذِينَ ءَامَنُوا۟ وَيَمْحَقَ ٱلْكَٰفِرِينَ","translation":"and that God might render pure of all dross those who have attained to faith, and bring to nought those who deny the truth.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/434.mp3","surahId":3,"words":[{"id":79312,"position":1,"arabic":"وَلِيُمَحِّصَ","translation":"এবং যেন ছেঁটে বাছাই করেন","audioUrl":"wbw/003_141_001.mp3","charTypeName":"word"},{"id":79313,"position":2,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/003_141_002.mp3","charTypeName":"word"},{"id":79314,"position":3,"arabic":"ٱلَّذِينَ","translation":"(তাদেরকে) যারা","audioUrl":"wbw/003_141_003.mp3","charTypeName":"word"},{"id":79315,"position":4,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/003_141_004.mp3","charTypeName":"word"},{"id":79316,"position":5,"arabic":"وَيَمْحَقَ","translation":"এবং চূর্ণ করেন (যেন)","audioUrl":"wbw/003_141_005.mp3","charTypeName":"word"},{"id":79317,"position":6,"arabic":"ٱلْكَـٰفِرِينَ","translation":"কাফিরদেরকে","audioUrl":"wbw/003_141_006.mp3","charTypeName":"word"},{"id":79318,"position":7,"arabic":"١٤١","translation":"(১৪১)","audioUrl":null,"charTypeName":"end"}]},{"number":142,"arabic":"أَمْ حَسِبْتُمْ أَن تَدْخُلُوا۟ ٱلْجَنَّةَ وَلَمَّا يَعْلَمِ ٱللَّهُ ٱلَّذِينَ جَٰهَدُوا۟ مِنكُمْ وَيَعْلَمَ ٱلصَّٰبِرِينَ","translation":"Do you think that you could enter paradise unless God takes cognizance of your having striven hard [in His cause], and takes cognizance of your having been patient in adversity?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/435.mp3","surahId":3,"words":[{"id":79319,"position":1,"arabic":"أَمْ","translation":"কি","audioUrl":"wbw/003_142_001.mp3","charTypeName":"word"},{"id":79320,"position":2,"arabic":"حَسِبْتُمْ","translation":"তোমরা ধারণা করেছ","audioUrl":"wbw/003_142_002.mp3","charTypeName":"word"},{"id":79321,"position":3,"arabic":"أَن","translation":"যে","audioUrl":"wbw/003_142_003.mp3","charTypeName":"word"},{"id":79322,"position":4,"arabic":"تَدْخُلُوا۟","translation":"তোমরা প্রবেশ করবে","audioUrl":"wbw/003_142_004.mp3","charTypeName":"word"},{"id":79323,"position":5,"arabic":"ٱلْجَنَّةَ","translation":"জান্নাতে","audioUrl":"wbw/003_142_005.mp3","charTypeName":"word"},{"id":79324,"position":6,"arabic":"وَلَمَّا","translation":"অথচ (এখনও) না","audioUrl":"wbw/003_142_006.mp3","charTypeName":"word"},{"id":79325,"position":7,"arabic":"يَعْلَمِ","translation":"জেনেছেন (অর্থাৎ বাস্তবে দেখেননি)","audioUrl":"wbw/003_142_007.mp3","charTypeName":"word"},{"id":79326,"position":8,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/003_142_008.mp3","charTypeName":"word"},{"id":79327,"position":9,"arabic":"ٱلَّذِينَ","translation":"(তাদেরকে) যারা","audioUrl":"wbw/003_142_009.mp3","charTypeName":"word"},{"id":79328,"position":10,"arabic":"جَـٰهَدُوا۟","translation":"জিহাদ করেছে","audioUrl":"wbw/003_142_010.mp3","charTypeName":"word"},{"id":79329,"position":11,"arabic":"مِنكُمْ","translation":"তোমাদের মধ্যে","audioUrl":"wbw/003_142_011.mp3","charTypeName":"word"},{"id":79330,"position":12,"arabic":"وَيَعْلَمَ","translation":"এবং তিনি জানেন","audioUrl":"wbw/003_142_012.mp3","charTypeName":"word"},{"id":79331,"position":13,"arabic":"ٱلصَّـٰبِرِينَ","translation":"ধৈর্যশীলদেরকে","audioUrl":"wbw/003_142_013.mp3","charTypeName":"word"},{"id":79332,"position":14,"arabic":"١٤٢","translation":"(১৪২)","audioUrl":null,"charTypeName":"end"}]},{"number":143,"arabic":"وَلَقَدْ كُنتُمْ تَمَنَّوْنَ ٱلْمَوْتَ مِن قَبْلِ أَن تَلْقَوْهُ فَقَدْ رَأَيْتُمُوهُ وَأَنتُمْ تَنظُرُونَ","translation":"For, indeed, you did long for death [in God’s cause] before you came face to face with it; and now you have seen it with your own eyes!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/436.mp3","surahId":3,"words":[{"id":79560,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়","audioUrl":"wbw/003_143_001.mp3","charTypeName":"w