{"id":371,"ayahs":[{"number":84,"arabic":"وَٱجْعَل لِّى لِسَانَ صِدْقٍۢ فِى ٱلْءَاخِرِينَ","translation":"and grant me the power to convey the truth unto those who will come after me,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3016.mp3","surahId":26,"words":[{"id":65939,"position":1,"arabic":"وَٱجْعَل","translation":"এবং দাও","audioUrl":"wbw/026_084_001.mp3","charTypeName":"word"},{"id":65940,"position":2,"arabic":"لِّى","translation":"জন্যে আমার","audioUrl":"wbw/026_084_002.mp3","charTypeName":"word"},{"id":65941,"position":3,"arabic":"لِسَانَ","translation":"জিহবা (খ্যাতি)","audioUrl":"wbw/026_084_003.mp3","charTypeName":"word"},{"id":65942,"position":4,"arabic":"صِدْقٍۢ","translation":"সত্যিকার","audioUrl":"wbw/026_084_004.mp3","charTypeName":"word"},{"id":65943,"position":5,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/026_084_005.mp3","charTypeName":"word"},{"id":65944,"position":6,"arabic":"ٱلْـَٔاخِرِينَ","translation":"পরবর্তীদের","audioUrl":"wbw/026_084_006.mp3","charTypeName":"word"},{"id":65945,"position":7,"arabic":"٨٤","translation":"(৮৪)","audioUrl":null,"charTypeName":"end"}]},{"number":85,"arabic":"وَٱجْعَلْنِى مِن وَرَثَةِ جَنَّةِ ٱلنَّعِيمِ","translation":"and place me among those who shall inherit the garden of bliss!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3017.mp3","surahId":26,"words":[{"id":66304,"position":1,"arabic":"وَٱجْعَلْنِى","translation":"এবং আমাকে করো","audioUrl":"wbw/026_085_001.mp3","charTypeName":"word"},{"id":66305,"position":2,"arabic":"مِن","translation":"অন্তর্ভূক্ত","audioUrl":"wbw/026_085_002.mp3","charTypeName":"word"},{"id":66306,"position":3,"arabic":"وَرَثَةِ","translation":"উত্তরাধিকারীদের","audioUrl":"wbw/026_085_003.mp3","charTypeName":"word"},{"id":66307,"position":4,"arabic":"جَنَّةِ","translation":"জান্নাতের","audioUrl":"wbw/026_085_004.mp3","charTypeName":"word"},{"id":66308,"position":5,"arabic":"ٱلنَّعِيمِ","translation":"সুখকর","audioUrl":"wbw/026_085_005.mp3","charTypeName":"word"},{"id":66309,"position":6,"arabic":"٨٥","translation":"(৮৫)","audioUrl":null,"charTypeName":"end"}]},{"number":86,"arabic":"وَٱغْفِرْ لِأَبِىٓ إِنَّهُۥ كَانَ مِنَ ٱلضَّآلِّينَ","translation":"“And forgive my father - for, verily, he is among those who have gone astray –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3018.mp3","surahId":26,"words":[{"id":66657,"position":1,"arabic":"وَٱغْفِرْ","translation":"এবং ক্ষমা করো","audioUrl":"wbw/026_086_001.mp3","charTypeName":"word"},{"id":66658,"position":2,"arabic":"لِأَبِىٓ","translation":"আমার পিতাকে","audioUrl":"wbw/026_086_002.mp3","charTypeName":"word"},{"id":66659,"position":3,"arabic":"إِنَّهُۥ","translation":"নিশ্চয়ই তিনি","audioUrl":"wbw/026_086_003.mp3","charTypeName":"word"},{"id":66660,"position":4,"arabic":"كَانَ","translation":"ছিলেন","audioUrl":"wbw/026_086_004.mp3","charTypeName":"word"},{"id":66661,"position":5,"arabic":"مِنَ","translation":"অর্ন্তভূক্ত","audioUrl":"wbw/026_086_005.mp3","charTypeName":"word"},{"id":66662,"position":6,"arabic":"ٱلضَّآلِّينَ","translation":"পথভ্রষ্ঠদের","audioUrl":"wbw/026_086_006.mp3","charTypeName":"word"},{"id":66663,"position":7,"arabic":"٨٦","translation":"(৮৬)","audioUrl":null,"charTypeName":"end"}]},{"number":87,"arabic":"وَلَا تُخْزِنِى يَوْمَ يُبْعَثُونَ","translation":"and do not put me to shame on the Day when all shall be raised from the dead:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3019.mp3","surahId":26,"words":[{"id":66823,"position":1,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/026_087_001.mp3","charTypeName":"word"},{"id":66824,"position":2,"arabic":"تُخْزِنِى","translation":"আমাকে লাঞ্চিত করো","audioUrl":"wbw/026_087_002.mp3","charTypeName":"word"},{"id":66825,"position":3,"arabic":"يَوْمَ","translation":"দিনে","audioUrl":"wbw/026_087_003.mp3","charTypeName":"word"},{"id":66826,"position":4,"arabic":"يُبْعَثُونَ","translation":"উত্থানের","audioUrl":"wbw/026_087_004.mp3","charTypeName":"word"},{"id":66827,"position":5,"arabic":"٨٧","translation":"(৮৭)","audioUrl":null,"charTypeName":"end"}]},{"number":88,"arabic":"يَوْمَ لَا يَنفَعُ مَالٌۭ وَلَا بَنُونَ","translation":"the Day on which neither wealth will be of any use, nor children,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3020.mp3","surahId":26,"words":[{"id":67086,"position":1,"arabic":"يَوْمَ","translation":"সেদিন","audioUrl":"wbw/026_088_001.mp3","charTypeName":"word"},{"id":67087,"position":2,"arabic":"لَا","translation":"না","audioUrl":"wbw/026_088_002.mp3","charTypeName":"word"},{"id":67088,"position":3,"arabic":"يَنفَعُ","translation":"উপকারে আসবে","audioUrl":"wbw/026_088_003.mp3","charTypeName":"word"},{"id":67089,"position":4,"arabic":"مَالٌۭ","translation":"ধন-সম্পদ","audioUrl":"wbw/026_088_004.mp3","charTypeName":"word"},{"id":67090,"position":5,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/026_088_005.mp3","charTypeName":"word"},{"id":67091,"position":6,"arabic":"بَنُونَ","translation":"সন্তান-সন্ততি","audioUrl":"wbw/026_088_006.mp3","charTypeName":"word"},{"id":67092,"position":7,"arabic":"٨٨","translation":"(৮৮)","audioUrl":null,"charTypeName":"end"}]},{"number":89,"arabic":"إِلَّا مَنْ أَتَى ٱللَّهَ بِقَلْبٍۢ سَلِيمٍۢ","translation":"[and when] only he [will be happy] who comes before God with a heart free of evil!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3021.mp3","surahId":26,"words":[{"id":67816,"position":1,"arabic":"إِلَّا","translation":"তবে","audioUrl":"wbw/026_089_001.mp3","charTypeName":"word"},{"id":67817,"position":2,"arabic":"مَنْ","translation":"(তাকে) যে","audioUrl":"wbw/026_089_002.mp3","charTypeName":"word"},{"id":67818,"position":3,"arabic":"أَتَى","translation":"আসবে","audioUrl":"wbw/026_089_003.mp3","charTypeName":"word"},{"id":67819,"position":4,"arabic":"ٱللَّهَ","translation":"আল্লাহর নিকট","audioUrl":"wbw/026_089_004.mp3","charTypeName":"word"},{"id":67820,"position":5,"arabic":"بِقَلْبٍۢ","translation":"সহ অন্তর","audioUrl":"wbw/026_089_005.mp3","charTypeName":"word"},{"id":67821,"position":6,"arabic":"سَلِيمٍۢ","translation":"প্রশান্ত (বিশুদ্ধ)\"","audioUrl":"wbw/026_089_006.mp3","charTypeName":"word"},{"id":67822,"position":7,"arabic":"٨٩","translation":"(৮৯)","audioUrl":null,"charTypeName":"end"}]},{"number":90,"arabic":"وَأُزْلِفَتِ ٱلْجَنَّةُ لِلْمُتَّقِينَ","translation":"For, [on that Day,] paradise will be brought within sight of the God-conscious,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3022.mp3","surahId":26,"words":[{"id":68017,"position":1,"arabic":"وَأُزْلِفَتِ","translation":"এবং নিকটে আনা হবে","audioUrl":"wbw/026_090_001.mp3","charTypeName":"word"},{"id":68018,"position":2,"arabic":"ٱلْجَنَّةُ","translation":"জান্নাত","audioUrl":"wbw/026_090_002.mp3","charTypeName":"word"},{"id":68019,"position":3,"arabic":"لِلْمُتَّقِينَ","translation":"জন্যে মুত্তাকীদের","audioUrl":"wbw/026_090_003.mp3","charTypeName":"word"},{"id":68020,"position":4,"arabic":"٩٠","translation":"(৯০)","audioUrl":null,"charTypeName":"end"}]},{"number":91,"arabic":"وَبُرِّزَتِ ٱلْجَحِيمُ لِلْغَاوِينَ","translation":"whereas the blazing fire will be laid open before those who had been lost in grievous error;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3023.mp3","surahId":26,"words":[{"id":68480,"position":1,"arabic":"وَبُرِّزَتِ","translation":"এবং খোলা হবে","audioUrl":"wbw/026_091_001.mp3","charTypeName":"word"},{"id":68481,"position":2,"arabic":"ٱلْجَحِيمُ","translation":"জাহান্নাম","audioUrl":"wbw/026_091_002.mp3","charTypeName":"word"},{"id":68482,"position":3,"arabic":"لِلْغَاوِينَ","translation":"জন্যে বিভ্রান্ত লোকদের","audioUrl":"wbw/026_091_003.mp3","charTypeName":"word"},{"id":68483,"position":4,"arabic":"٩١","translation":"(৯১)","audioUrl":null,"charTypeName":"end"}]},{"number":92,"arabic":"وَقِيلَ لَهُمْ أَيْنَ مَا كُنتُمْ تَعْبُدُونَ","translation":"and they will be asked: “Where now is all that you were wont to worship","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3024.mp3","surahId":26,"words":[{"id":68606,"position":1,"arabic":"وَقِيلَ","translation":"এবং বলা হবে","audioUrl":"wbw/026_092_001.mp3","charTypeName":"word"},{"id":68607,"position":2,"arabic":"لَهُمْ","translation":"উদ্দেশ্যে তাদের","audioUrl":"wbw/026_092_002.mp3","charTypeName":"word"},{"id":68608,"position":3,"arabic":"أَيْنَ","translation":"\"কোথায়","audioUrl":"wbw/026_092_003.mp3","charTypeName":"word"},{"id":68609,"position":4,"arabic":"مَا","translation":"যা","audioUrl":"wbw/026_092_004.mp3","charTypeName":"word"},{"id":68610,"position":5,"arabic":"كُنتُمْ","translation":"তোমরা ছিলে","audioUrl":"wbw/026_092_005.mp3","charTypeName":"word"},{"id":68611,"position":6,"arabic":"تَعْبُدُونَ","translation":"তোমরা উপাসনা করো","audioUrl":"wbw/026_092_006.mp3","charTypeName":"word"},{"id":68612,"position":7,"arabic":"٩٢","translation":"(৯২)","audioUrl":null,"charTypeName":"end"}]},{"number":93,"arabic":"مِن دُونِ ٱللَّهِ هَلْ يَنصُرُونَكُمْ أَوْ يَنتَصِرُونَ","translation":"instead of God? Can these [things and beings] be of any help to you or to themselves?”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3025.mp3","surahId":26,"words":[{"id":69273,"position":1,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/026_093_001.mp3","charTypeName":"word"},{"id":69274,"position":2,"arabic":"دُونِ","translation":"পরিবর্তে","audioUrl":"wbw/026_093_002.mp3","charTypeName":"word"},{"id":69275,"position":3,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/026_093_003.mp3","charTypeName":"word"},{"id":69276,"position":4,"arabic":"هَلْ","translation":"কি","audioUrl":"wbw/026_093_004.mp3","charTypeName":"word"},{"id":69277,"position":5,"arabic":"يَنصُرُونَكُمْ","translation":"তারা সাহায্য করতে পারে তোমাদেরকে","audioUrl":"wbw/026_093_005.mp3","charTypeName":"word"},{"id":69278,"position":6,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/026_093_006.mp3","charTypeName":"word"},{"id":69279,"position":7,"arabic":"يَنتَصِرُونَ","translation":"আত্মরক্ষা করতে পারে (কি)\"","audioUrl":"wbw/026_093_007.mp3","charTypeName":"word"},{"id":69280,"position":8,"arabic":"٩٣","translation":"(৯৩)","audioUrl":null,"charTypeName":"end"}]},{"number":94,"arabic":"فَكُبْكِبُوا۟ فِيهَا هُمْ وَٱلْغَاوُۥنَ","translation":"Thereupon they will be hurled into hell – they, as well as all [others] who had been lost in grievous error,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3026.mp3","surahId":26,"words":[{"id":69617,"position":1,"arabic":"فَكُبْكِبُوا۟","translation":"অতঃপর মুখ নিচু করে ফেলা হবে তাদেরকে","audioUrl":"wbw/026_094_001.mp3","charTypeName":"word"},{"id":69618,"position":2,"arabic":"فِيهَا","translation":"মধ্যে তার","audioUrl":"wbw/026_094_002.mp3","charTypeName":"word"},{"id":69619,"position":3,"arabic":"هُمْ","translation":"তাদেরকে","audioUrl":"wbw/026_094_003.mp3","charTypeName":"word"},{"id":69620,"position":4,"arabic":"وَٱلْغَاوُۥنَ","translation":"ও বিভ্রান্তদেরকে","audioUrl":"wbw/026_094_004.mp3","charTypeName":"word"},{"id":69621,"position":5,"arabic":"٩٤","translation":"(৯৪)","audioUrl":null,"charTypeName":"end"}]},{"number":95,"arabic":"وَجُنُودُ إِبْلِيسَ أَجْمَعُونَ","translation":"and the hosts of Iblis - all together.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3027.mp3","surahId":26,"words":[{"id":69954,"position":1,"arabic":"وَجُنُودُ","translation":"ও সৈন্যসামন্তদেরকে","audioUrl":"wbw/026_095_001.mp3","charTypeName":"word"},{"id":69955,"position":2,"arabic":"إِبْلِيسَ","translation":"ইবলীসের","audioUrl":"wbw/026_095_002.mp3","charTypeName":"word"},{"id":69956,"position":3,"arabic":"أَجْمَعُونَ","translation":"সবাইকে","audioUrl":"wbw/026_095_003.mp3","charTypeName":"word"},{"id":69957,"position":4,"arabic":"٩٥","translation":"(৯৫)","audioUrl":null,"charTypeName":"end"}]},{"number":96,"arabic":"قَالُوا۟ وَهُمْ فِيهَا يَخْتَصِمُونَ","translation":"And there and then, blaming one another, they [who had grievously sinned in life] will exclaim:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3028.mp3","surahId":26,"words":[{"id":70054,"position":1,"arabic":"قَالُوا۟","translation":"তারা বলবে","audioUrl":"wbw/026_096_001.mp3","charTypeName":"word"},{"id":70055,"position":2,"arabic":"وَهُمْ","translation":"এমতাবস্হায় যে তারা","audioUrl":"wbw/026_096_002.mp3","charTypeName":"word"},{"id":70056,"position":3,"arabic":"فِيهَا","translation":"মধ্যে তার","audioUrl":"wbw/026_096_003.mp3","charTypeName":"word"},{"id":70057,"position":4,"arabic":"يَخْتَصِمُونَ","translation":"ঝগড়া করতে থাকবে","audioUrl":"wbw/026_096_004.mp3","charTypeName":"word"},{"id":70058,"position":5,"arabic":"٩٦","translation":"(৯৬)","audioUrl":null,"charTypeName":"end"}]},{"number":97,"arabic":"تَٱللَّهِ إِن كُنَّا لَفِى ضَلَٰلٍۢ مُّبِينٍ","translation":"“By God, we were most obviously astray","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3029.mp3","surahId":26,"words":[{"id":70275,"position":1,"arabic":"تَٱللَّهِ","translation":"\"শপথ আল্লাহর","audioUrl":"wbw/026_097_001.mp3","charTypeName":"word"},{"id":70276,"position":2,"arabic":"إِن","translation":"নিশ্চয়ই","audioUrl":"wbw/026_097_002.mp3","charTypeName":"word"},{"id":70277,"position":3,"arabic":"كُنَّا","translation":"আমরা ছিলাম","audioUrl":"wbw/026_097_003.mp3","charTypeName":"word"},{"id":70278,"position":4,"arabic":"لَفِى","translation":"অবশ্যই মধ্যে","audioUrl":"wbw/026_097_004.mp3","charTypeName":"word"},{"id":70279,"position":5,"arabic":"ضَلَـٰلٍۢ","translation":"বিভ্রান্তির","audioUrl":"wbw/026_097_005.mp3","charTypeName":"word"},{"id":70280,"position":6,"arabic":"مُّبِينٍ","translation":"সুস্পষ্ট","audioUrl":"wbw/026_097_006.mp3","charTypeName":"word"},{"id":70281,"position":7,"arabic":"٩٧","translation":"(৯৭)","audioUrl":null,"charTypeName":"end"}]},{"number":98,"arabic":"إِذْ نُسَوِّيكُم بِرَبِّ ٱلْعَٰلَمِينَ","translation":"when we deemed you [false deities] equal to the Sustainer of all the worlds –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3030.mp3","surahId":26,"words":[{"id":70720,"position":1,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/026_098_001.mp3","charTypeName":"word"},{"id":70721,"position":2,"arabic":"نُسَوِّيكُم","translation":"সমকক্ষ মনে করতাম আমরা তোমাদেরকে","audioUrl":"wbw/026_098_002.mp3","charTypeName":"word"},{"id":70722,"position":3,"arabic":"بِرَبِّ","translation":"সাথে রবের","audioUrl":"wbw/026_098_003.mp3","charTypeName":"word"},{"id":70723,"position":4,"arabic":"ٱلْعَـٰلَمِينَ","translation":"বিশ্বজগতের","audioUrl":"wbw/026_098_004.mp3","charTypeName":"word"},{"id":70724,"position":5,"arabic":"٩٨","translation":"(৯৮)","audioUrl":null,"charTypeName":"end"}]},{"number":99,"arabic":"وَمَآ أَضَلَّنَآ إِلَّا ٱلْمُجْرِمُونَ","translation":"yet they who have seduced us [into believing in you] are the truly guilty ones!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3031.mp3","surahId":26,"words":[{"id":70976,"position":1,"arabic":"وَمَآ","translation":"এবং না","audioUrl":"wbw/026_099_001.mp3","charTypeName":"word"},{"id":70977,"position":2,"arabic":"أَضَلَّنَآ","translation":"পথ ভ্রষ্ট করেছে আমাদেরকে","audioUrl":"wbw/026_099_002.mp3","charTypeName":"word"},{"id":70978,"position":3,"arabic":"إِلَّا","translation":"(অন্য কেউ) এ ছাড়া","audioUrl":"wbw/026_099_003.mp3","charTypeName":"word"},{"id":70979,"position":4,"arabic":"ٱلْمُجْرِمُونَ","translation":"অপরাধীরা","audioUrl":"wbw/026_099_004.mp3","charTypeName":"word"},{"id":70980,"position":5,"arabic":"٩٩","translation":"(৯৯)","audioUrl":null,"charTypeName":"end"}]},{"number":100,"arabic":"فَمَا لَنَا مِن شَٰفِعِينَ","translation":"And now we have none to intercede for us,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3032.mp3","surahId":26,"words":[{"id":71216,"position":1,"arabic":"فَمَا","translation":"সুতরাং (আজ) নেই","audioUrl":"wbw/026_100_001.mp3","charTypeName":"word"},{"id":71217,"position":2,"arabic":"لَنَا",