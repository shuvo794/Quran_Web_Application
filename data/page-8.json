,"audioUrl":null,"charTypeName":"end"}]},{"number":55,"arabic":"وَإِذْ قُلْتُمْ يَٰمُوسَىٰ لَن نُّؤْمِنَ لَكَ حَتَّىٰ نَرَى ٱللَّهَ جَهْرَةًۭ فَأَخَذَتْكُمُ ٱلصَّٰعِقَةُ وَأَنتُمْ تَنظُرُونَ","translation":"And [remember] when you said, \"O Moses. indeed we shall not believe thee unto we see God face to face!\" - whereupon the thunderbolt of punishment overtook you before your very eyes.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/62.mp3","surahId":2,"words":[{"id":52044,"position":1,"arabic":"وَإِذْ","translation":"এবং স্মরণ কর যখন","audioUrl":"wbw/002_055_001.mp3","charTypeName":"word"},{"id":52045,"position":2,"arabic":"قُلْتُمْ","translation":"তোমরা বলেছিলে","audioUrl":"wbw/002_055_002.mp3","charTypeName":"word"},{"id":52046,"position":3,"arabic":"يَـٰمُوسَىٰ","translation":"''হে মুসা","audioUrl":"wbw/002_055_003.mp3","charTypeName":"word"},{"id":52047,"position":4,"arabic":"لَن","translation":"কখনও","audioUrl":"wbw/002_055_004.mp3","charTypeName":"word"},{"id":52048,"position":5,"arabic":"نُّؤْمِنَ","translation":"আমরা ঈমান আনব","audioUrl":"wbw/002_055_005.mp3","charTypeName":"word"},{"id":52049,"position":6,"arabic":"لَكَ","translation":"তোমার উপর","audioUrl":"wbw/002_055_006.mp3","charTypeName":"word"},{"id":52050,"position":7,"arabic":"حَتَّىٰ","translation":"যতক্ষণ না","audioUrl":"wbw/002_055_007.mp3","charTypeName":"word"},{"id":52051,"position":8,"arabic":"نَرَى","translation":"আমরা দেখব","audioUrl":"wbw/002_055_008.mp3","charTypeName":"word"},{"id":52052,"position":9,"arabic":"ٱللَّهَ","translation":"আল্লাহকে","audioUrl":"wbw/002_055_009.mp3","charTypeName":"word"},{"id":52053,"position":10,"arabic":"جَهْرَةًۭ","translation":"প্রকাশ্যভাবে''","audioUrl":"wbw/002_055_010.mp3","charTypeName":"word"},{"id":52054,"position":11,"arabic":"فَأَخَذَتْكُمُ","translation":"ফলে তোমাদেরকে ধরেছিল","audioUrl":"wbw/002_055_011.mp3","charTypeName":"word"},{"id":52055,"position":12,"arabic":"ٱلصَّـٰعِقَةُ","translation":"বজ্রপাত","audioUrl":"wbw/002_055_012.mp3","charTypeName":"word"},{"id":52056,"position":13,"arabic":"وَأَنتُمْ","translation":"এ অবস্থায় যে তোমরা","audioUrl":"wbw/002_055_013.mp3","charTypeName":"word"},{"id":52057,"position":14,"arabic":"تَنظُرُونَ","translation":"দেখছিলে","audioUrl":"wbw/002_055_014.mp3","charTypeName":"word"},{"id":52058,"position":15,"arabic":"٥٥","translation":"(৫৫)","audioUrl":null,"charTypeName":"end"}]},{"number":56,"arabic":"ثُمَّ بَعَثْنَٰكُم مِّنۢ بَعْدِ مَوْتِكُمْ لَعَلَّكُمْ تَشْكُرُونَ","translation":"But We raised you again after you had been as dead, so that you might have cause to be grateful.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/63.mp3","surahId":2,"words":[{"id":52059,"position":1,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/002_056_001.mp3","charTypeName":"word"},{"id":52060,"position":2,"arabic":"بَعَثْنَـٰكُم","translation":"তোমাদের আমরা আবার জীবিত করলাম","audioUrl":"wbw/002_056_002.mp3","charTypeName":"word"},{"id":52061,"position":3,"arabic":"مِّنۢ","translation":"(থেকে)","audioUrl":"wbw/002_056_003.mp3","charTypeName":"word"},{"id":52062,"position":4,"arabic":"بَعْدِ","translation":"পরে","audioUrl":"wbw/002_056_004.mp3","charTypeName":"word"},{"id":52063,"position":5,"arabic":"مَوْتِكُمْ","translation":"তোমাদের মৃত্যুর","audioUrl":"wbw/002_056_005.mp3","charTypeName":"word"},{"id":52064,"position":6,"arabic":"لَعَلَّكُمْ","translation":"যেন তোমরা","audioUrl":"wbw/002_056_006.mp3","charTypeName":"word"},{"id":52065,"position":7,"arabic":"تَشْكُرُونَ","translation":"কৃতজ্ঞতা প্রকাশ কর","audioUrl":"wbw/002_056_007.mp3","charTypeName":"word"},{"id":52066,"position":8,"arabic":"٥٦","translation":"(৫৬)","audioUrl":null,"charTypeName":"end"}]},{"number":57,"arabic":"وَظَلَّلْنَا عَلَيْكُمُ ٱلْغَمَامَ وَأَنزَلْنَا عَلَيْكُمُ ٱلْمَنَّ وَٱلسَّلْوَىٰ ۖ كُلُوا۟ مِن طَيِّبَٰتِ مَا رَزَقْنَٰكُمْ ۖ وَمَا ظَلَمُونَا وَلَٰكِن كَانُوٓا۟ أَنفُسَهُمْ يَظْلِمُونَ","translation":"And We caused the clouds to comfort you with their shade, and sent down unto you manna and quails. [saying,] \"Partake of the good things which We have provided for you as sustenance.\" And [by all their sinning] they did no harm unto Us-but [only] against their own selves did they sin.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/64.mp3","surahId":2,"words":[{"id":52611,"position":1,"arabic":"وَظَلَّلْنَا","translation":"এবং আমরা ছায়া দিয়েছিলাম","audioUrl":"wbw/002_057_001.mp3","charTypeName":"word"},{"id":52612,"position":2,"arabic":"عَلَيْكُمُ","translation":"তোমাদের উপর","audioUrl":"wbw/002_057_002.mp3","charTypeName":"word"},{"id":52613,"position":3,"arabic":"ٱلْغَمَامَ","translation":"মেঘের","audioUrl":"wbw/002_057_003.mp3","charTypeName":"word"},{"id":52614,"position":4,"arabic":"وَأَنزَلْنَا","translation":"এবং আমরা পাঠিয়েছিলাম","audioUrl":"wbw/002_057_004.mp3","charTypeName":"word"},{"id":52615,"position":5,"arabic":"عَلَيْكُمُ","translation":"তোমাদের কাছে","audioUrl":"wbw/002_057_005.mp3","charTypeName":"word"},{"id":52616,"position":6,"arabic":"ٱلْمَنَّ","translation":"মান্না","audioUrl":"wbw/002_057_006.mp3","charTypeName":"word"},{"id":52617,"position":7,"arabic":"وَٱلسَّلْوَىٰ ۖ","translation":"ও সালওয়া","audioUrl":"wbw/002_057_007.mp3","charTypeName":"word"},{"id":52619,"position":8,"arabic":"كُلُوا۟","translation":"''(বলেছিলাম) তোমরা খাও","audioUrl":"wbw/002_057_009.mp3","charTypeName":"word"},{"id":52620,"position":9,"arabic":"مِن","translation":"হতে","audioUrl":"wbw/002_057_010.mp3","charTypeName":"word"},{"id":52621,"position":10,"arabic":"طَيِّبَـٰتِ","translation":"পবিত্র (খাদ্য)","audioUrl":"wbw/002_057_011.mp3","charTypeName":"word"},{"id":52622,"position":11,"arabic":"مَا","translation":"যা","audioUrl":"wbw/002_057_012.mp3","charTypeName":"word"},{"id":52623,"position":12,"arabic":"رَزَقْنَـٰكُمْ ۖ","translation":"তোমাদেরকে আমরা জীবিকা দিয়েছি''","audioUrl":"wbw/002_057_013.mp3","charTypeName":"word"},{"id":52625,"position":13,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/002_057_015.mp3","charTypeName":"word"},{"id":52626,"position":14,"arabic":"ظَلَمُونَا","translation":"আমাদের (উপর) তারা অবিচার করেছে","audioUrl":"wbw/002_057_016.mp3","charTypeName":"word"},{"id":52627,"position":15,"arabic":"وَلَـٰكِن","translation":"কিন্তু","audioUrl":"wbw/002_057_017.mp3","charTypeName":"word"},{"id":52628,"position":16,"arabic":"كَانُوٓا۟","translation":"তারা ছিল","audioUrl":"wbw/002_057_018.mp3","charTypeName":"word"},{"id":52629,"position":17,"arabic":"أَنفُسَهُمْ","translation":"তাদের নিজেদের (উপর)","audioUrl":"wbw/002_057_019.mp3","charTypeName":"word"},{"id":52630,"position":18,"arabic":"يَظْلِمُونَ","translation":"অবিচার করত","audioUrl":"wbw/002_057_020.mp3","charTypeName":"word"},{"id":52631,"position":19,"arabic":"٥٧","translation":"(৫৭)","audioUrl":null,"charTypeName":"end"}]}]}