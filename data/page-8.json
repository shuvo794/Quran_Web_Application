{"id":8,"ayahs":[{"number":49,"arabic":"وَإِذْ نَجَّيْنَٰكُم مِّنْ ءَالِ فِرْعَوْنَ يَسُومُونَكُمْ سُوٓءَ ٱلْعَذَابِ يُذَبِّحُونَ أَبْنَآءَكُمْ وَيَسْتَحْيُونَ نِسَآءَكُمْ ۚ وَفِى ذَٰلِكُم بَلَآءٌۭ مِّن رَّبِّكُمْ عَظِيمٌۭ","translation":"And [remember the time] when We saved you from Pharaoh's people, who afflicted you with cruel suffering, slaughtering your sons and sparing [only] your women - which was an awesome trial from your Sustainer;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/56.mp3","surahId":2,"words":[{"id":48261,"position":1,"arabic":"وَإِذْ","translation":"এবং (স্মরণ করো) যখন","audioUrl":"wbw/002_049_001.mp3","charTypeName":"word"},{"id":48262,"position":2,"arabic":"نَجَّيْنَـٰكُم","translation":"তোমাদেরকে মুক্তি দিয়েছিলাম","audioUrl":"wbw/002_049_002.mp3","charTypeName":"word"},{"id":48263,"position":3,"arabic":"مِّنْ","translation":"হতে","audioUrl":"wbw/002_049_003.mp3","charTypeName":"word"},{"id":48264,"position":4,"arabic":"ءَالِ","translation":"সম্প্রদায়ের","audioUrl":"wbw/002_049_004.mp3","charTypeName":"word"},{"id":48265,"position":5,"arabic":"فِرْعَوْنَ","translation":"ফিরাউনের","audioUrl":"wbw/002_049_005.mp3","charTypeName":"word"},{"id":48266,"position":6,"arabic":"يَسُومُونَكُمْ","translation":"তোমাদেরকে তারা যন্ত্রণা দিত","audioUrl":"wbw/002_049_006.mp3","charTypeName":"word"},{"id":48267,"position":7,"arabic":"سُوٓءَ","translation":"নিকৃষ্ট","audioUrl":"wbw/002_049_007.mp3","charTypeName":"word"},{"id":48268,"position":8,"arabic":"ٱلْعَذَابِ","translation":"যন্ত্রণা","audioUrl":"wbw/002_049_008.mp3","charTypeName":"word"},{"id":48269,"position":9,"arabic":"يُذَبِّحُونَ","translation":"তারা জবাই করত","audioUrl":"wbw/002_049_009.mp3","charTypeName":"word"},{"id":48270,"position":10,"arabic":"أَبْنَآءَكُمْ","translation":"তোমাদের ছেলে সন্তানদের","audioUrl":"wbw/002_049_010.mp3","charTypeName":"word"},{"id":48271,"position":11,"arabic":"وَيَسْتَحْيُونَ","translation":"এবং জীবিত রাখত","audioUrl":"wbw/002_049_011.mp3","charTypeName":"word"},{"id":48272,"position":12,"arabic":"نِسَآءَكُمْ ۚ","translation":"তোমাদের কন্যা সন্তানদের","audioUrl":"wbw/002_049_012.mp3","charTypeName":"word"},{"id":48274,"position":13,"arabic":"وَفِى","translation":"এবং মধ্যে (ছিল)","audioUrl":"wbw/002_049_014.mp3","charTypeName":"word"},{"id":48275,"position":14,"arabic":"ذَٰلِكُم","translation":"এর","audioUrl":"wbw/002_049_015.mp3","charTypeName":"word"},{"id":48276,"position":15,"arabic":"بَلَآءٌۭ","translation":"পরীক্ষা","audioUrl":"wbw/002_049_016.mp3","charTypeName":"word"},{"id":48277,"position":16,"arabic":"مِّن","translation":"পক্ষ হতে","audioUrl":"wbw/002_049_017.mp3","charTypeName":"word"},{"id":48278,"position":17,"arabic":"رَّبِّكُمْ","translation":"তোমাদের রবের","audioUrl":"wbw/002_049_018.mp3","charTypeName":"word"},{"id":48279,"position":18,"arabic":"عَظِيمٌۭ","translation":"কঠিন","audioUrl":"wbw/002_049_019.mp3","charTypeName":"word"},{"id":48280,"position":19,"arabic":"٤٩","translation":"(৪৯)","audioUrl":null,"charTypeName":"end"}]},{"number":50,"arabic":"وَإِذْ فَرَقْنَا بِكُمُ ٱلْبَحْرَ فَأَنجَيْنَٰكُمْ وَأَغْرَقْنَآ ءَالَ فِرْعَوْنَ وَأَنتُمْ تَنظُرُونَ","translation":"and when We cleft the sea before you, and thus saved you and caused Pharaoh's people to drown before your very eyes;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/57.mp3","surahId":2,"words":[{"id":48527,"position":1,"arabic":"وَإِذْ","translation":"এবং (স্মরণ করো) যখন","audioUrl":"wbw/002_050_001.mp3","charTypeName":"word"},{"id":48528,"position":2,"arabic":"فَرَقْنَا","translation":"আমরা বিভক্ত করেছিলাম","audioUrl":"wbw/002_050_002.mp3","charTypeName":"word"},{"id":48529,"position":3,"arabic":"بِكُمُ","translation":"তোমাদের (জন্যে)","audioUrl":"wbw/002_050_003.mp3","charTypeName":"word"},{"id":48530,"position":4,"arabic":"ٱلْبَحْرَ","translation":"সাগরকে","audioUrl":"wbw/002_050_004.mp3","charTypeName":"word"},{"id":48531,"position":5,"arabic":"فَأَنجَيْنَـٰكُمْ","translation":"এরপর আমরা উদ্ধা