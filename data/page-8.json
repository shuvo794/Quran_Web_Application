453,"position":7,"arabic":"ٱتَّخَذْتُمُ","translation":"তোমরা গ্রহণ করেছিলে","audioUrl":"wbw/002_051_007.mp3","charTypeName":"word"},{"id":49454,"position":8,"arabic":"ٱلْعِجْلَ","translation":"গরুর বাছুরকে (উপাস্যরূপে)","audioUrl":"wbw/002_051_008.mp3","charTypeName":"word"},{"id":49455,"position":9,"arabic":"مِنۢ","translation":"তার","audioUrl":"wbw/002_051_009.mp3","charTypeName":"word"},{"id":49456,"position":10,"arabic":"بَعْدِهِۦ","translation":"পরে","audioUrl":"wbw/002_051_010.mp3","charTypeName":"word"},{"id":49457,"position":11,"arabic":"وَأَنتُمْ","translation":"যখন তোমরা","audioUrl":"wbw/002_051_011.mp3","charTypeName":"word"},{"id":49458,"position":12,"arabic":"ظَـٰلِمُونَ","translation":"সীমালঙ্ঘঙ্কারী (ছিলে)","audioUrl":"wbw/002_051_012.mp3","charTypeName":"word"},{"id":49459,"position":13,"arabic":"٥١","translation":"(৫১)","audioUrl":null,"charTypeName":"end"}]},{"number":52,"arabic":"ثُمَّ عَفَوْنَا عَنكُم مِّنۢ بَعْدِ ذَٰلِكَ لَعَلَّكُمْ تَشْكُرُونَ","translation":"yet, even after that, We blotted out this your sin, so that you might have cause to be grateful.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/59.mp3","surahId":2,"words":[{"id":50252,"position":1,"arabic":"ثُمَّ","translation":"অতঃপর","audioUrl":"wbw/002_052_001.mp3","charTypeName":"word"},{"id":50253,"position":2,"arabic":"عَفَوْنَا","translation":"আমরা ক্ষমা করেছিলাম","audioUrl":"wbw/002_052_002.mp3","charTypeName":"word"},{"id":50254,"position":3,"arabic":"عَنكُم","translation":"তোমাদের প্রতি","audioUrl":"wbw/002_052_003.mp3","charTypeName":"word"},{"id":50255,"position":4,"arabic":"مِّنۢ","translation":"(থেকে)","audioUrl":"wbw/002_052_004.mp3","charTypeName":"word"},{"id":50256,"position":5,"arabic":"بَعْدِ","translation":"পরেও","audioUrl":"wbw/002_052_005.mp3","charTypeName":"word"},{"id":50257,"position":6,"arabic":"ذَٰلِكَ","translation":"এর","audioUrl":"wbw/002_052_006.mp3","charTypeName":"word"},{"id":50258,"position":7,"arabic":"لَعَلَّكُمْ","translation":"যেন তোমরা","audioUrl":"wbw/002_052_007.mp3","charTypeName":"word"},{"id":50259,"position":8,"arabic":"تَشْكُرُونَ","translation":"কৃতজ্ঞতা প্রকাশ কর","audioUrl":"wbw/002_052_008.mp3","charTypeName":"word"},{"id":50260,"position":9,"arabic":"٥٢","translation":"(৫২)","audioUrl":null,"charTypeName":"end"}]},{"number":53,"arabic":"وَإِذْ ءَاتَيْنَا مُوسَى ٱلْكِتَٰبَ وَٱلْفُرْقَانَ لَعَلَّكُمْ تَهْتَدُونَ","translation":"And [remember the time] when We vouchsafed unto Moses the divine writ-and [thus] a standard by which to discern the true from the false -so that you might be guided aright;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/60.mp3","surahId":2,"words":[{"id":50897,"position":1,"arabic":"وَإِذْ","translation":"এবং (স্মরণ করো) যখন","audioUrl":"wbw/002_053_001.mp3","charTypeName":"word"},{"id":50898,"position":2,"arabic":"ءَاتَيْنَا","translation":"আমরা দিয়েছিলাম","audioUrl":"wbw/002_053_002.mp3","charTypeName":"word"},{"id":50899,"position":3,"arabic":"مُوسَى","translation":"মুসাকে","audioUrl":"wbw/002_053_003.mp3","charTypeName":"word"},{"id":50900,"position":4,"arabic":"ٱلْكِتَـٰبَ","translation":"কিতাব","audioUrl":"wbw/002_053_004.mp3","charTypeName":"word"},{"id":50901,"position":5,"arabic":"وَٱلْفُرْقَانَ","translation":"এবং ফুরকান","audioUrl":"wbw/002_053_005.mp3","charTypeName":"word"},{"id":50902,"position":6,"arabic":"لَعَلَّكُمْ","translation":"তোমরা যেন","audioUrl":"wbw/002_053_006.mp3","charTypeName":"word"},{"id":50903,"position":7,"arabic":"تَهْتَدُونَ","translation":"সঠিক পথ প্রাপ্ত হও","audioUrl":"wbw/002_053_007.mp3","charTypeName":"word"},{"id":50904,"position":8,"arabic":"٥٣","translation":"(৫৩)","audioUrl":null,"charTypeName":"end"}]},{"number":54,"arabic":"وَإِذْ قَالَ مُوسَىٰ لِقَوْمِهِۦ يَٰقَوْمِ إِنَّكُمْ ظَلَمْتُمْ أَنفُسَكُم بِٱتِّخَاذِكُمُ ٱلْعِجْلَ فَتُوبُوٓا۟ إِلَىٰ بَارِئِكُمْ فَٱقْتُلُوٓا۟ أَنفُسَكُمْ ذَٰلِكُمْ خَيْرٌۭ لَّكُمْ عِندَ بَارِئِكُمْ فَتَابَ عَلَيْكُمْ ۚ إِنَّهُۥ هُوَ ٱلتَّوَّابُ ٱلرَّحِيمُ","translation":"and when Moses said unto his people: \"O my people! Verily, you have sinned against yourselves by worshipping the calf; turn, then. in repentance to your Maker and mortify yourselves; this will be the best for you in your Maker's sight\". And thereupon He accepted your repentance: for, behold, He alone is the Acceptor of Repentance, the Dispenser of Grace.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/61.mp3","surahId":2,"words":[{"id":51496,"position":1,"arabic":"وَإِذْ","translation":"এবং (স্মরণ করো) যখন","audioUrl":"wbw/002_054_001.mp3","charTypeName":"word"},{"id":51497,"position":2,"arabic":"قَالَ","translation":"বলেছিল","audioUrl":"wbw/002_054_002.mp3","charTypeName":"word"},{"id":51498,"position":3,"arabic":"مُوسَىٰ","translation":"মুসা","audioUrl":"wbw/002_054_003.mp3","charTypeName":"word"},{"id":51499,"position":4,"arabic":"لِقَوْمِهِۦ","translation":"তার জাতির উদ্দ্যেশে","audioUrl":"wbw/002_054_004.mp3","charTypeName":"word"},{"id":51500,"position":5,"arabic":"يَـٰقَوْمِ","translation":"''হে আমার জাতি","audioUrl":"wbw/002_054_005.mp3","charTypeName":"word"},{"id":51501,"position":6,"arabic":"إِنَّكُمْ","translation":"তোমরা নিশ্চয়ই","audioUrl":"wbw/002_054_006.mp3","charTypeName":"word"},{"id":51502,"position":7,"arabic":"ظَلَمْتُمْ","translation":"তোমরা অত্যাচার করেছ","audioUrl":"wbw/002_054_007.mp3","charTypeName":"word"},{"id":51503,"position":8,"arabic":"أَنفُسَكُم","translation":"তোমাদের নিজেদের (উপর)","audioUrl":"wbw/002_054_008.mp3","charTypeName":"word"},{"id":51504,"position":9,"arabic":"بِٱتِّخَاذِكُمُ","translation":"তোমাদের গ্রহণ করার মাধ্যমে","audioUrl":"wbw/002_054_009.mp3","charTypeName":"word"},{"id":51505,"position":10,"arabic":"ٱلْعِجْلَ","translation":"গো বাছুরকে (উপাস্যরূপে)","audioUrl":"wbw/002_054_010.mp3","charTypeName":"word"},{"id":51506,"position":11,"arabic":"فَتُوبُوٓا۟","translation":"সুতরাং তোমরা ফিরে এস","audioUrl":"wbw/002_054_011.mp3","charTypeName":"word"},{"id":51507,"position":12,"arabic":"إِلَىٰ",