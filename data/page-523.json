{"id":523,"ayahs":[{"number":52,"arabic":"كَذَٰلِكَ مَآ أَتَى ٱلَّذِينَ مِن قَبْلِهِم مِّن رَّسُولٍ إِلَّا قَالُوا۟ سَاحِرٌ أَوْ مَجْنُونٌ","translation":"[But] thus it is: never yet came any apostle to those who lived before their time but they said, “A spellbinder [Lit., \"sorcerer\".] [is he], or a madman!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4727.mp3","surahId":51,"words":[{"id":49830,"position":1,"arabic":"كَذَٰلِكَ","translation":"এভাবেই","audioUrl":"wbw/051_052_001.mp3","charTypeName":"word"},{"id":49831,"position":2,"arabic":"مَآ","translation":"না","audioUrl":"wbw/051_052_002.mp3","charTypeName":"word"},{"id":49832,"position":3,"arabic":"أَتَى","translation":"এসেছে","audioUrl":"wbw/051_052_003.mp3","charTypeName":"word"},{"id":49833,"position":4,"arabic":"ٱلَّذِينَ","translation":"(তাদের কাছে) যারা","audioUrl":"wbw/051_052_004.mp3","charTypeName":"word"},{"id":49834,"position":5,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/051_052_005.mp3","charTypeName":"word"},{"id":49835,"position":6,"arabic":"قَبْلِهِم","translation":"তাদের পূর্বে (ছিল)","audioUrl":"wbw/051_052_006.mp3","charTypeName":"word"},{"id":49836,"position":7,"arabic":"مِّن","translation":"কোনো","audioUrl":"wbw/051_052_007.mp3","charTypeName":"word"},{"id":49837,"position":8,"arabic":"رَّسُولٍ","translation":"রাসূল","audioUrl":"wbw/051_052_008.mp3","charTypeName":"word"},{"id":49838,"position":9,"arabic":"إِلَّا","translation":"এছাড়া যে","audioUrl":"wbw/051_052_009.mp3","charTypeName":"word"},{"id":49839,"position":10,"arabic":"قَالُوا۟","translation":"তারা বলে ছিল","audioUrl":"wbw/051_052_010.mp3","charTypeName":"word"},{"id":49840,"position":11,"arabic":"سَاحِرٌ","translation":"\"(সে একজন) জাদুকর","audioUrl":"wbw/051_052_011.mp3","charTypeName":"word"},{"id":49841,"position":12,"arabic":"أَوْ","translation":"বা","audioUrl":"wbw/051_052_012.mp3","charTypeName":"word"},{"id":49842,"position":13,"arabic":"مَجْنُونٌ","translation":"পাগল\"","audioUrl":"wbw/051_052_013.mp3","charTypeName":"word"},{"id":49843,"position":14,"arabic":"٥٢","translation":"(৫২)","audioUrl":null,"charTypeName":"end"}]},{"number":53,"arabic":"أَتَوَاصَوْا۟ بِهِۦ ۚ بَلْ هُمْ قَوْمٌۭ طَاغُونَ","translation":"Have they, perchance, handed down this [way of thinking] as a legacy unto one another? Nay, they are people filled with overweening ar­rogance!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4728.mp3","surahId":51,"words":[{"id":50463,"position":1,"arabic":"أَتَوَاصَوْا۟","translation":"তারা পরস্পরে কি পরামর্শ করে নিয়েছে","audioUrl":"wbw/051_053_001.mp3","charTypeName":"word"},{"id":50464,"position":2,"arabic":"بِهِۦ ۚ","translation":"সে বিষয়ে","audioUrl":"wbw/051_053_002.mp3","charTypeName":"word"},{"id":50466,"position":3,"arabic":"بَلْ","translation":"(না) বরং","audioUrl":"wbw/051_053_004.mp3","charTypeName":"word"},{"id":50467,"position":4,"arabic":"هُمْ","translation":"তারা(ছিল)","audioUrl":"wbw/051_053_005.mp3","charTypeName":"word"},{"id":50468,"position":5,"arabic":"قَوْمٌۭ","translation":"জাতি","audioUrl":"wbw/051_053_006.mp3","charTypeName":"word"},{"id":50469,"position":6,"arabic":"طَاغُونَ","translation":"দুর্বিনীত","audioUrl":"wbw/051_053_007.mp3","charTypeName":"word"},{"id":50470,"position":7,"arabic":"٥٣","translation":"(৫৩)","audioUrl":null,"charTypeName":"end"}]},{"number":54,"arabic":"فَتَوَلَّ عَنْهُمْ فَمَآ أَنتَ بِمَلُومٍۢ","translation":"Turn, then, away from them, and thou shalt incur no blame;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4729.mp3","surahId":51,"words":[{"id":51119,"position":1,"arabic":"فَتَوَلَّ","translation":"তাই তুমি উপেক্ষা করো","audioUrl":"wbw/051_054_001.mp3","charTypeName":"word"},{"id":51120,"position":2,"arabic":"عَنْهُمْ","translation":"তাদের হতে","audioUrl":"wbw/051_054_002.mp3","charTypeName":"word"},{"id":51121,"position":3,"arabic":"فَمَآ","translation":"আর নও","audioUrl":"wbw/051_054_003.mp3","charTypeName":"word"},{"id":51122,"position":4,"arabic":"أَنتَ","translation":"তুমি","audioUrl":"wbw/051_054_004.mp3","charTypeName":"word"},{"id":51123,"position":5,"arabic":"بِمَلُومٍۢ","translation":"তিরস্কৃত","audioUrl":"wbw/051_054_005.mp3","charTypeName":"word"},{"id":51124,"position":6,"arabic":"٥٤","translation":"(৫৪)","audioUrl":null,"charTypeName":"end"}]},{"number":55,"arabic":"وَذَكِّرْ فَإِنَّ ٱلذِّكْرَىٰ تَنفَعُ ٱلْمُؤْمِنِينَ","translation":"yet go on reminding [all who would listen]: for, verily, such a reminder will profit the believers.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4730.mp3","surahId":51,"words":[{"id":51663,"position":1,"arabic":"وَذَكِّرْ","translation":"এবং উপদেশ দাও","audioUrl":"wbw/051_055_001.mp3","charTypeName":"word"},{"id":51664,"position":2,"arabic":"فَإِنَّ","translation":"কেননা নিশ্চয়ই","audioUrl":"wbw/051_055_002.mp3","charTypeName":"word"},{"id":51665,"position":3,"arabic":"ٱلذِّكْرَىٰ","translation":"উপদেশ","audioUrl":"wbw/051_055_003.mp3","charTypeName":"word"},{"id":51666,"position":4,"arabic":"تَنفَعُ","translation":"উপকার দিবে","audioUrl":"wbw/051_055_004.mp3","charTypeName":"word"},{"id":51667,"position":5,"arabic":"ٱلْمُؤْمِنِينَ","translation":"মু'মিনদেরকে","audioUrl":"wbw/051_055_005.mp3","charTypeName":"word"},{"id":51668,"position":6,"arabic":"٥٥","translation":"(৫৫)","audioUrl":null,"charTypeName":"end"}]},{"number":56,"arabic":"وَمَا خَلَقْتُ ٱلْجِنَّ وَٱلْإِنسَ إِلَّا لِيَعْبُدُونِ","translation":"And [tell them that] I have not created the invisible beings and men to any end other than that they may [know and] worship Me.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4731.mp3","surahId":51,"words":[{"id":52169,"position":1,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/051_056_001.mp3","charTypeName":"word"},{"id":52170,"position":2,"arabic":"خَلَقْتُ","translation":"আমি সৃষ্টি করেছি","audioUrl":"wbw/051_056_002.mp3","charTypeName":"word"},{"id":52171,"position":3,"arabic":"ٱلْجِنَّ","translation":"জিনকে","audioUrl":"wbw/051_056_003.mp3","charTypeName":"word"},{"id":52172,"position":4,"arabic":"وَٱلْإِنسَ","translation":"ও মানুষকে","audioUrl":"wbw/051_056_004.mp3","charTypeName":"word"},{"id":52173,"position":5,"arabic":"إِلَّا","translation":"এছাড়া যে","audioUrl":"wbw/051_056_005.mp3","charTypeName":"word"},{"id":52174,"position":6,"arabic":"لِيَعْبُدُونِ","translation":"যেন আমাকে তারা ইবাদত করে","audioUrl":"wbw/051_056_006.mp3","charTypeName":"word"},{"id":52175,"position":7,"arabic":"٥٦","translation":"(৫৬)","audioUrl":null,"charTypeName":"end"}]},{"number":57,"arabic":"مَآ أُرِيدُ مِنْهُم مِّن رِّزْقٍۢ وَمَآ أُرِيدُ أَن يُطْعِمُونِ","translation":"[But withal,] no sustenance do I ever demand of them, nor do I demand that they feed Me:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4732.mp3","surahId":51,"words":[{"id":52743,"position":1,"arabic":"مَآ","translation":"না","audioUrl":"wbw/051_057_001.mp3","charTypeName":"word"},{"id":52744,"position":2,"arabic":"أُرِيدُ","translation":"চাই আমি","audioUrl":"wbw/051_057_002.mp3","charTypeName":"word"},{"id":52745,"position":3,"arabic":"مِنْهُم","translation":"তাদের নিকট হতে","audioUrl":"wbw/051_057_003.mp3","charTypeName":"word"},{"id":52746,"position":4,"arabic":"مِّن","translation":"কোনো","audioUrl":"wbw/051_057_004.mp3","charTypeName":"word"},{"id":52747,"position":5,"arabic":"رِّزْقٍۢ","translation":"জীবিকা","audioUrl":"wbw/051_057_005.mp3","charTypeName":"word"},{"id":52748,"position":6,"arabic":"وَمَآ","translation":"আর না","audioUrl":"wbw/051_057_006.mp3","charTypeName":"word"},{"id":52749,"position":7,"arabic":"أُرِيدُ","translation":"চাই আমি","audioUrl":"wbw/051_057_007.mp3","charTypeName":"word"},{"id":52750,"position":8,"arabic":"أَن","translation":"যে","audioUrl":"wbw/051_057_008.mp3","charTypeName":"word"},{"id":52751,"position":9,"arabic":"يُطْعِمُونِ","translation":"আমাকে তারা খাওয়াবে","audioUrl":"wbw/051_057_009.mp3","charTypeName":"word"},{"id":52752,"position":10,"arabic":"٥٧","