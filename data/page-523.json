an/audio/128/ar.alafasy/4749.mp3","surahId":52,"words":[{"id":15997,"position":1,"arabic":"هَـٰذِهِ","translation":"\"(বলা হবে) সেই এই","audioUrl":"wbw/052_014_001.mp3","charTypeName":"word"},{"id":15998,"position":2,"arabic":"ٱلنَّارُ","translation":"আগুন","audioUrl":"wbw/052_014_002.mp3","charTypeName":"word"},{"id":15999,"position":3,"arabic":"ٱلَّتِى","translation":"যা","audioUrl":"wbw/052_014_003.mp3","charTypeName":"word"},{"id":16000,"position":4,"arabic":"كُنتُم","translation":"তোমরা ছিলে","audioUrl":"wbw/052_014_004.mp3","charTypeName":"word"},{"id":16001,"position":5,"arabic":"بِهَا","translation":"সে বিষয়ে","audioUrl":"wbw/052_014_005.mp3","charTypeName":"word"},{"id":16002,"position":6,"arabic":"تُكَذِّبُونَ","translation":"মিথ্যা মনে করতে","audioUrl":"wbw/052_014_006.mp3","charTypeName":"word"},{"id":16003,"position":7,"arabic":"١٤","translation":"(১৪)","audioUrl":null,"charTypeName":"end"}]}]}