{"id":20,"ayahs":[{"number":127,"arabic":"وَإِذْ يَرْفَعُ إِبْرَٰهِۦمُ ٱلْقَوَاعِدَ مِنَ ٱلْبَيْتِ وَإِسْمَٰعِيلُ رَبَّنَا تَقَبَّلْ مِنَّآ ۖ إِنَّكَ أَنتَ ٱلسَّمِيعُ ٱلْعَلِيمُ","translation":"And when Abraham and Ishmael were raising the foundations of the Temple, [they prayed:] \"O our Sustainer! Accept Thou this from us: for, verily, Thou alone art all-hearing, all-knowing!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/134.mp3","surahId":2,"words":[{"id":77456,"position":1,"arabic":"وَإِذْ","translation":"এবং (স্মরণ করো) যখন","audioUrl":"wbw/002_127_001.mp3","charTypeName":"word"},{"id":77457,"position":2,"arabic":"يَرْفَعُ","translation":"উঠায়","audioUrl":"wbw/002_127_002.mp3","charTypeName":"word"},{"id":77458,"position":3,"arabic":"إِبْرَٰهِـۧمُ","translation":"ইবরাহীম","audioUrl":"wbw/002_127_003.mp3","charTypeName":"word"},{"id":77459,"position":4,"arabic":"ٱلْقَوَاعِدَ","translation":"প্রাচীর বা ভিত্তি","audioUrl":"wbw/002_127_004.mp3","charTypeName":"word"},{"id":77460,"position":5,"arabic":"مِنَ","translation":"এর","audioUrl":"wbw/002_127_005.mp3","charTypeName":"word"},{"id":77461,"position":6,"arabic":"ٱلْبَيْتِ","translation":"(কাবা) ঘর","audioUrl":"wbw/002_127_006.mp3","charTypeName":"word"},{"id":77462,"position":7,"arabic":"وَإِسْمَـٰعِيلُ","translation":"ও ইসমাঈল","audioUrl":"wbw/002_127_007.mp3","charTypeName":"word"},{"id":77463,"position":8,"arabic":"رَبَّنَا","translation":"(তারা বলেছিল) হে আমাদের রব","audioUrl":"wbw/002_127_008.mp3","charTypeName":"word"},{"id":77464,"position":9,"arabic":"تَقَبَّلْ","translation":"প্রহন করো","audioUrl":"wbw/002_127_009.mp3","charTypeName":"word"},{"id":77465,"position":10,"arabic":"مِنَّآ ۖ","translation":"আমাদের থেকে (এ কাজ)","audioUrl":"wbw/002_127_010.mp3","charTypeName":"word"},{"id":77467,"position":11,"arabic":"إِنَّكَ","translation":"তুমি নিশ্চয়ই","audioUrl":"wbw/002_127_012.mp3","charTypeName":"word"},{"id":77468,"position":12,"arabic":"أَنتَ","translation":"তুমিই","audioUrl":"wbw/002_127_013.mp3","charTypeName":"word"},{"id":77469,"position":13,"arabic":"ٱلسَّمِيعُ","translation":"শ্রবণকারী","audioUrl":"wbw/002_127_014.mp3","charTypeName":"word"},{"id":77470,"position":14,"arabic":"ٱلْعَلِيمُ","translation":"সবকিছু জ্ঞাত","audioUrl":"wbw/002_127_015.mp3","charTypeName":"word"},{"id":77471,"position":15,"arabic":"١٢٧","translation":"(১২৭)","audioUrl":null,"charTypeName":"end"}]},{"number":128,"arabic":"رَبَّنَا وَٱجْعَلْنَا مُسْلِمَيْنِ لَكَ وَمِن ذُرِّيَّتِنَآ أُمَّةًۭ مُّسْلِمَةًۭ لَّكَ وَأَرِنَا مَنَاسِكَنَا وَتُبْ عَلَيْنَآ ۖ إِنَّكَ أَنتَ ٱلتَّوَّابُ ٱلرَّحِيمُ","translation":"\"O our Sustainer! Make us surrender ourselves unto Thee, and make out of our offspring a community that shall surrender itself unto Thee, and show us our ways of worship, and accept our repentance: for, verily, Thou alone art the Acceptor of Repentance, the Dispenser of Grace!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/135.mp3","surahId":2,"words":[{"id":77756,"position":1,"arabic":"رَبَّنَا","translation":"হে আমাদের রব","audioUrl":"wbw/002_128_001.mp3","charTypeName":"word"},{"id":77757,"position":2,"arabic":"وَٱجْعَلْنَا","translation":"এবং আমাদেরকে বানাও","audioUrl":"wbw/002_128_002.mp3","charTypeName":"word"},{"id":77758,"position":3,"arabic":"مُسْلِمَيْنِ","translation":"উভয়কে অনুগত","audioUrl":"wbw/002_128_003.mp3","charTypeName":"word"},{"id":77759,"position":4,"arabic":"لَكَ","translation":"তোমারই জন্য","audioUrl":"wbw/002_128_004.mp3","charTypeName":"word"},{"id":77760,"position":5,"arabic":"وَمِن","translation":"এবং মধ্যে হতেও","audioUrl":"wbw/002_128_005.mp3","charTypeName":"word"},{"id":77761,"position":6,"arabic":"ذُرِّيَّتِنَآ","translation":"আমাদের বংশধরদের","audioUrl":"wbw/002_128_006.mp3","charTypeName":"word"},{"id":77762,"position":7,"arabic":"أُمَّةًۭ","translation":"একটি জাতি (বানাও)","audioUrl":"wbw/002_128_007.mp3","charTypeName":"word"},{"id":77763,"position":8,"arabic":"مُّسْلِمَةًۭ","translation":"অনুগত","audioUrl":"wbw/002_128_008.mp3","charTypeName":"word"},{"id":77764,"position":9,"arabic":"لَّكَ","translation":"তোমারই","audioUrl":"wbw/002_128_009.mp3","charTypeName":"word"},{"id":77765,"position":10,"arabic":"وَأَرِنَا","translation":"এবং আমাদেরকে দেখাও","audioUrl":"wbw/002_128_010.mp3","charTypeName":"word"},{"id":77766,"position":11,"arabic":"مَنَاسِكَنَا","translation":"আমাদের ইবাদাতের নিয়মপদ্ধতি","audioUrl":"wbw/002_128_011.mp3","charTypeName":"word"},{"id":77767,"position":12,"arabic":"وَتُبْ","translation":"এবং ক্ষমাশীল হও","audioUrl":"wbw/002_128_012.mp3","charTypeName":"word"},{"id":77768,"position":13,"arabic":"عَلَيْنَآ ۖ","translation":"আমাদের উপর","audioUrl":"wbw/002_128_013.mp3","charTypeName":"word"},{"id":77770,"position":14,"arabic":"إِنَّكَ","translation":"নিশ্চয়ই তুমি","audioUrl":"wbw/002_128_015.mp3","charTypeName":"word"},{"id":77771,"position":15,"arabic":"أَنتَ","translation":"তুমিই","audioUrl":"wbw/002_128_016.mp3","charTypeName":"word"},{"id":77772,"position":16,"arabic":"ٱلتَّوَّابُ","translation":"ক্ষমাশীল","audioUrl":"wbw/002_128_017.mp3","charTypeName":"word"},{"id":77773,"position":17,"arabic":"ٱلرَّحِيمُ","translation":"পরমদয়ালু","audioUrl":"wbw/002_128_018.mp3","charTypeName":"word"},{"id":77774,"position":18,"arabic":"١٢٨","translation":"(১২৮)","audioUrl":null,"charTypeName":"end"}]},{"number":129,"arabic":"رَبَّنَا وَٱبْعَثْ فِيهِمْ رَسُولًۭا مِّنْهُمْ يَتْلُوا۟ عَلَيْهِمْ ءَايَٰتِكَ وَيُعَلِّمُهُمُ ٱلْكِتَٰبَ وَٱلْحِكْمَةَ وَيُزَكِّيهِمْ ۚ إِنَّكَ أَنتَ ٱلْعَزِيزُ ٱلْحَكِيمُ","translation":"\"O our Sustainer! Raise up from the midst of our off spring an apostle from among themselves, who shall convey unto them Thy messages, and impart unto them revelation as well as wisdom, and cause them to grow in purity: for, verily, Thou alone art almighty, truly wise!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/136.mp3","surahId":2,"words":[{"id":77885,"position":1,"arabic":"رَبَّنَا","translation":"হে আমাদের রব","audioUrl":"wbw/002_129_001.mp3","charTypeName":"word"},{"id":77886,"position":2,"arabic":"وَٱبْعَثْ","translation":"এবং পাঠাও","audioUrl":"wbw/002_129_002.mp3","charTypeName":"word"},{"id":77887,"position":3,"arabic":"فِيهِمْ","translation":"তাদের মাঝে","audioUrl":"wbw/002_129_003.mp3","charTypeName":"word"},{"id":77888,"position":4,"arabic":"رَسُولًۭا","translation":"একজন রাসূল","audioUrl":"wbw/002_129_004.mp3","charTypeName":"word"},{"id":77889,"position":5,"arabic":"مِّنْهُمْ","translation":"তাদের মধ্য হতে","audioUrl":"wbw/002_129_005.mp3","charTypeName":"word"},{"id":77890,"position":6,"arabic":"يَتْلُوا۟","translation":"সে তিলাওাত করবে","audioUrl":"wbw/002_129_006.mp3","charTypeName":"word"},{"id":77891,"position":7,"arabic":"عَلَيْهِمْ","translation":"তাদের কাছে","audioUrl":"wbw/002_129_007.mp3","charTypeName":"word"},{"id":77892,"position":8,"arabic":"ءَايَـٰتِكَ","translation":"তোমার আয়াতগুলোকে","audioUrl":"wbw/002_129_008.mp3","charTypeName":"word"},{"id":77893,"position":9,"arabic":"وَيُعَلِّمُهُمُ","translation":"এবং তাদের সে শিখাবে","audioUrl":"wbw/002_129_009.mp3","charTypeName":"word"},{"id":77894,"position":10,"arabic":"ٱلْكِتَـٰبَ","translation":"কিতাব","audioUrl":"wbw/002_129_010.mp3","charTypeName":"word"},{"id":77895,"position":11,"arabic":"وَٱلْحِكْمَةَ","translation":"ও প্রজ্ঞা","audioUrl":"wbw/002_129_011.mp3","charTypeName":"word"},{"id":77896,"position":12,"arabic":"وَيُزَكِّيهِمْ ۚ","translation":"ও তাদের পরিশুদ্ধ করবে","audioUrl":"wbw/002_129_012.mp3","charTypeName":"word"},{"id":77898,"position":13,"arabic":"إِنَّكَ","translation":"তুমি নিশ্চয়ই","audioUrl":"wbw/002_129_014.mp3","charTypeName":"word"},{"id":77899,"position":14,"arabic":"أَنتَ","translation":"তুমিই","audioUrl":"wbw/002_129_015.mp3","charTypeName":"word"},{"id":77900,"position":15,"arabic":"ٱلْعَزِيزُ","translation":"পরাক্রমশালী","audioUrl":"wbw/002_129_016.mp3","charTypeName":"word"},{"id":77901,"position":16,"arabic":"ٱلْحَكِيمُ","translation":"মহাবিজ্ঞ''","audioUrl":"wbw/002_129_017.mp3","charTypeName":"word"},{"id":77902,"position":17,"arabic":"١٢٩","translation":"(১২৯)","audioUrl":null,"charTypeName":"end"}]},{"number":130,"arabic":"وَمَن يَرْغَبُ عَن مِّلَّةِ إِبْرَٰهِۦمَ إِلَّا مَن سَفِهَ نَفْسَهُۥ ۚ وَلَقَدِ ٱصْطَفَيْنَٰهُ فِى ٱلدُّنْيَا ۖ وَإِنَّهُۥ فِى ٱلْءَاخِرَةِ لَمِنَ ٱلصَّٰلِحِينَ","translation":"And who, unless he be weak of mind, would want to abandon Abraham's creed, seeing that We have indeed raised him high in this world, and that, verily, in the life to come he shall be among the righteous?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/137.mp3","surahId":2,"words":[{"id":77957,"position":1,"arabic":"وَمَن","translation":"আর কে","audioUrl":"wbw/002_130_001.mp3","charTypeName":"word"},{"id":77958,"position":2,"arabic":"يَرْغَبُ","translation":"মুখ ফেরাবে","audioUrl":"wbw/002_130_002.mp3","charTypeName":"word"},{"id":77959,"position":3,"arabic":"عَن","translation":"হতে","audioUrl":"wbw/002_130_003.mp3","charTypeName":"word"},{"id":77960,"position":4,"arabic":"مِّلَّةِ","translation":"দীন","audioUrl":"wbw/002_130_004.mp3","charTypeName":"word"},{"id":77961,"position":5,"arabic":"إِبْرَٰهِـۧمَ","translation":"ইবরাহীমের","audioUrl":"wbw/002_130_005.mp3","charTypeName":"word"},{"id":77962,"position":6,"arabic":"إِلَّا","translation":"এছাড়া","audioUrl":"wbw/002_130_006.mp3","charTypeName":"word"},{"id":77963,"position":7,"arabic":"مَن","translation":"যে","audioUrl":"wbw/002_130_007.mp3","charTypeName":"word"},{"id":77964,"position":8,"arabic":"سَفِهَ","translation":"নির্বোধ বানিয়েছে","audioUrl":"wbw/002_130_008.mp3","charTypeName":"word"},{"id":77965,"position":9,"arabic":"نَفْسَهُۥ ۚ","translation":"তার নিজেকে","audioUrl":"wbw/002_130_009.mp3","charTypeName":"word"},{"id":77967,"position":10,"arabic":"وَلَقَدِ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/002_130_011.mp3","charTypeName":"word"},{"id":77968,"position":11,"arabic":"ٱصْطَفَيْنَـٰهُ","translation":"তাকে আমরা মনোনীত করেছি","audioUrl":"wbw/002_130_012.mp3","charTypeName":"word"},{"id":77969,"position":12,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/002_130_013.mp3","charTypeName":"word"},{"id":77970,"position":13,"arabic":"ٱلدُّنْيَا ۖ","translation":"পৃথিবীর","audioUrl":"wbw/002_130_014.mp3","charTypeName":"word"},{"id":77972,"position":14,"arabic":"وَإِنَّهُۥ","translation":"এবং সে নিশ্চয়ই(হবে)","audioUrl":"wbw/002_130_016.mp3","charTypeName":"word"},{"id":77973,"position":15,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/002_130_017.mp3","charTypeName":"word"},{"id":77974,"position":16,"arabic":"ٱلْـَٔاخِرَةِ","translation":"আখিরাতের''","audioUrl":"wbw/002_130_018.mp3","charTypeName":"word"},{"id":77975,"position":17,"arabic":"لَمِنَ","translation":"অন্তর্ভুক্ত অবশ্যই","audioUrl":"wbw/002_130_019.mp3","charTypeName":"word"},{"id":77976,"position":18,"arabic":"ٱلصَّـٰلِحِينَ","translation":"সৎলোকদের","audioUrl":"wbw/002_130_020.mp3","charTypeName":"word"},{"id":77977,"position":19,"arabic":"١٣٠","translation":"(১৩০)","audioUrl":null,"charTypeName":"end"}]},{"number":131,"arabic":"إِذْ قَالَ لَهُۥ رَبُّهُۥٓ أَسْلِمْ ۖ قَالَ أَسْلَمْتُ لِرَبِّ ٱلْعَٰلَمِينَ","translation":"When his Sustainer said to him, \"Surrender thyself unto Me!\" - he answered, \"I have surrendered myself unto [Thee,] the Sustainer of all the worlds.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/138.mp3","surahId":2,"words":[{"id":78034,"position":1,"arabic":"إِذْ","translation":"(সে ছিল এমন যে) যখন","audioUrl":"wbw/002_131_001.mp3","charTypeName":"word"},{"id":78035,"position":2,"arabic":"قَالَ","translation":"বলেছিলেন","audioUrl":"wbw/002_131_002.mp3","charTypeName":"word"},{"id":78036,"position":3,"arabic":"لَهُۥ","translation":"তার","audioUrl":"wbw/002_131_003.mp3","charTypeName":"word"},{"id":78037,"position":4,"arabic":"رَبُّهُۥٓ","translation":"তার রব","audioUrl":"wbw/002_131_004.mp3","charTypeName":"word"},{"id":78038,"position":5,"arabic":"أَسْلِمْ ۖ","translation":"''তুমি আত্মসমর্পণ করো''","audioUrl":"wbw/002_131_005.mp3","charTypeName":"word"},{"id":78040,"position":6,"arabic":"قَالَ","translation":"সে বলেছিল","audioUrl":"wbw/002_131_007.mp3","charTypeName":"word"},{"id":78041,"position":7,"arabic":"أَسْلَمْتُ","translation":"''আমি আত্মসমর্পণ করলাম","audioUrl":"wbw/002_131_008.mp3","charTypeName":"word"},{"id":78042,"position":8,"arabic":"لِرَبِّ","translation":"রবের কাছে","audioUrl":"wbw/002_131_009.mp3","charTypeName":"word"},{"id":78043,"position":9,"arabic":"ٱلْعَـٰلَمِينَ","translation":"জগতের''","audioUrl":"wbw/002_131_010.mp3","charTypeName":"word"},{"id":78044,"position":10,"arabic":"١٣١","translation":"(১৩১)","audioUrl":null,"charTypeName":"end"}]},{"number":132,"arabic":"وَوَصَّىٰ بِهَآ إِبْرَٰهِۦمُ بَنِيهِ وَيَعْقُوبُ يَٰبَنِىَّ إِنَّ ٱللَّهَ ٱصْطَفَىٰ لَكُمُ ٱلدِّينَ فَلَا تَمُوتُنَّ إِلَّا وَأَنتُم مُّسْلِمُونَ","translation":"And this very thing did Abraham bequeath unto his children, and [so did] Jacob: \"O my children! Behold, God has granted you the purest faith; so do not allow death to overtake you ere you have surrendered yourselves unto Him.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/139.mp3","surahId":2,"words":[{"id":78169,"position":1,"arabic":"وَوَصَّىٰ","translation":"এবং জোর নির্দেশ দিয়েছিল","audioUrl":"wbw/002_132_001.mp3","charTypeName":"word"},{"id":78170,"position":2,"arabic":"بِهَآ","translation":"এ সম্বন্ধে","audioUrl":"wbw/002_132_002.mp3","charTypeName":"word"},{"id":78171,"position":3,"arabic":"إِبْرَٰهِـۧمُ","translation":"ইবরাহীম","audioUrl":"wbw/002_132_003.mp3","charTypeName":"word"},{"id":78172,"position":4,"arabic":"بَنِيهِ","translation":"তার সন্তানদেরকে","audioUrl":"wbw/002_132_004.mp3","charTypeName":"word"},{"id":78173,"position":5,"arabic":"وَيَعْقُوبُ","translation":"এবং ইয়াকুবও","audioUrl":"wbw/002_132_005.mp3","charTypeName":"word"},{"id":78174,"position":6,"arabic":"يَـٰبَنِىَّ","translation":"''(সে বলেছিল) হে আমার সন্তানেরা","audioUrl":"wbw/002_132_006.mp3","charTypeName":"word"},{