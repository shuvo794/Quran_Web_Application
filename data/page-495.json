{"id":495,"ayahs":[{"number":74,"arabic":"إِنَّ ٱلْمُجْرِمِينَ فِى عَذَابِ جَهَنَّمَ خَٰلِدُونَ","translation":"[But,] behold, they who are lost in sin shall abide in the suffering of hell:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4399.mp3","surahId":43,"words":[{"id":61375,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/043_074_001.mp3","charTypeName":"word"},{"id":61376,"position":2,"arabic":"ٱلْمُجْرِمِينَ","translation":"অপরাধীরা","audioUrl":"wbw/043_074_002.mp3","charTypeName":"word"},{"id":61377,"position":3,"arabic":"فِى","translation":"(হবে) মধ্যে","audioUrl":"wbw/043_074_003.mp3","charTypeName":"word"},{"id":61378,"position":4,"arabic":"عَذَابِ","translation":"শাস্তির","audioUrl":"wbw/043_074_004.mp3","charTypeName":"word"},{"id":61379,"position":5,"arabic":"جَهَنَّمَ","translation":"জাহান্নামের","audioUrl":"wbw/043_074_005.mp3","charTypeName":"word"},{"id":61380,"position":6,"arabic":"خَـٰلِدُونَ","translation":"তারা স্থায়ী হবে (সেখানে)","audioUrl":"wbw/043_074_006.mp3","charTypeName":"word"},{"id":61381,"position":7,"arabic":"٧٤","translation":"(৭৪)","audioUrl":null,"charTypeName":"end"}]},{"number":75,"arabic":"لَا يُفَتَّرُ عَنْهُمْ وَهُمْ فِيهِ مُبْلِسُونَ","translation":"it will not be lightened for them; and therein they will be lost in hopeless despair.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4400.mp3","surahId":43,"words":[{"id":61838,"position":1,"arabic":"لَا","translation":"না","audioUrl":"wbw/043_075_001.mp3","charTypeName":"word"},{"id":61839,"position":2,"arabic":"يُفَتَّرُ","translation":"কম করা হবে","audioUrl":"wbw/043_075_002.mp3","charTypeName":"word"},{"id":61840,"position":3,"arabic":"عَنْهُمْ","translation":"তাদের থেকে (শাস্তি)","audioUrl":"wbw/043_075_003.mp3","charTypeName":"word"},{"id":61841,"position":4,"arabic":"وَهُمْ","translation":"এবং তারা","audioUrl":"wbw/043_075_004.mp3","charTypeName":"word"},{"id":61842,"position":5,"arabic":"فِيهِ","translation":"তার মধ্যে","audioUrl":"wbw/043_075_005.mp3","charTypeName":"word"},{"id":61843,"position":6,"arabic":"مُبْلِسُونَ","translation":"হতাশ হয়ে পড়ে থাকবে","audioUrl":"wbw/043_075_006.mp3","charTypeName":"word"},{"id":61844,"position":7,"arabic":"٧٥","translation":"(৭৫)","audioUrl":null,"charTypeName":"end"}]},{"number":76,"arabic":"وَمَا ظَلَمْنَٰهُمْ وَلَٰكِن كَانُوا۟ هُمُ ٱلظَّٰلِمِينَ","translation":"And it is not We who will be doing wrong unto them, but it is they who will have wronged them­selves.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4401.mp3","surahId":43,"words":[{"id":62346,"position":1,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/043_076_001.mp3","charTypeName":"word"},{"id":62347,"position":2,"arabic":"ظَلَمْنَـٰهُمْ","translation":"তাদেরকে আমরা অত্যাচার করেছি","audioUrl":"wbw/043_076_002.mp3","charTypeName":"word"},{"id":62348,"position":3,"arabic":"وَلَـٰكِن","translation":"কিন্তু","audioUrl":"wbw/043_076_003.mp3","charTypeName":"word"},{"id":62349,"position":4,"arabic":"كَانُوا۟","translation":"ছিলো","audioUrl":"wbw/043_076_004.mp3","charTypeName":"word"},{"id":62350,"position":5,"arabic":"هُمُ","translation":"তারা","audioUrl":"wbw/043_076_005.mp3","charTypeName":"word"},{"id":62351,"position":6,"arabic":"ٱلظَّـٰلِمِينَ","translation":"সীমালঙ্ঘনকারী (তাদের নিজেদের উপর)","audioUrl":"wbw/043_076_006.mp3","charTypeName":"word"},{"id":62352,"position":7,"arabic":"٧٦","translation":"(৭৬)","audioUrl":null,"charTypeName":"end"}]},{"number":77,"arabic":"وَنَادَوْا۟ يَٰمَٰلِكُ لِيَقْضِ عَلَيْنَا رَبُّكَ ۖ قَالَ إِنَّكُم مَّٰكِثُونَ","translation":"And they will cry: “O thou [angel] who rulest [over hell]! Let thy Sustainer put an end to us!” - whereupon] he will reply: “Verily, you must live on [in this state]","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4402.mp3","surahId":43,"words":[{"id":62852,"position":1,"arabic":"وَنَادَوْا۟","translation":"এবং তারা ডেকে বলবে","audioUrl":"wbw/043_077_001.mp3","charTypeName":"word"},{"id":62853,"position":2,"arabic":"يَـٰمَـٰلِكُ","translation":"\"হে মালিক (জাহান্নামের প্রহরী)","audioUrl":"wbw/043_077_002.mp3","charTypeName":"word"},{"id":62854,"position":3,"arabic":"لِيَقْضِ","translation":"শেষ করে দিক","audioUrl":"wbw/043_077_003.mp3","charTypeName":"word"},{"id":62855,"position":4,"arabic":"عَلَيْنَا","translation":"আমাদের উপর (ব্যাপারটা)","audioUrl":"wbw/043_077_004.mp3","charTypeName":"word"},{"id":62856,"position":5,"arabic":"رَبُّكَ ۖ","translation":"তোমার রব\"","audioUrl":"wbw/043_077_005.mp3","charTypeName":"word"},{"id":62858,"position":6,"arabic":"قَالَ","translation":"সে বলবে","audioUrl":"wbw/043_077_007.mp3","charTypeName":"word"},{"id":62859,"position":7,"arabic":"إِنَّكُم","translation":"\"তোমরা নিশ্চয়ই","audioUrl":"wbw/043_077_008.mp3","charTypeName":"word"},{"id":62860,"position":8,"arabic":"مَّـٰكِثُونَ","translation":"অবস্থানকারী (এভাবেই)\"","audioUrl":"wbw/043_077_009.mp3","charTypeName":"word"},{"id":62861,"position":9,"arabic":"٧٧","translation":"(৭৭)","audioUrl":null,"charTypeName":"end"}]},{"number":78,"arabic":"لَقَدْ جِئْنَٰكُم بِٱلْحَقِّ وَلَٰكِنَّ أَكْثَرَكُمْ لِلْحَقِّ كَٰرِهُونَ","translation":"INDEED, [O you sinners,] We have conveyed the truth unto you; but most of you abhor the truth.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4403.mp3","surahId":43,"words":[{"id":63267,"position":1,"arabic":"لَقَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/043_078_001.mp3","charTypeName":"word"},{"id":63268,"position":2,"arabic":"جِئْنَـٰكُم","translation":"তোমাদের কাছে আমরা এসেছিলাম","audioUrl":"wbw/043_078_002.mp3","charTypeName":"word"},{"id":63269,"position":3,"arabic":"بِٱلْحَقِّ","translation":"সত্যসহ","audioUrl":"wbw/043_078_003.mp3","charTypeName":"word"},{"id":63270,"position":4,"arabic":"وَلَـٰكِنَّ","translation":"কিন্তু","audioUrl":"wbw/043_078_004.mp3","charTypeName":"word"},{"id":63271,"position":5,"arabic":"أَكْثَرَكُمْ","translation":"তোমাদের বেশীর ভাগই (ছিলে)","audioUrl":"wbw/043_078_005.mp3","charTypeName":"word"},{"id":63272,"position":6,"arabic":"لِلْحَقِّ","translation":"সত্যের প্রতি","audioUrl":"wbw/043_078_006.mp3","charTypeName":"word"},{"id":63273,"position":7,"arabic":"كَـٰرِهُونَ","translation":"বিমুখ","audioUrl":"wbw/043_078_007.mp3","charTypeName":"word"},{"id":63274,"position":8,"arabic":"٧٨","translation":"(৭৮)","audioUrl":null,"charTypeName":"end"}]},{"number":79,"arabic":"أَمْ أَبْرَمُوٓا۟ أَمْرًۭا فَإِنَّا مُبْرِمُونَ","translation":"Why - can they [who deny the truth ever] determine what [the truth] should be?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4404.mp3","surahId":43,"words":[{"id":63707,"position":1,"arabic":"أَمْ","translation":"তবে কি","audioUrl":"wbw/043_079_001.mp3","charTypeName":"word"},{"id":63708,"position":2,"arabic":"أَبْرَمُوٓا۟","translation":"তারা সিদ্ধান্ত নিয়েছে","audioUrl":"wbw/043_079_002.mp3","charTypeName":"word"},{"id":63709,"position":3,"arabic":"أَمْرًۭا","translation":"একটি বিষয়ে","audioUrl":"wbw/043_079_003.mp3","charTypeName":"word"},{"id":63710,"position":4,"arabic":"فَإِنَّا","translation":"নিশ্চয়ই তবে আমরাও","audioUrl":"wbw/043_079_004.mp3","charTypeName":"word"},{"id":63711,"position":5,"arabic":"مُبْرِمُونَ","translation":"সিদ্ধান্ত গ্রহণকারী (তাদের ব্যাপারে)","audioUrl":"wbw/043_079_005.mp3","charTypeName":"word"},{"id":63712,"position":6,"arabic":"٧٩","translation":"(৭৯)","audioUrl":null,"charTypeName":"end"}]},{"number":80,"arabic":"أَمْ يَحْسَبُونَ أَنَّا لَا نَسْمَعُ سِرَّهُمْ وَنَجْوَىٰهُم ۚ بَلَىٰ وَرُسُلُنَا لَدَيْهِمْ يَكْتُبُونَ","translation":"Or do they, perchance, think that We do not hear their hidden thoughts and their secret confabulations? Yea, indeed, [We do,] and Our heavenly forces are with them, recording [all].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4405.mp3","surahId":43,"words":[{"id":64052,"position":1,"arabic":"أَمْ","translation":"না কি","audioUrl":"wbw/043_080_001.mp3","charTypeName":"word"},{"id":64053,"position":2,"arabic":"يَحْسَبُونَ","translation":"তারা মনে করেছে","audioUrl":"wbw/043_080_002.mp3","charTypeName":"word"},{"id":64054,"position":3,"arabic":"أَنَّا","translation":"যে আমরা","audioUrl":"wbw/043_080_003.mp3","charTypeName":"word"},{"id":64055,"position":4,"arabic":"لَا","translation":"না","audioUrl":"wbw/043_080_004.mp3","charTypeName":"word"},{"id":64056,"position":5,"arabic":"نَسْمَعُ","translation":"আমরা শুনি","audioUrl":"wbw/043_080_005.mp3","charTypeName":"word"},{"id":64057,"position":6,"arabic":"سِرَّهُمْ","translation":"তাদের গোপন কথাবার্তা","audioUrl":"wbw/043_080_006.mp3","charTypeName":"word"},{"id":64058,"position":7,"arabic":"وَنَجْوَىٰهُم ۚ","translation":"ও তাদের গোপন পরামর্শ","audioUrl":"wbw/043_080_007.mp3","charTypeName":"word"},{"id":64060,"position":8,"arabic":"بَلَىٰ","translation":"হ্যাঁ (সবই শুনি)","audioUrl":"wbw/043_080_009.mp3","charTypeName":"word"},{"id":64061,"position":9,"arabic":"وَرُسُلُنَا","translation":"এবং আমাদের ফেরেশতারা","audioUrl":"wbw/043_080_010.mp3","charTypeName":"word"},{"id":64062,"position":10,"arabic":"لَدَيْهِمْ","translation":"তাদের কাছে আছে","audioUrl":"wbw/043_080_011.mp3","charTypeName":"word"},{"id":64063,"position":11,"arabic":"يَكْتُبُونَ","translation":"তারা লিখছে","audioUrl":"wbw/043_080_012.mp3","charTypeName":"word"},{"id":64064,"position":12,"arabic":"٨٠","translation":"(৮০)","audioUrl":null,"charTypeName":"end"}]},{"number":81,"arabic":"قُلْ إِن كَانَ لِلرَّحْمَٰنِ وَلَدٌۭ فَأَنَا۠ أَوَّلُ ٱلْعَٰبِدِينَ","translation":"Say [O Prophet]: “If the Most Gracious [truly] had a son, I would be the first to worship him!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4406.mp3","surahId":43,"words":[{"id":64743,"position":1,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/043_081_001.mp3","charTypeName":"word"},{"id":64744,"position":2,"arabic":"إِن","translation":"\"যদি","audioUrl":"wbw/043_081_002.mp3","charTypeName":"word"},{"id":64745,"position":3,"arabic":"كَانَ","translation":"থাকতো","audioUrl":"wbw/043_081_003.mp3","charTypeName":"word"},{"id":64746,"position":4,"arabic":"لِلرَّحْمَـٰنِ","translation":"দয়াময়ের জন্যে","audioUrl":"wbw/043_081_004.mp3","charTypeName":"word"},{"id":64747,"position":5,"arabic":"وَلَدٌۭ","translation":"কোনো ছেলে","audioUrl":"wbw/043_081_005.mp3","charTypeName":"word"},{"id":64748,"position":6,"arabic":"فَأَنَا۠","translation":"তবে আমি","audioUrl":"wbw/043_081_006.mp3","charTypeName":"word"},{"id":64749,"position":7,"arabic":"أَوَّلُ","translation":"প্রথম (হতাম)","audioUrl":"wbw/043_081_007.mp3","charTypeName":"word"},{"id":64750,"position":8,"arabic":"ٱلْعَـٰبِدِينَ","translation":"উপাসকদের মধ্যে\"","audioUrl":"wbw/043_081_008.mp3","charTypeName":"word"},{"id":64751,"position":9,"arabic":"٨١","translation":"(৮১)","audioUrl":null,"charTypeName":"end"}]},{"number":82,"arabic":"سُبْحَٰنَ رَبِّ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ رَبِّ ٱلْعَرْشِ عَمَّا يَصِفُونَ","translation":"Utterly remote, in His glory, is the Sustainer of the heavens and the earth - the Sustainer, in almigh­tiness enthroned from all that they may attribute to Him by way of definition!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4407.mp3","surahId":43,"words":[{"id":64941,"position":1,"arabic":"سُبْحَـٰنَ","translation":"মহান পবিত্র","audioUrl":"wbw/043_082_001.mp3","charTypeName":"word"},{"id":64942,"position":2,"arabic":"رَبِّ","translation":"রব","audioUrl":"wbw/043_082_002.mp3","charTypeName":"word"},{"id":64943,"position":3,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশের","audioUrl":"wbw/043_082_003.mp3","charTypeName":"word"},{"id":64944,"position":4,"arabic":"وَٱلْأَرْضِ","translation":"ও পৃথিবীর","audioUrl":"wbw/043_082_004.mp3","charTypeName":"word"},{"id":64945,"position":5,"arabic":"رَبِّ","translation":"রব","audioUrl":"wbw/043_082_005.mp3","charTypeName":"word"},{"id":64946,"position":6,"arabic":"ٱلْعَرْشِ","translation":"আরশের","audioUrl":"wbw/043_082_006.mp3","charTypeName":"word"},{"id":64947,"position":7,"arabic":"عَمَّا","translation":"তা হ'তে যা","audioUrl":"wbw/043_082_007.mp3","charTypeName":"word"},{"id":64948,"position":8,"arabic":"يَصِفُونَ","translation":"তারা আরোপ করে","audioUrl":"wbw/043_082_008.mp3","charTypeName":"word"},{"id":64949,"position":9,"arabic":"٨٢","translation":"(৮২)","audioUrl":null,"charTypeName":"end"}]},{"number":83,"arabic":"فَذَرْهُمْ يَخُوضُوا۟ وَيَلْعَبُوا۟ حَتَّىٰ يُلَٰقُوا۟ يَوْمَهُمُ ٱلَّذِى يُوعَدُونَ","translation":"But leave them to indulge in idle talk and play [with words] until they face that [Judgment] Day of theirs which they have been promised:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4408.mp3","surahId":43,"words":[{"id":65594,"position":1,"arabic":"فَذَرْهُمْ","translation":"সুতরাং ছেড়ে দাও তাদেরকে","audioUrl":"wbw/043_083_001.mp3","charTypeName":"word"},{"id":65595,"position":2,"arabic":"يَخُوضُوا۟","translation":"বাকবিতন্ডা করতে","audioUrl":"wbw/043_083_002.mp3","charTypeName":"word"},{"id":65596,"position":3,"arabic":"وَيَلْعَبُوا۟","translation":"ও ক্রীড়া-কৌতুক করতে","audioUrl":"wbw/043_083_003.mp3","charTypeName":"word"},{"id":65597,"position":4,"arabic":"حَتَّىٰ","translation":"যতক্ষণ না","audioUrl":"wbw/043_083_004.mp3","charTypeName":"word"},{"id":65598,"position":5,"arabic":"يُلَـٰقُوا۟","translation":"তারা সাক্ষাত পায়","audioUrl":"wbw/043_083_005.mp3","charTypeName":"word"},{"id":65599,"position":6,"arabic":"يَوْمَهُمُ","translation":"তাদের দিনের","audioUrl":"wbw/043_083_006.mp3","charTypeName":"word"},{"id":65600,"position":7,"arabic":"ٱلَّذِى","translation":"যা","audioUrl":"wbw/043_083_007.mp3","charTypeName":"word"},{"id":65601,"position":8,"arabic":"يُوعَدُونَ","translation":"তাদের প্রতিশ্রুতি দেয়া হচ্ছে","audioUrl":"wbw/043_083_008.mp3","charTypeName":"word"},{"id":65602,"position":9,"arabic":"٨٣","translation":"(৮৩)","audioUrl":null,"charTypeName":"end"}]},{"number":84,"arabic":"وَهُوَ ٱلَّذِى فِى ٱلسَّمَآءِ إِلَٰهٌۭ وَفِى ٱلْأَرْضِ إِلَٰهٌۭ ۚ وَهُوَ ٱلْحَكِيمُ ٱلْعَلِيمُ","translation":"for [then they will come to know that] it is He [alone] who is God in heaven and God on earth, and [that] He alone is truly wise, all-knowing.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4409.mp3","surahId":43,"words":[{"id":65656,"position":1,"arabic":"وَهُوَ","translation":"এবং তিনিই (আল্লাহ)","audioUrl":"wbw/043_084_001.mp3","charTypeName":"word"},{"id":65657,"position":2,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/043_084_002.mp3","charTypeName":"word"},{"id":65658,"position":3,"arabic":"فِى","translation":"আছেন","audioUrl":"wbw/043_084_003.mp3","charTypeName":"word"},{"id":65659,"position":4,"arabic":"ٱلسَّمَآءِ","translation":"আকাশে","audioUrl":"wbw/043_084_004.mp3","charTypeName":"word"},{"id":65660,"position":5,"arabic":"إِلَـٰهٌۭ","translation":"ইলাহ","audioUrl":"wbw/043_084_005.mp3","charTypeName":"word"},{"id":65661,"position":6,"arabic":"وَفِى","translation":"এবং আছেন","audioUrl":"wbw/043_084_006.mp3","charTypeName":"word"},{"id":65662,"position":7,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীতেও","audioUrl":"wbw/043_084_007.mp3","charTypeName":"word"},{"id":65663,"position":8,"arabic":"إِلَـٰهٌۭ ۚ","translation":"ইলাহ","audioUrl":"wbw/043_084_008.mp3","charTypeName":"word"},{"id":65665,"position":9,"arabic":"وَهُوَ","translation":"এবং তিনিই","audioUrl":"wbw/043_084_010.mp3","charTypeName":"word"},{"id":65666,"position":10,"arabic":"ٱلْحَكِيمُ","translation":"মহাজ্ঞানী","audioUrl":"wbw/043_084_011.mp3","charTypeName":"word"},{"id":65667,"position":11,"arabic":"ٱلْعَلِيمُ","translation":"মহাবিজ্ঞ","audioUrl":"wbw/043_084_012.mp3","charTypeName":"word"},{"id":65668,"position":12,"arabic":"٨٤","translation":"(৮৪)","audioUrl":null,"charTypeName":"end"}]},{"number":85,"arabic":"وَتَبَارَكَ ٱلَّذِى لَهُۥ مُلْكُ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ وَمَا بَيْنَهُمَا وَعِندَهُۥ عِلْمُ ٱلسَّاعَةِ وَإِلَيْهِ تُرْجَعُونَ","translation":"And hallowed be He unto whom the dominion over the heavens and the earth and all that is between them belongs, and with whom the knowledge of the Last Hour rests, and unto whom you all shall be brought back!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4410.mp3","surahId":43,"words":[{"id":66270,"position":1,"arabic":"وَتَبَارَكَ","translation":"এবং মহান তিনি","audioUrl":"wbw/043_085_001.mp3","charTypeName":"word"},{"id":66271,"position":2,"arabic":"ٱلَّذِى","translation":"যিনি (এমন সত্ত্বা যে)","audioUrl":"wbw/043_085_002.mp3","charTypeName":"word"},{"id":66272,"position":3,"arabic":"لَهُۥ","translation":"তাঁরই","audioUrl":"wbw/043_085_003.mp3","charTypeName":"word"},{"id":66273,"position":4,"arabic":"مُلْكُ","translation":"সার্বভৌমত্ব","audioUrl":"wbw/043_085_004.mp3","charTypeName":"word"},{"id":66274,"position":5,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশের","audioUrl":"wbw/043_085_005.mp3","charTypeName":"word"},{"id":66275,"position":6,"arabic":"وَٱلْأَرْضِ","translation":"ও পৃথিবীর","audioUrl":"wbw/043_085_006.mp3","charTypeName":"word"},{"id":66276,"position":7,"arabic":"وَمَا","translation":"এবং যা কিছু","audioUrl":"wbw/043_085_007.mp3","charTypeName":"word"},{"id":66277,"position":8,"arabic":"بَيْنَهُمَا","translation":"তাদের উভয়ের মাঝে আছে","audioUrl":"wbw/043_085_008.mp3","charTypeName":"word"},{"id":66278,"position":9,"arabic":"وَعِندَهُۥ","translation":"এবং তাঁরই কাছে আছে","audioUrl":"wbw/043_085_009.mp3","charTypeName":"word"},{"id":66279,"position":10,"arabic":"عِلْمُ","translation":"জ্ঞান","audioUrl":"wbw/043_085_010.mp3","charTypeName":"word"},{"id":66280,"position":11,"arabic":"ٱلسَّاعَةِ","translation":"ক্বিয়ামাতের","audioUrl":"wbw/043_085_011.mp3","charTypeName":"word"},{"id":66281,"position":12,"arabic":"وَإِلَيْهِ","translation":"এবং তাঁরই দিকে","audioUrl":"wbw/043_085_012.mp3","charTypeName":"word"},{"id":66282,"position":13,"arabic":"تُرْجَعُونَ","translation":"তোমাদেরকে ফিরে যেতে হবে","audioUrl":"wbw/043_085_013.mp3","charTypeName":"word"},{"id":66283,"position":14,"arabic":"٨٥","translation":"(৮৫)","audioUrl":null,"charTypeName":"end"}]},{"number":86,"arabic":"وَلَا يَمْلِكُ ٱلَّذِينَ يَدْعُونَ مِن دُونِهِ ٱلشَّفَٰعَةَ إِلَّا مَن شَهِدَ بِٱلْحَقِّ وَهُمْ يَعْلَمُونَ","translation":"And those [beings] whom some invoke beside God have it not in their power to intercede [on Judgment Day] for any but such as have [in their lifetime] borne witness to the truth, and have been aware [that God is one and unique].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4411.mp3","surahId":43,"words":[{"id":66412,"position":1,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/043_086_001.mp3","charTypeName":"word"},{"id":66413,"position":2,"arabic":"يَمْلِكُ","translation":"ক্ষমতা রাখে","audioUrl":"wbw/043_086_002.mp3","charTypeName":"word"},{"id":66414,"position":3,"arabic":"ٱلَّذِينَ","translation":"যাদেরকে","audioUrl":"wbw/043_086_003.mp3","charTypeName":"word"},{"id":66415,"position":4,"arabic":"يَدْعُونَ","translation":"তারা ডাকে","audioUrl":"wbw/043_086_004.mp3","charTypeName":"word"},{"id":66416,"position":5,"arabic":"مِن","translation":"মধ্য হতে","audioUrl":"wbw/043_086_005.mp3","charTypeName":"word"},{"id":66417,"position":6,"arabic":"دُونِهِ","translation":"তাঁকে ছাড়া","audioUrl":"wbw/043_086_006.mp3","charTypeName":"word"},{"id":66418,"position":7,"arabic":"ٱلشَّفَـٰعَةَ","translation":"সুপারিশের","audioUrl":"wbw/043_086_007.mp3","charTypeName":"word"},{"id":66419,"position":8,"arabic":"إِلَّا","translation":"কিন্তু","audioUrl":"wbw/043_086_008.mp3","charTypeName":"word"},{"id":66420,"position":9,"arabic":"مَن","translation":"যে","audioUrl":"wbw/043_086_009.mp3","charTypeName":"word"},{"id":66421,"position":10,"arabic":"شَهِدَ","translation":"সাক্ষ্য দেয়","audioUrl":"wbw/043_086_010.mp3","charTypeName":"word"},{"id":66422,"position":11,"arabic":"بِٱلْحَقِّ","translation":"সত্যের","audioUrl":"wbw/043_086_011.mp3","charTypeName":"word"},{"id":66423,"position":12,"arabic":"وَهُمْ","translation":"তারা যখন","audioUrl":"wbw/043_086_012.mp3","charTypeName":"word"},{"id":66424,"position":13,"arabic":"يَعْلَمُونَ","translation":"জানেও","audioUrl":"wbw/043_086_013.mp3","charTypeName":"word"},{"id":66425,"position":14,"arabic":"٨٦","translation":"(৮৬)","audioUrl":null,"charTypeName":"end"}]},{"number":87,"arabic":"وَلَئِن سَأَلْتَهُم مَّنْ خَلَقَهُمْ لَيَقُولُنَّ ٱللَّهُ ۖ فَأَنَّىٰ يُؤْفَكُونَ","translation":"Now if thou ask those [who worship any being other than God] as to who it is that has created them, they are sure to answer, “God.” How perverted, then, are their minds!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4412.mp3","surahId":43,"words":[{"id":66985,"position":1,"arabic":"وَلَئِن","translation":"এবং অবশ্যই যদি","audioUrl":"wbw/043_087_001.mp3","charTypeName":"word"},{"id":66986,"position":2,"arabic":"سَأَلْتَهُم","translation":"তাদেরকে তুমি জিজ্ঞেস করো","audioUrl":"wbw/043_087_002.mp3","charTypeName":"word"},{"id":66987,"position":3,"arabic":"مَّنْ","translation":"কে","audioUrl":"wbw/043_087_003.mp3","charTypeName":"word"},{"id":66988,"position":4,"arabic":"خَلَقَهُمْ","translation":"তাদের সৃষ্টি করেছে","audioUrl":"wbw/043_087_004.mp3","charTypeName":"word"},{"id":66989,"position":5,"arabic":"لَيَقُولُنَّ","translation":"অবশ্যই তারা বলবে","audioUrl":"wbw/043_087_005.mp3","charTypeName":"word"},{"id":66990,"position":6,"arabic":"ٱللَّهُ ۖ","translation":"\"আল্লাহ\"","audioUrl":"wbw/043_087_006.mp3","charTypeName":"word"},{"id":66992,"position":7,"arabic":"فَأَنَّىٰ","translation":"তাহ'লে কোথায়","audioUrl":"wbw/043_087_008.mp3","charTypeName":"word"},{"id":66993,"position":8,"arabic":"يُؤْفَكُونَ","translation":"তাদের ফিরানো হচ্ছে","audioUrl":"wbw/043_087_009.mp3","charTypeName":"word"},{"id":66994,"position":9,"arabic":"٨٧","translation":"(৮৭)","audioUrl":null,"charTypeName":"end"}]},{"number":88,"arabic":"وَقِيلِهِۦ يَٰرَبِّ إِنَّ هَٰٓؤُلَآءِ قَوْمٌۭ لَّا يُؤْمِنُونَ","translation":"[But God has full knowledge of the true be­liever] and of his [despairing] cry: “O my Sustainer! Verily, these are 