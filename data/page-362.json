787,"position":1,"arabic":"وَكَذَٰلِكَ","translation":"এবং এভাবে","audioUrl":"wbw/025_031_001.mp3","charTypeName":"word"},{"id":33788,"position":2,"arabic":"جَعَلْنَا","translation":"আমরা করেছি","audioUrl":"wbw/025_031_002.mp3","charTypeName":"word"},{"id":33789,"position":3,"arabic":"لِكُلِّ","translation":"জন্যে প্রত্যেক","audioUrl":"wbw/025_031_003.mp3","charTypeName":"word"},{"id":33790,"position":4,"arabic":"نَبِىٍّ","translation":"নাবীর","audioUrl":"wbw/025_031_004.mp3","charTypeName":"word"},{"id":33791,"position":5,"arabic":"عَدُوًّۭا","translation":"শত্রু","audioUrl":"wbw/025_031_005.mp3","charTypeName":"word"},{"id":33792,"position":6,"arabic":"مِّنَ","translation":"থেকে","audioUrl":"wbw/025_031_006.mp3","charTypeName":"word"},{"id":33793,"position":7,"arabic":"ٱلْمُجْرِمِينَ ۗ","translation":"দুষ্কৃতিকারীদেরকে","audioUrl":"wbw/025_031_007.mp3","charTypeName":"word"},{"id":33795,"position":8,"arabic":"وَكَفَىٰ","translation":"এবং যথেষ্ট","audioUrl":"wbw/025_031_009.mp3","charTypeName":"word"},{"id":33796,"position":9,"arabic":"بِرَبِّكَ","translation":"তোমার রব (তোমার জন্যে)","audioUrl":"wbw/025_031_010.mp3","charTypeName":"word"},{"id":33797,"position":10,"arabic":"هَادِيًۭا","translation":"পথপ্রদর্শক","audioUrl":"wbw/025_031_011.mp3","charTypeName":"word"},{"id":33798,"position":11,"arabic":"وَنَصِيرًۭا","translation":"ও সাহায্যকারীরূপে","audioUrl":"wbw/025_031_012.mp3","charTypeName":"word"},{"id":33799,"position":12,"arabic":"٣١","translation":"(৩১)","audioUrl":null,"charTypeName":"end"}]},{"number":32,"arabic":"وَقَالَ ٱلَّذِينَ كَفَرُوا۟ لَوْلَا نُزِّلَ عَلَيْهِ ٱلْقُرْءَانُ جُمْلَةًۭ وَٰحِدَةًۭ ۚ كَذَٰلِكَ لِنُثَبِّتَ بِهِۦ فُؤَادَكَ ۖ وَرَتَّلْنَٰهُ تَرْتِيلًۭا","translation":"Now they who are bent on denying the truth are wont to ask. “Why has not the Qur’an been bestowed on him from on high in one single re­velation?” [it has been revealed] in this manner so that We might strengthen thy heart thereby - for We have so arranged its component parts that they form one consistent whole -","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2887.mp3","surahId":25,"words":[{"id":35017,"position":1,"arabic":"وَقَالَ","translation":"এবং বলে","audioUrl":"wbw/025_032_001.mp3","charTypeName":"word"},{"id":35018,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/025_032_002.mp3","charTypeName":"word"},{"id":35019,"position":3,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/025_032_003.mp3","charTypeName":"word"},{"id":35020,"position":4,"arabic":"لَوْلَا","translation":"\"কেন না","audioUrl":"wbw/025_032_004.mp3","charTypeName":"word"},{"id":35021,"position":5,"arabic":"نُزِّلَ","translation":"অবতীর্ণ হলো","audioUrl":"wbw/025_032_005.mp3","charTypeName":"word"},{"id":35022,"position":6,"arabic":"عَلَيْهِ","translation":"তার উপর","audioUrl":"wbw/025_032_006.mp3","charTypeName":"word"},{"id":35023,"position":7,"arabic":"ٱلْقُرْءَانُ","translation":"কুরআন","audioUrl":"wbw/025_032_007.mp3","charTypeName":"word"},{"id":35024,"position":8,"arabic":"جُمْلَةًۭ","translation":"সমগ্র\"","audioUrl":"wbw/025_032_008.mp3","charTypeName":"word"},{"id":35025,"position":9,"arabic":"وَٰحِدَةًۭ ۚ","translation":"একবারে\"","audioUrl":"wbw/025_032_009.mp3","charTypeName":"word"},{"id":35027,"position":10,"arabic":"كَذَٰلِكَ","translation":"এভাবে (করেছি)","audioUrl":"wbw/025_032_011.mp3","charTypeName":"word"},{"id":35028,"position":11,"arabic":"لِنُثَبِّتَ","translation":"যেন আমরা দৃঢ় করি","audioUrl":"wbw/025_032_012.mp3","charTypeName":"word"},{"id":35029,"position":12,"arabic":"بِهِۦ","translation":"এদ্বারা","audioUrl":"wbw/025_032_013.mp3","charTypeName":"word"},{"id":35030,"position":13,"arabic":"فُؤَادَكَ ۖ","translation":"তোমার অন্তরকে","audioUrl":"wbw/025_032_014.mp3","charTypeName":"word"},{"id":35032,"position":14,"arabic":"وَرَتَّلْنَـٰهُ","translation":"এবং তা আমরা আবৃত্তি করেছি (সাজিয়েছি)","audioUrl":"wbw/025_032_016.mp3","charTypeName":"word"},{"id":35033,"position":15,"arabic":"تَرْتِيلًۭا","translation":"থেমে থেমে আবৃত্তি (স্পষ্টভাবে সাজানো)","audioUrl":"wbw/025_032_017.mp3","charTypeName":"word"},{"id":35034,"position":16,"arabic":"٣٢","translation":"(৩২)","audioUrl":null,"charTypeName":"end"}]}]}