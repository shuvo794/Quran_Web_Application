{"id":362,"ayahs":[{"number":21,"arabic":"۞ وَقَالَ ٱلَّذِينَ لَا يَرْجُونَ لِقَآءَنَا لَوْلَآ أُنزِلَ عَلَيْنَا ٱلْمَلَٰٓئِكَةُ أَوْ نَرَىٰ رَبَّنَا ۗ لَقَدِ ٱسْتَكْبَرُوا۟ فِىٓ أَنفُسِهِمْ وَعَتَوْ عُتُوًّۭا كَبِيرًۭا","translation":"But those who do not believe that they are destined to meet Us are wont to say, “Why have no angels been sent down to us?” – or, “Why do we not see our Sustainer?” Indeed, they are far too proud of themselves, hav­ing rebelled [against God’s truth] with utter disdain!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2876.mp3","surahId":25,"words":[{"id":24183,"position":1,"arabic":"۞ وَقَالَ","translation":"এবং বলবে","audioUrl":"wbw/025_021_002.mp3","charTypeName":"word"},{"id":24184,"position":2,"arabic":"ٱلَّذِينَ","translation":"(তারা) যারা","audioUrl":"wbw/025_021_003.mp3","charTypeName":"word"},{"id":24185,"position":3,"arabic":"لَا","translation":"না","audioUrl":"wbw/025_021_004.mp3","charTypeName":"word"},{"id":24186,"position":4,"arabic":"يَرْجُونَ","translation":"আশা করে","audioUrl":"wbw/025_021_005.mp3","charTypeName":"word"},{"id":24187,"position":5,"arabic":"لِقَآءَنَا","translation":"প্রতি আমাদের সাক্ষাতের","audioUrl":"wbw/025_021_006.mp3","charTypeName":"word"},{"id":24188,"position":6,"arabic":"لَوْلَآ","translation":"\"কেন না","audioUrl":"wbw/025_021_007.mp3","charTypeName":"word"},{"id":24189,"position":7,"arabic":"أُنزِلَ","translation":"অবতীর্ণ করা হলো","audioUrl":"wbw/025_021_008.mp3","charTypeName":"word"},{"id":24190,"position":8,"arabic":"عَلَيْنَا","translation":"আমাদের উপর","audioUrl":"wbw/025_021_009.mp3","charTypeName":"word"},{"id":24191,"position":9,"arabic":"ٱلْمَلَـٰٓئِكَةُ","translation":"ফেরেশতাদের","audioUrl":"wbw/025_021_010.mp3","charTypeName":"word"},{"id":24192,"position":10,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/025_021_011.mp3","charTypeName":"word"},{"id":24193,"position":11,"arabic":"نَرَىٰ","translation":"আমরা প্রত্যক্ষ করি","audioUrl":"wbw/025_021_012.mp3","charTypeName":"word"},{"id":24194,"position":12,"arabic":"رَبَّنَا ۗ","translation":"আমাদের রবকে\"","audioUrl":"wbw/025_021_013.mp3","charTypeName":"word"},{"id":24196,"position":13,"arabic":"لَقَدِ","translation":"নিশ্চয়ই","audioUrl":"wbw/025_021_015.mp3","charTypeName":"word"},{"id":24197,"position":14,"arabic":"ٱسْتَكْبَرُوا۟","translation":"তারা অহঙ্কার করেছে","audioUrl":"wbw/025_021_016.mp3","charTypeName":"word"},{"id":24198,"position":15,"arabic":"فِىٓ","translation":"মধ্যে","audioUrl":"wbw/025_021_017.mp3","charTypeName":"word"},{"id":24199,"position":16,"arabic":"أَنفُسِهِمْ","translation":"নিজেদের মনের তাদের","audioUrl":"wbw/025_021_018.mp3","charTypeName":"word"},{"id":24200,"position":17,"arabic":"وَعَتَوْ","translation":"ও  অবাধ্য হয়েছে","audioUrl":"wbw/025_021_019.mp3","charTypeName":"word"},{"id":24201,"position":18,"arabic":"عُتُوًّۭا","translation":"অবাধ্য","audioUrl":"wbw/025_021_020.mp3","charTypeName":"word"},{"id":24202,"position":19,"arabic":"كَبِيرًۭا","translation":"গুরুতর","audioUrl":"wbw/025_021_021.mp3","charTypeName":"word"},{"id":24203,"position":20,"arabic":"٢١","translation":"(২১)","audioUrl":null,"charTypeName":"end"}]},{"number":22,"arabic":"يَوْمَ يَرَوْنَ ٱلْمَلَٰٓئِكَةَ لَا بُشْرَىٰ يَوْمَئِذٍۢ لِّلْمُجْرِمِينَ وَيَقُولُونَ حِجْرًۭا مَّحْجُورًۭا","translation":"[Yet] on that Day - the Day on which they shall see the angels there will be no glad tiding for those who were lost in sin; and they will exclaim, “By a forbidding ban [are we from God’s grace debarred]!” –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2877.mp3","surahId":25,"words":[{"id":25007,"position":1,"arabic":"يَوْمَ","translation":"যেদিন","audioUrl":"wbw/025_022_001.mp3","charTypeName":"word"},{"id":25008,"position":2,"arabic":"يَرَوْنَ","translation":"তারা দেখবে","audioUrl":"wbw/025_022_002.mp3","charTypeName":"word"},{"id":25009,"position":3,"arabic":"ٱلْمَلَـٰٓئِكَةَ","translation":"ফেরেশতাদেরকে","audioUrl":"wbw/025_022_003.mp3","charTypeName":"word"},{"id":25010,"position":4,"arabic":"لَا","translation":"না","audioUrl":"wbw/025_022_004.mp3","charTypeName":"word"},{"id":25011,"position":5,"arabic":"بُشْرَىٰ","translation":"সুসংবাদ (থাকবে)","audioUrl":"wbw/025_022_005.mp3","charTypeName":"word"},{"id":25012,"position":6,"arabic":"يَوْمَئِذٍۢ","translation":"সেদিন","audioUrl":"wbw/025_022_006.mp3","charTypeName":"word"},{"id":25013,"position":7,"arabic":"لِّلْمُجْرِمِينَ","translation":"জন্যে অপরাধীদের","audioUrl":"wbw/025_022_007.mp3","charTypeName":"word"},{"id":25014,"position":8,"arabic":"وَيَقُولُونَ","translation":"এবং তারা বলবে (আছে কি)","audioUrl":"wbw/025_022_008.mp3","charTypeName":"word"},{"id":25015,"position":9,"arabic":"حِجْرًۭا","translation":"\"কোন আড়াল","audioUrl":"wbw/025_022_009.mp3","charTypeName":"word"},{"id":25016,"position":10,"arabic":"مَّحْجُورًۭا","translation":"দুর্ভেদ্য\"","audioUrl":"wbw/025_022_010.mp3","charTypeName":"word"},{"id":25017,"position":11,"arabic":"٢٢","translation":"(২২)","audioUrl":null,"charTypeName":"end"}]},{"number":23,"arabic":"وَقَدِمْنَآ إِلَىٰ مَا عَمِلُوا۟ مِنْ عَمَلٍۢ فَجَعَلْنَٰهُ هَبَآءًۭ مَّنثُورًا","translation":"for We shall have turned towards all the [supposedly good] deeds they ever wrought, and shall have transformed them into scattered dust –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2878.mp3","surahId":25,"words":[{"id":26074,"position":1,"arabic":"وَقَدِمْنَآ","translation":"এবং আমরা অগ্রসর হবো (বিবেচনা করবো)","audioUrl":"wbw/025_023_001.mp3","charTypeName":"word"},{"id":26075,"position":2,"arabic":"إِلَىٰ","translation":"(তার) প্রতি","audioUrl":"wbw/025_023_002.mp3","charTypeName":"word"},{"id":26076,"position":3,"arabic":"مَا","translation":"যা","audioUrl":"wbw/025_023_003.mp3","charTypeName":"word"},{"id":26077,"position":4,"arabic":"عَمِلُوا۟","translation":"তারা করেছে","audioUrl":"wbw/025_023_004.mp3","charTypeName":"word"},{"id":26078,"position":5,"arabic":"مِنْ","translation":"কোন","audioUrl":"wbw/025_023_005.mp3","charTypeName":"word"},{"id":26079,"position":6,"arabic":"عَمَلٍۢ","translation":"কাজ","audioUrl":"wbw/025_023_006.mp3","charTypeName":"word"},{"id":26080,"position":7,"arabic":"فَجَعَلْنَـٰهُ","translation":"অতঃপর তা আমরা পরিণত করবো","audioUrl":"wbw/025_023_007.mp3","charTypeName":"word"},{"id":26081,"position":8,"arabic":"هَبَآءًۭ","translation":"ধুলিকণায়","audioUrl":"wbw/025_023_008.mp3","charTypeName":"word"},{"id":26082,"position":9,"arabic":"مَّنثُورًا","translation":"বিক্ষিপ্ত","audioUrl":"wbw/025_023_009.mp3","charTypeName":"word"},{"id":26083,"position":10,"arabic":"٢٣","translation":"(২৩)","audioUrl":null,"charTypeName":"end"}]},{"number":24,"arabic":"أَصْحَٰبُ ٱلْجَنَّةِ يَوْمَئِذٍ خَيْرٌۭ مُّسْتَقَرًّۭا وَأَحْسَنُ مَقِيلًۭا","translation":"[whereas] on that same Day those who are destined for paradise will be graced with the best of abodes and the fairest place of repose.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2879.mp3","surahId":25,"words":[{"id":26908,"position":1,"arabic":"أَصْحَـٰبُ","translation":"অধিবাসীদের (জন্যে)","audioUrl":"wbw/025_024_001.mp3","charTypeName":"word"},{"id":26909,"position":2,"arabic":"ٱلْجَنَّةِ","translation":"জান্নাতের","audioUrl":"wbw/025_024_002.mp3","charTypeName":"word"},{"id":26910,"position":3,"arabic":"يَوْمَئِذٍ","translation":"সেদিন","audioUrl":"wbw/025_024_003.mp3","charTypeName":"word"},{"id":26911,"position":4,"arabic":"خَيْرٌۭ","translation":"উত্তম","audioUrl":"wbw/025_024_004.mp3","charTypeName":"word"},{"id":26912,"position":5,"arabic":"مُّسْتَقَرًّۭا","translation":"বাসস্থান (থাকবে)","audioUrl":"wbw/025_024_005.mp3","charTypeName":"word"},{"id":26913,"position":6,"arabic":"وَأَحْسَنُ","translation":"ও উৎকৃষ্ট","audioUrl":"wbw/025_024_006.mp3","charTypeName":"word"},{"id":26914,"position":7,"arabic":"مَقِيلًۭا","translation":"(দুপুরের) বিশ্রামস্থল","audioUrl":"wbw/025_024_007.mp3","charTypeName":"word"},{"id":26915,"position":8,"arabic":"٢٤","translation":"(২৪)","audioUrl":nul