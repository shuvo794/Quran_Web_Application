ন","audioUrl":"wbw/025_026_002.mp3","charTypeName":"word"},{"id":29122,"position":3,"arabic":"ٱلْحَقُّ","translation":"প্রকৃত (কর্তৃত্ব)","audioUrl":"wbw/025_026_003.mp3","charTypeName":"word"},{"id":29123,"position":4,"arabic":"لِلرَّحْمَـٰنِ ۚ","translation":"জন্যে দয়াময়ের","audioUrl":"wbw/025_026_004.mp3","charTypeName":"word"},{"id":29125,"position":5,"arabic":"وَكَانَ","translation":"আর হবে","audioUrl":"wbw/025_026_006.mp3","charTypeName":"word"},{"id":29126,"position":6,"arabic":"يَوْمًا","translation":"সেদিন","audioUrl":"wbw/025_026_007.mp3","charTypeName":"word"},{"id":29127,"position":7,"arabic":"عَلَى","translation":"জন্যে","audioUrl":"wbw/025_026_008.mp3","charTypeName":"word"},{"id":29128,"position":8,"arabic":"ٱلْكَـٰفِرِينَ","translation":"কাফিরদের","audioUrl":"wbw/025_026_009.mp3","charTypeName":"word"},{"id":29129,"position":9,"arabic":"عَسِيرًۭا","translation":"কঠিন","audioUrl":"wbw/025_026_010.mp3","charTypeName":"word"},{"id":29130,"position":10,"arabic":"٢٦","translation":"(২৬)","audioUrl":null,"charTypeName":"end"}]},{"number":27,"arabic":"وَيَوْمَ يَعَضُّ ٱلظَّالِمُ عَلَىٰ يَدَيْهِ يَقُولُ يَٰلَيْتَنِى ٱتَّخَذْتُ مَعَ ٱلرَّسُولِ سَبِيلًۭا","translation":"and a Day on which the evildoer will bite his hands [in despair], exclaiming: “Oh, would that I had followed the path shown to me by the apostle!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2882.mp3","surahId":25,"words":[{"id":30030,"position":1,"arabic":"وَيَوْمَ","translation":"এবং সেদিন","audioUrl":"wbw/025_027_001.mp3","charTypeName":"word"},{"id":30031,"position":2,"arabic":"يَعَضُّ","translation":"কামড়াবে","audioUrl":"wbw/025_027_002.mp3","charTypeName":"word"},{"id":30032,"position":3,"arabic":"ٱلظَّالِمُ","translation":"সীমালঙ্ঘনকারী","audioUrl":"wbw/025_027_003.mp3","charTypeName":"word"},{"id":30033,"position":4,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/025_027_004.mp3","charTypeName":"word"},{"id":30034,"position":5,"arabic":"يَدَيْهِ","translation":"তার দু'হাতের","audioUrl":"wbw/025_027_005.mp3","charTypeName":"word"},{"id":30035,"position":6,"arabic":"يَقُولُ","translation":"বলবে","audioUrl":"wbw/025_027_006.mp3","charTypeName":"word"},{"id":30036,"position":7,"arabic":"يَـٰلَيْتَنِى","translation":"\"হায়! আমার দুর্ভোগ","audioUrl":"wbw/025_027_007.mp3","charTypeName":"word"},{"id":30037,"position":8,"arabic":"ٱتَّخَذْتُ","translation":"আমি ধরতাম (যদি)","audioUrl":"wbw/025_027_008.mp3","charTypeName":"word"},{"id":30038,"position":9,"arabic":"مَعَ","translation":"সাথে","audioUrl":"wbw/025_027_009.mp3","charTypeName":"word"},{"id":30039,"position":10,"arabic":"ٱلرَّسُولِ","translation":"রাসূলের","audioUrl":"wbw/025_027_010.mp3","charTypeName":"word"},{"id":30040,"position":11,"arabic":"سَبِيلًۭا","translation":"পথ","audioUrl":"wbw/025_027_011.mp3","charTypeName":"word"},{"id":30041,"position":12,"arabic":"٢٧","translation":"(২৭)","audioUrl":null,"charTypeName":"end"}]},{"number":28,"arabic":"يَٰوَيْلَتَىٰ لَيْتَنِى لَمْ أَتَّخِذْ فُلَانًا خَلِيلًۭا","translation":"Oh, woe is me! Would that I had not taken so-and-so for a friend!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2883.mp3","surahId":25,"words":[{"id":31080,"position":1,"arabic":"يَـٰوَيْلَتَىٰ","translation":"হায়! আমার দুর্ভাগ্য","audioUrl":"wbw/025_028_001.mp3","charTypeName":"word"},{"id":31081,"position":2,"arabic":"لَيْتَنِى","translation":"আমার দুর্ভোগ","audioUrl":"wbw/025_028_002.mp3","charTypeName":"word"},{"id":31082,"position":3,"arabic":"لَمْ","translation":"না","audioUrl":"wbw/025_028_003.mp3","charTypeName":"word"},{"id":31083,"position":4,"arabic":"أَتَّخِذْ","translation":"গ্রহণ করতাম","audioUrl":"wbw/025_028_004.mp3","charTypeName":"word"},{"id":31084,"position":5,"arabic":"فُلَانًا","translation":"অমুককে","audioUrl":"wbw/025_028_005.mp3","charTypeName":"word"},{"id":31085,"position":6,"arabic":"خَلِيلًۭا","translation":"বন্ধুরূপে","audioUrl":"wbw/025_028_006.mp3","charTypeName":"word"},{"id":31086,"position":7,"arabic":"٢٨","translation":"(২৮)","audioUrl":null,"charTypeName":"end"}]},{"number":29,"arabic":"لَّقَدْ أَضَلَّنِى عَنِ ٱلذِّكْرِ بَعْدَ إِذْ جَآءَنِى ۗ وَكَانَ ٱلشَّيْطَٰنُ لِلْإِنسَٰنِ خَذُولًۭا","translation":"Indeed, he led me astray from the remembrance [of God] after it had come unto me!” For [thus it is:] Satan is ever a betrayer of man.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2884.mp3","surahId":25,"words":[{"id":32058,"position":1,"arabic":"لَّقَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/025_029_001.mp3","charTypeName":"word"},{"id":32059,"position":2,"arabic":"أَضَلَّنِى","translation":"আমাকে সে বিভ্রান্ত করেছে","audioUrl":"wbw/025_029_002.mp3","charTypeName":"word"},{"id":32060,"position":3,"arabic":"عَنِ","translation":"হ'তে","audioUrl":"wbw/025_029_003.mp3","charTypeName":"word"},{"id":32061,"position":4,"arabic":"ٱلذِّكْرِ","translation":"উপদেশ (কুরআন)","audioUrl":"wbw/025_029_004.mp3","charTypeName":"word"},{"id":32062,"position":5,"arabic":"بَعْدَ","translation":"এরপরও","audioUrl":"wbw/025_029_005.mp3","charTypeName":"word"},{"id":32063,"position":6,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/025_029_006.mp3","charTypeName":"word"},{"id":32064,"position":7,"arabic":"جَآءَنِى ۗ","translation":"আমার (নিকট) এসেছিলো","audioUrl":"wbw/025_029_007.mp3","charTypeName":"word"},{"id":32066,"position":8,"arabic":"وَكَانَ","translation":"আর হলো","audioUrl":"wbw/025_029_009.mp3","charTypeName":"word"},{"id":32067,"position":9,"arabic":"ٱلشَّيْطَـٰنُ","translation":"শয়তান","audioUrl":"wbw/025_029_010.mp3","charTypeName":"word"},{"id":32068,"position":10,"arabic":"لِلْإِنسَـٰنِ","translation":"জন্যে মানুষের","audioUrl":"wbw/025_029_011.mp3","charTypeName":"word"},{"id":32069,"position":11,"arabic":"خَذُولًۭا","translation":"প্রতারক\"","audioUrl":"wbw/025_029_012.mp3","charTypeName":"word"},{"id":32070,"position":12,"arabic":"٢٩","translation":"(২৯)","audioUrl":null,"charTypeName":"end"}]},{"number":30,"arabic":"وَقَالَ ٱلرَّسُولُ يَ