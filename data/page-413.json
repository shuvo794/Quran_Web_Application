bw/031_027_022.mp3","charTypeName":"word"},{"id":30227,"position":22,"arabic":"٢٧","translation":"(২৭)","audioUrl":null,"charTypeName":"end"}]},{"number":28,"arabic":"مَّا خَلْقُكُمْ وَلَا بَعْثُكُمْ إِلَّا كَنَفْسٍۢ وَٰحِدَةٍ ۗ إِنَّ ٱللَّهَ سَمِيعٌۢ بَصِيرٌ","translation":"[For Him,] the creation of you all and the resurrection of you all is but like [the creation and resurrection of] a single soul: for, verily, God is all-hearing, all-seeing.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3497.mp3","surahId":31,"words":[{"id":31248,"position":1,"arabic":"مَّا","translation":"নয়","audioUrl":"wbw/031_028_001.mp3","charTypeName":"word"},{"id":31249,"position":2,"arabic":"خَلْقُكُمْ","translation":"সৃষ্টি তোমাদের","audioUrl":"wbw/031_028_002.mp3","charTypeName":"word"},{"id":31250,"position":3,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/031_028_003.mp3","charTypeName":"word"},{"id":31251,"position":4,"arabic":"بَعْثُكُمْ","translation":"উত্থান তোমাদের","audioUrl":"wbw/031_028_004.mp3","charTypeName":"word"},{"id":31252,"position":5,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/031_028_005.mp3","charTypeName":"word"},{"id":31253,"position":6,"arabic":"كَنَفْسٍۢ","translation":"মতো(সৃষ্টি ও উত্থান)প্রাণীর","audioUrl":"wbw/031_028_006.mp3","charTypeName":"word"},{"id":31254,"position":7,"arabic":"وَٰحِدَةٍ ۗ","translation":"একটিমাত্র","audioUrl":"wbw/031_028_007.mp3","charTypeName":"word"},{"id":31256,"position":8,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/031_028_009.mp3","charTypeName":"word"},{"id":31257,"position":9,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/031_028_010.mp3","charTypeName":"word"},{"id":31258,"position":10,"arabic":"سَمِيعٌۢ","translation":"সব শুনেন","audioUrl":"wbw/031_028_011.mp3","charTypeName":"word"},{"id":31259,"position":11,"arabic":"بَصِيرٌ","translation":"সব দেখেন","audioUrl":"wbw/031_028_012.mp3","charTypeName":"word"},{"id":31260,"position":12,"arabic":"٢٨","translation"