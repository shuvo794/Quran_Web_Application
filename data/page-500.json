ُمْ","translation":"তোমার রবের","audioUrl":"wbw/045_015_012.mp3","charTypeName":"word"},{"id":17020,"position":11,"arabic":"تُرْجَعُونَ","translation":"তোমাদেরকে ফিরিয়ে আনা হবে","audioUrl":"wbw/045_015_013.mp3","charTypeName":"word"},{"id":17021,"position":12,"arabic":"١٥","translation":"(১৫)","audioUrl":null,"charTypeName":"end"}]},{"number":16,"arabic":"وَلَقَدْ ءَاتَيْنَا بَنِىٓ إِسْرَٰٓءِيلَ ٱلْكِتَٰبَ وَٱلْحُكْمَ وَٱلنُّبُوَّةَ وَرَزَقْنَٰهُم مِّنَ ٱلطَّيِّبَٰتِ وَفَضَّلْنَٰهُمْ عَلَى ٱلْعَٰلَمِينَ","translation":"AND, INDEED, [already] unto the children of Israel did We vouchsafe revelation, and wisdom, and prophethood; and We provided for them sustenance out of the good things of life, and favoured them above all other people [of their time].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4489.mp3","surahId":45,"words":[{"id":18113,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/045_016_001.mp3","charTypeName":"word"},{"id":18114,"position":2,"arabic":"ءَاتَيْنَا","translation":"আমরা দিয়েছিলাম","audioUrl":"wbw/045_016_002.mp3","charTypeName":"word"},{"id":18115,"position":3,"arabic":"بَنِىٓ","translation":"বনী","audioUrl":"wbw/045_016_003.mp3","charTypeName":"word"},{"id":18116,"position":4,"arabic":"إِسْرَٰٓءِيلَ","translation":"ইসরাইলকে","audioUrl":"wbw/045_016_004.mp3","charTypeName":"word"},{"id":18117,"position":5,"arabic":"ٱلْكِتَـٰبَ","translation":"কিতাব","audioUrl":"wbw/045_016_005.mp3","charTypeName":"word"},{"id":18118,"position":6,"arabic":"وَٱلْحُكْمَ","translation":"ও কর্তৃত্ব","audioUrl":"wbw/045_016_006.mp3","charTypeName":"word"},{"id":18119,"position":7,"arabic":"وَٱلنُّبُوَّةَ","translation":"ও নবুয়ত","audioUrl":"wbw/045_016_007.mp3","charTypeName":"word"},{"id":18120,"position":8,"arabic":"وَرَزَقْنَـٰهُم","translation":"এবং তাদের আমরা জীবিকা দিয়েছিলাম","audioUrl":"wbw/045_016_008.mp3","charTypeName":"word"},{"id":18121,"position":9,"arabic":"مِّنَ","translation":"হতে","audioUrl":"wbw/045_016_009.mp3","charTypeName":"word"},{"id":18122,"position":10,"arabic":"ٱلطَّيِّبَـٰتِ","translation":"উত্তম বস্তু","audioUrl":"wbw/045_016_010.mp3","charTypeName":"word"},{"id":18123,"position":11,"arabic":"وَفَضَّلْنَـٰهُمْ","translation":"এবং আমরা তাদেরকে মর্যাদা দিয়েছিলাম","audioUrl":"wbw/045_016_011.mp3","charTypeName":"word"},{"id":18124,"position":12,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/045_016_012.mp3","charTypeName":"word"},{"id":18125,"position":13,"arabic":"ٱلْعَـٰلَمِينَ","translation":"সারা দুনিয়ার (মানুষের)","audioUrl":"wbw/045_016_013.mp3","charTypeName":"word"},{"id":18126,"position":14,"arabic":"١٦","translation":"(১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":17,"arabic":"وَءَاتَيْنَٰهُم بَيِّنَٰتٍۢ مِّنَ ٱلْأَمْرِ ۖ فَمَا ٱخْتَلَفُوٓا۟ إِلَّا مِنۢ بَعْدِ مَا جَآءَهُمُ ٱلْعِلْمُ بَغْيًۢا بَيْنَهُمْ ۚ إِنَّ رَبَّكَ يَقْضِى بَيْنَهُمْ يَوْمَ ٱلْقِيَٰمَةِ فِيمَا كَانُوا۟ فِيهِ يَخْتَلِفُونَ","translation":"And We gave them clear indications of the purpose [of faith]; and it was only after all this knowledge had been vouchsafed to them that they began, out of mutual jealousy, to hold divergent views: [but,] verily, thy Sustainer will judge be­tween them on Resurrection Day regarding all whereon they were wont to differ.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4490.mp3","surahId":45,"words":[{"id":19141,"position":1,"arabic":"وَءَاتَيْنَـٰهُم","translation":"এবং তাদেরকে আমরা দিয়েছি","audioUrl":"wbw/045_017_001.mp3","charTypeName":"word"},{"id":19142,"position":2,"arabic":"بَيِّنَـٰتٍۢ","translation":"সুস্পষ্ট প্রমাণ","audioUrl":"wbw/045_017_002.mp3","charTypeName":"word"},{"id":19143,"position":3,"arabic":"مِّنَ","translation":"সম্পর্কে","audioUrl":"wbw/045_017_003.mp3","charTypeName":"word"},{"id":19144,"position":4,"arabic":"ٱلْأَمْرِ ۖ","translation":"(দ্বীনের) নির্দেশ","audioUrl":"wbw/045_017_004.mp3","charTypeName":"word"},{"id":19146,"position":5,"arabic":"فَمَا","translation":"অতঃপর নি","audioUrl":"wbw/045_017_006.mp3","charTypeName":"word"},{"id":19147,"position":6,"arabic":"ٱخْتَلَفُوٓا۟","translation":"(মতবিরোধ করেছিল) বাড়াবাড়ি করে","audioUrl":"wbw/045_017_007.mp3","charTypeName":"word"},{"id":19148,"position":7,"arabic":"إِلَّا","translation":"কিন্তু","audioUrl":"wbw/045_017_008.mp3","charTypeName":"word"},{"id":19149,"position":8,"arabic":"مِنۢ","translation":"মধ্য হতে","audioUrl":"wbw/045_017_009.mp3","charTypeName":"word"},{"id":19150,"position":9,"arabic":"بَعْدِ","translation":"এরপরে","audioUrl":"wbw/045_017_010.mp3","charTypeName":"word"},{"id":19151,"position":10,"arabic":"مَا","translation":"যা","audioUrl":"wbw/045_017_011.mp3","charTypeName":"word"},{"id":19152,"position":11,"arabic":"جَآءَهُمُ","translation":"তাদের কাছে এসেছিল","audioUrl":"wbw/045_017_012.mp3","charTypeName":"word"},{"id":19153,"position":12,"arabic":"ٱلْعِلْمُ","translation":"(নির্ভুল) জ্ঞান","audioUrl":"wbw/045_017_013.mp3","charTypeName":"word"},{"id":19154,"position":13,"arabic":"بَغْيًۢا","translation":"বাড়াবাড়ি করে","audioUrl":"wbw/045_017_014.mp3","charTypeName":"word"},{"id":19155,"position":14,"arabic":"بَيْنَهُمْ ۚ","translation":"তাদের মাঝে","audioUrl":"wbw/045_017_015.mp3","charTypeName":"word"},{"id":19157,"position":15,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/045_017_017.mp3","charTypeName":"word"},{"id":19158,"position":16,"arabic":"رَبَّكَ","translation":"তোমার রব","audioUrl":"wbw/045_017_018.mp3","charTypeName":"word"},{"id":19159,"position":17,"arabic":"يَقْضِى","translation":"মীমাংসা করে দিবেন","audioUrl":"wbw/045_017_019.mp3","charTypeName":"word"},{"id":19160,"position":18,"arabic":"بَيْنَهُمْ","translation":"তাদের মাঝে","audioUrl":"wbw/045_017_020.mp3","charTypeName":"word"},{"id":19161,"position":19,"arabic":"يَوْمَ","translation":"দিনে","audioUrl":"wbw/045_017_021.mp3","charTypeName":"word"},{"id":19162,"position":20,"arabic":"ٱلْقِيَـٰمَةِ","translation":"কিয়ামতের","audioUrl":"wbw/045_017_022.mp3","charTypeName":"word"},{"id":19163,"position":21,"arabic":"فِيمَا","translation":"সে বিষয়ে","audioUrl":"wbw/045_017_023.mp3","charTypeName":"word"},{"id":19164,"position":22,"arabic":"كَانُوا۟","translation":"তারা ছিল","audioUrl":"wbw/045_017_024.mp3","charTypeName":"word"},{"id":19165,"position":23,"arabic":"فِيهِ","translation":"যার মধ্যে","audioUrl":"wbw/045_017_025.mp3","charTypeName":"word"},{"id":19166,"position":24,"arabic":"يَخْتَلِفُونَ","translation":"মতবিরোধ করত","audioUrl":"wbw/045_017_026.mp3","charTypeName":"word"},{"id":19167,"position":25,"arabic":"١٧","translation":"(১৭)","audioUrl":null,"charTypeName":"end"}]},{"number":18,"arabic":"ثُمَّ جَعَلْنَٰكَ عَلَىٰ شَرِيعَةٍۢ مِّنَ ٱلْأَمْرِ فَٱتَّبِعْهَا وَلَا تَتَّبِعْ أَهْوَآءَ ٱلَّذِينَ لَا يَعْلَمُونَ","translation":"And, finally, [O Muhammad,] We have set thee on a way by which the purpose [of faith] may be fulfilled: so follow thou this [way], and follow not the likes and dislikes of those who do not know [the truth].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4491.mp3","surahId":45,"words":[{"id":20255,"position":1,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/045_018_001.mp3","charTypeName":"word"},{"id":20256,"position":2,"arabic":"جَعَلْنَـٰكَ","translation":"তোমাকে আমরা প্রতিষ্ঠিত করেছি","audioUrl":"wbw/045_018_002.mp3","charTypeName":"word"},{"id":20257,"position":3,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/045_018_003.mp3","charTypeName":"word"},{"id":20258,"position":4,"arabic":"شَرِيعَةٍۢ","translation":"শরীয়তের","audioUrl":"wbw/045_018_004.mp3","charTypeName":"word"},{"id":20259,"position":5,"arabic":"مِّنَ","translation":"সম্পর্কিত","audioUrl":"wbw/045_018_005.mp3","charTypeName":"word"},{"id":20260,"position":6,"arabic":"ٱلْأَمْرِ","translation":"(দ্বীনের) নির্দেশ","audioUrl":"wbw/045_018_006.mp3","charTypeName":"word"},{"id":20261,"position":7,"arabic":"فَٱتَّبِعْهَا","translation":"তাই তার অনুসরণ করো","audioUrl":"wbw/045_018_007.mp3","charTypeName":"word"},{"id":20262,"position":8,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/045_018_008.mp3","charTypeName":"word"},{"id":20263,"position":9,"arabic":"تَتَّبِعْ","translation":"অনুসরণ করো","audioUrl":"wbw/045_018_009.mp3","charTypeName":"word"},{"id":20264,"position":10,"arabic":"أَهْوَآءَ","translation":"খেয়াল খুশির","audioUrl":"wbw/045_018_010.mp3","charTypeName":"word"},{"id":20265,"position":11,"arabic":"ٱلَّذِينَ","translation":"(তাদের) যারা","audioUrl":"wbw/045_018_011.mp3","charTypeName":"word"},{"id":20266,"position":12,"arabic":"لَا","translation":"না","audioUrl":"wbw/045_018_012.mp3","charTypeName":"word"},{"id":20267,"position":13,"arabic":"يَعْلَمُونَ","translation":"জানে","audioUrl":"wbw/045_018_013.mp3","charTypeName":"word"},{"id":20268,"position":14,"arabic":"١٨","translation":"(১৮)","audioUrl":null,"charTypeName":"end"}]},{"number":19,"arabic":"إِنَّهُمْ لَن يُغْنُوا۟ عَنكَ مِنَ ٱللَّهِ شَيْـًۭٔا ۚ وَإِنَّ ٱلظَّٰلِمِينَ بَعْضُهُمْ أَوْلِيَآءُ بَعْضٍۢ ۖ وَٱللَّهُ وَلِىُّ ٱلْمُتَّقِينَ","translation":"Behold, they could never be of any avail to thee if thou wert to defy the will of God for, verily, such evildoers are but friends and protectors of one another, whereas God is the Protector of all who are conscious of Him.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4492.mp3","surahId":45,"words":[{"id":21358,"position":1,"arabic":"إِنَّهُمْ","translation":"তারা নিশ্চয়ই","audioUrl":"wbw/045_019_001.mp3","charTypeName":"word"},{"id":21359,"position":2,"arabic":"لَن","translation":"কখনও না","audioUrl":"wbw/045_019_002.mp3","charTypeName":"word"},{"id":21360,"position":3,"arabic":"يُغْنُوا۟","translation":"তারা কাজে আসবে","audioUrl":"wbw/045_019_003.mp3","charTypeName":"word"},{"id":21361,"position":4,"arabic":"عَنكَ","translation":"তোমার জন্যে","audioUrl":"wbw/045_019_004.mp3","charTypeName":"word"},{"id":21362,"position":5,"arabic":"مِنَ","translation":"(পাকড়াও) হতে","audioUrl":"wbw/045_019_005.mp3","charTypeName":"word"},{"id":21363,"position":6,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/045_019_006.mp3","charTypeName":"word"},{"id":21364,"position":7,"arabic":"شَيْـًۭٔا ۚ","translation":"কিছুমাত্র","audioUrl":"wbw/045_019_007.mp3","charTypeName":"word"},{"id":21366,"position":8,"arabic":"وَإِنَّ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/045_019_009.mp3","charTypeName":"word"},{"id":21367,"position":9,"arabic":"ٱلظَّـٰلِمِينَ","translation":"সীমালঙ্ঘনকারীরা","audioUrl":"wbw/045_019_010.mp3","charTypeName":"word"},{"id":21368,"position":10,"arabic":"بَعْضُهُمْ","translation":"তাদের একে","audioUrl":"wbw/045_019_011.mp3","charTypeName":"word"},{"id":21369,"position":11,"arabic":"أَوْلِيَآءُ","translation":"বন্ধু","audioUrl":"wbw/045_019_012.mp3","charTypeName":"word"},{"id":21370,"position":12,"arabic":"بَعْضٍۢ ۖ","translation":"অপরের","audioUrl":"wbw/045_019_013.mp3","charTypeName":"word"},{"id":21372,"position":13,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/045_019_015.mp3","charTypeName":"word"},{"id":21373,"position":14,"arabic":"وَلِىُّ","translation":"বন্ধু","audioUrl":"wbw/045_019_016.mp3","charTypeName":"word"},{"id":21374,"position":15,"arabic":"ٱلْمُتَّقِينَ","translation":"মুত্তাকীদের","audioUrl":"wbw/045_019_017.mp3","charTypeName":"word"},{"id":21375,"position":16,"arabic":"١٩","translation":"(১৯)","audioUrl":null,"charTypeName":"end"}]},{"number":20,"arabic":"هَٰذَا بَصَٰٓئِرُ لِلنَّاسِ وَهُدًۭى وَرَحْمَةٌۭ لِّقَوْمٍۢ يُوقِنُونَ","translation":"This [revelation, then,] is a means of insight for mankind, and a guidance and grace unto people who are endowed with inner certainty.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4493.mp3","surahId":45,"words":[{"id":22408,"position":1,"arabic":"هَـٰذَا","translation":"এটা","audioUrl":"wbw/045_020_001.mp3","charTypeName":"word"},{"id":22409,"position":2,"arabic":"بَصَـٰٓئِرُ","translation":"(সঠিক পথের) আলো","audioUrl":"wbw/045_020_002.mp3","charTypeName":"word"},{"id":22410,"position":3,"arabic":"لِلنَّاسِ","translation":"সব লোকের জন্যে","audioUrl":"wbw/045_020_003.mp3","charTypeName":"word"},{"id":22411,"position":4,"arabic":"وَهُدًۭى","translation":"এবং পথনির্দেশ","audioUrl":"wbw/045_020_004.mp3","charTypeName":"word"},{"id":22412,"position":5,"arabic":"وَرَحْمَةٌۭ","translation":"ও অনুগ্রহ","audioUrl":"wbw/045_020_005.mp3","charTypeName":"word"},{"id":22413,"position":6,"arabic":"لِّقَوْمٍۢ","translation":"(এমন) লোকদের জন্যে","audioUrl":"wbw/045_020_006.mp3","charTypeName":"word"},{"id":22414,"position":7,"arabic":"يُوقِنُونَ","translation":"(যারা) দৃঢ় বিশ্বাস করে","audioUrl":"wbw/045_020_007.mp3","charTypeName":"word"},{"id":22415,"position":8,"arabic":"٢٠","translation":"(২০)","audioUrl":null,"charTypeName":"end"}]},{"number":21,"arabic":"أَمْ حَسِبَ ٱلَّذِينَ ٱجْتَرَحُوا۟ ٱلسَّيِّـَٔاتِ أَن نَّجْعَلَهُمْ كَٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ سَوَآءًۭ مَّحْيَاهُمْ وَمَمَاتُهُمْ ۚ سَآءَ مَا يَحْكُمُونَ","translation":"Now as for those who indulge in sinful doings - do they think that We place them, both in their life and their death, on an equal footing with those who have attained to faith and do righteous deeds? Bad, indeed, is their judgment:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4494.mp3","surahId":45,"words":[{"id":23539,"position":1,"arabic":"أَمْ","translation":"কি","audioUrl":"wbw/045_021_001.mp3","charTypeName":"word"},{"id":23540,"position":2,"arabic":"حَسِبَ","translation":"মনে করেছে","audioUrl":"wbw/045_021_002.mp3","charTypeName":"word"},{"id":23541,"position":3,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/045_021_003.mp3","charTypeName":"word"},{"id":23542,"position":4,"arabic":"ٱجْتَرَحُوا۟","translation":"লিপ্ত রয়েছে","audioUrl":"wbw/045_021_004.mp3","charTypeName":"word"},{"id":23543,"position":5,"arabic":"ٱلسَّيِّـَٔاتِ","translation":"পাপকাজ","audioUrl":"wbw/045_021_005.mp3","charTypeName":"word"},{"id":23544,"position":6,"arabic":"أَن","translation":"যে","audioUrl":"wbw/045_021_006.mp3","charTypeName":"word"},{"id":23545,"position":7,"arabic":"نَّجْعَلَهُمْ","translation":"তাদেরকে করব আমরা","audioUrl":"wbw/045_021_007.mp3","charTypeName":"word"},{"id":23546,"position":8,"arabic":"كَٱلَّذِينَ","translation":"(তাদের) মতো যারা","audioUrl":"wbw/045_021_008.mp3","charTypeName":"word"},{"id":23547,"position":9,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/045_021_009.mp3","charTypeName":"word"},{"id":23548,"position":10,"arabic":"وَعَمِلُوا۟","translation":"ও কাজ করেছে","audioUrl":"wbw/045_021_010.mp3","charTypeName":"word"},{"id":23549,"position":11,"arabic":"ٱلصَّـٰلِحَـٰتِ","translation":"সৎ","audioUrl":"wbw/045_021_011.mp3","charTypeName":"word"},{"id":23550,"position":12,"arabic":"سَوَآءًۭ","translation":"(উভয়ে) সমান","audioUrl":"wbw/045_021_012.mp3","charTypeName":"word"},{"id":23551,"position":13,"arabic":"مَّحْيَاهُمْ","translation":"তাদের জীবন","audioUrl":"wbw/045_021_013.mp3","charTypeName":"word"},{"id":23552,"position":14,"arabic":"وَمَمَاتُهُمْ ۚ","translation":"ও তাদের মৃত্যু (এক রকম হবে)","audioUrl":"wbw/045_021_014.mp3","charTypeName":"word"},{"id":23554,"position":15,"arabic":"سَآءَ","translation":"কত মন্দ","audioUrl":"wbw/045_021_016.mp3","charTypeName":"word"},{"id":23555,"position":16,"arabic":"مَا","translation":"যা","audioUrl":"wbw/045_021_017.mp3","charTypeName":"word"},{"id":23556,"position":17,"arabic":"يَحْكُمُونَ","translation":"তারা মীমাংসা করে","audioUrl":"wbw/045_021_018.mp3","charTypeName":"word"},{"id":23557,"position":18,"arabic":"٢١","translation":"(২১)","audioUrl":null,"charTypeName":"end"}]},{"number":22,"arabic":"وَخَلَقَ ٱللَّهُ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضَ بِٱلْحَقِّ وَلِتُجْزَىٰ كُلُّ نَفْسٍۭ بِمَا كَسَبَتْ وَهُمْ لَا يُظْلَمُونَ","translation":"for, God has created the heavens and the earth in accordance with [an inner] truth, and [has therefore willed] that every human being shall be recompensed for what he has earned and none shall be wronged.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4495.mp3","surahId":45,"words":[{"id":24575,"position":1,"arabic":"وَخَلَقَ","translation":"এবং সৃষ্টি করেছেন","audioUrl":"wbw/045_022_001.mp3","charTypeName":"word"},{"id":24576,"position":2,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/045_022_002.mp3","charTypeName":"word"},{"id":24577,"position":3,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশ","audioUrl":"wbw/045_022_003.mp3","charTypeName":"word"},{"id":24578,"position":4,"arabic":"وَٱلْأَرْضَ","translation":"ও পৃথিবী","audioUrl":"wbw/045_022_004.mp3","charTypeName":"word"},{"id":24579,"position":5,"arabic":"بِٱلْحَقِّ","translation":"যথাযথভাবে","audioUrl":"wbw/045_022_005.mp3","charTypeName":"word"},{"id":24580,"position":6,"arabic":"وَلِتُجْزَىٰ","translation":"এবং যেন প্রতিদান দেওয়া যায়","audioUrl":"wbw/045_022_006.mp3","charTypeName":"word"},{"id":24581,"position":7,"arabic":"كُلُّ","translation":"প্রত্যেক","audioUrl":"wbw/045_022_007.mp3","charTypeName":"word"},{"id":24582,"position":8,"arabic":"نَفْسٍۭ","translation":"ব্যক্তিকে","audioUrl":"wbw/045_022_008.mp3","charTypeName":"word"},{"id":24583,"position":9,"arabic":"بِمَا","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/045_022_009.mp3","charTypeName":"word"},{"id":24584,"position":10,"arabic":"كَسَبَتْ","translation":"সে অর্জন করেছে","audioUrl":"wbw/045_022_010.mp3","charTypeName":"word"},{"id":24585,"position":11,"arabic":"وَهُمْ","translation":"এবং তাদের (উপর)","audioUrl":"wbw/045_022_011.mp3","charTypeName":"word"},{"id":24586,"position":12,"arabic":"لَا","translation":"না","audioUrl":"wbw/045_022_012.mp3","charTypeName":"word"},{"id":24587,"position":13,"arabic":"يُظْلَمُونَ","translation":"যুলুম করা হবে","audioUrl":"wbw/045_022_013.mp3","charTypeName":"word"},{"id":24588,"position":14,"arabic":"٢٢","translation":"(২২)","audioUrl":null,"charTypeName":"end"}]}]}