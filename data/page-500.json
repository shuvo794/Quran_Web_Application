{"id":500,"ayahs":[{"number":14,"arabic":"قُل لِّلَّذِينَ ءَامَنُوا۟ يَغْفِرُوا۟ لِلَّذِينَ لَا يَرْجُونَ أَيَّامَ ٱللَّهِ لِيَجْزِىَ قَوْمًۢا بِمَا كَانُوا۟ يَكْسِبُونَ","translation":"Tell all who have attained to faith that they should forgive those who do not believe in the com­ing of the Days of God, [since it is] for Him [alone] to requite people for whatever they may have earned.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4487.mp3","surahId":45,"words":[{"id":15887,"position":1,"arabic":"قُل","translation":"(হে নাবী) বলো","audioUrl":"wbw/045_014_001.mp3","charTypeName":"word"},{"id":15888,"position":2,"arabic":"لِّلَّذِينَ","translation":"(তাদের)-কে যারা","audioUrl":"wbw/045_014_002.mp3","charTypeName":"word"},{"id":15889,"position":3,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/045_014_003.mp3","charTypeName":"word"},{"id":15890,"position":4,"arabic":"يَغْفِرُوا۟","translation":"তারা যেন ক্ষমা করে","audioUrl":"wbw/045_014_004.mp3","charTypeName":"word"},{"id":15891,"position":5,"arabic":"لِلَّذِينَ","translation":"(তাদের)-কে যারা","audioUrl":"wbw/045_014_005.mp3","charTypeName":"word"},{"id":15892,"position":6,"arabic":"لَا","translation":"না","audioUrl":"wbw/045_014_006.mp3","charTypeName":"word"},{"id":15893,"position":7,"arabic":"يَرْجُونَ","translation":"প্রত্যাশা করে","audioUrl":"wbw/045_014_007.mp3","charTypeName":"word"},{"id":15894,"position":8,"arabic":"أَيَّامَ","translation":"(খারাপ) দিনগুলোর","audioUrl":"wbw/045_014_008.mp3","charTypeName":"word"},{"id":15895,"position":9,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/045_014_009.mp3","charTypeName":"word"},{"id":15896,"position":10,"arabic":"لِيَجْزِىَ","translation":"যেন প্রতিদান দেন তিনি","audioUrl":"wbw/045_014_010.mp3","charTypeName":"word"},{"id":15897,"position":11,"arabic":"قَوْمًۢا","translation":"লোকদেরকে","audioUrl":"wbw/045_014_011.mp3","charTypeName":"word"},{"id":15898,"position":12,"arabic":"بِمَا","translation":"এ বিষয়ে যা","a