{"id":526,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلنَّجْمِ إِذَا هَوَىٰ","translation":"CONSIDER this unfolding [of God’s message], as it comes down from on high!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4785.mp3","surahId":53,"words":[{"id":280,"position":1,"arabic":"وَٱلنَّجْمِ","translation":"শপথ তারকার","audioUrl":"wbw/053_001_001.mp3","charTypeName":"word"},{"id":281,"position":2,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/053_001_002.mp3","charTypeName":"word"},{"id":282,"position":3,"arabic":"هَوَىٰ","translation":"অস্তমিত হয়","audioUrl":"wbw/053_001_003.mp3","charTypeName":"word"},{"id":283,"position":4,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"مَا ضَلَّ صَاحِبُكُمْ وَمَا غَوَىٰ","translation":"This fellow-man of yours has not gone astray, nor is he deluded,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4786.mp3","surahId":53,"words":[{"id":1162,"position":1,"arabic":"مَا","translation":"না","audioUrl":"wbw/053_002_001.mp3","charTypeName":"word"},{"id":1163,"position":2,"arabic":"ضَلَّ","translation":"পথভ্রষ্ট হয়েছে","audioUrl":"wbw/053_002_002.mp3","charTypeName":"word"},{"id":1164,"position":3,"arabic":"صَاحِبُكُمْ","translation":"তোমাদের সঙ্গী","audioUrl":"wbw/053_002_003.mp3","charTypeName":"word"},{"id":1165,"position":4,"arabic":"وَمَا","translation":"আর না","audioUrl":"wbw/053_002_004.mp3","charTypeName":"word"},{"id":1166,"position":5,"arabic":"غَوَىٰ","translation":"বিপথগামী হয়েছে","audioUrl":"wbw/053_002_005.mp3","charTypeName":"word"},{"id":1167,"position":6,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"وَمَا يَنطِقُ عَنِ ٱلْهَوَىٰٓ","translation":"and neither does he speak out of his own desire:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4787.mp3","surahId":53,"words":[{"id":2208,"position":1,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/053_003_001.mp3","charTypeName":"word"},{"id":2209,"position":2,"arabic":"يَنطِقُ","translation":"সে কথা বলে","audioUrl":"wbw/053_003_002.mp3","charTypeName":"word"},{"id":2210,"position":3,"arabic":"عَنِ","translation":"হতে","audioUrl":"wbw/053_003_003.mp3","charTypeName":"word"},{"id":2211,"position":4,"arabic":"ٱلْهَوَىٰٓ","translation":"প্রবৃত্তির তাড়না","audioUrl":"wbw/053_003_004.mp3","charTypeName":"word"},{"id":2212,"position":5,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"إِنْ هُوَ إِلَّا وَحْىٌۭ يُوحَىٰ","translation":"that [which he conveys to you] is but [a divine] inspiration with which he is being inspired –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4788.mp3","surahId":53,"words":[{"id":3538,"position":1,"arabic":"إِنْ","translation":"নয়","audioUrl":"wbw/053_004_001.mp3","charTypeName":"word"},{"id":3539,"position":2,"arabic":"هُوَ","translation":"তা","audioUrl":"wbw/053_004_002.mp3","charTypeName":"word"},{"id":3540,"position":3,"arabic":"إِلَّا","translation":"এছাড়া","audioUrl":"wbw/053_004_003.mp3","charTypeName":"word"},{"id":3541,"position":4,"arabic":"وَحْىٌۭ","translation":"ওহী","audioUrl":"wbw/053_004_004.mp3","charTypeName":"word"},{"id":3542,"position":5,"arabic":"يُوحَىٰ","translation":"অবতীর্ণ করা হয় (যা)","audioUrl":"wbw/053_004_005.mp3","charTypeName":"word"},{"id":3543,"position":6,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"عَلَّمَهُۥ شَدِيدُ ٱلْقُوَىٰ","translation":"something that a very mighty one has imparted to him:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4789.mp3","surahId":53,"words":[{"id":4898,"position":1,"arabic":"عَلَّمَهُۥ","translation":"তাকে শিক্ষা দিয়েছে","audioUrl":"wbw/053_005_001.mp3","charTypeName":"word"},{"id":4899,"position":2,"arabic":"شَدِيدُ","translation":"(জিবরাইল) অত্যন্তপ্রবল","audioUrl":"wbw/053_005_002.mp3","charTypeName":"word"},{"id":4900,"position":3,"arabic":"ٱلْقُوَىٰ","translation":"শক্তিতে","audioUrl":"wbw/053_005_003.mp3","charTypeName":"word"},{"id":4901,"position":4,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"ذُو مِرَّةٍۢ فَٱسْتَوَىٰ","translation":"[an angel] endowed with sur­passing power, who in time manifested himself in his true shape and nature,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4790.mp3","surahId":53,"words":[{"id":6144,"position":1,"arabic":"ذُو","translation":"আছে","audioUrl":"wbw/053_006_001.mp3","charTypeName":"word"},{"id":6145,"position":2,"arabic":"مِرَّةٍۢ","translation":"কৌশলসম্পন্ন","audioUrl":"wbw/053_006_002.mp3","charTypeName":"word"},{"id":6146,"position":3,"arabic":"فَٱسْتَوَىٰ","translation":"অতঃপর সে স্থির হয়ে (দাঁড়িয়ে) ছিল","audioUrl":"wbw/053_006_003.mp3","charTypeName":"word"},{"id":6147,"position":4,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"وَهُوَ بِٱلْأُفُقِ ٱلْأَعْلَىٰ","translation":"appearing in the horizon’s loftiest part,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4791.mp3","surahId":53,"words":[{"id":7482,"position":1,"arabic":"وَهُوَ","translation":"এমতাবস্থায় সে (ছিল)","audioUrl":"wbw/053_007_001.mp3","charTypeName":"word"},{"id":7483,"position":2,"arabic":"بِٱلْأُفُقِ","translation":"দিগন্তে","audioUrl":"wbw/053_007_002.mp3","charTypeName":"word"},{"id":7484,"position":3,"arabic":"ٱلْأَعْلَىٰ","translation":"ঊর্ধ্ব","audioUrl":"wbw/053_007_003.mp3","charTypeName":"word"},{"id":7485,"position":4,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"ثُمَّ دَنَا فَتَدَلَّىٰ","translation":"and then drew near, and came close,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4792.mp3","surahId":53,"words":[{"id":8727,"position":1,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/053_008_001.mp3","charTypeName":"word"},{"id":8728,"position":2,"arabic":"دَنَا