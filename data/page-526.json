া","audioUrl":"wbw/053_010_004.mp3","charTypeName":"word"},{"id":11159,"position":5,"arabic":"أَوْحَىٰ","translation":"ওহী পৌঁছানোর","audioUrl":"wbw/053_010_005.mp3","charTypeName":"word"},{"id":11160,"position":6,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"مَا كَذَبَ ٱلْفُؤَادُ مَا رَأَىٰٓ","translation":"The [servant’s] heart did not give the lie to what he saw:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4795.mp3","surahId":53,"words":[{"id":12481,"position":1,"arabic":"مَا","translation":"না","audioUrl":"wbw/053_011_001.mp3","charTypeName":"word"},{"id":12482,"position":2,"arabic":"كَذَبَ","translation":"মিথ্যা বলেছে","audioUrl":"wbw/053_011_002.mp3","charTypeName":"word"},{"id":12483,"position":3,"arabic":"ٱلْفُؤَادُ","translation":"(তার) অন্তর","audioUrl":"wbw/053_011_003.mp3","charTypeName":"word"},{"id":12484,"position":4,"arabic":"مَا","translation":"যা","audioUrl":"wbw/053_011_004.mp3","charTypeName":"word"},{"id":12485,"position":5,"arabic":"رَأَىٰٓ","translation":"সে দেখেছে","audioUrl":"wbw/053_011_005.mp3","charTypeName":"word"},{"id":12486,"position":6,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]},{"number":12,"arabic":"أَفَتُمَٰرُونَهُۥ عَلَىٰ مَا يَرَىٰ","translation":"will you, then, contend with him as to what he saw?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4796.mp3","surahId":53,"words":[{"id":13797,"position":1,"arabic":"أَفَتُمَـٰرُونَهُۥ","translation":"তার সাথে তোমরা এখন কি তর্ক করছ","audioUrl":"wbw/053_012_001.mp3","charTypeName":"word"},{"id":13798,"position":2,"arabic":"عَلَىٰ","translation":"(তার) উপর","audioUrl":"wbw/053_012_002.mp3","charTypeName":"word"},{"id":13799,"position":3,"arabic":"مَا","translation":"যা","audioUrl":"wbw/053_012_003.mp3","charTypeName":"word"},{"id":13800,"position":4,"arabic":"يَرَىٰ","translation":"সে দেখেছে","audioUrl":"wbw/053_012_004.mp3","charTypeName":"word"},{"id":13801,"positio