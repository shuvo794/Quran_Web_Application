{"id":80490,"position":24,"arabic":"ٱبْنَ","translation":"\"ছেলে","audioUrl":"wbw/007_150_027.mp3","charTypeName":"word"},{"id":80491,"position":25,"arabic":"أُمَّ","translation":"মায়ের (অর্থাৎ হে ভাই)","audioUrl":"wbw/007_150_028.mp3","charTypeName":"word"},{"id":80492,"position":26,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/007_150_029.mp3","charTypeName":"word"},{"id":80493,"position":27,"arabic":"ٱلْقَوْمَ","translation":"এ জাতি","audioUrl":"wbw/007_150_030.mp3","charTypeName":"word"},{"id":80494,"position":28,"arabic":"ٱسْتَضْعَفُونِى","translation":"আমাকে দুর্বল মনে করেছিলো","audioUrl":"wbw/007_150_031.mp3","charTypeName":"word"},{"id":80495,"position":29,"arabic":"وَكَادُوا۟","translation":"ও উপক্রম হয়েছিলো","audioUrl":"wbw/007_150_032.mp3","charTypeName":"word"},{"id":80496,"position":30,"arabic":"يَقْتُلُونَنِى","translation":"আমাকে তারা হত্যা করবে","audioUrl":"wbw/007_150_033.mp3","charTypeName":"word"},{"id":80497,"position":31,"arabic":"فَلَا","translation":"অতএব না","audioUrl":"wbw/007_150_034.mp3","charTypeName":"word"},{"id":80498,"position":32,"arabic":"تُشْمِتْ","translation":"হাসতে দিও","audioUrl":"wbw/007_150_035.mp3","charTypeName":"word"},{"id":80499,"position":33,"arabic":"بِىَ","translation":"উপর আমার","audioUrl":"wbw/007_150_036.mp3","charTypeName":"word"},{"id":80500,"position":34,"arabic":"ٱلْأَعْدَآءَ","translation":"শত্রুদেরকে","audioUrl":"wbw/007_150_037.mp3","charTypeName":"word"},{"id":80501,"position":35,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/007_150_038.mp3","charTypeName":"word"},{"id":80502,"position":36,"arabic":"تَجْعَلْنِى","translation":"আমাকে গণ্য করো","audioUrl":"wbw/007_150_039.mp3","charTypeName":"word"},{"id":80503,"position":37,"arabic":"مَعَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/007_150_040.mp3","charTypeName":"word"},{"id":80504,"position":38,"arabic":"ٱلْقَوْمِ","translation":"সম্প্রদায়ের\"","audioUrl":"wbw/007_150_041.mp3","charTypeName":"word"},{"id":80505,"position":39,"arabic":"ٱلظَّـٰلِمِينَ","translation":"সীমালঙ্ঘনকারী\"","audioUrl":"wbw/007_150_042.mp3","charTypeName":"word"},{"id":80506,"position":40,"arabic":"١٥٠","translation":"(১৫০)","audioUrl":null,"charTypeName":"end"}]},{"number":151,"arabic":"قَالَ رَبِّ ٱغْفِرْ لِى وَلِأَخِى وَأَدْخِلْنَا فِى رَحْمَتِكَ ۖ وَأَنتَ أَرْحَمُ ٱلرَّٰحِمِينَ","translation":"Said [Moses]: \"O my Sustainer! Grant Thou forgiveness unto me and my brother, and admit us unto Thy grace: for Thou art the most merciful of the merciful!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1105.mp3","surahId":7,"words":[{"id":80604,"position":1,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/007_151_001.mp3","charTypeName":"word"},{"id":80605,"position":2,"arabic":"رَبِّ","translation":"\"হে আমার রব","audioUrl":"wbw/007_151_002.mp3","charTypeName":"word"},{"id":80606,"position":3,"arabic":"ٱغْفِرْ","translation":"ক্ষমা করো","audioUrl":"wbw/007_151_003.mp3","charTypeName":"word"},{"id":80607,"position":4,"arabic":"لِى","translation":"আমাকে","audioUrl":"wbw/007_151_004.mp3","charTypeName":"word"},{"id":80608,"position":5,"arabic":"وَلِأَخِى","translation":"ও আমার ভাইকে","audioUrl":"wbw/007_151_005.mp3","charTypeName":"word"},{"id":80609,"position":6,"arabic":"وَأَدْخِلْنَا","translation":"ও প্রবেশ করাও আমাদের","audioUrl":"wbw/007_151_006.mp3","charTypeName":"word"},{"id":80610,"position":7,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/007_151_007.mp3","charTypeName":"word"},{"id":80611,"position":8,"arabic":"رَحْمَتِكَ ۖ","translation":"তোমার অনুগ্রহের","audioUrl":"wbw/007_151_008.mp3","charTypeName":"word"},{"id":80613,"position":9,"arabic":"وَأَنتَ","translation":"এবং তুমিই","audioUrl":"wbw/007_151_010.mp3","charTypeName":"word"},{"id":80614,"position":10,"arabic":"أَرْحَمُ","translation":"শ্রেষ্ঠ দয়াবান","audioUrl":"wbw/007_151_011.mp3","charTypeName":"word"},{"id":80615,"position":11,"arabic":"ٱلرَّٰحِمِينَ","translation":"দয়াবানদের\"","audioUrl":"wbw/007_151_012.mp3","charTypeName":"word"},{"id":80616,"position":12,"arabic":"١٥١","translation":"(১৫১)","audioUrl":null,"charTypeName":"end"}]},{"number":152,"arabic":"إِنَّ ٱلَّذِينَ ٱتَّخَذُوا۟ ٱلْعِجْلَ سَيَنَالُهُمْ غَضَبٌۭ مِّن رَّبِّهِمْ وَذِلَّةٌۭ فِى ٱلْحَيَوٰةِ ٱلدُّنْيَا ۚ وَكَذَٰلِكَ نَجْزِى ٱلْمُفْتَرِينَ","translation":"[And to Aaron he said:] \"Verily, as for those who have taken to worshipping the [golden] - calf - their Sustainer's condemnation will overtake them, and ignominy [will be their lot] in the -life of this world!\" For thus do We requite all who invent [such] falsehood.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1106.mp3","surahId":7,"words":[{"id":80757,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/007_152_001.mp3","charTypeName":"word"},{"id":80758,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/007_152_002.mp3","charTypeName":"word"},{"id":80759,"position":3,"arabic":"ٱتَّخَذُوا۟","translation":"গ্রহণ করেছিলো","audioUrl":"wbw/007_152_003.mp3","charTypeName":"word"},{"id":80760,"position":4,"arabic":"ٱلْعِجْلَ","translation":"বাছুরকে (উপাস্যরূপে)","audioUrl":"wbw/007_152_004.mp3","charTypeName":"word"},{"id":80761,"position":5,"arabic":"سَيَنَالُهُمْ","translation":"শীঘ্রই তাদের উপর পড়বে","audioUrl":"wbw/007_152_005.mp3","charTypeName":"word"},{"id":80762,"position":6,"arabic":"غَضَبٌۭ","translation":"রাগ","audioUrl":"wbw/007_152_006.mp3","charTypeName":"word"},{"id":80763,"position":7,"arabic":"مِّن","translation":"পক্ষ হতে","audioUrl":"wbw/007_152_007.mp3","charTypeName":"word"},{"id":80764,"position":8,"arabic":"رَّبِّهِمْ","translation":"রবের তাদের","audioUrl":"wbw/007_152_008.mp3","charTypeName":"word"},{"id":80765,"position":9,"arabic":"وَذِلَّةٌۭ","translation":"এবং লাঞ্ছনা","audioUrl":"wbw/007_152_009.mp3","charTypeName":"word"},{"id":80766,"position":10,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/007_152_010.mp3","charTypeName":"word"},{"id":80767,"position":11,"arabic":"