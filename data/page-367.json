{"id":367,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ طسٓمٓ","translation":"Ta. Sin, Mim.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2933.mp3","surahId":26,"words":[{"id":710,"position":1,"arabic":"طسٓمٓ","translation":"ত্বা-সীন-মীম","audioUrl":"wbw/026_001_001.mp3","charTypeName":"word"},{"id":711,"position":2,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"تِلْكَ ءَايَٰتُ ٱلْكِتَٰبِ ٱلْمُبِينِ","translation":"THESE ARE MESSAGES of the divine writ, clear in itself and clearly showing the truth!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2934.mp3","surahId":26,"words":[{"id":1769,"position":1,"arabic":"تِلْكَ","translation":"এই","audioUrl":"wbw/026_002_001.mp3","charTypeName":"word"},{"id":1770,"position":2,"arabic":"ءَايَـٰتُ","translation":"আয়াতগুলো","audioUrl":"wbw/026_002_002.mp3","charTypeName":"word"},{"id":1771,"position":3,"arabic":"ٱلْكِتَـٰبِ","translation":"কিতাবের","audioUrl":"wbw/026_002_003.mp3","charTypeName":"word"},{"id":1772,"position":4,"arabic":"ٱلْمُبِينِ","translation":"(যা) সুস্পষ্ট","audioUrl":"wbw/026_002_004.mp3","charTypeName":"word"},{"id":1773,"position":5,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"لَعَلَّكَ بَٰخِعٌۭ نَّفْسَكَ أَلَّا يَكُونُوا۟ مُؤْمِنِينَ","translation":"Wouldst thou, perhaps, torment thyself to death [with grief] because they [who live around thee] refuse to believe [in it]?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2935.mp3","surahId":26,"words":[{"id":2807,"position":1,"arabic":"لَعَلَّكَ","translation":"হয়তো তুমি (হে নাবী)","audioUrl":"wbw/026_003_001.mp3","charTypeName":"word"},{"id":2808,"position":2,"arabic":"بَـٰخِعٌۭ","translation":"ধ্বংসকারী","audioUrl":"wbw/026_003_002.mp3","charTypeName":"word"},{"id":2809,"position":3,"arabic":"نَّفْسَكَ","translation":"তোমার প্রাণ (এ চিন্তায়)","audioUrl":"wbw/026_003_003.mp3","charTypeName":"word"},{"id":2810,"position":4,"arabic":"أَلَّا","translation":"যে না","audioUrl":"wbw/026_003_004.mp3","charTypeName":"word"},{"id":2811,"position":5,"arabic":"يَكُونُوا۟","translation":"তারা হচ্ছে","audioUrl":"wbw/026_003_005.mp3","charTypeName":"word"},{"id":2812,"position":6,"arabic":"مُؤْمِنِينَ","translation":"মু'মিন","audioUrl":"wbw/026_003_006.mp3","charTypeName":"word"},{"id":2813,"position":7,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"إِن نَّشَأْ نُنَزِّلْ عَلَيْهِم مِّنَ ٱلسَّمَآءِ ءَايَةًۭ فَظَلَّتْ أَعْنَٰقُهُمْ لَهَا خَٰضِعِينَ","translation":"Had We so willed, We could have sent down unto them a message from the skies, so that their necks would [be forced to] bow down before it in humility.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2936.mp3","surahId":26,"words":[{"id":3727,"position":1,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/026_004_001.mp3","charTypeName":"word"},{"id":3728,"position":2,"arabic":"نَّشَأْ","translation":"আমরা চাইতাম","audioUrl":"wbw/026_004_002.mp3","charTypeName":"word"},{"id":3729,"position":3,"arabic":"نُنَزِّلْ","translation":"অবতীর্ণ করতাম আমরা","audioUrl":"wbw/026_004_003.mp3","charTypeName":"word"},{"id":3730,"position":4,"arabic":"عَلَيْهِم","translation":"উপর তাদের","audioUrl":"wbw/026_004_004.mp3","charTypeName":"word"},{"id":3731,"position":5,"arabic":"مِّنَ","translation":"হ'তে","audioUrl":"wbw/026_004_005.mp3","charTypeName":"word"},{"id":3732,"position":6,"arabic":"ٱلسَّمَآءِ","translation":"আকাশ","audioUrl":"wbw/026_004_006.mp3","charTypeName":"word"},{"id":3733,"position":7,"arabic":"ءَايَةًۭ","translation":"(এমন) কোনো নিদর্শন","audioUrl":"wbw/026_004_007.mp3","charTypeName":"word"},{"id":3734,"position":8,"arabic":"فَظَلَّتْ","translation":"ফলে হয়ে পড়তো","audioUrl":"wbw/026_004_008.mp3","charTypeName":"word"},{"id":3735,"position":9,"arabic":"أَعْنَـٰقُهُمْ","translation":"ঘাড়গুলো তাদের","audioUrl":"wbw/026_004_009.mp3","charTypeName":"word"},{"id":3736,"position":10,"arabic":"لَهَا","translation":"প্রতি তাঁর","audioUrl":"wbw/026_004_010.mp3","charTypeName":"word"},{"id":3737,"position":11,"arabic":"خَـٰضِعِينَ","translation":"অবনত","audioUrl":"wbw/026_004_011.mp3","charTypeName":"word"},{"id":3738,"position":12,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"وَمَا يَأْتِيهِم مِّن ذِكْرٍۢ مِّنَ ٱلرَّحْمَٰنِ مُحْدَثٍ إِلَّا كَانُوا۟ عَنْهُ مُعْرِضِينَ","translation":"[But We have not willed it:] and so, whenever there comes unto them any fresh reminder from the Most Gracious, they [who are blind of heart] always - turn their backs upon it:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2937.mp3","surahId":26,"words":[{"id":4698,"position":1,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/026_005_001.mp3","charTypeName":"word"},{"id":4699,"position":2,"arabic":"يَأْتِيهِم","translation":"আসে তাদের (কাছে)","audioUrl":"wbw/026_005_002.mp3","charTypeName":"word"},{"id":4700,"position":3,"arabic":"مِّن","translation":"কোনো","audioUrl":"wbw/026_005_003.mp3","charTypeName":"word"},{"id":4701,"position":4,"arabic":"ذِكْرٍۢ","translation":"উপদেশ","audioUrl":"wbw/026_005_004.mp3","charTypeName":"word"},{"id":4702,"position":5,"arabic":"مِّنَ","translation":"হ'তে","audioUrl":"wbw/026_005_005.mp3","charTypeName":"word"},{"id":4703,"position":6,"arabic":"ٱلرَّحْمَـٰنِ","translation":"দয়াময়","audioUrl":"wbw/026_005_006.mp3","charTypeName":"word"},{"id":4704,"position":7,"arabic":"مُحْدَثٍ","translation":"(উপদেশ) নতুন","audioUrl":"wbw/026_005_007.mp3","charTypeName":"word"},{"id":4705,"position":8,"arabic":"إِلَّا","translation":"এ ছাড়া যে","audioUrl":"wbw/026_005_008.mp3","charTypeName":"word"},{"id":4706,"position":9,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/026_005_009.mp3","charTypeName":"word"},{"id":4707,"position":10,"arabic":"عَنْهُ","translation":"তা হতে","audioUrl":"wbw/026_005_010.mp3","charTypeName":"word"},{"id":4708,"position":11,"arabic":"مُعْرِضِينَ","translation":"মুখ ফিরিয়ে নিতো","audioUrl":"wbw/026_005_011.mp3","charTypeName":"word"},{"id":4709,"position":12,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"فَقَدْ كَذَّبُوا۟ فَسَيَأْتِيهِمْ أَنۢبَٰٓؤُا۟ مَا كَانُوا۟ بِهِۦ يَسْتَهْزِءُونَ","translation":"thus, indeed, have they given the lie (to this message as well). But [in time] they will come to understand what it was that they were wont to deride!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2938.mp3","surahId":26,"words":[{"id":5968,"position":1,"arabic":"فَقَدْ","translation":"এখন নিশ্চয়ই","audioUrl":"wbw/026_006_001.mp3","charTypeName":"word"},{"id":5969,"position":2,"arabic":"كَذَّبُوا۟","translation":"তারা মিথ্যারোপ করেছে","audioUrl":"wbw/026_006_002.mp3","charTypeName":"word"},{"id":5970,"position":3,"arabic":"فَسَيَأْتِيهِمْ","translation":"সুতরাং শীঘ্রই আসবে তাদের (কাছে)","audioUrl":"wbw/026_006_003.mp3","charTypeName":"word"},{"id":5971,"position":4,"arabic":"أَنۢبَـٰٓؤُا۟","translation":"সংবাদ","audioUrl":"wbw/026_006_004.mp3","charTypeName":"word"},{"id":5972,"position":5,"arabic":"مَا","translation":"যা কিছু","audioUrl":"wbw/026_006_005.mp3","charTypeName":"word"},{"id":5973,"position":6,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/026_006_006.mp3","charTypeName":"word"},{"id":5974,"position":7,"arabic":"بِهِۦ","translation":"সম্পর্কে সে","audioUrl":"wbw/026_006_007.mp3","charTypeName":"word"},{"id":5975,"position":8,"arabic":"يَسْتَهْزِءُونَ","translation":"ঠাট্টা-বিদ্রুপ করতো","audioUrl":"wbw/026_006_008.mp3","charTypeName":"word"},{"id":5976,"position":9,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"أَوَلَمْ يَرَوْا۟ إِلَى ٱلْأَرْضِ كَمْ أَنۢبَتْنَا فِيهَا مِن كُلِّ زَوْجٍۢ كَرِيمٍ","translation":"Have they, then, never considered the earth - how much of every noble kind [of life] We have caused to grow thereon?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2939.mp3","surahId":26,"words":[{"id":7192,"position":1,"arabic":"أَوَلَمْ","translation":"কি নি","audioUrl":"wbw/026_007_001.mp3","charTypeName":"word"},{"id":7193,"position":2,"arabic":"يَرَوْا۟","translation":"তারা লক্ষ্য করে","audioUrl":"wbw/026_007_002.mp3","charTypeName":"word"},{"id":7194,"position":3,"arabic":"إِلَى","translation":"প্রতি","audioUrl":"wbw/026_007_003.mp3","charTypeName":"word"},{"id":7195,"position":4,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/026_007_004.mp3","charTypeName":"word"},{"id":7196,"position":5,"arabic":"كَمْ","translation":"কত (বিপুল পরিমাণ)","audioUrl":"wbw/026_007_005.mp3","charTypeName":"word"},{"id":7197,"position":6,"arabic":"أَنۢبَتْنَا","translation":"উদ্গত করেছি আমরা","audioUrl":"wbw/026_007_006.mp3","charTypeName":"word"},{"id":7198,"position":7,"arabic":"فِيهَا","translation":"মধ্যে তার","audioUrl":"wbw/026_007_007.mp3","charTypeName":"word"},{"id":7199,"position":8,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/026_007_008.mp3","charTypeName":"word"},{"id":7200,"position":9,"arabic":"كُلِّ","translation":"প্রত্যেক","audioUrl":"wbw/026_007_009.mp3","charTypeName":"word"},{"id":7201,"position":10,"arabic":"زَوْجٍۢ","translation":"প্রকার (উদ্ভিদ)","audioUrl":"wbw/026_007_010.mp3","charTypeName":"word"},{"id":7202,"position":11,"arabic":"كَرِيمٍ","translation":"চমৎকার","audioUrl":"wbw/026_007_011.mp3","charTypeName":"word"},{"id":7203,"position":12,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"إِنَّ فِى ذَٰلِكَ لَءَايَةًۭ ۖ وَمَا كَانَ أَكْثَرُهُم مُّؤْمِنِينَ","translation":"In this, behold, there is a message [unto men], even though most of them will not believe [in it].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2940.mp3","surahId":26,"words":[{"id":9266,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/026_008_001.mp3","charTypeName":"word"},{"id":9267,"position":2,"arabic":"فِى","translation":"মধ্যে (রয়েছে)","audioUrl":"wbw/026_008_002.mp3","charTypeName":"word"},{"id":9268,"position":3,"arabic":"ذَٰلِكَ","translation":"এর","audioUrl":"wbw/026_008_003.mp3","charTypeName":"word"},{"id":9269,"position":4,"arabic":"لَـَٔايَةًۭ ۖ","translation":"অবশ্যই নিদর্শন","audioUrl":"wbw/026_008_004.mp3","charTypeName":"word"},{"id":9271,"position":5,"arabic":"وَمَا","translation":"কিন্তু না","audioUrl":"wbw/026_008_006.mp3","charTypeName":"word"},{"id":9272,"position":6,"arabic":"كَانَ","translation":"ছিলো","audioUrl":"wbw/026_008_007.mp3","charTypeName":"word"},{"id":9273,"position":7,"arabic":"أَكْثَرُهُم","translation":"অধিকাংশ তাদের","audioUrl":"wbw/026_008_008.mp3","charTypeName":"word"},{"id":9274,"position":8,"arabic":"مُّؤْمِنِينَ","translation":"মু'মিন","audioUrl":"wbw/026_008_009.mp3","charTypeName":"word"},{"id":9275,"position":9,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"وَإِنَّ رَبَّكَ لَهُوَ ٱلْعَزِيزُ ٱلرَّحِيمُ","translation":"But, verily, thy Sustainer - He alone - is almighty, a dispenser of grace!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2941.mp3","surahId":26,"words":[{"id":10462,"position":1,"arabic":"وَإِنَّ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/026_009_001.mp3","charTypeName":"word"},{"id":10463,"position":2,"arabic":"رَبَّكَ","translation":"তোমার রব","audioUrl":"wbw/026_009_002.mp3","charTypeName":"word"},{"id":10464,"position":3,"arabic":"لَهُوَ","translation":"অবশ্যই তিনি","audioUrl":"wbw/026_009_003.mp3","charTypeName":"word"},{"id":10465,"position":4,"arabic":"ٱلْعَزِيزُ","translation":"পরাক্রমশালী","audioUrl":"wbw/026_009_004.mp3","charTypeName":"word"},{"id":10466,"position":5,"arabic":"ٱلرَّحِيمُ","translation":"পরম দয়ালুও","audioUrl":"wbw/026_009_005.mp3","charTypeName":"word"},{"id":10467,"position":6,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"وَإِذْ نَادَىٰ رَبُّكَ مُوسَىٰٓ أَنِ ٱئْتِ ٱلْقَوْمَ ٱلظَّٰلِمِينَ","translation":"HENCE, [remember how it was] when thy Sustainer summoned Moses: “Go unto those evil doing people.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2942.mp3","surahId":26,"words":[{"id":11675,"position":1,"arabic":"وَإِذْ","translation":"এবং (স্মরণ করো) যখন","audioUrl":"wbw/026_010_001.mp3","charTypeName":"word"},{"id":11676,"position":2,"arabic":"نَادَىٰ","translation":"ডেকেছিলেন","audioUrl":"wbw/026_010_002.mp3","charTypeName":"word"},{"id":11677,"position":3,"arabic":"رَبُّكَ","translation":"তোমার রব","audioUrl":"wbw/026_010_003.mp3","charTypeName":"word"},{"id":11678,"position":4,"arabic":"مُوسَىٰٓ","translation":"মূসাকে","audioUrl":"wbw/026_010_004.mp3","charTypeName":"word"},{"id":11679,"position":5,"arabic":"أَنِ","translation":"যে","audioUrl":"wbw/026_010_005.mp3","charTypeName":"word"},{"id":11680,"position":6,"arabic":"ٱئْتِ","translation":"\"যাও তুমি","audioUrl":"wbw/026_010_006.mp3","charTypeName":"word"},{"id":11681,"position":7,"arabic":"ٱلْقَوْمَ","translation":"জাতির (নিকট)","audioUrl":"wbw/026_010_007.mp3","charTypeName":"word"},{"id":11682,"position":8,"arabic":"ٱلظَّـٰلِمِينَ","translation":"সীমালঙ্ঘনকারী","audioUrl":"wbw/026_010_008.mp3","charTypeName":"word"},{"id":11683,"position":9,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"قَوْمَ فِرْعَوْنَ ۚ أَلَا يَتَّقُونَ","translation":"the people of Pharaoh, who refuse to be con­scious of Me!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2943.mp3","surahId":26,"words":[{"id":13044,"position":1,"arabic":"قَوْمَ","translation":"জাতি","audioUrl":"wbw/026_011_001.mp3","charTypeName":"word"},{"id":13045,"position":2,"arabic":"فِرْعَوْنَ ۚ","translation":"ফিরআউনের","audioUrl":"wbw/026_011_002.mp3","charTypeName":"word"},{"id":13047,"position":3,"arabic":"أَلَا","translation":"কি না","audioUrl":"wbw/026_011_004.mp3","charTypeName":"word"},{"id":13048,"position":4,"arabic":"يَتَّقُونَ","translation":"তারা ভয় করে\"","audioUrl":"wbw/026_011_005.mp3","charTypeName":"word"},{"id":13049,"position":5,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]},{"number":12,"arabic":"قَالَ رَبِّ إِنِّىٓ أَخَافُ أَن يُكَذِّبُونِ","translation":"He answered: “O my Sustainer! Behold, I fear that they will give me the lie,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2944.mp3","surahId":26,"words":[{"id":14287,"position":1,"arabic":"قَالَ","translation":"(মূসা) বললো","audioUrl":"wbw/026_012_001.mp3","charTypeName":"word"},{"id":14288,"position":2,"arabic":"رَبِّ","translation":"\"হে আমার রব","audioUrl":"wbw/026_012_002.mp3","charTypeName":"word"},{"id":14289,"position":3,"arabic":"إِنِّىٓ","translation":"নিশ্চয়ই আমি","audioUrl":"wbw/026_012_003.mp3","charTypeName":"word"},{"id":14290,"position":4,"arabic":"أَخَافُ","translation":"আমি আশংকা করছি","audioUrl":"wbw/026_012_004.mp3","charTypeName":"word"},{"id":14291,"position":5,"arabic":"أَن","translation":"যে","audioUrl":"wbw/026_012_005.mp3","charTypeName":"word"},{"id":14292,"position":6,"arabic":"يُكَذِّبُونِ","translation":"মিথ্যাবাদী বলবে তারা আমাকে","audioUrl":"wbw/026_012_006.mp3","charTypeName":"word"},{"id":14293,"position":7,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]},{"number":13,"arabic":"وَيَضِيقُ صَدْرِى وَلَا يَنطَلِقُ لِسَانِى فَأَرْسِلْ إِلَىٰ هَٰرُونَ","translation":"and then my breast will be straitened and my tongue will not be free: send, then, [this Thy command] to Aaron.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2945.mp3","surahId":26,"words":[{"id":15413,"position":1,"arabic":"وَيَضِيقُ","translation":"এবং সংকুচিত হচ্ছে","audioUrl":"wbw/026_013_001.mp3","charTypeName":"word"},{"id":15414,"position":2,"arabic":"صَدْرِى","translation":"আমার অন্তর","audioUrl":"wbw/026_013_002.mp3","charTypeName":"word"},{"id":15415,"position":3,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/026_013_003.mp3","charTypeName":"word"},{"id":15416,"position":4,"arabic":"يَنطَلِقُ","translation":"অগ্রসর হয়","audioUrl":"wbw/026_013_004.mp3","charTypeName":"word"},{"id":15417,"position":5,"arabic":"لِسَانِى","translation":"জিহবা আমার","audioUrl":"wbw/026_013_005.mp3","charTypeName":"word"},{"id":15418,"position":6,"arabic":"فَأَرْسِلْ","translation":"সুতরাং আপনি পাঠান (ওহি)","audioUrl":"wbw/026_013_006.mp3","charTypeName":"word"},{"id":15419,"position":7,"arabic":"إِلَىٰ","translation":"প্রতিও","audioUrl":"wbw/026_013_007.mp3","charTypeName":"word"},{"id":15420,"position":8,"arabic":"هَـٰرُونَ","translation":"হারূনের","audioUrl":"wbw/026_013_008.mp3","charTypeName":"word"},{"id":15421,"position":9,"arabic":"١٣","translation":"(১৩)","audioUrl":null,"charTypeName":"end"}]},{"number":14,"arabic":"وَلَهُمْ عَلَىَّ ذَنۢبٌۭ فَأَخَافُ أَن يَقْتُلُونِ","translation":"Moreover, they keep a grave charge [pending] against me, and I fear that they will slay me.”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2946.mp3","surahId":26,"words":[{"id":16456,"position":1,"arabic":"وَلَهُمْ","translation":"এবং আছে তাদের","audioUrl":"wbw/026_014_001.mp3","charTypeName":"word"},{"id":16457,"position":2,"arabic":"عَلَىَّ","translation":"বিরুদ্ধে আমার","audioUrl":"wbw/026_014_002.mp3","charTypeName":"word"},{"id":16458,"position":3,"arabic":"ذَنۢبٌۭ","translation":"(অপরাধের) অভিযোগ","audioUrl":"wbw/026_014_003.mp3","charTypeName":"word"},{"id":16459,"position":4,"arabic":"فَأَخَافُ","translation":"তাই আমি আশংকা করছি","audioUrl":"wbw/026_014_004.mp3","charTypeName":"word"},{"id":16460,"position":5,"arabic":"أَن","translation":"যে","audioUrl":"wbw/026_014_005.mp3","charTypeName":"word"},{"id":16461,"position":6,"arabic":"يَقْتُلُونِ","translation":"আমাকে তারা হত্যা করবে\"","audioUrl":"wbw/026_014_006.mp3","charTypeName":"word"},{"id":16462,"position":7,"arabic":"١٤","translation":"(১৪)","audioUrl":null,"charTypeName":"end"}]},{"number":15,"arabic":"قَالَ كَلَّا ۖ فَٱذْهَبَا بِـَٔايَٰتِنَآ ۖ إِنَّا مَعَكُم مُّسْتَمِعُونَ","translation":"Said He: “Not so, indeed! Go forth, then, both of you, with Our messages: verify, We shall be with you, listening [to your call]!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2947.mp3","surahId":26,"words":[{"id":17616,"position":1,"arabic":"قَالَ","translation":"(আল্লাহ) বললেন","audioUrl":"wbw/026_015_001.mp3","charTypeName":"word"},{"id":17617,"position":2,"arabic":"كَلَّا ۖ","translation":"\"কখনও না (তারা পারবে)","audioUrl":"wbw/026_015_002.mp3","charTypeName":"word"},{"id":17619,"position":3,"arabic":"فَٱذْهَبَا","translation":"অতএব তোমরা দু'জনে যাও","audioUrl":"wbw/026_015_004.mp3","charTypeName":"word"},{"id":17620,"position":4,"arabic":"بِـَٔايَـٰتِنَآ ۖ","translation":"নিয়ে নিদর্শনাবলী আমাদের","audioUrl":"wbw/026_015_005.mp3","charTypeName":"word"},{"id":17622,"position":5,"arabic":"إِنَّا","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/026_015_007.mp3","charTypeName":"word"},{"id":17623,"position":6,"arabic":"مَعَكُم","translation":"সাথে তোমাদের (আছি)","audioUrl":"wbw/026_015_008.mp3","charTypeName":"word"},{"id":17624,"position":7,"arabic":"مُّسْتَمِعُونَ","translation":"(সদা সর্বদা)শ্রবণকারী","audioUrl":"wbw/026_015_009.mp3","charTypeName":"word"},{"id":17625,"position":8,"arabic":"١٥","translation":"(১৫)","audioUrl":null,"charTypeName":"end"}]},{"number":16,"arabic":"فَأْتِيَا فِرْعَوْنَ فَقُولَآ إِنَّا رَسُولُ رَبِّ ٱلْعَٰلَمِينَ","translation":"And go, both of you, unto Pharaoh and say, ‘Behold, we bear a message from the Sustainer of all the worlds:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2948.mp3","surahId":26,"words":[{"id":18650,"position":1,"arabic":"فَأْتِيَا","translation":"সুতরাং দু'জনে যাও","audioUrl":"wbw/026_016_001.mp3","charTypeName":"word"},{"id":18651,"position":2,"arabic":"فِرْعَوْنَ","translation":"ফিরআউনের (নিকট)","audioUrl":"wbw/026_016_002.mp3","charTypeName":"word"},{"id":18652,"position":3,"arabic":"فَقُولَآ","translation":"অতঃপর দু'জনে বলো","audioUrl":"wbw/026_016_003.mp3","charTypeName":"word"},{"id":18653,"position":4,"arabic":"إِنَّا","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/026_016_004.mp3","charTypeName":"word"},{"id":18654,"position":5,"arabic":"رَسُولُ","translation":"রাসূল","audioUrl":"wbw/026_016_005.mp3","charTypeName":"word"},{"id":18655,"position":6,"arabic":"رَبِّ","translation":"রবের","audioUrl":"wbw/026_016_006.mp3","charTypeName":"word"},{"id":18656,"position":7,"arabic":"ٱلْعَـٰلَمِينَ","translation":"বিশ্বজগতের","audioUrl":"wbw/026_016_007.mp3","charTypeName":"word"},{"id":18657,"position":8,"arabic":"١٦","translation":"(১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":17,"arabic":"أَنْ أَرْسِلْ مَعَنَا بَنِىٓ إِسْرَٰٓءِيلَ","translation":"Let the children of Israel go with us!’”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2949.mp3","surahId":26,"words":[{"id":19716,"position":1,"arabic":"أَنْ","translation":"(আরও বলো) যে","audioUrl":"wbw/026_017_001.mp3","charTypeName":"word"},{"id":19717,"position":2,"arabic":"أَرْسِلْ","translation":"পাঠাও","audioUrl":"wbw/026_017_002.mp3","charTypeName":"word"},{"id":19718,"position":3,"arabic":"مَعَنَا","translation":"সাথে আমাদের","audioUrl":"wbw/026_017_003.mp3","charTypeName":"word"},{"id":19719,"position":4,"arabic":"بَنِىٓ","translation":"বনী","audioUrl":"wbw/026_017_004.mp3","charTypeName":"word"},{"id":19720,"position":5,"arabic":"إِسْرَٰٓءِيلَ","translation":"ইসরাঈলকে","audioUrl":"wbw/026_017_005.mp3","charTypeName":"word"},{"id":19721,"position":6,"arabic":"١٧","translation":"(১৭)","audioUrl":null,"charTypeName":"end"}]},{"number":18,"arabic":"قَالَ أَلَمْ نُرَبِّكَ فِينَا وَلِيدًۭا وَلَبِثْتَ فِينَا مِنْ عُمُرِكَ سِنِينَ","translation":"[But when Moses had delivered his message, Pharaoh] said: “Did we not bring thee up among us when thou wert a child? And didst thou not spend among us years of thy [later] life?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2950.mp3","surahId":26,"words":[{"id":20799,"position":1,"arabic":"قَالَ","translation":"(ফিরআউন) বললো","audioUrl":"wbw/026_018_001.mp3","charTypeName":"word"},{"id":20800,"position":2,"arabic":"أَلَمْ","translation":"\"কি নি","audioUrl":"wbw/026_018_002.mp3","charTypeName":"word"},{"id":20801,"position":3,"arabic":"نُرَبِّكَ","translation":"আমরা তোমাকে প্রতিপালন করি","audioUrl":"wbw/026_018_003.mp3","charTypeName":"word"},{"id":20802,"position":4,"arabic":"فِينَا","translation":"মাঝে আমাদের","audioUrl":"wbw/026_018_004.mp3","charTypeName":"word"},{"id":20803,"position":5,"arabic":"وَلِيدًۭا","translation":"শৈশবে","audioUrl":"wbw/026_018_005.mp3","charTypeName":"word"},{"id":20804,"position":6,"arabic":"وَلَبِثْتَ","translation":"এবং তুমি কাটিয়েছো","audioUrl":"wbw/026_018_006.mp3","charTypeName":"word"},{"id":20805,"position":7,"arabic":"فِينَا","translation":"মাঝে আমাদের","audioUrl":"wbw/026_018_007.mp3","charTypeName":"word"},{"id":20806,"position":8,"arabic":"مِنْ","translation":"থেকে","audioUrl":"wbw/026_018_008.mp3","charTypeName":"word"},{"id":20807,"position":9,"arabic":"عُمُرِكَ","translation":"জীবনের তোমার","audioUrl":"wbw/026_018_009.mp3","charTypeName":"word"},{"id":20808,"position":10,"arabic":"سِنِينَ","translation":"(কয়েকটি) বছর","audioUrl":"wbw/026_018_010.mp3","charTypeName":"word"},{"id":20809,"position":11,"arabic":"١٨","translation":"(১৮)","audioUrl":null,"charTypeName":"end"}]},{"number":19,"arabic":"وَفَعَلْتَ فَعْلَتَكَ ٱلَّتِى فَعَلْتَ وَأَنتَ مِنَ ٱلْكَٰفِرِينَ","translation":"And yet thou didst commit that [heinous] deed of thine, and [hast thus shown that] thou art one of the ingrate!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2951.mp3","surahId":26,"words":[{"id":22102,"position":1,"arabic":"وَفَعَلْتَ","translation":"এবং তুমি করেছো","audioUrl":"wbw/026_019_001.mp3","charTypeName":"word"},{"id":22103,"position":2,"arabic":"فَعْلَتَكَ","translation":"কর্ম তোমার","audioUrl":"wbw/026_019_002.mp3","charTypeName":"word"},{"id":22104,"position":3,"arabic":"ٱلَّتِى","translation":"যা কিছু","audioUrl":"wbw/026_019_003.mp3","charTypeName":"word"},{"id":22105,"position":4,"arabic":"فَعَلْتَ","translation":"তুমি করেছো","audioUrl":"wbw/026_019_004.mp3","charTypeName":"word"},{"id":22106,"position":5,"arabic":"وَأَنتَ","translation":"আর তুমি","audioUrl":"wbw/026_019_005.mp3","charTypeName":"word"},{"id":22107,"position":6,"arabic":"مِنَ","translation":"অন্তর্ভূক্ত","audioUrl":"wbw/026_019_006.mp3","charTypeName":"word"},{"id":22108,"position":7,"arabic":"ٱلْكَـٰفِرِينَ","translation":"অকৃতজ্ঞদের\"","audioUrl":"wbw/026_019_007.mp3","charTypeName":"word"},{"id":22109,"position":8,"arabic":"١٩","translation":"(১৯)","audioUrl":null,"charTypeName":"end"}]}]}