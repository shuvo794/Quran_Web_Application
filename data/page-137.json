{"id":137,"ayahs":[{"number":74,"arabic":"۞ وَإِذْ قَالَ إِبْرَٰهِيمُ لِأَبِيهِ ءَازَرَ أَتَتَّخِذُ أَصْنَامًا ءَالِهَةً ۖ إِنِّىٓ أَرَىٰكَ وَقَوْمَكَ فِى ضَلَٰلٍۢ مُّبِينٍۢ","translation":"AND, LO, [thus] spoke Abraham unto his father Azar: \"Takest thou idols for gods? Verily, I see that thou and thy people have obviously gone astray!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/863.mp3","surahId":6,"words":[{"id":61772,"position":1,"arabic":"۞ وَإِذْ","translation":"এবং (স্মরণ করো) যখন","audioUrl":"wbw/006_074_002.mp3","charTypeName":"word"},{"id":61773,"position":2,"arabic":"قَالَ","translation":"বলেছিলো","audioUrl":"wbw/006_074_003.mp3","charTypeName":"word"},{"id":61774,"position":3,"arabic":"إِبْرَٰهِيمُ","translation":"ইবরাহীম","audioUrl":"wbw/006_074_004.mp3","charTypeName":"word"},{"id":61775,"position":4,"arabic":"لِأَبِيهِ","translation":"উদ্দেশ্যে তার পিতার","audioUrl":"wbw/006_074_005.mp3","charTypeName":"word"},{"id":61776,"position":5,"arabic":"ءَازَرَ","translation":"(অর্থাৎ) আজরকে","audioUrl":"wbw/006_074_006.mp3","charTypeName":"word"},{"id":61777,"position":6,"arabic":"أَتَتَّخِذُ","translation":"\"কি আপনি গ্রহণ করেন","audioUrl":"wbw/006_074_007.mp3","charTypeName":"word"},{"id":61778,"position":7,"arabic":"أَصْنَامًا","translation":"মূর্তিগুলোকে","audioUrl":"wbw/006_074_008.mp3","charTypeName":"word"},{"id":61779,"position":8,"arabic":"ءَالِهَةً ۖ","translation":"উপাস্যরূপে","audioUrl":"wbw/006_074_009.mp3","charTypeName":"word"},{"id":61781,"position":9,"arabic":"إِنِّىٓ","translation":"নিশ্চয়ই আমি","audioUrl":"wbw/006_074_011.mp3","charTypeName":"word"},{"id":61782,"position":10,"arabic":"أَرَىٰكَ","translation":"আপনাকে দেখছি","audioUrl":"wbw/006_074_012.mp3","charTypeName":"word"},{"id":61783,"position":11,"arabic":"وَقَوْمَكَ","translation":"ও আপনার সম্প্রদায়কে","audioUrl":"wbw/006_074_013.mp3","charTypeName":"word"},{"id":61784,"position":12,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/006_074_014.mp3","charTypeName":"word"},{"id":61785,"position":13,"arabic":"ضَلَـٰلٍۢ","translation":"পথভ্রষ্টতার","audioUrl":"wbw/006_074_015.mp3","charTypeName":"word"},{"id":61786,"position":14,"arabic":"مُّبِينٍۢ","translation":"সুস্পষ্ট\"","audioUrl":"wbw/006_074_016.mp3","charTypeName":"word"},{"id":61787,"position":15,"arabic":"٧٤","translation":"(৭৪)","audioUrl":null,"charTypeName":"end"}]},{"number":75,"arabic":"وَكَذَٰلِكَ نُرِىٓ إِبْرَٰهِيمَ مَلَكُوتَ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ وَلِيَكُونَ مِنَ ٱلْمُوقِنِينَ","translation":"And thus We gave Abraham [his first] insight into [God's] mighty dominion over the heavens and the earth - and [this] to the end that he might become one of those who are inwardly sure.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/864.mp3","surahId":6,"words":[{"id":61856,"position":1,"arabic":"وَكَذَٰلِكَ","translation":"এবং এভাবে","audioUrl":"wbw/006_075_001.mp3","charTypeName":"word"},{"id":61857,"position":2,"arabic":"نُرِىٓ","translation":"দেখাই আমরা","audioUrl":"wbw/006_075_002.mp3","charTypeName":"word"},{"id":61858,"position":3,"arabic":"إِبْرَٰهِيمَ","translation":"ইবরাহীমকে","audioUrl":"wbw/006_075_003.mp3","charTypeName":"word"},{"id":61859,"position":4,"arabic":"مَلَكُوتَ","translation":"পরিচালনা ব্যবস্হা","audioUrl":"wbw/006_075_004.mp3","charTypeName":"word"},{"id":61860,"position":5,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশসমূহের","audioUrl":"wbw/006_075_005.mp3","charTypeName":"word"},{"id":61861,"position":6,"arabic":"وَٱلْأَرْضِ","translation":"ও পৃথিবীর","audioUrl":"wbw/006_075_006.mp3","charTypeName":"word"},{"id":61862,"position":7,"arabic":"وَلِيَكُونَ","translation":"এবং যেন সে হয়","audioUrl":"wbw/006_075_007.mp3","charTypeName":"word"},{"id":61863,"position":8,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/006_075_008.mp3","charTypeName":"word"},{"id":61864,"position":9,"arabic":"ٱلْمُوقِنِينَ","translation":"দৃঢ় বিশ্বাসীদের","audioUrl":"wbw/006_075_009.mp3","charTypeName":"word"},{"id":61865,"position":10,"arabic":"٧٥","translation":"(৭৫)","audioUrl":null,"charTypeName":"end"}]},{"number":76,"arabic":"فَلَمَّا جَنَّ عَلَيْهِ ٱلَّيْلُ رَءَا كَوْكَبًۭا ۖ قَالَ هَٰذَا رَبِّى ۖ فَلَمَّآ أَفَلَ قَالَ لَآ أُحِبُّ ٱلْءَافِلِينَ","translation":"Then, when the night overshadowed him with its darkness, he beheld a star;., [and] he exclaimed, \"This is my Sustainer!\" -but when it went down, he said, \"I love not the things that go down.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/865.mp3","surahId":6,"words":[{"id":62699,"position":1,"arabic":"فَلَمَّا","translation":"অতঃপর যখন","audioUrl":"wbw/006_076_001.mp3","charTypeName":"word"},{"id":62700,"position":2,"arabic":"جَنَّ","translation":"আচ্ছন্ন হলো","audioUrl":"wbw/006_076_002.mp3","charTypeName":"word"},{"id":62701,"position":3,"arabic":"عَلَيْهِ","translation":"উপর তার","audioUrl":"wbw/006_076_003.mp3","charTypeName":"word"},{"id":62702,"position":4,"arabic":"ٱلَّيْلُ","translation":"রাত","audioUrl":"wbw/006_076_004.mp3","charTypeName":"word"},{"id":62703,"position":5,"arabic":"رَءَا","translation":"(ইবরাহীম) দেখলো","audioUrl":"wbw/006_076_005.mp3","charTypeName":"word"},{"id":62704,"position":6,"arabic":"كَوْكَبًۭا ۖ","translation":"একটি তারা (উজ্জ্বল)","audioUrl":"wbw/006_076_006.mp3","charTypeName":"word"},{"id":62706,"position":7,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/006_076_008.mp3","charTypeName":"word"},{"id":62707,"position":8,"arabic":"هَـٰذَا","translation":"\"এই","audioUrl":"wbw/006_076_009.mp3","charTypeName":"word"},{"id":62708,"position":9,"arabic":"رَبِّى ۖ","translation":"আমার রব\"","audioUrl":"wbw/006_076_010.mp3","charTypeName":"word"},{"id":62710,"position":10,"arabic":"فَلَمَّآ","translation":"অতঃপর যখন","audioUrl":"wbw/006_076_012.mp3","charTypeName":"word"},{"id":62711,"position":11,"arabic":"أَفَلَ","translation":"তা অস্তমিত হলো","audioUrl":"wbw/006_076_013.mp3","charTypeName":"word"},{"id":62712,"position":12,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/006_076_014.mp3","charTypeName":"word"},{"id":62713,"position":13,"arabic":"لَآ","translation":"\"না","audioUrl":"wbw/006_076_015.mp3","charTypeName":"word"},{"id":62714,"position":14,"arabic":"أُحِبُّ","translation":"\"আমি ভালোবাসি","audioUrl":"wbw/006_076_016.mp3","charTypeName":"word"},{"id":62715,"position":15,"arabic":"ٱلْـَٔافِلِينَ","translation":"অস্তগামীদেরকে\"","audioUrl":"wbw/006_076_017.mp3","charTypeName":"word"},{"id":62716,"position":16,"arabic":"٧٦","translation":"(৭৬)","audioUrl":null,"charTypeName":"end"}]},{"number":77,"arabic":"فَلَمَّا رَءَا ٱلْقَمَرَ بَازِغًۭا قَالَ هَٰذَا رَبِّى ۖ فَلَمَّآ أَفَلَ قَالَ لَئِن لَّمْ يَهْدِنِى رَبِّى لَأَكُونَنَّ مِنَ ٱلْقَوْمِ ٱلضَّآلِّينَ","translation":"Then, when he beheld the moon rising, he said, \"This is my Sustainer!\"-but when it went down, he said, \"Indeed, if my Sustainer guide me not. I will most certainly become one of the people who go astray!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/866.mp3","surahId":6,"words":[{"id":63137,"position":1,"arabic":"فَلَمَّا","translation":"অতঃপর যখন","audioUrl":"wbw/006_077_001.mp3","charTypeName":"word"},{"id":63138,"position":2,"arabic":"رَءَا","translation":"সে দেখলো","audioUrl":"wbw/006_077_002.mp3","charTypeName":"word"},{"id":63139,"position":3,"arabic":"ٱلْقَمَرَ","translation":"চাঁদকে","audioUrl":"wbw/006_077_003.mp3","charTypeName":"word"},{"id":63140,"position":4,"arabic":"بَازِغًۭا","translation":"উদীয়মান (উজ্জ্বল)","audioUrl":"wbw/006_077_004.mp3","charTypeName":"word"},{"id":63141,"position":5,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/006_077_005.mp3","charTypeName":"word"},{"id":63142,"position":6,"arabic":"هَـٰذَا","translation":"\"এই","audioUrl":"wbw/006_077_006.mp3","charTypeName":"word"},{"id":63143,"position":7,"arabic":"رَبِّى ۖ","translation":"আমার রব\"","audioUrl":"wbw/006_077_007.mp3","charTypeName":"word"},{"id":63145,"position":8,"arabic":"فَلَمَّآ","translation":"অতঃপর যখন","audioUrl":"wbw/006_077_009.mp3","charTypeName":"word"},{"id":63146,"position":9,"arabic":"أَفَلَ","translation":"তা অস্তমিত হলো","audioUrl":"wbw/006_077_010.mp3","charTypeName":"word"},{"id":63147,"position":10,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/006_077_011.mp3","charTypeName":"word"},{"id":63148,"position":11,"arabic":"لَئِن","translation":"\"অবশ্যই যদি","audioUrl":"wbw/006_077_012.mp3","charTypeName":"word"},{"id":63149,"position":12,"arabic":"لَّمْ","translation":"না","audioUrl":"wbw/006_077_013.mp3","charTypeName":"word"},{"id":63150,"position":13,"arabic":"يَهْدِنِى","translation":"আমাকে সৎপথ দেখান","audioUrl":"wbw/006_077_014.mp3","charTypeName":"word"},{"id":63151,"position":14,"arabic":"رَبِّى","translation":"আমার রব","audioUrl":"wbw/006_077_015.mp3","charTypeName":"word"},{"id":63152,"position":15,"arabic":"لَأَكُونَنَّ","translation":"অবশ্যই হবো আমি","audioUrl":"wbw/006_077_016.mp3","charTypeName":"word"},{"id":63153,"position":16,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/006_077_017.mp3","charTypeName":"word"},{"id":63154,"position":17,"arabic":"ٱلْقَوْمِ","translation":"সম্প্রদায়ের","audioUrl":"wbw/006_077_018.mp3","charTypeName":"word"},{"id":63155,"position":18,"arabic":"ٱلضَّآلِّينَ","translation":"পথভ্রষ্ট\"","audioUrl":"wbw/006_077_019.mp3","charTypeName":"word"},{"id":63156,"position":19,"arabic":"٧٧","translation":"(৭৭)","audioUrl":null,"charTypeName":"end"}]},{"number":78,"arabic":"فَلَمَّا رَءَا ٱلشَّمْسَ بَازِغَةًۭ قَالَ هَٰذَا رَبِّى هَٰذَآ أَكْبَرُ ۖ فَلَمَّآ أَفَلَتْ قَالَ يَٰقَوْمِ إِنِّى بَرِىٓءٌۭ مِّمَّا تُشْرِكُونَ","translation":"Then, when he beheld the sun rising, he said, \"This is my Sustainer! This one is the greatest [of all]!\" - but when it [too] went down, he exclaimed: \"O my people! Behold, far be it from me to ascribe divinity, as you do, to aught beside God!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/867.mp3","surahId":6,"words":[{"id":63664,"position":1,"arabic":"فَلَمَّا","translation":"অতঃপর যখন","audioUrl":"wbw/006_078_001.mp3","charTypeName":"word"},{"id":63665,"position":2,"arabic":"رَءَا","translation":"দেখলো","audioUrl":"wbw/006_078_002.mp3","charTypeName":"word"},{"id":63666,"position":3,"arabic":"ٱلشَّمْسَ","translation":"সূর্যকে","audioUrl":"wbw/006_078_003.mp3","charTypeName":"word"},{"id":63667,"position":4,"arabic":"بَازِغَةًۭ","translation":"উদীয়মান (উজ্জ্বল)","audioUrl":"wbw/006_078_004.mp3","charTypeName":"word"},{"id":63668,"position":5,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/006_078_005.mp3","charTypeName":"word"},{"id":63669,"position":6,"arabic":"هَـٰذَا","translation":"\"এই","audioUrl":"wbw/006_078_006.mp3","charTypeName":"word"},{"id":63670,"position":7,"arabic":"رَبِّى","translation":"আমার রব","audioUrl":"wbw/006_078_007.mp3","charTypeName":"word"},{"id":63671,"position":8,"arabic":"هَـٰذَآ","translation":"এই","audioUrl":"wbw/006_078_008.mp3","charTypeName":"word"},{"id":63672,"position":9,"arabic":"أَكْبَرُ ۖ","translation":"সবচেয়ে বড়\"","audioUrl":"wbw/006_078_009.mp3","charTypeName":"word"},{"id":63674,"position":10,"arabic":"فَلَمَّآ","translation":"অতঃপর যখন","audioUrl":"wbw/006_078_011.mp3","charTypeName":"word"},{"id":63675,"position":11,"arabic":"أَفَلَتْ","translation":"তা অস্তমিত হলো","audioUrl":"wbw/006_078_012.mp3","charTypeName":"word"},{"id":63676,"position":12,"arabic":"قَالَ","translation":"বললো সে","audioUrl":"wbw/006_078_013.mp3","charTypeName":"word"},{"id":63677,"position":13,"arabic":"يَـٰقَوْمِ","translation":"\"হে আমার জাতি","audioUrl":"wbw/006_078_014.mp3","charTypeName":"word"},{"id":63678,"position":14,"arabic":"إِنِّى","translation":"নিশ্চয়ই আমি","audioUrl":"wbw/006_078_015.mp3","charTypeName":"word"},{"id":63679,"position":15,"arabic":"بَرِىٓءٌۭ","translation":"সম্পর্কহীন","audioUrl":"wbw/006_078_016.mp3","charTypeName":"word"},{"id":63680,"position":16,"arabic":"مِّمَّا","translation":"(তা) হতে না","audioUrl":"wbw/006_078_017.mp3","charTypeName":"word"},{"id":63681,"position":17,"arabic":"تُشْرِكُونَ","translation":"তোমরা শিরক করছো\"","audioUrl":"wbw/006_078_018.mp3","charTypeName":"word"},{"id":63682,"position":18,"arabic":"٧٨","translation":"(৭৮)","audioUrl":null,"charTypeName":"end"}]},{"number":79,"arabic":"إِنِّى وَجَّهْتُ وَجْهِىَ لِلَّذِى فَطَرَ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضَ حَنِيفًۭا ۖ وَمَآ أَنَا۠ مِنَ ٱلْمُشْرِكِينَ","translation":"Behold, unto Him who brought into being the heavens and the earth have I turned my face, having turned away from all that is false; and I am not of those who ascribe divinity to aught beside Him.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/868.mp3","surahId":6,"words":[{"id":64022,"position":1,"arabic":"إِنِّى","translation":"নিশ্চয়ই আমি","audioUrl":"wbw/006_079_001.mp3","charTypeName":"word"},{"id":64023,"position":2,"arabic":"وَجَّهْتُ","translation":"আমি মুখ ফেরাচ্ছি","audioUrl":"wbw/006_079_002.mp3","charTypeName":"word"},{"id":64024,"position":3,"arabic":"وَجْهِىَ","translation":"আমার মুখ (অর্থাৎ কেন্দ্রীভূত করেছি)","audioUrl":"wbw/006_079_003.mp3","charTypeName":"word"},{"id":64025,"position":4,"arabic":"لِلَّذِى","translation":"(তাঁর) দিকে যিনি","audioUrl":"wbw/006_079_004.mp3","charTypeName":"word"},{"id":64026,"position":5,"arabic":"فَطَرَ","translation":"সৃষ্টি করেছেন","audioUrl":"wbw/006_079_005.mp3","charTypeName":"word"},{"id":64027,"position":6,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশসমূহ","audioUrl":"wbw/006_079_006.mp3","charTypeName":"word"},{"id":64028,"position":7,"arabic":"وَٱلْأَرْضَ","translation":"ও পৃথিবী","audioUrl":"wbw/006_079_007.mp3","charTypeName":"word"},{"id":64029,"position":8,"arabic":"حَنِيفًۭا ۖ","translation":"একনিষ্ঠভাবে","audioUrl":"wbw/006_079_008.mp3","charTypeName":"word"},{"id":64031,"position":9,"arabic":"وَمَآ","translation":"এবং নই","audioUrl":"wbw/006_079_010.mp3","charTypeName":"word"},{"id":64032,"position":10,"arabic":"أَنَا۠","translation":"আমি","audioUrl":"wbw/006_079_011.mp3","charTypeName":"word"},{"id":64033,"position":11,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/006_079_012.mp3","charTypeName":"word"},{"id":64034,"position":12,"arabic":"ٱلْمُشْرِكِينَ","translation":"মুশরিকদের","audioUrl":"wbw/006_079_013.mp3","charTypeName":"word"},{"id":64035,"position":13,"arabic":"٧٩","translation":"(৭৯)","audioUrl":null,"charTypeName":"end"}]},{"number":80,"arabic":"وَحَآجَّهُۥ قَوْمُهُۥ ۚ قَالَ أَتُحَٰٓجُّوٓنِّى فِى ٱللَّهِ وَقَدْ هَدَىٰنِ ۚ وَلَآ أَخَافُ مَا تُشْرِكُونَ بِهِۦٓ إِلَّآ أَن يَشَآءَ رَبِّى شَيْـًۭٔا ۗ وَسِعَ رَبِّى كُلَّ شَىْءٍ عِلْمًا ۗ أَفَلَا تَتَذَكَّرُونَ","translation":"And his people argued with him. He said: \"Do you argue with me about God, when it is He who has guided me? But I do not fear anything to which you ascribe divinity side by side with Him, [for no evil can befall me] unless my Sustainer so wills. All things does my Sustainer embrace within His knowledge; will you not, then, keep this in mind?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/869.mp3","surahId":6,"words":[{"id":64348,"position":1,"arabic":"وَحَآجَّهُۥ","translation":"কিন্তু তার সাথে বিতর্ক করলো","audioUrl":"wbw/006_080_001.mp3","charTypeName":"word"},{"id":64349,"position":2,"arabic":"قَوْمُهُۥ ۚ","translation":"জাতি তার","audioUrl":"wbw/006_080_002.mp3","charTypeName":"word"},{"id":64351,"position":3,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/006_080_004.mp3","charTypeName":"word"},{"id":64352,"position":4,"arabic":"أَتُحَـٰٓجُّوٓنِّى","translation":"\"কি আমার সাথে বিতর্ক করছো","audioUrl":"wbw/006_080_005.mp3","charTypeName":"word"},{"id":64353,"position":5,"arabic":"فِى","translation":"সম্বন্ধে","audioUrl":"wbw/006_080_006.mp3","charTypeName":"word"},{"id":64354,"position":6,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌","audioUrl":"wbw/006_080_007.mp3","charTypeName":"word"},{"id":64355,"position":7,"arabic":"وَقَدْ","translation":"অথচ","audioUrl":"wbw/006_080_008.mp3","charTypeName":"word"},{"id":64356,"position":8,"arabic":"هَدَىٰنِ ۚ","translation":"তিনি সঠিক পথ দেখিয়েছেন আমাকে","audioUrl":"wbw/006_080_009.mp3","charTypeName":"word"},{"id":64358,"position":9,"arabic":"وَلَآ","translation":"এবং না","audioUrl":"wbw/006_080_011.mp3","charTypeName":"word"},{"id":64359,"position":10,"arabic":"أَخَافُ","translation":"আমি ভয় করি","audioUrl":"wbw/006_080_012.mp3","charTypeName":"word"},{"id":64360,"position":11,"arabic":"مَا","translation":"তার (যা কিছুর)","audioUrl":"wbw/006_080_013.mp3","charTypeName":"word"},{"id":64361,"position":12,"arabic":"تُشْرِكُونَ","translation":"তোমরা শিরক করো","audioUrl":"wbw/006_080_014.mp3","charTypeName":"word"},{"id":64362,"position":13,"arabic":"بِهِۦٓ","translation":"সাথে তাঁর","audioUrl":"wbw/006_080_015.mp3","charTypeName":"word"},{"id":64363,"position":14,"arabic":"إِلَّآ","translation":"এ ছাড়া","audioUrl":"wbw/006_080_016.mp3","charTypeName":"word"},{"id":64364,"position":15,"arabic":"أَن","translation":"যে (যদি)","audioUrl":"wbw/006_080_017.mp3","charTypeName":"word"},{"id":64365,"position":16,"arabic":"يَشَآءَ","translation":"ইচ্ছে করেন","audioUrl":"wbw/006_080_018.mp3","charTypeName":"word"},{"id":64366,"position":17,"arabic":"رَبِّى","translation":"আমার রব","audioUrl":"wbw/006_080_019.mp3","charTypeName":"word"},{"id":64367,"position":18,"arabic":"شَيْـًۭٔا ۗ","translation":"(অন্য) কিছু","audioUrl":"wbw/006_080_020.mp3","charTypeName":"word"},{"id":64369,"position":19,"arabic":"وَسِعَ","translation":"পরিব্যাপ্ত করেছেন","audioUrl":"wbw/006_080_022.mp3","charTypeName":"word"},{"id":64370,"position":20,"arabic":"رَبِّى","translation":"আমার রব","audioUrl":"wbw/006_080_023.mp3","charTypeName":"word"},{"id":64371,"position":21,"arabic":"كُلَّ","translation":"সব","audioUrl":"wbw/006_080_024.mp3","charTypeName":"word"},{"id":64372,"position":22,"arabic":"شَىْءٍ","translation":"কিছুকে","audioUrl":"wbw/006_080_025.mp3","charTypeName":"word"},{"id":64373,"position":23,"arabic":"عِلْمًا ۗ","translation":"জ্ঞানে","audioUrl":"wbw/006_080_026.mp3","charTypeName":"word"},{"id":64375,"position":24,"arabic":"أَفَلَا","translation":"কি তবুও না","audioUrl":"wbw/006_080_028.mp3","charTypeName":"word"},{"id":64376,"position":25,"arabic":"تَتَذَكَّرُونَ","translation":"তোমরা শিক্ষা গ্রহণ করবে","audioUrl":"wbw/006_080_029.mp3","charTypeName":"word"},{"id":64377,"position":26,"arabic":"٨٠","translation":"(৮০)","audioUrl":null,"charTypeName":"end"}]},{"number":81,"arabic":"وَكَيْفَ أَخَافُ مَآ أَشْرَكْتُمْ وَلَا تَخَافُونَ أَنَّكُمْ أَشْرَكْتُم بِٱللَّهِ مَا لَمْ يُنَزِّلْ بِهِۦ عَلَيْكُمْ سُلْطَٰنًۭا ۚ فَأَىُّ ٱلْفَرِيقَيْنِ أَحَقُّ بِٱلْأَمْنِ ۖ إِن كُنتُمْ تَعْلَمُونَ","translation":"And why should I fear anything that you worship side by side with Him, seeing that you are not afraid of ascribing divinity to other powers beside God without His ever having bestowed upon you from on high any warrant therefor? [Tell me,] then, which of the two parties has a better right to feel secure -if you happen to know [the answer]?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/870.mp3","surahId":6,"words":[{"id":64481,"position":1,"arabic":"وَكَيْفَ","translation":"এবং কিরূপে","audioUrl":"wbw/006_081_001.mp3","charTypeName":"word"},{"id":64482,"position":2,"arabic":"أَخَافُ","translation":"আমি ভয় করবো","audioUrl":"wbw/006_081_002.mp3","charTypeName":"word"},{"id":64483,"position":3,"arabic":"مَآ","translation":"তার (যা কিছুকে)","audioUrl":"wbw/006_081_003.mp3","charTypeName":"word"},{"id":64484,"position":4,"arabic":"أَشْرَكْتُمْ","translation":"শিরক করেছো তোমরা","audioUrl":"wbw/006_081_004.mp3","charTypeName":"word"},{"id":64485,"position":5,"arabic":"وَلَا","translation":"অথচ না","audioUrl":"wbw/006_081_005.mp3","charTypeName":"word"},{"id":64486,"position":6,"arabic":"تَخَافُونَ","translation":"তোমরা ভয় করছো","audioUrl":"wbw/006_081_006.mp3","charTypeName":"word"},{"id":64487,"position":7,"arabic":"أَنَّكُمْ","translation":"যে তোমরা","audioUrl":"wbw/006_081_007.mp3","charTypeName":"word"},{"id":64488,"position":8,"arabic":"أَشْرَكْتُم","translation":"শিরক করেছো","audioUrl":"wbw/006_081_008.mp3","charTypeName":"word"},{"id":64489,"position":9,"arabic":"بِٱللَّهِ","translation":"সাথে আল্লাহ্‌র","audioUrl":"wbw/006_081_009.mp3","charTypeName":"word"},{"id":64490,"position":10,"arabic":"مَا","translation":"যা","audioUrl":"wbw/006_081_010.mp3","charTypeName":"word"},{"id":64491,"position":11,"arabic":"لَمْ","translation":"না","audioUrl":"wbw/006_081_011.mp3","charTypeName":"word"},{"id":64492,"position":12,"arabic":"يُنَزِّلْ","translation":"তিনি অবতীর্ণ করেছেন","audioUrl":"wbw/006_081_012.mp3","charTypeName":"word"},{"id":64493,"position":13,"arabic":"بِهِۦ","translation":"সম্বন্ধে সে","audioUrl":"wbw/006_081_013.mp3","charTypeName":"word"},{"id":64494,"position":14,"arabic":"عَلَيْكُمْ","translation":"উপর তোমাদের","audioUrl":"wbw/006_081_014.mp3","charTypeName":"word"},{"id":64495,"position":15,"arabic":"سُلْطَـٰنًۭا ۚ","translation":"কোনো প্রমাণ","audioUrl":"wbw/006_081_015.mp3","charTypeName":"word"},{"id":64497,"position":16,"arabic":"فَأَىُّ","translation":"সুতরাং কোনো (পক্ষ)","audioUrl":"wbw/006_081_017.mp3","charTypeName":"word"},{"id":64498,"position":17,"arabic":"ٱلْفَرِيقَيْنِ","translation":"দুই পক্ষের","audioUrl":"wbw/006_081_018.mp3","charTypeName":"word"},{"id":64499,"position":18,"arabic":"أَحَقُّ","translation":"অধিকযোগ্য","audioUrl":"wbw/006_081_019.mp3","charTypeName":"word"},{"id":64500,"position":19,"arabic":"بِٱلْأَمْنِ ۖ","translation":"নিরাপত্তা লাভের","audioUrl":"wbw/006_081_020.mp3","charTypeName":"word"},{"id":64502,"position":20,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/006_081_022.mp3","charTypeName":"word"},{"id":64503,"position":21,"arabic":"كُنتُمْ","translation":"তোমরা থাকো","audioUrl":"wbw/006_081_023.mp3","charTypeName":"word"},{"id":64504,"position":22,"arabic":"تَعْلَمُونَ","translation":"তোমরা জানো(তবে বলো)\"","audioUrl":"wbw/006_081_024.mp3","charTypeName":"word"},{"id":64505,"position":23,"arabic":"٨١","translation":"(৮১)","audioUrl":null,"charTypeName":"end"}]}]}