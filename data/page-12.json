for all that they may have gained!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/86.mp3","surahId":2,"words":[{"id":63900,"position":1,"arabic":"فَوَيْلٌۭ","translation":"অতএব দুর্ভোগ","audioUrl":"wbw/002_079_001.mp3","charTypeName":"word"},{"id":63901,"position":2,"arabic":"لِّلَّذِينَ","translation":"তাদের জন্য (যারা)","audioUrl":"wbw/002_079_002.mp3","charTypeName":"word"},{"id":63902,"position":3,"arabic":"يَكْتُبُونَ","translation":"লিখে","audioUrl":"wbw/002_079_003.mp3","charTypeName":"word"},{"id":63903,"position":4,"arabic":"ٱلْكِتَـٰبَ","translation":"কিতাবে (অর্থাৎ শরয়ীবিধান)","audioUrl":"wbw/002_079_004.mp3","charTypeName":"word"},{"id":63904,"position":5,"arabic":"بِأَيْدِيهِمْ","translation":"তাদের হাত দিয়ে","audioUrl":"wbw/002_079_005.mp3","charTypeName":"word"},{"id":63905,"position":6,"arabic":"ثُمَّ","translation":"পরে","audioUrl":"wbw/002_079_006.mp3","charTypeName":"word"},{"id":63906,"position":7,"arabic":"يَقُولُونَ","translation":"তারা বলে","audioUrl":"wbw/002_079_007.mp3","charTypeName":"word"},{"id":63907,"position":8,"arabic":"هَـٰذَا","translation":"''এটা (এসেছে)","audioUrl":"wbw/002_079_008.mp3","charTypeName":"word"},{"id":63908,"position":9,"arabic":"مِنْ","translation":"থেকে","audioUrl":"wbw/002_079_009.mp3","charTypeName":"word"},{"id":63909,"position":10,"arabic":"عِندِ","translation":"নিকট","audioUrl":"wbw/002_079_010.mp3","charTypeName":"word"},{"id":63910,"position":11,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌র''","audioUrl":"wbw/002_079_011.mp3","charTypeName":"word"},{"id":63911,"position":12,"arabic":"لِيَشْتَرُوا۟","translation":"(এরূপ করে) তারা কিনতে পারে","audioUrl":"wbw/002_079_012.mp3","charTypeName":"word"},{"id":63912,"position":13,"arabic":"بِهِۦ","translation":"তা দিয়ে","audioUrl":"wbw/002_079_013.mp3","charTypeName":"word"},{"id":63913,"position":14,"arabic":"ثَمَنًۭا","translation":"মূল্য (অর্থাৎ স্বার্থ)","audioUrl":"wbw/002_079_014.mp3","charTypeName":"word"},{"id":63914,"position":15,"arabic":"ق