":65110,"position":5,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐসব লোক","audioUrl":"wbw/002_082_005.mp3","charTypeName":"word"},{"id":65111,"position":6,"arabic":"أَصْحَـٰبُ","translation":"অধিবাসী (হবে)","audioUrl":"wbw/002_082_006.mp3","charTypeName":"word"},{"id":65112,"position":7,"arabic":"ٱلْجَنَّةِ ۖ","translation":"জান্নাতের","audioUrl":"wbw/002_082_007.mp3","charTypeName":"word"},{"id":65114,"position":8,"arabic":"هُمْ","translation":"তারাই","audioUrl":"wbw/002_082_009.mp3","charTypeName":"word"},{"id":65115,"position":9,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/002_082_010.mp3","charTypeName":"word"},{"id":65116,"position":10,"arabic":"خَـٰلِدُونَ","translation":"চিরস্থায়ী হবে","audioUrl":"wbw/002_082_011.mp3","charTypeName":"word"},{"id":65117,"position":11,"arabic":"٨٢","translation":"(৮২)","audioUrl":null,"charTypeName":"end"}]},{"number":83,"arabic":"وَإِذْ أَخَذْنَا مِيثَٰقَ بَنِىٓ إِسْرَٰٓءِيلَ لَا تَعْبُدُونَ إِلَّا ٱللَّهَ وَبِٱلْوَٰلِدَيْنِ إِحْسَانًۭا وَذِى ٱلْقُرْبَىٰ وَٱلْيَتَٰمَىٰ وَٱلْمَسَٰكِينِ وَقُولُوا۟ لِلنَّاسِ حُسْنًۭا وَأَقِيمُوا۟ ٱلصَّلَوٰةَ وَءَاتُوا۟ ٱلزَّكَوٰةَ ثُمَّ تَوَلَّيْتُمْ إِلَّا قَلِيلًۭا مِّنكُمْ وَأَنتُم مُّعْرِضُونَ","translation":"AND LO! We accepted this solemn pledge from [you,] ' the children of Israel: \"You shall worship none but God; and you shall do good unto your parents and kinsfolk, and the orphans, and the poor; and you shall speak unto all people in a kindly way; and you shall be constant in prayer; and you shall spend in charity.” And yet, save for a few of you, you turned away: for you are obstinate folk!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/90.mp3","surahId":2,"words":[{"id":65369,"position":1,"arabic":"وَإِذْ","translation":"এবং (স্মরণ করো) যখন","audioUrl":"wbw/002_083_001.mp3","charTypeName":"word"},{"id":65370,"position":2,"arabic":"أَخَذْنَا","translation":"আমরা নিয়ে ছিলাম","audioUrl":"wbw/002_083_002.mp3","charTypeName":"word"},{"id":65371,"position":3,"ar