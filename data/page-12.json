{"id":12,"ayahs":[{"number":77,"arabic":"أَوَلَا يَعْلَمُونَ أَنَّ ٱللَّهَ يَعْلَمُ مَا يُسِرُّونَ وَمَا يُعْلِنُونَ","translation":"Do they not know, then, that God is aware of all that they would conceal as well as of all that they bring into the open?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/84.mp3","surahId":2,"words":[{"id":63127,"position":1,"arabic":"أَوَلَا","translation":"না কি","audioUrl":"wbw/002_077_001.mp3","charTypeName":"word"},{"id":63128,"position":2,"arabic":"يَعْلَمُونَ","translation":"তারা জানে","audioUrl":"wbw/002_077_002.mp3","charTypeName":"word"},{"id":63129,"position":3,"arabic":"أَنَّ","translation":"যে","audioUrl":"wbw/002_077_003.mp3","charTypeName":"word"},{"id":63130,"position":4,"arabic":"ٱللَّهَ","translation":"আল্লাহ্‌","audioUrl":"wbw/002_077_004.mp3","charTypeName":"word"},{"id":63131,"position":5,"arabic":"يَعْلَمُ","translation":"জানেন","audioUrl":"wbw/002_077_005.mp3","charTypeName":"word"},{"id":63132,"position":6,"arabic":"مَا","translation":"যা কিছু","audioUrl":"wbw/002_077_006.mp3","charTypeName":"word"},{"id":63133,"position":7,"arabic":"يُسِرُّونَ","translation":"তারা গোপন করে","audioUrl":"wbw/002_077_007.mp3","charTypeName":"word"},{"id":63134,"position":8,"arabic":"وَمَا","translation":"ও যা","audioUrl":"wbw/002_077_008.mp3","charTypeName":"word"},{"id":63135,"position":9,"arabic":"يُعْلِنُونَ","translation":"তারা প্রকাশ করে","audioUrl":"wbw/002_077_009.mp3","charTypeName":"word"},{"id":63136,"position":10,"arabic":"٧٧","translation":"(৭৭)","audioUrl":null,"charTypeName":"end"}]},{"number":78,"arabic":"وَمِنْهُمْ أُمِّيُّونَ لَا يَعْلَمُونَ ٱلْكِتَٰبَ إِلَّآ أَمَانِىَّ وَإِنْ هُمْ إِلَّا يَظُنُّونَ","translation":"And there are among them unlettered people who have no real knowledge of the divine writ, [following] only wishful beliefs and depending on nothing but conjecture.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/85.mp3","surahId":2,"words":[{"id":63416,"position":1,"ara