d"},{"id":75662,"position":9,"arabic":"رَبُّ","translation":"রব (মালিক)","audioUrl":"wbw/023_116_010.mp3","charTypeName":"word"},{"id":75663,"position":10,"arabic":"ٱلْعَرْشِ","translation":"আরশের","audioUrl":"wbw/023_116_011.mp3","charTypeName":"word"},{"id":75664,"position":11,"arabic":"ٱلْكَرِيمِ","translation":"মর্যাদাবান","audioUrl":"wbw/023_116_012.mp3","charTypeName":"word"},{"id":75665,"position":12,"arabic":"١١٦","translation":"(১১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":117,"arabic":"وَمَن يَدْعُ مَعَ ٱللَّهِ إِلَٰهًا ءَاخَرَ لَا بُرْهَٰنَ لَهُۥ بِهِۦ فَإِنَّمَا حِسَابُهُۥ عِندَ رَبِّهِۦٓ ۚ إِنَّهُۥ لَا يُفْلِحُ ٱلْكَٰفِرُونَ","translation":"Hence, he who invokes, side by side with God, any other deity [- a deity] for whose existence he has no evidence - shall but find his reckoning with his Sustainer: [and,] verily, such deniers of the truth will never attain to a happy state!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2790.mp3","surahId":23,"words":[{"id":75821,"position":1,"arabic":"وَمَن","translation":"আর যে কেউ","audioUrl":"wbw/023_117_001.mp3","charTypeName":"word"},{"id":75822,"position":2,"arabic":"يَدْعُ","translation":"ডাকবে","audioUrl":"wbw/023_117_002.mp3","charTypeName":"word"},{"id":75823,"position":3,"arabic":"مَعَ","translation":"সাথে","audioUrl":"wbw/023_117_003.mp3","charTypeName":"word"},{"id":75824,"position":4,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/023_117_004.mp3","charTypeName":"word"},{"id":75825,"position":5,"arabic":"إِلَـٰهًا","translation":"ইলাহ (হিসেবে)","audioUrl":"wbw/023_117_005.mp3","charTypeName":"word"},{"id":75826,"position":6,"arabic":"ءَاخَرَ","translation":"অন্য (কাউকে)","audioUrl":"wbw/023_117_006.mp3","charTypeName":"word"},{"id":75827,"position":7,"arabic":"لَا","translation":"নেই","audioUrl":"wbw/023_117_007.mp3","charTypeName":"word"},{"id":75828,"position":8,"arabic":"بُرْهَـٰنَ","translation":"কোন প্রমাণ","audioUrl":"wbw/023_117_008.mp3","charTypeName":"wo