{"id":349,"ayahs":[{"number":105,"arabic":"أَلَمْ تَكُنْ ءَايَٰتِى تُتْلَىٰ عَلَيْكُمْ فَكُنتُم بِهَا تُكَذِّبُونَ","translation":"[And God will say:] “Were not My messages conveyed unto you, and were you [not] wont to give them the lie?”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2778.mp3","surahId":23,"words":[{"id":72847,"position":1,"arabic":"أَلَمْ","translation":"\"(বলা হবে) কি না","audioUrl":"wbw/023_105_001.mp3","charTypeName":"word"},{"id":72848,"position":2,"arabic":"تَكُنْ","translation":"\"হচ্ছিল","audioUrl":"wbw/023_105_002.mp3","charTypeName":"word"},{"id":72849,"position":3,"arabic":"ءَايَـٰتِى","translation":"আমার আয়াতগুলোকে","audioUrl":"wbw/023_105_003.mp3","charTypeName":"word"},{"id":72850,"position":4,"arabic":"تُتْلَىٰ","translation":"তিলাওয়াত করা হতো","audioUrl":"wbw/023_105_004.mp3","charTypeName":"word"},{"id":72851,"position":5,"arabic":"عَلَيْكُمْ","translation":"তোমাদের নিকট","audioUrl":"wbw/023_105_005.mp3","charTypeName":"word"},{"id":72852,"position":6,"arabic":"فَكُنتُم","translation":"তখন তোমরা ছিলে","audioUrl":"wbw/023_105_006.mp3","charTypeName":"word"},{"id":72853,"position":7,"arabic":"بِهَا","translation":"সম্পর্কে তা\"","audioUrl":"wbw/023_105_007.mp3","charTypeName":"word"},{"id":72854,"position":8,"arabic":"تُكَذِّبُونَ","translation":"মিথ্যারোপ করতে\"","audioUrl":"wbw/023_105_008.mp3","charTypeName":"word"},{"id":72855,"position":9,"arabic":"١٠٥","translation":"(১০৫)","audioUrl":null,"charTypeName":"end"}]},{"number":106,"arabic":"قَالُوا۟ رَبَّنَا غَلَبَتْ عَلَيْنَا شِقْوَتُنَا وَكُنَّا قَوْمًۭا ضَآلِّينَ","translation":"They will exclaim: “O our Sustainer! Our bad luck has overwhelmed us, and so we went astray!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2779.mp3","surahId":23,"words":[{"id":73049,"position":1,"arabic":"قَالُوا۟","translation":"তারা বলবে","audioUrl":"wbw/023_106_001.mp3","charTypeName":"word"},{"id":73050,"position":2,"arabic":"رَبَّنَا","translation":"\"হে আমার রব","audioUrl":"wbw/023_106_002.mp3","charTypeName":"word"},{"id":73051,"position":3,"arabic":"غَلَبَتْ","translation":"বিজয় লাভ করেছিলো","audioUrl":"wbw/023_106_003.mp3","charTypeName":"word"},{"id":73052,"position":4,"arabic":"عَلَيْنَا","translation":"উপর আমাদের","audioUrl":"wbw/023_106_004.mp3","charTypeName":"word"},{"id":73053,"position":5,"arabic":"شِقْوَتُنَا","translation":"আমাদের দুর্ভাগ্য","audioUrl":"wbw/023_106_005.mp3","charTypeName":"word"},{"id":73054,"position":6,"arabic":"وَكُنَّا","translation":"এবং আমরা ছিলাম","audioUrl":"wbw/023_106_006.mp3","charTypeName":"word"},{"id":73055,"position":7,"arabic":"قَوْمًۭا","translation":"জাতি","audioUrl":"wbw/023_106_007.mp3","charTypeName":"word"},{"id":73056,"position":8,"arabic":"ضَآلِّينَ","translation":"পথভ্রষ্ট","audioUrl":"wbw/023_106_008.mp3","charTypeName":"word"},{"id":73057,"position":9,"arabic":"١٠٦","translation":"(১০৬)","audioUrl":null,"charTypeName":"end"}]},{"number":107,"arabic":"رَبَّنَآ أَخْرِجْنَا مِنْهَا فَإِنْ عُدْنَا فَإِنَّا ظَٰلِمُونَ","translation":"O our Sustainer! Cause us to come out of this [suffering] - and then, if ever We revert [to sinning], may we truly be [deemed] evildoers!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2780.mp3","surahId":23,"words":[{"id":73187,"position":1,"arabic":"رَبَّنَآ","translation":"হে আমার রব","audioUrl":"wbw/023_107_001.mp3","charTypeName":"word"},{"id":73188,"position":2,"arabic":"أَخْرِجْنَا","translation":"আমাদেরকে বের করে দাও","audioUrl":"wbw/023_107_002.mp3","charTypeName":"word"},{"id":73189,"position":3,"arabic":"مِنْهَا","translation":"তা হ'তে","audioUrl":"wbw/023_107_003.mp3","charTypeName":"word"},{"id":73190,"position":4,"arabic":"فَإِنْ","translation":"অতঃপর যদি","audioUrl":"wbw/023_107_004.mp3","charTypeName":"word"},{"id":73191,"position":5,"arabic":"عُدْنَا","translation":"আমরা পুনরায় করি","audioUrl":"wbw/023_107_005.mp3","charTypeName":"word"},{"id":73192,"position":6,"arabic":"فَإِنَّا","translation":"তবে আমরা নিশ্চয়ই","audioUrl":"wbw/023_107_006.mp3","charTypeName":"word"},{"id":73193,"position":7,"arabic":"ظَـٰلِمُونَ","translation":"সীমালঙ্ঘনকারী (প্রমাণিত হবো)\"","audioUrl":"wbw/023_107_007.mp3","charTypeName":"word"},{"id":73194,"position":8,"arabic":"١٠٧","translation":"(১০৭)","audioUrl":null,"charTypeName":"end"}]},{"number":108,"arabic":"قَالَ ٱخْسَـُٔوا۟ فِيهَا وَلَا تُكَلِّمُونِ","translation":"[But] He will say: “Away with you into this [ignominy]! And speak no more unto Me!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2781.mp3","surahId":23,"words":[{"id":73700,"position":1,"arabic":"قَالَ","translation":"তিনি বলবেন","audioUrl":"wbw/023_108_001.mp3","charTypeName":"word"},{"id":73701,"position":2,"arabic":"ٱخْسَـُٔوا۟","translation":"\"পড়ে থাকো অপদস্হ হয়ে","audioUrl":"wbw/023_108_002.mp3","charTypeName":"word"},{"id":73702,"position":3,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/023_108_003.mp3","charTypeName":"word"},{"id":73703,"position":4,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/023_108_004.mp3","charTypeName":"word"},{"id":73704,"position":5,"arabic":"تُكَلِّمُونِ","translation":"আমার সাথে তোমরা কথা বলবে","audioUrl":"wbw/023_108_005.mp3","charTypeName":"word"},{"id":73705,"position":6,"arabic":"١٠٨","translation":"(১০৮)","audioUrl":null,"charTypeName":"end"}]},{"number":109,"arabic":"إِنَّهُۥ كَانَ فَرِيقٌۭ مِّنْ عِبَادِى يَقُولُونَ رَبَّنَآ ءَامَنَّا فَٱغْفِرْ لَنَا وَٱرْحَمْنَا وَأَنتَ خَيْرُ ٱلرَّٰحِمِينَ","translation":"“Behold, there were among My servants such as would pray, ‘O our Sustainer! We have come to believe [in Thee]; forgive, then, our sins and bestow Thy mercy on us: for Thou art the truest bestower of mercy!’","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2782.mp3","surahId":23,"words":[{"id":73870,"position":1,"arabic":"إِنَّهُۥ","translation":"নিশ্চয়ই","audioUrl":"wbw/023_109_001.mp3","charTypeName":"word"},{"id":73871,"position":2,"arabic":"كَانَ","translation":"ছিলো","audioUrl":"wbw/023_109_002.mp3","charTypeName":"word"},{"id":73872,"position":3,"arabic":"فَرِيقٌۭ","translation":"একদল","audioUrl":"wbw/023_109_003.mp3","charTypeName":"word"},{"id":73873,"position":4,"arabic":"مِّنْ","translation":"মধ্যে","audioUrl":"wbw/023_109_004.mp3","charTypeName":"word"},{"id":73874,"position":5,"arabic":"عِبَادِى","translation":"আমার দাসদের","audioUrl":"wbw/023_109_005.mp3","charTypeName":"word"},{"id":73875,"position":6,"arabic":"يَقُولُونَ","translation":"(যারা) বলতো","audioUrl":"wbw/023_109_006.mp3","charTypeName":"word"},{"id":73876,"position":7,"arabic":"رَبَّنَآ","translation":"\"হে আমাদের রব","audioUrl":"wbw/023_109_007.mp3","charTypeName":"word"},{"id":73877,"position":8,"arabic":"ءَامَنَّا","translation":"আমরা ঈমান এনেছি","audioUrl":"wbw/023_109_008.mp3","charTypeName":"word"},{"id":73878,"position":9,"arabic":"فَٱغْفِرْ","translation":"তাই ক্ষমা করো","audioUrl":"wbw/023_109_009.mp3","charTypeName":"word"},{"id":73879,"position":10,"arabic":"لَنَا","translation":"আমাদেরকে","audioUrl":"wbw/023_109_010.mp3","charTypeName":"word"},{"id":73880,"position":11,"arabic":"وَٱرْحَمْنَا","translation":"ও আমাদের উপর দয়া করো","audioUrl":"wbw/023_109_011.mp3","charTypeName":"word"},{"id":73881,"position":12,"arabic":"وَأَنتَ","translation":"আর তুমিই","audioUrl":"wbw/023_109_012.mp3","charTypeName":"word"},{"id":73882,"position":13,"arabic":"خَيْرُ","translation":"অতি উত্তম","audioUrl":"wbw/023_109_013.mp3","charTypeName":"word"},{"id":73883,"position":14,"arabic":"ٱلرَّٰحِمِينَ","translation":"দয়াকারীদের","audioUrl":"wbw/023_109_014.mp3","charTypeName":"word"},{"id":73884,"position":15,"arabic":"١٠٩","translation":"(১০৯)","audioUrl":null,"charTypeName":"end"}]},{"number":110,"arabic":"فَٱتَّخَذْتُمُوهُمْ سِخْرِيًّا حَتَّىٰٓ أَنسَوْكُمْ ذِكْرِى وَكُنتُم مِّنْهُمْ تَضْحَكُونَ","translation":"- but you made them a target of your derision to the point where it made you forget all remembrance of Me; and you went on and on laugh­ing at them.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2783.mp3","surahId":23,"words":[{"id":74041,"position":1,"arabic":"فَٱتَّخَذْتُمُوهُمْ","translation":"তখন তোমরা গ্রহণ করেছিলে তাদেরকে","audioUrl":"wbw/023_110_001.mp3","charTypeName":"word"},{"id":74042,"position":2,"arabic":"سِخْرِيًّا","translation":"ঠাট্টার পাত্ররূপে","audioUrl":"wbw/023_110_002.mp3","charTypeName":"word"},{"id":74043,"position":3,"arabic":"حَتَّىٰٓ","translation":"এমনকি (তা)","audioUrl":"wbw/023_110_003.mp3","charTypeName":"word"},{"id":74044,"position":4,"arabic":"أَنسَوْكُمْ","translation":"তোমাদেরকে ভুলিয়ে দিয়েছিলো","audioUrl":"wbw/023_110_004.mp3","charTypeName":"word"},{"id":74045,"position":5,"arabic":"ذِكْرِى","translation":"আমার স্মরণ","audioUrl":"wbw/023_110_005.mp3","charTypeName":"word"},{"id":74046,"position":6,"arabic":"وَكُنتُم","translation":"আর তোমরা ছিলে","audioUrl":"wbw/023_110_006.mp3","charTypeName":"word"},{"id":74047,"position":7,"arabic":"مِّنْهُمْ","translation":"সাথে তাদের","audioUrl":"wbw/023_110_007.mp3","charTypeName":"word"},{"id":74048,"position":8,"arabic":"تَضْحَكُونَ","translation":"ঠাট্টা-বিদ্রুপ করতে","audioUrl":"wbw/023_110_008.mp3","charTypeName":"word"},{"id":74049,"position":9,"arabic":"١١٠","translation":"(১১০)","audioUrl":null,"charTypeName":"end"}]},{"number":111,"arabic":"إِنِّى جَزَيْتُهُمُ ٱلْيَوْمَ بِمَا صَبَرُوٓا۟ أَنَّهُمْ هُمُ ٱلْفَآئِزُونَ","translation":"[But,] behold, today I have rewarded them for their patience in adversity: verily, it is they, they who have achieved a triumph!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2784.mp3","surahId":23,"words":[{"id":74468,"position":1,"arabic":"إِنِّى","translation":"নিশ্চয়ই আমি","audioUrl":"wbw/023_111_001.mp3","charTypeName":"word"},{"id":74469,"position":2,"arabic":"جَزَيْتُهُمُ","translation":"আমি পুরস্কার দিলাম তাদেরকে","audioUrl":"wbw/023_111_002.mp3","charTypeName":"word"},{"id":74470,"position":3,"arabic":"ٱلْيَوْمَ","translation":"আজ","audioUrl":"wbw/023_111_003.mp3","charTypeName":"word"},{"id":74471,"position":4,"arabic":"بِمَا","translation":"এ কারণে যে","audioUrl":"wbw/023_111_004.mp3","charTypeName":"word"},{"id":74472,"position":5,"arabic":"صَبَرُوٓا۟","translation":"তারা ধৈর্য ধরেছিলো","audioUrl":"wbw/023_111_005.mp3","charTypeName":"word"},{"id":74473,"position":6,"arabic":"أَنَّهُمْ","translation":"(ফল এই) যে তারা","audioUrl":"wbw/023_111_006.mp3","charTypeName":"word"},{"id":74474,"position":7,"arabic":"هُمُ","translation":"তারাই","audioUrl":"wbw/023_111_007.mp3","charTypeName":"word"},{"id":74475,"position":8,"arabic":"ٱلْفَآئِزُونَ","translation":"সফলকাম (হলো)","audioUrl":"wbw/023_111_008.mp3","charTypeName":"word"},{"id":74476,"position":9,"arabic":"١١١","translation":"(১১১)","audioUrl":null,"charTypeName":"end"}]},{"number":112,"arabic":"قَٰلَ كَمْ لَبِثْتُمْ فِى ٱلْأَرْضِ عَدَدَ سِنِينَ","translation":"[And] He will ask [the doomed]: “What number of years have you spent on earth?”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2785.mp3","surahId":23,"words":[{"id":74825,"position":1,"arabic":"قَـٰلَ","translation":"(আল্লাহ) বলবেন","audioUrl":"wbw/023_112_001.mp3","charTypeName":"word"},{"id":74826,"position":2,"arabic":"كَمْ","translation":"\"কত (কাল)","audioUrl":"wbw/023_112_002.mp3","charTypeName":"word"},{"id":74827,"position":3,"arabic":"لَبِثْتُمْ","translation":"তোমরা অবস্থান করেছিলে","audioUrl":"wbw/023_112_003.mp3","charTypeName":"word"},{"id":74828,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/023_112_004.mp3","charTypeName":"word"},{"id":74829,"position":5,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/023_112_005.mp3","charTypeName":"word"},{"id":74830,"position":6,"arabic":"عَدَدَ","translation":"হিসেবে","audioUrl":"wbw/023_112_006.mp3","charTypeName":"word"},{"id":74831,"position":7,"arabic":"سِنِينَ","translation":"বছরের\"","audioUrl":"wbw/023_112_007.mp3","charTypeName":"word"},{"id":74832,"position":8,"arabic":"١١٢","translation":"(১১২)","audioUrl":null,"charTypeName":"end"}]},{"number":113,"arabic":"قَالُوا۟ لَبِثْنَا يَوْمًا أَوْ بَعْضَ يَوْمٍۢ فَسْـَٔلِ ٱلْعَآدِّينَ","translation":"They will answer: ‘We have spent there a day, or part of a day; but ask those who [are able to] count [time] …”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2786.mp3","surahId":23,"words":[{"id":75022,"position":1,"arabic":"قَالُوا۟","translation":"তারা বলবে","audioUrl":"wbw/023_113_001.mp3","charTypeName":"word"},{"id":75023,"position":2,"arabic":"لَبِثْنَا","translation":"\"আমরা অবস্থান করেছিলাম","audioUrl":"wbw/023_113_002.mp3","charTypeName":"word"},{"id":75024,"position":3,"arabic":"يَوْمًا","translation":"একদিন","audioUrl":"wbw/023_113_003.mp3","charTypeName":"word"},{"id":75025,"position":4,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/023_113_004.mp3","charTypeName":"word"},{"id":75026,"position":5,"arabic":"بَعْضَ","translation":"কিছু অংশ","audioUrl":"wbw/023_113_005.mp3","charTypeName":"word"},{"id":75027,"position":6,"arabic":"يَوْمٍۢ","translation":"দিনের","audioUrl":"wbw/023_113_006.mp3","charTypeName":"word"},{"id":75028,"position":7,"arabic":"فَسْـَٔلِ","translation":"তবে জিজ্ঞেস করুন","audioUrl":"wbw/023_113_007.mp3","charTypeName":"word"},{"id":75029,"position":8,"arabic":"ٱلْعَآدِّينَ","translation":"গণনাকারীদেরকে\"","audioUrl":"wbw/023_113_008.mp3","charTypeName":"word"},{"id":75030,"position":9,"arabic":"١١٣","translation":"(১১৩)","audioUrl":null,"charTypeName":"end"}]},{"number":114,"arabic":"قَٰلَ إِن لَّبِثْتُمْ إِلَّا قَلِيلًۭا ۖ لَّوْ أَنَّكُمْ كُنتُمْ تَعْلَمُونَ","translation":"[Whereupon] He will say: “You have spent there but a short while: had you but known [how short it was to be]!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2787.mp3","surahId":23,"words":[{"id":75185,"position":1,"arabic":"قَـٰلَ","translation":"(আল্লাহ) বলবেন","audioUrl":"wbw/023_114_001.mp3","charTypeName":"word"},{"id":75186,"position":2,"arabic":"إِن","transla