{"id":224,"ayahs":[{"number":20,"arabic":"أُو۟لَٰٓئِكَ لَمْ يَكُونُوا۟ مُعْجِزِينَ فِى ٱلْأَرْضِ وَمَا كَانَ لَهُم مِّن دُونِ ٱللَّهِ مِنْ أَوْلِيَآءَ ۘ يُضَٰعَفُ لَهُمُ ٱلْعَذَابُ ۚ مَا كَانُوا۟ يَسْتَطِيعُونَ ٱلسَّمْعَ وَمَا كَانُوا۟ يُبْصِرُونَ","translation":"Never can they elude [their final reckoning, even if they remain unscathed] on earth: never will they find anyone who could protect them from God. [In the life to come] double suffering will be imposed on them for having lost the ability to hear [the truth] and having failed to see [it].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1493.mp3","surahId":11,"words":[{"id":22977,"position":1,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐসব লোক","audioUrl":"wbw/011_020_001.mp3","charTypeName":"word"},{"id":22978,"position":2,"arabic":"لَمْ","translation":"না","audioUrl":"wbw/011_020_002.mp3","charTypeName":"word"},{"id":22979,"position":3,"arabic":"يَكُونُوا۟","translation":"তারা ছিলো (সক্ষম)","audioUrl":"wbw/011_020_003.mp3","charTypeName":"word"},{"id":22980,"position":4,"arabic":"مُعْجِزِينَ","translation":"(আল্লাহ-কে) অক্ষমকারী","audioUrl":"wbw/011_020_004.mp3","charTypeName":"word"},{"id":22981,"position":5,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/011_020_005.mp3","charTypeName":"word"},{"id":22982,"position":6,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/011_020_006.mp3","charTypeName":"word"},{"id":22983,"position":7,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/011_020_007.mp3","charTypeName":"word"},{"id":22984,"position":8,"arabic":"كَانَ","translation":"ছিলো","audioUrl":"wbw/011_020_008.mp3","charTypeName":"word"},{"id":22985,"position":9,"arabic":"لَهُم","translation":"তাদের জন্যে","audioUrl":"wbw/011_020_009.mp3","charTypeName":"word"},{"id":22986,"position":10,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/011_020_010.mp3","charTypeName":"word"},{"id":22987,"position":11,"arabic":"دُونِ","translation":"ছাড়া","audioUrl":"wbw/011_020_011.mp3","charTypeName":"word"},{"id":22988,"position":12,"arabic":"ٱللَّهِ","translation":"আল্লাহ","audioUrl":"wbw/011_020_012.mp3","charTypeName":"word"},{"id":22989,"position":13,"arabic":"مِنْ","translation":"কোন","audioUrl":"wbw/011_020_013.mp3","charTypeName":"word"},{"id":22990,"position":14,"arabic":"أَوْلِيَآءَ ۘ","translation":"অভিভাবক","audioUrl":"wbw/011_020_014.mp3","charTypeName":"word"},{"id":22992,"position":15,"arabic":"يُضَـٰعَفُ","translation":"দ্বিগুণ করা হবে","audioUrl":"wbw/011_020_016.mp3","charTypeName":"word"},{"id":22993,"position":16,"arabic":"لَهُمُ","translation":"তাদের জন্যে","audioUrl":"wbw/011_020_017.mp3","charTypeName":"word"},{"id":22994,"position":17,"arabic":"ٱلْعَذَابُ ۚ","translation":"শাস্তি","audioUrl":"wbw/011_020_018.mp3","charTypeName":"word"},{"id":22996,"position":18,"arabic":"مَا","translation":"না","audioUrl":"wbw/011_020_020.mp3","charTypeName":"word"},{"id":22997,"position":19,"arabic":"كَانُوا۟","translation":"ছিলো","audioUrl":"wbw/011_020_021.mp3","charTypeName":"word"},{"id":22998,"position":20,"arabic":"يَسْتَطِيعُونَ","translation":"তারা সক্ষম","audioUrl":"wbw/011_020_022.mp3","charTypeName":"word"},{"id":22999,"position":21,"arabic":"ٱلسَّمْعَ","translation":"শুনতে","audioUrl":"wbw/011_020_023.mp3","charTypeName":"word"},{"id":23000,"position":22,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/011_020_024.mp3","charTypeName":"word"},{"id":23001,"position":23,"arabic":"كَانُوا۟","translation":"ছিলো (সক্ষম)","audioUrl":"wbw/011_020_025.mp3","charTypeName":"word"},{"id":23002,"position":24,"arabic":"يُبْصِرُونَ","translation":"তারা দেখতে","audioUrl":"wbw/011_020_026.mp3","charTypeName":"word"},{"id":23003,"position":25,"arabic":"٢٠","translation":"(২০)","audioUrl":null,"charTypeName":"end"}]},{"number":21,"arabic":"أُو۟لَٰٓئِكَ ٱلَّذِينَ خَسِرُوٓا۟ أَنفُسَهُمْ وَضَلَّ عَنْهُم مَّا كَانُوا۟ يَفْتَرُونَ","translation":"It is they who have squandered their own selves-for [on the Day of Resurrection] all their false imagery will have forsaken them:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1494.mp3","surahId":11,"words":[{"id":24015,"position":1,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐসব লোক","audioUrl":"wbw/011_021_001.mp3","charTypeName":"word"},{"id":24016,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/011_021_002.mp3","charTypeName":"word"},{"id":24017,"position":3,"arabic":"خَسِرُوٓا۟","translation":"ক্ষতি করেছে","audioUrl":"wbw/011_021_003.mp3","charTypeName":"word"},{"id":24018,"position":4,"arabic":"أَنفُسَهُمْ","translation":"তাদের নিজেদেরকে","audioUrl":"wbw/011_021_004.mp3","charTypeName":"word"},{"id":24019,"position":5,"arabic":"وَضَلَّ","translation":"ও উধাও হয়েছে","audioUrl":"wbw/011_021_005.mp3","charTypeName":"word"},{"id":24020,"position":6,"arabic":"عَنْهُم","translation":"তাদের থেকে","audioUrl":"wbw/011_021_006.mp3","charTypeName":"word"},{"id":24021,"position":7,"arabic":"مَّا","translation":"যা","audioUrl":"wbw/011_021_007.mp3","charTypeName":"word"},{"id":24022,"position":8,"arabic":"كَانُوا۟","translation":"করতেছিলো","audioUrl":"wbw/011_021_008.mp3","charTypeName":"word"},{"id":24023,"position":9,"arabic":"يَفْتَرُونَ","translation":"তারা রচনা","audioUrl":"wbw/011_021_009.mp3","charTypeName":"word"},{"id":24024,"position":10,"arabic":"٢١","translation":"(২১)","audioUrl":null,"charTypeName":"end"}]},{"number":22,"arabic":"لَا جَرَمَ أَنَّهُمْ فِى ٱلْءَاخِرَةِ هُمُ ٱلْأَخْسَرُونَ","translation":"truly it is they, they who in the life to come shall be the losers!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1495.mp3","surahId":11,"words":[{"id":25032,"position":1,"arabic":"لَا","translation":"নেই","audioUrl":"wbw/011_022_001.mp3","charTypeName":"word"},{"id":25033,"position":2,"arabic":"جَرَمَ","translation":"কোন সন্দেহ","audioUrl":"wbw/011_022_002.mp3","charTypeName":"word"},{"id":25034,"position":3,"arabic":"أَنَّهُمْ","translation":"যে তারা","audioUrl":"wbw/011_022_003.mp3","charTypeName":"word"},{"id":25035,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/011_022_004.mp3","charTypeName":"word"},{"id":25036,"position":5,"arabic":"ٱلْـَٔاخِرَةِ","translation":"পরকালের","audioUrl":"wbw/011_022_005.mp3","charTypeName":"word"},{"id":25037,"position":6,"arabic":"هُمُ","translation":"তারাই","audioUrl":"wbw/011_022_006.mp3","charTypeName":"word"},{"id":25038,"position":7,"arabic":"ٱلْأَخْسَرُونَ","translation":"সর্বাধিক ক্ষতিগ্রস্ত (হবে)","audioUrl":"wbw/011_022_007.mp3","charTypeName":"word"},{"id":25039,"position":8,"arabic":"٢٢","translation":"(২২)","audioUrl":null,"charTypeName":"end"}]},{"number":23,"arabic":"إِنَّ ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ وَأَخْبَتُوٓا۟ إِلَىٰ رَبِّهِمْ أُو۟لَٰٓئِكَ أَصْحَٰبُ ٱلْجَنَّةِ ۖ هُمْ فِيهَا خَٰلِدُونَ","translation":"Behold, [only] those who attain to faith and do righteous deeds and humble themselves before their Sustainer - [only] they are destined for paradise, and there shall they abide.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1496.mp3","surahId":11,"words":[{"id":26102,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/011_023_001.mp3","charTypeName":"word"},{"id":26103,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/011_023_002.mp3","charTypeName":"word"},{"id":26104,"position":3,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/011_023_003.mp3","charTypeName":"word"},{"id":26105,"position":4,"arabic":"وَعَمِلُوا۟","translation":"ও কাজ করেছে","audioUrl":"wbw/011_023_004.mp3","charTypeName":"word"},{"id":26106,"position":5,"arabic":"ٱلصَّـٰلِحَـٰتِ","translation":"সৎ","audioUrl":"wbw/011_023_005.mp3","charTypeName":"word"},{"id":26107,"position":6,"arabic":"وَأَخْبَتُوٓا۟","translation":"ও তারা বিনয়াবনত হয়েছে","audioUrl":"wbw/011_023_006.mp3","charTypeName":"word"},{"id":26108,"position":7,"arabic":"إِلَىٰ","translation":"প্রতি","audioUrl":"wbw/011_023_007.mp3","charTypeName":"word"},{"id":26109,"position":8,"arabic":"رَبِّهِمْ","translation":"তাদের রবের","audioUrl":"wbw/011_023_008.mp3","charTypeName":"word"},{"id":26110,"position":9,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐসব লোক","audioUrl":"wbw/011_023_009.mp3","charTypeName":"word"},{"id":26111,"position":10,"arabic":"أَصْحَـٰبُ","translation":"অধিবাসী হবে","audioUrl":"wbw/011_023_010.mp3","charTypeName":"word"},{"id":26112,"position":11,"arabic":"ٱلْجَنَّةِ ۖ","translation":"জান্নাতের","audioUrl":"wbw/011_023_011.mp3","charTypeName":"word"},{"id":26114,"position":12,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/011_023_013.mp3","charTypeName":"word"},{"id":26115,"position":13,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/011_023_014.mp3","charTypeName":"word"},{"id":26116,"position":14,"arabic":"خَـٰلِدُونَ","translation":"চিরস্থায়ী হবে","audioUrl":"wbw/011_023_015.mp3","charTypeName":"word"},{"id":26117,"position":15,"arabic":"٢٣","translation":"(২৩)","audioUrl":null,"charTypeName":"end"}]},{"number":24,"arabic":"۞ مَثَلُ ٱلْفَرِيقَيْنِ كَٱلْأَعْمَىٰ وَٱلْأَصَمِّ وَٱلْبَصِيرِ وَٱلسَّمِيعِ ۚ هَلْ يَسْتَوِيَانِ مَثَلًا ۚ أَفَلَا تَذَكَّرُونَ","translation":"These two kinds of man may be likened to the blind and deaf and the seeing and hearing. Can these two be deemed alike in [their] nature? ` Will you not, then, keep this in mind?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1497.mp3","surahId":11,"words":[{"id":27164,"position":1,"arabic":"۞ مَثَلُ","translation":"উপমা","audioUrl":"wbw/011_024_002.mp3","charTypeName":"word"},{"id":27165,"position":2,"arabic":"ٱلْفَرِيقَيْنِ","translation":"দলের","audioUrl":"wbw/011_024_003.mp3","charTypeName":"word"},{"id":27166,"position":3,"arabic":"كَٱلْأَعْمَىٰ","translation":"যেমন একজন অন্ধ","audioUrl":"wbw/011_024_004.mp3","charTypeName":"word"},{"id":27167,"position":4,"arabic":"وَٱلْأَصَمِّ","translation":"ও বধির","audioUrl":"wbw/011_024_005.mp3","charTypeName":"word"},{"id":27168,"position":5,"arabic":"وَٱلْبَصِيرِ","translation":"এবং (অপরজন) দৃষ্টিসম্পন্ন","audioUrl":"wbw/011_024_006.mp3","charTypeName":"word"},{"id":27169,"position":6,"arabic":"وَٱلسَّمِيعِ ۚ","translation":"ও শ্রবণশীল","audioUrl":"wbw/011_024_007.mp3","charTypeName":"word"},{"id":27171,"position":7,"arabic":"هَلْ","translation":"কি","audioUrl":"wbw/011_024_009.mp3","charTypeName":"word"},{"id":27172,"position":8,"arabic":"يَسْتَوِيَانِ","translation":"দু'টো সমান হয়","audioUrl":"wbw/011_024_010.mp3","charTypeName":"word"},{"id":27173,"position":9,"arabic":"مَثَلًا ۚ","translation":"তুলনায়","audioUrl":"wbw/011_024_011.mp3","charTypeName":"word"},{"id":27175,"position":10,"arabic":"أَفَلَا","translation":"তবুও কি না","audioUrl":"wbw/011_024_013.mp3","charTypeName":"word"},{"id":27176,"position":11,"arabic":"تَذَكَّرُونَ","translation":"তোমরা শিক্ষা গ্রহণ করবে","audioUrl":"wbw/011_024_014.mp3","charTypeName":"word"},{"id":27177,"position":12,"arabic":"٢٤","translation":"(২৪)","audioUrl":null,"charTypeName":"end"}]},{"number":25,"arabic":"وَلَقَدْ أَرْسَلْنَا نُوحًا إِلَىٰ قَوْمِهِۦٓ إِنِّى لَكُمْ نَذِيرٌۭ مُّبِينٌ","translation":"AND INDEED, [it was with the same message that] We sent forth Noah unto his people: \"Behold, I come unto you with the plain warning","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1498.mp3","surahId":11,"words":[{"id":28185,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/011_025_001.mp3","charTypeName":"word"},{"id":28186,"position":2,"arabic":"أَرْسَلْنَا","translation":"আমরা পাঠিয়েছি","audioUrl":"wbw/011_025_002.mp3","charTypeName":"word"},{"id":28187,"position":3,"arabic":"نُوحًا","translation":"নূহকে","audioUrl":"wbw/011_025_003.mp3","charTypeName":"word"},{"id":28188,"position":4,"arabic":"إِلَىٰ","translation":"কাছে","audioUrl":"wbw/011_025_004.mp3","charTypeName":"word"},{"id":28189,"position":5,"arabic":"قَوْمِهِۦٓ","translation":"তাঁর জাতির","audioUrl":"wbw/011_025_005.mp3","charTypeName":"word"},{"id":28190,"position":6,"arabic":"إِنِّى","translation":"\"(সে বলেছিলো) আমি নিশ্চয়ই","audioUrl":"wbw/011_025_006.mp3","charTypeName":"word"},{"id":28191,"position":7,"arabic":"لَكُمْ","translation":"তোমাদের জন্যে","audioUrl":"wbw/011_025_007.mp3","charTypeName":"word"},{"id":28192,"position":8,"arabic":"نَذِيرٌۭ","translation":"সতর্ককারী","audioUrl":"wbw/011_025_008.mp3","charTypeName":"word"},{"id":28193,"position":9,"arabic":"مُّبِينٌ","translation":"সুস্পষ্ট","audioUrl":"wbw/011_025_009.mp3","charTypeName":"word"},{"id":28194,"position":10,"arabic":"٢٥","translation":"(২৫)","audioUrl":null,"charTypeName":"end"}]},{"number":26,"arabic":"أَن لَّا تَعْبُدُوٓا۟ إِلَّا ٱللَّهَ ۖ إِنِّىٓ أَخَافُ عَلَيْكُمْ عَذَابَ يَوْمٍ أَلِيمٍۢ","translation":"that you may worship none but God-for, verily, I fear lest suffering befall you on a grievous Day!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1499.mp3","surahId":11,"words":[{"id":29149,"position":1,"arabic":"أَن","translation":"(সে বলেছিলো) যে","audioUrl":"wbw/011_026_001.mp3","charTypeName":"word"},{"id":29150,"position":2,"arabic":"لَّا","translation":"না","audioUrl":"wbw/011_026_002.mp3","charTypeName":"word"},{"id":29151,"position":3,"arabic":"تَعْبُدُوٓا۟","translation":"তোমরা উপাসনা করো","audioUrl":"wbw/011_026_003.mp3","charTypeName":"word"},{"id":29152,"position":4,"arabic":"إِلَّا","translation":"এছাড়া","audioUrl":"wbw/011_026_004.mp3","charTypeName":"word"},{"id":29153,"position":5,"arabic":"ٱللَّهَ ۖ","translation":"আল্লাহর","audioUrl":"wbw/011_026_005.mp3","charTypeName":"word"},{"id":29155,"position":6,"arabic":"إِنِّىٓ","translation":"নিশ্চয়ই আমি","audioUrl":"wbw/011_026_007.mp3","charTypeName":"word"},{"id":29156,"position":7,"arabic":"أَخَافُ","translation":"আমি আশঙ্কা করি","audioUrl":"wbw/011_026_008.mp3","charTypeName":"word"},{"id":29157,"position":8,"arabic":"عَلَيْكُمْ","translation":"তোমাদের উপর","audioUrl":"wbw/011_026_009.mp3","charTypeName":"word"},{"id":29158,"position":9,"arabic":"عَذَابَ","translation":"শাস্তির","audioUrl":"wbw/011_026_010.mp3","charTypeName":"word"},{"id":29159,"position":10,"arabic":"يَوْمٍ","translation":"দিনের","audioUrl":"wbw/011_026_011.mp3","charTypeName":"word"},{"id":29160,"position":11,"arabic":"أَلِيمٍۢ","translation":"যন্ত্রণাদায়ক\"","audioUrl":"wbw/011_026_012.mp3","charTypeName":"word"},{"id":29161,"position":12,"arabic":"٢٦","translation":"(২৬)","audioUrl":null,"charTypeName":"end"}]},{"number":27,"arabic":"فَقَالَ ٱلْمَلَأُ ٱلَّذِينَ كَفَرُوا۟ مِن قَوْمِهِۦ مَا نَرَىٰكَ إِلَّا بَشَرًۭا مِّثْلَنَا وَمَا نَرَىٰكَ ٱتَّبَعَكَ إِلَّا ٱلَّذِينَ هُمْ أَرَاذِلُنَا بَادِىَ ٱلرَّأْىِ وَمَا نَرَىٰ لَكُمْ عَلَيْنَا مِن فَضْلٍۭ بَلْ نَظُنُّكُمْ كَٰذِبِينَ","translation":"But the great ones among his people, who refused to acknowledge the truth, answered: \"We do not see in thee anything but a mortal man like ourselves; and we do not see that any follow thee save those who are quite obviously the most abject among us; and we do not see that you could be in any way superior to us: on the contrary, we think that you are liars!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1500.mp3","surahId":11,"words":[{"id":30042,"position":1,"arabic":"فَقَالَ","translation":"অতঃপর বললো","audioUrl":"wbw/011_027_001.mp3","charTypeName":"word"},{"id":30043,"position":2,"arabic":"ٱلْمَلَأُ","translation":"(তার জাতির) প্রধানরা","audioUrl":"wbw/011_027_002.mp3","charTypeName":"word"},{"id":30044,"position":3,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/011_027_003.mp3","charTypeName":"word"},{"id":30045,"position":4,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করেছিলো","audioUrl":"wbw/011_027_004.mp3","charTypeName":"word"},{"id":30046,"position":5,"arabic":"مِن","translation":"মধ্য হ'তে","audioUrl":"wbw/011_027_005.mp3","charTypeName":"word"},{"id":30047,"position":6,"arabic":"قَوْمِهِۦ","translation":"তাঁর জাতির","audioUrl":"wbw/011_027_006.mp3","charTypeName":"word"},{"id":30048,"position":7,"arabic":"مَا","translation":"\"না","audioUrl":"w