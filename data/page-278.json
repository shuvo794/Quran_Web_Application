,"position":4,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/016_095_004.mp3","charTypeName":"word"},{"id":69675,"position":5,"arabic":"ثَمَنًۭا","translation":"মূল্যে","audioUrl":"wbw/016_095_005.mp3","charTypeName":"word"},{"id":69676,"position":6,"arabic":"قَلِيلًا ۚ","translation":"সামান্য","audioUrl":"wbw/016_095_006.mp3","charTypeName":"word"},{"id":69678,"position":7,"arabic":"إِنَّمَا","translation":"প্রকৃতপক্ষে","audioUrl":"wbw/016_095_008.mp3","charTypeName":"word"},{"id":69679,"position":8,"arabic":"عِندَ","translation":"কাছে (যা)","audioUrl":"wbw/016_095_009.mp3","charTypeName":"word"},{"id":69680,"position":9,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/016_095_010.mp3","charTypeName":"word"},{"id":69681,"position":10,"arabic":"هُوَ","translation":"তা-ই","audioUrl":"wbw/016_095_011.mp3","charTypeName":"word"},{"id":69682,"position":11,"arabic":"خَيْرٌۭ","translation":"উত্তম","audioUrl":"wbw/016_095_012.mp3","charTypeName":"word"},{"id":69683,"position":12,"arabic":"لَّكُمْ","translation":"জন্যে তোমাদের","audioUrl":"wbw/016_095_013.mp3","charTypeName":"word"},{"id":69684,"position":13,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/016_095_014.mp3","charTypeName":"word"},{"id":69685,"position":14,"arabic":"كُنتُمْ","translation":"তোমরা ছিলে","audioUrl":"wbw/016_095_015.mp3","charTypeName":"word"},{"id":69686,"position":15,"arabic":"تَعْلَمُونَ","translation":"তোমরা জানো","audioUrl":"wbw/016_095_016.mp3","charTypeName":"word"},{"id":69687,"position":16,"arabic":"٩٥","translation":"(৯৫)","audioUrl":null,"charTypeName":"end"}]},{"number":96,"arabic":"مَا عِندَكُمْ يَنفَدُ ۖ وَمَا عِندَ ٱللَّهِ بَاقٍۢ ۗ وَلَنَجْزِيَنَّ ٱلَّذِينَ صَبَرُوٓا۟ أَجْرَهُم بِأَحْسَنِ مَا كَانُوا۟ يَعْمَلُونَ","translation":"all that is with you is bound to come to an end, whereas that which is with God is everlasting. And most certainly shall We grant unto those who are patient in adversity their reward in accordance with the best that they ever did.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1997.mp3","surahId":16,"words":[{"id":70207,"position":1,"arabic":"مَا","translation":"যা কিছু","audioUrl":"wbw/016_096_001.mp3","charTypeName":"word"},{"id":70208,"position":2,"arabic":"عِندَكُمْ","translation":"কাছে আছে তোমাদের","audioUrl":"wbw/016_096_002.mp3","charTypeName":"word"},{"id":70209,"position":3,"arabic":"يَنفَدُ ۖ","translation":"(তা) শেষ হয়ে যাবে","audioUrl":"wbw/016_096_003.mp3","charTypeName":"word"},{"id":70211,"position":4,"arabic":"وَمَا","translation":"এবং যা আছে","audioUrl":"wbw/016_096_005.mp3","charTypeName":"word"},{"id":70212,"position":5,"arabic":"عِندَ","translation":"কাছে","audioUrl":"wbw/016_096_006.mp3","charTypeName":"word"},{"id":70213,"position":6,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/016_096_007.mp3","charTypeName":"word"},{"id":70214,"position":7,"arabic":"بَاقٍۢ ۗ","translation":"তা স্থায়ী","audioUrl":"wbw/016_096_008.mp3","charTypeName":"word"},{"id":70216,"position":8,"arabic":"وَلَنَجْزِيَنَّ","translation":"এবং আমরা অবশ্যই প্রতিফল দিবো","audioUrl":"wbw/016_096_010.mp3","charTypeName":"word"},{"id":70217,"position":9,"arabic":"ٱلَّذِينَ","translation":"(তাদের) যারা","audioUrl":"wbw/016_096_011.mp3","charTypeName":"word"},{"id":70218,"position":10,"arabic":"صَبَرُوٓا۟","translation":"ধৈর্য ধরেছে","audioUrl":"wbw/016_096_012.mp3","charTypeName":"word"},{"id":70219,"position":11,"arabic":"أَجْرَهُم","translation":"পুরস্কার তাদের","audioUrl":"wbw/016_096_013.mp3","charTypeName":"word"},{"id":70220,"position":12,"arabic":"بِأَحْسَنِ","translation":"ভাবে অতি উত্তম","audioUrl":"wbw/016_096_014.mp3","charTypeName":"word"},{"id":70221,"position":13,"arabic":"مَا","translation":"যা","audioUrl":"wbw/016_096_015.mp3","charTypeName":"word"},{"id":70222,"position":14,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/016_096_016.mp3","charTypeName":"word"},{"id":70223,"position":15,"arabic":"يَعْمَلُونَ","translation":"তারা কাজ করতে","audioUrl":"wbw/016_096_017.mp3","charTypeName":"word"},{"id":70224,"position":16,"arabic":"٩٦","translation":"(৯৬)","audioUrl":null,"charTypeName":"end"}]},{"number":97,"arabic":"مَنْ عَمِلَ صَٰلِحًۭا مِّن ذَكَرٍ أَوْ أُنثَىٰ وَهُوَ مُؤْمِنٌۭ فَلَنُحْيِيَنَّهُۥ حَيَوٰةًۭ طَيِّبَةًۭ ۖ وَلَنَجْزِيَنَّهُمْ أَجْرَهُم بِأَحْسَنِ مَا كَانُوا۟ يَعْمَلُونَ","translation":"As for anyone - be it man or woman - who does righteous deeds, and is a believer withal - him shall We most certainly cause to live a good life. and most certainly shall We grant unto such as these their reward in accordance with the best that they ever did.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1998.mp3","surahId":16,"words":[{"id":70492,"position":1,"arabic":"مَنْ","translation":"যে","audioUrl":"wbw/016_097_001.mp3","charTypeName":"word"},{"id":70493,"position":2,"arabic":"عَمِلَ","translation":"কাজ করবে","audioUrl":"wbw/016_097_002.mp3","charTypeName":"word"},{"id":70494,"position":3,"arabic":"صَـٰلِحًۭا","translation":"সৎ","audioUrl":"wbw/016_097_003.mp3","charTypeName":"word"},{"id":70495,"position":4,"arabic":"مِّن","translation":"মধ্যে","audioUrl":"wbw/016_097_004.mp3","charTypeName":"word"},{"id":70496,"position":5,"arabic":"ذَكَرٍ","translation":"পুরুষদের","audioUrl":"wbw/016_097_005.mp3","charTypeName":"word"},{"id":70497,"position":6,"arabic":"أَوْ","translation":"বা","audioUrl":"wbw/016_097_006.mp3","charTypeName":"word"},{"id":70498,"position":7,"arabic":"أُنثَىٰ","translation":"নারীদের","audioUrl":"wbw/016_097_007.mp3","charTypeName":"word"},{"id":70499,"position":8,"arabic":"وَهُوَ","translation":"যখন সে","audioUrl":"wbw/016_097_008.mp3","charTypeName":"word"},{"id":70500,"position":9,"arabic":"مُؤْمِنٌۭ","translation":"ঈমানদারও","audioUrl":"wbw/016_097_009.mp3","charTypeName":"word"},{"id":70501,"position":10,"arabic":"فَلَنُحْيِيَنَّهُۥ","translation":"তখন অবশ্যই তাকে জীবন দিবো আমরা","audioUrl":"wbw/016_097_010.mp3","charTypeName":"word"},{"id":70502,"position":11,"arabic":"حَيَوٰةًۭ","translation":"জীবন","audioUrl":"wbw/016_097_011.mp3","charTypeName":"word"},{"id":70503,"position":12,"arabic":"طَيِّبَةًۭ ۖ","translation":"পবিত্র","audioUrl":"wbw/016_097_012.mp3","charTypeName":"word"},{"id":70505,"position":13,"arabic":"وَلَنَجْزِيَنَّهُمْ","translation":"এবং অবশ্যই তাদের প্রতিদান দিবো আমরা","audioUrl":"wbw/016_097_014.mp3","charTypeName":"word"},{"id":70506,"position":14,"arabic":"أَجْرَهُم","translation":"পুরস্কার তাদের","audioUrl":"wbw/016_097_015.mp3","charTypeName":"word"},{"id":70507,"position":15,"arabic":"بِأَحْسَنِ","translation":"ভাবে অতি উত্তম","audioUrl":"wbw/016_097_016.mp3","charTypeName":"word"},{"id":70508,"position":16,"arabic":"مَا","translation":"যা","audioUrl":"wbw/016_097_017.mp3","charTypeName":"word"},{"id":70509,"position":17,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/016_097_018.mp3","charTypeName":"word"},{"id":70510,"position":18,"arabic":"يَعْمَلُونَ","translation":"তারা করতে","audioUrl":"wbw/016_097_019.mp3","charTypeName":"word"},{"id":70511,"position":19,"arabic":"٩٧","translation":"(৯৭)","audioUrl":null,"charTypeName":"end"}]},{"number":98,"arabic":"فَإِذَا قَرَأْتَ ٱلْقُرْءَانَ فَٱسْتَعِذْ بِٱللَّهِ مِنَ ٱلشَّيْطَٰنِ ٱلرَّجِيمِ","translation":"NOW whenever thou happen to read this Qur'an, seek refuge with God from Satan, the accursed.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1999.mp3","surahId":16,"words":[{"id":70624,"position":1,"arabic":"فَإِذَا","translation":"অতঃপর যখন","audioUrl":"wbw/016_098_001.mp3","charTypeName":"word"},{"id":70625,"position":2,"arabic":"قَرَأْتَ","translation":"তুমি পাঠ করবে","audioUrl":"wbw/016_098_002.mp3","charTypeName":"word"},{"id":70626,"position":3,"arabic":"ٱلْقُرْءَانَ","translation":"কুরআন","audioUrl":"wbw/016_098_003.mp3","charTypeName":"word"},{"id":70627,"position":4,"arabic":"فَٱسْتَعِذْ","translation":"তখন আশ্রয় চাইবে","audioUrl":"wbw/016_098_004.mp3","charTypeName":"word"},{"id":70628,"position":5,"arabic":"بِٱللّ