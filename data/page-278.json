/016_099_009.mp3","charTypeName":"word"},{"id":70974,"position":10,"arabic":"يَتَوَكَّلُونَ","translation":"তারা নির্ভর করে","audioUrl":"wbw/016_099_010.mp3","charTypeName":"word"},{"id":70975,"position":11,"arabic":"٩٩","translation":"(৯৯)","audioUrl":null,"charTypeName":"end"}]},{"number":100,"arabic":"إِنَّمَا سُلْطَٰنُهُۥ عَلَى ٱلَّذِينَ يَتَوَلَّوْنَهُۥ وَٱلَّذِينَ هُم بِهِۦ مُشْرِكُونَ","translation":"he has power only over those who are willing to follow him, and who [thus] ascribe to him a share in God's divinity.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2001.mp3","surahId":16,"words":[{"id":71291,"position":1,"arabic":"إِنَّمَا","translation":"মূলতঃ","audioUrl":"wbw/016_100_001.mp3","charTypeName":"word"},{"id":71292,"position":2,"arabic":"سُلْطَـٰنُهُۥ","translation":"তার আধিপত্য","audioUrl":"wbw/016_100_002.mp3","charTypeName":"word"},{"id":71293,"position":3,"arabic":"عَلَى","translation":"(তাদের) উপর","audioUrl":"wbw/016_100_003.mp3","charTypeName":"word"},{"id":71294,"position":4,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/016_100_004.mp3","charTypeName":"word"},{"id":71295,"position":5,"arabic":"يَتَوَلَّوْنَهُۥ","translation":"তাকে অভিভাবক বানিয়েছে","audioUrl":"wbw/016_100_005.mp3","charTypeName":"word"},{"id":71296,"position":6,"arabic":"وَٱلَّذِينَ","translation":"ও যারা (এমন যে)","audioUrl":"wbw/016_100_006.mp3","charTypeName":"word"},{"id":71297,"position":7,"arabic":"هُم","translation":"তারা","audioUrl":"wbw/016_100_007.mp3","charTypeName":"word"},{"id":71298,"position":8,"arabic":"بِهِۦ","translation":"সাথে তাঁর","audioUrl":"wbw/016_100_008.mp3","charTypeName":"word"},{"id":71299,"position":9,"arabic":"مُشْرِكُونَ","translation":"শরীককারী","audioUrl":"wbw/016_100_009.mp3","charTypeName":"word"},{"id":71300,"position":10,"arabic":"١٠٠","translation":"(১০০)","audioUrl":null,"charTypeName":"end"}]},{"number":101,"arabic":"وَإِذَا بَدَّلْنَآ ءَايَةًۭ مَّكَانَ ءَايَةٍۢ ۙ وَٱللَّهُ أَعْلَمُ بِمَا يُنَزِّلُ قَالُ