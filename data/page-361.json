ition":2,"arabic":"سُبْحَـٰنَكَ","translation":"\"সত্ত্বা আপনার পবিত্র মহান","audioUrl":"wbw/025_018_002.mp3","charTypeName":"word"},{"id":20759,"position":3,"arabic":"مَا","translation":"না","audioUrl":"wbw/025_018_003.mp3","charTypeName":"word"},{"id":20760,"position":4,"arabic":"كَانَ","translation":"ছিলো","audioUrl":"wbw/025_018_004.mp3","charTypeName":"word"},{"id":20761,"position":5,"arabic":"يَنۢبَغِى","translation":"উচিত","audioUrl":"wbw/025_018_005.mp3","charTypeName":"word"},{"id":20762,"position":6,"arabic":"لَنَآ","translation":"জন্যে আমাদের","audioUrl":"wbw/025_018_006.mp3","charTypeName":"word"},{"id":20763,"position":7,"arabic":"أَن","translation":"যে","audioUrl":"wbw/025_018_007.mp3","charTypeName":"word"},{"id":20764,"position":8,"arabic":"نَّتَّخِذَ","translation":"গ্রহণ করবো আমরা","audioUrl":"wbw/025_018_008.mp3","charTypeName":"word"},{"id":20765,"position":9,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/025_018_009.mp3","charTypeName":"word"},{"id":20766,"position":10,"arabic":"دُونِكَ","translation":"আপনার পরিবর্তে","audioUrl":"wbw/025_018_010.mp3","charTypeName":"word"},{"id":20767,"position":11,"arabic":"مِنْ","translation":"কোন","audioUrl":"wbw/025_018_011.mp3","charTypeName":"word"},{"id":20768,"position":12,"arabic":"أَوْلِيَآءَ","translation":"অভিভাবক","audioUrl":"wbw/025_018_012.mp3","charTypeName":"word"},{"id":20769,"position":13,"arabic":"وَلَـٰكِن","translation":"কিন্তু","audioUrl":"wbw/025_018_013.mp3","charTypeName":"word"},{"id":20770,"position":14,"arabic":"مَّتَّعْتَهُمْ","translation":"আপনি ভোগ-সম্ভার দিয়েছেলেন তাদেরকে","audioUrl":"wbw/025_018_014.mp3","charTypeName":"word"},{"id":20771,"position":15,"arabic":"وَءَابَآءَهُمْ","translation":"এবং তাদের পিতৃ পুরুষদেরকেও","audioUrl":"wbw/025_018_015.mp3","charTypeName":"word"},{"id":20772,"position":16,"arabic":"حَتَّىٰ","translation":"শেষ পর্যন্ত","audioUrl":"wbw/025_018_016.mp3","charTypeName":"word"},{"id":20773,"position":17,"arabic":"نَسُوا۟","translation":"তারা ভুলে গিয়েছিলো","audioUrl":"wbw/025_018_017.mp3","charTypeName":"word"},{"id":20774,"position":18,"arabic":"ٱلذِّكْرَ","translation":"(আপনার) স্মরণ","audioUrl":"wbw/025_018_018.mp3","charTypeName":"word"},{"id":20775,"position":19,"arabic":"وَكَانُوا۟","translation":"এবং তারা হয়েছিলো","audioUrl":"wbw/025_018_019.mp3","charTypeName":"word"},{"id":20776,"position":20,"arabic":"قَوْمًۢا","translation":"জাতিতে","audioUrl":"wbw/025_018_020.mp3","charTypeName":"word"},{"id":20777,"position":21,"arabic":"بُورًۭا","translation":"ধ্বংসপ্রাপ্ত\"","audioUrl":"wbw/025_018_021.mp3","charTypeName":"word"},{"id":20778,"position":22,"arabic":"١٨","translation":"(১৮)","audioUrl":null,"charTypeName":"end"}]},{"number":19,"arabic":"فَقَدْ كَذَّبُوكُم بِمَا تَقُولُونَ فَمَا تَسْتَطِيعُونَ صَرْفًۭا وَلَا نَصْرًۭا ۚ وَمَن يَظْلِم مِّنكُمْ نُذِقْهُ عَذَابًۭا كَبِيرًۭا","translation":"[Thereupon God will say:] “And now, they [whom you regarded as divine] have given the lie to all your [past] assertions, and you can neither ward off [your punishment] nor obtain any succour! For, whoever of you has committed [such] evil, him shall We cause to taste great suffering!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2874.mp3","surahId":25,"words":[{"id":21897,"position":1,"arabic":"فَقَدْ","translation":"\"তখন নিশ্চয়ই","audioUrl":"wbw/025_019_001.mp3","charTypeName":"word"},{"id":21898,"position":2,"arabic":"كَذَّبُوكُم","translation":"তারা মিথ্যা সাব্যস্ত করেছে তোমাদেরকে","audioUrl":"wbw/025_019_002.mp3","charTypeName":"word"},{"id":21899,"position":3,"arabic":"بِمَا","translation":"ঐবিষয় যা","audioUrl":"wbw/025_019_003.mp3","charTypeName":"word"},{"id":21900,"position":4,"arabic":"تَقُولُونَ","translation":"তোমরা বলছো","audioUrl":"wbw/025_019_004.mp3","charTypeName":"word"},{"id":21901,"position":5,"arabic":"فَمَا","translation":"সুতরাং না","audioUrl":"wbw/025_019_005.mp3","charTypeName":"word"},{"id":21902,"position":6,"arabic":"تَسْتَطِيعُونَ","translation":"তোমরা পারবে","audioUrl":"wbw/025_019_006.mp3","charTypeName":"word"},{"id":21903,"position":7,"arabic":"صَرْفًۭا","translation":"ফিরাতে (শাস্তি)","audioUrl":"wbw/025_019_007.mp3","charTypeName":"word"},{"id":21904,"position":8,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/025_019_008.mp3","charTypeName":"word"},{"id":21905,"position":9,"arabic":"نَصْرًۭا ۚ","translation":"সাহায্যও (পাবে)\"","audioUrl":"wbw/025_019_009.mp3","charTypeName":"word"},{"id":21907,"position":10,"arabic":"وَمَن","translation":"আর যে","audioUrl":"wbw/025_019_011.mp3","charTypeName":"word"},{"id":21908,"position":11,"arabic":"يَظْلِم","translation":"সীমালঙ্ঘন করবে","audioUrl":"wbw/025_019_012.mp3","charTypeName":"word"},{"id":21909,"position":12,"arabic":"مِّنكُمْ","translation":"তোমাদের মধ্য হ'তে","audioUrl":"wbw/025_019_013.mp3","charTypeName":"word"},{"id":21910,"position":13,"arabic":"نُذِقْهُ","translation":"তাকে আস্বাদ করাবো আমরা","audioUrl":"wbw/025_019_014.mp3","charTypeName":"word"},{"id":21911,"position":14,"arabic":"عَذَابًۭا","translation":"শাস্তি","audioUrl":"wbw/025_019_015.mp3","charTypeName":"word"},{"id":21912,"position":15,"arabic":"كَبِيرًۭا","translation":"গুরুতর","audioUrl":"wbw/025_019_016.mp3","charTypeName":"word"},{"id":21913,"position":16,"arabic":"١٩","translation":"(১৯)","audioUrl":null,"charTypeName":"end"}]},{"number":20,"arabic":"وَمَآ أَرْسَلْنَا قَبْلَكَ مِنَ ٱلْمُرْسَلِينَ إِلَّآ إِنَّهُمْ لَيَأْكُلُونَ ٱلطَّعَامَ وَيَمْشُونَ فِى ٱلْأَسْوَاقِ ۗ وَجَعَلْنَا بَعْضَكُمْ لِبَعْضٍۢ فِتْنَةً أَتَصْبِرُونَ ۗ وَكَانَ رَبُّكَ بَصِيرًۭا","translation":"AND [even] before thee, [O Muhammad,] We never sent as Our message-bearers any but [mortal men] who indeed ate food [like other human beings] and went about in the market places: for [it is thus that] We cause you [human beings] to be a means of testing one another. Are you able to endure [this test] with patience? For [remember, O man,] thy Sustainer is truly all-seeing!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2875.mp3","surahId":25,"words":[{"id":22941,"position":1,"arabic":"وَمَآ","translation":"আর (হে নাবী) না","audioUrl":"wbw/025_020_001.mp3","charTypeName":"word"},{"id":22942,"position":2,"arabic":"أَرْسَلْنَا","translation":"আমরা পাঠিয়েছি","audioUrl":"wbw/025_020_002.mp3","charTypeName":"word"},{"id":22943,"position":3,"arabic":"قَبْلَكَ","translation":"তোমার পূর্বে (কাউকে)","audioUrl":"wbw/025_020_003.mp3","charTypeName":"word"},{"id":22944,"position":4,"arabic":"مِنَ","translation":"মধ্য হ'তে","audioUrl":"wbw/025_020_004.mp3","charTypeName":"word"},{"id":22945,"position":5,"arabic":"ٱلْمُرْسَلِينَ","translation":"রাসূলদের","audioUrl":"wbw/025_020_005.mp3","charTypeName":"word"},{"id":22946,"position":6,"arabic":"إِلَّآ","translation":"এ ছাড়া যে","audioUrl":"wbw/025_020_006.mp3","charTypeName":"word"},{"id":22947,"position":7,"arabic":"إِنَّهُمْ","translation":"নিশ্চয়ই তারা","audioUrl":"wbw/025_020_007.mp3","charTypeName":"word"},{"id":22948,"position":8,"arabic":"لَيَأْكُلُونَ","translation":"অবশ্যই তারা খায়","audioUrl":"wbw/025_020_008.mp3","charTypeName":"word"},{"id":22949,"position":9,"arabic":"ٱلطَّعَامَ","translation":"খাবার","audioUrl":"wbw/025_020_009.mp3","charTypeName":"word"},{"id":22950,"position":10,"arabic":"وَيَمْشُونَ","translation":"ও চলাফেরা করে","audioUrl":"wbw/025_020_010.mp3","charTypeName":"word"},{"id":22951,"position":11,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/025_020_011.mp3","charTypeName":"word"},{"id":22952,"position":12,"arabic":"ٱلْأَسْوَاقِ ۗ","translation":"হাট-বাজারগুলোর","audioUrl":"wbw/025_020_012.mp3","charTypeName":"word"},{"id":22954,"position":13,"arabic":"وَجَعَلْنَا","translation":"আর আমরা করেছি","audioUrl":"wbw/025_020_014.mp3","charTypeName":"word"},{"id":22955,"position":14,"arabic":"بَعْضَكُمْ","translation":"একে তোমাদের","audioUrl":"wbw/025_020_015.mp3","charTypeName":"word"},{"id":22956,"position":15,"arabic":"لِبَعْضٍۢ","translation":"জন্যে অপরের","audioUrl":"wbw/025_020_016.mp3","charTypeName":"word"},{"id":22957,"position":16,"arabic":"فِتْنَةً","translation":"পরীক্ষাস্বরূপ","audioUrl":"wbw/025_020_017.mp3","charTypeName":"word"},{"id":22958,"position":17,"arabic":"أَتَصْبِرُونَ ۗ","translation":"তোমরা ধৈর্য ধারণ করবে কি","audioUrl":"wbw/025_020_018.mp3","charTypeName":"word"},{"id":22960,"position":18,"arabic":"وَكَانَ","translation":"আর (জেনে রেখো) হলেন","audioUrl":"wbw/025_020_020.mp3","charTypeName":"word"},{"id":22961,"position":19,"arabic":"رَبُّكَ","translation":"তোমার রব (এমন যে)","audioUrl":"wbw/025_020_021.mp3","charTypeName":"word"},{"id":22962,"position":20,"arabic":"بَصِيرًۭا","translation":"তিনি সবকিছু দেখেন","audioUrl":"wbw/025_020_022.mp3","charTypeName":"word"},{"id":22963,"position":21,"arabic":"٢٠","translation":"(২০)","audioUrl":null,"charTypeName":"end"}]}]}