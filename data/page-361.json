":"word"},{"id":17666,"position":9,"arabic":"ٱلْمُتَّقُونَ ۚ","translation":"মুত্তাকীদেরকে","audioUrl":"wbw/025_015_009.mp3","charTypeName":"word"},{"id":17668,"position":10,"arabic":"كَانَتْ","translation":"(সেটা) হবে","audioUrl":"wbw/025_015_011.mp3","charTypeName":"word"},{"id":17669,"position":11,"arabic":"لَهُمْ","translation":"জন্যে তাদের","audioUrl":"wbw/025_015_012.mp3","charTypeName":"word"},{"id":17670,"position":12,"arabic":"جَزَآءًۭ","translation":"পুরস্কার","audioUrl":"wbw/025_015_013.mp3","charTypeName":"word"},{"id":17671,"position":13,"arabic":"وَمَصِيرًۭا","translation":"ও প্রত্যাবর্তনস্থল","audioUrl":"wbw/025_015_014.mp3","charTypeName":"word"},{"id":17672,"position":14,"arabic":"١٥","translation":"(১৫)","audioUrl":null,"charTypeName":"end"}]},{"number":16,"arabic":"لَّهُمْ فِيهَا مَا يَشَآءُونَ خَٰلِدِينَ ۚ كَانَ عَلَىٰ رَبِّكَ وَعْدًۭا مَّسْـُٔولًۭا","translation":"a promise given by thy Sustainer, [always] to be prayed for?”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2871.mp3","surahId":25,"words":[{"id":18616,"position":1,"arabic":"لَّهُمْ","translation":"জন্যে তাদের (থাকবে)","audioUrl":"wbw/025_016_001.mp3","charTypeName":"word"},{"id":18617,"position":2,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/025_016_002.mp3","charTypeName":"word"},{"id":18618,"position":3,"arabic":"مَا","translation":"যা","audioUrl":"wbw/025_016_003.mp3","charTypeName":"word"},{"id":18619,"position":4,"arabic":"يَشَآءُونَ","translation":"তারা চাইবে","audioUrl":"wbw/025_016_004.mp3","charTypeName":"word"},{"id":18620,"position":5,"arabic":"خَـٰلِدِينَ ۚ","translation":"তারা স্থায়ী হবে (সেখানে)","audioUrl":"wbw/025_016_005.mp3","charTypeName":"word"},{"id":18622,"position":6,"arabic":"كَانَ","translation":"(এটা) হলো","audioUrl":"wbw/025_016_007.mp3","charTypeName":"word"},{"id":18623,"position":7,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/025_016_008.mp3","charTypeName":"word"},{"id":18624,"position":8,"arabic":"رَبِّكَ",