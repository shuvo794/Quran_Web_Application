{"id":361,"ayahs":[{"number":12,"arabic":"إِذَا رَأَتْهُم مِّن مَّكَانٍۭ بَعِيدٍۢ سَمِعُوا۟ لَهَا تَغَيُّظًۭا وَزَفِيرًۭا","translation":"when it shall face them from afar, they will hear its angry roar and its hiss;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2867.mp3","surahId":25,"words":[{"id":14253,"position":1,"arabic":"إِذَا","translation":"যখন (আগুন )","audioUrl":"wbw/025_012_001.mp3","charTypeName":"word"},{"id":14254,"position":2,"arabic":"رَأَتْهُم","translation":"তুমি দেখবে তাদেরকে","audioUrl":"wbw/025_012_002.mp3","charTypeName":"word"},{"id":14255,"position":3,"arabic":"مِّن","translation":"হ'তে","audioUrl":"wbw/025_012_003.mp3","charTypeName":"word"},{"id":14256,"position":4,"arabic":"مَّكَانٍۭ","translation":"জায়গা","audioUrl":"wbw/025_012_004.mp3","charTypeName":"word"},{"id":14257,"position":5,"arabic":"بَعِيدٍۢ","translation":"দূরবর্তী","audioUrl":"wbw/025_012_005.mp3","charTypeName":"word"},{"id":14258,"position":6,"arabic":"سَمِعُوا۟","translation":"তারা শুনতে পাবে (তখন)","audioUrl":"wbw/025_012_006.mp3","charTypeName":"word"},{"id":14259,"position":7,"arabic":"لَهَا","translation":"প্রতি তার","audioUrl":"wbw/025_012_007.mp3","charTypeName":"word"},{"id":14260,"position":8,"arabic":"تَغَيُّظًۭا","translation":"ক্রোধের গর্জন","audioUrl":"wbw/025_012_008.mp3","charTypeName":"word"},{"id":14261,"position":9,"arabic":"وَزَفِيرًۭا","translation":"ও চীৎকার","audioUrl":"wbw/025_012_009.mp3","charTypeName":"word"},{"id":14262,"position":10,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]},{"number":13,"arabic":"وَإِذَآ أُلْقُوا۟ مِنْهَا مَكَانًۭا ضَيِّقًۭا مُّقَرَّنِينَ دَعَوْا۟ هُنَالِكَ ثُبُورًۭا","translation":"and when they are flung, linked [all] together, into a tight space within, they will pray for extinction there and then!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2868.mp3","surahId":25,"words":[{"id":15365,"position":1,"arabic":"وَإِذَآ","translation":"এবং যখন","audioUrl":