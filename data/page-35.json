{"id":35,"ayahs":[{"number":220,"arabic":"فِى ٱلدُّنْيَا وَٱلْءَاخِرَةِ ۗ وَيَسْـَٔلُونَكَ عَنِ ٱلْيَتَٰمَىٰ ۖ قُلْ إِصْلَاحٌۭ لَّهُمْ خَيْرٌۭ ۖ وَإِن تُخَالِطُوهُمْ فَإِخْوَٰنُكُمْ ۚ وَٱللَّهُ يَعْلَمُ ٱلْمُفْسِدَ مِنَ ٱلْمُصْلِحِ ۚ وَلَوْ شَآءَ ٱللَّهُ لَأَعْنَتَكُمْ ۚ إِنَّ ٱللَّهَ عَزِيزٌ حَكِيمٌۭ","translation":"on this world and on the life to come. And they will ask thee about [how to deal with] orphans. Say: \"To improve their condition is best.\" And if you share their life, [remember that] they are your brethren: for God distinguishes between him who spoils things and him who improves. And had God so willed, He would indeed have imposed on you hardships which you would not have been able to bear: [but,] behold, God is almighty, wise!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/227.mp3","surahId":2,"words":[{"id":85992,"position":1,"arabic":"فِى","translation":"সম্পর্কে","audioUrl":"wbw/002_220_001.mp3","charTypeName":"word"},{"id":85993,"position":2,"arabic":"ٱلدُّنْيَا","translation":"ইহকাল","audioUrl":"wbw/002_220_002.mp3","charTypeName":"word"},{"id":85994,"position":3,"arabic":"وَٱلْـَٔاخِرَةِ ۗ","translation":"ও পরকাল","audioUrl":"wbw/002_220_003.mp3","charTypeName":"word"},{"id":85996,"position":4,"arabic":"وَيَسْـَٔلُونَكَ","translation":"এবং তোমাকে তারা প্রশ্ন করে","audioUrl":"wbw/002_220_005.mp3","charTypeName":"word"},{"id":85997,"position":5,"arabic":"عَنِ","translation":"(আচরণ) সম্পর্কে","audioUrl":"wbw/002_220_006.mp3","charTypeName":"word"},{"id":85998,"position":6,"arabic":"ٱلْيَتَـٰمَىٰ ۖ","translation":"ইয়াতীমদের (সাথে)","audioUrl":"wbw/002_220_007.mp3","charTypeName":"word"},{"id":86000,"position":7,"arabic":"قُلْ","translation":"তুমি বলো","audioUrl":"wbw/002_220_009.mp3","charTypeName":"word"},{"id":86001,"position":8,"arabic":"إِصْلَاحٌۭ","translation":"সুব্যবস্থা করা","audioUrl":"wbw/002_220_010.mp3","charTypeName":"word"},{"id":86002,"position":9,"arabic":"لَّهُمْ","translation":"তাদের জন্যে","audioUrl":"wbw/002_220_011.mp3","charTypeName":"word"},{"id":86003,"position":10,"arabic":"خَيْرٌۭ ۖ","translation":"উত্তম","audioUrl":"wbw/002_220_012.mp3","charTypeName":"word"},{"id":86005,"position":11,"arabic":"وَإِن","translation":"এবং যদি","audioUrl":"wbw/002_220_014.mp3","charTypeName":"word"},{"id":86006,"position":12,"arabic":"تُخَالِطُوهُمْ","translation":"তাদের সাথে (খরচ পত্রে) সংমিশ্রণ কর (দোষ নেই)","audioUrl":"wbw/002_220_015.mp3","charTypeName":"word"},{"id":86007,"position":13,"arabic":"فَإِخْوَٰنُكُمْ ۚ","translation":"তারা তাহলে তোমাদের ভাই","audioUrl":"wbw/002_220_016.mp3","charTypeName":"word"},{"id":86009,"position":14,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/002_220_018.mp3","charTypeName":"word"},{"id":86010,"position":15,"arabic":"يَعْلَمُ","translation":"জানেন","audioUrl":"wbw/002_220_019.mp3","charTypeName":"word"},{"id":86011,"position":16,"arabic":"ٱلْمُفْسِدَ","translation":"অনিষ্টকারীকে (পৃথক করতে)","audioUrl":"wbw/002_220_020.mp3","charTypeName":"word"},{"id":86012,"position":17,"arabic":"مِنَ","translation":"হতে","audioUrl":"wbw/002_220_021.mp3","charTypeName":"word"},{"id":86013,"position":18,"arabic":"ٱلْمُصْلِحِ ۚ","translation":"হিতকারী","audioUrl":"wbw/002_220_022.mp3","charTypeName":"word"},{"id":86015,"position":19,"arabic":"وَلَوْ","translation":"এবং যদি","audioUrl":"wbw/002_220_024.mp3","charTypeName":"word"},{"id":86016,"position":20,"arabic":"شَآءَ","translation":"চাইতেন","audioUrl":"wbw/002_220_025.mp3","charTypeName":"word"},{"id":86017,"position":21,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/002_220_026.mp3","charTypeName":"word"},{"id":86018,"position":22,"arabic":"لَأَعْنَتَكُمْ ۚ","translation":"তোমাদেরকে অবশ্যই কষ্টে ফেলতে পারতেন","audioUrl":"wbw/002_220_027.mp3","charTypeName":"word"},{"id":86020,"position":23,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/002_220_029.mp3","charTypeName":"word"},{"id":86021,"position":24,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/002_220_030.mp3","charTypeName":"word"},{"id":86022,"position":25,"arabic":"عَزِيزٌ","translation":"পরাক্রমশালী","audioUrl":"wbw/002_220_031.mp3","charTypeName":"word"},{"id":86023,"position":26,"arabic":"حَكِيمٌۭ","translation":"মহাবিজ্ঞ","audioUrl":"wbw/002_220_032.mp3","charTypeName":"word"},{"id":86024,"position":27,"arabic":"٢٢٠","translation":"(২২০)","audioUrl":null,"charTypeName":"end"}]},{"number":221,"arabic":"وَلَا تَنكِحُوا۟ ٱلْمُشْرِكَٰتِ حَتَّىٰ يُؤْمِنَّ ۚ وَلَأَمَةٌۭ مُّؤْمِنَةٌ خَيْرٌۭ مِّن مُّشْرِكَةٍۢ وَلَوْ أَعْجَبَتْكُمْ ۗ وَلَا تُنكِحُوا۟ ٱلْمُشْرِكِينَ حَتَّىٰ يُؤْمِنُوا۟ ۚ وَلَعَبْدٌۭ مُّؤْمِنٌ خَيْرٌۭ مِّن مُّشْرِكٍۢ وَلَوْ أَعْجَبَكُمْ ۗ أُو۟لَٰٓئِكَ يَدْعُونَ إِلَى ٱلنَّارِ ۖ وَٱللَّهُ يَدْعُوٓا۟ إِلَى ٱلْجَنَّةِ وَٱلْمَغْفِرَةِ بِإِذْنِهِۦ ۖ وَيُبَيِّنُ ءَايَٰتِهِۦ لِلنَّاسِ لَعَلَّهُمْ يَتَذَكَّرُونَ","translation":"AND DO NOT marry women who ascribe divinity to aught beside God ere they attain to [true] belief: for any believing bondwoman [of God] is certainly better than a woman who ascribes divinity to aught beside God, even though she please you greatly. And do not give your women in marriage to men who ascribe divinity to aught beside God ere they attain to [true] belief: for- any believing bondman [of God] is certainly better than a man who ascribes divinity to aught beside God, even though he please you greatly. [Such as] these invite unto the fire, whereas God invites unto paradise, and unto [the achievement of] forgiveness by His leave; and He makes clear His messages unto mankind, so that they might bear them in mind.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/228.mp3","surahId":2,"words":[{"id":86025,"position":1,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/002_221_001.mp3","charTypeName":"word"},{"id":86026,"position":2,"arabic":"تَنكِحُوا۟","translation":"তোমরা বিয়ে করো","audioUrl":"wbw/002_221_002.mp3","charTypeName":"word"},{"id":86027,"position":3,"arabic":"ٱلْمُشْرِكَـٰتِ","translation":"মুশরিক নারীদেরকে","audioUrl":"wbw/002_221_003.mp3","charTypeName":"word"},{"id":86028,"position":4,"arabic":"حَتَّىٰ","translation":"যতক্ষণ না","audioUrl":"wbw/002_221_004.mp3","charTypeName":"word"},{"id":86029,"position":5,"arabic":"يُؤْمِنَّ ۚ","translation":"ঈমান আনে","audioUrl":"wbw/002_221_005.mp3","charTypeName":"word"},{"id":86031,"position":6,"arabic":"وَلَأَمَةٌۭ","translation":"এবং অবশ্যই ক্রীতদাসী","audioUrl":"wbw/002_221_007.mp3","charTypeName":"word"},{"id":86032,"position":7,"arabic":"مُّؤْمِنَةٌ","translation":"মুমিন নারী","audioUrl":"wbw/002_221_008.mp3","charTypeName":"word"},{"id":86033,"position":8,"arabic":"خَيْرٌۭ","translation":"উত্তম","audioUrl":"wbw/002_221_009.mp3","charTypeName":"word"},{"id":86034,"position":9,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/002_221_010.mp3","charTypeName":"word"},{"id":86035,"position":10,"arabic":"مُّشْرِكَةٍۢ","translation":"মুশরিক নারী","audioUrl":"wbw/002_221_011.mp3","charTypeName":"word"},{"id":86036,"position":11,"arabic":"وَلَوْ","translation":"এবং যদিও","audioUrl":"wbw/002_221_012.mp3","charTypeName":"word"},{"id":86037,"position":12,"arabic":"أَعْجَبَتْكُمْ ۗ","translation":"তোমাদের মুগ্ধ করে সে","audioUrl":"wbw/002_221_013.mp3","charTypeName":"word"},{"id":86039,"position":13,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/002_221_015.mp3","charTypeName":"word"},{"id":86040,"position":14,"arabic":"تُنكِحُوا۟","translation":"তোমরা বিয়ে দিও (মুসলিম নারীকে)","audioUrl":"wbw/002_221_016.mp3","charTypeName":"word"},{"id":86041,"position":15,"arabic":"ٱلْمُشْرِكِينَ","translation":"মুশরিক পুরুষদের (সাথে)","audioUrl":"wbw/002_221_017.mp3","charTypeName":"word"},{"id":86042,"position":16,"arabic":"حَتَّىٰ","translation":"যতক্ষণ না","audioUrl":"wbw/002_221_018.mp3","charTypeName":"word"},{"id":86043,"position":17,"arabic":"يُؤْمِنُوا۟ ۚ","translation":"তারা ঈমান আনে","audioUrl":"wbw/002_221_019.mp3","charTypeName":"word"},{"id":86045,"position":18,"arabic":"وَلَعَبْدٌۭ","translation":"এবং অবশ্যই ক্রীতদাস","audioUrl":"wbw/002_221_021.mp3","charTypeName":"word"},{"id":86046,"position":19,"arabic":"مُّؤْمِنٌ","translation":"মু’মিন","audioUrl":"wbw/002_221_022.mp3","charTypeName":"word"},{"id":86047,"position":20,"arabic":"خَيْرٌۭ","translation":"উত্তম","audioUrl":"wbw/002_221_023.mp3","charTypeName":"word"},{"id":86048,"position":21,"arabic":"مِّن","translation":"অপেক্ষা","audioUrl":"wbw/002_221_024.mp3","charTypeName":"word"},{"id":86049,"position":22,"arabic":"مُّشْرِكٍۢ","translation":"মুশরিক পুরুষ","audioUrl":"wbw/002_221_025.mp3","charTypeName":"word"},{"id":86050,"position":23,"arabic":"وَلَوْ","translation":"এবং যদিও","audioUrl":"wbw/002_221_026.mp3","charTypeName":"word"},{"id":86051,"position":24,"arabic":"أَعْجَبَكُمْ ۗ","translation":"তোমাদের মুগ্ধ করে সে","audioUrl":"wbw/002_221_027.mp3","charTypeName":"word"},{"id":86053,"position":25,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐসব লোক","audioUrl":"wbw/002_221_029.mp3","charTypeName":"word"},{"id":86054,"position":26,"arabic":"يَدْعُونَ","translation":"ডাকে (তোমাদেরকে)","audioUrl":"wbw/002_221_030.mp3","charTypeName":"word"},{"id":86055,"position":27,"arabic":"إِلَى","translation":"দিকে","audioUrl":"wbw/002_221_031.mp3","charTypeName":"word"},{"id":86056,"position":28,"arabic":"ٱلنَّارِ ۖ","translation":"(আগুনের)","audioUrl":"wbw/002_221_032.mp3","charTypeName":"word"},{"id":86058,"position":29,"arabic":"وَٱللَّهُ","translation":"আর আল্লাহ","audioUrl":"wbw/002_221_034.mp3","charTypeName":"word"},{"id":86059,"position":30,"arabic":"يَدْعُوٓا۟","translation":"ডাকেন","audioUrl":"wbw/002_221_035.mp3","charTypeName":"word"},{"id":86060,"position":31,"arabic":"إِلَى","translation":"দিকে","audioUrl":"wbw/002_221_036.mp3","charTypeName":"word"},{"id":86061,"position":32,"arabic":"ٱلْجَنَّةِ","translation":"জান্নাতের","audioUrl":"wbw/002_221_037.mp3","charTypeName":"word"},{"id":86062,"position":33,"arabic":"وَٱلْمَغْفِرَةِ","translation":"ও ক্ষমার","audioUrl":"wbw/002_221_038.mp3","charTypeName":"word"},{"id":86063,"position":34,"arabic":"بِإِذْنِهِۦ ۖ","translation":"তাঁর অনুমতিমাধ্যমে (ও অনুগ্রহে)","audioUrl":"wbw/002_221_039.mp3","charTypeName":"word"},{"id":86065,"position":35,"arabic":"وَيُبَيِّنُ","translation":"এবং স্পষ্ট বর্ণনা করেন","audioUrl":"wbw/002_221_041.mp3","charTypeName":"word"},{"id":86066,"position":36,"arabic":"ءَايَـٰتِهِۦ","translation":"তাঁর নিদর্শনাবলী","audioUrl":"wbw/002_221_042.mp3","charTypeName":"word"},{"id":86067,"position":37,"arabic":"لِلنَّاسِ","translation":"মানুষের জন্য","audioUrl":"wbw/002_221_043.mp3","charTypeName":"word"},{"id":86068,"position":38,"arabic":"لَعَلَّهُمْ","translation":"আশা করা যায় তারা","audioUrl":"wbw/002_221_044.mp3","charTypeName":"word"},{"id":86069,"position":39,"arabic":"يَتَذَكَّرُونَ","translation":"শিক্ষা গ্রহণ করবে","audioUrl":"wbw/002_221_045.mp3","charTypeName":"word"},{"id":86070,"position":40,"arabic":"٢٢١","translation":"(২২১)","audioUrl":null,"charTypeName":"end"}]},{"number":222,"arabic":"وَيَسْـَٔلُونَكَ عَنِ ٱلْمَحِيضِ ۖ قُلْ هُوَ أَذًۭى فَٱعْتَزِلُوا۟ ٱلنِّسَآءَ فِى ٱلْمَحِيضِ ۖ وَلَا تَقْرَبُوهُنَّ حَتَّىٰ يَطْهُرْنَ ۖ فَإِذَا تَطَهَّرْنَ فَأْتُوهُنَّ مِنْ حَيْثُ أَمَرَكُمُ ٱللَّهُ ۚ إِنَّ ٱللَّهَ يُحِبُّ ٱلتَّوَّٰبِينَ وَيُحِبُّ ٱلْمُتَطَهِّرِينَ","translation":"AND THEY will ask thee about [woman's] monthly courses. Say: \"It is a vulnerable condition. Keep, therefore, aloof from women during their monthly courses, and do not draw near unto them until they are cleansed; and when they are cleansed, go in unto them as God has bidden you to do.\" Verily, God loves those who turn unto Him in repentance and He loves those who keep themselves pure.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/229.mp3","surahId":2,"words":[{"id":86078,"position":1,"arabic":"وَيَسْـَٔلُونَكَ","translation":"এবং তোমাকে তারা প্রশ্ন করে","audioUrl":"wbw/002_222_001.mp3","charTypeName":"word"},{"id":86079,"position":2,"arabic":"عَنِ","translation":"সম্পর্কে","audioUrl":"wbw/002_222_002.mp3","charTypeName":"word"},{"id":86080,"position":3,"arabic":"ٱلْمَحِيضِ ۖ","translation":"(রজঃস্রাব)","audioUrl":"wbw/002_222_003.mp3","charTypeName":"word"},{"id":86082,"position":4,"arabic":"قُلْ","translation":"তুমি বলো","audioUrl":"wbw/002_222_005.mp3","charTypeName":"word"},{"id":86083,"position":5,"arabic":"هُوَ","translation":"তা","audioUrl":"wbw/002_222_006.mp3","charTypeName":"word"},{"id":86084,"position":6,"arabic":"أَذًۭى","translation":"অশুচি/কষ্ট","audioUrl":"wbw/002_222_007.mp3","charTypeName":"word"},{"id":86085,"position":7,"arabic":"فَٱعْتَزِلُوا۟","translation":"তাই তোমরা দূরে থাক","audioUrl":"wbw/002_222_008.mp3","charTypeName":"word"},{"id":86086,"position":8,"arabic":"ٱلنِّسَآءَ","translation":"স্ত্রীদের (থেকে)","audioUrl":"wbw/002_222_009.mp3","charTypeName":"word"},{"id":86087,"position":9,"arabic":"فِى","translation":"(মধ্যে)","audioUrl":"wbw/002_222_010.mp3","charTypeName":"word"},{"id":86088,"position":10,"arabic":"ٱلْمَحِيضِ ۖ","translation":"(রজঃস্রাব)কালে","audioUrl":"wbw/002_222_011.mp3","charTypeName":"word"},{"id":86090,"position":11,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/002_222_013.mp3","charTypeName":"word"},{"id":86091,"position":12,"arabic":"تَقْرَبُوهُنَّ","translation":"তাদের নিকটে যেয়ো (স্ত্রী মিলনে)","audioUrl":"wbw/002_222_014.mp3","charTypeName":"word"},{"id":86092,"position":13,"arabic":"حَتَّىٰ","translation":"যতক্ষণ না","audioUrl":"wbw/002_222_015.mp3","charTypeName":"word"},{"id":86093,"position":14,"arabic":"يَطْهُرْنَ ۖ","translation":"তারা পবিত্র হয়(রজঃস্রাব বন্ধ হয়)","audioUrl":"wbw/002_222_016.mp3","charTypeName":"word"},{"id":86095,"position":15,"arabic":"فَإِذَا","translation":"অতঃপর যখন","audioUrl":"wbw/002_222_018.mp3","charTypeName":"word"},{"id":86096,"position":16,"arabic":"تَطَهَّرْنَ","translation":"তারা পবিত্র হয়(উত্তমরূপে গোসল করে)","audioUrl":"wbw/002_222_019.mp3","charTypeName":"word"},{"id":86097,"position":17,"arabic":"فَأْتُوهُنَّ","translation":"তখন তাদের কাছে আসো","audioUrl":"wbw/002_222_020.mp3","charTypeName":"word"},{"id":86098,"position":18,"arabic":"مِنْ","translation":"(থেকে)","audioUrl":"wbw/002_222_021.mp3","charTypeName":"word"},{"id":86099,"position":19,"arabic":"حَيْثُ","translation":"যেমন ভাবে","audioUrl":"wbw/002_222_022.mp3","charTypeName":"word"},{"id":86100,"position":20,"arabic":"أَمَرَكُمُ","translation":"তোমাদেরকে নির্দেশ দিয়েছেন","audioUrl":"wbw/002_222_023.mp3","charTypeName":"word"},{"id":86101,"position":21,"arabic":"ٱللَّهُ ۚ","translation":"আল্লাহ","audioUrl":"wbw/002_222_024.mp3","charTypeName":"word"},{"id":86103,"position":22,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/002_222_026.mp3","charTypeName":"word"},{"id":86104,"position":23,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/002_222_027.mp3","charTypeName":"word"},{"id":86105,"position":24,"arabic":"يُحِبُّ","translation":"ভালবাসেন","audioUrl":"wbw/002_222_028.mp3","charTypeName":"word"},{"id":86106,"position":25,"arabic":"ٱلتَّوَّٰبِينَ","translation":"তওবাকারীদেরকে","audioUrl":"wbw/002_222_029.mp3","charTypeName":"word"},{"id":86107,"position":26,"arabic":"وَيُحِبُّ","translation":"ও ভালবাসেন","audioUrl":"wbw/002_222_030.mp3","charTypeName":"word"},{"id":86108,"position":27,"arabic":"ٱلْمُتَطَهِّرِينَ","translation":"পবিত্রতা অবলম্বনকারীদের","audioUrl":"wbw/002_222_031.mp3","charTypeName":"word"},{"id":86109,"position":28,"arabic":"٢٢٢","translation":"(২২২)","audioUrl":null,"charTypeName":"end"}]},{"number":223,"arabic":"نِسَآؤُكُمْ حَرْثٌۭ لَّكُمْ فَأْتُوا۟ حَرْثَكُمْ أَنَّىٰ شِئْتُمْ ۖ وَقَدِّمُوا۟ لِأَنفُسِكُمْ ۚ وَٱتَّقُوا۟ ٱللَّهَ وَٱعْلَمُوٓا۟ أَنَّكُم مُّلَٰقُوهُ ۗ وَبَشِّرِ ٱلْمُؤْمِنِينَ","translation":"Your wives are your tilth; go, then, unto your tilth as you may desire, but first provide something for your souls, and remain conscious of God, and know that you are destined to meet Him. And give glad tidings unto those who believe.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/230.mp3","surahId":2,"words":[{"id":