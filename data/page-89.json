{"id":89,"ayahs":[{"number":66,"arabic":"وَلَوْ أَنَّا كَتَبْنَا عَلَيْهِمْ أَنِ ٱقْتُلُوٓا۟ أَنفُسَكُمْ أَوِ ٱخْرُجُوا۟ مِن دِيَٰرِكُم مَّا فَعَلُوهُ إِلَّا قَلِيلٌۭ مِّنْهُمْ ۖ وَلَوْ أَنَّهُمْ فَعَلُوا۟ مَا يُوعَظُونَ بِهِۦ لَكَانَ خَيْرًۭا لَّهُمْ وَأَشَدَّ تَثْبِيتًۭا","translation":"Yet if We were to ordain for them, \"Lay down your lives,\" or, \"Forsake your homelands,\" only a very few of them would do it - although, if they did what they are admonished to do, it would indeed be for their own good and apt to strengthen them greatly [in faith],","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/559.mp3","surahId":4,"words":[{"id":57518,"position":1,"arabic":"وَلَوْ","translation":"এবং যদি","audioUrl":"wbw/004_066_001.mp3","charTypeName":"word"},{"id":57519,"position":2,"arabic":"أَنَّا","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/004_066_002.mp3","charTypeName":"word"},{"id":57520,"position":3,"arabic":"كَتَبْنَا","translation":"হুকুম দিতাম","audioUrl":"wbw/004_066_003.mp3","charTypeName":"word"},{"id":57521,"position":4,"arabic":"عَلَيْهِمْ","translation":"তাদের উপর","audioUrl":"wbw/004_066_004.mp3","charTypeName":"word"},{"id":57522,"position":5,"arabic":"أَنِ","translation":"যে","audioUrl":"wbw/004_066_005.mp3","charTypeName":"word"},{"id":57523,"position":6,"arabic":"ٱقْتُلُوٓا۟","translation":"''তোমরা হত্যা কর","audioUrl":"wbw/004_066_006.mp3","charTypeName":"word"},{"id":57524,"position":7,"arabic":"أَنفُسَكُمْ","translation":"তোমাদের নিজেদেরকে''","audioUrl":"wbw/004_066_007.mp3","charTypeName":"word"},{"id":57525,"position":8,"arabic":"أَوِ","translation":"বা","audioUrl":"wbw/004_066_008.mp3","charTypeName":"word"},{"id":57526,"position":9,"arabic":"ٱخْرُجُوا۟","translation":"''তোমরা বের হও","audioUrl":"wbw/004_066_009.mp3","charTypeName":"word"},{"id":57527,"position":10,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/004_066_010.mp3","charTypeName":"word"},{"id":57528,"position":11,"arabic":"دِيَـٰرِكُم","translation":"তোমাদের ঘরগুলো''","audioUrl":"wbw/004_066_011.mp3","charTypeName":"word"},{"id":57529,"position":12,"arabic":"مَّا","translation":"না","audioUrl":"wbw/004_066_012.mp3","charTypeName":"word"},{"id":57530,"position":13,"arabic":"فَعَلُوهُ","translation":"তা তারা করত","audioUrl":"wbw/004_066_013.mp3","charTypeName":"word"},{"id":57531,"position":14,"arabic":"إِلَّا","translation":"এছাড়া","audioUrl":"wbw/004_066_014.mp3","charTypeName":"word"},{"id":57532,"position":15,"arabic":"قَلِيلٌۭ","translation":"অল্প কিছু সংখ্যক","audioUrl":"wbw/004_066_015.mp3","charTypeName":"word"},{"id":57533,"position":16,"arabic":"مِّنْهُمْ ۖ","translation":"তাদের মধ্যে হতে","audioUrl":"wbw/004_066_016.mp3","charTypeName":"word"},{"id":57535,"position":17,"arabic":"وَلَوْ","translation":"এবং যদি","audioUrl":"wbw/004_066_018.mp3","charTypeName":"word"},{"id":57536,"position":18,"arabic":"أَنَّهُمْ","translation":"তারা বাস্তবিক","audioUrl":"wbw/004_066_019.mp3","charTypeName":"word"},{"id":57537,"position":19,"arabic":"فَعَلُوا۟","translation":"করত","audioUrl":"wbw/004_066_020.mp3","charTypeName":"word"},{"id":57538,"position":20,"arabic":"مَا","translation":"যা","audioUrl":"wbw/004_066_021.mp3","charTypeName":"word"},{"id":57539,"position":21,"arabic":"يُوعَظُونَ","translation":"তাদের উপদেশ দেয়া হয়","audioUrl":"wbw/004_066_022.mp3","charTypeName":"word"},{"id":57540,"position":22,"arabic":"بِهِۦ","translation":"সে সে সম্পর্কে","audioUrl":"wbw/004_066_023.mp3","charTypeName":"word"},{"id":57541,"position":23,"arabic":"لَكَانَ","translation":"নিশ্চয়ই হত","audioUrl":"wbw/004_066_024.mp3","charTypeName":"word"},{"id":57542,"position":24,"arabic":"خَيْرًۭا","translation":"উত্তম","audioUrl":"wbw/004_066_025.mp3","charTypeName":"word"},{"id":57543,"position":25,"arabic":"لَّهُمْ","translation":"তাদের জন্য","audioUrl":"wbw/004_066_026.mp3","charTypeName":"word"},{"id":57544,"position":26,"arabic":"وَأَشَدَّ","translation":"এবং দৃঢ়তর (হত)","audioUrl":"wbw/004_066_027.mp3","charTypeName":"word"},{"id":57545,"position":27,"arabic":"تَثْبِيتًۭا","translation":"চিত্ত স্থিরতায়","audioUrl":"wbw/004_066_028.mp3","charTypeName":"word"},{"id":57546,"position":28,"arabic":"٦٦","translation":"(৬৬)","audioUrl":null,"charTypeName":"end"}]},{"number":67,"arabic":"وَإِذًۭا لَّءَاتَيْنَٰهُم مِّن لَّدُنَّآ أَجْرًا عَظِيمًۭا","translation":"whereupon We should indeed grant them, out of Our grace, a mighty reward,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/560.mp3","surahId":4,"words":[{"id":58121,"position":1,"arabic":"وَإِذًۭا","translation":"এবং তখন","audioUrl":"wbw/004_067_001.mp3","charTypeName":"word"},{"id":58122,"position":2,"arabic":"لَّـَٔاتَيْنَـٰهُم","translation":"তাদের অবশ্যই দিতাম আমরা","audioUrl":"wbw/004_067_002.mp3","charTypeName":"word"},{"id":58123,"position":3,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/004_067_003.mp3","charTypeName":"word"},{"id":58124,"position":4,"arabic":"لَّدُنَّآ","translation":"নিজের কাছ","audioUrl":"wbw/004_067_004.mp3","charTypeName":"word"},{"id":58125,"position":5,"arabic":"أَجْرًا","translation":"প্রতিফল","audioUrl":"wbw/004_067_005.mp3","charTypeName":"word"},{"id":58126,"position":6,"arabic":"عَظِيمًۭا","translation":"বিরাট","audioUrl":"wbw/004_067_006.mp3","charTypeName":"word"},{"id":58127,"position":7,"arabic":"٦٧","translation":"(৬৭)","audioUrl":null,"charTypeName":"end"}]},{"number":68,"arabic":"وَلَهَدَيْنَٰهُمْ صِرَٰطًۭا مُّسْتَقِيمًۭا","translation":"and indeed guide them onto a straight way.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/561.mp3","surahId":4,"words":[{"id":58529,"position":1,"arabic":"وَلَهَدَيْنَـٰهُمْ","translation":"এবং আমরা তাদের হিদায়াত দিতাম","audioUrl":"wbw/004_068_001.mp3","charTypeName":"word"},{"id":58530,"position":2,"arabic":"صِرَٰطًۭا","translation":"পথের","audioUrl":"wbw/004_068_002.mp3","charTypeName":"word"},{"id":58531,"position":3,"arabic":"مُّسْتَقِيمًۭا","translation":"সরল সঠিক","audioUrl":"wbw/004_068_003.mp3","charTypeName":"word"},{"id":58532,"position":4,"arabic":"٦٨","translation":"(৬৮)","audioUrl":null,"charTypeName":"end"}]},{"number":69,"arabic":"وَمَن يُطِعِ ٱللَّهَ وَٱلرَّسُولَ فَأُو۟لَٰٓئِكَ مَعَ ٱلَّذِينَ أَنْعَمَ ٱللَّهُ عَلَيْهِم مِّنَ ٱلنَّبِيِّۦنَ وَٱلصِّدِّيقِينَ وَٱلشُّهَدَآءِ وَٱلصَّٰلِحِينَ ۚ وَحَسُنَ أُو۟لَٰٓئِكَ رَفِيقًۭا","translation":"For, all who pay heed unto God and the Apostle shall be among those upon whom God has bestowed His blessings: the prophets, and those who never deviated from the truth, and those who [with their lives] bore witness to the truth, and the right­eous ones: and how goodly a company are these!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/562.mp3","surahId":4,"words":[{"id":58952,"position":1,"arabic":"وَمَن","translation":"এবং যে","audioUrl":"wbw/004_069_001.mp3","charTypeName":"word"},{"id":58953,"position":2,"arabic":"يُطِعِ","translation":"আনুগত্য করবে","audioUrl":"wbw/004_069_002.mp3","charTypeName":"word"},{"id":58954,"position":3,"arabic":"ٱللَّهَ","translation":"আল্লাহর","audioUrl":"wbw/004_069_003.mp3","charTypeName":"word"},{"id":58955,"position":4,"arabic":"وَٱلرَّسُولَ","translation":"ও রাসূলের","audioUrl":"wbw/004_069_004.mp3","charTypeName":"word"},{"id":58956,"position":5,"arabic":"فَأُو۟لَـٰٓئِكَ","translation":"ঐসব লোকে তখন (হবে)","audioUrl":"wbw/004_069_005.mp3","charTypeName":"word"},{"id":58957,"position":6,"arabic":"مَعَ","translation":"সাথে","audioUrl":"wbw/004_069_006.mp3","charTypeName":"word"},{"id":58958,"position":7,"arabic":"ٱلَّذِينَ","translation":"(তাদের) যাদের","audioUrl":"wbw/004_069_007.mp3","charTypeName":"word"},{"id":58959,"position":8,"arabic":"أَنْعَمَ","translation":"নিয়ামত দিয়েছেন","audioUrl":"wbw/004_069_008.mp3","charTypeName":"word"},{"id":58960,"position":9,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/004_069_009.mp3","charTypeName":"word"},{"id":58961,"position":10,"arabic":"عَلَيْهِم","translation":"তাদের উপর","audioUrl":"wbw/004_069_010.mp3","charTypeName":"word"},{"id":58962,"position":11,"arabic":"مِّنَ","translation":"(যেমন) থেকে","audioUrl":"wbw/004_069_011.mp3","charTypeName":"word"},{"id":58963,"position":12,"arabic":"ٱلنَّبِيِّـۧنَ","translation":"নবীদের","audioUrl":"wbw/004_069_012.mp3","charTypeName":"word"},{"id":58964,"position":13,"arabic":"وَٱلصِّدِّيقِينَ","translation":"ও সিদ্দিকদের","audioUrl":"wbw/004_069_013.mp3","charTypeName":"word"},{"id":58965,"position":14,"arabic":"وَٱلشُّهَدَآءِ","translation":"ও শহীদদের","audioUrl":"wbw/004_069_014.mp3","charTypeName":"word"},{"id":58966,"position":15,"arabic":"وَٱلصَّـٰلِحِينَ ۚ","translation":"ও সৎ লোকদের (সাথে)","audioUrl":"wbw/004_069_015.mp3","charTypeName":"word"},{"id":58968,"position":16,"arabic":"وَحَسُنَ","translation":"এবং কতই উত্তম","audioUrl":"wbw/004_069_017.mp3","charTypeName":"word"},{"id":58969,"position":17,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐসব","audioUrl":"wbw/004_069_018.mp3","charTypeName":"word"},{"id":58970,"position":18,"arabic":"رَفِيقًۭا","translation":"সাথী","audioUrl":"wbw/004_069_019.mp3","charTypeName":"word"},{"id":58971,"position":19,"arabic":"٦٩","translation":"(৬৯)","audioUrl":null,"charTypeName":"end"}]},{"number":70,"arabic":"ذَٰلِكَ ٱلْفَضْلُ مِنَ ٱللَّهِ ۚ وَكَفَىٰ بِٱللَّهِ عَلِيمًۭا","translation":"Such is the bounty of God - and none has the knowledge which God has.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/563.mp3","surahId":4,"words":[{"id":59365,"position":1,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/004_070_001.mp3","charTypeName":"word"},{"id":59366,"position":2,"arabic":"ٱلْفَضْلُ","translation":"অনুগ্রহ","audioUrl":"wbw/004_070_002.mp3","charTypeName":"word"},{"id":59367,"position":3,"arabic":"مِنَ","translation":"(থেকে)","audioUrl":"wbw/004_070_003.mp3","charTypeName":"word"},{"id":59368,"position":4,"arabic":"ٱللَّهِ ۚ","translation":"আল্লাহর","audioUrl":"wbw/004_070_004.mp3","charTypeName":"word"},{"id":59370,"position":5,"arabic":"وَكَفَىٰ","translation":"এবং যথেষ্ট","audioUrl":"wbw/004_070_006.mp3","charTypeName":"word"},{"id":59371,"position":6,"arabic":"بِٱللَّهِ","translation":"আল্লাহই","audioUrl":"wbw/004_070_007.mp3","charTypeName":"word"},{"id":59372,"position":7,"arabic":"عَلِيمًۭا","translation":"জ্ঞানে","audioUrl":"wbw/004_070_008.mp3","charTypeName":"word"},{"id":59373,"position":8,"arabic":"٧٠","translation":"(৭০)","audioUrl":null,"charTypeName":"end"}]},{"number":71,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ خُذُوا۟ حِذْرَكُمْ فَٱنفِرُوا۟ ثُبَاتٍ أَوِ ٱنفِرُوا۟ جَمِيعًۭا","translation":"O YOU who have attained to faith! Be fully prepared against danger, whether you go to war in small groups or all together.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/564.mp3","surahId":4,"words":[{"id":59902,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"ওহে","audioUrl":"wbw/004_071_001.mp3","charTypeName":"word"},{"id":59903,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/004_071_002.mp3","charTypeName":"word"},{"id":59904,"position":3,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছ","audioUrl":"wbw/004_071_003.mp3","charTypeName":"word"},{"id":59905,"position":4,"arabic":"خُذُوا۟","translation":"তোমরা অবলম্বন কর","audioUrl":"wbw/004_071_004.mp3","charTypeName":"word"},{"id":59906,"position":5,"arabic":"حِذْرَكُمْ","translation":"তোমাদের সতর্কতা","audioUrl":"wbw/004_071_005.mp3","charTypeName":"word"},{"id":59907,"position":6,"arabic":"فَٱنفِرُوا۟","translation":"তোমরা অতঃপর বের হও","audioUrl":"wbw/004_071_006.mp3","charTypeName":"word"},{"id":59908,"position":7,"arabic":"ثُبَاتٍ","translation":"পৃথক দলে","audioUrl":"wbw/004_071_007.mp3","charTypeName":"word"},{"id":59909,"position":8,"arabic":"أَوِ","translation":"অথবা","audioUrl":"wbw/004_071_008.mp3","charTypeName":"word"},{"id":59910,"position":9,"arabic":"ٱنفِرُوا۟","translation":"তোমরা বের হও","audioUrl":"wbw/004_071_009.mp3","charTypeName":"word"},{"id":59911,"position":10,"arabic":"جَمِيعًۭا","translation":"একত্রে","audioUrl":"wbw/004_071_010.mp3","charTypeName":"word"},{"id":59912,"position":11,"arabic":"٧١","translation":"(৭১)","audioUrl":null,"charTypeName":"end"}]},{"number":72,"arabic":"وَإِنَّ مِنكُمْ لَمَن لَّيُبَطِّئَنَّ فَإِنْ أَصَٰبَتْكُم مُّصِيبَةٌۭ قَالَ قَدْ أَنْعَمَ ٱللَّهُ عَلَىَّ إِذْ لَمْ أَكُن مَّعَهُمْ شَهِيدًۭا","translation":"And, behold, there are indeed among you such as would lag behind, and then, if calamity befalls you, say, \"God has bestowed His favour upon me in that I did not accompany them.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/565.mp3","surahId":4,"words":[{"id":60733,"position":1,"arabic":"وَإِنَّ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/004_072_001.mp3","charTypeName":"word"},{"id":60734,"position":2,"arabic":"مِنكُمْ","translation":"তোমাদের মধ্যে (এমনও আছে)","audioUrl":"wbw/004_072_002.mp3","charTypeName":"word"},{"id":60735,"position":3,"arabic":"لَمَن","translation":"অবশ্যই যে","audioUrl":"wbw/004_072_003.mp3","charTypeName":"word"},{"id":60736,"position":4,"arabic":"لَّيُبَطِّئَنَّ","translation":"(যুদ্ধে) পশ্চাদপদ হবেই","audioUrl":"wbw/004_072_004.mp3","charTypeName":"word"},{"id":60737,"position":5,"arabic":"فَإِنْ","translation":"অতঃপর যদি","audioUrl":"wbw/004_072_005.mp3","charTypeName":"word"},{"id":60738,"position":6,"arabic":"أَصَـٰبَتْكُم","translation":"তোমাদের পৌঁছে","audioUrl":"wbw/004_072_006.mp3","charTypeName":"word"},{"id":60739,"position":7,"arabic":"مُّصِيبَةٌۭ","translation":"কোন বিপদ","audioUrl":"wbw/004_072_007.mp3","charTypeName":"word"},{"id":60740,"position":8,"arabic":"قَالَ","translation":"বলবে","audioUrl":"wbw/004_072_008.mp3","charTypeName":"word"},{"id":60741,"position":9,"arabic":"قَدْ","translation":"''নিশ্চয়","audioUrl":"wbw/004_072_009.mp3","charTypeName":"word"},{"id":60742,"position":10,"arabic":"أَنْعَمَ","translation":"অনুগ্রহ করেছেন","audioUrl":"wbw/004_072_010.mp3","charTypeName":"word"},{"id":60743,"position":11,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/004_072_011.mp3","charTy