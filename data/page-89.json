bw/004_073_005.mp3","charTypeName":"word"},{"id":61348,"position":6,"arabic":"لَيَقُولَنَّ","translation":"তারা বলবেই","audioUrl":"wbw/004_073_006.mp3","charTypeName":"word"},{"id":61349,"position":7,"arabic":"كَأَن","translation":"এমন ভাবে যে","audioUrl":"wbw/004_073_007.mp3","charTypeName":"word"},{"id":61350,"position":8,"arabic":"لَّمْ","translation":"না","audioUrl":"wbw/004_073_008.mp3","charTypeName":"word"},{"id":61351,"position":9,"arabic":"تَكُنۢ","translation":"ছিল","audioUrl":"wbw/004_073_009.mp3","charTypeName":"word"},{"id":61352,"position":10,"arabic":"بَيْنَكُمْ","translation":"তোমাদের মাঝে","audioUrl":"wbw/004_073_010.mp3","charTypeName":"word"},{"id":61353,"position":11,"arabic":"وَبَيْنَهُۥ","translation":"ও তার মাঝে","audioUrl":"wbw/004_073_011.mp3","charTypeName":"word"},{"id":61354,"position":12,"arabic":"مَوَدَّةٌۭ","translation":"কোন সম্পর্ক","audioUrl":"wbw/004_073_012.mp3","charTypeName":"word"},{"id":61355,"position":13,"arabic":"يَـٰلَيْتَنِى","translation":"''হায় আফসোস আমার","audioUrl":"wbw/004_073_013.mp3","charTypeName":"word"},{"id":61356,"position":14,"arabic":"كُنتُ","translation":"আমি হতাম (যদি)","audioUrl":"wbw/004_073_014.mp3","charTypeName":"word"},{"id":61357,"position":15,"arabic":"مَعَهُمْ","translation":"তাদের সাথে","audioUrl":"wbw/004_073_015.mp3","charTypeName":"word"},{"id":61358,"position":16,"arabic":"فَأَفُوزَ","translation":"তবে আমি সফল হতাম","audioUrl":"wbw/004_073_016.mp3","charTypeName":"word"},{"id":61359,"position":17,"arabic":"فَوْزًا","translation":"সাফল্য","audioUrl":"wbw/004_073_017.mp3","charTypeName":"word"},{"id":61360,"position":18,"arabic":"عَظِيمًۭا","translation":"বিরাট''","audioUrl":"wbw/004_073_018.mp3","charTypeName":"word"},{"id":61361,"position":19,"arabic":"٧٣","translation":"(৭৩)","audioUrl":null,"charTypeName":"end"}]},{"number":74,"arabic":"۞ فَلْيُقَٰتِلْ فِى سَبِيلِ ٱللَّهِ ٱلَّذِينَ يَشْرُونَ ٱلْحَيَوٰةَ ٱلدُّنْيَا بِٱلْءَاخِرَةِ ۚ وَمَن يُقَٰتِلْ فِى سَبِيلِ ٱللَّهِ فَيُقْتَلْ أَوْ يَغْلِبْ