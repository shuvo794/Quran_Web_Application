ypeName":"word"},{"id":63624,"position":27,"arabic":"ذُنُوبِهِمُ","translation":"অপরাধসমূহ তাদের","audioUrl":"wbw/028_078_029.mp3","charTypeName":"word"},{"id":63625,"position":28,"arabic":"ٱلْمُجْرِمُونَ","translation":"অপরাধীদেরকে","audioUrl":"wbw/028_078_030.mp3","charTypeName":"word"},{"id":63626,"position":29,"arabic":"٧٨","translation":"(৭৮)","audioUrl":null,"charTypeName":"end"}]},{"number":79,"arabic":"فَخَرَجَ عَلَىٰ قَوْمِهِۦ فِى زِينَتِهِۦ ۖ قَالَ ٱلَّذِينَ يُرِيدُونَ ٱلْحَيَوٰةَ ٱلدُّنْيَا يَٰلَيْتَ لَنَا مِثْلَ مَآ أُوتِىَ قَٰرُونُ إِنَّهُۥ لَذُو حَظٍّ عَظِيمٍۢ","translation":"And so he went forth before his people in all his pomp; [and] those who cared only for the life of this world would say, “Oh, if we but had the like of what Qarun has been given! Verily, with tremendous good fortune is he endowed!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3331.mp3","surahId":28,"words":[{"id":63858,"position":1,"arabic":"فَخَرَجَ","translation":"অতঃপর সে  বের হয়েছিলো","audioUrl":"wbw/028_079_001.mp3","charTypeName":"word"},{"id":63859,"position":2,"arabic":"عَلَىٰ","translation":"সামনে","audioUrl":"wbw/028_079_002.mp3","charTypeName":"word"},{"id":63860,"position":3,"arabic":"قَوْمِهِۦ","translation":"জাতির তার","audioUrl":"wbw/028_079_003.mp3","charTypeName":"word"},{"id":63861,"position":4,"arabic":"فِى","translation":"সাথে","audioUrl":"wbw/028_079_004.mp3","charTypeName":"word"},{"id":63862,"position":5,"arabic":"زِينَتِهِۦ ۖ","translation":"জাঁকজমকের তার","audioUrl":"wbw/028_079_005.mp3","charTypeName":"word"},{"id":63864,"position":6,"arabic":"قَالَ","translation":"বললো","audioUrl":"wbw/028_079_007.mp3","charTypeName":"word"},{"id":63865,"position":7,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/028_079_008.mp3","charTypeName":"word"},{"id":63866,"position":8,"arabic":"يُرِيدُونَ","translation":"চায়","audioUrl":"wbw/028_079_009.mp3","charTypeName":"word"},{"id":63867,"position":9,"arabic":"ٱلْحَيَوٰةَ","translation":"জীবন","audioUrl":"wbw/028_079_010.mp3","charTypeName":"word"},{"id":63868,"position":10,"arabic":"ٱلدُّنْيَا","translation":"পার্থিব","audioUrl":"wbw/028_079_011.mp3","charTypeName":"word"},{"id":63869,"position":11,"arabic":"يَـٰلَيْتَ","translation":"\"হায়! যদি হতো","audioUrl":"wbw/028_079_012.mp3","charTypeName":"word"},{"id":63870,"position":12,"arabic":"لَنَا","translation":"জন্যে আমাদের","audioUrl":"wbw/028_079_013.mp3","charTypeName":"word"},{"id":63871,"position":13,"arabic":"مِثْلَ","translation":"এরূপ","audioUrl":"wbw/028_079_014.mp3","charTypeName":"word"},{"id":63872,"position":14,"arabic":"مَآ","translation":"যা","audioUrl":"wbw/028_079_015.mp3","charTypeName":"word"},{"id":63873,"position":15,"arabic":"أُوتِىَ","translation":"দেয়া হয়েছে","audioUrl":"wbw/028_079_016.mp3","charTypeName":"word"},{"id":63874,"position":16,"arabic":"قَـٰرُونُ","translation":"ক্বারুনকে","audioUrl":"wbw/028_079_017.mp3","charTypeName":"word"},{"id":63875,"position":17,"arabic":"إِنَّهُۥ","translation":"নিশ্চয়ই সে","audioUrl":"wbw/028_079_018.mp3","charTypeName":"word"},{"id":63876,"position":18,"arabic":"لَذُو","translation":"অবশ্যই অধিকারী","audioUrl":"wbw/028_079_019.mp3","charTypeName":"word"},{"id":63877,"position":19,"arabic":"حَظٍّ","translation":"সৌভাগ্যের","audioUrl":"wbw/028_079_020.mp3","charTypeName":"word"},{"id":63878,"position":20,"arabic":"عَظِيمٍۢ","translation":"বড়\"","audioUrl":"wbw/028_079_021.mp3","charTypeName":"word"},{"id":63879,"position":21,"arabic":"٧٩","translation":"(৭৯)","audioUrl":null,"charTypeName":"end"}]},{"number":80,"arabic":"وَقَالَ ٱلَّذِينَ أُوتُوا۟ ٱلْعِلْمَ وَيْلَكُمْ ثَوَابُ ٱللَّهِ خَيْرٌۭ لِّمَنْ ءَامَنَ وَعَمِلَ صَٰلِحًۭا وَلَا يُلَقَّىٰهَآ إِلَّا ٱلصَّٰبِرُونَ","translation":"But those who had been granted true knowl­edge said: “Woe unto you! Merit in the sight of God is by far the best for any who attains to faith and does what is right: but none save the patient in adversity can ever achieve this [blessing].”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3332.mp3","surahId":28,"words":[{"id":64316,"position":1,"arabic":"وَقَالَ","translation":"কিন্তু বললো","audioUrl":"wbw/028_080_001.mp3","charTypeName":"word"},{"id":64317,"position":2,"arabic":"ٱلَّذِينَ","translation":"(তারা) যাদেরকে","audioUrl":"wbw/028_080_002.mp3","charTypeName":"word"},{"id":64318,"position":3,"arabic":"أُوتُوا۟","translation":"দেয়া হয়েছিলো","audioUrl":"wbw/028_080_003.mp3","charTypeName":"word"},{"id":64319,"position":4,"arabic":"ٱلْعِلْمَ","translation":"জ্ঞান","audioUrl":"wbw/028_080_004.mp3","charTypeName":"word"},{"id":64320,"position":5,"arabic":"وَيْلَكُمْ","translation":"\"ধ্বংস জন্যে তোমাদের","audioUrl":"wbw/028_080_005.mp3","charTypeName":"word"},{"id":64321,"position":6,"arabic":"ثَوَابُ","translation":"পুরস্কার","audioUrl":"wbw/028_080_006.mp3","charTypeName":"word"},{"id":64322,"position":7,"arabic":"ٱللَّهِ","translation":"আল্লাহরই","audioUrl":"wbw/028_080_007.mp3","charTypeName":"word"},{"id":64323,"position":8,"arabic":"خَيْرٌۭ","translation":"উত্তম","audioUrl":"wbw/028_080_008.mp3","charTypeName":"word"},{"id":64324,"position":9,"arabic":"لِّمَنْ","translation":"(তার) জন্যে যে","audioUrl":"wbw/028_080_009.mp3","charTypeName":"word"},{"id":64325,"position":10,"arabic":"ءَامَنَ","translation":"ঈমান এনেছে","audioUrl":"wbw/028_080_010.mp3","charTypeName":"word"},{"id":64326,"position":11,"arabic":"وَعَمِلَ","translation":"কাজ করেছে","audioUrl":"wbw/028_080_011.mp3","charTypeName":"word"},{"id":64327,"position":12,"arabic":"صَـٰلِحًۭا","translation":"সৎ","audioUrl":"wbw/028_080_012.mp3","charTypeName":"word"},{"id":64328,"position":13,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/028_080_013.mp3","charTypeName":"word"},{"id":64329,"position":14,"arabic":"يُلَقَّىٰهَآ","translation":"তা পায় (অন্য কেউ)","audioUrl":"wbw/028_080_014.mp3","charTypeName":"word"},{"id":64330,"position":15,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/028_080_015.mp3","charTypeName":"word"},{"id":64331,"position":16,"arabic":"ٱلصَّـٰبِرُونَ","translation":"ধৈর্য্যশীলরা\"","audioUrl":"wbw/028_080_016.mp3","charTypeName":"word"},{"id":64332,"position":17,"arabic":"٨٠","translation":"(৮০)","audioUrl":null,"charTypeName":"end"}]},{"number":81,"arabic":"فَخَسَفْنَا بِهِۦ وَبِدَارِهِ ٱلْأَرْضَ فَمَا كَانَ لَهُۥ مِن فِئَةٍۢ يَنصُرُونَهُۥ مِن دُونِ ٱللَّهِ وَمَا كَانَ مِنَ ٱلْمُنتَصِرِينَ","translation":"And thereupon We caused the earth to swallow him and his dwelling; and he had none and nothing to succour him against God, nor was he of those who could succour themselves.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3333.mp3","surahId":28,"words":[{"id":64671,"position":1,"arabic":"فَخَسَفْنَا","translation":"অতঃপর ধ্বসিয়ে দিলাম আমরা","audioUrl":"wbw/028_081_001.mp3","charTypeName":"word"},{"id":64672,"position":2,"arabic":"بِهِۦ","translation":"সহ তাকে","audioUrl":"wbw/028_081_002.mp3","charTypeName":"word"},{"id":64673,"position":3,"arabic":"وَبِدَارِهِ","translation":"ও সহ তার ঘর (অর্থাৎ তার প্রাসাদ)","audioUrl":"wbw/028_081_003.mp3","charTypeName":"word"},{"id":64674,"position":4,"arabic":"ٱلْأَرْضَ","translation":"জমীনে","audioUrl":"wbw/028_081_004.mp3","charTypeName":"word"},{"id":64675,"position":5,"arabic":"فَمَا","translation":"তখন না","audioUrl":"wbw/028_081_005.mp3","charTypeName":"word"},{"id":64676,"position":6,"arabic":"كَانَ","translation":"ছিলো","audioUrl":"wbw/028_081_006.mp3","charTypeName":"word"},{"id":64677,"position":7,"arabic":"لَهُۥ","translation":"জন্যে তার","audioUrl":"wbw/028_081_007.mp3","charTypeName":"word"},{"id":64678,"position":8,"arabic":"مِن","translation":"কোনো","audioUrl":"wbw/028_081_008.mp3","charTypeName":"word"},{"id":64679,"position":9,"arabic":"فِئَةٍۢ","translation":"দল","audioUrl":"wbw/028_081_009.mp3","charTypeName":"word"},{"id":64680,"position":10,"arabic":"يَنصُرُونَهُۥ","translation":"তারা সাহায্য করবে তাকে","audioUrl":"wbw/028_081_010.mp3","charTypeName":"word"},{"id":64681,"position":11,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/028_081_011.mp3","charTypeName":"word"},{"id":64682,"position":12,"arabic":"دُونِ","translation":"ছাড়া","audioUrl":"wbw/028_081_012.mp3","charTypeName":"word"},{"id":64683,"position":13,"arabic":"ٱللَّهِ","translation":"আল্লাহ","audioUrl":"wbw/028_081_013.mp3","charTypeName":"word"},{"id":64684,"position":14,"arabic":"وَمَا","translation":"আর না","audioUrl":"wbw/028_081_014.mp3","charTypeName":"word"},{"id":64685,"position":15,"arabic":"كَانَ","translation":"সে ছিলো","audioUrl":"wbw/028_081_015.mp3","charTypeName":"word"},{"id":64686,"position":16,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/028_081_016.mp3","charTypeName":"word"},{"id":64687,"position":17,"arabic":"ٱلْمُنتَصِرِينَ","translation":"আত্মরক্ষায় সক্ষমদের","audioUrl":"wbw/028_081_017.mp3","charTypeName":"word"},{"id":64688,"position":18,"arabic":"٨١","translation":"(৮১)","audioUrl":null,"charTypeName":"end"}]},{"number":82,"arabic":"وَأَصْبَحَ ٱلَّذِينَ تَمَنَّوْا۟ مَكَانَهُۥ بِٱلْأَمْسِ يَقُولُونَ وَيْكَأَنَّ ٱللَّهَ يَبْسُطُ ٱلرِّزْقَ لِمَن يَشَآءُ مِنْ عِبَادِهِۦ وَيَقْدِرُ ۖ لَوْلَآ أَن مَّنَّ ٱللَّهُ عَلَيْنَا لَخَسَفَ بِنَا ۖ وَيْكَأَنَّهُۥ لَا يُفْلِحُ ٱلْكَٰفِرُونَ","translation":"And on the morrow, those who but yesterday had longed to be in his place exclaimed: “Alas [for our not having been aware] that it is indeed God [alone] who grants abundant sustenance, or gives it in scant measure, unto whichever He wills of His crea­tures! Had not God been gracious to us, He might have caused [the earth] to swallow us, too! Alas [for our having forgotten] that those who deny the truth can never attain to a happy state!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3334.mp3","surahId":28,"words":[{"id":64897,"position":1,"arabic":"وَأَصْبَحَ","translation":"এবং সকাল হলো","audioUrl":"wbw/028_082_001.mp3","charTypeName":"word"},{"id":64898,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা (তাদের)","audioUrl":"wbw/028_082_002.mp3","charTypeName":"word"},{"id":64899,"position":3,"arabic":"تَمَنَّوْا۟","translation":"কামনা করেছিলো","audioUrl":"wbw/028_082_003.mp3","charTypeName":"word"},{"id":64900,"position":4,"arabic":"مَكَانَهُۥ","translation":"তার মতো হওয়ার","audioUrl":"wbw/028_082_004.mp3","charTypeName":"word"},{"id":64901,"position":5,"arabic":"بِٱلْأَمْسِ","translation":"গতকালকে","audioUrl":"wbw/028_082_005.mp3","charTypeName":"word"},{"id":64902,"position":6,"arabic":"يَقُولُونَ","translation":"তারা বলতে লাগলো (আজ)","audioUrl":"wbw/028_082_006.mp3","charTypeName":"word"},{"id":64903,"position":7,"arabic":"وَيْكَأَنَّ","translation":"\"বড়ই পরিতাপ নিশ্চয়ই (আমরা ভুলে গিয়েছিলাম)","audioUrl":"wbw/028_082_007.mp3","charTypeName":"word"},{"id":64904,"position":8,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/028_082_008.mp3","charTypeName":"word"},{"id":64905,"position":9,"arabic":"يَبْسُطُ","translation":"সম্প্রসারিত করেন","audioUrl":"wbw/028_082_009.mp3","charTypeName":"word"},{"id":64906,"position":10,"arabic":"ٱلرِّزْقَ","translation":"জীবিকা","audioUrl":"wbw/028_082_010.mp3","charTypeName":"word"},{"id":64907,"position":11,"arabic":"لِمَن","translation":"(তার) জন্যে যাকে","audioUrl":"wbw/028_082_011.mp3","charTypeName":"word"},{"id":64908,"position":12,"arabic":"يَشَآءُ","translation":"তিনি ইচ্ছে করেন","audioUrl":"wbw/028_082_012.mp3","charTypeName":"word"},{"id":64909,"position":13,"arabic":"مِنْ","translation":"মধ্য হ'তে","audioUrl":"wbw/028_082_013.mp3","charTypeName":"word"},{"id":64910,"position":14,"arabic":"عِبَادِهِۦ","translation":"দাসদের তাঁর","audioUrl":"wbw/028_082_014.mp3","charTypeName":"word"},{"id":64911,"position":15,"arabic":"وَيَقْدِرُ ۖ","translation":"আর পরিমিত দেন (যাকে চান)","audioUrl":"wbw/028_082_015.mp3","charTypeName":"word"},{"id":64913,"position":16,"arabic":"لَوْلَآ","translation":"যদি না","audioUrl":"wbw/028_082_017.mp3","charTypeName":"word"},{"id":64914,"position":17,"arabic":"أَن","translation":"যে","audioUrl":"wbw/028_082_018.mp3","charTypeName":"word"},{"id":64915,"position":18,"arabic":"مَّنَّ","translation":"অনুগ্রহ করতেন","audioUrl":"wbw/028_082_019.mp3","charTypeName":"word"},{"id":64916,"position":19,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/028_082_020.mp3","charTypeName":"word"},{"id":64917,"position":20,"arabic":"عَلَيْنَا","translation":"উপর আমাদের","audioUrl":"wbw/028_082_021.mp3","charTypeName":"word"},{"id":64918,"position":21,"arabic":"لَخَسَفَ","translation":"অবশ্যই ধসিয়ে দিতেন","audioUrl":"wbw/028_082_022.mp3","charTypeName":"word"},{"id":64919,"position":22,"arabic":"بِنَا ۖ","translation":"সহ আমাদের (মাটিতে)","audioUrl":"wbw/028_082_023.mp3","charTypeName":"word"},{"id":64921,"position":23,"arabic":"وَيْكَأَنَّهُۥ","translation":"বড়ই পরিতাপ নিশ্চয়ই সে বিষয়ে (আমরা ভুলে গিয়েছিলাম)","audioUrl":"wbw/028_082_025.mp3","charTypeName":"word"},{"id":64922,"position":24,"arabic":"لَا","translation":"না","audioUrl":"wbw/028_082_026.mp3","charTypeName":"word"},{"id":64923,"position":25,"arabic":"يُفْلِحُ","translation":"সফল হয়","audioUrl":"wbw/028_082_027.mp3","charTypeName":"word"},{"id":64924,"position":26,"arabic":"ٱلْكَـٰفِرُونَ","translation":"কাফিররা\"","audioUrl":"wbw/028_082_028.mp3","charTypeName":"word"},{"id":64925,"position":27,"arabic":"٨٢","translation":"(৮২)","audioUrl":null,"charTypeName":"end"}]},{"number":83,"arabic":"تِلْكَ ٱلدَّارُ ٱلْءَاخِرَةُ نَجْعَلُهَا لِلَّذِينَ لَا يُرِيدُونَ عُلُوًّۭا فِى ٱلْأَرْضِ وَلَا فَسَادًۭا ۚ وَٱلْعَٰقِبَةُ لِلْمُتَّقِينَ","translation":"As for that [happy] life in the hereafter, We grant it [only] to those who do not seek to exalt themselves on earth, nor yet to spread corruption: for the future belongs to the God-conscious.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3335.mp3","surahId":28,"words":[{"id":65321,"position":1,"arabic":"تِلْكَ","translation":"এই","audioUrl":"wbw/028_083_001.mp3","charTypeName":"word"},{"id":65322,"position":2,"arabic":"ٱلدَّارُ","translation":"ঘর","