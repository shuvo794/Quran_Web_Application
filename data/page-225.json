l":"wbw/011_031_033.mp3","charTypeName":"word"},{"id":33848,"position":32,"arabic":"٣١","translation":"(৩১)","audioUrl":null,"charTypeName":"end"}]},{"number":32,"arabic":"قَالُوا۟ يَٰنُوحُ قَدْ جَٰدَلْتَنَا فَأَكْثَرْتَ جِدَٰلَنَا فَأْتِنَا بِمَا تَعِدُنَآ إِن كُنتَ مِنَ ٱلصَّٰدِقِينَ","translation":"[But the great ones] said: \"O Noah! Thou hast contended with us in argument, and hast [needlessly] prolonged our controversy: bring upon us, therefore, that with which thou dost threaten us, if thou art a man of truth!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1505.mp3","surahId":11,"words":[{"id":34795,"position":1,"arabic":"قَالُوا۟","translation":"(শেষ পর্যন্ত) তারা বললো","audioUrl":"wbw/011_032_001.mp3","charTypeName":"word"},{"id":34796,"position":2,"arabic":"يَـٰنُوحُ","translation":"\"হে নূহ","audioUrl":"wbw/011_032_002.mp3","charTypeName":"word"},{"id":34797,"position":3,"arabic":"قَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/011_032_003.mp3","charTypeName":"word"},{"id":34798,"position":4,"arabic":"جَـٰدَلْتَنَا","translation":"আমাদের সাথে তুমি তর্ক করেছো","audioUrl":"wbw/011_032_004.mp3","charTypeName":"word"},{"id":34799,"position":5,"arabic":"فَأَكْثَرْتَ","translation":"অতঃপর করেছো তুমি বড় বেশী","audioUrl":"wbw/011_032_005.mp3","charTypeName":"word"},{"id":34800,"position":6,"arabic":"جِدَٰلَنَا","translation":"আমাদের সাথে তর্ক","audioUrl":"wbw/011_032_006.mp3","charTypeName":"word"},{"id":34801,"position":7,"arabic":"فَأْتِنَا","translation":"অতএব আস আমাদের কাছে","audioUrl":"wbw/011_032_007.mp3","charTypeName":"word"},{"id":34802,"position":8,"arabic":"بِمَا","translation":"নিয়ে ঐ বিষয় যার","audioUrl":"wbw/011_032_008.mp3","charTypeName":"word"},{"id":34803,"position":9,"arabic":"تَعِدُنَآ","translation":"আমাদেরকে ভয় দেখাচ্ছো","audioUrl":"wbw/011_032_009.mp3","charTypeName":"word"},{"id":34804,"position":10,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/011_032_010.mp3","charTypeName":"word"},{"id":34805,"position":11,"arabic":"كُنتَ","translation":"তুমি হও","audioUrl":"wbw/011_032_011.mp3","charTypeName":"word"},{"id":34806,"position":12,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/011_032_012.mp3","charTypeName":"word"},{"id":34807,"position":13,"arabic":"ٱلصَّـٰدِقِينَ","translation":"সত্যবাদীদের\"","audioUrl":"wbw/011_032_013.mp3","charTypeName":"word"},{"id":34808,"position":14,"arabic":"٣٢","translation":"(৩২)","audioUrl":null,"charTypeName":"end"}]},{"number":33,"arabic":"قَالَ إِنَّمَا يَأْتِيكُم بِهِ ٱللَّهُ إِن شَآءَ وَمَآ أَنتُم بِمُعْجِزِينَ","translation":"He answered: \"Only God can bring it upon you, if He so wills, and you shall not elude it:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1506.mp3","surahId":11,"words":[{"id":35615,"position":1,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/011_033_001.mp3","charTypeName":"word"},{"id":35616,"position":2,"arabic":"إِنَّمَا","translation":"\"প্রকৃতপক্ষে","audioUrl":"wbw/011_033_002.mp3","charTypeName":"word"},{"id":35617,"position":3,"arabic":"يَأْتِيكُم","translation":"তোমাদের কাছে আসবেন","audioUrl":"wbw/011_033_003.mp3","charTypeName":"word"},{"id":35618,"position":4,"arabic":"بِهِ","translation":"নিয়ে তা","audioUrl":"wbw/011_033_004.mp3","charTypeName":"word"},{"id":35619,"position":5,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/011_033_005.mp3","charTypeName":"word"},{"id":35620,"position":6,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/011_033_006.mp3","charTypeName":"word"},{"id":35621,"position":7,"arabic":"شَآءَ","translation":"তিনি ইচ্ছে করেন","audioUrl":"wbw/011_033_007.mp3","charTypeName":"word"},{"id":35622,"position":8,"arabic":"وَمَآ","translation":"এবং নও","audioUrl":"wbw/011_033_008.mp3","charTypeName":"word"},{"id":35623,"position":9,"arabic":"أَنتُم","translation":"তোমরা","audioUrl":"wbw/011_033_009.mp3","charTypeName":"word"},{"id":35624,"position":10,"arabic":"بِمُعْجِزِينَ","translation":"ব্যর্থ করতে সক্ষম (আল্লাহকে)","audioUrl":"wbw/0