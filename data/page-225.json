{"id":225,"ayahs":[{"number":29,"arabic":"وَيَٰقَوْمِ لَآ أَسْـَٔلُكُمْ عَلَيْهِ مَالًا ۖ إِنْ أَجْرِىَ إِلَّا عَلَى ٱللَّهِ ۚ وَمَآ أَنَا۠ بِطَارِدِ ٱلَّذِينَ ءَامَنُوٓا۟ ۚ إِنَّهُم مُّلَٰقُوا۟ رَبِّهِمْ وَلَٰكِنِّىٓ أَرَىٰكُمْ قَوْمًۭا تَجْهَلُونَ","translation":"\"And, O my people, no benefit do I ask of you for this [message]: my reward rests with none but God. And I shall not repulse [any of] those who have attained to faith. Verily, they [know that they] are destined to meet their Sustainer, whereas in you I see people without any awareness [of right and wrong]!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1502.mp3","surahId":11,"words":[{"id":32093,"position":1,"arabic":"وَيَـٰقَوْمِ","translation":"এবং হে আমার সম্প্রদায়","audioUrl":"wbw/011_029_001.mp3","charTypeName":"word"},{"id":32094,"position":2,"arabic":"لَآ","translation":"না","audioUrl":"wbw/011_029_002.mp3","charTypeName":"word"},{"id":32095,"position":3,"arabic":"أَسْـَٔلُكُمْ","translation":"তোমাদের কাছে আমি চাই","audioUrl":"wbw/011_029_003.mp3","charTypeName":"word"},{"id":32096,"position":4,"arabic":"عَلَيْهِ","translation":"এর বিনিময়ে","audioUrl":"wbw/011_029_004.mp3","charTypeName":"word"},{"id":32097,"position":5,"arabic":"مَالًا ۖ","translation":"কোন ধন-সম্পদ","audioUrl":"wbw/011_029_005.mp3","charTypeName":"word"},{"id":32099,"position":6,"arabic":"إِنْ","translation":"নয়","audioUrl":"wbw/011_029_007.mp3","charTypeName":"word"},{"id":32100,"position":7,"arabic":"أَجْرِىَ","translation":"আমার পারিশ্রমিক","audioUrl":"wbw/011_029_008.mp3","charTypeName":"word"},{"id":32101,"position":8,"arabic":"إِلَّا","translation":"এছাড়া","audioUrl":"wbw/011_029_009.mp3","charTypeName":"word"},{"id":32102,"position":9,"arabic":"عَلَى","translation":"কাছে","audioUrl":"wbw/011_029_010.mp3","charTypeName":"word"},{"id":32103,"position":10,"arabic":"ٱللَّهِ ۚ","translation":"আল্লাহর","audioUrl":"wbw/011_029_011.mp3","charTypeName":"word"},{"id":32105,"position":11,"arabic":"وَمَآ","translation":"এবং নই","audioUrl":"wbw/011_029_013.mp3","charTypeName":"word"},{"id":32106,"position":12,"arabic":"أَنَا۠","translation":"আমি","audioUrl":"wbw/011_029_014.mp3","charTypeName":"word"},{"id":32107,"position":13,"arabic":"بِطَارِدِ","translation":"বিতাড়নকারী","audioUrl":"wbw/011_029_015.mp3","charTypeName":"word"},{"id":32108,"position":14,"arabic":"ٱلَّذِينَ","translation":"(তাদেরকে) যারা","audioUrl":"wbw/011_029_016.mp3","charTypeName":"word"},{"id":32109,"position":15,"arabic":"ءَامَنُوٓا۟ ۚ","translation":"ঈমান এনেছে","audioUrl":"wbw/011_029_017.mp3","charTypeName":"word"},{"id":32111,"position":16,"arabic":"إِنَّهُم","translation":"তারা নিশ্চয়ই","audioUrl":"wbw/011_029_019.mp3","charTypeName":"word"},{"id":32112,"position":17,"arabic":"مُّلَـٰقُوا۟","translation":"সাক্ষাত করবে","audioUrl":"wbw/011_029_020.mp3","charTypeName":"word"},{"id":32113,"position":18,"arabic":"رَبِّهِمْ","translation":"তাদের রবের","audioUrl":"wbw/011_029_021.mp3","charTypeName":"word"},{"id":32114,"position":19,"arabic":"وَلَـٰكِنِّىٓ","translation":"কিন্তু আমি","audioUrl":"wbw/011_029_022.mp3","charTypeName":"word"},{"id":32115,"position":20,"arabic":"أَرَىٰكُمْ","translation":"তোমাদেরকে দেখছি","audioUrl":"wbw/011_029_023.mp3","charTypeName":"word"},{"id":32116,"position":21,"arabic":"قَوْمًۭا","translation":"(এমন) সম্প্রদায়","audioUrl":"wbw/011_029_024.mp3","charTypeName":"word"},{"id":32117,"position":22,"arabic":"تَجْهَلُونَ","translation":"(যারা তোমরা) মূর্খতা করছো","audioUrl":"wbw/011_029_025.mp3","charTypeName":"word"},{"id":32118,"position":23,"arabic":"٢٩","translation":"(২৯)","audioUrl":null,"charTypeName":"end"}]},{"number":30,"arabic":"وَيَٰقَوْمِ مَن يَنصُرُنِى مِنَ ٱللَّهِ إِن طَرَدتُّهُمْ ۚ أَفَلَا تَذَكَّرُونَ","translation":"And, O my people, who would shield me from God were I to repulse them? Will you not, then, keep this in mind?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1503.mp3","surahId":11,"words":[{"id":32943,"position":1,"arabic":"وَيَـٰقَوْمِ","translation":"আর হে আমার সম্প্রদায়","audioUrl":"wbw/011_030_001.mp3","charTypeName":"word"},{"id":32944,"position":2,"arabic":"مَن","translation":"কে","audioUrl":"wbw/011_030_002.mp3","charTypeName":"word"},{"id":32945,"position":3,"arabic":"يَنصُرُنِى","translation":"সাহায্য করবে আমাকে","audioUrl":"wbw/011_030_003.mp3","charTypeName":"word"},{"id":32946,"position":4,"arabic":"مِنَ","translation":"থেকে","audioUrl":"wbw/011_030_004.mp3","charTypeName":"word"},{"id":32947,"position":5,"arabic":"ٱللَّهِ","translation":"আল্লাহ","audioUrl":"wbw/011_030_005.mp3","charTypeName":"word"},{"id":32948,"position":6,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/011_030_006.mp3","charTypeName":"word"},{"id":32949,"position":7,"arabic":"طَرَدتُّهُمْ ۚ","translation":"তাদেরকে আমি তাড়িয়ে দিই","audioUrl":"wbw/011_030_007.mp3","charTypeName":"word"},{"id":32951,"position":8,"arabic":"أَفَلَا","translation":"তবে কি না","audioUrl":"wbw/011_030_009.mp3","charTypeName":"word"},{"id":32952,"position":9,"arabic":"تَذَكَّرُونَ","translation":"তোমরা শিক্ষা গ্রহণ করবে","audioUrl":"wbw/011_030_010.mp3","charTypeName":"word"},{"id":32953,"position":10,"arabic":"٣٠","translation":"(৩০)","audioUrl":null,"charTypeName":"end"}]},{"number":31,"arabic":"وَلَآ أَقُولُ لَكُمْ عِندِى خَزَآئِنُ ٱللَّهِ وَلَآ أَعْلَمُ ٱلْغَيْبَ وَلَآ أَقُولُ إِنِّى مَلَكٌۭ وَلَآ أَقُولُ لِلَّذِينَ تَزْدَرِىٓ أَعْيُنُكُمْ لَن يُؤْتِيَهُمُ ٱللَّهُ خَيْرًا ۖ ٱللَّهُ أَعْلَمُ بِمَا فِىٓ أَنفُسِهِمْ ۖ إِنِّىٓ إِذًۭا لَّمِنَ ٱلظَّٰلِمِينَ","translation":"\"And I do not say unto you, `God's treasures are with me'; nor [do I say], `I know the reality which is beyond the reach of human perception'; nor do I say, 'Behold, I am an angel'; nor do I say of those whom your eyes hold in contempt, `Never will God grant them any good'- for God is fully aware of what is in their hearts. [Were I to speak thus,] verily, I would indeed be among the evildoers.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1504.mp3","surahId":11,"words":[{"id":33815,"position":1,"arabic":"وَلَآ","translation":"এবং না","audioUrl":"wbw/011_031_001.mp3","charTypeName":"word"},{"id":33816,"position":2,"arabic":"أَقُولُ","translation":"আমি বলছি","audioUrl":"wbw/011_031_002.mp3","charTypeName":"word"},{"id":33817,"position":3,"arabic":"لَكُمْ","translation":"তোমাদেরকে (এ কথা যে)","audioUrl":"wbw/011_031_003.mp3","charTypeName":"word"},{"id":33818,"position":4,"arabic":"عِندِى","translation":"আমার কাছে (আছে)","audioUrl":"wbw/011_031_004.mp3","charTypeName":"word"},{"id":33819,"position":5,"arabic":"خَزَآئِنُ","translation":"ধনভান্ডার","audioUrl":"wbw/011_031_005.mp3","charTypeName":"word"},{"id":33820,"position":6,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/011_031_006.mp3","charTypeName":"word"},{"id":33821,"position":7,"arabic":"وَلَآ","translation":"এবং না","audioUrl":"wbw/011_031_007.mp3","charTypeName":"word"},{"id":33822,"position":8,"arabic":"أَعْلَمُ","translation":"আমি জানি","audioUrl":"wbw/011_031_008.mp3","charTypeName":"word"},{"id":33823,"position":9,"arabic":"ٱلْغَيْبَ","translation":"অদৃশ্য (সম্বন্ধে)","audioUrl":"wbw/011_031_009.mp3","charTypeName":"word"},{"id":33824,"position":10,"arabic":"وَلَآ","translation":"এবং না","audioUrl":"wbw/011_031_010.mp3","charTypeName":"word"},{"id":33825,"position":11,"arabic":"أَقُولُ","translation":"আমি বলছি (এ কথা যে)","audioUrl":"wbw/011_031_011.mp3","charTypeName":"word"},{"id":33826,"position":12,"arabic":"إِنِّى","translation":"নিশ্চয়ই আমি","audioUrl":"wbw/011_031_012.mp3","charTypeName":"word"},{"id":33827,"position":13,"arabic":"مَلَكٌۭ","translation":"ফেরেশতা","audioUrl":"wbw/011_031_013.mp3","charTypeName":"word"},{"id":33828,"position":14,"arabic":"وَلَآ","translation":"এবং না","audioUrl":"wbw/011_031_014.mp3","charTypeName":"word"},{"id":33829,"position":15,"arabic":"أَقُولُ","translation":"আমি বলছি","audioUrl":"wbw/011_031_015.mp3","charTypeName":"word"},{"id":33830,"position":16,"arabic":"لِلَّذِينَ",