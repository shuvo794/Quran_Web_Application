{"id":51,"ayahs":[{"number":10,"arabic":"إِنَّ ٱلَّذِينَ كَفَرُوا۟ لَن تُغْنِىَ عَنْهُمْ أَمْوَٰلُهُمْ وَلَآ أَوْلَٰدُهُم مِّنَ ٱللَّهِ شَيْـًۭٔا ۖ وَأُو۟لَٰٓئِكَ هُمْ وَقُودُ ٱلنَّارِ","translation":"BEHOLD, as for those who are bent on denying the truth - neither their worldly possessions nor their offspring will in the least avail them against God; and it is they, they who shall be the fuel of the fire!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/303.mp3","surahId":3,"words":[{"id":11174,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/003_010_001.mp3","charTypeName":"word"},{"id":11175,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/003_010_002.mp3","charTypeName":"word"},{"id":11176,"position":3,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/003_010_003.mp3","charTypeName":"word"},{"id":11177,"position":4,"arabic":"لَن","translation":"কখনও না","audioUrl":"wbw/003_010_004.mp3","charTypeName":"word"},{"id":11178,"position":5,"arabic":"تُغْنِىَ","translation":"উপকার দিবে","audioUrl":"wbw/003_010_005.mp3","charTypeName":"word"},{"id":11179,"position":6,"arabic":"عَنْهُمْ","translation":"তাদের জন্য","audioUrl":"wbw/003_010_006.mp3","charTypeName":"word"},{"id":11180,"position":7,"arabic":"أَمْوَٰلُهُمْ","translation":"তাদের ধনসম্পদগুলো","audioUrl":"wbw/003_010_007.mp3","charTypeName":"word"},{"id":11181,"position":8,"arabic":"وَلَآ","translation":"আর না","audioUrl":"wbw/003_010_008.mp3","charTypeName":"word"},{"id":11182,"position":9,"arabic":"أَوْلَـٰدُهُم","translation":"সন্তানাদি তাদের","audioUrl":"wbw/003_010_009.mp3","charTypeName":"word"},{"id":11183,"position":10,"arabic":"مِّنَ","translation":"কাছে","audioUrl":"wbw/003_010_010.mp3","charTypeName":"word"},{"id":11184,"position":11,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/003_010_011.mp3","charTypeName":"word"},{"id":11185,"position":12,"arabic":"شَيْـًۭٔا ۖ","translation":"কিছুমাত্রই","audioUrl":"wbw/003_010_012.mp3","charTypeName":"word"},{"id":11187,"position":13,"arabic":"وَأُو۟لَـٰٓئِكَ","translation":"এবং ঐসব লোক","audioUrl":"wbw/003_010_014.mp3","charTypeName":"word"},{"id":11188,"position":14,"arabic":"هُمْ","translation":"তারাই (হবে)","audioUrl":"wbw/003_010_015.mp3","charTypeName":"word"},{"id":11189,"position":15,"arabic":"وَقُودُ","translation":"ইন্ধন","audioUrl":"wbw/003_010_016.mp3","charTypeName":"word"},{"id":11190,"position":16,"arabic":"ٱلنَّارِ","translation":"আগুনের (দোজখের)","audioUrl":"wbw/003_010_017.mp3","charTypeName":"word"},{"id":11191,"position":17,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"كَدَأْبِ ءَالِ فِرْعَوْنَ وَٱلَّذِينَ مِن قَبْلِهِمْ ۚ كَذَّبُوا۟ بِـَٔايَٰتِنَا فَأَخَذَهُمُ ٱللَّهُ بِذُنُوبِهِمْ ۗ وَٱللَّهُ شَدِيدُ ٱلْعِقَابِ","translation":"[To them shall - happen] the like of what happened to Pharaoh's people and those who lived before them: they gave the lie to Our messages - and so God took them to task for their sins: for God is severe in retribution.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/304.mp3","surahId":3,"words":[{"id":12513,"position":1,"arabic":"كَدَأْبِ","translation":"পরিণতি মতো (হয়েছে)","audioUrl":"wbw/003_011_001.mp3","charTypeName":"word"},{"id":12514,"position":2,"arabic":"ءَالِ","translation":"সম্প্রদায়ের","audioUrl":"wbw/003_011_002.mp3","charTypeName":"word"},{"id":12515,"position":3,"arabic":"فِرْعَوْنَ","translation":"ফিরআউনের","audioUrl":"wbw/003_011_003.mp3","charTypeName":"word"},{"id":12516,"position":4,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/003_011_004.mp3","charTypeName":"word"},{"id":12517,"position":5,"arabic":"مِن","translation":"(থেকে)","audioUrl":"wbw/003_011_005.mp3","charTypeName":"word"},{"id":12518,"position":6,"arabic":"قَبْلِهِمْ ۚ","translation":"তাদের পূর্ব থেকে (ছিল)","audioUrl":"wbw/003_011_006.mp3","charTypeName":"word"},{"id":12520,"position":7,"arabic":"كَذَّبُوا۟","translation":"তারা অস্বীকার করেছিল","audioUrl":"wbw/003_011_008.mp3","charTypeName":"word"},{"id":12521,"position":8,"arabic":"بِـَٔايَـٰتِنَا","translation":"আমাদের নিদর্শনগুলোর প্রতি","audioUrl":"wbw/003_011_009.mp3","charTypeName":"word"},{"id":12522,"position":9,"arabic":"فَأَخَذَهُمُ","translation":"অতঃপর ধরলেন তাদেরকে","audioUrl":"wbw/003_011_010.mp3","charTypeName":"word"},{"id":12523,"position":10,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/003_011_011.mp3","charTypeName":"word"},{"id":12524,"position":11,"arabic":"بِذُنُوبِهِمْ ۗ","translation":"তাদের পাপের কারণে","audioUrl":"wbw/003_011_012.mp3","charTypeName":"word"},{"id":12526,"position":12,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/003_011_014.mp3","charTypeName":"word"},{"id":12527,"position":13,"arabic":"شَدِيدُ","translation":"বড় কঠোর","audioUrl":"wbw/003_011_015.mp3","charTypeName":"word"},{"id":12528,"position":14,"arabic":"ٱلْعِقَابِ","translation":"শাস্তিদানে","audioUrl":"wbw/003_011_016.mp3","charTypeName":"word"},{"id":12529,"position":15,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]},{"number":12,"arabic":"قُل لِّلَّذِينَ كَفَرُوا۟ سَتُغْلَبُونَ وَتُحْشَرُونَ إِلَىٰ جَهَنَّمَ ۚ وَبِئْسَ ٱلْمِهَادُ","translation":"Say unto those who are bent on denying the truth: \"You shall be overcome and gathered unto hell - and how evil a resting-place!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/305.mp3","surahId":3,"words":[{"id":13837,"position":1,"arabic":"قُل","translation":"বলো তুমি","audioUrl":"wbw/003_012_001.mp3","charTypeName":"word"},{"id":13838,"position":2,"arabic":"لِّلَّذِينَ","translation":"তাদের উদ্দেশে (যারা)","audioUrl":"wbw/003_012_002.mp3","charTypeName":"word"},{"id":13839,"position":3,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/003_012_003.mp3","charTypeName":"word"},{"id":13840,"position":4,"arabic":"سَتُغْلَبُونَ","translation":"শীঘ্রই তোমাদের পরাজিত হবে","audioUrl":"wbw/003_012_004.mp3","charTypeName":"word"},{"id":13841,"position":5,"arabic":"وَتُحْشَرُونَ","translation":"ও তোমাদের একত্র করা হবে","audioUrl":"wbw/003_012_005.mp3","charTypeName":"word"},{"id":13842,"position":6,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/003_012_006.mp3","charTypeName":"word"},{"id":13843,"position":7,"arabic":"جَهَنَّمَ ۚ","translation":"জাহান্নামের","audioUrl":"wbw/003_012_007.mp3","charTypeName":"word"},{"id":13845,"position":8,"arabic":"وَبِئْسَ","translation":"এবং (তা) অতিনিকৃষ্ট","audioUrl":"wbw/003_012_009.mp3","charTypeName":"word"},{"id":13846,"position":9,"arabic":"ٱلْمِهَادُ","translation":"আবাসস্থল","audioUrl":"wbw/003_012_010.mp3","charTypeName":"word"},{"id":13847,"position":10,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]},{"number":13,"arabic":"قَدْ كَانَ لَكُمْ ءَايَةٌۭ فِى فِئَتَيْنِ ٱلْتَقَتَا ۖ فِئَةٌۭ تُقَٰتِلُ فِى سَبِيلِ ٱللَّهِ وَأُخْرَىٰ كَافِرَةٌۭ يَرَوْنَهُم مِّثْلَيْهِمْ رَأْىَ ٱلْعَيْنِ ۚ وَٱللَّهُ يُؤَيِّدُ بِنَصْرِهِۦ مَن يَشَآءُ ۗ إِنَّ فِى ذَٰلِكَ لَعِبْرَةًۭ لِّأُو۟لِى ٱلْأَبْصَٰرِ","translation":"You have already had a sign in the two hosts that met in battle, one host fighting in God's cause and the other denying Him; with their own eyes [the former] saw the others as twice their own number: but God strengthens with His succour whom He wills. In this, behold, there is indeed a lesson for all who have eyes to see.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/306.mp3","surahId":3,"words":[{"id":15136,"position":1,"arabic":"قَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/003_013_001.mp3","charTypeName":"word"},{"id":15137,"position":2,"arabic":"كَانَ","translation":"রয়েছে","audioUrl":"wbw/003_013_002.mp3","charTypeName":"word"},{"id":15138,"position":3,"arabic":"لَكُمْ","translation":"তোমাদের জন্য","audioUrl":"wbw/003_013_003.mp3","charTypeName":"word"},{"id":15139,"position":4,"arabic":"ءَايَةٌۭ","translation":"নিদর্শন","audioUrl":"wbw/003_013_004.mp3","charTypeName":"word"},{"id":15140,"position":5,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/003_013_005.mp3","charTypeName":"word"},{"id":15141,"position":6,"arabic":"فِئَتَيْنِ","translation":"দুই দলের","audioUrl":"wbw/003_013_006.mp3","charTypeName":"word"},{"id":15142,"position":7,"arabic":"ٱلْتَقَتَا ۖ","translation":"সম্মুখীন হয়েছিল পরস্পর (বদরের যুদ্ধে)","audioUrl":"wbw/003_013_007.mp3","charTypeName":"word"},{"id":15144,"position":8,"arabic":"فِئَةٌۭ","translation":"একদল","audioUrl":"wbw/003_013_009.mp3","charTypeName":"word"},{"id":15145,"position":9,"arabic":"تُقَـٰتِلُ","translation":"লড়াই করেছে","audioUrl":"wbw/003_013_010.mp3","charTypeName":"word"},{"id":15146,"position":10,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/003_013_011.mp3","charTypeName":"word"},{"id":15147,"position":11,"arabic":"سَبِيلِ","translation":"পথের","audioUrl":"wbw/003_013_012.mp3","charTypeName":"word"},{"id":15148,"position":12,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/003_013_013.mp3","charTypeName":"word"},{"id":15149,"position":13,"arabic":"وَأُخْرَىٰ","translation":"এবং অন্যটি","audioUrl":"wbw/003_013_014.mp3","charTypeName":"word"},{"id":15150,"position":14,"arabic":"كَافِرَةٌۭ","translation":"কাফির","audioUrl":"wbw/003_013_015.mp3","charTypeName":"word"},{"id":15151,"position":15,"arabic":"يَرَوْنَهُم","translation":"তাদেরকে তারা(মুসলিমদেরকে) দেখে","audioUrl":"wbw/003_013_016.mp3","charTypeName":"word"},{"id":15152,"position":16,"arabic":"مِّثْلَيْهِمْ","translation":"তাদের দ্বিগুণ","audioUrl":"wbw/003_013_017.mp3","charTypeName":"word"},{"id":15153,"position":17,"arabic":"رَأْىَ","translation":"(দেখ)","audioUrl":"wbw/003_013_018.mp3","charTypeName":"word"},{"id":15154,"position":18,"arabic":"ٱلْعَيْنِ ۚ","translation":"চাক্ষুসভাবে","audioUrl":"wbw/003_013_019.mp3","charTypeName":"word"},{"id":15156,"position":19,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/003_013_021.mp3","charTypeName":"word"},{"id":15157,"position":20,"arabic":"يُؤَيِّدُ