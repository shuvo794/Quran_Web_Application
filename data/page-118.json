{"id":118,"ayahs":[{"number":58,"arabic":"وَإِذَا نَادَيْتُمْ إِلَى ٱلصَّلَوٰةِ ٱتَّخَذُوهَا هُزُوًۭا وَلَعِبًۭا ۚ ذَٰلِكَ بِأَنَّهُمْ قَوْمٌۭ لَّا يَعْقِلُونَ","translation":"for, when you call to prayer, they mock at it and make a jest of it-simply because they are people who do not use their reason.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/727.mp3","surahId":5,"words":[{"id":53595,"position":1,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/005_058_001.mp3","charTypeName":"word"},{"id":53596,"position":2,"arabic":"نَادَيْتُمْ","translation":"ডাকা হয় তোমাদেরকে","audioUrl":"wbw/005_058_002.mp3","charTypeName":"word"},{"id":53597,"position":3,"arabic":"إِلَى","translation":"দিকে","audioUrl":"wbw/005_058_003.mp3","charTypeName":"word"},{"id":53598,"position":4,"arabic":"ٱلصَّلَوٰةِ","translation":"সালাতের","audioUrl":"wbw/005_058_004.mp3","charTypeName":"word"},{"id":53599,"position":5,"arabic":"ٱتَّخَذُوهَا","translation":"তারা গ্রহণ করে তা","audioUrl":"wbw/005_058_005.mp3","charTypeName":"word"},{"id":53600,"position":6,"arabic":"هُزُوًۭا","translation":"বিদ্রুপ (রূপে)","audioUrl":"wbw/005_058_006.mp3","charTypeName":"word"},{"id":53601,"position":7,"arabic":"وَلَعِبًۭا ۚ","translation":"ও খেলা হিসেবে","audioUrl":"wbw/005_058_007.mp3","charTypeName":"word"},{"id":53603,"position":8,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/005_058_009.mp3","charTypeName":"word"},{"id":53604,"position":9,"arabic":"بِأَنَّهُمْ","translation":"এ কারণে যে তারা","audioUrl":"wbw/005_058_010.mp3","charTypeName":"word"},{"id":53605,"position":10,"arabic":"قَوْمٌۭ","translation":"(এমন)সম্প্রদায়","audioUrl":"wbw/005_058_011.mp3","charTypeName":"word"},{"id":53606,"position":11,"arabic":"لَّا","translation":"(যারা) না","audioUrl":"wbw/005_058_012.mp3","charTypeName":"word"},{"id":53607,"position":12,"arabic":"يَعْقِلُونَ","translation":"বিচার বিবেচনা করে","audioUrl":"wbw/005_058_013.mp3","charTypeName":"word"},{"id":53608,"position":13,"arabic":"٥٨","translation":"(৫৮)","audioUrl":null,"charTypeName":"end"}]},{"number":59,"arabic":"قُلْ يَٰٓأَهْلَ ٱلْكِتَٰبِ هَلْ تَنقِمُونَ مِنَّآ إِلَّآ أَنْ ءَامَنَّا بِٱللَّهِ وَمَآ أُنزِلَ إِلَيْنَا وَمَآ أُنزِلَ مِن قَبْلُ وَأَنَّ أَكْثَرَكُمْ فَٰسِقُونَ","translation":"Say: \"O followers of earlier revelation! Do you find fault with us for no other reason than that we believe in God [alone], and in that which He has bestowed from on high upon us as well as that which He has bestowed aforetime? - or [is it only] because most of you are iniquitous?\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/728.mp3","surahId":5,"words":[{"id":53882,"position":1,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/005_059_001.mp3","charTypeName":"word"},{"id":53883,"position":2,"arabic":"يَـٰٓأَهْلَ","translation":"\"হে অধিকারীরা","audioUrl":"wbw/005_059_002.mp3","charTypeName":"word"},{"id":53884,"position":3,"arabic":"ٱلْكِتَـٰبِ","translation":"কিতাবের","audioUrl":"wbw/005_059_003.mp3","charTypeName":"word"},{"id":53885,"position":4,"arabic":"هَلْ","translation":"কি","audioUrl":"wbw/005_059_004.mp3","charTypeName":"word"},{"id":53886,"position":5,"arabic":"تَنقِمُونَ","translation":"তোমরা প্রতিশোধ নিচ্ছো","audioUrl":"wbw/005_059_005.mp3","charTypeName":"word"},{"id":53887,"position":6,"arabic":"مِنَّآ","translation":"থেকে আমাদের","audioUrl":"wbw/005_059_006.mp3","charTypeName":"word"},{"id":53888,"position":7,"arabic":"إِلَّآ","translation":"এ ছাড়া (অন্য কিছুর)","audioUrl":"wbw/005_059_007.mp3","charTypeName":"word"},{"id":53889,"position":8,"arabic":"أَنْ","translation":"যে","audioUrl":"wbw/005_059_008.mp3","charTypeName":"word"},{"id":53890,"position":9,"arabic":"ءَامَنَّا","translation":"ঈমান এনেছি আমরা","audioUrl":"wbw/005_059_009.mp3","charTypeName":"word"},{"id":53891,"position":10,"arabic":"بِٱللَّهِ","translation":"উপর আল্লাহর","audioUrl":"wbw/005_059_010.mp3","charTypeName":"word"},{"id":53892,"position":11,"arabic":"وَمَآ","translation":"এবং যা","audioUrl":"wbw/005_059_011.mp3","charTypeName":"word"},{"id":53893,"position":12,"arabic":"أُنزِلَ","translation":"অবতীর্ণ করা হয়েছে","audioUrl":"wbw/005_059_012.mp3","charTypeName":"word"},{"id":53894,"position":13,"arabic":"إِلَيْنَا","translation":"প্রতি আমাদের","audioUrl":"wbw/005_059_013.mp3","charTypeName":"word"},{"id":53895,"position":14,"arabic":"وَمَآ","translation":"এবং যা","audioUrl":"wbw/005_059_014.mp3","charTypeName":"word"},{"id":53896,"position":15,"arabic":"أُنزِلَ","translation":"অবতীর্ণ করা হয়েছে","audioUrl":"wbw/005_059_015.mp3","charTypeName":"word"},{"id":53897,"position":16,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/005_059_016.mp3","charTypeName":"word"},{"id":53898,"position":17,"arabic":"قَبْلُ","translation":"পূর্ব","audioUrl":"wbw/005_059_017.mp3","charTypeName":"word"},{"id":53899,"position":18,"arabic":"وَأَنَّ","translation":"আর(মূল কথা হলো)যে","audioUrl":"wbw/005_059_018.mp3","charTypeName":"word"},{"id":53900,"position":19,"arabic":"أَكْثَرَكُمْ","translation":"অধিকাংশ তোমাদের","audioUrl":"wbw/005_059_019.mp3","charTypeName":"word"},{"id":53901,"position":20,"arabic":"فَـٰسِقُونَ","translation":"সত্যত্যাগী\"","audioUrl":"wbw/005_059_020.mp3","charTypeName":"word"},{"id":53902,"position":21,"arabic":"٥٩","translation":"(৫৯)","audioUrl":null,"charTypeName":"end"}]},{"number":60,"arabic":"قُلْ هَلْ أُنَبِّئُكُم بِشَرٍّۢ مِّن ذَٰلِكَ مَثُوبَةً عِندَ ٱللَّهِ ۚ مَن لَّعَنَهُ ٱللَّهُ وَغَضِبَ عَلَيْهِ وَجَعَلَ مِنْهُمُ ٱلْقِرَدَةَ وَٱلْخَنَازِيرَ وَعَبَدَ ٱلطَّٰغُوتَ ۚ أُو۟لَٰٓئِكَ شَرٌّۭ مَّكَانًۭا وَأَضَلُّ عَن سَوَآءِ ٱلسَّبِيلِ","translation":"Say: \"Shall I tell you who, in the sight of God, deserves a yet worse retribution than these? They whom God has rejected and whom He has condemned, and whom He has turned into apes and swine because they worshipped the powers of evil: these are yet worse in station, and farther astray from the right path [than the mockers].\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/729.mp3","surahId":5,"words":[{"id":54740,"position":1,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/005_060_001.mp3","charTypeName":"word"},{"id":54741,"position":2,"arabic":"هَلْ","translation":"\"কি","audioUrl":"wbw/005_060_002.mp3","charTypeName":"word"},{"id":54742,"position":3,"arabic":"أُنَبِّئُكُم","translation":"সংবাদ দিবো তোমাদের","audioUrl":"wbw/005_060_003.mp3","charTypeName":"word"},{"id":54743,"position":4,"arabic":"بِشَرٍّۢ","translation":"ব্যাপারে নিকৃষ্টের","audioUrl":"wbw/005_060_004.mp3","charTypeName":"word"},{"id":54744,"position":5,"arabic":"مِّن","translation":"চেয়েও","audioUrl":"wbw/005_060_005.mp3","charTypeName":"word"},{"id":54745,"position":6,"arabic":"ذَٰلِكَ","translation":"এর","audioUrl":"wbw/005_060_006.mp3","charTypeName":"word"},{"id":54746,"position":7,"arabic":"مَثُوبَةً","translation":"পরিণতির দিক দিয়ে","audioUrl":"wbw/005_060_007.mp3","charTypeName":"word"},{"id":54747,"position":8,"arabic":"عِندَ","translation":"কাছে","audioUrl":"wbw/005_060_008.mp3","charTypeName":"word"},{"id":54748,"position":9,"arabic":"ٱللَّهِ ۚ","translation":"আল্লাহর","audioUrl":"wbw/005_060_009.mp3","charTypeName":"word"},{"id":54750,"position":10,"arabic":"مَن","translation":"(সে ঐলোক) যে","audioUrl":"wbw/005_060_011.mp3","charTypeName":"word"},{"id":54751,"position":11,"arabic":"لَّعَنَهُ","translation":"অভিশাপ দিয়েছেন তাকে","audioUrl":"wbw/005_060_012.mp3","charTypeName":"word"},{"id":54752,"position":12,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/005_060_013.mp3","charTypeName":"word"},{"id":54753,"position":13,"arabic":"وَغَضِبَ","translation":"ও রাগ হয়েছেন","audioUrl":"wbw/005_060_014.mp3","charTypeName":"word"},{"id":54754,"position":14,"arabic":"عَلَيْهِ","translation":"উপর তার","audioUrl":"wbw/005_060_015.mp3","charTypeName":"word"},{"id":54755,"position":15,"arabic":"وَجَعَلَ","translation":"ও বানিয়েছেন","audioUrl":"wbw/005_060_016.mp3","charTypeName":"word"},{"id":54756,"position":16,"arabic":"مِنْهُمُ","translation":"মধ্য হতে কাউকে তাদের","audioUrl":"wbw/005_060_017.mp3","charTypeName":"word"},{"id":54757,"position":17,"arabic":"ٱلْقِرَدَةَ","translation":"বানর","audioUrl":"wbw/005_060_018.mp3","charTypeName":"word"},{"id":54758,"position":18,"arabic":"وَٱلْخَنَازِيرَ","translation":"ও শুকর","audioUrl":"wbw/005_060_019.mp3","charTypeName":"word"},{"id":54759,"position":19,"arabic":"وَعَبَدَ","translation":"ও সে উপাসনা করেছে","audioUrl":"wbw/005_060_020.mp3","charTypeName":"word"},{"id":54760,"position":20,"arabic":"ٱلطَّـٰغُوتَ ۚ","translation":"অসত্য দেবতার","audioUrl":"wbw/005_060_021.mp3","charTypeName":"word"},{"id":54762,"position":21,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐসব লোক","audioUrl":"wbw/005_060_023.mp3","charTypeName":"word"},{"id":54763,"position":22,"arabic":"شَرٌّۭ","translation":"নিকৃষ্ট","audioUrl":"wbw/005_060_024.mp3","charTypeName":"word"},{"id":54764,"position":23,"arabic":"مَّكَانًۭا","translation":"মর্যাদায়","audioUrl":"wbw/005_060_025.mp3","charTypeName":"word"},{"id":54765,"position":24,"arabic":"وَأَضَلُّ","translation":"ও অধিক পথভ্রষ্ট","audioUrl":"wbw/005_060_026.mp3","charTypeName":"word"},{"id":54766,"position":25,"arabic":"عَن","translation":"হতে","audioUrl":"wbw/005_060_027.mp3","charTypeName":"word"},{"id":54767,"position":26,"arabic":"سَوَآءِ","translation":"সরল সোজা","audioUrl":"wbw/005_060_028.mp3","charTypeName":"word"},{"id":54768,"position":27,"arabic":"ٱلسَّبِيلِ","translation":"পথ\"","audioUrl":"wbw/005_060_029.mp3","charTypeName":"word"},{"id":54769,"position":28,"arabic":"٦٠","translation":"(৬০)","audioUrl":null,"charTypeName":"end"}]},{"number":61,"arabic":"وَإِذَا جَآءُوكُمْ قَالُوٓا۟ ءَامَنَّا وَقَد دَّخَلُوا۟ بِٱلْكُفْرِ وَهُمْ قَدْ خَرَجُوا۟ بِهِۦ ۚ وَٱللَّهُ أَعْلَمُ بِمَا كَانُوا۟ يَكْتُمُونَ","translation":"For, when they come unto you, they say, \"We do believe\": whereas, in fact, they come with the resolve to deny the truth, and depart in the same state. But God is fully aware of all that they would conceal.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/730.mp3","surahId":5,"words":[{"id":55320,"position":1,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/005_061_001.mp3","charTypeName":"word"},{"id":55321,"position":2,"arabic":"جَآءُوكُمْ","translation":"কাছে আসে তোমাদের","audioUrl":"wbw/005_061_002.mp3","charTypeName":"word"},{"id":55322,"position":3,"arabic":"قَالُوٓا۟","translation":"তারা বলে","audioUrl":"wbw/005_061_003.mp3","charTypeName":"word"},{"id":55323,"position":4,"arabic":"ءَامَنَّا","translation":"\"ঈমান এনেছি আমরা\"","audioUrl":"wbw/005_061_004.mp3","charTypeName":"word"},{"id":55324,"position":5,"arabic":"وَقَد","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/005_061_005.mp3","charTypeName":"word"},{"id":55325,"position":6,"arabic":"دَّخَلُوا۟","translation":"তারা প্রবেশ করেছে","audioUrl":"wbw/005_061_006.mp3","charTypeName":"word"},{"id":55326,"position":7,"arabic":"بِٱلْكُفْرِ","translation":"নিয়ে অবিশ্বাস","audioUrl":"wbw/005_061_007.mp3","charTypeName":"word"},{"id":55327,"position":8,"arabic":"وَهُمْ","translation":"এবং তারা","audioUrl":"wbw/005_061_008.mp3","charTypeName":"word"},{"id":55328,"position":9,"arabic":"قَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/005_061_009.mp3","charTypeName":"word"},{"id":55329,"position":10,"arabic":"خَرَجُوا۟","translation":"বের হয়েছে","audioUrl":"wbw/005_061_010.mp3","charTypeName":"word"},{"id":55330,"position":11,"arabic":"بِهِۦ ۚ","translation":"নিয়ে তা","audioUrl":"wbw/005_061_011.mp3","charTypeName":"word"},{"id":55332,"position":12,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/005_061_013.mp3","charTypeName":"word"},{"id":55333,"position":13,"arabic":"أَعْلَمُ","translation":"খুব জানেন","audioUrl":"wbw/005_061_014.mp3","charTypeName":"word"},{"id":55334,"position":14,"arabic":"بِمَا","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/005_061_015.mp3","charTypeName":"word"},{"id":55335,"position":15,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/005_061_016.mp3","charTypeName":"word"},{"id":55336,"position":16,"arabic":"يَكْتُمُونَ","translation":"তারা গোপন করে (মনের মধ্যে)","audioUrl":"wbw/005_061_017.mp3","charTypeName":"word"},{"id":55337,"position":17,"arabic":"٦١","translation":"(৬১)","audioUrl":null,"charTypeName":"end"}]},{"number":62,"arabic":"وَتَرَىٰ كَثِيرًۭا مِّنْهُمْ يُسَٰرِعُونَ فِى ٱلْإِثْمِ وَٱلْعُدْوَٰنِ وَأَكْلِهِمُ ٱلسُّحْتَ ۚ لَبِئْسَ مَا كَانُوا۟ يَعْمَلُونَ","translation":"And thou canst see many of them vie with one another in sinning and tyrannical conduct and in their swallowing of all that is evil.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/731.mp3","surahId":5,"words":[{"id":55723,"position":1,"arabic":"وَتَرَىٰ","translation":"এবং তুমি দেখবে","audioUrl":"wbw/005_062_001.mp3","charTypeName":"word"},{"id":55724,"position":2,"arabic":"كَثِيرًۭا","translation":"অনেক (লোককে)","audioUrl":"wbw/005_062_002.mp3","charTypeName":"word"},{"id":55725,"position":3,"arabic":"مِّنْهُمْ","translation":"মধ্য থেকে তাদের","audioUrl":"wbw/005_062_003.mp3","charTypeName":"word"},{"id":55726,"position":4,"arabic":"يُسَـٰرِعُونَ","translation":"তারা দ্রুত ধাবিত হয়","audioUrl":"wbw/005_062_004.mp3","charTypeName":"word"},{"id":55727,"position":5,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/005_062_005.mp3","charTypeName":"word"},{"id":55728,"position":6,"arabic":"ٱلْإِثْمِ","translation":"পাপের","audioUrl":"wbw/005_062_006.mp3","charTypeName":"word"},{"id":55729,"position":7,"arabic":"وَٱلْعُدْوَٰنِ","translation":"ও সীমালঙ্ঘনে","audioUrl":"wbw/005_062_007.mp3","charTypeName":"word"},{"id":55730,"position":8,"arabic":"وَأَكْلِهِمُ","translation":"ও তাদের খাওয়া","audioUrl":"wbw/005_062_008.mp3","charTypeName":"word"},{"id":55731,"position":9,"arabic":"ٱلسُّحْتَ ۚ","translation":"অবৈধ(অতি তৎপর)","audioUrl":"wbw/005_062_009.mp3","charTypeName":"word"},{"id":55733,"position":10,"arabic":"لَبِئْسَ","translation":"অবশ্যই নিকৃষ্ট","audioUrl":"wbw/005_062_011.mp3","charTypeName":"word"},{"id":55734,"position":11,"arabic":"مَا","translation":"যা","audioUrl":"wbw/005_062_012.mp3","charTypeName":"word"},{"id":55735,"position":12,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/005_062_013.mp3","charTypeName":"word"},{"id":55736,"position":13,"arabic":"يَعْمَلُونَ","translation":"তারা কাজ করে এসেছে","audioUrl":"wbw/005_062_014.mp3","charTypeName":"word"},{"id":55737,"position":14,"arabic":"٦٢","translation":"(৬২)","audioUrl":null,"charTypeName":"end"}]},{"number":63,"arabic":"لَوْلَا يَنْهَىٰهُمُ ٱلرَّبَّٰنِيُّونَ وَٱلْأَحْبَارُ عَن قَوْلِهِمُ ٱلْإِثْمَ وَأَكْلِهِمُ ٱلسُّحْتَ ۚ لَبِئْسَ مَا كَانُوا۟ يَصْنَعُونَ","translation":"Why do not their men of God and their rabbis forbid them to make sinful assertions and to swallow all that is evil? Vile indeed is what they contrive!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/732.mp3","surahId":5,"words":[{"id":56225,"position":1,"arabic":"لَوْلَا","translation":"কেন না","audioUrl":"wbw/005_063_001.mp3","charTypeName":"word"},{"id":56226,"position":2,"arabic":"يَنْهَىٰهُمُ","translation":"নিষেধ করে তাদের","audioUrl":"wbw/005_063_002.mp3","charTypeName":"word"},{"id":56227,"position":3,"arabic":"ٱلرَّبَّـٰنِيُّونَ","translation":"রব্বানি","audioUrl":"wbw/005_063_003.mp3","charTypeName":"word"},{"id":56228,"position":4,"arabic":"وَٱلْأَحْبَارُ","translation":"ও পন্ডিতগণ (তাদের মধ্যকার)","audioUrl":"wbw/005_063_004.mp3","charTypeName":"word"},{"id":56229,"position":5,"arabic":"عَن","translation":"হতে","audioUrl":"wbw/005_063_005.mp3","charTypeName":"word"},{"id":56230,"position":6,"arabic":"قَوْلِهِمُ","translation":"কথা তাদের (বলা)","audioUrl":"wbw/005_063_006.mp3","charTypeName":"word"},{"id":56231,"position":7,"arabic":"ٱلْإِثْمَ","translation":"পাপের","audioUrl":"wbw/005_063_007.mp3","charTypeName":"word"},{"id":56232,"position":8,"arabic":"وَأَكْلِهِمُ","translation":"ও তাদের খাওয়া (হতে)","audioUrl":"wbw/005_063_008.mp3","charTypeName":"word"},{"id":56233,"position":9,"arabic":"ٱلسُّحْتَ ۚ","translation":"অবৈধ","audioUrl":"wbw/005_063_009.mp3","charTypeName":"word"},{"id":56235,"position":10,"arabic":"لَبِئْسَ","translation":"অবশ্যই নিকৃষ্ট","audioUrl":"wbw/005_063_011.mp3","charTypeName":"word"},{"id":56236,"position":11,"arabic":"مَا","translation":"যা","audioUrl":"wbw/005_063_012.mp3","charTypeName":"word"},{"id":56237,"position":12,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/005_063_013.mp3","charTypeName":"word"},{"id":56238,"position":13,"arabic":"يَصْنَعُونَ","translation":"তারা রচনা করে এসেছে","audioUrl":"wbw/005_063_014.mp3","charTypeName":"word"},{"id":56239,"position":14,"arabic":"٦٣","translation":"(৬৩)","audioUrl":null,"charTypeName":"end"}]},{"number":64,"arabic":"وَقَالَتِ ٱلْيَهُودُ يَدُ ٱللَّهِ مَغْلُولَةٌ ۚ غُلَّتْ أَيْدِيهِمْ وَلُعِنُوا۟ بِمَا قَالُوا۟ ۘ بَلْ يَدَاهُ مَبْسُوطَتَانِ يُنفِقُ كَيْفَ يَشَآءُ ۚ وَلَيَزِيدَنَّ كَثِيرًۭا مِّنْهُم مَّآ أُنزِلَ إِلَيْكَ مِن رَّبِّكَ طُغْيَٰنًۭا وَكُفْرًۭا ۚ وَأَلْقَيْنَا بَيْنَهُمُ ٱلْعَدَٰوَةَ وَٱلْبَغْضَآءَ إِلَىٰ يَوْمِ ٱلْقِيَٰمَةِ ۚ كُلَّمَآ أَوْقَدُوا۟ نَارًۭا لِّلْحَرْبِ أَطْفَأَهَا ٱللَّهُ ۚ وَيَسْعَوْنَ فِى ٱلْأَرْضِ فَسَادًۭا ۚ وَٱللَّهُ لَا يُحِبُّ ٱلْمُفْسِدِينَ","translation":"And the Jews say, \"God's hand is shackled!\" It is their own hands that are shackled; and rejected [by God] are they because of this their assertion. Nay, but wide are His hands stretched out: He dispenses [bounty] as He wills. But all that has been bestowed from on high upon thee [O Prophet] by thy Sustainer is bound to make many of them yet more stubborn in their overweening arrogance and in their denial of the truth. And so We have cast enmity and hatred among the followers of the Bible, [to last] until Resurrection Day; every time they light the fires of war, God extinguishes them; and they labour hard to spread corruption on earth: and God does not -love the spreaders of corruption.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/733.mp3","surahId":5,"words":[{"id":56686,"position":1,"arabic":"وَقَالَتِ","translation":"এবং বলে","audioUrl":"wbw/005_064_001.mp3","charTypeName":"word"},{"id":56687,"position":2,"arabic":"ٱلْيَهُودُ","translation":"ইয়াহুদীরা","audioUrl":"wbw/005_064_002.mp3","charTypeName":"word"},{"id":56688,"position":3,"arabic":"يَدُ","translation":"হাত","audioUrl":"wbw/005_064_003.mp3","charTypeName":"word"},{"id":56689,"position":4,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/005_064_004.mp3","charTypeName":"word"},{"id":56690,"position":5,"arabic":"مَغْلُولَةٌ ۚ","translation":"অবরুদ্ধ\"","audioUrl":"wbw/005_064_005.mp3","charTypeName":"word"},{"id":56692,"position":6,"arabic":"غُلَّتْ","translation":"প্রকৃতপক্ষে অবরুদ্ধ হয়েছে","audioUrl":"wbw/005_064_007.mp3","charTypeName":"word"},{"id":56693,"position":7,"arabic":"أَيْدِيهِمْ","translation":"হাতগুলো তাদের (অর্থাৎ ইয়াহুদীদের)","audioUrl":"wbw/005_064_008.mp3","charTypeName":"word"},{"id":56694,"position":8,"arabic":"وَلُعِنُوا۟","translation":"ও তারা অভিশপ্ত হয়েছে","audioUrl":"wbw/005_064_009.mp3","charTypeName":"word"},{"id":56695,"position":9,"arabic":"بِمَا","translation":"এ কারণে যা","audioUrl":"wbw/005_064_010.mp3","charTypeName":"word"},{"id":56696,"position":10,"arabic":"قَالُوا۟ ۘ","translation":"তারা বলেছে","audioUrl":"wbw/005_064_011.mp3","charTypeName":"word"},{"id":56698,"position":11,"arabic":"بَلْ","translation":"বরং","audioUrl":"wbw/005_064_013.mp3","charTypeName":"word"},{"id":56699,"position":12,"arabic":"يَدَاهُ","translation":"দু'হাত তাঁর","audioUrl":"wbw/005_064_014.mp3","charTypeName":"word"},{"id":56700,"position":13,"arabic":"مَبْسُوطَتَانِ","translation":"প্রসারিত","audioUrl":"wbw/005_064_015.mp3","charTypeName":"word"},{"id":56701,"position":14,"arabic":"يُنفِقُ","translation":"ব্যয় করেন তিনি","audioUrl":"wbw/005_064_016.mp3","charTypeName":"word"},{"id":56702,"position":15,"arabic":"كَيْفَ","translation":"যেভাবে","audioUrl":"wbw/005_064_017.mp3","charTypeName":"word"},{"id":56703,"position"