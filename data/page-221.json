{"id":221,"ayahs":[{"number":107,"arabic":"وَإِن يَمْسَسْكَ ٱللَّهُ بِضُرٍّۢ فَلَا كَاشِفَ لَهُۥٓ إِلَّا هُوَ ۖ وَإِن يُرِدْكَ بِخَيْرٍۢ فَلَا رَآدَّ لِفَضْلِهِۦ ۚ يُصِيبُ بِهِۦ مَن يَشَآءُ مِنْ عِبَادِهِۦ ۚ وَهُوَ ٱلْغَفُورُ ٱلرَّحِيمُ","translation":"And [know that] if God should touch thee with misfortune, there is none who could remove it save Him; and if He intends good for thee, there is none who could turn away His bounty: He causes it to alight upon whomsoever He wills of His servants. And He alone is truly forgiving, truly a dispenser of grace.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1471.mp3","surahId":10,"words":[{"id":73206,"position":1,"arabic":"وَإِن","translation":"এবং যদি","audioUrl":"wbw/010_107_001.mp3","charTypeName":"word"},{"id":73207,"position":2,"arabic":"يَمْسَسْكَ","translation":"তোমাকে স্পর্শ করেন","audioUrl":"wbw/010_107_002.mp3","charTypeName":"word"},{"id":73208,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/010_107_003.mp3","charTypeName":"word"},{"id":73209,"position":4,"arabic":"بِضُرٍّۢ","translation":"দিয়ে কষ্ট","audioUrl":"wbw/010_107_004.mp3","charTypeName":"word"},{"id":73210,"position":5,"arabic":"فَلَا","translation":"তবে নেই","audioUrl":"wbw/010_107_005.mp3","charTypeName":"word"},{"id":73211,"position":6,"arabic":"كَاشِفَ","translation":"মোচনকারী","audioUrl":"wbw/010_107_006.mp3","charTypeName":"word"},{"id":73212,"position":7,"arabic":"لَهُۥٓ","translation":"জন্যে তার","audioUrl":"wbw/010_107_007.mp3","charTypeName":"word"},{"id":73213,"position":8,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/010_107_008.mp3","charTypeName":"word"},{"id":73214,"position":9,"arabic":"هُوَ ۖ","translation":"তিনিই","audioUrl":"wbw/010_107_009.mp3","charTypeName":"word"},{"id":73216,"position":10,"arabic":"وَإِن","translation":"এবং যদি (আল্লাহ)","audioUrl":"wbw/010_107_011.mp3","charTypeName":"word"},{"id":73217,"position":11,"arabic":"يُرِدْكَ","translation":"তোমার জন্যে চান","audioUrl":"wbw/010_107_012.mp3","charTypeName":"word"},{"id":73218,"position":12,"arabic":"بِخَيْرٍۢ","translation":"বিষয় কল্যাণের","audioUrl":"wbw/010_107_013.mp3","charTypeName":"word"},{"id":73219,"position":13,"arabic":"فَلَا","translation":"তবে নেই","audioUrl":"wbw/010_107_014.mp3","charTypeName":"word"},{"id":73220,"position":14,"arabic":"رَآدَّ","translation":"কোনো রদকারী","audioUrl":"wbw/010_107_015.mp3","charTypeName":"word"},{"id":73221,"position":15,"arabic":"لِفَضْلِهِۦ ۚ","translation":"জন্যে অনুগ্রহের তাঁর","audioUrl":"wbw/010_107_016.mp3","charTypeName":"word"},{"id":73223,"position":16,"arabic":"يُصِيبُ","translation":"তিনি পৌঁছান","audioUrl":"wbw/010_107_018.mp3","charTypeName":"word"},{"id":73224,"position":17,"arabic":"بِهِۦ","translation":"সহ তা","audioUrl":"wbw/010_107_019.mp3","charTypeName":"word"},{"id":73225,"position":18,"arabic":"مَن","translation":"যাকে","audioUrl":"wbw/010_107_020.mp3","charTypeName":"word"},{"id":73226,"position":19,"arabic":"يَشَآءُ","translation":"তিনি ইচ্ছে করেন","audioUrl":"wbw/010_107_021.mp3","charTypeName":"word"},{"id":73227,"position":20,"arabic":"مِنْ","translation":"মধ্য হতে","audioUrl":"wbw/010_107_022.mp3","charTypeName":"word"},{"id":73228,"position":21,"arabic":"عِبَادِهِۦ ۚ","translation":"দাসদের তাঁর","audioUrl":"wbw/010_107_023.mp3","charTypeName":"word"},{"id":73230,"position":22,"arabic":"وَهُوَ","translation":"এবং তিনি","audioUrl":"wbw/010_107_025.mp3","charTypeName":"word"},{"id":73231,"position":23,"arabic":"ٱلْغَفُورُ","translation":"ক্ষমাশীল","audioUrl":"wbw/010_107_026.mp3","charTypeName":"word"},{"id":73232,"position":24,"arabic":"ٱلرَّحِيمُ","translation":"পরম দয়ালু","audioUrl":"wbw/010_107_027.mp3","charTypeName":"word"},{"id":73233,"position":25,"arabic":"١٠٧","translation":"(১০৭)","audioUrl":null,"charTypeName":"end"}]},{"number":108,"arabic":"قُلْ يَٰٓأَيُّهَا ٱلنَّاسُ قَدْ جَآءَكُمُ ٱلْحَقُّ مِن رَّبِّكُمْ ۖ فَمَنِ ٱهْتَدَىٰ فَإِنَّمَا يَهْتَدِى لِنَفْسِهِۦ ۖ وَمَن ضَلَّ فَإِنَّمَا يَضِلُّ عَلَيْهَا ۖ وَمَآ أَنَا۠ عَلَيْكُم بِوَكِيلٍۢ","translation":"SAY [O Prophet]: \"O mankind! The truth from your Sustainer has now come unto you. Whoever, therefore, chooses to follow the right path, follows it but for his own good; and whoever chooses to go astray, goes but astray to his own hurt. And I am not responsible for your conduct.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1472.mp3","surahId":10,"words":[{"id":73458,"position":1,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/010_108_001.mp3","charTypeName":"word"},{"id":73459,"position":2,"arabic":"يَـٰٓأَيُّهَا","translation":"\"হে","audioUrl":"wbw/010_108_002.mp3","charTypeName":"word"},{"id":73460,"position":3,"arabic":"ٱلنَّاسُ","translation":"\"মানুষ","audioUrl":"wbw/010_108_003.mp3","charTypeName":"word"},{"id":73461,"position":4,"arabic":"قَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/010_108_004.mp3","charTypeName":"word"},{"id":73462,"position":5,"arabic":"جَآءَكُمُ","translation":"কাছে এসেছে তোমাদের","audioUrl":"wbw/010_108_005.mp3","charTypeName":"word"},{"id":73463,"position":6,"arabic":"ٱلْحَقُّ","translation":"(প্রকৃত)সত্য","audioUrl":"wbw/010_108_006.mp3","charTypeName":"word"},{"id":73464,"position":7,"arabic":"مِن","translation":"পক্ষ হতে","audioUrl":"wbw/010_108_007.mp3","charTypeName":"word"},{"id":73465,"position":8,"arabic":"رَّبِّكُمْ ۖ","translation":"রবের তোমাদের","audioUrl":"wbw/010_108_008.mp3","charTypeName":"word"},{"id":73467,"position":9,"arabic":"فَمَنِ","translation":"অতএব যে","audioUrl":"wbw/010_108_010.mp3","charTypeName":"word"},{"id":73468,"position":10,"arabic":"ٱهْتَدَىٰ","translation":"সঠিক পথ পেলো","audioUrl":"wbw/010_108_011.mp3","charTypeName":"word"},{"id":73469,"position":11,"arabic":"فَإِنَّمَا","translation":"তবে প্রকৃতপক্ষে","audioUrl":"wbw/010_108_012.mp3","charTypeName":"word"},{"id":73470,"position":12,"arabic":"يَهْتَدِى","translation":"সে সঠিকপথ পায়","audioUrl":"wbw/010_108_013.mp3","charTypeName":"word"},{"id":73471,"position":13,"arabic":"لِنَفْسِهِۦ ۖ","translation":"জন্যে তার নিজের (মঙ্গলের)","audioUrl":"wbw/010_108_014.mp3","charTypeName":"word"},{"id":73473,"position":14,"arabic":"وَمَن","translation":"এবং যে","audioUrl":"wbw/010_108_016.mp3","charTypeName":"word"},{"id":73474,"position":15,"arabic":"ضَلَّ","translation":"পথভ্রষ্ট হলো","audioUrl":"wbw/010_108_017.mp3","charTypeName":"word"},{"id":73475,"position":16,"arabic":"فَإِنَّمَا","translation":"তবে প্রকৃতপক্ষে","audioUrl":"wbw/010_108_018.mp3","charTypeName":"word"},{"id":73476,"position":17,"arabic":"يَضِلُّ","translation":"সে পথভ্রষ্ট হয়","audioUrl":"wbw/010_108_019.mp3","charTypeName":"word"},{"id":73477,"position":18,"arabic":"عَلَيْهَا ۖ","translation":"জন্যে তার (ক্ষতির)","audioUrl":"wbw/010_108_020.mp3","charTypeName":"word"},{"id":73479,"position":19,"arabic":"وَمَآ","translation":"এবং নই","audioUrl":"wbw/010_108_022.mp3","charTypeName":"word"},{"id":73480,"position":20,"arabic":"أَنَا۠","translation":"আমি","audioUrl":"wbw/010_108_023.mp3","charTypeName":"word"},{"id":73481,"position":21,"arabic":"عَلَيْكُم","translation":"উপর তোমাদের","audioUrl":"wbw/010_108_024.mp3","charTypeName":"word"},{"id":73482,"position":22,"arabic":"بِوَكِيلٍۢ","translation":"কোনো কর্মবিধায়ক\"","audioUrl":"wbw/010_108_025.mp3","charTypeName":"word"},{"id":73483,"position":23,"arabic":"١٠٨","translation":"(১০৮)","audioUrl":null,"charTypeName":"end"}]},{"number":109,"arabic":"وَٱتَّبِعْ مَا يُوحَىٰٓ إِلَيْكَ وَٱصْبِرْ حَتَّىٰ يَحْكُمَ ٱللَّهُ ۚ وَهُوَ خَيْرُ ٱلْحَٰكِمِينَ","translation":"And [as for thyself, O Muhammad,] follow but what is being revealed unto thee, and be patient in adversity, until God shall give His judgment: for He is the best of all judges.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1473.mp3","surahId":10,"words":[{"id":73738,"position":1,"arabic":"وَٱتَّبِعْ","translation":"এবং তুমি অনুসরণ করো","audioUrl":"wbw/010_109_001.mp3","charTypeName":"word"},{"id":73739,"position":2,"arabic":"مَا","translation":"যা কিছু","audioUrl":"wbw/010_109_002.mp3","charTypeName":"word"},{"id":73740,"position":3,"arabic":"يُوحَىٰٓ","translation":"ওহী করা হয়েছে","audioUrl":"wbw/010_109_003.mp3","charTypeName":"word"},{"id":73741,"position":4,"arabic":"إِلَيْكَ","translation":"প্রতি তোমার","audioUrl":"wbw/010_109_004.mp3","charTypeName":"word"},{"id":73742,"position":5,"arabic":"وَٱصْبِرْ","translation":"এবং ধৈর্য ধরো","audioUrl":"wbw/010_109_005.mp3","charTypeName":"word"},{"id":73743,"position":6,"arabic":"حَتَّىٰ","translation":"যতক্ষণ না","audioUrl":"wbw/010_109_006.mp3","charTypeName":"word"},{"id":73744,"position":7,"arabic":"يَحْكُمَ","translation":"মীমাংসা করে দেন","audioUrl":"wbw/010_109_007.mp3","charTypeName":"word"},{"id":73745,"position":8,"arabic":"ٱللَّهُ ۚ","translation":"আল্লাহ","audioUrl":"wbw/010_109_008.mp3","charTypeName":"word"},{"id":73747,"position":9,"arabic":"وَهُوَ","translation":"এবং তিনি","audioUrl":"wbw/010_109_010.mp3","charTypeName":"word"},{"id":73748,"position":10,"arabic":"خَيْرُ","translation":"উত্তম","audioUrl":"wbw/010_109_011.mp3","charTypeName":"word"},{"id":73749,"position":11,"arabic":"ٱلْحَـٰكِمِينَ","translation":"মীমাংসাকারীদের","audioUrl":"wbw/010_109_012.mp3","charTypeName":"word"},{"id":73750,"position":12,"arabic":"١٠٩","translation":"(১০৯)","audioUrl":null,"charTypeName":"end"}]},{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ الٓر ۚ كِتَٰبٌ أُحْكِمَتْ ءَايَٰتُهُۥ ثُمَّ فُصِّلَتْ مِن لَّدُنْ حَكِيمٍ خَبِيرٍ","translation":"Alif. Lam. Ra. A DIVINE WRIT [is this], with messages that have been made clear in and by themselves, and have been distinctly spelled out as well - [bestowed upon you] out of the grace of One who is wise, all-aware,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1474.mp3","surahId":11,"words":[{"id":651,"position":1,"arabic":"الٓر ۚ","translation":"আলিফ-লাম-রা","audioUrl":"wbw/011_001_001.mp3","charTypeName":"word"},{"id":653,"position":2,"arabic":"كِتَـٰبٌ","translation":"(এই) কিতাব","audioUrl":"wbw/011_001_003.mp3","charTypeName":"word"},{"id":654,"position":3,"arabic":"أُحْكِمَتْ","translation":"সুপ্রতিষ্ঠিত করা হয়েছে","audioUrl":"wbw/011_001_004.mp3","charTypeName":"word"},{"id":655,"position":4,"arabic":"ءَايَـٰتُهُۥ","translation":"তার আয়াতসমূহ","audioUrl":"wbw/011_001_005.mp3","charTypeName":"word"},{"id":656,"position":5,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/011_001_006.mp3","charTypeName":"word"},{"id":657,"position":6,"arabic":"فُصِّلَتْ","translation":"বিশদভাবে বর্ণিত","audioUrl":"wbw/011_001_007.mp3","charTypeName":"word"},{"id":658,"position":7,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/011_001_008.mp3","charTypeName":"word"},{"id":659,"position":8,"arabic":"لَّدُنْ","translation":"পক্ষ","audioUrl":"wbw/011_001_009.mp3","charTypeName":"word"},{"id":660,"position":9,"arabic":"حَكِيمٍ","translation":"(এমন সত্ত্বার যিনি) প্রজ্ঞাময়","audioUrl":"wbw/011_001_010.mp3","charTypeName":"word"},{"id":661,"position":10,"arabic":"خَبِيرٍ","translation":"সর্বজ্ঞ","audioUrl":"wbw/011_001_011.mp3","charTypeName":"word"},{"id":662,"position":11,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"أَلَّا تَعْبُدُوٓا۟ إِلَّا ٱللَّهَ ۚ إِنَّنِى لَكُم مِّنْهُ نَذِيرٌۭ وَبَشِيرٌۭ","translation":"so that you may worship none but God. [Say, O Prophet:] \"Behold, I come unto you from Him [as] a warner and a bearer of glad tidings:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1475.mp3","surahId":11,"words":[{"id":1749,"position":1,"arabic":"أَلَّا","translation":"(হুকুম হলো) না যে","audioUrl":"wbw/011_002_001.mp3","charTypeName":"word"},{"id":1750,"position":2,"arabic":"تَعْبُدُوٓا۟","translation":"তোমরা উপাসনা করো","audioUrl":"wbw/011_002_002.mp3","charTypeName":"word"},{"id":1751,"position":3,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/011_002_003.mp3","charTypeName":"word"},{"id":1752,"position":4,"arabic":"ٱللَّهَ ۚ","translation":"আল্লাহ","audioUrl":"wbw/011_002_004.mp3","charTypeName":"word"},{"id":1754,"position":5,"arabic":"إِنَّنِى","translation":"নিশ্চয়ই আমি","audioUrl":"wbw/011_002_006.mp3","charTypeName":"word"},{"id":1755,"position":6,"arabic":"لَكُم","translation":"তোমাদের জন্য","audioUrl":"wbw/011_002_007.mp3","charTypeName":"word"},{"id":1756,"position":7,"arabic":"مِّنْهُ","translation":"তাঁরই পক্ষ হ'তে","audioUrl":"wbw/011_002_008.mp3","charTypeName":"word"},{"id":1757,"position":8,"arabic":"نَذِيرٌۭ","translation":"সতর্ককারী","audioUrl":"wbw/011_002_009.mp3","charTypeName":"word"},{"id":1758,"position":9,"arabic":"وَبَشِيرٌۭ","translation":"ও সুসংবাদ বাহক\"","audioUrl":"wbw/011_002_010.mp3","charTypeName":"word"},{"id":1759,"position":10,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"وَأَنِ ٱسْتَغْفِرُوا۟ رَبَّكُمْ ثُمَّ تُوبُوٓا۟ إِلَيْهِ يُمَتِّعْكُم مَّتَٰعًا حَسَنًا إِلَىٰٓ أَجَلٍۢ مُّسَمًّۭى وَيُؤْتِ كُلَّ ذِى فَضْلٍۢ فَضْلَهُۥ ۖ وَإِن تَوَلَّوْا۟ فَإِنِّىٓ أَخَافُ عَلَيْكُمْ عَذَابَ يَوْمٍۢ كَبِيرٍ","translation":"Ask your Sustainer to forgive you your sins, and then turn towards Him in repentance - [whereupon] He will grant you a goodly enjoyment of life [in this world] until a term set [by Him is fulfilled]; and [in the life to come] He will bestow upon everyone possessed of merit [a full reward for] his merit. But if you turn away, then, verily, I dread for you the suffering [which is bound to befall you] on that awesome Day","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1476.mp3","surahId":11,"words":[{"id":2916,"position":1,"arabic":"وَأَنِ","translation":"এবং (এও) যে","audioUrl":"wbw/011_003_001.mp3","charTypeName":"word"},{"id":2917,"position":2,"arabic":"ٱسْتَغْفِرُوا۟","translation":"\"তোমরা ক্ষমা চাও","audioUrl":"wbw/011_003_002.mp3","charTypeName":"word"},{"id":2918,"position":3,"arabic":"رَبَّكُمْ","translation":"তোমাদের রবের (কাছে)","audioUrl":"wbw/011_003_003.mp3","charTypeName":"word"},{"id":2919,"position":4,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/011_003_004.mp3","charTypeName":"word"},{"id":2920,"position":5,"arabic":"تُوبُوٓا۟","translation":"ফিরে আসো তোমরা","audioUrl":"wbw/011_003_005.mp3","charTypeName":"word"},{"id":2921,"position":6,"arabic":"إِلَيْهِ","translation":"তাঁরই দিকে","audioUrl":"wbw/011_003_006.mp3","charTypeName":"word"},{"id":2922,"position":7,"arabic":"يُمَتِّعْكُم","translation":"তিনি তোমাদের উপভোগ করতে দিবেন","audioUrl":"wbw/011_003_007.mp3","charTypeName":"word"},{"id":2923,"position":8,"arabic":"مَّتَـٰعًا","translation":"জীবন সামগ্রী","audioUrl":"wbw/011_003_008.mp3","charTypeName":"word"},{"id":2924,"position":9,"arabic":"حَسَنًا","translation":"উত্তম","audioUrl":"wbw/011_003_009.mp3","charTypeName":"word"},{"id":2925,"position":10,"arabic":"إِلَىٰٓ","translation":"পর্যন্ত","audioUrl":"wbw/011_003_010.mp3","charTypeName":"word"},{"id":2926,"position":11,"arabic":"أَجَلٍۢ","translation":"একটি কাল","audioUrl":"wbw/011_003_011.mp3","charTypeName":"word"},{"id":2927,"position":12,"arabic":"مُّسَمًّۭى","translation":"নির্দিষ্ট","audioUrl":"wbw/011_003_012.mp3","charTypeName":"word"},{"id":2928,"position":13,"arabic":"وَيُؤْتِ","translation":"ও দিবেন","audioUrl":"wbw/011_003_013.mp3","charTypeName":"word"},{"id":2929,"position":14,"arabic":"كُلَّ","translation":"প্রত্যেক","audioUrl":"wbw/011_003_014.mp3","charTypeName":"word"},{"id":2930,"position":15,"arabic":"ذِى","translation":"যোগ্য (ব্যক্তিকে)","audioUrl":"wbw/011_003_015.mp3","charTypeName":"word"},{"id":2931,"position":16,"arabic":"فَضْلٍۢ","translation":"অনুগ্রহ পাওয়ার","audioUrl":"wbw/011_003_016.mp3","charTypeName":"word"},{"id":2932,"position":17,"arabic":"فَضْلَهُۥ ۖ","translation":"তাঁর অনুগ্রহ","audioUrl":"wbw/011_003_017.mp3","charTypeName":"word"},{"id":2934,"position":18,"arabic":"وَإِن","translation":"কিন্তু যদি","audioUrl":"wbw/011_003_019.mp3","charTypeName":"word"},{"id":2935,"position":19,"arabic":"تَوَلَّوْا۟","translation":"তোমরা মুখ ফিরিয়ে নাও","audioUrl":"wbw/011_003_020.mp3","charTypeName":"word"},{"id":2936,"position":20,"arabic":"فَإِنِّىٓ","translation":"তবে নিশ্চয়ই আমি","audioUrl":"wbw/011_003_021.mp3","charTypeName":"word"},{"id":2937,"position":21,"arabic":"أَخَافُ","translation":"আমি আশঙ্কা করছি","audioUrl":"wbw/011_003_022.mp3","charTypeName":"word"},{"id":2938,"position":22,"arabic":"عَلَيْكُمْ","translation":"তোমাদের উপর","audioUrl":"wbw/011_003_023.mp3","charTypeName":"word"},{"id":2939,"position":23,"arabic":"عَذَابَ","translation":"শাস্তির","audioUrl":"wbw/011_003_024.mp3","charTypeName":"word"},{"id":2940,"position":24,"arabic":"يَوْمٍۢ","translation":"দিনের","audioUrl":"wbw/011_003_025.mp3","charTypeName":"word"},{"id":2941,"position":25,"arabic":"كَبِيرٍ","translation":"মহা","audioUrl":"wbw/011_003_026.mp3","charTypeName":"word"},{"id":2942,"position":26,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"إِلَى ٱللَّهِ مَرْجِعُكُمْ ۖ وَهُوَ عَلَىٰ كُلِّ شَىْءٍۢ قَدِيرٌ","translation":"Unto God you all must return: and He has the power to will anything.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1477.mp3","surahId":11,"words":[{"id":4259,"position":1,"arabic":"إِلَى","translation":"দিকে","audioUrl":"wbw/011_004_001.mp3","charTypeName":"word"},{"id":4260,"position":2,"arabic":"ٱللَّهِ","translation":"আল্লাহরই","audioUrl":"wbw/011_004_002.mp3","charTypeName":"word"},{"id":4261,"position":3,"arabic":"مَرْجِعُكُمْ ۖ","translation":"তোমাদের প্রত্যাবর্তন (হবে)","audioUrl":"wbw/011_004_003.mp3","charTypeName":"word"},{"id":4263,"position":4,"arabic":"وَهُوَ","translation":"এবং তিনি","audioUrl":"wbw/011_004_005.mp3","charTypeName":"word"},{"id":4264,"position":5,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/011_004_006.mp3","charTypeName":"word"},{"id":4265,"position":6,"arabic":"كُلِّ","translation":"সব","audioUrl":"wbw/011_004_007.mp3","charTypeName":"word"},{"id":4266,"position":7,"arabic":"شَىْءٍۢ","translation":"কিছুরই","audioUrl":"wbw/011_004_008.mp3","charTypeName":"word"},{"id":4267,"position":8,"arabic":"قَدِيرٌ","translation":"সর্বশক্তিমান\"","audioUrl":"wbw/011_004_009.mp3","charTypeName":"word"},{"id":4268,"position":9,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"أَلَآ إِنَّهُمْ يَثْنُونَ صُدُورَهُمْ لِيَسْتَخْفُوا۟ مِنْهُ ۚ أَلَا حِينَ يَسْتَغْشُونَ ثِيَابَهُمْ يَعْلَمُ مَا يُسِرُّونَ وَمَا يُعْلِنُونَ ۚ إِنَّهُۥ عَلِيمٌۢ بِذَاتِ ٱلصُّدُورِ","translation":"Oh, verily, they [who are bent on denying the truth of this divine writ] are enshrouding their hearts in order to hide from Him. Oh, verily, [even] when they cover themselves with their garments [in order not to see or hear], He knows all that they keep secret as well as all that they bring into the open - for, behold, He has full knowledge of what is in the hearts [of men].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1478.mp3","surahId":11,"words":[{"id":5511,"position":1,"arabic":"أَلَآ","translation":"জেনে রাখো (লক্ষ্য করো)","audioUrl":"wbw/011_005_001.mp3","charTypeName":"word"},{"id":5512,"position":2,"arabic":"إِنَّهُمْ","translation":"তারা নিশ্চয়ই","audioUrl":"wbw/011_005_002.mp3","charTypeName":"word"},{"id":5513,"position":3,"arabic":"يَثْنُونَ","translation":"দু-ভাঁজ করে","audioUrl":"wbw/011_005_003.mp3","charTypeName":"word"},{"id":5514,"position":4,"arabic":"صُدُورَهُمْ","translation":"তাদের অন্তরগুলোকে","audioUrl":"wbw/011_005_004.mp3","charTypeName":"word"},{"id":5515,"position":5,"arabic":"لِيَسْتَخْفُوا۟","translation":"গোপন রাখার জন্যে (তাদের বিদ্বেষ)","audioUrl":"wbw/011_005_005.mp3","charTypeName":"word"},{"id":5516,"position":6,"arabic":"مِنْهُ ۚ","translation":"তাঁর থেকে","audioUrl":"wbw/011_005_006.mp3","charTypeName":"word"},{"id":5518,"position":7,"arabic":"أَلَا","translation":"জেনে রাখো","audioUrl":"wbw/011_005_008.mp3","charTypeName":"word"},{"id":5519,"position":8,"arabic":"حِينَ","translation":"যখন","audioUrl":"wbw/011_005_009.mp3","charTypeName":"word"},{"id":5520,"position":9,"arabic":"يَسْتَغْشُونَ","translation":"তারা ঢেকে রাখে (নিজেদেরকে)","audioUrl":"wbw/011_005_010.mp3","charTypeName":"word"},{"id":5521,"position":10,"arabic":"ثِيَابَهُمْ","translation":"তাদের কাপড় (দিয়ে)","audioUrl":"wbw/011_005_011.mp3","charTypeName":"word"},{"id":5522,"position":11,"arabic":"يَعْلَمُ","translation":"(তখনও) তিনি জানেন","audioUrl":"wbw/011_005_012.mp3","charTypeName":"word"},{"id":5523,"position":12,"arabic":"مَا","translation":"যা","audioUrl":"wbw/011_005_013.mp3","charTypeName":"word"},{"id":5524,"position":13,"arabic":"يُسِرُّونَ","translation":"তারা গোপন করে","audioUrl":"wbw/011_005_014.mp3","charTypeName":"word"},{"id":5525,"position":14,"arabic":"وَمَا","translation":"আর যা","audioUrl":"wbw/011_005_015.mp3","charTypeName":"word"},{"id":5526,"position":15,"arabic":"يُعْلِنُونَ ۚ","translation":"তারা প্রকাশ করে","audioUrl":"wbw/011_005_016.mp3","charTypeName":"word"},{"id":5528,"position":16,"arabic":"إِنَّهُۥ","translation":"নিশ্চয়ই তিনি","audioUrl":"wbw/011_005_018.mp3","charTypeName":"word"},{"id":5529,"position":17,"arabic":"عَلِيمٌۢ","translation":"সবিশেষ অবহিত","audioUrl":"wbw/011_005_019.mp3","charTypeName":"word"},{"id":5530,"position":18,"arabic":"بِذَاتِ","translation":"সম্পর্কে অবস্থা","audioUrl":"wbw/011_005_020.mp3","charTypeName":"word"},{"id":5531,"position":19,"arabic":"ٱلصُّدُورِ","translation":"অন্তরসমূহের","audioUrl":"wbw/011_005_021.mp3","charTypeName":"word"},{"id":5532,"position":20,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]}]}