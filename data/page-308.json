{"id":308,"ayahs":[{"number":39,"arabic":"وَأَنذِرْهُمْ يَوْمَ ٱلْحَسْرَةِ إِذْ قُضِىَ ٱلْأَمْرُ وَهُمْ فِى غَفْلَةٍۢ وَهُمْ لَا يُؤْمِنُونَ","translation":"hence, warn them of [the coming of] the Day of Regrets, when everything will have been decided-for as yet they are heedless, and they do not believe [in it].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2289.mp3","surahId":19,"words":[{"id":40451,"position":1,"arabic":"وَأَنذِرْهُمْ","translation":"এবং সতর্ক করো তাদেরকে","audioUrl":"wbw/019_039_001.mp3","charTypeName":"word"},{"id":40452,"position":2,"arabic":"يَوْمَ","translation":"দিন (সম্পর্কে)","audioUrl":"wbw/019_039_002.mp3","charTypeName":"word"},{"id":40453,"position":3,"arabic":"ٱلْحَسْرَةِ","translation":"পরিতাপের","audioUrl":"wbw/019_039_003.mp3","charTypeName":"word"},{"id":40454,"position":4,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/019_039_004.mp3","charTypeName":"word"},{"id":40455,"position":5,"arabic":"قُضِىَ","translation":"সিদ্ধান্ত হয়ে যাবে","audioUrl":"wbw/019_039_005.mp3","charTypeName":"word"},{"id":40456,"position":6,"arabic":"ٱلْأَمْرُ","translation":"বিষয়টির","audioUrl":"wbw/019_039_006.mp3","charTypeName":"word"},{"id":40457,"position":7,"arabic":"وَهُمْ","translation":"তারা এ অবস্থায় যখন","audioUrl":"wbw/019_039_007.mp3","charTypeName":"word"},{"id":40458,"position":8,"arabic":"فِى","translation":"মধ্যে (আছে)","audioUrl":"wbw/019_039_008.mp3","charTypeName":"word"},{"id":40459,"position":9,"arabic":"غَفْلَةٍۢ","translation":"উদাসীনতা","audioUrl":"wbw/019_039_009.mp3","charTypeName":"word"},{"id":40460,"position":10,"arabic":"وَهُمْ","translation":"এবং তারা","audioUrl":"wbw/019_039_010.mp3","charTypeName":"word"},{"id":40461,"position":11,"arabic":"لَا","translation":"না","audioUrl":"wbw/019_039_011.mp3","charTypeName":"word"},{"id":40462,"position":12,"arabic":"يُؤْمِنُونَ","translation":"ঈমান আনছে","audioUrl":"wbw/019_039_012.mp3","charTypeName":"word"},{"id":40463,"position":13,"arabic":"٣٩","translation":"(৩৯)","audioUrl":null,"charTypeName":"end"}]},{"number":40,"arabic":"إِنَّا نَحْنُ نَرِثُ ٱلْأَرْضَ وَمَنْ عَلَيْهَا وَإِلَيْنَا يُرْجَعُونَ","translation":"Behold, We alone shall remain after the earth and all who live on it have passed away, and (when] unto Us all will have been brought back.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2290.mp3","surahId":19,"words":[{"id":41143,"position":1,"arabic":"إِنَّا","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/019_040_001.mp3","charTypeName":"word"},{"id":41144,"position":2,"arabic":"نَحْنُ","translation":"আমরা","audioUrl":"wbw/019_040_002.mp3","charTypeName":"word"},{"id":41145,"position":3,"arabic":"نَرِثُ","translation":"উত্তরাধিকারী হবো","audioUrl":"wbw/019_040_003.mp3","charTypeName":"word"},{"id":41146,"position":4,"arabic":"ٱلْأَرْضَ","translation":"পৃথিবীর","audioUrl":"wbw/019_040_004.mp3","charTypeName":"word"},{"id":41147,"position":5,"arabic":"وَمَنْ","translation":"এবং যা কিছু","audioUrl":"wbw/019_040_005.mp3","charTypeName":"word"},{"id":41148,"position":6,"arabic":"عَلَيْهَا","translation":"তার উপর (আছে)","audioUrl":"wbw/019_040_006.mp3","charTypeName":"word"},{"id":41149,"position":7,"arabic":"وَإِلَيْنَا","translation":"এবং আমাদেরই দিকে","audioUrl":"wbw/019_040_007.mp3","charTypeName":"word"},{"id":41150,"position":8,"arabic":"يُرْجَعُونَ","translation":"তাদের ফিরিয়ে আনা হবে","audioUrl":"wbw/019_040_008.mp3","charTypeName":"word"},{"id":41151,"position":9,"arabic":"٤٠","translation":"(৪০)","audioUrl":null,"charTypeName":"end"}]},{"number":41,"arabic":"وَٱذْكُرْ فِى ٱلْكِتَٰبِ إِبْرَٰهِيمَ ۚ إِنَّهُۥ كَانَ صِدِّيقًۭا نَّبِيًّا","translation":"AND CALL to mind, through this divine writ, Abraham. Behold, he was a man of truth, [already] a prophet","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2291.mp3","surahId":19,"words":[{"id":42036,"position":1,"arabic":"وَٱذْكُرْ","translation":"এবং বর্ণনা করো (যা)","audioUrl":"wbw/019_041_001.mp3","charTypeName":"word"},{"id":42037,"position":2,"arabic":"فِى","translation":"মধ্যে (বলা হচ্ছে)","audioUrl":"wbw/019_041_002.mp3","charTypeName":"word"},{"id":42038,"position":3,"arabic":"ٱلْكِتَـٰبِ","translation":"(এই) কিতাবের","audioUrl":"wbw/019_041_003.mp3","charTypeName":"word"},{"id":42039,"position":4,"arabic":"إِبْرَٰهِيمَ ۚ","translation":"ইবরাহীম (সম্পর্কে)","audioUrl":"wbw/019_041_004.mp3","charTypeName":"word"},{"id":42041,"position":5,"arabic":"إِنَّهُۥ","translation":"সে নিশ্চয়ই","audioUrl":"wbw/019_041_006.mp3","charTypeName":"word"},{"id":42042,"position":6,"arabic":"كَانَ","translation":"ছিলো","audioUrl":"wbw/019_041_007.mp3","charTypeName":"word"},{"id":42043,"position":7,"arabic":"صِدِّيقًۭا","translation":"সত্যনিষ্ঠ","audioUrl":"wbw/019_041_008.mp3","charTypeName":"word"},{"id":42044,"position":8,"arabic":"نَّبِيًّا","translation":"নাবী","audioUrl":"wbw/019_041_009.mp3","charTypeName":"word"},{"id":42045,"position":9,"arabic":"٤١","translation":"(৪১)","audioUrl":null,"charTypeName":"end"}]},{"number":42,"arabic":"إِذْ قَالَ لِأَبِيهِ يَٰٓأَبَتِ لِمَ تَعْبُدُ مَا لَا يَسْمَعُ وَلَا يُبْصِرُ وَلَا يُغْنِى عَنكَ شَيْـًۭٔا","translation":"when he spoke [thus] unto his father: \"O my father! Why dost thou worship something that neither hears nor sees and can be of no avail whatever to thee?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2292.mp3","surahId":19,"words":[{"id":42844,"position":1,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/019_042_001.mp3","charTypeName":"word"},{"id":42845,"position":2,"arabic":"قَالَ","translation":"সে বলেছিলো","audioUrl":"wbw/019_042_002.mp3","charTypeName":"word"},{"id":42846,"position":3,"arabic":"لِأَبِيهِ","translation":"তার বাপকে","audioUrl":"wbw/019_042_003.mp3","charTypeName":"word"},{"id":42847,"position":4,"arabic":"يَـٰٓأَبَتِ","translation":"\"হে আমার পিতা","audioUrl":"wbw/019_042_004.mp3","charTypeName":"word"},{"id":42848,"position":5,"arabic":"لِمَ","translation":"কেন","audioUrl":"wbw/019_042_005.mp3","charTypeName":"word"},{"id":42849,"position":6,"arabic":"تَعْبُدُ","translation":"উপাসনা করেন আপনি","audioUrl":"wbw/019_042_006.mp3","charTypeName":"word"},{"id":42850,"position":7,"arabic":"مَا","translation":"যা","audioUrl":"wbw/019_042_007.mp3","charTypeName":"word"},{"id":42851,"position":8,"arabic":"لَا","translation":"না","audioUrl":"wbw/019_042_008.mp3","charTypeName":"word"},{"id":42852,"position":9,"arabic":"يَسْمَعُ","translation":"শুনে","audioUrl":"wbw/019_042_009.mp3","charTypeName":"word"},{"id":42853,"position":10,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/019_042_010.mp3","charTypeName":"word"},{"id":42854,"position":11,"arabic":"يُبْصِرُ","translation":"দেখে","audioUrl":"wbw/019_042_011.mp3","charTypeName":"word"},{"id":42855,"position":12,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/019_042_012.mp3","charTypeName":"word"},{"id":42856,"position":13,"arabic":"يُغْنِى","translation":"কাজে আসে","audioUrl":"wbw/019_042_013.mp3","charTypeName":"word"},{"id":42857,"position":14,"arabic":"عَنكَ","translation":"আপনার জন্য","audioUrl":"wbw/019_042_014.mp3","charTypeName":"word"},{"id":42858,"position":15,"arabic":"شَيْـًۭٔا","translation":"কিছুই","audioUrl":"wbw/019_042_015.mp3","charTypeName":"word"},{"id":42859,"position":16,"arabic":"٤٢","translation":"(৪২)","audioUrl":null,"charTypeName":"end"}]},{"number":43,"arabic":"يَٰٓأَبَتِ إِنِّى قَدْ جَآءَنِى مِنَ ٱلْعِلْمِ مَا لَمْ يَأْتِكَ فَٱتَّبِعْنِىٓ أَهْدِكَ صِرَٰطًۭا سَوِيًّۭا","translation":"\"O my father! Behold, there has indeed come to me [a ray] of knowledge such as has never yet come unto thee: follow me, then; I shall guide thee onto a perfect way.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2293.mp3","surahId":19,"words":[{"id":43579,"position":1,"arabic":"يَـٰٓأَبَتِ","translation":"হে আমার পিতা","audioUrl":"wbw/019_043_001.mp3","charTypeName":"word"},{"id":43580,"position":2,"arabic":"إِنِّى","translation":"নিশ্চয়ই আমার","audioUrl":"wbw/019_043_002.mp3","charTypeName":"word"},{"id":43581,"position":3,"arabic":"قَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/019_043_003.mp3","charTypeName":"word"},{"id":43582,"position":4,"arabic":"جَآءَنِى","translation":"এসেছে আমার কাছে","audioUrl":"wbw/019_043_004.mp3","charTypeName":"word"},{"id":43583,"position":5,"arabic":"مِنَ","translation":"(এমন) কিছু","audioUrl":"wbw/019_043_005.mp3","charTypeName":"word"},{"id":43584,"position":6,"arabic":"ٱلْعِلْمِ","translation":"জ্ঞান","audioUrl":"wbw/019_043_006.mp3","charTypeName":"word"},{"id":43585,"position":7,"arabic":"مَا","translation":"যা","audioUrl":"wbw/019_043_007.mp3","charTypeName":"word"},{"id":43586,"position":8,"arabic":"لَمْ","translation":"নি","audioUrl":"wbw/019_043_008.mp3","charTypeName":"word"},{"id":43587,"position":9,"arabic":"يَأْتِكَ","translation":"আপনার কাছে আসে","audioUrl":"wbw/019_043_009.mp3","charTypeName":"word"},{"id":43588,"position":10,"arabic":"فَٱتَّبِعْنِىٓ","translation":"সুতরাং অনুসরণ করুন","audioUrl":"wbw/019_043_010.mp3","charTypeName":"word"},{"id":43589,"position":11,"arabic":"أَهْدِكَ","translation":"আমি পথ দেখাবো","audioUrl":"wbw/019_043_011.mp3","charTypeName":"word"},{"id":43590,"position":12,"arabic":"صِرَٰطًۭا","translation":"পথ","audioUrl":"wbw/019_043_012.mp3","charTypeName":"word"},{"id":43591,"position":13,"arabic":"سَوِيًّۭا","translation":"সরল সঠিক","audioUrl":"wbw/019_043_013.mp3","charTypeName":"word"},{"id":43592,"position":14,"arabic":"٤٣","translation":"(৪৩)","audioUrl":null,"charTypeName":"end"}]},{"number":44,"arabic":"يَٰٓأَبَتِ لَا تَعْبُدِ ٱلشَّيْطَٰنَ ۖ إِنَّ ٱلشَّيْطَٰنَ كَانَ لِلرَّحْمَٰنِ عَصِيًّۭا","translation":"\"O my father! Do not worship Satan-for, verily, Satan is a rebel against the Most Gracious!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2294.mp3","surahId":19,"words":[{"id":44313,"position":1,"arabic":"يَـٰٓأَبَتِ","translation":"হে আমার পিতা","audioUrl":"wbw/019_044_001.mp3","charTypeName":"word"},{"id":44314,"position":2,"arabic":"لَا","translation":"না","audioUrl":"wbw/019_044_002.mp3","charTypeName":"word"},{"id":44315,"position":3,"arabic":"تَعْبُدِ","translation":"উপাসনা করবেন","audioUrl":"wbw/019_044_003.mp3","charTypeName":"word"},{"id":44316,"position":4,"arabic":"ٱلشَّيْطَـٰنَ ۖ","translation":"শয়তানের","audioUrl":"wbw/019_044_004.mp3","charTypeName":"word"},{"id":44318,"position":5,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/019_044_006.mp3","charTypeName":"word"},{"id":44319,"position":6,"arabic":"ٱلشَّيْطَـٰنَ","translation":"শয়তান","audioUrl":"wbw/019_044_007.mp3","charTypeName":"word"},{"id":44320,"position":7,"arabic":"كَانَ","translation":"হলো","audioUrl":"wbw/019_044_008.mp3","charTypeName":"word"},{"id":44321,"position":8,"arabic":"لِلرَّحْمَـٰنِ","translation":"দয়াময়ের","audioUrl":"wbw/019_044_009.mp3","charTypeName":"word"},{"id":44322,"position":9,"arabic":"عَصِيًّۭا","translation":"অবাধ্য","audioUrl":"wbw/019_044_010.mp3","charTypeName":"word"},{"id":44323,"position":10,"arabic":"٤٤","translation":"(৪৪)","audioUrl":null,"charTypeName":"end"}]},{"number":45,"arabic":"يَٰٓأَبَتِ إِنِّىٓ أَخَافُ أَن يَمَسَّكَ عَذَابٌۭ مِّنَ ٱلرَّحْمَٰنِ فَتَكُونَ لِلشَّيْطَٰنِ وَلِيًّۭا","translation":"O my father! I dread lest a chastisement from the Most Gracious befall thee, and then thou wilt become [aware of having been] close unto Satan!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2295.mp3","surahId":19,"words":[{"id":45077,"position":1,"arabic":"يَـٰٓأَبَتِ","translation":"হে আমার পিতা","audioUrl":"wbw/019_045_001.mp3","charTypeName":"word"},{"id":45078,"position":2,"arabic":"إِنِّىٓ","translation":"নিশ্চয়ই আমি","audioUrl":"wbw/019_045_002.mp3","charTypeName":"word"},{"id":45079,"position":3,"arabic":"أَخَافُ","translation":"ভয় করি আমি","audioUrl":"wbw/019_045_003.mp3","charTypeName":"word"},{"id":45080,"position":4,"arabic":"أَن","translation":"যে","audioUrl":"wbw/019_045_004.mp3","charTypeName":"word"},{"id":45081,"position":5,"arabic":"يَمَسَّكَ","translation":"আপনাকে স্পর্শ করবে","audioUrl":"wbw/019_045_005.mp3","charTypeName":"word"},{"id":45082,"position":6,"arabic":"عَذَابٌۭ","translation":"শাস্তি","audioUrl":"wbw/019_045_006.mp3","charTypeName":"word"},{"id":45083,"position":7,"arabic":"مِّنَ","translation":"থেকে","audioUrl":"wbw/019_045_007.mp3","charTypeName":"word"},{"id":45084,"position":8,"arabic":"ٱلرَّحْمَـٰنِ","translation":"দয়াময়ের","audioUrl":"wbw/019_045_008.mp3","charTypeName":"word"},{"id":45085,"position":9,"arabic":"فَتَكُونَ","translation":"অতঃপর আপনি হবেন","audioUrl":"wbw/019_045_009.mp3","charTypeName":"word"},{"id":45086,"position":10,"arabic":"لِلشَّيْطَـٰنِ","translation":"শয়তানের জন্য","audioUrl":"wbw/019_045_010.mp3","charTypeName":"word"},{"id":45087,"position":11,"arabic":"وَلِيًّۭا","translation":"বন্ধু\"","audioUrl":"wbw/019_045_011.mp3","charTypeName":"word"},{"id":45088,"position":12,"arabic":"٤٥","translation":"(৪৫)","audioUrl":null,"charTypeName":"end"}]},{"number":46,"arabic":"قَالَ أَرَاغِبٌ أَنتَ عَنْ ءَالِهَتِى يَٰٓإِبْرَٰهِيمُ ۖ لَئِن لَّمْ تَنتَهِ لَأَرْجُمَنَّكَ ۖ وَٱهْجُرْنِى مَلِيًّۭا","translation":"He answered: \"Dost thou dislike my gods, O Abraham? Indeed, if thou desist not, I shall most certainly cause thee to be stoned to death! Now begone from me for good!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2296.mp3","surahId":19,"words":[{"id":45824,"position":1,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/019_046_001.mp3","charTypeName":"word"},{"id":45825,"position":2,"arabic":"أَرَاغِبٌ","translation":"\"কি বিমুখ","audioUrl":"wbw/019_046_002.mp3","charTypeName":"word"},{"id":45826,"position":3,"arabic":"أَنتَ","translation":"\"তুমি","audioUrl":"wbw/019_046_003.mp3","charTypeName":"word"},{"id":45827,"position":4,"arabic":"عَنْ","translation":"হ'তে","audioUrl":"wbw/019_046_004.mp3","charTypeName":"word"},{"id":45828,"position":5,"arabic":"ءَالِهَتِى","translation":"আমার দেব-দেবীগুলো","audioUrl":"wbw/019_046_005.mp3","charTypeName":"word"},{"id":45829,"position":6,"arabic":"يَـٰٓإِبْرَٰهِيمُ ۖ","translation":"হে ইবরাহীম","audioUrl":"wbw/019_046_006.mp3","charTypeName":"word"},{"id":45831,"position":7,"arabic":"لَئِن","translation":"অবশ্যই যদি","audioUrl":"wbw/019_046_008.mp3","charTypeName":"word"},{"id":45832,"position":8,"arabic":"لَّمْ","translation":"না","audioUrl":"wbw/019_046_009.mp3","charTypeName":"word"},{"id":45833,"position":9,"arabic":"تَنتَهِ","translation":"বিরত হও তুমি","audioUrl":"wbw/019_046_010.mp3","charTypeName":"word"},{"id":45834,"position":10,"arabic":"لَأَرْجُمَنَّكَ ۖ","translation":"অবশ্যই তোমাকে পাথর মেরে হত্যা করবোই","audioUrl":"wbw/019_046_011.mp3","charTypeName":"word"},{"id":45836,"position":11,"arabic":"وَٱهْجُرْنِى","translation":"এবং আমাকে ছেড়ে চলে যাও","audioUrl":"wbw/019_046_013.mp3","charTypeName":"word"},{"id":45837,"position":12,"arabic":"مَلِيًّۭا","translation":"চিরতরে\"","audioUrl":"wbw/019_046_014.mp3","charTypeName":"word"},{"id":45838,"position":13,"arabic":"٤٦","translation":"(৪৬)","audioUrl":null,"charTypeName":"end"}]},{"number":47,"arabic":"قَالَ سَلَٰمٌ عَلَيْكَ ۖ سَأَسْتَغْفِرُ لَكَ رَبِّىٓ ۖ إِنَّهُۥ كَانَ بِى حَفِيًّۭا","translation":"[Abraham] replied: \"Peace be upon thee! I shall ask my Sustainer to forgive thee: for, behold, He has always been kind unto me.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2297.mp3","surahId":19,"words":[{"id":46475,"position":1,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/019_047_001.mp3","charTypeName":"word"},{"id":46476,"position":2,"arabic":"سَلَـٰمٌ","translation":"\"শান্তি (সালাম)","audioUrl":"wbw/019_047_002.mp3","charTypeName":"word"},{"id":46477,"position":3,"arabic":"عَلَيْكَ ۖ","translation":"আপনার উপর","audioUrl":"wbw/019_047_003.mp3","charTypeName":"word"},{"id":46479,"position":4,"arabic":"سَأَسْتَغْفِرُ","translation":"অচিরেই ক্ষমা চাইবো আমি","audioUrl":"wbw/019_047_005.mp3","charTypeName":"word"},{"id":46480,"position":5,"arabic":"لَكَ","translation":"আপনার