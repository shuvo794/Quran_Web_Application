_048_006.mp3","charTypeName":"word"},{"id":47196,"position":7,"arabic":"وَأَدْعُوا۟","translation":"এবং ডাকবো আমি","audioUrl":"wbw/019_048_007.mp3","charTypeName":"word"},{"id":47197,"position":8,"arabic":"رَبِّى","translation":"আমার রবকে","audioUrl":"wbw/019_048_008.mp3","charTypeName":"word"},{"id":47198,"position":9,"arabic":"عَسَىٰٓ","translation":"আশা করি","audioUrl":"wbw/019_048_009.mp3","charTypeName":"word"},{"id":47199,"position":10,"arabic":"أَلَّآ","translation":"যে না","audioUrl":"wbw/019_048_010.mp3","charTypeName":"word"},{"id":47200,"position":11,"arabic":"أَكُونَ","translation":"হবো আমি","audioUrl":"wbw/019_048_011.mp3","charTypeName":"word"},{"id":47201,"position":12,"arabic":"بِدُعَآءِ","translation":"ডাকার কারণে","audioUrl":"wbw/019_048_012.mp3","charTypeName":"word"},{"id":47202,"position":13,"arabic":"رَبِّى","translation":"আমার রবের","audioUrl":"wbw/019_048_013.mp3","charTypeName":"word"},{"id":47203,"position":14,"arabic":"شَقِيًّۭا","translation":"ব্যর্থকাম\"","audioUrl":"wbw/019_048_014.mp3","charTypeName":"word"},{"id":47204,"position":15,"arabic":"٤٨","translation":"(৪৮)","audioUrl":null,"charTypeName":"end"}]},{"number":49,"arabic":"فَلَمَّا ٱعْتَزَلَهُمْ وَمَا يَعْبُدُونَ مِن دُونِ ٱللَّهِ وَهَبْنَا لَهُۥٓ إِسْحَٰقَ وَيَعْقُوبَ ۖ وَكُلًّۭا جَعَلْنَا نَبِيًّۭا","translation":"And after he had withdrawn from them and from all that they were worshipping instead of God, We bestowed upon him Isaac and Jacob, and made each of them a prophet;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2299.mp3","surahId":19,"words":[{"id":47821,"position":1,"arabic":"فَلَمَّا","translation":"অতঃপর যখন","audioUrl":"wbw/019_049_001.mp3","charTypeName":"word"},{"id":47822,"position":2,"arabic":"ٱعْتَزَلَهُمْ","translation":"তাদের থেকে পৃথক হলো সে","audioUrl":"wbw/019_049_002.mp3","charTypeName":"word"},{"id":47823,"position":3,"arabic":"وَمَا","translation":"এবং যাদের","audioUrl":"wbw/019_049_003.mp3","charTypeName":"word"},{"id":47824,"position":4,"arabic":"يَعْبُدُونَ","translation":"তারা উপাসনা করতো","audioUrl":"wbw/019_049_004.mp3","charTypeName":"word"},{"id":47825,"position":5,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/019_049_005.mp3","charTypeName":"word"},{"id":47826,"position":6,"arabic":"دُونِ","translation":"ছাড়া","audioUrl":"wbw/019_049_006.mp3","charTypeName":"word"},{"id":47827,"position":7,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌","audioUrl":"wbw/019_049_007.mp3","charTypeName":"word"},{"id":47828,"position":8,"arabic":"وَهَبْنَا","translation":"আমরা দান করলাম","audioUrl":"wbw/019_049_008.mp3","charTypeName":"word"},{"id":47829,"position":9,"arabic":"لَهُۥٓ","translation":"তাকে","audioUrl":"wbw/019_049_009.mp3","charTypeName":"word"},{"id":47830,"position":10,"arabic":"إِسْحَـٰقَ","translation":"ইসহাককে","audioUrl":"wbw/019_049_010.mp3","charTypeName":"word"},{"id":47831,"position":11,"arabic":"وَيَعْقُوبَ ۖ","translation":"ও ইয়াকুবকে","audioUrl":"wbw/019_049_011.mp3","charTypeName":"word"},{"id":47833,"position":12,"arabic":"وَكُلًّۭا","translation":"এবং প্রত্যেককে","audioUrl":"wbw/019_049_013.mp3","charTypeName":"word"},{"id":47834,"position":13,"arabic":"جَعَلْنَا","translation":"আমরা বানালাম","audioUrl":"wbw/019_049_014.mp3","charTypeName":"word"},{"id":47835,"position":14,"arabic":"نَبِيًّۭا","translation":"নাবী","audioUrl":"wbw/019_049_015.mp3","charTypeName":"word"},{"id":47836,"position":15,"arabic":"٤٩","translation":"(৪৯)","audioUrl":null,"charTypeName":"end"}]},{"number":50,"arabic":"وَوَهَبْنَا لَهُم مِّن رَّحْمَتِنَا وَجَعَلْنَا لَهُمْ لِسَانَ صِدْقٍ عَلِيًّۭا","translation":"and We bestowed upon them [manifold] gifts out of Our grace, and granted them a lofty power to convey the truth [unto others].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2300.mp3","surahId":19,"words":[{"id":48426,"position":1,"arabic":"وَوَهَبْنَا","translation":"এবং আমরা দান করলাম","audioUrl":"wbw/019_050_001.mp3","charTypeName":"word"},{"id":48427,"position":2,"arab