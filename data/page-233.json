me":"word"},{"id":73048,"position":10,"arabic":"١٠٦","translation":"(১০৬)","audioUrl":null,"charTypeName":"end"}]},{"number":107,"arabic":"خَٰلِدِينَ فِيهَا مَا دَامَتِ ٱلسَّمَٰوَٰتُ وَٱلْأَرْضُ إِلَّا مَا شَآءَ رَبُّكَ ۚ إِنَّ رَبَّكَ فَعَّالٌۭ لِّمَا يُرِيدُ","translation":"therein to abide as long as the heavens and the earth endure-unless thy Sustainer wills it otherwise: for, verily, thy Sustainer is a sovereign doer of whatever He wills.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1580.mp3","surahId":11,"words":[{"id":73304,"position":1,"arabic":"خَـٰلِدِينَ","translation":"তারা স্থায়ী হবে","audioUrl":"wbw/011_107_001.mp3","charTypeName":"word"},{"id":73305,"position":2,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/011_107_002.mp3","charTypeName":"word"},{"id":73306,"position":3,"arabic":"مَا","translation":"যতক্ষণ","audioUrl":"wbw/011_107_003.mp3","charTypeName":"word"},{"id":73307,"position":4,"arabic":"دَامَتِ","translation":"বিদ্যমান থাকবে","audioUrl":"wbw/011_107_004.mp3","charTypeName":"word"},{"id":73308,"position":5,"arabic":"ٱلسَّمَـٰوَٰتُ","translation":"আকাশসমূহ","audioUrl":"wbw/011_107_005.mp3","charTypeName":"word"},{"id":73309,"position":6,"arabic":"وَٱلْأَرْضُ","translation":"এবং পৃথিবী","audioUrl":"wbw/011_107_006.mp3","charTypeName":"word"},{"id":73310,"position":7,"arabic":"إِلَّا","translation":"তবে","audioUrl":"wbw/011_107_007.mp3","charTypeName":"word"},{"id":73311,"position":8,"arabic":"مَا","translation":"যা","audioUrl":"wbw/011_107_008.mp3","charTypeName":"word"},{"id":73312,"position":9,"arabic":"شَآءَ","translation":"ইচ্ছে করেন","audioUrl":"wbw/011_107_009.mp3","charTypeName":"word"},{"id":73313,"position":10,"arabic":"رَبُّكَ ۚ","translation":"তোমার রব (সেটা ভিন্ন কথা)","audioUrl":"wbw/011_107_010.mp3","charTypeName":"word"},{"id":73315,"position":11,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/011_107_012.mp3","charTypeName":"word"},{"id":73316,"position":12,"arabic":"رَبَّكَ","transl