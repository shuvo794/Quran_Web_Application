6,"position":6,"arabic":"ٱلْقُرَىٰ","translation":"জনবসতিকে","audioUrl":"wbw/011_102_006.mp3","charTypeName":"word"},{"id":71867,"position":7,"arabic":"وَهِىَ","translation":"এমতাবস্হায় তা","audioUrl":"wbw/011_102_007.mp3","charTypeName":"word"},{"id":71868,"position":8,"arabic":"ظَـٰلِمَةٌ ۚ","translation":"(ছিল) অত্যাচারী","audioUrl":"wbw/011_102_008.mp3","charTypeName":"word"},{"id":71870,"position":9,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/011_102_010.mp3","charTypeName":"word"},{"id":71871,"position":10,"arabic":"أَخْذَهُۥٓ","translation":"তাঁর পাকড়াও","audioUrl":"wbw/011_102_011.mp3","charTypeName":"word"},{"id":71872,"position":11,"arabic":"أَلِيمٌۭ","translation":"যন্ত্রণাদায়ক","audioUrl":"wbw/011_102_012.mp3","charTypeName":"word"},{"id":71873,"position":12,"arabic":"شَدِيدٌ","translation":"কঠোর","audioUrl":"wbw/011_102_013.mp3","charTypeName":"word"},{"id":71874,"position":13,"arabic":"١٠٢","translation":"(১০২)","audioUrl":null,"charTypeName":"end"}]},{"number":103,"arabic":"إِنَّ فِى ذَٰلِكَ لَءَايَةًۭ لِّمَنْ خَافَ عَذَابَ ٱلْءَاخِرَةِ ۚ ذَٰلِكَ يَوْمٌۭ مَّجْمُوعٌۭ لَّهُ ٱلنَّاسُ وَذَٰلِكَ يَوْمٌۭ مَّشْهُودٌۭ","translation":"Herein, behold, lies a message indeed for all who fear the suffering [which may befall them] in the life to come, (and are conscious of the coming of] that Day on which all mankind shall be gathered together-that Day [of Judgment] which shall be witnessed [by all that ever lived],","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1576.mp3","surahId":11,"words":[{"id":72304,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/011_103_001.mp3","charTypeName":"word"},{"id":72305,"position":2,"arabic":"فِى","translation":"মধ্যে (রয়েছে)","audioUrl":"wbw/011_103_002.mp3","charTypeName":"word"},{"id":72306,"position":3,"arabic":"ذَٰلِكَ","translation":"এর","audioUrl":"wbw/011_103_003.mp3","charTypeName":"word"},{"id":72307,"position":4,"arabic":"لَـَٔايَةًۭ","translation":"অবশ্যই নিদর্শন","audioUrl":"wbw/011_103_004.mp3","charTypeName":"word"},{"id":72308,"position":5,"arabic":"لِّمَنْ","translation":"তার জন্য যে","audioUrl":"wbw/011_103_005.mp3","charTypeName":"word"},{"id":72309,"position":6,"arabic":"خَافَ","translation":"ভয় করে","audioUrl":"wbw/011_103_006.mp3","charTypeName":"word"},{"id":72310,"position":7,"arabic":"عَذَابَ","translation":"শাস্তির","audioUrl":"wbw/011_103_007.mp3","charTypeName":"word"},{"id":72311,"position":8,"arabic":"ٱلْـَٔاخِرَةِ ۚ","translation":"আখিরাতের","audioUrl":"wbw/011_103_008.mp3","charTypeName":"word"},{"id":72313,"position":9,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/011_103_010.mp3","charTypeName":"word"},{"id":72314,"position":10,"arabic":"يَوْمٌۭ","translation":"দিন","audioUrl":"wbw/011_103_011.mp3","charTypeName":"word"},{"id":72315,"position":11,"arabic":"مَّجْمُوعٌۭ","translation":"একত্র করার","audioUrl":"wbw/011_103_012.mp3","charTypeName":"word"},{"id":72316,"position":12,"arabic":"لَّهُ","translation":"তার (মধ্যে)","audioUrl":"wbw/011_103_013.mp3","charTypeName":"word"},{"id":72317,"position":13,"arabic":"ٱلنَّاسُ","translation":"(সকল) মানুষকে","audioUrl":"wbw/011_103_014.mp3","charTypeName":"word"},{"id":72318,"position":14,"arabic":"وَذَٰلِكَ","translation":"এবং এটা","audioUrl":"wbw/011_103_015.mp3","charTypeName":"word"},{"id":72319,"position":15,"arabic":"يَوْمٌۭ","translation":"দিন","audioUrl":"wbw/011_103_016.mp3","charTypeName":"word"},{"id":72320,"position":16,"arabic":"مَّشْهُودٌۭ","translation":"সবার উপস্হিতির","audioUrl":"wbw/011_103_017.mp3","charTypeName":"word"},{"id":72321,"position":17,"arabic":"١٠٣","translation":"(১০৩)","audioUrl":null,"charTypeName":"end"}]},{"number":104,"arabic":"وَمَا نُؤَخِّرُهُۥٓ إِلَّا لِأَجَلٍۢ مَّعْدُودٍۢ","translation":"and which We shall not delay beyond a term set [by Us].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1577.mp3","surahId":11,"words":[{"id":72662,"position":1,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/011_104_001.mp3","charTypeName":"word"},{"id":72663,"position":2,"arabic":"نُؤَخِّرُهُۥٓ","translation":"তা আমরা স্হগিত করবো","audioUrl":"wbw/011_104_002.mp3","charTypeName":"word"},{"id":72664,"position":3,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/011_104_003.mp3","charTypeName":"word"},{"id":72665,"position":4,"arabic":"لِأَجَلٍۢ","translation":"জন্যে একটি সময়ের","audioUrl":"wbw/011_104_004.mp3","charTypeName":"word"},{"id":72666,"position":5,"arabic":"مَّعْدُودٍۢ","translation":"নির্দিষ্ট","audioUrl":"wbw/011_104_005.mp3","charTypeName":"word"},{"id":72667,"position":6,"arabic":"١٠٤","translation":"(১০৪)","audioUrl":null,"charTypeName":"end"}]},{"number":105,"arabic":"يَوْمَ يَأْتِ لَا تَكَلَّمُ نَفْسٌ إِلَّا بِإِذْنِهِۦ ۚ فَمِنْهُمْ شَقِىٌّۭ وَسَعِيدٌۭ","translation":"When that Day comes, not a soul will speak. unless it be by His leave; and of those [that are gathered together], some will be wretched and some, happy.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1578.mp3","surahId":11,"words":[{"id":72714,"position":1,"arabic":"يَوْمَ","translation":"সেদিন","audioUrl":"wbw/011_105_001.mp3","charTypeName":"word"},{"id":72715,"position":2,"arabic":"يَأْتِ","translation":"(যখন) আসবে","audioUrl":"wbw/011_105_002.mp3","charTypeName":"word"},{"id":72716,"position":3,"arabic":"لَا","translation":"না","audioUrl":"wbw/011_105_003.mp3","charTypeName":"word"},{"id":72717,"position":4,"arabic":"تَكَلَّمُ","translation":"কথা বলতে পারবে","audioUrl":"wbw/011_105_004.mp3","charTypeName":"word"},{"id":72718,"position":5,"arabic":"نَفْسٌ","translation":"কোন ব্যক্তি","audioUrl":"wbw/011_105_005.mp3","charTypeName":"word"},{"id":72719,"position":6,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/011_105_006.mp3","charTypeName":"word"},{"id":72720,"position":7,"arabic":"بِإِذْنِهِۦ ۚ","translation":"তাঁর অনুমতির মাধ্যমে","audioUrl":"wbw/011_105_007.mp3","charTypeName":"word"},{"id":72722,"position":8,"arabic":"فَمِنْهُمْ","translation":"অতঃপ