{"id":233,"ayahs":[{"number":98,"arabic":"يَقْدُمُ قَوْمَهُۥ يَوْمَ ٱلْقِيَٰمَةِ فَأَوْرَدَهُمُ ٱلنَّارَ ۖ وَبِئْسَ ٱلْوِرْدُ ٱلْمَوْرُودُ","translation":"[And so] he shall go before his people on the Day of Resurrection, having led them [in this world] towards the fire [of the life to come]; and vile was the destination towards which they were led -","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1571.mp3","surahId":11,"words":[{"id":70598,"position":1,"arabic":"يَقْدُمُ","translation":"সে সামনে থাকবে","audioUrl":"wbw/011_098_001.mp3","charTypeName":"word"},{"id":70599,"position":2,"arabic":"قَوْمَهُۥ","translation":"তার জাতির লোকদের","audioUrl":"wbw/011_098_002.mp3","charTypeName":"word"},{"id":70600,"position":3,"arabic":"يَوْمَ","translation":"দিনে","audioUrl":"wbw/011_098_003.mp3","charTypeName":"word"},{"id":70601,"position":4,"arabic":"ٱلْقِيَـٰمَةِ","translation":"ক্বিয়ামাতের","audioUrl":"wbw/011_098_004.mp3","charTypeName":"word"},{"id":70602,"position":5,"arabic":"فَأَوْرَدَهُمُ","translation":"অতঃপর তাদের উপস্থিত করবে","audioUrl":"wbw/011_098_005.mp3","charTypeName":"word"},{"id":70603,"position":6,"arabic":"ٱلنَّارَ ۖ","translation":"(জাহান্নামের) আগুনে","audioUrl":"wbw/011_098_006.mp3","charTypeName":"word"},{"id":70605,"position":7,"arabic":"وَبِئْسَ","translation":"এবং অতি জঘন্য","audioUrl":"wbw/011_098_008.mp3","charTypeName":"word"},{"id":70606,"position":8,"arabic":"ٱلْوِرْدُ","translation":"উপস্থিত স্থান","audioUrl":"wbw/011_098_009.mp3","charTypeName":"word"},{"id":70607,"position":9,"arabic":"ٱلْمَوْرُودُ","translation":"যেখানে তারা উপস্থিত  হবে","audioUrl":"wbw/011_098_010.mp3","charTypeName":"word"},{"id":70608,"position":10,"arabic":"٩٨","translation":"(৯৮)","audioUrl":null,"charTypeName":"end"}]},{"number":99,"arabic":"وَأُتْبِعُوا۟ فِى هَٰذِهِۦ لَعْنَةًۭ وَيَوْمَ ٱلْقِيَٰمَةِ ۚ بِئْسَ ٱلرِّفْدُ ٱلْمَرْفُودُ","translation":"seeing that they were pursued by [God's] rejection in this [world], and [shall be finally overtaken by it] on the Day of Resurrection; [and] vile was the gift which they were given!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1572.mp3","surahId":11,"words":[{"id":70948,"position":1,"arabic":"وَأُتْبِعُوا۟","translation":"এবং তাদেরকে অনুসরণ করলো","audioUrl":"wbw/011_099_001.mp3","charTypeName":"word"},{"id":70949,"position":2,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/011_099_002.mp3","charTypeName":"word"},{"id":70950,"position":3,"arabic":"هَـٰذِهِۦ","translation":"এই (পৃথিবীর)","audioUrl":"wbw/011_099_003.mp3","charTypeName":"word"},{"id":70951,"position":4,"arabic":"لَعْنَةًۭ","translation":"অভিশাপ","audioUrl":"wbw/011_099_004.mp3","charTypeName":"word"},{"id":70952,"position":5,"arabic":"وَيَوْمَ","translation":"এবং (অভিশাপ) দিনে","audioUrl":"wbw/011_099_005.mp3","charTypeName":"word"},{"id":70953,"position":6,"arabic":"ٱلْقِيَـٰمَةِ ۚ","translation":"ক্বিয়ামাতের","audioUrl":"wbw/011_099_006.mp3","charTypeName":"word"},{"id":70955,"position":7,"arabic":"بِئْسَ","translation":"অতি জঘন্য","audioUrl":"wbw/011_099_008.mp3","charTypeName":"word"},{"id":70956,"position":8,"arabic":"ٱلرِّفْدُ","translation":"পুরস্কার","audioUrl":"wbw/011_099_009.mp3","charTypeName":"word"},{"id":70957,"position":9,"arabic":"ٱلْمَرْفُودُ","translation":"(যা তাদেরকে) পুরস্কার দেয়া হবে","audioUrl":"wbw/011_099_010.mp3","charTypeName":"word"},{"id":70958,"position":10,"arabic":"٩٩","translation":"(৯৯)","audioUrl":null,"charTypeName":"end"}]},{"number":100,"arabic":"ذَٰلِكَ مِنْ أَنۢبَآءِ ٱلْقُرَىٰ نَقُصُّهُۥ عَلَيْكَ ۖ مِنْهَا قَآئِمٌۭ وَحَصِيدٌۭ","translation":"THIS ACCOUNT of the [fate of those ancient] communities - some of them still remaining, and some [extinct like] a field mown-down - We convey unto thee [as a lesson for mankind]:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1573.mp3","surahId":11,"words":[{"id":71301,"position":1,"arabic":"ذَٰلِكَ","translation":"এই (খবর)","audioUrl":"wbw/011_100_001.mp3","charTypeName":"word"},{"id":71302,"position":2,"arabic":"مِنْ","translation":"কিছু","audioUrl":"wbw/011_100_002.mp3","charTypeName":"word"},{"id":71303,"position":3,"arabic":"أَنۢبَآءِ","translation":"সংবাদ","audioUrl":"wbw/011_100_003.mp3","charTypeName":"word"},{"id":71304,"position":4,"arabic":"ٱلْقُرَىٰ","translation":"জনপদসমূহের","audioUrl":"wbw/011_100_004.mp3","charTypeName":"word"},{"id":71305,"position":5,"arabic":"نَقُصُّهُۥ","translation":"তা আমরা বর্ণনা করছি","audioUrl":"wbw/011_100_005.mp3","charTypeName":"word"},{"id":71306,"position":6,"arabic":"عَلَيْكَ ۖ","translation":"তোমার কাছে","audioUrl":"wbw/011_100_006.mp3","charTypeName":"word"},{"id":71308,"position":7,"arabic":"مِنْهَا","translation":"তার মধ্যে হ'তে","audioUrl":"wbw/011_100_008.mp3","charTypeName":"word"},{"id":71309,"position":8,"arabic":"قَآئِمٌۭ","translation":"(কিছু) বিদ্যমান আছে","audioUrl":"wbw/011_100_009.mp3","charTypeName":"word"},{"id":71310,"position":9,"arabic":"وَحَصِيدٌۭ","translation":"আবার (কিছু) নির্মূল হয়েছে","audioUrl":"wbw/011_100_010.mp3","charTypeName":"word"},{"id":71311,"position":10,"arabic":"١٠٠","translation":"(১০০)","audioUrl":null,"charTypeName":"end"}]},{"number":101,"arabic":"وَمَا ظَلَمْنَٰهُمْ وَلَٰكِن ظَلَمُوٓا۟ أَنفُسَهُمْ ۖ فَمَآ أَغْنَتْ عَنْهُمْ ءَالِهَتُهُمُ ٱلَّتِى يَدْعُونَ مِن دُونِ ٱللَّهِ مِن شَىْءٍۢ لَّمَّا جَآءَ أَمْرُ رَبِّكَ ۖ وَمَا زَادُوهُمْ غَيْرَ تَتْبِيبٍۢ","translation":"for, no wrong did We do to them, but it was they who wronged themselves. And when thy Sustainer's judgment came to pass, those deities of theirs which they had been wont to invoke instead of God proved of no avail whatever to them, and brought them no more than utter perdition.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1574.mp3","surahId":11,"words":[{"id":71612,"position":1,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/011_101_001.mp3","charTypeName":"word"},{"id":71613,"position":2,"arabic":"ظَلَمْنَـٰهُمْ","translation":"তাদের উপর আমরা অত্যাচার করেছি","audioUrl":"wbw/011_101_002.mp3","charTypeName":"word"},{"id":71614,"position":3,"arabic":"وَلَـٰكِن","translation":"কিন্তু","audioUrl":"wbw/011_101_003.mp3","charTypeName":"word"},{"id":71615,"position":4,"arabic":"ظَلَمُوٓا۟","translation":"তারা অত্যাচার করেছিলো","audioUrl":"wbw/011_101_004.mp3","charTypeName":"word"},{"id":71616,"position":5,"arabic":"أَنفُسَهُمْ ۖ","translation":"তাদের নিজেদের (উপর)","audioUrl":"wbw/011_101_005.mp3","charTypeName":"word"},{"id":71618,"position":6,"arabic":"فَمَآ","translation":"অতঃপর না","audioUrl":"wbw/011_101_007.mp3","charTypeName":"word"},{"id":71619,"position":7,"arabic":"أَغْنَتْ","translation":"কাজে লাগলো","audioUrl":"wbw/011_101_008.mp3","charTypeName":"word"},{"id":71620,"position":8,"arabic":"عَنْهُمْ","translation":"তাদের জন্যে","audioUrl":"wbw/011_101_009.mp3","charTypeName":"word"},{"id":71621,"position":9,"arabic":"ءَالِهَتُهُمُ","translation":"তাদের উপাস্যরা","audioUrl":"wbw/011_101_010.mp3","charTypeName":"word"},{"id":71622,"position":10,"arabic":"ٱلَّتِى","translation":"যাকে","audioUrl":"wbw/011_101_011.mp3","charTypeName":"word"},{"id":71623,"position":11,"arabic":"يَدْعُونَ","translation":"তারা ডাকত","audioUrl":"wbw/011_101_012.mp3","charTypeName":"word"},{"id":71624,"position":12,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/011_101_013.mp3","charTypeName":"word"},{"id":71625,"position":13,"arabic":"دُونِ","translation":"ছাড়া","audioUrl":"wbw/011_101_014.mp3","charTypeName":"word"},{"id":71626,"position":14,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌কে","audioUrl":"wbw/011_101_015.mp3","charTypeName":"word"},{"id":71627,"position":15,"arabic":"مِن","translation":"কোন","audioUrl":"wbw/011_101_016.mp3","charTypeName":"word"},{"id":71628,"position":16,"arabic":"شَىْءٍۢ","translation":"কিছুই","audioUrl":"wbw/011_101_017.mp3","charTypeName":"word"},{"id":71629,"position":17,"arabic":"لَّمَّا","translation":"যখন","audioUrl":"wbw/011_101_018.mp3","charTypeName":"word"},{"id":71630,"position":18,"arabic":"جَآء