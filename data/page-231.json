{"id":231,"ayahs":[{"number":82,"arabic":"فَلَمَّا جَآءَ أَمْرُنَا جَعَلْنَا عَٰلِيَهَا سَافِلَهَا وَأَمْطَرْنَا عَلَيْهَا حِجَارَةًۭ مِّن سِجِّيلٍۢ مَّنضُودٍۢ","translation":"And so, when Our judgment came to pass, We turned those [sinful towns] upside down, and rained down upon them stone-hard blows of chastisement pre-ordained. one upon another,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1555.mp3","surahId":11,"words":[{"id":65174,"position":1,"arabic":"فَلَمَّا","translation":"অতঃপর যখন","audioUrl":"wbw/011_082_001.mp3","charTypeName":"word"},{"id":65175,"position":2,"arabic":"جَآءَ","translation":"আসলো","audioUrl":"wbw/011_082_002.mp3","charTypeName":"word"},{"id":65176,"position":3,"arabic":"أَمْرُنَا","translation":"আমাদের নির্দেশ","audioUrl":"wbw/011_082_003.mp3","charTypeName":"word"},{"id":65177,"position":4,"arabic":"جَعَلْنَا","translation":"আমরা করলাম","audioUrl":"wbw/011_082_004.mp3","charTypeName":"word"},{"id":65178,"position":5,"arabic":"عَـٰلِيَهَا","translation":"তার উপর দিককে","audioUrl":"wbw/011_082_005.mp3","charTypeName":"word"},{"id":65179,"position":6,"arabic":"سَافِلَهَا","translation":"তার নিচের দিকে","audioUrl":"wbw/011_082_006.mp3","charTypeName":"word"},{"id":65180,"position":7,"arabic":"وَأَمْطَرْنَا","translation":"এবং আমরা বর্ষণ করলাম","audioUrl":"wbw/011_082_007.mp3","charTypeName":"word"},{"id":65181,"position":8,"arabic":"عَلَيْهَا","translation":"তার উপর","audioUrl":"wbw/011_082_008.mp3","charTypeName":"word"},{"id":65182,"position":9,"arabic":"حِجَارَةًۭ","translation":"পাথর","audioUrl":"wbw/011_082_009.mp3","charTypeName":"word"},{"id":65183,"position":10,"arabic":"مِّن","translation":"তৈরি","audioUrl":"wbw/011_082_010.mp3","charTypeName":"word"},{"id":65184,"position":11,"arabic":"سِجِّيلٍۢ","translation":"শুকনো মাটির","audioUrl":"wbw/011_082_011.mp3","charTypeName":"word"},{"id":65185,"position":12,"arabic":"مَّنضُودٍۢ","translation":"একটানা","audioUrl":"wbw/011_082_012.mp3","charTypeName":"word"},{"id":65186,"position":13,"arabic":"٨٢","translation":"(৮২)","audioUrl":null,"charTypeName":"end"}]},{"number":83,"arabic":"مُّسَوَّمَةً عِندَ رَبِّكَ ۖ وَمَا هِىَ مِنَ ٱلظَّٰلِمِينَ بِبَعِيدٍۢ","translation":"marked out in thy Sustainer's sight [for the punishment of such as are lost in sin]. And these [blows of God-willed doom] are never far from evildoers","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1556.mp3","surahId":11,"words":[{"id":65470,"position":1,"arabic":"مُّسَوَّمَةً","translation":"(প্রত্যেকের জন্যে) চিহ্নিত","audioUrl":"wbw/011_083_001.mp3","charTypeName":"word"},{"id":65471,"position":2,"arabic":"عِندَ","translation":"কাছে","audioUrl":"wbw/011_083_002.mp3","charTypeName":"word"},{"id":65472,"position":3,"arabic":"رَبِّكَ ۖ","translation":"তোমার রবের","audioUrl":"wbw/011_083_003.mp3","charTypeName":"word"},{"id":65474,"position":4,"arabic":"وَمَا","translation":"এবং নয়","audioUrl":"wbw/011_083_005.mp3","charTypeName":"word"},{"id":65475,"position":5,"arabic":"هِىَ","translation":"তা","audioUrl":"wbw/011_083_006.mp3","charTypeName":"word"},{"id":65476,"position":6,"arabic":"مِنَ","translation":"হ'তে","audioUrl":"wbw/011_083_007.mp3","charTypeName":"word"},{"id":65477,"position":7,"arabic":"ٱلظَّـٰلِمِينَ","translation":"সীমালঙ্ঘনকারীদের","audioUrl":"wbw/011_083_008.mp3","charTypeName":"word"},{"id":65478,"position":8,"arabic":"بِبَعِيدٍۢ","translation":"বহুদূরে","audioUrl":"wbw/011_083_009.mp3","charTypeName":"word"},{"id":65479,"position":9,"arabic":"٨٣","translation":"(৮৩)","audioUrl":null,"charTypeName":"end"}]},{"number":84,"arabic":"۞ وَإِلَىٰ مَدْيَنَ أَخَاهُمْ شُعَيْبًۭا ۚ قَالَ يَٰقَوْمِ ٱعْبُدُوا۟ ٱللَّهَ مَا لَكُم مِّنْ إِلَٰهٍ غَيْرُهُۥ ۖ وَلَا تَنقُصُوا۟ ٱلْمِكْيَالَ وَٱلْمِيزَانَ ۚ إِنِّىٓ أَرَىٰكُم بِخَيْرٍۢ وَإِنِّىٓ أَخَافُ عَلَيْكُمْ عَذَابَ يَوْمٍۢ مُّحِيطٍۢ","translation":"AND UNTO [the people of] Madyan [We sent] their brother Shu'ayb. He said: \"O my people! Worship God [alone]: you have no deity other than Him; and do not give short measure and weight [in any of your dealings with men]. Behold, I see you [now] in a happy state; but, verily, I dread lest suffering befall you on a Day that will encompass [you with doom]!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1557.mp3","surahId":11,"words":[{"id":65803,"position":1,"arabic":"۞ وَإِلَىٰ","translation":"এবং প্রতি","audioUrl":"wbw/011_084_002.mp3","charTypeName":"word"},{"id":65804,"position":2,"arabic":"مَدْيَنَ","translation":"মাদইয়ানের","audioUrl":"wbw/011_084_003.mp3","charTypeName":"word"},{"id":65805,"position":3,"arabic":"أَخَاهُمْ","translation":"তাদের ভাই","audioUrl":"wbw/011_084_004.mp3","charTypeName":"word"},{"id":65806,"position":4,"arabic":"شُعَيْبًۭا ۚ","translation":"শুআয়বকে (পাঠিয়েছিলাম)","audioUrl":"wbw/011_084_005.mp3","charTypeName":"word"},{"id":65808,"position":5,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/011_084_007.mp3","charTypeName":"word"},{"id":65809,"position":6,"arabic":"يَـٰقَوْمِ","translation":"\"হে আমার জাতি","audioUrl":"wbw/011_084_008.mp3","charTypeName":"word"},{"id":65810,"position":7,"arabic":"ٱعْبُدُوا۟","translation":"তোমরা ইবাদাত করো","audioUrl":"wbw/011_084_009.mp3","charTypeName":"word"},{"id":65811,"position":8,"arabic":"ٱللَّهَ","translation":"আল্লাহর","audioUrl":"wbw/011_084_010.mp3","charTypeName":"word"},{"id":65812,"position":9,"arabic":"مَا","translation":"নেই","audioUrl":"wbw/011_084_011.mp3","charTypeName":"word"},{"id":65813,"position":10,"arabic":"لَكُم","translation":"তোমাদের জন্যে","audioUrl":"wbw/011_084_012.mp3","charTypeName":"word"},{"id":65814,"position":11,"arabic":"مِّنْ","translation":"কোন","audioUrl":"wbw/011_084_013.mp3","charTypeName":"word"},{"id":65815,"position":12,"arabic":"إِلَـٰهٍ","translation":"ইলাহ","audioUrl":"wbw/011_084_014.mp3","charTypeName":"word"},{"id":65816,"position":13,"arabic":"غَيْرُهُۥ ۖ","translation":"তিনি ছাড়া","audioUrl":"wbw/011_084_015.mp3","charTypeName":"word"},{"id":65818,"position":14,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/011_084_017.mp3","charTypeName":"word"},{"id":65819,"position":15,"arabic":"تَنقُصُوا۟","translation":"তোমরা কম করো","audioUrl":"wbw/011_084_018.mp3","charTypeName":"word"},{"id":65820,"position":16,"arabic":"ٱلْمِكْيَالَ","translation":"মাপে","audioUrl":"wbw/011_084_019.mp3","charTypeName":"word"},{"id":65821,"position":17,"arabic":"وَٱلْمِيزَانَ ۚ","translation":"আর (না) ওজনে","audioUrl":"wbw/011_084_020.mp3","charTypeName":"word"},{"id":65823,"position":18,"arabic":"إِنِّىٓ","translation":"নিশ্চয়ই আমি","audioUrl":"wbw/011_084_022.mp3","charTypeName":"word"},{"id":65824,"position":19,"arabic":"أَرَىٰكُم","translation":"তোমাদের দেখছি","audioUrl":"wbw/011_084_023.mp3","charTypeName":"word"},{"id":65825,"position":20,"arabic":"بِخَيْرٍۢ","translation":"ভালো অবস্থায়","audioUrl":"wbw/011_084_024.mp3","charTypeName":"word"},{"id":65826,"position":21,"arabic":"وَإِنِّىٓ","translation":"কিন্তু আমি নিশ্চয়ই","audioUrl":"wbw/011_084_025.mp3","charTypeName":"word"},{"id":65827,"position":22,"arabic":"أَخَافُ","translation":"আমি আশঙ্কা করছি","audioUrl":"wbw/011_084_026.mp3","charTypeName":"word"},{"id":65828,"position":23,"arabic":"عَلَيْكُمْ","translation":"তোমাদের উপর","audioUrl":"wbw/011_084_027.mp3","charTypeName":"word"},{"id":65829,"position":24,"arabic":"عَذَابَ","translation":"শাস্তি","audioUrl":"wbw/011_084_028.mp3","charTypeName":"word"},{"id":65830,"position":25,"arabic":"يَوْمٍۢ","translation":"দিনের","audioUrl":"wbw/011_084_029.mp3","charTypeName":"word"},{"id":65831,"position":26,"arabic":"مُّحِيطٍۢ","translation":"পরিবেষ্টনকারী","audioUrl":"wbw/011_084_030.mp3","charTypeName":"word"},{"id":65832,"position":27,"arabic":"٨٤","translation":"(৮৪)","audioUrl":null,"charTypeName":"end"}]},{"number":85,"arabic":"وَيَٰقَوْمِ أَوْفُوا۟ ٱلْمِكْيَالَ وَٱلْمِيزَانَ بِٱلْقِسْطِ ۖ وَلَا تَبْخَسُوا۟ ٱلنَّاسَ أَشْيَآءَهُمْ وَلَا تَعْثَوْا۟ فِى ٱلْأَرْضِ مُفْسِدِينَ","translation":"Hence, O my people, [always] give full measure and weight, with equity, and do not deprive people of what is rightfully theirs, and do not act wickedly on earth by spreading corruption.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1558.mp3","surahId":11,"words":[{"id":66070,"position":1,"arabic":"وَيَـٰقَوْمِ","translation":"এবং হে আমার জাতি","audioUrl":"wbw/011_085_001.mp3","charTypeName":"word"},{"id":66071,"position":2,"arabic":"أَوْفُوا۟","translation":"তোমরা পূর্ণ করো","audioUrl":"wbw/011_085_002.mp3","charTypeName":"word"},{"id":66072,"position":3,"arabic":"ٱلْمِكْيَالَ","translation":"মাপ","audioUrl":"wbw/011_085_003.mp3","charTypeName":"word"},{"id":66073,"position":4,"arabic":"وَٱلْمِيزَانَ","translation":"ও ওজন","audioUrl":"wbw/011_085_004.mp3","charTypeName":"word"},{"id":66074,"position":5,"arabic":"بِٱلْقِسْطِ ۖ","translation":"ভাবে ন্যায়সংগত","audioUrl":"wbw/011_085_005.mp3","charTypeName":"word"},{"id":66076,"position":6,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/011_085_007.mp3","charTypeName":"word"},{"id":66077,"position":7,"arabic":"تَبْخَسُوا۟","translation":"তোমরা কম করো","audioUrl":"wbw/011_085_008.mp3","charTypeName":"word"},{"id":66078,"position":8,"arabic":"ٱلنَّاسَ","translation":"লোকদেরকে","audioUrl":"wbw/011_085_009.mp3","charTypeName":"word"},{"id":66079,"position":9,"arabic":"أَشْيَآءَهُمْ","translation":"তাদের জিনিসগুলোকে","audioUrl":"wbw/011_085_010.mp3","charTypeName":"word"},{"id":66080,"position":10,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/011_085_011.mp3","charTypeName":"word"},{"id":66081,"position":11,"arabic":"تَعْثَوْا۟","translation":"তোমরা বিপর্যয় ঘটিয়ো","audioUrl":"wbw/011_085_012.mp3","charTypeName":"word"},{"id":66082,"position":12,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/011_085_013.mp3","charTypeName":"word"},{"id":66083,"position":13,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/011_085_014.mp3","charTypeName":"word"},{"id":66084,"position":14,"arabic":"مُفْسِدِينَ","translation":"বিপর্যয় সৃষ্টিকারী (হয়ে)","audioUrl":"wbw/011_085_015.mp3","charTypeName":"word"},{"id":66085,"position":15,"arabic":"٨٥","translation":"(৮৫)","audioUrl":null,"charTypeName":"end"}]},{"number":86,"arabic":"بَقِيَّتُ ٱللَّهِ خَيْرٌۭ لَّكُمْ إِن كُنتُم مُّؤْمِنِينَ ۚ وَمَآ أَنَا۠ عَلَيْكُم بِحَفِيظٍۢ","translation":"That which rests with God is best for you, if you but believe [in Him]! However, I am not your keeper.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1559.mp3","surahId":11,"words":[{"id":66608,"position":1,"arabic":"بَقِيَّتُ","translation":"অবশিষ্টই","audioUrl":"wbw/011_086_001.mp3","charTypeName":"word"},{"id":66609,"position":2,"arabic":"ٱللَّهِ","translation":"আল্লাহর অনুমোদিত","audioUrl":"wbw/011_086_002.mp3","charTypeName":"word"},{"id":66610,"position":3,"arabic":"خَيْرٌۭ","translation":"উত্তম","audioUrl":"wbw/011_086_003.mp3","charTypeName":"word"},{"id":66611,"position":4,"arabic":"لَّكُمْ","translation":"তোমাদের জন্যে","audioUrl":"wbw/011_086_004.mp3","charTypeName":"word"},{"id":66612,"position":5,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/011_086_005.mp3","charTypeName":"word"},{"id":66613,"position":6,"arabic":"كُنتُم","translation":"তোমরা হও","audioUrl":"wbw/011_086_006.mp3","charTypeName":"word"},{"id":66614,"position":7,"arabic":"مُّؤْمِنِينَ ۚ","translation":"ঈমানদার","audioUrl":"wbw/011_086_007.mp3","charTypeName":"word"},{"id":66616,"position":8,"arabic":"وَمَآ","translation":"এবং নই","audioUrl":"wbw/011_086_009.mp3","charTypeName":"word"},{"id":66617,"position":9,"arabic":"أَنَا۠","translation":"আমি","audioUrl":"wbw/011_086_010.mp3","charTypeName":"word"},{"id":66618,"position":10,"arabic":"عَلَيْكُم","translation":"তোমাদের উপর","audioUrl":"wbw/011_086_011.mp3","charTypeName":"word"},{"id":66619,"position":11,"arabic":"بِحَفِيظٍۢ","translation":"কোন তত্ত্বাবধায়ক\"","audioUrl":"wbw/011_086_012.mp3","charTypeName":"word"},{"id":66620,"position":12,"arabic":"٨٦","translation":"(৮৬)","audioUrl":null,"charTypeName":"end"}]},{"number":87,"arabic":"قَالُوا۟ يَٰشُعَيْبُ أَصَلَوٰتُكَ تَأْمُرُكَ أَن نَّتْرُكَ مَا يَعْبُدُ ءَابَآؤُنَآ أَوْ أَن نَّفْعَلَ فِىٓ أَمْوَٰلِنَا مَا نَشَٰٓؤُا۟ ۖ إِنَّكَ لَأَنتَ ٱلْحَلِيمُ ٱلرَّشِيدُ","translation":"Said they: \"O Shu'ayb! Does thy [habit of] praying compel thee to demand of us that we give up all that our forefathers were wont to worship, or that we refrain from doing whatever we please with our possessions? Behold, [thou wouldst have us believe that] thou art indeed the only clement, the only right-minded man!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1560.mp3","surahId":11,"words":[{"id":66751,"position":1,"arabic":"قَالُوا۟","translation":"তারা বললো","audioUrl":"wbw/011_087_001.mp3","charTypeName":"word"},{"id":66752,"position":2,"arabic":"يَـٰشُعَيْبُ","translation":"\"হে শুআইব","audioUrl":"wbw/011_087_002.mp3","charTypeName":"word"},{"id":66753,"position":3,"arabic":"أَصَلَوٰتُكَ","translation":"কি তোমার সালাত","audioUrl":"wbw/011_087_003.mp3","charTypeName":"word"},{"id":66754,"position":4,"arabic":"تَأْمُرُكَ","translation":"তোমাকে নির্দেশ দেয়","audioUrl":"wbw/011_087_004.mp3","charTypeName":"word"},{"id":66755,"position":5,"arabic":"أَن","translation":"যে","audioUrl":"wbw/011_087_005.mp3","charTypeName":"word"},{"id":66756,"position":6,"arabic":"نَّتْرُكَ","translation":"ছেড়ে দিবো আমরা","audioUrl":"wbw/011_087_006.mp3","charTypeName":"word"},{"id":66757,"position":7,"arabic":"مَا","translation":"(তা) যার","audioUrl":"wbw/011_087_007.mp3","charTypeName":"word"},{"id":66758,"position":8,"arabic":"يَعْبُدُ","translation":"উপাসনা করতো","audioUrl":"wbw/011_087_008.mp3","charTypeName":"word"},{"id":66759,"position":9,"arabic":"ءَابَآؤُنَآ","translation":"আমাদের পূর্ব পুরুষেরা","audioUrl":"wbw/011_087_009.mp3","charTypeName":"word"},{"id":66760,"position":10,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/011_087_010.mp3","charTypeName":"word"},{"id":66761,"position":11,"arabic":"أَن","translation":"যেন (না)","audioUrl":"wbw/011_087_011.mp3","charTypeName":"word"},{"id":66762,"position":12,"arabic":"نَّفْعَلَ","translation":"আমরা করি","audioUrl":"wbw/011_087_012.mp3","charTypeName":"word"},{"id":66763,"position":13,"arabic":"فِىٓ","translation":"মধ্যে","audioUrl":"wbw/011_087_013.mp3","charTypeName":"word"},{"id":66764,"position":14,"arabic":"أَمْوَٰلِنَا","translation":"আমাদের ধন-সম্পদের","audioUrl":"wbw/011_087_014.mp3","charTypeName":"word"},{"id":66765,"position":15,"arabic":"مَا","translation":"যা","audioUrl":"wbw/011_087_015.mp3","charTypeName":"word"},{"id":66766,"position":16,"arabic":"نَشَـٰٓؤُا۟ ۖ","translation":"আমরা চাই","audioUrl":"wbw/011_087_016.mp3","charTypeName":"word"},{"id":66768,"position":17,"arabic":"إِنَّكَ","translation":"নিশ্চয়ই তুমি","audioUrl":"wbw/011_087_018.mp3","charTypeName":"word"},{"id":66769,"position":18,"arabic":"لَأَنتَ","translation":"অবশ্যই তুমি","audioUrl":"wbw/011_087_019.mp3","charTypeName":"word"},{"id":66770,"position":19,"arabic":"ٱلْحَلِيمُ","translation":"ধৈর্যধারী","audioUrl":"wbw/011_087_020.mp3","charTypeName":"word"},{"id":66771,"position":20,"arabic":"ٱلرَّشِيدُ","translation":"সদাচারী\"","audioUrl":"wbw/011_087_021.mp3","charTypeName":"word"},{"id":66772,"position":21,"arabic":"٨٧","translation":"(৮৭)","audioUrl":null,"charTypeName":"end"}]},{"number":88,"arabic":"قَالَ يَٰقَوْمِ أَرَءَيْتُمْ إِن كُنتُ عَلَىٰ بَيِّنَةٍۢ مِّن رَّبِّى وَرَزَقَنِى مِنْهُ رِزْقًا حَسَنًۭا ۚ وَمَآ أُرِيدُ أَنْ أُخَالِفَكُمْ إِلَىٰ مَآ أَنْهَىٰكُمْ عَنْهُ ۚ إِنْ أُرِيدُ إِلَّا ٱلْإِصْلَٰحَ مَا ٱسْتَطَعْتُ ۚ وَمَا تَوْفِيقِىٓ إِلَّا بِٱللَّهِ ۚ عَلَيْهِ تَوَكَّلْتُ وَإِلَيْهِ أُنِيبُ","translation":"He answered: \"O my people! What do you think? If [it be true that] I am taking my stand on a clear evidence from my Sustainer, who has vouchsafed me goodly sustenance [as a gift] from Himself - [how could I speak to you otherwise than I do]? And yet, I have no desire to do, out of opposition to you, what I am asking you not to do: I desire no more than to set things to rights in so far as it lies within my power; but the achievement of my aim depends on God alone. In Him have I placed my trust, and unto Him do I always turn!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1561.mp3","surahId":11,"words":[{"id":67268,"position":1,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/011_088_001.mp3","charTypeName":"word"},{"id":67269,"position":2,"arabic":"يَـٰقَوْمِ","translation":"\"হে আমার জাতি","audioUrl":"wbw/011_088_002.mp3","charTypeName":"word"},{"id":67270,"position":3,"arabic":"أَرَءَيْتُمْ","translation":"তোমরা কি (ভেবে) দেখেছো","audioUrl":"wbw/011_088_003.mp3","charTypeName":"word"},{"id":67271,"position":4,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/011_088_004.mp3","charTypeName":"word"},{"id":67272,"position":5,"arabic":"كُنتُ","translation":"আমি হই","audioUrl":"wbw/011_088_005.mp3","charTypeName":"word"},{"id":67273,"position":6,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/011_088_006.mp3","charTypeName":"word"},{"id":67274,"position":7,"arabic":"بَيِّنَةٍۢ","translation":"সুস্পষ্ট প্রমাণের","audioUrl":"wbw/011_088_007.mp3","charTypeName":"word"},{"id":67275,"position":8,"arabic":"مِّن","translation":"কাছ থেকে","audioUrl":"wbw/011_088_008.mp3","charTypeName":"word"},{"id":67276,"position":9,"arabic":"رَّبِّى","translation":"আমার রবের","audioUrl":"wbw/011_088_009.mp3","charTypeName":"word"},{"id":67277,"position":10,"arabic":"وَرَزَقَنِى","translation":"এবং আমাকে জীবিকা‌ দিয়েছেন","audioUrl":"wbw/011_088_010.mp3","charTypeName":"word"},{"id":67278,"position":11,"arabic":"مِنْهُ","translation":"তাঁর নিকট হ'তে","audioUrl":"wbw/011_088_011.mp3","charTypeName":"word"},{"id":67279,"position":12,"arabic":"رِزْقًا","translation":"জীবিকা","audioUrl":"wbw/011_088_012.mp3","charTypeName":"word"},{"id":67280,"position":13,"arabic":"حَسَنًۭا ۚ","translation":"উত্তম","audioUrl":"wbw/011_088_013.mp3","charTypeName":"word"},{"id":67282,"position":14,"arabic":"وَمَآ","translation":"এবং না","audioUrl":"wbw/011_088_015.mp3","charTypeName":"word"},{"id":67283,"position":15,"arabic":"أُرِيدُ","translation":"আমি চাই","audioUrl":"wbw/011_088_016.mp3","charTypeName":"word"},{"id":67284,"position":16,"arabic":"أَنْ","translation":"যে","audioUrl":"wbw/011_088_017.mp3","charTypeName":"word"},{"id":67285,"position":17,"arabic":"أُخَالِفَكُمْ","translation":"তোমাদের বিরুদ্ধাচারণ করি","audioUrl":"wbw/011_088_018.mp3","charTypeName":"word"},{"id":67286,"position":18,"arabic":"إِلَىٰ","translation":"(তার) প্রতি","audioUrl":"wbw/011_088_019.mp3","charTypeName":"word"},{"id":67287,"position":19,"arabic":"مَآ","translation":"যা","audioUrl":"wbw/011_088_020.mp3","charTypeName":"word"},{"id":67288,"position":20,"arabic":"أَنْهَىٰكُمْ","translation":"তোমাদের আমি নিষেধ করি","audioUrl":"wbw/011_088_021.mp3","charTypeName":"word"},{"id":67289,"position":21,"arabic":"عَنْهُ ۚ","translation":"তা হ'তে","audioUrl":"wbw/011_088_022.mp3","charTypeName":"word"},{"id":67291,"position":22,"arabic":"إِنْ","translation":"না","audioUrl":"wbw/011_088_024.mp3","charTypeName":"word"},{"id":67292,"position":23,"arabic":"أُرِيدُ","translation":"আমি চাই","audioUrl":"wbw/011_088_025.mp3","charTypeName":"word"},{"id":67293,"position":24,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/011_088_026.mp3","charTypeName":"word"},{"id":67294,"position":25,"arabic":"ٱلْإِصْلَـٰحَ","translation":"সংশোধন","audioUrl":"wbw/011_088_027.mp3","charTypeName":"word"},{"id":67295,"position":26,"arabic":"مَا","translation":"যতটুকু","audioUrl":"wbw/011_088_028.mp3","charTypeName":"word"},{"id":67296,"position":27,"arabic":"ٱسْتَطَعْتُ ۚ","translation":"আমি করতে পারি","audioUrl":"wbw/011_088_029.mp3","charTypeName":"word"},{"id":67298,"position":28,"arabic":"وَمَا","translation":"এবং নেই","audioUrl":"wbw/011_088_031.mp3","charTypeName":"word"},{"id":67299,"position":29,"arabic":"تَوْفِيقِىٓ","translation":"আমার সামর্থ","audioUrl":"wbw/011_088_032.mp3","charTypeName":"word"},{"id":673