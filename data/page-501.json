سِ لَا يَعْلَمُونَ","translation":"Say: “It is God who gives you life, and then causes you to die; and in the end He will gather you together on Resurrection Day, [the coming of] which is beyond all doubt - but most human beings under­stand it not.”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4499.mp3","surahId":45,"words":[{"id":28698,"position":1,"arabic":"قُلِ","translation":"বলো","audioUrl":"wbw/045_026_001.mp3","charTypeName":"word"},{"id":28699,"position":2,"arabic":"ٱللَّهُ","translation":"\"আল্লাহই","audioUrl":"wbw/045_026_002.mp3","charTypeName":"word"},{"id":28700,"position":3,"arabic":"يُحْيِيكُمْ","translation":"তোমাদেরকে জীবন দেন","audioUrl":"wbw/045_026_003.mp3","charTypeName":"word"},{"id":28701,"position":4,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/045_026_004.mp3","charTypeName":"word"},{"id":28702,"position":5,"arabic":"يُمِيتُكُمْ","translation":"তোমাদেরকে মৃত্যু দেন","audioUrl":"wbw/045_026_005.mp3","charTypeName":"word"},{"id":28703,"position":6,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/045_026_006.mp3","charTypeName":"word"},{"id":28704,"position":7,"arabic":"يَجْمَعُكُمْ","translation":"তোমাদেরকে একত্র করবেন","audioUrl":"wbw/045_026_007.mp3","charTypeName":"word"},{"id":28705,"position":8,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/045_026_008.mp3","charTypeName":"word"},{"id":28706,"position":9,"arabic":"يَوْمِ","translation":"দিনের","audioUrl":"wbw/045_026_009.mp3","charTypeName":"word"},{"id":28707,"position":10,"arabic":"ٱلْقِيَـٰمَةِ","translation":"কিয়ামতের","audioUrl":"wbw/045_026_010.mp3","charTypeName":"word"},{"id":28708,"position":11,"arabic":"لَا","translation":"নেই","audioUrl":"wbw/045_026_011.mp3","charTypeName":"word"},{"id":28709,"position":12,"arabic":"رَيْبَ","translation":"কোন সন্দেহ","audioUrl":"wbw/045_026_012.mp3","charTypeName":"word"},{"id":28710,"position":13,"arabic":"فِيهِ","translation":"তার মধ্যে\"","audioUrl":"wbw/045_026_013.mp3","charTypeName":"word"},{"id