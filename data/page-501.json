{"id":501,"ayahs":[{"number":23,"arabic":"أَفَرَءَيْتَ مَنِ ٱتَّخَذَ إِلَٰهَهُۥ هَوَىٰهُ وَأَضَلَّهُ ٱللَّهُ عَلَىٰ عِلْمٍۢ وَخَتَمَ عَلَىٰ سَمْعِهِۦ وَقَلْبِهِۦ وَجَعَلَ عَلَىٰ بَصَرِهِۦ غِشَٰوَةًۭ فَمَن يَهْدِيهِ مِنۢ بَعْدِ ٱللَّهِ ۚ أَفَلَا تَذَكَّرُونَ","translation":"HAST THOU ever considered [the kind of man] who makes his own desires his deity, and whom God has [thereupon] let go astray, knowing [that his mind is closed to all guidance], and whose hearing and heart He has sealed, and upon whose sight He has placed a veil? Who, then, could guide him after God [has abandoned him]? Will you not, then, bethink your­selves?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4496.mp3","surahId":45,"words":[{"id":25645,"position":1,"arabic":"أَفَرَءَيْتَ","translation":"তুমি (ভেবে) দেখেছ কি","audioUrl":"wbw/045_023_001.mp3","charTypeName":"word"},{"id":25646,"position":2,"arabic":"مَنِ","translation":"যে","audioUrl":"wbw/045_023_002.mp3","charTypeName":"word"},{"id":25647,"position":3,"arabic":"ٱتَّخَذَ","translation":"বানিয়েছে","audioUrl":"wbw/045_023_003.mp3","charTypeName":"word"},{"id":25648,"position":4,"arabic":"إِلَـٰهَهُۥ","translation":"তার ইলাহ","audioUrl":"wbw/045_023_004.mp3","charTypeName":"word"},{"id":25649,"position":5,"arabic":"هَوَىٰهُ","translation":"নিজ প্রবৃত্তিকে","audioUrl":"wbw/045_023_005.mp3","charTypeName":"word"},{"id":25650,"position":6,"arabic":"وَأَضَلَّهُ","translation":"এবং তাকে পথভ্রষ্ট করেছে","audioUrl":"wbw/045_023_006.mp3","charTypeName":"word"},{"id":25651,"position":7,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/045_023_007.mp3","charTypeName":"word"},{"id":25652,"position":8,"arabic":"عَلَىٰ","translation":"ভিত্তিতে","audioUrl":"wbw/045_023_008.mp3","charTypeName":"word"},{"id":25653,"position":9,"arabic":"عِلْمٍۢ","translation":"জ্ঞানের","audioUrl":"wbw/045_023_009.mp3","charTypeName":"word"},{"id":25654,"position":10,"arabic":"وَخَتَمَ","translation":"এবং মোহর মেরে দিয়েছেন","audioUrl":"wbw/045_023_010.mp3","charTypeName":"word"},{"id":25655,"position":11,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/045_023_011.mp3","charTypeName":"word"},{"id":25656,"position":12,"arabic":"سَمْعِهِۦ","translation":"তার কানের","audioUrl":"wbw/045_023_012.mp3","charTypeName":"word"},{"id":25657,"position":13,"arabic":"وَقَلْبِهِۦ","translation":"ও তার অন্তরের","audioUrl":"wbw/045_023_013.mp3","charTypeName":"word"},{"id":25658,"position":14,"arabic":"وَجَعَلَ","translation":"ও রেখে দিয়েছেন","audioUrl":"wbw/045_023_014.mp3","charTypeName":"word"},{"id":25659,"position":15,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/045_023_015.mp3","charTypeName":"word"},{"id":25660,"position":16,"arabic":"بَصَرِهِۦ","translation":"তার চোখের","audioUrl":"wbw/045_023_016.mp3","charTypeName":"word"},{"id":25661,"position":17,"arabic":"غِشَـٰوَةًۭ","translation":"আবরণ","audioUrl":"wbw/045_023_017.mp3","charTypeName":"word"},{"id":25662,"position":18,"arabic":"فَمَن","translation":"সুতরাং কে","audioUrl":"wbw/045_023_018.mp3","charTypeName":"word"},{"id":25663,"position":19,"arabic":"يَهْدِيهِ","translation":"তাকে সৎপথ দেখাবে","audioUrl":"wbw/045_023_019.mp3","charTypeName":"word"},{"id":25664,"position":20,"arabic":"مِنۢ","translation":"মধ্য হতে","audioUrl":"wbw/045_023_020.mp3","charTypeName":"word"},{"id":25665,"position":21,"arabic":"بَعْدِ","translation":"পরে","audioUrl":"wbw/045_023_021.mp3","charTypeName":"word"},{"id":25666,"position":22,"arabic":"ٱللَّهِ ۚ","translation":"আল্লাহর","audioUrl":"wbw/045_023_022.mp3","charTypeName":"word"},{"id":25668,"position":23,"arabic":"أَفَلَا","translation":"তবুও কি না","audioUrl":"wbw/045_023_024.mp3","charTypeName":"word"},{"id":25669,"position":24,"arabic":"تَذَكَّرُونَ","translation":"তোমরা শিক্ষা গ্রহণ করবে","audioUrl":"wbw/045_023_025.mp3","charTypeName":"word"},{"id":25670,"position":25,"arabic":"٢٣","translation":"(২৩)","audioUrl":null,"charTypeName":"end"}]},{"number":24,"arabic":"وَقَالُوا۟ مَا هِىَ إِلَّا حَيَاتُنَا ٱلدُّنْيَا نَمُوتُ وَنَحْيَا وَمَا يُهْلِكُنَآ إِلَّا ٱلدَّهْرُ ۚ وَمَا لَهُم بِذَٰلِكَ مِنْ عِلْمٍ ۖ إِنْ هُمْ إِلَّا يَظُنُّونَ","translation":"And yet they say: “There is nothing beyond our life in this world. We die as we come to life, and nothing but time destroys us.” But of this they have no knowledge whatever: they do nothing but guess.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4497.mp3","surahId":45,"words":[{"id":26716,"position":1,"arabic":"وَقَالُوا۟","translation":"এবং তারা বলে","audioUrl":"wbw/045_024_001.mp3","charTypeName":"word"},{"id":26717,"position":2,"arabic":"مَا","translation":"\"না","audioUrl":"wbw/045_024_002.mp3","charTypeName":"word"},{"id":26718,"position":3,"arabic":"هِىَ","translation":"সেটা (অর্থাৎ পূনরুত্থান)","audioUrl":"wbw/045_024_003.mp3","charTypeName":"word"},{"id":26719,"position":4,"arabic":"إِلَّا","translation":"(যদি থাকে) তবে","audioUrl":"wbw/045_024_004.mp3","charTypeName":"word"},{"id":26720,"position":5,"arabic":"حَيَاتُنَا","translation":"আমাদের এ জীবন","audioUrl":"wbw/045_024_005.mp3","charTypeName":"word"},{"id":26721,"position":6,"arabic":"ٱلدُّنْيَا","translation":"দুনিয়ার","audioUrl":"wbw/045_024_006.mp3","charTypeName":"word"},{"id":26722,"position":7,"arabic":"نَمُوتُ","translation":"আমরা মরি","audioUrl":"wbw/045_024_007.mp3","charTypeName":"word"},{"id":26723,"position":8,"arabic":"وَنَحْيَا","translation":"ও আমরা বাঁচি (তা সব এখানেই)","audioUrl":"wbw/045_024_008.mp3","charTypeName":"word"},{"id":26724,"position":9,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/045_024_009.mp3","charTypeName":"word"},{"id":26725,"position":10,"arabic":"يُهْلِكُنَآ","translation":"আমাদের ধ্বংস করে","audioUrl":"wbw/045_024_010.mp3","charTypeName":"word"},{"id":26726,"position":11,"arabic":"إِلَّا","translation":"এ ব্যতীত","audioUrl":"wbw/045_024_011.mp3","charTypeName":"word"},{"id":26727,"position":12,"arabic":"ٱلدَّهْرُ ۚ","translation":"কালের (আবর্তন)\"","audioUrl":"wbw/045_024_012.mp3","charTypeName":"word"},{"id":26729,"position":13,"arabic":"وَمَا","translation":"এবং নেই","audioUrl":"wbw/045_024_014.mp3","charTypeName":"word"},{"id":26730,"position":14,"arabic":"لَهُم","translation":"তাদের কাছে","audioUrl":"wbw/045_024_015.mp3","charTypeName":"word"},{"id":26731,"position":15,"arabic":"بِذَٰلِكَ","translation":"এ সম্বন্ধে","audioUrl":"wbw/045_024_016.mp3","charTypeName":"word"},{"id":26732,"position":16,"arabic":"مِنْ","translation":"কোনো","audioUrl":"wbw/045_024_017.mp3","charTypeName":"word"},{"id":26733,"position":17,"arabic":"عِلْمٍ ۖ","translation":"জ্ঞান","audioUrl":"wbw/045_024_018.mp3","charTypeName":"word"},{"id":26735,"position":18,"arabic":"إِنْ","translation":"না","audioUrl":"wbw/045_024_020.mp3","charTypeName":"word"},{"id":26736,"position":19,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/045_024_021.mp3","charTypeName":"word"},{"id":26737,"position":20,"arabic":"إِلَّا","translation":"এ ব্যতীত","audioUrl":"wbw/045_024_022.mp3","charTypeName":"word"},{"id":26738,"position":21,"arabic":"يَظُنُّونَ","translation":"অনুমান করে","audioUrl":"wbw/045_024_023.mp3","charTypeName":"word"},{"id":26739,"position":22,"arabic":"٢٤","translation":"(২৪)","audioUrl":null,"charTypeName":"end"}]},{"number":25,"arabic":"وَإِذَا تُتْلَىٰ عَلَيْهِمْ ءَايَٰتُنَا بَيِّنَٰتٍۢ مَّا كَانَ حُجَّتَهُمْ إِلَّآ أَن قَالُوا۟ ٱئْتُوا۟ بِـَٔابَآئِنَآ إِن كُنتُمْ صَٰدِقِينَ","translation":"And [so,] whenever Our messages are conveyed to them in all their clarity, their only argument is this: “Bring forth our fore­fathers [as witnesses], if what you claim is true!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4498.mp3","surahId":45,"words":[{"id":27732,"position":1,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/045_025_001.mp3","charTypeName":"word"},{"id":27733,"position":2,"arabic":"تُتْلَىٰ","translation":"আবৃত্তি করা হয়","audioUrl":"wbw/045_025_002.mp3","charTypeName":"word"},{"id":27734,"position":3,"arabic":"عَلَيْهِمْ","translati