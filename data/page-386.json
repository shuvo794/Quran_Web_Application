2_017.mp3","charTypeName":"word"},{"id":14367,"position":17,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]},{"number":13,"arabic":"فَرَدَدْنَٰهُ إِلَىٰٓ أُمِّهِۦ كَىْ تَقَرَّ عَيْنُهَا وَلَا تَحْزَنَ وَلِتَعْلَمَ أَنَّ وَعْدَ ٱللَّهِ حَقٌّۭ وَلَٰكِنَّ أَكْثَرَهُمْ لَا يَعْلَمُونَ","translation":"And thus We restored him to his mother, so that her eye might he gladdened, and that she might grieve no longer, and that she might know that God’s promise always comes true - even though most of them know it not!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3265.mp3","surahId":28,"words":[{"id":15462,"position":1,"arabic":"فَرَدَدْنَـٰهُ","translation":"অতঃপর আমরা ফিরিয়ে দিই তাকে","audioUrl":"wbw/028_013_001.mp3","charTypeName":"word"},{"id":15463,"position":2,"arabic":"إِلَىٰٓ","translation":"নিকট","audioUrl":"wbw/028_013_002.mp3","charTypeName":"word"},{"id":15464,"position":3,"arabic":"أُمِّهِۦ","translation":"মায়ের তার","audioUrl":"wbw/028_013_003.mp3","charTypeName":"word"},{"id":15465,"position":4,"arabic":"كَىْ","translation":"যেন","audioUrl":"wbw/028_013_004.mp3","charTypeName":"word"},{"id":15466,"position":5,"arabic":"تَقَرَّ","translation":"জুড়ায়","audioUrl":"wbw/028_013_005.mp3","charTypeName":"word"},{"id":15467,"position":6,"arabic":"عَيْنُهَا","translation":"চক্ষু তার","audioUrl":"wbw/028_013_006.mp3","charTypeName":"word"},{"id":15468,"position":7,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/028_013_007.mp3","charTypeName":"word"},{"id":15469,"position":8,"arabic":"تَحْزَنَ","translation":"দুশ্চিন্তা করে","audioUrl":"wbw/028_013_008.mp3","charTypeName":"word"},{"id":15470,"position":9,"arabic":"وَلِتَعْلَمَ","translation":"এবং যেন জানতে পারে","audioUrl":"wbw/028_013_009.mp3","charTypeName":"word"},{"id":15471,"position":10,"arabic":"أَنَّ","translation":"যে","audioUrl":"wbw/028_013_010.mp3","charTypeName":"word"},{"id":15472,"position":11,"arabic":"وَعْدَ","translation":"প্রতিশ্রুতি","audioUrl":"wbw/028_013_011.mp3","charTypeName":"word"},{"id":15473,"position":12,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/028_013_012.mp3","charTypeName":"word"},{"id":15474,"position":13,"arabic":"حَقٌّۭ","translation":"সত্য","audioUrl":"wbw/028_013_013.mp3","charTypeName":"word"},{"id":15475,"position":14,"arabic":"وَلَـٰكِنَّ","translation":"কিন্তু","audioUrl":"wbw/028_013_014.mp3","charTypeName":"word"},{"id":15476,"position":15,"arabic":"أَكْثَرَهُمْ","translation":"অধিকাংশই তাদের","audioUrl":"wbw/028_013_015.mp3","charTypeName":"word"},{"id":15477,"position":16,"arabic":"لَا","translation":"না","audioUrl":"wbw/028_013_016.mp3","charTypeName":"word"},{"id":15478,"position":17,"arabic":"يَعْلَمُونَ","translation":"জানে","audioUrl":"wbw/028_013_017.mp3","charTypeName":"word"},{"id":15479,"position":18,"arabic":"١٣","translation":"(১৩)","audioUrl":null,"charTypeName":"end"}]}]}