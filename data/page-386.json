{"id":386,"ayahs":[{"number":6,"arabic":"وَنُمَكِّنَ لَهُمْ فِى ٱلْأَرْضِ وَنُرِىَ فِرْعَوْنَ وَهَٰمَٰنَ وَجُنُودَهُمَا مِنْهُم مَّا كَانُوا۟ يَحْذَرُونَ","translation":"and to establish them securely on earth, and to let Pharaoh and Haman and their hosts experience through those [children of Israel] the very thing against which they sought to protect themselves.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3258.mp3","surahId":28,"words":[{"id":6831,"position":1,"arabic":"وَنُمَكِّنَ","translation":"এবং আমরা ক্ষমতাসীন করবো","audioUrl":"wbw/028_006_001.mp3","charTypeName":"word"},{"id":6832,"position":2,"arabic":"لَهُمْ","translation":"তাদেরকে","audioUrl":"wbw/028_006_002.mp3","charTypeName":"word"},{"id":6833,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/028_006_003.mp3","charTypeName":"word"},{"id":6834,"position":4,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/028_006_004.mp3","charTypeName":"word"},{"id":6835,"position":5,"arabic":"وَنُرِىَ","translation":"এবং আমরা দেখাবো","audioUrl":"wbw/028_006_005.mp3","charTypeName":"word"},{"id":6836,"position":6,"arabic":"فِرْعَوْنَ","translation":"ফিরআউনকে","audioUrl":"wbw/028_006_006.mp3","charTypeName":"word"},{"id":6837,"position":7,"arabic":"وَهَـٰمَـٰنَ","translation":"ও হামানকে","audioUrl":"wbw/028_006_007.mp3","charTypeName":"word"},{"id":6838,"position":8,"arabic":"وَجُنُودَهُمَا","translation":"ও উভয়ের সৈন্য বাহিনীকে তাদের","audioUrl":"wbw/028_006_008.mp3","charTypeName":"word"},{"id":6839,"position":9,"arabic":"مِنْهُم","translation":"হ'তে তাদের (অর্থাৎ বনি ঈসরাঈল)","audioUrl":"wbw/028_006_009.mp3","charTypeName":"word"},{"id":6840,"position":10,"arabic":"مَّا","translation":"(সেইসব) যা","audioUrl":"wbw/028_006_010.mp3","charTypeName":"word"},{"id":6841,"position":11,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/028_006_011.mp3","charTypeName":"word"},{"id":6842,"position":12,"arabic":"يَحْذَرُونَ","translation":"আশংকা করে তারা","audioUrl":"wbw/028_006_012.mp3","charTypeName":"word"},{"id":6843,"position":13,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"وَأَوْحَيْنَآ إِلَىٰٓ أُمِّ مُوسَىٰٓ أَنْ أَرْضِعِيهِ ۖ فَإِذَا خِفْتِ عَلَيْهِ فَأَلْقِيهِ فِى ٱلْيَمِّ وَلَا تَخَافِى وَلَا تَحْزَنِىٓ ۖ إِنَّا رَآدُّوهُ إِلَيْكِ وَجَاعِلُوهُ مِنَ ٱلْمُرْسَلِينَ","translation":"And so, [when he was born,] We inspired [thus] the mother of Moses: Suckle him [for a time], and then, when thou hast cause to fear for him, cast him into the river, and have no fear and do not grieve - for We shall restore him to thee, and shall make him one of Our message-bearers!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3259.mp3","surahId":28,"words":[{"id":8157,"position":1,"arabic":"وَأَوْحَيْنَآ","translation":"এবং ইঙ্গিতে বলেছিলাম আমরা","audioUrl":"wbw/028_007_001.mp3","charTypeName":"word"},{"id":8158,"position":2,"arabic":"إِلَىٰٓ","translation":"প্রতি","audioUrl":"wbw/028_007_002.mp3","charTypeName":"word"},{"id":8159,"position":3,"arabic":"أُمِّ","translation":"মায়ের","audioUrl":"wbw/028_007_003.mp3","charTypeName":"word"},{"id":8160,"position":4,"arabic":"مُوسَىٰٓ","translation":"মূসার","audioUrl":"wbw/028_007_004.mp3","charTypeName":"word"},{"id":8161,"position":5,"arabic":"أَنْ","translation":"যে","audioUrl":"wbw/028_007_005.mp3","charTypeName":"word"},{"id":8162,"position":6,"arabic":"أَرْضِعِيهِ ۖ","translation":"\"দুধপান করাও তাকে","audioUrl":"wbw/028_007_006.mp3","charTypeName":"word"},{"id":8164,"position":7,"arabic":"فَإِذَا","translation":"অতঃপর যখন","audioUrl":"wbw/028_007_008.mp3","charTypeName":"word"},{"id":8165,"position":8,"arabic":"خِفْتِ","translation":"তুমি আশংকা করবে","audioUrl":"wbw/028_007_009.mp3","charTypeName":"word"},{"id":8166,"position":9,"arabic":"عَلَيْهِ","translation":"সম্পর্কে তার","audioUrl":"wbw/028_007_010.mp3","charTypeName":"word"},{"id":8167,"position":10,"arabic":"فَأَلْقِيهِ","translation":"তখন (ফেলে) দাও তাকে","audioUrl":"wbw/028_007_011.mp3","charTypeName":"word"},{"id":8168,"position":11,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/028_007_012.mp3","charTypeName":"word"},{"id":8169,"position":12,"arabic":"ٱلْيَمِّ","translation":"সাগরের","audioUrl":"wbw/028_007_013.mp3","charTypeName":"word"},{"id":8170,"position":13,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/028_007_014.mp3","charTypeName":"word"},{"id":8171,"position":14,"arabic":"تَخَافِى","translation":"ভয় করো","audioUrl":"wbw/028_007_015.mp3","charTypeName":"word"},{"id":8172,"position":15,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/028_007_016.mp3","charTypeName":"word"},{"id":8173,"position":16,"arabic":"تَحْزَنِىٓ ۖ","translation":"দুঃশ্চিন্তা করো","audioUrl":"wbw/028_007_017.mp3","charTypeName":"word"},{"id":8175,"position":17,"arabic":"إِنَّا","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/028_007_019.mp3","charTypeName":"word"},{"id":8176,"position":18,"arabic":"رَآدُّوهُ","translation":"ফিরিয়ে দিবো তাকে","audioUrl":"wbw/028_007_020.mp3","charTypeName":"word"},{"id":8177,"position":19,"arabic":"إِلَيْكِ","translation":"কাছে তোমার","audioUrl":"wbw/028_007_021.mp3","charTypeName":"word"},{"id":8178,"position":20,"arabic":"وَجَاعِلُوهُ","translation":"ও করবো তাকে","audioUrl":"wbw/028_007_022.mp3","charTypeName":"word"},{"id":8179,"position":21,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/028_007_023.mp3","charTypeName":"word"},{"id":8180,"position":22,"arabic":"ٱلْمُرْسَلِينَ","translation":"রাসূলদের\"","audioUrl":"wbw/028_007_024.mp3","charTypeName":"word"},{"id":8181,"position":23,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"فَٱلْتَقَطَهُۥٓ ءَالُ فِرْعَوْنَ لِيَكُونَ لَهُمْ عَدُوًّۭا وَحَزَنًا ۗ إِنَّ فِرْعَوْنَ وَهَٰمَٰنَ وَجُنُودَهُمَا كَانُوا۟ خَٰطِـِٔينَ","translation":"And [some of] Pharaoh’s household found [and spared] him: for [We had willed] that he becomes an enemy unto them and [a source of] grief, seeing that Pharaoh and Haman and their hosts were sinners indeed!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3260.mp3","surahId":28,"words":[{"id":9331,"position":1,"arabic":"فَٱلْتَقَطَهُۥٓ","translation":"অতঃপর তুলে নিলো তাকে","audioUrl":"wbw/028_008_001.mp3","charTypeName":"word"},{"id":9332,"position":2,"arabic":"ءَالُ","translation":"পরিবার","audioUrl":"wbw/028_008_002.mp3","charTypeName":"word"},{"id":9333,"position":3,"arabic":"فِرْعَوْنَ","translation":"ফিরআউনের","audioUrl":"wbw/028_008_003.mp3","charTypeName":"word"},{"id":9334,"position":4,"arabic":"لِيَكُونَ","translation":"যেন হয় সে","audioUrl":"wbw/028_008_004.mp3","charTypeName":"word"},{"id":9335,"position":5,"arabic":"لَهُمْ","translation":"জন্যে তাদের","audioUrl":"wbw/028_008_005.mp3","charTypeName":"word"},{"id":9336,"position":6,"arabic":"عَدُوًّۭا","translation":"শত্রু","audioUrl":"wbw/028_008_006.mp3","charTypeName":"word"},{"id":9337,"position":7,"arabic":"وَحَزَنًا ۗ","translation":"ও দুঃশ্চিন্তার কারণ","audioUrl":"wbw/028_008_007.mp3","charTypeName":"word"},{"id":9339,"position":8,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/028_008_009.mp3","charTypeName":"word"},{"id":9340,"position":9,"arabic":"فِرْعَوْنَ","translation":"ফিরআউন","audioUrl":"wbw/028_008_010.mp3","charTypeName":"word"},{"id":9341,"position":10,"arabic":"وَهَـٰمَـٰنَ","translation":"ও হামান","audioUrl":"wbw/028_008_011.mp3","charTypeName":"word"},{"id":9342,"position":11,"arabic":"وَجُنُودَهُمَا","translation":"ও উভয়ের সেনাবাহিনী তাদের","audioUrl":"wbw/028_008_012.mp3","charTypeName":"word"},{"id":9343,"position":12,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/028_008_013.mp3","charTypeName":"word"},{"id":9344,"position":13,"arabic":"خَـٰطِـِٔينَ","translation":"অপরাধী","audioUrl":"wbw/028_008_014.mp3","charTypeName":"word"},{"id":9345,"position":14,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"وَقَالَتِ ٱمْرَأَتُ فِرْعَوْنَ قُرَّتُ عَيْنٍۢ لِّى وَلَكَ ۖ لَا تَقْتُلُوهُ عَسَىٰٓ أَن يَنفَعَنَآ أَوْ نَتَّخِذَهُۥ وَلَدًۭا وَهُمْ لَا يَشْعُرُونَ","translation":"Now the wife of Pharaoh said: “A joy to the eye [could this child be] for me and thee! Slay him not: he may well be of use to us, or we may adopt him as a son!” And they had no presentiment [of what he was to become].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3261.mp3","surahId":28,"words":[{"id":10512,"position":1,"arabic":"وَقَالَتِ","translation":"এবং বললো","audioUrl":"wbw/028_009_001.mp3","charTypeName":"word"},{"id":10513,"position":2,"arabic":"ٱمْرَأَتُ","translation":"স্ত্রী","audioUrl":"wbw/028_009_002.mp3","charTypeName":"word"},{"id":10514,"position":3,"arabic":"فِرْعَوْنَ","translation":"ফিরআউনের","audioUrl":"wbw/028_009_003.mp3","charTypeName":"word"},{"id":10515,"position":4,"arabic":"قُرَّتُ","translation":"\"(এই বালক) প্রশান্তি","audioUrl":"wbw/028_009_004.mp3","charTypeName":"word"},{"id":10516,"position":5,"arabic":"عَيْنٍۢ","translation":"নয়নের","audioUrl":"wbw/028_009_005.mp3","charTypeName":"word"},{"id":10517,"position":6,"arabic":"لِّى","translation":"জন্যে আমার","audioUrl":"wbw/028_009_006.mp3","charTypeName":"word"},{"id":10518,"position":7,"arabic":"وَلَكَ ۖ","translation":"ও জন্যে তোমার","audioUrl":"wbw/028_009_007.mp3","charTypeName":"word"},{"id":10520,"position":8,"arabic":"لَا","translation":"না","audioUrl":"wbw/028_009_009.mp3","charTypeName":"word"},{"id":10521,"position":9,"arabic":"تَقْتُلُوهُ","translation":"তোমরা হত্যা করো তাকে","audioUrl":"wbw/028_009_010.mp3","charTypeName":"word"},{"id":10522,"position":10,"arabic":"عَسَىٰٓ","translation":"হয়তো","audioUrl":"wbw/028_009_011.mp3","charTypeName":"word"},{"id":10523,"position":11,"arabic":"أَن","translation":"সে","audioUrl":"wbw/028_009_012.mp3","charTypeName":"word"},{"id":10524,"position":12,"arabic":"يَنفَعَنَآ","translation":"উপকারে আসবে আমাদের","audioUrl":"wbw/028_009_013.mp3","charTypeName":"word"},{"id":10525,"position":13,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/028_009_014.mp3","charTypeName":"word"},{"id":10526,"position":14,"arabic":"نَتَّخِذَهُۥ","translation":"আমরা গ্রহন করবো তাকে","audioUrl":"wbw/028_009_015.mp3","charTypeName":"word"},{"id":10527,"position":15,"arabic":"وَلَدًۭا","translation":"পুত্রসন্তান হিসেবে\"","audioUrl":"wbw/028_009_016.mp3","charTypeName":"word"},{"id":10528,"position":16,"arabic":"وَهُمْ","translation":"অথচ তারা","audioUrl":"wbw/028_009_017.mp3","charTypeName":"word"},{"id":10529,"position":17,"arabic":"لَا","translation":"না","audioUrl":"wbw/028_009_018.mp3","charTypeName":"word"},{"id":10530,"position":18,"arabic":"يَشْعُرُونَ","translation":"টেরও পায় (এর পরিমাণ)","audioUrl":"wbw/028_009_019.mp3","charTypeName":"word"},{"id":10531,"position":19,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"وَأَصْبَحَ فُؤَادُ أُمِّ مُوسَىٰ فَٰرِغًا ۖ إِن كَادَتْ لَتُبْدِى بِهِۦ لَوْلَآ أَن رَّبَطْنَا عَلَىٰ قَلْبِهَا لِتَكُونَ مِنَ ٱلْمُؤْمِنِينَ","translation":"On the morrow, however, an aching void grew up in the heart of the mother of Moses, and she would indeed have disclosed all about him had We not endowed her heart with enough strength to keep alive her faith [in Our promise].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3262.mp3","surahId":28,"words":[{"id":11748,"position":1,"arabic":"وَأَصْبَحَ","translation":"এবং হয়ে পড়লো","audioUrl":"wbw/028_010_001.mp3","charTypeName":"word"},{"id":11749,"position":2,"arabic":"فُؤَادُ","translation":"অন্তর","audioUrl":"wbw/028_010_002.mp3","charTypeName":"word"},{"id":11750,"position":3,"arabic":"أُمِّ","translation":"মায়ের","audioUrl":"wbw/028_010_003.mp3","charTypeName":"word"},{"id":11751,"position":4,"arabic":"مُوسَىٰ","translation":"মূসার","audioUrl":"wbw/028_010_004.mp3","charTypeName":"word"},{"id":11752,"position":5,"arabic":"فَـٰرِغًا ۖ","translation":"বিচলিত","audioUrl":"wbw/028_010_005.mp3","charTypeName":"word"},{"id":11754,"position":6,"arabic":"إِن","translation":"নিশ্চয়ই","audioUrl":"wbw/028_010_007.mp3","charTypeName":"word"},{"id":11755,"position":7,"arabic":"كَادَتْ","translation":"উপক্রম হয়েছিলো যে","audioUrl":"wbw/028_010_008.mp3","charTypeName":"word"},{"id":11756,"position":8,"arabic":"لَتُبْدِى","translation":"অবশ্যই সে প্রকাশ করবে","audioUrl":"wbw/028_010_009.mp3","charTypeName":"word"},{"id":11757,"position":9,"arabic":"بِهِۦ","translation":"সম্পর্কে সে","audioUrl":"wbw/028_010_010.mp3","charTypeName":"word"},{"id":11758,"position":10,"arabic":"لَوْلَآ","translation":"যদি না","audioUrl":"wbw/028_010_011.mp3","charTypeName":"word"},{"id":11759,"position":11,"arabic":"أَن","translation":"যে","audioUrl":"wbw/028_010_012.mp3","charTypeName":"word"},{"id":11760,"position":12,"arabic":"رَّبَطْنَا","translation":"দৃঢ় করতাম আমরা","audioUrl":"wbw/028_010_013.mp3","charTypeName":"word"},{"id":11761,"position":13,"arabic":"عَلَىٰ","translation":"ওপর","audioUrl":"wbw/028_010_014.mp3","charTypeName":"word"},{"id":11762,"position":14,"arabic":"قَلْبِهَا","translation":"অন্তরের তার","audioUrl":"wbw/028_010_015.mp3","charTypeName":"word"},{"id":11763,"position":15,"arabic":"لِتَكُونَ","translation":"যেন সে হয় (আমাদের প্রতিশ্রুতির প্রতি)","audioUrl":"wbw/028_010_016.mp3","charTypeName":"word"},{"id":11764,"position":16,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/028_010_017.mp3","charTypeName":"word"},{"id":11765,"position":17,"arabic":"ٱلْمُؤْمِنِينَ","translation":"মু'মিনদের","audioUrl":"wbw/028_010_018.mp3","charTypeName":"word"},{"id":11766,"position":18,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"وَقَالَتْ لِأُخْتِهِۦ قُصِّيهِ ۖ فَبَصُرَتْ بِهِۦ عَن جُنُبٍۢ وَهُمْ لَا يَشْعُرُونَ","translation":"And so she said to his sister, “Follow him” - and [the girl] watched him from afar, while they [who had taken him in] were not aware of it,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3263.mp3","surahId":28,"words":[{"id":13080,"position":1,"arabic":"وَقَالَتْ","translation":"এবং (তার মা) বললো","audioUrl":"wbw/028_011_001.mp3","charTypeName":"word"},{"id":13081,"position":2,"arabic":"لِأُخْتِهِۦ","translation":"উদ্দেশ্যে তার বোনের","audioUrl":"wbw/028_011_002.mp3","charTypeName":"word"},{"id":13082,"position":3,"arabic":"قُصِّيهِ ۖ","translation":"\"পিছনে পিছনে যাও তার\"","audioUrl":"wbw/028_011_003.mp3","charTypeName":"word"},{"id":13084,"position":4,"arabic":"فَبَصُرَتْ","translation":"তাই সে দেখে যেতে থাকলো","audioUrl":"wbw/028_011_005.mp3","charTypeName":"word"},{"id":13085,"position":5,"arabic":"بِهِۦ","translation":"প্রতি তার","audioUrl":"wbw/028_011_006.mp3","charTypeName":"word"},{"id":13086,"position":6,"arabic":"عَن","translation":"হ'তে","audioUrl":"wbw/028_011_007.mp3","charTypeName":"word"},{"id":13087,"position":7,"arabic":"جُنُبٍۢ","translation":"দূর","audioUrl":"wbw/028_011_008.mp3","charTypeName":"word"},{"id":13088,"position":8,"arabic":"وَهُمْ","translation":"অথচ তারা","audioUrl":"wbw/028_011_009.mp3","charTypeName":"word"},{"id":13089,"position":9,"arabic":"لَا","translation":"না","audioUrl":"wbw/028_011_010.mp3","charTypeName":"word"},{"id":13090,"position":10,"arabic":"يَشْعُرُونَ","translation":"টেরও পেলো","audioUrl":"wbw/028_011_011.mp3","charTypeName":"word"},{"id":13091,"position":11,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]},{"number":12,"arabic":"۞ وَحَرَّمْنَا عَلَيْهِ ٱلْمَرَاضِعَ مِن قَبْلُ فَقَالَتْ هَلْ أَدُلُّكُمْ عَلَىٰٓ أَهْلِ بَيْتٍۢ يَكْفُلُونَهُۥ لَكُمْ وَهُمْ لَهُۥ نَٰصِحُونَ","translation":"Now from the very beginning We caused him to refuse the breast of [Egyptian] nurses; and [when his sister came to know this,] she said: “Shall I guide you to a family that might rear him for you, and look after him with good will?”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3264.mp3","surahId":28,"words":[{"id":14351,"position":1,"arabic":"۞ وَحَرَّمْنَا","translation":"এবং হারাম