{"id":419,"ayahs":[{"number":7,"arabic":"وَإِذْ أَخَذْنَا مِنَ ٱلنَّبِيِّۦنَ مِيثَٰقَهُمْ وَمِنكَ وَمِن نُّوحٍۢ وَإِبْرَٰهِيمَ وَمُوسَىٰ وَعِيسَى ٱبْنِ مَرْيَمَ ۖ وَأَخَذْنَا مِنْهُم مِّيثَٰقًا غَلِيظًۭا","translation":"AND LO! We did accept a solemn pledge from all the prophets from thee, [O Muhammad,] as well as from Noah, and Abraham, and Moses, and Jesus the son of Mary -: for We accepted a most weighty, solemn pledge from [all of] them,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3540.mp3","surahId":33,"words":[{"id":8290,"position":1,"arabic":"وَإِذْ","translation":"এবং (স্মরণ করো) যখন","audioUrl":"wbw/033_007_001.mp3","charTypeName":"word"},{"id":8291,"position":2,"arabic":"أَخَذْنَا","translation":"নিয়েছিলাম আমরা","audioUrl":"wbw/033_007_002.mp3","charTypeName":"word"},{"id":8292,"position":3,"arabic":"مِنَ","translation":"কাছ থেকে","audioUrl":"wbw/033_007_003.mp3","charTypeName":"word"},{"id":8293,"position":4,"arabic":"ٱلنَّبِيِّـۧنَ","translation":"নাবীদের","audioUrl":"wbw/033_007_004.mp3","charTypeName":"word"},{"id":8294,"position":5,"arabic":"مِيثَـٰقَهُمْ","translation":"অঙ্গীকার তাদের","audioUrl":"wbw/033_007_005.mp3","charTypeName":"word"},{"id":8295,"position":6,"arabic":"وَمِنكَ","translation":"এবং থেকেও তোমার","audioUrl":"wbw/033_007_006.mp3","charTypeName":"word"},{"id":8296,"position":7,"arabic":"وَمِن","translation":"এবং থেকে","audioUrl":"wbw/033_007_007.mp3","charTypeName":"word"},{"id":8297,"position":8,"arabic":"نُّوحٍۢ","translation":"নূহ","audioUrl":"wbw/033_007_008.mp3","charTypeName":"word"},{"id":8298,"position":9,"arabic":"وَإِبْرَٰهِيمَ","translation":"এবং ইবরাহীম","audioUrl":"wbw/033_007_009.mp3","charTypeName":"word"},{"id":8299,"position":10,"arabic":"وَمُوسَىٰ","translation":"এবং মূসা","audioUrl":"wbw/033_007_010.mp3","charTypeName":"word"},{"id":8300,"position":11,"arabic":"وَعِيسَى","translation":"ও ঈসা","audioUrl":"wbw/033_007_011.mp3","charTypeName":"word"},{"id":8301,"position":12,"arabic":"ٱبْنِ","translation":"তনয়","audioUrl":"wbw/033_007_012.mp3","charTypeName":"word"},{"id":8302,"position":13,"arabic":"مَرْيَمَ ۖ","translation":"মারইয়াম (থেকেও)","audioUrl":"wbw/033_007_013.mp3","charTypeName":"word"},{"id":8304,"position":14,"arabic":"وَأَخَذْنَا","translation":"এবং নিয়েছিলাম আমরা","audioUrl":"wbw/033_007_015.mp3","charTypeName":"word"},{"id":8305,"position":15,"arabic":"مِنْهُم","translation":"থেকে তাদের","audioUrl":"wbw/033_007_016.mp3","charTypeName":"word"},{"id":8306,"position":16,"arabic":"مِّيثَـٰقًا","translation":"অঙ্গীকার","audioUrl":"wbw/033_007_017.mp3","charTypeName":"word"},{"id":8307,"position":17,"arabic":"غَلِيظًۭا","translation":"দৃঢ়","audioUrl":"wbw/033_007_018.mp3","charTypeName":"word"},{"id":8308,"position":18,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"لِّيَسْـَٔلَ ٱلصَّٰدِقِينَ عَن صِدْقِهِمْ ۚ وَأَعَدَّ لِلْكَٰفِرِينَ عَذَابًا أَلِيمًۭا","translation":"so that [at the end of time] He might ask those men of truth as to [what response] their truthfulness [had received on earth]. And grievous suffering has He readied for all who deny the truth!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3541.mp3","surahId":33,"words":[{"id":9469,"position":1,"arabic":"لِّيَسْـَٔلَ","translation":"যেন সে জিজ্ঞেস করতে পারে","audioUrl":"wbw/033_008_001.mp3","charTypeName":"word"},{"id":9470,"position":2,"arabic":"ٱلصَّـٰدِقِينَ","translation":"সত্যবাদীদেরকে","audioUrl":"wbw/033_008_002.mp3","charTypeName":"word"},{"id":9471,"position":3,"arabic":"عَن","translation":"সম্বন্ধে","audioUrl":"wbw/033_008_003.mp3","charTypeName":"word"},{"id":9472,"position":4,"arabic":"صِدْقِهِمْ ۚ","translation":"সত্যবাদীতা তাদের","audioUrl":"wbw/033_008_004.mp3","charTypeName":"word"},{"id":9474,"position":5,"arabic":"وَأَعَدَّ","translation":"এবং তিনি প্রস্তুত করে রেখেছেন","audioUrl":"wbw/033_008_006.mp3","charTypeName":"word"},{"id":9475,"position":6,"arabic":"لِلْكَـٰفِرِينَ","translation":"জন্যে কাফিরদের","audioUrl":"wbw/033_008_007.mp3","charTypeName":"word"},{"id":9476,"position":7,"arabic":"عَذَابًا","translation":"শাস্তি","audioUrl":"wbw/033_008_008.mp3","charTypeName":"word"},{"id":9477,"position":8,"arabic":"أَلِيمًۭا","translation":"নিদারুণ","audioUrl":"wbw/033_008_009.mp3","charTypeName":"word"},{"id":9478,"position":9,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ ٱذْكُرُوا۟ نِعْمَةَ ٱللَّهِ عَلَيْكُمْ إِذْ جَآءَتْكُمْ جُنُودٌۭ فَأَرْسَلْنَا عَلَيْهِمْ رِيحًۭا وَجُنُودًۭا لَّمْ تَرَوْهَا ۚ وَكَانَ ٱللَّهُ بِمَا تَعْمَلُونَ بَصِيرًا","translation":"O YOU who have attained to faith! Call to mind the blessings which God bestowed on you (at the time) when [enemy] hosts came down upon you, where­upon We let loose against them a storm wind and [heavenly] hosts that you could not see: yet God saw all that you did.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3542.mp3","surahId":33,"words":[{"id":10617,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/033_009_001.mp3","charTypeName":"word"},{"id":10618,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/033_009_002.mp3","charTypeName":"word"},{"id":10619,"position":3,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছো","audioUrl":"wbw/033_009_003.mp3","charTypeName":"word"},{"id":10620,"position":4,"arabic":"ٱذْكُرُوا۟","translation":"তোমরা স্মরণ করো","audioUrl":"wbw/033_009_004.mp3","charTypeName":"word"},{"id":10621,"position":5,"arabic":"نِعْمَةَ","translation":"অনুগ্রহের","audioUrl":"wbw/033_009_005.mp3","charTypeName":"word"},{"id":10622,"position":6,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/033_009_006.mp3","charTypeName":"word"},{"id":10623,"position":7,"arabic":"عَلَيْكُمْ","translation":"প্রতি তোমাদের","audioUrl":"wbw/033_009_007.mp3","charTypeName":"word"},{"id":10624,"position":8,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/033_009_008.mp3","charTypeName":"word"},{"id":10625,"position":9,"arabic":"جَآءَتْكُمْ","translation":"এসেছিলো তোমাদের (উপর)","audioUrl":"wbw/033_009_009.mp3","charTypeName":"word"},{"id":10626,"position":10,"arabic":"جُنُودٌۭ","translation":"(শত্রু) সৈন্যবাহিনী","audioUrl":"wbw/033_009_010.mp3","charTypeName":"word"},{"id":10627,"position":11,"arabic":"فَأَرْسَلْنَا","translation":"তখন পাঠিয়েছিলাম আমরা","audioUrl":"wbw/033_009_011.mp3","charTypeName":"word"},{"id":10628,"position":12,"arabic":"عَلَيْهِمْ","translation":"বিরুদ্ধে তাদের","audioUrl":"wbw/033_009_012.mp3","charTypeName":"word"},{"id":10629,"position":13,"arabic":"رِيحًۭا","translation":"প্রবল ঝড়","audioUrl":"wbw/033_009_013.mp3","charTypeName":"word"},{"id":10630,"position":14,"arabic":"وَجُنُودًۭا","translation":"ও সৈন্যবাহিনী","audioUrl":"wbw/033_009_014.mp3","charTypeName":"word"},{"id":10631,"position":15,"arabic":"لَّمْ","translation":"নাই","audioUrl":"wbw/033_009_015.mp3","charTypeName":"word"},{"id":10632,"position":16,"arabic":"تَرَوْهَا ۚ","translation":"তোমরা দেখো তা","audioUrl":"wbw/033_009_016.mp3","charTypeName":"word"},{"id":10634,"position":17,"arabic":"وَكَانَ","translation":"এবং হলেন","audioUrl":"wbw/033_009_018.mp3","charTypeName":"word"},{"id":10635,"position":18,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/033_009_019.mp3","charTypeName":"word"},{"id":10636,"position":19,"arabic":"بِمَا","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/033_009_020.mp3","charTypeName":"word"},{"id":10637,"position":20,"arabic":"تَعْمَلُونَ","translation":"তোমরা করো","audioUrl":"wbw/033_009_021.mp3","charTypeName":"word"},{"id":10638,"position":21,"arabic":"بَصِيرًا","translation":"খুব দৃষ্টিমান","audioUrl":"wbw/033_009_022.mp3","charTypeName":"word"},{"id":10639,"position":22,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"إِذْ جَآءُوكُم مِّن فَوْقِكُمْ وَمِنْ أَسْفَلَ مِنكُمْ وَإِذْ زَاغَتِ ٱلْأَبْصَٰرُ وَبَلَغَتِ ٱلْقُلُوبُ ٱلْحَنَاجِرَ وَتَظُنُّونَ بِٱللَّهِ ٱلظُّنُونَا۠","translation":"[Remember what you felt] when they came upon you from above you and from below you, and when [your] eyes became dim and [your] hearts came up to [your] throats, and [when] most conflicting thoughts about God passed through your minds:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3543.mp3","surahId":33,"words":[{"id":11896,"position":1,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/033_010_001.mp3","charTypeName":"word"},{"id":11897,"position":2,"arabic":"جَآءُوكُم","translation":"তারা এসেছিলো বিরুদ্ধে তোমাদের","audioUrl":"wbw/033_010_002.mp3","charTypeName":"word"},{"id":11898,"position":3,"arabic":"مِّن","translation":"হতে","audioUrl":"wbw/033_010_003.mp3","charTypeName":"word"},{"id":11899,"position":4,"arabic":"فَوْقِكُمْ","translation":"উপর তোমাদের(অঞ্চল)","audioUrl":"wbw/033_010_004.mp3","charTypeName":"word"},{"id":11900,"position":5,"arabic":"وَمِنْ","translation":"ও হ'তে","audioUrl":"wbw/033_010_005.mp3","charTypeName":"word"},{"id":11901,"position":6,"arabic":"أَسْفَلَ","translation":"নিচ (অঞ্চল)","audioUrl":"wbw/033_010_006.mp3","charTypeName":"word"},{"id":11902,"position":7,"arabic":"مِنكُمْ","translation":"হ'তে তোমাদের","audioUrl":"wbw/033_010_007.mp3","charTypeName":"word"},{"id":11903,"position":8,"arabic":"وَإِذْ","translation":"এবং যখন","audioUrl":"wbw/033_010_008.mp3","charTypeName":"word"},{"id":11904,"position":9,"arabic":"زَاغَتِ","translation":"বিস্ফোরিত হয়েছিলো","audioUrl":"wbw/033_010_009.mp3","charTypeName":"word"},{"id":11905,"position":10,"arabic":"ٱلْأَبْصَـٰرُ","translation":"চোখসমূহ","audioUrl":"wbw/033_010_010.mp3","charTypeName":"word"},{"id":11906,"position":11,"arabic":"وَبَلَغَتِ","translation":"ও পৌঁছে গিয়েছিলো","audioUrl":"wbw/033_010_011.mp3","charTypeName":"word"},{"id":11907,"position":12,"arabic":"ٱلْقُلُوبُ","translation":"প্রাণসমূহ","audioUrl":"wbw/033_010_012.mp3","charTypeName":"word"},{"id":11908,"position":13,"arabic":"ٱلْحَنَاجِرَ","translation":"কণ্ঠসমূহে","audioUrl":"wbw/033_010_013.mp3","charTypeName":"word"},{"id":11909,"position":14,"arabic":"وَتَظُنُّونَ","translation":"এবং তোমরা মনে করতে","audioUrl":"wbw/033_010_014.mp3","charTypeName":"word"},{"id":11910,"position":15,"arabic":"بِٱللَّهِ","translation":"সম্পর্কে আল্লাহ","audioUrl":"wbw/033_010_015.mp3","charTypeName":"word"},{"id":11911,"position":16,"arabic":"ٱلظُّنُونَا۠","translation":"নানাবিধ ধারণা","audioUrl":"wbw/033_010_016.mp3","charTypeName":"word"},{"id":11912,"position":17,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"هُنَالِكَ ٱبْتُلِىَ ٱلْمُؤْمِنُونَ وَزُلْزِلُوا۟ زِلْزَالًۭا شَدِيدًۭا","translation":"[for] there and then were the believers tried, and shaken with a shock severe.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3544.mp3","surahId":33,"words":[{"id":13199,"position":1,"arabic":"هُنَالِكَ","translation":"তখনই","audioUrl":"wbw/033_011_001.mp3","charTypeName":"word"},{"id":13200,"position":2,"arabic":"ٱبْتُلِىَ","translation":"পরীক্ষা করা হয়েছিলো","audioUrl":"wbw/033_011_002.mp3","charTypeName":"word"},{"id":13201,"position":3,"arabic":"ٱلْمُؤْمِنُونَ","translation":"মু’মিনদেরকে","audioUrl":"wbw/033_011_003.mp3","charTypeName":"word"},{"id":13202,"position":4,"arabic":"وَزُلْزِلُوا۟","translation":"এবং প্রকম্পিত করা হয়েছিলো","audioUrl":"wbw/033_011_004.mp3","charTypeName":"word"},{"id":13203,"position":5,"arabic":"زِلْزَالًۭا","translation":"প্রকম্পন","audioUrl":"wbw/033_011_005.mp3","charTypeName":"word"},{"id":13204,"position":6,"arabic":"شَدِيدًۭا","translation":"ভীষণভাবে","audioUrl":"wbw/033_011_006.mp3","charTypeName":"word"},{"id":13205,"position":7,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]},{"number":12,"arabic":"وَإِذْ يَقُولُ ٱلْمُنَٰفِقُونَ وَٱلَّذِينَ فِى قُلُوبِهِم مَّرَضٌۭ مَّا وَعَدَنَا ٱللَّهُ وَرَسُولُهُۥٓ إِلَّا غُرُورًۭا","translation":"And [remember how it was] when the hypo­crites and those with hearts diseased said [to one another], “God and His Apostle have promised us nothing but delusions!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3545.mp3","surahId":33,"words":[{"id":14481,"position":1,"arabic":"وَإِذْ","translation":"এবং যখন","audioUrl":"wbw/033_012_001.mp3","charTypeName":"word"},{"id":14482,"position":2,"arabic":"يَقُولُ","translation":"বলেছিলো","audioUrl":"wbw/033_012_002.mp3","charTypeName":"word"},{"id":14483,"position":3,"arabic":"ٱلْمُنَـٰفِقُونَ","translation":"মুনাফিকরা","audioUrl":"wbw/033_012_003.mp3","charTypeName":"word"},{"id":14484,"position":4,"arabic":"وَٱلَّذِينَ","translation":"ও যাদের","audioUrl":"wbw/033_012_004.mp3","charTypeName":"word"},{"id":14485,"position":5,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/033_012_005.mp3","charTypeName":"word"},{"id":14486,"position":6,"arabic":"قُلُوبِهِم","translation":"অন্তরসমূহের তাদের","audioUrl":"wbw/033_012_006.mp3","charTypeName":"word"},{"id":14487,"position":7,"arabic":"مَّرَضٌۭ","translation":"রোগ (ছিলো)","audioUrl":"wbw/033_012_007.mp3","charTypeName":"word"},{"id":14488,"position":8,"arabic":"مَّا","translation":"\"না","audioUrl":"wbw/033_012_008.mp3","charTypeName":"word"},{"id":14489,"position":9,"arabic":"وَعَدَنَا","translation":"প্রতিশ্রুতি দিয়েছেন আমাদের","audioUrl":"wbw/033_012_009.mp3","charTypeName":"word"},{"id":14490,"position":10,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/033_012_010.mp3","charTypeName":"word"},{"id":14491,"position":11,"arabic":"وَرَسُولُهُۥٓ","translation":"ও রাসূল তাঁর","audioUrl":"wbw/033_012_011.mp3","charTypeName":"word"},{"id":14492,"position":12,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/033_012_012.mp3","charTypeName":"word"},{"id":14493,"position":13,"arabic":"غُرُورًۭا","translation":"প্রতারণা\"","audioUrl":"wbw/033_012_013.mp3","charTypeName":"word"},{"id":14494,"position":14,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]},{"number":13,"arabic":"وَإِذْ قَالَت طَّآئِفَةٌۭ مِّنْهُمْ يَٰٓأَهْلَ يَثْرِبَ لَا مُقَامَ لَكُمْ فَٱرْجِعُوا۟ ۚ وَيَسْتَـْٔذِنُ فَرِيقٌۭ مِّنْهُمُ ٱلنَّبِىَّ يَقُولُونَ إِنَّ بُيُوتَنَا عَوْرَةٌۭ وَمَا هِىَ بِعَوْرَةٍ ۖ إِن يُرِيدُونَ إِلَّا فِرَارًۭا","translation":"and when some of them said, “O you people of Yathrib! You cannot withstand [the enemy] here: hence, go back [to your homes]!” — Whereupon a party from among them asked leave of the Prophet, saying, “Behold, our houses are exposed [to attack]!” — The while they were not [really] exposed: they wanted nothing but to flee.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3546.mp3","surahId":33,"words":[{"id":15587,"position":1,"arabic":"وَإِذْ","translation":"এবং যখন","audioUrl":"wbw/033_013_001.mp3","charTypeName":"word"},{"id":15588,"position":2,"arabic":"قَالَت","translation":"বলেছিলো","audioUrl":"wbw/033_013_002.mp3","charTypeName":"word"},{"id":15589,"position":3,"arabic":"طَّآئِفَةٌۭ","translation":"একদল","audioUrl":"wbw/033_013_003.mp3","charTypeName":"word"},{"id":15590,"position":4,"arabic":"مِّنْهُمْ","translation":"মধ্যে হ'তে তাদের","audioUrl":"wbw/033_013_004.mp3","charTypeName":"word"},{"id":15591,"position":5,"arabic":"يَـٰٓأَهْلَ","translation":"\"হে অধিবাসীরা","audioUrl":"wbw/033_013_005.mp3","charTypeName":"word"},{"id":15592,"position":6,"arabic":"يَثْرِبَ","translation":"ইযাসরিবের (অর্থাৎ মাদীনাহর)","audioUrl":"wbw/033_013_006.mp3","charTypeName":"word"},{"id":15593,"position":7,"arabic":"لَا","translation":"নেই","audioUrl":"wbw/033_013_007.mp3","charTypeName":"word"},{"id":15594,"position":8,"arabic":"مُقَامَ","translation":"দাঁড়াবার স্থান","audioUrl":"wbw/033_013_008.mp3","charTypeName":"word"},{"id":15595,"position":9,"arabic":"لَكُمْ","translation":"জন্যে তোমাদের","audioUrl":"wbw/033_013_009.mp3","charTypeName":"word"},{"id":15596,"position":10,"arabic":"فَٱرْجِعُوا۟ ۚ","translation":"সুতরাং তোমরা ফিরে যাও\"","audioUrl":"wbw/033_013_010.mp3","charTypeName":"word"},{"id":15598,"position":11,"arabic":"وَيَسْتَـْٔذِنُ","transl