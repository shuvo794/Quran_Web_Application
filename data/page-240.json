09,"position":28,"arabic":"وَلَـٰكِنَّ","translation":"কিন্তু","audioUrl":"wbw/012_040_031.mp3","charTypeName":"word"},{"id":41710,"position":29,"arabic":"أَكْثَرَ","translation":"অধিকাংশ","audioUrl":"wbw/012_040_032.mp3","charTypeName":"word"},{"id":41711,"position":30,"arabic":"ٱلنَّاسِ","translation":"মানুষ","audioUrl":"wbw/012_040_033.mp3","charTypeName":"word"},{"id":41712,"position":31,"arabic":"لَا","translation":"না","audioUrl":"wbw/012_040_034.mp3","charTypeName":"word"},{"id":41713,"position":32,"arabic":"يَعْلَمُونَ","translation":"জানে","audioUrl":"wbw/012_040_035.mp3","charTypeName":"word"},{"id":41714,"position":33,"arabic":"٤٠","translation":"(৪০)","audioUrl":null,"charTypeName":"end"}]},{"number":41,"arabic":"يَٰصَىٰحِبَىِ ٱلسِّجْنِ أَمَّآ أَحَدُكُمَا فَيَسْقِى رَبَّهُۥ خَمْرًۭا ۖ وَأَمَّا ٱلْءَاخَرُ فَيُصْلَبُ فَتَأْكُلُ ٱلطَّيْرُ مِن رَّأْسِهِۦ ۚ قُضِىَ ٱلْأَمْرُ ٱلَّذِى فِيهِ تَسْتَفْتِيَانِ","translation":"\"[And now,] O my companions in imprisonment, [I shall tell you the meaning of your dreams:] as for one of you two, he will [again] give his lord [the King] wine to drink; but as for the other, he will be crucified, and birds will eat off his head. [But whatever be your future,] the matter on which you have asked me to enlighten you has been decided [by God].\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1637.mp3","surahId":12,"words":[{"id":42482,"position":1,"arabic":"يَـٰصَـٰحِبَىِ","translation":"হে সঙ্গী দু'জন","audioUrl":"wbw/012_041_001.mp3","charTypeName":"word"},{"id":42483,"position":2,"arabic":"ٱلسِّجْنِ","translation":"কারাগারের","audioUrl":"wbw/012_041_002.mp3","charTypeName":"word"},{"id":42484,"position":3,"arabic":"أَمَّآ","translation":"(ব্যখ্যা হলো) এ প্রসঙ্গে","audioUrl":"wbw/012_041_003.mp3","charTypeName":"word"},{"id":42485,"position":4,"arabic":"أَحَدُكُمَا","translation":"তোমরা দু'জনের মধ্যে একজনের","audioUrl":"wbw/012_041_004.mp3","charTypeName":"word"},{"id":42486,"position":5,"arabic":"فَيَسْقِى","translation":"সে পান করাবে","audioUrl":"wbw/012_041_005.mp3","charTypeName":"word"},{"id":42487,"position":6,"arabic":"رَبَّهُۥ","translation":"তার প্রভুকে","audioUrl":"wbw/012_041_006.mp3","charTypeName":"word"},{"id":42488,"position":7,"arabic":"خَمْرًۭا ۖ","translation":"মদ","audioUrl":"wbw/012_041_007.mp3","charTypeName":"word"},{"id":42490,"position":8,"arabic":"وَأَمَّا","translation":"আর (ব্যাখ্যা) এ প্রসঙ্গে","audioUrl":"wbw/012_041_009.mp3","charTypeName":"word"},{"id":42491,"position":9,"arabic":"ٱلْـَٔاخَرُ","translation":"অন্যজনের","audioUrl":"wbw/012_041_010.mp3","charTypeName":"word"},{"id":42492,"position":10,"arabic":"فَيُصْلَبُ","translation":"সে শূলবিদ্ধ হবে","audioUrl":"wbw/012_041_011.mp3","charTypeName":"word"},{"id":42493,"position":11,"arabic":"فَتَأْكُلُ","translation":"এরপর খাবে","audioUrl":"wbw/012_041_012.mp3","charTypeName":"word"},{"id":42494,"position":12,"arabic":"ٱلطَّيْرُ","translation":"পাখি","audioUrl":"wbw/012_041_013.mp3","charTypeName":"word"},{"id":42495,"position":13,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/012_041_014.mp3","charTypeName":"word"},{"id":42496,"position":14,"arabic":"رَّأْسِهِۦ ۚ","translation":"তার মাথা","audioUrl":"wbw/012_041_015.mp3","charTypeName":"word"},{"id":42498,"position":15,"arabic":"قُضِىَ","translation":"সিদ্ধান্ত হয়ে গেছে","audioUrl":"wbw/012_041_017.mp3","charTypeName":"word"},{"id":42499,"position":16,"arabic":"ٱلْأَمْرُ","translation":"বিষয়ের","audioUrl":"wbw/012_041_018.mp3","charTypeName":"word"},{"id":42500,"position":17,"arabic":"ٱلَّذِى","translation":"এমন","audioUrl":"wbw/012_041_019.mp3","charTypeName":"word"},{"id":42501,"position":18,"arabic":"فِيهِ","translation":"যা সম্বন্ধে","audioUrl":"wbw/012_041_020.mp3","charTypeName":"word"},{"id":42502,"position":19,"arabic":"تَسْتَفْتِيَانِ","translation":"তোমরা দু'জনে জানতে চেয়েছো\"","audioUrl":"wbw/012_041_021.mp3","charTypeName":"word"},{"id":42503,"position":20,"arabic":"٤١","translation":"(৪১)","audioUrl":null,"charTypeName":"end"}]},{"number":42,"arabic":"وَقَالَ لِلَّذِى ظَنَّ أَنَّهُۥ نَاجٍۢ مِّنْهُمَا ٱذْكُرْنِى عِندَ رَبِّكَ فَأَنسَىٰهُ ٱلشَّيْطَٰنُ ذِكْرَ رَبِّهِۦ فَلَبِثَ فِى ٱلسِّجْنِ بِضْعَ سِنِينَ","translation":"And [thereupon Joseph] said unto the one of the two whom he considered saved: \"Mention me unto thy lord [when thou art free]!\" But Satan caused him to forget to mention [Joseph] to his lord, and so he remained in prison a few [more] years.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1638.mp3","surahId":12,"words":[{"id":43171,"position":1,"arabic":"وَقَالَ","translation":"এবং (ইউসুফ) বললো","audioUrl":"wbw/012_042_001.mp3","charTypeName":"word"},{"id":43172,"position":2,"arabic":"لِلَّذِى","translation":"(তাকে) যার ব্যাপারে","audioUrl":"wbw/012_042_002.mp3","charTypeName":"word"},{"id":43173,"position":3,"arabic":"ظَنَّ","translation":"সে ভেবেছিলো","audioUrl":"wbw/012_042_003.mp3","charTypeName":"word"},{"id":43174,"position":4,"arabic":"أَنَّهُۥ","translation":"যে সে","audioUrl":"wbw/012_042_004.mp3","charTypeName":"word"},{"id":43175,"position":5,"arabic":"نَاجٍۢ","translation":"মুক্তি পাবে","audioUrl":"wbw/012_042_005.mp3","charTypeName":"word"},{"id":43176,"position":6,"arabic":"مِّنْهُمَا","translation":"তাদের দু'জনের মধ্য হ'তে","audioUrl":"wbw/012_042_006.mp3","charTypeName":"word"},{"id":43177,"position":7,"arabic":"ٱذْكُرْنِى","translation":"\"আমার কথা উল্লেখ করবে","audioUrl":"wbw/012_042_007.mp3","charTypeName":"word"},{"id":43178,"position":8,"arabic":"عِندَ","translation":"কাছে","audioUrl":"wbw/012_042_008.mp3","charTypeName":"word"},{"id":43179,"position":9,"arabic":"رَبِّكَ","translation":"তোমার প্রভুর\"","audioUrl":"wbw/012_042_009.mp3","charTypeName":"word"},{"id":43180,"position":10,"arabic":"فَأَنسَىٰهُ","translation":"অতঃপর তাকে ভুলিয়েছিলো","audioUrl":"wbw/012_042_010.mp3","charTypeName":"word"},{"id":43181,"position":11,"arabic":"ٱلشَّيْطَـٰنُ","translation":"শয়তান","audioUrl":"wbw/012_042_011.mp3","charTypeName":"word"},{"id":43182,"position":12,"arabic":"ذِكْرَ","translation":"উল্লেখ করতে","audioUrl":"wbw/012_042_012.mp3","charTypeName":"word"},{"id":43183,"position":13,"arabic":"رَبِّهِۦ","translation":"তার প্রভুর কাছে","audioUrl":"wbw/012_042_013.mp3","charTypeName":"word"},{"id":43184,"position":14,"arabic":"فَلَبِثَ","translation":"অতঃপর সে রয়ে গেলো","audioUrl":"wbw/012_042_014.mp3","charTypeName":"word"},{"id":43185,"position":15,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/012_042_015.mp3","charTypeName":"word"},{"id":43186,"position":16,"arabic":"ٱلسِّجْنِ","translation":"কারাগারের","audioUrl":"wbw/012_042_016.mp3","charTypeName":"word"},{"id":43187,"position":17,"arabic":"بِضْعَ","translation":"কয়েক","audioUrl":"wbw/012_042_017.mp3","charTypeName":"word"},{"id":43188,"position":18,"arabic":"سِنِينَ","translation":"বছর (পর্যন্ত)","audioUrl":"wbw/012_042_018.mp3","charTypeName":"word"},{"id":43189,"position":19,"arabic":"٤٢","translation":"(৪২)","audioUrl":null,"charTypeName":"end"}]},{"number":43,"arabic":"وَقَالَ ٱلْمَلِكُ إِنِّىٓ أَرَىٰ سَبْعَ بَقَرَٰتٍۢ سِمَانٍۢ يَأْكُلُهُنَّ سَبْعٌ عِجَافٌۭ وَسَبْعَ سُنۢبُلَٰتٍ خُضْرٍۢ وَأُخَرَ يَابِسَٰتٍۢ ۖ يَٰٓأَيُّهَا ٱلْمَلَأُ أَفْتُونِى فِى رُءْيَٰىَ إِن كُنتُمْ لِلرُّءْيَا تَعْبُرُونَ","translation":"AND [one day] the King said: Behold, I saw [in a dream] seven fat cows being devoured by seven emaciated ones, and seven green ears [of wheat] next to [seven] others that were withered. O you nobles! Enlighten me about [the meaning of] my dream, if you are able to interpret dreams!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1639.mp3","surahId":12,"words":[{"id":43898,"position":1,"arabic":"وَقَالَ","translation":"এবং বললো","audioUrl":"wbw/012_043_001.mp3","charTypeName":"word"},{"id":43899,"position":2,"arabic":"ٱلْمَلِكُ","translation":"রাজা","audioUrl":"wbw/012_043_002.mp3","charTypeName":"word"},{"id":43900,"position":3,"arabic":"إِنِّىٓ","translation":"\"নিশ্চয়ই আমি","audioUrl":"wbw/012_043_003.mp3","ch