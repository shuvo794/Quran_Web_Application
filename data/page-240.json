{"id":240,"ayahs":[{"number":38,"arabic":"وَٱتَّبَعْتُ مِلَّةَ ءَابَآءِىٓ إِبْرَٰهِيمَ وَإِسْحَٰقَ وَيَعْقُوبَ ۚ مَا كَانَ لَنَآ أَن نُّشْرِكَ بِٱللَّهِ مِن شَىْءٍۢ ۚ ذَٰلِكَ مِن فَضْلِ ٱللَّهِ عَلَيْنَا وَعَلَى ٱلنَّاسِ وَلَٰكِنَّ أَكْثَرَ ٱلنَّاسِ لَا يَشْكُرُونَ","translation":"and I follow the creed of my forefathers Abraham, Isaac and Jacob. It is not conceivable that we should [be allowed to] ascribe divinity to aught beside God: this is [an outcome] of God's bounty unto us and unto all mankind -but most people are ungrateful.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1634.mp3","surahId":12,"words":[{"id":39999,"position":1,"arabic":"وَٱتَّبَعْتُ","translation":"এবং আমি অনুসরণ করেছি","audioUrl":"wbw/012_038_001.mp3","charTypeName":"word"},{"id":40000,"position":2,"arabic":"مِلَّةَ","translation":"আদর্শ","audioUrl":"wbw/012_038_002.mp3","charTypeName":"word"},{"id":40001,"position":3,"arabic":"ءَابَآءِىٓ","translation":"আমার পিতৃ-পুরুষদের","audioUrl":"wbw/012_038_003.mp3","charTypeName":"word"},{"id":40002,"position":4,"arabic":"إِبْرَٰهِيمَ","translation":"(যেমন) ইবরাহীম","audioUrl":"wbw/012_038_004.mp3","charTypeName":"word"},{"id":40003,"position":5,"arabic":"وَإِسْحَـٰقَ","translation":"ও ইসহাক","audioUrl":"wbw/012_038_005.mp3","charTypeName":"word"},{"id":40004,"position":6,"arabic":"وَيَعْقُوبَ ۚ","translation":"ও ইয়াকুবের","audioUrl":"wbw/012_038_006.mp3","charTypeName":"word"},{"id":40006,"position":7,"arabic":"مَا","translation":"নয়","audioUrl":"wbw/012_038_008.mp3","charTypeName":"word"},{"id":40007,"position":8,"arabic":"كَانَ","translation":"সমীচীন","audioUrl":"wbw/012_038_009.mp3","charTypeName":"word"},{"id":40008,"position":9,"arabic":"لَنَآ","translation":"জন্যে আমাদের","audioUrl":"wbw/012_038_010.mp3","charTypeName":"word"},{"id":40009,"position":10,"arabic":"أَن","translation":"যে","audioUrl":"wbw/012_038_011.mp3","charTypeName":"word"},{"id":40010,"position":11,"arabic":"نُّشْرِكَ","translation":"আমরা শরীক করবো","a