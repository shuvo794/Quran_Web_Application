udioUrl":null,"charTypeName":"end"}]},{"number":39,"arabic":"يَٰصَىٰحِبَىِ ٱلسِّجْنِ ءَأَرْبَابٌۭ مُّتَفَرِّقُونَ خَيْرٌ أَمِ ٱللَّهُ ٱلْوَٰحِدُ ٱلْقَهَّارُ","translation":"\"O my companions in imprisonment! Which is more reasonable: [belief in the existence of numerous divine] lords, each of them different from the other\" -or [in] the One God, who holds absolute sway over all that exists?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1635.mp3","surahId":12,"words":[{"id":40804,"position":1,"arabic":"يَـٰصَـٰحِبَىِ","translation":"হে সঙ্গী দু'জন","audioUrl":"wbw/012_039_001.mp3","charTypeName":"word"},{"id":40805,"position":2,"arabic":"ٱلسِّجْنِ","translation":"কারাগারের","audioUrl":"wbw/012_039_002.mp3","charTypeName":"word"},{"id":40806,"position":3,"arabic":"ءَأَرْبَابٌۭ","translation":"কি বহু রব","audioUrl":"wbw/012_039_003.mp3","charTypeName":"word"},{"id":40807,"position":4,"arabic":"مُّتَفَرِّقُونَ","translation":"পৃথক পৃথক","audioUrl":"wbw/012_039_004.mp3","charTypeName":"word"},{"id":40808,"position":5,"arabic":"خَيْرٌ","translation":"উত্তম","audioUrl":"wbw/012_039_005.mp3","charTypeName":"word"},{"id":40809,"position":6,"arabic":"أَمِ","translation":"না কি","audioUrl":"wbw/012_039_006.mp3","charTypeName":"word"},{"id":40810,"position":7,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/012_039_007.mp3","charTypeName":"word"},{"id":40811,"position":8,"arabic":"ٱلْوَٰحِدُ","translation":"এক (উত্তম রব)","audioUrl":"wbw/012_039_008.mp3","charTypeName":"word"},{"id":40812,"position":9,"arabic":"ٱلْقَهَّارُ","translation":"(যিনি) মহাপরাক্রমশালী","audioUrl":"wbw/012_039_009.mp3","charTypeName":"word"},{"id":40813,"position":10,"arabic":"٣٩","translation":"(৩৯)","audioUrl":null,"charTypeName":"end"}]},{"number":40,"arabic":"مَا تَعْبُدُونَ مِن دُونِهِۦٓ إِلَّآ أَسْمَآءًۭ سَمَّيْتُمُوهَآ أَنتُمْ وَءَابَآؤُكُم مَّآ أَنزَلَ ٱللَّهُ بِهَا مِن سُلْطَٰنٍ ۚ إِنِ ٱلْحُكْمُ إِلَّا لِلَّهِ ۚ أَمَرَ أَلَّا تَعْبُدُوٓا۟ إِلَّآ إِيَّاهُ ۚ ذَٰلِكَ ٱلدِّينُ ٱلْقَيِّمُ وَلَٰكِنَّ أَكْثَرَ ٱلنَّاسِ لَا يَعْلَمُونَ","translation":"\"All that you worship instead of God is nothing but [empty] names which you have invented - you and your forefathers- [and] for which God has bestowed no warrant from on high. Judgment [as to what is right and what is wrong] rests with God alone-[and] He has ordained that you should worship nought but Him: this is the [one] ever-true faith; but most people know it not","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1636.mp3","surahId":12,"words":[{"id":41679,"position":1,"arabic":"مَا","translation":"না","audioUrl":"wbw/012_040_001.mp3","charTypeName":"word"},{"id":41680,"position":2,"arabic":"تَعْبُدُونَ","translation":"তোমরা উপাসনা করছো","audioUrl":"wbw/012_040_002.mp3","charTypeName":"word"},{"id":41681,"position":3,"arabic":"مِن","translation":"ছেড়ে","audioUrl":"wbw/012_040_003.mp3","charTypeName":"word"},{"id":41682,"position":4,"arabic":"دُونِهِۦٓ","translation":"তাকে","audioUrl":"wbw/012_040_004.mp3","charTypeName":"word"},{"id":41683,"position":5,"arabic":"إِلَّآ","translation":"এ ছাড়া","audioUrl":"wbw/012_040_005.mp3","charTypeName":"word"},{"id":41684,"position":6,"arabic":"أَسْمَآءًۭ","translation":"(কিছু) নামের","audioUrl":"wbw/012_040_006.mp3","charTypeName":"word"},{"id":41685,"position":7,"arabic":"سَمَّيْتُمُوهَآ","translation":"যার তোমরা নামকরণ করেছো","audioUrl":"wbw/012_040_007.mp3","charTypeName":"word"},{"id":41686,"position":8,"arabic":"أَنتُمْ","translation":"তোমরা","audioUrl":"wbw/012_040_008.mp3","charTypeName":"word"},{"id":41687,"position":9,"arabic":"وَءَابَآؤُكُم","translation":"ও তোমাদের পিতৃ-পুরুষেরা","audioUrl":"wbw/012_040_009.mp3","charTypeName":"word"},{"id":41688,"position":10,"arabic":"مَّآ","translation":"না","audioUrl":"wbw/012_040_010.mp3","charTypeName":"word"},{"id":41689,"position":11,"arabic":"أَنزَلَ","translation":"পাঠিয়েছেন","audioUrl":"wbw/012_040_011.mp3","charTypeName":"word"},{"id":41690,"position":12,"arabic"