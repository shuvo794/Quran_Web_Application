"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1869.mp3","surahId":15,"words":[{"id":58345,"position":1,"arabic":"وَجَآءَ","translation":"এবং আসলো","audioUrl":"wbw/015_067_001.mp3","charTypeName":"word"},{"id":58346,"position":2,"arabic":"أَهْلُ","translation":"অধিবাসীরা","audioUrl":"wbw/015_067_002.mp3","charTypeName":"word"},{"id":58347,"position":3,"arabic":"ٱلْمَدِينَةِ","translation":"শহরের","audioUrl":"wbw/015_067_003.mp3","charTypeName":"word"},{"id":58348,"position":4,"arabic":"يَسْتَبْشِرُونَ","translation":"উল্লসিত","audioUrl":"wbw/015_067_004.mp3","charTypeName":"word"},{"id":58349,"position":5,"arabic":"٦٧","translation":"(৬৭)","audioUrl":null,"charTypeName":"end"}]},{"number":68,"arabic":"قَالَ إِنَّ هَٰٓؤُلَآءِ ضَيْفِى فَلَا تَفْضَحُونِ","translation":"Exclaimed [Lot]: \"Behold, these are my guests: so put me not to shame,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1870.mp3","surahId":15,"words":[{"id":58825,"position":1,"arabic":"قَالَ","translation":"(লূত) বললো","audioUrl":"wbw/015_068_001.mp3","charTypeName":"word"},{"id":58826,"position":2,"arabic":"إِنَّ","translation":"\"নিশ্চয়ই","audioUrl":"wbw/015_068_002.mp3","charTypeName":"word"},{"id":58827,"position":3,"arabic":"هَـٰٓؤُلَآءِ","translation":"ঐসব লোক","audioUrl":"wbw/015_068_003.mp3","charTypeName":"word"},{"id":58828,"position":4,"arabic":"ضَيْفِى","translation":"আমার অতিথি","audioUrl":"wbw/015_068_004.mp3","charTypeName":"word"},{"id":58829,"position":5,"arabic":"فَلَا","translation":"অতএব না","audioUrl":"wbw/015_068_005.mp3","charTypeName":"word"},{"id":58830,"position":6,"arabic":"تَفْضَحُونِ","translation":"আমাকে তোমরা অপমান করো","audioUrl":"wbw/015_068_006.mp3","charTypeName":"word"},{"id":58831,"position":7,"arabic":"٦٨","translation":"(৬৮)","audioUrl":null,"charTypeName":"end"}]},{"number":69,"arabic":"وَٱتَّقُوا۟ ٱللَّهَ وَلَا تُخْزُونِ","translation":"but be conscious of God and disgrace me not!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1871.mp3","surahId":15,"words":[{"id":59329,"position":1,"arabic":"وَٱتَّقُوا۟","translation":"এবং তোমরা ভয় করো","audioUrl":"wbw/015_069_001.mp3","charTypeName":"word"},{"id":59330,"position":2,"arabic":"ٱللَّهَ","translation":"আল্লাহকে","audioUrl":"wbw/015_069_002.mp3","charTypeName":"word"},{"id":59331,"position":3,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/015_069_003.mp3","charTypeName":"word"},{"id":59332,"position":4,"arabic":"تُخْزُونِ","translation":"আমাকে তোমরা লাঞ্ছিত করো\"","audioUrl":"wbw/015_069_004.mp3","charTypeName":"word"},{"id":59333,"position":5,"arabic":"٦٩","translation":"(৬৯)","audioUrl":null,"charTypeName":"end"}]},{"number":70,"arabic":"قَالُوٓا۟ أَوَلَمْ نَنْهَكَ عَنِ ٱلْعَٰلَمِينَ","translation":"They answered: \"Have we not forbidden thee [to offer protection] to any kind of people?\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1872.mp3","surahId":15,"words":[{"id":59762,"position":1,"arabic":"قَالُوٓا۟","translation":"তারা বললো","audioUrl":"wbw/015_070_001.mp3","charTypeName":"word"},{"id":59763,"position":2,"arabic":"أَوَلَمْ","translation":"\"কি নি","audioUrl":"wbw/015_070_002.mp3","charTypeName":"word"},{"id":59764,"position":3,"arabic":"نَنْهَكَ","translation":"তোমাকে আমরা নিষেধ করি","audioUrl":"wbw/015_070_003.mp3","charTypeName":"word"},{"id":59765,"position":4,"arabic":"عَنِ","translation":"সম্পর্কে","audioUrl":"wbw/015_070_004.mp3","charTypeName":"word"},{"id":59766,"position":5,"arabic":"ٱلْعَـٰلَمِينَ","translation":"সারা দুনিয়ার (দায়িত্ব নেয়া)\"","audioUrl":"wbw/015_070_005.mp3","charTypeName":"word"},{"id":59767,"position":6,"arabic":"٧٠","translation":"(৭০)","audioUrl":null,"charTypeName":"end"}]}]}