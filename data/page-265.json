{"id":265,"ayahs":[{"number":52,"arabic":"إِذْ دَخَلُوا۟ عَلَيْهِ فَقَالُوا۟ سَلَٰمًۭا قَالَ إِنَّا مِنكُمْ وَجِلُونَ","translation":"[how,] when they presented themselves before him and bade him peace, he answered: \"Behold, we are afraid of you!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1854.mp3","surahId":15,"words":[{"id":50201,"position":1,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/015_052_001.mp3","charTypeName":"word"},{"id":50202,"position":2,"arabic":"دَخَلُوا۟","translation":"তারা প্রবেশ  করেছিলো","audioUrl":"wbw/015_052_002.mp3","charTypeName":"word"},{"id":50203,"position":3,"arabic":"عَلَيْهِ","translation":"তার কাছে","audioUrl":"wbw/015_052_003.mp3","charTypeName":"word"},{"id":50204,"position":4,"arabic":"فَقَالُوا۟","translation":"অতঃপর তারা বলেছিলো","audioUrl":"wbw/015_052_004.mp3","charTypeName":"word"},{"id":50205,"position":5,"arabic":"سَلَـٰمًۭا","translation":"\"(তোমাকে) সালাম\"","audioUrl":"wbw/015_052_005.mp3","charTypeName":"word"},{"id":50206,"position":6,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/015_052_006.mp3","charTypeName":"word"},{"id":50207,"position":7,"arabic":"إِنَّا","translation":"\"নিশ্চয়ই আমরা","audioUrl":"wbw/015_052_007.mp3","charTypeName":"word"},{"id":50208,"position":8,"arabic":"مِنكُمْ","translation":"তোমাদের থেকে","audioUrl":"wbw/015_052_008.mp3","charTypeName":"word"},{"id":50209,"position":9,"arabic":"وَجِلُونَ","translation":"আতঙ্কিত\"","audioUrl":"wbw/015_052_009.mp3","charTypeName":"word"},{"id":50210,"position":10,"arabic":"٥٢","translation":"(৫২)","audioUrl":null,"charTypeName":"end"}]},{"number":53,"arabic":"قَالُوا۟ لَا تَوْجَلْ إِنَّا نُبَشِّرُكَ بِغُلَٰمٍ عَلِيمٍۢ","translation":"Said they: \"Fear not! Behold, we bring thee the glad tiding of [the birth of] a son who will be endowed with deep knowledge.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1855.mp3","surahId":15,"words":[{"id":50870,"position":1,"arabic":"قَالُوا۟","translation":"তারা বললো","audioUrl":"wbw/015_053_001.mp3","charTypeName":"word"},{"id":50871,"position":2,"arabic":"لَا","translation":"\"না","audioUrl":"wbw/015_053_002.mp3","charTypeName":"word"},{"id":50872,"position":3,"arabic":"تَوْجَلْ","translation":"আতঙ্কিত হয়ো","audioUrl":"wbw/015_053_003.mp3","charTypeName":"word"},{"id":50873,"position":4,"arabic":"إِنَّا","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/015_053_004.mp3","charTypeName":"word"},{"id":50874,"position":5,"arabic":"نُبَشِّرُكَ","translation":"তোমাকে সুসংবাদ দিচ্ছি","audioUrl":"wbw/015_053_005.mp3","charTypeName":"word"},{"id":50875,"position":6,"arabic":"بِغُلَـٰمٍ","translation":"একটি ছেলের","audioUrl":"wbw/015_053_006.mp3","charTypeName":"word"},{"id":50876,"position":7,"arabic":"عَلِيمٍۢ","translation":"বড় জ্ঞানী\"","audioUrl":"wbw/015_053_007.mp3","charTypeName":"word"},{"id":50877,"position":8,"arabic":"٥٣","translation":"(৫৩)","audioUrl":null,"charTypeName":"end"}]},{"number":54,"arabic":"قَالَ أَبَشَّرْتُمُونِى عَلَىٰٓ أَن مَّسَّنِىَ ٱلْكِبَرُ فَبِمَ تُبَشِّرُونَ","translation":"Said he: \"Do you give me this glad tiding despite the fact that old age has overtaken me? Of what [strange thing], then, are you giving me a tiding!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1856.mp3","surahId":15,"words":[{"id":51322,"position":1,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/015_054_001.mp3","charTypeName":"word"},{"id":51323,"position":2,"arabic":"أَبَشَّرْتُمُونِى","translation":"\"কি আমাকে তোমরা সুসংবাদ দিচ্ছো","audioUrl":"wbw/015_054_002.mp3","charTypeName":"word"},{"id":51324,"position":3,"arabic":"عَلَىٰٓ","translation":"\"এ অবস্থায়","audioUrl":"wbw/015_054_003.mp3","charTypeName":"word"},{"id":51325,"position":4,"arabic":"أَن","translation":"যে","audioUrl":"wbw/015_054_004.mp3","charTypeName":"word"},{"id":51326,"position":5,"arabic":"مَّسَّنِىَ","translation":"আমাকে পেয়েছে","audioUrl":"wbw/015_054_005.mp3","charTypeName":"word"},{"id":51327,"position":6,"arabic":"ٱلْكِبَرُ","translation":"বার্ধক্য","audioUrl":"wbw/015_054_006.mp3","charTypeName":"word"},{"id":51328,"position":7,"arabic":"فَبِمَ","translation":"অতএব কি ধরণের","audioUrl":"wbw/015_054_007.mp3","charTypeName":"word"},{"id":51329,"position":8,"arabic":"تُبَشِّرُونَ","translation":"তোমরা সুসংবাদ দিচ্ছো\"","audioUrl":"wbw/015_054_008.mp3","charTypeName":"word"},{"id":51330,"position":9,"arabic":"٥٤","translation":"(৫৪)","audioUrl":null,"charTypeName":"end"}]},{"number":55,"arabic":"قَالُوا۟ بَشَّرْنَٰكَ بِٱلْحَقِّ فَلَا تَكُن مِّنَ ٱلْقَٰنِطِينَ","translation":"They answered: \"We have given thee the glad tiding of something that is bound to come true. - so be not of those who abandon hope!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1857.mp3","surahId":15,"words":[{"id":51782,"position":1,"arabic":"قَالُوا۟","translation":"তারা বলেছিলো","audioUrl":"wbw/015_055_001.mp3","charTypeName":"word"},{"id":51783,"position":2,"arabic":"بَشَّرْنَـٰكَ","translation":"\"তোমাকে সুসংবাদ দিচ্ছি আমরা","audioUrl":"wbw/015_055_002.mp3","charTypeName":"word"},{"id":51784,"position":3,"arabic":"بِٱلْحَقِّ","translation":"সহকারে সত্য","audioUrl":"wbw/015_055_003.mp3","charTypeName":"word"},{"id":51785,"position":4,"arabic":"فَلَا","translation":"অতএব না","audioUrl":"wbw/015_055_004.mp3","charTypeName":"word"},{"id":51786,"position":5,"arabic":"تَكُن","translation":"তুমি হয়ো","audioUrl":"wbw/015_055_005.mp3","charTypeName":"word"},{"id":51787,"position":6,"arabic":"مِّنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/015_055_006.mp3","charTypeName":"word"},{"id":51788,"position":7,"arabic":"ٱلْقَـٰنِطِينَ","translation":"হতাশদের\"","audioUrl":"wbw/015_055_007.mp3","charTypeName":"word"},{"id":51789,"position":8,"arabic":"٥٥","translation":"(৫৫)","audioUrl":null,"charTypeName":"end"}]},{"number":56,"arabic":"قَالَ وَمَن يَقْنَطُ مِن رَّحْمَةِ رَبِّهِۦٓ إِلَّا ٱلضَّآلُّونَ","translation":"[Abraham] exclaimed: \"And who-other than those who have utterly lost their way-could ever abandon the hope of his Sustainer's grace?\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1858.mp3","surahId":15,"words":[{"id":52314,"position":1,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/015_056_001.mp3","charTypeName":"word"},{"id":52315,"position":2,"arabic":"وَمَن","translation":"\"এবং কে","audioUrl":"wbw/015_056_002.mp3","charTypeName":"word"},{"id":52316,"position":3,"arabic":"يَقْنَطُ","translation":"নিরাশ হয়","audioUrl":"wbw/015_056_003.mp3","charTypeName":"word"},{"id":52317,"position":4,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/015_056_004.mp3","charTypeName":"word"},{"id":52318,"position":5,"arabic":"رَّحْمَةِ","translation":"অনুগ্রহ","audioUrl":"wbw/015_056_005.mp3","charTypeName":"word"},{"id":52319,"position":6,"arabic":"رَبِّهِۦٓ","translation":"তার রবের","audioUrl":"wbw/015_056_006.mp3","charTypeName":"word"},{"id":52320,"position":7,"arabic":"إِلَّا","translation":"এছাড়া","audioUrl":"wbw/015_056_007.mp3","charTypeName":"word"},{"id":52321,"position":8,"arabic":"ٱلضَّآلُّونَ","translation":"পথভ্রষ্টরা","audioUrl":"wbw/015_056_008.mp3","charTypeName":"word"},{"id":52322,"position":9,"arabic":"٥٦","translation":"(৫৬)","audioUrl":null,"charTypeName":"end"}]},{"number":57,"arabic":"قَالَ فَمَا خَطْبُكُمْ أَيُّهَا ٱلْمُرْسَلُونَ","translation":"He added: \"And what [else] may you have in view, O you [heavenly] messengers?\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1859.mp3","surahId":15,"words":[{"id":52875,"position":1,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/015_057_001.mp3","charTypeName":"word"},{"id":52876,"position":2,"arabic":"فَمَا","translation":"\"অতএব কি","audioUrl":"wbw/015_057_002.mp3","charTypeName":"word"},{"id":52877,"position":3,"arabic":"خَطْبُكُمْ","translation":"আপনাদের উদ্দেশ্য","audioUrl":"wbw/015_057_003.mp3","charTypeName":"word"},{"id":52878,"position":4,"arabic":"أَيُّهَا","translation":"হে\"","audioUrl":"wbw/015_057_004.mp3","charTypeName":"word"},{"id":52879,"position":5,"arabic":"ٱلْمُرْسَلُونَ","translation":"প্রেরিত (ফেরেশতারা)\"","audioUrl":"wbw/015_057_005.mp3","charTypeName":"word"},{"id":52880,"position":6,"arabic":"٥٧","translation":"(৫৭)","audioUrl":null,"charTypeName":"end"}]},{"number":58,"arabic":"قَالُوٓا۟ إِنَّآ أُرْسِلْنَآ إِلَىٰ قَوْمٍۢ مُّجْرِمِينَ","translation":"They answered: \"We are sent to people lost in sin [who are to be destroyed],","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1860.mp3","surahId":15,"words":[{"id":53566,"position":1,"arabic":"قَالُوٓا۟","translation":"তারা বললো","audioUrl":"wbw/015_058_001.mp3","charTypeName":"word"},{"id":53567,"position":2,"arabic":"إِنَّآ","translation":"\"নিশ্চয়ই আমরা","audioUrl":"wbw/015_058_002.mp3","charTypeName":"word"},{"id":53568,"position":3,"arabic":"أُرْسِلْنَآ","translation":"আমরা প্রেরিত হয়েছি","audioUrl":"wbw/015_058_003.mp3","charTypeName":"word"},{"id":53569,"position":4,"arabic":"إِلَىٰ","translation":"প্রতি","audioUrl":"wbw/015_058_004.mp3","charTypeName":"word"},{"id":53570,"position":5,"arabic":"قَوْمٍۢ","translation":"সম্প্রদায়ের","audioUrl":"wbw/015_058_005.mp3","charTypeName":"word"},{"id":53571,"position":6,"arabic":"مُّجْرِمِينَ","translation":"অপরাধী","audioUrl":"wbw/015_058_006.mp3","charTypeName":"word"},{"id":53572,"position":7,"arabic":"٥٨","translation":"(৫৮)","audioUrl":null,"charTypeName":"end"}]},{"number":59,"arabic":"إِلَّآ ءَالَ لُوطٍ إِنَّا لَمُنَجُّوهُمْ أَجْمَعِينَ","translation":"barring Lot's household, all of whom, behold, we shall save -","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1861.mp3","surahId":15,"words":[{"id":53857,"position":1,"arabic":"إِلَّآ","translation":"ছাড়া","audioUrl":"wbw/015_059_001.mp3","charTypeName":"word"},{"id":53858,"position":2,"arabic":"ءَالَ","translation":"পরিবার","audioUrl":"wbw/015_059_002.mp3","charTypeName":"word"},{"id":53859,"position":3,"arabic":"لُوطٍ","translation":"লূতের","audioUrl":"wbw/015_059_003.mp3","charTypeName":"word"},{"id":53860,"position":4,"arabic":"إِنَّا","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/015_059_004.mp3","charTypeName":"word"},{"id":53861,"position":5,"arabic":"لَمُنَجُّوهُمْ","translation":"অবশ্যই রক্ষাকারী তাদের","audioUrl":"wbw/015_059_005.mp3","charTypeName":"word"},{"id":53862,"position":6,"arabic":"أَجْمَعِينَ","translation":"সকলকে","audioUrl":"wbw/015_059_006.mp3","charTypeName":"word"},{"id":53863,"position":7,"arabic":"٥٩","translation":"(৫৯)","audioUrl":null,"charTypeName":"end"}]},{"number":60,"arabic":"إِلَّا ٱمْرَأَتَهُۥ قَدَّرْنَآ ۙ إِنَّهَا لَمِنَ ٱلْغَٰبِرِينَ","translation":"excepting only his wife, [of whom God says,] `We have ordained [that], behold, she should be among those who stay behind!'","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1862.mp3","surahId":15,"words":[{"id":54439,"position":1,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/015_060_001.mp3","charTypeName":"word"},{"id":54440,"position":2,"arabic":"ٱمْرَأَتَهُۥ","translation":"তার স্ত্রী\"","audioUrl":"wbw/015_060_002.mp3","charTypeName":"word"},{"id":54441,"position":3,"arabic":"قَدَّرْنَآ ۙ","translation":"আমরা স্থির করেছি","audioUrl":"wbw/015_060_003.mp3","charTypeName":"word"},{"id":54443,"position":4,"arabic":"إِنَّهَا","translation":"নিশ্চয়ই সে","audioUrl":"wbw/015_060_005.mp3","charTypeName":"word"},{"id":54444,"position":5,"arabic":"لَمِنَ","translation":"অব্যশই অন্তর্ভুক্ত","audioUrl":"wbw/015_060_006.mp3","charTypeName":"word"},{"id":54445,"position":6,"arabic":"ٱلْغَـٰبِرِينَ","translation":"পিছনে থেকে যাওয়া লোকদের","audioUrl":"wbw/015_060_007.mp3","charTypeName":"word"},{"id":54446,"position":7,"arabic":"٦٠","translation":"(৬০)","audioUrl":null,"charTypeName":"end"}]},{"number":61,"arabic":"فَلَمَّا جَآءَ ءَالَ لُوطٍ ٱلْمُرْسَلُونَ","translation":"AND WHEN the messengers [of God] came to the house of Lot,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1863.mp3","surahId":15,"words":[{"id":55345,"position":1,"arabic":"فَلَمَّا","translation":"অতঃপর যখন","audioUrl":"wbw/015_061_001.mp3","charTypeName":"word"},{"id":55346,"position":2,"arabic":"جَآءَ","translation":"আসলো","audioUrl":"wbw/015_061_002.mp3","charTypeName":"word"},{"id":55347,"position":3,"arabic":"ءَالَ","translation":"পরিবারের কাছে","audioUrl":"wbw/015_061_003.mp3","charTypeName":"word"},{"id":55348,"position":4,"arabic":"لُوطٍ","translation":"লূতের","audioUrl":"wbw/015_061_004.mp3","charTypeName":"word"},{"id":55349,"position":5,"arabic":"ٱلْمُرْسَلُونَ","translation":"প্রেরিত (ফেরেশতারা)","audioUrl":"wbw/015_061_005.mp3","charTypeName":"word"},{"id":55350,"position":6,"arabic":"٦١","translation":"(৬১)","audioUrl":null,"charTypeName":"end"}]},{"number":62,"arabic":"قَالَ إِنَّكُمْ قَوْمٌۭ مُّنكَرُونَ","translation":"he said: \"Behold, you are people unknown [here]!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1864.mp3","surahId":15,"words":[{"id":55853,"position":1,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/015_062_001.mp3","charTypeName":"word"},{"id":55854,"position":2,"arabic":"إِنَّكُمْ","translation":"\"নিশ্চয়ই তোমরা","audioUrl":"wbw/015_062_002.mp3","charTypeName":"word"},{"id":55855,"position":3,"arabic":"قَوْمٌۭ","translation":"লোক","audioUrl":"wbw/015_062_003.mp3","charTypeName":"word"},{"id":55856,"position":4,"arabic":"مُّنكَرُونَ","translation":"অপরিচিত\"","audioUrl":"wbw/015_062_004.mp3","charTypeName":"word"},{"id":55857,"position":5,"arabic":"٦٢","translation":"(৬২)","audioUrl":null,"charTypeName":"end"}]},{"number":63,"arabic":"قَالُوا۟ بَلْ جِئْنَٰكَ بِمَا كَانُوا۟ فِيهِ يَمْتَرُونَ","translation":"They answered: \"Nay, but we have come unto thee with [the announcement of] something that they [who are given to evil] have always been wont to call in question,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1865.mp3","surahId":15,"words":[{"id":56423,"position":1,"arabic":"قَالُوا۟","translation":"তারা বললো","audioUrl":"wbw/015_063_001.mp3","charTypeName":"word"},{"id":56424,"position":2,"arabic":"بَلْ","translation":"\"বরং","audioUrl":"wbw/015_063_002.mp3","charTypeName":"word"},{"id":56425,"position":3,"arabic":"جِئْنَـٰكَ","translation":"তোমার কাছে আমরা এসেছি","audioUrl":"wbw/015_063_003.mp3","charTypeName":"word"},{"id":56426,"position":4,"arabic":"بِمَا","translation":"ঐ বিষয় নিয়ে যা","audioUrl":"wbw/015_063_004.mp3","charTypeName":"word"},{"id":56427,"position":5,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/015_063_005.mp3","charTypeName":"word"},{"id":56428,"position":6,"arabic":"فِيهِ","translation":"সে ব্যাপারে","audioUrl":"wbw/015_063_006.mp3","charTypeName":"word"},{"id":56429,"position":7,"arabic":"يَمْتَرُونَ","translation":"সন্দেহ করতো","audioUrl":"wbw/015_063_007.mp3","charTypeName":"word"},{"id":56430,"position":8,"arabic":"٦٣","translation":"(৬৩)","audioUrl":null,"charTypeName":"end"}]},{"number":64,"arabic":"وَأَتَيْنَٰكَ بِٱلْحَقِّ وَإِنَّا لَصَٰدِقُونَ","translation":"and we are bringing thee the certainty [of its fulfilment]: for, behold, we are speaking the truth indeed.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1866.mp3","surahId":15,"words":[{"id":56940,"position":1,"arabic":"وَأَتَيْنَـٰكَ","translation":"এবং তোমার কাছে আমরা এসেছি","audioUrl":"wbw/015_064_001.mp3","charTypeName":"word"},{"id":56941,"position":2,"arabic":"بِٱلْحَقِّ","translation":"নিয়ে সত্য","audioUrl":"wbw/015_064_002.mp3","charTypeName":"word"},{"id":56942,"position":3,"arabic":"وَإِنَّا","translation":"এবং নিশ্চয়ই আমরা","audioUrl":"wbw/015_064_003.mp3","charTypeName":"word"},{"id":56943,"position":4,"arabic":"لَصَـٰدِقُونَ","translation":"অবশ্যই সত্যবাদী","audioUrl":"wbw/015_064_004.mp3","charTypeName":"word"},{"id":56944,"position":5,"arabic":"٦٤","translation":"(৬৪)","audioUrl":null,"charTypeName":"end"}]},{"number":65,"arabic":"فَأَسْرِ بِأَهْلِكَ بِقِطْعٍۢ مِّنَ ٱلَّيْلِ وَٱتَّبِعْ أَدْبَٰرَهُمْ وَلَا يَلْتَفِتْ مِنكُمْ أَحَدٌۭ وَٱمْضُوا۟ حَيْثُ تُؤْمَ