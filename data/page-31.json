{"id":31,"ayahs":[{"number":197,"arabic":"ٱلْحَجُّ أَشْهُرٌۭ مَّعْلُومَٰتٌۭ ۚ فَمَن فَرَضَ فِيهِنَّ ٱلْحَجَّ فَلَا رَفَثَ وَلَا فُسُوقَ وَلَا جِدَالَ فِى ٱلْحَجِّ ۗ وَمَا تَفْعَلُوا۟ مِنْ خَيْرٍۢ يَعْلَمْهُ ٱللَّهُ ۗ وَتَزَوَّدُوا۟ فَإِنَّ خَيْرَ ٱلزَّادِ ٱلتَّقْوَىٰ ۚ وَٱتَّقُونِ يَٰٓأُو۟لِى ٱلْأَلْبَٰبِ","translation":"The pilgrimage shall take place in the months appointed for it. And whoever undertakes the pilgrimage in those [months] shall, while on pilgrimage, abstain from lewd speech, from all wicked conduct, and from quarrelling; and whatever good you may do, God is aware of it. And make provision for yourselves - but, verily, the best of all provisions is God-consciousness: remain, then, conscious of Me, O you who are endowed with insight!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/204.mp3","surahId":2,"words":[{"id":85071,"position":1,"arabic":"ٱلْحَجُّ","translation":"হজ্জের","audioUrl":"wbw/002_197_001.mp3","charTypeName":"word"},{"id":85072,"position":2,"arabic":"أَشْهُرٌۭ","translation":"মাসগুলো","audioUrl":"wbw/002_197_002.mp3","charTypeName":"word"},{"id":85073,"position":3,"arabic":"مَّعْلُومَـٰتٌۭ ۚ","translation":"সুবিদিত","audioUrl":"wbw/002_197_003.mp3","charTypeName":"word"},{"id":85075,"position":4,"arabic":"فَمَن","translation":"তাই যে কেউ","audioUrl":"wbw/002_197_005.mp3","charTypeName":"word"},{"id":85076,"position":5,"arabic":"فَرَضَ","translation":"স্থির করল","audioUrl":"wbw/002_197_006.mp3","charTypeName":"word"},{"id":85077,"position":6,"arabic":"فِيهِنَّ","translation":"তার মধ্যে","audioUrl":"wbw/002_197_007.mp3","charTypeName":"word"},{"id":85078,"position":7,"arabic":"ٱلْحَجَّ","translation":"হজ্জ করার","audioUrl":"wbw/002_197_008.mp3","charTypeName":"word"},{"id":85079,"position":8,"arabic":"فَلَا","translation":"না তখন","audioUrl":"wbw/002_197_009.mp3","charTypeName":"word"},{"id":85080,"position":9,"arabic":"رَفَثَ","translation":"যৌন সম্ভোগ করবে (হজ্জের সময়)","audioUrl":"wbw/002_197_010.mp3","charTypeName":"word"},{"id":85081,"position":10,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/002_197_011.mp3","charTypeName":"word"},{"id":85082,"position":11,"arabic":"فُسُوقَ","translation":"অন্যায় আচরণ করবে","audioUrl":"wbw/002_197_012.mp3","charTypeName":"word"},{"id":85083,"position":12,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/002_197_013.mp3","charTypeName":"word"},{"id":85084,"position":13,"arabic":"جِدَالَ","translation":"কলহ-বিবাদ করবে","audioUrl":"wbw/002_197_014.mp3","charTypeName":"word"},{"id":85085,"position":14,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/002_197_015.mp3","charTypeName":"word"},{"id":85086,"position":15,"arabic":"ٱلْحَجِّ ۗ","translation":"হজ্জের","audioUrl":"wbw/002_197_016.mp3","charTypeName":"word"},{"id":85088,"position":16,"arabic":"وَمَا","translation":"এবং যা","audioUrl":"wbw/002_197_018.mp3","charTypeName":"word"},{"id":85089,"position":17,"arabic":"تَفْعَلُوا۟","translation":"তোমরা কর","audioUrl":"wbw/002_197_019.mp3","charTypeName":"word"},{"id":85090,"position":18,"arabic":"مِنْ","translation":"কোনো","audioUrl":"wbw/002_197_020.mp3","charTypeName":"word"},{"id":85091,"position":19,"arabic":"خَيْرٍۢ","translation":"কল্যাণ","audioUrl":"wbw/002_197_021.mp3","charTypeName":"word"},{"id":85092,"position":20,"arabic":"يَعْلَمْهُ","translation":"তা জানেন","audioUrl":"wbw/002_197_022.mp3","charTypeName":"word"},{"id":85093,"position":21,"arabic":"ٱللَّهُ ۗ","translation":"আল্লাহ","audioUrl":"wbw/002_197_023.mp3","charTypeName":"word"},{"id":85095,"position":22,"arabic":"وَتَزَوَّدُوا۟","translation":"এবং তোমরা পাথেয় সাথে নাও","audioUrl":"wbw/002_197_025.mp3","charTypeName":"word"},{"id":85096,"position":23,"arabic":"فَإِنَّ","translation":"নিশ্চয়ই তবে","audioUrl":"wbw/002_197_026.mp3","charTypeName":"word"},{"id":85097,"position":24,"arabic":"خَيْرَ","translation":"উত্তম","audioUrl":"wbw/002_197_027.mp3","charTypeName":"word"},{"id":85098,"position":25,"arabic":"ٱلزَّادِ","translation":"পাথেয় (হল)","audioUrl":"wbw/002_197_028.mp3","charTypeName":"word"},{"id":85099,"position":26,"arabic":"ٱلتَّقْوَىٰ ۚ","translation":"তাকওয়া","audioUrl":"wbw/002_197_029.mp3","charTypeName":"word"},{"id":85101,"position":27,"arabic":"وَٱتَّقُونِ","translation":"এবং আমাকে তোমরা ভয় করো","audioUrl":"wbw/002_197_031.mp3","charTypeName":"word"},{"id":85102,"position":28,"arabic":"يَـٰٓأُو۟لِى","translation":"হে","audioUrl":"wbw/002_197_032.mp3","charTypeName":"word"},{"id":85103,"position":29,"arabic":"ٱلْأَلْبَـٰبِ","translation":"বুদ্ধিমান লোকেরা","audioUrl":"wbw/002_197_033.mp3","charTypeName":"word"},{"id":85104,"position":30,"arabic":"١٩٧","translation":"(১৯৭)","audioUrl":null,"charTypeName":"end"}]},{"number":198,"arabic":"لَيْسَ عَلَيْكُمْ جُنَاحٌ أَن تَبْتَغُوا۟ فَضْلًۭا مِّن رَّبِّكُمْ ۚ فَإِذَآ أَفَضْتُم مِّنْ عَرَفَٰتٍۢ فَٱذْكُرُوا۟ ٱللَّهَ عِندَ ٱلْمَشْعَرِ ٱلْحَرَامِ ۖ وَٱذْكُرُوهُ كَمَا هَدَىٰكُمْ وَإِن كُنتُم مِّن قَبْلِهِۦ لَمِنَ ٱلضَّآلِّينَ","translation":"[However,] you will be committing no sin if [during the pilgrimage] you seek to obtain any bounty from your Sustainer. And when you surge downward in multitudes from `Arafat, remember God at the holy place, and remember Him as the One who guided you after you had indeed been lost on your way;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/205.mp3","surahId":2,"words":[{"id":85158,"position":1,"arabic":"لَيْسَ","translation":"নেই","audioUrl":"wbw/002_198_001.mp3","charTypeName":"word"},{"id":85159,"position":2,"arabic":"عَلَيْكُمْ","translation":"তোমাদের উপর","audioUrl":"wbw/002_198_002.mp3","charTypeName":"word"},{"id":85160,"position":3,"arabic":"جُنَاحٌ","translation":"কোন পাপ","audioUrl":"wbw/002_198_003.mp3","charTypeName":"word"},{"id":85161,"position":4,"arabic":"أَن","translation":"যে","audioUrl":"wbw/002_198_004.mp3","charTypeName":"word"},{"id":85162,"position":5,"arabic":"تَبْتَغُوا۟","translation":"তোমরা সন্ধান করবে","audioUrl":"wbw/002_198_005.mp3","charTypeName":"word"},{"id":85163,"position":6