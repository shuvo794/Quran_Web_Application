{"id":304,"ayahs":[{"number":98,"arabic":"قَالَ هَٰذَا رَحْمَةٌۭ مِّن رَّبِّى ۖ فَإِذَا جَآءَ وَعْدُ رَبِّى جَعَلَهُۥ دَكَّآءَ ۖ وَكَانَ وَعْدُ رَبِّى حَقًّۭا","translation":"Said [the King]: \"This is a mercy from my Sustainer! Yet when the time appointed by my Sustainer shall come, He will make this [rampart] level with the ground: and my Sustainer's promise always comes true!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2238.mp3","surahId":18,"words":[{"id":70633,"position":1,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/018_098_001.mp3","charTypeName":"word"},{"id":70634,"position":2,"arabic":"هَـٰذَا","translation":"\"এটা","audioUrl":"wbw/018_098_002.mp3","charTypeName":"word"},{"id":70635,"position":3,"arabic":"رَحْمَةٌۭ","translation":"অনুগ্রহ","audioUrl":"wbw/018_098_003.mp3","charTypeName":"word"},{"id":70636,"position":4,"arabic":"مِّن","translation":"পক্ষ হ'তে","audioUrl":"wbw/018_098_004.mp3","charTypeName":"word"},{"id":70637,"position":5,"arabic":"رَّبِّى ۖ","translation":"আমার রবের","audioUrl":"wbw/018_098_005.mp3","charTypeName":"word"},{"id":70639,"position":6,"arabic":"فَإِذَا","translation":"অতঃপর যখন","audioUrl":"wbw/018_098_007.mp3","charTypeName":"word"},{"id":70640,"position":7,"arabic":"جَآءَ","translation":"আসবে","audioUrl":"wbw/018_098_008.mp3","charTypeName":"word"},{"id":70641,"position":8,"arabic":"وَعْدُ","translation":"প্রতিশ্রুতি","audioUrl":"wbw/018_098_009.mp3","charTypeName":"word"},{"id":70642,"position":9,"arabic":"رَبِّى","translation":"আমার রবের","audioUrl":"wbw/018_098_010.mp3","charTypeName":"word"},{"id":70643,"position":10,"arabic":"جَعَلَهُۥ","translation":"তা করে দিবেন","audioUrl":"wbw/018_098_011.mp3","charTypeName":"word"},{"id":70644,"position":11,"arabic":"دَكَّآءَ ۖ","translation":"চূর্ণবিচূর্ণ","audioUrl":"wbw/018_098_012.mp3","charTypeName":"word"},{"id":70646,"position":12,"arabic":"وَكَانَ","translation":"এবং হলো","audioUrl":"wbw/018_098_014.mp3","charTypeName":"word"},{"id":70647,"position":13,"arabic":"وَعْدُ","translation":"প্রতিশ্রুতি","audioUrl":"wbw/018_098_015.mp3","charTypeName":"word"},{"id":70648,"position":14,"arabic":"رَبِّى","translation":"আমার রবের","audioUrl":"wbw/018_098_016.mp3","charTypeName":"word"},{"id":70649,"position":15,"arabic":"حَقًّۭا","translation":"সত্য\"","audioUrl":"wbw/018_098_017.mp3","charTypeName":"word"},{"id":70650,"position":16,"arabic":"٩٨","translation":"(৯৮)","audioUrl":null,"charTypeName":"end"}]},{"number":99,"arabic":"۞ وَتَرَكْنَا بَعْضَهُمْ يَوْمَئِذٍۢ يَمُوجُ فِى بَعْضٍۢ ۖ وَنُفِخَ فِى ٱلصُّورِ فَجَمَعْنَٰهُمْ جَمْعًۭا","translation":"AND ON that Day\" We shall [call forth all mankind and] leave them to surge like waves [that dash] against one another; and the trumpet [of judgment] will be blown, and We shall gather them all together.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2239.mp3","surahId":18,"words":[{"id":70935,"position":1,"arabic":"۞ وَتَرَكْنَا","translation":"এবং আমরা ছেড়ে দিববো","audioUrl":"wbw/018_099_002.mp3","charTypeName":"word"},{"id":70936,"position":2,"arabic":"بَعْضَهُمْ","translation":"তাদের কাউকে","audioUrl":"wbw/018_099_003.mp3","charTypeName":"word"},{"id":70937,"position":3,"arabic":"يَوْمَئِذٍۢ","translation":"সেদিন","audioUrl":"wbw/018_099_004.mp3","charTypeName":"word"},{"id":70938,"position":4,"arabic":"يَمُوجُ","translation":"তরঙ্গের মত পড়বে","audioUrl":"wbw/018_099_005.mp3","charTypeName":"word"},{"id":70939,"position":5,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/018_099_006.mp3","charTypeName":"word"},{"id":70940,"position":6,"arabic":"بَعْضٍۢ ۖ","translation":"কারও","audioUrl":"wbw/018_099_007.mp3","charTypeName":"word"},{"id":70942,"position":7,"arabic":"وَنُفِخَ","translation":"এবং ফুঁ দেয়া হবে","audioUrl":"wbw/018_099_009.mp3","charTypeName":"word"},{"id":70943,"position":8,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/018_099_010.mp3","charTypeName":"word"},{"id":70944,"position":9,"arabic":"ٱلصُّورِ","translation":"শিঙ্গার","audioUrl":"wbw/018_099_011.mp3","charTypeName":"word"},{"id":70945,"position":10,"arabic":"فَجَمَعْنَـٰهُمْ","translation":"অতঃপর আমরা একত্র করবো তাদেরকে","audioUrl":"wbw/018_099_012.mp3","charTypeName":"word"},{"id":70946,"position":11,"arabic":"جَمْعًۭا","translation":"একসঙ্গে","audioUrl":"wbw/018_099_013.mp3","charTypeName":"word"},{"id":70947,"position":12,"arabic":"٩٩","translation":"(৯৯)","audioUrl":null,"charTypeName":"end"}]},{"number":100,"arabic":"وَعَرَضْنَا جَهَنَّمَ يَوْمَئِذٍۢ لِّلْكَٰفِرِينَ عَرْضًا","translation":"And on that Day We shall place hell, for all to see, before those who denied the truth-","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2240.mp3","surahId":18,"words":[{"id":71194,"position":1,"arabic":"وَعَرَضْنَا","translation":"এবং আমরা পেশ করবো","audioUrl":"wbw/018_100_001.mp3","charTypeName":"word"},{"id":71195,"position":2,"arabic":"جَهَنَّمَ","translation":"জাহান্নামকে","audioUrl":"wbw/018_100_002.mp3","charTypeName":"word"},{"id":71196,"position":3,"arabic":"يَوْمَئِذٍۢ","translation":"সেদিন","audioUrl":"wbw/018_100_003.mp3","charTypeName":"word"},{"id":71197,"position":4,"arabic":"لِّلْكَـٰفِرِينَ","translation":"জন্যে কাফিরদের","audioUrl":"wbw/018_100_004.mp3","charTypeName":"word"},{"id":71198,"position":5,"arabic":"عَرْضًا","translation":"প্রত্যক্ষভাবে","audioUrl":"wbw/018_100_005.mp3","charTypeName":"word"},{"id":71199,"position":6,"arabic":"١٠٠","translation":"(১০০)","audioUrl":null,"charTypeName":"end"}]},{"number":101,"arabic":"ٱلَّذِينَ كَانَتْ أَعْيُنُهُمْ فِى غِطَآءٍ عَن ذِكْرِى وَكَانُوا۟ لَا يَسْتَطِيعُونَ سَمْعًا","translation":"those whose eyes had been veiled against any remembrance of Me because they could not bear to listen [to the voice of truth]!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2241.mp3","surahId":18,"words":[{"id":71543,"position":1,"arabic":"ٱلَّذِينَ","translation":"যাদের","audioUrl":"wbw/018_101_001.mp3","charTypeName":"word"},{"id":71544,"position":2,"arabic":"كَانَتْ","translation":"ছিলো","audioUrl":"wbw/018_101_002.mp3","charTypeName":"word"},{"id":71545,"position":3,"arabic":"أَعْيُنُهُمْ","translation":"চোখগুলোর তাদের","audioUrl":"wbw/018_101_003.mp3","charTypeName":"word"},{"id":71546,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/018_101_004.mp3","charTypeName":"word"},{"id":71547,"position":5,"arabic":"غِطَآءٍ","translation":"পর্দা","audioUrl":"wbw/018_101_005.mp3","charTypeName":"word"},{"id":71548,"position":6,"arabic":"عَن","translation":"থেকে","audioUrl":"wbw/018_101_006.mp3","charTypeName":"word"},{"id":71549,"position":7,"arabic":"ذِكْرِى","translation":"আমার স্মরণ","audioUrl":"wbw/018_101_007.mp3","charTypeName":"word"},{"id":71550,"position":8,"arabic":"وَكَانُوا۟","translation":"এবং তারা ছিলো","audioUrl":"wbw/018_101_008.mp3","charTypeName":"word"},{"id":71551,"position":9,"arabic":"لَا","translation":"না","audioUrl":"wbw/018_101_009.mp3","charTypeName":"word"},{"id":71552,"position":10,"arabic":"يَسْتَطِيعُونَ","translation":"সক্ষম হতো","audioUrl":"wbw/018_101_010.mp3","charTypeName":"word"},{"id":71553,"position":11,"arabic":"سَمْعًا","translation":"শুনতে","audioUrl":"wbw/018_101_011.mp3","charTypeName":"word"},{"id":71554,"position":12,"arabic":"١٠١","translation":"(১০১)","audioUrl":null,"charTypeName":"end"}]},{"number":102,"arabic":"أَفَحَسِبَ ٱلَّذِينَ كَفَرُوٓا۟ أَن يَتَّخِذُوا۟ عِبَادِى مِن دُونِىٓ أَوْلِيَآءَ ۚ إِنَّآ أَعْتَدْنَا جَهَنَّمَ لِلْكَٰفِرِينَ نُزُلًۭا","translation":"Do they who are bent on denying the truth think, perchance, that they could take [any of] My creatures for protectors against Me? Verily, We have readied hell to welcome all who [thus] deny the truth!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2242.mp3","surahId":18,"words":[{"id":71790,"position":1,"arabic":"أَفَحَسِبَ","translation":"কি মনে করেছে","audioUrl":"wbw/018_102_001.mp3","charTypeName":"word"},{"id":71791,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/018_102_002.mp3","charTypeName":"word"},{"id":71792,"position":3,"arabic":"كَفَرُوٓا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/018_102_003.mp3","charTypeName":"word"},{"id":71793,"position":4,"arabic":"أَن","translation":"যে","audioUrl":"wbw/018_102_004.mp3","charTypeName":"word"},{"id":71794,"position":5,"arabic":"يَتَّخِذُوا۟","translation":"তারা গ্রহণ করবে","audioUrl":"wbw/018_102_005.mp3","charTypeName":"word"},{"id":71795,"position":6,"arabic":"عِبَادِى","translation":"আমার দাসদেরকে","audioUrl":"wbw/018_102_006.mp3","charTypeName":"word"},{"id":71796,"position":7,"arabic":"مِن","translation":"ছাড়া","audioUrl":"wbw/018_102_007.mp3","charTypeName":"word"},{"id":71797,"position":8,"arabic":"دُونِىٓ","translation":"আমাকে","audioUrl":"wbw/018_102_008.mp3","charTypeName":"word"},{"id":71798,"position":9,"arabic":"أَوْلِيَآءَ ۚ","translation":"অভিভাবকরূপে","audioUrl":"wbw/018_102_009.mp3","charTypeName":"word"},{"id":71800,"position":10,"arabic":"إِنَّآ","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/018_102_011.mp3","charTypeName":"word"},{"id":71801,"position":11,"arabic":"أَعْتَدْنَا","translation":"আমরা প্রস্তুত করে রেখেছি","audioUrl":"wbw/018_102_012.mp3","charTypeName":"word"},{"id":71802,"position":12,"arabic":"جَهَنَّمَ","translation":"জাহান্নামকে","audioUrl":"wbw/018_102_013.mp3","charTypeName":"word"},{"id":71803,"position":13,"arabic":"لِلْكَـٰفِرِينَ","translation":"জন্যে কাফিরদের","audioUrl":"wbw/018_102_014.mp3","charTypeName":"word"},{"id":71804,"position":14,"arabic":"نُزُلًۭا","translation":"মেহমানদারী হিসেবে","audioUrl":"wbw/018_102_015.mp3","charTypeName":"word"},{"id":71805,"position":15,"arabic":"١٠٢","translation":"(১০২)","audioUrl":null,"charTypeName":"end"}]},{"number":103,"arabic":"قُلْ هَلْ نُنَبِّئُكُم بِٱلْأَخْسَرِينَ أَعْمَٰلًا","translation":"Say: \"Shall we tell you who are the greatest losers in whatever they may do?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2243.mp3","surahId":18,"words":[{"id":72370,"position":1,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/018_103_001.mp3","charTypeName":"word"},{"id":72371,"position":2,"arabic":"هَلْ","translation":"\"কি","audioUrl":"wbw/018_103_002.mp3","charTypeName":"word"},{"id":72372,"position":3,"arabic":"نُنَبِّئُكُم","translation":"খবর দিবো আমরা তোমাদেরকে","audioUrl":"wbw/018_103_003.mp3","charTypeName":"word"},{"id":72373,"position":4,"arabic":"بِٱلْأَخْسَرِينَ","translation":"সম্বন্ধে খুবই ক্ষতিগ্রস্তদের","audioUrl":"wbw/018_103_004.mp3","charTypeName":"word"},{"id":72374,"position":5,"arabic":"أَعْمَـٰلًا","translation":"কর্মসমূহে","audioUrl":"wbw/018_103_005.mp3","charTypeName":"word"},{"id":72375,"position":6,"arabic":"١٠٣","translation":"(১০৩)","audioUrl":null,"charTypeName":"end"}]},{"number":104,"arabic":"ٱلَّذِينَ ضَلَّ سَعْيُهُمْ فِى ٱلْحَيَوٰةِ ٱلدُّنْيَا وَهُمْ يَحْسَبُونَ أَنَّهُمْ يُحْسِنُونَ صُنْعًا","translation":"\"[It is] they whose labour has gone astray in [the pursuit of no more than] this world's life, and who none the less think that they are doing good works:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2244.mp3","surahId":18,"words":[{"id":72618,"position":1,"arabic":"ٱلَّذِينَ","translation":"যাদের","audioUrl":"wbw/018_104_001.mp3","charTypeName":"word"},{"id":72619,"position":2,"arabic":"ضَلَّ","translation":"পন্ড হয়েছে","audioUrl":"wbw/018_104_002.mp3","charTypeName":"word"},{"id":72620,"position":3,"arabic":"سَعْيُهُمْ","translation":"তাদের প্রচেষ্টা","audioUrl":"wbw/018_104_003.mp3","charTypeName":"word"},{"id":72621,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/018_104_004.mp3","charTypeName":"word"},{"id":72622,"position":5,"arabic":"ٱلْحَيَوٰةِ","translation":"জীবনের","audioUrl":"wbw/018_104_005.mp3","charTypeName":"word"},{"id":72623,"position":6,"arabic":"ٱلدُّنْيَا","translation":"পার্থিব","audioUrl":"wbw/018_104_006.mp3","charTypeName":"word"},{"id":72624,"position":7,"arabic":"وَهُمْ","translation":"অথচ তারা","audioUrl":"wbw/018_104_007.mp3","charTypeName":"word"},{"id":72625,"position":8,"arabic":"يَحْسَبُونَ","translation":"মনে করে","audioUrl":"wbw/018_104_008.mp3","charTypeName":"word"},{"id":72626,"position":9,"arabic":"أَنَّهُمْ","translation":"যে তারা","audioUrl":"wbw/018_104_009.mp3","charTypeName":"word"},{"id":72627,"position":10,"arabic":"يُحْسِنُونَ","translation":"উত্তম করছে","audioUrl":"wbw/018_104_010.mp3","charTypeName":"word"},{"id":72628,"position":11,"arabic":"صُنْعًا","translation":"কর্ম\"","audioUrl":"wbw/018_104_011.mp3","charTypeName":"word"},{"id":72629,"position":12,"arabic":"١٠٤","translation":"(১০৪)","audioUrl":null,"charTypeName":"end"}]},{"number":105,"arabic":"أُو۟لَٰٓئِكَ ٱلَّذِينَ كَفَرُوا۟ بِـَٔايَٰتِ رَبِّهِمْ وَلِقَآئِهِۦ فَحَبِطَتْ أَعْمَٰلُهُمْ فَلَا نُقِيمُ لَهُمْ يَوْمَ ٱلْقِيَٰمَةِ وَزْنًۭا","translation":"it is they who have chosen to deny their Sustainer's messages and the truth; that they are deseined to meet Him.\" Hence, all their [good] deeds come to nought, and no weight shall We assign to them on Resurrection Day.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2245.mp3","surahId":18,"words":[{"id":72776,"position":1,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐসব লোক","audioUrl":"wbw/018_105_001.mp3","charTypeName":"word"},{"id":72777,"position":2,"arabic":"ٱلَّذِينَ","translation":"(তারাই) যারা","audioUrl":"wbw/018_105_002.mp3","charTypeName":"word"},{"id":72778,"position":3,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/018_105_003.mp3","charTypeName":"word"},{"id":72779,"position":4,"arabic":"بِـَٔايَـٰتِ","translation":"নিদর্শনসমূহকে","audioUrl":"wbw/018_105_004.mp3","charTypeName":"word"},{"id":72780,"position":5,"arabic":"رَبِّهِمْ","translation":"তাদের রবের","audioUrl":"wbw/018_105_005.mp3","charTypeName":"word"},{"id":72781,"position":6,"arabic":"وَلِقَآئِهِۦ","translation":"ও তার সাক্ষাত","audioUrl":"wbw/018_105_006.mp3","charTypeName":"word"},{"id":72782,"position":7,"arabic":"فَحَبِطَت