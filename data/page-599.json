{"id":599,"ayahs":[{"number":8,"arabic":"جَزَآؤُهُمْ عِندَ رَبِّهِمْ جَنَّٰتُ عَدْنٍۢ تَجْرِى مِن تَحْتِهَا ٱلْأَنْهَٰرُ خَٰلِدِينَ فِيهَآ أَبَدًۭا ۖ رَّضِىَ ٱللَّهُ عَنْهُمْ وَرَضُوا۟ عَنْهُ ۚ ذَٰلِكَ لِمَنْ خَشِىَ رَبَّهُۥ","translation":"Their reward [awaits them] with God: gardens of perpetual bliss, through which running waters flow, therein to abide beyond the count of time; well-pleased is God with them, and well-pleased are they with Him: all this awaits him who of his Sustainer stands in awe!.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6138.mp3","surahId":98,"words":[{"id":9410,"position":1,"arabic":"جَزَآؤُهُمْ","translation":"তাদের পুরস্কার (রয়েছে)","audioUrl":"wbw/098_008_001.mp3","charTypeName":"word"},{"id":9411,"position":2,"arabic":"عِندَ","translation":"কাছে","audioUrl":"wbw/098_008_002.mp3","charTypeName":"word"},{"id":9412,"position":3,"arabic":"رَبِّهِمْ","translation":"তাদের রবের","audioUrl":"wbw/098_008_003.mp3","charTypeName":"word"},{"id":9413,"position":4,"arabic":"جَنَّـٰتُ","translation":"জান্নাত","audioUrl":"wbw/098_008_004.mp3","charTypeName":"word"},{"id":9414,"position":5,"arabic":"عَدْنٍۢ","translation":"চিরস্থায়ী","audioUrl":"wbw/098_008_005.mp3","charTypeName":"word"},{"id":9415,"position":6,"arabic":"تَجْرِى","translation":"প্রবাহিত হয়","audioUrl":"wbw/098_008_006.mp3","charTypeName":"word"},{"id":9416,"position":7,"arabic":"مِن","translation":"দিয়ে","audioUrl":"wbw/098_008_007.mp3","charTypeName":"word"},{"id":9417,"position":8,"arabic":"تَحْتِهَا","translation":"তার তলদেশ","audioUrl":"wbw/098_008_008.mp3","charTypeName":"word"},{"id":9418,"position":9,"arabic":"ٱلْأَنْهَـٰرُ","translation":"ঝর্ণা ধারা","audioUrl":"wbw/098_008_009.mp3","charTypeName":"word"},{"id":9419,"position":10,"arabic":"خَـٰلِدِينَ","translation":"চিরস্থায়ী হবে","audioUrl":"wbw/098_008_010.mp3","charTypeName":"word"},{"id":9420,"position":11,"arabic":"فِيهَآ","translation":"তার মধ্যে","audioUrl":"wbw/098_008_011.mp3","charTypeN