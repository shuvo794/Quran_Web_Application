sition":7,"arabic":"يَخْرُجُ","translation":"বের হয়","audioUrl":"wbw/034_002_007.mp3","charTypeName":"word"},{"id":1912,"position":8,"arabic":"مِنْهَا","translation":"থেকে তা","audioUrl":"wbw/034_002_008.mp3","charTypeName":"word"},{"id":1913,"position":9,"arabic":"وَمَا","translation":"এবং যা কিছু","audioUrl":"wbw/034_002_009.mp3","charTypeName":"word"},{"id":1914,"position":10,"arabic":"يَنزِلُ","translation":"নামে (অবতীর্ণ হয়)","audioUrl":"wbw/034_002_010.mp3","charTypeName":"word"},{"id":1915,"position":11,"arabic":"مِنَ","translation":"থেকে","audioUrl":"wbw/034_002_011.mp3","charTypeName":"word"},{"id":1916,"position":12,"arabic":"ٱلسَّمَآءِ","translation":"আকাশ","audioUrl":"wbw/034_002_012.mp3","charTypeName":"word"},{"id":1917,"position":13,"arabic":"وَمَا","translation":"আর যা কিছু","audioUrl":"wbw/034_002_013.mp3","charTypeName":"word"},{"id":1918,"position":14,"arabic":"يَعْرُجُ","translation":"উত্থিত হয়","audioUrl":"wbw/034_002_014.mp3","charTypeName":"word"},{"id":1919,"position":15,"arabic":"فِيهَا ۚ","translation":"মধ্যে তার","audioUrl":"wbw/034_002_015.mp3","charTypeName":"word"},{"id":1921,"position":16,"arabic":"وَهُوَ","translation":"এবং তিনিই","audioUrl":"wbw/034_002_017.mp3","charTypeName":"word"},{"id":1922,"position":17,"arabic":"ٱلرَّحِيمُ","translation":"পরম দয়ালু","audioUrl":"wbw/034_002_018.mp3","charTypeName":"word"},{"id":1923,"position":18,"arabic":"ٱلْغَفُورُ","translation":"ক্ষমাশীল","audioUrl":"wbw/034_002_019.mp3","charTypeName":"word"},{"id":1924,"position":19,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"وَقَالَ ٱلَّذِينَ كَفَرُوا۟ لَا تَأْتِينَا ٱلسَّاعَةُ ۖ قُلْ بَلَىٰ وَرَبِّى لَتَأْتِيَنَّكُمْ عَٰلِمِ ٱلْغَيْبِ ۖ لَا يَعْزُبُ عَنْهُ مِثْقَالُ ذَرَّةٍۢ فِى ٱلسَّمَٰوَٰتِ وَلَا فِى ٱلْأَرْضِ وَلَآ أَصْغَرُ مِن ذَٰلِكَ وَلَآ أَكْبَرُ إِلَّا فِى كِتَٰبٍۢ مُّبِينٍۢ","translation":"And yet, they who are bent on denying the truth assert, “Never will the Last Hour come upon us!” Say: “Nay, by my Sustainer! By Him who knows all that is beyond the reach of a created being’s perception: it will most certainly come upon you!” Not an atom’s weight [of whatever there is] in the heavens or on earth escapes His knowledge; and neither is there anything smaller than that, or larger, but is recorded in [His] clear decree,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3609.mp3","surahId":34,"words":[{"id":3097,"position":1,"arabic":"وَقَالَ","translation":"এবং বলে","audioUrl":"wbw/034_003_001.mp3","charTypeName":"word"},{"id":3098,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/034_003_002.mp3","charTypeName":"word"},{"id":3099,"position":3,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/034_003_003.mp3","charTypeName":"word"},{"id":3100,"position":4,"arabic":"لَا","translation":"\"(কেন) না","audioUrl":"wbw/034_003_004.mp3","charTypeName":"word"},{"id":3101,"position":5,"arabic":"تَأْتِينَا","translation":"উপর আসছে আমাদের","audioUrl":"wbw/034_003_005.mp3","charTypeName":"word"},{"id":3102,"position":6,"arabic":"ٱلسَّاعَةُ ۖ","translation":"ক্বিয়ামাত\"","audioUrl":"wbw/034_003_006.mp3","charTypeName":"word"},{"id":3104,"position":7,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/034_003_008.mp3","charTypeName":"word"},{"id":3105,"position":8,"arabic":"بَلَىٰ","translation":"\"কেন না নিশ্চয়ই","audioUrl":"wbw/034_003_009.mp3","charTypeName":"word"},{"id":3106,"position":9,"arabic":"وَرَبِّى","translation":"শপথ আমার রবের","audioUrl":"wbw/034_003_010.mp3","charTypeName":"word"},{"id":3107,"position":10,"arabic":"لَتَأْتِيَنَّكُمْ","translation":"অবশ্যই উপর আসবেই তোমাদের","audioUrl":"wbw/034_003_011.mp3","charTypeName":"word"},{"id":3108,"position":11,"arabic":"عَـٰلِمِ","translation":"(আমার রব)জ্ঞানী","audioUrl":"wbw/034_003_012.mp3","charTypeName":"word"},{"id":3109,"position":12,"arabic":"ٱلْغَيْبِ ۖ","translation":"অদৃশ্যের (ব্যাপারে)\"","audioUrl":"wbw/034_003_013.mp3","charTypeName":"word"},{"id":3111,"position":13,"arabic":"لَا","translation":"না","audioUrl":"wbw/034_003_015.mp3","charTypeName":"word"},{"id":3112,"position":14,"arabic":"يَعْزُبُ","translation":"লুকায়িত আছে","audioUrl":"wbw/034_003_016.mp3","charTypeName":"word"},{"id":3113,"position":15,"arabic":"عَنْهُ","translation":"থেকে তাঁর","audioUrl":"wbw/034_003_017.mp3","charTypeName":"word"},{"id":3114,"position":16,"arabic":"مِثْقَالُ","translation":"(কিছু) পরিমাণও","audioUrl":"wbw/034_003_018.mp3","charTypeName":"word"},{"id":3115,"position":17,"arabic":"ذَرَّةٍۢ","translation":"কোনো অণুর","audioUrl":"wbw/034_003_019.mp3","charTypeName":"word"},{"id":3116,"position":18,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/034_003_020.mp3","charTypeName":"word"},{"id":3117,"position":19,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশসমূহের","audioUrl":"wbw/034_003_021.mp3","charTypeName":"word"},{"id":3118,"position":20,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/034_003_022.mp3","charTypeName":"word"},{"id":3119,"position":21,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/034_003_023.mp3","charTypeName":"word"},{"id":3120,"position":22,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/034_003_024.mp3","charTypeName":"word"},{"id":3121,"position":23,"arabic":"وَلَآ","translation":"এবং না","audioUrl":"wbw/034_003_025.mp3","charTypeName":"word"},{"id":3122,"position":24,"arabic":"أَصْغَرُ","translation":"ক্ষুদ্রতর","audioUrl":"wbw/034_003_026.mp3","charTypeName":"word"},{"id":3123,"position":25,"arabic":"مِن","translation":"চেয়েও","audioUrl":"wbw/034_003_027.mp3","charTypeName":"word"},{"id":3124,"position":26,"arabic":"ذَٰلِكَ","translation":"সেটার","audioUrl":"wbw/034_003_028.mp3","charTypeName":"word"},{"id":3125,"position":27,"arabic":"وَلَآ","translation":"আর না","audioUrl":"wbw/034_003_029.mp3","charTypeName":"word"},{"id":3126,"position":28,"arabic":"أَكْبَرُ","translation":"বৃহত্তর","audioUrl":"wbw/034_003_030.mp3","charTypeName":"word"},{"id":3127,"position":29,"arabic":"إِلَّا","translation":"কিন্তু","audioUrl":"wbw/034_003_031.mp3","charTypeName":"word"},{"id":3128,"position":30,"arabic":"فِى","translation":"মধ্যে (আছে)","audioUrl":"wbw/034_003_032.mp3","charTypeName":"word"},{"id":3129,"position":31,"arabic":"كِتَـٰبٍۢ","translation":"(লিখিত) একটি কিতাবের","audioUrl":"wbw/034_003_033.mp3","charTypeName":"word"},{"id":3130,"position":32,"arabic":"مُّبِينٍۢ","translation":"সুস্পষ্ট","audioUrl":"wbw/034_003_034.mp3","charTypeName":"word"},{"id":3131,"position":33,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"لِّيَجْزِىَ ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ ۚ أُو۟لَٰٓئِكَ لَهُم مَّغْفِرَةٌۭ وَرِزْقٌۭ كَرِيمٌۭ","translation":"to the end that He may reward those who believe and do right­eous deeds: [for] it is they whom forgiveness of sins awaits, and a most excellent sustenance","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3610.mp3","surahId":34,"words":[{"id":4495,"position":1,"arabic":"لِّيَجْزِىَ","translation":"(ক্বিয়ামাত এজন্যে) যেন তিনি পুরস্কার দেন","audioUrl":"wbw/034_004_001.mp3","charTypeName":"word"},{"id":4496,"position":2,"arabic":"ٱلَّذِينَ","translation":"(তাদেরকে) যারা","audioUrl":"wbw/034_004_002.mp3","charTypeName":"word"},{"id":4497,"position":3,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/034_004_003.mp3","charTypeName":"word"},{"id":4498,"position":4,"arabic":"وَعَمِلُوا۟","translation":"ও কাজ করেছে","audioUrl":"wbw/034_004_004.mp3","charTypeName":"word"},{"id":4499,"position":5,"arabic":"ٱلصَّـٰلِحَـٰتِ ۚ","translation":"সৎ","audioUrl":"wbw/034_004_005.mp3","charTypeName":"word"},{"id":4501,"position":6,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐসব (লোক)","audioUrl":"wbw/034_004_007.mp3","charTypeName":"word"},{"id":4502,"position":7,"arabic":"لَهُم","translation":"জন্যে তাদের (রয়েছে)","audioUrl":"wbw/034_004_008.mp3","charTypeName":"word"},{"id":4503,"position":8,"arabic":"مَّغْفِرَةٌۭ","translation":"ক্ষমা","audioUrl":"wbw/034_004_009.mp3","charTypeName":"word"},{"id":4504,"position":9,"arabic":"وَرِزْقٌۭ","translation":"ও জীবিকা","audioUrl":"wbw/034_004_010.mp3","charTypeName":"word"},{"id":4505,"position":10,"arabic":"كَرِيمٌۭ","translation":"সম্মানজনক","audioUrl":"wbw/034_004_011.mp3","charTypeName":"word"},{"id":4506,"position":11,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"وَٱلَّذِينَ سَعَوْ فِىٓ ءَايَٰتِنَا مُعَٰجِزِينَ أُو۟لَٰٓئِكَ لَهُمْ عَذَابٌۭ مِّن رِّجْزٍ أَلِيمٌۭ","translation":"whereas for those who strive against Our messages, seeking to defeat their purpose, there is grievous suffering in store as an outcome of [their] vileness.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3611.mp3","surahId":34,"words":[{"id":5753,"position":1,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/034_005_001.mp3","charTypeName":"word"},{"id":5754,"position":2,"arabic":"سَعَوْ","translation":"চেষ্টা করে","audioUrl":"wbw/034_005_002.mp3","charTypeName":"word"},{"id":5755,"position":3,"arabic":"فِىٓ","translation":"ক্ষেত্রে","audioUrl":"wbw/034_005_003.mp3","charTypeName":"word"},{"id":5756,"position":4,"arabic":"ءَايَـٰتِنَا","translation":"আয়াতগুলোর আমাদের","audioUrl":"wbw/034_005_004.mp3","charTypeName":"word"},{"id":5757,"position":5,"arabic":"مُعَـٰجِزِينَ","translation":"ব্যর্থ প্রমাণ করতে","audioUrl":"wbw/034_005_005.mp3","charTypeName":"word"},{"id":5758,"position":6,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐসব (লোক)","audioUrl":"wbw/034_005_006.mp3","charTypeName":"word"},{"id":5759,"position":7,"arabic":"لَهُمْ","translation":"জন্যে তাদের(রয়েছে)","audioUrl":"wbw/034_005_007.mp3","charTypeName":"word"},{"id":5760,"position":8,"arabic":"عَذَابٌۭ","translation":"শাস্তি","audioUrl":"wbw/034_005_008.mp3","charTypeName":"word"},{"id":5761,"position":9,"arabic":"مِّن","translation":"ধরণের","audioUrl":"wbw/034_005_009.mp3","charTypeName":"word"},{"id":5762,"position":10,"arabic":"رِّجْزٍ","translation":"ভয়ংকর","audioUrl":"wbw/034_005_010.mp3","charTypeName":"word"},{"id":5763,"position":11,"arabic":"أَلِيمٌۭ","translation":"নির্মম","audioUrl":"wbw/034_005_011.mp3","charTypeName":"word"},{"id":5764,"position":12,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"وَيَرَى ٱلَّذِينَ أُوتُوا۟ ٱلْعِلْمَ ٱلَّذِىٓ أُنزِلَ إِلَيْكَ مِن رَّبِّكَ هُوَ ٱلْحَقَّ وَيَهْدِىٓ إِلَىٰ صِرَٰطِ ٱلْعَزِيزِ ٱلْحَمِيدِ","translation":"NOW THEY who are endowed with [innate] knowl­edge are well aware that whatever has been be­stowed upon thee from on high by thy Sustainer is indeed the truth, and that it guides onto the way that leads to the Almighty, the One to whom all praise is due!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3612.mp3","surahId":34,"words":[{"id":7037,"position":1,"arabic":"وَيَرَى","translation":"এবং জানে","audioUrl":"wbw/034_006_001.mp3","charTypeName":"word"},{"id":7038,"position":2,"arabic":"ٱلَّذِينَ","translation":"(তারা) যাদের","audioUrl":"wbw/034_006_002.mp3","charTypeName":"word"},{"id":7039,"position":3,"arabic":"أُوتُوا۟","translation":"দেয়া হয়েছে","audioUrl":"wbw/034_006_003.mp3","charTypeName":"word"},{"id":7040,"position":4,"arabic":"ٱلْعِلْمَ","translation":"জ্ঞান","audioUrl":"wbw/034_006_004.mp3","charTypeName":"word"},{"id":7041,"position":5,"arabic":"ٱلَّذِىٓ","translation":"যা","audioUrl":"wbw/034_006_005.mp3","charTypeName":"word"},{"id":7042,"position":6,"arabic":"أُنزِلَ","translation":"অবতীর্ণ করা হয়েছে","audioUrl":"wbw/034_006_006.mp3","charTypeName":"word"},{"id":7043,"position":7,"arabic":"إِلَيْكَ","translation":"প্রতি তোমার","audioUrl":"wbw/034_006_007.mp3","charTypeName":"word"},{"id":7044,"position":8,"arabic":"مِن","translation":"পক্ষ হ'তে","audioUrl":"wbw/034_006_008.mp3","charTypeName":"word"},{"id":7045,"position":9,"arabic":"رَّبِّكَ","translation":"তোমার রবের","audioUrl":"wbw/034_006_009.mp3","charTypeName":"word"},{"id":7046,"position":10,"arabic":"هُوَ","translation":"তা","audioUrl":"wbw/034_006_010.mp3","charTypeName":"word"},{"id":7047,"position":11,"arabic":"ٱلْحَقَّ","translation":"সত্য","audioUrl":"wbw/034_006_011.mp3","charTypeName":"word"},{"id":7048,"position":12,"arabic":"وَيَهْدِىٓ","translation":"এবং তা পথ দেখায়","audioUrl":"wbw/034_006_012.mp3","charTypeName":"word"},{"id":7049,"position":13,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/034_006_013.mp3","charTypeName":"word"},{"id":7050,"position":14,"arabic":"صِرَٰطِ","translation":"পথের","audioUrl":"wbw/034_006_014.mp3","charTypeName":"word"},{"id":7051,"position":15,"arabic":"ٱلْعَزِيزِ","translation":"পরাক্রমশালী (রবের)","audioUrl":"wbw/034_006_015.mp3","charTypeName":"word"},{"id":7052,"position":16,"arabic":"ٱلْحَمِيدِ","translation":"(যিনি) প্রশংসিত","audioUrl":"wbw/034_006_016.mp3","charTypeName":"word"},{"id":7053,"position":17,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"وَقَالَ ٱلَّذِينَ كَفَرُوا۟ هَلْ نَدُلُّكُمْ عَلَىٰ رَجُلٍۢ يُنَبِّئُكُمْ إِذَا مُزِّقْتُمْ كُلَّ مُمَزَّقٍ إِنَّكُمْ لَفِى خَلْقٍۢ جَدِيدٍ","translation":"As against this, they who are bent on denying the truth say [unto all who are of like mind]: “Shall we point out to you a man who will tell you that [after your death,] when you will have been scattered in countless fragments, you shall - lo and behold! - be [restored to life] in a new act of creation?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3613.mp3","surahId":34,"words":[{"id":8337,"position":1,"arabic":"وَقَالَ","translation":"এবং বলে","audioUrl":"wbw/034_007_001.mp3","charTypeName":"word"},{"id":8338,"position":2,"arabic":"ٱلَّذِينَ","translation":"(তারা) যারা","audioUrl":"wbw/034_007_002.mp3","charTypeName":"word"},{"id":8339,"position":3,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/034_007_003.mp3","charTypeName":"word"},{"id":8340,"position":4,"arabic":"هَلْ","translation":"\"কি","audioUrl":"wbw/034_007_004.mp3","charTypeName":"word"},{"id":8341,"position":5,"arabic":"نَدُلُّكُمْ","translation":"আমরা সন্ধান দিবো তোমাদেরকে","audioUrl":"wbw/034_007_005.mp3","charTypeName":"word"},{"id":8342,"position":6,"arabic":"عَلَىٰ","translation":"সম্পর্কে","audioUrl":"wbw/034_007_006.mp3","charTypeName":"word"},{"id":8343,"position":7,"arabic":"رَجُلٍۢ","translation":"এক ব্যক্তির","audioUrl":"wbw/034_007_007.mp3","charTypeName":"word"},{"id":8344,"position":8,"arabic":"يُنَبِّئُكُمْ","translation":"যে জানিয়ে দিবে তোমাদেরকে","audioUrl":"wbw/034_007_008.mp3","charTypeName":"word"},{"id":8345,"position":9,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/034_007_009.mp3","charTypeName":"word"},{"id":8346,"position":10,"arabic":"مُزِّقْتُمْ","translation":"ছিন্ন-বিচ্ছিন্ন করা হবে তোমাদেরকে","audioUrl":"wbw/034_007_010.mp3","charTypeName":"word"},{"id":8347,"position":11,"arabic":"كُلَّ","translation":"সম্পূর্ণ","audioUrl":"wbw/034_007_011.mp3","charTypeName":"word"},{"id":8348,"position":12,"arabic":"مُمَزَّقٍ","translation":"খুব ছিন্ন-বিচ্ছিন্ন","audioUrl":"wbw/034_007_012.mp3","charTypeName":"word"},{"id":8349,"position":13,"arabic":"إِنَّكُمْ","translation":"নিশ্চয়ই তোমরা(হবে)","audioUrl":"wbw/034_007_013.mp3","charTypeName":"word"},{"id":8350,"position":14,"arabic":"لَفِى","translation":"অবশ্যই মধ্যে","audioUrl":"wbw/034_007_014.mp3","charTypeName":"word"},{"id":8351,"position":15,"arabic":"خَلْقٍۢ","translation":"সৃষ্টির","audioUrl":"wbw/034_007_015.mp3","charTypeName":"word"},{"id":8352,"position":16,"arabic":"جَدِيدٍ","translation":"নতুন (অর্থাৎ উত্থিত হবে?)","audioUrl":"wbw/034_007_016.mp3","charTypeName":"word"},{"id":8353,"position":17,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]}]}