{"id":428,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ ٱلْحَمْدُ لِلَّهِ ٱلَّذِى لَهُۥ مَا فِى ٱلسَّمَٰوَٰتِ وَمَا فِى ٱلْأَرْضِ وَلَهُ ٱلْحَمْدُ فِى ٱلْءَاخِرَةِ ۚ وَهُوَ ٱلْحَكِيمُ ٱلْخَبِيرُ","translation":"ALL PRAISE is due to God, to whom all that is in the heavens and all that is on earth belongs; and to Him will be due all praise in the life to come. For He alone is truly wise, all-aware:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3607.mp3","surahId":34,"words":[{"id":841,"position":1,"arabic":"ٱلْحَمْدُ","translation":"সমস্ত প্রশংসা","audioUrl":"wbw/034_001_001.mp3","charTypeName":"word"},{"id":842,"position":2,"arabic":"لِلَّهِ","translation":"জন্যে আল্লাহর","audioUrl":"wbw/034_001_002.mp3","charTypeName":"word"},{"id":843,"position":3,"arabic":"ٱلَّذِى","translation":"যিনি (এমন সত্ত্বা)","audioUrl":"wbw/034_001_003.mp3","charTypeName":"word"},{"id":844,"position":4,"arabic":"لَهُۥ","translation":"জন্যে তাঁরই (মালিকানায়)","audioUrl":"wbw/034_001_004.mp3","charTypeName":"word"},{"id":845,"position":5,"arabic":"مَا","translation":"যা কিছু","audioUrl":"wbw/034_001_005.mp3","charTypeName":"word"},{"id":846,"position":6,"arabic":"فِى","translation":"মধ্যে (আছে)","audioUrl":"wbw/034_001_006.mp3","charTypeName":"word"},{"id":847,"position":7,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশমন্ডলীর","audioUrl":"wbw/034_001_007.mp3","charTypeName":"word"},{"id":848,"position":8,"arabic":"وَمَا","translation":"আর যা কিছু","audioUrl":"wbw/034_001_008.mp3","charTypeName":"word"},{"id":849,"position":9,"arabic":"فِى","translation":"মধ্যে (আছে)","audioUrl":"wbw/034_001_009.mp3","charTypeName":"word"},{"id":850,"position":10,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/034_001_010.mp3","charTypeName":"word"},{"id":851,"position":11,"arabic":"وَلَهُ","translation":"এবং জন্যে তাঁরই","audioUrl":"wbw/034_001_011.mp3","charTypeName":"word"},{"id":852,"position":12,"arabic":"ٱلْحَمْدُ","translation":"সকল প্রশংসা","audi