{"id":293,"ayahs":[{"number":105,"arabic":"وَبِٱلْحَقِّ أَنزَلْنَٰهُ وَبِٱلْحَقِّ نَزَلَ ۗ وَمَآ أَرْسَلْنَٰكَ إِلَّا مُبَشِّرًۭا وَنَذِيرًۭا","translation":"AND AS a guide towards the truth have We bestowed this [revelation] from on high; with this [very] truth has it come down [unto thee, O Prophet]: for We have sent thee but as a herald of glad tidings and a warner,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2134.mp3","surahId":17,"words":[{"id":72726,"position":1,"arabic":"وَبِٱلْحَقِّ","translation":"এবং সহ সত্য","audioUrl":"wbw/017_105_001.mp3","charTypeName":"word"},{"id":72727,"position":2,"arabic":"أَنزَلْنَـٰهُ","translation":"তা আমরা অবতীর্ণ করেছি","audioUrl":"wbw/017_105_002.mp3","charTypeName":"word"},{"id":72728,"position":3,"arabic":"وَبِٱلْحَقِّ","translation":"এবং সহ সত্য","audioUrl":"wbw/017_105_003.mp3","charTypeName":"word"},{"id":72729,"position":4,"arabic":"نَزَلَ ۗ","translation":"অবতীর্ণ হয়েছে","audioUrl":"wbw/017_105_004.mp3","charTypeName":"word"},{"id":72731,"position":5,"arabic":"وَمَآ","translation":"এবং নি","audioUrl":"wbw/017_105_006.mp3","charTypeName":"word"},{"id":72732,"position":6,"arabic":"أَرْسَلْنَـٰكَ","translation":"তোমাকে আমরা পাঠিয়েছি","audioUrl":"wbw/017_105_007.mp3","charTypeName":"word"},{"id":72733,"position":7,"arabic":"إِلَّا","translation":"এছাড়া","audioUrl":"wbw/017_105_008.mp3","charTypeName":"word"},{"id":72734,"position":8,"arabic":"مُبَشِّرًۭا","translation":"সুসংবাদদাতা হিসেবে","audioUrl":"wbw/017_105_009.mp3","charTypeName":"word"},{"id":72735,"position":9,"arabic":"وَنَذِيرًۭا","translation":"ও সতর্ককারী হিসেবে","audioUrl":"wbw/017_105_010.mp3","charTypeName":"word"},{"id":72736,"position":10,"arabic":"١٠٥","translation":"(১০৫)","audioUrl":null,"charTypeName":"end"}]},{"number":106,"arabic":"وَقُرْءَانًۭا فَرَقْنَٰهُ لِتَقْرَأَهُۥ عَلَى ٱلنَّاسِ عَلَىٰ مُكْثٍۢ وَنَزَّلْنَٰهُ تَنزِيلًۭا","translation":"[bearing] a discourse which We have gradually unfolded, so that thou might read it ou