[{"id":73393,"position":1,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/017_107_001.mp3","charTypeName":"word"},{"id":73394,"position":2,"arabic":"ءَامِنُوا۟","translation":"\"ঈমান আনো","audioUrl":"wbw/017_107_002.mp3","charTypeName":"word"},{"id":73395,"position":3,"arabic":"بِهِۦٓ","translation":"উপর এর","audioUrl":"wbw/017_107_003.mp3","charTypeName":"word"},{"id":73396,"position":4,"arabic":"أَوْ","translation":"বা","audioUrl":"wbw/017_107_004.mp3","charTypeName":"word"},{"id":73397,"position":5,"arabic":"لَا","translation":"না","audioUrl":"wbw/017_107_005.mp3","charTypeName":"word"},{"id":73398,"position":6,"arabic":"تُؤْمِنُوٓا۟ ۚ","translation":"তোমরা ঈমান আনো","audioUrl":"wbw/017_107_006.mp3","charTypeName":"word"},{"id":73400,"position":7,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/017_107_008.mp3","charTypeName":"word"},{"id":73401,"position":8,"arabic":"ٱلَّذِينَ","translation":"যাদেরকে","audioUrl":"wbw/017_107_009.mp3","charTypeName":"word"},{"id":73402,"position":9,"arabic":"أُوتُوا۟","translation":"দেয়া হয়েছে","audioUrl":"wbw/017_107_010.mp3","charTypeName":"word"},{"id":73403,"position":10,"arabic":"ٱلْعِلْمَ","translation":"জ্ঞান","audioUrl":"wbw/017_107_011.mp3","charTypeName":"word"},{"id":73404,"position":11,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/017_107_012.mp3","charTypeName":"word"},{"id":73405,"position":12,"arabic":"قَبْلِهِۦٓ","translation":"পূর্ব এর","audioUrl":"wbw/017_107_013.mp3","charTypeName":"word"},{"id":73406,"position":13,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/017_107_014.mp3","charTypeName":"word"},{"id":73407,"position":14,"arabic":"يُتْلَىٰ","translation":"পাঠ করা হয়","audioUrl":"wbw/017_107_015.mp3","charTypeName":"word"},{"id":73408,"position":15,"arabic":"عَلَيْهِمْ","translation":"কাছে তাদের","audioUrl":"wbw/017_107_016.mp3","charTypeName":"word"},{"id":73409,"position":16,"arabic":"يَخِرُّونَ","translation":"তারা লুটিয়ে পড়ে যায়","audioUrl":"wbw/017_107_017.mp3","charTypeName":"w