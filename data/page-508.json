{"id":508,"ayahs":[{"number":12,"arabic":"إِنَّ ٱللَّهَ يُدْخِلُ ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ جَنَّٰتٍۢ تَجْرِى مِن تَحْتِهَا ٱلْأَنْهَٰرُ ۖ وَٱلَّذِينَ كَفَرُوا۟ يَتَمَتَّعُونَ وَيَأْكُلُونَ كَمَا تَأْكُلُ ٱلْأَنْعَٰمُ وَٱلنَّارُ مَثْوًۭى لَّهُمْ","translation":"Verily, God will admit all who attain to faith and do righteous deeds into gardens through which running waters flow, whereas they who are bent on denying the truth shall have - even though they may enjoy their life [in this world] and eat as cattle eat - the fire [of the hereafter] for their abode.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4557.mp3","surahId":47,"words":[{"id":13654,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/047_012_001.mp3","charTypeName":"word"},{"id":13655,"position":2,"arabic":"ٱللَّهَ","translation":"আল্লাহ্‌","audioUrl":"wbw/047_012_002.mp3","charTypeName":"word"},{"id":13656,"position":3,"arabic":"يُدْخِلُ","translation":"প্রবেশ করাবেন","audioUrl":"wbw/047_012_003.mp3","charTypeName":"word"},{"id":13657,"position":4,"arabic":"ٱلَّذِينَ","translation":"(তাদেরকে) যারা","audioUrl":"wbw/047_012_004.mp3","charTypeName":"word"},{"id":13658,"position":5,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/047_012_005.mp3","charTypeName":"word"},{"id":13659,"position":6,"arabic":"وَعَمِلُوا۟","translation":"ও কাজ করেছে","audioUrl":"wbw/047_012_006.mp3","charTypeName":"word"},{"id":13660,"position":7,"arabic":"ٱلصَّـٰلِحَـٰتِ","translation":"সৎকর্ম","audioUrl":"wbw/047_012_007.mp3","charTypeName":"word"},{"id":13661,"position":8,"arabic":"جَنَّـٰتٍۢ","translation":"জান্নাতে","audioUrl":"wbw/047_012_008.mp3","charTypeName":"word"},{"id":13662,"position":9,"arabic":"تَجْرِى","translation":"প্র্রবাহিত হয়","audioUrl":"wbw/047_012_009.mp3","charTypeName":"word"},{"id":13663,"position":10,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/047_012_010.mp3","charTypeName":"word"},{"id":13664,"position":11,"arabic":"تَ