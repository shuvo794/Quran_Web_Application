audio/128/ar.alafasy/4558.mp3","surahId":47,"words":[{"id":14842,"position":1,"arabic":"وَكَأَيِّن","translation":"এবং কতই না","audioUrl":"wbw/047_013_001.mp3","charTypeName":"word"},{"id":14843,"position":2,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/047_013_002.mp3","charTypeName":"word"},{"id":14844,"position":3,"arabic":"قَرْيَةٍ","translation":"জনপদ (বিলীন হয়েছে)","audioUrl":"wbw/047_013_003.mp3","charTypeName":"word"},{"id":14845,"position":4,"arabic":"هِىَ","translation":"যা (ছিল)","audioUrl":"wbw/047_013_004.mp3","charTypeName":"word"},{"id":14846,"position":5,"arabic":"أَشَدُّ","translation":"অধিকতর দৃঢ়","audioUrl":"wbw/047_013_005.mp3","charTypeName":"word"},{"id":14847,"position":6,"arabic":"قُوَّةًۭ","translation":"শক্তিতে","audioUrl":"wbw/047_013_006.mp3","charTypeName":"word"},{"id":14848,"position":7,"arabic":"مِّن","translation":"চেয়েও","audioUrl":"wbw/047_013_007.mp3","charTypeName":"word"},{"id":14849,"position":8,"arabic":"قَرْيَتِكَ","translation":"তোমার জনপদের","audioUrl":"wbw/047_013_008.mp3","charTypeName":"word"},{"id":14850,"position":9,"arabic":"ٱلَّتِىٓ","translation":"যা (হতে)","audioUrl":"wbw/047_013_009.mp3","charTypeName":"word"},{"id":14851,"position":10,"arabic":"أَخْرَجَتْكَ","translation":"তোমাকে বের করেছে","audioUrl":"wbw/047_013_010.mp3","charTypeName":"word"},{"id":14852,"position":11,"arabic":"أَهْلَكْنَـٰهُمْ","translation":"আমরা তাদেরকে ধ্বংস করে দিয়েছি","audioUrl":"wbw/047_013_011.mp3","charTypeName":"word"},{"id":14853,"position":12,"arabic":"فَلَا","translation":"অতঃপর না  (ছিল)","audioUrl":"wbw/047_013_012.mp3","charTypeName":"word"},{"id":14854,"position":13,"arabic":"نَاصِرَ","translation":"কোনো সাহায্যকারী","audioUrl":"wbw/047_013_013.mp3","charTypeName":"word"},{"id":14855,"position":14,"arabic":"لَهُمْ","translation":"তাদের জন্যে","audioUrl":"wbw/047_013_014.mp3","charTypeName":"word"},{"id":14856,"position":15,"arabic":"١٣","translation":"(১৩)","audioUrl":null,"charTypeName":"end"}]},{"number":14,"arabic":"أَفَمَن كَانَ عَلَىٰ بَيِّنَةٍۢ مِّن رَّبِّهِۦ كَمَن زُيِّنَ لَهُۥ سُوٓءُ عَمَلِهِۦ وَٱتَّبَعُوٓا۟ أَهْوَآءَهُم","translation":"CAN, THEN, he who takes his stand on a clear evidence from his Sustainer be likened Unto one to whom the evil of his own doings [always] seems goodly, and unto such as would follow but their own lusts?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4559.mp3","surahId":47,"words":[{"id":15912,"position":1,"arabic":"أَفَمَن","translation":"তবে কি যে","audioUrl":"wbw/047_014_001.mp3","charTypeName":"word"},{"id":15913,"position":2,"arabic":"كَانَ","translation":"হয়","audioUrl":"wbw/047_014_002.mp3","charTypeName":"word"},{"id":15914,"position":3,"arabic":"عَلَىٰ","translation":"(হেদায়াতের) উপর","audioUrl":"wbw/047_014_003.mp3","charTypeName":"word"},{"id":15915,"position":4,"arabic":"بَيِّنَةٍۢ","translation":"সুস্পষ্ট","audioUrl":"wbw/047_014_004.mp3","charTypeName":"word"},{"id":15916,"position":5,"arabic":"مِّن","translation":"পক্ষ হতে","audioUrl":"wbw/047_014_005.mp3","charTypeName":"word"},{"id":15917,"position":6,"arabic":"رَّبِّهِۦ","translation":"তার রবের","audioUrl":"wbw/047_014_006.mp3","charTypeName":"word"},{"id":15918,"position":7,"arabic":"كَمَن","translation":"(তার) মতো যাকে","audioUrl":"wbw/047_014_007.mp3","charTypeName":"word"},{"id":15919,"position":8,"arabic":"زُيِّنَ","translation":"শোভনীয় করা হয়েছে","audioUrl":"wbw/047_014_008.mp3","charTypeName":"word"},{"id":15920,"position":9,"arabic":"لَهُۥ","translation":"তার জন্যে","audioUrl":"wbw/047_014_009.mp3","charTypeName":"word"},{"id":15921,"position":10,"arabic":"سُوٓءُ","translation":"খারাপ","audioUrl":"wbw/047_014_010.mp3","charTypeName":"word"},{"id":15922,"position":11,"arabic":"عَمَلِهِۦ","translation":"তার কাজকে","audioUrl":"wbw/047_014_011.mp3","charTypeName":"word"},{"id":15923,"position":12,"arabic":"وَٱتَّبَعُوٓا۟","translation":"এবং তারা অনুসরণ করেছে","audioUrl":"wbw/047_014_012.mp3","charTypeName":"word"},{"id":15924,"position":13,"arabic":"أَهْوَآءَهُم","translation":"তাদের খেয়াল খুশির","audioUrl":"wbw/047_014_013.mp3","charTypeName":"word"},{"id":15925,"position":14,"arabic":"١٤","translation":"(১৪)","audioUrl":null,"charTypeName":"end"}]},{"number":15,"arabic":"مَّثَلُ ٱلْجَنَّةِ ٱلَّتِى وُعِدَ ٱلْمُتَّقُونَ ۖ فِيهَآ أَنْهَٰرٌۭ مِّن مَّآءٍ غَيْرِ ءَاسِنٍۢ وَأَنْهَٰرٌۭ مِّن لَّبَنٍۢ لَّمْ يَتَغَيَّرْ طَعْمُهُۥ وَأَنْهَٰرٌۭ مِّنْ خَمْرٍۢ لَّذَّةٍۢ لِّلشَّٰرِبِينَ وَأَنْهَٰرٌۭ مِّنْ عَسَلٍۢ مُّصَفًّۭى ۖ وَلَهُمْ فِيهَا مِن كُلِّ ٱلثَّمَرَٰتِ وَمَغْفِرَةٌۭ مِّن رَّبِّهِمْ ۖ كَمَنْ هُوَ خَٰلِدٌۭ فِى ٱلنَّارِ وَسُقُوا۟ مَآءً حَمِيمًۭا فَقَطَّعَ أَمْعَآءَهُمْ","translation":"[And can] the parable of the paradise which the God-conscious are promised [a paradise] wherein there are rivers of water which time does not corrupt, and rivers of milk the taste whereof never alters, and rivers of wine delightful to those who drink it, and rivers of honey of all impurity cleansed, and the enjoyment of all the fruits [of their good deeds] and of forgiveness from their Sustainer -: can this [parable of paradise] be likened unto [the parable of the recompense of] such as are to abide in the fire and be given waters of burning despair to drink, so that it will tear their bowels asunder?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4560.mp3","surahId":47,"words":[{"id":17091,"position":1,"arabic":"مَّثَلُ","translation":"একটি দৃষ্টান্ত","audioUrl":"wbw/047_015_001.mp3","charTypeName":"word"},{"id":17092,"position":2,"arabic":"ٱلْجَنَّةِ","translation":"জান্নাতের","audioUrl":"wbw/047_015_002.mp3","charTypeName":"word"},{"id":17093,"position":3,"arabic":"ٱلَّتِى","translation":"যা","audioUrl":"wbw/047_015_003.mp3","charTypeName":"word"},{"id":17094,"position":4,"arabic":"وُعِدَ","translation":"প্রতিশ্রুতি দেওয়া হয়েছে","audioUrl":"wbw/047_015_004.mp3","charTypeName":"word"},{"id":17095,"position":5,"arabic":"ٱلْمُتَّقُونَ ۖ","translation":"মুত্তাকীদের (জন্যে)","audioUrl":"wbw/047_015_005.mp3","