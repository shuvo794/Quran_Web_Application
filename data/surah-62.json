{"id":62,"nameArabic":"سُورَةُ الجُمُعَةِ","nameEnglish":"Al-Jumu'a","nameTranslation":"Friday","revelationType":"Medinan","numberOfAyahs":11,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ يُسَبِّحُ لِلَّهِ مَا فِى ٱلسَّمَٰوَٰتِ وَمَا فِى ٱلْأَرْضِ ٱلْمَلِكِ ٱلْقُدُّوسِ ٱلْعَزِيزِ ٱلْحَكِيمِ","translation":"ALL THAT IS in the heavens and all that is on earth extols the limitless glory of God, the Sovereign Supreme, the Holy, the Almighty, the Wise!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5178.mp3","surahId":62,"words":[{"id":456,"position":1,"arabic":"يُسَبِّحُ","translation":"মহিমা ঘোষণা করে","audioUrl":"wbw/062_001_001.mp3","charTypeName":"word"},{"id":457,"position":2,"arabic":"لِلَّهِ","translation":"আল্লাহরই","audioUrl":"wbw/062_001_002.mp3","charTypeName":"word"},{"id":458,"position":3,"arabic":"مَا","translation":"যা","audioUrl":"wbw/062_001_003.mp3","charTypeName":"word"},{"id":459,"position":4,"arabic":"فِى","translation":"মধ্যে (আছে)","audioUrl":"wbw/062_001_004.mp3","charTypeName":"word"},{"id":460,"position":5,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশ জগতের","audioUrl":"wbw/062_001_005.mp3","charTypeName":"word"},{"id":461,"position":6,"arabic":"وَمَا","translation":"ও যা","audioUrl":"wbw/062_001_006.mp3","charTypeName":"word"},{"id":462,"position":7,"arabic":"فِى","translation":"মধ্যে (আছে)","audioUrl":"wbw/062_001_007.mp3","charTypeName":"word"},{"id":463,"position":8,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/062_001_008.mp3","charTypeName":"word"},{"id":464,"position":9,"arabic":"ٱلْمَلِكِ","translation":"অধিপতি","audioUrl":"wbw/062_001_009.mp3","charTypeName":"word"},{"id":465,"position":10,"arabic":"ٱلْقُدُّوسِ","translation":"মহান পবিত্র","audioUrl":"wbw/062_001_010.mp3","charTypeName":"word"},{"id":466,"position":11,"arabic":"ٱلْعَزِيزِ","translation":"মহাপরাক্রমশালী","audioUrl":"wbw/062_001_011.mp3","charTypeName":"word"},{"id":467,"position":12,"arabic":"ٱلْحَكِيمِ","translat