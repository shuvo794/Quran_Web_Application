َّهِ وَذَرُوا۟ ٱلْبَيْعَ ۚ ذَٰلِكُمْ خَيْرٌۭ لَّكُمْ إِن كُنتُمْ تَعْلَمُونَ","translation":"O YOU who have attained to faith! When the call to prayer is sounded on the day of congregation, hasten to the remembrance of God, and leave all worldly commerce: this is for your own good, if you but knew it.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5186.mp3","surahId":62,"words":[{"id":10136,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"ওহে","audioUrl":"wbw/062_009_001.mp3","charTypeName":"word"},{"id":10137,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/062_009_002.mp3","charTypeName":"word"},{"id":10138,"position":3,"arabic":"ءَامَنُوٓا۟","translation":"ঈমান এনেছো","audioUrl":"wbw/062_009_003.mp3","charTypeName":"word"},{"id":10139,"position":4,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/062_009_004.mp3","charTypeName":"word"},{"id":10140,"position":5,"arabic":"نُودِىَ","translation":"ডাকা হয়","audioUrl":"wbw/062_009_005.mp3","charTypeName":"word"},{"id":10141,"position":6,"arabic":"لِلصَّلَوٰةِ","translation":"নামাজের জন্যে","audioUrl":"wbw/062_009_006.mp3","charTypeName":"word"},{"id":10142,"position":7,"arabic":"مِن","translation":"মধ্য হতে","audioUrl":"wbw/062_009_007.mp3","charTypeName":"word"},{"id":10143,"position":8,"arabic":"يَوْمِ","translation":"দিনে","audioUrl":"wbw/062_009_008.mp3","charTypeName":"word"},{"id":10144,"position":9,"arabic":"ٱلْجُمُعَةِ","translation":"জুমুয়া'র","audioUrl":"wbw/062_009_009.mp3","charTypeName":"word"},{"id":10145,"position":10,"arabic":"فَٱسْعَوْا۟","translation":"তখন তোমরা ধাবিত  হও","audioUrl":"wbw/062_009_010.mp3","charTypeName":"word"},{"id":10146,"position":11,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/062_009_011.mp3","charTypeName":"word"},{"id":10147,"position":12,"arabic":"ذِكْرِ","translation":"স্মরণের","audioUrl":"wbw/062_009_012.mp3","charTypeName":"word"},{"id":10148,"position":13,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/062_009_013.mp3","charTypeName":"word"},{"id":10149,"position":14,"arabic":"وَذَرُوا۟","translation":"ও ত্যাগ করো","audioUrl":"wbw/062_009_014.mp3","charTypeName":"word"},{"id":10150,"position":15,"arabic":"ٱلْبَيْعَ ۚ","translation":"কেনাবেচা","audioUrl":"wbw/062_009_015.mp3","charTypeName":"word"},{"id":10152,"position":16,"arabic":"ذَٰلِكُمْ","translation":"এটা","audioUrl":"wbw/062_009_017.mp3","charTypeName":"word"},{"id":10153,"position":17,"arabic":"خَيْرٌۭ","translation":"উত্তম","audioUrl":"wbw/062_009_018.mp3","charTypeName":"word"},{"id":10154,"position":18,"arabic":"لَّكُمْ","translation":"তোমাদের জন্যে","audioUrl":"wbw/062_009_019.mp3","charTypeName":"word"},{"id":10155,"position":19,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/062_009_020.mp3","charTypeName":"word"},{"id":10156,"position":20,"arabic":"كُنتُمْ","translation":"তোমরা","audioUrl":"wbw/062_009_021.mp3","charTypeName":"word"},{"id":10157,"position":21,"arabic":"تَعْلَمُونَ","translation":"জানো","audioUrl":"wbw/062_009_022.mp3","charTypeName":"word"},{"id":10158,"position":22,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"فَإِذَا قُضِيَتِ ٱلصَّلَوٰةُ فَٱنتَشِرُوا۟ فِى ٱلْأَرْضِ وَٱبْتَغُوا۟ مِن فَضْلِ ٱللَّهِ وَٱذْكُرُوا۟ ٱللَّهَ كَثِيرًۭا لَّعَلَّكُمْ تُفْلِحُونَ","translation":"And when the prayer is ended, disperse freely on earth and seek to obtain [something] of God's bounty; but remember God often, so that you might attain to a happy state!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5187.mp3","surahId":62,"words":[{"id":11381,"position":1,"arabic":"فَإِذَا","translation":"অতঃপর যখন","audioUrl":"wbw/062_010_001.mp3","charTypeName":"word"},{"id":11382,"position":2,"arabic":"قُضِيَتِ","translation":"সমাপ্ত হয়","audioUrl":"wbw/062_010_002.mp3","charTypeName":"word"},{"id":11383,"position":3,"arabic":"ٱلصَّلَوٰةُ","translation":"নামাজ","audioUrl":"wbw/062_010_003.mp3","charTypeName":"word"},{"id":11384,"position":4,"arabic":"فَٱنتَشِرُوا۟","translation":"তখন তোমরা ছড়িয়ে পড়ো","audioUrl":"wbw/062_010_004.mp3","charTypeName":"word"},{"id":11385,"position":5,"arabic":"فِى","translation":"উপর","audioUrl":"wbw/062_010_005.mp3","charTypeName":"word"},{"id":11386,"position":6,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/062_010_006.mp3","charTypeName":"word"},{"id":11387,"position":7,"arabic":"وَٱبْتَغُوا۟","translation":"ও তোমরা সন্ধান করো","audioUrl":"wbw/062_010_007.mp3","charTypeName":"word"},{"id":11388,"position":8,"arabic":"مِن","translation":"মধ্য হতে","audioUrl":"wbw/062_010_008.mp3","charTypeName":"word"},{"id":11389,"position":9,"arabic":"فَضْلِ","translation":"অনুগ্রহ","audioUrl":"wbw/062_010_009.mp3","charTypeName":"word"},{"id":11390,"position":10,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/062_010_010.mp3","charTypeName":"word"},{"id":11391,"position":11,"arabic":"وَٱذْكُرُوا۟","translation":"এবং তোমরা স্মরণ করো","audioUrl":"wbw/062_010_011.mp3","charTypeName":"word"},{"id":11392,"position":12,"arabic":"ٱللَّهَ","translation":"আল্লাহকে","audioUrl":"wbw/062_010_012.mp3","charTypeName":"word"},{"id":11393,"position":13,"arabic":"كَثِيرًۭا","translation":"অধিক","audioUrl":"wbw/062_010_013.mp3","charTypeName":"word"},{"id":11394,"position":14,"arabic":"لَّعَلَّكُمْ","translation":"সম্ভবতঃ","audioUrl":"wbw/062_010_014.mp3","charTypeName":"word"},{"id":11395,"position":15,"arabic":"تُفْلِحُونَ","translation":"তোমরা সফল হবে","audioUrl":"wbw/062_010_015.mp3","charTypeName":"word"},{"id":11396,"position":16,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"وَإِذَا رَأَوْا۟ تِجَٰرَةً أَوْ لَهْوًا ٱنفَضُّوٓا۟ إِلَيْهَا وَتَرَكُوكَ قَآئِمًۭا ۚ قُلْ مَا عِندَ ٱللَّهِ خَيْرٌۭ مِّنَ ٱللَّهْوِ وَمِنَ ٱلتِّجَٰرَةِ ۚ وَٱللَّهُ خَيْرُ ٱلرَّٰزِقِينَ","translation":"Yet [it does happen that] when people become aware of [an occasion for] worldly gain or a passing delight, they rush headlong towards it, and leave thee standing [and preaching]. Say: \"That which is with God is far better than all passing delight and all gain! And God is the best of providers!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5188.mp3","surahId":62,"words":[{"id":12677,"position":1,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/062_011_001.mp3","charTypeName":"word"},{"id":12678,"position":2,"arabic":"رَأَوْا۟","translation":"তারা দেখল","audioUrl":"wbw/062_011_002.mp3","charTypeName":"word"},{"id":12679,"position":3,"arabic":"تِجَـٰرَةً","translation":"ব্যবসা","audioUrl":"wbw/062_011_003.mp3","charTypeName":"word"},{"id":12680,"position":4,"arabic":"أَوْ","translation":"বা","audioUrl":"wbw/062_011_004.mp3","charTypeName":"word"},{"id":12681,"position":5,"arabic":"لَهْوًا","translation":"খেলা-তামাশা","audioUrl":"wbw/062_011_005.mp3","charTypeName":"word"},{"id":12682,"position":6,"arabic":"ٱنفَضُّوٓا۟","translation":"তারা ছুটে গেল","audioUrl":"wbw/062_011_006.mp3","charTypeName":"word"},{"id":12683,"position":7,"arabic":"إِلَيْهَا","translation":"তার দিকে","audioUrl":"wbw/062_011_007.mp3","charTypeName":"word"},{"id":12684,"position":8,"arabic":"وَتَرَكُوكَ","translation":"ও তোমাকে ছেড়ে গেল","audioUrl":"wbw/062_011_008.mp3","charTypeName":"word"},{"id":12685,"position":9,"arabic":"قَآئِمًۭا ۚ","translation":"দাঁড়ানো অবস্থায়","audioUrl":"wbw/062_011_009.mp3","charTypeName":"word"},{"id":12687,"position":10,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/062_011_011.mp3","charTypeName":"word"},{"id":12688,"position":11,"arabic":"مَا","translation":"\"যা কিছুু","audioUrl":"wbw/062_011_012.mp3","charTypeName":"word"},{"id":12689,"position":12,"arabic":"عِندَ","translation":"কাছে","audioUrl":"wbw/062_011_013.mp3","charTypeName":"word"},{"id":12690,"position":13,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/062_011_014.mp3","charTypeName":"word"},{"id":12691,"position":14,"arabic":"خَيْرٌۭ","translation":"উত্তম","audioUrl":"wbw/062_011_015.mp3","charTypeName":"word"},{"id":12692,"position":15,"arabic":"مِّنَ","translation":"অপেক্ষা","audioUrl":"wbw/062_011_016.mp3","charTypeName":"word"},{"id":12693,"position":16,"arabic":"ٱللَّهْوِ","translation":"খেলা-তামাশা","audioUrl":"wbw/062_011_017.mp3","charTypeName":"word"},{"id":12694,"position":17,"arabic":"وَمِنَ","translation":"ও থেকে","audioUrl":"wbw/062_011_018.mp3","charTypeName":"word"},{"id":12695,"position":18,"arabic":"ٱلتِّجَـٰرَةِ ۚ","translation":"ব্যবসা","audioUrl":"wbw/062_011_019.mp3","charTypeName":"word"},{"id":12697,"position":19,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহই","audioUrl":"wbw/062_011_021.mp3","charTypeName":"word"},{"id":12698,"position":20,"arabic":"خَيْرُ","translation":"উত্তম","audioUrl":"wbw/062_011_022.mp3","charTypeName":"word"},{"id":12699,"position":21,"arabic":"ٱلرَّٰزِقِينَ","translation":"রিযিকদাতাদের\"","audioUrl":"wbw/062_011_023.mp3","charTypeName":"word"},{"id":12700,"position":22,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]}]}