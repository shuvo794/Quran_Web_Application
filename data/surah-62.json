"audioUrl":"wbw/062_002_010.mp3","charTypeName":"word"},{"id":1340,"position":11,"arabic":"وَيُزَكِّيهِمْ","translation":"ও তাদের পরিশুদ্ধ করে","audioUrl":"wbw/062_002_011.mp3","charTypeName":"word"},{"id":1341,"position":12,"arabic":"وَيُعَلِّمُهُمُ","translation":"ও তাদের শিক্ষা দেয়","audioUrl":"wbw/062_002_012.mp3","charTypeName":"word"},{"id":1342,"position":13,"arabic":"ٱلْكِتَـٰبَ","translation":"কিতাব","audioUrl":"wbw/062_002_013.mp3","charTypeName":"word"},{"id":1343,"position":14,"arabic":"وَٱلْحِكْمَةَ","translation":"হিকমত","audioUrl":"wbw/062_002_014.mp3","charTypeName":"word"},{"id":1344,"position":15,"arabic":"وَإِن","translation":"এবং যদিও","audioUrl":"wbw/062_002_015.mp3","charTypeName":"word"},{"id":1345,"position":16,"arabic":"كَانُوا۟","translation":"তারা ছিল","audioUrl":"wbw/062_002_016.mp3","charTypeName":"word"},{"id":1346,"position":17,"arabic":"مِن","translation":"মধ্য হতে","audioUrl":"wbw/062_002_017.mp3","charTypeName":"word"},{"id":1347,"position":18,"arabic":"قَبْلُ","translation":"ইতিপূর্বে","audioUrl":"wbw/062_002_018.mp3","charTypeName":"word"},{"id":1348,"position":19,"arabic":"لَفِى","translation":"মধ্যে অবশ্যই","audioUrl":"wbw/062_002_019.mp3","charTypeName":"word"},{"id":1349,"position":20,"arabic":"ضَلَـٰلٍۢ","translation":"বিভ্রান্তির","audioUrl":"wbw/062_002_020.mp3","charTypeName":"word"},{"id":1350,"position":21,"arabic":"مُّبِينٍۢ","translation":"সুস্পষ্ট","audioUrl":"wbw/062_002_021.mp3","charTypeName":"word"},{"id":1351,"position":22,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"وَءَاخَرِينَ مِنْهُمْ لَمَّا يَلْحَقُوا۟ بِهِمْ ۚ وَهُوَ ٱلْعَزِيزُ ٱلْحَكِيمُ","translation":"and [to cause this message to spread] from them unto other people as soon as they come into contact with them: for He alone is almighty, truly wise!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5180.mp3","surahId":62,"words":[{"id":2416,"position":1,"arabic":"وَءَاخَرِينَ","translation":"