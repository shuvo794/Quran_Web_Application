":"word"},{"id":3810,"position":6,"arabic":"يَشَآءُ ۚ","translation":"তিনি চান","audioUrl":"wbw/062_004_006.mp3","charTypeName":"word"},{"id":3812,"position":7,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/062_004_008.mp3","charTypeName":"word"},{"id":3813,"position":8,"arabic":"ذُو","translation":"(আছে)","audioUrl":"wbw/062_004_009.mp3","charTypeName":"word"},{"id":3814,"position":9,"arabic":"ٱلْفَضْلِ","translation":"অনুগ্রহকারী","audioUrl":"wbw/062_004_010.mp3","charTypeName":"word"},{"id":3815,"position":10,"arabic":"ٱلْعَظِيمِ","translation":"মহান","audioUrl":"wbw/062_004_011.mp3","charTypeName":"word"},{"id":3816,"position":11,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"مَثَلُ ٱلَّذِينَ حُمِّلُوا۟ ٱلتَّوْرَىٰةَ ثُمَّ لَمْ يَحْمِلُوهَا كَمَثَلِ ٱلْحِمَارِ يَحْمِلُ أَسْفَارًۢا ۚ بِئْسَ مَثَلُ ٱلْقَوْمِ ٱلَّذِينَ كَذَّبُوا۟ بِـَٔايَٰتِ ٱللَّهِ ۚ وَٱللَّهُ لَا يَهْدِى ٱلْقَوْمَ ٱلظَّٰلِمِينَ","translation":"THE PARABLE of those who were graced with the burden of the Torah, and thereafter failed to bear this burden, is that of an ass that carries a load of books [but cannot benefit from them]. Calamitous is the parable of people who are bent on giving the lie to God's messages - for God does not bestow His guidance upon such evildoing folk!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5182.mp3","surahId":62,"words":[{"id":5066,"position":1,"arabic":"مَثَلُ","translation":"দৃষ্টান্ত","audioUrl":"wbw/062_005_001.mp3","charTypeName":"word"},{"id":5067,"position":2,"arabic":"ٱلَّذِينَ","translation":"যাদের","audioUrl":"wbw/062_005_002.mp3","charTypeName":"word"},{"id":5068,"position":3,"arabic":"حُمِّلُوا۟","translation":"ভার দেয়া হয়েছিল","audioUrl":"wbw/062_005_003.mp3","charTypeName":"word"},{"id":5069,"position":4,"arabic":"ٱلتَّوْرَىٰةَ","translation":"তাওরাতের (দায়িত্ব)","audioUrl":"wbw/062_005_004.mp3","charTypeName":"word"},{"id":5070,"position":5,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/062_005_005.mp3","charTypeName":"word"},{"id":5071,"position":6,"arabic":"لَمْ","translation":"নাই","audioUrl":"wbw/062_005_006.mp3","charTypeName":"word"},{"id":5072,"position":7,"arabic":"يَحْمِلُوهَا","translation":"তা বহন করে","audioUrl":"wbw/062_005_007.mp3","charTypeName":"word"},{"id":5073,"position":8,"arabic":"كَمَثَلِ","translation":"দৃষ্টান্ত যেমন","audioUrl":"wbw/062_005_008.mp3","charTypeName":"word"},{"id":5074,"position":9,"arabic":"ٱلْحِمَارِ","translation":"গাধার","audioUrl":"wbw/062_005_009.mp3","charTypeName":"word"},{"id":5075,"position":10,"arabic":"يَحْمِلُ","translation":"বহন করে","audioUrl":"wbw/062_005_010.mp3","charTypeName":"word"},{"id":5076,"position":11,"arabic":"أَسْفَارًۢا ۚ","translation":"কিতাবসমূহ","audioUrl":"wbw/062_005_011.mp3","charTypeName":"word"},{"id":5078,"position":12,"arabic":"بِئْسَ","translation":"কত নিকৃষ্ট","audioUrl":"wbw/062_005_013.mp3","charTypeName":"word"},{"id":5079,"position":13,"arabic":"مَثَلُ","translation":"দৃষ্টান্ত","audioUrl":"wbw/062_005_014.mp3","charTypeName":"word"},{"id":5080,"position":14,"arabic":"ٱلْقَوْمِ","translation":"(সেই) লোকদের","audioUrl":"wbw/062_005_015.mp3","charTypeName":"word"},{"id":5081,"position":15,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/062_005_016.mp3","charTypeName":"word"},{"id":5082,"position":16,"arabic":"كَذَّبُوا۟","translation":"মিথ্যারোপ করেছে","audioUrl":"wbw/062_005_017.mp3","charTypeName":"word"},{"id":5083,"position":17,"arabic":"بِـَٔايَـٰتِ","translation":"আয়াতগুলোকে","audioUrl":"wbw/062_005_018.mp3","charTypeName":"word"},{"id":5084,"position":18,"arabic":"ٱللَّهِ ۚ","translation":"আল্লাহর","audioUrl":"wbw/062_005_019.mp3","charTypeName":"word"},{"id":5086,"position":19,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/062_005_021.mp3","charTypeName":"word"},{"id":5087,"position":20,"arabic":"لَا","translation":"না","audioUrl":"wbw/062_005_022.mp3","charTypeName":"word"},{"id":5088,"position":21,"arabi