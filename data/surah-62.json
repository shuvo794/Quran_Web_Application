oUrl":"wbw/062_007_004.mp3","charTypeName":"word"},{"id":7758,"position":5,"arabic":"قَدَّمَتْ","translation":"আগে পাঠিয়েছে","audioUrl":"wbw/062_007_005.mp3","charTypeName":"word"},{"id":7759,"position":6,"arabic":"أَيْدِيهِمْ ۚ","translation":"তাদের হাতগুলো","audioUrl":"wbw/062_007_006.mp3","charTypeName":"word"},{"id":7761,"position":7,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/062_007_008.mp3","charTypeName":"word"},{"id":7762,"position":8,"arabic":"عَلِيمٌۢ","translation":"খুব অবহিত","audioUrl":"wbw/062_007_009.mp3","charTypeName":"word"},{"id":7763,"position":9,"arabic":"بِٱلظَّـٰلِمِينَ","translation":"যালিমদের সম্পর্কে","audioUrl":"wbw/062_007_010.mp3","charTypeName":"word"},{"id":7764,"position":10,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"قُلْ إِنَّ ٱلْمَوْتَ ٱلَّذِى تَفِرُّونَ مِنْهُ فَإِنَّهُۥ مُلَٰقِيكُمْ ۖ ثُمَّ تُرَدُّونَ إِلَىٰ عَٰلِمِ ٱلْغَيْبِ وَٱلشَّهَٰدَةِ فَيُنَبِّئُكُم بِمَا كُنتُمْ تَعْمَلُونَ","translation":"Say: \"Behold, the death from which you are fleeing is bound to overtake you - and then you will be brought back unto Him who knows all that is beyond the reach of a created being's perception as well as all that can be witnessed by a creature's senses or mind, whereupon He will make you truly understand all that you were doing [in life].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5185.mp3","surahId":62,"words":[{"id":8920,"position":1,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/062_008_001.mp3","charTypeName":"word"},{"id":8921,"position":2,"arabic":"إِنَّ","translation":"\"নিশ্চয়","audioUrl":"wbw/062_008_002.mp3","charTypeName":"word"},{"id":8922,"position":3,"arabic":"ٱلْمَوْتَ","translation":"মৃত্যু","audioUrl":"wbw/062_008_003.mp3","charTypeName":"word"},{"id":8923,"position":4,"arabic":"ٱلَّذِى","translation":"যা (থেকে)","audioUrl":"wbw/062_008_004.mp3","charTypeName":"word"},{"id":8924,"position":5,"arabic":"تَفِرُّونَ","translati