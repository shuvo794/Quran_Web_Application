{"id":38,"ayahs":[{"number":234,"arabic":"وَٱلَّذِينَ يُتَوَفَّوْنَ مِنكُمْ وَيَذَرُونَ أَزْوَٰجًۭا يَتَرَبَّصْنَ بِأَنفُسِهِنَّ أَرْبَعَةَ أَشْهُرٍۢ وَعَشْرًۭا ۖ فَإِذَا بَلَغْنَ أَجَلَهُنَّ فَلَا جُنَاحَ عَلَيْكُمْ فِيمَا فَعَلْنَ فِىٓ أَنفُسِهِنَّ بِٱلْمَعْرُوفِ ۗ وَٱللَّهُ بِمَا تَعْمَلُونَ خَبِيرٌۭ","translation":"And if any of you die and leave wives behind, they shall undergo, without remarrying, a waiting-period of four months and ten days; whereupon, when they have reached the end of their waiting-term, there shall be no sin in whatever they may do with their persons in a lawful manner. And God is aware of all that you do.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/241.mp3","surahId":2,"words":[{"id":86528,"position":1,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/002_234_001.mp3","charTypeName":"word"},{"id":86529,"position":2,"arabic":"يُتَوَفَّوْنَ","translation":"মারা যায়","audioUrl":"wbw/002_234_002.mp3","charTypeName":"word"},{"id":86530,"position":3,"arabic":"مِنكُمْ","translation":"তোমাদের মধ্যেথেকে","audioUrl":"wbw/002_234_003.mp3","charTypeName":"word"},{"id":86531,"position":4,"arabic":"وَيَذَرُونَ","translation":"এবং তারা রেখে যায়","audioUrl":"wbw/002_234_004.mp3","charTypeName":"word"},{"id":86532,"position":5,"arabic":"أَزْوَٰجًۭا","translation":"স্ত্রীদেরকে","audioUrl":"wbw/002_234_005.mp3","charTypeName":"word"},{"id":86533,"position":6,"arabic":"يَتَرَبَّصْنَ","translation":"তারা অপেক্ষায় রাখবে (অর্থাৎ স্ত্রীরা)","audioUrl":"wbw/002_234_006.mp3","charTypeName":"word"},{"id":86534,"position":7,"arabic":"بِأَنفُسِهِنَّ","translation":"তাদের নিজেদেরকে","audioUrl":"wbw/002_234_007.mp3","charTypeName":"word"},{"id":86535,"position":8,"arabic":"أَرْبَعَةَ","translation":"চার","audioUrl":"wbw/002_234_008.mp3","charTypeName":"word"},{"id":86536,"position":9,"arabic":"أَشْهُرٍۢ","translation":"মাস","audioUrl":"wbw/002_234_009.mp3","charTypeName":"word"},{"id":86537,"position":10,"arabic":"وَعَشْرًۭا ۖ","translation":"ও দশ (দিন পর্যন্ত)","audioUrl":"wbw/002_234_010.mp3","charTypeName":"word"},{"id":86539,"position":11,"arabic":"فَإِذَا","translation":"অতঃপর যখন","audioUrl":"wbw/002_234_012.mp3","charTypeName":"word"},{"id":86540,"position":12,"arabic":"بَلَغْنَ","translation":"তারা পৌঁছে","audioUrl":"wbw/002_234_013.mp3","charTypeName":"word"},{"id":86541,"position":13,"arabic":"أَجَلَهُنَّ","translation":"তাদের মেয়াদে","audioUrl":"wbw/002_234_014.mp3","charTypeName":"word"},{"id":86542,"position":14,"arabic":"فَلَا","translation":"নেই তখন","audioUrl":"wbw/002_234_015.mp3","charTypeName":"word"},{"id":86543,"position":15,"arabic":"جُنَاحَ","translation":"কোনো পাপ","audioUrl":"wbw/002_234_016.mp3","charTypeName":"word"},{"id":86544,"position":16,"arabic":"عَلَيْكُمْ","translation":"তোমাদের উপর","audioUrl":"wbw/002_234_017.mp3","charTypeName":"word"},{"id":86545,"position":17,"arabic":"فِيمَا","translation":"সেক্ষেত্রে যা","audioUrl":"wbw/002_234_018.mp3","charTypeName":"word"},{"id":86546,"position":18,"arabic":"فَعَلْنَ","translation":"তারা করে","audioUrl":"wbw/002_234_019.mp3","charTypeName":"word"},{"id":86547,"position":19,"arabic":"فِىٓ","translation":"সম্পর্কে","audioUrl":"wbw/002_234_020.mp3","charTypeName":"word"},{"id":86548,"position":20,"arabic":"أَنفُسِهِنَّ","translation":"তাদের নিজেদের","audioUrl":"wbw/002_234_021.mp3","charTypeName":"word"},{"id":86549,"position":21,"arabic":"بِٱلْمَعْرُوفِ ۗ","translation":"ন্যায়সংগত ভাবে","audioUrl":"wbw/002_234_022.mp3","charTypeName":"word"},{"id":86551,"position":22,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/002_234_024.mp3","charTypeName":"word"},{"id":86552,"position":23,"arabic":"بِمَا","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/002_234_025.mp3","charTypeName":"word"},{"id":86553,"position":24,"arabic":"تَعْمَلُونَ","translation":"তোমরা কাজ কর","audioUrl":"wbw/002_234_026.mp3","charTypeName":"word"},{"id":86554,"position":25,"arabic":"خَبِيرٌۭ","translation":"সবিশেষ অবহিত","audioUrl":"wbw/002_234_027.mp3","charTypeName":"word"},{"id":86555,"position":26,"arabic":"٢٣٤","translation":"(২৩৪)","audioUrl":null,"charTypeName":"end"}]},{"number":235,"arabic":"وَلَا جُنَاحَ عَلَيْكُمْ فِيمَا عَرَّضْتُم بِهِۦ مِنْ خِطْبَةِ ٱلنِّسَآءِ أَوْ أَكْنَنتُمْ فِىٓ أَنفُسِكُمْ ۚ عَلِمَ ٱللَّهُ أَنَّكُمْ سَتَذْكُرُونَهُنَّ وَلَٰكِن لَّا تُوَاعِدُوهُنَّ سِرًّا إِلَّآ أَن تَقُولُوا۟ قَوْلًۭا مَّعْرُوفًۭا ۚ وَلَا تَعْزِمُوا۟ عُقْدَةَ ٱلنِّكَاحِ حَتَّىٰ يَبْلُغَ ٱلْكِتَٰبُ أَجَلَهُۥ ۚ وَٱعْلَمُوٓا۟ أَنَّ ٱللَّهَ يَعْلَمُ مَا فِىٓ أَنفُسِكُمْ فَٱحْذَرُوهُ ۚ وَٱعْلَمُوٓا۟ أَنَّ ٱللَّهَ غَفُورٌ حَلِيمٌۭ","translation":"But you will incur no sin if you give a hint of [an intended] marriage-offer to [any of] these women, or if you conceive such an intention without making it obvious: [for] God knows that you intend to ask them in marriage. Do not, however, plight your troth with them in secret, but speak only in a decent manner; and do not proceed with tying the marriage-knot ere the ordained [term of waiting] has come to its end. And know that God knows what is in your minds, and therefore remain conscious of Him; and know, too, that God is much-forgiving, forbearing.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/242.mp3","surahId":2,"words":[{"id":86556,"position":1,"arabic":"وَلَا","translation":"এবং নেই","audioUrl":"wbw/002_235_001.mp3","charTypeName":"word"},{"id":86557,"position":2,"arabic":"جُنَاحَ","translation":"কোনো পাপ","audioUrl":"wbw/002_235_002.mp3","charTypeName":"word"},{"id":86558,"position":3,"arabic":"عَلَيْكُمْ","translation":"তোমাদের উপর","audioUrl":"wbw/002_235_003.mp3","charTypeName":"word"},{"id":86559,"position":4,"arabic":"فِيمَا","translation":"সেক্ষেত্রে যা","audioUrl":"wbw/002_235_004.mp3","charTypeName":"word"},{"id":86560,"position":5,"arabic":"عَرَّضْتُم","translation":"তোমরা আভাস-ইঙ্গিতে প্রকাশ কর","audioUrl":"wbw/002_235_005.mp3","charTypeName":"word"},{"id":86561,"position":6,"arabic":"بِهِۦ","translation":"তা","audioUrl":"wbw/002_235_006.mp3","charTypeName":"word"},{"id":86562,"position":7,"arabic":"مِنْ","translation":"বিষয়টি","audioUrl":"wbw/002_235_007.mp3","charTypeName":"word"},{"id":86563,"position":8,"arabic":"خِطْبَةِ","translation":"বিয়ের প্রস্তাবের","audioUrl":"wbw/002_235_008.mp3","charTypeName":"word"},{"id":86564,"position":9,"arabic":"ٱلنِّسَآءِ","translation":"(বিধবা) নারীদের","audioUrl":"wbw/002_235_009.mp3","charTypeName":"word"},{"id":86565,"position":10,"arabic":"أَوْ","translation":"বা","audioUrl":"wbw/002_235_010.mp3","charTypeName":"word"},{"id":86566,"position":11,"arabic":"أَكْنَنتُمْ","translation":"তোমরা গোপন কর","audioUrl":"wbw/002_235_011.mp3","charTypeName":"word"},{"id":86567,"position":12,"arabic":"فِىٓ","translation":"মধ্যে","audioUrl":"wbw/002_235_012.mp3","charTypeName":"word"},{"id":86568,"position":13,"arabic":"أَنفُسِكُمْ ۚ","translation":"তোমাদের মনের","audioUrl":"wbw/002_235_013.mp3","charTypeName":"word"},{"id":86570,"position":14,"arabic":"عَلِمَ","translation":"জানেন","audioUrl":"wbw/002_235_015.mp3","charTypeName":"word"},{"id":86571,"position":15,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/002_235_016.mp3","charTypeName":"word"},{"id":86572,"position":16,"arabic":"أَنَّكُمْ","translation":"তোমরা যে","audioUrl":"wbw/002_235_017.mp3","charTypeName":"word"},{"id":86573,"position":17,"arabic":"سَتَذْكُرُونَهُنَّ","translation":"তাদেরকে আলোচনা করবে তোমরা","audioUrl":"wbw/002_235_018.mp3","charTypeName":"word"},{"id":86574,"position":18,"arabic":"وَلَـٰكِن","translation":"কিন্তু","audioUrl":"wbw/002_235_019.mp3","charTypeName":"word"},{"id":86575,"position":19,"arabic":"لَّا","translation":"না","audioUrl":"wbw/002_235_020.mp3","charTypeName":"word"},{"id":86576,"position":20,"arabic":"تُوَاعِدُوهُنَّ","translation":"তাদেরকে অঙ্গীকার করবে তোমরা","audioUrl":"wbw/002_235_021.mp3","charTypeName":"word"},{"id":86577,"position":21,"arabic":"سِرًّا","translation":"গোপনে","audioUrl":"wbw/002_235_022.mp3","charTypeName":"word"},{"id":86578,"position":22,"arabic":"إِلَّآ","translation":"এছাড়া","audioUrl":"wbw/002_235_023.mp3","charTypeName":"word"},{"id":86579,"position":23,"arabic":"أَن","translation":"যে","audioUrl":"wbw/002_235_024.mp3","charTypeName":"word"},{"id":86580,"position":24,"arabic":"تَقُولُوا۟","translation":"তোমরা বলবে","audioUrl":"wbw/002_235_025.mp3","charTypeName":"word"},{"id":86581,"position":25,"arabic":"قَوْلًۭا","translation":"কথা","audioUrl":"wbw/002_235_026.mp3","charTypeName":"word"},{"id":86582,"position":26,"arabic":"مَّعْرُوفًۭا ۚ","translation":"বিধি মতো","audioUrl":"wbw/002_235_027.mp3","charTypeName":"word"},{"id":86584,"position":27,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/002_235_029.mp3","charTypeName":"word"},{"id":86585,"position":28,"arabic":"تَعْزِمُوا۟","translation":"তোমরা সংকল্প করো","audioUrl":"wbw/002_235_030.mp3","charTypeName":"word"},{"id":86586,"position":29,"arabic":"عُقْدَةَ","translation":"বন্ধনের","audioUrl":"wbw/002_235_031.mp3","charTypeName":"word"},{"id":86587,"position":30,"arabic":"ٱلنِّكَاحِ","translation":"বিয়ের","audioUrl":"wbw/002_235_032.mp3","charTypeName":"word"},{"id":86588,"position":31,"arabic":"حَتَّىٰ","translation":"যতক্ষণ না","audioUrl":"wbw/002_235_033.mp3","charTypeName":"word"},{"id":86589,"position":32,"arabic":"يَبْلُغَ","translation":"পৌঁছে","audioUrl":"wbw/002_235_034.mp3","charTypeName":"word"},{"id":86590,"position":33,"arabic":"ٱلْكِتَـٰبُ","translation":"বিধান (অর্থাৎ ইদ্দত)","audioUrl":"wbw/002_235_035.mp3","charTypeName":"word"},{"id":86591,"position":34,"arabic":"أَجَلَهُۥ ۚ","translation":"তার নির্দিষ্ট সময়ে","audioUrl":"wbw/002_235_036.mp3","charTypeName":"word"},{"id":86593,"position":35,"arabic":"وَٱعْلَمُوٓا۟","translation":"এবং তোমরা জেনে রেখো","audioUrl":"wbw/002_235_038.mp3","charTypeName":"word"},{"id":86594,"position":36,"arabic":"أَنَّ","translation":"যে","audioUrl":"wbw/002_235_039.mp3","charTypeName":"word"},{"id":86595,"position":37,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/002_