upon all who would do good.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/243.mp3","surahId":2,"words":[{"id":86608,"position":1,"arabic":"لَّا","translation":"নেই","audioUrl":"wbw/002_236_001.mp3","charTypeName":"word"},{"id":86609,"position":2,"arabic":"جُنَاحَ","translation":"কোনো পাপ","audioUrl":"wbw/002_236_002.mp3","charTypeName":"word"},{"id":86610,"position":3,"arabic":"عَلَيْكُمْ","translation":"তোমাদের উপর","audioUrl":"wbw/002_236_003.mp3","charTypeName":"word"},{"id":86611,"position":4,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/002_236_004.mp3","charTypeName":"word"},{"id":86612,"position":5,"arabic":"طَلَّقْتُمُ","translation":"তোমরা তালাক দাও","audioUrl":"wbw/002_236_005.mp3","charTypeName":"word"},{"id":86613,"position":6,"arabic":"ٱلنِّسَآءَ","translation":"স্ত্রীদেরকে","audioUrl":"wbw/002_236_006.mp3","charTypeName":"word"},{"id":86614,"position":7,"arabic":"مَا","translation":"যে পর্যন্ত","audioUrl":"wbw/002_236_007.mp3","charTypeName":"word"},{"id":86615,"position":8,"arabic":"لَمْ","translation":"না","audioUrl":"wbw/002_236_008.mp3","charTypeName":"word"},{"id":86616,"position":9,"arabic":"تَمَسُّوهُنَّ","translation":"তাদেরকে স্পর্শ কর","audioUrl":"wbw/002_236_009.mp3","charTypeName":"word"},{"id":86617,"position":10,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/002_236_010.mp3","charTypeName":"word"},{"id":86618,"position":11,"arabic":"تَفْرِضُوا۟","translation":"তোমরা ধার্য কর (নাই)","audioUrl":"wbw/002_236_011.mp3","charTypeName":"word"},{"id":86619,"position":12,"arabic":"لَهُنَّ","translation":"তাদের জন্য","audioUrl":"wbw/002_236_012.mp3","charTypeName":"word"},{"id":86620,"position":13,"arabic":"فَرِيضَةًۭ ۚ","translation":"কোনো মোহর","audioUrl":"wbw/002_236_013.mp3","charTypeName":"word"},{"id":86622,"position":14,"arabic":"وَمَتِّعُوهُنَّ","translation":"এবং তাদেরকে কিছু খরচপত্র দাও","audioUrl":"wbw/002_236_015.mp3","charTypeName":"word"},{"id":86623,"position":15,"arabic":"عَلَى","translation":"উপর","au