"id":12435,"position":8,"arabic":"ٱلْخُرُوجُ","translation":"উত্থান (হবে)","audioUrl":"wbw/050_011_010.mp3","charTypeName":"word"},{"id":12436,"position":9,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]},{"number":12,"arabic":"كَذَّبَتْ قَبْلَهُمْ قَوْمُ نُوحٍۢ وَأَصْحَٰبُ ٱلرَّسِّ وَثَمُودُ","translation":"[Long] before those [who now deny resur­rection] did Noah’s people give the lie to this truth, and [so did] the folk of Ar-Rass, and [the tribes of] Thamud","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4642.mp3","surahId":50,"words":[{"id":13708,"position":1,"arabic":"كَذَّبَتْ","translation":"মিথ্যা বলে  অস্বীকার করেছে","audioUrl":"wbw/050_012_001.mp3","charTypeName":"word"},{"id":13709,"position":2,"arabic":"قَبْلَهُمْ","translation":"তাদের পূর্বে","audioUrl":"wbw/050_012_002.mp3","charTypeName":"word"},{"id":13710,"position":3,"arabic":"قَوْمُ","translation":"জাতি","audioUrl":"wbw/050_012_003.mp3","charTypeName":"word"},{"id":13711,"position":4,"arabic":"نُوحٍۢ","translation":"নূহের","audioUrl":"wbw/050_012_004.mp3","charTypeName":"word"},{"id":13712,"position":5,"arabic":"وَأَصْحَـٰبُ","translation":"ও অধিবাসীরা","audioUrl":"wbw/050_012_005.mp3","charTypeName":"word"},{"id":13713,"position":6,"arabic":"ٱلرَّسِّ","translation":"কূপ","audioUrl":"wbw/050_012_006.mp3","charTypeName":"word"},{"id":13714,"position":7,"arabic":"وَثَمُودُ","translation":"ও সামুদ","audioUrl":"wbw/050_012_007.mp3","charTypeName":"word"},{"id":13715,"position":8,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]},{"number":13,"arabic":"وَعَادٌۭ وَفِرْعَوْنُ وَإِخْوَٰنُ لُوطٍۢ","translation":"and Ad, and Pharaoh, and Lot’s brethren,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4643.mp3","surahId":50,"words":[{"id":14879,"position":1,"arabic":"وَعَادٌۭ","translation":"এবং আদ","audioUrl":"wbw/050_013_001.mp3","charTypeName":"word"},{"id":14880,"position":2,"arabic":"وَفِرْعَوْنُ","translation":"ও ফিরআউ