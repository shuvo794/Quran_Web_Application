{"id":518,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ قٓ ۚ وَٱلْقُرْءَانِ ٱلْمَجِيدِ","translation":"Qaf. CONSIDER this sublime Qur’an!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4631.mp3","surahId":50,"words":[{"id":261,"position":1,"arabic":"قٓ ۚ","translation":"কা-ফ","audioUrl":"wbw/050_001_001.mp3","charTypeName":"word"},{"id":263,"position":2,"arabic":"وَٱلْقُرْءَانِ","translation":"শপথ কুরআনের","audioUrl":"wbw/050_001_003.mp3","charTypeName":"word"},{"id":264,"position":3,"arabic":"ٱلْمَجِيدِ","translation":"সম্মানিত","audioUrl":"wbw/050_001_004.mp3","charTypeName":"word"},{"id":265,"position":4,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"بَلْ عَجِبُوٓا۟ أَن جَآءَهُم مُّنذِرٌۭ مِّنْهُمْ فَقَالَ ٱلْكَٰفِرُونَ هَٰذَا شَىْءٌ عَجِيبٌ","translation":"But nay - they deem it strange that a warner should have come unto them from their own midst; and so these deniers of the truth are saying, “A strange thing is this!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4632.mp3","surahId":50,"words":[{"id":1115,"position":1,"arabic":"بَلْ","translation":"বরং","audioUrl":"wbw/050_002_001.mp3","charTypeName":"word"},{"id":1116,"position":2,"arabic":"عَجِبُوٓا۟","translation":"তারা অবাক হয়েছে","audioUrl":"wbw/050_002_002.mp3","charTypeName":"word"},{"id":1117,"position":3,"arabic":"أَن","translation":"যে","audioUrl":"wbw/050_002_003.mp3","charTypeName":"word"},{"id":1118,"position":4,"arabic":"جَآءَهُم","translation":"তাদের কাছে এসেছে","audioUrl":"wbw/050_002_004.mp3","charTypeName":"word"},{"id":1119,"position":5,"arabic":"مُّنذِرٌۭ","translation":"একজন সতর্ককারী","audioUrl":"wbw/050_002_005.mp3","charTypeName":"word"},{"id":1120,"position":6,"arabic":"مِّنْهُمْ","translation":"তাদের মধ্য হতে","audioUrl":"wbw/050_002_006.mp3","charTypeName":"word"},{"id":1121,"position":7,"arabic":"فَقَالَ","translation":"বলে তাই","audioUrl":"wbw/050_002_007.mp3","charTypeName":"word"},{"id":1122,"position":8,"arabic":"ٱلْكَـٰفِرُونَ","translation":"অস্বীকারকারীরা","audioUrl":"wbw/050_002_008.mp3","charTypeName":"word"},{"id":1123,"position":9,"arabic":"هَـٰذَا","translation":"\"এটা","audioUrl":"wbw/050_002_009.mp3","charTypeName":"word"},{"id":1124,"position":10,"arabic":"شَىْءٌ","translation":"ব্যাপার","audioUrl":"wbw/050_002_010.mp3","charTypeName":"word"},{"id":1125,"position":11,"arabic":"عَجِيبٌ","translation":"আজব","audioUrl":"wbw/050_002_011.mp3","charTypeName":"word"},{"id":1126,"position":12,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"أَءِذَا مِتْنَا وَكُنَّا تُرَابًۭا ۖ ذَٰلِكَ رَجْعٌۢ بَعِيدٌۭ","translation":"Why - [how could we be resurrected] after we have died and become mere dust? Such a return seems far-fetched indeed!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4633.mp3","surahId":50,"words":[{"id":2180,"position":1,"arabic":"أَءِذَا","translation":"যখন কি","audioUrl":"wbw/050_003_001.mp3","charTypeName":"word"},{"id":2181,"position":2,"arabic":"مِتْنَا","translation":"আমরা মারা যাব","audioUrl":"wbw/050_003_002.mp3","charTypeName":"word"},{"id":2182,"position":3,"arabic":"وَكُنَّا","translation":"এবংআমরা হব","audioUrl":"wbw/050_003_003.mp3","charTypeName":"word"},{"id":2183,"position":4,"arabic":"تُرَابًۭا ۖ","translation":"মাটি (তখন পুনরুথিত হব)","audioUrl":"wbw/050_003_004.mp3","charTypeName":"word"},{"id":2185,"position":5,"arabic":"ذَٰلِكَ","translation":"সেই","audioUrl":"wbw/050_003_006.mp3","charTypeName":"word"},{"id":2186,"position":6,"arabic":"رَجْعٌۢ","translation":"প্রত্যাবর্তন (হবে)","audioUrl":"wbw/050_003_007.mp3","charTypeName":"word"},{"id":2187,"position":7,"arabic":"بَعِيدٌۭ","translation":"সুদূর পরাহত\"","audioUrl":"wbw/050_003_008.mp3","charTypeName":"word"},{"id":2188,"position":8,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"قَدْ عَلِمْنَا مَا تَنقُصُ ٱلْأَرْضُ مِنْهُمْ ۖ وَعِندَنَا كِتَٰبٌ حَفِيظٌۢ","translation":"Well do We know how the earth consumes their bodies, for with Us is a record unfailing.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4634.mp3","surahId":50,"words":[{"id":3496,"position":1,"arabic":"قَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/050_004_001.mp3","charTypeName":"word"},{"id":3497,"position":2,"arabic":"عَلِمْنَا","translation":"আমরা জানি","audioUrl":"wbw/050_004_002.mp3","charTypeName":"word"},{"id":3498,"position":3,"arabic":"مَا","translation":"যা","audioUrl":"wbw/050_004_003.mp3","charTypeName":"word"},{"id":3499,"position":4,"arabic":"تَنقُصُ","translation":"ক্ষয় করে","audioUrl":"wbw/050_004_004.mp3","charTypeName":"word"},{"id":3500,"position":5,"arabic":"ٱلْأَرْضُ","translation":"মাটি","audioUrl":"wbw/050_004_005.mp3","charTypeName":"word"},{"id":3501,"position":6,"arabic":"مِنْهُمْ ۖ","translation":"তাদের যে অংশ","audioUrl":"wbw/050_004_006.mp3","charTypeName":"word"},{"id":3503,"position":7,"arabic":"وَعِندَنَا","translation":"এবং আমাদের কাছে আছে","audioUrl":"wbw/050_004_008.mp3","charTypeName":"word"},{"id":3504,"position":8,"arabic":"كِتَـٰبٌ","translation":"একটি কিতাব","audioUrl":"wbw/050_004_009.mp3","charTypeName":"word"},{"id":3505,"position":9,"arabic":"حَفِيظٌۢ","translation":"সংরক্ষণকারী","audioUrl":"wbw/050_004_010.mp3","charTypeName":"word"},{"id":3506,"position":10,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"بَلْ كَذَّبُوا۟ بِٱلْحَقِّ لَمَّا جَآءَهُمْ فَهُمْ فِىٓ أَمْرٍۢ مَّرِيجٍ","translation":"Nay, but they [who refuse to believe in resurrection] have been wont to give the lie to this truth whenever it was proffered to them; and so they are in a state of confusion.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4635.mp3","surahId":50,"words":[{"id":4854,"position":1,"arabic":"بَلْ","translation":"বরং","audioUrl":"wbw/050_005_001.mp3","charTypeName":"word"},{"id":4855,"position":2,"arabic":"كَذَّبُوا۟",