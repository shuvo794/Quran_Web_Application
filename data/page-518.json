র উপরে","audioUrl":"wbw/050_006_005.mp3","charTypeName":"word"},{"id":6100,"position":6,"arabic":"كَيْفَ","translation":"কিভাবে","audioUrl":"wbw/050_006_006.mp3","charTypeName":"word"},{"id":6101,"position":7,"arabic":"بَنَيْنَـٰهَا","translation":"তা আমরা নির্মাণ করেছি","audioUrl":"wbw/050_006_007.mp3","charTypeName":"word"},{"id":6102,"position":8,"arabic":"وَزَيَّنَّـٰهَا","translation":"ও তা আমরা সুশোভিত করেছি","audioUrl":"wbw/050_006_008.mp3","charTypeName":"word"},{"id":6103,"position":9,"arabic":"وَمَا","translation":"এবং নেই","audioUrl":"wbw/050_006_009.mp3","charTypeName":"word"},{"id":6104,"position":10,"arabic":"لَهَا","translation":"তাতে","audioUrl":"wbw/050_006_010.mp3","charTypeName":"word"},{"id":6105,"position":11,"arabic":"مِن","translation":"কোনো","audioUrl":"wbw/050_006_011.mp3","charTypeName":"word"},{"id":6106,"position":12,"arabic":"فُرُوجٍۢ","translation":"ফাটল","audioUrl":"wbw/050_006_012.mp3","charTypeName":"word"},{"id":6107,"position":13,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"وَٱلْأَرْضَ مَدَدْنَٰهَا وَأَلْقَيْنَا فِيهَا رَوَٰسِىَ وَأَنۢبَتْنَا فِيهَا مِن كُلِّ زَوْجٍۭ بَهِيجٍۢ","translation":"And the earth - We have spread it wide, and set upon it mountains firm, and caused it to bring forth plants of all beauteous kinds,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4637.mp3","surahId":50,"words":[{"id":7424,"position":1,"arabic":"وَٱلْأَرْضَ","translation":"এবং ভূমিকে","audioUrl":"wbw/050_007_001.mp3","charTypeName":"word"},{"id":7425,"position":2,"arabic":"مَدَدْنَـٰهَا","translation":"তা আমরা বিস্তৃত করেছি","audioUrl":"wbw/050_007_002.mp3","charTypeName":"word"},{"id":7426,"position":3,"arabic":"وَأَلْقَيْنَا","translation":"এবং আমরা স্থাপন করেছি","audioUrl":"wbw/050_007_003.mp3","charTypeName":"word"},{"id":7427,"position":4,"arabic":"فِيهَا","translation":"তাতে","audioUrl":"wbw/050_007_004.mp3","charTypeName":"word"},{"id":7428,"position":5,"arabic":"رَوَٰسِىَ","translation":"পর্বতমালা","audioUrl":"wbw/050_007_005.mp3","charTypeName":"word"},{"id":7429,"position":6,"arabic":"وَأَنۢبَتْنَا","translation":"এবং আমরা উৎপন্ন করেছি","audioUrl":"wbw/050_007_006.mp3","charTypeName":"word"},{"id":7430,"position":7,"arabic":"فِيهَا","translation":"তাতে","audioUrl":"wbw/050_007_007.mp3","charTypeName":"word"},{"id":7431,"position":8,"arabic":"مِن","translation":"ধরণের","audioUrl":"wbw/050_007_008.mp3","charTypeName":"word"},{"id":7432,"position":9,"arabic":"كُلِّ","translation":"প্রত্যেক","audioUrl":"wbw/050_007_009.mp3","charTypeName":"word"},{"id":7433,"position":10,"arabic":"زَوْجٍۭ","translation":"(উদ্ভিদ) জোড়া জোড়া","audioUrl":"wbw/050_007_010.mp3","charTypeName":"word"},{"id":7434,"position":11,"arabic":"بَهِيجٍۢ","translation":"নয়নজুড়ানো","audioUrl":"wbw/050_007_011.mp3","charTypeName":"word"},{"id":7435,"position":12,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"تَبْصِرَةًۭ وَذِكْرَىٰ لِكُلِّ عَبْدٍۢ مُّنِيبٍۢ","translation":"thus offering an insight and a reminder unto every human being who willingly turns unto God.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4638.mp3","surahId":50,"words":[{"id":8693,"position":1,"arabic":"تَبْصِرَةًۭ","translation":"ও (এসব কিছু) দৃষ্টিপ্রসারণকারী","audioUrl":"wbw/050_008_001.mp3","charTypeName":"word"},{"id":8694,"position":2,"arabic":"وَذِكْرَىٰ","translation":"ও শিক্ষাপ্রদ","audioUrl":"wbw/050_008_002.mp3","charTypeName":"word"},{"id":8695,"position":3,"arabic":"لِكُلِّ","translation":"প্রত্যেকের জন্যে","audioUrl":"wbw/050_008_003.mp3","charTypeName":"word"},{"id":8696,"position":4,"arabic":"عَبْدٍۢ","translation":"বান্দার/ দাসের","audioUrl":"wbw/050_008_004.mp3","charTypeName":"word"},{"id":8697,"position":5,"arabic":"مُّنِيبٍۢ","translation":"যে প্রত্যাবর্তনকারী (আল্লাহর দিকে)","audioUrl":"wbw/050_008_005.mp3","charTypeName":"word"},{"id":8698,"position":6,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"وَنَزَّلْنَا مِنَ ٱلسَّمَآءِ مَآءًۭ مُّبَٰرَكًۭا فَأَنۢبَتْنَا بِهِۦ جَنَّٰتٍۢ وَحَبَّ ٱلْحَصِيدِ","translation":"And We send down from the skies water rich in blessings, and cause thereby gardens to grow, and fields of grain,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4639.mp3","surahId":50,"words":[{"id":9911,"position":1,"arabic":"وَنَزَّلْنَا","translation":"এবং আমরা অবতীর্ণ করেছি","audioUrl":"wbw/050_009_001.mp3","charTypeName":"word"},{"id":9912,"position":2,"arabic":"مِنَ","translation":"থেকে","audioUrl":"wbw/050_009_002.mp3","charTypeName":"word"},{"id":9913,"position":3,"arabic":"ٱلسَّمَآءِ","translation":"আকাশ","audioUrl":"wbw/050_009_003.mp3","charTypeName":"word"},{"id":9914,"position":4,"arabic":"مَآءًۭ","translation":"পানি","audioUrl":"wbw/050_009_004.mp3","charTypeName":"word"},{"id":9915,"position":5,"arabic":"مُّبَـٰرَكًۭا","translation":"উপকারী","audioUrl":"wbw/050_009_005.mp3","charTypeName":"word"},{"id":9916,"position":6,"arabic":"فَأَنۢبَتْنَا","translation":"এরপর আমরা  উৎপন্ন করেছি","audioUrl":"wbw/050_009_006.mp3","charTypeName":"word"},{"id":9917,"position":7,"arabic":"بِهِۦ","translation":"তা দিয়ে","audioUrl":"wbw/050_009_007.mp3","charTypeName":"word"},{"id":9918,"position":8,"arabic":"جَنَّـٰتٍۢ","translation":"বাগানসমূহ","audioUrl":"wbw/050_009_008.mp3","charTypeName":"word"},{"id":9919,"position":9,"arabic":"وَحَبَّ","translation":"ও শস্যাদি","audioUrl":"wbw/050_009_009.mp3","charTypeName":"word"},{"id":9920,"position":10,"arabic":"ٱلْحَصِيدِ","translation":"কৃষিজাত","audioUrl":"wbw/050_009_010.mp3","charTypeName":"word"},{"id":9921,"position":11,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"وَٱلنَّخْلَ بَاسِقَٰتٍۢ لَّهَا طَلْعٌۭ نَّضِيدٌۭ","translation":"and tall palm-trees with their thickly-clustered dates,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4640.mp3","surahId":50,"words":[{"id":11106,"posit