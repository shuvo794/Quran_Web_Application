{"id":499,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ حمٓ","translation":"Ha. Mim.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4474.mp3","surahId":45,"words":[{"id":167,"position":1,"arabic":"حمٓ","translation":"হা-মীম","audioUrl":"wbw/045_001_001.mp3","charTypeName":"word"},{"id":168,"position":2,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"تَنزِيلُ ٱلْكِتَٰبِ مِنَ ٱللَّهِ ٱلْعَزِيزِ ٱلْحَكِيمِ","translation":"THE BESTOWAL from on high of this divine writ issues from God, the Almighty, the Wise.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4475.mp3","surahId":45,"words":[{"id":1000,"position":1,"arabic":"تَنزِيلُ","translation":"অবতীর্ণ করা","audioUrl":"wbw/045_002_001.mp3","charTypeName":"word"},{"id":1001,"position":2,"arabic":"ٱلْكِتَـٰبِ","translation":"এই কিতাব","audioUrl":"wbw/045_002_002.mp3","charTypeName":"word"},{"id":1002,"position":3,"arabic":"مِنَ","translation":"পক্ষ হতে","audioUrl":"wbw/045_002_003.mp3","charTypeName":"word"},{"id":1003,"position":4,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/045_002_004.mp3","charTypeName":"word"},{"id":1004,"position":5,"arabic":"ٱلْعَزِيزِ","translation":"(যিনি) পরাক্রমশালী","audioUrl":"wbw/045_002_005.mp3","charTypeName":"word"},{"id":1005,"position":6,"arabic":"ٱلْحَكِيمِ","translation":"প্রজ্ঞাময়","audioUrl":"wbw/045_002_006.mp3","charTypeName":"word"},{"id":1006,"position":7,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"إِنَّ فِى ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ لَءَايَٰتٍۢ لِّلْمُؤْمِنِينَ","translation":"Behold, in the heavens as well as on earth there are indeed messages for all who [are willing to] believe.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4476.mp3","surahId":45,"words":[{"id":2097,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/045_003_001.mp3","charTypeName":"word"},{"id":2098,"position":2,"arabic":"فِى","translation":"মধ্যে রয়েছে","audioUrl":"wbw/045_003_002.mp3","charTypeName":"word"},{"id":2099,"position":3,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশমণ্ডলীর","audioUrl":"wbw/045_003_003.mp3","charTypeName":"word"},{"id":2100,"position":4,"arabic":"وَٱلْأَرْضِ","translation":"ও পৃথিবীর","audioUrl":"wbw/045_003_004.mp3","charTypeName":"word"},{"id":2101,"position":5,"arabic":"لَـَٔايَـٰتٍۢ","translation":"অবশ্যই নির্দশনাবলী","audioUrl":"wbw/045_003_005.mp3","charTypeName":"word"},{"id":2102,"position":6,"arabic":"لِّلْمُؤْمِنِينَ","translation":"মু'মিনদের জন্যে","audioUrl":"wbw/045_003_006.mp3","charTypeName":"word"},{"id":2103,"position":7,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"وَفِى خَلْقِكُمْ وَمَا يَبُثُّ مِن دَآبَّةٍ ءَايَٰتٌۭ لِّقَوْمٍۢ يُوقِنُونَ","translation":"And in your own nature, and in [that of] all the animals which He scatters [over the earth] there are messages for people who are endowed with inner certainty.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4477.mp3","surahId":45,"words":[{"id":3363,"position":1,"arabic":"وَفِى","translation":"এবং মধ্যেও","audioUrl":"wbw/045_004_001.mp3","charTypeName":"word"},{"id":3364,"position":2,"arabic":"خَلْقِكُمْ","translation":"তোমাদের সৃষ্টির","audioUrl":"wbw/045_004_002.mp3","charTypeName":"word"},{"id":3365,"position":3,"arabic":"وَمَا","translation":"এবং যা কিছু","audioUrl":"wbw/045_004_003.mp3","charTypeName":"word"},{"id":3366,"position":4,"arabic":"يَبُثُّ","translation":"তিনি (যমীনে) ছড়িয়ে দিয়েছেন","audioUrl":"wbw/045_004_004.mp3","charTypeName":"word"},{"id":3367,"position":5,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/045_004_005.mp3","charTypeName":"word"},{"id":3368,"position":6,"arabic":"دَآبَّةٍ","translation":"জীবজন্তু","audioUrl":"wbw/045_004_006.mp3","charTypeName":"word"},{"id":3369,"position":7,"arabic":"ءَايَـٰتٌۭ","translation":"নিদর্শনাবলী (রয়েছে)","audioUrl":"wbw/045_004_007.mp3","charTypeName":"word"},{"id":3370,"position":8,"arabic":"لِّقَوْمٍۢ","translation":"লোকদের জন্যে","audioUrl":"wbw/045_004_008.mp3","charTypeName":"word"},{"id":3371,"position":9,"arabic":"يُوقِنُونَ","translation":"(যারা) দৃঢ় বিশ্বাস করে","audioUrl":"wbw/045_004_009.mp3","charTypeName":"word"},{"id":3372,"position":10,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"وَٱخْتِلَٰفِ ٱلَّيْلِ وَٱلنَّهَارِ وَمَآ أَنزَلَ ٱللَّهُ مِنَ ٱلسَّمَآءِ مِن رِّزْقٍۢ فَأَحْيَا بِهِ ٱلْأَرْضَ بَعْدَ مَوْتِهَا وَتَصْرِيفِ ٱلرِّيَٰحِ ءَايَٰتٌۭ لِّقَوْمٍۢ يَعْقِلُونَ","translation":"And in the succession of night and day, and in the means of subsistence which God sends down from the skies, giving life thereby to the earth after it had been lifeless, and in the change of the winds: [in all this] there are messages for people who use their reason.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4478.mp3","surahId":45,"words":[{"id":4751,"position":1,"arabic":"وَٱخْتِلَـٰفِ","translation":"এবং পরিবর্তনে","audioUrl":"wbw/045_005_001.mp3","charTypeName":"word"},{"id":4752,"position":2,"arabic":"ٱلَّيْلِ","translation":"রাতের","audioUrl":"wbw/045_005_002.mp3","charTypeName":"word"},{"id":4753,"position":3,"arabic":"وَٱلنَّهَارِ","translation":"ও দিনের","audioUrl":"wbw/045_005_003.mp3","charTypeName":"word"},{"id":4754,"position":4,"arabic":"وَمَآ","translation":"এবং যা কিছু","audioUrl":"wbw/045_005_004.mp3","charTypeName":"word"},{"id":4755,"position":5,"arabic":"أَنزَلَ","translation":"অবতীর্ণ করেন","audioUrl":"wbw/045_005_005.mp3","charTypeName":"word"},{"id":4756,"position":6,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/045_005_006.mp3","charTypeName":"word"},{"id":4757,"position":7,"arabic":"مِنَ","translation":"থেকে","audioUrl":"wbw/045_005_007.mp3","charTypeName":"word"},{"id":4758,"position":8,"arabic":"ٱلسَّمَآءِ","translation":"আকাশ","audioUrl":"wbw/045_005_008.mp3","charTypeName":"word"},{"id":4759,"position":9,"arabic":"مِن","translation":"মধ্য থেকে","audioUrl":"wbw/045_005_009.mp3","charTypeName":"word"},{"id":4760,"position":10,"arabic":"رِّزْقٍۢ","translation":"আহার্য (অর্থাৎ পানি)","audioUrl":"wbw/045_005_010.mp3","charTypeName":"word"},{"id":4761,"position":11,"arabic":"فَأَحْيَا","translation":"অতঃপর জীবন্ত করেন","audioUrl":"wbw/045_005_011.mp3","charTypeName":"word"},{"id":4762,"position":12,"arabic":"بِهِ","translation":"তা দিয়ে","audioUrl":"wbw/045_005_012.mp3","charTypeName":"word"},{"id":4763,"position":13,"arabic":"ٱلْأَرْضَ","translation":"পৃথিবীকে","audioUrl":"wbw/045_005_013.mp3","charTypeName":"word"},{"id":4764,"position":14,"arabic":"بَعْدَ","translation":"পরে","audioUrl":"wbw/045_005_014.mp3","charTypeName":"word"},{"id":4765,"position":15,"arabic":"مَوْتِهَا","translation":"তার মৃত্যুর","audioUrl":"wbw/045_005_015.mp3","charTypeName":"word"},{"id":4766,"position":16,"arabic":"وَتَصْرِيفِ","translation":"এবং আবর্তনে","audioUrl":"wbw/045_005_016.mp3","charTypeName":"word"},{"id":4767,"position":17,"arabic":"ٱلرِّيَـٰحِ","translation":"বায়ুর","audioUrl":"wbw/045_005_017.mp3","charTypeName":"word"},{"id":4768,"position":18,"arabic":"ءَايَـٰتٌۭ","translation":"নির্দশনাবলী (রয়েছে)","audioUrl":"wbw/045_005_018.mp3","charTypeName":"word"},{"id":4769,"position":19,"arabic":"لِّقَوْمٍۢ","translation":"লোকদের জন্যে (যারা)","audioUrl":"wbw/045_005_019.mp3","charTypeName":"word"},{"id":4770,"position":20,"arabic":"يَعْقِلُونَ","translation":"বুদ্ধিবিবেক কাজে লাগায়","audioUrl":"wbw/045_005_020.mp3","charTypeName":"word"},{"id":4771,"position":21,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"تِلْكَ ءَايَٰتُ ٱللَّهِ نَتْلُوهَا عَلَيْكَ بِٱلْحَقِّ ۖ فَبِأَىِّ حَدِيثٍۭ بَعْدَ ٱللَّهِ وَءَايَٰتِهِۦ يُؤْمِنُونَ","translation":"These messages of God do We convey unto thee, setting forth the truth. In what other tiding, if not in God’s messages, will they, then, believe?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4479.mp3","surahId":45,"words":[{"id":6008,"position":1,"arabic":"تِلْكَ","translation":"এসব","audioUrl":"wbw/045_006_001.mp3","charTypeName":"word"},{"id":6009,"position":2,"arabic":"ءَايَـٰتُ","translation":"নির্দশনাবলী","audioUrl":"wbw/045_006_002.mp3","charTypeName":"word"},{"id":6010,"position":3,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/045_006_003.mp3","charTypeName":"word"},{"id":6011,"position":4,"arabic":"نَتْلُوهَا","translation":"তার আবৃত্তি/ তিলাওয়াত করছি আমরা","audioUrl":"wbw/045_006_004.mp3","charTypeName":"word"},{"id":6012,"position":5,"arabic":"عَلَيْكَ","translation":"তোমার কাছে","audioUrl":"wbw/045_006_005.mp3","charTypeName":"word"},{"id":6013,"position":6,"arabic":"بِٱلْحَقِّ ۖ","translation":"যথাযথভাবে","audioUrl":"wbw/045_006_006.mp3","charTypeName":"word"},{"id":6015,"position":7,"arabic":"فَبِأَىِّ","translation":"সুতরাং কোন","audioUrl":"wbw/045_006_008.mp3","charTypeName":"word"},{"id":6016,"position":8,"arabic":"حَدِيثٍۭ","translation":"কথার (উপর)","audioUrl":"wbw/045_006_009.mp3","charTypeName":"word"},{"id":6017,"position":9,"arabic":"بَعْدَ","translation":"পরে","audioUrl":"wbw/045_006_010.mp3","charTypeName":"word"},{"id":6018,"position":10,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/045_006_011.mp3","charTypeName":"word"},{"id":6019,"position":11,"arabic":"وَءَايَـٰتِهِۦ","translation":"ও তাঁর আয়াত গুলোর","audioUrl":"wbw/045_006_012.mp3","charTypeName":"word"},{"id":6020,"position":12,"arabic":"يُؤْمِنُونَ","translation":"তারা বিশ্বাস করবে?","audioUrl":"wbw/045_006_013.mp3","charTypeName":"word"},{"id":6021,"position":13,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"وَيْلٌۭ لِّكُلِّ أَفَّاكٍ أَثِيمٍۢ","translation":"Woe unto every sinful self-deceiver","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4480.mp3","surahId":45,"words":[{"id":7323,"position":1,"arabic":"وَيْلٌۭ","translation":"দুর্ভোগ","audioUrl":"wbw/045_007_001.mp3","charTypeName":"word"},{"id":7324,"position":2,"arabic":"لِّكُلِّ","translation":"প্রত্যেকের জন্য","audioUrl":"wbw/045_007_002.mp3","charTypeName":"word"},{"id":7325,"position":3,"arabic":"أَفَّاكٍ","translation":"ঘোর মিথ্যাবাদীর","audioUrl":"wbw/045_007_003.mp3","charTypeName":"word"},{"id":7326,"position":4,"arabic":"أَثِيمٍۢ","translation":"পাপীর","audioUrl":"wbw/045_007_004.mp3","charTypeName":"word"},{"id":7327,"position":5,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"يَسْمَعُ ءَايَٰتِ ٱللَّهِ تُتْلَىٰ عَلَيْهِ ثُمَّ يُصِرُّ مُسْتَكْبِرًۭا كَأَن لَّمْ يَسْمَعْهَا ۖ فَبَشِّرْهُ بِعَذَابٍ أَلِيمٍۢ","translation":"who hears God’s messages when they are conveyed to him, and yet, as though he had not heard them, persists in his haughty disdain! Hence, announce unto him grievous suffering –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4481.mp3","surahId":45,"words":[{"id":8599,"position":1,"arabic":"يَسْمَعُ","translation":"(যে) শুনে","audioUrl":"wbw/045_008_001.mp3","charTypeName":"word"},{"id":8600,"position":2,"arabic":"ءَايَـٰتِ","translation":"আয়াত সমূহ","audioUrl":"wbw/045_008_002.mp3","charTypeName":"word"},{"id":8601,"position":3,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/045_008_003.mp3","charTypeName":"word"},{"id":8602,"position":4,"arabic":"تُتْلَىٰ","translation":"পাঠ করা হয় (যা)","audioUrl":"wbw/045_008_004.mp3","charTypeName":"word"},{"id":8603,"position":5,"arabic":"عَلَيْهِ","translation":"তার কাছে","audioUrl":"wbw/045_008_005.mp3","charTypeName":"word"},{"id":8604,"position":6,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/045_008_006.mp3","charTypeName":"word"},{"id":8605,"position":7,"arabic":"يُصِرُّ","translation":"অটল থাকে","audioUrl":"wbw/045_008_007.mp3","charTypeName":"word"},{"id":8606,"position":8,"arabic":"مُسْتَكْبِرًۭا","translation":"ঔদ্ধত্যের সাথে","audioUrl":"wbw/045_008_008.mp3","charTypeName":"word"},{"id":8607,"position":9,"arabic":"كَأَن","translation":"যেন","audioUrl":"wbw/045_008_009.mp3","charTypeName":"word"},{"id":8608,"position":10,"arabic":"لَّمْ","translation":"নি","audioUrl":"wbw/045_008_010.mp3","charTypeName":"word"},{"id":8609,"position":11,"arabic":"يَسْمَعْهَا ۖ","translation":"তা শুনেই","audioUrl":"wbw/045_008_011.mp3","charTypeName":"word"},{"id":8611,"position":12,"arabic":"فَبَشِّرْهُ","translation":"তাই তাকে সুসংবাদ দাও","audioUrl":"wbw/045_008_013.mp3","charTypeName":"word"},{"id":8612,"position":13,"arabic":"بِعَذَابٍ","translation":"শাস্তির","audioUrl":"wbw/045_008_014.mp3","charTypeName":"word"},{"id":8613,"position":14,"arabic":"أَلِيمٍۢ","translation":"যন্ত্রণাদায়ক","audioUrl":"wbw/045_008_015.mp3","charTypeName":"word"},{"id":8614,"position":15,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"وَإِذَا عَلِمَ مِنْ ءَايَٰتِنَا شَيْـًٔا ٱتَّخَذَهَا هُزُوًا ۚ أُو۟لَٰٓئِكَ لَهُمْ عَذَابٌۭ مُّهِينٌۭ","translation":"for when he does become aware of any of Our messages, he makes them a target of his mockery! For all such there is shameful suffering in store.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4482.mp3","surahId":45,"words":[{"id":9802,"position":1,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/045_009_001.mp3","charTypeName":"word"},{"id":9803,"position":2,"arabic":"عَلِمَ","translation":"সে অবগত হয়","audioUrl":"wbw/045_009_002.mp3","charTypeName":"word"},{"id":9804,"position":3,"arabic":"مِنْ","translation":"মধ্য হতে","audioUrl":"wbw/045_009_003.mp3","charTypeName":"word"},{"id":9805,"position":4,"arabic":"ءَايَـٰتِنَا","translation":"আমাদের আয়াত সমূহের","audioUrl":"wbw/045_009_004.mp3","charTypeName":"word"},{"id":9806,"position":5,"arabic":"شَيْـًٔا","translation":"কোনো কিছু","audioUrl":"wbw/045_009_005.mp3","charTypeName":"word"},{"id":9807,"position":6,"arabic":"ٱتَّخَذَهَا","translation":"সে গ্রহণ করে তা","audioUrl":"wbw/045_009_006.mp3","charTypeName":"word"},{"id":9808,"position":7,"arabic":"هُزُوًا ۚ","translation":"বিদ্রুপ রূপে","audioUrl":"wbw/045_009_007.mp3","charTypeName":"word"},{"id":9810,"position":8,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐসব লোক","audioUrl":"wbw/045_009_009.mp3","charTypeName":"word"},{"id":9811,"position":9,"arabic":"لَهُمْ","translation":"তাদের জন্যে রয়েছে","audioUrl":"wbw/045_009_010.mp3","charTypeName":"word"},{"id":9812,"position":10,"arabic":"عَذَابٌۭ","translation":"শাস্তি","audioUrl":"wbw/045_009_011.mp3","charTypeName":"word"},{"id":9813,"position":11,"arabic":"مُّهِينٌۭ","translation":"অপমানকর","audioUrl":"wbw/045_009_012.mp3","charTypeName":"word"},{"id":9814,"position":12,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"مِّن وَرَآئِهِمْ جَهَنَّمُ ۖ وَلَا يُغْنِى عَنْهُم مَّا كَسَبُوا۟ شَيْـًۭٔا وَلَا مَا ٱتَّخَذُوا۟ مِن دُونِ ٱللَّهِ أَوْلِيَآءَ ۖ وَلَهُمْ عَذَابٌ عَظِيمٌ","translation":"Hell is ahead of them; and all that they may have gained [in this world] shall be of no avail whatever to them, and neither shall any of those things which, instead of God, they have come to regard as their protectors: for, awesome suffering awaits them.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4483.mp3","surahId":45,"words":[{"id":10968,"position":1,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/045_010_001.mp3","charTypeName":"word"},{"id":10969,"position":2,"arabic":"وَرَآئِهِمْ","translation":"তাদের পিছনে (রয়েছে)","audioUrl":"wbw/045_010_002.mp3","charTypeName":"word"},{"id":10970,"position":3,"arabic":"جَهَنَّمُ ۖ","translation":"জাহান্নাম","audioUrl":"wbw/045_010_003.mp3","charTypeName":"word"},{"id":10972,"position":4,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/045_010_005.mp3","charTypeName":"word"},{"id":10973,"position":5,"arabic":"يُغْنِى","translation":"কাজে আসবে","audioUrl":"wbw/045_010_006.mp3","charTypeName":"word"},{"id":10974,"position":6,"arabic":"عَنْهُم","translation":"তাদের জন্যে","audioUrl":"wbw/045_010_007.mp3","charTypeName":"word"},{"id":10975,"position":7,"arabic":"مَّا","translation":"যা কিছু","audioUrl":"wbw/045_010_008.mp3","charTypeName":"word"},{"id":10976,"position":8,"arabic":"كَسَبُوا۟","translation":"তারা অর্জন করেছে","audioUrl":"wbw/045_010_009.mp3","charTypeName":"word"},{"id":10977,"position":9,"arabic":"شَيْـًۭٔا","translation":"(তার) কোন কিছুই","audioUrl":"wbw/045_010_010.mp3","charTypeName":"word"},{"id":10978,"position":10,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/045_010_011.mp3","charTypeName":"word"},{"id":10979,"position":11,"arabic":"مَا","translation":"যা কিছু","audioUrl":"wbw/045_010_012.mp3","charTypeName":"word"},{"id":10980,"position":12,"arabic":"ٱتَّخَذُوا۟","translation":"তারা গ্রহণ করেছে","audioUrl":"wbw/045_010_013.mp3","charTypeName":"word"},{"id":10981,"position":13,"arabic":"مِن","translation":"মধ্য হতে","audioUrl":"wbw/045_010_014.mp3","charTypeName":"word"},{"id":10982,"position":14,"arabic":"دُونِ","translation":"ছাড়া/ পরিবর্তে","audioUrl":"wbw/045_010_015.mp3","charTypeName":"word"},{"id":10983,"position":15,"arabic":"ٱللَّهِ","translation":"আল্লাহকে","audioUrl":"wbw/045_010_016.mp3","charTypeName":"word"},{"id":10984,"position":16,"arabic":"أَوْلِيَآءَ ۖ","translation":"অভিভাবক রূপে","audioUrl":"wbw/045_010_017.mp3","charTypeName":"word"},{"id":10986,"position":17,"arabic":"وَلَهُمْ","translation":"এবং তাদের জন্যে রয়েছে","audioUrl":"wbw/045_010_019.mp3","charTypeName":"word"},{"id":10987,"position":18,"arabic":"عَذَابٌ","translation":"শাস্তি","audioUrl":"wbw/045_010_020.mp3","charTypeName":"word"},{"id":10988,"position":19,"arabic":"عَظِيمٌ","translation":"ভয়ানক","audioUrl":"wbw/045_010_021.mp3","charTypeName":"word"},{"id":10989,"position":20,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"هَٰذَا هُدًۭى ۖ وَٱلَّذِينَ كَفَرُوا۟ بِـَٔايَٰتِ رَبِّهِمْ لَهُمْ عَذَابٌۭ مِّن رِّجْزٍ أَلِيمٌ","translation":"[To pay heed to God’s signs and messages:] this is [the meaning of] guidance; on the other hand, for those who are bent on denying the truth of their Sustainer’s messages there is grievous suffering in store as an outcome of [their] vileness.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4484.mp3","surahId":45,"words":[{"id":12272,"position":1,"arabic":"هَـٰذَا","translation":"এই (কুরআন)","audioUrl":"wbw/045_011_001.mp3","charTypeName":"word"},{"id":12273,"position":2,"arabic":"هُدًۭى ۖ","translation":"সৎপথের দিশারি","audioUrl":"wbw/045_011_002.mp3","charTypeName":"word"},{"id":12275,"position":3,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/045_011_004.mp3","charTypeName":"word"},{"id":12276,"position":4,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/045_011_005.mp3","charTypeName":"word"},{"id":12277,"position":5,"arabic":"بِـَٔايَـٰتِ","translation":"নিদর্শনাবলীকে","audioUrl":"wbw/045_011_006.mp3","charTypeName":"word"},{"id":12278,"position":6,"arabic":"رَبِّهِمْ","translation":"তাদের রবের","audioUrl":"wbw/045_011_007.mp3","charTypeName":"word"},{"id":12279,"position":7,"arabic":"لَهُمْ","translation":"তাদের জন্যে রয়েছে","audioUrl":"wbw/045_011_008.mp3","charTypeName":"word"},{"id":12280,"position":8,"arabic":"عَذَابٌۭ","translation":"শাস্তি","audioUrl":"wbw/045_011_009.mp3","charTypeName":"word"},{"id":12281,"position":9,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/045_011_010.mp3","charTypeName":"word"},{"id":12282,"position":10,"arabic":"رِّجْزٍ","translation":"(বড় কঠিন) শাস্তি","audioUrl":"wbw/045_011_011.mp3","charTypeName":"word"},{"id":12283,"position":11,"arabic":"أَلِيمٌ","translation":"যন্ত্রণাদায়ক","audioUrl":"wbw/045_011_012.mp3","charTypeName":"word"},{"id":12284,"position":12,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]},{"number":12,"arabic":"۞ ٱللَّهُ ٱلَّذِى سَخَّرَ لَكُمُ ٱلْبَحْرَ لِتَجْرِىَ ٱلْفُلْكُ فِيهِ بِأَمْرِهِۦ وَلِتَبْتَغُوا۟ مِن فَضْلِهِۦ وَلَعَلَّكُمْ تَشْكُرُونَ","translation":"IT IS GOD who has made the sea subservient [to His laws, so that it be of use] to you so that ships might sail through it at His behest, and that you might seek to obtain [what you need] of His bounty, and that you might have cause to be grateful.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4485.mp3","surahId":45,"words":[{"id":13615,"position":1,"arabic":"۞ ٱللَّهُ","translation":"(তিনিই) আল্লাহ","audioUrl":"wbw/045_012_002.mp3","charTypeName":"word"},{"id":13616,"position":2,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/045_012_003.mp3","charTypeName":"word"},{"id":13617,"position":3,"arabic":"سَخَّرَ","translation":"অধীন করে দিয়েছেন","audioUrl":"wbw/045_012_004.mp3","charTypeName":"word"},{"id":13618,"position":4,"arabic":"لَكُمُ","translation":"তোমাদের জন্যে","audioUrl":"wbw/045_012_005.mp3","charTypeName":"word"},{"id":13619,"position":5,"arabic":"ٱلْبَحْرَ","translation":"সমুদ্রকে","audioUrl":"wbw/045_012_006.mp3","charTypeName":"word"},{"id":13620,"position":6,"arabic":"لِتَجْرِىَ","translation":"যেন চলাচল করতে থাকে","audioUrl":"wbw/045_012_007.mp3","charTypeName":"word"},{"id":13621,"position":7,"arabic":"ٱلْفُلْكُ","translation":"নৌযানসমূহ","audioUrl":"wbw/045_012_008.mp3","charTypeName":"word"},{"id":13622,"position":8,"arabic":"فِيهِ","translation":"তার মধ্যে","audioUrl":"wbw/045_012_009.mp3","charTypeName":"word"},{"id":13623,"position":9,"arabic":"بِأَمْرِهِۦ","translation":"তাঁর নির্দেশের মাধ্যমে","audioUrl":"wbw/045_012_010.mp3","charTypeName":"word"},{"id":13624,"position":10,"arabic":"وَلِتَبْتَغُوا۟","translation":"এবং যেন তোমরা সন্ধান করতে পার","audioUrl":"wbw/045_012_011.mp3","charTypeName":"word"},{"id":13625,"position":11,"arabic":"مِن","translation":"হতে","audioUrl":"wbw/045_012_012.mp3","charTypeName":"word"},{"id":13626,"position":12,"arabic":"فَضْلِهِۦ","translation":"তাঁর অনুগ্রহ","audioUrl":"wbw/045_012_013.mp3","charTypeName":"word"},{"id":13627,"position":13,"arabic":"وَلَعَلَّكُمْ","translation":"এবং যাতে তোমরা","audioUrl":"wbw/045_012_014.mp3","charTypeName":"word"},{"id":13628,"position":14,"arabic":"تَشْكُرُونَ","translation":"কৃতজ্ঞ হও","audioUrl":"wbw/045_012_015.mp3","charTypeName":"word"},{"id":13629,"position":15,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]},{"number":13,"arabic":"وَسَخَّرَ لَكُم مَّا فِى ٱلسَّمَٰوَٰتِ وَمَا فِى ٱلْأَرْضِ جَمِيعًۭا مِّنْهُ ۚ إِنَّ فِى ذَٰلِكَ لَءَايَٰتٍۢ لِّقَوْمٍۢ يَتَفَكَّرُونَ","translation":"And He has made subservient to you, [as a gift] from Himself, all that is in the heavens and on earth: in this, behold, there are messages indeed for people who think!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4486.mp3","surahId":45,"words":[{"id":14810,"position":1,"arabic":"وَسَخَّرَ","translation":"এবং অধীন করে দিয়েছেন","audioUrl":"wbw/045_013_001.mp3","charTypeName":"word"},{"id":14811,"position":2,"arabic":"لَكُم","translation":"তোমাদের জন্যে","audioUrl":"wbw/045_013_002.mp3","charTypeName":"word"},{"id":14812,"position":3,"arabic":"مَّا","translation":"যা কিছু","audioUrl":"wbw/045_013_003.mp3","charTypeName":"word"},{"id":14813,"position":4,"arabic":"فِى","translation":"মধ্যে আছে","audioUrl":"wbw/045_013_004.mp3","charTypeName":"word"},{"id":14814,"position":5,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশের","audioUrl":"wbw/045_013_005.mp3","charTypeName":"word"},{"id":14815,"position":6,"arabic":"وَمَا","translation":"ও যা কিছু","audioUrl":"wbw/045_013_006.mp3","charTypeName":"word"},{"id":14816,"position":7,"arabic":"فِى","translation":"মধ্যে আছে","audioUrl":"wbw/045_013_007.mp3","charTypeName":"word"},{"id":14817,"position":8,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/045_013_008.mp3","charTypeName":"word"},{"id":14818,"position":9,"arabic":"جَمِيعًۭا","translation":"সবকিছুকেই","audioUrl":"wbw/045_013_009.mp3","charTypeName":"word"},{"id":14819,"position":10,"arabic":"مِّنْهُ ۚ","translation":"তাঁর নিকট হতে","audioUrl":"wbw/045_013_010.mp3","char