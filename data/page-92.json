{"id":92,"ayahs":[{"number":87,"arabic":"ٱللَّهُ لَآ إِلَٰهَ إِلَّا هُوَ ۚ لَيَجْمَعَنَّكُمْ إِلَىٰ يَوْمِ ٱلْقِيَٰمَةِ لَا رَيْبَ فِيهِ ۗ وَمَنْ أَصْدَقُ مِنَ ٱللَّهِ حَدِيثًۭا","translation":"God - save whom there is no deity - will surely gather you all together on the Day of Resurrection, [the coming of] which is beyond all doubt: and whose word could be truer than God's?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/580.mp3","surahId":4,"words":[{"id":66842,"position":1,"arabic":"ٱللَّهُ","translation":"আল্লাহ (এমন সত্তা যে)","audioUrl":"wbw/004_087_001.mp3","charTypeName":"word"},{"id":66843,"position":2,"arabic":"لَآ","translation":"নাই","audioUrl":"wbw/004_087_002.mp3","charTypeName":"word"},{"id":66844,"position":3,"arabic":"إِلَـٰهَ","translation":"কোন ইলাহ","audioUrl":"wbw/004_087_003.mp3","charTypeName":"word"},{"id":66845,"position":4,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/004_087_004.mp3","charTypeName":"word"},{"id":66846,"position":5,"arabic":"هُوَ ۚ","translation":"তিনি","audioUrl":"wbw/004_087_005.mp3","charTypeName":"word"},{"id":66848,"position":6,"arabic":"لَيَجْمَعَنَّكُمْ","translation":"তোমাদের একত্রিত করবেনই","audioUrl":"wbw/004_087_007.mp3","charTypeName":"word"},{"id":66849,"position":7,"arabic":"إِلَىٰ","translation":"(থেকে)","audioUrl":"wbw/004_087_008.mp3","charTypeName":"word"},{"id":66850,"position":8,"arabic":"يَوْمِ","translation":"দিনে","audioUrl":"wbw/004_087_009.mp3","charTypeName":"word"},{"id":66851,"position":9,"arabic":"ٱلْقِيَـٰمَةِ","translation":"কিয়ামাতের","audioUrl":"wbw/004_087_010.mp3","charTypeName":"word"},{"id":66852,"position":10,"arabic":"لَا","translation":"নাই","audioUrl":"wbw/004_087_011.mp3","charTypeName":"word"},{"id":66853,"position":11,"arabic":"رَيْبَ","translation":"কোন সন্দেহ (বিন্দুমাত্র)","audioUrl":"wbw/004_087_012.mp3","charTypeName":"word"},{"id":66854,"position":12,"arabic":"فِيهِ ۗ","translation":"তারে মধ্যে","audioUrl":"wbw/004_087_013.mp3","charTypeName":"word"},{"id":66856,"position":13,"arabic":"وَمَنْ","translation":"এবং কে","audioUrl":"wbw/004_087_015.mp3","charTypeName":"word"},{"id":66857,"position":14,"arabic":"أَصْدَقُ","translation":"অধিক সত্য","audioUrl":"wbw/004_087_016.mp3","charTypeName":"word"},{"id":66858,"position":15,"arabic":"مِنَ","translation":"চেয়ে","audioUrl":"wbw/004_087_017.mp3","charTypeName":"word"},{"id":66859,"position":16,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/004_087_018.mp3","charTypeName":"word"},{"id":66860,"position":17,"arabic":"حَدِيثًۭا","translation":"কথায়","audioUrl":"wbw/004_087_019.mp3","charTypeName":"word"},{"id":66861,"position":18,"arabic":"٨٧","translation":"(৮৭)","audioUrl":null,"charTypeName":"end"}]},{"number":88,"arabic":"۞ فَمَا لَكُمْ فِى ٱلْمُنَٰفِقِينَ فِئَتَيْنِ وَٱللَّهُ أَرْكَسَهُم بِمَا كَسَبُوٓا۟ ۚ أَتُرِيدُونَ أَن تَهْدُوا۟ مَنْ أَضَلَّ ٱللَّهُ ۖ وَمَن يُضْلِلِ ٱللَّهُ فَلَن تَجِدَ لَهُۥ سَبِيلًۭا","translation":"How, then, could you be of two minds about the hypocrites, seeing that God [Himself] has disowned them because of their guilt? Do you, perchance, seek to guide those whom God has let go astray - when for him whom God lets go astray thou canst never find any way?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/581.mp3","surahId":4,"words":[{"id":67200,"position":1,"arabic":"۞ فَمَا","translation":"অতঃপর কি হয়েছে","audioUrl":"wbw/004_088_002.mp3","charTypeName":"word"},{"id":67201,"position":2,"arabic":"لَكُمْ","translation":"তোমাদের","audioUrl":"wbw/004_088_003.mp3","charTypeName":"word"},{"id":67202,"position":3,"arabic":"فِى","translation":"(মধ্যে)","audioUrl":"wbw/004_088_004.mp3","charTypeName":"word"},{"id":67203,"position":4,"arabic":"ٱلْمُنَـٰفِقِينَ","translation":"মুনাফিকদের","audioUrl":"wbw/004_088_005.mp3","charTypeName":"word"},{"id":67204,"position":5,"arabic":"فِئَتَيْنِ","translation":"(তোমরা) দুই মতের অধিকারী","audioUrl":"wbw/004_088_006.mp3","charTypeName":"word"},{"id":67205,"position":6,"arabic":"وَٱللَّهُ","translation":"অথচ আল্লাহই","audioUrl":"wbw/004_088_007.mp3","charTypeName":"word"},{"id":67206,"position":7,"arabic":"أَرْكَسَهُم","translation":"তাদের ঘুরিয়ে দিয়েছেন","audioUrl":"wbw/004_088_008.mp3","charTypeName":"word"},{"id":67207,"position":8,"arabic":"بِمَا","translation":"এ কারণে যা","audioUrl":"wbw/004_088_009.mp3","charTypeName":"word"},{"id":67208,"position":9,"arabic":"كَسَبُوٓا۟ ۚ","translation":"তারা অর্জন করেছে","audioUrl":"wbw/004_088_010.mp3","charTypeName":"word"},{"id":67210,"position":10,"arabic":"أَتُرِيدُونَ","translation":"কি তোমরা চাও","audioUrl":"wbw/004_088_012.mp3","charTypeName":"word"},{"id":67211,"position":11,"arabic":"أَن","translation":"যে","audioUrl":"wbw/004_088_013.mp3","charTypeName":"word"},{"id":67212,"position":12,"arabic":"تَهْدُوا۟","translation":"তোমরা হিদায়াত দিবে","audioUrl":"wbw/004_088_014.mp3","charTypeName":"word"},{"id":67213,"position":13,"arabic":"مَنْ","translation":"যাকে","audioUrl":"wbw/004_088_015.mp3","charTypeName":"word"},{"id":67214,"position":14,"arabic":"أَضَلَّ","translation":"পথভ্রষ্ট করেছেন","audioUrl":"wbw/004_088_016.mp3","charTypeName":"word"},{"id":67215,"position":15,"arabic":"ٱللَّهُ ۖ","translation":"আল্লাহ","audioUrl":"wbw/004_088_017.mp3","charTypeName":"word"},{"id":67217,"position":16,"arabic":"وَمَن","translation":"অথচ যাকে","audioUrl":"wbw/004_088_019.mp3","charTypeName":"word"},{"id":67218,"position":17,"arabic":"يُضْلِلِ","translation":"পথভ্রষ্ট করেন","audioUrl":"wbw/004_088_020.mp3","charTypeName":"word"},{"id":67219,"position":18,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/004_088_021.mp3","charTypeName":"word"},{"id":67220,"position":19,"arabic":"فَلَن","translation":"কক্ষনো না তখন","audioUrl":"wbw/004_088_022.mp3","charTypeName":"word"},{"id":67221,"position":20,"arabic":"تَجِدَ","translation":"পাবে তুমি","audioUrl":"wbw/004_088_023.mp3","charTypeName":"word"},{"id":67222,"position":21,"arabic":"لَهُۥ","translation":"তার জন্য","audioUrl":"wbw/004_088_024.mp3","charTypeName":"word"},{"id":67223,"position":22,"arabic":"سَبِيلًۭا","translation":"কোন পথ","audioUrl":"wbw/004_088_025.mp3","charTypeName":"word"},{"id":67224,"position":23,"arabic":"٨٨","translation":"(৮৮)","audioUrl":null,"charTypeName":"end"}]},{"number":89,"arabic":"وَدُّوا۟ لَوْ تَكْفُرُونَ كَمَا كَفَرُوا۟ فَتَكُونُونَ سَوَآءًۭ ۖ فَلَا تَتَّخِذُوا۟ مِنْهُمْ أَوْلِيَآءَ حَتَّىٰ يُهَاجِرُوا۟ فِى سَبِيلِ ٱللَّهِ ۚ فَإِن تَوَلَّوْا۟ فَخُذُوهُمْ وَٱقْتُلُوهُمْ حَيْثُ وَجَدتُّمُوهُمْ ۖ وَلَا تَتَّخِذُوا۟ مِنْهُمْ وَلِيًّۭا وَلَا نَصِيرًا","translation":"They would love to see you deny the truth even as they have denied it, so that you should be like them. Do not, therefore, take them for your allies until they forsake the domain of evil for the sake of God; and if they revert to [open] enmity, seize them and slay them wherever you may find them. And do not take any of them for your ally or giver of succour,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/582.mp3","surahId":4,"words":[{"id":67562,"position":1,"arabic":"وَدُّوا۟","translation":"তারা কামনা করে","audioUrl":"wbw/004_089_001.mp3","charTypeName":"word"},{"id":67563,"position":2,"arabic":"لَوْ","translation":"যদি","audioUrl":"wbw/004_089_002.mp3","charTypeName":"word"},{"id":67564,"position":3,"arabic":"تَكْفُرُونَ","translation":"তোমরা কাফির হয়ে যাও","audioUrl":"wbw/004_089_003.mp3","charTypeName":"word"},{"id":67565,"position":4,"arabic":"كَمَا","translation":"যেমন","audioUrl":"wbw/004_089_004.mp3","charTypeName":"word"},{"id":67566,"position":5,"arabic":"كَفَرُوا۟","translation":"তারা কাফির হয়েছে","audioUrl":"wbw/004_089_005.mp3","charTypeName":"word"},{"id":67567,"position":6,"arabic":"فَتَكُونُونَ","translation":"তবে তোমরা হয়ে যাবে","audioUrl":"wbw/004_089_006.mp3","charTypeName":"word"},{"id":67568,"position":7,"arabic":"سَوَآءًۭ ۖ","translation":"(তাদের সাথে) সমান","audioUrl":"wbw/004_089_007.mp3","charTypeName":"word"},{"id":67570,"position":8,"arabic":"فَلَا","translation":"না সুতরাং","audioUrl":"wbw/004_089_009.mp3","charTypeName":"word"},{"id":67571,"position":9,"arabic":"تَتَّخِذُوا۟","translation":"তোমরা গ্রহণ করো","audioUrl":"wbw/004_089_010.mp3","charTypeName":"word"},{"id":67572,"position":10,"arabic":"مِنْهُمْ","translation":"তাদেরকে","audioUrl":"wbw/004_089_011.mp3","charTypeName":"word"},{"id":67573,"position":11,"arabic":"أَوْلِيَآءَ","translation":"বন্ধুরূপে","audioUrl":"wbw/004_089_012.mp3","charTypeName":"word"},{"id":67574,"position":12,"arabic":"حَتَّىٰ","translation":"যতক্ষণ না","audioUrl":"wbw/004_089_013.mp3","charTypeName":"word"},{"id":67575,"position":13,"arabic":"يُهَاجِرُوا۟","translation":"তারা হিজরত করে","audioUrl":"wbw/004_089_014.mp3","charTypeName":"word"},{"id":67576,"position":14,"arabic":"فِى","translation":"(মধ্যে)","audioUrl":"wbw/004_089_015.mp3","charTypeName":"word"},{"id":67577,"position":15,"arabic":"سَبِيلِ","translation":"পথে","audioUrl":"wbw/004_089_016.mp3","charTypeName":"word"},{"id":67578,"position":16,"arabic":"ٱللَّهِ ۚ","translation":"আল্লাহর","audioUrl":"wbw/004_089_017.mp3","charTypeName":"word"},{"id":67580,"position":17,"arabic":"فَإِن","translation":"অতঃপর যদি","audioUrl":"wbw/004_089_019.mp3","charTypeName":"word"},{"id":67581,"position":18,"arabic":"تَوَلَّوْا۟","translation":"তারা মুখ ফিরায়","audioUrl":"wbw/004_089_020.mp3","charTypeName":"word"},{"id":67582,"position":19,"arabic":"فَخُذُوهُمْ","translation":"তবে তাদের তোমরা ধর","audioUrl":"wbw/004_089_021.mp3","charTypeName":"word"},{"id":67583,"position":20,"arabic":"وَٱقْتُلُوهُمْ","translation":"ও তাদেরকে হত্যা কর","audioUrl":"wbw/004_089_022.mp3","charTypeName":"word"},{"id":67584,"position":21,"arabic":"حَيْثُ","translation":"যেখানে","audioUrl":"wbw/004_089_023.mp3","charTypeName":"word"},{"id":67585,"position":22,"arabic":"وَجَدتُّمُوهُمْ ۖ","translation":"তাদের তোমরা পাও","audioUrl":"wbw/004_089_024.mp3","charTypeName":"word"},{"id":67587,"position":23,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/004_089_026.mp3","charTypeName":"word"},{"id":67588,"position":24,"arabic":"تَتَّخِذُوا۟","translation":"তোমরা গ্রহণ করো (কাউকে)","audioUrl":"wbw/004_089_027.mp3","charTypeName":"word"},{"id":67589,"position":25,"arabic":"مِنْهُمْ","translation":"তাদের মধ্য হতে","audioUrl":"wbw/004_089_028.mp3","charTypeName":"word"},{"id":67590,"position":26,"arabic":"وَلِيًّۭا","translation":"বন্ধুরূপে","audioUrl":"wbw/004_089_029.mp3","charTypeName":"word"},{"id":67591,"position":27,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/004_089_030.mp3","charTypeName":"word"},{"id":67592,"position":28,"arabic":"نَصِيرًا","translation":"সাহায্যকারীরূপে","audioUrl":"wbw/004_089_031.mp3","charTypeName":"word"},{"id":67593,"position":29,"arabic":"٨٩","translation":"(৮৯)","audioUrl":null,"charTypeName":"end"}]},{"number":90,"arabic":"إِلَّا ٱلَّذِينَ يَصِلُونَ إِلَىٰ قَوْمٍۭ بَيْنَكُمْ وَبَيْنَهُم مِّيثَٰقٌ أَوْ جَآءُوكُمْ حَصِرَتْ صُدُورُهُمْ أَن يُقَٰتِلُوكُمْ أَوْ يُقَٰتِلُوا۟ قَوْمَهُمْ ۚ وَلَوْ شَآءَ ٱللَّهُ لَسَلَّطَهُمْ عَلَيْكُمْ فَلَقَٰتَلُوكُمْ ۚ فَإِنِ ٱعْتَزَلُوكُمْ فَلَمْ يُقَٰتِلُوكُمْ وَأَلْقَوْا۟ إِلَيْكُمُ ٱلسَّلَمَ فَمَا جَعَلَ ٱللَّهُ لَكُمْ عَلَيْهِمْ سَبِيلًۭا","translation":"unless it be such [of them] as have ties with people to whom you yourselves are bound by a covenant, or such as come unto you because their hearts shrink from [the thought of] making war either on you or on their own folk - although, if God had willed to make them stronger than you, they would certainly have made war on you. Thus, if they let you be, and do not make war on you, and offer you peace, God does not allow you to harm them.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/583.mp3","surahId":4,"words":[{"id":67928,"position":1,"arabic":"إِلَّا","translation":"তবে","audioUrl":"wbw/004_090_001.mp3","charTypeName":"word"},{"id":67929,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/004_090_002.mp3","charTypeName":"word"},{"id":67930,"position":3,"arabic":"يَصِلُونَ","translation":"মিলিত হয়","audioUrl":"wbw/004_090_003.mp3","charTypeName":"word"},{"id":67931,"position":4,"arabic":"إِلَىٰ","translation":"সাথে","audioUrl":"wbw/004_090_004.mp3","charTypeName":"word"},{"id":67932,"position":5,"arabic":"قَوْمٍۭ","translation":"(এমন কোন) জাতির","audioUrl":"wbw/004_090_005.mp3","charTypeName":"word"},{"id":67933,"position":6,"arabic":"بَيْنَكُمْ","translation":"তোমাদের মাঝে","audioUrl":"wbw/004_090_006.mp3","charTypeName":"word"},{"id":67934,"position":7,"arabic":"وَبَيْنَهُم","translation":"ও তাদের মাঝে","audioUrl":"wbw/004_090_007.mp3","charTypeName":"word"},{"id":67935,"position":8,"arabic":"مِّيثَـٰقٌ","translation":"চুক্তি (রয়েছে)","audioUrl":"wbw/004_090_008.mp3","charTypeName":"word"},{"id":67936,"position":9,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/004_090_009.mp3","charTypeName":"word"},{"id":67937,"position":10,"arabic":"جَآءُوكُمْ","translation":"তোমাদের কাছে আসে (এমন ভাবে যে)","audioUrl":"wbw/004_090_010.mp3","charTypeName":"word"},{"id":67938,"position":11,"arabic":"حَصِرَتْ","translation":"অনিচ্ছুক","audioUrl":"wbw/004_090_011.mp3","charTypeName":"word"},{"id":67939,"position":12,"arabic":"صُدُورُهُمْ","translation":"তাদের অন্তর","audioUrl":"wbw/004_090_012.mp3","charTypeName":"word"},{"id":67940,"position":13,"arabic":"أَن","translation":"(যে)","audioUrl":"wbw/004_090_013.mp3","charTypeName":"word"},{"id":67941,"position":14,"arabic":"يُقَـٰتِلُوكُمْ","translation":"তোমাদের বিরুদ্ধে যুদ্ধ করতে","audioUrl":"wbw/004_090_014.mp3","charTypeName":"word"},{"id":67942,"position":15,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/004_090_015.mp3","charTypeName":"word"},{"id":67943,"position":16,"arabic":"يُقَـٰتِلُوا۟","translation":"যুদ্ধ করতে","audioUrl":"wbw/004_090_016.mp3","charTypeName":"word"},{"id":67944,"position":17,"arabic":"قَوْمَهُمْ ۚ","translation":"তাদের জাতির বিরুদ্ধে (তবে ভিন্ন কথা)","audioUrl":"wbw/004_090_017.mp3","charTypeName":"word"},{"id":67946,"position":18,"arabic":"وَلَوْ","tra