},{"id":68378,"position":5,"arabic":"يَأْمَنُوكُمْ","translation":"তোমাদের থেকে নিরাপত্তা পেতে","audioUrl":"wbw/004_091_005.mp3","charTypeName":"word"},{"id":68379,"position":6,"arabic":"وَيَأْمَنُوا۟","translation":"ও নিরাপত্তা পেতে","audioUrl":"wbw/004_091_006.mp3","charTypeName":"word"},{"id":68380,"position":7,"arabic":"قَوْمَهُمْ","translation":"তাদের জাতি হতেও","audioUrl":"wbw/004_091_007.mp3","charTypeName":"word"},{"id":68381,"position":8,"arabic":"كُلَّ","translation":"যখনই (সুযোগ পায়)","audioUrl":"wbw/004_091_008.mp3","charTypeName":"word"},{"id":68382,"position":9,"arabic":"مَا","translation":"(কি)","audioUrl":"wbw/004_091_009.mp3","charTypeName":"word"},{"id":68383,"position":10,"arabic":"رُدُّوٓا۟","translation":"তারা ফিরে যায়","audioUrl":"wbw/004_091_010.mp3","charTypeName":"word"},{"id":68384,"position":11,"arabic":"إِلَى","translation":"দিকে","audioUrl":"wbw/004_091_011.mp3","charTypeName":"word"},{"id":68385,"position":12,"arabic":"ٱلْفِتْنَةِ","translation":"ফিতনার","audioUrl":"wbw/004_091_012.mp3","charTypeName":"word"},{"id":68386,"position":13,"arabic":"أُرْكِسُوا۟","translation":"তারা ঝাঁপিয়ে পড়ে","audioUrl":"wbw/004_091_013.mp3","charTypeName":"word"},{"id":68387,"position":14,"arabic":"فِيهَا ۚ","translation":"তার মধ্যে","audioUrl":"wbw/004_091_014.mp3","charTypeName":"word"},{"id":68389,"position":15,"arabic":"فَإِن","translation":"অতএব যদি","audioUrl":"wbw/004_091_016.mp3","charTypeName":"word"},{"id":68390,"position":16,"arabic":"لَّمْ","translation":"না","audioUrl":"wbw/004_091_017.mp3","charTypeName":"word"},{"id":68391,"position":17,"arabic":"يَعْتَزِلُوكُمْ","translation":"তোমাদেরর থেকে সরে যায়","audioUrl":"wbw/004_091_018.mp3","charTypeName":"word"},{"id":68392,"position":18,"arabic":"وَيُلْقُوٓا۟","translation":"এবং প্রস্তাব ও (না) দেয়","audioUrl":"wbw/004_091_019.mp3","charTypeName":"word"},{"id":68393,"position":19,"arabic":"إِلَيْكُمُ","translation":"তোমাদের কাছে","audioUrl":"wbw/004_091_020.mp3","charTypeName":"word"},{"id":68394