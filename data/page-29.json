{"id":29,"ayahs":[{"number":187,"arabic":"أُحِلَّ لَكُمْ لَيْلَةَ ٱلصِّيَامِ ٱلرَّفَثُ إِلَىٰ نِسَآئِكُمْ ۚ هُنَّ لِبَاسٌۭ لَّكُمْ وَأَنتُمْ لِبَاسٌۭ لَّهُنَّ ۗ عَلِمَ ٱللَّهُ أَنَّكُمْ كُنتُمْ تَخْتَانُونَ أَنفُسَكُمْ فَتَابَ عَلَيْكُمْ وَعَفَا عَنكُمْ ۖ فَٱلْـَٰٔنَ بَٰشِرُوهُنَّ وَٱبْتَغُوا۟ مَا كَتَبَ ٱللَّهُ لَكُمْ ۚ وَكُلُوا۟ وَٱشْرَبُوا۟ حَتَّىٰ يَتَبَيَّنَ لَكُمُ ٱلْخَيْطُ ٱلْأَبْيَضُ مِنَ ٱلْخَيْطِ ٱلْأَسْوَدِ مِنَ ٱلْفَجْرِ ۖ ثُمَّ أَتِمُّوا۟ ٱلصِّيَامَ إِلَى ٱلَّيْلِ ۚ وَلَا تُبَٰشِرُوهُنَّ وَأَنتُمْ عَٰكِفُونَ فِى ٱلْمَسَٰجِدِ ۗ تِلْكَ حُدُودُ ٱللَّهِ فَلَا تَقْرَبُوهَا ۗ كَذَٰلِكَ يُبَيِّنُ ٱللَّهُ ءَايَٰتِهِۦ لِلنَّاسِ لَعَلَّهُمْ يَتَّقُونَ","translation":"IT IS lawful for you to go in unto your wives during the night preceding the [day's] fast: they are as a garment for you, and you are as a garment for them. God is aware that you would have deprived yourselves of this right, and so He has turned unto you in His mercy and removed this hardship from you. Now, then, you may lie with them skin to skin, and avail yourselves of that which God has ordained for you, and eat and drink until you can discern the white streak of dawn against the blackness of night, and then resume fasting until nightfall; but do not lie with them skin to skin when you are about to abide in meditation in houses of worship. These are the bounds set by God: do not, then, offend against them - [for] it is thus that God makes clear His messages unto mankind, so that they might remain conscious of Him.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/194.mp3","surahId":2,"words":[{"id":84355,"position":1,"arabic":"أُحِلَّ","translation":"(হালাল) করা হয়েছে","audioUrl":"wbw/002_187_001.mp3","charTypeName":"word"},{"id":84356,"position":2,"arabic":"لَكُمْ","translation":"তোমাদের জন্যে","audioUrl":"wbw/002_187_002.mp3","charTypeName":"word"},{"id":84357,"position":3,"arabic":"لَيْلَةَ","translation":"রাতে","audioUrl":"wbw/002_187_003.mp3","charTypeName":"word"},{"id":84358,"position":4,"arabic":"ٱلصِّيَامِ","translation":"সাওমের","audioUrl":"wbw/002_187_004.mp3","charTypeName":"word"},{"id":84359,"position":5,"arabic":"ٱلرَّفَثُ","translation":"স্ত্রী সহবাস","audioUrl":"wbw/002_187_005.mp3","charTypeName":"word"},{"id":84360,"position":6,"arabic":"إِلَىٰ","translation":"সাথে","audioUrl":"wbw/002_187_006.mp3","charTypeName":"word"},{"id":84361,"position":7,"arabic":"نِسَآئِكُمْ ۚ","translation":"তোমাদের স্ত্রীদের","audioUrl":"wbw/002_187_007.mp3","charTypeName":"word"},{"id":84363,"position":8,"arabic":"هُنَّ","translation":"তারা","audioUrl":"wbw/002_187_009.mp3","charTypeName":"word"},{"id":84364,"position":9,"arabic":"لِبَاسٌۭ","translation":"পোশাক","audioUrl":"wbw/002_187_010.mp3","charTypeName":"word"},{"id":84365,"position":10,"arabic":"لَّكُمْ","translation":"তোমাদের জন্যে","audioUrl":"wbw/002_187_011.mp3","charTypeName":"word"},{"id":84366,"position":11,"arabic":"وَأَنتُمْ","translation":"ও তোমরা","audioUrl":"wbw/002_187_012.mp3","charTypeName":"word"},{"id":84367,"position":12,"arabic":"لِبَاسٌۭ","translation":"পোশাক","audioUrl":"wbw/002_187_013.mp3","charTypeName":"word"},{"id":84368,"position":13,"arabic":"لَّهُنَّ ۗ","translation":"তাদের জন্যে","audioUrl":"wbw/002_187_014.mp3","charTypeName":"word"},{"id":84370,"position":14,"arabic":"عَلِمَ","translation":"জেনেছেন","audioUrl":"wbw/002_187_016.mp3","charTypeName":"word"},{"id":84371,"position":15,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/002_187_017.mp3","charTypeName":"word"},{"id":84372,"position":16,"arabic":"أَنَّكُمْ","translation":"তোমরা যে","audioUrl":"wbw/002_187_018.mp3","charTypeName":"word"},{"id":84373,"position":17,"arabic":"كُنتُمْ","translation":"তোমরা ছিলে","audioUrl":"wbw/002_187_019.mp3","charTypeName":"word"},{"id":84374,"position":18,"arabic":"تَخْتَانُونَ","translation":"প্রতারণা করতে","audioUrl":"wbw/002_187_020.mp3","charTypeName":"word"},{"id":84375,"position":19,"arabic":"أَنفُسَكُمْ","translation":"তোমাদের নিজেদের (সাথে)","audioUrl":"wbw/002_187_021.mp3","charTypeName":"word"},{"id":84376,"position":20,"arabic":"فَتَابَ","translation":"তওবা গ্রহণ করলেন","audioUrl":"wbw/002_187_022.mp3","charTypeName":"word"},{"id":84377,"position":21,"arabic":"عَلَيْكُمْ","translation":"তোমাদের উপর","audioUrl":"wbw/002_187_023.mp3","charTypeName":"word"},{"id":84378,"position":22,"arabic":"وَعَفَا","translation":"এবং ক্ষমা করলেন","audioUrl":"wbw/002_187_024.mp3","charTypeName":"word"},{"id":84379,"position":23,"arabic":"عَنكُمْ ۖ","translation":"তোমাদের","audioUrl":"wbw/002_187_025.mp3","charTypeName":"word"},{"id":84381,"position":24,"arabic":"فَٱلْـَٔـٰنَ","translation":"অতএব এখন","audioUrl":"wbw/002_187_027.mp3","charTypeName":"word"},{"id":84382,"position":25,"arabic":"بَـٰشِرُوهُنَّ","translation":"তাদের সাথে তোমরা সহবাস করো","audioUrl":"wbw/002_187_028.mp3","charTypeName":"word"},{"id":84383,"position":26,"arabic":"وَٱبْتَغُوا۟","translation":"এবং তোমরা সন্ধান করো","audioUrl":"wbw/002_187_029.mp3","charTypeName":"word"},{"id":84384,"position":27,"arabic":"مَا","translation":"যা","audioUrl":"wbw/002_187_030.mp3","charTypeName":"word"},{"id":84385,"position":28,"arabic":"كَتَبَ","translation":"লিখে দিয়েছেন","audioUrl":"wbw/002_187_031.mp3","charTypeName":"word"},{"id":84386,"position":29,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/002_187_032.mp3","charTypeName":"word"},{"id":84387,"position":30,"arabic":"لَكُمْ ۚ","translation":"তোমাদের জন্য","audioUrl":"wbw/002_187_033.mp3","charTypeName":"word"},{"id":84389,"position":31,"arabic":"وَكُلُوا۟","translation":"ও তোমরা খাও","audioUrl":"wbw/002_187_035.mp3","charTypeName":"word"},{"id":84390,"position":32,"arabic":"وَٱشْرَبُوا۟","translation":"ও তোমরা পান করো","audioUrl":"wbw/002_187_036.mp3","charTypeName":"word"},{"id":84391,"position":33,"arabic":"حَتَّىٰ","translation":"যতক্ষণ না","audioUrl":"wbw/002_187_037.mp3","charTypeName":"word"},{"id":84392,"position":34,"arabic":"يَتَبَيَّنَ","translation":"স্পষ্ট হয়ে যায়","audioUrl":"wbw/002_187_0