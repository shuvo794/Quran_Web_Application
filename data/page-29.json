,"position":50,"arabic":"وَأَنتُمْ","translation":"এমতাবস্থায় তোমরা","audioUrl":"wbw/002_187_056.mp3","charTypeName":"word"},{"id":84411,"position":51,"arabic":"عَـٰكِفُونَ","translation":"এতিকাফরত","audioUrl":"wbw/002_187_057.mp3","charTypeName":"word"},{"id":84412,"position":52,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/002_187_058.mp3","charTypeName":"word"},{"id":84413,"position":53,"arabic":"ٱلْمَسَـٰجِدِ ۗ","translation":"মসজিদের","audioUrl":"wbw/002_187_059.mp3","charTypeName":"word"},{"id":84415,"position":54,"arabic":"تِلْكَ","translation":"এই","audioUrl":"wbw/002_187_061.mp3","charTypeName":"word"},{"id":84416,"position":55,"arabic":"حُدُودُ","translation":"সীমাসমূহ","audioUrl":"wbw/002_187_062.mp3","charTypeName":"word"},{"id":84417,"position":56,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/002_187_063.mp3","charTypeName":"word"},{"id":84418,"position":57,"arabic":"فَلَا","translation":"না তাই","audioUrl":"wbw/002_187_064.mp3","charTypeName":"word"},{"id":84419,"position":58,"arabic":"تَقْرَبُوهَا ۗ","translation":"তার নিকটে যাবে তোমরা","audioUrl":"wbw/002_187_065.mp3","charTypeName":"word"},{"id":84421,"position":59,"arabic":"كَذَٰلِكَ","translation":"এভাবে","audioUrl":"wbw/002_187_067.mp3","charTypeName":"word"},{"id":84422,"position":60,"arabic":"يُبَيِّنُ","translation":"স্পষ্ট বর্ণনা করেন","audioUrl":"wbw/002_187_068.mp3","charTypeName":"word"},{"id":84423,"position":61,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/002_187_069.mp3","charTypeName":"word"},{"id":84424,"position":62,"arabic":"ءَايَـٰتِهِۦ","translation":"তার নিদর্শনগুলো","audioUrl":"wbw/002_187_070.mp3","charTypeName":"word"},{"id":84425,"position":63,"arabic":"لِلنَّاسِ","translation":"মানুষের জন্যে","audioUrl":"wbw/002_187_071.mp3","charTypeName":"word"},{"id":84426,"position":64,"arabic":"لَعَلَّهُمْ","translation":"আশা করা যায় তারা","audioUrl":"wbw/002_187_072.mp3","charTypeName":"word"},{"id":84427,"position":65,"arabic":"يَتَّقُونَ","translation":"তাকওয়া অবলম্বন করবে","audioUrl":"wbw/002_187_073.mp3","charTypeName":"word"},{"id":84428,"position":66,"arabic":"١٨٧","translation":"(১৮৭)","audioUrl":null,"charTypeName":"end"}]},{"number":188,"arabic":"وَلَا تَأْكُلُوٓا۟ أَمْوَٰلَكُم بَيْنَكُم بِٱلْبَٰطِلِ وَتُدْلُوا۟ بِهَآ إِلَى ٱلْحُكَّامِ لِتَأْكُلُوا۟ فَرِيقًۭا مِّنْ أَمْوَٰلِ ٱلنَّاسِ بِٱلْإِثْمِ وَأَنتُمْ تَعْلَمُونَ","translation":"AND DEVOUR NOT one another's possessions wrongfully, and neither employ legal artifices with a view to devouring sinfully, and knowingly, anything that by right belongs to others.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/195.mp3","surahId":2,"words":[{"id":84429,"position":1,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/002_188_001.mp3","charTypeName":"word"},{"id":84430,"position":2,"arabic":"تَأْكُلُوٓا۟","translation":"তোমরা খেয়ো","audioUrl":"wbw/002_188_002.mp3","charTypeName":"word"},{"id":84431,"position":3,"arabic":"أَمْوَٰلَكُم","translation":"ধন-সম্পদসমূহকে","audioUrl":"wbw/002_188_003.mp3","charTypeName":"word"},{"id":84432,"position":4,"arabic":"بَيْنَكُم","translation":"তোমাদের পরস্পরের","audioUrl":"wbw/002_188_004.mp3","charTypeName":"word"},{"id":84433,"position":5,"arabic":"بِٱلْبَـٰطِلِ","translation":"অন্যায়ভাবে","audioUrl":"wbw/002_188_005.mp3","charTypeName":"word"},{"id":84434,"position":6,"arabic":"وَتُدْلُوا۟","translation":"তোমরা (না) পেশ কর","audioUrl":"wbw/002_188_006.mp3","charTypeName":"word"},{"id":84435,"position":7,"arabic":"بِهَآ","translation":"তা নিয়ে","audioUrl":"wbw/002_188_007.mp3","charTypeName":"word"},{"id":84436,"position":8,"arabic":"إِلَى","translation":"কাছে","audioUrl":"wbw/002_188_008.mp3","charTypeName":"word"},{"id":84437,"position":9,"arabic":"ٱلْحُكَّامِ","translation":"বিচারকদের","audioUrl":"wbw/002_188_009.mp3","charTypeName":"word"},{"id":84438,"position":10,"arabic":"لِتَأْكُلُوا۟","translation":"তোমরা খেতে পার যেন","audioUrl":"wbw/002_188_010.mp3","charTypeName":"word"},{"id":84439,"position":11,"arabic":"فَرِيقًۭا","translation":"কিয়দংশ","audioUrl":"wbw/002_188_011.mp3","charTypeName":"word"},{"id":84440,"position":12,"arabic":"مِّنْ","translation":"হতে","audioUrl":"wbw/002_188_012.mp3","charTypeName":"word"},{"id":84441,"position":13,"arabic":"أَمْوَٰلِ","translation":"ধন-সম্পদের","audioUrl":"wbw/002_188_013.mp3","charTypeName":"word"},{"id":84442,"position":14,"arabic":"ٱلنَّاسِ","translation":"মানুষের","audioUrl":"wbw/002_188_014.mp3","charTypeName":"word"},{"id":84443,"position":15,"arabic":"بِٱلْإِثْمِ","translation":"অন্যায়ভাবে","audioUrl":"wbw/002_188_015.mp3","charTypeName":"word"},{"id":84444,"position":16,"arabic":"وَأَنتُمْ","translation":"এমতাবস্থায় তোমরা","audioUrl":"wbw/002_188_016.mp3","charTypeName":"word"},{"id":84445,"position":17,"arabic":"تَعْلَمُونَ","translation":"জান","audioUrl":"wbw/002_188_017.mp3","charTypeName":"word"},{"id":84446,"position":18,"arabic":"١٨٨","translation":"(১৮৮)","audioUrl":null,"charTypeName":"end"}]},{"number":189,"arabic":"۞ يَسْـَٔلُونَكَ عَنِ ٱلْأَهِلَّةِ ۖ قُلْ هِىَ مَوَٰقِيتُ لِلنَّاسِ وَٱلْحَجِّ ۗ وَلَيْسَ ٱلْبِرُّ بِأَن تَأْتُوا۟ ٱلْبُيُوتَ مِن ظُهُورِهَا وَلَٰكِنَّ ٱلْبِرَّ مَنِ ٱتَّقَىٰ ۗ وَأْتُوا۟ ٱلْبُيُوتَ مِنْ أَبْوَٰبِهَا ۚ وَٱتَّقُوا۟ ٱللَّهَ لَعَلَّكُمْ تُفْلِحُونَ","translation":"THEY WILL ASK thee about the new moons. Say: \"They indicate the periods for [various doings of] mankind, including the pilgrimage.\" However, piety does not consist in your entering houses from the rear, [as it were,] but truly pious is he who is conscious of God. Hence, enter houses through their doors, and remain conscious of God, so that you might attain to a happy state.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/196.mp3","surahId":2,"words":[{"id":84507,"position":1,"arabic":"۞ يَسْـَٔلُونَكَ","translation":"তোমাকে তারা জিজ্ঞেস করে","audioUrl":"wbw/002_189_002.mp3","charTypeName":"word"},{"id":84508,"position":2,"arabic":"عَنِ","translation":"সম্বন্ধে","audioUrl":"wbw/002_189_003.mp3","charTypeName":"word"},{"id":84509,"position":3,"arabic":"ٱلْأَهِلَّةِ ۖ","translation":"নতুন চাঁদ","audioUrl":"wbw/002_189_004.mp3","charTypeName":"word"},{"id":84511,"position":4,"arabic":"قُلْ","translation":"তুমি বলো","audioUrl":"wbw/002_189_006.mp3","charTypeName":"word"},{"id":84512,"position":5,"arabic":"هِىَ","translation":"''তা","audioUrl":"wbw/002_189_007.mp3","charTypeName":"word"},{"id":84513,"position":6,"arabic":"مَوَٰقِيتُ","translation":"সময় (তারিখ) নির্দেশক","audioUrl":"wbw/002_189_008.mp3","charTypeName":"word"},{"id":84514,"position":7,"arabic":"لِلنَّاسِ","translation":"মানুষের জন্য","audioUrl":"wbw/002_189_009.mp3","charTypeName":"word"},{"id":84515,"position":8,"arabic":"وَٱلْحَجِّ ۗ","translation":"ও হজ্জের","audioUrl":"wbw/002_189_010.mp3","charTypeName":"word"},{"id":84517,"position":9,"arabic":"وَلَيْسَ","translation":"এবং নেই","audioUrl":"wbw/002_189_012.mp3","charTypeName":"word"},{"id":84518,"position":10,"arabic":"ٱلْبِرُّ","translation":"পূণ্য","audioUrl":"wbw/002_189_013.mp3","charTypeName":"word"},{"id":84519,"position":11,"arabic":"بِأَن","translation":"যে এতে","audioUrl":"wbw/002_189_014.mp3","charTypeName":"word"},{"id":84520,"position":12,"arabic":"تَأْتُوا۟","translation":"তোমরা আস","audioUrl":"wbw/002_189_015.mp3","charTypeName":"word"},{"id":84521,"position":13,"arabic":"ٱلْبُيُوتَ","translation":"ঘরগুলোতে","audioUrl":"wbw/002_189_016.mp3","charTypeName":"word"},{"id":84522,"position":14,"arabic":"مِن","translation":"হতে","audioUrl":"wbw/002_189_017.mp3","charTypeName":"word"},{"id":84523,"position":15,"arabic":"ظُهُورِهَا","translation":"তার পিছন দিক","audioUrl":"wbw/002_189_018.mp3","charTypeName":"word"},{"id":84524,"position":16,"arabic":"وَلَـٰكِنَّ","translation":"কিন্তু","audioUrl":"wbw/002_189_019.mp3","charTypeName":"word"},{"id":84525,"position":17,"arabic":"ٱلْبِرَّ","translation":"পূণ্য","audioUrl":"wbw/002_189_020.mp3","charTypeName":"word"},{"id":84526,"position":18,"arabic":"مَنِ","translation":"যে কেউ","audi