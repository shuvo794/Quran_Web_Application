{"id":429,"ayahs":[{"number":8,"arabic":"أَفْتَرَىٰ عَلَى ٱللَّهِ كَذِبًا أَم بِهِۦ جِنَّةٌۢ ۗ بَلِ ٱلَّذِينَ لَا يُؤْمِنُونَ بِٱلْءَاخِرَةِ فِى ٱلْعَذَابِ وَٱلضَّلَٰلِ ٱلْبَعِيدِ","translation":"Does he [knowingly] attribute his own lying inventions to God - or is he a madman?” Nay, [there is no madness in this Prophet -] but they who will not believe in the life to come are [bound to lose themselves] in suffering and in a profound aberration.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3614.mp3","surahId":34,"words":[{"id":9510,"position":1,"arabic":"أَفْتَرَىٰ","translation":"কি রচনা করেছে","audioUrl":"wbw/034_008_001.mp3","charTypeName":"word"},{"id":9511,"position":2,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/034_008_002.mp3","charTypeName":"word"},{"id":9512,"position":3,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/034_008_003.mp3","charTypeName":"word"},{"id":9513,"position":4,"arabic":"كَذِبًا","translation":"মিথ্যা","audioUrl":"wbw/034_008_004.mp3","charTypeName":"word"},{"id":9514,"position":5,"arabic":"أَم","translation":"অথবা","audioUrl":"wbw/034_008_005.mp3","charTypeName":"word"},{"id":9515,"position":6,"arabic":"بِهِۦ","translation":"সাথে তার (আছে)","audioUrl":"wbw/034_008_006.mp3","charTypeName":"word"},{"id":9516,"position":7,"arabic":"جِنَّةٌۢ ۗ","translation":"জিন\"","audioUrl":"wbw/034_008_007.mp3","charTypeName":"word"},{"id":9518,"position":8,"arabic":"بَلِ","translation":"বরং","audioUrl":"wbw/034_008_009.mp3","charTypeName":"word"},{"id":9519,"position":9,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/034_008_010.mp3","charTypeName":"word"},{"id":9520,"position":10,"arabic":"لَا","translation":"না","audioUrl":"wbw/034_008_011.mp3","charTypeName":"word"},{"id":9521,"position":11,"arabic":"يُؤْمِنُونَ","translation":"বিশ্বাস করে","audioUrl":"wbw/034_008_012.mp3","charTypeName":"word"},{"id":9522,"position":12,"arabic":"بِٱلْـَٔاخِرَةِ","translation":"প্রতি আখেরাতের","audioUrl":"wbw/034_008_013.mp3","charTypeName":"word"},{"id":9523,"position":13,"arabic":"فِى","translation":"মধ্যে (রয়েছে)","audioUrl":"wbw/034_008_014.mp3","charTypeName":"word"},{"id":9524,"position":14,"arabic":"ٱلْعَذَابِ","translation":"শাস্তির","audioUrl":"wbw/034_008_015.mp3","charTypeName":"word"},{"id":9525,"position":15,"arabic":"وَٱلضَّلَـٰلِ","translation":"এবং বিভ্রান্তির","audioUrl":"wbw/034_008_016.mp3","charTypeName":"word"},{"id":9526,"position":16,"arabic":"ٱلْبَعِيدِ","translation":"সুদূর","audioUrl":"wbw/034_008_017.mp3","charTypeName":"word"},{"id":9527,"position":17,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"أَفَلَمْ يَرَوْا۟ إِلَىٰ مَا بَيْنَ أَيْدِيهِمْ وَمَا خَلْفَهُم مِّنَ ٱلسَّمَآءِ وَٱلْأَرْضِ ۚ إِن نَّشَأْ نَخْسِفْ بِهِمُ ٱلْأَرْضَ أَوْ نُسْقِطْ عَلَيْهِمْ كِسَفًۭا مِّنَ ٱلسَّمَآءِ ۚ إِنَّ فِى ذَٰلِكَ لَءَايَةًۭ لِّكُلِّ عَبْدٍۢ مُّنِيبٍۢ","translation":"Are they, then, not aware of how little of the sky and the earth lies open before them, and how much is hidden from them? [or that,] if We so willed, We could cause the earth to swallow them, or cause fragments of the sky to fall down upon them? In all this, behold, there is a message indeed for every servant [of God] who is wont to turn unto Him [in repentance].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3615.mp3","surahId":34,"words":[{"id":10681,"position":1,"arabic":"أَفَلَمْ","translation":"কি তবে না","audioUrl":"wbw/034_009_001.mp3","charTypeName":"word"},{"id":10682,"position":2,"arabic":"يَرَوْا۟","translation":"তারা দেখে","audioUrl":"wbw/034_009_002.mp3","charTypeName":"word"},{"id":10683,"position":3,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/034_009_003.mp3","charTypeName":"word"},{"id":10684,"position":4,"arabic":"مَا","translation":"(তার) যা","audioUrl":"wbw/034_009_004.mp3","charTypeName":"word"},{"id":10685,"position":5,"arabic":"بَيْنَ","translation":"মাঝে","audioUrl":"wbw/034_009_005.mp3","charTypeName":"word"},{"id":10686,"position":6,"arabic":"أَيْدِيهِمْ","translation":"হাতের (সামনে রয়েছে) তাদের","audioUrl":"wbw/034_009_006.mp3","charTypeName":"word"},{"id":10687,"position":7,"arabic":"وَمَا","translation":"এবং যা","audioUrl":"wbw/034_009_007.mp3","charTypeName":"word"},{"id":10688,"position":8,"arabic":"خَلْفَهُم","translation":"পিছনে তাদের","audioUrl":"wbw/034_009_008.mp3","charTypeName":"word"},{"id":10689,"position":9,"arabic":"مِّنَ","translation":"হ'তে","audioUrl":"wbw/034_009_009.mp3","charTypeName":"word"},{"id":10690,"position":10,"arabic":"ٱلسَّمَآءِ","translation":"আকাশ","audioUrl":"wbw/034_009_010.mp3","charTypeName":"word"},{"id":10691,"position":11,"arabic":"وَٱلْأَرْضِ ۚ","translation":"এবং পৃথিবী","audioUrl":"wbw/034_009_011.mp3","charTypeName":"word"},{"id":10693,"position":12,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/034_009_013.mp3","charTypeName":"word"},{"id":10694,"position":13,"arabic":"نَّشَأْ","translation":"আমরা চাই","audioUrl":"wbw/034_009_014.mp3","charTypeName":"word"},{"id":10695,"position":14,"arabic":"نَخْسِفْ","translation":"আমরা ধ্বসিয়ে দিবো","audioUrl":"wbw/034_009_015.mp3","charTypeName":"word"},{"id":10696,"position":15,"arabic":"بِهِمُ","translation":"সহ তাদের","audioUrl":"wbw/034_009_016.mp3","charTypeName":"word"},{"id":10697,"position":16,"arabic":"ٱلْأَرْضَ","translation":"পৃথিবীকে","audioUrl":"wbw/034_009_017.mp3","charTypeName":"word"},{"id":10698,"position":17,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/034_009_018.mp3","charTypeName":"word"},{"id":10699,"position":18,"arabic":"نُسْقِطْ","translation":"আমরা পতিত করবো","audioUrl":"wbw/034_009_019.mp3","charTypeName":"word"},{"id":10700,"position":19,"arabic":"عَلَيْهِمْ","translation":"উপর তাদের","audioUrl":"wbw/034_009_020.mp3","charTypeName":"word"},{"id":10701,"position":20,"arabic":"كِسَفًۭا","translation":"(কিছু) খণ্ড","audioUrl":"wbw/034_009_021.mp3","charTypeName":"word"},{"id":10702,"position":21,"arabic":"مِّنَ","translation":"থেকে","audioUrl":"wbw/034_009_022.mp3","charTypeName":"word"},{"id":10703,"position":22,"arabic":"ٱلسَّمَآءِ ۚ","translation":"আকাশ","audioUrl":"wbw/034_009_023.mp3","charTypeName":"word"},{"id":10705,"position":23,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/034_009_025.mp3","charTypeName":"word"},{"id":10706,"position":24,"arabic":"فِى","translation":"মধ্যে (রয়েছে)","audioUrl":"wbw/034_009_026.mp3","charTypeName":"word"},{"id":10707,"position":25,"arabic":"ذَٰلِكَ","translation":"এর","audioUrl":"wbw/034_009_027.mp3","charTypeName":"word"},{"id":10708,"position":26,"arabic":"لَـَٔايَةًۭ","translation":"অবশ্যই নিদর্শন","audioUrl":"wbw/034_009_028.mp3","charTypeName":"word"},{"id":10709,"position":27,"arabic":"لِّكُلِّ","translation":"জন্যে প্রত্যেক","audioUrl":"wbw/034_009_029.mp3","charTypeName":"word"},{"id":10710,"position":28,"arabic":"عَبْدٍۢ","translation":"দাসের","audioUrl":"wbw/034_009_030.mp3","charTypeName":"word"},{"id":10711,"position":29,"arabic":"مُّنِيبٍۢ","translation":"যে (আল্লাহ) অভিমুখী","audioUrl":"wbw/034_009_031.mp3","charTypeName":"word"},{"id":10712,"position":30,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"۞ وَلَقَدْ ءَاتَيْنَا دَاوُۥدَ مِنَّا فَضْلًۭا ۖ يَٰجِبَالُ أَوِّبِى مَعَهُۥ وَٱلطَّيْرَ ۖ وَأَلَنَّا لَهُ ٱلْحَدِيدَ","translation":"AND [thus], indeed, did We grace David with Our favour: “O you mountains! Sing with him the praise of God! And [likewise] you birds!” And We softened all sharpness in him,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3616.mp3","surahId":34,"words":[{"id":11951,"position":1,"arabic":"۞ وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/034_010_002.mp3","charTypeName":"word"},{"id":11952,"position":2,"arabic":"ءَاتَيْنَا","translation":"আমরা দিয়েছি","audioUrl":"wbw/034_010_003.mp3","charTypeName":"word"},{"id":11953,"position":3,"arabic":"دَاوُۥدَ","translation":"দাউদকে","audioUrl":"wbw/034_010_004.mp3","charTypeName":"word"},{"id":11954,"position":4,"arabic":"مِنَّا","translation":"আমাদের পক্ষ থেকে","audioUrl":"wbw/034_010_005.mp3","charTypeName":"word"},{"id":11955,"position":5,"arabic":"فَضْلًۭا ۖ","translation":"অনুগ্রহ","audioUrl":"wbw/034_010_006.mp3","charTypeName":"word"},{"id":11957,"position":6,"arabic":"يَـٰجِبَالُ","translation":"\"(এবং বলেছিলাম) হে পর্বতমালা","audioUrl":"wbw/034_010_008.mp3","charTypeName":"word"},{"id":11958,"position":7,"arabic":"أَوِّبِى","translation":"পবিত্রতা ঘোষণা করো","audioUrl":"wbw/034_010_009.mp3","charTypeName":"word"},{"id":11959,"position":8,"arabic":"مَعَهُۥ","translation":"তার সাথে","audioUrl":"wbw/034_010_010.mp3","charTypeName":"word"},{"id":11960,"position":9,"arabic":"وَٱلطَّيْرَ ۖ","translation":"এবং পাখীদেরকেও (হুকুম দিয়েছিলাম)\"","audioUrl":"wbw/034_010_011.mp3","charTypeName":"word"},{"id":11962,"position":10,"arabic":"وَأَلَنَّا","translation":"এবং আমরা নরম করে দেই","audioUrl":"wbw/034_010_013.mp3","charTypeName":"word"},{"id":11963,"position":11,"arabic":"لَهُ","translation":"জন্যে তার","audioUrl":"wbw/034_010_014.mp3","charTypeName":"word"},{"id":11964,"position":12,"arabic":"ٱلْحَدِيدَ","translation":"লোহাকে","audioUrl":"wbw/034_010_015.mp3","charTypeName":"word"},{"id":11965,"position":13,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"أَنِ ٱعْمَلْ سَٰبِغَٰتٍۢ وَقَدِّرْ فِى ٱلسَّرْدِ ۖ وَٱعْمَلُوا۟ صَٰلِحًا ۖ إِنِّى بِمَا تَعْمَلُونَ بَصِيرٌۭ","translation":"[and inspired him thus:] “Do good deeds lavishly, without stint, and give deep thought to their steady flow.” And [thus should you all, O believers,] do righteous deeds: for, verily, I see all that you do!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3617.mp3","surahId":34,"words":[{"id":13247,"position":1,"arabic":"أَنِ","translation":"(এবং নির্দেশ দিয়েছিলাম) যে","audioUrl":"wbw/034_011_001.mp3","charTypeName":"word"},{"id":13248,"position":2,"arabic":"ٱعْمَلْ","translation":"তুমি তৈরি করো","audioUrl":"wbw/034_011_002.mp3","charTypeName":"word"},{"id":13249,"position":3,"arabic":"سَـٰبِغَـٰتٍۢ","translation":"(নিখুঁত) বর্মসমূহ","audioUrl":"wbw/034_011_003.mp3","charTypeName":"word"},{"id":13250,"position":4,"arabic":"وَقَدِّرْ","translation":"ও পরিমাণ রক্ষা করো","audioUrl":"wbw/034_011_004.mp3","charTypeName":"word"},{"id":13251,"position":5,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/034_011_005.mp3","charTypeName":"word"},{"id":13252,"position":6,"arabic":"ٱلسَّرْدِ ۖ","translation":"কড়াগুলোর","audioUrl":"wbw/034_011_006.mp3","charTypeName":"word"},{"id":13254,"position":7,"arabic":"وَٱعْمَلُوا۟","translation":"এবং তোমরা কাজ করো","audioUrl":"wbw/034_011_008.mp3","charTypeName":"word"},{"id":13255,"position":8,"arabic":"صَـٰلِحًا ۖ","translation":"সৎ","audioUrl":"wbw/034_011_009.mp3","charTypeName":"word"},{"id":13257,"position":9,"arabic":"إِنِّى","translation":"নিশ্চয়ই আমি","audioUrl":"wbw/034_011_011.mp3","charTypeName":"word"},{"id":13258,"position":10,"arabic":"بِمَا","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/034_011_012.mp3","charTypeName":"word"},{"id":13259,"position":11,"arabic":"تَعْمَلُونَ","translation":"তোমরা করছো","audioUrl":"wbw/034_011_013.mp3","charTypeName":"word"},{"id":13260,"position":12,"arabic":"بَصِيرٌۭ","translation":"দৃষ্টিমান","audioUrl":"wbw/034_011_014.mp3","charTypeName":"word"},{"id":13261,"position":13,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]},{"number":12,"arabic":"وَلِسُلَيْمَٰنَ ٱلرِّيحَ غُدُوُّهَا شَهْرٌۭ وَرَوَاحُهَا شَهْرٌۭ ۖ وَأَسَلْنَا لَهُۥ عَيْنَ ٱلْقِطْرِ ۖ وَمِنَ ٱلْجِنِّ مَن يَعْمَلُ بَيْنَ يَدَيْهِ بِإِذْنِ رَبِّهِۦ ۖ وَمَن يَزِغْ مِنْهُمْ عَنْ أَمْرِنَا نُذِقْهُ مِنْ عَذَابِ ٱلسَّعِيرِ","translation":"AND UNTO Solomon [We made subservient] the wind: its morning course [covered the distance of] a month’s journey, and its evening course, a month’s journey. And We caused a fountain of molten copper to flow at his behest; and [even] among the invisible beings there were some that had [been constrained] to labour for him by his Sustainer’s leave and whichever of them deviated from Our command, him would We let taste suffering through a blazing flame -:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3618.mp3","surahId":34,"words":[{"id":14525,"position":1,"arabic":"وَلِسُلَيْمَـٰنَ","translation":"এবং জন্যে সোলায়মানের (অধীন করে দেই)","audioUrl":"wbw/034_012_001.mp3","charTypeName":"word"},{"id":14526,"position":2,"arabic":"ٱلرِّيحَ","translation":"বাতাসকে","audioUrl":"wbw/034_012_002.mp3","charTypeName":"word"},{"id":14527,"position":3,"arabic":"غُدُوُّهَا","translation":"সকালের বেড়ানো তার","audioUrl":"wbw/034_012_003.mp3","charTypeName":"word"},{"id":14528,"position":4,"arabic":"شَهْرٌۭ","translation":"এক মাসের","audioUrl":"wbw/034_012_004.mp3","charTypeName":"word"},{"id":14529,"position":5,"arabic":"وَرَوَاحُهَا","translation":"এবং সন্ধ্যার বেড়ানো তার","audioUrl":"wbw/034_012_005.mp3","charTypeName":"word"},{"id":14530,"position":6,"arabic":"شَهْرٌۭ ۖ","translation":"এক মাসের (অর্থাৎ সে এক মাসের পথ এক সকাল বা এক সন্ধায় অতিক্রম করতো","audioUrl":"wbw/034_012_006.mp3","charTypeName":"word"},{"id":14532,"position":7,"arabic":"وَأَسَلْنَا","translation":"এবং আমরা প্রবাহিত করেছি","audioUrl":"wbw/034_012_008.mp3","charTypeName":"word"},{"id":14533,"position":8,"arabic":"لَهُۥ","translation":"জন্যে তার","audioUrl":"wbw/034_012_009.mp3","charTypeName":"word"},{"id":14534,"position":9,"arabic":"عَيْنَ","translation":"ঝর্ণা","audioUrl":"wbw/034_012_010.mp3","charTypeName":"word"},{"id":14535,"position":10,"arabic":"ٱلْقِطْرِ ۖ","translation":"গলানো তামার","audioUrl":"wbw/034_012_011.mp3","charTypeName":"word"},{"id":14537,"position":11,"arabic":"وَمِنَ","translation":"এবং কিছু","audioUrl":"wbw/034_012_013.mp3","charTypeName":"word"},{"id":14538,"position":12,"arabic":"ٱلْجِنِّ","translation":"জিনদের","audioUrl":"wbw/034_012_014.mp3","charTypeName":"word"},{"id":14539,"position":13,"arabic":"مَن","translation":"যারা","audioUrl":"wbw/03