charTypeName":"end"}]},{"number":75,"arabic":"۞ أَفَتَطْمَعُونَ أَن يُؤْمِنُوا۟ لَكُمْ وَقَدْ كَانَ فَرِيقٌۭ مِّنْهُمْ يَسْمَعُونَ كَلَٰمَ ٱللَّهِ ثُمَّ يُحَرِّفُونَهُۥ مِنۢ بَعْدِ مَا عَقَلُوهُ وَهُمْ يَعْلَمُونَ","translation":"CAN YOU, then, hope that they will believe in what you are preaching - seeing that a good many of them were wont to listen to the word of God and then, after having understood it, to pervert it knowingly?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/82.mp3","surahId":2,"words":[{"id":61875,"position":1,"arabic":"۞ أَفَتَطْمَعُونَ","translation":"তবে কি তোমরা আশা কর","audioUrl":"wbw/002_075_002.mp3","charTypeName":"word"},{"id":61876,"position":2,"arabic":"أَن","translation":"যে","audioUrl":"wbw/002_075_003.mp3","charTypeName":"word"},{"id":61877,"position":3,"arabic":"يُؤْمِنُوا۟","translation":"তারা ঈমান আনবে","audioUrl":"wbw/002_075_004.mp3","charTypeName":"word"},{"id":61878,"position":4,"arabic":"لَكُمْ","translation":"তোমাদের (দাওয়াতে)","audioUrl":"wbw/002_075_005.mp3","charTypeName":"word"},{"id":61879,"position":5,"arabic":"وَقَدْ","translation":"অথচ নিশ্চয়ই","audioUrl":"wbw/002_075_006.mp3","charTypeName":"word"},{"id":61880,"position":6,"arabic":"كَانَ","translation":"আছে","audioUrl":"wbw/002_075_007.mp3","charTypeName":"word"},{"id":61881,"position":7,"arabic":"فَرِيقٌۭ","translation":"একদল","audioUrl":"wbw/002_075_008.mp3","charTypeName":"word"},{"id":61882,"position":8,"arabic":"مِّنْهُمْ","translation":"তাদের মধ্যে","audioUrl":"wbw/002_075_009.mp3","charTypeName":"word"},{"id":61883,"position":9,"arabic":"يَسْمَعُونَ","translation":"(যারা) শুনে","audioUrl":"wbw/002_075_010.mp3","charTypeName":"word"},{"id":61884,"position":10,"arabic":"كَلَـٰمَ","translation":"(কালাম) বাণী","audioUrl":"wbw/002_075_011.mp3","charTypeName":"word"},{"id":61885,"position":11,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌র","audioUrl":"wbw/002_075_012.mp3","charTypeName":"word"},{"id":61886,"position":12,"arabic":"ثُمَّ","translation":"পরে","audioUrl":"wbw/002_075_013.mp3","charTypeName":"word"},{"id":61887,"position":13,"arabic":"يُحَرِّفُونَهُۥ","translation":"তা তারা বিকৃত করে","audioUrl":"wbw/002_075_014.mp3","charTypeName":"word"},{"id":61888,"position":14,"arabic":"مِنۢ","translation":"থেকে","audioUrl":"wbw/002_075_015.mp3","charTypeName":"word"},{"id":61889,"position":15,"arabic":"بَعْدِ","translation":"এরপর","audioUrl":"wbw/002_075_016.mp3","charTypeName":"word"},{"id":61890,"position":16,"arabic":"مَا","translation":"যা","audioUrl":"wbw/002_075_017.mp3","charTypeName":"word"},{"id":61891,"position":17,"arabic":"عَقَلُوهُ","translation":"তা তারা বুঝেছিল","audioUrl":"wbw/002_075_018.mp3","charTypeName":"word"},{"id":61892,"position":18,"arabic":"وَهُمْ","translation":"অথচ তারা","audioUrl":"wbw/002_075_019.mp3","charTypeName":"word"},{"id":61893,"position":19,"arabic":"يَعْلَمُونَ","translation":"(ভালভাবে) জানেও","audioUrl":"wbw/002_075_020.mp3","charTypeName":"word"},{"id":61894,"position":20,"arabic":"٧٥","translation":"(৭৫)","audioUrl":null,"charTypeName":"end"}]},{"number":76,"arabic":"وَإِذَا لَقُوا۟ ٱلَّذِينَ ءَامَنُوا۟ قَالُوٓا۟ ءَامَنَّا وَإِذَا خَلَا بَعْضُهُمْ إِلَىٰ بَعْضٍۢ قَالُوٓا۟ أَتُحَدِّثُونَهُم بِمَا فَتَحَ ٱللَّهُ عَلَيْكُمْ لِيُحَآجُّوكُم بِهِۦ عِندَ رَبِّكُمْ ۚ أَفَلَا تَعْقِلُونَ","translation":"For, when they meet those who have attained to faith. they say, \"We believe [as you believe]\" - but when they find themselves alone with one another, they say. \"Do you inform them of what God has disclosed to you, so that they might use it in argument against you, quoting the words of your Sustainer? Will you not. then, use your reason?\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/83.mp3","surahId":2,"words":[{"id":62474,"position":1,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/002_076_001.mp3","charTypeName":"word"},{"id":62475,"position":2,"arabic":"لَقُوا۟","translation":"তারা মিলে (তাদের সাথে)","audioUrl":"wbw/002_076_002.mp3","charTypeName":"word"},{"id":62476,"position":3,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/002_076_003.mp3","charTypeName":"word"},{"id":62477,"position":4,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/002_076_004.mp3","charTypeName":"word"},{"id":62478,"position":5,"arabic":"قَالُوٓا۟","translation":"তারা বলে","audioUrl":"wbw/002_076_005.mp3","charTypeName":"word"},{"id":62479,"position":6,"arabic":"ءَامَنَّا","translation":"''আমরা ঈমান এনেছি''","audioUrl":"wbw/002_076_006.mp3","charTypeName":"word"},{"id":62480,"position":7,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/002_076_007.mp3","charTypeName":"word"},{"id":62481,"position":8,"arabic":"خَلَا","translation":"মিলে গোপনে","audioUrl":"wbw/002_076_008.mp3","charTypeName":"word"},{"id":62482,"position":9,"arabic":"بَعْضُهُمْ","translation":"তাদের কেউ","audioUrl":"wbw/002_076_009.mp3","charTypeName":"word"},{"id":62483,"position":10,"arabic":"إِلَىٰ","translation":"সাথে","audioUrl":"wbw/002_076_010.mp3","charTypeName":"word"},{"id":62484,"position":11,"arabic":"بَعْضٍۢ","translation":"কারো","audioUrl":"wbw/002_076_011.mp3","charTypeName":"word"},{"id":62485,"position":12,"arabic":"قَالُوٓا۟","translation":"তারা বলে","audioUrl":"wbw/002_076_012.mp3","charTypeName":"word"},{"id":62486,"position":13,"arabic":"أَتُحَدِّثُونَهُم","translation":"''তাদেরকে তোমরা বলে দাও কি","audioUrl":"wbw/002_076_013.mp3","charTypeName":"word"},{"id":62487,"position":14,"arabic":"بِمَا","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/002_076_014.mp3","charTypeName":"word"},{"id":62488,"position":15,"arabic":"فَتَحَ","translation":"প্রকাশ করেছেন","audioUrl":"wbw/002_076_015.mp3","charTypeName":"word"},{"id":62489,"position":16,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌","audioUrl":"wbw/002_076_016.mp3","charTypeName":"word"},{"id":62490,"position":17,"arabic":"عَلَيْكُمْ","translation":"তোমাদের কাছে","audioUrl":"wbw/002_076_017.mp3","charTypeName":"word"},{"id":62491,"position":18,"arabic":"لِيُحَآجّ