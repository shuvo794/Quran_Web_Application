mp3","charTypeName":"word"},{"id":3860,"position":10,"arabic":"تُعْلِنُونَ ۚ","translation":"তোমরা প্রকাশ কর","audioUrl":"wbw/064_004_010.mp3","charTypeName":"word"},{"id":3862,"position":11,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ্‌","audioUrl":"wbw/064_004_012.mp3","charTypeName":"word"},{"id":3863,"position":12,"arabic":"عَلِيمٌۢ","translation":"খুব জানেন","audioUrl":"wbw/064_004_013.mp3","charTypeName":"word"},{"id":3864,"position":13,"arabic":"بِذَاتِ","translation":"অবস্থা সম্পর্কে","audioUrl":"wbw/064_004_014.mp3","charTypeName":"word"},{"id":3865,"position":14,"arabic":"ٱلصُّدُورِ","translation":"অন্তরসমূহের","audioUrl":"wbw/064_004_015.mp3","charTypeName":"word"},{"id":3866,"position":15,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"أَلَمْ يَأْتِكُمْ نَبَؤُا۟ ٱلَّذِينَ كَفَرُوا۟ مِن قَبْلُ فَذَاقُوا۟ وَبَالَ أَمْرِهِمْ وَلَهُمْ عَذَابٌ أَلِيمٌۭ","translation":"HAVE THE STORIES of those who, in earlier times, refused to acknowledge the truth never yet come within your ken? [They denied it -] and so they had to taste the evil outcome of their own doings, with [more] grievous suffering awaiting them [in the life to come]:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5204.mp3","surahId":64,"words":[{"id":5111,"position":1,"arabic":"أَلَمْ","translation":"নাই কি","audioUrl":"wbw/064_005_001.mp3","charTypeName":"word"},{"id":5112,"position":2,"arabic":"يَأْتِكُمْ","translation":"তোমাদের কাছে আসে","audioUrl":"wbw/064_005_002.mp3","charTypeName":"word"},{"id":5113,"position":3,"arabic":"نَبَؤُا۟","translation":"খবর","audioUrl":"wbw/064_005_003.mp3","charTypeName":"word"},{"id":5114,"position":4,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/064_005_004.mp3","charTypeName":"word"},{"id":5115,"position":5,"arabic":"كَفَرُوا۟","translation":"কুফরি করেছিল","audioUrl":"wbw/064_005_005.mp3","charTypeName":"word"},{"id":5116,"position":6,"arabic":"مِن","translation":"মধ্য হতে","audioUrl"