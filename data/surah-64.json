{"id":64,"nameArabic":"سُورَةُ التَّغَابُنِ","nameEnglish":"At-Taghaabun","nameTranslation":"Mutual Disillusion","revelationType":"Medinan","numberOfAyahs":18,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ يُسَبِّحُ لِلَّهِ مَا فِى ٱلسَّمَٰوَٰتِ وَمَا فِى ٱلْأَرْضِ ۖ لَهُ ٱلْمُلْكُ وَلَهُ ٱلْحَمْدُ ۖ وَهُوَ عَلَىٰ كُلِّ شَىْءٍۢ قَدِيرٌ","translation":"ALL THAT IS in the heavens and all that is on earth extols God's limitless glory: His is all dominion, and to Him all praise is due; and He has the power to will anything.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5200.mp3","surahId":64,"words":[{"id":488,"position":1,"arabic":"يُسَبِّحُ","translation":"মহিমা ঘোষণা করে","audioUrl":"wbw/064_001_001.mp3","charTypeName":"word"},{"id":489,"position":2,"arabic":"لِلَّهِ","translation":"আল্লাহ্‌র জন্যে","audioUrl":"wbw/064_001_002.mp3","charTypeName":"word"},{"id":490,"position":3,"arabic":"مَا","translation":"যা","audioUrl":"wbw/064_001_003.mp3","charTypeName":"word"},{"id":491,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/064_001_004.mp3","charTypeName":"word"},{"id":492,"position":5,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আসমানসমূহের","audioUrl":"wbw/064_001_005.mp3","charTypeName":"word"},{"id":493,"position":6,"arabic":"وَمَا","translation":"ও যা","audioUrl":"wbw/064_001_006.mp3","charTypeName":"word"},{"id":494,"position":7,"arabic":"فِى","translation":"মধ্যে (আছে)","audioUrl":"wbw/064_001_007.mp3","charTypeName":"word"},{"id":495,"position":8,"arabic":"ٱلْأَرْضِ ۖ","translation":"পৃথিবীর","audioUrl":"wbw/064_001_008.mp3","charTypeName":"word"},{"id":497,"position":9,"arabic":"لَهُ","translation":"তাঁরই জন্যে","audioUrl":"wbw/064_001_010.mp3","charTypeName":"word"},{"id":498,"position":10,"arabic":"ٱلْمُلْكُ","translation":"সার্বভৌমত্ব","audioUrl":"wbw/064_001_011.mp3","charTypeName":"word"},{"id":499,"position":11,"arabic":"وَلَهُ","translation":"ও তাঁর জন্যেই","audioUrl":"wbw/064_001_012.mp3","charTypeName":"word"},{"id":500,"position":12,"arabic":"ٱلْحَمْدُ ۖ","translation":"সব প্রশংসা","audioUrl":"wbw/064_001_013.mp3","charTypeName":"word"},{"id":502,"position":13,"arabic":"وَهُوَ","translation":"ও তিনিই","audioUrl":"wbw/064_001_015.mp3","charTypeName":"word"},{"id":503,"position":14,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/064_001_016.mp3","charTypeName":"word"},{"id":504,"position":15,"arabic":"كُلِّ","translation":"সব","audioUrl":"wbw/064_001_017.mp3","charTypeName":"word"},{"id":505,"position":16,"arabic":"شَىْءٍۢ","translation":"কিছুর","audioUrl":"wbw/064_001_018.mp3","charTypeName":"word"},{"id":506,"position":17,"arabic":"قَدِيرٌ","translation":"ক্ষমতাবান","audioUrl":"wbw/064_001_019.mp3","charTypeName":"word"},{"id":507,"position":18,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"هُوَ ٱلَّذِى خَلَقَكُمْ فَمِنكُمْ كَافِرٌۭ وَمِنكُم مُّؤْمِنٌۭ ۚ وَٱللَّهُ بِمَا تَعْمَلُونَ بَصِيرٌ","translation":"He it is who has created you: and among you are such as deny this truth, and among you are such as believe [in it]. And God sees all that you do.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5201.mp3","surahId":64,"words":[{"id":1379,"position":1,"arabic":"هُوَ","translation":"তিনিই","audioUrl":"wbw/064_002_001.mp3","charTypeName":"word"},{"id":1380,"position":2,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/064_002_002.mp3","charTypeName":"word"},{"id":1381,"position":3,"arabic":"خَلَقَكُمْ","translation":"তোমাদের সৃষ্টি করেছেন","audioUrl":"wbw/064_002_003.mp3","charTypeName":"word"},{"id":1382,"position":4,"arabic":"فَمِنكُمْ","translation":"অতঃপর তোমাদের  মধ্যে","audioUrl":"wbw/064_002_004.mp3","charTypeName":"word"},{"id":1383,"position":5,"arabic":"كَافِرٌۭ","translation":"(কেউ) কাফির","audioUrl":"wbw/064_002_005.mp3","charTypeName":"word"},{"id":1384,"position":6,"arabic":"وَمِنكُم","translation":"আবার তোমাদের মধ্যে","audioUrl":"wbw/064_002_006.mp3","charTypeName":"wo