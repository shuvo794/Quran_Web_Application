َا عَمِلْتُمْ ۚ وَذَٰلِكَ عَلَى ٱللَّهِ يَسِيرٌۭ","translation":"They who are bent on denying the truth claim that they will never be raised from the dead! Say: \"Yea, by my Sustainer! Most surely will you be raised from the dead, and then, most surely, will you be made to understand what you did [in life]! For, easy is this for God!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5206.mp3","surahId":64,"words":[{"id":7791,"position":1,"arabic":"زَعَمَ","translation":"দাবী করে","audioUrl":"wbw/064_007_001.mp3","charTypeName":"word"},{"id":7792,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/064_007_002.mp3","charTypeName":"word"},{"id":7793,"position":3,"arabic":"كَفَرُوٓا۟","translation":"কুফরি করেছে","audioUrl":"wbw/064_007_003.mp3","charTypeName":"word"},{"id":7794,"position":4,"arabic":"أَن","translation":"যে","audioUrl":"wbw/064_007_004.mp3","charTypeName":"word"},{"id":7795,"position":5,"arabic":"لَّن","translation":"কক্ষনো না","audioUrl":"wbw/064_007_005.mp3","charTypeName":"word"},{"id":7796,"position":6,"arabic":"يُبْعَثُوا۟ ۚ","translation":"তাদের পুনরায় উঠানো হবে","audioUrl":"wbw/064_007_006.mp3","charTypeName":"word"},{"id":7798,"position":7,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/064_007_008.mp3","charTypeName":"word"},{"id":7799,"position":8,"arabic":"بَلَىٰ","translation":"\"অবশ্যই হবে","audioUrl":"wbw/064_007_009.mp3","charTypeName":"word"},{"id":7800,"position":9,"arabic":"وَرَبِّى","translation":"কসম আমার রবের","audioUrl":"wbw/064_007_010.mp3","charTypeName":"word"},{"id":7801,"position":10,"arabic":"لَتُبْعَثُنَّ","translation":"অবশ্যই তোমাদের  উঠানো হবে","audioUrl":"wbw/064_007_011.mp3","charTypeName":"word"},{"id":7802,"position":11,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/064_007_012.mp3","charTypeName":"word"},{"id":7803,"position":12,"arabic":"لَتُنَبَّؤُنَّ","translation":"অবশ্যই তোমাদের খবর দেয়া হবে","audioUrl":"wbw/064_007_013.mp3","charTypeName":"word"},{"id":7804,"positio