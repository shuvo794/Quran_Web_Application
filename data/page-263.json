{"id":263,"ayahs":[{"number":16,"arabic":"وَلَقَدْ جَعَلْنَا فِى ٱلسَّمَآءِ بُرُوجًۭا وَزَيَّنَّٰهَا لِلنَّٰظِرِينَ","translation":"AND, INDEED, We have set up in the heavens great constellations, and endowed them with beauty for all to behold;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1818.mp3","surahId":15,"words":[{"id":18922,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/015_016_001.mp3","charTypeName":"word"},{"id":18923,"position":2,"arabic":"جَعَلْنَا","translation":"আমরা বানিয়েছি","audioUrl":"wbw/015_016_002.mp3","charTypeName":"word"},{"id":18924,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/015_016_003.mp3","charTypeName":"word"},{"id":18925,"position":4,"arabic":"ٱلسَّمَآءِ","translation":"আকাশের","audioUrl":"wbw/015_016_004.mp3","charTypeName":"word"},{"id":18926,"position":5,"arabic":"بُرُوجًۭا","translation":"গ্রহনক্ষত্র","audioUrl":"wbw/015_016_005.mp3","charTypeName":"word"},{"id":18927,"position":6,"arabic":"وَزَيَّنَّـٰهَا","translation":"ও তা আমরা সুশোভিত করেছি","audioUrl":"wbw/015_016_006.mp3","charTypeName":"word"},{"id":18928,"position":7,"arabic":"لِلنَّـٰظِرِينَ","translation":"দর্শকদের জন্যে","audioUrl":"wbw/015_016_007.mp3","charTypeName":"word"},{"id":18929,"position":8,"arabic":"١٦","translation":"(১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":17,"arabic":"وَحَفِظْنَٰهَا مِن كُلِّ شَيْطَٰنٍۢ رَّجِيمٍ","translation":"and We have made them secure against every satanic force accursed -","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1819.mp3","surahId":15,"words":[{"id":20031,"position":1,"arabic":"وَحَفِظْنَـٰهَا","translation":"এবং আমরা রক্ষা করেছি তা","audioUrl":"wbw/015_017_001.mp3","charTypeName":"word"},{"id":20032,"position":2,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/015_017_002.mp3","charTypeName":"word"},{"id":20033,"position":3,"arabic":"كُلِّ","translation":"প্রত্যেক","audioUrl":"wbw/015_017_003.mp3","charTypeName":"word"},{"id":20034,"position":4,"arabic":"شَيْطَـٰنٍۢ","translation":"শয়তান","audioUrl":"wbw/015_017_004.mp3","charTypeName":"word"},{"id":20035,"position":5,"arabic":"رَّجِيمٍ","translation":"অভিশপ্ত","audioUrl":"wbw/015_017_005.mp3","charTypeName":"word"},{"id":20036,"position":6,"arabic":"١٧","translation":"(১৭)","audioUrl":null,"charTypeName":"end"}]},{"number":18,"arabic":"إِلَّا مَنِ ٱسْتَرَقَ ٱلسَّمْعَ فَأَتْبَعَهُۥ شِهَابٌۭ مُّبِينٌۭ","translation":"so that anyone who seeks to learn [the unknowable] by stealth is pursued by a flame clear to see.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1820.mp3","surahId":15,"words":[{"id":21100,"position":1,"arabic":"إِلَّا","translation":"কিন্তু","audioUrl":"wbw/015_018_001.mp3","charTypeName":"word"},{"id":21101,"position":2,"arabic":"مَنِ","translation":"যে","audioUrl":"wbw/015_018_002.mp3","charTypeName":"word"},{"id":21102,"position":3,"arabic":"ٱسْتَرَقَ","translation":"চুরি করে","audioUrl":"wbw/015_018_003.mp3","charTypeName":"word"},{"id":21103,"position":4,"arabic":"ٱلسَّمْعَ","translation":"শুনতে চায়","audioUrl":"wbw/015_018_004.mp3","charTypeName":"word"},{"id":21104,"position":5,"arabic":"فَأَتْبَعَهُۥ","translation":"তখন তার পিছু ধাওয়া করে","audioUrl":"wbw/015_018_005.mp3","charTypeName":"word"},{"id":21105,"position":6,"arabic":"شِهَابٌۭ","translation":"অগ্নি শিখা","audioUrl":"wbw/015_018_006.mp3","charTypeName":"word"},{"id":21106,"position":7,"arabic":"مُّبِينٌۭ","translation":"উজ্জ্বল","audioUrl":"wbw/015_018_007.mp3","charTypeName":"word"},{"id":21107,"position":8,"arabic":"١٨","translation":"(১৮)","audioUrl":null,"charTypeName":"end"}]},{"number":19,"arabic":"وَٱلْأَرْضَ مَدَدْنَٰهَا وَأَلْقَيْنَا فِيهَا رَوَٰسِىَ وَأَنۢبَتْنَا فِيهَا مِن كُلِّ شَىْءٍۢ مَّوْزُونٍۢ","translation":"And the earth -We have spread it out wide, and placed on it mountains firm, and caused [life] of every kind to grow on it in a balanced manner,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1821.mp3","surahId":15,"words":[{"id":22214,"position":1,"arabic":"وَٱلْأَرْضَ","translation":"এবং জমিনকে","audioUrl":"wbw/015_019_001.mp3","charTypeName":"word"},{"id":22215,"position":2,"arabic":"مَدَدْنَـٰهَا","translation":"আমরা বিস্তৃত করেছি তা","audioUrl":"wbw/015_019_002.mp3","charTypeName":"word"},{"id":22216,"position":3,"arabic":"وَأَلْقَيْنَا","translation":"ও আমরা স্থাপন করেছি","audioUrl":"wbw/015_019_003.mp3","charTypeName":"word"},{"id":22217,"position":4,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/015_019_004.mp3","charTypeName":"word"},{"id":22218,"position":5,"arabic":"رَوَٰسِىَ","translation":"পর্বতমালা","audioUrl":"wbw/015_019_005.mp3","charTypeName":"word"},{"id":22219,"position":6,"arabic":"وَأَنۢبَتْنَا","translation":"এবং আমরা উদগত করেছি","audioUrl":"wbw/015_019_006.mp3","charTypeName":"word"},{"id":22220,"position":7,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/015_019_007.mp3","charTypeName":"word"},{"id":22221,"position":8,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/015_019_008.mp3","charTypeName":"word"},{"id":22222,"position":9,"arabic":"كُلِّ","translation":"প্রত্যেক","audioUrl":"wbw/015_019_009.mp3","charTypeName":"word"},{"id":22223,"position":10,"arabic":"شَىْءٍۢ","translation":"বস্তু","audioUrl":"wbw/015_019_010.mp3","charTypeName":"word"},{"id":22224,"position":11,"arabic":"مَّوْزُونٍۢ","translation":"সুপরিমিত","audioUrl":"wbw/015_019_011.mp3","charTypeName":"word"},{"id":22225,"position":12,"arabic":"١٩","translation":"(১৯)","audioUrl":null,"charTypeName":"end"}]},{"number":20,"arabic":"وَجَعَلْنَا لَكُمْ فِيهَا مَعَٰيِشَ وَمَن لَّسْتُمْ لَهُۥ بِرَٰزِقِينَ","translation":"and provided thereon means of livelihood for you [O men] as well as for all [living beings] whose sustenance does not depend on you.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1822.mp3","surahId":15,"words":[{"id":23244,"position":1,"arabic":"وَجَعَلْنَا","translation":"এবং আমরা ব্যবস্হা করেছি","audioUrl":"wbw/015_020_001.mp3","charTypeName":"word"},{"id":23245,"position":2,"arabic":"لَكُمْ","translation":"তোমাদের জন্যে","audioUrl":"wbw/015_020_002.mp3","charTypeName":"word"},{"id":23246,"position":3,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/015_020_003.mp3","charTypeName":"word"},{"id":23247,"position":4,"arabic":"مَعَـٰيِشَ","translation":"জীবিকার উপকরণসমূহ","audioUrl":"wbw/015_020_004.mp3","charTypeName":"word"},{"id":23248,"position":5,"arabic":"وَمَن","translation":"এবং যাকে","audioUrl":"wbw/015_020_005.mp3","charTypeName":"word"},{"id":23249,"position":6,"arabic":"لَّسْتُمْ","translation":"তোমরা নও","audioUrl":"wbw/015_020_006.mp3","charTypeName":"word"},{"id":23250,"position":7,"arabic":"لَهُۥ","translation":"জন্যে তার","audioUrl":"wbw/015_020_007.mp3","charTypeName":"word"},{"id":23251,"position":8,"arabic":"بِرَٰزِقِينَ","translation":"জীবিকাদাতা","audioUrl":"wbw/015_020_008.mp3","charTypeName":"word"},{"id":23252,"position":9,"arabic":"٢٠","translation":"(২০)","audioUrl":null,"charTypeName":"end"}]},{"number":21,"arabic":"وَإِن مِّن شَىْءٍ إِلَّا عِندَنَا خَزَآئِنُهُۥ وَمَا نُنَزِّلُهُۥٓ إِلَّا بِقَدَرٍۢ مَّعْلُومٍۢ","translation":"For, no single thing exists that does not have its source with Us; and nought do We bestow from on high unless it be in accordance with a measure well-defined.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1823.mp3","surahId":15,"words":[{"id":24309,"position":1,"arabic":"وَإِن","translation":"এবং নেই","audioUrl":"wbw/015_021_001.mp3","charTypeName":"word"},{"id":24310,"position":2,"arabic":"مِّن","translation":"কোনো","audioUrl":"wbw/015_021_002.mp3","charTypeName":"word"},{"id":24311,"position":3,"arabic":"شَىْءٍ","translation":"জিনিস","audioUrl":"wbw/015_021_003.mp3","charTypeName":"word"},{"id":24312,"position":4,"arabic":"إِلَّا","translation":"এ ছাড়া যে","audioUrl":"wbw/015_021_004.mp3","charTypeName":"word"},{"id":24313,"position":5,"arabic":"عِندَنَا","translation":"আমাদের কাছে আছে","audioUrl":"wbw/015_021_005.mp3","charTypeName":"word"},{"id":24314,"position":6,"arabic":"خَزَآئِنُهُۥ","translation":"তার ভান্ডারসমূহ","audioUrl":"wbw/015_021_006.mp3","charTypeName":"word"},{"id":24315,"position":7,"arabic":"وَمَا","translation":"(","audioUrl":"wbw/015_021_007.mp3","charTypeName":"word"},{"id":24316,"position":8,"arabic":"نُنَزِّلُهُۥٓ","translation":"আমরা অবতরণ করি তা","audioUrl":"wbw/015_021_008.mp3","charTypeName":"word"},{"id":24317,"position":9,"arabic":"إِلَّا","translation":"এ ছাড়া যে","audioUrl":"wbw/015_021_009.mp3","charTypeName":"word"},{"id":24318,"position":10,"arabic":"بِقَدَرٍۢ","translation":"সহ পরিমাণ","audioUrl":"wbw/015_021_010.mp3","charTypeName":"word"},{"id":24319,"position":11,"arabic":"مَّعْلُومٍۢ","translation":"নির্দিষ্ট","audioUrl":"wbw/015_021_011.mp3","charTypeName":"word"},{"id":24320,"position":12,"arabic":"٢١","translation":"(২১)","audioUrl":null,"charTypeName":"end"}]},{"number":22,"arabic":"وَأَرْسَلْنَا ٱلرِّيَٰحَ لَوَٰقِحَ فَأَنزَلْنَا مِنَ ٱلسَّمَآءِ مَآءًۭ فَأَسْقَيْنَٰكُمُوهُ وَمَآ أَنتُمْ لَهُۥ بِخَٰزِنِينَ","translation":"And We let loose the winds to fertilize [plants] and We send down water from the skies and let you drink thereof: and it is not you who dispose of its source-","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1824.mp3","surahId":15,"words":[{"id":25333,"position":1,"arabic":"وَأَرْسَلْنَا","translation":"এবং আমরা পাঠাই","audioUrl":"wbw/015_022_001.mp3","charTypeName":"word"},{"id":25334,"position":2,"arabic":"ٱلرِّيَـٰحَ","translation":"বাতাস","audioUrl":"wbw/015_022_002.mp3","charTypeName":"word"},{"id":25335,"position":3,"arabic":"لَوَٰقِحَ","translation":"বৃষ্টিবাহী","audioUrl":"wbw/015_022_003.mp3","charTypeName":"word"},{"id":25336,"position":4,"arabic":"فَأَنزَلْنَا","translation":"অতপর আমরা বর্ষণ করি","audioUrl":"wbw/015_022_004.mp3","charTypeName":"word"},{"id":25337,"position":5,"arabic":"مِنَ","translation":"থেকে","audioUrl":"wbw/015_022_005.mp3","charTypeName":"word"},{"id":25338,"position":6,"arabic":"ٱلسَّمَآءِ","translation":"আকাশ","audioUrl":"wbw/015_022_006.mp3","charTypeName":"word"},{"id":25339,"position":7,"arabic":"مَآءًۭ","translation":"পানি","audioUrl":"wbw/015_022_007.mp3","charTypeName":"word"},{"id":25340,"position":8,"arabic":"فَأَسْقَيْنَـٰكُمُوهُ","translation":"অতঃপর পান করাই তা আমরা তোমাদের","audioUrl":"wbw/015_022_008.mp3","charTypeName":"word"},{"id":25341,"position":9,"arabic":"وَمَآ","translation":"এবং নও","audioUrl":"wbw/015_022_009.mp3","charTypeName":"word"},{"id":25342,"position":10,"arabic":"أَنتُمْ","translation":"তোমরা","audioUrl":"wbw/015_022_010.mp3","charTypeName":"word"},{"id":25343,"position":11,"arabic":"لَهُۥ","translation":"তার জন্যে","audioUrl":"wbw/015_022_011.mp3","charTypeName":"word"},{"id":25344,"position":12,"arabic":"بِخَـٰزِنِينَ","translation":"ভান্ডার রক্ষাকারী","audioUrl":"wbw/015_022_012.mp3","charTypeName":"word"},{"id":25345,"position":13,"arabic":"٢٢","translation":"(২২)","audioUrl":null,"charTypeName":"end"}]},{"number":23,"arabic":"وَإِنَّا لَنَحْنُ نُحْىِۦ وَنُمِيتُ وَنَحْنُ ٱلْوَٰرِثُونَ","translation":"for, behold, it is We-We alone -who grant life and deal death, and it is We alone who shall remain after all else will have passed away!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1825.mp3","surahId":15,"words":[{"id":26380,"position":1,"arabic":"وَإِنَّا","translation":"এবং নিশ্চয়ই আমরা","audioUrl":"wbw/015_023_001.mp3","charTypeName":"word"},{"id":26381,"position":2,"arabic":"لَنَحْنُ","translation":"অবশ্যই আমরা","audioUrl":"wbw/015_023_002.mp3","charTypeName":"word"},{"id":26382,"position":3,"arabic":"نُحْىِۦ","translation":"আমরা জীবন দিই","audioUrl":"wbw/015_023_003.mp3","charTypeName":"word"},{"id":26383,"position":4,"arabic":"وَنُمِيتُ","translation":"ও আমরা মৃত্যু দিই","audioUrl":"wbw/015_023_004.mp3","charTypeName":"word"},{"id":26384,"position":5,"arabic":"وَنَحْنُ","translation":"এবং আমরাই","audioUrl":"wbw/015_023_005.mp3","charTypeName":"word"},{"id":26385,"position":6,"arabic":"ٱلْوَٰرِثُونَ","translation":"উত্তরাধিকারী (সকলেরই)","audioUrl":"wbw/015_023_006.mp3","charTypeName":"word"},{"id":26386,"position":7,"arabic":"٢٣","translation":"(২৩)","audioUrl":null,"charTypeName":"end"}]},{"number":24,"arabic":"وَلَقَدْ عَلِمْنَا ٱلْمُسْتَقْدِمِينَ مِنكُمْ وَلَقَدْ عَلِمْنَا ٱلْمُسْتَـْٔخِرِينَ","translation":"And well do We know [the hearts and deeds of all human beings - both] those who lived before you and those who will come after you;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1826.mp3","surahId":15,"words":[{"id":27400,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/015_024_001.mp3","charTypeName":"word"},{"id":27401,"position":2,"arabic":"عَلِمْنَا","translation":"আমরা জানি","audioUrl":"wbw/015_024_002.mp3","charTypeName":"word"},{"id":27402,"position":3,"arabic":"ٱلْمُسْتَقْدِمِينَ","translation":"অগ্রগামীদেরকে","audioUrl":"wbw/015_024_003.mp3","charTypeName":"word"},{"id":27403,"position":4,"arabic":"مِنكُمْ","translation":"তোমাদের মধ্য থেকে","audioUrl":"wbw/015_024_004.mp3","charTypeName":"word"},{"id":27404,"position":5,"arabic":"وَلَقَدْ","translation":"ও নিশ্চয়ই","audioUrl":"wbw/015_024_005.mp3","charTypeName":"word"},{"id":27405,"position":6,"arabic":"عَلِمْنَا","translation":"আমরা জানি","audioUrl":"wbw/015_024_006.mp3","charTypeName":"word"},{"id":27406,"position":7,"arabic":"ٱلْمُسْتَـْٔخِرِينَ","translation":"পরে আগমনকারীদেরকে","audioUrl":"wbw/015_024_007.mp3","charTypeName":"word"},{"id":27407,"position":8,"arabic":"٢٤","translation":"(২৪)","audioUrl":null,"charTypeName":"end"}]},{"number":25,"arabic":"وَإِنَّ رَبَّكَ هُوَ يَحْشُرُهُمْ ۚ إِنَّهُۥ حَكِيمٌ عَلِيمٌۭ","translation":"and, behold, it is thy Sustainer who will gather them all together [on Judgment Day]: verily, He is wise, all-knowing!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1827.mp3","surahId":15,"words":[{"id":28464,"position":1,"arabic":"وَإِنَّ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/015_025_001.mp3","charTypeName":"word"},{"id":28465,"position":2,"arabic":"رَبَّكَ","translation":"তোমার রব","audioUrl":"wbw/015_025_002.mp3","charTypeName":"word"},{"id":28466,"position":3,"arabic":"هُوَ","translation":"তিনিই","audioUrl":"wbw/015_025_003.mp3","charTypeName":"word"},{"id":28467,"position":4,"arabic":"يَحْشُرُهُمْ ۚ","translation":"তাদের একত্র করবেন","audioUrl":"wbw/015_025_004.mp3","charTypeName":"word"},{"id":28469,"position":5,"arabic":"إِنَّهُۥ","translation":"নিশ্চয়ই তিনি","audioUrl":"wbw/015_025_006.mp3","charTypeName":"word"},{"id":28470,"position":6,"arabic":"حَكِيمٌ","translation":"প্রজ্ঞাময়","audioUrl":"wbw/015_025_007.mp3","charTypeName":"word"},{"id":28471,"position":7,"arabic":"عَلِيمٌۭ","translation":"জ্ঞানময়","audioUrl":"wbw/015_025_008.mp3","charTypeName":"word"},{"id":28472,"position":8,"arabic":"٢٥","translation":"(২৫)","audioUrl":null,"charTypeName":"end"}]},{"number":26,"arabic":"وَلَقَدْ خَلَقْنَا ٱلْإِنسَٰنَ مِن صَلْصَٰلٍۢ مِّنْ حَمَإٍۢ مَّسْنُونٍۢ","translation":"AND, INDEED, We have created man out of sounding clay, out of dark-slime transmuted","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1828.mp3","surahId":15,"words":[{"id":29372,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/015_026_001.mp3","charTypeName":"word"},{"id":29373,"position":2,"arabic":"خَلَقْنَا","translation":"আমরা সৃষ্টি করেছি","audioUrl":"wbw/015_026_002.mp3","charTypeName":"word"},{"id":29374,"position":3,"arabic":"ٱلْإِنسَـٰنَ","translation":"মানুষকে","audioUrl":"wbw/015_026_003.mp3","charTypeName":"word"},{"id":29375,"position":4,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/015_026_004.mp3","charTypeName":"word"},{"id":29376,"position":5,"arabic":"صَلْصَـٰلٍۢ","translation":"শুকনো ঠনঠনে মাটি","audioUrl":"wbw/015_026_005.mp3","charTypeName":"word"},{"id":29377,"position":6,"arabic":"مِّنْ","translation":"(তৈরী) থেকে","audioUrl":"wbw/015_026_006.mp3","charTypeName":"word"},{"id":29378,"position":7,"arabic":"حَمَإٍۢ","translation":"কাদা","audioUrl":"wbw/015_026_007.mp3","charTypeName":"word"},{"id":29379,"position":8,"arabic":"مَّسْنُونٍۢ","translation":"দুর্গন্ধযুক্ত","audioUrl":"wbw/015_026_008.mp3","charTypeName":"word"},{"id":29380,"position":9,"arabic":"٢٦","translation":"(২৬)","audioUrl":null,"charTypeName":"end"}]},{"number":27,"arabic":"وَٱلْجَآنَّ خَلَقْنَٰهُ مِن قَبْلُ مِن نَّارِ ٱلسَّمُومِ","translation":"whereas the invisible beings We had created, [long] before that, out of the fire of scorching winds.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1829.mp3","surahId":15,"words":[{"id":30363,"position":1,"arabic":"وَٱلْجَآنَّ","translation":"এবং জিন","audioUrl":"wbw/015_027_001.mp3","charTypeName":"word"},{"id":30364,"position":2,"arabic":"خَلَقْنَـٰهُ","translation":"আমরা সৃষ্টি করেছি তাকে","audioUrl":"wbw/015_027_002.mp3","charTypeName":"word"},{"id":30365,"position":3,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/015_027_003.mp3","charTypeName":"word"},{"id":30366,"position":4,"arabic":"قَبْلُ","translation":"পূর্ব","audioUrl":"wbw/015_027_004.mp3","charTypeName":"word"},{"id":30367,"position":5,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/015_027_005.mp3","charTypeName":"word"},{"id":30368,"position":6,"arabic":"نَّارِ","translation":"আগুন","audioUrl":"wbw/015_027_006.mp3","charTypeName":"word"},{"id":30369,"position":7,"arabic":"ٱلسَّمُومِ","translation":"অতি উত্তপ্ত","audioUrl":"wbw/015_027_007.mp3","charTypeName":"word"},{"id":30370,"position":8,"arabic":"٢٧","translation":"(২৭)","audioUrl":null,"charTypeName":"end"}]},{"number":28,"arabic":"وَإِذْ قَالَ رَبُّكَ لِلْمَلَٰٓئِكَةِ إِنِّى خَٰلِقٌۢ بَشَرًۭا مِّن صَلْصَٰلٍۢ مِّنْ حَمَإٍۢ مَّسْنُونٍۢ","translation":"And lo! Thy Sustainer said unto the angels: \"Behold, I am about to create mortal man out of sounding clay, out of dark slime transmuted;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1830.mp3","surahId":15,"words":[{"id":31367,"position":1,"arabic":"وَإِذْ","translation":"এবং (স্মরণ করো) যখন","audioUrl":"wbw/015_028_001.mp3","charTypeName":"word"},{"id":31368,"position":2,"arabic":"قَالَ","translation":"বলেছিলেন","audioUrl":"wbw/015_028_002.mp3","charTypeName":"word"},{"id":31369,"position":3,"arabic":"رَبُّكَ","translation":"তোমার রব","audioUrl":"wbw/015_028_003.mp3","charTypeName":"word"},{"id":31370,"position":4,"arabic":"لِلْمَلَـٰٓئِكَةِ","translation":"ফেরেশতাদেরকে","audioUrl":"wbw/015_028_004.mp3","charTypeName":"word"},{"id":31371,"position":5,"arabic":"إِنِّى","translation":"\"নিশ্চয়ই আমি","audioUrl":"wbw/015_028_005.mp3","charTypeName":"word"},{"id":31372,"position":6,"arabic":"خَـٰلِقٌۢ","translation":"(শীঘ্র) সৃষ্টিকারী","audioUrl":"wbw/015_028_006.mp3","charTypeName":"word"},{"id":31373,"position":7,"arabic":"بَشَرًۭا","translation":"মানুষ","audioUrl":"wbw/015_028_007.mp3","charTypeName":"word"},{"id":31374,"position":8,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/015_028_008.mp3","charTypeName":"word"},{"id":31375,"position":9,"arabic":"صَلْصَـٰلٍۢ","translation":"শুকনো ঠনঠনে মাটি","audioUrl":"wbw/015_028_009.mp3","charTypeName":"word"},{"id":31376,"position":10,"arabic":"مِّنْ","translation":"থেকে (তৈরী)","audioUrl":"wbw/015_028_010.mp3","charTypeName":"word"},{"id":31377,"position":11,"arabic":"حَمَإٍۢ","translation":"কাদা","audioUrl":"wbw/015_028_011.mp3","charTypeName":"word"},{"id":31378,"position":12,"arabic":"مَّسْنُونٍۢ","translation":"দুর্গন্ধযুক্ত","audioUrl":"wbw/015_028_012.mp3","charTypeName":"word"},{"id":31379,"position":13,"arabic":"٢٨","translation":"(২৮)","audioUrl":null,"charTypeName":"end"}]},{"number":29,"arabic":"فَإِذَا سَوَّيْتُهُۥ وَنَفَخْتُ فِيهِ مِن رُّوحِى فَقَعُوا۟ لَهُۥ سَٰجِدِينَ","translation":"and when I have formed him fully and breathed into him of My spirit, fall down before him in prostration!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1831.mp3","surahId":15,"words":[{"id":32324,"position":1,"arabic":"فَإِذَا","translation":"অতঃপর যখন","audioUrl":"wbw/015_029_001.mp3","charTypeName":"word"},{"id":32325,"position":2,"arabic":"سَوَّيْتُهُۥ","translation":"আমি সুঠাম করবো তাকে","audioUrl":"wbw/015_029_002.mp3","charTypeName":"word"},{"id":32326,"position":3,"arabic":"وَنَفَخْتُ","translation":"ও আমি ফুঁকে দিবো","audioUrl":"wbw/015_029_003.mp3","charTypeName":"word"},{"id":32327,"position":4,"arabic":"فِيهِ","translation":"তার মধ্যে","audioUrl":"wbw/015_029_004.mp3","charTypeName":"word"},{"id":32328,"position":5,"arabic":"مِن","translation":"থেকে কিছু","audioUrl":"wbw/015_029_005.mp3","charTypeName":"word"},{"id":32329,"position":6,"arabic":"رُّوحِى","translation":"আমার রুহ","audioUrl":"wbw/015_029_006.mp3","charTypeName":"word"},{"id":32330,"position":7,"arabic":"فَقَعُوا۟","translation":"তোমার তখন হয়ে পড়ো","audioUrl":"wbw/015_029_007.mp3","charTypeName":"word"},{"id":32331,"position":8,"arabic":"لَهُۥ","translation":"তার জন্যে","audioUrl":"wbw/015_029_008.mp3","charTypeName":"word"},{"id":32332,"position":9,"arabic":"سَـٰجِدِينَ","translation":"সিজদাকারী\"","audioUrl":"wbw/015_029_009.mp3","charTypeName":"word"},{"id":32333,"position":10,"arabic":"٢٩","translation":"(২৯)","audioUrl":null,"charTypeName":"end"}]},{"number":30,"arabic":"فَسَجَدَ ٱلْمَلَٰٓئِكَةُ كُلُّهُمْ أَجْمَعُونَ","translation":"Thereupon the angels prostrated themselves, all of them together,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1832.mp3","surahId":15,"words":[{"id":33185,"position":1,"arabic":"فَسَجَدَ","translation":"অতঃপর সিজদা করলো","audioUrl":"wbw/015_030_001.mp3","charTypeName":"word"},{"id":33186,"position":2,"arabic":"ٱلْمَلَـٰٓئِكَةُ","translation":"ফেরেশতারা","audioUrl":"wbw/015_030_002.mp3","charTypeName":"word"},{"id":33187,"position":3,"arabic":"كُلُّهُمْ","translation":"তাদের সবাই","audioUrl":"wbw/015_030_003.mp3","charTypeName":"word"},{"id":33188,"position":4,"arabic":"أَجْمَعُونَ","translation":"একত্রে","audioUrl":"wbw/015_030_004.mp3","charTypeName":"word"},{"id":33189,"position":5,"arabic":"٣٠","translation":"(৩০)","audioUrl":null,"charTypeName":"end"}]},{"number":31,"arabic":"إِلَّآ إِبْلِيسَ أَبَىٰٓ أَن يَكُونَ مَعَ ٱلسَّٰجِدِينَ","translation":"save Iblis: he refused to be among those who prostrated themselves.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1833.mp3","surahId":15,"words":[{"id":34242,"position":1,"arabic":"إِلَّآ","translation":"ছাড়া","audioUrl":"wbw/015_031_001.mp3","charTypeName":"word"},{"id":34243,"position":2,"arabic":"إِبْلِيسَ","translation":"ইবলীস","audioUrl":"wbw/015_031_002.mp3","charTypeName":"word"},{"id":34244,"position":3,"arabic":"أَبَىٰٓ","translation":"সে অস্বীকার করলো","audioUrl":"wbw/015_031_003.mp3","charTypeName":"word"},{"id":34245,"position":4,"arabic":"أَن","translation":"যে","audioUrl":"wbw/015_031_004.mp3","charTypeName":"word"},{"id":34246,"position":5,"arabic":"يَكُونَ","translation":"হবে","audioUrl":"wbw/015_031_005.mp3","charTypeName":"word"},{"id":34247,"position":6,"arabic":"مَعَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/015_031_006.mp3","charTypeName":"word"},{"id":34248,"position":7,"arabic":"ٱلسَّـٰجِدِينَ","translation":"সিজদাকারীদের","audioUrl":"wbw/015_031_007.mp3","charTypeName":"word"},{"id":34249,"position":8,"arabic":"٣١","translation":"(৩১)","audioUrl":null,"charTypeName":"end"}]}]}