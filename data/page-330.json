{"id":330,"ayahs":[{"number":91,"arabic":"وَٱلَّتِىٓ أَحْصَنَتْ فَرْجَهَا فَنَفَخْنَا فِيهَا مِن رُّوحِنَا وَجَعَلْنَٰهَا وَٱبْنَهَآ ءَايَةًۭ لِّلْعَٰلَمِينَ","translation":"AND [remember] her who guarded her chastity, whereupon We breathed into her of Our spirit and caused her, together with her son, to become a symbol [of Our grace] unto all people.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2574.mp3","surahId":21,"words":[{"id":68570,"position":1,"arabic":"وَٱلَّتِىٓ","translation":"এবং (স্মরণ করো) (মারইয়ামকে) যে","audioUrl":"wbw/021_091_001.mp3","charTypeName":"word"},{"id":68571,"position":2,"arabic":"أَحْصَنَتْ","translation":"রক্ষা করেছিলো","audioUrl":"wbw/021_091_002.mp3","charTypeName":"word"},{"id":68572,"position":3,"arabic":"فَرْجَهَا","translation":"তার সতীত্বকে","audioUrl":"wbw/021_091_003.mp3","charTypeName":"word"},{"id":68573,"position":4,"arabic":"فَنَفَخْنَا","translation":"অতঃপর আমরা ফুঁকে দিলাম","audioUrl":"wbw/021_091_004.mp3","charTypeName":"word"},{"id":68574,"position":5,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/021_091_005.mp3","charTypeName":"word"},{"id":68575,"position":6,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/021_091_006.mp3","charTypeName":"word"},{"id":68576,"position":7,"arabic":"رُّوحِنَا","translation":"আমাদের রূহ","audioUrl":"wbw/021_091_007.mp3","charTypeName":"word"},{"id":68577,"position":8,"arabic":"وَجَعَلْنَـٰهَا","translation":"এবং তাকে বানিয়েছিলাম","audioUrl":"wbw/021_091_008.mp3","charTypeName":"word"},{"id":68578,"position":9,"arabic":"وَٱبْنَهَآ","translation":"ও তার পুত্রকে","audioUrl":"wbw/021_091_009.mp3","charTypeName":"word"},{"id":68579,"position":10,"arabic":"ءَايَةًۭ","translation":"একটি নিদর্শন","audioUrl":"wbw/021_091_010.mp3","charTypeName":"word"},{"id":68580,"position":11,"arabic":"لِّلْعَـٰلَمِينَ","translation":"জন্যে বিশ্ববাসীদের","audioUrl":"wbw/021_091_011.mp3","charTypeName":"word"},{"id":68581,"position":12,"arabic":"٩١","translation":"(৯১)","audioUrl":null,"charTypeName":"end"}]},{"number":92,"arabic":"إِنَّ هَٰذِهِۦٓ أُمَّتُكُمْ أُمَّةًۭ وَٰحِدَةًۭ وَأَنَا۠ رَبُّكُمْ فَٱعْبُدُونِ","translation":"VERILY, [O you who believe in Me,] this community of yours is one single community, since I am the Sustainer of you all: worship, then, Me [alone]!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2575.mp3","surahId":21,"words":[{"id":68654,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/021_092_001.mp3","charTypeName":"word"},{"id":68655,"position":2,"arabic":"هَـٰذِهِۦٓ","translation":"এই যে","audioUrl":"wbw/021_092_002.mp3","charTypeName":"word"},{"id":68656,"position":3,"arabic":"أُمَّتُكُمْ","translation":"তোমাদের জাতি","audioUrl":"wbw/021_092_003.mp3","charTypeName":"word"},{"id":68657,"position":4,"arabic":"أُمَّةًۭ","translation":"জাতি (প্রকৃতপক্ষে)","audioUrl":"wbw/021_092_004.mp3","charTypeName":"word"},{"id":68658,"position":5,"arabic":"وَٰحِدَةًۭ","translation":"একই","audioUrl":"wbw/021_092_005.mp3","charTypeName":"word"},{"id":68659,"position":6,"arabic":"وَأَنَا۠","translation":"এবং আমি","audioUrl":"wbw/021_092_006.mp3","charTypeName":"word"},{"id":68660,"position":7,"arabic":"رَبُّكُمْ","translation":"তোমাদের রব","audioUrl":"wbw/021_092_007.mp3","charTypeName":"word"},{"id":68661,"position":8,"arabic":"فَٱعْبُدُونِ","translation":"সুতরাং তোমরা আমারই ইবাদাত করো","audioUrl":"wbw/021_092_008.mp3","charTypeName":"word"},{"id":68662,"position":9,"arabic":"٩٢","translation":"(৯২)","audioUrl":null,"charTypeName":"end"}]},{"number":93,"arabic":"وَتَقَطَّعُوٓا۟ أَمْرَهُم بَيْنَهُمْ ۖ كُلٌّ إِلَيْنَا رَٰجِعُونَ","translation":"But men have torn their unity wide asunder, [forgetting that] unto Us they all are bound to return.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2576.mp3","surahId":21,"words":[{"id":69181,"position":1,"arabic":"وَتَقَطَّعُوٓا۟","translation":"কিন্তু তারা টুকরা টুকরা করে ফেললো","audioUrl":"wbw/021_093_001.mp3","charTypeName":"word"},{"id":69182,"position":2,"arabic":"أَمْرَهُم","translation":"তাদের কার্যকলাপ (দ্বীন)","audioUrl":"wbw/021_093_002.mp3","charTypeName":"word"},{"id":69183,"position":3,"arabic":"بَيْنَهُمْ ۖ","translation":"তাদের মাঝে","audioUrl":"wbw/021_093_003.mp3","charTypeName":"word"},{"id":69185,"position":4,"arabic":"كُلٌّ","translation":"প্রত্যেককে","audioUrl":"wbw/021_093_005.mp3","charTypeName":"word"},{"id":69186,"position":5,"arabic":"إِلَيْنَا","translation":"আমাদের দিকেই","audioUrl":"wbw/021_093_006.mp3","charTypeName":"word"},{"id":69187,"position":6,"arabic":"رَٰجِعُونَ","translation":"প্রত্যাবর্তনকারী","audioUrl":"wbw/021_093_007.mp3","charTypeName":"word"},{"id":69188,"position":7,"arabic":"٩٣","translation":"(৯৩)","audioUrl":null,"charTypeName":"end"}]},{"number":94,"arabic":"فَمَن يَعْمَلْ مِنَ ٱلصَّٰلِحَٰتِ وَهُوَ مُؤْمِنٌۭ فَلَا كُفْرَانَ لِسَعْيِهِۦ وَإِنَّا لَهُۥ كَٰتِبُونَ","translation":"And yet, whoever does [the least] of righteous deeds and is a believer withal, his endeavour shall not be disowned: for, behold, We shall record it in his favour.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2577.mp3","surahId":21,"words":[{"id":69414,"position":1,"arabic":"فَمَن","translation":"তবে যে","audioUrl":"wbw/021_094_001.mp3","charTypeName":"word"},{"id":69415,"position":2,"arabic":"يَعْمَلْ","translation":"কাজ করবে","audioUrl":"wbw/021_094_002.mp3","charTypeName":"word"},{"id":69416,"position":3,"arabic":"مِنَ","translation":"থেকে","audioUrl":"wbw/021_094_003.mp3","charTypeName":"word"},{"id":69417,"position":4,"arabic":"ٱلصَّـٰلِحَـٰتِ","translation":"সৎকাজসমূহের","audioUrl":"wbw/021_094_004.mp3","charTypeName":"word"},{"id":69418,"position":5,"arabic":"وَهُوَ","translation":"এ অবস্থায় যে সে","audioUrl":"wbw/021_094_005.mp3","charTypeName":"word"},{"id":69419,"position":6,"arabic":"مُؤْمِنٌۭ","translation":"মু'মিনও (হবে)","audioUrl":"wbw/021_094_006.mp3","charTypeName":"word"},{"id":69420,"position":7,"arabic":"فَلَا","translation":"তখন না","audioUrl":"wbw/021_094_007.mp3","charTypeName":"word"},{"id":69421,"position":8,"arabic":"كُفْرَانَ","translation":"অগ্রাহ্য হবে (তার কাজ)","audioUrl":"wbw/021_094_008.mp3","charTypeName":"word"},{"id":69422,"position":9,"arabic":"لِسَعْيِهِۦ","translation":"জন্যে তার প্রচেষ্টার","audioUrl":"wbw/021_094_009.mp3","charTypeName":"word"},{"id":69423,"position":10,"arabic":"وَإِنَّا","translation":"এবং নিশ্চয়ই আমরা","audioUrl":"wbw/021_094_010.mp3","charTypeName":"word"},{"id":69424,"position":11,"arabic":"لَهُۥ","translation":"জন্যে তার","audioUrl":"wbw/021_094_011.mp3","charTypeName":"word"},{"id":69425,"position":12,"arabic":"كَـٰتِبُونَ","translation":"লেখক (অর্থাৎ লিখে রাখি)","audioUrl":"wbw/021_094_012.mp3","charTypeName":"word"},{"id":69426,"position":13,"arabic":"٩٤","translation":"(৯৪)","audioUrl":null,"charTypeName":"end"}]},{"number":95,"arabic":"وَحَرَٰمٌ عَلَىٰ قَرْيَةٍ أَهْلَكْنَٰهَآ أَنَّهُمْ لَا يَرْجِعُونَ","translation":"Hence, it has been unfailingly true of any community whom We have ever destroyed that they [were people who] would never turn back [from their sinful ways]","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2578.mp3","surahId":21,"words":[{"id":69829,"position":1,"arabic":"وَحَرَٰمٌ","translation":"এবং (প্রত্যাবর্তন) নিষিদ্ধ","audioUrl":"wbw/021_095_001.mp3","charTypeName":"word"},{"id":69830,"position":2,"arabic":"عَلَىٰ","translation":"জন্য","audioUrl":"wbw/021_095_002.mp3","charTypeName":"word"},{"id":69831,"position":3,"arabic":"قَرْيَةٍ","translation":"কোন জনপদের","audioUrl":"wbw/021_095_003.mp3","charTypeName":"word"},{"id":69832,"position":4,"arabic":"أَهْلَكْنَـٰهَآ","translation":"আমরা ধ্বংস করেছি তাকে","audioUrl":"wbw/021_095_004.mp3","charTypeName":"word"},{"id":69833,"position":5,"arabic":"أَنَّهُمْ","translation":"তারা যে","audioUrl":"wbw/021_095_005.mp3","charTypeName":"word"},{"id":69834,"position":6,"arabic":"لَا","translation":"না","audioUrl":"wbw/021_095_006.mp3","charTypeName":"word"},{"id":69835,"position":7,"arabic":"يَرْجِعُونَ","translation":"ফিরে আসতে পারবে","audioUrl":"wbw/021_095_007.mp3","charTypeName":"word"},{"id":69836,"position":8,"arabic":"٩٥","translation":"(৯৫)","audioUrl":null,"charTypeName":"end"}]},{"number":96,"arabic":"حَتَّىٰٓ إِذَا فُتِحَتْ يَأْجُوجُ وَمَأْجُوجُ وَهُم مِّن كُلِّ حَدَبٍۢ يَنسِلُونَ","translation":"until such a time as Gog and Magog are let loose [upon the world] and swarm down from every corner [of the earth],","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2579.mp3","surahId":21,"words":[{"id":70126,"position":1,"arabic":"حَتَّىٰٓ","translation":"এমনকি","audioUrl":"wbw/021_096_001.mp3","charTypeName":"word"},{"id":70127,"position":2,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/021_096_002.mp3","charTypeName":"word"},{"id":70128,"position":3,"arabic":"فُتِحَتْ","translation":"খুলে দেয়া হবে","audioUrl":"wbw/021_096_003.mp3","charTypeName":"word"},{"id":70129,"position":4,"arabic":"يَأْجُوجُ","translation":"ইয়াজুজ","audioUrl":"wbw/021_096_004.mp3","charTypeName":"word"},{"id":70130,"position":5,"arabic":"وَمَأْجُوجُ","translation":"ও মাজুজকে","audioUrl":"wbw/021_096_005.mp3","charTypeName":"word"},{"id":70131,"position":6,"arabic":"وَهُم","translation":"এবং তারা","audioUrl":"wbw/021_096_006.mp3","charTypeName":"word"},{"id":70132,"position":7,"arabic":"مِّن","translation":"হ'তে","audioUrl":"wbw/021_096_007.mp3","charTypeName":"word"},{"id":70133,"position":8,"arabic":"كُلِّ","translation":"প্রত্যেক","audioUrl":"wbw/021_096_008.mp3","charTypeName":"word"},{"id":70134,"position":9,"arabic":"حَدَبٍۢ","translation":"উচ্চভূমি","audioUrl":"wbw/021_096_009.mp3","charTypeName":"word"},{"id":70135,"position":10,"arabic":"يَنسِلُونَ","translation":"ছুটে আসবে","audioUrl":"wbw/021_096_010.mp3","charTypeName":"word"},{"id":70136,"position":11,"arabic":"٩٦","translation":"(৯৬)","audioUrl":null,"charTypeName":"end"}]},{"number":97,"arabic":"وَٱقْتَرَبَ ٱلْوَعْدُ ٱلْحَقُّ فَإِذَا هِىَ شَٰخِصَةٌ أَبْصَٰرُ ٱلَّذِينَ كَفَرُوا۟ يَٰوَيْلَنَا قَدْ كُنَّا فِى غَفْلَةٍۢ مِّنْ هَٰذَا بَلْ كُنَّا ظَٰلِمِينَ","translation":"the while the true promise [of resurrection] draws close [to its fulfillment]. But then, lo! the eyes of those who [in their lifetime] were bent on denying the truth will stare in horror, [and they will exclaim:] “Oh, woe unto us! We were indeed heedless of this [promise of resur­rection]! - nay, we were [bent on] doing evil!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2580.mp3","surahId":21,"words":[{"id":70282,"position":1,"arabic":"وَٱقْتَرَبَ","translation":"এবং নিকটবর্তী হবে","audioUrl":"wbw/021_097_001.mp3","charTypeName":"word"},{"id":70283,"position":2,"arabic":"ٱلْوَعْدُ","translation":"প্রতিশ্রুতি (ক্বিয়ামাতের)","audioUrl":"wbw/021_097_002.mp3","charTypeName":"word"},{"id":70284,"position":3,"arabic":"ٱلْحَقُّ","translation":"সত্য","audioUrl":"wbw/021_097_003.mp3","charTypeName":"word"},{"id":70285,"position":4,"arabic":"فَإِذَا","translation":"অতঃপর যখন","audioUrl":"wbw/021_097_004.mp3","charTypeName":"word"},{"id":70286,"position":5,"arabic":"هِىَ","translation":"তা","audioUrl":"wbw/021_097_005.mp3","charTypeName":"word"},{"id":70287,"position":6,"arabic":"شَـٰخِصَةٌ","translation":"বিস্ফোরিত হবে","audioUrl":"wbw/021_097_006.mp3","charTypeName":"word"},{"id":70288,"position":7,"arabic":"أَبْصَـٰرُ","translation":"চোখগুলো","audioUrl":"wbw/021_097_007.mp3","charTypeName":"word"},{"id":70289,"position":8,"arabic":"ٱلَّذِينَ","translation":"(তাদের) যারা","audioUrl":"wbw/021_097_008.mp3","charTypeName":"word"},{"id":70290,"position":9,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করেছিলো","audioUrl":"wbw/021_097_009.mp3","charTypeName":"word"},{"id":70291,"position":10,"arabic":"يَـٰوَيْلَنَا","translation":"\"(এবং বলবে) হায় আমাদের দুর্ভোগ","audioUrl":"wbw/021_097_010.mp3","charTypeName":"word"},{"id":70292,"position":11,"arabic":"قَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/021_097_011.mp3","charTypeName":"word"},{"id":70293,"position":12,"arabic":"كُنَّا","translation":"আমরা ছিলাম","audioUrl":"wbw/021_097_012.mp3","charTypeName":"word"},{"id":70294,"position":13,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/021_097_013.mp3","charTypeName":"word"},{"id":70295,"position":14,"arabic":"غَفْلَةٍۢ","translation":"উদাসীনতার","audioUrl":"wbw/021_097_014.mp3","charTypeName":"word"},{"id":70296,"position":15,"arabic":"مِّنْ","translation":"সম্পর্কে","audioUrl":"wbw/021_097_015.mp3","charTypeName":"word"},{"id":70297,"position":16,"arabic":"هَـٰذَا","translation":"এটা","audioUrl":"wbw/021_097_016.mp3","charTypeName":"word"},{"id":70298,"position":17,"arabic":"بَلْ","translation":"বরং","audioUrl":"wbw/021_097_017.mp3","charTypeName":"word"},{"id":70299,"position":18,"arabic":"كُنَّا","translation":"আমরা ছিলাম","audioUrl":"wbw/021_097_018.mp3","charTypeName":"word"},{"id":70300,"position":19,"arabic":"ظَـٰلِمِينَ","translation":"সীমালঙ্ঘনকারী\"","audioUrl":"wbw/021_097_019.mp3","charTypeName":"word"},{"id":70301,"position":20,"arabic":"٩٧","translation":"(৯৭)","audioUrl":null,"charTypeName":"end"}]},{"number":98,"arabic":"إِنَّكُمْ وَمَا تَعْبُدُونَ مِن دُونِ ٱللَّهِ حَصَبُ جَهَنَّمَ أَنتُمْ لَهَا وَٰرِدُونَ","translation":"[Then they will be told:] “Verily, you and all that you [were wont to] worship instead of God are but the fuel of hell: that is what you are destined for.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2581.mp3","surahId":21,"words":[{"id":70725,"position":1,"arabic":"إِنَّكُمْ","translation":"নিশ্চয়ই তোমরা","audioUrl":"wbw/021_098_001.mp3","charTypeName":"word"},{"id":70726,"position":2,"arabic":"وَمَا","translation":"ও যাদের","audioUrl":"wbw/021_098_002.mp3","charTypeName":"word"},{"id":70727,"position":3,"arabic":"تَعْبُدُونَ","translation":"তোমরা ইবাদাত করতে","audioUrl":"wbw/021_098_003.mp3","charTypeName":"word"},{"id":70728,"position":4,"arabic":"مِن","translation":"মধ্য হতে","audioUrl":"wbw/021_098_004.mp3","charTypeName":"word"},{"id":70729,"posit