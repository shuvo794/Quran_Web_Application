peName":"word"},{"id":84205,"position":20,"arabic":"حَدِيثٍۭ","translation":"কথায়","audioUrl":"wbw/007_185_021.mp3","charTypeName":"word"},{"id":84206,"position":21,"arabic":"بَعْدَهُۥ","translation":"পর এর","audioUrl":"wbw/007_185_022.mp3","charTypeName":"word"},{"id":84207,"position":22,"arabic":"يُؤْمِنُونَ","translation":"তারা ঈমান আনবে","audioUrl":"wbw/007_185_023.mp3","charTypeName":"word"},{"id":84208,"position":23,"arabic":"١٨٥","translation":"(১৮৫)","audioUrl":null,"charTypeName":"end"}]},{"number":186,"arabic":"مَن يُضْلِلِ ٱللَّهُ فَلَا هَادِىَ لَهُۥ ۚ وَيَذَرُهُمْ فِى طُغْيَٰنِهِمْ يَعْمَهُونَ","translation":"For those whom God lets go astray, there is no guide; and He shall leave them in their overweening arrogance, blindly stumbling to and fro.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1140.mp3","surahId":7,"words":[{"id":84246,"position":1,"arabic":"مَن","translation":"যাকে","audioUrl":"wbw/007_186_001.mp3","charTypeName":"word"},{"id":84247,"position":2,"arabic":"يُضْلِلِ","translation":"পথভ্রষ্ট করেন","audioUrl":"wbw/007_186_002.mp3","charTypeName":"word"},{"id":84248,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/007_186_003.mp3","charTypeName":"word"},{"id":84249,"position":4,"arabic":"فَلَا","translation":"অতঃপর নেই","audioUrl":"wbw/007_186_004.mp3","charTypeName":"word"},{"id":84250,"position":5,"arabic":"هَادِىَ","translation":"কোনো পথ প্রদর্শক","audioUrl":"wbw/007_186_005.mp3","charTypeName":"word"},{"id":84251,"position":6,"arabic":"لَهُۥ ۚ","translation":"জন্যে তার","audioUrl":"wbw/007_186_006.mp3","charTypeName":"word"},{"id":84253,"position":7,"arabic":"وَيَذَرُهُمْ","translation":"এবং  তিনি ছেড়ে দেন তাদেরকে","audioUrl":"wbw/007_186_008.mp3","charTypeName":"word"},{"id":84254,"position":8,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/007_186_009.mp3","charTypeName":"word"},{"id":84255,"position":9,"arabic":"طُغْيَـٰنِهِمْ","translation":"বিদ্রোহিতার তাদের","audioUrl":"wbw/007_186_010.mp3","charTypeName":"word"},{"id":84256,"position":10,"arabic":"يَعْمَهُونَ","translation":"তারা উদভ্রান্ত হয়ে ফিরবে","audioUrl":"wbw/007_186_011.mp3","charTypeName":"word"},{"id":84257,"position":11,"arabic":"١٨٦","translation":"(১৮৬)","audioUrl":null,"charTypeName":"end"}]},{"number":187,"arabic":"يَسْـَٔلُونَكَ عَنِ ٱلسَّاعَةِ أَيَّانَ مُرْسَىٰهَا ۖ قُلْ إِنَّمَا عِلْمُهَا عِندَ رَبِّى ۖ لَا يُجَلِّيهَا لِوَقْتِهَآ إِلَّا هُوَ ۚ ثَقُلَتْ فِى ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ ۚ لَا تَأْتِيكُمْ إِلَّا بَغْتَةًۭ ۗ يَسْـَٔلُونَكَ كَأَنَّكَ حَفِىٌّ عَنْهَا ۖ قُلْ إِنَّمَا عِلْمُهَا عِندَ ٱللَّهِ وَلَٰكِنَّ أَكْثَرَ ٱلنَّاسِ لَا يَعْلَمُونَ","translation":"THEY WILL ASK thee [O Prophet] about the Last Hour: \"When will it come to pass?\" Say: \"Verily, knowledge thereof rests with my Sustainer alone. None but He will reveal it in its time. Heavily will it weigh on the heavens and the earth; [and] it will not fall upon you otherwise than of a sudden.\" They will ask thee - as if thou couldst gain insight into this [mystery] by dint of persistent inquiry! Say: \"Knowledge thereof rests with my Sustainer alone; but [of this] most people are unaware.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1141.mp3","surahId":7,"words":[{"id":84311,"position":1,"arabic":"يَسْـَٔلُونَكَ","translation":"তোমাকে তারা জিজ্ঞাসা করে","audioUrl":"wbw/007_187_001.mp3","charTypeName":"word"},{"id":84312,"position":2,"arabic":"عَنِ","translation":"সম্পর্কে","audioUrl":"wbw/007_187_002.mp3","charTypeName":"word"},{"id":84313,"position":3,"arabic":"ٱلسَّاعَةِ","translation":"ক্বিয়ামাত","audioUrl":"wbw/007_187_003.mp3","charTypeName":"word"},{"id":84314,"position":4,"arabic":"أَيَّانَ","translation":"কখন","audioUrl":"wbw/007_187_004.mp3","charTypeName":"word"},{"id":84315,"position":5,"arabic":"مُرْسَىٰهَا ۖ","translation":"ঘটবে তা","audioUrl":"wbw/007_187_005.mp3","charTypeName":"word"},{"id":84317,"position":6,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/007_187_007.mp3","charTypeName":"word"},{"id":84318,"position":7,"arabic":"إِنَّمَا","translation":"\"মূলতঃ","audioUrl":"wbw/007_187_008.mp3","charTypeName":"word"},{"id":84319,"position":8,"arabic":"عِلْمُهَا","translation":"জ্ঞান তার","audioUrl":"wbw/007_187_009.mp3","charTypeName":"word"},{"id":84320,"position":9,"arabic":"عِندَ","translation":"কাছে","audioUrl":"wbw/007_187_010.mp3","charTypeName":"word"},{"id":84321,"position":10,"arabic":"رَبِّى ۖ","translation":"আমার রবের","audioUrl":"wbw/007_187_011.mp3","charTypeName":"word"},{"id":84323,"position":11,"arabic":"لَا","translation":"না","audioUrl":"wbw/007_187_013.mp3","charTypeName":"word"},{"id":84324,"position":12,"arabic":"يُجَلِّيهَا","translation":"কেউ প্রকাশ করে তা","audioUrl":"wbw/007_187_014.mp3","charTypeName":"word"},{"id":84325,"position":13,"arabic":"لِوَقْتِهَآ","translation":"মধ্যে সময়ের তার (অন্য কারো কাছে)","audioUrl":"wbw/007_187_015.mp3","charTypeName":"word"},{"id":84326,"position":14,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/007_187_016.mp3","charTypeName":"word"},{"id":84327,"position":15,"arabic":"هُوَ ۚ","translation":"তিনি","audioUrl":"wbw/007_187_017.mp3","charTypeName":"word"},{"id":84329,"position":16,"arabic":"ثَقُلَتْ","translation":"ভারী হবে","audioUrl":"wbw/007_187_019.mp3","charTypeName":"word"},{"id":84330,"position":17,"arabic":"فِى","translation":"উপর","audioUrl":"wbw/007_187_020.mp3","charTypeName":"word"},{"id":84331,"position":18,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশমন্ডলীর","audioUrl":"wbw/007_187_021.mp3","charTypeName":"word"},{"id":84332,"position":19,"arabic":"وَٱلْأَرْضِ ۚ","translation":"ও পৃথিবীর (উপর)","audioUrl":"wbw/007_187_022.mp3","charTypeName":"word"},{"id":84334,"position":20,"arabic":"لَا","translation":"না","audioUrl":"wbw/007_187_024.mp3","charTypeName":"word"},{"id":84335,"position":21,"arabic":"تَأْتِيكُمْ","translation":"কাছে তা আসবে তোমাদের","audioUrl":"wbw/007_187_025.mp3","charTypeName":"word"},{"id":84336,"position":22,"arabic":"إِلَّا","tr