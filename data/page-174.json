{"id":83764,"position":26,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/007_179_028.mp3","charTypeName":"word"},{"id":83765,"position":27,"arabic":"أَضَلُّ ۚ","translation":"অধিক বিভ্রান্ত","audioUrl":"wbw/007_179_029.mp3","charTypeName":"word"},{"id":83767,"position":28,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐসব (লোক)","audioUrl":"wbw/007_179_031.mp3","charTypeName":"word"},{"id":83768,"position":29,"arabic":"هُمُ","translation":"তারাই","audioUrl":"wbw/007_179_032.mp3","charTypeName":"word"},{"id":83769,"position":30,"arabic":"ٱلْغَـٰفِلُونَ","translation":"উদাসীন","audioUrl":"wbw/007_179_033.mp3","charTypeName":"word"},{"id":83770,"position":31,"arabic":"١٧٩","translation":"(১৭৯)","audioUrl":null,"charTypeName":"end"}]},{"number":180,"arabic":"وَلِلَّهِ ٱلْأَسْمَآءُ ٱلْحُسْنَىٰ فَٱدْعُوهُ بِهَا ۖ وَذَرُوا۟ ٱلَّذِينَ يُلْحِدُونَ فِىٓ أَسْمَٰٓئِهِۦ ۚ سَيُجْزَوْنَ مَا كَانُوا۟ يَعْمَلُونَ","translation":"AND GOD'S [alone] are the attributes of perfection; invoke Him, then, by these, and stand aloof from all who distort the meaning of His attributes: they shall be requited for all that they were wont to do!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1134.mp3","surahId":7,"words":[{"id":83775,"position":1,"arabic":"وَلِلَّهِ","translation":"এবং জন্যে আল্লাহর (রয়েছে)","audioUrl":"wbw/007_180_001.mp3","charTypeName":"word"},{"id":83776,"position":2,"arabic":"ٱلْأَسْمَآءُ","translation":"নামসমূহ","audioUrl":"wbw/007_180_002.mp3","charTypeName":"word"},{"id":83777,"position":3,"arabic":"ٱلْحُسْنَىٰ","translation":"উত্তম","audioUrl":"wbw/007_180_003.mp3","charTypeName":"word"},{"id":83778,"position":4,"arabic":"فَٱدْعُوهُ","translation":"অতএব তাঁকে ডাকো","audioUrl":"wbw/007_180_004.mp3","charTypeName":"word"},{"id":83779,"position":5,"arabic":"بِهَا ۖ","translation":"দিয়ে তা","audioUrl":"wbw/007_180_005.mp3","charTypeName":"word"},{"id":83781,"position":6,"arabic":"وَذَرُوا۟","translation":"এবং তোমরা বর্জন করো","audioUrl":"wbw/007_180_007.mp3","charTypeName":"word"},{"id":83782,"position":7,"arabic":"ٱلَّذِينَ","translation":"(তাদেরকে) যারা","audioUrl":"wbw/007_180_008.mp3","charTypeName":"word"},{"id":83783,"position":8,"arabic":"يُلْحِدُونَ","translation":"বিকৃত করে","audioUrl":"wbw/007_180_009.mp3","charTypeName":"word"},{"id":83784,"position":9,"arabic":"فِىٓ","translation":"মধ্যে","audioUrl":"wbw/007_180_010.mp3","charTypeName":"word"},{"id":83785,"position":10,"arabic":"أَسْمَـٰٓئِهِۦ ۚ","translation":"তাঁর নামসমূহের","audioUrl":"wbw/007_180_011.mp3","charTypeName":"word"},{"id":83787,"position":11,"arabic":"سَيُجْزَوْنَ","translation":"শীঘ্রই তাদেরকে প্রতিফল দেওয়া হবে","audioUrl":"wbw/007_180_013.mp3","charTypeName":"word"},{"id":83788,"position":12,"arabic":"مَا","translation":"যা","audioUrl":"wbw/007_180_014.mp3","charTypeName":"word"},{"id":83789,"position":13,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/007_180_015.mp3","charTypeName":"word"},{"id":83790,"position":14,"arabic":"يَعْمَلُونَ","translation":"তারা কাজ করে চলেছে","audioUrl":"wbw/007_180_016.mp3","charTypeName":"word"},{"id":83791,"position":15,"arabic":"١٨٠","translation":"(১৮০)","audioUrl":null,"charTypeName":"end"}]},{"number":181,"arabic":"وَمِمَّنْ خَلَقْنَآ أُمَّةٌۭ يَهْدُونَ بِٱلْحَقِّ وَبِهِۦ يَعْدِلُونَ","translation":"Now, among those whom We have created there are people who guide [others] in the way of the truth and act justly in its light.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1135.mp3","surahId":7,"words":[{"id":83905,"position":1,"arabic":"وَمِمَّنْ","translation":"এবং তাদের মধ্যে হতে","audioUrl":"wbw/007_181_001.mp3","charTypeName":"word"},{"id":83906,"position":2,"arabic":"خَلَقْنَآ","translation":"সৃষ্টি করেছি আমরা","audioUrl":"wbw/007_181_002.mp3","charTypeName":"word"},{"id":83907,"position":3,"arabic":"أُمَّةٌۭ","translation":"(এমনও) একদল","audioUrl":"wbw/007_181_003.mp3","charTypeName":"word"},{"id":83908,"position":4,"arabic":"يَهْدُونَ","translation":"(যারা) পথ দেখায়","audioUrl":"wbw/007_181_004.mp3","charTypeName":"word"},{"id":83909,"position":5,"arabic":"بِٱلْحَقِّ","translation":"দিকে সত্যের","audioUrl":"wbw/007_181_005.mp3","charTypeName":"word"},{"id":83910,"position":6,"arabic":"وَبِهِۦ","translation":"এবং দিয়ে তা","audioUrl":"wbw/007_181_006.mp3","charTypeName":"word"},{"id":83911,"position":7,"arabic":"يَعْدِلُونَ","translation":"তারা ন্যায় বিচার করে","audioUrl":"wbw/007_181_007.mp3","charTypeName":"word"},{"id":83912,"position":8,"arabic":"١٨١","translation":"(১৮১)","audioUrl":null,"charTypeName":"end"}]},{"number":182,"arabic":"وَٱلَّذِينَ كَذَّبُوا۟ بِـَٔايَٰتِنَا سَنَسْتَدْرِجُهُم مِّنْ حَيْثُ لَا يَعْلَمُونَ","translation":"But as for those who are bent on giving the lie to Our messages-We shall bring them low, step by step, without their perceiving how it came about:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1136.mp3","surahId":7,"words":[{"id":83947,"position":1,"arabic":"وَٱلَّذِينَ","translation":"ও যারা","audioUrl":"wbw/007_182_001.mp3","charTypeName":"word"},{"id":83948,"position":2,"arabic":"كَذَّبُوا۟","translation":"মিথ্যারোপ করেছে","audioUrl":"wbw/007_182_002.mp3","charTypeName":"word"},{"id":83949,"position":3,"arabic":"بِـَٔايَـٰتِنَا","translation":"প্রতি নিদর্শনগুলোর আমাদের","audioUrl":"wbw/007_182_003.mp3","charTypeName":"word"},{"id":83950,"position":4,"arabic":"سَنَسْتَدْرِجُهُم","translation":"অচিরেই ক্রমান্বয়ে নিয়ে যাবো আমরা তাদের (ধ্বংসের দিকে)","audioUrl":"wbw/007_182_004.mp3","charTypeName":"word"},{"id":83951,"position":5,"arabic":"مِّنْ","translation":"থেকে","audioUrl":"wbw/007_182_005.mp3","charTypeName":"word"},{"id":83952,"position":6,"arabic":"حَيْثُ","translation":"যেখান","audioUrl":"wbw/007_182_006.mp3","charTypeName":"word"},{"id":83953,"position":7,"arabic":"لَا","translation":"না","audioUrl":"wbw/007_182_007.mp3","charTypeName":"word"},{"id":83954,"position":8,"arabic":"يَعْلَمُونَ","translation":"তারা জানতেও পারবে","audioUrl":"wbw/007_182_008.mp3","charTypeName":"word"},{"id":83955,"position":9,"arabic":"١٨٢","translation":"(১৮২)","audioUrl":null,"charTypeName":"end"}]},{"number":183,"arabic":"وَأُمْلِى لَهُمْ ۚ إِنَّ كَيْدِى مَتِينٌ","translation":"for, behold, though I may give them rein for a while. My subtle scheme is exceedingly firm!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1137.mp3","surahId":7,"words":[{"id":84026,"position":1,"arabic":"وَأُمْلِى","translation":"এবং অবকাশ দিচ্ছি আমি","audioUrl":"wbw/007_183_001.mp3","charTypeName":"word"},{"id":84027,"position":2,"arabic":"لَهُمْ ۚ","translation":"জন্যে তাদের","audioUrl":"wbw/007_183_002.mp3","charTypeName":"word"},{"id":84029,"position":3,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/007_183_004.mp3","charTypeName":"word"},{"id":84030,"position":4,"arabic":"كَيْدِى","translation":"আমার কৌশল","audioUrl":"wbw/007_183_005.mp3","charTypeName":"word"},{"id":84031,"position":5,"arabic":"مَتِينٌ","translation":"বলিষ্ঠ","audioUrl":"wbw/007_183_006.mp3","charTypeName":"word"},{"id":84032,"position":6,"arabic":"١٨٣","translation":"(১৮৩)","audioUrl":null,"charTypeName":"end"}]},{"number":184,"arabic":"أَوَلَمْ يَتَفَكَّرُوا۟ ۗ مَا بِصَاحِبِهِم مِّن جِنَّةٍ ۚ إِنْ هُوَ إِلَّا نَذِيرٌۭ مُّبِينٌ","translation":"Has it, then, never occurred to them that there is no madness whatever in [this] their fellowman? He is only a plain warner.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1138.mp3","surahId":7,"words":[{"id":84039,"position":1,"arabic":"أَوَلَمْ","translation":"কি না","audioUrl":"wbw/007_184_001.mp3","charTypeName":"word"},{"id":84040,"position":2,"arabic":"يَتَفَكَّرُوا۟ ۗ","translation":"তারা চিন্তা করে","audioUrl":"wbw/007_184_002.mp3","charTypeName":"word"},{"id":84042,"position":3,"arabic":"مَا","translation":"(যে) নেই","audioUrl":"wbw/007_184_004.mp3","charTypeName":"word"},{"id":84043,"position":4,"arabic":"بِصَاحِبِهِم","translation":"মধ্যে সাথীর তাদের","audioUrl":"wbw/007_184_005.mp3","charTypeName":"word"},{"id":84044,"position":5,"arabic":"مِّن","translation":"কোনো","audioUrl":"wbw/007_184_006.mp3","charTypeName":"word"},{"id":84045,"position":6,"arabic":"جِنَّةٍ ۚ","translation":"উন্মাদ","audioUrl":"wbw/007_184_007.mp3","charTypeName":"word"},{"id":84047,"position":7,"arabic":"إِنْ","translation":"নয়","audioUrl":"wbw/007_184_009.mp3","charTypeName":"word"},{"id":84048,"position":8,"arabic":"هُوَ","translation":"সে","audioUrl":"wbw/007_184_010.mp3","charTypeName":"word"},{"id":84049,"position":9,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/007_184_011.mp3","charTypeName":"word"},{"id":84050,"position":10,"arabic":"نَذِيرٌۭ","translation":"একজন সতর্ককারী","audioUrl":"wbw/007_184_012.mp3","charTypeName":"word"},{"id":84051,"position":11,"arabic":"مُّبِينٌ","translation":"সুস্পষ্ট","audioUrl":"wbw/007_184_013.mp3","charTypeName":"word"},{"id":84052,"position":12,"arabic":"١٨٤","translation":"(১৮৪)","audioUrl":null,"charTypeName":"end"}]},{"number":185,"arabic":"أَوَلَمْ يَنظُرُوا۟ فِى مَلَكُوتِ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ وَمَا خَلَقَ ٱللَّهُ مِن شَىْءٍۢ وَأَنْ عَسَىٰٓ أَن يَكُونَ قَدِ ٱقْتَرَبَ أَجَلُهُمْ ۖ فَبِأَىِّ حَدِيثٍۭ بَعْدَهُۥ يُؤْمِنُونَ","translation":"Have they, then, never considered [God's] mighty dominion over the heavens and the earth, and all the things that God has created, and [asked themselves] whether, perchance, the end of their own term might already have drawn nigh? In what other tiding, then, will they, after this, believe?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1139.mp3","surahId":7,"words":[{"id":84185,"position":1,"arabic":"أَوَلَمْ","translation":"কি না","audioUrl":"wbw/007_185_001.mp3","charTypeName":"word"},{"id":84186,"position":2,"arabic":"يَنظُرُوا۟","translation":"তারা লক্ষ্য করে","audioUrl":"wbw/007_185_002.mp3","charTypeName":"word"},{"id":84187,"position":3,"arabic":"فِى","translation":"ব্যাপারে","audioUrl":"wbw/007_185_003.mp3","charTypeName":"word"},{"id":84188,"position":4,"a