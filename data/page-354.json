{"id":354,"ayahs":[{"number":32,"arabic":"وَأَنكِحُوا۟ ٱلْأَيَٰمَىٰ مِنكُمْ وَٱلصَّٰلِحِينَ مِنْ عِبَادِكُمْ وَإِمَآئِكُمْ ۚ إِن يَكُونُوا۟ فُقَرَآءَ يُغْنِهِمُ ٱللَّهُ مِن فَضْلِهِۦ ۗ وَٱللَّهُ وَٰسِعٌ عَلِيمٌۭ","translation":"AND [you ought to] marry the single from among you as well as such of your male and female slaves as are fit [for marriage]. If they [whom you intend to marry] are poor, [let this not deter you;] God will grant them sufficiency out of His bounty - for God is infinite [in His mercy], all-knowing.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2823.mp3","surahId":24,"words":[{"id":34758,"position":1,"arabic":"وَأَنكِحُوا۟","translation":"এবং তোমরা বিয়ে দাও","audioUrl":"wbw/024_032_001.mp3","charTypeName":"word"},{"id":34759,"position":2,"arabic":"ٱلْأَيَـٰمَىٰ","translation":"বিবাহহীনদেরকে","audioUrl":"wbw/024_032_002.mp3","charTypeName":"word"},{"id":34760,"position":3,"arabic":"مِنكُمْ","translation":"তোমাদের মধ্য থেকে","audioUrl":"wbw/024_032_003.mp3","charTypeName":"word"},{"id":34761,"position":4,"arabic":"وَٱلصَّـٰلِحِينَ","translation":"ও (যারা) সচ্চরিত্রবান","audioUrl":"wbw/024_032_004.mp3","charTypeName":"word"},{"id":34762,"position":5,"arabic":"مِنْ","translation":"মধ্য হ'তে","audioUrl":"wbw/024_032_005.mp3","charTypeName":"word"},{"id":34763,"position":6,"arabic":"عِبَادِكُمْ","translation":"তোমাদের দাসদের","audioUrl":"wbw/024_032_006.mp3","charTypeName":"word"},{"id":34764,"position":7,"arabic":"وَإِمَآئِكُمْ ۚ","translation":"ও তোমাদের দাসীদের","audioUrl":"wbw/024_032_007.mp3","charTypeName":"word"},{"id":34766,"position":8,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/024_032_009.mp3","charTypeName":"word"},{"id":34767,"position":9,"arabic":"يَكُونُوا۟","translation":"তারা হয়","audioUrl":"wbw/024_032_010.mp3","charTypeName":"word"},{"id":34768,"position":10,"arabic":"فُقَرَآءَ","translation":"অভাবগ্রস্ত","audioUrl":"wbw/024_032_011.mp3","charTypeName":"word"},{"id":34769,"position":11,"arabic":"يُغْنِهِمُ","translation":"তাদের অভাবমুক্ত করে দিবেন","audioUrl":"wbw/024_032_012.mp3","charTypeName":"word"},{"id":34770,"position":12,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌","audioUrl":"wbw/024_032_013.mp3","charTypeName":"word"},{"id":34771,"position":13,"arabic":"مِن","translation":"মাধ্যমে","audioUrl":"wbw/024_032_014.mp3","charTypeName":"word"},{"id":34772,"position":14,"arabic":"فَضْلِهِۦ ۗ","translation":"তাঁর অনুগ্রহের","audioUrl":"wbw/024_032_015.mp3","charTypeName":"word"},{"id":34774,"position":15,"arabic":"وَٱللَّهُ","translation":"আর আল্লাহ্‌","audioUrl":"wbw/024_032_017.mp3","charTypeName":"word"},{"id":34775,"position":16,"arabic":"وَٰسِعٌ","translation":"প্রাচুর্যময়","audioUrl":"wbw/024_032_018.mp3","charTypeName":"word"},{"id":34776,"position":17,"arabic":"عَلِيمٌۭ","translation":"মহাবিজ্ঞ","audioUrl":"wbw/024_032_019.mp3","charTypeName":"word"},{"id":34777,"position":18,"arabic":"٣٢","translation":"(৩২)","audioUrl":null,"charTypeName":"end"}]},{"number":33,"arabic":"وَلْيَسْتَعْفِفِ ٱلَّذِينَ لَا يَجِدُونَ نِكَاحًا حَتَّىٰ يُغْنِيَهُمُ ٱللَّهُ مِن فَضْلِهِۦ ۗ وَٱلَّذِينَ يَبْتَغُونَ ٱلْكِتَٰبَ مِمَّا مَلَكَتْ أَيْمَٰنُكُمْ فَكَاتِبُوهُمْ إِنْ عَلِمْتُمْ فِيهِمْ خَيْرًۭا ۖ وَءَاتُوهُم مِّن مَّالِ ٱللَّهِ ٱلَّذِىٓ ءَاتَىٰكُمْ ۚ وَلَا تُكْرِهُوا۟ فَتَيَٰتِكُمْ عَلَى ٱلْبِغَآءِ إِنْ أَرَدْنَ تَحَصُّنًۭا لِّتَبْتَغُوا۟ عَرَضَ ٱلْحَيَوٰةِ ٱلدُّنْيَا ۚ وَمَن يُكْرِههُّنَّ فَإِنَّ ٱللَّهَ مِنۢ بَعْدِ إِكْرَٰهِهِنَّ غَفُورٌۭ رَّحِيمٌۭ","translation":"And as for those who are unable to marry, let them live in continence until God grants them sufficiency out of His bounty, And if any of those whom you rightfully possess desire [to obtain] a deed of freedom, write it out for them if you are aware of any good in them: and give them [their share of the wealth of God which He has given you. And do not, in order to gain some of the fleeting pleasures of this worldly life, coerce your [slave] maidens into whoredom if they happen to be desirous of marriage; and if anyone should coerce them, then, verily, after they have been compelled [to submit in their helplessness], God will be much-forgiving, a dispenser of grace!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2824.mp3","surahId":24,"words":[{"id":35761,"position":1,"arabic":"وَلْيَسْتَعْفِفِ","translation":"এবং যেন সংযত হয়","audioUrl":"wbw/024_033_001.mp3","charTypeName":"word"},{"id":35762,"position":2,"arabic":"ٱلَّذِينَ","translation":"(তাদের) যারা","audioUrl":"wbw/024_033_002.mp3","charTypeName":"word"},{"id":35763,"position":3,"arabic":"لَا","translation":"না","audioUrl":"wbw/024_033_003.mp3","charTypeName":"word"},{"id":35764,"position":4,"arabic":"يَجِدُونَ","translation":"তারা পায় (সামর্থ্য রাখে)","audioUrl":"wbw/024_033_004.mp3","charTypeName":"word"},{"id":35765,"position":5,"arabic":"نِكَاحًا","translation":"বিয়ে করতে","audioUrl":"wbw/024_033_005.mp3","charTypeName":"word"},{"id":35766,"position":6,"arabic":"حَتَّىٰ","translation":"যতক্ষণ না","audioUrl":"wbw/024_033_006.mp3","charTypeName":"word"},{"id":35767,"position":7,"arabic":"يُغْنِيَهُمُ","translation":"তাদেরকে অভাবমুক্ত করে দেন","audioUrl":"wbw/024_033_007.mp3","charTypeName":"word"},{"id":35768,"position":8,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌","audioUrl":"wbw/024_033_008.mp3","charTypeName":"word"},{"id":35769,"position":9,"arabic":"مِن","translation":"মাধ্যমে","audioUrl":"wbw/024_033_009.mp3","charTypeName":"word"},{"id":35770,"position":10,"arabic":"فَضْلِهِۦ ۗ","translation":"তাঁর অনুগ্রহের","audioUrl":"wbw/024_033_010.mp3","charTypeName":"word"},{"id":35772,"position":11,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/024_033_012.mp3","charTypeName":"word"},{"id":35773,"position":12,"arabic":"يَبْتَغُونَ","translation":"তারা চায়","audioUrl":"wbw/024_033_013.mp3","charTypeName":"word"},{"id":35774,"position":13,"arabic":"ٱلْكِتَـٰبَ","translation":"(মুক্তির) লিখিত চুক্তিপত্র করতে","audioUrl":"wbw/024_033_014.mp3","charTypeName":"word"},{"id":35775,"position":14,"arabic":"مِمَّا","translation":"তাদের মধ্য হ'তে যাদের","audioUrl":"wbw/024_033_015.mp3","charTypeName":"word"},{"id":35776,"position":15,"arabic":"مَلَكَتْ","translation":"মালিক করেছে","audioUrl":"wbw/024_033_016.mp3","charTypeName":"word"},{"id":35777,"position":16,"arabic":"أَيْمَـٰنُكُمْ","translation":"তোমাদের ডান হাত (অর্থাৎ দাসদাসী)","audioUrl":"wbw/024_033_017.mp3","charTypeName":"word"},{"id":35778,"position":17,"arabic":"فَكَاتِبُوهُمْ","translation":"তাহ'লে তোমরা লিখে নাও (মুক্তির চুক্তি করো) তাদের সাথে","audioUrl":"wbw/024_033_018.mp3","charTypeName":"word"},{"id":35779,"position":18,"arabic":"إِنْ","translation":"যদি","audioUrl":"wbw/024_033_019.mp3","charTypeName":"word"},{"id":35780,"position":19,"arabic":"عَلِمْتُمْ","translation":"তোমরা জানতে পারো","audioUrl":"wbw/024_033_020.mp3","charTypeName":"word"},{"id":35781,"position":20,"arabic":"فِيهِمْ","translation":"তাদের মধ্যে রয়েছে","audioUrl":"wbw/024_033_021.mp3","charTypeName":"word"},{"id":35782,"position":21,"arabic":"خَيْرًۭا ۖ","translation":"কল্যাণ","audioUrl":"wbw/024_033_022.mp3","charTypeName":"word"},{"id":35784,"position":22,"arabic":"وَءَاتُوهُم","translation":"এবং তাদেরকে দাও","audioUrl":"wbw/024_033_024.mp3","charTypeName":"word"},{"id":35785,"position":23,"arabic":"مِّن","translation":"হ'তে","audioUrl":"wbw/024_033_025.mp3","charTypeName":"word"},{"id":35786,"position":24,"arabic":"مَّالِ","translation":"সম্পদ","audioUrl":"wbw/024_033_026.mp3","charTypeName":"word"},{"id":35787,"position":25,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌র","audioUrl":"wbw/024_033_027.mp3","charTypeName":"word"},{"id":35788,"position":26,"arabic":"ٱلَّذِىٓ","translation":"যা","audioUrl":"wbw/024_033_028.mp3","charTypeName":"word"},{"id":35789,"position":27,"arabic":"ءَاتَىٰكُمْ ۚ","translation":"তিনি দিয়েছেন তোমাদেরকে","audioUrl":"wbw/024_033_029.mp3","charTypeName":"word"},{"id":35791,"position":28,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/024_033_031.mp3","charTypeName":"word"},{"id":35792,"position":29,"arabic":"تُكْرِهُوا۟","translation":"তোমরা বাধ্য করো","audioUrl":"wbw/024_033_032.mp3","charTypeName":"word"},{"id":35793,"position":30,"arabic":"فَتَيَـٰتِكُمْ","translation":"তোমাদের দাসদাসীদেরকে","audioUrl":"wbw/024_033_033.mp3","charTypeName":"word"},{"id":35794,"position":31,"arabic":"عَلَى","translation":"জন্য","audioUrl":"wbw/024_033_034.mp3","charTypeName":"word"},{"id":35795,"position":32,"arabic":"ٱلْبِغَآءِ","translation":"বেশ্যা বৃত্তির","audioUrl":"wbw/024_033_035.mp3","charTypeName":"word"},{"id":35796,"position":33,"arabic":"إِنْ","translation":"যখন","audioUrl":"wbw/024_033_036.mp3","charTypeName":"word"},{"id":35797,"position":34,"arabic":"أَرَدْنَ","translation":"তারা চায়","audioUrl":"wbw/024_033_037.mp3","charTypeName":"word"},{"id":35798,"position":35,"arabic":"تَحَصُّنًۭا","translation":"সতীত্ব রক্ষা করতে","audioUrl":"wbw/024_033_038.mp3","charTypeName":"word"},{"id":35799,"position":36,"arabic":"لِّتَبْتَغُوا۟","translation":"যেন তোমরা আশা করো","audioUrl":"wbw/024_033_039.mp3","charTypeName":"word"},{"id":35800,"position":37,"arabic":"عَرَضَ","translation":"স্বার্থ","audioUrl":"wbw/024_033_040.mp3","charTypeName":"word"},{"id":35801,"position":38,"arabic":"ٱلْحَيَوٰةِ","translation":"জীবনের","audioUrl":"wbw/024_033_041.mp3","charTypeName":"word"},{"id":35802,"position":39,"arabic":"ٱلدُّنْيَا ۚ","translation":"পার্থিব","audioUrl":"wbw/024_033_042.mp3","charTypeName":"word"},{"id":35804,"position":40,"arabic":"وَمَن","translation":"আর যে","audioUrl":"wbw/024_033_044.mp3","charTypeName":"word"},{"id":35805,"position":41,"arabic":"يُكْرِههُّنَّ","translation":"তাদেরকে বাধ্য করবে","audioUrl":"wbw/024_033_045.mp3","charTypeName":"word"},{"id":35806,"position":42,"arabic":"فَإِنَّ","translation":"তাহ'লে নিশ্চয়ই","audioUrl":"wbw/024_033_046.mp3","charTypeName":"word"},{"id":35807,"position":43,"arabic":"ٱللَّهَ","translation":"আল্লাহ্‌","audioUrl":"wbw/024_033_047.mp3","charTypeName":"word"},{"id":35808,"position":44,"arabic":"مِنۢ","translation":"থেকে","audioUrl":"wbw/024_033_048.mp3","charTypeName":"word"},{"id":35809,"position":45,"arabic":"بَعْدِ","translation":"পর","audioUrl":"wbw/024_033_049.mp3","charTypeName":"word"},{"id":35810,"position":46,"arabic":"إِكْرَٰهِهِنَّ","translation":"তাদেরকে জবরদস্তির","audioUrl":"wbw/024_033_050.mp3","charTypeName":"word"},{"id":35811,"position":47,"arabic":"غَفُورٌۭ","translation":"(তাদের উপর) ক্ষমাশীল","audioUrl":"wbw/024_033_051.mp3","charTypeName":"word"},{"id":35812,"position":48,"arabic":"رَّحِيمٌۭ","translation":"পরম দয়ালু","audioUrl":"wbw/024_033_052.mp3","charTypeName":"word"},{"id":35813,"position":49,"arabic":"٣٣","translation":"(৩৩)","audioUrl":null,"charTypeName":"end"}]},{"number":34,"arabic":"وَلَقَدْ أَنزَلْنَآ إِلَيْكُمْ ءَايَٰتٍۢ مُّبَيِّنَٰتٍۢ وَمَثَلًۭا مِّنَ ٱلَّذِينَ خَلَوْا۟ مِن قَبْلِكُمْ وَمَوْعِظَةًۭ لِّلْمُتَّقِينَ","translation":"AND, INDEED, from on high have We bestowed upon you messages clearly showing the truth, and [many] a lesson from [the stories of] those who have passed away before you, and [many] an admonition to the God-conscious.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2825.mp3","surahId":24,"words":[{"id":36711,"position":1,"arabic":"وَلَقَدْ","translation":"আর নিশ্চয়ই","audioUrl":"wbw/024_034_001.mp3","charTypeName":"word"},{"id":36712,"position":2,"arabic":"أَنزَلْنَآ","translation":"আমরা অবতীর্ণ করেছি","audioUrl":"wbw/024_034_002.mp3","charTypeName":"word"},{"id":36713,"position":3,"arabic":"إِلَيْكُمْ","translation":"নিকট তোমাদের","audioUrl":"wbw/024_034_003.mp3","charTypeName":"word"},{"id":36714,"position":4,"arabic":"ءَايَـٰتٍۢ","translation":"আয়াতসমূহ","audioUrl":"wbw/024_034_004.mp3","charTypeName":"word"},{"id":36715,"position":5,"arabic":"مُّبَيِّنَـٰتٍۢ","translation":"সুস্পষ্ট","audioUrl":"wbw/024_034_005.mp3","charTypeName":"word"},{"id":36716,"position":6,"arabic":"وَمَثَلًۭا","translation":"ও দৃষ্টান্ত","audioUrl":"wbw/024_034_006.mp3","charTypeName":"word"},{"id":36717,"position":7,"arabic":"مِّنَ","translation":"হ'তে","audioUrl":"wbw/024_034_007.mp3","charTypeName":"word"},{"id":36718,"position":8,"arabic":"ٱلَّذِينَ","translation":"(তাদের) যারা","audioUrl":"wbw/024_034_008.mp3","charTypeName":"word"},{"id":36719,"position":9,"arabic":"خَلَوْا۟","translation":"অতীত হয়েছে","audioUrl":"wbw/024_034_009.mp3","charTypeName":"word"},{"id":36720,"position":10,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/024_034_010.mp3","charTypeName":"word"},{"id":36721,"position":11,"arabic":"قَبْلِكُمْ","translation":"তোমাদের পূর্ব","audioUrl":"wbw/024_034_011.mp3","charTypeName":"word"},{"id":36722,"position":12,"arabic":"وَمَوْعِظَةًۭ","translation":"ও উপদেশ","audioUrl":"wbw/024_034_012.mp3","charTypeName":"word"},{"id":36723,"position":13,"arabic":"لِّلْمُتَّقِينَ","translation":"মুত্তাকীদের জন্যে","audioUrl":"wbw/024_034_013.mp3","charTypeName":"word"},{"id":36724,"position":14,"arabic":"٣٤","translation":"(৩৪)","audioUrl":null,"charTypeName":"end"}]},{"number":35,"arabic":"۞ ٱللَّهُ نُورُ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ ۚ مَثَلُ نُورِهِۦ كَمِشْكَوٰةٍۢ فِيهَا مِصْبَاحٌ ۖ ٱلْمِصْبَاحُ فِى زُجَاجَةٍ ۖ ٱلزُّجَاجَةُ كَأَنَّهَا كَوْكَبٌۭ دُرِّىٌّۭ يُوقَدُ مِن شَجَرَةٍۢ مُّبَٰرَكَةٍۢ زَيْتُونَةٍۢ لَّا شَرْقِيَّةٍۢ وَلَا غَرْبِيَّةٍۢ يَكَادُ زَيْتُهَا يُضِىٓءُ وَلَوْ لَمْ تَمْسَسْهُ نَارٌۭ ۚ نُّورٌ عَلَىٰ نُورٍۢ ۗ يَهْدِى ٱللَّهُ لِنُورِهِۦ مَن يَشَآءُ ۚ وَيَضْرِبُ ٱللَّهُ ٱلْأَمْثَٰلَ لِلنَّاسِ ۗ وَٱللَّهُ بِكُلِّ شَىْءٍ عَلِيمٌۭ","translation":"God is the Light of the heavens and the earth. The parable of His light is, as it were, that of a niche containing a lamp; the lamp is [enclosed] in glass, the glass [shining] like a radiant star: [a lamp] lit from a blessed tree - an olive-tree that is neither of the east nor of the west the oil whereof [is so bright that it] would well-nigh give light [of itself] even though fire had not touched it: light upon light! God guides unto His light him that wills [to be guided]; and [to this end] God propounds parables unto men, since God [alone] has full knowledge of all things.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2826.mp3","surahId":24,"words":[{"id":37215,"position":1,"arabic":"۞ ٱللَّهُ","translation":"আল্লাহ্‌","audioUrl":"wbw/024_035_002.mp3","charTypeName":"word"},{"id":37216,"position":2,"arabic":"نُورُ","translation":"আলো","audioUrl":"wbw/024_035_003.mp3","charTypeName":"word"},{"id":37217,"position":3,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশমণ্ডলির","audioUrl":"wbw/024_035_004.mp3","charTypeName":"word"},{"id":37218,"position":4,"arabic":"وَٱلْأَرْضِ ۚ","translation":"ও পৃথিবীর","audioUrl":"wbw/024_035_005.mp3","charTypeName":"word"},{"id":37220,"position":5,"arabic":"مَثَلُ","translation":"দৃষ্টান্ত","audioUrl":"wbw/024_035_007.mp3","charTypeName":"word"},{"id":37221,"position":6,"arabic":"نُورِهِۦ","translation":"তাঁর আলোর","audioUrl":"wbw/024_035_008.mp3","charTypeName":"word"},{"id":37222,"position":7,"arabic":"كَمِشْكَوٰةٍۢ","translation":"মতো দীপাধারের","audioUrl":"wbw/024_035_009.mp3","charTypeName":"word"},{"id":37223,"position":8,"arabic":"فِيهَا","translation":"তার মধ্যে (আছে)","audioUrl":"wbw/024_035_010.mp3","charTypeName":"word"},{"id":37224,"position":9,"arabic":"مِصْبَاحٌ ۖ","translation":"একটি প্রদীপ","audioUrl":"wbw/024_035_011.mp3","charTypeName":"word"},{"id":37226,"position":10,"arabic":"ٱلْمِصْبَاحُ","translation":"প্রদীপটি","audioUrl":"wbw/024_035_013.mp3","charTypeName":"word"},{"id":37227,"position":11,"arabic":"فِى","translation":"(অবস্থিত) মধ্যে","audioUrl":"wbw/024_035_014.mp3","charTypeName":"word"},{"id":37228,"position":12,"arabic":"زُجَاجَةٍ ۖ","translation":"একটি কাঁচপাত্রের","audioUrl":"wbw/024_035_015.mp3","charTypeName":"word"},{"id":37230,"position":13,"arabic":"ٱلزُّجَاجَةُ","translation":"(এমন) কাঁচপাত্র","audioUrl":"wbw/024_035_017.mp3","charTypeName":"word"},{"id":37231,"position":14,"arabic":"كَأَنَّهَا","translation":"যেন তা","audioUrl":"wbw/024_035_018.mp3","charTypeName":"word"},{"id":3723