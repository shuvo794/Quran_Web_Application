009.mp3","charTypeName":"word"},{"id":38243,"position":10,"arabic":"يُسَبِّحُ","translation":"পবিত্র মহিমা ঘোষনা করে (তারা)","audioUrl":"wbw/024_036_010.mp3","charTypeName":"word"},{"id":38244,"position":11,"arabic":"لَهُۥ","translation":"জন্যে তাঁরই","audioUrl":"wbw/024_036_011.mp3","charTypeName":"word"},{"id":38245,"position":12,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/024_036_012.mp3","charTypeName":"word"},{"id":38246,"position":13,"arabic":"بِٱلْغُدُوِّ","translation":"বেলায় সকাল","audioUrl":"wbw/024_036_013.mp3","charTypeName":"word"},{"id":38247,"position":14,"arabic":"وَٱلْـَٔاصَالِ","translation":"ও সন্ধ্যাসমূহে","audioUrl":"wbw/024_036_014.mp3","charTypeName":"word"},{"id":38248,"position":15,"arabic":"٣٦","translation":"(৩৬)","audioUrl":null,"charTypeName":"end"}]}]}