5.mp3","charTypeName":"word"},{"id":41032,"position":6,"arabic":"يُحْـِۧىَ","translation":"জীবিত করবেন","audioUrl":"wbw/075_040_006.mp3","charTypeName":"word"},{"id":41033,"position":7,"arabic":"ٱلْمَوْتَىٰ","translation":"মৃত্যুকে","audioUrl":"wbw/075_040_007.mp3","charTypeName":"word"},{"id":41034,"position":8,"arabic":"٤٠","translation":"(৪০)","audioUrl":null,"charTypeName":"end"}]}]}