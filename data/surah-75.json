udioUrl":"wbw/075_029_003.mp3","charTypeName":"word"},{"id":31742,"position":4,"arabic":"٢٩","translation":"(২৯)","audioUrl":null,"charTypeName":"end"}]},{"number":30,"arabic":"إِلَىٰ رَبِّكَ يَوْمَئِذٍ ٱلْمَسَاقُ","translation":"at that time towards thy Sustainer does he feel impelled to turn!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5581.mp3","surahId":75,"words":[{"id":32866,"position":1,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/075_030_001.mp3","charTypeName":"word"},{"id":32867,"position":2,"arabic":"رَبِّكَ","translation":"তোমার রবের","audioUrl":"wbw/075_030_002.mp3","charTypeName":"word"},{"id":32868,"position":3,"arabic":"يَوْمَئِذٍ","translation":"সে দিন","audioUrl":"wbw/075_030_003.mp3","charTypeName":"word"},{"id":32869,"position":4,"arabic":"ٱلْمَسَاقُ","translation":"যাত্রা","audioUrl":"wbw/075_030_004.mp3","charTypeName":"word"},{"id":32870,"position":5,"arabic":"٣٠","translation":"(৩০)","audioUrl":null,"charTypeName":"end"}]},{"number":31,"arabic":"فَلَا صَدَّقَ وَلَا صَلَّىٰ","translation":"[Useless, though, will be his repentance: for [as long as he was alive] he did not accept the truth, nor did he pray [for enlightenment],","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5582.mp3","surahId":75,"words":[{"id":33725,"position":1,"arabic":"فَلَا","translation":"না অতঃপর","audioUrl":"wbw/075_031_001.mp3","charTypeName":"word"},{"id":33726,"position":2,"arabic":"صَدَّقَ","translation":"সত্য মানল","audioUrl":"wbw/075_031_002.mp3","charTypeName":"word"},{"id":33727,"position":3,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/075_031_003.mp3","charTypeName":"word"},{"id":33728,"position":4,"arabic":"صَلَّىٰ","translation":"নামায পড়ল","audioUrl":"wbw/075_031_004.mp3","charTypeName":"word"},{"id":33729,"position":5,"arabic":"٣١","translation":"(৩১)","audioUrl":null,"charTypeName":"end"}]},{"number":32,"arabic":"وَلَٰكِن كَذَّبَ وَتَوَلَّىٰ","translation":"but, on the contrary, he gave the lie to t