ioUrl":"wbw/075_034_002.mp3","charTypeName":"word"},{"id":36507,"position":3,"arabic":"فَأَوْلَىٰ","translation":"অতঃপর দুর্ভোগ","audioUrl":"wbw/075_034_003.mp3","charTypeName":"word"},{"id":36508,"position":4,"arabic":"٣٤","translation":"(৩৪)","audioUrl":null,"charTypeName":"end"}]},{"number":35,"arabic":"ثُمَّ أَوْلَىٰ لَكَ فَأَوْلَىٰٓ","translation":"and ever nearer unto thee, and nearer!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5586.mp3","surahId":75,"words":[{"id":37354,"position":1,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/075_035_001.mp3","charTypeName":"word"},{"id":37355,"position":2,"arabic":"أَوْلَىٰ","translation":"দুুর্ভোগ","audioUrl":"wbw/075_035_002.mp3","charTypeName":"word"},{"id":37356,"position":3,"arabic":"لَكَ","translation":"তোমার জন্য","audioUrl":"wbw/075_035_003.mp3","charTypeName":"word"},{"id":37357,"position":4,"arabic":"فَأَوْلَىٰٓ","translation":"দুর্ভোগ অতঃপর","audioUrl":"wbw/075_035_004.mp3","charTypeName":"word"},{"id":37358,"position":5,"arabic":"٣٥","translation":"(৩৫)","audioUrl":null,"charTypeName":"end"}]},{"number":36,"arabic":"أَيَحْسَبُ ٱلْإِنسَٰنُ أَن يُتْرَكَ سُدًى","translation":"DOES MAN, then, think that he is to be left to himself to go about at will?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5587.mp3","surahId":75,"words":[{"id":37868,"position":1,"arabic":"أَيَحْسَبُ","translation":"মনে করেছ কি","audioUrl":"wbw/075_036_001.mp3","charTypeName":"word"},{"id":37869,"position":2,"arabic":"ٱلْإِنسَـٰنُ","translation":"মানুষ","audioUrl":"wbw/075_036_002.mp3","charTypeName":"word"},{"id":37870,"position":3,"arabic":"أَن","translation":"যে","audioUrl":"wbw/075_036_003.mp3","charTypeName":"word"},{"id":37871,"position":4,"arabic":"يُتْرَكَ","translation":"ছেড়ে দেয়া হবে","audioUrl":"wbw/075_036_004.mp3","charTypeName":"word"},{"id":37872,"position":5,"arabic":"سُدًى","translation":"লাগামহিন","audioUrl":"wbw/075_036_005.mp3","charTypeName":"word"},{"id":37873,"position":6,"arabic":"٣٦","translation":"(৩৬)","audioUrl":null,"charTypeName":"end"}]},{"number":37,"arabic":"أَلَمْ يَكُ نُطْفَةًۭ مِّن مَّنِىٍّۢ يُمْنَىٰ","translation":"Was he not once a [mere] drop of sperm that had been spilt,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5588.mp3","surahId":75,"words":[{"id":39018,"position":1,"arabic":"أَلَمْ","translation":"না কি","audioUrl":"wbw/075_037_001.mp3","charTypeName":"word"},{"id":39019,"position":2,"arabic":"يَكُ","translation":"সে ছিল","audioUrl":"wbw/075_037_002.mp3","charTypeName":"word"},{"id":39020,"position":3,"arabic":"نُطْفَةًۭ","translation":"এক ফটা","audioUrl":"wbw/075_037_003.mp3","charTypeName":"word"},{"id":39021,"position":4,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/075_037_004.mp3","charTypeName":"word"},{"id":39022,"position":5,"arabic":"مَّنِىٍّۢ","translation":"শুক্র","audioUrl":"wbw/075_037_005.mp3","charTypeName":"word"},{"id":39023,"position":6,"arabic":"يُمْنَىٰ","translation":"নির্গত","audioUrl":"wbw/075_037_006.mp3","charTypeName":"word"},{"id":39024,"position":7,"arabic":"٣٧","translation":"(৩৭)","audioUrl":null,"charTypeName":"end"}]},{"number":38,"arabic":"ثُمَّ كَانَ عَلَقَةًۭ فَخَلَقَ فَسَوَّىٰ","translation":"and thereafter became a germ-cell - whereupon He created and formed [it] in accordance with what [it] was meant to be,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5589.mp3","surahId":75,"words":[{"id":39857,"position":1,"arabic":"ثُمَّ","translation":"পরে","audioUrl":"wbw/075_038_001.mp3","charTypeName":"word"},{"id":39858,"position":2,"arabic":"كَانَ","translation":"হয়","audioUrl":"wbw/075_038_002.mp3","charTypeName":"word"},{"id":39859,"position":3,"arabic":"عَلَقَةًۭ","translation":"জমাট রক্ত","audioUrl":"wbw/075_038_003.mp3","charTypeName":"word"},{"id":39860,"position":4,"arabic":"فَخَلَقَ","translation":"তিনি আকৃতি অতঃপর দিলেন","audioUrl":"wbw/075_038_004.mp3","charTypeName":"word"},{"id":39861,"position":5,"arabic":"فَسَوَّىٰ","tran