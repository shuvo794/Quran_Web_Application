{"id":75,"nameArabic":"سُورَةُ القِيَامَةِ","nameEnglish":"Al-Qiyaama","nameTranslation":"The Resurrection","revelationType":"Meccan","numberOfAyahs":40,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ لَآ أُقْسِمُ بِيَوْمِ ٱلْقِيَٰمَةِ","translation":"NAY! I call to witness the Day of Resurrection!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5552.mp3","surahId":75,"words":[{"id":634,"position":1,"arabic":"لَآ","translation":"না","audioUrl":"wbw/075_001_001.mp3","charTypeName":"word"},{"id":635,"position":2,"arabic":"أُقْسِمُ","translation":"কসম খাচ্ছি","audioUrl":"wbw/075_001_002.mp3","charTypeName":"word"},{"id":636,"position":3,"arabic":"بِيَوْمِ","translation":"দিনের","audioUrl":"wbw/075_001_003.mp3","charTypeName":"word"},{"id":637,"position":4,"arabic":"ٱلْقِيَـٰمَةِ","translation":"কিয়ামাতের","audioUrl":"wbw/075_001_004.mp3","charTypeName":"word"},{"id":638,"position":5,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"وَلَآ أُقْسِمُ بِٱلنَّفْسِ ٱللَّوَّامَةِ","translation":"But nay! I call to witness the accusing voice of man's own conscience!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5553.mp3","surahId":75,"words":[{"id":1616,"position":1,"arabic":"وَلَآ","translation":"এবং না","audioUrl":"wbw/075_002_001.mp3","charTypeName":"word"},{"id":1617,"position":2,"arabic":"أُقْسِمُ","translation":"শপথ করছি আমি","audioUrl":"wbw/075_002_002.mp3","charTypeName":"word"},{"id":1618,"position":3,"arabic":"بِٱلنَّفْسِ","translation":"মনের","audioUrl":"wbw/075_002_003.mp3","charTypeName":"word"},{"id":1619,"position":4,"arabic":"ٱللَّوَّامَةِ","translation":"তিরস্কারকারী","audioUrl":"wbw/075_002_004.mp3","charTypeName":"word"},{"id":1620,"position":5,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"أَيَحْسَبُ ٱلْإِنسَٰنُ أَلَّن نَّجْمَعَ عِظَامَهُۥ","translation":"Does man think that We cannot [resurrect him and] bring his bones together again?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5554.mp3","surahId":75,"words":[{"id":2639,"position":1,"arabic":"أَيَحْسَبُ","translation":"মনে করেছে কি","audioUrl":"wbw/075_003_001.mp3","charTypeName":"word"},{"id":2640,"position":2,"arabic":"ٱلْإِنسَـٰنُ","translation":"মানুষ","audioUrl":"wbw/075_003_002.mp3","charTypeName":"word"},{"id":2641,"position":3,"arabic":"أَلَّن","translation":"কখন না","audioUrl":"wbw/075_003_003.mp3","charTypeName":"word"},{"id":2642,"position":4,"arabic":"نَّجْمَعَ","translation":"একত্রিত আমরা করব","audioUrl":"wbw/075_003_004.mp3","charTypeName":"word"},{"id":2643,"position":5,"arabic":"عِظَامَهُۥ","translation":"তার অস্তিগুলকে","audioUrl":"wbw/075_003_005.mp3","charTypeName":"word"},{"id":2644,"position":6,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"بَلَىٰ قَٰدِرِينَ عَلَىٰٓ أَن نُّسَوِّىَ بَنَانَهُۥ","translation":"Yea indeed, We are able to make whole his very finger-tips!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5555.mp3","surahId":75,"words":[{"id":4048,"position":1,"arabic":"بَلَىٰ","translation":"কােনো না","audioUrl":"wbw/075_004_001.mp3","charTypeName":"word"},{"id":4049,"position":2,"arabic":"قَـٰدِرِينَ","translation":"সক্ষম","audioUrl":"wbw/075_004_002.mp3","charTypeName":"word"},{"id":4050,"position":3,"arabic":"عَلَىٰٓ","translation":"এতে","audioUrl":"wbw/075_004_003.mp3","charTypeName":"word"},{"id":4051,"position":4,"arabic":"أَن","translation":"যে","audioUrl":"wbw/075_004_004.mp3","charTypeName":"word"},{"id":4052,"position":5,"arabic":"نُّسَوِّىَ","translation":"পূর্ণবিন্যস্ত আমরা করবো","audioUrl":"wbw/075_004_005.mp3","charTypeName":"word"},{"id":4053,"position":6,"arabic":"بَنَانَهُۥ","translation":"তার আঙ্গুলির অগ্রভাগ","audioUrl":"wbw/075_004_006.mp3","charTypeName":"word"},{"id":4054,"position":7,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"بَ