ে","audioUrl":"wbw/075_010_001.mp3","charTypeName":"word"},{"id":11557,"position":2,"arabic":"ٱلْإِنسَـٰنُ","translation":"মানুষ","audioUrl":"wbw/075_010_002.mp3","charTypeName":"word"},{"id":11558,"position":3,"arabic":"يَوْمَئِذٍ","translation":"সেই দিন","audioUrl":"wbw/075_010_003.mp3","charTypeName":"word"},{"id":11559,"position":4,"arabic":"أَيْنَ","translation":"\"কোথায়","audioUrl":"wbw/075_010_004.mp3","charTypeName":"word"},{"id":11560,"position":5,"arabic":"ٱلْمَفَرُّ","translation":"পালাবার জায়গা\"","audioUrl":"wbw/075_010_005.mp3","charTypeName":"word"},{"id":11561,"position":6,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"كَلَّا لَا وَزَرَ","translation":"But nay: no refuge [for thee, O man]!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5562.mp3","surahId":75,"words":[{"id":12877,"position":1,"arabic":"كَلَّا","translation":"কক্ষন না","audioUrl":"wbw/075_011_001.mp3","charTypeName":"word"},{"id":12878,"position":2,"arabic":"لَا","translation":"নাই","audioUrl":"wbw/075_011_002.mp3","charTypeName":"word"},{"id":12879,"position":3,"arabic":"وَزَرَ","translation":"আশ্রয় স্থল","audioUrl":"wbw/075_011_003.mp3","charTypeName":"word"},{"id":12880,"position":4,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]},{"number":12,"arabic":"إِلَىٰ رَبِّكَ يَوْمَئِذٍ ٱلْمُسْتَقَرُّ","translation":"With thy Sustainer, on that Day, the journey's end will be!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5563.mp3","surahId":75,"words":[{"id":14131,"position":1,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/075_012_001.mp3","charTypeName":"word"},{"id":14132,"position":2,"arabic":"رَبِّكَ","translation":"তোমার রবের","audioUrl":"wbw/075_012_002.mp3","charTypeName":"word"},{"id":14133,"position":3,"arabic":"يَوْمَئِذٍ","translation":"সেদিন","audioUrl":"wbw/075_012_003.mp3","charTypeName":"word"},{"id":14134,"position":4,"arabic":"ٱلْمُسْتَقَرُّ","translatio