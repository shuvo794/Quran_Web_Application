156_029.mp3","charTypeName":"word"},{"id":81263,"position":26,"arabic":"ٱلزَّكَوٰةَ","translation":"যাকাত","audioUrl":"wbw/007_156_030.mp3","charTypeName":"word"},{"id":81264,"position":27,"arabic":"وَٱلَّذِينَ","translation":"এবং তাদেরকে","audioUrl":"wbw/007_156_031.mp3","charTypeName":"word"},{"id":81265,"position":28,"arabic":"هُم","translation":"যারা","audioUrl":"wbw/007_156_032.mp3","charTypeName":"word"},{"id":81266,"position":29,"arabic":"بِـَٔايَـٰتِنَا","translation":"উপর আমার নিদর্শনগুলোর","audioUrl":"wbw/007_156_033.mp3","charTypeName":"word"},{"id":81267,"position":30,"arabic":"يُؤْمِنُونَ","translation":"বিশ্বাস করে","audioUrl":"wbw/007_156_034.mp3","charTypeName":"word"},{"id":81268,"position":31,"arabic":"١٥٦","translation":"(১৫৬)","audioUrl":null,"charTypeName":"end"}]},{"number":157,"arabic":"ٱلَّذِينَ يَتَّبِعُونَ ٱلرَّسُولَ ٱلنَّبِىَّ ٱلْأُمِّىَّ ٱلَّذِى يَجِدُونَهُۥ مَكْتُوبًا عِندَهُمْ فِى ٱلتَّوْرَىٰةِ وَٱلْإِنجِيلِ يَأْمُرُهُم بِٱلْمَعْرُوفِ وَيَنْهَىٰهُمْ عَنِ ٱلْمُنكَرِ وَيُحِلُّ لَهُمُ ٱلطَّيِّبَٰتِ وَيُحَرِّمُ عَلَيْهِمُ ٱلْخَبَٰٓئِثَ وَيَضَعُ عَنْهُمْ إِصْرَهُمْ وَٱلْأَغْلَٰلَ ٱلَّتِى كَانَتْ عَلَيْهِمْ ۚ فَٱلَّذِينَ ءَامَنُوا۟ بِهِۦ وَعَزَّرُوهُ وَنَصَرُوهُ وَٱتَّبَعُوا۟ ٱلنُّورَ ٱلَّذِىٓ أُنزِلَ مَعَهُۥٓ ۙ أُو۟لَٰٓئِكَ هُمُ ٱلْمُفْلِحُونَ","translation":"those who shall follow the [last] Apostle, the unlettered Prophet whom they shall find described in the Torah that is with them, and [later on] in the Gospel: [the Prophet] who will enjoin upon them the doing of what is right and forbid them the doing of what is wrong, and make lawful to them the good things of life and forbid them the bad things, and lift from them their burdens and the shackles that were upon them [aforetime]. Those, therefore, who shall believe in him, and honour him, and succour him, and follow the light that has been bestowed from on high through him-it is they that shall attain to a happy state.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1111.mp3","surahId":7,"words":[{"id":81392,"position":1,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/007_157_001.mp3","charTypeName":"word"},{"id":81393,"position":2,"arabic":"يَتَّبِعُونَ","translation":"অনুসরণ করে","audioUrl":"wbw/007_157_002.mp3","charTypeName":"word"},{"id":81394,"position":3,"arabic":"ٱلرَّسُولَ","translation":"রাসূলকে","audioUrl":"wbw/007_157_003.mp3","charTypeName":"word"},{"id":81395,"position":4,"arabic":"ٱلنَّبِىَّ","translation":"নাবীকে","audioUrl":"wbw/007_157_004.mp3","charTypeName":"word"},{"id":81396,"position":5,"arabic":"ٱلْأُمِّىَّ","translation":"নিরক্ষর","audioUrl":"wbw/007_157_005.mp3","charTypeName":"word"},{"id":81397,"position":6,"arabic":"ٱلَّذِى","translation":"যার","audioUrl":"wbw/007_157_006.mp3","charTypeName":"word"},{"id":81398,"position":7,"arabic":"يَجِدُونَهُۥ","translation":"তারা (উল্লেখ) পায় তার","audioUrl":"wbw/007_157_007.mp3","charTypeName":"word"},{"id":81399,"position":8,"arabic":"مَكْتُوبًا","translation":"লিখিত অবস্থায়","audioUrl":"wbw/007_157_008.mp3","charTypeName":"word"},{"id":81400,"position":9,"arabic":"عِندَهُمْ","translation":"কাছে তাদের","audioUrl":"wbw/007_157_009.mp3","charTypeName":"word"},{"id":81401,"position":10,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/007_157_010.mp3","charTypeName":"word"},{"id":81402,"position":11,"arabic":"ٱلتَّوْرَىٰةِ","translation":"তাওরাতের","audioUrl":"wbw/007_157_011.mp3","charTypeName":"word"},{"id":81403,"position":12,"arabic":"وَٱلْإِنجِيلِ","translation":"ও ইনজীলে","audioUrl":"wbw/007_157_012.mp3","charTypeName":"word"},{"id":81404,"position":13,"arabic":"يَأْمُرُهُم","translation":"সে নির্দেশ দেয় তাদের","audioUrl":"wbw/007_157_013.mp3","charTypeName":"word"},{"id":81405,"position":14,"arabic":"بِٱلْمَعْرُوفِ","translation":"সৎ কাজের","audioUrl":"wbw/007_157_014.mp3","charTypeName":"word"},{"id":81406,"position":15,"arabic":"وَيَنْهَىٰهُمْ","translation":"ও নিষেধ করে তাদের","audioUrl":"wbw/007_157_015.mp3","charTypeName":"word"},{"id":8