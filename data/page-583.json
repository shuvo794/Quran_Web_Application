{"id":583,"ayahs":[{"number":31,"arabic":"إِنَّ لِلْمُتَّقِينَ مَفَازًا","translation":"[But,] verily for the God-conscious there is supreme fulfilment in store:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5703.mp3","surahId":78,"words":[{"id":33849,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/078_031_001.mp3","charTypeName":"word"},{"id":33850,"position":2,"arabic":"لِلْمُتَّقِينَ","translation":"মুত্তাকীদের জন্যে","audioUrl":"wbw/078_031_002.mp3","charTypeName":"word"},{"id":33851,"position":3,"arabic":"مَفَازًا","translation":"সাফল্য (রয়েছে)","audioUrl":"wbw/078_031_003.mp3","charTypeName":"word"},{"id":33852,"position":4,"arabic":"٣١","translation":"(৩১)","audioUrl":null,"charTypeName":"end"}]},{"number":32,"arabic":"حَدَآئِقَ وَأَعْنَٰبًۭا","translation":"luxuriant gardens and vinyards,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5704.mp3","surahId":78,"words":[{"id":34755,"position":1,"arabic":"حَدَآئِقَ","translation":"বাগিচাসমূহ","audioUrl":"wbw/078_032_001.mp3","charTypeName":"word"},{"id":34756,"position":2,"arabic":"وَأَعْنَـٰبًۭا","translation":"ও আঙুরসমূহ","audioUrl":"wbw/078_032_002.mp3","charTypeName":"word"},{"id":34757,"position":3,"arabic":"٣٢","translation":"(৩২)","audioUrl":null,"charTypeName":"end"}]},{"number":33,"arabic":"وَكَوَاعِبَ أَتْرَابًۭا","translation":"and splendid companions well matched,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5705.mp3","surahId":78,"words":[{"id":36038,"position":1,"arabic":"وَكَوَاعِبَ","translation":"এবং নব্য যুবতীরা","audioUrl":"wbw/078_033_001.mp3","charTypeName":"word"},{"id":36039,"position":2,"arabic":"أَتْرَابًۭا","translation":"সমবয়স্কা","audioUrl":"wbw/078_033_002.mp3","charTypeName":"word"},{"id":36040,"position":3,"arabic":"٣٣","translation":"(৩৩)","audioUrl":null,"charTypeName":"end"}]},{"number":34,"arabic":"وَكَأْسًۭا دِهَاقًۭا","translation":"and a cup [of happiness] overflowing.","audio":"https://cdn.is