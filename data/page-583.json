oUrl":"wbw/078_036_002.mp3","charTypeName":"word"},{"id":38537,"position":3,"arabic":"رَّبِّكَ","translation":"তোমার রবের","audioUrl":"wbw/078_036_003.mp3","charTypeName":"word"},{"id":38538,"position":4,"arabic":"عَطَآءً","translation":"(এ ছাড়াও) দান","audioUrl":"wbw/078_036_004.mp3","charTypeName":"word"},{"id":38539,"position":5,"arabic":"حِسَابًۭا","translation":"যথোচিত","audioUrl":"wbw/078_036_005.mp3","charTypeName":"word"},{"id":38540,"position":6,"arabic":"٣٦","translation":"(৩৬)","audioUrl":null,"charTypeName":"end"}]},{"number":37,"arabic":"رَّبِّ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ وَمَا بَيْنَهُمَا ٱلرَّحْمَٰنِ ۖ لَا يَمْلِكُونَ مِنْهُ خِطَابًۭا","translation":"[a reward from] the Sustainer of the heavens and the earth and all that is between them, the Most Gracious! [And] none shall have it in their power to raise their voices unto Him","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5709.mp3","surahId":78,"words":[{"id":39402,"position":1,"arabic":"رَّبِّ","translation":"(পক্ষ হতে) রবের","audioUrl":"wbw/078_037_001.mp3","charTypeName":"word"},{"id":39403,"position":2,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশসমূহের","audioUrl":"wbw/078_037_002.mp3","charTypeName":"word"},{"id":39404,"position":3,"arabic":"وَٱلْأَرْضِ","translation":"এবং পৃথিবীর","audioUrl":"wbw/078_037_003.mp3","charTypeName":"word"},{"id":39405,"position":4,"arabic":"وَمَا","translation":"এবং যা কিছু","audioUrl":"wbw/078_037_004.mp3","charTypeName":"word"},{"id":39406,"position":5,"arabic":"بَيْنَهُمَا","translation":"তাদের দু'য়ের মাঝে আছে","audioUrl":"wbw/078_037_005.mp3","charTypeName":"word"},{"id":39407,"position":6,"arabic":"ٱلرَّحْمَـٰنِ ۖ","translation":"অশেষ দয়াবানের (পক্ষ হতে)","audioUrl":"wbw/078_037_006.mp3","charTypeName":"word"},{"id":39409,"position":7,"arabic":"لَا","translation":"না","audioUrl":"wbw/078_037_008.mp3","charTypeName":"word"},{"id":39410,"position":8,"arabic":"يَمْلِكُونَ","translation":"তারা সক্ষম হবে","audioUrl":"wbw/078_037_009.mp3","charTypeName":"word"},{"id":39411,"position":9,"arabic":"مِنْهُ","translation":"তাঁর সাথে","audioUrl":"wbw/078_037_010.mp3","charTypeName":"word"},{"id":39412,"position":10,"arabic":"خِطَابًۭا","translation":"কথা বলতে","audioUrl":"wbw/078_037_011.mp3","charTypeName":"word"},{"id":39413,"position":11,"arabic":"٣٧","translation":"(৩৭)","audioUrl":null,"charTypeName":"end"}]},{"number":38,"arabic":"يَوْمَ يَقُومُ ٱلرُّوحُ وَٱلْمَلَٰٓئِكَةُ صَفًّۭا ۖ لَّا يَتَكَلَّمُونَ إِلَّا مَنْ أَذِنَ لَهُ ٱلرَّحْمَٰنُ وَقَالَ صَوَابًۭا","translation":"on the Day when all [human] souls and all the angels will stand up in ranks: none will speak but he to whom the Most Gracious will have given leave; and [everyone] will say [only] what is right.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5710.mp3","surahId":78,"words":[{"id":40124,"position":1,"arabic":"يَوْمَ","translation":"সেদিন","audioUrl":"wbw/078_038_001.mp3","charTypeName":"word"},{"id":40125,"position":2,"arabic":"يَقُومُ","translation":"দাঁড়াবে","audioUrl":"wbw/078_038_002.mp3","charTypeName":"word"},{"id":40126,"position":3,"arabic":"ٱلرُّوحُ","translation":"রূহ (জিবরাইল)","audioUrl":"wbw/078_038_003.mp3","charTypeName":"word"},{"id":40127,"position":4,"arabic":"وَٱلْمَلَـٰٓئِكَةُ","translation":"ও ফেরেশতারা","audioUrl":"wbw/078_038_004.mp3","charTypeName":"word"},{"id":40128,"position":5,"arabic":"صَفًّۭا ۖ","translation":"সারিবদ্ধ ভাবে","audioUrl":"wbw/078_038_005.mp3","charTypeName":"word"},{"id":40130,"position":6,"arabic":"لَّا","translation":"না","audioUrl":"wbw/078_038_007.mp3","charTypeName":"word"},{"id":40131,"position":7,"arabic":"يَتَكَلَّمُونَ","translation":"তারা কথা বলবে","audioUrl":"wbw/078_038_008.mp3","charTypeName":"word"},{"id":40132,"position":8,"arabic":"إِلَّا","translation":"(সে) ছাড়া","audioUrl":"wbw/078_038_009.mp3","charTypeName":"word"},{"id":40133,"position":9,"arabic":"مَنْ","translation":"যাকে","audioUrl":"wbw/078_038_010.mp3","charTypeName":"word"},{"id":40134,"position":10,"