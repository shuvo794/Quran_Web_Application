009.mp3","charTypeName":"word"},{"id":40940,"position":9,"arabic":"مَـَٔابًا","translation":"প্রত্যাবর্তনের (পথ)","audioUrl":"wbw/078_039_010.mp3","charTypeName":"word"},{"id":40941,"position":10,"arabic":"٣٩","translation":"(৩৯)","audioUrl":null,"charTypeName":"end"}]},{"number":40,"arabic":"إِنَّآ أَنذَرْنَٰكُمْ عَذَابًۭا قَرِيبًۭا يَوْمَ يَنظُرُ ٱلْمَرْءُ مَا قَدَّمَتْ يَدَاهُ وَيَقُولُ ٱلْكَافِرُ يَٰلَيْتَنِى كُنتُ تُرَٰبًۢا","translation":"Verily, We have warned you of suffering near at hand - [suffering] on the Day when man shall [clearly] see what his hands have sent ahead, and when he who has denied the truth shall say, \"Oh, would that I were mere dust...!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5712.mp3","surahId":78,"words":[{"id":41863,"position":1,"arabic":"إِنَّآ","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/078_040_001.mp3","charTypeName":"word"},{"id":41864,"position":2,"arabic":"أَنذَرْنَـٰكُمْ","translation":"তোমাদেরকে আমরা সতর্ক করছি","audioUrl":"wbw/078_040_002.mp3","charTypeName":"word"},{"id":41865,"position":3,"arabic":"عَذَابًۭا","translation":"শাস্তির","audioUrl":"wbw/078_040_003.mp3","charTypeName":"word"},{"id":41866,"position":4,"arabic":"قَرِيبًۭا","translation":"আসন্ন","audioUrl":"wbw/078_040_004.mp3","charTypeName":"word"},{"id":41867,"position":5,"arabic":"يَوْمَ","translation":"সেদিন","audioUrl":"wbw/078_040_005.mp3","charTypeName":"word"},{"id":41868,"position":6,"arabic":"يَنظُرُ","translation":"দেখবে","audioUrl":"wbw/078_040_006.mp3","charTypeName":"word"},{"id":41869,"position":7,"arabic":"ٱلْمَرْءُ","translation":"মানুষ","audioUrl":"wbw/078_040_007.mp3","charTypeName":"word"},{"id":41870,"position":8,"arabic":"مَا","translation":"যা","audioUrl":"wbw/078_040_008.mp3","charTypeName":"word"},{"id":41871,"position":9,"arabic":"قَدَّمَتْ","translation":"আগে পাঠিয়েছে","audioUrl":"wbw/078_040_009.mp3","charTypeName":"word"},{"id":41872,"position":10,"arabic":"يَدَاهُ","translation":"তার দু'হাত","audioUrl":"wbw/078_040_010.mp3","charTypeName":"word"},{"id":41873,"position":11,"arabic":"وَيَقُولُ","translation":"এবং বলবে","audioUrl":"wbw/078_040_011.mp3","charTypeName":"word"},{"id":41874,"position":12,"arabic":"ٱلْكَافِرُ","translation":"কাফের","audioUrl":"wbw/078_040_012.mp3","charTypeName":"word"},{"id":41875,"position":13,"arabic":"يَـٰلَيْتَنِى","translation":"\"হায় আমার আফসোস","audioUrl":"wbw/078_040_013.mp3","charTypeName":"word"},{"id":41876,"position":14,"arabic":"كُنتُ","translation":"যদি আমি হতাম","audioUrl":"wbw/078_040_014.mp3","charTypeName":"word"},{"id":41877,"position":15,"arabic":"تُرَٰبًۢا","translation":"মাটি\"","audioUrl":"wbw/078_040_015.mp3","charTypeName":"word"},{"id":41878,"position":16,"arabic":"٤٠","translation":"(৪০)","audioUrl":null,"charTypeName":"end"}]},{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلنَّٰزِعَٰتِ غَرْقًۭا","translation":"CONSIDER those [stars] that rise only to set,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5713.mp3","surahId":79,"words":[{"id":679,"position":1,"arabic":"وَٱلنَّـٰزِعَـٰتِ","translation":"শপথ সজোরে (প্রাণ) নির্গতকারী (ফেরেশতাদের)","audioUrl":"wbw/079_001_001.mp3","charTypeName":"word"},{"id":680,"position":2,"arabic":"غَرْقًۭا","translation":"(যারা নির্গত করে) ডুবে","audioUrl":"wbw/079_001_002.mp3","charTypeName":"word"},{"id":681,"position":3,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"وَٱلنَّٰشِطَٰتِ نَشْطًۭا","translation":"and move [in their orbits] with steady motion,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5714.mp3","surahId":79,"words":[{"id":1695,"position":1,"arabic":"وَٱلنَّـٰشِطَـٰتِ","translation":"শপথ (আত্মার) বাঁধন উন্মুক্তকারী (ফেরেশতাদের)","audioUrl":"wbw/079_002_001.mp3","charTypeName":"word"},{"id":1696,"position":2,"arabic":"نَشْطًۭا","translation":"(যারা মৃদুভাবে) উন্মুক্ত (করে)","audioUrl":"wbw/079_002_002.mp3","charTypeName":"word"},{"id":1697,"position":3,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"وَٱلسَّٰبِحَٰتِ سَبْحًۭا","translation":"and float [through space] with floating serene,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5715.mp3","surahId":79,"words":[{"id":2804,"position":1,"arabic":"وَٱلسَّـٰبِحَـٰتِ","translation":"শপথ সাঁতারকারী (ফেরেশতাদের)","audioUrl":"wbw/079_003_001.mp3","charTypeName":"word"},{"id":2805,"position":2,"arabic":"سَبْحًۭا","translation":"(যারা তীব্র গতিতে) সাঁতরায়","audioUrl":"wbw/079_003_002.mp3","charTypeName":"word"},{"id":2806,"position":3,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"فَٱلسَّٰبِقَٰتِ سَبْقًۭا","translation":"and yet overtake [one another] with swift overtaking:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5716.mp3","surahId":79,"words":[{"id":4178,"position":1,"arabic":"فَٱلسَّـٰبِقَـٰتِ","translation":"অতঃপর (শপথ) অগ্রগামী (ফেরেশতাদের)","audioUrl":"wbw/079_004_001.mp3","charTypeName":"word"},{"id":4179,"position":2,"arabic":"سَبْقًۭا","translation":"দ্রুতবেগে","audioUrl":"wbw/079_004_002.mp3","charTypeName":"word"},{"id":4180,"position":3,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"فَٱلْمُدَبِّرَٰتِ أَمْرًۭا","translation":"and thus they fulfil the [Creator's] behest!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5717.mp3","surahId":79,"words":[{"id":5452,"position":1,"arabic":"فَٱلْمُدَبِّرَٰتِ","translation":"অতঃপর (শপথ) কার্যনির্বাহী (ফেরেশতাদের)","audioUrl":"wbw/079_005_001.mp3","charTypeName":"word"},{"id":5453,"position":2,"arabic":"أَمْرًۭا","translation":"(যারা পরিচালনা করে) কর্ম","audioUrl":"wbw/079_005_002.mp3","charTypeName":"word"},{"id":5454,"position":3,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"يَوْمَ تَرْجُفُ ٱلرَّاجِفَةُ","translation":"[HENCE, think of] the Day when a violent convulsion will convulse [the world],","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5718.mp3","surahId":79,"words":[{"id":6681,"position":1,"arabic":"يَوْمَ","translation":"সেদিন","audioUrl":"wbw/079_006_001.mp3","charTypeName":"word"},{"id":6682,"position":2,"arabic":"تَرْجُفُ","translation":"প্রকম্পিত করবে","audioUrl":"wbw/079_006_002.mp3","charTypeName":"word"},{"id":6683,"position":3,"arabic":"ٱلرَّاجِفَةُ","translation":"প্রথম শিংগাধ্বনি","audioUrl":"wbw/079_006_003.mp3","charTypeName":"word"},{"id":6684,"position":4,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"تَتْبَعُهَا ٱلرَّادِفَةُ","translation":"to be followed by further [convulsions]!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5719.mp3","surahId":79,"words":[{"id":8026,"position":1,"arabic":"تَتْبَعُهَا","translation":"তার অনুসরণ করবে","audioUrl":"wbw/079_007_001.mp3","charTypeName":"word"},{"id":8027,"position":2,"arabic":"ٱلرَّادِفَةُ","translation":"(আরো একটি) শিংগাধ্বনি","audioUrl":"wbw/079_007_002.mp3","charTypeName":"word"},{"id":8028,"position":3,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"قُلُوبٌۭ يَوْمَئِذٍۢ وَاجِفَةٌ","translation":"On that Day will [men's] hearts be throbbing,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5720.mp3","surahId":79,"words":[{"id":9189,"position":1,"arabic":"قُلُوبٌۭ","translation":"(কতিপয়) হৃদয়","audioUrl":"wbw/079_008_001.mp3","charTypeName":"word"},{"id":9190,"position":2,"arabic":"يَوْمَئِذٍۢ","translation":"সেদিন","audioUrl":"wbw/079_008_002.mp3","charTypeName":"word"},{"id":9191,"position":3,"arabic":"وَاجِفَةٌ","translation":"ভীত-কম্পিত (হবে)","audioUrl":"wbw/079_008_003.mp3","charTypeName":"word"},{"id":9192,"position":4,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"أَبْصَٰرُهَا خَٰشِعَةٌۭ","translation":"[and] their eyes downcast...","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5721.mp3","surahId":79,"words":[{"id":10401,"position":1,"arabic":"أَبْصَـٰرُهَا","translation":"তার দৃষ্টি সমূহ","audioUrl":"wbw/079_009_001.mp3","charTypeName":"word"},{"id":10402,"position":2,"arabic":"خَـٰشِعَةٌۭ","translation":"ভীতসন্ত্রস্ত (হবে)","audioUrl":"wbw/079_009_002.mp3","charTypeName":"word"},{"id":10403,"position":3,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"يَقُولُونَ أَءِنَّا لَمَرْدُودُونَ فِى ٱلْحَافِرَةِ","translation":"[And yet,] some say, \"What! Are we indeed to be restored to our former state –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5722.mp3","surahId":79,"words":[{"id":11628,"position":1,"arabic":"يَقُولُونَ","translation":"তারা বলে","audioUrl":"wbw/079_010_001.mp3","charTypeName":"word"},{"id":11629,"position":2,"arabic":"أَءِنَّا","translation":"\"অবশ্যই কি আমরা","audioUrl":"wbw/079_010_002.mp3","charTypeName":"word"},{"id":11630,"position":3,"arabic":"لَمَرْدُودُونَ","translation":"অবশ্যই প্রত্যাবর্তিত হবো","audioUrl":"wbw/079_010_003.mp3","charTypeName":"word"},{"id":11631,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/079_010_004.mp3","charTypeName":"word"},{"id":11632,"position":5,"arabic":"ٱلْحَافِرَةِ","translation":"পূর্বাবস্থার","audioUrl":"wbw/079_010_005.mp3","charTypeName":"word"},{"id":11633,"position":6,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"أَءِذَا كُنَّا عِظَٰمًۭا نَّخِرَةًۭ","translation":"even though we may have become [a heap of] crumbling bones?\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5723.mp3","surahId":79,"words":[{"id":12979,"position":1,"arabic":"أَءِذَا","translation":"যখন কি","audioUrl":"wbw/079_011_001.mp3","charTypeName":"word"},{"id":12980,"position":2,"arabic":"كُنَّا","translation":"আমরা হবো (পরিণত)","audioUrl":"wbw/079_011_002.mp3","charTypeName":"word"},{"id":12981,"position":3,"arabic":"عِظَـٰمًۭا","