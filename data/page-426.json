{"id":426,"ayahs":[{"number":55,"arabic":"لَّا جُنَاحَ عَلَيْهِنَّ فِىٓ ءَابَآئِهِنَّ وَلَآ أَبْنَآئِهِنَّ وَلَآ إِخْوَٰنِهِنَّ وَلَآ أَبْنَآءِ إِخْوَٰنِهِنَّ وَلَآ أَبْنَآءِ أَخَوَٰتِهِنَّ وَلَا نِسَآئِهِنَّ وَلَا مَا مَلَكَتْ أَيْمَٰنُهُنَّ ۗ وَٱتَّقِينَ ٱللَّهَ ۚ إِنَّ ٱللَّهَ كَانَ عَلَىٰ كُلِّ شَىْءٍۢ شَهِيدًا","translation":"[However,] it is no sin for them [to appear freely] before their fathers, or their sons, or their brothers, or their brothers’ sons, or their sisters’ sons, or their womenfolk, or such [male slaves] as their right hands may possess. But [always, O wives of the Prophet,] remain con­scious of God - for, behold, God is witness unto everything.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3588.mp3","surahId":33,"words":[{"id":51938,"position":1,"arabic":"لَّا","translation":"নেই","audioUrl":"wbw/033_055_001.mp3","charTypeName":"word"},{"id":51939,"position":2,"arabic":"جُنَاحَ","translation":"অপরাধ","audioUrl":"wbw/033_055_002.mp3","charTypeName":"word"},{"id":51940,"position":3,"arabic":"عَلَيْهِنَّ","translation":"উপর তাদের","audioUrl":"wbw/033_055_003.mp3","charTypeName":"word"},{"id":51941,"position":4,"arabic":"فِىٓ","translation":"ক্ষেত্রে","audioUrl":"wbw/033_055_004.mp3","charTypeName":"word"},{"id":51942,"position":5,"arabic":"ءَابَآئِهِنَّ","translation":"পিতাদের তাদের(সাথে দেখা সাক্ষাতের)","audioUrl":"wbw/033_055_005.mp3","charTypeName":"word"},{"id":51943,"position":6,"arabic":"وَلَآ","translation":"আর না","audioUrl":"wbw/033_055_006.mp3","charTypeName":"word"},{"id":51944,"position":7,"arabic":"أَبْنَآئِهِنَّ","translation":"পুত্রদের তাদের","audioUrl":"wbw/033_055_007.mp3","charTypeName":"word"},{"id":51945,"position":8,"arabic":"وَلَآ","translation":"আর না","audioUrl":"wbw/033_055_008.mp3","charTypeName":"word"},{"id":51946,"position":9,"arabic":"إِخْوَٰنِهِنَّ","translation":"ভাইদের তাদের","audioUrl":"wbw/033_055_009.mp3","charTypeName":"word"},{"id":51947,"position":10,"arabic":"وَلَآ","transla