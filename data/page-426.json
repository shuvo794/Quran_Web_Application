"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/033_055_027.mp3","charTypeName":"word"},{"id":51965,"position":26,"arabic":"كَانَ","translation":"হলেন","audioUrl":"wbw/033_055_028.mp3","charTypeName":"word"},{"id":51966,"position":27,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/033_055_029.mp3","charTypeName":"word"},{"id":51967,"position":28,"arabic":"كُلِّ","translation":"সব","audioUrl":"wbw/033_055_030.mp3","charTypeName":"word"},{"id":51968,"position":29,"arabic":"شَىْءٍۢ","translation":"কিছুর","audioUrl":"wbw/033_055_031.mp3","charTypeName":"word"},{"id":51969,"position":30,"arabic":"شَهِيدًا","translation":"প্রত্যক্ষ সাক্ষী","audioUrl":"wbw/033_055_032.mp3","charTypeName":"word"},{"id":51970,"position":31,"arabic":"٥٥","translation":"(৫৫)","audioUrl":null,"charTypeName":"end"}]},{"number":56,"arabic":"إِنَّ ٱللَّهَ وَمَلَٰٓئِكَتَهُۥ يُصَلُّونَ عَلَى ٱلنَّبِىِّ ۚ يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ صَلُّوا۟ عَلَيْهِ وَسَلِّمُوا۟ تَسْلِيمًا","translation":"Verily, God and His angels bless the Prophet: [hence,] O you who have attained to faith, bless him and give yourselves up [to his guidance] in utter self-surrender!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3589.mp3","surahId":33,"words":[{"id":52513,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/033_056_001.mp3","charTypeName":"word"},{"id":52514,"position":2,"arabic":"ٱللَّهَ","translation":"আল্লাহ (প্রশংসা করেন)","audioUrl":"wbw/033_056_002.mp3","charTypeName":"word"},{"id":52515,"position":3,"arabic":"وَمَلَـٰٓئِكَتَهُۥ","translation":"ও ফেরেশতাগণ তাঁর","audioUrl":"wbw/033_056_003.mp3","charTypeName":"word"},{"id":52516,"position":4,"arabic":"يُصَلُّونَ","translation":"দু'আ পাঠান","audioUrl":"wbw/033_056_004.mp3","charTypeName":"word"},{"id":52517,"position":5,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/033_056_005.mp3","charTypeName":"word"},{"id":52518,"position":6,"arabic":"ٱلنَّبِىِّ ۚ","translation":"নাবীর","audioUrl":"wbw/033_056_006.mp3","charTypeName":"word"},{"id":52520,"position":7,"arabic":"يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/033_056_008.mp3","charTypeName":"word"},{"id":52521,"position":8,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/033_056_009.mp3","charTypeName":"word"},{"id":52522,"position":9,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছো","audioUrl":"wbw/033_056_010.mp3","charTypeName":"word"},{"id":52523,"position":10,"arabic":"صَلُّوا۟","translation":"দরূদ পাঠাও","audioUrl":"wbw/033_056_011.mp3","charTypeName":"word"},{"id":52524,"position":11,"arabic":"عَلَيْهِ","translation":"উপর তার","audioUrl":"wbw/033_056_012.mp3","charTypeName":"word"},{"id":52525,"position":12,"arabic":"وَسَلِّمُوا۟","translation":"ও তোমরা সালাম জানাও","audioUrl":"wbw/033_056_013.mp3","charTypeName":"word"},{"id":52526,"position":13,"arabic":"تَسْلِيمًا","translation":"(অতি উত্তম) সালাম","audioUrl":"wbw/033_056_014.mp3","charTypeName":"word"},{"id":52527,"position":14,"arabic":"٥٦","translation":"(৫৬)","audioUrl":null,"charTypeName":"end"}]},{"number":57,"arabic":"إِنَّ ٱلَّذِينَ يُؤْذُونَ ٱللَّهَ وَرَسُولَهُۥ لَعَنَهُمُ ٱللَّهُ فِى ٱلدُّنْيَا وَٱلْءَاخِرَةِ وَأَعَدَّ لَهُمْ عَذَابًۭا مُّهِينًۭا","translation":"Verily, as for those who [knowingly] affront God and His Apostle - God will reject them in this world and in the life to come; and shameful suffering will He ready for them.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3590.mp3","surahId":33,"words":[{"id":52715,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/033_057_001.mp3","charTypeName":"word"},{"id":52716,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/033_057_002.mp3","charTypeName":"word"},{"id":52717,"position":3,"arabic":"يُؤْذُونَ","translation":"কষ্ট দেয়","audioUrl":"wbw/033_057_003.mp3","charTypeName":"word"},{"id":52718,"position":4,"arabic":"ٱللَّهَ","translation":"আল্লাহকে","audioUrl":"wbw/033_057_004.mp3","charTypeName":"word"},{"id":52719,"position":5,"arabic":"وَرَسُولَهُۥ","translation":"ও রাসূলকে তাঁর","audioUrl":"wbw/033_057_005.mp3","charTypeName":"word"},{"id":52720,"position":6,"arabic":"لَعَنَهُمُ","translation":"অভিশাপ দেন তাদেরকে","audioUrl":"wbw/033_057_006.mp3","charTypeName":"word"},{"id":52721,"position":7,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/033_057_007.mp3","charTypeName":"word"},{"id":52722,"position":8,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/033_057_008.mp3","charTypeName":"word"},{"id":52723,"position":9,"arabic":"ٱلدُّنْيَا","translation":"দুনিয়ার","audioUrl":"wbw/033_057_009.mp3","charTypeName":"word"},{"id":52724,"position":10,"arabic":"وَٱلْـَٔاخِرَةِ","translation":"ও আখিরাতে","audioUrl":"wbw/033_057_010.mp3","charTypeName":"word"},{"id":52725,"position":11,"arabic":"وَأَعَدَّ","translation":"এবং প্রস্তুত করে রেখেছেন","audioUrl":"wbw/033_057_011.mp3","charTypeName":"word"},{"id":52726,"position":12,"arabic":"لَهُمْ","translation":"জন্যে তাদের","audioUrl":"wbw/033_057_012.mp3","charTypeName":"word"},{"id":52727,"position":13,"arabic":"عَذَابًۭا","translation":"শাস্তি","audioUrl":"wbw/033_057_013.mp3","charTypeName":"word"},{"id":52728,"position":14,"arabic":"مُّهِينًۭا","translation":"অপমানকর","audioUrl":"wbw/033_057_014.mp3","charTypeName":"word"},{"id":52729,"position":15,"arabic":"٥٧","translation":"(৫৭)","audioUrl":null,"charTypeName":"end"}]},{"number":58,"arabic":"وَٱلَّذِينَ يُؤْذُونَ ٱلْمُؤْمِنِينَ وَٱلْمُؤْمِنَٰتِ بِغَيْرِ مَا ٱكْتَسَبُوا۟ فَقَدِ ٱحْتَمَلُوا۟ بُهْتَٰنًۭا وَإِثْمًۭا مُّبِينًۭا","translation":"And as for those who malign believing men and believing women without their having done any wrong - they surely burden themselves with the guilt of calumny, and [thus] with a flagrant sin!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3591.mp3","surahId":33,"words":[{"id":53553,"position":1,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/033_058_001.mp3","charTypeName":"word"},{"id":53554,"position":2,"arabic":"يُؤْذُونَ","translation":"কষ্ট দেয়","audioUrl":"wbw/033_058_002.mp3","charTypeName":"word"},{"id":53555,"position":3,"arabic":"ٱلْمُؤْمِنِينَ","translation":"মু’মিনদেরকে","audioUrl":"wbw/033_058_003.mp3","charTypeName":"word"},{"id":53556,"position":4,"arabic":"وَٱلْمُؤْمِنَـٰتِ","translation":"ও মু’মিন নারীদেরকে","audioUrl":"wbw/033_058_004.mp3","charTypeName":"word"},{"id":53557,"position":5,"arabic":"بِغَيْرِ","translation":"এ ছাড়া","audioUrl":"wbw/033_058_005.mp3","charTypeName":"word"},{"id":53558,"position":6,"arabic":"مَا","translation":"যা","audioUrl":"wbw/033_058_006.mp3","charTypeName":"word"},{"id":53559,"position":7,"arabic":"ٱكْتَسَبُوا۟","translation":"তারা অর্জন (অপরাধ) করেছে","audioUrl":"wbw/033_058_007.mp3","charTypeName":"word"},{"id":53560,"position":8,"arabic":"فَقَدِ","translation":"তাহ'লে নিশ্চয়ই","audioUrl":"wbw/033_058_008.mp3","charTypeName":"word"},{"id":53561,"position":9,"arabic":"ٱحْتَمَلُوا۟","translation":"তারা বহন করবে","audioUrl":"wbw/033_058_009.mp3","charTypeName":"word"},{"id":53562,"position":10,"arabic":"بُهْتَـٰنًۭا","translation":"অপবাদ","audioUrl":"wbw/033_058_010.mp3","charTypeName":"word"},{"id":53563,"position":11,"arabic":"وَإِثْمًۭا","translation":"ও পাপ","audioUrl":"wbw/033_058_011.mp3","charTypeName":"word"},{"id":53564,"position":12,"arabic":"مُّبِينًۭا","translation":"সুস্পষ্ট","audioUrl":"wbw/033_058_012.mp3","charTypeName":"word"},{"id":53565,"position":13,"arabic":"٥٨","translation":"(৫৮)","audioUrl":null,"charTypeName":"end"}]},{"number":59,"arabic":"يَٰٓأَيُّهَا ٱلنَّبِىُّ قُل لِّأَزْوَٰجِكَ وَبَنَاتِكَ وَنِسَآءِ ٱلْمُؤْمِنِينَ يُدْنِينَ عَلَيْهِنَّ مِن جَلَٰبِيبِهِنَّ ۚ ذَٰلِكَ أَدْنَىٰٓ أَن يُعْرَفْنَ فَلَا يُؤْذَيْنَ ۗ وَكَانَ ٱللَّهُ غَفُورًۭا رَّحِيمًۭا","translation":"O Prophet! Tell thy wives and thy daughters, as well as all [other] believing women, that they should draw over themselves some of their outer garments [when in public]: this will be more con­ducive to their being recognized [as decent women] and not annoyed. But [withal,] God is indeed much- forgiving, a dispenser of grace!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3592.mp3","surahId":33,"words":[{"id":54099,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/033_059_001.mp3","charTypeName":"word"},{"id":54100,"position":2,"arabic":"ٱلنَّبِىُّ","translation":"নাবী","audioUrl":"wbw/033_059_002.mp3","charTypeName":"word"},{"id":54101,"position":3,"arabic":"قُل","translation":"বলো","audioUrl":"wbw/033_059_003.mp3","charTypeName":"word"},{"id":54102,"position":4,"arabic":"لِّأَزْوَٰجِكَ","translation":"উদ্দেশ্যে স্ত্রীদের তোমার","audioUrl":"wbw/033_059_004.mp3","charTypeName":"word"},{"id":54103,"position":5,"arabic":"وَبَنَاتِكَ","translation":"ও তোমাদের মেয়েদেরকে","audioUrl":"wbw/033_059_005.mp3","charTypeName":"word"},{"id":54104,"position":6,"arabic":"وَنِسَآءِ","translation":"ও নারীদের","audioUrl":"wbw/033_059_006.mp3","charTypeName":"word"},{"id":54105,"position":7,"arabic":"ٱلْمُؤْمِنِينَ","translation":"মু’মিনদের (যেন)","audioUrl":"wbw/033_059_007.mp3","charTypeName":"word"},{"id":54106,"position":8,"arabic":"يُدْنِينَ","translation":"তারা টেনে দেয়","audioUrl":"wbw/033_059_008.mp3","charTypeName":"word"},{"id":54107,"position":9,"arabic":"عَلَيْهِنَّ","translation":"উপর তাদের","audioUrl":"wbw/033_059_009.mp3","charTypeName":"word"},{"id":54108,"position":10,"arabic":"مِن","translation":"কিছু অংশ (অর্থাৎ আঁচল)","audioUrl":"wbw/033_059_010.mp3","charTypeName":"word"},{"id":54109,"position":11,"arabic":"جَلَـٰبِيبِهِنَّ ۚ","translation":"চাদরের তাদের","audioUrl":"wbw/033_059_011.mp3","charTypeName":"word"},{"id":54111,"position":12,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/033_059_013.mp3","charTypeName":"word"},{"id":54112,"position":13,"arabic":"أَدْنَىٰٓ","translation":"নিকটতর","audioUrl":"wbw/033_059_014.mp3","charTypeName":"word"},{"id":54113,"position":14,"arabic":"أَن","translation":"যে","audioUrl":"wbw/033_059_015.mp3","charTypeN