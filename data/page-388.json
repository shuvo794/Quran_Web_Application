{"id":388,"ayahs":[{"number":22,"arabic":"وَلَمَّا تَوَجَّهَ تِلْقَآءَ مَدْيَنَ قَالَ عَسَىٰ رَبِّىٓ أَن يَهْدِيَنِى سَوَآءَ ٱلسَّبِيلِ","translation":"And as he turned his face towards Madyan, he said [to himself]: “It may well be that my Sustainer will [thus] guide me onto the right path”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3274.mp3","surahId":28,"words":[{"id":25059,"position":1,"arabic":"وَلَمَّا","translation":"এবং যখন","audioUrl":"wbw/028_022_001.mp3","charTypeName":"word"},{"id":25060,"position":2,"arabic":"تَوَجَّهَ","translation":"মুখ ফেরালো (রওনা হলো)","audioUrl":"wbw/028_022_002.mp3","charTypeName":"word"},{"id":25061,"position":3,"arabic":"تِلْقَآءَ","translation":"দিকে","audioUrl":"wbw/028_022_003.mp3","charTypeName":"word"},{"id":25062,"position":4,"arabic":"مَدْيَنَ","translation":"মাদইয়ানের","audioUrl":"wbw/028_022_004.mp3","charTypeName":"word"},{"id":25063,"position":5,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/028_022_005.mp3","charTypeName":"word"},{"id":25064,"position":6,"arabic":"عَسَىٰ","translation":"\"আশা করা যায়","audioUrl":"wbw/028_022_006.mp3","charTypeName":"word"},{"id":25065,"position":7,"arabic":"رَبِّىٓ","translation":"আমার রব","audioUrl":"wbw/028_022_007.mp3","charTypeName":"word"},{"id":25066,"position":8,"arabic":"أَن","translation":"যে","audioUrl":"wbw/028_022_008.mp3","charTypeName":"word"},{"id":25067,"position":9,"arabic":"يَهْدِيَنِى","translation":"প্রদর্শন করবেন আমাকে","audioUrl":"wbw/028_022_009.mp3","charTypeName":"word"},{"id":25068,"position":10,"arabic":"سَوَآءَ","translation":"সরল","audioUrl":"wbw/028_022_010.mp3","charTypeName":"word"},{"id":25069,"position":11,"arabic":"ٱلسَّبِيلِ","translation":"পথ\"","audioUrl":"wbw/028_022_011.mp3","charTypeName":"word"},{"id":25070,"position":12,"arabic":"٢٢","translation":"(২২)","audioUrl":null,"charTypeName":"end"}]},{"number":23,"arabic":"وَلَمَّا وَرَدَ مَآءَ مَدْيَنَ وَجَدَ عَلَيْهِ أُمَّةًۭ مِّنَ ٱلنَّاسِ يَسْقُونَ وَوَجَدَ مِن دُونِهِمُ ٱمْرَأَتَيْنِ تَذُودَانِ ۖ قَالَ مَا خَطْبُكُمَا ۖ قَالَتَا لَا نَسْقِى حَتَّىٰ يُصْدِرَ ٱلرِّعَآءُ ۖ وَأَبُونَا شَيْخٌۭ كَبِيرٌۭ","translation":"NOW WHEN he arrived at the wells of Madyan, he found there a large group of men who were watering [their herds and flocks]; and at some distance from them he came upon two women who were keeping back their flock. He asked [them]: “What is the matter with you?” They answered: “We cannot water [our animals] until the herdsmen drive [theirs] home - for [we are weak and] our father is a very old man.”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3275.mp3","surahId":28,"words":[{"id":26145,"position":1,"arabic":"وَلَمَّا","translation":"আর যখন","audioUrl":"wbw/028_023_001.mp3","charTypeName":"word"},{"id":26146,"position":2,"arabic":"وَرَدَ","translation":"পৌঁছলো","audioUrl":"wbw/028_023_002.mp3","charTypeName":"word"},{"id":26147,"position":3,"arabic":"مَآءَ","translation":"পানির (কূপের নিকট)","audioUrl":"wbw/028_023_003.mp3","charTypeName":"word"},{"id":26148,"position":4,"arabic":"مَدْيَنَ","translation":"মাদইয়ানের","audioUrl":"wbw/028_023_004.mp3","charTypeName":"word"},{"id":26149,"position":5,"arabic":"وَجَدَ","translation":"সে পেলো","audioUrl":"wbw/028_023_005.mp3","charTypeName":"word"},{"id":26150,"position":6,"arabic":"عَلَيْهِ","translation":"কাছে তার","audioUrl":"wbw/028_023_006.mp3","charTypeName":"word"},{"id":26151,"position":7,"arabic":"أُمَّةًۭ","translation":"একদল","audioUrl":"wbw/028_023_007.mp3","charTypeName":"word"},{"id":26152,"position":8,"arabic":"مِّنَ","translation":"মধ্য হ'তে","audioUrl":"wbw/028_023_008.mp3","charTypeName":"word"},{"id":26153,"position":9,"arabic":"ٱلنَّاسِ","translation":"লোকদের","audioUrl":"wbw/028_023_009.mp3","charTypeName":"word"},{"id":26154,"position":10,"arabic":"يَسْقُونَ","translation":"পানি পান করাচ্ছে (নিজেদের জন্তুগুলোকে)","audioUrl":"wbw/028_023_010.mp3","charTypeName":"word"},{"id":26155,"position":11,"arabic":"وَوَجَدَ","translation":"এবং সে পেলো","audioUrl":"wbw/028_023_011.mp3","charTypeName":"word"},{"id":26156,"position":12,"arabic":"مِن","translation":"ছাড়াও","audioUrl":"wbw/028_023_012.mp3","charTypeName":"word"},{"id":26157,"position":13,"arabic":"دُونِهِمُ","translation":"তাদের","audioUrl":"wbw/028_023_013.mp3","charTypeName":"word"},{"id":26158,"position":14,"arabic":"ٱمْرَأَتَيْنِ","translation":"দু'জন স্ত্রীলোককে","audioUrl":"wbw/028_023_014.mp3","charTypeName":"word"},{"id":26159,"position":15,"arabic":"تَذُودَانِ ۖ","translation":"দু'জনে আগলে রেখেছে (তাদের জন্তুগুলোকে)","audioUrl":"wbw/028_023_015.mp3","charTypeName":"word"},{"id":26161,"position":16,"arabic":"قَالَ","translation":"(মূসা) বললো","audioUrl":"wbw/028_023_017.mp3","charTypeName":"word"},{"id":26162,"position":17,"arabic":"مَا","translation":"\"কি","audioUrl":"wbw/028_023_018.mp3","charTypeName":"word"},{"id":26163,"position":18,"arabic":"خَطْبُكُمَا ۖ","translation":"ব্যাপার তোমাদের দু'জনের\"","audioUrl":"wbw/028_023_019.mp3","charTypeName":"word"},{"id":26165,"position":19,"arabic":"قَالَتَا","translation":"দু'জনে বললো","audioUrl":"wbw/028_023_021.mp3","charTypeName":"word"},{"id":26166,"position":20,"arabic":"لَا","translation":"\"না","audioUrl":"wbw/028_023_022.mp3","charTypeName":"word"},{"id":26167,"position":21,"arabic":"نَسْقِى","translation":"\"আমরা পানি পান করাই","audioUrl":"wbw/028_023_023.mp3","charTypeName":"word"},{"id":26168,"position":22,"arabic":"حَتَّىٰ","translation":"যতক্ষণ না","audioUrl":"wbw/028_023_024.mp3","charTypeName":"word"},{"id":26169,"position":23,"arabic":"يُصْدِرَ","translation":"সরিয়ে নিয়ে যায়","audioUrl":"wbw/028_023_025.mp3","charTypeName":"word"},{"id":26170,"position":24,"arabic":"ٱلرِّعَآءُ ۖ","translation":"রাখালরা (তাদের জন্তুগুলো)","audioUrl":"wbw/028_023_026.mp3","charTypeName":"word"},{"id":26172,"position":25,"arabic":"وَأَبُونَا","translation":"এবং আমাদের আব্বা","audioUrl":"wbw/028_023_028.mp3","charTypeName":"word"},{"id":26173,"position":26,"arabic":"شَيْخٌۭ","translation":"বৃদ্ধ\"","audioUrl":"wbw/028_023_029.mp3","charTypeName":"word"},{"id":26174,"position":27,"arabic":"كَبِيرٌۭ","translation":"অতিশয় (তাই আমরা এসেছি)\"","audioUrl":"wbw/028_023_030.mp3","charTypeName":"word"},{"id":26175,"position":28,"arabic":"٢٣","translation":"(২৩)","audioUrl":null,"charTypeName":"end"}]},{"number":24,"arabic":"فَسَقَىٰ لَهُمَا ثُمَّ تَوَلَّىٰٓ إِلَى ٱلظِّلِّ فَقَالَ رَبِّ إِنِّى لِمَآ أَنزَلْتَ إِلَىَّ مِنْ خَيْرٍۢ فَقِيرٌۭ","translation":"So he watered [their flock] for them: and when he withdrew into the shade and prayed: “O my Sus­tainer! Verily, in dire need am I of any good which Thou mayest bestow upon me!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3276.mp3","surahId":28,"words":[{"id":27196,"position":1,"arabic":"فَسَقَىٰ","translation":"তখন সে পানি পান করালো","audioUrl":"wbw/028_024_001.mp3","charTypeName":"word"},{"id":27197,"position":2,"arabic":"لَهُمَا","translation":"পক্ষে তাদের দু'জনের (জন্তুগুলোকে)","audioUrl":"wbw/028_024_002.mp3","charTypeName":"word"},{"id":27198,"position":3,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/028_024_003.mp3","charTypeName":"word"},{"id":27199,"position":4,"arabic":"تَوَلَّىٰٓ","translation":"ফিরে গেলো","audioUrl":"wbw/028_024_004.mp3","charTypeName":"word"},{"id":27200,"position":5,"arabic":"إِلَى","translation":"দিকে","audioUrl":"wbw/028_024_005.mp3","charTypeName":"word"},{"id":27201,"position":6,"arabic":"ٱلظِّلِّ","translation":"ছায়ার","audioUrl":"wbw/028_024_006.mp3","charTypeName":"word"},{"id":27202,"position":7,"arabic":"فَقَالَ","translation":"অতঃপর বললো","audioUrl":"wbw/028_024_007.mp3","charTypeName":"word"},{"id":27203,"position":8,"arabic":"رَبِّ","translation":"\"হে আমার রব","audioUrl":"wbw/028_024_008.mp3","charTypeName":"word"},{"id":27204,"position":9,"arabic":"إِنِّى","translation":"নিশ্চয়ই আমি","audioUrl":"wbw/028_024_009.mp3","charTypeName":"word"},{"id":27205,"position":10,"arabic":"لِمَآ","translation":"তার প্রতি যা","audioUrl":"wbw/028_024_010.mp3","charTypeName":"word"},{"id":27206,"position":11,"arabic":"أَنزَلْتَ","translation":"অবতীর্ণ করবে তুমি","audioUrl":"wbw/028_024_011.mp3","charTypeName":"word"},{"id":27207,"position":12,"arabic":"إِلَىَّ","translation":"প্রতি আমার","audioUrl":"wbw/028_024_012.mp3","charTypeName":"word"},{"id":27208,"position":13,"arabic":"مِنْ","translation":"কোনো","audioUrl":"wbw/028_024_013.mp3","charTypeName":"word"},{"id":27209,"position":14,"arabic":"خَيْرٍۢ","translation":"কল্যাণ","audioUrl":"wbw/028_024_014.mp3","charTypeName":"word"},{"id":27210,"position":15,"arabic":"فَقِيرٌۭ","translation":"(আমি তারই)মুখাপেক্ষী\"","audioUrl":"wbw/028_024_015.mp3","charTypeName":"word"},{"id":27211,"position":16,"arabic":"٢٤","translation":"(২৪)","audioUrl":null,"charTypeName":"end"}]},{"number":25,"arabic":"فَجَآءَتْهُ إِحْدَىٰهُمَا تَمْشِى عَلَى ٱسْتِحْيَآءٍۢ قَالَتْ إِنَّ أَبِى يَدْعُوكَ لِيَجْزِيَكَ أَجْرَ مَا سَقَيْتَ لَنَا ۚ فَلَمَّا جَآءَهُۥ وَقَصَّ عَلَيْهِ ٱلْقَصَصَ قَالَ لَا تَخَفْ ۖ نَجَوْتَ مِنَ ٱلْقَوْمِ ٱلظَّٰلِمِينَ","translation":"[Shortly] afterwards, one of the two [maidens] approached him, walking shyly, and said: “Behold, my father invites thee, so that he might duly reward thee for thy having watered [our flock] for us.” And as soon as [Moses] came unto him and told him the story [of his life], he said: “Have no fear! Thou art now safe from those evildoing folk!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3277.mp3","surahId":28,"words":[{"id":28210,"position":1,"arabic":"فَجَآءَتْهُ","translation":"অতঃপর কাছে আসলো তার","audioUrl":"wbw/028_025_001.mp3","charTypeName":"word"},{"id":28211,"position":2,"arabic":"إِحْدَىٰهُمَا","translation":"দু'জনের একজন তাদের","audioUrl":"wbw/028_025_002.mp3","charTypeName":"word"},{"id":28212,"position":3,"arabic":"تَمْشِى","translation":"হেঁটে","audioUrl":"wbw/028_025_003.mp3","charTypeName":"word"},{"id":28213,"position":4,"arabic":"عَلَى","translation":"সাথে","audioUrl":"wbw/028_025_004.mp3","charTypeName":"word"},{"id":28214,"position":5,"arabic":"ٱسْتِحْيَآءٍۢ","translation":"লজ্জা ও শালিনতার","audioUrl":"wbw/028_025_005.mp3","charTypeName":"word"},{"id":28215,"position":6,"arabic":"قَالَتْ","translation":"(মেয়েটি) বললো","audioUrl":"wbw/028_025_006.mp3","charTypeName":"word"},{"id":28216,"position":7,"arabic":"إِنَّ","translation":"\"নিশ্চয়ই","audioUrl":"wbw/028_025_007.mp3","charTypeName":"word"},{"id":28217,"position":8,"arabic":"أَبِى","translation":"আমার পিতা (শোয়াইব আঃ)","audioUrl":"wbw/028_025_008.mp3","charTypeName":"word"},{"id":28218,"position":9,"arabic":"يَدْعُوكَ","translation":"আপনাকে ডাকছেন","audioUrl":"wbw/028_025_009.mp3","charTypeName":"word"},{"id":28219,"position":10,"arabic":"لِيَجْزِيَكَ","translation":"যাতে তিনি আপনাকে প্রতিদান দিতে পারেন","audioUrl":"wbw/028_025_010.mp3","charTypeName":"word"},{"id":28220,"position":11,"arabic":"أَجْرَ","translation":"পারিশ্রমিক","audioUrl":"wbw/028_025_011.mp3","charTypeName":"word"},{"id":28221,"position":12,"arabic":"مَا","translation":"(তার) যা","audioUrl":"wbw/028_025_012.mp3","charTypeName":"word"},{"id":28222,"position":13,"arabic":"سَقَيْتَ","translation":"আপনি (জন্তুগুলোকে) পানি পান করিয়েছেন","audioUrl":"wbw/028_025_013.mp3","charTypeName":"word"},{"id":28223,"position":14,"arabic":"لَنَا ۚ","translation":"পক্ষ হয়ে আমাদের\"","audioUrl":"wbw/028_025_014.mp3","charTypeName":"word"},{"id":28225,"position":15,"arabic":"فَلَمَّا","translation":"অতঃপর যখন","audioUrl":"wbw/028_025_016.mp3","charTypeName":"word"},{"id":28226,"position":16,"arabic":"جَآءَهُۥ","translation":"সে আসলো কাছে তার","audioUrl":"wbw/028_025_017.mp3","charTypeName":"word"},{"id":28227,"position":17,"arabic":"وَقَصَّ","translation":"ও বর্ণনা করলো","audioUrl":"wbw/028_025_018.mp3","charTypeName":"word"},{"id":28228,"position":18,"arabic":"عَلَيْهِ","translation":"কাছে তার","audioUrl":"wbw/028_025_019.mp3","charTypeName":"word"},{"id":28229,"position":19,"arabic":"ٱلْقَصَصَ","translation":"সব বৃত্তান্ত","audioUrl":"wbw/028_025_020.mp3","charTypeName":"word"},{"id":28230,"position":20,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/028_025_021.mp3","charTypeName":"word"},{"id":28231,"position":21,"arabic":"لَا","translation":"\"না","audioUrl":"wbw/028_025_022.mp3","charTypeName":"word"},{"id":28232,"position":22,"arabic":"تَخَفْ ۖ","translation":"ভয় করো","audioUrl":"wbw/028_025_023.mp3","charTypeName":"word"},{"id":28234,"position":23,"arabic":"نَجَوْتَ","translation":"তুমি বেঁচে গিয়েছো","audioUrl":"wbw/028_025_025.mp3","charTypeName":"word"},{"id":28235,"position":24,"arabic":"مِنَ","translation":"হ'তে","audioUrl":"wbw/028_025_026.mp3","charTypeName":"word"},{"id":28236,"position":25,"arabic":"ٱلْقَوْمِ","translation":"সম্প্রদায়","audioUrl":"wbw/028_025_027.mp3","charTypeName":"word"},{"id":28237,"position":26,"arabic":"ٱلظَّـٰلِمِينَ","translation":"সীমালঙ্ঘনকারী\"","audioUrl":"wbw/028_025_028.mp3","charTypeName":"word"},{"id":28238,"position":27,"arabic":"٢٥","translation":"(২৫)","audioUrl":null,"charTypeName":"end"}]},{"number":26,"arabic":"قَالَتْ إِحْدَىٰهُمَا يَٰٓأَبَتِ ٱسْتَـْٔجِرْهُ ۖ إِنَّ خَيْرَ مَنِ ٱسْتَـْٔجَرْتَ ٱلْقَوِىُّ ٱلْأَمِينُ","translation":"Said one of the two [daughters]: “O my father! Hire him: for, behold, the best [man] that thou couldst hire is one who is [as] strong and worthy of trust [as he]!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3278.mp3","surahId":28,"words":[{"id":29180,"position":1,"arabic":"قَالَتْ","translation":"বললো","audioUrl":"wbw/028_026_001.mp3","charTypeName":"word"},{"id":29181,"position":2,"arabic":"إِحْدَىٰهُمَا","translation":"একজন তাদের","audioUrl":"wbw/028_026_002.mp3","charTypeName":"word"},{"id":29182,"position":3,"arabic":"يَـٰٓأَبَتِ","translation":"\"হে আমার পিতা","audioUrl":"wbw/028_026_003.mp3","charTypeName":"word"},{"id":29183,"position":4,"arabic":"ٱسْتَـْٔجِرْهُ ۖ","translation":"তাকে মজুর নিযুক্ত করুন","audioUrl":"wbw/028_026_004.mp3","charTypeName":"word"},{"id":29185,"position":