e":"word"},{"id":86728,"position":26,"arabic":"عَزِيزٌ","translation":"পরাক্রমশালী","audioUrl":"wbw/002_240_028.mp3","charTypeName":"word"},{"id":86729,"position":27,"arabic":"حَكِيمٌۭ","translation":"মহাবিজ্ঞ","audioUrl":"wbw/002_240_029.mp3","charTypeName":"word"},{"id":86730,"position":28,"arabic":"٢٤٠","translation":"(২৪০)","audioUrl":null,"charTypeName":"end"}]},{"number":241,"arabic":"وَلِلْمُطَلَّقَٰتِ مَتَٰعٌۢ بِٱلْمَعْرُوفِ ۖ حَقًّا عَلَى ٱلْمُتَّقِينَ","translation":"And the divorced women, too, shall have [a right to] maintenance in a goodly manner: this is a duty for all who are conscious of God.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/248.mp3","surahId":2,"words":[{"id":86731,"position":1,"arabic":"وَلِلْمُطَلَّقَـٰتِ","translation":"এবং তালাক প্রাপ্তাদের জন্যে","audioUrl":"wbw/002_241_001.mp3","charTypeName":"word"},{"id":86732,"position":2,"arabic":"مَتَـٰعٌۢ","translation":"কিছু ভরণপোষণ দেওয়া","audioUrl":"wbw/002_241_002.mp3","charTypeName":"word"},{"id":86733,"position":3,"arabic":"بِٱلْمَعْرُوفِ ۖ","translation":"উপযুক্তভাবে","audioUrl":"wbw/002_241_003.mp3","charTypeName":"word"},{"id":86735,"position":4,"arabic":"حَقًّا","translation":"কর্তব্য","audioUrl":"wbw/002_241_005.mp3","charTypeName":"word"},{"id":86736,"position":5,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/002_241_006.mp3","charTypeName":"word"},{"id":86737,"position":6,"arabic":"ٱلْمُتَّقِينَ","translation":"মুত্তাকীদের","audioUrl":"wbw/002_241_007.mp3","charTypeName":"word"},{"id":86738,"position":7,"arabic":"٢٤١","translation":"(২৪১)","audioUrl":null,"charTypeName":"end"}]},{"number":242,"arabic":"كَذَٰلِكَ يُبَيِّنُ ٱللَّهُ لَكُمْ ءَايَٰتِهِۦ لَعَلَّكُمْ تَعْقِلُونَ","translation":"In this way God makes clear unto you His messages, so that you might [learn to] use your reason.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/249.mp3","surahId":2,"words":[{"id":86739,"position":1,"arabic":"كَذَٰلِكَ","translation":"এভাবে","audioUrl":"wbw/002_242_001.mp3","charTypeName":"word"},{"id":86740,"position":2,"arabic":"يُبَيِّنُ","translation":"বর্ণনা করেন","audioUrl":"wbw/002_242_002.mp3","charTypeName":"word"},{"id":86741,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/002_242_003.mp3","charTypeName":"word"},{"id":86742,"position":4,"arabic":"لَكُمْ","translation":"তোমাদের জন্য","audioUrl":"wbw/002_242_004.mp3","charTypeName":"word"},{"id":86743,"position":5,"arabic":"ءَايَـٰتِهِۦ","translation":"তাঁর বিধানাবলীকে","audioUrl":"wbw/002_242_005.mp3","charTypeName":"word"},{"id":86744,"position":6,"arabic":"لَعَلَّكُمْ","translation":"তোমরা যেন","audioUrl":"wbw/002_242_006.mp3","charTypeName":"word"},{"id":86745,"position":7,"arabic":"تَعْقِلُونَ","translation":"বুঝতে পার","audioUrl":"wbw/002_242_007.mp3","charTypeName":"word"},{"id":86746,"position":8,"arabic":"٢٤٢","translation":"(২৪২)","audioUrl":null,"charTypeName":"end"}]},{"number":243,"arabic":"۞ أَلَمْ تَرَ إِلَى ٱلَّذِينَ خَرَجُوا۟ مِن دِيَٰرِهِمْ وَهُمْ أُلُوفٌ حَذَرَ ٱلْمَوْتِ فَقَالَ لَهُمُ ٱللَّهُ مُوتُوا۟ ثُمَّ أَحْيَٰهُمْ ۚ إِنَّ ٱللَّهَ لَذُو فَضْلٍ عَلَى ٱلنَّاسِ وَلَٰكِنَّ أَكْثَرَ ٱلنَّاسِ لَا يَشْكُرُونَ","translation":"ART THOU NOT aware of those who forsook their homelands in their thousands for fear of death-whereupon God said unto them, \"Die,\" and later brought them back to life? Behold, God is indeed limitless in His bounty unto man -but most people are ungrateful.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/250.mp3","surahId":2,"words":[{"id":86748,"position":1,"arabic":"۞ أَلَمْ","translation":"নি কি","audioUrl":"wbw/002_243_002.mp3","charTypeName":"word"},{"id":86749,"position":2,"arabic":"تَرَ","translation":"তুমি দেখ","audioUrl":"wbw/002_243_003.mp3","charTypeName":"word"},{"id":86750,"position":3,"arabic":"إِلَى","translation":"প্রতি","audioUrl":"wbw/002_243_004.mp3","charTypeName":"word"},{"id":86751,"position":4,"arabic":"ٱلَّذِينَ","translation":"(তাদের) যারা","audioUrl":"wbw/002_243_005.mp3","charTypeName":"word"},{"id":86752,"position":5,"arabic":"خَرَجُوا۟","translation":"বের হয়েছিল","audioUrl":"wbw/002_243_006.mp3","charTypeName":"word"},{"id":86753,"position":6,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/002_243_007.mp3","charTypeName":"word"},{"id":86754,"position":7,"arabic":"دِيَـٰرِهِمْ","translation":"ঘরগুলো তাদের","audioUrl":"wbw/002_243_008.mp3","charTypeName":"word"},{"id":86755,"position":8,"arabic":"وَهُمْ","translation":"অথচ তারা (ছিল)","audioUrl":"wbw/002_243_009.mp3","charTypeName":"word"},{"id":86756,"position":9,"arabic":"أُلُوفٌ","translation":"হাজার হাজার","audioUrl":"wbw/002_243_010.mp3","charTypeName":"word"},{"id":86757,"position":10,"arabic":"حَذَرَ","translation":"ভয়ে","audioUrl":"wbw/002_243_011.mp3","charTypeName":"word"},{"id":86758,"position":11,"arabic":"ٱلْمَوْتِ","translation":"মৃত্যুর","audioUrl":"wbw/002_243_012.mp3","charTypeName":"word"},{"id":86759,"position":12,"arabic":"فَقَالَ","translation":"অতঃপর বললেন","audioUrl":"wbw/002_243_013.mp3","charTypeName":"word"},{"id":86760,"position":13,"arabic":"لَهُمُ","translation":"তাদের উদ্দেশে","audioUrl":"wbw/002_243_014.mp3","charTypeName":"word"},{"id":86761,"position":14,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/002_243_015.mp3","charTypeName":"word"},{"id":86762,"position":15,"arabic":"مُوتُوا۟","translation":"তোমরা মরে যাও","audioUrl":"wbw/002_243_016.mp3","charTypeName":"word"},{"id":86763,"position":16,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/002_243_017.mp3","charTypeName":"word"},{"id":86764,"position":17,"arabic":"أَحْيَـٰهُمْ ۚ","translation":"তিনি জীবিত করলেন (আবার) তাদেরকে","audioUrl":"wbw/002_243_018.mp3","charTypeName":"word"},{"id":86766,"position":18,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/002_243_020.mp3","charTypeName":"word"},{"id":86767,"position":19,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/002_243_021.mp3","charTypeName":"word"},{"id":86768,"position":20,"arabic":"