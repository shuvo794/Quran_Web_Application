{"id":39,"ayahs":[{"number":238,"arabic":"حَٰفِظُوا۟ عَلَى ٱلصَّلَوَٰتِ وَٱلصَّلَوٰةِ ٱلْوُسْطَىٰ وَقُومُوا۟ لِلَّهِ قَٰنِتِينَ","translation":"BE EVER mindful of prayers, and of praying in the most excellent way; and stand before God in devout obedience.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/245.mp3","surahId":2,"words":[{"id":86675,"position":1,"arabic":"حَـٰفِظُوا۟","translation":"তোমরা সংরক্ষণ করো","audioUrl":"wbw/002_238_001.mp3","charTypeName":"word"},{"id":86676,"position":2,"arabic":"عَلَى","translation":"প্রতি","audioUrl":"wbw/002_238_002.mp3","charTypeName":"word"},{"id":86677,"position":3,"arabic":"ٱلصَّلَوَٰتِ","translation":"সব সালাত গুলোর","audioUrl":"wbw/002_238_003.mp3","charTypeName":"word"},{"id":86678,"position":4,"arabic":"وَٱلصَّلَوٰةِ","translation":"এবং (বিশেষ করে) সালাত","audioUrl":"wbw/002_238_004.mp3","charTypeName":"word"},{"id":86679,"position":5,"arabic":"ٱلْوُسْطَىٰ","translation":"মধ্যবর্তী (অর্থাৎ আছরের)","audioUrl":"wbw/002_238_005.mp3","charTypeName":"word"},{"id":86680,"position":6,"arabic":"وَقُومُوا۟","translation":"এবং তোমরা দাঁড়িয়ে যাও","audioUrl":"wbw/002_238_006.mp3","charTypeName":"word"},{"id":86681,"position":7,"arabic":"لِلَّهِ","translation":"আল্লাহর জন্য","audioUrl":"wbw/002_238_007.mp3","charTypeName":"word"},{"id":86682,"position":8,"arabic":"قَـٰنِتِينَ","translation":"একান্ত বিনীত ভাবে","audioUrl":"wbw/002_238_008.mp3","charTypeName":"word"},{"id":86683,"position":9,"arabic":"٢٣٨","translation":"(২৩৮)","audioUrl":null,"charTypeName":"end"}]},{"number":239,"arabic":"فَإِنْ خِفْتُمْ فَرِجَالًا أَوْ رُكْبَانًۭا ۖ فَإِذَآ أَمِنتُمْ فَٱذْكُرُوا۟ ٱللَّهَ كَمَا عَلَّمَكُم مَّا لَمْ تَكُونُوا۟ تَعْلَمُونَ","translation":"But if you are in danger, [pray] walking or riding; and when you are again secure, bear God in mind - since it is He who taught you what you did not previously know.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/246.mp3","surahId":2,"words":[{"id":86684,"position":1,"arabic":"فَإِنْ","translation":"অতঃপর যদি","audioUrl":"wbw/002_239_001.mp3","charTypeName":"word"},{"id":86685,"position":2,"arabic":"خِفْتُمْ","translation":"তোমরা ভয় করো","audioUrl":"wbw/002_239_002.mp3","charTypeName":"word"},{"id":86686,"position":3,"arabic":"فَرِجَالًا","translation":"তবে হেঁটে চলা অবস্থায়","audioUrl":"wbw/002_239_003.mp3","charTypeName":"word"},{"id":86687,"position":4,"arabic":"أَوْ","translation":"বা","audioUrl":"wbw/002_239_004.mp3","charTypeName":"word"},{"id":86688,"position":5,"arabic":"رُكْبَانًۭا ۖ","translation":"আরোহী অবস্থায় (সালাত পড়বে)","audioUrl":"wbw/002_239_005.mp3","charTypeName":"word"},{"id":86690,"position":6,"arabic":"فَإِذَآ","translation":"অতঃপর যখন","audioUrl":"wbw/002_239_007.mp3","charTypeName":"word"},{"id":86691,"position":7,"arabic":"أَمِنتُمْ","translation":"তোমরা নিরাপদ হও","audioUrl":"wbw/002_239_008.mp3","charTypeName":"word"},{"id":86692,"position":8,"arabic":"فَٱذْكُرُوا۟","translation":"স্মরণ করো তখন","audioUrl":"wbw/002_239_009.mp3","charTypeName":"word"},{"id":86693,"position":9,"arabic":"ٱللَّهَ","translation":"আল্লাহকে","audioUrl":"wbw/002_239_010.mp3","charTypeName":"word"},{"id":86694,"position":10,"arabic":"كَمَا","translation":"যেমন","audioUrl":"wbw/002_239_011.mp3","charTypeName":"word"},{"id":86695,"position":11,"arabic":"عَلَّمَكُم","translation":"তোমাদের তিনি শিখিয়েছেন","audioUrl":"wbw/002_239_012.mp3","charTypeName":"word"},{"id":86696,"position":12,"arabic":"مَّا","translation":"যা","audioUrl":"wbw/002_239_013.mp3","charTypeName":"word"},{"id":86697,"position":13,"arabic":"لَمْ","translation":"না","audioUrl":"wbw/002_239_014.mp3","charTypeName":"word"},{"id":86698,"position":14,"arabic":"تَكُونُوا۟","translation":"তোমরা হও","audioUrl":"wbw/002_239_015.mp3","charTypeName":"word"},{"id":86699,"position":15,"arabic":"تَعْلَمُونَ","translation":"তোমরা জানতে","audioUrl":"wbw/002_239_016.mp3","charTypeName":"word"},{"id":86700,"position":16,"arabic":"٢٣٩","translation":"(২৩৯)","audioUrl":null,"charTypeName":"end"}]},{"number":240,"arabic":"وَٱلَّذِينَ يُتَوَفَّوْنَ مِنكُمْ وَيَذَرُونَ أَزْوَٰجًۭا وَصِيَّةًۭ لِّأَزْوَٰجِهِم مَّتَٰعًا إِلَى ٱلْحَوْلِ غَيْرَ إِخْرَاجٍۢ ۚ فَإِنْ خَرَجْنَ فَلَا جُنَاحَ عَلَيْكُمْ فِى مَا فَعَلْنَ فِىٓ أَنفُسِهِنَّ مِن مَّعْرُوفٍۢ ۗ وَٱللَّهُ عَزِيزٌ حَكِيمٌۭ","translation":"AND IF any of you die and leave wives behind, they bequeath thereby to their widows [the right to] one year's maintenance without their being obliged to leave [the dead husband's home]. If, however, they leave [of their own accord], there shall be no sin in whatever they may do with themselves in a lawful manner. And God is almighty, wise.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/247.mp3","surahId":2,"words":[{"id":86701,"position":1,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/002_240_001.mp3","charTypeName":"word"},{"id":86702,"position":2,"arabic":"يُتَوَفَّوْنَ","translation":"মারা যায়","audioUrl":"wbw/002_240_002.mp3","charTypeName":"word"},{"id":86703,"position":3,"arabic":"مِنكُمْ","translation":"তোমাদের মধ্য হতে","audioUrl":"wbw/002_240_003.mp3","charTypeName":"word"},{"id":86704,"position":4,"arabic":"وَيَذَرُونَ","translation":"এবং তারা রেখে যায়","audioUrl":"wbw/002_240_004.mp3","charTypeName":"word"},{"id":86705,"position":5,"arabic":"أَزْوَٰجًۭا","translation":"স্ত্রীদেরকে","audioUrl":"wbw/002_240_005.mp3","charTypeName":"word"},{"id":86706,"position":6,"arabic":"وَصِيَّةًۭ","translation":"(তাদের উচিৎ) জোর নির্দেশ করা","audioUrl":"wbw/002_240_006.mp3","charTypeName":"word"},{"id":86707,"position":7,"arabic":"لِّأَزْوَٰجِهِم","translation":"তাদের স্ত্রীদের জন্যে","audioUrl":"wbw/002_240_007.mp3","charTypeName":"word"},{"id":86708,"position":8,"arabic":"مَّتَـٰعًا","translation":"ভরণ পোষণের","audioUrl":"wbw/002_240_008.mp3","charTypeName":"word"},{"id":86709,"position":9,"arabic":"إِلَى","translation":"পর্যন্ত","audioUrl":"wbw/002_240_009.mp3","charTypeName":"word"},{"id":86710,"position":10,"arabic":"ٱ