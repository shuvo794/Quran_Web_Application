{"id":259,"ayahs":[{"number":25,"arabic":"تُؤْتِىٓ أُكُلَهَا كُلَّ حِينٍۭ بِإِذْنِ رَبِّهَا ۗ وَيَضْرِبُ ٱللَّهُ ٱلْأَمْثَالَ لِلنَّاسِ لَعَلَّهُمْ يَتَذَكَّرُونَ","translation":"yielding its fruit at all times by its Sustainer's leave. And [thus it is that] God propounds parables unto men,' so that they might bethink themselves [of the truth].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1775.mp3","surahId":14,"words":[{"id":28421,"position":1,"arabic":"تُؤْتِىٓ","translation":"দেয়","audioUrl":"wbw/014_025_001.mp3","charTypeName":"word"},{"id":28422,"position":2,"arabic":"أُكُلَهَا","translation":"তার ফল","audioUrl":"wbw/014_025_002.mp3","charTypeName":"word"},{"id":28423,"position":3,"arabic":"كُلَّ","translation":"প্রত্যেক","audioUrl":"wbw/014_025_003.mp3","charTypeName":"word"},{"id":28424,"position":4,"arabic":"حِينٍۭ","translation":"মুহূর্তে (মৌসুমে)","audioUrl":"wbw/014_025_004.mp3","charTypeName":"word"},{"id":28425,"position":5,"arabic":"بِإِذْنِ","translation":"অনুমতিক্রমে","audioUrl":"wbw/014_025_005.mp3","charTypeName":"word"},{"id":28426,"position":6,"arabic":"رَبِّهَا ۗ","translation":"রবের তার","audioUrl":"wbw/014_025_006.mp3","charTypeName":"word"},{"id":28428,"position":7,"arabic":"وَيَضْرِبُ","translation":"এবং বর্ণনা করেন","audioUrl":"wbw/014_025_008.mp3","charTypeName":"word"},{"id":28429,"position":8,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/014_025_009.mp3","charTypeName":"word"},{"id":28430,"position":9,"arabic":"ٱلْأَمْثَالَ","translation":"দৃষ্টান্তসমূহ","audioUrl":"wbw/014_025_010.mp3","charTypeName":"word"},{"id":28431,"position":10,"arabic":"لِلنَّاسِ","translation":"মানুষের জন্যে","audioUrl":"wbw/014_025_011.mp3","charTypeName":"word"},{"id":28432,"position":11,"arabic":"لَعَلَّهُمْ","translation":"তারা যাতে","audioUrl":"wbw/014_025_012.mp3","charTypeName":"word"},{"id":28433,"position":12,"arabic":"يَتَذَكَّرُونَ","translation":"শিক্ষা গ্রহণ করে","audioUrl":"wbw/014_025_013.mp3","charTypeName":"word"},{"id":28434,"position":13,"arabic":"٢٥","translation":"(২৫)","audioUrl":null,"charTypeName":"end"}]},{"number":26,"arabic":"وَمَثَلُ كَلِمَةٍ خَبِيثَةٍۢ كَشَجَرَةٍ خَبِيثَةٍ ٱجْتُثَّتْ مِن فَوْقِ ٱلْأَرْضِ مَا لَهَا مِن قَرَارٍۢ","translation":"And the parable of a corrupt word is that of a corrupt tree, torn up [from its roots] onto the face of the earth, wholly unable to endure.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1776.mp3","surahId":14,"words":[{"id":29337,"position":1,"arabic":"وَمَثَلُ","translation":"এবং উপমা","audioUrl":"wbw/014_026_001.mp3","charTypeName":"word"},{"id":29338,"position":2,"arabic":"كَلِمَةٍ","translation":"বাক্যের","audioUrl":"wbw/014_026_002.mp3","charTypeName":"word"},{"id":29339,"position":3,"arabic":"خَبِيثَةٍۢ","translation":"নোংরা (অসার)","audioUrl":"wbw/014_026_003.mp3","charTypeName":"word"},{"id":29340,"position":4,"arabic":"كَشَجَرَةٍ","translation":"মতো (তা) একটি গাছের","audioUrl":"wbw/014_026_004.mp3","charTypeName":"word"},{"id":29341,"position":5,"arabic":"خَبِيثَةٍ","translation":"নোংরা (অসার)","audioUrl":"wbw/014_026_005.mp3","charTypeName":"word"},{"id":29342,"position":6,"arabic":"ٱجْتُثَّتْ","translation":"উপড়ে নেয়া হয়েছে","audioUrl":"wbw/014_026_006.mp3","charTypeName":"word"},{"id":29343,"position":7,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/014_026_007.mp3","charTypeName":"word"},{"id":29344,"position":8,"arabic":"فَوْقِ","translation":"উপর","audioUrl":"wbw/014_026_008.mp3","charTypeName":"word"},{"id":29345,"position":9,"arabic":"ٱلْأَرْضِ","translation":"মাটির","audioUrl":"wbw/014_026_009.mp3","charTypeName":"word"},{"id":29346,"position":10,"arabic":"مَا","translation":"নেই","audioUrl":"wbw/014_026_010.mp3","charTypeName":"word"},{"id":29347,"position":11,"arabic":"لَهَا","translation":"তার জন্যে","audioUrl":"wbw/014_026_011.mp3","charTypeName":"word"},{"id":29348,"position":12,"arabic":"مِن","translation":"কোনো","audioUrl":"wbw/014_026_012.mp3","charTypeName":"word"},{"id":29349,"position":13,"arabic":"قَرَارٍۢ","translation":"স্থিতি","audioUrl":"wbw/014_026_013.mp3","charTypeName":"word"},{"id":29350,"position":14,"arabic":"٢٦","translation":"(২৬)","audioUrl":null,"charTypeName":"end"}]},{"number":27,"arabic":"يُثَبِّتُ ٱللَّهُ ٱلَّذِينَ ءَامَنُوا۟ بِٱلْقَوْلِ ٱلثَّابِتِ فِى ٱلْحَيَوٰةِ ٱلدُّنْيَا وَفِى ٱلْءَاخِرَةِ ۖ وَيُضِلُّ ٱللَّهُ ٱلظَّٰلِمِينَ ۚ وَيَفْعَلُ ٱللَّهُ مَا يَشَآءُ","translation":"[Thus,] God grants firmness unto those who have attained to faith through the word that is unshakably true in the life of this world as well as in the life to come; but the wrongdoers He lets go astray: for God does whatever He wills.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1777.mp3","surahId":14,"words":[{"id":30303,"position":1,"arabic":"يُثَبِّتُ","translation":"প্রতিষ্ঠিত করেন","audioUrl":"wbw/014_027_001.mp3","charTypeName":"word"},{"id":30304,"position":2,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/014_027_002.mp3","charTypeName":"word"},{"id":30305,"position":3,"arabic":"ٱلَّذِينَ","translation":"(তাদের) যারা","audioUrl":"wbw/014_027_003.mp3","charTypeName":"word"},{"id":30306,"position":4,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/014_027_004.mp3","charTypeName":"word"},{"id":30307,"position":5,"arabic":"بِٱلْقَوْلِ","translation":"দিয়ে বাণী","audioUrl":"wbw/014_027_005.mp3","charTypeName":"word"},{"id":30308,"position":6,"arabic":"ٱلثَّابِتِ","translation":"সুদৃঢ়","audioUrl":"wbw/014_027_006.mp3","charTypeName":"word"},{"id":30309,"position":7,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/014_027_007.mp3","charTypeName":"word"},{"id":30310,"position":8,"arabic":"ٱلْحَيَوٰةِ","translation":"জীবনের","audioUrl":"wbw/014_027_008.mp3","charTypeName":"word"},{"id":30311,"position":9,"arabic":"ٱلدُّنْيَا","translation":"পার্থিব","audioUrl":"wbw/014_027_009.mp3","charTypeName":"word"},{"id":30312,"position":10,"arabic":"وَفِى","translation":"এবং মধ্যে","audioUrl":"wbw/014_027_010.mp3","charTypeName":"word"},{"id":30313,"position":11,"arabic":"ٱلْـَٔاخِرَةِ ۖ","translation":"আখিরাতের","audioUrl":"wbw/014_027_011.mp3","charTypeName":"word"},{"id":30315,"position":12,"arabic":"وَيُضِلُّ","translation":"এবং পথভ্রষ্ট করেন","audioUrl":"wbw/014_027_013.mp3","charTypeName":"word"},{"id":30316,"position":13,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/014_027_014.mp3","charTypeName":"word"},{"id":30317,"position":14,"arabic":"ٱلظَّـٰلِمِينَ ۚ","translation":"সীমালঙ্ঘনকারীদের","audioUrl":"wbw/014_027_015.mp3","charTypeName":"word"},{"id":30319,"position":15,"arabic":"وَيَفْعَلُ","translation":"ও করেন","audioUrl":"wbw/014_027_017.mp3","charTypeName":"word"},{"id":30320,"position":16,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/014_027_018.mp3","charTypeName":"word"},{"id":30321,"position":17,"arabic":"مَا","translation":"যা","audioUrl":"wbw/014_027_019.mp3","charTypeName":"word"},{"id":30322,"position":18,"arabic":"يَشَآءُ","translation":"তিনি ইচ্ছে করেন","audioUrl":"wbw/014_027_020.mp3","charTypeName":"word"},{"id":30323,"position":19,"arabic":"٢٧","translation":"(২৭)","audioUrl":null,"charTypeName":"end"}]},{"number":28,"arabic":"۞ أَلَمْ تَرَ إِلَى ٱلَّذِينَ بَدَّلُوا۟ نِعْمَتَ ٱللَّهِ كُفْرًۭا وَأَحَلُّوا۟ قَوْمَهُمْ دَارَ ٱلْبَوَارِ","translation":"ART THOU NOT aware of those who have preferred a denial of the truth to God's blessings, and [thereby] invited their people to alight in that abode of utter desolation","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1778.mp3","surahId":14,"words":[{"id":31299,"position":1,"arabic":"۞ أَلَمْ","translation":"নি কি","audioUrl":"wbw/014_028_002.mp3","charTypeName":"word"},{"id":31300,"position":2,"arabic":"تَرَ","translation":"তুমি লক্ষ্য করো","audioUrl":"wbw/014_028_003.mp3","charTypeName":"word"},{"id":31301,"position":3,"arabic":"إِلَى","translation":"প্রতি","audioUrl":"wbw/014_028_004.mp3","charTypeName":"word"},{"id":31302,"position":4,"arabic":"ٱلَّذِينَ","translation":"(তাদের) যারা","audioUrl":"wbw/014_028_005.mp3","charTypeName":"word"},{"id":31303,"position":5,"arabic":"بَدَّلُوا۟","translation":"বদলে দিয়েছে","audioUrl":"wbw/014_028_006.mp3","charTypeName":"word"},{"id":31304,"position":6,"arabic":"نِعْمَتَ","translation":"অনুগ্রহ","audioUrl":"wbw/014_028_007.mp3","charTypeName":"word"},{"id":31305,"position":7,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/014_028_008.mp3","charTypeName":"word"},{"id":31306,"position":8,"arabic":"كُفْرًۭا","translation":"অকৃতজ্ঞতায়","audioUrl":"wbw/014_028_009.mp3","charTypeName":"word"},{"id":31307,"position":9,"arabic":"وَأَحَلُّوا۟","translation":"এবং নামিয়ে এনেছে","audioUrl":"wbw/014_028_010.mp3","charTypeName":"word"},{"id":31308,"position":10,"arabic":"قَوْمَهُمْ","translation":"তাদের জাতিকে","audioUrl":"wbw/014_028_011.mp3","charTypeName":"word"},{"id":31309,"position":11,"arabic":"دَارَ","translation":"ঘরে","audioUrl":"wbw/014_028_012.mp3","charTypeName":"word"},{"id":31310,"position":12,"arabic":"ٱلْبَوَارِ","translation":"ধ্বংসের","audioUrl":"wbw/014_028_013.mp3","charTypeName":"word"},{"id":31311,"position":13,"arabic":"٢٨","translation":"(২৮)","audioUrl":null,"charTypeName":"end"}]},{"number":29,"arabic":"جَهَنَّمَ يَصْلَوْنَهَا ۖ وَبِئْسَ ٱلْقَرَارُ","translation":"- hell - which they [themselves] will ' have to endure? And how vile a state to settle in!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1779.mp3","surahId":14,"words":[{"id":32286,"position":1,"arabic":"جَهَنَّمَ","translation":"জাহান্নামে","audioUrl":"wbw/014_029_001.mp3","charTypeName":"word"},{"id":32287,"position":2,"arabic":"يَصْلَوْنَهَا ۖ","translation":"তাতে তারা প্রবেশ করবে","audioUrl":"wbw/014_029_002.mp3","charTypeName":"word"},{"id":32289,"position":3,"arabic":"وَبِئْسَ","translation":"এবং অতি নিকৃষ্ট","audioUrl":"wbw/014_029_004.mp3","charTypeName":"word"},{"id":32290,"position":4,"arabic":"ٱلْقَرَارُ","translation":"আশ্রয়স্থল","audioUrl":"wbw/014_029_005.mp3","charTypeName":"word"},{"id":32291,"position":5,"arabic":"٢٩","translation":"(২৯)","audioUrl":null,"charTypeName":"end"}]},{"number":30,"arabic":"وَجَعَلُوا۟ لِلَّهِ أَندَادًۭا لِّيُضِلُّوا۟ عَن سَبِيلِهِۦ ۗ قُلْ تَمَتَّعُوا۟ فَإِنَّ مَصِيرَكُمْ إِلَى ٱلنَّارِ","translation":"For, they claimed that there are powers that could rival God, and so they strayed from His path. Say: \"Enjoy yourselves [in this world], but, verily, the fire will be your journey's end!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1780.mp3","surahId":14,"words":[{"id":33161,"position":1,"arabic":"وَجَعَلُوا۟","translation":"এবং তারা বানিয়েছে","audioUrl":"wbw/014_030_001.mp3","charTypeName":"word"},{"id":33162,"position":2,"arabic":"لِلَّهِ","translation":"জন্যে আল্লাহর","audioUrl":"wbw/014_030_002.mp3","charTypeName":"word"},{"id":33163,"position":3,"arabic":"أَندَادًۭا","translation":"সমকক্ষসমূহ","audioUrl":"wbw/014_030_003.mp3","charTypeName":"word"},{"id":33164,"position":4,"arabic":"لِّيُضِلُّوا۟","translation":"যেন তারা পথভ্রষ্ট করে","audioUrl":"wbw/014_030_004.mp3","charTypeName":"word"},{"id":33165,"position":5,"arabic":"عَن","translation":"হ'তে","audioUrl":"wbw/014_030_005.mp3","charTypeName":"word"},{"id":33166,"position":6,"arabic":"سَبِيلِهِۦ ۗ","translation":"তাঁর পথ (মানুষকে)","audioUrl":"wbw/014_030_006.mp3","charTypeName":"word"},{"id":33168,"position":7,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/014_030_008.mp3","charTypeName":"word"},{"id":33169,"position":8,"arabic":"تَمَتَّعُوا۟","translation":"\"তোমরা ভোগ করো","audioUrl":"wbw/014_030_009.mp3","charTypeName":"word"},{"id":33170,"position":9,"arabic":"فَإِنَّ","translation":"অতঃপর নিশ্চয়ই","audioUrl":"wbw/014_030_010.mp3","charTypeName":"word"},{"id":33171,"position":10,"arabic":"مَصِيرَكُمْ","translation":"তোমাদের ফেরার জায়গা","audioUrl":"wbw/014_030_011.mp3","charTypeName":"word"},{"id":33172,"position":11,"arabic":"إِلَى","translation":"দিকে","audioUrl":"wbw/014_030_012.mp3","charTypeName":"word"},{"id":33173,"position":12,"arabic":"ٱلنَّارِ","translation":"(জাহান্নামের) আগুনের\"","audioUrl":"wbw/014_030_013.mp3","charTypeName":"word"},{"id":33174,"position":13,"arabic":"٣٠","translation":"(৩০)","audioUrl":null,"charTypeName":"end"}]},{"number":31,"arabic":"قُل لِّعِبَادِىَ ٱلَّذِينَ ءَامَنُوا۟ يُقِيمُوا۟ ٱلصَّلَوٰةَ وَيُنفِقُوا۟ مِمَّا رَزَقْنَٰهُمْ سِرًّۭا وَعَلَانِيَةًۭ مِّن قَبْلِ أَن يَأْتِىَ يَوْمٌۭ لَّا بَيْعٌۭ فِيهِ وَلَا خِلَٰلٌ","translation":"[And] tell [those of] My servants who have attained to faith that they should be constant in prayer and spend [in Our way], secretly and openly, out of what We provide for them as sustenance, ere there come a Day when there will be no bargaining, and no mutual befriending.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1781.mp3","surahId":14,"words":[{"id":34085,"position":1,"arabic":"قُل","translation":"বলো (হে নাবী)","audioUrl":"wbw/014_031_001.mp3","charTypeName":"word"},{"id":34086,"position":2,"arabic":"لِّعِبَادِىَ","translation":"আমার দাসদেরকে","audioUrl":"wbw/014_031_002.mp3","charTypeName":"word"},{"id":34087,"position":3,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/014_031_003.mp3","charTypeName":"word"},{"id":34088,"position":4,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/014_031_004.mp3","charTypeName":"word"},{"id":34089,"position":5,"arabic":"يُقِيمُوا۟","translation":"তারা যেন প্রতিষ্ঠা করে","audioUrl":"wbw/014_031_005.mp3","charTypeName":"word"},{"id":34090,"position":6,"arabic":"ٱلصَّلَوٰةَ","translation":"সালাত","audioUrl":"wbw/014_031_006.mp3","charTypeName":"word"},{"id":34091,"position":7,"arabic":"وَيُنفِقُوا۟","translation":"ও তারা ব্যয় করে","audioUrl":"wbw/014_031_007.mp3","charTypeName":"word"},{"id":34092,"position":8,"arabic":"مِمَّا","translation":"তা হ'তে যা","audioUrl":"wbw/014_031_008.mp3","charTypeName":"word"},{"id":34093,"position":9,"arabic":"رَزَقْنَـٰهُمْ","translation":"আমরা জীবিকা দিয়েছি তাদের","audioUrl":"wbw/014_031_009.mp3","charTypeName":"word"},{"id":34094,"position":10,"arabic":"سِرًّۭا","translation":"গোপনে","audioUrl":"wbw/014_031_010.mp3","charTypeName":"word"},{"id":34095,"position":11,"arabic":"وَعَلَانِيَةًۭ","translation":"ও প্রকাশ্যে","audioUrl":"wbw/014_031_011.mp3","charTypeName":"word"},{"id":34096,"position":12,"arabic":"مِّن","translation":"থেকেই","audioUrl":"wbw/014_031_012.mp3","charTypeName":"word"},{"id":34097,"position":13,"arabic":"قَبْلِ","translation":"পূর্ব","audioUrl":"wbw/014_031_013.mp3","charTypeName":"word"},{"id":34098,"position":14,"arabic":"أَن","translation":"যে","audioUrl":"wbw/014_031_014.mp3","charTypeName":"word"},{"id":34099,"position":15,"arabic":"يَأْتِىَ","translation":"আসবে","audioUrl":"wbw/014_031_015.mp3","charTypeName":"word"},{"id":34100,"position":16,"arabic":"يَوْمٌۭ","translation":"সেদিন","audioUrl":"wbw/014_031_016.mp3","charTypeName":"word"},{"id":34101,"position":17,"arabic":"لَّا","translation":"না","audioUrl":"wbw/014_031_017.mp3","charTypeName":"word"},{"id":34102,"position":18,"arabic":"بَيْعٌۭ","translation":"কেনা-বেচা হবে","audioUrl":"wbw/014_031_018.mp3","charTypeName":"word"},{"id":34103,"position":19,"arabic":"فِيهِ","translation":"তার মধ্যে","audioUrl":"wbw/014_031_019.mp3","charTypeName":"word"},{"id":34104,"position":20,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/014_031_020.mp3","charTypeName":"word"},{"id":34105,"position":21,"arabic":"خِلَـٰلٌ","translation":"বন্ধুত্ব (কাজে আসবে)","audioUrl":"wbw/014_031_021.mp3","charTypeName":"word"},{"id":34106,"position":22,"arabic":"٣١","translation":"(৩১)","audioUrl":null,"charTypeName":"end"}]},{"number":32,"arabic":"ٱللَّهُ ٱلَّذِى خَلَقَ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضَ وَأَنزَلَ مِنَ ٱلسَّمَآءِ مَآءًۭ فَأَخْرَجَ بِهِۦ مِنَ ٱلثَّمَرَٰتِ رِزْقًۭا لَّكُمْ ۖ وَسَخَّرَ لَكُمُ ٱلْفُلْكَ لِتَجْرِىَ فِى ٱلْبَحْرِ بِأَمْرِهِۦ ۖ وَسَخَّرَ لَكُمُ ٱلْأَنْهَٰرَ","translation":"[And remember that] it is God who has created the heavens and the earth, and who sends down