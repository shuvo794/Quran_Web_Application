","charTypeName":"word"},{"id":35048,"position":14,"arabic":"رِزْقًۭا","translation":"জীবিকার জন্যে","audioUrl":"wbw/014_032_014.mp3","charTypeName":"word"},{"id":35049,"position":15,"arabic":"لَّكُمْ ۖ","translation":"তোমাদের","audioUrl":"wbw/014_032_015.mp3","charTypeName":"word"},{"id":35051,"position":16,"arabic":"وَسَخَّرَ","translation":"এবং অধীন করে দিয়েছেন","audioUrl":"wbw/014_032_017.mp3","charTypeName":"word"},{"id":35052,"position":17,"arabic":"لَكُمُ","translation":"জন্যে তোমাদের","audioUrl":"wbw/014_032_018.mp3","charTypeName":"word"},{"id":35053,"position":18,"arabic":"ٱلْفُلْكَ","translation":"নৌযান","audioUrl":"wbw/014_032_019.mp3","charTypeName":"word"},{"id":35054,"position":19,"arabic":"لِتَجْرِىَ","translation":"যেন চলাচল করে","audioUrl":"wbw/014_032_020.mp3","charTypeName":"word"},{"id":35055,"position":20,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/014_032_021.mp3","charTypeName":"word"},{"id":35056,"position":21,"arabic":"ٱلْبَحْرِ","translation":"সাগরের","audioUrl":"wbw/014_032_022.mp3","charTypeName":"word"},{"id":35057,"position":22,"arabic":"بِأَمْرِهِۦ ۖ","translation":"নির্দেশক্রমে তার","audioUrl":"wbw/014_032_023.mp3","charTypeName":"word"},{"id":35059,"position":23,"arabic":"وَسَخَّرَ","translation":"এবং অধীন করেছেন","audioUrl":"wbw/014_032_025.mp3","charTypeName":"word"},{"id":35060,"position":24,"arabic":"لَكُمُ","translation":"জন্যে তোমাদের","audioUrl":"wbw/014_032_026.mp3","charTypeName":"word"},{"id":35061,"position":25,"arabic":"ٱلْأَنْهَـٰرَ","translation":"নদীসমূহকে","audioUrl":"wbw/014_032_027.mp3","charTypeName":"word"},{"id":35062,"position":26,"arabic":"٣٢","translation":"(৩২)","audioUrl":null,"charTypeName":"end"}]},{"number":33,"arabic":"وَسَخَّرَ لَكُمُ ٱلشَّمْسَ وَٱلْقَمَرَ دَآئِبَيْنِ ۖ وَسَخَّرَ لَكُمُ ٱلَّيْلَ وَٱلنَّهَارَ","translation":"and has made the sun and the moon, both of them constant upon their courses, subservient [to His laws, so that they be of use] to you; and has made the night and the day s