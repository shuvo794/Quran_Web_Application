{"id":202,"ayahs":[{"number":94,"arabic":"يَعْتَذِرُونَ إِلَيْكُمْ إِذَا رَجَعْتُمْ إِلَيْهِمْ ۚ قُل لَّا تَعْتَذِرُوا۟ لَن نُّؤْمِنَ لَكُمْ قَدْ نَبَّأَنَا ٱللَّهُ مِنْ أَخْبَارِكُمْ ۚ وَسَيَرَى ٱللَّهُ عَمَلَكُمْ وَرَسُولُهُۥ ثُمَّ تُرَدُّونَ إِلَىٰ عَٰلِمِ ٱلْغَيْبِ وَٱلشَّهَٰدَةِ فَيُنَبِّئُكُم بِمَا كُنتُمْ تَعْمَلُونَ","translation":"[And] they will [still] be offering excuses to you when you return to them, [from the campaign]! Say: \"Do not offer [empty] excuses, [for] we shall not believe you: God has already enlightened us about you. And God will behold your [future] deeds, and [so will] His Apostle; and in the end you will be brought before Him who knows all that is beyond the reach of a created being's perception as well as all that can be witnessed by a creature's senses or mind, and then He will make you truly understand what you were doing [in life].\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1329.mp3","surahId":9,"words":[{"id":69481,"position":1,"arabic":"يَعْتَذِرُونَ","translation":"তারা অজুহাত পেশ করবে","audioUrl":"wbw/009_094_001.mp3","charTypeName":"word"},{"id":69482,"position":2,"arabic":"إِلَيْكُمْ","translation":"কাছে তোমাদের","audioUrl":"wbw/009_094_002.mp3","charTypeName":"word"},{"id":69483,"position":3,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/009_094_003.mp3","charTypeName":"word"},{"id":69484,"position":4,"arabic":"رَجَعْتُمْ","translation":"তোমরা ফিরে যাবে","audioUrl":"wbw/009_094_004.mp3","charTypeName":"word"},{"id":69485,"position":5,"arabic":"إِلَيْهِمْ ۚ","translation":"নিকট তাদের","audioUrl":"wbw/009_094_005.mp3","charTypeName":"word"},{"id":69487,"position":6,"arabic":"قُل","translation":"বলো","audioUrl":"wbw/009_094_007.mp3","charTypeName":"word"},{"id":69488,"position":7,"arabic":"لَّا","translation":"\"না","audioUrl":"wbw/009_094_008.mp3","charTypeName":"word"},{"id":69489,"position":8,"arabic":"تَعْتَذِرُوا۟","translation":"তোমরা অজুহাত পেশ করো","audioUrl":"wbw/009_094_009.mp3","charTypeName":"word"},{"id":69490,"position":9,"arabic":"لَن","translation":"কখনও না","audioUrl":"wbw/009_094_010.mp3","charTypeName":"word"},{"id":69491,"position":10,"arabic":"نُّؤْمِنَ","translation":"বিশ্বাস করব আমরা","audioUrl":"wbw/009_094_011.mp3","charTypeName":"word"},{"id":69492,"position":11,"arabic":"لَكُمْ","translation":"প্রতি তোমাদের","audioUrl":"wbw/009_094_012.mp3","charTypeName":"word"},{"id":69493,"position":12,"arabic":"قَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/009_094_013.mp3","charTypeName":"word"},{"id":69494,"position":13,"arabic":"نَبَّأَنَا","translation":"আমাদের জানিয়ে দিয়েছেন","audioUrl":"wbw/009_094_014.mp3","charTypeName":"word"},{"id":69495,"position":14,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/009_094_015.mp3","charTypeName":"word"},{"id":69496,"position":15,"arabic":"مِنْ","translation":"হতে","audioUrl":"wbw/009_094_016.mp3","charTypeName":"word"},{"id":69497,"position":16,"arabic":"أَخْبَارِكُمْ ۚ","translation":"সংবাদ তোমাদের","audioUrl":"wbw/009_094_017.mp3","charTypeName":"word"},{"id":69499,"position":17,"arabic":"وَسَيَرَى","translation":"এবং শীঘ্রই দেখবেন","audioUrl":"wbw/009_094_019.mp3","charTypeName":"word"},{"id":69500,"position":18,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/009_094_020.mp3","charTypeName":"word"},{"id":69501,"position":19,"arabic":"عَمَلَكُمْ","translation":"কাজকর্ম তোমাদের","audioUrl":"wbw/009_094_021.mp3","charTypeName":"word"},{"id":69502,"position":20,"arabic":"وَرَسُولُهُۥ","translation":"ও রাসূল তাঁর","audioUrl":"wbw/009_094_022.mp3","charTypeName":"word"},{"id":69503,"position":21,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/009_094_023.mp3","charTypeName":"word"},{"id":69504,"position":22,"arabic":"تُرَدُّونَ","translation":"প্রত্যাবর্তিত হবে তোমরা","audioUrl":"wbw/009_094_024.mp3","charTypeName":"word"},{"id":69505,"position":23,"arabic":"إِلَىٰ","translation":"(তাঁর) দিকে","audioUrl":"wbw/009_094_025.mp3","charTypeName":"word"},{"id":69506,"position":24,"arabic":"عَـٰلِمِ","translation":"(যিনি) খুব অবহিত","audioUrl":"wbw/009_094_026.mp3","charTypeName":"word"},{"id":69507,"position":25,"arabic":"ٱلْغَيْبِ","translation":"অদৃশ্যের","audioUrl":"wbw/009_094_027.mp3","charTypeName":"word"},{"id":69508,"position":26,"arabic":"وَٱلشَّهَـٰدَةِ","translation":"ও দৃশ্যের","audioUrl":"wbw/009_094_028.mp3","charTypeName":"word"},{"id":69509,"position":27,"arabic":"فَيُنَبِّئُكُم","translation":"তখন জানিয়ে দিবেন তোমাদের","audioUrl":"wbw/009_094_029.mp3","charTypeName":"word"},{"id":69510,"position":28,"arabic":"بِمَا","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/009_094_030.mp3","charTypeName":"word"},{"id":69511,"position":29,"arabic":"كُنتُمْ","translation":"তোমরা ছিলে","audioUrl":"wbw/009_094_031.mp3","charTypeName":"word"},{"id":69512,"position":30,"arabic":"تَعْمَلُونَ","translation":"কাজ করতে","audioUrl":"wbw/009_094_032.mp3","charTypeName":"word"},{"id":69513,"position":31,"arabic":"٩٤","translation":"(৯৪)","audioUrl":null,"charTypeName":"end"}]},{"number":95,"arabic":"سَيَحْلِفُونَ بِٱللَّهِ لَكُمْ إِذَا ٱنقَلَبْتُمْ إِلَيْهِمْ لِتُعْرِضُوا۟ عَنْهُمْ ۖ فَأَعْرِضُوا۟ عَنْهُمْ ۖ إِنَّهُمْ رِجْسٌۭ ۖ وَمَأْوَىٰهُمْ جَهَنَّمُ جَزَآءًۢ بِمَا كَانُوا۟ يَكْسِبُونَ","translation":"When you will have returned to them, (O believers,] they will swear to you by God, [repeating their excuses,] with a view to your letting them be. Let them be, then: behold, they are loathsome, and hell is their goal in recompense for what they were wont to do.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1330.mp3","surahId":9,"words":[{"id":69794,"position":1,"arabic":"سَيَحْلِفُونَ","translation":"শীঘ্রই তারা শপথ করে বলবে","audioUrl":"wbw/009_095_001.mp3","charTypeName":"word"},{"id":69795,"position":2,"arabic":"بِٱللَّهِ","translation":"নামে আল্লাহর","audioUrl":"wbw/009_095_002.mp3","charTypeName":"word"},{"id":69796,"position":3,"arabic":"لَكُمْ","translation":"উদ্দেশ্যে তোমাদের","audioUrl":"wbw/009_095_003.mp3","charTypeName":"word"},{"id":69797,"position":4,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/009_095_004.mp3","charTypeName":"word"},{"id":69798,"position":5,"arabic":"ٱنقَلَبْتُمْ","translation":"ফিরে যাবে তোমরা","audioUrl":"wbw/009_095_005.mp3","charTypeName":"word"},{"id":69799,"position":6,"arabic":"إِلَيْهِمْ","translation":"দিকে তাদের","audioUrl":"wbw/009_095_006.mp3","charTypeName":"word"},{"id":69800,"position":7,"arabic":"لِتُعْرِضُوا۟","translation":"যেন তোমরা উপেক্ষা করো","audioUrl":"wbw/009_095_007.mp3","charTypeName":"word"},{"id":69801,"position":8,"arabic":"عَنْهُمْ ۖ","translation":"ব্যাপারে তাদের","audioUrl":"wbw/009_095_008.mp3","charTypeName":"word"},{"id":69803,"position":9,"arabic":"فَأَعْرِضُوا۟","translation":"তাই তোমরা উপেক্ষা করো","audioUrl":"wbw/009_095_010.mp3","charTypeName":"word"},{"id":69804,"position":10,"arabic":"عَنْهُمْ ۖ","translation":"ব্যাপারে তাদের","audioUrl":"wbw/009_095_011.mp3","charTypeName":"word"},{"id":69806,"position":11,"arabic":"إِنَّهُمْ","translation":"নিশ্চয়ই তারা","audioUrl":"wbw/009_095_013.mp3","charTypeName":"word"},{"id":69807,"position":12,"arabic":"رِجْسٌۭ ۖ","translation":"অপবিত্র","audioUrl":"wbw/009_095_014.mp3","charTypeName":"word"},{"id":69809,"position":13,"arabic":"وَمَأْوَىٰهُمْ","translation":"এবং আবাসস্থল তাদের","audioUrl":"wbw/009_095_016.mp3","charTypeName":"word"},{"id":69810,"position":14,"arabic":"جَهَنَّمُ","translation":"জাহান্নাম","audioUrl":"wbw/009_095_017.mp3","charTypeName":"word"},{"id":69811,"position":15,"arabic":"جَزَآءًۢ","translation":"প্রতিফল (স্বরূপ)","audioUrl":"wbw/009_095_018.mp3","charTypeName":"word"},{"id":69812,"position":16,"arabic":"بِمَا","translation":"ঐ বিষয়ের যা","audioUrl":"wbw/009_095_019.mp3","charTypeName":"word"},{"id":69813,"position":17,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/009_095_020.mp3","charTypeName":"word"},{"id":69814,"position":18,"arabic":"يَكْسِبُونَ","translation":"তারা উপার্জন করে আসতে","audioUrl":"wbw/009_095_021.mp3","charTypeName":"word"},{"id":69815,"position":19,"arabic":"٩٥","translation":"(৯৫)","audioUrl":null,"charTypeName":"end"}]},{"number":96,"arabic":"يَحْلِفُونَ لَكُمْ لِتَرْضَوْا۟ عَنْهُمْ ۖ فَإِن تَرْضَوْا۟ عَنْهُمْ فَإِنَّ ٱللَّهَ لَا يَرْضَىٰ عَنِ ٱلْقَوْمِ ٱلْفَٰسِقِينَ","translation":"They will swear to you with a view to making you pleased with them: but [even] should you be pleased with them, verily, God shall never be pleased with iniquitous folk.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1331.mp3","surahId":9,"words":[{"id":70110,"position":1,"arabic":"يَحْلِفُونَ","translation":"শপথ করে তারা বলবে","audioUrl":"wbw/009_096_001.mp3","charTypeName":"word"},{"id":70111,"position":2,"arabic":"لَكُمْ","translation":"উদ্দেশ্যে তোমাদের","audioUrl":"wbw/009_096_002.mp3","charTypeName":"word"},{"id":70112,"position":3,"arabic":"لِتَرْضَوْا۟","translation":"যেন তোমরা সন্তুষ্ট হও","audioUrl":"wbw/009_096_003.mp3","charTypeName":"word"},{"id":70113,"position":4,"arabic":"عَنْهُمْ ۖ","translation":"ব্যাপারে তাদের","audioUrl":"wbw/009_096_004.mp3","charTypeName":"word"},{"id":70115,"position":5,"arabic":"فَإِن","translation":"অতঃপর যদি","audioUrl":"wbw/009_096_006.mp3","charTypeName":"word"},{"id":70116,"position":6,"arabic":"تَرْضَوْا۟","translation":"তোমরা সন্তুষ্ট হও","audioUrl":"wbw/009_096_007.mp3","charTypeName":"word"},{"id":70117,"position":7,"arabic":"عَنْهُمْ","translation":"ব্যাপারে তাদের","audioUrl":"wbw/009_096_008.mp3","charTypeName":"word"},{"id":70118,"position":8,"arabic":"فَإِنَّ","translation":"তবে নিশ্চয়ই","audioUrl":"wbw/009_096_009.mp3","charTypeName":"word"},{"id":70119,"position":9,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/009_096_010.mp3","charTypeName":"word"},{"id":70120,"position":10,"arabic":"لَا","translation":"না","audioUrl":"wbw/009_096_011.mp3","charTypeName":"word"},{"id":70121,"position":11,"arabic":"يَرْضَىٰ","translation":"সন্তুষ্ট হন","audioUrl":"wbw/009_096_012.mp3","charTypeName":"word"},{"id":70122,"position":12,"arabic":"عَنِ","translation":"হতে","audioUrl":"wbw/009_096_013.mp3","charTypeName":"word"},{"id":70123,"position":13,"arabic":"ٱلْقَوْمِ","translation":"(এমন)সম্প্রদায়","audioUrl":"wbw/009_096_014.mp3","charTypeName":"word"},{"id":70124,"position":14,"arabic":"ٱلْفَـٰسِقِينَ","translation":"(যারা)সত্যত্যাগী","audioUrl":"wbw/009_096_015.mp3","charTypeName":"word"},{"id":70125,"position":15,"arabic":"٩٦","translation":"(৯৬)","audioUrl":null,"charTypeName":"end"}]},{"number":97,"arabic":"ٱلْأَعْرَابُ أَشَدُّ كُفْرًۭا وَنِفَاقًۭا وَأَجْدَرُ أَلَّا يَعْلَمُوا۟ حُدُودَ مَآ أَنزَلَ ٱللَّهُ عَلَىٰ رَسُولِهِۦ ۗ وَٱللَّهُ عَلِيمٌ حَكِيمٌۭ","translation":"[The hypocrites among] the bedouin are more tenacious in [their] refusal to acknowledge the truth and in [their] hypocrisy [than are settled people], and more liable to ignore the ordinances which God has bestowed from on high upon His Apostle - but God is all-knowing, wise.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1332.mp3","surahId":9,"words":[{"id":70257,"position":1,"arabic":"ٱلْأَعْرَابُ","translation":"বেদুঈনরা","audioUrl":"wbw/009_097_001.mp3","charTypeName":"word"},{"id":70258,"position":2,"arabic":"أَشَدُّ","translation":"কঠোরতর","audioUrl":"wbw/009_097_002.mp3","charTypeName":"word"},{"id":70259,"position":3,"arabic":"كُفْرًۭا","translation":"অবিশ্বাসে","audioUrl":"wbw/009_097_003.mp3","charTypeName":"word"},{"id":70260,"position":4,"arabic":"وَنِفَاقًۭا","translation":"ও কপটতায়","audioUrl":"wbw/009_097_004.mp3","charTypeName":"word"},{"id":70261,"position":5,"arabic":"وَأَجْدَرُ","translation":"এবং বেশি উপযুক্ত","audioUrl":"wbw/009_097_005.mp3","charTypeName":"word"},{"id":70262,"position":6,"arabic":"أَلَّا","translation":"যে না","audioUrl":"wbw/009_097_006.mp3","charTypeName":"word"},{"id":70263,"position":7,"arabic":"يَعْلَمُوا۟","translation":"তারা জানবে","audioUrl":"wbw/009_097_007.mp3","charTypeName":"word"},{"id":70264,"position":8,"arabic":"حُدُودَ","translation":"সীমারেখা","audioUrl":"wbw/009_097_008.mp3","charTypeName":"word"},{"id":70265,"position":9,"arabic":"مَآ","translation":"যা","audioUrl":"wbw/009_097_009.mp3","charTypeName":"word"},{"id":70266,"position":10,"arabic":"أَنزَلَ","translation":"অবতীর্ণ করেছেন","audioUrl":"wbw/009_097_010.mp3","charTypeName":"word"},{"id":70267,"position":11,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/009_097_011.mp3","charTypeName":"word"},{"id":70268,"position":12,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/009_097_012.mp3","charTypeName":"word"},{"id":70269,"position":13,"arabic":"رَسُولِهِۦ ۗ","translation":"রাসূলের তাঁর","audioUrl":"wbw/009_097_013.mp3","charTypeName":"word"},{"id":70271,"position":14,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/009_097_015.mp3","charTypeName":"word"},{"id":70272,"position":15,"arabic":"عَلِيمٌ","translation":"মহাজ্ঞানী","audioUrl":"wbw/009_097_016.mp3","charTypeName":"word"},{"id":70273,"position":16,"arabic":"حَكِيمٌۭ","translation":"মহাবিজ্ঞ","audioUrl":"wbw/009_097_017.mp3","charTypeName":"word"},{"id":70274,"position":17,"arabic":"٩٧","translation":"(৯৭)","audioUrl":null,"charTypeName":"end"}]},{"number":98,"arabic":"وَمِنَ ٱلْأَعْرَابِ مَن يَتَّخِذُ مَا يُنفِقُ مَغْرَمًۭا وَيَتَرَبَّصُ بِكُمُ ٱلدَّوَآئِرَ ۚ عَلَيْهِمْ دَآئِرَةُ ٱلسَّوْءِ ۗ وَٱللَّهُ سَمِيعٌ عَلِيمٌۭ","translation":"And among the bedouin there are such as regard all that they might spend [in God's cause] as a loss, and wait for misfortune to encompass you, [O believers: but] it is they whom evil fortune shall encompass - for God is all-hearing, all-knowing.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1333.mp3","surahId":9,"words":[{"id":70701,"position":1,"arabic":"وَمِنَ","translation":"এবং মধ্য থেকে","audioUrl":"wbw/009_098_001.mp3","charTypeName":"word"},{"id":70702,"position":2,"arabic":"ٱلْأَعْرَابِ","translation":"বেদুঈনদের","audioUrl":"wbw/009_098_002.mp3","charTypeName":"word"},{"id":70703,"position":3,"arabic":"مَن","translation":"কেউ কেউ","audioUrl":"wbw/009_098_003.mp3","charTypeName":"word"},{"id":70704,"position":4,"arabic":"يَتَّخِذُ","translation":"মনর করে","audioUrl":"wbw/009_098_004.mp3","charTypeName":"word"},{"id":70705,"position":5,"arabic":"مَا","translation":"যা","audioUrl":"wbw/009_098_005.mp3","charTypeName":"word"},{"id":70706,"position":6,"arabic":"يُنفِقُ","translation":"ব্যয় করে (আল্লাহর পথে)","audioUrl":"wbw/009_098_006.mp3","charTypeName":"word"},{"id":70707,"position":7,"arabic":"مَغْرَمًۭا","translation":"জরিমানাস্বরূপ","audioUrl":"wbw/009_098_007.mp3","charTypeName":"word"},{"id":70708,"position":8,"arabic":"وَيَتَرَبَّصُ","translation":"ও অপেক্ষা করে","audioUrl":"wbw/009_098_008.mp3","charTypeName":"word"},{"id":70709,"position":9,"arabic":"بِكُمُ","translation":"জন্যে তোমাদের","audioUrl":"wbw/009_098_009.mp3","charTypeName":"word"},{"id":70710,"position":10,"arabic":"ٱلدَّوَآئِرَ ۚ","translation":"ভাগ্যচক্রের পরিবর্তনের (অর্থাৎ অমঙ্গলের)","audioUrl":"wbw/009_098_010.mp3","charTypeName":"word"},{"id":70712,"position":11,"arabic":"عَلَيْهِمْ","translation":"তাদের  উপর (আসছে)","audioUrl":"wbw/009_098_012.mp3","charTypeName":"word"},{"id":70713,"position":12,"arabic":"دَآئِرَةُ","translation":"ভাগ্য বিপর্যয়","audioUrl":"wbw/009_098_013.mp3","charTypeName":"word"},{"id":70714,"position":13,"arabic":"ٱلسَّوْءِ ۗ","translation":"খারাপ","audioUrl":"wbw/009_098_014.mp3","charTypeName":"word"},{"id":70716,"position":14,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/009_098_016.mp3","charTypeName":"word"},{"id":70717,"position":15,"arabic":"سَمِيعٌ","translation":"সবকিছু শুনেন","audioUrl":"wbw/009_098_017.mp3","charTypeName":"word"},{"id":70718,"position":16,"arabic":"عَلِيمٌۭ","translation":"সবকিছু জানেন","audioUrl":"wbw/009_098_018.mp3","charTypeName":"word"},{"id":70719,"position":17,"arabic":"٩٨","translation":"(৯৮)","audioUrl":null,"charTypeName":"end"}]},{"number":99,"arabic":"وَمِنَ ٱلْأَعْرَابِ مَن يُؤْمِنُ بِٱللَّهِ وَٱلْيَوْمِ ٱلْءَاخِرِ وَيَتَّخِذُ مَا يُنفِقُ قُرُبَٰتٍ عِندَ ٱللَّهِ وَصَلَوَٰتِ ٱلرَّسُولِ ۚ أَلَآ إِنَّهَا قُرْبَةٌۭ لَّهُمْ ۚ سَيُدْخِلُهُمُ ٱللَّهُ فِى رَحْمَتِهِۦٓ ۗ إِنَّ ٱللَّهَ غَفُورٌۭ رَّحِيمٌۭ","translation":"However, among the bedouin there are [also] such as believe in God and the Last Day, and regard all that they spend (in God's cause] as a means of drawing them nearer to God and of [their being remembered in] the. Apostle's prayers. Oh, verily, it shall [indeed] be a means of [God's] nearness to them, [for] God will admit them unto His grace: verily, God is much-forgiving, a dispenser of grace!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1334.mp3","surahId":9,"words":[{"id":71105,"position":1,"arabic":"وَمِنَ","translation":"এবং মধ্য হতে","audioUrl":"wbw/009_099_001.mp3","charTypeName":"word"},{"id":71106,"position":2,"arabic":"ٱلْأَعْرَابِ","translation":"বেদুঈনদের","audioUrl":"wbw/009_099_002.mp3","charTypeName":"word"},{"id":71107,"position":3,"arabic":"مَن","translation":"কেউ কেউ","audioUrl":"wbw/009_099_003.mp3","charTypeName":"word"},{"id":71108,"position":4,"arabic":"يُؤْمِنُ","translation":"বিশ্বাস করে","audioUrl":"wbw/009_099_004.mp3","charTypeName":"word"},{"id":71109,"position":5,"arabic":"بِٱللَّهِ","translation":"উপর আল্লাহর","audioUrl":"wbw/009_099_005.mp3","charTypeName":"word"},{"id":71110,"position":6,"arabic":"وَٱلْيَوْمِ","translation":"এবং দিনে","audioUrl":"wbw/009_099_006.mp3","charTypeName":"word"},{"id":71111,"position":7,"arabic":"ٱلْـَٔاخِرِ","translation":"আখেরাতের","audioUrl":"wbw/009_099_007.mp3","charTypeName":"word"},{"id":71112,"position":8,"arabic":"وَيَتَّخِذُ","translation":"ও মনে করে","audioUrl":"wbw/009_099_008.mp3","charTypeName":"word"},{"id":71113,"position":9,"arabic":"مَا","translation":"যা","audioUrl":"wbw/009_099_009.mp3","charTypeName":"word"},{"id":71114,"position":10,"arabic":"يُنفِقُ","translation":"ব্যয় করে (আল্লাহর পথে)","audioUrl":"wbw/009_099_010.mp3","charTypeName":"word"},{"id":71115,"po