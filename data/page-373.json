,"arabic":"وَمَا","translation":"আর না","audioUrl":"wbw/026_158_009.mp3","charTypeName":"word"},{"id":81525,"position":8,"arabic":"كَانَ","translation":"ছিলো","audioUrl":"wbw/026_158_010.mp3","charTypeName":"word"},{"id":81526,"position":9,"arabic":"أَكْثَرُهُم","translation":"অধিকাংশ তাদের","audioUrl":"wbw/026_158_011.mp3","charTypeName":"word"},{"id":81527,"position":10,"arabic":"مُّؤْمِنِينَ","translation":"মু'মিন","audioUrl":"wbw/026_158_012.mp3","charTypeName":"word"},{"id":81528,"position":11,"arabic":"١٥٨","translation":"(১৫৮)","audioUrl":null,"charTypeName":"end"}]},{"number":159,"arabic":"وَإِنَّ رَبَّكَ لَهُوَ ٱلْعَزِيزُ ٱلرَّحِيمُ","translation":"But, verily, thy Sustainer - He alone – is almighty, a dispenser of grace!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3091.mp3","surahId":26,"words":[{"id":81679,"position":1,"arabic":"وَإِنَّ","translation":"অথচ নিশ্চয়ই","audioUrl":"wbw/026_159_001.mp3","charTypeName":"word"},{"id":81680,"position":2,"arabic":"رَبَّكَ","translation":"তোমার রব","audioUrl":"wbw/026_159_002.mp3","charTypeName":"word"},{"id":81681,"position":3,"arabic":"لَهُوَ","translation":"অবশ্যই তিনি","audioUrl":"wbw/026_159_003.mp3","charTypeName":"word"},{"id":81682,"position":4,"arabic":"ٱلْعَزِيزُ","translation":"পরাক্রমশালী","audioUrl":"wbw/026_159_004.mp3","charTypeName":"word"},{"id":81683,"position":5,"arabic":"ٱلرَّحِيمُ","translation":"পরম দয়ালু","audioUrl":"wbw/026_159_005.mp3","charTypeName":"word"},{"id":81684,"position":6,"arabic":"١٥٩","translation":"(১৫৯)","audioUrl":null,"charTypeName":"end"}]}]}