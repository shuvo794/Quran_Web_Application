{"id":373,"ayahs":[{"number":137,"arabic":"إِنْ هَٰذَآ إِلَّا خُلُقُ ٱلْأَوَّلِينَ","translation":"This [religion of ours] is none other than that to which our forebears clung,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3069.mp3","surahId":26,"words":[{"id":78793,"position":1,"arabic":"إِنْ","translation":"নয়","audioUrl":"wbw/026_137_001.mp3","charTypeName":"word"},{"id":78794,"position":2,"arabic":"هَـٰذَآ","translation":"এটা","audioUrl":"wbw/026_137_002.mp3","charTypeName":"word"},{"id":78795,"position":3,"arabic":"إِلَّا","translation":"এ ছাড়া যে","audioUrl":"wbw/026_137_003.mp3","charTypeName":"word"},{"id":78796,"position":4,"arabic":"خُلُقُ","translation":"স্বভাব","audioUrl":"wbw/026_137_004.mp3","charTypeName":"word"},{"id":78797,"position":5,"arabic":"ٱلْأَوَّلِينَ","translation":"পুর্ববর্তীদের","audioUrl":"wbw/026_137_005.mp3","charTypeName":"word"},{"id":78798,"position":6,"arabic":"١٣٧","translation":"(১৩৭)","audioUrl":null,"charTypeName":"end"}]},{"number":138,"arabic":"وَمَا نَحْنُ بِمُعَذَّبِينَ","translation":"and we are not going to be chastised [for adhering to it]!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3070.mp3","surahId":26,"words":[{"id":78888,"position":1,"arabic":"وَمَا","translation":"আর না","audioUrl":"wbw/026_138_001.mp3","charTypeName":"word"},{"id":78889,"position":2,"arabic":"نَحْنُ","translation":"আমরা","audioUrl":"wbw/026_138_002.mp3","charTypeName":"word"},{"id":78890,"position":3,"arabic":"بِمُعَذَّبِينَ","translation":"শাস্তিপ্রাপ্ত হবো\"","audioUrl":"wbw/026_138_003.mp3","charTypeName":"word"},{"id":78891,"position":4,"arabic":"١٣٨","translation":"(১৩৮)","audioUrl":null,"charTypeName":"end"}]},{"number":139,"arabic":"فَكَذَّبُوهُ فَأَهْلَكْنَٰهُمْ ۗ إِنَّ فِى ذَٰلِكَ لَءَايَةًۭ ۖ وَمَا كَانَ أَكْثَرُهُم مُّؤْمِنِينَ","translation":"And so they gave him the lie: and thereupon We destroyed them. In this [story], behold, there is a message [unto men], even though most of them will not believe [in it].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3071.mp3","surahId":26,"words":[{"id":78994,"position":1,"arabic":"فَكَذَّبُوهُ","translation":"তারা তাকে মিথ্যা সাব্যস্ত করলো","audioUrl":"wbw/026_139_001.mp3","charTypeName":"word"},{"id":78995,"position":2,"arabic":"فَأَهْلَكْنَـٰهُمْ ۗ","translation":"তখন আমরা ধ্বংস করলাম তাদেরকে","audioUrl":"wbw/026_139_002.mp3","charTypeName":"word"},{"id":78997,"position":3,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/026_139_004.mp3","charTypeName":"word"},{"id":78998,"position":4,"arabic":"فِى","translation":"মধ্যে (আছে)","audioUrl":"wbw/026_139_005.mp3","charTypeName":"word"},{"id":78999,"position":5,"arabic":"ذَٰلِكَ","translation":"এর","audioUrl":"wbw/026_139_006.mp3","charTypeName":"word"},{"id":79000,"position":6,"arabic":"لَـَٔايَةًۭ ۖ","translation":"অবশ্যই নিদর্শন","audioUrl":"wbw/026_139_007.mp3","charTypeName":"word"},{"id":79002,"position":7,"arabic":"وَمَا","translation":"কিন্তু না","audioUrl":"wbw/026_139_009.mp3","charTypeName":"word"},{"id":79003,"position":8,"arabic":"كَانَ","translation":"ছিলো","audioUrl":"wbw/026_139_010.mp3","charTypeName":"word"},{"id":79004,"position":9,"arabic":"أَكْثَرُهُم","translation":"অধিকাংশ তাদের","audioUrl":"wbw/026_139_011.mp3","charTypeName":"word"},{"id":79005,"position":10,"arabic":"مُّؤْمِنِينَ","translation":"মু'মিন","audioUrl":"wbw/026_139_012.mp3","charTypeName":"word"},{"id":79006,"position":11,"arabic":"١٣٩","translation":"(১৩৯)","audioUrl":null,"charTypeName":"end"}]},{"number":140,"arabic":"وَإِنَّ رَبَّكَ لَهُوَ ٱلْعَزِيزُ ٱلرَّحِيمُ","translation":"But, verily, thy Sustainer - He alone - is almighty, a dispenser of grace!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3072.mp3","surahId":26,"words":[{"id":79082,"position":1,"arabic":"وَإِنَّ","translation":"আর নিশ্চয়ই","audioUrl":"wbw/026_140_001.mp3","charTypeName":"word"},{"id":79083,"position":2,"arabic":"رَبَّكَ","translation":"তোমার রব","audioUr