","charTypeName":"word"},{"id":79705,"position":4,"arabic":"١٤٤","translation":"(১৪৪)","audioUrl":null,"charTypeName":"end"}]},{"number":145,"arabic":"وَمَآ أَسْـَٔلُكُمْ عَلَيْهِ مِنْ أَجْرٍ ۖ إِنْ أَجْرِىَ إِلَّا عَلَىٰ رَبِّ ٱلْعَٰلَمِينَ","translation":"“And no reward whatever do I ask of you for it: my reward rests with none but the Sustainer of all the worlds.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3077.mp3","surahId":26,"words":[{"id":79767,"position":1,"arabic":"وَمَآ","translation":"এবং না","audioUrl":"wbw/026_145_001.mp3","charTypeName":"word"},{"id":79768,"position":2,"arabic":"أَسْـَٔلُكُمْ","translation":"তোমাদের (নিকট) আমি চাচ্ছি","audioUrl":"wbw/026_145_002.mp3","charTypeName":"word"},{"id":79769,"position":3,"arabic":"عَلَيْهِ","translation":"জন্যে এর","audioUrl":"wbw/026_145_003.mp3","charTypeName":"word"},{"id":79770,"position":4,"arabic":"مِنْ","translation":"কোনো","audioUrl":"wbw/026_145_004.mp3","charTypeName":"word"},{"id":79771,"position":5,"arabic":"أَجْرٍ ۖ","translation":"প্রতিদান","audioUrl":"wbw/026_145_005.mp3","charTypeName":"word"},{"id":79773,"position":6,"arabic":"إِنْ","translation":"নয়","audioUrl":"wbw/026_145_007.mp3","charTypeName":"word"},{"id":79774,"position":7,"arabic":"أَجْرِىَ","translation":"আমার প্রতিদান (অন্য কারো নিকট)","audioUrl":"wbw/026_145_008.mp3","charTypeName":"word"},{"id":79775,"position":8,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/026_145_009.mp3","charTypeName":"word"},{"id":79776,"position":9,"arabic":"عَلَىٰ","translation":"নিকট","audioUrl":"wbw/026_145_010.mp3","charTypeName":"word"},{"id":79777,"position":10,"arabic":"رَبِّ","translation":"রবের","audioUrl":"wbw/026_145_011.mp3","charTypeName":"word"},{"id":79778,"position":11,"arabic":"ٱلْعَـٰلَمِينَ","translation":"বিশ্বজগতের","audioUrl":"wbw/026_145_012.mp3","charTypeName":"word"},{"id":79779,"position":12,"arabic":"١٤٥","translation":"(১৪৫)","audioUrl":null,"charTypeName":"end"}]},{"number":146,"arabic":"أَتُ