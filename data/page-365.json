{"id":365,"ayahs":[{"number":56,"arabic":"وَمَآ أَرْسَلْنَٰكَ إِلَّا مُبَشِّرًۭا وَنَذِيرًۭا","translation":"Yet [withal, O Prophet,] We have sent thee only as a herald of glad tidings and a warner.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2911.mp3","surahId":25,"words":[{"id":52176,"position":1,"arabic":"وَمَآ","translation":"এবং না","audioUrl":"wbw/025_056_001.mp3","charTypeName":"word"},{"id":52177,"position":2,"arabic":"أَرْسَلْنَـٰكَ","translation":"তোমাকে আমরা পাঠিয়েছি","audioUrl":"wbw/025_056_002.mp3","charTypeName":"word"},{"id":52178,"position":3,"arabic":"إِلَّا","translation":"এ ছাড়া যে","audioUrl":"wbw/025_056_003.mp3","charTypeName":"word"},{"id":52179,"position":4,"arabic":"مُبَشِّرًۭا","translation":"সুসংবাদদাতা","audioUrl":"wbw/025_056_004.mp3","charTypeName":"word"},{"id":52180,"position":5,"arabic":"وَنَذِيرًۭا","translation":"ও সতর্ক কারী রূপে","audioUrl":"wbw/025_056_005.mp3","charTypeName":"word"},{"id":52181,"position":6,"arabic":"٥٦","translation":"(৫৬)","audioUrl":null,"charTypeName":"end"}]},{"number":57,"arabic":"قُلْ مَآ أَسْـَٔلُكُمْ عَلَيْهِ مِنْ أَجْرٍ إِلَّا مَن شَآءَ أَن يَتَّخِذَ إِلَىٰ رَبِّهِۦ سَبِيلًۭا","translation":"Say: “For this, no reward do I ask of you [- no reward] other than that he who so wills may unto his Sustainer find a way!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2912.mp3","surahId":25,"words":[{"id":53014,"position":1,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/025_057_001.mp3","charTypeName":"word"},{"id":53015,"position":2,"arabic":"مَآ","translation":"\"না","audioUrl":"wbw/025_057_002.mp3","charTypeName":"word"},{"id":53016,"position":3,"arabic":"أَسْـَٔلُكُمْ","translation":"তোমাদের (নিকট) চাচ্ছি আমি","audioUrl":"wbw/025_057_003.mp3","charTypeName":"word"},{"id":53017,"position":4,"arabic":"عَلَيْهِ","translation":"এর জন্য","audioUrl":"wbw/025_057_004.mp3","charTypeName":"word"},{"id":53018,"position":5,"arabic":"مِنْ","translation":"কোন","audioUrl":"wbw/025_057_005.mp3","charTypeName":"word"},{"id":53019,"position":6,"arabic":"أَجْرٍ","translation":"প্রতিদান","audioUrl":"wbw/025_057_006.mp3","charTypeName":"word"},{"id":53020,"position":7,"arabic":"إِلَّا","translation":"তবে (এতটুকু)","audioUrl":"wbw/025_057_007.mp3","charTypeName":"word"},{"id":53021,"position":8,"arabic":"مَن","translation":"যে","audioUrl":"wbw/025_057_008.mp3","charTypeName":"word"},{"id":53022,"position":9,"arabic":"شَآءَ","translation":"ইচ্ছে করে","audioUrl":"wbw/025_057_009.mp3","charTypeName":"word"},{"id":53023,"position":10,"arabic":"أَن","translation":"যে","audioUrl":"wbw/025_057_010.mp3","charTypeName":"word"},{"id":53024,"position":11,"arabic":"يَتَّخِذَ","translation":"সে গ্রহণ করবে","audioUrl":"wbw/025_057_011.mp3","charTypeName":"word"},{"id":53025,"position":12,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/025_057_012.mp3","charTypeName":"word"},{"id":53026,"position":13,"arabic":"رَبِّهِۦ","translation":"তার রবের","audioUrl":"wbw/025_057_013.mp3","charTypeName":"word"},{"id":53027,"position":14,"arabic":"سَبِيلًۭا","translation":"পথ\"","audioUrl":"wbw/025_057_014.mp3","charTypeName":"word"},{"id":53028,"position":15,"arabic":"٥٧","translation":"(৫৭)","audioUrl":null,"charTypeName":"end"}]},{"number":58,"arabic":"وَتَوَكَّلْ عَلَى ٱلْحَىِّ ٱلَّذِى لَا يَمُوتُ وَسَبِّحْ بِحَمْدِهِۦ ۚ وَكَفَىٰ بِهِۦ بِذُنُوبِ عِبَادِهِۦ خَبِيرًا","translation":"Hence, place thy trust in the Living One who dies not, and extol His limitless glory and praise: for none is as aware as His creatures’ sins as He –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2913.mp3","surahId":25,"words":[{"id":53231,"position":1,"arabic":"وَتَوَكَّلْ","translation":"এবং নির্ভর করো","audioUrl":"wbw/025_058_001.mp3","charTypeName":"word"},{"id":53232,"position":2,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/025_058_002.mp3","charTypeName":"word"},{"id":53233,"position":3,"arabic":"ٱلْحَىِّ","translation":"চিরঞ্জীব (আল্লাহর)","audioUrl":"wbw/025_058_003.mp3","charTypeName":"word"},{"id":53234,"position":4,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/025_058_004.mp3","charTypeName":"word"},{"id":53235,"position":5,"arabic":"لَا","translation":"না","audioUrl":"wbw/025_058_005.mp3","charTypeName":"word"},{"id":53236,"position":6,"arabic":"يَمُوتُ","translation":"মরবেন (কখনও)","audioUrl":"wbw/025_058_006.mp3","charTypeName":"word"},{"id":53237,"position":7,"arabic":"وَسَبِّحْ","translation":"ও পবিত্রতা ঘোষণা করো","audioUrl":"wbw/025_058_007.mp3","charTypeName":"word"},{"id":53238,"position":8,"arabic":"بِحَمْدِهِۦ ۚ","translation":"তাঁর প্রশংসাসহ","audioUrl":"wbw/025_058_008.mp3","charTypeName":"word"},{"id":53240,"position":9,"arabic":"وَكَفَىٰ","translation":"আর যথেষ্ট","audioUrl":"wbw/025_058_010.mp3","charTypeName":"word"},{"id":53241,"position":10,"arabic":"بِهِۦ","translation":"এ ব্যাপারে","audioUrl":"wbw/025_058_011.mp3","charTypeName":"word"},{"id":53242,"position":11,"arabic":"بِذُنُوبِ","translation":"সম্পর্কে পাপ","audioUrl":"wbw/025_058_012.mp3","charTypeName":"word"},{"id":53243,"position":12,"arabic":"عِبَادِهِۦ","translation":"তাঁর দাসদের","audioUrl":"wbw/025_058_013.mp3","charTypeName":"word"},{"id":53244,"position":13,"arabic":"خَبِيرًا","translation":"(তাঁরই) অবহিত হওয়া","audioUrl":"wbw/025_058_014.mp3","charTypeName":"word"},{"id":53245,"position":14,"arabic":"٥٨","translation":"(৫৮)","audioUrl":null,"charTypeName":"end"}]},{"number":59,"arabic":"ٱلَّذِى خَلَقَ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضَ وَمَا بَيْنَهُمَا فِى سِتَّةِ أَيَّامٍۢ ثُمَّ ٱسْتَوَىٰ عَلَى ٱلْعَرْشِ ۚ ٱلرَّحْمَٰنُ فَسْـَٔلْ بِهِۦ خَبِيرًۭا","translation":"He who has created the heavens and the earth and all that is between them in six aeons, and is established on the throne of His almightiness: the Most Gracious! Ask, then, about Him, [the] One who is [truly] aware.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2914.mp3","surahId":25,"words":[{"id":53635,"position":1,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/025_059_001.mp3","charTypeName":"word"},{"id":53636,"position":2,"arabic":"خَلَقَ","translation":"সৃষ্টি করেছেন","audioUrl":"wbw/025_059_002.mp3","charTypeName":"word"},{"id":53637,"position":3,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশমণ্ডলী","audioUrl":"wbw/025_059_003.mp3","charTypeName":"word"},{"id":53638,"position":4,"arabic":"وَٱلْأَرْضَ","translation":"ও পৃথিবী","audioUrl":"wbw/025_059_004.mp3","charTypeName":"word"},{"id":53639,"position":5,"arabic":"وَمَا","translation":"এবং যা কিছু","audioUrl":"wbw/025_059_005.mp3","charTypeName":"word"},{"id":53640,"position":6,"arabic":"بَيْنَهُمَا","translation":"উভয়ের মাঝে (আছে)","audioUrl":"wbw/025_059_006.mp3","charTypeName":"word"},{"id":53641,"position":7,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/025_059_007.mp3","charTypeName":"word"},{"id":53642,"position":8,"arabic":"سِتَّةِ","translation":"ছয়","audioUrl":"wbw/025_059_008.mp3","charTypeName":"word"},{"id":53643,"position":9,"arabic":"أَيَّامٍۢ","translation":"দিনে","audioUrl":"wbw/025_059_009.mp3","charTypeName":"word"},{"id":53644,"position":10,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/025_059_010.mp3","charTypeName":"word"},{"id":53645,"position":11,"arabic":"ٱسْتَوَىٰ","translation":"সমাসীন হন","audioUrl":"wbw/025_059_011.mp3","charTypeName":"word"},{"id":53646,"position":12,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/025_059_012.mp3","charTypeName":"word"},{"id":53647,"position":13,"arabic":"ٱلْعَرْشِ ۚ","translation":"আরশের","audioUrl":"wbw/025_059_013.mp3","charTypeName":"word"},{"id":53649,"position":14,"arabic":"ٱلرَّحْمَـٰنُ","translation":"অশেষ দয়াবান","audioUrl":"wbw/025_059_015.mp3","charTypeName":"word"},{"id":53650,"position":15,"arabic":"فَسْـَٔلْ","translation":"সুতরাং জিজ্ঞেস করো","audioUrl":"wbw/025_059_016.mp3","charTypeName":"word"},{"id":53651,"position":16,"arabic":"بِهِۦ","translation":"সম্পর্কে তাঁর","audioUrl":"wbw/025_059_017.mp3","charTypeName":"word"},{"id":53652,"position":17,"arabic":"خَبِيرًۭا","translation":"(তাদের হ'তে) যারা অবহিত","audioUrl":"wbw/025_059_018.mp3","charTypeName":"word"},{"id":53653,"position":18,"arabic":"٥٩","translation":"(৫৯)","audioUrl":null,"charTypeName":"end"}]},{"number":60,"arabic":"وَإِذَا قِيلَ لَهُمُ ٱسْجُدُوا۟ لِلرَّحْمَٰنِ قَالُوا۟ وَمَا ٱلرَّحْمَٰنُ أَنَسْجُدُ لِمَا تَأْمُرُنَا وَزَادَهُمْ نُفُورًۭا ۩","translation":"Yet when they [who are bent on denying the truth! are told, “Prostrate yourselves before the Most Gracious.” they are wont to ask, “And [who and] what is the Most Gracious? Are we to prostrate ourselves before whatever thou biddest us [to worship]?” - and so [thy call] but increases their aversion,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2915.mp3","surahId":25,"words":[{"id":54284,"position":1,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/025_060_001.mp3","charTypeName":"word"},{"id":54285,"position":2,"arabic":"قِيلَ","translation":"বলা হয়","audioUrl":"wbw/025_060_002.mp3","charTypeName":"word"},{"id":54286,"position":3,"arabic":"لَهُمُ","translation":"তাদেরকে","audioUrl":"wbw/025_060_003.mp3","charTypeName":"word"},{"id":54287,"position":4,"arabic":"ٱسْجُدُوا۟","translation":"\"তোমরা সিজদা করো","audioUrl":"wbw/025_060_004.mp3","charTypeName":"word"},{"id":54288,"position":5,"arabic":"لِلرَّحْمَـٰنِ","translation":"জন্যে দয়াময়ের\"","audioUrl":"wbw/025_060_005.mp3","charTypeName":"word"},{"id":54289,"position":6,"arabic":"قَالُوا۟","translation":"তারা বলে","audioUrl":"wbw/025_060_006.mp3","charTypeName":"word"},{"id":54290,"position":7,"arabic":"وَمَا","translation":"\"কে আবার","audioUrl":"wbw/025_060_007.mp3","charTypeName":"word"},{"id":54291,"position":8,"arabic":"ٱلرَّحْمَـٰنُ","translation":"(সেই) দয়াময়","audioUrl":"wbw/025_060_008.mp3","charTypeName":"word"},{"id":54292,"position":9,"arabic":"أَنَسْجُدُ","translation":"কি আমরা সিজদা করবো","audioUrl":"wbw/025_060_009.mp3","charTypeName":"word"},{"id":54293,"position":10,"arabic":"لِمَا","translation":"(তাকে) যাকে","audioUrl":"wbw/025_060_010.mp3","charTypeName":"word"},{"id":54294,"position":11,"arabic":"تَأْمُرُنَا","translation":"আমাদের তুমি নির্দেশ দিবে\"","audioUrl":"wbw/025_060_011.mp3","charTypeName":"word"},{"id":54295,"position":12,"arabic":"وَزَادَهُمْ","translation":"আর (এভাবে) বৃদ্ধি করলো তাদের","audioUrl":"wbw/025_060_012.mp3","charTypeName":"word"},{"id":54296,"position":13,"arabic":"نُفُورًۭا ۩","translation":"বিমুখতা","audioUrl":"wbw/025_060_013.mp3","charTypeName":"word"},{"id":54298,"position":14,"arabic":"٦٠","translation":"(৬০)","audioUrl":null,"charTypeName":"end"}]},{"number":61,"arabic":"تَبَارَكَ ٱلَّذِى جَعَلَ فِى ٱلسَّمَآءِ بُرُوجًۭا وَجَعَلَ فِيهَا سِرَٰجًۭا وَقَمَرًۭا مُّنِيرًۭا","translation":"HALLOWED is He who has set up in the skies great constellations, and has placed among them a [radiant] lamp and a light-giving moon.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2916.mp3","surahId":25,"words":[{"id":55308,"position":1,"arabic":"تَبَارَكَ","translation":"কল্যাণময়","audioUrl":"wbw/025_061_001.mp3","charTypeName":"word"},{"id":55309,"position":2,"arabic":"ٱلَّذِى","translation":"(সেই সত্ত্বা) যিনি","audioUrl":"wbw/025_061_002.mp3","charTypeName":"word"},{"id":55310,"position":3,"arabic":"جَعَلَ","translation":"স্থাপন করেছেন","audioUrl":"wbw/025_061_003.mp3","charTypeName":"word"},{"id":55311,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/025_061_004.mp3","charTypeName":"word"},{"id":55312,"position":5,"arabic":"ٱلسَّمَآءِ","translation":"আকাশের","audioUrl":"wbw/025_061_005.mp3","charTypeName":"word"},{"id":55313,"position":6,"arabic":"بُرُوجًۭا","translation":"বুরুজ (রাশিচক্র)","audioUrl":"wbw/025_061_006.mp3","charTypeName":"word"},{"id":55314,"position":7,"arabic":"وَجَعَلَ","translation":"ও স্থাপন করেছেন","audioUrl":"wbw/025_061_007.mp3","charTypeName":"word"},{"id":55315,"position":8,"arabic":"فِيهَا","translation":"মধ্যে তার","audioUrl":"wbw/025_061_008.mp3","charTypeName":"word"},{"id":55316,"position":9,"arabic":"سِرَٰجًۭا","translation":"প্রদীপ (সূর্য)","audioUrl":"wbw/025_061_009.mp3","charTypeName":"word"},{"id":55317,"position":10,"arabic":"وَقَمَرًۭا","translation":"ও চাঁদ","audioUrl":"wbw/025_061_010.mp3","charTypeName":"word"},{"id":55318,"position":11,"arabic":"مُّنِيرًۭا","translation":"উজ্জ্বল","audioUrl":"wbw/025_061_011.mp3","charTypeName":"word"},{"id":55319,"position":12,"arabic":"٦١","translation":"(৬১)","audioUrl":null,"charTypeName":"end"}]},{"number":62,"arabic":"وَهُوَ ٱلَّذِى جَعَلَ ٱلَّيْلَ وَٱلنَّهَارَ خِلْفَةًۭ لِّمَنْ أَرَادَ أَن يَذَّكَّرَ أَوْ أَرَادَ شُكُورًۭا","translation":"And He it is who causes the night and the day to succeed one another, [revealing Himself in His works] unto him who has the will to take thought - that is has the will to be grateful.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2917.mp3","surahId":25,"words":[{"id":55676,"position":1,"arabic":"وَهُوَ","translation":"এবং তিনিই","audioUrl":"wbw/025_062_001.mp3","charTypeName":"word"},{"id":55677,"position":2,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/025_062_002.mp3","charTypeName":"word"},{"id":55678,"position":3,"arabic":"جَعَلَ","translation":"বানিয়েছেন","audioUrl":"wbw/025_062_003.mp3","charTypeName":"word"},{"id":55679,"position":4,"arabic":"ٱلَّيْلَ","translation":"রাতকে","audioUrl":"wbw/025_062_004.mp3","charTypeName":"word"},{"id":55680,"position":5,"arabic":"وَٱلنَّهَارَ","translation":"ও দিনকে","audioUrl":"wbw/025_062_005.mp3","charTypeName":"word"},{"id":55681,"position":6,"arabic":"خِلْفَةًۭ","translation":"পরস্পরের অনুগামী","audioUrl":"wbw/025_062_006.mp3","charTypeName":"word"},{"id":55682,"position":7,"arabic":"لِّمَنْ","translation":"(এসব নিদর্শন) তার জন্য যে","audioUrl":"wbw/025_062_007.mp3","charTypeName":"word"},{"id":55683,"position":8,"arabic":"أَرَادَ","translation":"চায়","audioUrl":"wbw/025_062_008.mp3","charTypeName":"word"},{"id":55684,"position":9,"arabic":"أَن","translation":"যে","audioUrl":"wbw/025_062_009.mp3","charTypeName":"word"},{"id":55685,"position":10,"arabic":"يَذَّكَّرَ","translation":"উপদেশ গ্রহণ করবে","audioUrl":"wbw/025_062_010.mp3","charTypeName":"word"},{"id":55686,"position":11,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/025_062_011.mp3","charTypeName":"word"},{"id":55687,"position":12,"arabic":"أَرَادَ","translation":"সে চায়","audioUrl":"wbw/025_062_012.mp3","charTypeName":"word"},{"id":55688,"position":13,"arabic":"شُكُورًۭا","translation":"কৃতজ্ঞতা প্রকাশ করতে","audioUrl":"wbw/025_062_013.mp3","charTypeName":"word"},{"id":55689,"position":14,"arabic":"٦٢","translation":"(৬২)","audioUrl":null,"charTypeName":"end"}]},{"number":63,"arabic":"وَعِبَادُ ٱلرَّحْمَٰنِ ٱلَّذِينَ يَمْشُونَ عَلَى ٱلْأَرْضِ هَوْنًۭا وَإِذَا خَاطَبَهُمُ ٱلْجَٰهِلُونَ قَالُوا۟ سَلَٰمًۭا","translation":"For, [true] servants of the Most Gracious are [only] they who walk gently on earth, and who, whenever the foolish address them, reply with [words of] peace;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2918.mp3","surahId":25,"words":[{"id":55982,"position":1,"arabic":"وَعِبَادُ","translation":"আর দাসরা","audioUrl":"wbw/025_063_001.mp3","charTypeName":"word"},{"id":55983,"position":2,"arabic":"ٱلرَّحْمَـٰنِ","translation":"দয়াময়ের","audioUrl":"wbw/025_063_002.mp3","charTypeName":"word"},{"id":55984,"position":3,"arabic":"ٱلَّذِينَ","translation":"(তারাই) যারা","audioUrl":"wbw/025_063_003.mp3","charTypeName":"word"},{"id":55985,"position":4,"arabic":"يَمْشُونَ","translation":"চলাফেরা করে","audioUrl":"wbw/025_063_004.mp3","charTypeName":"word"},{"id":55986,"position":5,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/025_063_005.mp3","charTypeName":"word"},{"id":55987,"position":6,"arabic":"ٱلْأَرْضِ","translation":"জমিনের","audioUrl":"wbw/025_063_006.mp3","charTypeName":"word"},{"id":55988,"position":7,"arabic":"هَوْنًۭا","translation":"নম্রভাবে","audioUrl":"wbw/025_063_007.mp3","charTypeName":"word"},{"id":55989,"pos