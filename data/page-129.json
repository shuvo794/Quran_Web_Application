{"id":129,"ayahs":[{"number":9,"arabic":"وَلَوْ جَعَلْنَٰهُ مَلَكًۭا لَّجَعَلْنَٰهُ رَجُلًۭا وَلَلَبَسْنَا عَلَيْهِم مَّا يَلْبِسُونَ","translation":"And (even] if We had appointed an angel as Our message-bearer, We would certainly have made him [appear as] a man - and thus We would only have confused them in the same way as they are now confusing themselves.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/798.mp3","surahId":6,"words":[{"id":10480,"position":1,"arabic":"وَلَوْ","translation":"এবং যদি","audioUrl":"wbw/006_009_001.mp3","charTypeName":"word"},{"id":10481,"position":2,"arabic":"جَعَلْنَـٰهُ","translation":"আমরা করতাম তাকে","audioUrl":"wbw/006_009_002.mp3","charTypeName":"word"},{"id":10482,"position":3,"arabic":"مَلَكًۭا","translation":"ফেরেশতা","audioUrl":"wbw/006_009_003.mp3","charTypeName":"word"},{"id":10483,"position":4,"arabic":"لَّجَعَلْنَـٰهُ","translation":"অবশ্যই আমরা বানাতাম তাকে","audioUrl":"wbw/006_009_004.mp3","charTypeName":"word"},{"id":10484,"position":5,"arabic":"رَجُلًۭا","translation":"মানুষরূপে","audioUrl":"wbw/006_009_005.mp3","charTypeName":"word"},{"id":10485,"position":6,"arabic":"وَلَلَبَسْنَا","translation":"এবং অবশ্যই বিভ্রমে ফেলতাম আমরা","audioUrl":"wbw/006_009_006.mp3","charTypeName":"word"},{"id":10486,"position":7,"arabic":"عَلَيْهِم","translation":"উপর তাদের","audioUrl":"wbw/006_009_007.mp3","charTypeName":"word"},{"id":10487,"position":8,"arabic":"مَّا","translation":"যেমন","audioUrl":"wbw/006_009_008.mp3","charTypeName":"word"},{"id":10488,"position":9,"arabic":"يَلْبِسُونَ","translation":"তারা বিভ্রমে পড়েছে (এমন)","audioUrl":"wbw/006_009_009.mp3","charTypeName":"word"},{"id":10489,"position":10,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"وَلَقَدِ ٱسْتُهْزِئَ بِرُسُلٍۢ مِّن قَبْلِكَ فَحَاقَ بِٱلَّذِينَ سَخِرُوا۟ مِنْهُم مَّا كَانُوا۟ بِهِۦ يَسْتَهْزِءُونَ","translation":"And, indeed, [even] before thy time have apostles been derided - but those who scoffed at them were [in the end] overwhelmed by the very thing which they were wont to deride.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/799.mp3","surahId":6,"words":[{"id":11734,"position":1,"arabic":"وَلَقَدِ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/006_010_001.mp3","charTypeName":"word"},{"id":11735,"position":2,"arabic":"ٱسْتُهْزِئَ","translation":"বিদ্রুপ করা হয়েছে","audioUrl":"wbw/006_010_002.mp3","charTypeName":"word"},{"id":11736,"position":3,"arabic":"بِرُسُلٍۢ","translation":"সাথে রাসূলদের","audioUrl":"wbw/006_010_003.mp3","charTypeName":"word"},{"id":11737,"position":4,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/006_010_004.mp3","charTypeName":"word"},{"id":11738,"position":5,"arabic":"قَبْلِكَ","translation":"পূর্ব তোমার","audioUrl":"wbw/006_010_005.mp3","charTypeName":"word"},{"id":11739,"position":6,"arabic":"فَحَاقَ","translation":"তখন ঘিরে ফেলেছে","audioUrl":"wbw/006_010_006.mp3","charTypeName":"word"},{"id":11740,"position":7,"arabic":"بِٱلَّذِينَ","translation":"(তাদের)  উপর যারা","audioUrl":"wbw/006_010_007.mp3","charTypeName":"word"},{"id":11741,"position":8,"arabic":"سَخِرُوا۟","translation":"ঠাট্টা করেছিলো","audioUrl":"wbw/006_010_008.mp3","charTypeName":"word"},{"id":11742,"position":9,"arabic":"مِنْهُم","translation":"মধ্যে হতে তাদের","audioUrl":"wbw/006_010_009.mp3","charTypeName":"word"},{"id":11743,"position":10,"arabic":"مَّا","translation":"ঐ বিষয়","audioUrl":"wbw/006_010_010.mp3","charTypeName":"word"},{"id":11744,"position":11,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/006_010_011.mp3","charTypeName":"word"},{"id":11745,"position":12,"arabic":"بِهِۦ","translation":"নিয়ে যা","audioUrl":"wbw/006_010_012.mp3","charTypeName":"word"},{"id":11746,"position":13,"arabic":"يَسْتَهْزِءُونَ","translation":"ঠাট্টা বিদ্রুপ করতো","audioUrl":"wbw/006_010_013.mp3","charTypeName":"word"},{"id":11747,"position":14,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"قُلْ سِيرُوا۟ فِى ٱلْأَرْضِ ثُمَّ ٱنظُرُوا۟ كَيْفَ كَانَ عَٰقِبَةُ ٱلْمُكَذِّبِينَ","translation":"Say: \"Go all over the earth, and behold what happened in the end to those who gave the lie to the truth!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/800.mp3","surahId":6,"words":[{"id":13104,"position":1,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/006_011_001.mp3","charTypeName":"word"},{"id":13105,"position":2,"arabic":"سِيرُوا۟","translation":"\"তোমরা ভ্রমণ করো","audioUrl":"wbw/006_011_002.mp3","charTypeName":"word"},{"id":13106,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/006_011_003.mp3","charTypeName":"word"},{"id":13107,"position":4,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/006_011_004.mp3","charTypeName":"word"},{"id":13108,"position":5,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/006_011_005.mp3","charTypeName":"word"},{"id":13109,"position":6,"arabic":"ٱنظُرُوا۟","translation":"তোমরা দেখো","audioUrl":"wbw/006_011_006.mp3","charTypeName":"word"},{"id":13110,"position":7,"arabic":"كَيْفَ","translation":"কেমন","audioUrl":"wbw/006_011_007.mp3","charTypeName":"word"},{"id":13111,"position":8,"arabic":"كَانَ","translation":"ছিলো","audioUrl":"wbw/006_011_008.mp3","charTypeName":"word"},{"id":13112,"position":9,"arabic":"عَـٰقِبَةُ","translation":"পরিণাম","audioUrl":"wbw/006_011_009.mp3","charTypeName":"word"},{"id":13113,"position":10,"arabic":"ٱلْمُكَذِّبِينَ","translation":"সত্য অমান্যকারীদের\"","audioUrl":"wbw/006_011_010.mp3","charTypeName":"word"},{"id":13114,"position":11,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]},{"number":12,"arabic":"قُل لِّمَن مَّا فِى ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ ۖ قُل لِّلَّهِ ۚ كَتَبَ عَلَىٰ نَفْسِهِ ٱلرَّحْمَةَ ۚ لَيَجْمَعَنَّكُمْ إِلَىٰ يَوْمِ ٱلْقِيَٰمَةِ لَا رَيْبَ فِيهِ ۚ ٱلَّذِينَ خَسِرُوٓا۟ أَنفُسَهُمْ فَهُمْ لَا يُؤْمِنُونَ","translation":"Say: \"Unto whom belongs all that is in the heavens and on earth?\" Say: \"Unto God, who has willed upon Himself the law of grace and mercy. He will assuredly gather you all together on the Day of Resurrection, [the coming of] which is beyond all doubt: yet those who have squandered their own selves-it is they who refuse to believe [in Him],","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/801.mp3","surahId":6,"words":[{"id":14377,"position":1,"arabic":"قُل","translation":"বলো","audioUrl":"wbw/006_012_001.mp3","charTypeName":"word"},{"id":14378,"position":2,"arabic":"لِّمَن","translation":"\"কার (মালিকানায়)","audioUrl":"wbw/006_012_002.mp3","charTypeName":"word"},{"id":14379,"position":3,"arabic":"مَّا","translation":"যাকিছু","audioUrl":"wbw/006_012_003.mp3","charTypeName":"word"},{"id":14380,"position":4,"arabic":"فِى","translation":"মধ্যে (আছে)","audioUrl":"wbw/006_012_004.mp3","charTypeName":"word"},{"id":14381,"position":5,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশসমূহের","audioUrl":"wbw/006_012_005.mp3","charTypeName":"word"},{"id":14382,"position":6,"arabic":"وَٱلْأَرْضِ ۖ","translation":"ও পৃথিবীর\"","audioUrl":"wbw/006_012_006.mp3","charTypeName":"word"},{"id":14384,"position":7,"arabic":"قُل","translation":"বলো","audioUrl":"wbw/006_012_008.mp3","charTypeName":"word"},{"id":14385,"position":8,"arabic":"لِّلَّهِ ۚ","translation":"\"জন্যে আল্লাহরই (মালিকানায়)\"","audioUrl":"wbw/006_012_009.mp3","charTypeName":"word"},{"id":14387,"position":9,"arabic":"كَتَبَ","translation":"তিনি নির্ধারিত করে দিয়েছেন","audioUrl":"wbw/006_012_011.mp3","charTypeName":"word"},{"id":14388,"position":10,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/006_012_012.mp3","charTypeName":"word"},{"id":14389,"position":11,"arabic":"نَفْسِهِ","translation":"নিজের তাঁর","audioUrl":"wbw/006_012_013.mp3","charTypeName":"word"},{"id":14390,"position":12,"arabic":"ٱلرَّحْمَةَ ۚ","translation":"দয়া করা","audioUrl":"wbw/006_012_014.mp3","charTypeName":"word"},{"id":14392,"position":13,"arabic":"لَيَجْمَعَنَّكُمْ","translation":"নিশ্চয়ই একত্র করবেন তোমাদের","audioUrl":"wbw/006_012_016.mp3","charTypeName":"word"},{"id":14393,"position":14,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/006_012_017.mp3","charTypeName":"word"},{"id":14394,"position":15,"arabic":"يَوْمِ","translation":"দিনে","audioUrl":"wbw/006_012_018.mp3","charTypeName":"word"},{"id":14395,"position":16,"arabic":"ٱلْقِيَـٰمَةِ","translation":"ক্বিয়ামাতের","audioUrl":"wbw/006_012_019.mp3","charTypeName":"word"},{"id":14396,"position":17,"arabic":"لَا","translation":"নেই","audioUrl":"wbw/006_012_020.mp3","charTypeName":"word"},{"id":14397,"position":18,"arabic":"رَيْبَ","translation":"সন্দেহ","audioUrl":"wbw/006_012_021.mp3","charTypeName":"word"},{"id":14398,"position":19,"arabic":"فِيهِ ۚ","translation":"মধ্যে তার (বিন্দুমাত্র)","audioUrl":"wbw/006_012_022.mp3","charTypeName":"word"},{"id":14400,"position":20,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/006_012_024.mp3","charTypeName":"word"},{"id":14401,"position":21,"arabic":"خَسِرُوٓا۟","translation":"ক্ষতিগ্রস্ত করেছে","audioUrl":"wbw/006_012_025.mp3","charTypeName":"word"},{"id":14402,"position":22,"arabic":"أَنفُسَهُمْ","translation":"নিজেদেরকে তাদের","audioUrl":"wbw/006_012_026.mp3","charTypeName":"word"},{"id":14403,"position":23,"arabic":"فَهُمْ","translation":"অতঃপর তারা","audioUrl":"wbw/006_012_027.mp3","charTypeName":"word"},{"id":14404,"position":24,"arabic":"لَا","translation":"না","audioUrl":"wbw/006_012_028.mp3","charTypeName":"word"},{"id":14405,"position":25,"arabic":"يُؤْمِنُونَ","translation":"ঈমান আনবে","audioUrl":"wbw/006_012_029.mp3","charTypeName":"word"},{"id":14406,"position":26,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]},{"number":13,"arabic":"۞ وَلَهُۥ مَا سَكَنَ فِى ٱلَّيْلِ وَٱلنَّهَارِ ۚ وَهُوَ ٱلسَّمِيعُ ٱلْعَلِيمُ","translation":"although His is all that dwells in the night and the day, and He alone is all-hearing, all-knowing.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/802.mp3","surahId":6,"words":[{"id":15500,"position":1,"arabic":"۞ وَلَهُۥ","translation":"এবং জন্যে তাঁরই","audioUrl":"wbw/006_013_002.mp3","charTypeName":"word"},{"id":15501,"position":2,"arabic":"مَا","translation":"যাকিছু","audioUrl":"wbw/006_013_003.mp3","charTypeName":"word"},{"id":15502,"position":3,"arabic":"سَكَنَ","translation":"স্থিতি লাভ করে","audioUrl":"wbw/006_013_004.mp3","charTypeName":"word"},{"id":15503,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/006_013_005.mp3","charTypeName":"word"},{"id":15504,"position":5,"arabic":"ٱلَّيْلِ","translation":"রাতের","audioUrl":"wbw/006_013_006.mp3","charTypeName":"word"},{"id":15505,"position":6,"arabic":"وَٱلنَّهَارِ ۚ","translation":"ও দিনের","audioUrl":"wbw/006_013_007.mp3","charTypeName":"word"},{"id":15507,"position":7,"arabic":"وَهُوَ","translation":"এবং তিনিই","audioUrl":"wbw/006_013_009.mp3","charTypeName":"word"},{"id":15508,"position":8,"arabic":"ٱلسَّمِيعُ","translation":"সবকিছু শুনেন","audioUrl":"wbw/006_013_010.mp3","charTypeName":"word"},{"id":15509,"position":9,"arabic":"ٱلْعَلِيمُ","translation":"সবকিছু জানেন","audioUrl":"wbw/006_013_011.mp3","charTypeName":"word"},{"id":15510,"position":10,"arabic":"١٣","translation":"(১৩)","audioUrl":null,"charTypeName":"end"}]},{"number":14,"arabic":"قُلْ أَغَيْرَ ٱللَّهِ أَتَّخِذُ وَلِيًّۭا فَاطِرِ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ وَهُوَ يُطْعِمُ وَلَا يُطْعَمُ ۗ قُلْ إِنِّىٓ أُمِرْتُ أَنْ أَكُونَ أَوَّلَ مَنْ أَسْلَمَ ۖ وَلَا تَكُونَنَّ مِنَ ٱلْمُشْرِكِينَ","translation":"Say: \"Am I to take for my master anyone but God, the Originator of the heavens and the earth, when it is He who gives nourishment and Himself needs none?” Say: \"I am bidden to be foremost among those who surrender themselves unto God, and not to be among those who ascribe divinity to aught beside Him.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/803.mp3","surahId":6,"words":[{"id":16527,"position":1,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/006_01