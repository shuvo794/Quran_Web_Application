{"id":538,"ayahs":[{"number":4,"arabic":"هُوَ ٱلَّذِى خَلَقَ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضَ فِى سِتَّةِ أَيَّامٍۢ ثُمَّ ٱسْتَوَىٰ عَلَى ٱلْعَرْشِ ۚ يَعْلَمُ مَا يَلِجُ فِى ٱلْأَرْضِ وَمَا يَخْرُجُ مِنْهَا وَمَا يَنزِلُ مِنَ ٱلسَّمَآءِ وَمَا يَعْرُجُ فِيهَا ۖ وَهُوَ مَعَكُمْ أَيْنَ مَا كُنتُمْ ۚ وَٱللَّهُ بِمَا تَعْمَلُونَ بَصِيرٌۭ","translation":"He it is who has created the heavens and the earth in six aeons, and is established on the throne of His almightiness. He knows all that enters the earth, and all that comes out of it, as well as all that descends from the skies, and all that ascends to them. And He is with you wherever you may be; and God sees all that you do.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5079.mp3","surahId":57,"words":[{"id":3638,"position":1,"arabic":"هُوَ","translation":"তিনিই","audioUrl":"wbw/057_004_001.mp3","charTypeName":"word"},{"id":3639,"position":2,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/057_004_002.mp3","charTypeName":"word"},{"id":3640,"position":3,"arabic":"خَلَقَ","translation":"সৃষ্টি করেছেন","audioUrl":"wbw/057_004_003.mp3","charTypeName":"word"},{"id":3641,"position":4,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশ সমুহকে","audioUrl":"wbw/057_004_004.mp3","charTypeName":"word"},{"id":3642,"position":5,"arabic":"وَٱلْأَرْضَ","translation":"ও পৃথিবীকে","audioUrl":"wbw/057_004_005.mp3","charTypeName":"word"},{"id":3643,"position":6,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/057_004_006.mp3","charTypeName":"word"},{"id":3644,"position":7,"arabic":"سِتَّةِ","translation":"ছয়","audioUrl":"wbw/057_004_007.mp3","charTypeName":"word"},{"id":3645,"position":8,"arabic":"أَيَّامٍۢ","translation":"দিনের","audioUrl":"wbw/057_004_008.mp3","charTypeName":"word"},{"id":3646,"position":9,"arabic":"ثُمَّ","translation":"অতঃপর","audioUrl":"wbw/057_004_009.mp3","charTypeName":"word"},{"id":3647,"position":10,"arabic":"ٱسْتَوَىٰ","translation":"সমাসীন হন","audioUrl":"wbw/057_004_010.mp3","charTypeName":