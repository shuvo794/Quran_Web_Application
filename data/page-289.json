osition":10,"arabic":"وَأَضَلُّ","translation":"বরং অধিকতর ভ্রষ্ট","audioUrl":"wbw/017_072_010.mp3","charTypeName":"word"},{"id":60419,"position":11,"arabic":"سَبِيلًۭا","translation":"পথ হ'তে","audioUrl":"wbw/017_072_011.mp3","charTypeName":"word"},{"id":60420,"position":12,"arabic":"٧٢","translation":"(৭২)","audioUrl":null,"charTypeName":"end"}]},{"number":73,"arabic":"وَإِن كَادُوا۟ لَيَفْتِنُونَكَ عَنِ ٱلَّذِىٓ أَوْحَيْنَآ إِلَيْكَ لِتَفْتَرِىَ عَلَيْنَا غَيْرَهُۥ ۖ وَإِذًۭا لَّٱتَّخَذُوكَ خَلِيلًۭا","translation":"AND,. behold, they [who have gone astray] endeavour to tempt thee away from all [the truth] with which We have inspired thee, [O Prophet,] with a view to making thee invent something else in Our name - in which case they would surely have made thee their friend!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2102.mp3","surahId":17,"words":[{"id":61276,"position":1,"arabic":"وَإِن","translation":"এবং যদিও","audioUrl":"wbw/017_073_001.mp3","charTypeName":"word"},{"id":61277,"position":2,"arabic":"كَادُوا۟","translation":"তারা প্রচেষ্টায় ক্রুটি রাখেনি","audioUrl":"wbw/017_073_002.mp3","charTypeName":"word"},{"id":61278,"position":3,"arabic":"لَيَفْتِنُونَكَ","translation":"অবশ্যই তোমার বিচ্যুতি ঘটাতে","audioUrl":"wbw/017_073_003.mp3","charTypeName":"word"},{"id":61279,"position":4,"arabic":"عَنِ","translation":"থেকে","audioUrl":"wbw/017_073_004.mp3","charTypeName":"word"},{"id":61280,"position":5,"arabic":"ٱلَّذِىٓ","translation":"যা","audioUrl":"wbw/017_073_005.mp3","charTypeName":"word"},{"id":61281,"position":6,"arabic":"أَوْحَيْنَآ","translation":"ওহী করেছি আমরা","audioUrl":"wbw/017_073_006.mp3","charTypeName":"word"},{"id":61282,"position":7,"arabic":"إِلَيْكَ","translation":"প্রতি তোমার","audioUrl":"wbw/017_073_007.mp3","charTypeName":"word"},{"id":61283,"position":8,"arabic":"لِتَفْتَرِىَ","translation":"যেন তুমি রচনা করো","audioUrl":"wbw/017_073_008.mp3","charTypeName":"word"},{"id":61284,"position":9,"arabic":"عَلَيْنَا","tr