"পাশে","audioUrl":"wbw/017_068_005.mp3","charTypeName":"word"},{"id":58470,"position":6,"arabic":"ٱلْبَرِّ","translation":"স্থলভাগের","audioUrl":"wbw/017_068_006.mp3","charTypeName":"word"},{"id":58471,"position":7,"arabic":"أَوْ","translation":"বা","audioUrl":"wbw/017_068_007.mp3","charTypeName":"word"},{"id":58472,"position":8,"arabic":"يُرْسِلَ","translation":"পাঠাবেন (না)","audioUrl":"wbw/017_068_008.mp3","charTypeName":"word"},{"id":58473,"position":9,"arabic":"عَلَيْكُمْ","translation":"বিরুদ্ধে তোমাদের","audioUrl":"wbw/017_068_009.mp3","charTypeName":"word"},{"id":58474,"position":10,"arabic":"حَاصِبًۭا","translation":"কংকর বর্ষণকারী ঝড়ো হাওয়া","audioUrl":"wbw/017_068_010.mp3","charTypeName":"word"},{"id":58475,"position":11,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/017_068_011.mp3","charTypeName":"word"},{"id":58476,"position":12,"arabic":"لَا","translation":"না","audioUrl":"wbw/017_068_012.mp3","charTypeName":"word"},{"id":58477,"position":13,"arabic":"تَجِدُوا۟","translation":"তোমরা পাবে","audioUrl":"wbw/017_068_013.mp3","charTypeName":"word"},{"id":58478,"position":14,"arabic":"لَكُمْ","translation":"জন্যে তোমাদের","audioUrl":"wbw/017_068_014.mp3","charTypeName":"word"},{"id":58479,"position":15,"arabic":"وَكِيلًا","translation":"কোনো কর্মবিধায়ক","audioUrl":"wbw/017_068_015.mp3","charTypeName":"word"},{"id":58480,"position":16,"arabic":"٦٨","translation":"(৬৮)","audioUrl":null,"charTypeName":"end"}]},{"number":69,"arabic":"أَمْ أَمِنتُمْ أَن يُعِيدَكُمْ فِيهِ تَارَةً أُخْرَىٰ فَيُرْسِلَ عَلَيْكُمْ قَاصِفًۭا مِّنَ ٱلرِّيحِ فَيُغْرِقَكُم بِمَا كَفَرْتُمْ ۙ ثُمَّ لَا تَجِدُوا۟ لَكُمْ عَلَيْنَا بِهِۦ تَبِيعًۭا","translation":"Or can you, perchance, feel sure that He will not make you put back to sea once again, and then let loose upon you a raging tempest and cause you to drown in requital of your ingratitude - whereupon you would find none to uphold you against Us?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2098.mp3","surahI