{"id":289,"ayahs":[{"number":67,"arabic":"وَإِذَا مَسَّكُمُ ٱلضُّرُّ فِى ٱلْبَحْرِ ضَلَّ مَن تَدْعُونَ إِلَّآ إِيَّاهُ ۖ فَلَمَّا نَجَّىٰكُمْ إِلَى ٱلْبَرِّ أَعْرَضْتُمْ ۚ وَكَانَ ٱلْإِنسَٰنُ كَفُورًا","translation":"And whenever danger befalls you at sea, all those (powers] that you are wont to invoke forsake you, [and nothing remains for you] save Him: but as soon as He has brought you safe ashore, you turn aside [and forget Him]-for, indeed, bereft of all gratitude is man!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2096.mp3","surahId":17,"words":[{"id":57940,"position":1,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/017_067_001.mp3","charTypeName":"word"},{"id":57941,"position":2,"arabic":"مَسَّكُمُ","translation":"তোমাদের স্পর্শ করে","audioUrl":"wbw/017_067_002.mp3","charTypeName":"word"},{"id":57942,"position":3,"arabic":"ٱلضُّرُّ","translation":"বিপদ","audioUrl":"wbw/017_067_003.mp3","charTypeName":"word"},{"id":57943,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/017_067_004.mp3","charTypeName":"word"},{"id":57944,"position":5,"arabic":"ٱلْبَحْرِ","translation":"সাগরের","audioUrl":"wbw/017_067_005.mp3","charTypeName":"word"},{"id":57945,"position":6,"arabic":"ضَلَّ","translation":"হারিয়ে যায়","audioUrl":"wbw/017_067_006.mp3","charTypeName":"word"},{"id":57946,"position":7,"arabic":"مَن","translation":"যাকে","audioUrl":"wbw/017_067_007.mp3","charTypeName":"word"},{"id":57947,"position":8,"arabic":"تَدْعُونَ","translation":"তোমরা ডাকো","audioUrl":"wbw/017_067_008.mp3","charTypeName":"word"},{"id":57948,"position":9,"arabic":"إِلَّآ","translation":"ছাড়া","audioUrl":"wbw/017_067_009.mp3","charTypeName":"word"},{"id":57949,"position":10,"arabic":"إِيَّاهُ ۖ","translation":"শুধু তিনিই","audioUrl":"wbw/017_067_010.mp3","charTypeName":"word"},{"id":57951,"position":11,"arabic":"فَلَمَّا","translation":"অতএব যখন","audioUrl":"wbw/017_067_012.mp3","charTypeName":"word"},{"id":57952,"position":12,"arabic":"نَجَّىٰكُ