{"id":572,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ قُلْ أُوحِىَ إِلَىَّ أَنَّهُ ٱسْتَمَعَ نَفَرٌۭ مِّنَ ٱلْجِنِّ فَقَالُوٓا۟ إِنَّا سَمِعْنَا قُرْءَانًا عَجَبًۭا","translation":"SAY: \"It has been revealed to me that some of the unseen beings gave ear [to this divine writ], and thereupon said [unto their fellow-beings]: \"'Verily, we have heard a wondrous discourse,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5448.mp3","surahId":72,"words":[{"id":614,"position":1,"arabic":"قُلْ","translation":"বল (হে নবী)","audioUrl":"wbw/072_001_001.mp3","charTypeName":"word"},{"id":615,"position":2,"arabic":"أُوحِىَ","translation":"\"ওহী করা হয়েছে","audioUrl":"wbw/072_001_002.mp3","charTypeName":"word"},{"id":616,"position":3,"arabic":"إِلَىَّ","translation":"আমার প্রতি","audioUrl":"wbw/072_001_003.mp3","charTypeName":"word"},{"id":617,"position":4,"arabic":"أَنَّهُ","translation":"যে","audioUrl":"wbw/072_001_004.mp3","charTypeName":"word"},{"id":618,"position":5,"arabic":"ٱسْتَمَعَ","translation":"মনযোগসহ শুনেছে","audioUrl":"wbw/072_001_005.mp3","charTypeName":"word"},{"id":619,"position":6,"arabic":"نَفَرٌۭ","translation":"একটি দল","audioUrl":"wbw/072_001_006.mp3","charTypeName":"word"},{"id":620,"position":7,"arabic":"مِّنَ","translation":"মধ্যে","audioUrl":"wbw/072_001_007.mp3","charTypeName":"word"},{"id":621,"position":8,"arabic":"ٱلْجِنِّ","translation":"জ্বীনদের","audioUrl":"wbw/072_001_008.mp3","charTypeName":"word"},{"id":622,"position":9,"arabic":"فَقَالُوٓا۟","translation":"তারা বলেছে অতঃপর","audioUrl":"wbw/072_001_009.mp3","charTypeName":"word"},{"id":623,"position":10,"arabic":"إِنَّا","translation":"\"আমরা নিশ্চয়ই","audioUrl":"wbw/072_001_010.mp3","charTypeName":"word"},{"id":624,"position":11,"arabic":"سَمِعْنَا","translation":"আমরা শুনেছি","audioUrl":"wbw/072_001_011.mp3","charTypeName":"word"},{"id":625,"position":12,"arabic":"قُرْءَانًا","translation":"কুরআন","audioUrl":"wbw/072_001_012.mp3","charTypeName":"word"},{"id":626,"position":13,"arabic":"عَجَبًۭا","translation":"বিস্ময়কর","audioUrl":"wbw/072_001_013.mp3","charTypeName":"word"},{"id":627,"position":14,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"يَهْدِىٓ إِلَى ٱلرُّشْدِ فَـَٔامَنَّا بِهِۦ ۖ وَلَن نُّشْرِكَ بِرَبِّنَآ أَحَدًۭا","translation":"guiding towards consciousness of what is right; and so We have come to believe in it. And we shall never ascribe divinity to anyone beside our Sustainer,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5449.mp3","surahId":72,"words":[{"id":1564,"position":1,"arabic":"يَهْدِىٓ","translation":"পথ দেখায়","audioUrl":"wbw/072_002_001.mp3","charTypeName":"word"},{"id":1565,"position":2,"arabic":"إِلَى","translation":"দিকে","audioUrl":"wbw/072_002_002.mp3","charTypeName":"word"},{"id":1566,"position":3,"arabic":"ٱلرُّشْدِ","translation":"সত্যের","audioUrl":"wbw/072_002_003.mp3","charTypeName":"word"},{"id":1567,"position":4,"arabic":"فَـَٔامَنَّا","translation":"আমরা ঈমান অতঃপর এনেছি","audioUrl":"wbw/072_002_004.mp3","charTypeName":"word"},{"id":1568,"position":5,"arabic":"بِهِۦ ۖ","translation":"তার উপর","audioUrl":"wbw/072_002_005.mp3","charTypeName":"word"},{"id":1570,"position":6,"arabic":"وَلَن","translation":"এবং কক্ষণ না","audioUrl":"wbw/072_002_007.mp3","charTypeName":"word"},{"id":1571,"position":7,"arabic":"نُّشْرِكَ","translation":"শরীক আমরা করবো","audioUrl":"wbw/072_002_008.mp3","charTypeName":"word"},{"id":1572,"position":8,"arabic":"بِرَبِّنَآ","translation":"আমাদের রবের সাথে","audioUrl":"wbw/072_002_009.mp3","charTypeName":"word"},{"id":1573,"position":9,"arabic":"أَحَدًۭا","translation":"কাউকে","audioUrl":"wbw/072_002_010.mp3","charTypeName":"word"},{"id":1574,"position":10,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"وَأَنَّهُۥ تَعَٰلَىٰ جَدُّ رَبِّنَا مَا ٱتَّخَذَ صَٰحِبَةًۭ وَلَا وَلَدًۭا","translation":"for [we know] that sublimely exalted is our Sustainer's majesty: no consort has He ever taken unto Himself, nor a son!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5450.mp3","surahId":72,"words":[{"id":2593,"position":1,"arabic":"وَأَنَّهُۥ","translation":"এবং যে","audioUrl":"wbw/072_003_001.mp3","charTypeName":"word"},{"id":2594,"position":2,"arabic":"تَعَـٰلَىٰ","translation":"অতি উচ্চ","audioUrl":"wbw/072_003_002.mp3","charTypeName":"word"},{"id":2595,"position":3,"arabic":"جَدُّ","translation":"মর্যাদা","audioUrl":"wbw/072_003_003.mp3","charTypeName":"word"},{"id":2596,"position":4,"arabic":"رَبِّنَا","translation":"আমাদের রবের","audioUrl":"wbw/072_003_004.mp3","charTypeName":"word"},{"id":2597,"position":5,"arabic":"مَا","translation":"নাই","audioUrl":"wbw/072_003_005.mp3","charTypeName":"word"},{"id":2598,"position":6,"arabic":"ٱتَّخَذَ","translation":"তিনি গ্রহণ করেন","audioUrl":"wbw/072_003_006.mp3","charTypeName":"word"},{"id":2599,"position":7,"arabic":"صَـٰحِبَةًۭ","translation":"স্ত্রী","audioUrl":"wbw/072_003_007.mp3","charTypeName":"word"},{"id":2600,"position":8,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/072_003_008.mp3","charTypeName":"word"},{"id":2601,"position":9,"arabic":"وَلَدًۭا","translation":"পুত্র","audioUrl":"wbw/072_003_009.mp3","charTypeName":"word"},{"id":2602,"position":10,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"وَأَنَّهُۥ كَانَ يَقُولُ سَفِيهُنَا عَلَى ٱللَّهِ شَطَطًۭا","translation":"\"'And [now we know] that the foolish among us were wont to say outrageous things about God,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5451.mp3","surahId":72,"words":[{"id":4026,"position":1,"arabic":"وَأَنَّهُۥ","translation":"এবং যে","audioUrl":"wbw/072_004_001.mp3","charTypeName":"word"},{"id":4027,"position":2,"arabic":"كَانَ","translation":"ছিল","audioUrl":"wbw/072_004_002.mp3","charTypeName":"word"},{"id":4028,"position":3,"arabic":"يَقُولُ","translation":"বলত","audioUrl":"wbw/072_004_003.mp3","charTypeName":"word"},{"id":4029,"position":4,"arabic":"سَفِيهُنَا","translation":"আমাদের নির্বোধরা","audioUrl":"wbw/072_004_004.mp3","charTypeName":"word"},{"id":4030,"position":5,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/072_004_005.mp3","charTypeName":"word"},{"id":4031,"position":6,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/072_004_006.mp3","charTypeName":"word"},{"id":4032,"position":7,"arabic":"شَطَطًۭا","translation":"সীমাহীন মিথ্যা","audioUrl":"wbw/072_004_007.mp3","charTypeName":"word"},{"id":4033,"position":8,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"وَأَنَّا ظَنَنَّآ أَن لَّن تَقُولَ ٱلْإِنسُ وَٱلْجِنُّ عَلَى ٱللَّهِ كَذِبًۭا","translation":"and that [we were mistaken when] we thought that neither man nor [any of] the invisible forces would ever tell a lie about God.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5452.mp3","surahId":72,"words":[{"id":5314,"position":1,"arabic":"وَأَنَّا","translation":"এবং আমরা যে","audioUrl":"wbw/072_005_001.mp3","charTypeName":"word"},{"id":5315,"position":2,"arabic":"ظَنَنَّآ","translation":"ভেবেছিলাম","audioUrl":"wbw/072_005_002.mp3","charTypeName":"word"},{"id":5316,"position":3,"arabic":"أَن","translation":"যে","audioUrl":"wbw/072_005_003.mp3","charTypeName":"word"},{"id":5317,"position":4,"arabic":"لَّن","translation":"কখনও না","audioUrl":"wbw/072_005_004.mp3","charTypeName":"word"},{"id":5318,"position":5,"arabic":"تَقُولَ","translation":"বলবে","audioUrl":"wbw/072_005_005.mp3","charTypeName":"word"},{"id":5319,"position":6,"arabic":"ٱلْإِنسُ","translation":"মানুষ","audioUrl":"wbw/072_005_006.mp3","charTypeName":"word"},{"id":5320,"position":7,"arabic":"وَٱلْجِنُّ","translation":"ও জীন্ন","audioUrl":"wbw/072_005_007.mp3","charTypeName":"word"},{"id":5321,"position":8,"arabic":"عَلَى","translation":"সম্পর্কে","audioUrl":"wbw/072_005_008.mp3","charTypeName":"word"},{"id":5322,"position":9,"arabic":"ٱللَّهِ","translation":"আল্লাহ","audioUrl":"wbw/072_005_009.mp3","charTypeName":"word"},{"id":5323,"position":10,"arabic":"كَذِبًۭا","translation":"মিথ্যা","audioUrl":"wbw/072_005_010.mp3","charTypeName":"word"},{"id":5324,"position":11,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"وَأَنَّهُۥ كَانَ رِجَالٌۭ مِّنَ ٱلْإِنسِ يَعُوذُونَ بِرِجَالٍۢ مِّنَ ٱلْجِنِّ فَزَادُوهُمْ رَهَقًۭا","translation":"Yet [it has always happened] that certain kinds of humans would seek refuge with certain kinds of [such] invisible forces: but these only increased their confusion –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5453.mp3","surahId":72,"words":[{"id":6515,"position":1,"arabic":"وَأَنَّهُۥ","translation":"এবং যে","audioUrl":"wbw/072_006_001.mp3","charTypeName":"word"},{"id":6516,"position":2,"arabic":"كَانَ","translation":"ছিল","audioUrl":"wbw/072_006_002.mp3","charTypeName":"word"},{"id":6517,"position":3,"arabic":"رِجَالٌۭ","translation":"কিছু লোক","audioUrl":"wbw/072_006_003.mp3","charTypeName":"word"},{"id":6518,"position":4,"arabic":"مِّنَ","translation":"মধ্যে","audioUrl":"wbw/072_006_004.mp3","charTypeName":"word"},{"id":6519,"position":5,"arabic":"ٱلْإِنسِ","translation":"মানুষের","audioUrl":"wbw/072_006_005.mp3","charTypeName":"word"},{"id":6520,"position":6,"arabic":"يَعُوذُونَ","translation":"আশ্রয় চাইত","audioUrl":"wbw/072_006_006.mp3","charTypeName":"word"},{"id":6521,"position":7,"arabic":"بِرِجَالٍۢ","translation":"কিছু লোকের","audioUrl":"wbw/072_006_007.mp3","charTypeName":"word"},{"id":6522,"position":8,"arabic":"مِّنَ","translation":"মধ্যের","audioUrl":"wbw/072_006_008.mp3","charTypeName":"word"},{"id":6523,"position":9,"arabic":"ٱلْجِنِّ","translation":"জিন্নদের","audioUrl":"wbw/072_006_009.mp3","charTypeName":"word"},{"id":6524,"position":10,"arabic":"فَزَادُوهُمْ","translation":"তাদের বাড়িয়েছিল এভাবে","audioUrl":"wbw/072_006_010.mp3","charTypeName":"word"},{"id":6525,"position":11,"arabic":"رَهَقًۭا","translation":"অহংকার","audioUrl":"wbw/072_006_011.mp3","charTypeName":"word"},{"id":6526,"position":12,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"وَأَنَّهُمْ ظَنُّوا۟ كَمَا ظَنَنتُمْ أَن لَّن يَبْعَثَ ٱللَّهُ أَحَدًۭا","translation":"so much so that they came to think, as you [once] thought, that God would never [again] send forth anyone [as His apostle].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5454.mp3","surahId":72,"words":[{"id":7930,"position":1,"arabic":"وَأَنَّهُمْ","translation":"এবং তারা যে","audioUrl":"wbw/072_007_001.mp3","charTypeName":"word"},{"id":7931,"position":2,"arabic":"ظَنُّوا۟","translation":"ভেবেছিল","audioUrl":"wbw/072_007_002.mp3","charTypeName":"word"},{"id":7932,"position":3,"arabic":"كَمَا","translation":"যেমন","audioUrl":"wbw/072_007_003.mp3","charTypeName":"word"},{"id":7933,"position":4,"arabic":"ظَنَنتُمْ","translation":"তোমরা ভেবেছ","audioUrl":"wbw/072_007_004.mp3","charTypeName":"word"},{"id":7934,"position":5,"arabic":"أَن","translation":"যে","audioUrl":"wbw/072_007_005.mp3","charTypeName":"word"},{"id":7935,"position":6,"arabic":"لَّن","translation":"কখনও না","audioUrl":"wbw/072_007_006.mp3","charTypeName":"word"},{"id":7936,"position":7,"arabic":"يَبْعَثَ","translation":"পাঠাবেন","audioUrl":"wbw/072_007_007.mp3","charTypeName":"word"},{"id":7937,"position":8,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/072_007_008.mp3","charTypeName":"word"},{"id":7938,"position":9,"arabic":"أَحَدًۭا","translation":"কাউকে (রাসূলরূপে)","audioUrl":"wbw/072_007_009.mp3","charTypeName":"word"},{"id":7939,"position":10,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"وَأَنَّا لَمَسْنَا ٱلسَّمَآءَ فَوَجَدْنَٰهَا مُلِئَتْ حَرَسًۭا شَدِيدًۭا وَشُهُبًۭا","translation":"\"'And [so it happened] that we reached out towards heaven: but we found it filled with mighty guards and flames,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5455.mp3","surahId":72,"words":[{"id":9097,"position":1,"arabic":"وَأَنَّا","translation":"এবং আমরা যে","audioUrl":"wbw/072_008_001.mp3","charTypeName":"word"},{"id":9098,"position":2,"arabic":"لَمَسْنَا","translation":"আমরা তালাশ করেছি","audioUrl":"wbw/072_008_002.mp3","charTypeName":"word"},{"id":9099,"position":3,"arabic":"ٱلسَّمَآءَ","translation":"আসমানে","audioUrl":"wbw/072_008_003.mp3","charTypeName":"word"},{"id":9100,"position":4,"arabic":"فَوَجَدْنَـٰهَا","translation":"তা আমরা পেয়েছি ফলে","audioUrl":"wbw/072_008_004.mp3","charTypeName":"word"},{"id":9101,"position":5,"arabic":"مُلِئَتْ","translation":"পরিপূর্ণ","audioUrl":"wbw/072_008_005.mp3","charTypeName":"word"},{"id":9102,"position":6,"arabic":"حَرَسًۭا","translation":"পাহারাদারে","audioUrl":"wbw/072_008_006.mp3","charTypeName":"word"},{"id":9103,"position":7,"arabic":"شَدِيدًۭا","translation":"কঠোর","audioUrl":"wbw/072_008_007.mp3","charTypeName":"word"},{"id":9104,"position":8,"arabic":"وَشُهُبًۭا","translation":"ও অগ্নিশিখা সমূহে","audioUrl":"wbw/072_008_008.mp3","charTypeName":"word"},{"id":9105,"position":9,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"وَأَنَّا كُنَّا نَقْعُدُ مِنْهَا مَقَٰعِدَ لِلسَّمْعِ ۖ فَمَن يَسْتَمِعِ ٱلْءَانَ يَجِدْ لَهُۥ شِهَابًۭا رَّصَدًۭا","translation":"notwithstanding that we were established in positions [which we had thought well-suited] to listening to [whatever secrets might be in] it: and anyone who now [or ever] tries to listen will [likewise] find a flame lying in wait for him!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5456.mp3","surahId":72,"words":[{"id":10313,"position":1,"arabic":"وَأَنَّا","translation":"এবং যে","audioUrl":"wbw/072_009_001.mp3","charTypeName":"word"},{"id":10314,"position":2,"arabic":"كُنَّا","translation":"(আমরা)","audioUrl":"wbw/072_009_002.mp3","charTypeName":"word"},{"id":10315,"position":3,"arabic":"نَقْعُدُ","translation":"আমরা বসতাম","audioUrl":"wbw/072_009_003.mp3","charTypeName":"word"},{"id":10316,"position":4,"arabic":"مِنْهَا","translation":"সেখানে","audioUrl":"wbw/072_009_004.mp3","charTypeName":"word"},{"id":10317,"position":5,"arabic":"مَقَـٰعِدَ","translation":"আসনগুলোতে","audioUrl":"wbw/072_009_005.mp3","charTypeName":"word"},{"id":10318,"position":6,"arabic":"لِلسَّمْعِ ۖ","translation":"শুনার জন্য","audioUrl":"wbw/072_009_006.mp3","charTypeName":"word"},{"id":10320,"position":7,"arabic":"فَمَن","translation":"যে কিন্তু","audioUrl":"wbw/072_009_008.mp3","charTypeName":"word"},{"id":10321,"position":8,"arabic":"يَسْتَمِعِ","translation":"শুনবে","audioUrl":"wbw/072_009_009.mp3","charTypeName":"word"},{"id":10322,"position":9,"arabic":"ٱلْـَٔانَ","translation":"এখন","audioUrl":"wbw/072_009_010.mp3","charTypeName":"word"},{"id":10323,"position":10,"arabic":"يَجِدْ","translation":"সে পাবে","audioUrl":"wbw/072_009_011.mp3","charTypeName":"word"},{"id":10324,"position":11,"arabic":"لَهُۥ","translation":"তার জন্য","audioUrl":"wbw/072_009_012.mp3","charTypeName":"word"},{"id":10325,"position":12,"arabic":"شِهَابًۭا","translation":"অগ্নিশিখা","audioUrl":"wbw/072_009_013.mp3","charTypeName":"word"},{"id":10326,"position":13,"arabic":"رَّصَدًۭا","translation":"পেতে রাখা","audioUrl":"wbw/072_009_014.mp3","charTypeName":"word"},{"id":10327,"position":14,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"وَأَنَّا لَا نَدْرِىٓ أَشَرٌّ أُرِيدَ بِمَن فِى ٱلْأَرْضِ أَمْ أَرَادَ بِهِمْ رَبُّهُمْ رَشَدًۭا","translation":"\"'And [now we have become aware] that we [created beings] may not know whether evil fortune is intended for [any of] those who live on earth, or whether it is their Sustainer’s will to endow them with consciousness of what is right:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5457.mp3","surahId":72,"words":[{"id":11542,"position":1,"arabic":"وَأَنَّا","translation":"এবং আমরা যে","audioUrl":"wbw/072_010_001.mp3","charTypeNa