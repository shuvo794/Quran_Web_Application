004.mp3","charTypeName":"word"},{"id":15242,"position":5,"arabic":"ءَامَنَّا","translation":"আমরা ঈমান এনেছি","audioUrl":"wbw/072_013_005.mp3","charTypeName":"word"},{"id":15243,"position":6,"arabic":"بِهِۦ ۖ","translation":"তার উপর","audioUrl":"wbw/072_013_006.mp3","charTypeName":"word"},{"id":15245,"position":7,"arabic":"فَمَن","translation":"যে অতএব","audioUrl":"wbw/072_013_008.mp3","charTypeName":"word"},{"id":15246,"position":8,"arabic":"يُؤْمِنۢ","translation":"ঈমান আনবে","audioUrl":"wbw/072_013_009.mp3","charTypeName":"word"},{"id":15247,"position":9,"arabic":"بِرَبِّهِۦ","translation":"তার রবের উপর","audioUrl":"wbw/072_013_010.mp3","charTypeName":"word"},{"id":15248,"position":10,"arabic":"فَلَا","translation":"না অতএব","audioUrl":"wbw/072_013_011.mp3","charTypeName":"word"},{"id":15249,"position":11,"arabic":"يَخَافُ","translation":"সে ভয় করবে","audioUrl":"wbw/072_013_012.mp3","charTypeName":"word"},{"id":15250,"position":12,"arabic":"بَخْسًۭا","translation":"অবিচারের","audioUrl":"wbw/072_013_013.mp3","charTypeName":"word"},{"id":15251,"position":13,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/072_013_014.mp3","charTypeName":"word"},{"id":15252,"position":14,"arabic":"رَهَقًۭا","translation":"জুলুমের","audioUrl":"wbw/072_013_015.mp3","charTypeName":"word"},{"id":15253,"position":15,"arabic":"١٣","translation":"(১৩)","audioUrl":null,"charTypeName":"end"}]}]}