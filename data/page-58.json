,"charTypeName":"word"},{"id":58551,"position":11,"arabic":"وَٱللَّهُ","translation":"ও আল্লাহ","audioUrl":"wbw/003_068_012.mp3","charTypeName":"word"},{"id":58552,"position":12,"arabic":"وَلِىُّ","translation":"অভিভাবক","audioUrl":"wbw/003_068_013.mp3","charTypeName":"word"},{"id":58553,"position":13,"arabic":"ٱلْمُؤْمِنِينَ","translation":"ঈমানদারদের","audioUrl":"wbw/003_068_014.mp3","charTypeName":"word"},{"id":58554,"position":14,"arabic":"٦٨","translation":"(৬৮)","audioUrl":null,"charTypeName":"end"}]},{"number":69,"arabic":"وَدَّت طَّآئِفَةٌۭ مِّنْ أَهْلِ ٱلْكِتَٰبِ لَوْ يُضِلُّونَكُمْ وَمَا يُضِلُّونَ إِلَّآ أَنفُسَهُمْ وَمَا يَشْعُرُونَ","translation":"Some of the followers of earlier revelation would love to lead you astray: yet none do they lead astray but themselves, and perceive it not.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/362.mp3","surahId":3,"words":[{"id":59162,"position":1,"arabic":"وَدَّت","translation":"চায়","audioUrl":"wbw/003_069_001.mp3","charTypeName":"word"},{"id":59163,"position":2,"arabic":"طَّآئِفَةٌۭ","translation":"একদল","audioUrl":"wbw/003_069_002.mp3","charTypeName":"word"},{"id":59164,"position":3,"arabic":"مِّنْ","translation":"মধ্য হতে","audioUrl":"wbw/003_069_003.mp3","charTypeName":"word"},{"id":59165,"position":4,"arabic":"أَهْلِ","translation":"আহলি","audioUrl":"wbw/003_069_004.mp3","charTypeName":"word"},{"id":59166,"position":5,"arabic":"ٱلْكِتَـٰبِ","translation":"কিতাবদের","audioUrl":"wbw/003_069_005.mp3","charTypeName":"word"},{"id":59167,"position":6,"arabic":"لَوْ","translation":"যদি","audioUrl":"wbw/003_069_006.mp3","charTypeName":"word"},{"id":59168,"position":7,"arabic":"يُضِلُّونَكُمْ","translation":"তোমাদেরকে তারা পথভ্রষ্ট করতে পারত","audioUrl":"wbw/003_069_007.mp3","charTypeName":"word"},{"id":59169,"position":8,"arabic":"وَمَا","translation":"আর না","audioUrl":"wbw/003_069_008.mp3","charTypeName":"word"},{"id":59170,"position":9,"arabic":"يُضِلُّونَ","translation":"তারা পথভ্রষ্ট করে","