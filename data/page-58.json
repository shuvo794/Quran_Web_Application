{"id":58,"ayahs":[{"number":62,"arabic":"إِنَّ هَٰذَا لَهُوَ ٱلْقَصَصُ ٱلْحَقُّ ۚ وَمَا مِنْ إِلَٰهٍ إِلَّا ٱللَّهُ ۚ وَإِنَّ ٱللَّهَ لَهُوَ ٱلْعَزِيزُ ٱلْحَكِيمُ","translation":"Behold, this is indeed the truth of the matter, and there is no deity whatever save God; and, verily, God - He alone - is almighty, truly wise.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/355.mp3","surahId":3,"words":[{"id":55701,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়","audioUrl":"wbw/003_062_001.mp3","charTypeName":"word"},{"id":55702,"position":2,"arabic":"هَـٰذَا","translation":"এটা","audioUrl":"wbw/003_062_002.mp3","charTypeName":"word"},{"id":55703,"position":3,"arabic":"لَهُوَ","translation":"অবশ্যই সেই","audioUrl":"wbw/003_062_003.mp3","charTypeName":"word"},{"id":55704,"position":4,"arabic":"ٱلْقَصَصُ","translation":"বৃত্তান্ত","audioUrl":"wbw/003_062_004.mp3","charTypeName":"word"},{"id":55705,"position":5,"arabic":"ٱلْحَقُّ ۚ","translation":"সত্য","audioUrl":"wbw/003_062_005.mp3","charTypeName":"word"},{"id":55707,"position":6,"arabic":"وَمَا","translation":"আর নাই","audioUrl":"wbw/003_062_007.mp3","charTypeName":"word"},{"id":55708,"position":7,"arabic":"مِنْ","translation":"কোন","audioUrl":"wbw/003_062_008.mp3","charTypeName":"word"},{"id":55709,"position":8,"arabic":"إِلَـٰهٍ","translation":"ইলাহ","audioUrl":"wbw/003_062_009.mp3","charTypeName":"word"},{"id":55710,"position":9,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/003_062_010.mp3","charTypeName":"word"},{"id":55711,"position":10,"arabic":"ٱللَّهُ ۚ","translation":"আল্লাহ","audioUrl":"wbw/003_062_011.mp3","charTypeName":"word"},{"id":55713,"position":11,"arabic":"وَإِنَّ","translation":"এবং নিশ্চয়","audioUrl":"wbw/003_062_013.mp3","charTypeName":"word"},{"id":55714,"position":12,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/003_062_014.mp3","charTypeName":"word"},{"id":55715,"position":13,"arabic":"لَهُوَ","translation":"নিশ্চয়ই তিনি","audioUrl":"wbw/003_062_015.mp3","charTypeName":"word"},{"id":55716,"position":14,"arabic":"ٱلْعَزِيزُ","translation":"পরাক্রমশালী","audioUrl":"wbw/003_062_016.mp3","charTypeName":"word"},{"id":55717,"position":15,"arabic":"ٱلْحَكِيمُ","translation":"মহাবিজ্ঞ","audioUrl":"wbw/003_062_017.mp3","charTypeName":"word"},{"id":55718,"position":16,"arabic":"٦٢","translation":"(৬২)","audioUrl":null,"charTypeName":"end"}]},{"number":63,"arabic":"فَإِن تَوَلَّوْا۟ فَإِنَّ ٱللَّهَ عَلِيمٌۢ بِٱلْمُفْسِدِينَ","translation":"And if they turn away [from this truth] - behold, God has full knowledge of the spreaders of corruption.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/356.mp3","surahId":3,"words":[{"id":56156,"position":1,"arabic":"فَإِن","translation":"যদি অতঃপর","audioUrl":"wbw/003_063_001.mp3","charTypeName":"word"},{"id":56157,"position":2,"arabic":"تَوَلَّوْا۟","translation":"তারা ফিরে যায়","audioUrl":"wbw/003_063_002.mp3","charTypeName":"word"},{"id":56158,"position":3,"arabic":"فَإِنَّ","translation":"তবে নিশ্চয়","audioUrl":"wbw/003_063_003.mp3","charTypeName":"word"},{"id":56159,"position":4,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/003_063_004.mp3","charTypeName":"word"},{"id":56160,"position":5,"arabic":"عَلِيمٌۢ","translation":"খুব অবহিত","audioUrl":"wbw/003_063_005.mp3","charTypeName":"word"},{"id":56161,"position":6,"arabic":"بِٱلْمُفْسِدِينَ","translation":"ফাসাদ সৃষ্টিকারীদের সম্পর্কে","audioUrl":"wbw/003_063_006.mp3","charTypeName":"word"},{"id":56162,"position":7,"arabic":"٦٣","translation":"(৬৩)","audioUrl":null,"charTypeName":"end"}]},{"number":64,"arabic":"قُلْ يَٰٓأَهْلَ ٱلْكِتَٰبِ تَعَالَوْا۟ إِلَىٰ كَلِمَةٍۢ سَوَآءٍۭ بَيْنَنَا وَبَيْنَكُمْ أَلَّا نَعْبُدَ إِلَّا ٱللَّهَ وَلَا نُشْرِكَ بِهِۦ شَيْـًۭٔا وَلَا يَتَّخِذَ بَعْضُنَا بَعْضًا أَرْبَابًۭا مِّن دُونِ ٱللَّهِ ۚ فَإِن تَوَلَّوْا۟ فَقُولُوا۟ ٱشْهَدُوا۟ بِأَنَّا مُسْلِمُونَ","translation":"Say: \"O followers of earlier revelation! Come unto that tenet which we and you hold in common: that we shall worship none but God, and that we shall not ascribe divinity to aught beside Him, and that we shall not take human beings for our lords beside God.\" And if they turn away, then say: \"Bear witness that it is we who have surrendered ourselves unto Him.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/357.mp3","surahId":3,"words":[{"id":56595,"position":1,"arabic":"قُلْ","translation":"তুমি বল","audioUrl":"wbw/003_064_001.mp3","charTypeName":"word"},{"id":56596,"position":2,"arabic":"يَـٰٓأَهْلَ","translation":"''হে আহলে","audioUrl":"wbw/003_064_002.mp3","charTypeName":"word"},{"id":56597,"position":3,"arabic":"ٱلْكِتَـٰبِ","translation":"কিতাব","audioUrl":"wbw/003_064_003.mp3","charTypeName":"word"},{"id":56598,"position":4,"arabic":"تَعَالَوْا۟","translation":"তোমরা এস","audioUrl":"wbw/003_064_004.mp3","charTypeName":"word"},{"id":56599,"position":5,"arabic":"إِلَىٰ","translation":"প্রতি","audioUrl":"wbw/003_064_005.mp3","charTypeName":"word"},{"id":56600,"position":6,"arabic":"كَلِمَةٍۢ","translation":"একটি বাণীর (যা)","audioUrl":"wbw/003_064_006.mp3","charTypeName":"word"},{"id":56601,"position":7,"arabic":"سَوَآءٍۭ","translation":"সমান","audioUrl":"wbw/003_064_007.mp3","charTypeName":"word"},{"id":56602,"position":8,"arabic":"بَيْنَنَا","translation":"আমাদের মাঝে","audioUrl":"wbw/003_064_008.mp3","charTypeName":"word"},{"id":56603,"position":9,"arabic":"وَبَيْنَكُمْ","translation":"ও তোমাদের মাঝে","audioUrl":"wbw/003_064_009.mp3","charTypeName":"word"},{"id":56604,"position":10,"arabic":"أَلَّا","translation":"(এই) যে না","audioUrl":"wbw/003_064_010.mp3","charTypeName":"word"},{"id":56605,"position":11,"arabic":"نَعْبُدَ","translation":"ইবাদাত করব আমরা","audioUrl":"wbw/003_064_011.mp3","charTypeName":"word"},{"id":56606,"position":12,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/003_064_012.mp3","charTypeName":"word"},{"id":56607,"position":13,"arabic":"ٱللَّهَ","translation":"আল্লাহর","audioUrl":"wbw/003_064_013.mp3","charTypeName"