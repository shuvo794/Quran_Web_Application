{"id":277,"ayahs":[{"number":88,"arabic":"ٱلَّذِينَ كَفَرُوا۟ وَصَدُّوا۟ عَن سَبِيلِ ٱللَّهِ زِدْنَٰهُمْ عَذَابًۭا فَوْقَ ٱلْعَذَابِ بِمَا كَانُوا۟ يُفْسِدُونَ","translation":"Upon all who were bent on denying the truth and who turned others away from the path of God will We heap suffering upon suffering in return for all the corruption that they wrought:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1989.mp3","surahId":16,"words":[{"id":67230,"position":1,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/016_088_001.mp3","charTypeName":"word"},{"id":67231,"position":2,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/016_088_002.mp3","charTypeName":"word"},{"id":67232,"position":3,"arabic":"وَصَدُّوا۟","translation":"ও বাঁধা দিয়েছে","audioUrl":"wbw/016_088_003.mp3","charTypeName":"word"},{"id":67233,"position":4,"arabic":"عَن","translation":"থেকে","audioUrl":"wbw/016_088_004.mp3","charTypeName":"word"},{"id":67234,"position":5,"arabic":"سَبِيلِ","translation":"পথ","audioUrl":"wbw/016_088_005.mp3","charTypeName":"word"},{"id":67235,"position":6,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/016_088_006.mp3","charTypeName":"word"},{"id":67236,"position":7,"arabic":"زِدْنَـٰهُمْ","translation":"আমরা বাড়াবো তাদের","audioUrl":"wbw/016_088_007.mp3","charTypeName":"word"},{"id":67237,"position":8,"arabic":"عَذَابًۭا","translation":"শাস্তি","audioUrl":"wbw/016_088_008.mp3","charTypeName":"word"},{"id":67238,"position":9,"arabic":"فَوْقَ","translation":"উপরে","audioUrl":"wbw/016_088_009.mp3","charTypeName":"word"},{"id":67239,"position":10,"arabic":"ٱلْعَذَابِ","translation":"শাস্তির","audioUrl":"wbw/016_088_010.mp3","charTypeName":"word"},{"id":67240,"position":11,"arabic":"بِمَا","translation":"এ কারণে যা","audioUrl":"wbw/016_088_011.mp3","charTypeName":"word"},{"id":67241,"position":12,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/016_088_012.mp3","charTypeName":"word"},{"id":67242,"position":13,"arabic":"يُفْسِدُونَ","translation":"তারা অশান্তি সৃষ্টি করে","audioUrl":"wbw/016_088_013.mp3","charTypeName":"word"},{"id":67243,"position":14,"arabic":"٨٨","translation":"(৮৮)","audioUrl":null,"charTypeName":"end"}]},{"number":89,"arabic":"وَيَوْمَ نَبْعَثُ فِى كُلِّ أُمَّةٍۢ شَهِيدًا عَلَيْهِم مِّنْ أَنفُسِهِمْ ۖ وَجِئْنَا بِكَ شَهِيدًا عَلَىٰ هَٰٓؤُلَآءِ ۚ وَنَزَّلْنَا عَلَيْكَ ٱلْكِتَٰبَ تِبْيَٰنًۭا لِّكُلِّ شَىْءٍۢ وَهُدًۭى وَرَحْمَةًۭ وَبُشْرَىٰ لِلْمُسْلِمِينَ","translation":"for one Day We shall raise up within every community a witness against them from among themselves. And thee [too, O Prophet,] have We brought forth to bear witness regarding those [whom thy message may have reached], inasmuch as We have bestowed from on high upon thee, step by step, this divine writ, to make everything clear, and to provide guidance and grace and a glad tiding unto all who have surrendered themselves to God.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1990.mp3","surahId":16,"words":[{"id":67518,"position":1,"arabic":"وَيَوْمَ","translation":"এবং সেদিন","audioUrl":"wbw/016_089_001.mp3","charTypeName":"word"},{"id":67519,"position":2,"arabic":"نَبْعَثُ","translation":"আমরা উঠাবো","audioUrl":"wbw/016_089_002.mp3","charTypeName":"word"},{"id":67520,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/016_089_003.mp3","charTypeName":"word"},{"id":67521,"position":4,"arabic":"كُلِّ","translation":"প্রত্যেক","audioUrl":"wbw/016_089_004.mp3","charTypeName":"word"},{"id":67522,"position":5,"arabic":"أُمَّةٍۢ","translation":"সম্প্রদায়ের","audioUrl":"wbw/016_089_005.mp3","charTypeName":"word"},{"id":67523,"position":6,"arabic":"شَهِيدًا","translation":"একজন সাক্ষী","audioUrl":"wbw/016_089_006.mp3","charTypeName":"word"},{"id":67524,"position":7,"arabic":"عَلَيْهِم","translation":"বিরুদ্ধে তাদের","audioUrl":"wbw/016_089_007.mp3","charTypeName":"word"},{"id":67525,"position":8,"arabic":"مِّنْ","translation":"মধ্য থেকে","audioUrl":"wbw/016_089_008.mp3","charTypeName":"word"},{"id":67526,"position":9,"arabic":"أَنفُسِهِمْ ۖ","translation":"নিজেদের তাদের","audioUrl":"wbw/016_089_009.mp3","charTypeName":"word"},{"id":67528,"position":10,"arabic":"وَجِئْنَا","translation":"এবং আমরা আসবো","audioUrl":"wbw/016_089_011.mp3","charTypeName":"word"},{"id":67529,"position":11,"arabic":"بِكَ","translation":"নিয়ে তোমাকে","audioUrl":"wbw/016_089_012.mp3","charTypeName":"word"},{"id":67530,"position":12,"arabic":"شَهِيدًا","translation":"সাক্ষী (স্বরূপ)","audioUrl":"wbw/016_089_013.mp3","charTypeName":"word"},{"id":67531,"position":13,"arabic":"عَلَىٰ","translation":"বিরুদ্ধে","audioUrl":"wbw/016_089_014.mp3","charTypeName":"word"},{"id":67532,"position":14,"arabic":"هَـٰٓؤُلَآءِ ۚ","translation":"এদের","audioUrl":"wbw/016_089_015.mp3","charTypeName":"word"},{"id":67534,"position":15,"arabic":"وَنَزَّلْنَا","translation":"এবং আমরা অবতীর্ণ করেছি","audioUrl":"wbw/016_089_017.mp3","charTypeName":"word"},{"id":67535,"position":16,"arabic":"عَلَيْكَ","translation":"তোমার উপর","audioUrl":"wbw/016_089_018.mp3","charTypeName":"word"},{"id":67536,"position":17,"arabic":"ٱلْكِتَـٰبَ","translation":"(এই) কিতাব","audioUrl":"wbw/016_089_019.mp3","charTypeName":"word"},{"id":67537,"position":18,"arabic":"تِبْيَـٰنًۭا","translation":"সুস্পষ্ট বর্ণনা করা","audioUrl":"wbw/016_089_020.mp3","charTypeName":"word"},{"id":67538,"position":19,"arabic":"لِّكُلِّ","translation":"জন্যে প্রত্যেক","audioUrl":"wbw/016_089_021.mp3","charTypeName":"word"},{"id":67539,"position":20,"arabic":"شَىْءٍۢ","translation":"বস্তুর","audioUrl":"wbw/016_089_022.mp3","charTypeName":"word"},{"id":67540,"position":21,"arabic":"وَهُدًۭى","translation":"ও পথ নির্দেশ","audioUrl":"wbw/016_089_023.mp3","charTypeName":"word"},{"id":67541,"position":22,"arabic":"وَرَحْمَةًۭ","translation":"ও অনুগ্রহ","audioUrl":"wbw/016_089_024.mp3","charTypeName":"word"},{"id":67542,"position":23,"arabic":"وَبُشْرَىٰ","translation":"এবং সুসংবাদ","audioUrl":"wbw/016_089_025.mp3","charTypeName":"word"},{"id":67543,"position":24,"arabic":"لِلْمُسْلِمِينَ","translation":"জন্যে আত্নসমর্পণকারীদের","audioUrl":"wbw/016_089_026.mp3","charTypeName":"word"},{"id":67544,"position":25,"arabic":"٨٩","translation":"(৮৯)","audioUrl":null,"charTypeName":"end"}]},{"number":90,"arabic":"۞ إِنَّ ٱللَّهَ يَأْمُرُ بِٱلْعَدْلِ وَٱلْإِحْسَٰنِ وَإِيتَآئِ ذِى ٱلْقُرْبَىٰ وَيَنْهَىٰ عَنِ ٱلْفَحْشَآءِ وَٱلْمُنكَرِ وَٱلْبَغْىِ ۚ يَعِظُكُمْ لَعَلَّكُمْ تَذَكَّرُونَ","translation":"BEHOLD, God enjoins justice, and the doing of good, and generosity towards [one's] fellow-men; and He forbids all that is shameful and all that runs counter to reason, as well as envy; [and] He exhorts you [repeatedly] so that you might bear [all this] in mind.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1991.mp3","surahId":16,"words":[{"id":67999,"position":1,"arabic":"۞ إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/016_090_002.mp3","charTypeName":"word"},{"id":68000,"position":2,"arabic":"ٱللَّهَ","translation":"আল্লাহ্‌","audioUrl":"wbw/016_090_003.mp3","charTypeName":"word"},{"id":68001,"position":3,"arabic":"يَأْمُرُ","translation":"নির্দেশ দেন","audioUrl":"wbw/016_090_004.mp3","charTypeName":"word"},{"id":68002,"position":4,"arabic":"بِٱلْعَدْلِ","translation":"ব্যাপারে ন্যায়ের","audioUrl":"wbw/016_090_005.mp3","charTypeName":"word"},{"id":68003,"position":5,"arabic":"وَٱلْإِحْسَـٰنِ","translation":"সদাচরণ","audioUrl":"wbw/016_090_006.mp3","charTypeName":"word"},{"id":68004,"position":6,"arabic":"وَإِيتَآئِ","translation":"ও দান করার","audioUrl":"wbw/016_090_007.mp3","charTypeName":"word"},{"id":68005,"position":7,"arabic":"ذِى","translation":"সম্পন্ন","audioUrl":"wbw/016_090_008.mp3","charTypeName":"word"},{"id":68006,"position":8,"arabic":"ٱلْقُرْبَىٰ","translation":"নৈকট্য (আত্নীয়-স্বজনকে)","audioUrl":"wbw/016_090_009.mp3","charTypeName":"word"},{"id":68007,"position":9,"arabic":"وَيَنْهَىٰ","translation":"এবং নিষেধ করেন","audioUrl":"wbw/016_090_010.mp3","charTypeName":"word"},{"id":68008,"position":10,"arabic":"عَنِ","translation":"থেকে","audioUrl":"wbw/016_090_011.mp3","charTypeName":"word"},{"id":68009,"position":11,"arabic":"ٱلْفَحْشَآءِ","translation":"অশ্লীলতা","audioUrl":"wbw/016_090_012.mp3","charTypeName":"word"},{"id":68010,"position":12,"arabic":"وَٱلْمُنكَرِ","translation":"ও অসৎ কাজ","audioUrl":"wbw/016_090_013.mp3","charTypeName":"word"},{"id":68011,"position":13,"arabic":"وَٱلْبَغْىِ ۚ","translation":"ও সীমালঙ্ঘন","audioUrl":"wbw/016_090_014.mp3","charTypeName":"word"},{"id":68013,"position":14,"arabic":"يَعِظُكُمْ","translation":"তিনি উপদেশ দিচ্ছেন তোমাদের","audioUrl":"wbw/016_090_016.mp3","charTypeName":"word"},{"id":68014,"position":15,"arabic":"لَعَلَّكُمْ","translation":"যাতে তোমরা","audioUrl":"wbw/016_090_017.mp3","charTypeName":"word"},{"id":68015,"position":16,"arabic":"تَذَكَّرُونَ","translation":"শিক্ষা গ্রহণ করো","audioUrl":"wbw/016_090_018.mp3","charTypeName":"word"},{"id":68016,"position":17,"arabic":"٩٠","translation":"(৯০)","audioUrl":null,"charTypeName":"end"}]},{"number":91,"arabic":"وَأَوْفُوا۟ بِعَهْدِ ٱللَّهِ إِذَا عَٰهَدتُّمْ وَلَا تَنقُضُوا۟ ٱلْأَيْمَٰنَ بَعْدَ تَوْكِيدِهَا وَقَدْ جَعَلْتُمُ ٱللَّهَ عَلَيْكُمْ كَفِيلًا ۚ إِنَّ ٱللَّهَ يَعْلَمُ مَا تَفْعَلُونَ","translation":"And be true to your bond with God whenever you bind yourselves by a pledge, and do not break [your] oaths after having [freely] confirmed them and having called upon God to be witness to your good faith: behold, God knows all that you do.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1992.mp3","surahId":16,"words":[{"id":68244,"position":1,"arabic":"وَأَوْفُوا۟","translation":"তোমরা পূর্ণ করো","audioUrl":"wbw/016_091_001.mp3","charTypeName":"word"},{"id":68245,"position":2,"arabic":"بِعَهْدِ","translation":"অঙ্গীকার","audioUrl":"wbw/016_091_002.mp3","charTypeName":"word"},{"id":68246,"position":3,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/016_091_003.mp3","charTypeName":"word"},{"id":68247,"position":4,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/016_091_004.mp3","charTypeName":"word"},{"id":68248,"position":5,"arabic":"عَـٰهَدتُّمْ","translation":"তোমরা অঙ্গীকার করেছো","audioUrl":"wbw/016_091_005.mp3","charTypeName":"word"},{"id":68249,"position":6,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/016_091_006.mp3","charTypeName":"word"},{"id":68250,"position":7,"arabic":"تَنقُضُوا۟","translation":"তোমরা ভঙ্গ করো","audioUrl":"wbw/016_091_007.mp3","charTypeName":"word"},{"id":68251,"position":8,"arabic":"ٱلْأَيْمَـٰنَ","translation":"শপথসমূহকে","audioUrl":"wbw/016_091_008.mp3","charTypeName":"word"},{"id":68252,"position":9,"arabic":"بَعْدَ","translation":"পরে","audioUrl":"wbw/016_091_009.mp3","charTypeName":"word"},{"id":68253,"position":10,"arabic":"تَوْكِيدِهَا","translation":"দৃঢ় করার তা","audioUrl":"wbw/016_091_010.mp3","charTypeName":"word"},{"id":68254,"position":11,"arabic":"وَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/016_091_011.mp3","charTypeName":"word"},{"id":68255,"position":12,"arabic":"جَعَلْتُمُ","translation":"তোমরা করেছো","audioUrl":"wbw/016_091_012.mp3","charTypeName":"word"},{"id":68256,"position":13,"arabic":"ٱللَّهَ","translation":"আল্লাহকে","audioUrl":"wbw/016_091_013.mp3","charTypeName":"word"},{"id":68257,"position":14,"arabic":"عَلَيْكُمْ","translation":"উপর তোমাদের","audioUrl":"wbw/016_091_014.mp3","charTypeName":"word"},{"id":68258,"position":15,"arabic":"كَفِيلًا ۚ","translation":"অভিভাবক","audioUrl":"wbw/016_091_015.mp3","charTypeName":"word"},{"id":68260,"position":16,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/016_091_017.mp3","charTypeName":"word"},{"id":68261,"position":17,"arabic":"ٱللَّهَ","translation":"আল্লাহ্‌","audioUrl":"wbw/016_091_018.mp3","charTypeName":"word"},{"id":68262,"position":18,"arabic":"يَعْلَمُ","translation":"জানেন","audioUrl":"wbw/016_091_019.mp3","charTypeName":"word"},{"id":68263,"position":19,"arabic":"مَا","translation":"যা","audioUrl":"wbw/016_091_020.mp3","charTypeName":"word"},{"id":68264,"position":20,"arabic":"تَفْعَلُونَ","translation":"তোমরা কাজ কর্ম করছো","audioUrl":"wbw/016_091_021.mp3","charTypeName":"word"},{"id":68265,"position":21,"arabic":"٩١","translation":"(৯১)","audioUrl":null,"charTypeName":"end"}]},{"number":92,"arabic":"وَلَا تَكُونُوا۟ كَٱلَّتِى نَقَضَتْ غَزْلَهَا مِنۢ بَعْدِ قُوَّةٍ أَنكَٰثًۭا تَتَّخِذُونَ أَيْمَٰنَكُمْ دَخَلًۢا بَيْنَكُمْ أَن تَكُونَ أُمَّةٌ هِىَ أَرْبَىٰ مِنْ أُمَّةٍ ۚ إِنَّمَا يَبْلُوكُمُ ٱللَّهُ بِهِۦ ۚ وَلَيُبَيِّنَنَّ لَكُمْ يَوْمَ ٱلْقِيَٰمَةِ مَا كُنتُمْ فِيهِ تَخْتَلِفُونَ","translation":"Hence, be not like her who breaks and completely untwists the yarn which she [herself] has spun and made strong-[be not like this by] using your oaths as a means of deceiving one another, simply because some of you may be more powerful than others.\" By all this, God but puts you to a test-and [He does it] so that on Resurrection Day He might make clear unto you all that on which you were wont to differ.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1993.mp3","surahId":16,"words":[{"id":68878,"position":1,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/016_092_001.mp3","charTypeName":"word"},{"id":68879,"position":2,"arabic":"تَكُونُوا۟","translation":"তোমরা হয়ো","audioUrl":"wbw/016_092_002.mp3","charTypeName":"word"},{"id":68880,"position":3,"arabic":"كَٱلَّتِى","translation":"মতো সেই (মহিলার)","audioUrl":"wbw/016_092_003.mp3","charTypeName":"word"},{"id":68881,"position":4,"arabic":"نَقَضَتْ","translation":"যে কেটেছে","audioUrl":"wbw/016_092_004.mp3","charTypeName":"word"},{"id":68882,"position":5,"arabic":"غَزْلَهَا","translation":"তার সূতা","audioUrl":"wbw/016_092_005.mp3","charTypeName":"word"},{"id":68883,"position":6,"arabic":"مِنۢ","translation":"থেকে","audioUrl":"wbw/016_092_006.mp3","charTypeName":"word"},{"id":68884,"position":7,"arabic":"بَعْدِ","translation":"পর","audioUrl":"wbw/016_092_007.mp3","charTypeName":"word"},{"id":68885,"position":8,"arabic