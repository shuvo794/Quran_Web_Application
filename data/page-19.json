{"id":19,"ayahs":[{"number":120,"arabic":"وَلَن تَرْضَىٰ عَنكَ ٱلْيَهُودُ وَلَا ٱلنَّصَٰرَىٰ حَتَّىٰ تَتَّبِعَ مِلَّتَهُمْ ۗ قُلْ إِنَّ هُدَى ٱللَّهِ هُوَ ٱلْهُدَىٰ ۗ وَلَئِنِ ٱتَّبَعْتَ أَهْوَآءَهُم بَعْدَ ٱلَّذِى جَآءَكَ مِنَ ٱلْعِلْمِ ۙ مَا لَكَ مِنَ ٱللَّهِ مِن وَلِىٍّۢ وَلَا نَصِيرٍ","translation":"For, never will the Jews be pleased with thee. nor yet the Christians, unless thou follow their own creeds. Say: \"Behold, God's guidance is the only true guidance.\" And, indeed, if thou shouldst follow their errant views after all the knowledge that has come unto thee. thou wouldst have none to protect thee from God, and none to bring thee succour.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/127.mp3","surahId":2,"words":[{"id":76304,"position":1,"arabic":"وَلَن","translation":"এবং কখনও না","audioUrl":"wbw/002_120_001.mp3","charTypeName":"word"},{"id":76305,"position":2,"arabic":"تَرْضَىٰ","translation":"খুশি হবে","audioUrl":"wbw/002_120_002.mp3","charTypeName":"word"},{"id":76306,"position":3,"arabic":"عَنكَ","translation":"তোমার প্রতি","audioUrl":"wbw/002_120_003.mp3","charTypeName":"word"},{"id":76307,"position":4,"arabic":"ٱلْيَهُودُ","translation":"ইহূদীরা","audioUrl":"wbw/002_120_004.mp3","charTypeName":"word"},{"id":76308,"position":5,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/002_120_005.mp3","charTypeName":"word"},{"id":76309,"position":6,"arabic":"ٱلنَّصَـٰرَىٰ","translation":"খ্রিষ্টানরা","audioUrl":"wbw/002_120_006.mp3","charTypeName":"word"},{"id":76310,"position":7,"arabic":"حَتَّىٰ","translation":"যতক্ষণ না","audioUrl":"wbw/002_120_007.mp3","charTypeName":"word"},{"id":76311,"position":8,"arabic":"تَتَّبِعَ","translation":"তুমি অনুসরণ করবে","audioUrl":"wbw/002_120_008.mp3","charTypeName":"word"},{"id":76312,"position":9,"arabic":"مِلَّتَهُمْ ۗ","translation":"তাদের ধর্মাদর্শ","audioUrl":"wbw/002_120_009.mp3","charTypeName":"word"},{"id":76314,"position":10,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/002_120_011.mp3","charTypeName":"word"},{"id":76315,"position":11,"arabic":"إِنَّ","translation":"''নিশ্চয়ই","audioUrl":"wbw/002_120_012.mp3","charTypeName":"word"},{"id":76316,"position":12,"arabic":"هُدَى","translation":"পথ নির্দেশনা","audioUrl":"wbw/002_120_013.mp3","charTypeName":"word"},{"id":76317,"position":13,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌র","audioUrl":"wbw/002_120_014.mp3","charTypeName":"word"},{"id":76318,"position":14,"arabic":"هُوَ","translation":"সেটাই","audioUrl":"wbw/002_120_015.mp3","charTypeName":"word"},{"id":76319,"position":15,"arabic":"ٱلْهُدَىٰ ۗ","translation":"সঠিক পথনির্দেশনা''","audioUrl":"wbw/002_120_016.mp3","charTypeName":"word"},{"id":76321,"position":16,"arabic":"وَلَئِنِ","translation":"এবং অবশ্যই যদি","audioUrl":"wbw/002_120_018.mp3","charTypeName":"word"},{"id":76322,"position":17,"arabic":"ٱتَّبَعْتَ","translation":"তুমি অনুসরণ কর","audioUrl":"wbw/002_120_019.mp3","charTypeName":"word"},{"id":76323,"position":18,"arabic":"أَهْوَآءَهُم","translation":"তাদের খেয়ালখুশির","audioUrl":"wbw/002_120_020.mp3","charTypeName":"word"},{"id":76324,"position":19,"arabic":"بَعْدَ","translation":"পরেও","audioUrl":"wbw/002_120_021.mp3","charTypeName":"word"},{"id":76325,"position":20,"arabic":"ٱلَّذِى","translation":"যা","audioUrl":"wbw/002_120_022.mp3","charTypeName":"word"},{"id":76326,"position":21,"arabic":"جَآءَكَ","translation":"তোমার কাছে এসেছে","audioUrl":"wbw/002_120_023.mp3","charTypeName":"word"},{"id":76327,"position":22,"arabic":"مِنَ","translation":"থেকে","audioUrl":"wbw/002_120_024.mp3","charTypeName":"word"},{"id":76328,"position":23,"arabic":"ٱلْعِلْمِ ۙ","translation":"(সঠিক) জ্ঞান","audioUrl":"wbw/002_120_025.mp3","charTypeName":"word"},{"id":76330,"position":24,"arabic":"مَا","translation":"না","audioUrl":"wbw/002_120_027.mp3","charTypeName":"word"},{"id":76331,"position":25,"arabic":"لَكَ","translation":"তোমার জন্য (পাবে)","audioUrl":"wbw/002_120_028.mp3","charTypeName":"word"},{"id":76332,"position":26,"arabic":"مِنَ","translation":"হতে","audioUrl":"wbw/002_120_029.mp3","charTypeName":"word"},{"id":76333,"position":27,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌ (বাঁচাতে)","audioUrl":"wbw/002_120_030.mp3","charTypeName":"word"},{"id":76334,"position":28,"arabic":"مِن","translation":"কোনো","audioUrl":"wbw/002_120_031.mp3","charTypeName":"word"},{"id":76335,"position":29,"arabic":"وَلِىٍّۢ","translation":"বন্ধু","audioUrl":"wbw/002_120_032.mp3","charTypeName":"word"},{"id":76336,"position":30,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/002_120_033.mp3","charTypeName":"word"},{"id":76337,"position":31,"arabic":"نَصِيرٍ","translation":"কোনো সাহায্যকারী","audioUrl":"wbw/002_120_034.mp3","charTypeName":"word"},{"id":76338,"position":32,"arabic":"١٢٠","translation":"(১২০)","audioUrl":null,"charTypeName":"end"}]},{"number":121,"arabic":"ٱلَّذِينَ ءَاتَيْنَٰهُمُ ٱلْكِتَٰبَ يَتْلُونَهُۥ حَقَّ تِلَاوَتِهِۦٓ أُو۟لَٰٓئِكَ يُؤْمِنُونَ بِهِۦ ۗ وَمَن يَكْفُرْ بِهِۦ فَأُو۟لَٰٓئِكَ هُمُ ٱلْخَٰسِرُونَ","translation":"Those unto whom We have vouchsafed the divine writ [and who] follow it as it ought to be followed -it is they who [truly] believe in it; whereas all who choose to deny its truth -it is they, they who are the losers!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/128.mp3","surahId":2,"words":[{"id":76566,"position":1,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/002_121_001.mp3","charTypeName":"word"},{"id":76567,"position":2,"arabic":"ءَاتَيْنَـٰهُمُ","translation":"তাদের আমরা দিয়েছি","audioUrl":"wbw/002_121_002.mp3","charTypeName":"word"},{"id":76568,"position":3,"arabic":"ٱلْكِتَـٰبَ","translation":"কিতাব","audioUrl":"wbw/002_121_003.mp3","charTypeName":"word"},{"id":76569,"position":4,"arabic":"يَتْلُونَهُۥ","translation":"তা তারা তিলাওয়াত","audioUrl":"wbw/002_121_004.mp3","charTypeName":"word"},{"id":76570,"position":5,"arabic":"حَقَّ","translation":"যথোপযুক্ত","audioUrl":"wbw/002_121_005.mp3","charTypeName":"word"},{"id":76571,"position":6,"arabic":"تِلَاوَتِهِۦٓ","translation":"তার তিলাওয়াত","audioUrl":"wbw/002_121_006.mp3","charTypeName":"word"},{"id":76572,"position":7,"arabic":"أُو۟لَـٰٓئِكَ","translation":"তারাই","audioUrl":"wbw/002_121_007.mp3","charTypeName":"word"},{"id":76573,"position":8,"arabic":"يُؤْمِنُونَ","translation":"ঈমান আনে","audioUrl":"wbw/002_121_008.mp3","charTypeName":"word"},{"id":76574,"position":9,"arabic":"بِهِۦ ۗ","translation":"এর উপর","audioUrl":"wbw/002_121_009.mp3","charTypeName":"word"},{"id":76576,"position":10,"arabic":"وَمَن","translation":"এবং যে","audioUrl":"wbw/002_121_011.mp3","charTypeName":"word"},{"id":76577,"position":11,"arabic":"يَكْفُرْ","translation":"অস্বীকার করে","audioUrl":"wbw/002_121_012.mp3","charTypeName":"word"},{"id":76578,"position":12,"arabic":"بِهِۦ","translation":"তার প্রতি","audioUrl":"wbw/002_121_013.mp3","charTypeName":"word"},{"id":76579,"position":13,"arabic":"فَأُو۟لَـٰٓئِكَ","translation":"ঐসব (লোক) মূলত","audioUrl":"wbw/002_121_014.mp3","charTypeName":"word"},{"id":76580,"position":14,"arabic":"هُمُ","translation":"তারাই","audioUrl":"wbw/002_121_015.mp3","charTypeName":"word"},{"id":76581,"position":15,"arabic":"ٱلْخَـٰسِرُونَ","translation":"ক্ষতিগ্রস্থ","audioUrl":"wbw/002_121_016.mp3","charTypeName":"word"},{"id":76582,"position":16,"arabic":"١٢١","translation":"(১২১)","audioUrl":null,"charTypeName":"end"}]},{"number":122,"arabic":"يَٰبَنِىٓ إِسْرَٰٓءِيلَ ٱذْكُرُوا۟ نِعْمَتِىَ ٱلَّتِىٓ أَنْعَمْتُ عَلَيْكُمْ وَأَنِّى فَضَّلْتُكُمْ عَلَى ٱلْعَٰلَمِينَ","translation":"O CHILDREN of Israel! Remember those blessings of Mine with which I graced you, and how I favoured you above all other people;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/129.mp3","surahId":2,"words":[{"id":76716,"position":1,"arabic":"يَـٰبَنِىٓ","translation":"হে বনী","audioUrl":"wbw/002_122_001.mp3","charTypeName":"word"},{"id":76717,"position":2,"arabic":"إِسْرَٰٓءِيلَ","translation":"ইসরাঈল","audioUrl":"wbw/002_122_002.mp3","charTypeName":"word"},{"id":76718,"position":3,"arabic":"ٱذْكُرُوا۟","translation":"তোমরা স্মরণ করো","audioUrl":"wbw/002_122_003.mp3","charTypeName":"word"},{"id":76719,"position":4,"arabic":"نِعْمَتِىَ","translation":"আমার অনুগ্রহের(কথা)","audioUrl":"wbw/002_122_004.mp3","charTypeName":"word"},{"id":76720,"position":5,"arabic":"ٱلَّتِىٓ","translation":"যা","audioUrl":"wbw/002_122_005.mp3","charTypeName":"word"},{"id":76721,"position":6,"arabic":"أَنْعَمْتُ","translation":"আমি অনুগ্রহ দিয়েছি","audioUrl":"wbw/002_122_006.mp3","charTypeName":"word"},{"id":76722,"position":7,"arabic":"عَلَيْكُمْ","translation":"তোমাদের উপর","audioUrl":"wbw/002_122_007.mp3","charTypeName":"word"},{"id":76723,"position":8,"arabic":"وَأَنِّى","translation":"ও আমি নিশ্চয়ই","audioUrl":"wbw/002_122_008.mp3","charTypeName":"word"},{"id":76724,"position":9,"arabic":"فَضَّلْتُكُمْ","translation":"তোমাদেরকে শ্রেষ্ঠত্ব দিয়েছি","audioUrl":"wbw/002_122_009.mp3","charTypeName":"word"},{"id":76725,"position":10,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/002_122_010.mp3","charTypeName":"word"},{"id":76726,"position":11,"arabic":"ٱلْعَـٰلَمِينَ","translation":"সারা বিশ্বের","audioUrl":"wbw/002_122_011.mp3","charTypeName":"word"},{"id":76727,"position":12,"arabic":"١٢٢","translation":"(১২২)","audioUrl":null,"charTypeName":"end"}]},{"number":123,"arabic":"وَٱتَّقُوا۟ يَوْمًۭا لَّا تَجْزِى نَفْسٌ عَن نَّفْسٍۢ شَيْـًۭٔا وَلَا يُقْبَلُ مِنْهَا عَدْلٌۭ وَلَا تَنفَعُهَا شَفَٰعَةٌۭ وَلَا هُمْ يُنصَرُونَ","translation":"and remain conscious of [the coming of] a Day when no human being shall in the least avail another, nor shall ransom be accepted from any of them, nor shall intercession be of any use to them, and none shall be succoured.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/130.mp3","surahId":2,"words":[{"id":76787,"position":1,"arabic":"وَٱتَّقُوا۟","translation":"এবং তোমরা ভয় করো","audioUrl":"wbw/002_123_001.mp3","charTypeName":"word"},{"id":76788,"position":2,"arabic":"يَوْمًۭا","translation"