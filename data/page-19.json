ork/quran/audio/128/ar.alafasy/133.mp3","surahId":2,"words":[{"id":77357,"position":1,"arabic":"وَإِذْ","translation":"এবং (স্মরণ করো) যখন","audioUrl":"wbw/002_126_001.mp3","charTypeName":"word"},{"id":77358,"position":2,"arabic":"قَالَ","translation":"বলেছিল","audioUrl":"wbw/002_126_002.mp3","charTypeName":"word"},{"id":77359,"position":3,"arabic":"إِبْرَٰهِـۧمُ","translation":"ইবরাহীম","audioUrl":"wbw/002_126_003.mp3","charTypeName":"word"},{"id":77360,"position":4,"arabic":"رَبِّ","translation":"''হে আমার রব","audioUrl":"wbw/002_126_004.mp3","charTypeName":"word"},{"id":77361,"position":5,"arabic":"ٱجْعَلْ","translation":"বানাও","audioUrl":"wbw/002_126_005.mp3","charTypeName":"word"},{"id":77362,"position":6,"arabic":"هَـٰذَا","translation":"এই","audioUrl":"wbw/002_126_006.mp3","charTypeName":"word"},{"id":77363,"position":7,"arabic":"بَلَدًا","translation":"নগরকে","audioUrl":"wbw/002_126_007.mp3","charTypeName":"word"},{"id":77364,"position":8,"arabic":"ءَامِنًۭا","translation":"নিরাপদ","audioUrl":"wbw/002_126_008.mp3","charTypeName":"word"},{"id":77365,"position":9,"arabic":"وَٱرْزُقْ","translation":"ও জীবিকা দাও","audioUrl":"wbw/002_126_009.mp3","charTypeName":"word"},{"id":77366,"position":10,"arabic":"أَهْلَهُۥ","translation":"তার অধিবাসীদের","audioUrl":"wbw/002_126_010.mp3","charTypeName":"word"},{"id":77367,"position":11,"arabic":"مِنَ","translation":"থেকে","audioUrl":"wbw/002_126_011.mp3","charTypeName":"word"},{"id":77368,"position":12,"arabic":"ٱلثَّمَرَٰتِ","translation":"(সব রকমের) ফলমূল","audioUrl":"wbw/002_126_012.mp3","charTypeName":"word"},{"id":77369,"position":13,"arabic":"مَنْ","translation":"যে কেউ","audioUrl":"wbw/002_126_013.mp3","charTypeName":"word"},{"id":77370,"position":14,"arabic":"ءَامَنَ","translation":"ঈমান আনবে","audioUrl":"wbw/002_126_014.mp3","charTypeName":"word"},{"id":77371,"position":15,"arabic":"مِنْهُم","translation":"তাদের মধ্য থেকে","audioUrl":"wbw/002_126_015.mp3","charTypeName":"word"},{"id":77372,"position":16,"arabic"