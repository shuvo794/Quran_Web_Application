{"id":222,"ayahs":[{"number":6,"arabic":"۞ وَمَا مِن دَآبَّةٍۢ فِى ٱلْأَرْضِ إِلَّا عَلَى ٱللَّهِ رِزْقُهَا وَيَعْلَمُ مُسْتَقَرَّهَا وَمُسْتَوْدَعَهَا ۚ كُلٌّۭ فِى كِتَٰبٍۢ مُّبِينٍۢ","translation":"And there is no living creature on earth but depends for its sustenance on God; and He knows its time-limit [on earth] and its resting-place [after death]: all [this] is laid down in [His] clear decree.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1479.mp3","surahId":11,"words":[{"id":6748,"position":1,"arabic":"۞ وَمَا","translation":"এবং নেই","audioUrl":"wbw/011_006_002.mp3","charTypeName":"word"},{"id":6749,"position":2,"arabic":"مِن","translation":"(এমন) কোন","audioUrl":"wbw/011_006_003.mp3","charTypeName":"word"},{"id":6750,"position":3,"arabic":"دَآبَّةٍۢ","translation":"বিচরণশীল জীব","audioUrl":"wbw/011_006_004.mp3","charTypeName":"word"},{"id":6751,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/011_006_005.mp3","charTypeName":"word"},{"id":6752,"position":5,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/011_006_006.mp3","charTypeName":"word"},{"id":6753,"position":6,"arabic":"إِلَّا","translation":"এছাড়া","audioUrl":"wbw/011_006_007.mp3","charTypeName":"word"},{"id":6754,"position":7,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/011_006_008.mp3","charTypeName":"word"},{"id":6755,"position":8,"arabic":"ٱللَّهِ","translation":"আল্লাহরই","audioUrl":"wbw/011_006_009.mp3","charTypeName":"word"},{"id":6756,"position":9,"arabic":"رِزْقُهَا","translation":"তার জীবিকার (দায়িত্ব)","audioUrl":"wbw/011_006_010.mp3","charTypeName":"word"},{"id":6757,"position":10,"arabic":"وَيَعْلَمُ","translation":"এবং তিনি জানেন","audioUrl":"wbw/011_006_011.mp3","charTypeName":"word"},{"id":6758,"position":11,"arabic":"مُسْتَقَرَّهَا","translation":"তার স্থায়ী অবস্থান","audioUrl":"wbw/011_006_012.mp3","charTypeName":"word"},{"id":6759,"position":12,"arabic":"وَمُسْتَوْدَعَهَا ۚ","translation":"ও তার অস্থায়ী অবস্থান","audioUrl":"wbw/011_006_013.mp3","charTypeName":"word"},{"id":6761,"position":13,"arabic":"كُلٌّۭ","translation":"সবই","audioUrl":"wbw/011_006_015.mp3","charTypeName":"word"},{"id":6762,"position":14,"arabic":"فِى","translation":"মধ্যে (আছে)","audioUrl":"wbw/011_006_016.mp3","charTypeName":"word"},{"id":6763,"position":15,"arabic":"كِتَـٰبٍۢ","translation":"এক কিতাবের","audioUrl":"wbw/011_006_017.mp3","charTypeName":"word"},{"id":6764,"position":16,"arabic":"مُّبِينٍۢ","translation":"সুস্পষ্ট (লিখিত)","audioUrl":"wbw/011_006_018.mp3","charTypeName":"word"},{"id":6765,"position":17,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"وَهُوَ ٱلَّذِى خَلَقَ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضَ فِى سِتَّةِ أَيَّامٍۢ وَكَانَ عَرْشُهُۥ عَلَى ٱلْمَآءِ لِيَبْلُوَكُمْ أَيُّكُمْ أَحْسَنُ عَمَلًۭا ۗ وَلَئِن قُلْتَ إِنَّكُم مَّبْعُوثُونَ مِنۢ بَعْدِ ٱلْمَوْتِ لَيَقُولَنَّ ٱلَّذِينَ كَفَرُوٓا۟ إِنْ هَٰذَآ إِلَّا سِحْرٌۭ مُّبِينٌۭ","translation":"And He it is who has created the heavens and the earth in six aeons; and [ever since He has willed to create life,] the throne of His almightiness has rested upon water. [God reminds you of your dependence on Him] in order to test you [and thus to make manifest] which of you is best in conduct. For thus it is: if thou sayest [unto men], \"Behold, you shall be raised again after death!\" - they who are bent on denying the truth are sure to answer, \"This is clearly nothing but an enchanting delusion\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1480.mp3","surahId":11,"words":[{"id":8098,"position":1,"arabic":"وَهُوَ","translation":"এবং তিনিই (আল্লাহ)","audioUrl":"wbw/011_007_001.mp3","charTypeName":"word"},{"id":8099,"position":2,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/011_007_002.mp3","charTypeName":"word"},{"id":8100,"position":3,"arabic":"خَلَقَ","translation":"সৃষ্টি করেছেন","audioUrl":"wbw/011_007_003.mp3","charTypeName":"word"},{"id":8101,"position":4,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশ","audioUrl":"wbw/011_007_004.mp3","charTypeName":"word"},{"id":8102,"position":5,"arabic":"وَٱلْأَرْضَ","translation":"ও পৃথিবী","audioUrl":"wbw/011_007_005.mp3","charTypeName":"word"},{"id":8103,"position":6,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/011_007_006.mp3","charTypeName":"word"},{"id":8104,"position":7,"arabic":"سِتَّةِ","translation":"ছয়","audioUrl":"wbw/011_007_007.mp3","charTypeName":"word"},{"id":8105,"position":8,"arabic":"أَيَّامٍۢ","translation":"দিনে","audioUrl":"wbw/011_007_008.mp3","charTypeName":"word"},{"id":8106,"position":9,"arabic":"وَكَانَ","translation":"এবং (এর পূর্বে) ছিলো","audioUrl":"wbw/011_007_009.mp3","charTypeName":"word"},{"id":8107,"position":10,"arabic":"عَرْشُهُۥ","translation":"তাঁর আরশ","audioUrl":"wbw/011_007_010.mp3","charTypeName":"word"},{"id":8108,"position":11,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/011_007_011.mp3","charTypeName":"word"},{"id":8109,"position":12,"arabic":"ٱلْمَآءِ","translation":"পানির","audioUrl":"wbw/011_007_012.mp3","charTypeName":"word"},{"id":8110,"position":13,"arabic":"لِيَبْلُوَكُمْ","translation":"যেন তিনি তোমাদের পরীক্ষা করতে পারেন","audioUrl":"wbw/011_007_013.mp3","charTypeName":"word"},{"id":8111,"position":14,"arabic":"أَيُّكُمْ","translation":"তোমাদের মধ্যে কে","audioUrl":"wbw/011_007_014.mp3","charTypeName":"word"},{"id":8112,"position":15,"arabic":"أَحْسَنُ","translation":"উত্তম","audioUrl":"wbw/011_007_015.mp3","charTypeName":"word"},{"id":8113,"position":16,"arabic":"عَمَلًۭا ۗ","translation":"কাজকর্মে","audioUrl":"wbw/011_007_016.mp3","charTypeName":"word"},{"id":8115,"position":17,"arabic":"وَلَئِن","translation":"এবং অবশ্যই যদি","audioUrl":"wbw/011_007_018.mp3","charTypeName":"word"},{"id":8116,"position":18,"arabic":"قُلْتَ","translation":"তুমি বলো","audioUrl":"wbw/011_007_019.mp3","charTypeName":"word"},{"id":8117,"position":19,"arabic":"إِنَّكُم","translation":"\"নিশ্চয়ই তোমরা","audioUrl":"wbw/011_007_020.mp3","charTypeName":"word"},{"id":8118,"position":20,"arabic":"مَّبْعُوثُونَ","translation":"উত্থিত হবে","audioUrl":"wbw/011_007_021.mp3","charTypeName":"word"},{"id":8119,"position":21,"arabic":"مِنۢ","translation":"থেকে","audioUrl":"wbw/011_007_022.mp3","charTypeName":"word"},{"id":8120,"position":22,"arabic":"بَعْدِ","translation":"পরে","audioUrl":"wbw/011_007_023.mp3","charTypeName":"word"},{"id":8121,"position":23,"arabic":"ٱلْمَوْتِ","translation":"মৃত্যুর\"","audioUrl":"wbw/011_007_024.mp3","charTypeName":"word"},{"id":8122,"position":24,"arabic":"لَيَقُولَنَّ","translation":"অবশ্যই তারা বলবে","audioUrl":"wbw/011_007_025.mp3","charTypeName":"word"},{"id":8123,"position":25,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/011_007_026.mp3","charTypeName":"word"},{"id":8124,"position":26,"arabic":"كَفَرُوٓا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/011_007_027.mp3","charTypeName":"word"},{"id":8125,"position":27,"arabic":"إِنْ","translation":"\"নয়","audioUrl":"wbw/011_007_028.mp3","charTypeName":"word"},{"id":8126,"position":28,"arabic":"هَـٰذَآ","translation":"\"এটা","audioUrl":"wbw/011_007_029.mp3","charTypeName":"word"},{"id":8127,"position":29,"arabic":"إِلَّا","translation":"এছাড়া","audioUrl":"wbw/011_007_030.mp3","charTypeName":"word"},{"id":8128,"position":30,"arabic":"سِحْرٌۭ","translation":"জাদু","audioUrl":"wbw/011_007_031.mp3","charTypeName":"word"},{"id":8129,"position":31,"arabic":"مُّبِينٌۭ","translation":"সুস্পষ্ট\"","audioUrl":"wbw/011_007_032.mp3","charTypeName":"word"},{"id":8130,"position":32,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"وَلَئِنْ أَخَّرْنَا عَنْهُمُ ٱلْعَذَابَ إِلَىٰٓ أُمَّةٍۢ مَّعْدُودَةٍۢ لَّيَقُولُنَّ مَا يَحْبِسُهُۥٓ ۗ أَلَا يَوْمَ يَأْتِيهِمْ لَيْسَ مَصْرُوفًا عَنْهُمْ وَحَاقَ بِهِم مَّا كَانُوا۟ بِهِۦ يَسْتَهْزِءُونَ","translation":"And thus it is: if We defer their suffering until a time-limit set [by Us], they are sure to say, \"What is preventing it [from coming now]?\" Oh, verily, on the Day when it befalls them there will be nothing to avert it from them; and they shall be overwhelmed by the very thing which they were wont to deride.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1481.mp3","surahId":11,"words":[{"id":9276,"position":1,"arabic":"وَلَئِنْ","translation":"এবং অবশ্যই যদি","audioUrl":"wbw/011_008_001.mp3","charTypeName":"word"},{"id":9277,"position":2,"arabic":"أَخَّرْنَا","translation":"আমরা স্হগিত রাখি","audioUrl":"wbw/011_008_002.mp3","charTypeName":"word"},{"id":9278,"position":3,"arabic":"عَنْهُمُ","translation":"তাদের থেকে","audioUrl":"wbw/011_008_003.mp3","charTypeName":"word"},{"id":9279,"position":4,"arabic":"ٱلْعَذَابَ","translation":"শাস্তি","audioUrl":"wbw/011_008_004.mp3","charTypeName":"word"},{"id":9280,"position":5,"arabic":"إِلَىٰٓ","translation":"পর্যন্ত","audioUrl":"wbw/011_008_005.mp3","charTypeName":"word"},{"id":9281,"position":6,"arabic":"أُمَّةٍۢ","translation":"একটি সময়","audioUrl":"wbw/011_008_006.mp3","charTypeName":"word"},{"id":9282,"position":7,"arabic":"مَّعْدُودَةٍۢ","translation":"নির্দিষ্ট","audioUrl":"wbw/011_008_007.mp3","charTypeName":"word"},{"id":9283,"position":8,"arabic":"لَّيَقُولُنَّ","translation":"(তবে) অবশ্যই তারা বলবে","audioUrl":"wbw/011_008_008.mp3","charTypeName":"word"},{"id":9284,"position":9,"arabic":"مَا","translation":"\"কিসে","audioUrl":"wbw/011_008_009.mp3","charTypeName":"word"},{"id":9285,"position":10,"arabic":"يَحْبِسُهُۥٓ ۗ","translation":"তা আটকে রেখেছে\"","audioUrl":"wbw/011_008_010.mp3","charTypeName":"word"},{"id":9287,"position":11,"arabic":"أَلَا","translation":"সাবধান","audioUrl":"wbw/011_008_012.mp3","charTypeName":"word"},{"id":9288,"position":12,"arabic":"يَوْمَ","translation":"যেদিন","audioUrl":"wbw/011_008_013.mp3","charTypeName":"word"},{"id":9289,"position":13,"arabic":"يَأْتِيهِمْ","translation":"তাদের কাছে আসবে (তা)","audioUrl":"wbw/011_008_014.mp3","charTypeName":"word"},{"id":9290,"position":14,"arabic":"لَيْسَ","translation":"না","audioUrl":"wbw/011_008_015.mp3","charTypeName":"word"},{"id":9291,"position":15,"arabic":"مَصْرُوفًا","translation":"ফিরানো যায়","audioUrl":"wbw/011_008_016.mp3","charTypeName":"word"},{"id":9292,"position":16,"arabic":"عَنْهُمْ","translation":"থেকে তাদের (সেই শাস্তি)","audioUrl":"wbw/011_008_017.mp3","charTypeName":"word"},{"id":9293,"position":17,"arabic":"وَحَاقَ","translation":"এবং ঘিরে রাখবে","audioUrl":"wbw/011_008_018.mp3","charTypeName":"word"},{"id":9294,"position":18,"arabic":"بِهِم","translation":"তাদেরকে","audioUrl":"wbw/011_008_019.mp3","charTypeName":"word"},{"id":9295,"position":19,"arabic":"مَّا","translation":"যা","audioUrl":"wbw/011_008_020.mp3","charTypeName":"word"},{"id":9296,"position":20,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/011_008_021.mp3","charTypeName":"word"},{"id":9297,"position":21,"arabic":"بِهِۦ","translation":"সম্বন্ধে সে","audioUrl":"wbw/011_008_022.mp3","charTypeName":"word"},{"id":9298,"position":22,"arabic":"يَسْتَهْزِءُونَ","translation":"ঠাট্টা তামাশা করতো","audioUrl":"wbw/011_008_023.mp3","charTypeName":"word"},{"id":9299,"position":23,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"وَلَئِنْ أَذَقْنَا ٱلْإِنسَٰنَ مِنَّا رَحْمَةًۭ ثُمَّ نَزَعْنَٰهَا مِنْهُ إِنَّهُۥ لَيَـُٔوسٌۭ كَفُورٌۭ","translation":"And thus it is: if We let man taste some of Our grace, and then take it away from him -behold, he abandons all hope, forgetting all gratitude [for Our past favours].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1482.mp3","surahId":11,"words":[{"id":10468,"position":1,"arabic":"وَلَئِنْ","translation":"এবং অবশ্যই যদি","audioUrl":"wbw/011_009_001.mp3","charTypeName":"word"},{"id":10469,"position":2,"arabic":"أَذَقْنَا","translation":"আমরা আস্বাদন করাই","audioUrl":"wbw/011_009_002.mp3","charTypeName":"word"},{"id":10470,"position":3,"arabic":"ٱلْإِنسَـٰنَ","translation":"মানুষকে","audioUrl":"wbw/011_009_003.mp3","charTypeName":"word"},{"id":10471,"position":4,"arabic":"مِنَّا","translation":"আমাদের পক্ষ থেকে","audioUrl":"wbw/011_009_004.mp3","charTypeName":"word"},{"id":10472,"position":5,"arabic":"رَحْمَةًۭ","translation":"কোন অনুগ্রহ","audioUrl":"wbw/011_009_005.mp3","charTypeName":"word"},{"id":10473,"position":6,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/011_009_006.mp3","charTypeName":"word"},{"id":10474,"position":7,"arabic":"نَزَعْنَـٰهَا","translation":"তা আমরা ছিনিয়ে নিই","audioUrl":"wbw/011_009_007.mp3","charTypeName":"word"},{"id":10475,"position":8,"arabic":"مِنْهُ","translation":"তার থেকে","audioUrl":"wbw/011_009_008.mp3","charTypeName":"word"},{"id":10476,"position":9,"arabic":"إِنَّهُۥ","translation":"(তবে) সে নিশ্চয়ই","audioUrl":"wbw/011_009_009.mp3","charTypeName":"word"},{"id":10477,"position":10,"arabic":"لَيَـُٔوسٌۭ","translation":"অবশ্যই হতাশ হয়","audioUrl":"wbw/011_009_010.mp3","charTypeName":"word"},{"id":10478,"position":11,"arabic":"كَفُورٌۭ","translation":"অকৃতজ্ঞ (হয়)","audioUrl":"wbw/011_009_011.mp3","charTypeName":"word"},{"id":10479,"position":12,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"وَلَئِنْ أَذَقْنَٰهُ نَعْمَآءَ بَعْدَ ضَرَّآءَ مَسَّتْهُ لَيَقُولَنَّ ذَهَبَ ٱلسَّيِّـَٔاتُ عَنِّىٓ ۚ إِنَّهُۥ لَفَرِحٌۭ فَخُورٌ","translation":"And thus it is: if We let him taste ease and plenty after hardship has visited him, he is sure to say, \"Gone is all affliction from me!\"-for, behold, he is given to vain exultation, and glories only in himself.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1483.mp3","surahId":11,"words":[{"id":11684,"position":1,"arabic":"وَلَئِنْ","translation":"এবং অবশ্যই যদি","audioUrl":"wbw/011_010_001.mp3","charTypeName":"word"},{"id":11685,"position":2,"arabic":"أَذَقْنَـٰهُ","translation":"তাকে আমরা আস্বাদন করাই","audioUrl":"wbw/011_010_002.mp3","charTypeName":"word"},{"id":11686,"position":3,"arabic":"نَعْمَآءَ","translation":"অনুগ্রহসমূহ","audioUrl":"wbw/011_010_003.mp3","charTypeName":"word"},{"id":11687,"position":4,"arabic":"بَعْدَ","translation":"পরে","audioUrl":"wbw/011_010_004.mp3","charTypeName":"word"},{"id":11688,"position":5,"arabic":"ضَرَّآءَ","translation":"দুঃখ-কষ্টের (যা)","audioUrl":"wbw/011_010_005.mp3","charTypeName":"word"},{"id":11689,"position":6,"arabic":"مَسَّتْهُ","translation":"তাকে স্পর্শ করেছিলো","audioUrl":"wbw/011_010_006.mp3","charTypeName":"word"},{"id":11690,"position":7,"arabic":"لَيَقُولَنَّ","translation":"অবশ্যই তারা বলবেই","audioUrl":"wbw/011_010_007.mp3","charTypeName":"word"},{"id":11691,"position":8,"arabic":"ذَهَبَ","translation":"\"কেটে গেছে","audioUrl":"wbw/011_010_008.mp3","charTypeName":"word"},{"id":11692,"position":9,"arabic":"ٱلسَّيِّـَٔاتُ","translation":"বিপদ আপদ","audioUrl":"wbw/011_010_009.mp3","charTypeName":"word"},{"id":11693,"position":10,"arabic":"عَنِّىٓ ۚ","translation":"আমার থেকে","audioUrl":"wbw/011_010_010.mp3","charTypeName":"word"},{"id":11695,"position":11,"arabic":"إِنَّهُۥ","translation":"নিশ্চয়ই সে","audioUrl":"wbw/011_010_012.mp3","charTypeName":"word"},{"id":11696,"position":12,"arabic":"لَفَرِحٌۭ","translation":"অবশ্যই উল্লাসে ফেটে পড়ে","audioUrl":"wbw/011_010_013.mp3","charTypeName":"word"},{"id":11697,"position":13,"arabic":"فَخُورٌ","translation":"অহংকারী (হয়ে উঠে)","audioUrl":"wbw/011_010_014.mp3","charTypeName":"word"},{"id":11698,"position":14,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"إِلَّا ٱلَّذِينَ صَبَرُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ أُو۟لَٰٓئِكَ لَهُم مَّغْفِرَةٌۭ وَأَجْرٌۭ كَبِيرٌۭ","translation":"[And thus it is with most men-] save those who are patient in adversity and do righteous deeds: it is they whom forgiveness of sins awaits, and a great reward.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1484.mp3","surahId":11,"words":[{"id":13053,"position":1,"arabic":"إِلَّا","translation":"কিন্তু (ব্যতিক্রম)","audioUrl":"wbw/011_011_001.mp3","charTypeName":"word"},{"id":13054,"position":2,"arabic":"ٱلَّذِينَ","translation":"(তারা) যারা","audioUrl":"wbw/011_011_002.mp3","charTypeName":"word"},{"id":13055,"position":3,"arabic":"صَبَرُوا۟","translation":"ধৈর্য ধরেছে","audioUrl":"wbw/011_011_003.mp3","charTypeName":"word"},{"id":13056,"position":4,"arabic":"وَعَمِلُوا۟","translation":"ও কাজ করেছে","audioUrl":"wbw/011_011_004.mp3","charTypeName":"word"},{"id":13057,"position":5,"arabic":"ٱلصَّـٰلِحَـٰتِ","translation":"সৎ","audioUrl":"wbw/011_011_005.mp3","charTypeName":"word"},{"id":13058,"position":6,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐসব লোক","audioUrl":"wbw/011_011_006.mp3","charTypeName":"word"},{"id":13059,"position":7,"arabic":"لَهُم","translation":"তাদের জন্যে (রয়েছে)","audioUrl":"wbw/011_011_007.mp3","charTypeName":"word"},{"id":13060,"position":8,"arabic":"مَّغْفِرَةٌۭ","translation":"ক্ষমা","audioUrl":"wbw/011_011_008.mp3","charTypeName":"word"},{"id":13061,"position":9,"arabic":"وَأَجْرٌۭ","translation":"ও পুরস্কার","audioUrl":"wbw/011_011_009.mp3","charTypeName":"word"},{"id":13062,"position":10,"arabic":"كَبِيرٌۭ","translation":"মহা","audioUrl":"wbw/011_011_010.mp3","charTypeName":"word"},{"id":13063,"position":11,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]},{"number":12,"arabic":"فَلَعَلَّكَ تَارِكٌۢ بَعْضَ مَا يُوحَىٰٓ إِلَيْكَ وَضَآئِقٌۢ بِهِۦ صَدْرُكَ أَن يَقُولُوا۟ لَوْلَآ أُنزِلَ عَلَيْهِ كَنزٌ أَوْ جَآءَ مَعَهُۥ مَلَكٌ ۚ إِنَّمَآ أَنتَ نَذِيرٌۭ ۚ وَٱللَّهُ عَلَىٰ كُلِّ شَىْءٍۢ وَكِيلٌ","translation":"IS IT, then, conceivable [O Prophet] that thou couldst omit any part of what is being revealed unto thee [because the deniers of the truth dislike it,-and] because thy heart is distressed at their saying, \"Why has not a treasure been bestowed upon him from on high?\" -or, \"[Why has not] an angel come [visibly:: with him?\" [They fail to understand that] thou art only a warner, whereas God has everything in His care;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1485.mp3","surahId":11,"words":[{"id":14294,"position":1,"arabic":"فَلَعَلَّكَ","translation":"তবে যেন তুমি (না)","audioUrl":"wbw/011_012_001.mp3","charTypeName":"word"},{"id":14295,"position":2,"arabic":"تَارِكٌۢ","translation":"পরিত্যাগকারী (হয়ো)","audioUrl":"wbw/011_012_002.mp3","charTypeName":"word"},{"id":14296,"position":3,"arabic":"بَعْضَ","translation":"কিছু অংশ","audioUrl":"wbw/011_012_003.mp3","charTypeName":"word"},{"id":14297,"position":4,"arabic":"مَا","translation":"(তার) যা","audioUrl":"wbw/011_012_004.mp3","charTypeName":"word"},{"id":14298,"position":5,"arabic":"يُوحَىٰٓ","translation":"ওহী করা হয়েছে","audioUrl":"wbw/011_012_005.mp3","charTypeName":"word"},{"id":14299,"position":6,"arabic":"إِلَيْكَ","translation":"তোমার প্রতি","audioUrl":"wbw/011_012_006.mp3","charTypeName":"word"},{"id":14300,"position":7,"arabic":"وَضَآئِقٌۢ","translation":"এবং (যেন না) সংকুচিত করো","audioUrl":"wbw/011_012_007.mp3","charTypeName":"word"},{"id":14301,"position":8,"arabic":"بِهِۦ","translation":"সম্পর্কে সে","audioUrl":"wbw/011_012_008.mp3","charTypeName":"word"},{"id":14302,"position":9,"arabic":"صَدْرُكَ","translation":"তোমার মন","audioUrl":"wbw/011_012_009.mp3","charTypeName":"word"},{"id":14303,"position":10,"arabic":"أَن","translation":"(এজন্যে) যে","audioUrl":"wbw/011_012_010.mp3","charTypeName":"word"},{"id":14304,"position":11,"arabic":"يَقُولُوا۟","translation":"তারা বলে","audioUrl":"wbw/011_012_011.mp3","charTypeName":"word"},{"id":14305,"position":12,"arabic":"لَوْلَآ","translation":"\"কেন না","audioUrl":"wbw/011_012_012.mp3","charTypeName":"word"},{"id":14306,"position":13,"arabic":"أُنزِلَ","translation":"অবতীর্ণ করা হলো","audioUrl":"wbw/011_012_013.mp3","charTypeName":"word"},{"id":14307,"position":14,"arabic":"عَلَيْهِ","translation":"তার উপর","audioUrl":"wbw/011_012_014.mp3","charTypeName":"word"},{"id":14308,"position":15,"arabic":"كَنزٌ","translation":"ধন ভান্ডার","audioUrl":"wbw/011_012_015.mp3","charTypeName":"word"},{"id":14309,"position":16,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/011_012_016.mp3","charTypeName":"word"},{"id":14310,"position":17,"arabic":"جَآءَ","translation":"(কেন না) আসে","audioUrl":"wbw/011_012_017.mp3","charTypeName":"word"},{"id":14311,"position":18,"arabic":"مَعَهُۥ","translation":"তার সাথে","audioUrl":"wbw/011_012_018.mp3","charTypeName":"word"},{"id":14312,"position":19,"arabic":"مَلَكٌ ۚ","translation":"কোন ফেরেশতা\"","audioUrl":"wbw/011_012_019.mp3","charTypeName":"word"},{"id":14314,"position":20,"arabic":"إِنَّمَآ","translation":"মূলতঃ","audioUrl":"wbw/011_012_021.mp3","charTypeName":"word"},{"id":14315,"position":21,"arabic":"أَنتَ","translation":"তুমি","audioUrl":"wbw/011_012_022.mp3","charTypeName":"word"},{"id":14316,"position":22,"arabic":"نَذِيرٌۭ ۚ","translation":"একজন সতর্ককারী (মাত্র)","audioUrl":"wbw/011_012_023.mp3","charTypeName":"word"},{"id":14318,"position":23,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/011_012_025.mp3","charTypeName":"word"},{"id":14319,"position":24,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/011_012_026.mp3","charTypeName":"word"},{"id":14320,"position":25,"arabic":"كُلِّ","translation":"সব","audioUrl":"wbw/011_012_027.mp3","charTypeName":"word"},{"id":14321,"position":26,"arabic":"شَىْءٍۢ","translation":"কিছুর","audioUrl":"wbw/011_012_028.mp3","charTypeName":"word"},{"id":14322,"position":27,"arabic":"وَكِيلٌ","translation":"কর্ম বিধায়ক","audioUrl":"wbw/011_012_029.mp3","charTypeName":"word"},{"id":14323,"position":28,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]}]}