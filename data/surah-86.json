{"id":86,"nameArabic":"سُورَةُ الطَّارِقِ","nameEnglish":"At-Taariq","nameTranslation":"The Morning Star","revelationType":"Meccan","numberOfAyahs":17,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلسَّمَآءِ وَٱلطَّارِقِ","translation":"CONSIDER the heavens and that which comes in the night!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5932.mp3","surahId":86,"words":[{"id":716,"position":1,"arabic":"وَٱلسَّمَآءِ","translation":"শপথ আকাশের","audioUrl":"wbw/086_001_001.mp3","charTypeName":"word"},{"id":717,"position":2,"arabic":"وَٱلطَّارِقِ","translation":"এবং রাত্রে আত্মপ্রকাশকারী (নক্ষত্রের)","audioUrl":"wbw/086_001_002.mp3","charTypeName":"word"},{"id":718,"position":3,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"وَمَآ أَدْرَىٰكَ مَا ٱلطَّارِقُ","translation":"And what could make thee conceive what it is that comes in the night?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5933.mp3","surahId":86,"words":[{"id":1764,"position":1,"arabic":"وَمَآ","translation":"এবং কিসে","audioUrl":"wbw/086_002_001.mp3","charTypeName":"word"},{"id":1765,"position":2,"arabic":"أَدْرَىٰكَ","translation":"তোমাকে জানাবে","audioUrl":"wbw/086_002_002.mp3","charTypeName":"word"},{"id":1766,"position":3,"arabic":"مَا","translation":"কি সেই","audioUrl":"wbw/086_002_003.mp3","charTypeName":"word"},{"id":1767,"position":4,"arabic":"ٱلطَّارِقُ","translation":"রাতে আত্মপ্রকাশকারী","audioUrl":"wbw/086_002_004.mp3","charTypeName":"word"},{"id":1768,"position":5,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"ٱلنَّجْمُ ٱلثَّاقِبُ","translation":"It is the star that pierces through [life's] darkness:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5934.mp3","surahId":86,"words":[{"id":2882,"position":1,"arabic":"ٱلنَّجْمُ","translation":"নক্ষত্র","audioUrl":"wbw/086_003_001.mp3","charTypeName":"word"},{"id":2883,"posit