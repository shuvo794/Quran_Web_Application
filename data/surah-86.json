":"مِن","translation":"কোন","audioUrl":"wbw/086_010_003.mp3","charTypeName":"word"},{"id":11667,"position":4,"arabic":"قُوَّةٍۢ","translation":"শক্তি","audioUrl":"wbw/086_010_004.mp3","charTypeName":"word"},{"id":11668,"position":5,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/086_010_005.mp3","charTypeName":"word"},{"id":11669,"position":6,"arabic":"نَاصِرٍۢ","translation":"কোনো সাহায্যকারী","audioUrl":"wbw/086_010_006.mp3","charTypeName":"word"},{"id":11670,"position":7,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"وَٱلسَّمَآءِ ذَاتِ ٱلرَّجْعِ","translation":"Consider the heavens, ever-revolving,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5942.mp3","surahId":86,"words":[{"id":13040,"position":1,"arabic":"وَٱلسَّمَآءِ","translation":"শপথ আকাশের","audioUrl":"wbw/086_011_001.mp3","charTypeName":"word"},{"id":13041,"position":2,"arabic":"ذَاتِ","translation":"ধারণকারী","audioUrl":"wbw/086_011_002.mp3","charTypeName":"word"},{"id":13042,"position":3,"arabic":"ٱلرَّجْعِ","translation":"বৃষ্টির","audioUrl":"wbw/086_011_003.mp3","charTypeName":"word"},{"id":13043,"position":4,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]},{"number":12,"arabic":"وَٱلْأَرْضِ ذَاتِ ٱلصَّدْعِ","translation":"and the earth, bursting forth with plants!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5943.mp3","surahId":86,"words":[{"id":14495,"position":1,"arabic":"وَٱلْأَرْضِ","translation":"শপথ পৃথিবীর (যা)","audioUrl":"wbw/086_012_001.mp3","charTypeName":"word"},{"id":14496,"position":2,"arabic":"ذَاتِ","translation":"বিশিষ্ট","audioUrl":"wbw/086_012_002.mp3","charTypeName":"word"},{"id":14497,"position":3,"arabic":"ٱلصَّدْعِ","translation":"বিদীর্ণ (বক্ষ)","audioUrl":"wbw/086_012_003.mp3","charTypeName":"word"},{"id":14498,"position":4,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]},{"number":13,"arabic":"إِنَّهُۥ لَقَوْلٌۭ فَصْلٌۭ","tr