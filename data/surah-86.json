,"charTypeName":"word"},{"id":5506,"position":5,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"خُلِقَ مِن مَّآءٍۢ دَافِقٍۢ","translation":"he has been created out of a seminal fluid","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5937.mp3","surahId":86,"words":[{"id":6738,"position":1,"arabic":"خُلِقَ","translation":"সৃষ্টি করা হয়েছে","audioUrl":"wbw/086_006_001.mp3","charTypeName":"word"},{"id":6739,"position":2,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/086_006_002.mp3","charTypeName":"word"},{"id":6740,"position":3,"arabic":"مَّآءٍۢ","translation":"পানি","audioUrl":"wbw/086_006_003.mp3","charTypeName":"word"},{"id":6741,"position":4,"arabic":"دَافِقٍۢ","translation":"সবেগে স্খলিত","audioUrl":"wbw/086_006_004.mp3","charTypeName":"word"},{"id":6742,"position":5,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"يَخْرُجُ مِنۢ بَيْنِ ٱلصُّلْبِ وَٱلتَّرَآئِبِ","translation":"issuing from between the loins [of man] and the pelvic arch [of woman].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5938.mp3","surahId":86,"words":[{"id":8081,"position":1,"arabic":"يَخْرُجُ","translation":"যা বের হয়","audioUrl":"wbw/086_007_001.mp3","charTypeName":"word"},{"id":8082,"position":2,"arabic":"مِنۢ","translation":"থেকে","audioUrl":"wbw/086_007_002.mp3","charTypeName":"word"},{"id":8083,"position":3,"arabic":"بَيْنِ","translation":"মাঝ","audioUrl":"wbw/086_007_003.mp3","charTypeName":"word"},{"id":8084,"position":4,"arabic":"ٱلصُّلْبِ","translation":"মেরুদণ্ড","audioUrl":"wbw/086_007_004.mp3","charTypeName":"word"},{"id":8085,"position":5,"arabic":"وَٱلتَّرَآئِبِ","translation":"ও বক্ষপিঞ্জরের","audioUrl":"wbw/086_007_005.mp3","charTypeName":"word"},{"id":8086,"position":6,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"إِنَّهُۥ عَلَىٰ رَجْعِهِۦ لَقَادِرٌۭ","translation":"Now, verily, He [who thus