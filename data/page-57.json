{"id":57,"ayahs":[{"number":53,"arabic":"رَبَّنَآ ءَامَنَّا بِمَآ أَنزَلْتَ وَٱتَّبَعْنَا ٱلرَّسُولَ فَٱكْتُبْنَا مَعَ ٱلشَّٰهِدِينَ","translation":"O our Sustainer! We believe in what Thou hast bestowed from on high, and we follow this Apostle; make us one, then, with all who bear witness [to the truth]!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/346.mp3","surahId":3,"words":[{"id":50438,"position":1,"arabic":"رَبَّنَآ","translation":"হে আমাদের রব","audioUrl":"wbw/003_053_001.mp3","charTypeName":"word"},{"id":50439,"position":2,"arabic":"ءَامَنَّا","translation":"আমরা ঈমান এনেছি","audioUrl":"wbw/003_053_002.mp3","charTypeName":"word"},{"id":50440,"position":3,"arabic":"بِمَآ","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/003_053_003.mp3","charTypeName":"word"},{"id":50441,"position":4,"arabic":"أَنزَلْتَ","translation":"তুমি নাযিল করেছ","audioUrl":"wbw/003_053_004.mp3","charTypeName":"word"},{"id":50442,"position":5,"arabic":"وَٱتَّبَعْنَا","translation":"এবং আমরা অনুসরণ করেছি","audioUrl":"wbw/003_053_005.mp3","charTypeName":"word"},{"id":50443,"position":6,"arabic":"ٱلرَّسُولَ","translation":"রসূলকে","audioUrl":"wbw/003_053_006.mp3","charTypeName":"word"},{"id":50444,"position":7,"arabic":"فَٱكْتُبْنَا","translation":"অতএব আমাদের লেখ (নাম)","audioUrl":"wbw/003_053_007.mp3","charTypeName":"word"},{"id":50445,"position":8,"arabic":"مَعَ","translation":"সাথে","audioUrl":"wbw/003_053_008.mp3","charTypeName":"word"},{"id":50446,"position":9,"arabic":"ٱلشَّـٰهِدِينَ","translation":"সাক্ষ্যদাতাদের''","audioUrl":"wbw/003_053_009.mp3","charTypeName":"word"},{"id":50447,"position":10,"arabic":"٥٣","translation":"(৫৩)","audioUrl":null,"charTypeName":"end"}]},{"number":54,"arabic":"وَمَكَرُوا۟ وَمَكَرَ ٱللَّهُ ۖ وَٱللَّهُ خَيْرُ ٱلْمَٰكِرِينَ","translation":"And the unbelievers schemed [against Jesus]; but God brought their scheming to nought: for God is above all schemers.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/347.mp3","surahId":3,"words":[{"id":51057,"position":1,"arabic":"وَمَكَرُوا۟","translation":"এবং তারা ষড়যন্ত্র করল","audioUrl":"wbw/003_054_001.mp3","charTypeName":"word"},{"id":51058,"position":2,"arabic":"وَمَكَرَ","translation":"ও কৌশল করলেন","audioUrl":"wbw/003_054_002.mp3","charTypeName":"word"},{"id":51059,"position":3,"arabic":"ٱللَّهُ ۖ","translation":"আল্লাহ","audioUrl":"wbw/003_054_003.mp3","charTypeName":"word"},{"id":51061,"position":4,"arabic":"وَٱللَّهُ","translation":"আর আল্লাহই","audioUrl":"wbw/003_054_005.mp3","charTypeName":"word"},{"id":51062,"position":5,"arabic":"خَيْرُ","translation":"উত্তম (কৌশলী)","audioUrl":"wbw/003_054_006.mp3","charTypeName":"word"},{"id":51063,"position":6,"arabic":"ٱلْمَـٰكِرِينَ","translation":"সব ষড়যন্ত্রকারীদের","audioUrl":"wbw/003_054_007.mp3","charTypeName":"word"},{"id":51064,"position":7,"arabic":"٥٤","translation":"(৫৪)","audioUrl":null,"charTypeName":"end"}]},{"number":55,"arabic":"إِذْ قَالَ ٱللَّهُ يَٰعِيسَىٰٓ إِنِّى مُتَوَفِّيكَ وَرَافِعُكَ إِلَىَّ وَمُطَهِّرُكَ مِنَ ٱلَّذِينَ كَفَرُوا۟ وَجَاعِلُ ٱلَّذِينَ ٱتَّبَعُوكَ فَوْقَ ٱلَّذِينَ كَفَرُوٓا۟ إِلَىٰ يَوْمِ ٱلْقِيَٰمَةِ ۖ ثُمَّ إِلَىَّ مَرْجِعُكُمْ فَأَحْكُمُ بَيْنَكُمْ فِيمَا كُنتُمْ فِيهِ تَخْتَلِفُونَ","translation":"Lo! God said: \"O Jesus! Verily, I shall cause thee to die, and shall exalt thee unto Me, and cleanse thee of [the presence of] those who are bent on denying the truth; and I shall place those who follow thee [far] above those who are bent on denying the truth, unto the Day of Resurrection. In the end, unto Me you all must return, and I shall judge between you with regard to all on which you were wont to differ.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/348.mp3","surahId":3,"words":[{"id":51836,"position":1,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/003_055_001.mp3","charTypeName":"word"},{"id":51837,"position":2,"arabic":"قَالَ","translation":"বলেছিলেন","audioUrl":"wbw/003_055_002.mp3","charTypeName":"word"},{"id":51838,"