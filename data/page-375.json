d"},{"id":85354,"position":3,"arabic":"بِهِۦ","translation":"প্রতি তার","audioUrl":"wbw/026_201_003.mp3","charTypeName":"word"},{"id":85355,"position":4,"arabic":"حَتَّىٰ","translation":"যতক্ষণ না","audioUrl":"wbw/026_201_004.mp3","charTypeName":"word"},{"id":85356,"position":5,"arabic":"يَرَوُا۟","translation":"তারা দেখবে","audioUrl":"wbw/026_201_005.mp3","charTypeName":"word"},{"id":85357,"position":6,"arabic":"ٱلْعَذَابَ","translation":"শাস্তি","audioUrl":"wbw/026_201_006.mp3","charTypeName":"word"},{"id":85358,"position":7,"arabic":"ٱلْأَلِيمَ","translation":"নিদারুণ","audioUrl":"wbw/026_201_007.mp3","charTypeName":"word"},{"id":85359,"position":8,"arabic":"٢٠١","translation":"(২০১)","audioUrl":null,"charTypeName":"end"}]},{"number":202,"arabic":"فَيَأْتِيَهُم بَغْتَةًۭ وَهُمْ لَا يَشْعُرُونَ","translation":"that will come upon them [on resurrection,] all of a sudden, without their being aware [of its approach];","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3134.mp3","surahId":26,"words":[{"id":85370,"position":1,"arabic":"فَيَأْتِيَهُم","translation":"অতঃপর তাদের (উপর) এসে পড়বে","audioUrl":"wbw/026_202_001.mp3","charTypeName":"word"},{"id":85371,"position":2,"arabic":"بَغْتَةًۭ","translation":"হঠাৎ করে","audioUrl":"wbw/026_202_002.mp3","charTypeName":"word"},{"id":85372,"position":3,"arabic":"وَهُمْ","translation":"এমতাবস্হায় যে তারা","audioUrl":"wbw/026_202_003.mp3","charTypeName":"word"},{"id":85373,"position":4,"arabic":"لَا","translation":"না","audioUrl":"wbw/026_202_004.mp3","charTypeName":"word"},{"id":85374,"position":5,"arabic":"يَشْعُرُونَ","translation":"অনুভবও করবে","audioUrl":"wbw/026_202_005.mp3","charTypeName":"word"},{"id":85375,"position":6,"arabic":"٢٠٢","translation":"(২০২)","audioUrl":null,"charTypeName":"end"}]},{"number":203,"arabic":"فَيَقُولُوا۟ هَلْ نَحْنُ مُنظَرُونَ","translation":"and then they will exclaim, “Could we have a respite?”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3135.mp3","surahI