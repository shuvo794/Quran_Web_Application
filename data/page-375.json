w/026_193_004.mp3","charTypeName":"word"},{"id":84749,"position":5,"arabic":"١٩٣","translation":"(১৯৩)","audioUrl":null,"charTypeName":"end"}]},{"number":194,"arabic":"عَلَىٰ قَلْبِكَ لِتَكُونَ مِنَ ٱلْمُنذِرِينَ","translation":"upon thy heart, [O Muhammad] so that thou mayest be among those who preach","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3126.mp3","surahId":26,"words":[{"id":84803,"position":1,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/026_194_001.mp3","charTypeName":"word"},{"id":84804,"position":2,"arabic":"قَلْبِكَ","translation":"তোমার অন্তরের","audioUrl":"wbw/026_194_002.mp3","charTypeName":"word"},{"id":84805,"position":3,"arabic":"لِتَكُونَ","translation":"যেন তুমি হও","audioUrl":"wbw/026_194_003.mp3","charTypeName":"word"},{"id":84806,"position":4,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/026_194_004.mp3","charTypeName":"word"},{"id":84807,"position":5,"arabic":"ٱلْمُنذِرِينَ","translation":"সতর্ককারীদের","audioUrl":"wbw/026_194_005.mp3","charTypeName":"word"},{"id":84808,"position":6,"arabic":"١٩٤","translation":"(১৯৪)","audioUrl":null,"charTypeName":"end"}]},{"number":195,"arabic":"بِلِسَانٍ عَرَبِىٍّۢ مُّبِينٍۢ","translation":"in the clear Arabic tongue.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3127.mp3","surahId":26,"words":[{"id":84961,"position":1,"arabic":"بِلِسَانٍ","translation":"মাধ্যমে ভাষায়","audioUrl":"wbw/026_195_001.mp3","charTypeName":"word"},{"id":84962,"position":2,"arabic":"عَرَبِىٍّۢ","translation":"আরবী","audioUrl":"wbw/026_195_002.mp3","charTypeName":"word"},{"id":84963,"position":3,"arabic":"مُّبِينٍۢ","translation":"সুস্পষ্ট","audioUrl":"wbw/026_195_003.mp3","charTypeName":"word"},{"id":84964,"position":4,"arabic":"١٩٥","translation":"(১৯৫)","audioUrl":null,"charTypeName":"end"}]},{"number":196,"arabic":"وَإِنَّهُۥ لَفِى زُبُرِ ٱلْأَوَّلِينَ","translation":"And, verily, [the essence of] this [revelation] is indeed found in the ancient books of divine wisdom [as well].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3128.mp3","surahId":26,"words":[{"id":84965,"position":1,"arabic":"وَإِنَّهُۥ","translation":"এবং নিশ্চয়ই তা","audioUrl":"wbw/026_196_001.mp3","charTypeName":"word"},{"id":84966,"position":2,"arabic":"لَفِى","translation":"অবশ্যই মধ্যে (আছে)","audioUrl":"wbw/026_196_002.mp3","charTypeName":"word"},{"id":84967,"position":3,"arabic":"زُبُرِ","translation":"কিতাবসমূহের","audioUrl":"wbw/026_196_003.mp3","charTypeName":"word"},{"id":84968,"position":4,"arabic":"ٱلْأَوَّلِينَ","translation":"পুর্ববর্তী","audioUrl":"wbw/026_196_004.mp3","charTypeName":"word"},{"id":84969,"position":5,"arabic":"١٩٦","translation":"(১৯৬)","audioUrl":null,"charTypeName":"end"}]},{"number":197,"arabic":"أَوَلَمْ يَكُن لَّهُمْ ءَايَةً أَن يَعْلَمَهُۥ عُلَمَٰٓؤُا۟ بَنِىٓ إِسْرَٰٓءِيلَ","translation":"Is it not evidence enough for them that [so many] learned men from among the children of Israel have recognized this [as true]?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3129.mp3","surahId":26,"words":[{"id":85116,"position":1,"arabic":"أَوَلَمْ","translation":"কি নি","audioUrl":"wbw/026_197_001.mp3","charTypeName":"word"},{"id":85117,"position":2,"arabic":"يَكُن","translation":"হয়","audioUrl":"wbw/026_197_002.mp3","charTypeName":"word"},{"id":85118,"position":3,"arabic":"لَّهُمْ","translation":"জন্যে তাদের","audioUrl":"wbw/026_197_003.mp3","charTypeName":"word"},{"id":85119,"position":4,"arabic":"ءَايَةً","translation":"একটি নিদর্শন","audioUrl":"wbw/026_197_004.mp3","charTypeName":"word"},{"id":85120,"position":5,"arabic":"أَن","translation":"যে","audioUrl":"wbw/026_197_005.mp3","charTypeName":"word"},{"id":85121,"position":6,"arabic":"يَعْلَمَهُۥ","translation":"তা জানে","audioUrl":"wbw/026_197_006.mp3","charTypeName":"word"},{"id":85122,"position":7,"arabic":"عُلَمَـٰٓؤُا۟","translation":"পন্ডিতরা","audioUrl":"wbw/026_197_007.mp3","charTypeName":"word"},{"id":85123,"position":8,"arabic":"بَنِىٓ","translation":"বনী","audioUrl":"wbw/026_197_008.mp3","charTypeName":"word"},{"id":85124,"position":9,"arabic":"إِسْرَٰٓءِيلَ","translation":"ইসরাঈলের","audioUrl":"wbw/026_197_009.mp3","charTypeName":"word"},{"id":85125,"position":10,"arabic":"١٩٧","translation":"(১৯৭)","audioUrl":null,"charTypeName":"end"}]},{"number":198,"arabic":"وَلَوْ نَزَّلْنَٰهُ عَلَىٰ بَعْضِ ٱلْأَعْجَمِينَ","translation":"But [even] had We bestowed it from on high upon any of the non-Arabs,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3130.mp3","surahId":26,"words":[{"id":85187,"position":1,"arabic":"وَلَوْ","translation":"আর যদি","audioUrl":"wbw/026_198_001.mp3","charTypeName":"word"},{"id":85188,"position":2,"arabic":"نَزَّلْنَـٰهُ","translation":"তা আমরা অবতীর্ণ করতাম","audioUrl":"wbw/026_198_002.mp3","charTypeName":"word"},{"id":85189,"position":3,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/026_198_003.mp3","charTypeName":"word"},{"id":85190,"position":4,"arabic":"بَعْضِ","translation":"কারোও","audioUrl":"wbw/026_198_004.mp3","charTypeName":"word"},{"id":85191,"position":5,"arabic":"ٱلْأَعْجَمِينَ","translation":"অনারবদের","audioUrl":"wbw/026_198_005.mp3","charTypeName":"word"},{"id":85192,"position":6,"arabic":"١٩٨","translation":"(১৯৮)","audioUrl":null,"charTypeName":"end"}]},{"number":199,"arabic":"فَقَرَأَهُۥ عَلَيْهِم مَّا كَانُوا۟ بِهِۦ مُؤْمِنِينَ","translation":"and had he recited it unto them [in his own tongue], they would not have believed in it.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3131.mp3","surahId":26,"words":[{"id":85262,"position":1,"arabic":"فَقَرَأَهُۥ","translation":"অতঃপর পাঠ করতো তা","audioUrl":"wbw/026_199_001.mp3","charTypeName":"word"},{"id":85263,"position":2,"arabic":"عَلَيْهِم","translation":"কাছে তাদের","audioUrl":"wbw/026_199_002.mp3","charTypeName":"word"},{"id":85264,"position":3,"arabic":"مَّا","translation":"না","audioUrl":"wbw/026_199_003.mp3","charTypeName":"word"},{"id":85265,"position":4,"ar