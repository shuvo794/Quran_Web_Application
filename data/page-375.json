ranslation":"(বহু) বছর","audioUrl":"wbw/026_205_004.mp3","charTypeName":"word"},{"id":85479,"position":5,"arabic":"٢٠٥","translation":"(২০৫)","audioUrl":null,"charTypeName":"end"}]},{"number":206,"arabic":"ثُمَّ جَآءَهُم مَّا كَانُوا۟ يُوعَدُونَ","translation":"and thereupon that [chastisement] which they were promised befalls them –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3138.mp3","surahId":26,"words":[{"id":85513,"position":1,"arabic":"ثُمَّ","translation":"এরপরও","audioUrl":"wbw/026_206_001.mp3","charTypeName":"word"},{"id":85514,"position":2,"arabic":"جَآءَهُم","translation":"আসে তাদের (নিকট)","audioUrl":"wbw/026_206_002.mp3","charTypeName":"word"},{"id":85515,"position":3,"arabic":"مَّا","translation":"যা","audioUrl":"wbw/026_206_003.mp3","charTypeName":"word"},{"id":85516,"position":4,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/026_206_004.mp3","charTypeName":"word"},{"id":85517,"position":5,"arabic":"يُوعَدُونَ","translation":"তাদেরকে সতর্ক করা হচ্ছে","audioUrl":"wbw/026_206_005.mp3","charTypeName":"word"},{"id":85518,"position":6,"arabic":"٢٠٦","translation":"(২০৬)","audioUrl":null,"charTypeName":"end"}]}]}