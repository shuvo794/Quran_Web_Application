{"id":375,"ayahs":[{"number":184,"arabic":"وَٱتَّقُوا۟ ٱلَّذِى خَلَقَكُمْ وَٱلْجِبِلَّةَ ٱلْأَوَّلِينَ","translation":"but be conscious of Him who has created you, just as [He created] those countless generations of old!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3116.mp3","surahId":26,"words":[{"id":84033,"position":1,"arabic":"وَٱتَّقُوا۟","translation":"এবং তোমরা ভয় করো","audioUrl":"wbw/026_184_001.mp3","charTypeName":"word"},{"id":84034,"position":2,"arabic":"ٱلَّذِى","translation":"(তাঁকে) যিনি","audioUrl":"wbw/026_184_002.mp3","charTypeName":"word"},{"id":84035,"position":3,"arabic":"خَلَقَكُمْ","translation":"সৃষ্টি করেছেন তোমাদেরকে","audioUrl":"wbw/026_184_003.mp3","charTypeName":"word"},{"id":84036,"position":4,"arabic":"وَٱلْجِبِلَّةَ","translation":"জনগোষ্ঠীকেও","audioUrl":"wbw/026_184_004.mp3","charTypeName":"word"},{"id":84037,"position":5,"arabic":"ٱلْأَوَّلِينَ","translation":"পুর্ববর্তী\"","audioUrl":"wbw/026_184_005.mp3","charTypeName":"word"},{"id":84038,"position":6,"arabic":"١٨٤","translation":"(১৮৪)","audioUrl":null,"charTypeName":"end"}]},{"number":185,"arabic":"قَالُوٓا۟ إِنَّمَآ أَنتَ مِنَ ٱلْمُسَحَّرِينَ","translation":"Said they: “Thou art but one of the be­witched,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3117.mp3","surahId":26,"words":[{"id":84179,"position":1,"arabic":"قَالُوٓا۟","translation":"তারা বলেছিলো","audioUrl":"wbw/026_185_001.mp3","charTypeName":"word"},{"id":84180,"position":2,"arabic":"إِنَّمَآ","translation":"\"মূলতঃ","audioUrl":"wbw/026_185_002.mp3","charTypeName":"word"},{"id":84181,"position":3,"arabic":"أَنتَ","translation":"তুমি","audioUrl":"wbw/026_185_003.mp3","charTypeName":"word"},{"id":84182,"position":4,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/026_185_004.mp3","charTypeName":"word"},{"id":84183,"position":5,"arabic":"ٱلْمُسَحَّرِينَ","translation":"জাদুগ্রস্তদের","audioUrl":"wbw/026_185_005.mp3","charTypeName":"word"},{"id":84184,"position":6,"arabic":"١٨٥","translation":"(১৮৫)","audioUrl":null,"charTypeName":"end"}]},{"number":186,"arabic":"وَمَآ أَنتَ إِلَّا بَشَرٌۭ مِّثْلُنَا وَإِن نَّظُنُّكَ لَمِنَ ٱلْكَٰذِبِينَ","translation":"for thou art nothing but a mortal like ourselves! And, behold, we think that thou art a consummate liar!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3118.mp3","surahId":26,"words":[{"id":84236,"position":1,"arabic":"وَمَآ","translation":"আর না","audioUrl":"wbw/026_186_001.mp3","charTypeName":"word"},{"id":84237,"position":2,"arabic":"أَنتَ","translation":"তুমি","audioUrl":"wbw/026_186_002.mp3","charTypeName":"word"},{"id":84238,"position":3,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/026_186_003.mp3","charTypeName":"word"},{"id":84239,"position":4,"arabic":"بَشَرٌۭ","translation":"একজন মানুষ","audioUrl":"wbw/026_186_004.mp3","charTypeName":"word"},{"id":84240,"position":5,"arabic":"مِّثْلُنَا","translation":"মতো আমাদেরই","audioUrl":"wbw/026_186_005.mp3","charTypeName":"word"},{"id":84241,"position":6,"arabic":"وَإِن","translation":"আর নিশ্চয়ই","audioUrl":"wbw/026_186_006.mp3","charTypeName":"word"},{"id":84242,"position":7,"arabic":"نَّظُنُّكَ","translation":"তোমাকে আমরা মনেকরি","audioUrl":"wbw/026_186_007.mp3","charTypeName":"word"},{"id":84243,"position":8,"arabic":"لَمِنَ","translation":"অবশ্যই অন্তর্ভুক্ত","audioUrl":"wbw/026_186_008.mp3","charTypeName":"word"},{"id":84244,"position":9,"arabic":"ٱلْكَـٰذِبِينَ","translation":"মিথ্যাবাদীদের","audioUrl":"wbw/026_186_009.mp3","charTypeName":"word"},{"id":84245,"position":10,"arabic":"١٨٦","translation":"(১৮৬)","audioUrl":null,"charTypeName":"end"}]},{"number":187,"arabic":"فَأَسْقِطْ عَلَيْنَا كِسَفًۭا مِّنَ ٱلسَّمَآءِ إِن كُنتَ مِنَ ٱلصَّٰدِقِينَ","translation":"Cause, then, fragments of the sky to fall down upon us, if thou art a man of truth!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3119.mp3","surahId":26,"words":[{"id":84278,"position":1,"arabic":"فَأَسْقِطْ","translation":"অতএব ফেলে দাও","audioUrl":"wbw/026_187_001.mp3","charTypeName":"word"},{"id":84279,"position":2,"arabic":"عَلَيْنَا","translation":"উপর আমাদের","audioUrl":"wbw/026_187_002.mp3","charTypeName":"word"},{"id":84280,"position":3,"arabic":"كِسَفًۭا","translation":"এক টুকরো","audioUrl":"wbw/026_187_003.mp3","charTypeName":"word"},{"id":84281,"position":4,"arabic":"مِّنَ","translation":"থেকে","audioUrl":"wbw/026_187_004.mp3","charTypeName":"word"},{"id":84282,"position":5,"arabic":"ٱلسَّمَآءِ","translation":"আকাশের","audioUrl":"wbw/026_187_005.mp3","charTypeName":"word"},{"id":84283,"position":6,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/026_187_006.mp3","charTypeName":"word"},{"id":84284,"position":7,"arabic":"كُنتَ","translation":"তুমি হও","audioUrl":"wbw/026_187_007.mp3","charTypeName":"word"},{"id":84285,"position":8,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/026_187_008.mp3","charTypeName":"word"},{"id":84286,"position":9,"arabic":"ٱلصَّـٰدِقِينَ","translation":"সত্যবাদীদের\"","audioUrl":"wbw/026_187_009.mp3","charTypeName":"word"},{"id":84287,"position":10,"arabic":"١٨٧","translation":"(১৮৭)","audioUrl":null,"charTypeName":"end"}]},{"number":188,"arabic":"قَالَ رَبِّىٓ أَعْلَمُ بِمَا تَعْمَلُونَ","translation":"Answered [Shu’ayb]: “My Sustainer knows fully well what you are doing.”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3120.mp3","surahId":26,"words":[{"id":84469,"position":1,"arabic":"قَالَ","translation":"(শু'আইব) বললো","audioUrl":"wbw/026_188_001.mp3","charTypeName":"word"},{"id":84470,"position":2,"arabic":"رَبِّىٓ","translation":"\"আমার রব","audioUrl":"wbw/026_188_002.mp3","charTypeName":"word"},{"id":84471,"position":3,"arabic":"أَعْلَمُ","translation":"খুব জানেন","audioUrl":"wbw/026_188_003.mp3","charTypeName":"word"},{"id":84472,"position":4,"arabic":"بِمَا","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/026_188_004.mp3","charTypeName":"word"},{"id":84473,"position":5,"arabic":"تَعْمَلُونَ","translation":"তোমরা করছো\"","audioUrl":"wbw/026_188_005.mp3","charTypeName":"word"},{"id":84474,"position":6,"arabic":"١٨٨","translation":"(১৮৮)","audioUrl":null,"charTypeName":"end"}]},{"number":189,"arabic":"فَكَذَّبُوهُ فَأَخَذَهُمْ عَذَابُ يَوْمِ ٱلظُّلَّةِ ۚ إِنَّهُۥ كَانَ عَذَابَ يَوْمٍ عَظِيمٍ","translation":"But they gave him the lie. And thereupon suffering overtook them on a day dark with shadows: and, verily, it was the suffering of an awesome day!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3121.mp3","surahId":26,"words":[{"id":84583,"position":1,"arabic":"فَكَذَّبُوهُ","translation":"অতঃপর তারা তাকে মিথ্যা সাব্যস্ত করলো","audioUrl":"wbw/026_189_001.mp3","charTypeName":"word"},{"id":84584,"position":2,"arabic":"فَأَخَذَهُمْ","translation":"তখন ধরলো তাদেরকে","audioUrl":"wbw/026_189_002.mp3","charTypeName":"word"},{"id":84585,"position":3,"arabic":"عَذَابُ","translation":"শাস্তি","audioUrl":"wbw/026_189_003.mp3","charTypeName":"word"},{"id":84586,"position":4,"arabic":"يَوْمِ","translation":"দিনের","audioUrl":"wbw/026_189_004.mp3","charTypeName":"word"},{"id":84587,"position":5,"arabic":"ٱلظُّلَّةِ ۚ","translation":"(ছায়াওয়ালা) মেঘাচ্ছন্ন","audioUrl":"wbw/026_189_005.mp3","charTypeName":"word"},{"id":84589,"position":6,"arabic":"إِنَّهُۥ","translation":"নিশ্চয়ই তা","audioUrl":"wbw/026_189_007.mp3","charTypeName":"word"},{"id":84590,"position":7,"arabic":"كَانَ","translation":"ছিলো","audioUrl":"wbw/026_189_008.mp3","charTypeName":"word"},{"id":84591,"position":8,"arabic":"عَذَابَ","translation":"শাস্তি","audioUrl":"wbw/026_189_009.mp3","charTypeName":"word"},{"id":84592,"position":9,"arabic":"يَوْمٍ","translation":"দিনের","audioUrl":"wbw/026_189_010.mp3","charTypeName":"word"},{"id":84593,"position":10,"arabic":"عَظِيمٍ","translation":"ভয়াবহ","audioUrl":"wbw/026_189_011.mp3","charTypeName":"word"},{"id":84594,"position":11,"arabic":"١٨٩","translation":"(১৮৯)","audioUrl":null,"charTypeName":"end"}]},{"number":190,"arabic":"إِنَّ فِى ذَٰلِكَ لَءَايَةًۭ ۖ وَمَا كَانَ أَكْثَرُهُم مُّؤْمِنِينَ","translation":"In this [story], behold, there is a message [unto men], even though most of them will not believe [in it].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3122.mp3","surahId":26,"words":[{"id":84621,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/026_190_001.mp3","charTypeName":"word"},{"id":84622,"position":2,"arabic":"فِى","translation":"মধ্যে (আছে)","audioUrl":"wbw/026_190_002.mp3","charTypeName":"word"},{"id":84623,"position":3,"arabic":"ذَٰلِكَ","translation":"এর","audioUrl":"wbw/026_190_003.mp3","charTypeName":"word"},{"id":84624,"position":4,"arabic":"لَـَٔايَةًۭ ۖ","translation":"অবশ্যই নিদর্শন","audioUrl":"wbw/026_190_004.mp3","charTypeName":"word"},{"id":84626,"position":5,"arabic":"وَمَا","translation":"কিন্তু না","audioUrl":"wbw/026_190_006.mp3","charTypeName":"word"},{"id":84627,"position":6,"arabic":"كَانَ","translation":"ছিলো","audioUrl":"wbw/026_190_007.mp3","charTypeName":"word"},{"id":84628,"position":7,"arabic":"أَكْثَرُهُم","translation":"অধিকাংশ তাদের","audioUrl":"wbw/026_190_008.mp3","charTypeName":"word"},{"id":84629,"position":8,"arabic":"مُّؤْمِنِينَ","translation":"মু'মিন","audioUrl":"wbw/026_190_009.mp3","charTypeName":"word"},{"id":84630,"position":9,"arabic":"١٩٠","translation":"(১৯০)","audioUrl":null,"charTypeName":"end"}]},{"number":191,"arabic":"وَإِنَّ رَبَّكَ لَهُوَ ٱلْعَزِيزُ ٱلرَّحِيمُ","translation":"But, verily, thy Sustainer - He alone - is almighty, a dispenser of grace!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3123.mp3","surahId":26,"words":[{"id":84698,"position":1,"arabic":"وَإِنَّ","translation":"আর নিশ্চয়ই","audioUrl":"wbw/026_191_001.mp3","charTypeName":"word"},{"id":84699,"position":2,"arabic":"رَبَّكَ","translation":"তোমার রব","audioUrl":"wbw/026_191_002.mp3","charTypeName":"word"},{"id":84700,"position":3,"arabic":"لَهُوَ","translation":"অবশ্যই তিনি","audioUrl":"wbw/026_191_003.mp3","charT