{"id":315,"ayahs":[{"number":52,"arabic":"قَالَ عِلْمُهَا عِندَ رَبِّى فِى كِتَٰبٍۢ ۖ لَّا يَضِلُّ رَبِّى وَلَا يَنسَى","translation":"[Moses] answered: \"Knowledge thereof rests with my Sustainer [alone, and is laid down] in His decree; my Sustainer does not err, and neither does He forget.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2400.mp3","surahId":20,"words":[{"id":49844,"position":1,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/020_052_001.mp3","charTypeName":"word"},{"id":49845,"position":2,"arabic":"عِلْمُهَا","translation":"\"তার জ্ঞান","audioUrl":"wbw/020_052_002.mp3","charTypeName":"word"},{"id":49846,"position":3,"arabic":"عِندَ","translation":"নিকট (আছে)","audioUrl":"wbw/020_052_003.mp3","charTypeName":"word"},{"id":49847,"position":4,"arabic":"رَبِّى","translation":"আমার রবের","audioUrl":"wbw/020_052_004.mp3","charTypeName":"word"},{"id":49848,"position":5,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/020_052_005.mp3","charTypeName":"word"},{"id":49849,"position":6,"arabic":"كِتَـٰبٍۢ ۖ","translation":"একটি কিতাবের (সংরক্ষিত)","audioUrl":"wbw/020_052_006.mp3","charTypeName":"word"},{"id":49851,"position":7,"arabic":"لَّا","translation":"না","audioUrl":"wbw/020_052_008.mp3","charTypeName":"word"},{"id":49852,"position":8,"arabic":"يَضِلُّ","translation":"ভুল করেন","audioUrl":"wbw/020_052_009.mp3","charTypeName":"word"},{"id":49853,"position":9,"arabic":"رَبِّى","translation":"আমার রব","audioUrl":"wbw/020_052_010.mp3","charTypeName":"word"},{"id":49854,"position":10,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/020_052_011.mp3","charTypeName":"word"},{"id":49855,"position":11,"arabic":"يَنسَى","translation":"ভুলে যান\"","audioUrl":"wbw/020_052_012.mp3","charTypeName":"word"},{"id":49856,"position":12,"arabic":"٥٢","translation":"(৫২)","audioUrl":null,"charTypeName":"end"}]},{"number":53,"arabic":"ٱلَّذِى جَعَلَ لَكُمُ ٱلْأَرْضَ مَهْدًۭا وَسَلَكَ لَكُمْ فِيهَا سُبُلًۭا وَأَنزَلَ مِنَ ٱلسَّمَآءِ مَآءًۭ فَأَخْرَجْنَا بِهِۦٓ أَزْوَٰجًۭا مِّن نَّبَاتٍۢ شَتَّىٰ","translation":"HE IT IS who has made the earth a cradle for you, and has traced out for you ways [of livelihood] thereon, and [who] sends down waters from the sky: and by this means We bring forth various kinds of plants.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2401.mp3","surahId":20,"words":[{"id":50485,"position":1,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/020_053_001.mp3","charTypeName":"word"},{"id":50486,"position":2,"arabic":"جَعَلَ","translation":"করেছেন","audioUrl":"wbw/020_053_002.mp3","charTypeName":"word"},{"id":50487,"position":3,"arabic":"لَكُمُ","translation":"জন্যে তোমাদের","audioUrl":"wbw/020_053_003.mp3","charTypeName":"word"},{"id":50488,"position":4,"arabic":"ٱلْأَرْضَ","translation":"পৃথিবীকে","audioUrl":"wbw/020_053_004.mp3","charTypeName":"word"},{"id":50489,"position":5,"arabic":"مَهْدًۭا","translation":"বিছানা","audioUrl":"wbw/020_053_005.mp3","charTypeName":"word"},{"id":50490,"position":6,"arabic":"وَسَلَكَ","translation":"ও চালিয়ে দিয়েছেন","audioUrl":"wbw/020_053_006.mp3","charTypeName":"word"},{"id":50491,"position":7,"arabic":"لَكُمْ","translation":"তোমাদের জন্য","audioUrl":"wbw/020_053_007.mp3","charTypeName":"word"},{"id":50492,"position":8,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/020_053_008.mp3","charTypeName":"word"},{"id":50493,"position":9,"arabic":"سُبُلًۭا","translation":"পথসমূহ","audioUrl":"wbw/020_053_009.mp3","charTypeName":"word"},{"id":50494,"position":10,"arabic":"وَأَنزَلَ","translation":"এবং বর্ষণ করেছেন","audioUrl":"wbw/020_053_010.mp3","charTypeName":"word"},{"id":50495,"position":11,"arabic":"مِنَ","translation":"থেকে","audioUrl":"wbw/020_053_011.mp3","charTypeName":"word"},{"id":50496,"position":12,"arabic":"ٱلسَّمَآءِ","translation":"আকাশ","audioUrl":"wbw/020_053_012.mp3","charTypeName":"word"},{"id":50497,"position":13,"arabic":"مَآءًۭ","translation":"পানি","audioUrl":"wbw/020_053_013.mp3","charTypeN