{"id":214,"ayahs":[{"number":43,"arabic":"وَمِنْهُم مَّن يَنظُرُ إِلَيْكَ ۚ أَفَأَنتَ تَهْدِى ٱلْعُمْىَ وَلَوْ كَانُوا۟ لَا يُبْصِرُونَ","translation":"And there are among them such as [pretend to] look towards thee: but canst thou show the right way to the blind even though they cannot see?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1407.mp3","surahId":10,"words":[{"id":43697,"position":1,"arabic":"وَمِنْهُم","translation":"এবং মধ্যে থেকে তাদের","audioUrl":"wbw/010_043_001.mp3","charTypeName":"word"},{"id":43698,"position":2,"arabic":"مَّن","translation":"কেউ কেউ","audioUrl":"wbw/010_043_002.mp3","charTypeName":"word"},{"id":43699,"position":3,"arabic":"يَنظُرُ","translation":"তাকিয়ে থাকে","audioUrl":"wbw/010_043_003.mp3","charTypeName":"word"},{"id":43700,"position":4,"arabic":"إِلَيْكَ ۚ","translation":"দিকে তোমার","audioUrl":"wbw/010_043_004.mp3","charTypeName":"word"},{"id":43702,"position":5,"arabic":"أَفَأَنتَ","translation":"কি তবে তুমি","audioUrl":"wbw/010_043_006.mp3","charTypeName":"word"},{"id":43703,"position":6,"arabic":"تَهْدِى","translation":"পথ দেখাবে","audioUrl":"wbw/010_043_007.mp3","charTypeName":"word"},{"id":43704,"position":7,"arabic":"ٱلْعُمْىَ","translation":"অন্ধকে","audioUrl":"wbw/010_043_008.mp3","charTypeName":"word"},{"id":43705,"position":8,"arabic":"وَلَوْ","translation":"এবং যদিও","audioUrl":"wbw/010_043_009.mp3","charTypeName":"word"},{"id":43706,"position":9,"arabic":"كَانُوا۟","translation":"তারা হলো (এমন যে)","audioUrl":"wbw/010_043_010.mp3","charTypeName":"word"},{"id":43707,"position":10,"arabic":"لَا","translation":"না","audioUrl":"wbw/010_043_011.mp3","charTypeName":"word"},{"id":43708,"position":11,"arabic":"يُبْصِرُونَ","translation":"দেখতে পায়","audioUrl":"wbw/010_043_012.mp3","charTypeName":"word"},{"id":43709,"position":12,"arabic":"٤٣","translation":"(৪৩)","audioUrl":null,"charTypeName":"end"}]},{"number":44,"arabic":"إِنَّ ٱللَّهَ لَا يَظْلِمُ ٱلنَّاسَ شَيْـًۭٔا وَلَٰكِنَّ ٱلنَّاسَ أَنفُسَهُمْ يَظْلِمُونَ","translation":"Verily, God does not do the least wrong unto men, but it is men who wrong themselves.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1408.mp3","surahId":10,"words":[{"id":44498,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/010_044_001.mp3","charTypeName":"word"},{"id":44499,"position":2,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/010_044_002.mp3","charTypeName":"word"},{"id":44500,"position":3,"arabic":"لَا","translation":"না","audioUrl":"wbw/010_044_003.mp3","charTypeName":"word"},{"id":44501,"position":4,"arabic":"يَظْلِمُ","translation":"অবিচার করেন","audioUrl":"wbw/010_044_004.mp3","charTypeName":"word"},{"id":44502,"position":5,"arabic":"ٱلنَّاسَ","translation":"মানুষের (উপর)","audioUrl":"wbw/010_044_005.mp3","charTypeName":"word"},{"id":44503,"position":6,"arabic":"شَيْـًۭٔا","translation":"কিছুমাত্রও","audioUrl":"wbw/010_044_006.mp3","charTypeName":"word"},{"id":44504,"position":7,"arabic":"وَلَـٰكِنَّ","translation":"কিন্তু","audioUrl":"wbw/010_044_007.mp3","charTypeName":"word"},{"id":44505,"position":8,"arabic":"ٱلنَّاسَ","translation":"মানুষ","audioUrl":"wbw/010_044_008.mp3","charTypeName":"word"},{"id":44506,"position":9,"arabic":"أَنفُسَهُمْ","translation":"নিজেদের তাদের (উপর)","audioUrl":"wbw/010_044_009.mp3","charTypeName":"word"},{"id":44507,"position":10,"arabic":"يَظْلِمُونَ","translation":"তারা অবিচার করে","audioUrl":"wbw/010_044_010.mp3","charTypeName":"word"},{"id":44508,"position":11,"arabic":"٤٤","translation":"(৪৪)","audioUrl":null,"charTypeName":"end"}]},{"number":45,"arabic":"وَيَوْمَ يَحْشُرُهُمْ كَأَن لَّمْ يَلْبَثُوٓا۟ إِلَّا سَاعَةًۭ مِّنَ ٱلنَّهَارِ يَتَعَارَفُونَ بَيْنَهُمْ ۚ قَدْ خَسِرَ ٱلَّذِينَ كَذَّبُوا۟ بِلِقَآءِ ٱللَّهِ وَمَا كَانُوا۟ مُهْتَدِينَ","translation":"And on the Day when He shall gather them [unto Himself, it will seem to them] as if they had not tarried [on earth] longer than an hour of a day, knowing one another; [and] lost indeed will be they who [in their lifetime] considered it a lie that they were destined to meet God, and [thus] failed to find the right' way.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1409.mp3","surahId":10,"words":[{"id":45169,"position":1,"arabic":"وَيَوْمَ","translation":"এবং যেদিন","audioUrl":"wbw/010_045_001.mp3","charTypeName":"word"},{"id":45170,"position":2,"arabic":"يَحْشُرُهُمْ","translation":"একত্র করবেন তিনি তাদেরকে","audioUrl":"wbw/010_045_002.mp3","charTypeName":"word"},{"id":45171,"position":3,"arabic":"كَأَن","translation":"(তারা ভাববে) যেন","audioUrl":"wbw/010_045_003.mp3","charTypeName":"word"},{"id":45172,"position":4,"arabic":"لَّمْ","translation":"নি","audioUrl":"wbw/010_045_004.mp3","charTypeName":"word"},{"id":45173,"position":5,"arabic":"يَلْبَثُوٓا۟","translation":"তারা অবস্হান করে","audioUrl":"wbw/010_045_005.mp3","charTypeName":"word"},{"id":45174,"position":6,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/010_045_006.mp3","charTypeName":"word"},{"id":45175,"position":7,"arabic":"سَاعَةًۭ","translation":"(মাত্র)এক মুহূর্তকাল","audioUrl":"wbw/010_045_007.mp3","charTypeName":"word"},{"id":45176,"position":8,"arabic":"مِّنَ","translation":"থেকে","audioUrl":"wbw/010_045_008.mp3","charTypeName":"word"},{"id":45177,"position":9,"arabic":"ٱلنَّهَارِ","translation":"দিনের","audioUrl":"wbw/010_045_009.mp3","charTypeName":"word"},{"id":45178,"position":10,"arabic":"يَتَعَارَفُونَ","translation":"তারা পরস্পরে চিনবে","audioUrl":"wbw/010_045_010.mp3","charTypeName":"word"},{"id":45179,"position":11,"arabic":"بَيْنَهُمْ ۚ","translation":"তাদের মাঝের (লোকদেরকে)","audioUrl":"wbw/010_045_011.mp3","charTypeName":"word"},{"id":45181,"position":12,"arabic":"قَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/010_045_013.mp3","charTypeName":"word"},{"id":45182,"position":13,"arabic":"خَسِرَ","translation":"ক্ষতিগ্রস্ত হয়েছে","audioUrl":"wbw/010_045_014.mp3","charTypeName":"word"},{"id":45183,"position":14,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/010_045_015.mp3","charTypeName":"word"},{"id":45184,"position":15,"arabic":"كَذَّبُوا۟","translation":"মিথ্যারোপ করেছে","audioUrl":"wbw/010_045_016.mp3","charTypeName":"word"},{"id":45185,"position":16,"arabic":"بِلِقَآءِ","translation":"প্রতি সাক্ষাতের","audioUrl":"wbw/010_045_017.mp3","charTypeName":"word"},{"id":45186,"position":17,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/010_045_018.mp3","charTypeName":"word"},{"id":45187,"position":18,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/010_045_019.mp3","charTypeName":"word"},{"id":45188,"position":19,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/010_045_020.mp3","charTypeName":"word"},{"id":45189,"position":20,"arabic":"مُهْتَدِينَ","translation":"সৎপথ প্রাপ্ত","audioUrl":"wbw/010_045_021.mp3","charTypeName":"word"},{"id":45190,"position":21,"arabic":"٤٥","translation":"(৪৫)","audioUrl":null,"charTypeName":"end"}]},{"number":46,"arabic":"وَإِمَّا نُرِيَنَّكَ بَعْضَ ٱلَّذِى نَعِدُهُمْ أَوْ نَتَوَفَّيَنَّكَ فَإِلَيْنَا مَرْجِعُهُمْ ثُمَّ ٱللَّهُ شَهِيدٌ عَلَىٰ مَا يَفْعَلُونَ","translation":"And whether We show thee [in this world something of what We hold in store for those [deniers of the truth], or whether We cause thee to die [before that retribution takes place - know that, in the end], it is unto Us that they must return; and God is witness to all that they do.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1410.mp3","surahId":10,"words":[{"id":45889,"position":1,"arabic":"وَإِمَّا","translation":"এবং যদি","audioUrl":"wbw/010_046_001.mp3","charTypeName":"word"},{"id":45890,"position":2,"arabic":"نُرِيَنَّكَ","translation":"তোমাকে দেখাই আমরা","audioUrl":"wbw/010_046_002.mp3","charTypeName":"word"},{"id":45891,"position":3,"arabic":"بَعْضَ","translation":"কিছু অংশ","audioUrl":"wbw/010_046_003.mp3","charTypeName":"word"},{"id":45892,"position":4,"arabic":"ٱلَّذِى","translation":"যার","audioUrl":"wbw/010_046_004.mp3","charTypeName":"word"},{"id":45893,"position":5,"arabic":"نَعِدُهُمْ","translation":"ভয় দেখাচ্ছি তাদের","audioUrl":"wbw/010_046_005.mp3","charTypeName":"word"},{"id":45894,"position":6,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/010_046_006.mp3","charTypeName":"word"},{"id":45895,"position":7,"arabic":"نَتَوَفَّيَنَّكَ","translation":"তোমার মৃত্যু ঘটাই আমরা","audioUrl":"wbw/010_046_007.mp3","charTypeName":"word"},{"id":45896,"position":8,"arabic":"فَإِلَيْنَا","translation":"তবুও দিকে আমাদেরই","audioUrl":"wbw/010_046_008.mp3","charTypeName":"word"},{"id":45897,"position":9,"arabic":"مَرْجِعُهُمْ","translation":"প্রত্যাবর্তন তাদের (হবে)","audioUrl":"wbw/010_046_009.mp3","charTypeName":"word"},{"id":45898,"position":10,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/010_046_010.mp3","charTypeName":"word"},{"id":45899,"position":11,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/010_046_011.mp3","charTypeName":"word"},{"id":45900,"position":12,"arabic":"شَهِيدٌ","translation":"সাক্ষী (আছেন)","audioUrl":"wbw/010_046_012.mp3","charTypeName":"word"},{"id":45901,"position":13,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/010_046_013.mp3","charTypeName":"word"},{"id":45902,"position":14,"arabic":"مَا","translation":"(ঐ বিষয়ের) যা","audioUrl":"wbw/010_046_014.mp3","charTypeName":"word"},{"id":45903,"position":15,"arabic":"يَفْعَلُونَ","translation":"তারা করছে","audioUrl":"wbw/010_046_015.mp3","charTypeName":"word"},{"id":45904,"position":16,"arabic":"٤٦","translation":"(৪৬)","audioUrl":null,"charTypeName":"end"}]},{"number":47,"arabic":"وَلِكُلِّ أُمَّةٍۢ رَّسُولٌۭ ۖ فَإِذَا جَآءَ رَسُولُهُمْ قُضِىَ بَيْنَهُم بِٱلْقِسْطِ وَهُمْ لَا يُظْلَمُونَ","translation":"NOW every community has had an apostle; and only after their apostle has appeared [and delivered his message] is judgment passed on them, in all equity; and never are they wronged.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1411.mp3","surahId":10,"words":[{"id":46390,"position":1,"arabic":"وَلِكُلِّ","translation":"এবং জন্যে প্রত্যেক","audioUrl":"wbw/010_047_001.mp3","charTypeName":"word"},{"id":46391,"position":2,"arabic":"أُمَّةٍۢ","translation":"জাতির","audioUrl":"wbw/010_047_002.mp3","charTypeName":"word"},{"id":46392,"position":3,"arabic":"رَّسُولٌۭ ۖ","translation":"একজন রাসূল(রয়েছে)","audioUrl":"wbw/010_047_003.mp3","charTypeName":"word"},{"id":46394,"position":4,"arabic":"فَإِذَا","translation":"অতঃপর যখন","audioUrl":"wbw/010_047_005.mp3","charTypeName":"word"},{"id":46395,"position":5,"arabic":"جَآءَ","translation":"এসেছে","audioUrl":"wbw/010_047_006.mp3","charTypeName":"word"},{"id":46396,"position":6,"arabic":"رَسُولُهُمْ","translation":"রাসূল তাদের(রয়েছে)","audioUrl":"wbw/010_047_007.mp3","charTypeName":"word"},{"id":46397,"position":7,"arabic":"قُضِىَ","translation":"মীমাংসা করা হয়েছে","audioUrl":"wbw/010_047_008.mp3","charTypeName":"word"},{"id":46398,"position":8,"arabic":"بَيْنَهُم","translation":"মাঝে তাদের","audioUrl":"wbw/010_047_009.mp3","charTypeName":"word"},{"id":46399,"position":9,"arabic":"بِٱلْقِسْطِ","translation":"সাথে ন্যায়বিচারের","audioUrl":"wbw/010_047_010.mp3","charTypeName":"word"},{"id":46400,"position":10,"arabic":"وَهُمْ","translation":"এবং তাদের (উপর)","audioUrl":"wbw/010_047_011.mp3","charTypeName":"word"},{"id":46401,"position":11,"arabic":"لَا","translation":"না","audioUrl":"wbw/010_047_012.mp3","charTypeName":"word"},{"id":46402,"position":12,"arabic":"يُظْلَمُونَ","translation":"অবিচার করা হয়েছে","audioUrl":"wbw/010_047_013.mp3","charTypeName":"word"},{"id":46403,"position":13,"arabic":"٤٧","translation":"(৪৭)","audioUrl":null,"charTypeName":"end"}]},{"number":48,"arabic":"وَيَقُولُونَ مَتَىٰ هَٰذَا ٱلْوَعْدُ إِن كُنتُمْ صَٰدِقِينَ","translation":"And yet, they [who deny the truth] are wont to ask, \"When is that promise [of resurrection and judgment] to be fulfilled? [Answer this, O you who believe in it,] if you are men of truth!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1412.mp3","surahId":10,"words":[{"id":47182,"position":1,"arabic":"وَيَقُولُونَ","translation":"এবং তারা বলে","audioUrl":"wbw/010_048_001.mp3","charTypeName":"word"},{"id":47183,"position":2,"arabic":"مَتَىٰ","translation":"\"কখন (বাস্তবায়িত হবে)","audioUrl":"wbw/010_048_002.mp3","charTypeName":"word"},{"id":47184,"position":3,"arabic":"هَـٰذَا","translation":"এই","audioUrl":"wbw/010_048_003.mp3","charTypeName":"word"},{"id":47185,"position":4,"arabic":"ٱلْوَعْدُ","translation":"প্রতিশ্রুতি","audioUrl":"wbw/010_048_004.mp3","charTypeName":"word"},{"id":47186,"position":5,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/010_048_005.mp3","charTypeName":"word"},{"id":47187,"position":6,"arabic":"كُنتُمْ","translation":"হও তোমরা","audioUrl":"wbw/010_048_006.mp3","charTypeName":"word"},{"id":47188,"position":7,"arabic":"صَـٰدِقِينَ","translation":"সত্যবাদী\"","audioUrl":"wbw/010_048_007.mp3","charTypeName":"word"},{"id":47189,"position":8,"arabic":"٤٨","translation":"(৪৮)","audioUrl":null,"charTypeName":"end"}]},{"number":49,"arabic":"قُل لَّآ أَمْلِكُ لِنَفْسِى ضَرًّۭا وَلَا نَفْعًا إِلَّا مَا شَآءَ ٱللَّهُ ۗ لِكُلِّ أُمَّةٍ أَجَلٌ ۚ إِذَا جَآءَ أَجَلُهُمْ فَلَا يَسْتَـْٔخِرُونَ سَاعَةًۭ ۖ وَلَا يَسْتَقْدِمُونَ","translation":"Say [O Prophet]: \"It is not within my power to avert harm from, or bring benefit to, myself, except as God may please. For all people a term has been set: when the end of their term approaches, they can neither delay it by a single moment, nor hasten it.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1413.mp3","surahId":10,"words":[{"id":47703,"position":1,"arabic":"قُل","translation":"বলো","audioUrl":"wbw/010_049_001.mp3","charTypeName":"word"},{"id":47704,"position":2,"arabic":"لَّآ","translation":"\"না","audioUrl":"wbw/010_049_002.mp3","charTypeName":"word"},{"id":47705,"position":3,"arabic":"أَمْلِكُ","translation":"অধিকার রাখি আমি","audioUrl":"wbw/010_049_003.mp3","charTypeName":"word"},{"id":47706,"position":4,"arabic":"لِنَفْسِى","translation":"(এমনকি) জন্যও নিজের","audioUrl":"wbw/010_049_004.mp3","charTypeName":"word"},{"id":47707,"position":5,"arabic":"ضَرًّۭا","translation":"কোনো ক্ষতির","audioUrl":"wbw/010_049_005.mp3","charTypeName":"word"},{"id":47708,"position":6,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/010_049_006.mp3","charTypeName":"word"},{"id":47709,"position":7,"arabic":"نَفْعًا","translation":"কোনো উপকারের","audioUrl":"wbw/010_049_007.mp3","charTypeName":"word"},{"id":47710,"position":8,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/010_049_008.mp3","charTypeName":"word"},{"id":47711,"position":9,"arabic":"مَا","translation":"যা","audioUrl":"wbw/010_049_009.mp3","charTypeName":"word"},{"id":47712,"position":10,"arabic":"شَآءَ","translation":"ইচ্ছে করেন","audioUrl":"wbw/010_049_010.mp3","charTypeName":"word"},{"id":47713,"position":11,"arabic":"ٱللَّهُ ۗ","translation":"আল্লাহ","audioUrl":"wbw/010_049_011.mp3","charTypeName":"word"},{"id":47715,"position":12,"arabic":"لِكُلِّ","translation":"জন্যে প্রত্যেক","audioUrl":"wbw/010_049_013.mp3","charTypeName":"word"},{"id":47716,"position":13,"arabic":"أُمَّةٍ","translation":"জাতির","audioUrl":"wbw/010_049_014.mp3","charTypeName":"word"},{"id":47717,"position":14,"arabic":"أَجَلٌ ۚ","translation":"নির্দিষ্ট সময় (রয়েছে)","audioUrl":"wbw/010_049_015.mp3","charTypeName":"word"},{"id":47719,"position":15,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/010_049_017.mp3","charTypeName":"word"},{"id":47720,"position":16,"arabic":"جَآءَ","translation":"আসবে","audioUrl":"wbw/010_049_018.mp3","charTypeName":"word"},{"id":47721,"position":17,"arabic":"أَجَلُهُمْ","translation":"নির্দিষ্ট সময় তার","audioUrl":"wbw/010_049_019.mp3","charTypeName":"word"},{"id":47722,"position":18,"arabic":"فَلَا","translation":"অতঃপর না","audioUrl":"wbw/010_049_020.mp3","charTypeName":"word"},{"id":47723,"position":19,"arabic":"يَسْتَـْٔخِرُونَ","translation":"পিছাতে পারবে","audioUrl":"wbw/010_049_021.mp3","charTypeName":"word"},{"id":47724,"position":20,"arabic":"سَاعَةًۭ ۖ","translation":"মুহূর্তকালও","audioUrl":"wbw/010_049_022.mp3","charTypeName":"word"},{"id":47726,"position":21,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/010_049_024.mp3","charTypeName":"word"},{"id":47727,"position":22,"arabic":"يَسْتَقْدِمُونَ","translation":"এগিয়ে নিতে পারবে\"","audioUrl":"wbw/010_049_025.mp3","charTypeName":"word"},{"id":47728,"position":23,"arabic":"٤٩","translation":"(৪৯)","audioUrl":null,"charTypeName":"end"}]},{"number":50,"arabic":"قُلْ أَرَءَيْتُمْ إِنْ أَتَىٰكُمْ عَذَابُهُۥ بَيَٰتًا أَوْ نَهَارًۭا مَّاذَا يَسْتَعْجِلُ مِنْهُ ٱلْمُجْرِمُونَ","translation":"Say: \"Have you ever considered [how you would feel] if His chastisement were to befall you by night or by day? What could there be in that prospect that people lost in sin should wish to hasten?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1414.mp3","surahId":10,"words":[{"id":48538,"position":1,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/010_050_001.mp3","charTypeName":"word"},{"id":48539,"position":2,"arabic":"أَرَءَيْتُمْ","translation":"\"কি (ভেবে) দেখেছো তোমরা","audioUrl":"wbw/010_050_002.mp3","charTypeName":"word"},{"id":48540,"position":3,"arabic":"إِنْ","translation":"যদি","audioUrl":"wbw/010_050_003.mp3","charTypeName":"word"},{"id":48541,"position":4,"arabic":"أَتَىٰكُمْ","translation":"তোমাদের উপর আসে","audioUrl":"wbw/010_050_004.mp3","charTypeName":"word"},{"id":48542,"position":5,"arabic":"عَذَابُهُۥ","translation":"শাস্তি তাঁর(সহসা)","audioUrl":"wbw/010_050_005.mp3","charTypeName":"word"},{"id":48543,"position":6,"arabic":"بَيَـٰتًا","translation":"রাতে","audioUrl":"wbw/010_050_006.mp3","charTypeName":"word"},{"id":48544,"position":7,"arabic":"أَوْ","translation":"বা","audioUrl":"wbw/010_050_007.mp3","charTypeName":"word"},{"id":48545,"position":8,"arabic":"نَهَارًۭا","translation":"দিনে (তবে তোমরা কি করবে)","audioUrl":"wbw/010_050_008.mp3","charTypeName":"word"},{"id":48546,"position":9,"arabic":"مَّاذَا","translation":"কি (কারণ আছে)","audioUrl":"wbw/010_050_009.mp3","charTypeName":"word"},{"id":48547,"position":10,"arabic":"يَسْتَعْجِلُ","translation":"তাড়াহুড়া করতে চায়","audioUrl":"wbw/010_050_010.mp3","charTypeName":"word"},{"id":48548,"position":11,"arabic":"مِنْهُ","translation":"থেকে তা","audioUrl":"wbw/010_050_011.mp3","charTypeName":"word"},{"id":48549,"position":12,"arabic":"ٱلْمُجْرِمُونَ","translation":"অপরাধীরা\"","audioUrl":"wbw/010_050_012.mp3","charTypeName":"word"},{"id":48550,"position":13,"arabic":"٥٠","translation":"(৫০)","audioUrl":null,"charTypeName":"end"}]},{"number":51,"arabic":"أَثُمَّ إِذَا مَا وَقَعَ ءَامَنتُم بِهِۦٓ ۚ ءَآلْـَٰٔنَ وَقَدْ كُنتُم بِهِۦ تَسْتَعْجِلُونَ","translation":"Will you, then, believe in it [only] after it has come to pass -[on the Day when you will be asked, `Do you believe in it] now, after having [contemptuously] called for its speedy advent?'","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1415.mp3","surahId":10,"words":[{"id":49151,"position":1,"arabic":"أَثُمَّ","translation":"কি এরপর","audioUrl":"wbw/010_051_001.mp3","charTypeName":"word"},{"id":49152,"position":2,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/010_051_002.mp3","charTypeName":"word"},{"id":49153,"position":3,"arabic":"مَا","translation":"তা","audioUrl":"wbw/010_051_003.mp3","charTypeName":"word"},{"id":49154,"position":4,"arabic":"وَقَعَ","translation":"ঘটে যাবে","audioUrl":"wbw/010_051_004.mp3","charTypeName":"word"},{"id":49155,"position":5,"arabic":"ءَامَنتُم","translation":"বিশ্বাস করবে তোমরা","audioUrl":"wbw/010_051_005.mp3","charTypeName":"word"},{"id":49156,"position":6,"arabic":"بِهِۦٓ ۚ","translation":"উপর তার","audioUrl":"wbw/010_051_006.mp3","charTypeName":"word"},{"id":49158,"position":7,"arabic":"ءَآلْـَٔـٰنَ","translation":"কি এখন (রক্ষা পেতে চাও)","audioUrl":"wbw/010_051_008.mp3","charTypeName":"word"},{"id":49159,"position":8,"arabic":"وَقَدْ","translation":"অথচ নিশ্চয়ই","audio