{"id":237,"ayahs":[{"number":15,"arabic":"فَلَمَّا ذَهَبُوا۟ بِهِۦ وَأَجْمَعُوٓا۟ أَن يَجْعَلُوهُ فِى غَيَٰبَتِ ٱلْجُبِّ ۚ وَأَوْحَيْنَآ إِلَيْهِ لَتُنَبِّئَنَّهُم بِأَمْرِهِمْ هَٰذَا وَهُمْ لَا يَشْعُرُونَ","translation":"And so, when they went away with him, they decided to cast him into the dark depths of the well. And We revealed [this] unto him: \"Thou wilt yet remind them of this their deed at a time when they shall not perceive [who thou art]!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1611.mp3","surahId":12,"words":[{"id":17715,"position":1,"arabic":"فَلَمَّا","translation":"অতঃপর যখন","audioUrl":"wbw/012_015_001.mp3","charTypeName":"word"},{"id":17716,"position":2,"arabic":"ذَهَبُوا۟","translation":"তারা গেলো","audioUrl":"wbw/012_015_002.mp3","charTypeName":"word"},{"id":17717,"position":3,"arabic":"بِهِۦ","translation":"নিয়ে তাকে","audioUrl":"wbw/012_015_003.mp3","charTypeName":"word"},{"id":17718,"position":4,"arabic":"وَأَجْمَعُوٓا۟","translation":"এবং তারা একমত হলো","audioUrl":"wbw/012_015_004.mp3","charTypeName":"word"},{"id":17719,"position":5,"arabic":"أَن","translation":"যে","audioUrl":"wbw/012_015_005.mp3","charTypeName":"word"},{"id":17720,"position":6,"arabic":"يَجْعَلُوهُ","translation":"তাকে তারা ফেলে দিবে","audioUrl":"wbw/012_015_006.mp3","charTypeName":"word"},{"id":17721,"position":7,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/012_015_007.mp3","charTypeName":"word"},{"id":17722,"position":8,"arabic":"غَيَـٰبَتِ","translation":"(অন্ধকার) গভীরে","audioUrl":"wbw/012_015_008.mp3","charTypeName":"word"},{"id":17723,"position":9,"arabic":"ٱلْجُبِّ ۚ","translation":"কূপের","audioUrl":"wbw/012_015_009.mp3","charTypeName":"word"},{"id":17725,"position":10,"arabic":"وَأَوْحَيْنَآ","translation":"এ অবস্থায় আমরা ওহী করলাম","audioUrl":"wbw/012_015_011.mp3","charTypeName":"word"},{"id":17726,"position":11,"arabic":"إِلَيْهِ","translation":"তার কাছে","audioUrl":"wbw/012_015_012.mp3","charTypeName":"word"},{"id":17727,"position":12,"arabic":"لَتُنَبِّئَنَّهُم","translation":"\"তাদের তুমি নিশ্চয়ই এক সময় জানিয়ে দিবে","audioUrl":"wbw/012_015_013.mp3","charTypeName":"word"},{"id":17728,"position":13,"arabic":"بِأَمْرِهِمْ","translation":"সম্পর্কে তাদের কাজ","audioUrl":"wbw/012_015_014.mp3","charTypeName":"word"},{"id":17729,"position":14,"arabic":"هَـٰذَا","translation":"এই","audioUrl":"wbw/012_015_015.mp3","charTypeName":"word"},{"id":17730,"position":15,"arabic":"وَهُمْ","translation":"(এখন) অথচ তারা","audioUrl":"wbw/012_015_016.mp3","charTypeName":"word"},{"id":17731,"position":16,"arabic":"لَا","translation":"না","audioUrl":"wbw/012_015_017.mp3","charTypeName":"word"},{"id":17732,"position":17,"arabic":"يَشْعُرُونَ","translation":"তারা অনুভব করছে\"","audioUrl":"wbw/012_015_018.mp3","charTypeName":"word"},{"id":17733,"position":18,"arabic":"١٥","translation":"(১৫)","audioUrl":null,"charTypeName":"end"}]},{"number":16,"arabic":"وَجَآءُوٓ أَبَاهُمْ عِشَآءًۭ يَبْكُونَ","translation":"And at nightfall they came to their father, weeping,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1612.mp3","surahId":12,"words":[{"id":18724,"position":1,"arabic":"وَجَآءُوٓ","translation":"এবং তারা আসলো","audioUrl":"wbw/012_016_001.mp3","charTypeName":"word"},{"id":18725,"position":2,"arabic":"أَبَاهُمْ","translation":"তাদের পিতার কাছে","audioUrl":"wbw/012_016_002.mp3","charTypeName":"word"},{"id":18726,"position":3,"arabic":"عِشَآءًۭ","translation":"সন্ধ্যাকালে","audioUrl":"wbw/012_016_003.mp3","charTypeName":"word"},{"id":18727,"position":4,"arabic":"يَبْكُونَ","translation":"কাঁদতে কাঁদতে","audioUrl":"wbw/012_016_004.mp3","charTypeName":"word"},{"id":18728,"position":5,"arabic":"١٦","translation":"(১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":17,"arabic":"قَالُوا۟ يَٰٓأَبَانَآ إِنَّا ذَهَبْنَا نَسْتَبِقُ وَتَرَكْنَا يُوسُفَ عِندَ مَتَٰعِنَا فَأَكَلَهُ ٱلذِّئْبُ ۖ وَمَآ أَنتَ بِمُؤْمِنٍۢ لَّنَا وَلَوْ كُنَّا صَٰدِقِينَ","translation":"[and] said: \"O our father! Behold, we went off racing with one another, and left Joseph behind with our things; and thereupon the wolf devoured him! But [we know that] thou wouldst not believe us even though we speak the truth\" -","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1613.mp3","surahId":12,"words":[{"id":19804,"position":1,"arabic":"قَالُوا۟","translation":"তারা বললো","audioUrl":"wbw/012_017_001.mp3","charTypeName":"word"},{"id":19805,"position":2,"arabic":"يَـٰٓأَبَانَآ","translation":"\"হে আমাদের পিতা","audioUrl":"wbw/012_017_002.mp3","charTypeName":"word"},{"id":19806,"position":3,"arabic":"إِنَّا","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/012_017_003.mp3","charTypeName":"word"},{"id":19807,"position":4,"arabic":"ذَهَبْنَا","translation":"আমরা গিয়েছিলাম","audioUrl":"wbw/012_017_004.mp3","charTypeName":"word"},{"id":19808,"position":5,"arabic":"نَسْتَبِقُ","translation":"দৌড়ের পাল্লা দিচ্ছিলাম","audioUrl":"wbw/012_017_005.mp3","charTypeName":"word"},{"id":19809,"position":6,"arabic":"وَتَرَكْنَا","translation":"ও আমরা রেখে গিয়েছিলাম","audioUrl":"wbw/012_017_006.mp3","charTypeName":"word"},{"id":19810,"position":7,"arabic":"يُوسُفَ","translation":"ইউসুফকে","audioUrl":"wbw/012_017_007.mp3","charTypeName":"word"},{"id":19811,"position":8,"arabic":"عِندَ","translation":"কাছে","audioUrl":"wbw/012_017_008.mp3","charTypeName":"word"},{"id":19812,"position":9,"arabic":"مَتَـٰعِنَا","translation":"আমাদের মালপত্রের","audioUrl":"wbw/012_017_009.mp3","charTypeName":"word"},{"id":19813,"position":10,"arabic":"فَأَكَلَهُ","translation":"তাকে তখন খেয়ে ফেলে","audioUrl":"wbw/012_017_010.mp3","charTypeName":"word"},{"id":19814,"position":11,"arabic":"ٱلذِّئْبُ ۖ","translation":"নেকড়ে বাঘ","audioUrl":"wbw/012_017_011.mp3","charTypeName":"word"},{"id":19816,"position":12,"arabic":"وَمَآ","translation":"অথচ নন","audioUrl":"wbw/012_017_013.mp3","charTypeName":"word"},{"id":19817,"position":13,"arabic":"أَنتَ","translation":"আপনি","audioUrl":"wbw/012_017_014.mp3","charTypeName":"word"},{"id":19818,"position":14,"arabic":"بِمُؤْمِنٍۢ","translation":"বিশ্বাসকারী","audioUrl":"wbw/012_017_015.mp3","charTypeName":"word"},{"id":19819,"position":15,"arabic":"لَّنَا","translation":"আমাদেরকে","audioUrl":"wbw/012_017_016.mp3","charTypeName":"word"},{"id":19820,"position":16,"arabic":"وَلَوْ","translation":"যদিও","audioUrl":"wbw/012_017_017.mp3","charTypeName":"word"},{"id":19821,"position":17,"arabic":"كُنَّا","translation":"আমরা হই","audioUrl":"wbw/012_017_018.mp3","charTypeName":"word"},{"id":19822,"position":18,"arabic":"صَـٰدِقِينَ","translation":"(সবাই) সত্যবাদী\"","audioUrl":"wbw/012_017_019.mp3","charTypeName":"word"},{"id":19823,"position":19,"arabic":"١٧","translation":"(১৭)","audioUrl":null,"charTypeName":"end"}]},{"number":18,"arabic":"وَجَآءُو عَلَىٰ قَمِيصِهِۦ بِدَمٍۢ كَذِبٍۢ ۚ قَالَ بَلْ سَوَّلَتْ لَكُمْ أَنفُسُكُمْ أَمْرًۭا ۖ فَصَبْرٌۭ جَمِيلٌۭ ۖ وَٱللَّهُ ٱلْمُسْتَعَانُ عَلَىٰ مَا تَصِفُونَ","translation":"and they produced his tunic with false blood upon it. [But Jacob] exclaimed: \"Nay, but it is your [own] minds that have made [so terrible] a happening seem a matter of little account to you! But [as for myself,] patience in adversity is most goodly [in the sight of God]; and it is to God [alone] that I pray to give me strength to bear the misfortune which you have described to me.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1614.mp3","surahId":12,"words":[{"id":20881,"position":1,"arabic":"وَجَآءُو","translation":"এবং তারা আসলো","audioUrl":"wbw/012_018_001.mp3","charTypeName":"word"},{"id":20882,"position":2,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/012_018_002.mp3","charTypeName":"word"},{"id":20883,"position":3,"arabic":"قَمِيصِهِۦ","translation":"তার জামার","audioUrl":"wbw/012_018_003.mp3","charTypeName":"word"},{"id":20884,"position":4,"arabic":"بِدَمٍۢ","translation":"নিয়ে রক্ত (লাগিয়ে)","audioUrl":"wbw/012_018_004.mp3","charTypeName":"word"},{"id":20885,"position":5,"arabic":"كَذِبٍۢ ۚ","translation":"মিথ্যা","audioUrl":"wbw/012_018_005.mp3","charTypeName":"word"},{"id":20887,"position":6,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/012_018_007.mp3","charTypeName":"word"},{"id":20888,"position":7,"arabic":"بَلْ","translation":"\"বরং","audioUrl":"wbw/012_018_008.mp3","charTypeName":"word"},{"id":20889,"position":8,"arabic":"سَوَّلَتْ","translation":"সাজিয়ে দিয়েছে","audioUrl":"wbw/012_018_009.mp3","charTypeName":"word"},{"id":20890,"position":9,"arabic":"لَكُمْ","translation":"তোমাদেরকে","audioUrl":"wbw/012_018_010.mp3","charTypeName":"word"},{"id":20891,"position":10,"arabic":"أَنفُسُكُمْ","translation":"তোমাদের মন","audioUrl":"wbw/012_018_011.mp3","charTypeName":"word"},{"id":20892,"position":11,"arabic":"أَمْرًۭا ۖ","translation":"এ কাজ","audioUrl":"wbw/012_018_012.mp3","charTypeName":"word"},{"id":20894,"position":12,"arabic":"فَصَبْرٌۭ","translation":"অতএব ধৈর্য ধরাই","audioUrl":"wbw/012_018_014.mp3","charTypeName":"word"},{"id":20895,"position":13,"arabic":"جَمِيلٌۭ ۖ","translation":"উত্তম","audioUrl":"wbw/012_018_015.mp3","charTypeName":"word"},{"id":20897,"position":14,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহই","audioUrl":"wbw/012_018_017.mp3","charTypeName":"word"},{"id":20898,"position":15,"arabic":"ٱلْمُسْتَعَانُ","translation":"সাহায্যস্থল","audioUrl":"wbw/012_018_018.mp3","charTypeName":"word"},{"id":20899,"position":16,"arabic":"عَلَىٰ","translation":"এক্ষেত্রে","audioUrl":"wbw/012_018_019.mp3","charTypeName":"word"},{"id":20900,"position":17,"arabic":"مَا","translation":"যা","audioUrl":"wbw/012_018_020.mp3","charTypeName":"word"},{"id":20901,"position":18,"arabic":"تَصِفُونَ","translation":"তোমরা বর্ণনা করছো\"","audioUrl":"wbw/012_018_021.mp3","charTypeName":"word"},{"id":20902,"position":19,"arabic":"١٨","translation":"(১৮)","audioUrl":null,"charTypeName":"end"}]},{"number":19,"arabic":"وَجَآءَتْ سَيَّارَةٌۭ فَأَرْسَلُوا۟ وَارِدَهُمْ فَأَدْلَىٰ دَلْوَهُۥ ۖ قَالَ يَٰبُشْرَىٰ هَٰذَا غُلَٰمٌۭ ۚ وَأَسَرُّوهُ بِضَٰعَةًۭ ۚ وَٱللَّهُ عَلِيمٌۢ بِمَا يَعْمَلُونَ","translation":"AND THERE CAME a caravan; and they sent forth their drawer of water, and he let down his bucket into the well - [and when he saw Joseph] he exclaimed: \"Oh, what a lucky find, this boy!\" And they hid him with a view to selling him: but God had full knowledge of all that they were doing.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1615.mp3","surahId":12,"words":[{"id":21948,"position":1,"arabic":"وَجَآءَتْ","translation":"এবং আসলো","audioUrl":"wbw/012_019_001.mp3","charTypeName":"word"},{"id":21949,"position":2,"arabic":"سَيَّارَةٌۭ","translation":"এক যাত্রীদল","audioUrl":"wbw/012_019_002.mp3","charTypeName":"word"},{"id":21950,"position":3,"arabic":"فَأَرْسَلُوا۟","translation":"অতঃপর তারা পাঠালো","audioUrl":"wbw/012_019_003.mp3","charTypeName":"word"},{"id":21951,"position":4,"arabic":"وَارِدَهُمْ","translation":"তাদের পানি সংগ্রাহককে","audioUrl":"wbw/012_019_004.mp3","charTypeName":"word"},{"id":21952,"position":5,"arabic":"فَأَدْلَىٰ","translation":"সে তখন নামিয়ে দিলো","audioUrl":"wbw/012_019_005.mp3","charTypeName":"word"},{"id":21953,"position":6,"arabic":"دَلْوَهُۥ ۖ","translation":"তার বালতি","audioUrl":"wbw/012_019_006.mp3","charTypeName":"word"},{"id":21955,"position":7,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/012_019_008.mp3","charTypeName":"word"},{"id":21956,"position":8,"arabic":"يَـٰبُشْرَىٰ","translation":"\"কি সুখবর!","audioUrl":"wbw/012_019_009.mp3","charTypeName":"word"},{"id":21957,"position":9,"arabic":"هَـٰذَا","translation":"এযে","audioUrl":"wbw/012_019_010.mp3","charTypeName":"word"},{"id":21958,"position":10,"arabic":"غُلَـٰمٌۭ ۚ","translation":"একটি ছেলে\"","audioUrl":"wbw/012_019_011.mp3","charTypeName":"word"},{"id":21960,"position":11,"arabic":"وَأَسَرُّوهُ","translation":"এবং তাকে লুকালো","audioUrl":"wbw/012_019_013.mp3","charTypeName":"word"},{"id":21961,"position":12,"arabic":"بِضَـٰعَةًۭ ۚ","translation":"পণ্যদ্রব্য হিসেবে","audioUrl":"wbw/012_019_014.mp3","charTypeName":"word"},{"id":21963,"position":13,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/012_019_016.mp3","charTypeName":"word"},{"id":21964,"position":14,"arabic":"عَلِيمٌۢ","translation":"খুবই অবহিত","audioUrl":"wbw/012_019_017.mp3","charTypeName":"word"},{"id":21965,"position":15,"arabic":"بِمَا","translation":"বিষয়ে যা","audioUrl":"wbw/012_019_018.mp3","charTypeName":"word"},{"id":21966,"position":16,"arabic":"يَعْمَلُونَ","translation":"তারা কাজ করছিলো","audioUrl":"wbw/012_019_019.mp3","charTypeName":"word"},{"id":21967,"position":17,"arabic":"١٩","translation":"(১৯)","audioUrl":null,"charTypeName":"end"}]},{"number":20,"arabic":"وَشَرَوْهُ بِثَمَنٍۭ بَخْسٍۢ دَرَٰهِمَ مَعْدُودَةٍۢ وَكَانُوا۟ فِيهِ مِنَ ٱلزَّٰهِدِينَ","translation":"And they sold him for a paltry price - a mere few silver coins: thus low did they value him.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1616.mp3","surahId":12,"words":[{"id":22454,"position":1,"arabic":"وَشَرَوْهُ","translation":"এবং তাকে তারা বিক্রি করে দিলো","audioUrl":"wbw/012_020_001.mp3","charTypeName":"word"},{"id":22455,"position":2,"arabic":"بِثَمَنٍۭ","translation":"দাম দিয়ে","audioUrl":"wbw/012_020_002.mp3","charTypeName":"word"},{"id":22456,"position":3,"arabic":"بَخْسٍۢ","translation":"সামান্য","audioUrl":"wbw/012_020_003.mp3","charTypeName":"word"},{"id":22457,"position":4,"arabic":"دَرَٰهِمَ","translation":"দিরহাম","audioUrl":"wbw/012_020_004.mp3","charTypeName":"word"},{"id":22458,"position":5,"arabic":"مَعْدُودَةٍۢ","translation":"কয়েকটি মাত্র","audioUrl":"wbw/012_020_005.mp3","charTypeName":"word"},{"id":22459,"position":6,"arabic":"وَكَانُوا۟","translation":"এবং তারা ছিলো","audioUrl":"wbw/012_020_006.mp3","charTypeName":"word"},{"id":22460,"position":7,"arabic":"فِيهِ","translation":"তার (দামের) ব্যাপারে","audioUrl":"wbw/012_020_007.mp3","charTypeName":"word"},{"id":22461,"position":8,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/012_020_008.mp3","charTypeName":"word"},{"id":22462,"position":9,"arabic":"ٱلزَّٰهِدِينَ","translation":"নিরাসক্তদের","audioUrl":"wbw/012_020_009.mp3","charTypeName":"word"},{"id":22463,"position":10,"arabic":"٢٠","translation":"(২০)","audioUrl":null,"charTypeName":"end"}]},{"number":21,"arabic":"وَقَالَ ٱلَّذِى ٱشْتَرَىٰهُ مِن مِّصْرَ لِٱمْرَأَتِهِۦٓ أَكْرِمِى مَثْوَىٰهُ عَسَىٰٓ أَن يَنفَعَنَآ أَوْ نَتَّخِذَهُۥ وَلَدًۭا ۚ وَكَذَٰلِكَ مَكَّنَّا لِيُوسُفَ فِى ٱلْأَرْضِ وَلِنُعَلِّمَهُۥ مِن تَأْوِيلِ ٱلْأَحَادِيثِ ۚ وَٱللَّهُ غَالِبٌ عَلَىٰٓ أَمْرِهِۦ وَلَٰكِنَّ أَكْثَرَ ٱلنَّاسِ لَا يَعْلَمُونَ","translation":"And the man from Egypt who bought him said to his wife: \"Make his stay [with us] honourable; he may well be of use to us, or we may adopt him as a son. And thus We gave unto Joseph a firm place on earth; and [We did this] so that We might impart unto him some understanding of the inner meaning of happenings. For, God always prevails in whatever be His purpose: but most people know it not.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1617.mp3","surahId":12,"words":[{"id":24047,"position":1,"arabic":"وَقَالَ","translation":"এবং বললো","audioUrl":"wbw/012_021_001.mp3","charTypeName":"word"},{"id":24048,"position":2,"arabic":"ٱلَّذِى","translation":"যে","audioUrl":"wbw/012_021_002.mp3","charTypeName":"word"},{"id":24049,"position":3,"arabic":"ٱشْتَرَىٰهُ","translation":"তাকে কিনেছিলো","audioUrl":"wbw/012_021_003.mp3","charTypeName":"word"},{"id":24050,"position":4,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/012_021_004.mp3","charTypeName":"word"},{"id":24051,"position":5,"arabic":"مِّصْرَ","translation":"মিশর","audioUrl":"wbw/012_021_005.mp3","charTypeName":"word"},{"id":24052,"position":6,"arabic":"لِٱمْرَأَتِهِۦٓ","translation":"তার স্ত্রীকে","audioUrl":"wbw/012_021_006.mp3","charTypeName":"word"},{"id":24053,"position":7,"arabic":"أَكْرِمِى","translation":"\"সম্মানজনক ব্যবস্থা করো","audioUrl":"wbw/012_021_007.mp3","charTypeName":"word"},{"id":24054,"position":8,"arabic":"مَثْوَىٰهُ","translation":"তার থাকার","audioUrl":"wbw/012_021_008.mp3","charTypeName":"word"},{"id":24055,"position":9,"arabic":"عَسَىٰٓ","translation":"আশা করা যায়","audioUrl":"wbw/012_021_009.mp3","charTypeName":"word"},{"id":24056,"position":10,"arabic":"أَن","translation":"যে","audioUrl":"wbw/012_021_010.mp3","charTypeName":"word"},{"id":24057,"position":11,"arabic":"يَنفَعَنَآ","translation":"আমাদের সে উপকারে আসবে","audioUrl":"wbw/012_021_011.mp3","charTypeName":"word"},{"id":24058,"position":12,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/012_021_012.mp3","charTypeName":"word"},{"id":24059,"position":13,"arabic":"نَتَّخِذَهُۥ","translation":"তাকে আমরা গ্রহণ করবো","audioUrl":"wbw/012_021_013.mp3","charTypeName":"word"},{"id":24060,"position":14,"arabic":"وَلَدًۭا ۚ","translation":"পুত্র হিসাবে\"","audioUrl":"wbw/012_021_014.mp3","charTypeName":"word"},{"id":24062,"position":15,"arabic":"وَكَذَٰلِكَ","translation":"এবং এভাবে","audioUrl":"wbw/012_021_016.mp3","charTypeName":"word"},{"id":24063,"position":16,"arabic":"مَكَّنَّا","translation":"আমরা প্রতিষ্ঠিত করলাম","audioUrl":"wbw/012_021_017.mp3","charTypeName":"word"},{"id":24064,"position":17,"arabic":"لِيُوسُفَ","translation":"ইউসুফকে","audioUrl":"wbw/012_021_018.mp3","charTypeName":"word"},{"id":24065,"position":18,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/012_021_019.mp3","charTypeName":"word"},{"id":24066,"position":19,"arabic":"ٱلْأَرْضِ","translation":"(সে) দেশের","audioUrl":"wbw/012_021_020.mp3","charTypeName":"word"},{"id":24067,"position":20,"arabic":"وَلِنُعَلِّمَهُۥ","translation":"এবং আমরা যেন তাকে শিক্ষা দিতে পারি","audioUrl":"wbw/012_021_021.mp3","charTypeName":"word"},{"id":24068,"position":21,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/012_021_022.mp3","charTypeName":"word"},{"id":24069,"position":22,"arabic":"تَأْوِيلِ","translation":"ব্যখ্যা","audioUrl":"wbw/012_021_023.mp3","charTypeName":"word"},{"id":24070,"position":23,"arabic":"ٱلْأَحَادِيثِ