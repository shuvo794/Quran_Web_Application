ion":3,"arabic":"أَشُدَّهُۥٓ","translation":"তার যৌবনে","audioUrl":"wbw/012_022_003.mp3","charTypeName":"word"},{"id":25074,"position":4,"arabic":"ءَاتَيْنَـٰهُ","translation":"তাকে আমরা দিলাম","audioUrl":"wbw/012_022_004.mp3","charTypeName":"word"},{"id":25075,"position":5,"arabic":"حُكْمًۭا","translation":"প্রজ্ঞা","audioUrl":"wbw/012_022_005.mp3","charTypeName":"word"},{"id":25076,"position":6,"arabic":"وَعِلْمًۭا ۚ","translation":"ও জ্ঞান","audioUrl":"wbw/012_022_006.mp3","charTypeName":"word"},{"id":25078,"position":7,"arabic":"وَكَذَٰلِكَ","translation":"এবং এভাবে","audioUrl":"wbw/012_022_008.mp3","charTypeName":"word"},{"id":25079,"position":8,"arabic":"نَجْزِى","translation":"প্রতিফল দিই আমরা","audioUrl":"wbw/012_022_009.mp3","charTypeName":"word"},{"id":25080,"position":9,"arabic":"ٱلْمُحْسِنِينَ","translation":"সৎকর্মশীললোকদেরকে","audioUrl":"wbw/012_022_010.mp3","charTypeName":"word"},{"id":25081,"position":10,"arabic":"٢٢","translation":"(২২)","audioUrl":null,"charTypeName":"end"}]}]}