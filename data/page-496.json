{"id":496,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ حمٓ","translation":"Ha. Mim.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4415.mp3","surahId":44,"words":[{"id":120,"position":1,"arabic":"حمٓ","translation":"হা-মীম","audioUrl":"wbw/044_001_001.mp3","charTypeName":"word"},{"id":121,"position":2,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"وَٱلْكِتَٰبِ ٱلْمُبِينِ","translation":"CONSIDER this divine writ, clear in itself and clearly showing the truth!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4416.mp3","surahId":44,"words":[{"id":966,"position":1,"arabic":"وَٱلْكِتَـٰبِ","translation":"শপথ (এই) কিতাবের","audioUrl":"wbw/044_002_001.mp3","charTypeName":"word"},{"id":967,"position":2,"arabic":"ٱلْمُبِينِ","translation":"সুস্পষ্ট","audioUrl":"wbw/044_002_002.mp3","charTypeName":"word"},{"id":968,"position":3,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"إِنَّآ أَنزَلْنَٰهُ فِى لَيْلَةٍۢ مُّبَٰرَكَةٍ ۚ إِنَّا كُنَّا مُنذِرِينَ","translation":"Behold, from on high have We bestowed it on a blessed night: for, verily, We have always been warning [man].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4417.mp3","surahId":44,"words":[{"id":2083,"position":1,"arabic":"إِنَّآ","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/044_003_001.mp3","charTypeName":"word"},{"id":2084,"position":2,"arabic":"أَنزَلْنَـٰهُ","translation":"তা আমরা অবতীর্ণ করেছি","audioUrl":"wbw/044_003_002.mp3","charTypeName":"word"},{"id":2085,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/044_003_003.mp3","charTypeName":"word"},{"id":2086,"position":4,"arabic":"لَيْلَةٍۢ","translation":"এক রাতের","audioUrl":"wbw/044_003_004.mp3","charTypeName":"word"},{"id":2087,"position":5,"arabic":"مُّبَـٰرَكَةٍ ۚ","translation":"সৌভাগ্যময়","audioUrl":"wbw/044_003_005.mp3","charTypeName":"word"},{"id":2089,"position":6,"arabic":"إِنَّا","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/044_003_007.mp3","charTypeName":"word"},{"id":2090,"position":7,"arabic":"كُنَّا","translation":"আমরা ছিলাম","audioUrl":"wbw/044_003_008.mp3","charTypeName":"word"},{"id":2091,"position":8,"arabic":"مُنذِرِينَ","translation":"সতর্ককারী","audioUrl":"wbw/044_003_009.mp3","charTypeName":"word"},{"id":2092,"position":9,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"فِيهَا يُفْرَقُ كُلُّ أَمْرٍ حَكِيمٍ","translation":"On that [night] was made clear, in wisdom, the distinction between all things [good and evil]","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4418.mp3","surahId":44,"words":[{"id":3351,"position":1,"arabic":"فِيهَا","translation":"তার মধ্যে(অর্থাৎ সেই রাতে)","audioUrl":"wbw/044_004_001.mp3","charTypeName":"word"},{"id":3352,"position":2,"arabic":"يُفْرَقُ","translation":"স্থির করা হয়","audioUrl":"wbw/044_004_002.mp3","charTypeName":"word"},{"id":3353,"position":3,"arabic":"كُلُّ","translation":"প্রত্যেক","audioUrl":"wbw/044_004_003.mp3","charTypeName":"word"},{"id":3354,"position":4,"arabic":"أَمْرٍ","translation":"বিষয়","audioUrl":"wbw/044_004_004.mp3","charTypeName":"word"},{"id":3355,"position":5,"arabic":"حَكِيمٍ","translation":"বিজ্ঞতাপূর্ণ","audioUrl":"wbw/044_004_005.mp3","charTypeName":"word"},{"id":3356,"position":6,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"أَمْرًۭا مِّنْ عِندِنَآ ۚ إِنَّا كُنَّا مُرْسِلِينَ","translation":"at a behest from Ourselves: for, verily, We have always been sending [Our messages of guidance]","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4419.mp3","surahId":44,"words":[{"id":4738,"position":1,"arabic":"أَمْرًۭا","translation":"নির্দেশক্রমে","audioUrl":"wbw/044_005_001.mp3","charTypeName":"word"},{"id":4739,"position":2,"arabic":"مِّنْ","translation":"থেকে","audioUrl":"wbw/044_005_002.mp3","charTypeName":"word"},{"id":4740,"position":3,"arabic":"عِندِنَآ ۚ","translation":"আমাদের নিকট","audioUrl":"wbw/044_005_003.mp3","charTypeName":"word"},{"id":4742,"position":4,"arabic":"إِنَّا","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/044_005_005.mp3","charTypeName":"word"},{"id":4743,"position":5,"arabic":"كُنَّا","translation":"আমরা ছিলাম","audioUrl":"wbw/044_005_006.mp3","charTypeName":"word"},{"id":4744,"position":6,"arabic":"مُرْسِلِينَ","translation":"(এক রাসূল) প্রেরণকারী","audioUrl":"wbw/044_005_007.mp3","charTypeName":"word"},{"id":4745,"position":7,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"رَحْمَةًۭ مِّن رَّبِّكَ ۚ إِنَّهُۥ هُوَ ٱلسَّمِيعُ ٱلْعَلِيمُ","translation":"in pur­suance of thy Sustainer’s grace [unto man]. Verily, He alone is all-hearing, all-knowing,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4420.mp3","surahId":44,"words":[{"id":5999,"position":1,"arabic":"رَحْمَةًۭ","translation":"অনুগ্রহস্বরূপ","audioUrl":"wbw/044_006_001.mp3","charTypeName":"word"},{"id":6000,"position":2,"arabic":"مِّن","translation":"পক্ষ হ'তে","audioUrl":"wbw/044_006_002.mp3","charTypeName":"word"},{"id":6001,"position":3,"arabic":"رَّبِّكَ ۚ","translation":"তোমার রবের","audioUrl":"wbw/044_006_003.mp3","charTypeName":"word"},{"id":6003,"position":4,"arabic":"إِنَّهُۥ","translation":"নিশ্চয়ই তিনি","audioUrl":"wbw/044_006_005.mp3","charTypeName":"word"},{"id":6004,"position":5,"arabic":"هُوَ","translation":"তিনিই","audioUrl":"wbw/044_006_006.mp3","charTypeName":"word"},{"id":6005,"position":6,"arabic":"ٱلسَّمِيعُ","translation":"সব কিছুই শুনেন","audioUrl":"wbw/044_006_007.mp3","charTypeName":"word"},{"id":6006,"position":7,"arabic":"ٱلْعَلِيمُ","translation":"সবকিছু জানেন","audioUrl":"wbw/044_006_008.mp3","charTypeName":"word"},{"id":6007,"position":8,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"رَبِّ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ وَمَا بَيْنَهُمَآ ۖ إِن كُنتُم مُّوقِنِينَ","translation":"the Sustainer of the heavens and the earth and all that is between them - if you could but grasp it with inner certainty!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4421.mp3","surahId":44,"words":[{"id":7313,"position":1,"arabic":"رَبِّ","translation":"(তিনি) রব","audioUrl":"wbw/044_007_001.mp3","charTypeName":"word"},{"id":7314,"position":2,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশের","audioUrl":"wbw/044_007_002.mp3","charTypeName":"word"},{"id":7315,"position":3,"arabic":"وَٱلْأَرْضِ","translation":"ও পৃথিবীর","audioUrl":"wbw/044_007_003.mp3","charTypeName":"word"},{"id":7316,"position":4,"arabic":"وَمَا","translation":"এবং যা কিছু","audioUrl":"wbw/044_007_004.mp3","charTypeName":"word"},{"id":7317,"position":5,"arabic":"بَيْنَهُمَآ ۖ","translation":"উভয়ের মাঝে আছে","audioUrl":"wbw/044_007_005.mp3","charTypeName":"word"},{"id":7319,"position":6,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/044_007_007.mp3","charTypeName":"word"},{"id":7320,"position":7,"arabic":"كُنتُم","translation":"তোমরা হয়ে থাকো","audioUrl":"wbw/044_007_008.mp3","charTypeName":"word"},{"id":7321,"position":8,"arabic":"مُّوقِنِينَ","translation":"নিশ্চিত বিশ্বাসী","audioUrl":"wbw/044_007_009.mp3","charTypeName":"word"},{"id":7322,"position":9,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"لَآ إِلَٰهَ إِلَّا هُوَ يُحْىِۦ وَيُمِيتُ ۖ رَبُّكُمْ وَرَبُّ ءَابَآئِكُمُ ٱلْأَوَّلِينَ","translation":"There is no deity save Him: He grants life and deals death: He is your Sustainer as well as the Sustainer of your forebears of old.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4422.mp3","surahId":44,"words":[{"id":8578,"position":1,"arabic":"لَآ","translation":"নেই","audioUrl":"wbw/044_008_001.mp3","charTypeName":"word"},{"id":8579,"position":2,"arabic":"إِلَـٰهَ","translation":"কোনো ইলাহ","audioUrl":"wbw/044_008_002.mp3","charTypeName":"word"},{"id":8580,"position":3,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/044_008_003.mp3","charTypeName":"word"},{"id":8581,"position":4,"arabic":"هُوَ","translation":"তিনি","audioUrl":"wbw/044_008_004.mp3","charTypeName":"word"},{"id":8582,"position":5,"arabic":"يُحْىِۦ","translation":"তিনি জীবন দেন","audioUrl":"wbw/044_008_005.mp3","charTypeName":"word"},{"id":8583,"position":6,"arabic":"وَيُمِيتُ ۖ","translation":"এবং মৃত্যুও ঘটান","audioUrl":"wbw/044_008_006.mp3","charTypeName":"word"},{"id":8585,"position":7,"arabic":"رَبُّكُمْ","translation":"তোমাদের রব","audioUrl":"wbw/044_008_008.mp3","charTypeName":"word"},{"id":8586,"position":8,"arabic":"وَرَبُّ","translation":"ও রব","audioUrl":"wbw/044_008_009.mp3","charTypeName":"word"},{"id":8587,"position":9,"arabic":"ءَابَآئِكُمُ","translation":"তোমাদের পিতৃপুরুষদের","audioUrl":"wbw/044_008_010.mp3","charTypeName":"word"},{"id":8588,"position":10,"arabic":"ٱلْأَوَّلِينَ","translation":"পূর্বকালের","audioUrl":"wbw/044_008_011.mp3","charTypeName":"word"},{"id":8589,"position":11,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"بَلْ هُمْ فِى شَكٍّۢ يَلْعَبُونَ","translation":"Nay, but they [who lack inner certainty] are but Dying with their doubts.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4423.mp3","surahId":44,"words":[{"id":9796,"position":1,"arabic":"بَلْ","translation":"বরং","audioUrl":"wbw/044_009_001.mp3","charTypeName":"word"},{"id":9797,"position":2,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/044_009_002.mp3","charTypeName":"word"},{"id":9798,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/044_009_003.mp3","charTypeName":"word"},{"id":9799,"position":4,"arabic":"شَكٍّۢ","translation":"সন্দেহের","audioUrl":"wbw/044_009_004.mp3","charTypeName":"word"},{"id":9800,"position":5,"arabic":"يَلْعَبُونَ","translation":"খেলা করছে","audioUrl":"wbw/044_009_005.mp3","charTypeName":"word"},{"id":9801,"position":6,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"فَٱرْتَقِبْ يَوْمَ تَأْتِى ٱلسَّمَآءُ بِدُخَانٍۢ مُّبِينٍۢ","translation":"WAIT, THEN, for the Day when the skies shall bring forth a pall of smoke which will make obvious [the approach of the Last Hour],","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4424.mp3","surahId":44,"words":[{"id":10946,"position":1,"arabic":"فَٱرْتَقِبْ","translation":"সুতরাং অপেক্ষা করো","audioUrl":"wbw/044_010_001.mp3","charTypeName":"word"},{"id":10947,"position":2,"arabic":"يَوْمَ","translation":"সেই দিনের (যখন)","audioUrl":"wbw/044_010_002.mp3","charTypeName":"word"},{"id":10948,"position":3,"arabic":"تَأْتِى","translation":"আসবে","audioUrl":"wbw/044_010_003.mp3","charTypeName":"word"},{"id":10949,"position":4,"arabic":"ٱلسَّمَآءُ","translation":"আকাশ","audioUrl":"wbw/044_010_004.mp3","charTypeName":"word"},{"id":10950,"position":5,"arabic":"بِدُخَانٍۢ","translation":"নিয়ে ধোঁয়া (আচ্ছন্ন হয়ে)","audioUrl":"wbw/044_010_005.mp3","charTypeName":"word"},{"id":10951,"position":6,"arabic":"مُّبِينٍۢ","translation":"সুস্পষ্ট","audioUrl":"wbw/044_010_006.mp3","charTypeName":"word"},{"id":10952,"position":7,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"يَغْشَى ٱلنَّاسَ ۖ هَٰذَا عَذَابٌ أَلِيمٌۭ","translation":"enveloping all mankind, [and causing the sinners to exclaim:] “Grievous is this suffering!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4425.mp3","surahId":44,"words":[{"id":12265,"position":1,"arabic":"يَغْشَى","translation":"ঢেকে নিবে","audioUrl":"wbw/044_011_001.mp3","charTypeName":"word"},{"id":12266,"position":2,"arabic":"ٱلنَّاسَ ۖ","translation":"মানুষকে","audioUrl":"wbw/044_011_002.mp3","charTypeName":"word"},{"id":12268,"position":3,"arabic":"هَـٰذَا","translation":"এটাই","audioUrl":"wbw/044_011_004.mp3","charTypeName":"word"},{"id":12269,"position":4,"arabic":"عَذَابٌ","translation":"শাস্তি","audioUrl":"wbw/044_011_005.mp3","charTypeName":"word"},{"id":12270,"position":5,"arabic":"أَلِيمٌۭ","translation":"নিদারুণ","audioUrl":"wbw/044_011_006.mp3","charTypeName":"word"},{"id":12271,"position":6,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]},{"number":12,"arabic":"رَّبَّنَا ٱكْشِفْ عَنَّا ٱلْعَذَابَ إِنَّا مُؤْمِنُونَ","translation":"O our Sustainer, relieve us of suffering, for, verily, we [now] believe [in Thee]!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4426.mp3","surahId":44,"words":[{"id":13603,"position":1,"arabic":"رَّبَّنَا","translation":"\"(এখন তারা বলে) হে আমাদের রব","audioUrl":"wbw/044_012_001.mp3","charTypeName":"word"},{"id":13604,"position":2,"arabic":"ٱكْشِفْ","translation":"দূর করো","audioUrl":"wbw/044_012_002.mp3","charTypeName":"word"},{"id":13605,"position":3,"arabic":"عَنَّا","translation":"আমাদের থেকে","audioUrl":"wbw/044_012_003.mp3","charTypeName":"word"},{"id":13606,"position":4,"arabic":"ٱلْعَذَابَ","translation":"শাস্তি","audioUrl":"wbw/044_012_004.mp3","charTypeName":"word"},{"id":13607,"position":5,"arabic":"إِنَّا","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/044_012_005.mp3","charTypeName":"word"},{"id":13608,"position":6,"arabic":"مُؤْمِنُونَ","translation":"বিশ্বাসী হবো (ঈমান আনবো)\"","audioUrl":"wbw/044_012_006.mp3","charTypeName":"word"},{"id":13609,"position":7,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]},{"number":13,"arabic":"أَنَّىٰ لَهُمُ ٱلذِّكْرَىٰ وَقَدْ جَآءَهُمْ رَسُولٌۭ مُّبِينٌۭ","translation":"[But] how shall this remembrance avail them [at the Last Hour], seeing that an apostle had pre­viously come unto them, clearly expounding the truth,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4427.mp3","surahId":44,"words":[{"id":14802,"position":1,"arabic":"أَنَّىٰ","translation":"কেমন করে হবে","audioUrl":"wbw/044_013_001.mp3","charTypeName":"word"},{"id":14803,"position":2,"arabic":"لَهُمُ","translation":"তাদের জন্যে","audioUrl":"wbw/044_013_002.mp3","charTypeName":"word"},{"id":14804,"position":3,"arabic":"ٱلذِّكْرَىٰ","translation":"উপদেশ গ্রহণ (সম্ভব হবে)","audioUrl":"wbw/044_013_003.mp3","charTypeName":"word"},{"id":14805,"position":4,"arabic":"وَقَدْ","translation":"অথচ নিশ্চয়ই","audioUrl":"wbw/044_013_004.mp3","charTypeName":"word"},{"id":14806,"position":5,"arabic":"جَآءَهُمْ","translation":"তাদের কাছে এসেছে","audioUrl":"wbw/044_013_005.mp3","charTypeName":"word"},{"id":14807,"position":6,"arabic":"رَسُولٌۭ","translation":"একজন রাসূল","audioUrl":"wbw/044_013_006.mp3","charTypeName":"word"},{"id":14808,"position":7,"arabic":"مُّبِينٌۭ","translation":"সুস্পষ্ট","audioUrl":"wbw/044_013_007.mp3","charTypeName":"word"},{"id":14809,"position":8,"arabic":"١٣","translation":"(১৩)","audioUrl":null,"charTypeName":"end"}]},{"number":14,"arabic":"ثُمَّ تَوَلَّوْا۟ عَنْهُ وَقَالُوا۟ مُعَلَّمٌۭ مَّجْنُونٌ","translation":"whereupon they turned their backs on him and said, “Taught [by others] is he, a madman”?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4428.mp3","surahId":44,"words":[{"id":15880,"position":1,"arabic":"ثُمَّ","translation":"এরপরও","audioUrl":"wbw/044_014_001.mp3","charTypeName":"word"},{"id":15881,"position":2,"arabic":"تَوَلَّوْا۟","translation":"তারা ফিরে যায়","audioUrl":"wbw/044_014_002.mp3","charTypeName":"word"},{"id":15882,"position":3,"arabic":"عَنْهُ","translation":"তা হ'তে","audioUrl":"wbw/044_014_003.mp3","charTypeName":"word"},{"id":15883,"position":4,"arabic":"وَقَالُوا۟","translation":"এবং তারা বললো","audioUrl":"wbw/044_014_004.mp3","charTypeName":"word"},{"id":15884,"position":5,"arabic":"مُعَلَّمٌۭ","translation":"\"(সে একজন) প্রশিক্ষণপ্রাপ্ত","audioUrl":"wbw/044_014_005.mp3","charTypeName":"word"},{"id":15885,"position":6,"arabic":"مَّجْنُونٌ","translation":"পাগল\"","audioUrl":"wbw/044_014_006.mp3","charTypeName":"word"},{"id":15886,"position":7,"arabic":"١٤","translation":"(১৪)","audioUrl":null,"charTypeName":"end"}]},{"number":15,"arabic":"إِنَّا كَاشِفُوا۟ ٱلْعَذَابِ قَلِيلًا ۚ إِنَّكُمْ عَآئِدُونَ","translation":"[Still,] behold, We shall postpone this suffer­ing for a little while, although you are bound to revert [to your evil ways: but]","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4429.mp3","surahId":44,"words":[{"id":17000,"position":1,"arabic":"إِنَّا","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/044_015_001.mp3","charTypeName":"word"},{"id":17001,"position":2,"arabic":"كَاشِفُوا۟","translation":"দূর করে দিই","audioUrl":"wbw/044_015_002.mp3","charTypeName":"word"},{"id":17002,"position":3,"arabic":"ٱلْعَذَابِ","translation":"শাস্তি","audioUrl":"wbw/044_015_003.mp3","charTypeName":"word"},{"id":17003,"position":4,"arabic":"قَلِيلًا ۚ","translation":"কিছুটা (তবুও)","audioUrl":"wbw/044_015_004.mp3","charTypeName":"word"},{"id":17005,"position":5,"arabic":"إِنَّكُمْ","translation":"তোমরা নিশ্চয়ই","audioUrl":"wbw/044_015_006.mp3","charTypeName":"word"},{"id":17006,"position":6,"arabic":"عَآئِدُونَ","translation":"আগের অবস্হায় ফিরে যাও (যা পূর্বে করতে)","audioUrl":"wbw/044_015_007.mp3","charTypeName":"word"},{"id":17007,"position":7,"arabic":"١٥","translation":"(১৫)","audioUrl":null,"charTypeName":"end"}]},{"number":16,"arabic":"يَوْمَ نَبْطِشُ ٱلْبَطْشَةَ ٱلْكُبْرَىٰٓ إِنَّا مُنتَقِمُونَ","translation":"on the Day when We shall seize [all sinners] with a most mighty onslaught, We shall, verily, inflict Our retribution [on you as well]!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4430.mp3","surahId":44,"words":[{"id":18106,"position":1,"arabic":"يَوْمَ","translation":"যেদিন","audioUrl":"wbw/044_016_001.mp3","charTypeName":"word"},{"id":18107,"position":2,"arabic":"نَبْطِشُ","translation":"আমরা পাকড়াও করবো","audioUrl":"wbw/044_016_002.mp3","charTypeName":"word"},{"id":18108,"position":3,"arabic":"ٱلْبَطْشَةَ","translation":"পাকড়াও","audioUrl":"wbw/044_016_003.mp3","charTypeName":"word"},{"id":18109,"position":4,"arabic":"ٱلْكُبْرَىٰٓ","translation":"কঠিনভাবে","audioUrl":"wbw/044_016_004.mp3","charTypeName":"word"},{"id":18110,"position":5,"arabic":"إِنَّا","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/044_016_005.mp3","charTypeName":"word"},{"id":18111,"position":6,"arabic":"مُنتَقِمُونَ","translation":"প্রতিশোধ গ্রহণকারী(সেহদিন)","audioUrl":"wbw/044_016_006.mp3","charTypeName":"word"},{"id":18112,"position":7,"arabic":"١٦","translation":"(১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":17,"arabic":"۞ وَلَقَدْ فَتَنَّا قَبْلَهُمْ قَوْمَ فِرْعَوْنَ وَجَآءَهُمْ رَسُولٌۭ كَرِيمٌ","translation":"AND, INDEED, [long] before their time did We try Pharaoh’s people [in the same way]: for there came unto them a noble apostle, [who said:]","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4431.mp3","surahId":44,"words":[{"id":19132,"position":1,"arabic":"۞ وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/044_017_002.mp3","charTypeName":"word"},{"id":19133,"position":2,"arabic":"فَتَنَّا","translation":"আমরা পরীক্ষা করেছি","audioUrl":"wbw/044_017_003.mp3","charTypeName":"word"},{"id":19134,"position":3,"arabic":"قَبْلَهُمْ","translation":"তাদের পুর্বে","audioUrl":"wbw/044_017_004.mp3","charTypeName":"word"},{"id":19135,"position":4,"arabic":"قَوْمَ","translation":"জাতিকে","audioUrl":"wbw/044_017_005.mp3","charTypeName":"word"},{"id":19136,"position":5,"arabic":"فِرْعَوْنَ","translation":"ফিরআউনের","audioUrl":"wbw/044_017_006.mp3","charTypeName":"word"},{"id":19137,"position":6,"arabic":"وَجَآءَهُمْ","translation":"এবং তাদের কাছে এসেছিলো","audioUrl":"wbw/044_017_007.mp3","charTypeName":"word"},{"id":19138,"position":7,"arabic":"رَسُولٌۭ","translation":"একজন রাসূল","audioUrl":"wbw/044_017_008.mp3","charTypeName":"word"},{"id":19139,"position":8,"arabic":"كَرِيمٌ","translation":"মহান","audioUrl":"wbw/044_017_009.mp3","charTypeName":"word"},{"id":19140,"position":9,"arabic":"١٧","translation":"(১৭)","audioUrl":null,"charTypeName":"end"}]},{"number":18,"arabic":"أَنْ أَدُّوٓا۟ إِلَىَّ عِبَادَ ٱللَّهِ ۖ إِنِّى لَكُمْ رَسُولٌ أَمِينٌۭ","translation":"“Give in unto me, O God’s bondmen! Verily, I am an apostle [sent] unto you, worthy of trust!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4432.mp3","surahId":44,"words":[{"id":20244,"position":1,"arabic":"أَنْ","translation":"(সে বলেছিলো) যে","audioUrl":"wbw/044_018_001.mp3","charTypeName":"word"},{"id":20245,"position":2,"arabic":"أَدُّوٓا۟","translation":"\"তোমরা সমর্পণ করো","audioUrl":"wbw/044_018_002.mp3","charTypeName":"word"},{"id":20246,"position":3,"arabic":"إِلَىَّ","translation":"আমার কাছে","audioUrl":"wbw/044_018_003.mp3","charTypeName":"word"},{"id":20247,"position":4,"arabic":"عِبَادَ","translation":"দাসদেরকে","audioUrl":"wbw/044_018_004.mp3","charTypeName":"word"},{"id":20248,"position":5,"arabic":"ٱللَّهِ ۖ","translation":"আল্লাহ্‌র","audioUrl":"wbw/044_018_005.mp3","charTypeName":"word"},{"id":20250,"position":6,"arabic":"إِنِّى","translation":"নিশ্চয়ই আমি","audioUrl":"wbw/044_018_007.mp3","charTypeName":"word"},{"id":20251,"position":7,"arabic":"لَكُمْ","translation":"তোমাদের জন্যে","audioUrl":"wbw/044_018_008.mp3","charTypeName":"word"},{"id":20252,"position":8,"arabic":"رَسُولٌ","translation":"রাসূল","audioUrl":"wbw/044_018_009.mp3","charTypeName":"word"},{"id":20253,"position":9,"arabic":"أَمِينٌۭ","translation":"বিশ্বস্ত","audioUrl":"wbw/044_018_010.mp3","charTypeName":"word"},{"id":20254,"position":10,"arabic":"١٨","translation":"(১৮)","audioUrl":null,"charTypeName":"end"}]}]}