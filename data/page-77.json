 spirit of a gift; but if they, of their own accord, give up unto you aught thereof, then enjoy it with pleasure and good cheer.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/497.mp3","surahId":4,"words":[{"id":3256,"position":1,"arabic":"وَءَاتُوا۟","translation":"এবং তোমরা দাও","audioUrl":"wbw/004_004_001.mp3","charTypeName":"word"},{"id":3257,"position":2,"arabic":"ٱلنِّسَآءَ","translation":"নারীদেরকে","audioUrl":"wbw/004_004_002.mp3","charTypeName":"word"},{"id":3258,"position":3,"arabic":"صَدُقَـٰتِهِنَّ","translation":"তাদের মোহরগুলো","audioUrl":"wbw/004_004_003.mp3","charTypeName":"word"},{"id":3259,"position":4,"arabic":"نِحْلَةًۭ ۚ","translation":"স্বতঃপ্রবৃত্ত হয়ে","audioUrl":"wbw/004_004_004.mp3","charTypeName":"word"},{"id":3261,"position":5,"arabic":"فَإِن","translation":"যদি অতঃপর","audioUrl":"wbw/004_004_006.mp3","charTypeName":"word"},{"id":3262,"position":6,"arabic":"طِبْنَ","translation":"তারা ছেড়ে দেয়","audioUrl":"wbw/004_004_007.mp3","charTypeName":"word"},{"id":3263,"position":7,"arabic":"لَكُمْ","translation":"তোমাদের জন্য","audioUrl":"wbw/004_004_008.mp3","charTypeName":"word"},{"id":3264,"position":8,"arabic":"عَن","translation":"(প্রায়)","audioUrl":"wbw/004_004_009.mp3","charTypeName":"word"},{"id":3265,"position":9,"arabic":"شَىْءٍۢ","translation":"কোন কিছু","audioUrl":"wbw/004_004_010.mp3","charTypeName":"word"},{"id":3266,"position":10,"arabic":"مِّنْهُ","translation":"তা থেকে","audioUrl":"wbw/004_004_011.mp3","charTypeName":"word"},{"id":3267,"position":11,"arabic":"نَفْسًۭا","translation":"নিজেই","audioUrl":"wbw/004_004_012.mp3","charTypeName":"word"},{"id":3268,"position":12,"arabic":"فَكُلُوهُ","translation":"তোমরা খাও তবে তা","audioUrl":"wbw/004_004_013.mp3","charTypeName":"word"},{"id":3269,"position":13,"arabic":"هَنِيٓـًۭٔا","translation":"সানন্দে","audioUrl":"wbw/004_004_014.mp3","charTypeName":"word"},{"id":3270,"position":14,"arabic":"مَّرِيٓـًۭٔا","translation":"তৃপ্তিসহ","audioUrl":"wbw/004_004_015.mp3","charTypeName":"word"},{"id":3271,"position":15,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"وَلَا تُؤْتُوا۟ ٱلسُّفَهَآءَ أَمْوَٰلَكُمُ ٱلَّتِى جَعَلَ ٱللَّهُ لَكُمْ قِيَٰمًۭا وَٱرْزُقُوهُمْ فِيهَا وَٱكْسُوهُمْ وَقُولُوا۟ لَهُمْ قَوْلًۭا مَّعْرُوفًۭا","translation":"And do not entrust to those who are weak of judgment the possessions which God has placed in your charge for [their] support; but let them have their sustenance therefrom, and clothe them, and speak unto them in a kindly way.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/498.mp3","surahId":4,"words":[{"id":4574,"position":1,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/004_005_001.mp3","charTypeName":"word"},{"id":4575,"position":2,"arabic":"تُؤْتُوا۟","translation":"তোমরা দিও","audioUrl":"wbw/004_005_002.mp3","charTypeName":"word"},{"id":4576,"position":3,"arabic":"ٱلسُّفَهَآءَ","translation":"অবোধদেরকে","audioUrl":"wbw/004_005_003.mp3","charTypeName":"word"},{"id":4577,"position":4,"arabic":"أَمْوَٰلَكُمُ","translation":"তোমাদের সম্পদগুলোকে","audioUrl":"wbw/004_005_004.mp3","charTypeName":"word"},{"id":4578,"position":5,"arabic":"ٱلَّتِى","translation":"যা","audioUrl":"wbw/004_005_005.mp3","charTypeName":"word"},{"id":4579,"position":6,"arabic":"جَعَلَ","translation":"বানিয়েছেন","audioUrl":"wbw/004_005_006.mp3","charTypeName":"word"},{"id":4580,"position":7,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/004_005_007.mp3","charTypeName":"word"},{"id":4581,"position":8,"arabic":"لَكُمْ","translation":"তোমাদের জন্য","audioUrl":"wbw/004_005_008.mp3","charTypeName":"word"},{"id":4582,"position":9,"arabic":"قِيَـٰمًۭا","translation":"(জীবিকা) প্রতিষ্ঠার (জন্য)","audioUrl":"wbw/004_005_009.mp3","charTypeName":"word"},{"id":4583,"position":10,"arabic":"وَٱرْزُقُوهُمْ","translation":"এবং তোমরা খাওয়াও তাদেরকে","audioUrl":"wbw/004_005_010.mp3","charTypeName":"word"},{"id":4584,"position":11,"arabic":"فِيهَا","translation":"তা থেকে","audioUrl":"wbw/004_005_011.mp3","charTypeName":"word"},{"id":4585,"position":12,"arabic":"وَٱكْسُوهُمْ","translation":"ও তোমরা পরাও তাদেরকে","audioUrl":"wbw/004_005_012.mp3","charTypeName":"word"},{"id":4586,"position":13,"arabic":"وَقُولُوا۟","translation":"এবং তোমরা বল","audioUrl":"wbw/004_005_013.mp3","charTypeName":"word"},{"id":4587,"position":14,"arabic":"لَهُمْ","translation":"তাদেরকে","audioUrl":"wbw/004_005_014.mp3","charTypeName":"word"},{"id":4588,"position":15,"arabic":"قَوْلًۭا","translation":"কথা","audioUrl":"wbw/004_005_015.mp3","charTypeName":"word"},{"id":4589,"position":16,"arabic":"مَّعْرُوفًۭا","translation":"উত্তম","audioUrl":"wbw/004_005_016.mp3","charTypeName":"word"},{"id":4590,"position":17,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"وَٱبْتَلُوا۟ ٱلْيَتَٰمَىٰ حَتَّىٰٓ إِذَا بَلَغُوا۟ ٱلنِّكَاحَ فَإِنْ ءَانَسْتُم مِّنْهُمْ رُشْدًۭا فَٱدْفَعُوٓا۟ إِلَيْهِمْ أَمْوَٰلَهُمْ ۖ وَلَا تَأْكُلُوهَآ إِسْرَافًۭا وَبِدَارًا أَن يَكْبَرُوا۟ ۚ وَمَن كَانَ غَنِيًّۭا فَلْيَسْتَعْفِفْ ۖ وَمَن كَانَ فَقِيرًۭا فَلْيَأْكُلْ بِٱلْمَعْرُوفِ ۚ فَإِذَا دَفَعْتُمْ إِلَيْهِمْ أَمْوَٰلَهُمْ فَأَشْهِدُوا۟ عَلَيْهِمْ ۚ وَكَفَىٰ بِٱللَّهِ حَسِيبًۭا","translation":"And test the orphans [in your charge] until they reach a marriage­able age; then, if you find them to be mature of mind, hand over to them their possessions; and do not consume them by wasteful spending, and in haste, ere they grow up. And let him who is rich abstain entirely [from his ward's property]; and let him who is poor partake thereof in a fair manner. And when you hand over to them their possessions, let there be witnesses on their behalf - although none can take count as God does.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/499.mp3","surahId":4,"words":[{"id":5894,"position":1,"arabic":"وَٱبْتَلُوا۟","translation":"এবং তোমরা পরিক্ষা কর","audioUrl":"wbw/004_006_001.mp3","charTypeName":"word"},{"id":5895,"position":2,"arabic":"ٱلْيَتَـٰمَىٰ","translation":"ইয়াতীমদেরকে","audioUrl":"wbw/004_006_002.mp3","charTypeName":"word"},{"id":5896,"position":3,"arabic":"حَتَّىٰٓ","translation":"পর্যন্ত","audioUrl":"wbw/004_006_003.mp3","charTypeName":"word"},{"id":5897,"position":4,"arabic":"إِذَا","translation":"যতক্ষণ","audioUrl":"wbw/004_006_004.mp3","charTypeName":"word"},{"id":5898,"position":5,"arabic":"بَلَغُوا۟","translation":"তারা পৌঁছে","audioUrl":"wbw/004_006_005.mp3","charTypeName":"word"},{"id":5899,"position":6,"arabic":"ٱلنِّكَاحَ","translation":"বিবাহ (বয়সে)","audioUrl":"wbw/004_006_006.mp3","charTypeName":"word"},{"id":5900,"position":7,"arabic":"فَإِنْ","translation":"অতঃপর যদি","audioUrl":"wbw/004_006_007.mp3","charTypeName":"word"},{"id":5901,"position":8,"arabic":"ءَانَسْتُم","translation":"তোমরা দেখ","audioUrl":"wbw/004_006_008.mp3","charTypeName":"word"},{"id":5902,"position":9,"arabic":"مِّنْهُمْ","translation":"তাদের মধ্যে","audioUrl":"wbw/004_006_009.mp3","charTypeName":"word"},{"id":5903,"position":10,"arabic":"رُشْدًۭا","translation":"বিচারের জ্ঞান","audioUrl":"wbw/004_006_010.mp3","charTypeName":"word"},{"id":5904,"position":11,"arabic":"فَٱدْفَعُوٓا۟","translation":"তখন তোমরা অর্পণ কর","audioUrl":"wbw/004_006_011.mp3","charTypeName":"word"},{"id":5905,"position":12,"arabic":"إِلَيْهِمْ","translation":"তাদের কাছে","audioUrl":"wbw/004_006_012.mp3","charTypeName":"word"},{"id":5906,"position":13,"arabic":"أَمْوَٰلَهُمْ ۖ","translation":"তাদের ধন মাল","audioUrl":"wbw/004_006_013.mp3","charTypeName":"word"},{"id":5908,"position":14,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/004_006_015.mp3","charTypeName":"word"},{"id":5909,"position":15,"arabic":"تَأْكُلُوهَآ","translation":"তা খেয়ো তোমরা","audioUrl":"wbw/004_006_016.mp3","charTypeName":"word"},{"id":5910,"position":16,"arabic":"إِسْرَافًۭا","translation":"সীমালঙ্ঘন করে","audioUrl":"wbw/004_006_017.mp3","charTypeName":"word"},{"id":5911,"position":17,"arabic":"وَبِدَارًا","translation":"ও তাড়াতাড়ি করে","aud