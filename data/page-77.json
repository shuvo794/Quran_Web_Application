w/004_001_027.mp3","charTypeName":"word"},{"id":51,"position":26,"arabic":"كَانَ","translation":"আছেন","audioUrl":"wbw/004_001_028.mp3","charTypeName":"word"},{"id":52,"position":27,"arabic":"عَلَيْكُمْ","translation":"তোমাদের উপর","audioUrl":"wbw/004_001_029.mp3","charTypeName":"word"},{"id":53,"position":28,"arabic":"رَقِيبًۭا","translation":"দৃষ্টিবান","audioUrl":"wbw/004_001_030.mp3","charTypeName":"word"},{"id":54,"position":29,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"وَءَاتُوا۟ ٱلْيَتَٰمَىٰٓ أَمْوَٰلَهُمْ ۖ وَلَا تَتَبَدَّلُوا۟ ٱلْخَبِيثَ بِٱلطَّيِّبِ ۖ وَلَا تَأْكُلُوٓا۟ أَمْوَٰلَهُمْ إِلَىٰٓ أَمْوَٰلِكُمْ ۚ إِنَّهُۥ كَانَ حُوبًۭا كَبِيرًۭا","translation":"Hence, render unto the orphans their posses­sions, and do not substitute bad things [of your own] for the good things [that belong to them], and do not consume their possessions together with your own: this, verily, is a great crime.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/495.mp3","surahId":4,"words":[{"id":1251,"position":1,"arabic":"وَءَاتُوا۟","translation":"এবং তোমরা (ফেরত) দাও","audioUrl":"wbw/004_002_001.mp3","charTypeName":"word"},{"id":1252,"position":2,"arabic":"ٱلْيَتَـٰمَىٰٓ","translation":"ইয়াতীমদেরকে","audioUrl":"wbw/004_002_002.mp3","charTypeName":"word"},{"id":1253,"position":3,"arabic":"أَمْوَٰلَهُمْ ۖ","translation":"তাদের মাল সম্পদ সমূহ","audioUrl":"wbw/004_002_003.mp3","charTypeName":"word"},{"id":1255,"position":4,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/004_002_005.mp3","charTypeName":"word"},{"id":1256,"position":5,"arabic":"تَتَبَدَّلُوا۟","translation":"তোমরা বদল করো","audioUrl":"wbw/004_002_006.mp3","charTypeName":"word"},{"id":1257,"position":6,"arabic":"ٱلْخَبِيثَ","translation":"খারাপ (মালকে)","audioUrl":"wbw/004_002_007.mp3","charTypeName":"word"},{"id":1258,"position":7,"arabic":"بِٱلطَّيِّبِ ۖ","translation":"ভাল (মালের) পরিবর্তে","audioUrl":"wbw/004_002_008.mp3","charTypeName":"word"},{"id":1260,"position":8,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/004_002_010.mp3","charTypeName":"word"},{"id":1261,"position":9,"arabic":"تَأْكُلُوٓا۟","translation":"তোমরা খেয়ো","audioUrl":"wbw/004_002_011.mp3","charTypeName":"word"},{"id":1262,"position":10,"arabic":"أَمْوَٰلَهُمْ","translation":"তাদের মাল সমূহকে","audioUrl":"wbw/004_002_012.mp3","charTypeName":"word"},{"id":1263,"position":11,"arabic":"إِلَىٰٓ","translation":"সাথে (মিশিয়ে)","audioUrl":"wbw/004_002_013.mp3","charTypeName":"word"},{"id":1264,"position":12,"arabic":"أَمْوَٰلِكُمْ ۚ","translation":"তোমাদের মালসমূহের","audioUrl":"wbw/004_002_014.mp3","charTypeName":"word"},{"id":1266,"position":13,"arabic":"إِنَّهُۥ","translation":"তা নিশ্চয়ই","audioUrl":"wbw/004_002_016.mp3","charTypeName":"word"},{"id":1267,"position":14,"arabic":"كَانَ","translation":"হলো","audioUrl":"wbw/004_002_017.mp3","charTypeName":"word"},{"id":1268,"position":15,"arabic":"حُوبًۭا","translation":"গুনাহর (কাজ)","audioUrl":"wbw/004_002_018.mp3","charTypeName":"word"},{"id":1269,"position":16,"arabic":"كَبِيرًۭا","translation":"বড়ই","audioUrl":"wbw/004_002_019.mp3","charTypeName":"word"},{"id":1270,"position":17,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"وَإِنْ خِفْتُمْ أَلَّا تُقْسِطُوا۟ فِى ٱلْيَتَٰمَىٰ فَٱنكِحُوا۟ مَا طَابَ لَكُم مِّنَ ٱلنِّسَآءِ مَثْنَىٰ وَثُلَٰثَ وَرُبَٰعَ ۖ فَإِنْ خِفْتُمْ أَلَّا تَعْدِلُوا۟ فَوَٰحِدَةً أَوْ مَا مَلَكَتْ أَيْمَٰنُكُمْ ۚ ذَٰلِكَ أَدْنَىٰٓ أَلَّا تَعُولُوا۟","translation":"And if you have reason to fear that you might not act equitably towards orphans, then marry from among [other] women such as are lawful to you - [even] two, or three, or four: but if you have reason to fear that you might not be able to treat them with equal fairness, then [only] one - or [from among] those whom you rightfully possess. This will make it more likely that you will not deviate from the right course.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/496.mp3","surahId":4,"words":[{"id":2759,"position":1,"arabic":"وَإِنْ","translation":"এবং যদি","audioUrl":"wbw/004_003_001.mp3","charTypeName":"word"},{"id":2760,"position":2,"arabic":"خِفْتُمْ","translation":"তোমরা ভয় কর","audioUrl":"wbw/004_003_002.mp3","charTypeName":"word"},{"id":2761,"position":3,"arabic":"أَلَّا","translation":"যে না","audioUrl":"wbw/004_003_003.mp3","charTypeName":"word"},{"id":2762,"position":4,"arabic":"تُقْسِطُوا۟","translation":"তোমরা সুবিচার করতে পারবে","audioUrl":"wbw/004_003_004.mp3","charTypeName":"word"},{"id":2763,"position":5,"arabic":"فِى","translation":"প্রতি","audioUrl":"wbw/004_003_005.mp3","charTypeName":"word"},{"id":2764,"position":6,"arabic":"ٱلْيَتَـٰمَىٰ","translation":"ইয়াতীমদের","audioUrl":"wbw/004_003_006.mp3","charTypeName":"word"},{"id":2765,"position":7,"arabic":"فَٱنكِحُوا۟","translation":"তোমরা বিয়ে তবে কর","audioUrl":"wbw/004_003_007.mp3","charTypeName":"word"},{"id":2766,"position":8,"arabic":"مَا","translation":"যা","audioUrl":"wbw/004_003_008.mp3","charTypeName":"word"},{"id":2767,"position":9,"arabic":"طَابَ","translation":"পছন্দনীয়","audioUrl":"wbw/004_003_009.mp3","charTypeName":"word"},{"id":2768,"position":10,"arabic":"لَكُم","translation":"তোমাদের জন্য","audioUrl":"wbw/004_003_010.mp3","charTypeName":"word"},{"id":2769,"position":11,"arabic":"مِّنَ","translation":"মধ্য হতে","audioUrl":"wbw/004_003_011.mp3","charTypeName":"word"},{"id":2770,"position":12,"arabic":"ٱلنِّسَآءِ","translation":"(অন্য স্বাধীনা) নারীদের","audioUrl":"wbw/004_003_012.mp3","charTypeName":"word"},{"id":2771,"position":13,"arabic":"مَثْنَىٰ","translation":"দুই","audioUrl":"wbw/004_003_013.mp3","charTypeName":"word"},{"id":2772,"position":14,"arabic":"وَثُلَـٰثَ","translation":"বা তিন","audioUrl":"wbw/004_003_014.mp3","charTypeName":"word"},{"id":2773,"position":15,"arabic":"وَرُبَـٰعَ ۖ","translation":"বা চারটা (পর্যন্ত)","audioUrl":"wbw/004_003_015.mp3","charTypeName":"word"},{"id":2775,"position":16,"a