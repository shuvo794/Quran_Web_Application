{"id":77,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ يَٰٓأَيُّهَا ٱلنَّاسُ ٱتَّقُوا۟ رَبَّكُمُ ٱلَّذِى خَلَقَكُم مِّن نَّفْسٍۢ وَٰحِدَةٍۢ وَخَلَقَ مِنْهَا زَوْجَهَا وَبَثَّ مِنْهُمَا رِجَالًۭا كَثِيرًۭا وَنِسَآءًۭ ۚ وَٱتَّقُوا۟ ٱللَّهَ ٱلَّذِى تَسَآءَلُونَ بِهِۦ وَٱلْأَرْحَامَ ۚ إِنَّ ٱللَّهَ كَانَ عَلَيْكُمْ رَقِيبًۭا","translation":"O MANKIND! Be conscious of your Sustainer, who has created you out of one living entity, and out of it created its mate, and out of the two spread abroad a multitude of men and women. And remain conscious of God, in whose name you demand [your rights] from one another, and of these ties of kinship. Verily, God is ever watchful over you!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/494.mp3","surahId":4,"words":[{"id":24,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"''হে","audioUrl":"wbw/004_001_001.mp3","charTypeName":"word"},{"id":25,"position":2,"arabic":"ٱلنَّاسُ","translation":"মানবজাতি!","audioUrl":"wbw/004_001_002.mp3","charTypeName":"word"},{"id":26,"position":3,"arabic":"ٱتَّقُوا۟","translation":"তোমরা ভয় কর","audioUrl":"wbw/004_001_003.mp3","charTypeName":"word"},{"id":27,"position":4,"arabic":"رَبَّكُمُ","translation":"তোমাদের রবকে","audioUrl":"wbw/004_001_004.mp3","charTypeName":"word"},{"id":28,"position":5,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/004_001_005.mp3","charTypeName":"word"},{"id":29,"position":6,"arabic":"خَلَقَكُم","translation":"তোমাদেরকে সৃষ্টি করেছেন","audioUrl":"wbw/004_001_006.mp3","charTypeName":"word"},{"id":30,"position":7,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/004_001_007.mp3","charTypeName":"word"},{"id":31,"position":8,"arabic":"نَّفْسٍۢ","translation":"প্রাণ","audioUrl":"wbw/004_001_008.mp3","charTypeName":"word"},{"id":32,"position":9,"arabic":"وَٰحِدَةٍۢ","translation":"একটি (অর্থাৎ আদম (আঃ))","audioUrl":"wbw/004_001_009.mp3","charTypeName":"word"},{"id":33,"position":10,"arabic":"وَخَلَقَ","translation":"ও তিনি স