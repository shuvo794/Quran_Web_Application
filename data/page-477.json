d"},{"id":5941,"position":5,"arabic":"مِّثْلُكُمْ","translation":"তোমাদেরই মতো","audioUrl":"wbw/041_006_005.mp3","charTypeName":"word"},{"id":5942,"position":6,"arabic":"يُوحَىٰٓ","translation":"ওহী করা হয়","audioUrl":"wbw/041_006_006.mp3","charTypeName":"word"},{"id":5943,"position":7,"arabic":"إِلَىَّ","translation":"আমার প্রতি","audioUrl":"wbw/041_006_007.mp3","charTypeName":"word"},{"id":5944,"position":8,"arabic":"أَنَّمَآ","translation":"এই যে","audioUrl":"wbw/041_006_008.mp3","charTypeName":"word"},{"id":5945,"position":9,"arabic":"إِلَـٰهُكُمْ","translation":"তোমাদের ইলাহ","audioUrl":"wbw/041_006_009.mp3","charTypeName":"word"},{"id":5946,"position":10,"arabic":"إِلَـٰهٌۭ","translation":"ইলাহ","audioUrl":"wbw/041_006_010.mp3","charTypeName":"word"},{"id":5947,"position":11,"arabic":"وَٰحِدٌۭ","translation":"একই","audioUrl":"wbw/041_006_011.mp3","charTypeName":"word"},{"id":5948,"position":12,"arabic":"فَٱسْتَقِيمُوٓا۟","translation":"সুতরাং তোমরা দৃঢ় হয়ে থাকো","audioUrl":"wbw/041_006_012.mp3","charTypeName":"word"},{"id":5949,"position":13,"arabic":"إِلَيْهِ","translation":"তাঁর দিকে","audioUrl":"wbw/041_006_013.mp3","charTypeName":"word"},{"id":5950,"position":14,"arabic":"وَٱسْتَغْفِرُوهُ ۗ","translation":"ও তোমরা তাঁর কাছে ক্ষমা চাও\"","audioUrl":"wbw/041_006_014.mp3","charTypeName":"word"},{"id":5952,"position":15,"arabic":"وَوَيْلٌۭ","translation":"এবং দুর্ভোগ (রয়েছে)","audioUrl":"wbw/041_006_016.mp3","charTypeName":"word"},{"id":5953,"position":16,"arabic":"لِّلْمُشْرِكِينَ","translation":"মুশরিকদের জন্যে","audioUrl":"wbw/041_006_017.mp3","charTypeName":"word"},{"id":5954,"position":17,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"ٱلَّذِينَ لَا يُؤْتُونَ ٱلزَّكَوٰةَ وَهُم بِٱلْءَاخِرَةِ هُمْ كَٰفِرُونَ","translation":"[and] those who do not spend in charity: for it is they, they who [thus] deny the truth of the life to come!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4225.mp3","surahId":41,"words":[{"id":7253,"position":1,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/041_007_001.mp3","charTypeName":"word"},{"id":7254,"position":2,"arabic":"لَا","translation":"না","audioUrl":"wbw/041_007_002.mp3","charTypeName":"word"},{"id":7255,"position":3,"arabic":"يُؤْتُونَ","translation":"দেয়","audioUrl":"wbw/041_007_003.mp3","charTypeName":"word"},{"id":7256,"position":4,"arabic":"ٱلزَّكَوٰةَ","translation":"যাকাত","audioUrl":"wbw/041_007_004.mp3","charTypeName":"word"},{"id":7257,"position":5,"arabic":"وَهُم","translation":"এবং তারা","audioUrl":"wbw/041_007_005.mp3","charTypeName":"word"},{"id":7258,"position":6,"arabic":"بِٱلْـَٔاخِرَةِ","translation":"পরকালকে","audioUrl":"wbw/041_007_006.mp3","charTypeName":"word"},{"id":7259,"position":7,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/041_007_007.mp3","charTypeName":"word"},{"id":7260,"position":8,"arabic":"كَـٰفِرُونَ","translation":"অস্বীকারকারী","audioUrl":"wbw/041_007_008.mp3","charTypeName":"word"},{"id":7261,"position":9,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"إِنَّ ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ لَهُمْ أَجْرٌ غَيْرُ مَمْنُونٍۢ","translation":"[But,] verily, they who have attained to faith and do good works shall have a reward unending!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4226.mp3","surahId":41,"words":[{"id":8532,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/041_008_001.mp3","charTypeName":"word"},{"id":8533,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/041_008_002.mp3","charTypeName":"word"},{"id":8534,"position":3,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/041_008_003.mp3","charTypeName":"word"},{"id":8535,"position":4,"arabic":"وَعَمِلُوا۟","translation":"ও কাজ করেছে","audioUrl":"wbw/041_008_004.mp3","charTypeName":"word"},{"id":8536,"position":5,"arabic":"ٱلصَّـٰلِحَـٰتِ","translation":"নেক","audioUrl":"wbw/041_008_005.mp3","charTypeName":"word"},{"id":8537,"position":6,"arabic":"لَهُمْ","translation":"তাদের জন্যে","audioUrl":"wbw/041_008_006.mp3","charTypeName":"word"},{"id":8538,"position":7,"arabic":"أَجْرٌ","translation":"পুরস্কার রয়েছে","audioUrl":"wbw/041_008_007.mp3","charTypeName":"word"},{"id":8539,"position":8,"arabic":"غَيْرُ","translation":"ব্যতীত","audioUrl":"wbw/041_008_008.mp3","charTypeName":"word"},{"id":8540,"position":9,"arabic":"مَمْنُونٍۢ","translation":"শেষ হওয়া (অফুরন্ত)","audioUrl":"wbw/041_008_009.mp3","charTypeName":"word"},{"id":8541,"position":10,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"۞ قُلْ أَئِنَّكُمْ لَتَكْفُرُونَ بِٱلَّذِى خَلَقَ ٱلْأَرْضَ فِى يَوْمَيْنِ وَتَجْعَلُونَ لَهُۥٓ أَندَادًۭا ۚ ذَٰلِكَ رَبُّ ٱلْعَٰلَمِينَ","translation":"SAY: “Would you indeed deny Him who has created the earth in two aeons? And do you claim that there is any power that could rival Him, the Sustainer of all the worlds?”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4227.mp3","surahId":41,"words":[{"id":9737,"position":1,"arabic":"۞ قُلْ","translation":"বলো","audioUrl":"wbw/041_009_002.mp3","charTypeName":"word"},{"id":9738,"position":2,"arabic":"أَئِنَّكُمْ","translation":"\"তোমরা নিশ্চিত কি","audioUrl":"wbw/041_009_003.mp3","charTypeName":"word"},{"id":9739,"position":3,"arabic":"لَتَكْفُرُونَ","translation":"অস্বীকার করছো অবশ্যই","audioUrl":"wbw/041_009_004.mp3","charTypeName":"word"},{"id":9740,"position":4,"arabic":"بِٱلَّذِى","translation":"(তাকে) যিনি","audioUrl":"wbw/041_009_005.mp3","charTypeName":"word"},{"id":9741,"position":5,"arabic":"خَلَقَ","translation":"সৃষ্টি করেছেন","audioUrl":"wbw/041_009_006.mp3","charTypeName":"word"},{"id":9742,"position":6,"arabic":"ٱلْأَرْضَ","translation":"পৃথিবীকে","audioUrl":"wbw/041_009_007.mp3","charTypeName":"word"},{"id":9743,"position":7,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/041_009_008.mp3","charTypeName":"word"},{"id":9744,"position":8,"arabic":"يَوْمَيْنِ","translation":"দু'দিনের","audioUrl":"wbw/041_009_009.mp3","charTypeName":"word"},{"id":9745,"position":9,"arabic":"وَتَجْعَلُونَ","translation":"অথচ তোমরা দাঁড় করাচ্ছো","audioUrl":"wbw/041_009_010.mp3","charTypeName":"word"},{"id":9746,"position":10,"arabic":"لَهُۥٓ","translation":"তাঁর জন্যে","audioUrl":"wbw/041_009_011.mp3","charTypeName":"word"},{"id":9747,"position":11,"arabic":"أَندَادًۭا ۚ","translation":"সমকক্ষ (অন্যদেরকে)","audioUrl":"wbw/041_009_012.mp3","charTypeName":"word"},{"id":9749,"position":12,"arabic":"ذَٰلِكَ","translation":"তিনিই","audioUrl":"wbw/041_009_014.mp3","charTypeName":"word"},{"id":9750,"position":13,"arabic":"رَبُّ","translation":"রব","audioUrl":"wbw/041_009_015.mp3","charTypeName":"word"},{"id":9751,"position":14,"arabic":"ٱلْعَـٰلَمِينَ","translation":"বিশ্বজগতের\"","audioUrl":"wbw/041_009_016.mp3","charTypeName":"word"},{"id":9752,"position":15,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"وَجَعَلَ فِيهَا رَوَٰسِىَ مِن فَوْقِهَا وَبَٰرَكَ فِيهَا وَقَدَّرَ فِيهَآ أَقْوَٰتَهَا فِىٓ أَرْبَعَةِ أَيَّامٍۢ سَوَآءًۭ لِّلسَّآئِلِينَ","translation":"For He [it is who, after creating the earth,] placed firm mountains on it, [towering] above its surface, and bestowed [so many] blessings on it, and equitably apportioned its means of subsistence to all who would seek it: [and all this He created] in four aeons.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4228.mp3","surahId":41,"words":[{"id":10870,"position":1,"arabic":"وَجَعَلَ","translation":"এবং তিনি স্হাপন করেছেন","audioUrl":"wbw/041_010_001.mp3","charTypeName":"word"},{"id":10871,"position":2,"arabic":"فِيهَا","translation":"তার মধ্যে (অর্থাৎ পৃথিবীতে)","audioUrl":"wbw/041_010_002.mp3","charTypeName":"word"},{"id":10872,"position":3,"arabic":"رَوَٰسِىَ","translation":"পর্বতমালা","audioUrl":"wbw/041_010_003.mp3","charTypeName":"word"},{"id":10873,"position":4,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/041_010_004.mp3","charTypeName":"word"},{"id":10874,"position":5,"arabic":"فَوْقِهَا","translation":"তার উপর","audioUrl":"wbw/041_010_005.mp3","charTypeName":"word"},{"id":10875,"position":6,"arabic":"وَبَـٰرَكَ","translation":"এবং কল্যাণ দিয়েছেন","audioUrl":"wbw/041_010_006.mp3","charTypeName":"word"},{"id":10876,"position":7,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/041_010_007.mp3","charTypeName":"word"},{"id":10877,"position":8,"arabic":"وَقَدَّرَ","translation":"এবং নির্ধারণ করেছেন","audioUrl":"wbw/041_010_008.mp3","charTypeName":"word"},{"id":10878,"position":9,"arabic":"فِيهَآ","translation":"তার মধ্যে","audioUrl":"wbw/041_010_009.mp3","charTypeName":"word"},{"id":10879,"position":10,"arabic":"أَقْوَٰتَهَا","translation":"তার খাদ্য (অর্থাৎ খাদ্যসম্ভার)","audioUrl":"wbw/041_010_010.mp3","charTypeName":"word"},{"id":10880,"position":11,"arabic":"فِىٓ","translation":"মধ্যে","audioUrl":"wbw/041_010_011.mp3","charTypeName":"word"},{"id":10881,"position":12,"arabic":"أَرْبَعَةِ","translation":"চার","audioUrl":"wbw/041_010_012.mp3","charTypeName":"word"},{"id":10882,"position":13,"arabic":"أَيَّامٍۢ","translation":"দিনের","audioUrl":"wbw/041_010_013.mp3","charTypeName":"word"},{"id":10883,"position":14,"arabic":"سَوَآءًۭ","translation":"সমানভাবে","audioUrl":"wbw/041_010_014.mp3","charTypeName":"word"},{"id":10884,"position":15,"arabic":"لِّلسَّآئِلِينَ","translation":"প্রার্থীদের জন্যে","audioUrl":"wbw/041_010_015.mp3","charTypeName":"word"},{"id":10885,"position":16,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"ثُمَّ ٱسْتَوَىٰٓ إِلَى ٱلسَّمَآءِ وَهِىَ دُخَانٌۭ فَقَالَ لَهَا وَلِلْأَرْضِ ٱئْتِيَا طَوْعًا أَوْ كَرْهًۭا قَالَتَآ أَتَيْنَا طَآئِعِينَ","translation":"And He [it is who] applied His design to the skies, which were [yet but] smoke; and He [it is who] said to them and to the earth, “Come [into being], both of you, willingly or unwillingly!” - to which both responded, “We do come in obedience.”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4229.mp3","surahId":41,"words":[{"id":12187,"position":1,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/041_011_001.mp3","charTypeName":"word"},{"id":12188,"position":2,"arabic":"ٱسْتَوَىٰٓ","translation":"মনোযোগ দিলেন","audioUrl":"wbw/041_011_002.mp3","charTypeName":"word"},{"id":12189,"position":3,"arabic":"إِلَى","translation":"দিকে","audioUrl":"wbw/041_011_003.mp3","charTypeName":"word"},{"id":12190,"position":4,"arabic":"ٱلسَّمَآءِ","translation":"আকাশের","audioUrl":"wbw/041_011_004.mp3","charTypeName":"word"},{"id":12191,"position":5,"arabic":"وَهِىَ","translation":"তখন তা (ছিলো)","audioUrl":"wbw/041_011_005.mp3","charTypeName":"word"},{"id":12192,"position":6,"arabic":"دُخَانٌۭ","translation":"ধোঁয়া","audioUrl":"wbw/041_011_006.mp3","charTypeName":"word"},{"id":12193,"position":7,"arabic":"فَقَالَ","translation":"অতঃপর (আল্লাহ) বললেন","audioUrl":"wbw/041_011_007.mp3","charTypeName":"word"},{"id":12194,"position":8,"arabic":"لَهَا","translation":"তাকে","audioUrl":"wbw/041_011_008.mp3","charTypeName":"word"},{"id":12195,"position":9,"arabic":"وَلِلْأَرْضِ","translation":"ও পৃথিবীকে","audioUrl":"wbw/041_011_009.mp3","charTypeName":"word"},{"id":12196,"position":10,"arabic":"ٱئْتِيَا","translation":"\"উভয়ে আসো","audioUrl":"wbw/041_011_010.mp3","charTypeName":"word"},{"id":12197,"position":11,"arabic":"طَوْعًا","translation":"ইচ্ছায়","audioUrl":"wbw/041_011_011.mp3","charTypeName":"word"},{"id":12198,"position":12,"arabic":"أَوْ","translation":"বা","audioUrl":"wbw/041_011_012.mp3","charTypeName":"word"},{"id":12199,"position":13,"arabic":"كَرْهًۭا","translation":"অনিচ্ছায়\"","audioUrl":"wbw/041_011_013.mp3","charTypeName":"word"},{"id":12200,"position":14,"arabic":"قَالَتَآ","translation":"উভয়ে বললো","audioUrl":"wbw/041_011_014.mp3","charTypeName":"word"},{"id":12201,"position":15,"arabic":"أَتَيْنَا","translation":"\"আমরা আসলাম","audioUrl":"wbw/041_011_015.mp3","charTypeName":"word"},{"id":12202,"position":16,"arabic":"طَآئِعِينَ","translation":"স্বেচ্ছায়\"","audioUrl":"wbw/041_011_016.mp3","charTypeName":"word"},{"id":12203,"position":17,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]}]}