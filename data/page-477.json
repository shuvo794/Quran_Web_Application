{"id":477,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ حمٓ","translation":"Ha. Mim.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4219.mp3","surahId":41,"words":[{"id":106,"position":1,"arabic":"حمٓ","translation":"হা-মীম","audioUrl":"wbw/041_001_001.mp3","charTypeName":"word"},{"id":107,"position":2,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"تَنزِيلٌۭ مِّنَ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ","translation":"THE BESTOWAL from on high [of this revelation] issues from the Most Gracious, the Dis­penser of Grace:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4220.mp3","surahId":41,"words":[{"id":956,"position":1,"arabic":"تَنزِيلٌۭ","translation":"অবতরণ করা (হয়েছে এটা)","audioUrl":"wbw/041_002_001.mp3","charTypeName":"word"},{"id":957,"position":2,"arabic":"مِّنَ","translation":"(আল্লাহর) পক্ষ হ'তে","audioUrl":"wbw/041_002_002.mp3","charTypeName":"word"},{"id":958,"position":3,"arabic":"ٱلرَّحْمَـٰنِ","translation":"(যিনি) অশেষ দয়াময়","audioUrl":"wbw/041_002_003.mp3","charTypeName":"word"},{"id":959,"position":4,"arabic":"ٱلرَّحِيمِ","translation":"পরম দয়ালু","audioUrl":"wbw/041_002_004.mp3","charTypeName":"word"},{"id":960,"position":5,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"كِتَٰبٌۭ فُصِّلَتْ ءَايَٰتُهُۥ قُرْءَانًا عَرَبِيًّۭا لِّقَوْمٍۢ يَعْلَمُونَ","translation":"a divine writ, the messages whereof have been clearly spelled out as a discourse in the Arabic tongue for people of [innate] knowl­edge,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4221.mp3","surahId":41,"words":[{"id":2059,"position":1,"arabic":"كِتَـٰبٌۭ","translation":"এই কিতাব (এমন যে)","audioUrl":"wbw/041_003_001.mp3","charTypeName":"word"},{"id":2060,"position":2,"arabic":"فُصِّلَتْ","translation":"বিশদভাবে বিবৃত","audioUrl":"wbw/041_003_002.mp3","charTypeName":"word"},{"id":2061,"position":3,"arabic":"ءَايَـٰتُهُۥ","translation":"তার আয়াতসমূহ","audioUrl":"wbw/041_003_003.mp3","charTypeName":"word"},{"id":2062,"position":4,"arabic":"قُرْءَانًا","translation":"কুরআন","audioUrl":"wbw/041_003_004.mp3","charTypeName":"word"},{"id":2063,"position":5,"arabic":"عَرَبِيًّۭا","translation":"আরবী (ভাষার)","audioUrl":"wbw/041_003_005.mp3","charTypeName":"word"},{"id":2064,"position":6,"arabic":"لِّقَوْمٍۢ","translation":"(এমন) সম্প্রদায়ের জন্যে","audioUrl":"wbw/041_003_006.mp3","charTypeName":"word"},{"id":2065,"position":7,"arabic":"يَعْلَمُونَ","translation":"(যারা) জ্ঞান রাখে","audioUrl":"wbw/041_003_007.mp3","charTypeName":"word"},{"id":2066,"position":8,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"بَشِيرًۭا وَنَذِيرًۭا فَأَعْرَضَ أَكْثَرُهُمْ فَهُمْ لَا يَسْمَعُونَ","translation":"to be a herald of glad tidings as well as a warning. And yet, [whenever this divine writ is offered to men,] most of them turn away, so that they cannot hear [its message];","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4222.mp3","surahId":41,"words":[{"id":3312,"position":1,"arabic":"بَشِيرًۭا","translation":"(এই কিতাব) সুসংবাদদাতা","audioUrl":"wbw/041_004_001.mp3","charTypeName":"word"},{"id":3313,"position":2,"arabic":"وَنَذِيرًۭا","translation":"ও সতর্ককারী","audioUrl":"wbw/041_004_002.mp3","charTypeName":"word"},{"id":3314,"position":3,"arabic":"فَأَعْرَضَ","translation":"কিন্তু বিমুখ হয়েছে","audioUrl":"wbw/041_004_003.mp3","charTypeName":"word"},{"id":3315,"position":4,"arabic":"أَكْثَرُهُمْ","translation":"তাদের অনেকেই","audioUrl":"wbw/041_004_004.mp3","charTypeName":"word"},{"id":3316,"position":5,"arabic":"فَهُمْ","translation":"সুতরাং তারা","audioUrl":"wbw/041_004_005.mp3","charTypeName":"word"},{"id":3317,"position":6,"arabic":"لَا","translation":"না","audioUrl":"wbw/041_004_006.mp3","charTypeName":"word"},{"id":3318,"position":7,"arabic":"يَسْمَعُونَ","translation":"শুনে","audioUrl":"wbw/041_004_007.mp3","charTypeName":"word"},{"id":3319,"position":8,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"وَقَالُوا۟ قُلُوبُنَا فِىٓ أَكِنَّةٍۢ مِّمَّا تَدْعُونَآ إِلَيْهِ وَفِىٓ ءَاذَانِنَا وَقْرٌۭ وَمِنۢ بَيْنِنَا وَبَيْنِكَ حِجَابٌۭ فَٱعْمَلْ إِنَّنَا عَٰمِلُونَ","translation":"and so they say, [as it were:] “Our hearts are veiled from whatever thou callest us to, [O Muhammad,] and in our ears is deafness, and between us and thee is a barrier. Do, then, [whatever thou wilt, whereas,] behold, we shall do [as we have always done]!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4223.mp3","surahId":41,"words":[{"id":4653,"position":1,"arabic":"وَقَالُوا۟","translation":"এবং তারা বলে","audioUrl":"wbw/041_005_001.mp3","charTypeName":"word"},{"id":4654,"position":2,"arabic":"قُلُوبُنَا","translation":"\"আমাদের অন্তরগুলো","audioUrl":"wbw/041_005_002.mp3","charTypeName":"word"},{"id":4655,"position":3,"arabic":"فِىٓ","translation":"মধ্যে (আছে)","audioUrl":"wbw/041_005_003.mp3","charTypeName":"word"},{"id":4656,"position":4,"arabic":"أَكِنَّةٍۢ","translation":"পর্দাসমূহের","audioUrl":"wbw/041_005_004.mp3","charTypeName":"word"},{"id":4657,"position":5,"arabic":"مِّمَّا","translation":"তা থেকে যা","audioUrl":"wbw/041_005_005.mp3","charTypeName":"word"},{"id":4658,"position":6,"arabic":"تَدْعُونَآ","translation":"আমাদেরকে তোমরা ডাকছো","audioUrl":"wbw/041_005_006.mp3","charTypeName":"word"},{"id":4659,"position":7,"arabic":"إِلَيْهِ","translation":"তার দিকে","audioUrl":"wbw/041_005_007.mp3","charTypeName":"word"},{"id":4660,"position":8,"arabic":"وَفِىٓ","translation":"এবং মধ্যে","audioUrl":"wbw/041_005_008.mp3","charTypeName":"word"},{"id":4661,"position":9,"arabic":"ءَاذَانِنَا","translation":"আমাদের কানসমূহের","audioUrl":"wbw/041_005_009.mp3","charTypeName":"word"},{"id":4662,"position":10,"arabic":"وَقْرٌۭ","translation":"বধিরতা (রয়েছে)","audioUrl":"wbw/041_005_010.mp3","charTypeName":"word"},{"id":4663,"position":11,"arabic":"وَمِنۢ","tran