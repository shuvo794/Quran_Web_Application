","charTypeName":"word"},{"id":6581,"position":21,"arabic":"فَٱطَّهَّرُوا۟ ۚ","translation":"তবে তোমরা পবিত্র হবে","audioUrl":"wbw/005_006_022.mp3","charTypeName":"word"},{"id":6583,"position":22,"arabic":"وَإِن","translation":"এবং যদি","audioUrl":"wbw/005_006_024.mp3","charTypeName":"word"},{"id":6584,"position":23,"arabic":"كُنتُم","translation":"হও তোমরা","audioUrl":"wbw/005_006_025.mp3","charTypeName":"word"},{"id":6585,"position":24,"arabic":"مَّرْضَىٰٓ","translation":"অসুস্থ","audioUrl":"wbw/005_006_026.mp3","charTypeName":"word"},{"id":6586,"position":25,"arabic":"أَوْ","translation":"বা","audioUrl":"wbw/005_006_027.mp3","charTypeName":"word"},{"id":6587,"position":26,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/005_006_028.mp3","charTypeName":"word"},{"id":6588,"position":27,"arabic":"سَفَرٍ","translation":"সফরে (থাকো)","audioUrl":"wbw/005_006_029.mp3","charTypeName":"word"},{"id":6589,"position":28,"arabic":"أَوْ","translation":"বা","audioUrl":"wbw/005_006_030.mp3","charTypeName":"word"},{"id":6590,"position":29,"arabic":"جَآءَ","translation":"আসে","audioUrl":"wbw/005_006_031.mp3","charTypeName":"word"},{"id":6591,"position":30,"arabic":"أَحَدٌۭ","translation":"কেউ","audioUrl":"wbw/005_006_032.mp3","charTypeName":"word"},{"id":6592,"position":31,"arabic":"مِّنكُم","translation":"মধ্যে তোমাদের","audioUrl":"wbw/005_006_033.mp3","charTypeName":"word"},{"id":6593,"position":32,"arabic":"مِّنَ","translation":"হতে","audioUrl":"wbw/005_006_034.mp3","charTypeName":"word"},{"id":6594,"position":33,"arabic":"ٱلْغَآئِطِ","translation":"পায়খানা (মলমূত্র ত্যাগ করে)","audioUrl":"wbw/005_006_035.mp3","charTypeName":"word"},{"id":6595,"position":34,"arabic":"أَوْ","translation":"বা","audioUrl":"wbw/005_006_036.mp3","charTypeName":"word"},{"id":6596,"position":35,"arabic":"لَـٰمَسْتُمُ","translation":"স্পর্শ করো তোমরা (সহবাস করো)","audioUrl":"wbw/005_006_037.mp3","charTypeName":"word"},{"id":6597,"position":36,"arabic":"ٱلنِّسَآءَ","translation":"স্ত্রীদের","au