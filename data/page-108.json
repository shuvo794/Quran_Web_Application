"id":6614,"position":52,"arabic":"مِّنْ","translation":"কোনো","audioUrl":"wbw/005_006_055.mp3","charTypeName":"word"},{"id":6615,"position":53,"arabic":"حَرَجٍۢ","translation":"কষ্ট","audioUrl":"wbw/005_006_056.mp3","charTypeName":"word"},{"id":6616,"position":54,"arabic":"وَلَـٰكِن","translation":"কিন্তু","audioUrl":"wbw/005_006_057.mp3","charTypeName":"word"},{"id":6617,"position":55,"arabic":"يُرِيدُ","translation":"তিনি চান","audioUrl":"wbw/005_006_058.mp3","charTypeName":"word"},{"id":6618,"position":56,"arabic":"لِيُطَهِّرَكُمْ","translation":"যেন তিনি পবিত্র করেন তোমাদেরকে","audioUrl":"wbw/005_006_059.mp3","charTypeName":"word"},{"id":6619,"position":57,"arabic":"وَلِيُتِمَّ","translation":"এবং পূর্ণ করেন","audioUrl":"wbw/005_006_060.mp3","charTypeName":"word"},{"id":6620,"position":58,"arabic":"نِعْمَتَهُۥ","translation":"অনুগ্রহ তাঁর","audioUrl":"wbw/005_006_061.mp3","charTypeName":"word"},{"id":6621,"position":59,"arabic":"عَلَيْكُمْ","translation":"উপর তোমাদের","audioUrl":"wbw/005_006_062.mp3","charTypeName":"word"},{"id":6622,"position":60,"arabic":"لَعَلَّكُمْ","translation":"যাতে তোমরা","audioUrl":"wbw/005_006_063.mp3","charTypeName":"word"},{"id":6623,"position":61,"arabic":"تَشْكُرُونَ","translation":"কৃতজ্ঞতা প্রকাশ করো","audioUrl":"wbw/005_006_064.mp3","charTypeName":"word"},{"id":6624,"position":62,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"وَٱذْكُرُوا۟ نِعْمَةَ ٱللَّهِ عَلَيْكُمْ وَمِيثَٰقَهُ ٱلَّذِى وَاثَقَكُم بِهِۦٓ إِذْ قُلْتُمْ سَمِعْنَا وَأَطَعْنَا ۖ وَٱتَّقُوا۟ ٱللَّهَ ۚ إِنَّ ٱللَّهَ عَلِيمٌۢ بِذَاتِ ٱلصُّدُورِ","translation":"And [always] remember the blessings which God has bestowed upon you, and the solemn pledge by which He bound you to Himself when you said, \"We have heard, and we pay heed.\" Hence, remain conscious of God: verily, God has full knowledge of what is in the hearts [of men].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/676.mp3","surahId":5,"words":[