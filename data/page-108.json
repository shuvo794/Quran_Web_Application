هَ","translation":"আল্লাহ","audioUrl":"wbw/005_007_018.mp3","charTypeName":"word"},{"id":7985,"position":17,"arabic":"عَلِيمٌۢ","translation":"খুব অবহিত","audioUrl":"wbw/005_007_019.mp3","charTypeName":"word"},{"id":7986,"position":18,"arabic":"بِذَاتِ","translation":"সম্পর্কে অবস্থা","audioUrl":"wbw/005_007_020.mp3","charTypeName":"word"},{"id":7987,"position":19,"arabic":"ٱلصُّدُورِ","translation":"অন্তরসমূহের","audioUrl":"wbw/005_007_021.mp3","charTypeName":"word"},{"id":7988,"position":20,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ كُونُوا۟ قَوَّٰمِينَ لِلَّهِ شُهَدَآءَ بِٱلْقِسْطِ ۖ وَلَا يَجْرِمَنَّكُمْ شَنَـَٔانُ قَوْمٍ عَلَىٰٓ أَلَّا تَعْدِلُوا۟ ۚ ٱعْدِلُوا۟ هُوَ أَقْرَبُ لِلتَّقْوَىٰ ۖ وَٱتَّقُوا۟ ٱللَّهَ ۚ إِنَّ ٱللَّهَ خَبِيرٌۢ بِمَا تَعْمَلُونَ","translation":"O YOU who have attained to faith! Be ever steadfast in your devotion to God, bearing witness to the truth in all equity; and never let hatred of any-one lead you into the sin of deviating from justice. Be just: this is closest to being God-conscious. And remain conscious of God: verily, God is aware of all that you do.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/677.mp3","surahId":5,"words":[{"id":9131,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/005_008_001.mp3","charTypeName":"word"},{"id":9132,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/005_008_002.mp3","charTypeName":"word"},{"id":9133,"position":3,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছো","audioUrl":"wbw/005_008_003.mp3","charTypeName":"word"},{"id":9134,"position":4,"arabic":"كُونُوا۟","translation":"তোমরা থাকো","audioUrl":"wbw/005_008_004.mp3","charTypeName":"word"},{"id":9135,"position":5,"arabic":"قَوَّٰمِينَ","translation":"অবিচল","audioUrl":"wbw/005_008_005.mp3","charTypeName":"word"},{"id":9136,"position":6,"arabic":"لِلَّهِ","translation":"জন্যে আল্লাহর","audioUrl":"wbw/005_008_006.mp3","charTypeName":"word"},{"id":9137,"position":7,"arabic":"شُهَدَآءَ","translation":"সাক্ষ্যদাতা হিসেবে","audioUrl":"wbw/005_008_007.mp3","charTypeName":"word"},{"id":9138,"position":8,"arabic":"بِٱلْقِسْطِ ۖ","translation":"উপর ন্যায়ের","audioUrl":"wbw/005_008_008.mp3","charTypeName":"word"},{"id":9140,"position":9,"arabic":"وَلَا","translation":"এবং না (যেন)","audioUrl":"wbw/005_008_010.mp3","charTypeName":"word"},{"id":9141,"position":10,"arabic":"يَجْرِمَنَّكُمْ","translation":"প্ররোচিত করে তোমাদেরকে","audioUrl":"wbw/005_008_011.mp3","charTypeName":"word"},{"id":9142,"position":11,"arabic":"شَنَـَٔانُ","translation":"বিদ্বেষ","audioUrl":"wbw/005_008_012.mp3","charTypeName":"word"},{"id":9143,"position":12,"arabic":"قَوْمٍ","translation":"কোনো জাতির","audioUrl":"wbw/005_008_013.mp3","charTypeName":"word"},{"id":9144,"position":13,"arabic":"عَلَىٰٓ","translation":"(এর) উপর","audioUrl":"wbw/005_008_014.mp3","charTypeName":"word"},{"id":9145,"position":14,"arabic":"أَلَّا","translation":"যে না","audioUrl":"wbw/005_008_015.mp3","charTypeName":"word"},{"id":9146,"position":15,"arabic":"تَعْدِلُوا۟ ۚ","translation":"তোমরা সুবিচার করো","audioUrl":"wbw/005_008_016.mp3","charTypeName":"word"},{"id":9148,"position":16,"arabic":"ٱعْدِلُوا۟","translation":"তোমরা সুবিচার  করো","audioUrl":"wbw/005_008_018.mp3","charTypeName":"word"},{"id":9149,"position":17,"arabic":"هُوَ","translation":"তা","audioUrl":"wbw/005_008_019.mp3","charTypeName":"word"},{"id":9150,"position":18,"arabic":"أَقْرَبُ","translation":"নিকটতর","audioUrl":"wbw/005_008_020.mp3","charTypeName":"word"},{"id":9151,"position":19,"arabic":"لِلتَّقْوَىٰ ۖ","translation":"জন্যে তাকওয়ার","audioUrl":"wbw/005_008_021.mp3","charTypeName":"word"},{"id":9153,"position":20,"arabic":"وَٱتَّقُوا۟","translation":"এবং তোমরা ভয় করো","audioUrl":"wbw/005_008_023.mp3","charTypeName":"word"},{"id":9154,"position":21,"arabic":"ٱللَّهَ ۚ","translation":"আল্লাহকে","audioUrl":"wbw/005_008_024.mp3","charTypeName":"wo