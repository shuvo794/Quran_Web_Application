{"id":595,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلشَّمْسِ وَضُحَىٰهَا","translation":"CONSIDER the sun and its radiant brightness,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6044.mp3","surahId":91,"words":[{"id":793,"position":1,"arabic":"وَٱلشَّمْسِ","translation":"শপথ সূর্যের","audioUrl":"wbw/091_001_001.mp3","charTypeName":"word"},{"id":794,"position":2,"arabic":"وَضُحَىٰهَا","translation":"এবং তার কিরণের","audioUrl":"wbw/091_001_002.mp3","charTypeName":"word"},{"id":795,"position":3,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"وَٱلْقَمَرِ إِذَا تَلَىٰهَا","translation":"and the moon as it reflects the sun!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6045.mp3","surahId":91,"words":[{"id":1781,"position":1,"arabic":"وَٱلْقَمَرِ","translation":"শপথ চাঁদের","audioUrl":"wbw/091_002_001.mp3","charTypeName":"word"},{"id":1782,"position":2,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/091_002_002.mp3","charTypeName":"word"},{"id":1783,"position":3,"arabic":"تَلَىٰهَا","translation":"তার পিছে আসে","audioUrl":"wbw/091_002_003.mp3","charTypeName":"word"},{"id":1784,"position":4,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"وَٱلنَّهَارِ إِذَا جَلَّىٰهَا","translation":"Consider the day as it reveals the world,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6046.mp3","surahId":91,"words":[{"id":2093,"position":1,"arabic":"وَٱلنَّهَارِ","translation":"শপথ দিনের","audioUrl":"wbw/091_003_001.mp3","charTypeName":"word"},{"id":2094,"position":2,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/091_003_002.mp3","charTypeName":"word"},{"id":2095,"position":3,"arabic":"جَلَّىٰهَا","translation":"তাকে প্রকাশ করে","audioUrl":"wbw/091_003_003.mp3","charTypeName":"word"},{"id":2096,"position":4,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"وَٱلَّيْلِ إِذَا يَغْشَىٰهَا","translation":"and the night as it veils it darkly!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6047.mp3","surahId":91,"words":[{"id":4507,"position":1,"arabic":"وَٱلَّيْلِ","translation":"শপথ রাতের","audioUrl":"wbw/091_004_001.mp3","charTypeName":"word"},{"id":4508,"position":2,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/091_004_002.mp3","charTypeName":"word"},{"id":4509,"position":3,"arabic":"يَغْشَىٰهَا","translation":"তাকে ঢেকে ফেলে","audioUrl":"wbw/091_004_003.mp3","charTypeName":"word"},{"id":4510,"position":4,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"وَٱلسَّمَآءِ وَمَا بَنَىٰهَا","translation":"Consider the sky and its wondrous make,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6048.mp3","surahId":91,"words":[{"id":5742,"position":1,"arabic":"وَٱلسَّمَآءِ","translation":"শপথ আকাশের","audioUrl":"wbw/091_005_001.mp3","charTypeName":"word"},{"id":5743,"position":2,"arabic":"وَمَا","translation":"এবং যিনি","audioUrl":"wbw/091_005_002.mp3","charTypeName":"word"},{"id":5744,"position":3,"arabic":"بَنَىٰهَا","translation":"তা তৈরি করেছেন","audioUrl":"wbw/091_005_003.mp3","charTypeName":"word"},{"id":5745,"position":4,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"وَٱلْأَرْضِ وَمَا طَحَىٰهَا","translation":"and the earth and all its expanse!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6049.mp3","surahId":91,"words":[{"id":7077,"position":1,"arabic":"وَٱلْأَرْضِ","translation":"শপথ পৃথিবীর","audioUrl":"wbw/091_006_001.mp3","charTypeName":"word"},{"id":7078,"position":2,"arabic":"وَمَا","translation":"এবং যিনি","audioUrl":"wbw/091_006_002.mp3","charTypeName":"word"},{"id":7079,"position":3,"arabic":"طَحَىٰهَا","translation":"তা বিস্তৃত করেছেন","audioUrl":"wbw/091_006_003.mp3","charTypeName":"word"},{"id":7080,"position":4,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"وَنَفْسٍۢ وَمَا سَوَّىٰهَا","translation":"Consider the human self, and how it is formed in accordance with what it is meant to be,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6050.mp3","surahId":91,"words":[{"id":8376,"position":1,"arabic":"وَنَفْسٍۢ","translation":"শপথ মানুষের","audioUrl":"wbw/091_007_001.mp3","charTypeName":"word"},{"id":8377,"position":2,"arabic":"وَمَا","translation":"এবং যিনি","audioUrl":"wbw/091_007_002.mp3","charTypeName":"word"},{"id":8378,"position":3,"arabic":"سَوَّىٰهَا","translation":"তাকে সুঠাম করেছেন","audioUrl":"wbw/091_007_003.mp3","charTypeName":"word"},{"id":8379,"position":4,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"فَأَلْهَمَهَا فُجُورَهَا وَتَقْوَىٰهَا","translation":"and how it is imbued with moral failings as well as with consciousness of God!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6051.mp3","surahId":91,"words":[{"id":9528,"position":1,"arabic":"فَأَلْهَمَهَا","translation":"অতঃপর তাকে জ্ঞান দিয়েছেন","audioUrl":"wbw/091_008_001.mp3","charTypeName":"word"},{"id":9529,"position":2,"arabic":"فُجُورَهَا","translation":"তার মন্দকাজ","audioUrl":"wbw/091_008_002.mp3","charTypeName":"word"},{"id":9530,"position":3,"arabic":"وَتَقْوَىٰهَا","translation":"ও তার তাকওয়া (সম্পর্কে )","audioUrl":"wbw/091_008_003.mp3","charTypeName":"word"},{"id":9531,"position":4,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"قَدْ أَفْلَحَ مَن زَكَّىٰهَا","translation":"To a happy state shall indeed attain he who causes this [self] to grow in purity,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6052.mp3","surahId":91,"words":[{"id":10792,"position":1,"arabic":"قَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/091_009_001.mp3","charTypeName":"word"},{"id":10793,"position":2,"arabic":"أَفْلَحَ","translation":"সফল হলো","audioUrl":"wbw/091_009_002.mp3","charTypeName":"word"},{"id":10794,"position":3,"arabic":"مَن","translation":"যে","audioUrl":"wbw/091_009_003.mp3","charTypeName":"word"},{"id":10795,"position":4,"arabic":"زَكَّىٰهَا","translation":"তাকে পবিত্র করলো","audioUrl":"wbw/091_009_004.mp3","charTypeName":"word"},{"id":10796,"position":5,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"وَقَدْ خَابَ مَن دَسَّىٰهَا","translation":"and truly lost is he who buries it [in darkness].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6053.mp3","surahId":91,"words":[{"id":12039,"position":1,"arabic":"وَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/091_010_001.mp3","charTypeName":"word"},{"id":12040,"position":2,"arabic":"خَابَ","translation":"ব্যর্থ হলো","audioUrl":"wbw/091_010_002.mp3","charTypeName":"word"},{"id":12041,"position":3,"arabic":"مَن","translation":"যে","audioUrl":"wbw/091_010_003.mp3","charTypeName":"word"},{"id":12042,"position":4,"arabic":"دَسَّىٰهَا","translation":"তাকে কলুষিত করলো","audioUrl":"wbw/091_010_004.mp3","charTypeName":"word"},{"id":12043,"position":5,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"كَذَّبَتْ ثَمُودُ بِطَغْوَىٰهَآ","translation":"TO [THIS] TRUTH gave the lie, in their overweening arrogance, [the tribe of] Thamud,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6054.mp3","surahId":91,"words":[{"id":13328,"position":1,"arabic":"كَذَّبَتْ","translation":"মিথ্যারোপ করেছিল","audioUrl":"wbw/091_011_001.mp3","charTypeName":"word"},{"id":13329,"position":2,"arabic":"ثَمُودُ","translation":"সামূদ জাতি","audioUrl":"wbw/091_011_002.mp3","charTypeName":"word"},{"id":13330,"position":3,"arabic":"بِطَغْوَىٰهَآ","translation":"তার অবাধ্যতাবশতঃ","audioUrl":"wbw/091_011_003.mp3","charTypeName":"word"},{"id":13331,"position":4,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]},{"number":12,"arabic":"إِذِ ٱنۢبَعَثَ أَشْقَىٰهَا","translation":"when that most hapless wretch from among them rushed forward [to commit his evil deed],","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6055.mp3","surahId":91,"words":[{"id":14556,"position":1,"arabic":"إِذِ","translation":"যখন","audioUrl":"wbw/091_012_001.mp3","charTypeName":"word"},{"id":14557,"position":2,"arabic":"ٱنۢبَعَثَ","translation":"(তৎপর হয়ে)উঠলো","audioUrl":"wbw/091_012_002.mp3","charTypeName":"word"},{"id":14558,"position":3,"arabic":"أَشْقَىٰهَا","translation":"তার সবচেয়ে হতভাগা ব্যক্তি","audioUrl":"wbw/091_012_003.mp3","charTypeName":"word"},{"id":14559,"position":4,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]},{"number":13,"arabic":"فَقَالَ لَهُمْ رَسُولُ ٱللَّهِ نَاقَةَ ٱللَّهِ وَسُقْيَٰهَا","translation":"although God's apostle had told them, \"It is a she-camel belonging to God, so let her drink [and do her no harm]!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6056.mp3","surahId":91,"words":[{"id":15451,"position":1,"arabic":"فَقَالَ","translation":"অতঃপর বললো","audioUrl":"wbw/091_013_001.mp3","charTypeName":"word"},{"id":15452,"position":2,"arabic":"لَهُمْ","translation":"তাদেরকে","audioUrl":"wbw/091_013_002.mp3","charTypeName":"word"},{"id":15453,"position":3,"arabic":"رَسُولُ","translation":"রাসূল","audioUrl":"wbw/091_013_003.mp3","charTypeName":"word"},{"id":15454,"position":4,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/091_013_004.mp3","charTypeName":"word"},{"id":15455,"position":5,"arabic":"نَاقَةَ","translation":"\"(সাবধান)উষ্ট্রীকে","audioUrl":"wbw/091_013_005.mp3","charTypeName":"word"},{"id":15456,"position":6,"arabic":"ٱللَّهِ","translation":"আল্লাহর (স্পর্শ করো না)","audioUrl":"wbw/091_013_006.mp3","charTypeName":"word"},{"id":15457,"position":7,"arabic":"وَسُقْيَـٰهَا","translation":"ও তার পানি পান করায় (বাধা দিও না)\"","audioUrl":"wbw/091_013_007.mp3","charTypeName":"word"},{"id":15458,"position":8,"arabic":"١٣","translation":"(১৩)","audioUrl":null,"charTypeName":"end"}]},{"number":14,"arabic":"فَكَذَّبُوهُ فَعَقَرُوهَا فَدَمْدَمَ عَلَيْهِمْ رَبُّهُم بِذَنۢبِهِمْ فَسَوَّىٰهَا","translation":"But they gave him the lie, and cruelly slaughtered her - whereupon their Sustainer visited them with utter destruction for this their sin, destroying them all alike:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6057.mp3","surahId":91,"words":[{"id":15841,"position":1,"arabic":"فَكَذَّبُوهُ","translation":"কিন্তু তারা তাকে  মিথ্যা ভাবলো","audioUrl":"wbw/091_014_001.mp3","charTypeName":"word"},{"id":15842,"position":2,"arabic":"فَعَقَرُوهَا","translation":"অতঃপর তারা তাকে  হত্যা করলো","audioUrl":"wbw/091_014_002.mp3","charTypeName":"word"},{"id":15843,"position":3,"arabic":"فَدَمْدَمَ","translation":"ফলে ধ্বংস করে দিলেন","audioUrl":"wbw/091_014_003.mp3","charTypeName":"word"},{"id":15844,"position":4,"arabic":"عَلَيْهِمْ","translation":"তাদেরকে","audioUrl":"wbw/091_014_004.mp3","charTypeName":"word"},{"id":15845,"position":5,"arabic":"رَبُّهُم","translation":"তাদের রব","audioUrl":"wbw/091_014_005.mp3","charTypeName":"word"},{"id":15846,"position":6,"arabic":"بِذَنۢبِهِمْ","translation":"তাদের পাপের জন্য","audioUrl":"wbw/091_014_006.mp3","charTypeName":"word"},{"id":15847,"position":7,"arabic":"فَسَوَّىٰهَا","translation":"অতঃপর তাদেরকে (মাটি) সমান করে দিলেন","audioUrl":"wbw/091_014_007.mp3","charTypeName":"word"},{"id":15848,"position":8,"arabic":"١٤","translation":"(১৪)","audioUrl":null,"charTypeName":"end"}]},{"number":15,"arabic":"وَلَا يَخَافُ عُقْبَٰهَا","translation":"for none [of them] had any fear of what might befall them.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6058.mp3","surahId":91,"words":[{"id":16868,"position":1,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/091_015_001.mp3","charTypeName":"word"},{"id":16869,"position":2,"arabic":"يَخَافُ","translation":"ভয় করেন তিনি","audioUrl":"wbw/091_015_002.mp3","charTypeName":"word"},{"id":16870,"position":3,"arabic":"عُقْبَـٰهَا","translation":"তাঁর (কাজের) পরিণতির","audioUrl":"wbw/091_015_003.mp3","charTypeName":"word"},{"id":16871,"position":4,"arabic":"١٥","translation":"(১৫)","audioUrl":null,"charTypeName":"end"}]},{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلَّيْلِ إِذَا يَغْشَىٰ","translation":"CONSIDER the night as it veils [the earth] in darkness,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6059.mp3","surahId":92,"words":[{"id":222,"position":1,"arabic":"وَٱلَّيْلِ","translation":"শপথ রাতের","audioUrl":"wbw/092_001_001.mp3","charTypeName":"word"},{"id":223,"position":2,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/092_001_002.mp3","charTypeName":"word"},{"id":224,"position":3,"arabic":"يَغْشَىٰ","translation":"আচ্ছন্ন করে","audioUrl":"wbw/092_001_003.mp3","charTypeName":"word"},{"id":225,"position":4,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"وَٱلنَّهَارِ إِذَا تَجَلَّىٰ","translation":"and the day as it rises bright!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6060.mp3","surahId":92,"words":[{"id":1785,"position":1,"arabic":"وَٱلنَّهَارِ","translation":"শপথ দিনের","audioUrl":"wbw/092_002_001.mp3","charTypeName":"word"},{"id":1786,"position":2,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/092_002_002.mp3","charTypeName":"word"},{"id":1787,"position":3,"arabic":"تَجَلَّىٰ","translation":"আলোকিত হয়","audioUrl":"wbw/092_002_003.mp3","charTypeName":"word"},{"id":1788,"position":4,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"وَمَا خَلَقَ ٱلذَّكَرَ وَٱلْأُنثَىٰٓ","translation":"Consider the creation of the male and the female!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6061.mp3","surahId":92,"words":[{"id":2121,"position":1,"arabic":"وَمَا","translation":"শপথ তাঁর (যিনি)","audioUrl":"wbw/092_003_001.mp3","charTypeName":"word"},{"id":2122,"position":2,"arabic":"خَلَقَ","translation":"সৃষ্টি করেছেন","audioUrl":"wbw/092_003_002.mp3","charTypeName":"word"},{"id":2123,"position":3,"arabic":"ٱلذَّكَرَ","translation":"পুরুষ","audioUrl":"wbw/092_003_003.mp3","charTypeName":"word"},{"id":2124,"position":4,"arabic":"وَٱلْأُنثَىٰٓ","translation":"ও নারী","audioUrl":"wbw/092_003_004.mp3","charTypeName":"word"},{"id":2125,"position":5,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"إِنَّ سَعْيَكُمْ لَشَتَّىٰ","translation":"Verily, [O men,] you aim at most divergent ends!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6062.mp3","surahId":92,"words":[{"id":3404,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/092_004_001.mp3","charTypeName":"word"},{"id":3405,"position":2,"arabic":"سَعْيَكُمْ","translation":"তোমাদের কর্মপ্রচেষ্টা","audioUrl":"wbw/092_004_002.mp3","charTypeName":"word"},{"id":3406,"position":3,"arabic":"لَشَتَّىٰ","translation":"অবশ্যই বিভিন্ন প্রকৃতির","audioUrl":"wbw/092_004_003.mp3","charTypeName":"word"},{"id":3407,"position":4,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"فَأَمَّا مَنْ أَعْطَىٰ وَٱتَّقَىٰ","translation":"Thus, as for him who gives [to others] and is conscious of God,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6063.mp3","surahId":92,"words":[{"id":4746,"position":1,"arabic":"فَأَمَّا","translation":"অতঃপর (তার) ক্ষেত্রে","audioUrl":"wbw/092_005_001.mp3","charTypeName":"word"},{"id":4747,"position":2,"arabic":"مَنْ","translation":"যে","audioUrl":"wbw/092_005_002.mp3","charTypeName":"word"},{"id":4748,"position":3,"arabic":"أَعْطَىٰ","translation":"দান করলো","audioUrl":"wbw/092_005_003.mp3","charTypeName":"word"},{"id":4749,"position":4,"arabic":"وَٱتَّقَىٰ","translation":"ও খোদাভীরু হলো","audioUrl":"wbw/092_005_004.mp3","charTypeName":"word"},{"id":4750,"position":5,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"n