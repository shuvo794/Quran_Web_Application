"audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"وَكَذَّبَ بِٱلْحُسْنَىٰ","translation":"and calls the ultimate good a lie –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6067.mp3","surahId":92,"words":[{"id":9922,"position":1,"arabic":"وَكَذَّبَ","translation":"এবং অমান্য করলো","audioUrl":"wbw/092_009_001.mp3","charTypeName":"word"},{"id":9923,"position":2,"arabic":"بِٱلْحُسْنَىٰ","translation":"উত্তমকে (ইসলামকে)","audioUrl":"wbw/092_009_002.mp3","charTypeName":"word"},{"id":9924,"position":3,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"فَسَنُيَسِّرُهُۥ لِلْعُسْرَىٰ","translation":"for him shall We make easy the path towards hardship:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6068.mp3","surahId":92,"words":[{"id":11103,"position":1,"arabic":"فَسَنُيَسِّرُهُۥ","translation":"ফলে আমরা তাকে সহজতা দিব","audioUrl":"wbw/092_010_001.mp3","charTypeName":"word"},{"id":11104,"position":2,"arabic":"لِلْعُسْرَىٰ","translation":"কঠোর পথের জন্য","audioUrl":"wbw/092_010_002.mp3","charTypeName":"word"},{"id":11105,"position":3,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"وَمَا يُغْنِى عَنْهُ مَالُهُۥٓ إِذَا تَرَدَّىٰٓ","translation":"and what will his wealth avail him when he goes down [to his grave]?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6069.mp3","surahId":92,"words":[{"id":12446,"position":1,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/092_011_001.mp3","charTypeName":"word"},{"id":12447,"position":2,"arabic":"يُغْنِى","translation":"কাজে আসবে","audioUrl":"wbw/092_011_002.mp3","charTypeName":"word"},{"id":12448,"position":3,"arabic":"عَنْهُ","translation":"তার জন্যে","audioUrl":"wbw/092_011_003.mp3","charTypeName":"word"},{"id":12449,"position":4,"arabic":"مَالُهُۥٓ","translation":"তার ধনসম্পদ","audioUrl":"wbw/092_011_004.mp3","charTypeName":"word"},{"id":12450,"position":5,"arabic":"إ