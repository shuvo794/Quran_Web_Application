abic":"٢٥٣","translation":"(২৫৩)","audioUrl":null,"charTypeName":"end"}]},{"number":254,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوٓا۟ أَنفِقُوا۟ مِمَّا رَزَقْنَٰكُم مِّن قَبْلِ أَن يَأْتِىَ يَوْمٌۭ لَّا بَيْعٌۭ فِيهِ وَلَا خُلَّةٌۭ وَلَا شَفَٰعَةٌۭ ۗ وَٱلْكَٰفِرُونَ هُمُ ٱلظَّٰلِمُونَ","translation":"O YOU who have attained to faith! Spend [in Our way] out of what We have granted you as sustenance ere there come a Day when there will be no bargaining, and no friendship, and no intercession. And they who deny the truth -it is they who are evildoers!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/261.mp3","surahId":2,"words":[{"id":87125,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/002_254_001.mp3","charTypeName":"word"},{"id":87126,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/002_254_002.mp3","charTypeName":"word"},{"id":87127,"position":3,"arabic":"ءَامَنُوٓا۟","translation":"ঈমান এনেছ","audioUrl":"wbw/002_254_003.mp3","charTypeName":"word"},{"id":87128,"position":4,"arabic":"أَنفِقُوا۟","translation":"তোমরা ব্যয় করো","audioUrl":"wbw/002_254_004.mp3","charTypeName":"word"},{"id":87129,"position":5,"arabic":"مِمَّا","translation":"তা থেকে যা","audioUrl":"wbw/002_254_005.mp3","charTypeName":"word"},{"id":87130,"position":6,"arabic":"رَزَقْنَـٰكُم","translation":"তোমাদের আমরা জীবিকা দিয়েছি","audioUrl":"wbw/002_254_006.mp3","charTypeName":"word"},{"id":87131,"position":7,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/002_254_007.mp3","charTypeName":"word"},{"id":87132,"position":8,"arabic":"قَبْلِ","translation":"এর পূর্ব","audioUrl":"wbw/002_254_008.mp3","charTypeName":"word"},{"id":87133,"position":9,"arabic":"أَن","translation":"যে","audioUrl":"wbw/002_254_009.mp3","charTypeName":"word"},{"id":87134,"position":10,"arabic":"يَأْتِىَ","translation":"আসবে","audioUrl":"wbw/002_254_010.mp3","charTypeName":"word"},{"id":87135,"position":11,"arabic":"يَوْمٌۭ","translation":"দিন","audioUrl":"wbw/002_254_011.mp3","charTypeName":"word"},{"id":87136,"position":12,"arabic":"لَّا","translation":"না","audioUrl":"wbw/002_254_012.mp3","charTypeName":"word"},{"id":87137,"position":13,"arabic":"بَيْعٌۭ","translation":"কেনাবেচা হবে","audioUrl":"wbw/002_254_013.mp3","charTypeName":"word"},{"id":87138,"position":14,"arabic":"فِيهِ","translation":"তার মধ্যে","audioUrl":"wbw/002_254_014.mp3","charTypeName":"word"},{"id":87139,"position":15,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/002_254_015.mp3","charTypeName":"word"},{"id":87140,"position":16,"arabic":"خُلَّةٌۭ","translation":"বন্ধুত্ব","audioUrl":"wbw/002_254_016.mp3","charTypeName":"word"},{"id":87141,"position":17,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/002_254_017.mp3","charTypeName":"word"},{"id":87142,"position":18,"arabic":"شَفَـٰعَةٌۭ ۗ","translation":"সুপারিশ (কাজে আসবে)","audioUrl":"wbw/002_254_018.mp3","charTypeName":"word"},{"id":87144,"position":19,"arabic":"وَٱلْكَـٰفِرُونَ","translation":"এবং কাফিররা","audioUrl":"wbw/002_254_020.mp3","charTypeName":"word"},{"id":87145,"position":20,"arabic":"هُمُ","translation":"তারাই","audioUrl":"wbw/002_254_021.mp3","charTypeName":"word"},{"id":87146,"position":21,"arabic":"ٱلظَّـٰلِمُونَ","translation":"সীমালঙ্ঘনকারী","audioUrl":"wbw/002_254_022.mp3","charTypeName":"word"},{"id":87147,"position":22,"arabic":"٢٥٤","translation":"(২৫৪)","audioUrl":null,"charTypeName":"end"}]},{"number":255,"arabic":"ٱللَّهُ لَآ إِلَٰهَ إِلَّا هُوَ ٱلْحَىُّ ٱلْقَيُّومُ ۚ لَا تَأْخُذُهُۥ سِنَةٌۭ وَلَا نَوْمٌۭ ۚ لَّهُۥ مَا فِى ٱلسَّمَٰوَٰتِ وَمَا فِى ٱلْأَرْضِ ۗ مَن ذَا ٱلَّذِى يَشْفَعُ عِندَهُۥٓ إِلَّا بِإِذْنِهِۦ ۚ يَعْلَمُ مَا بَيْنَ أَيْدِيهِمْ وَمَا خَلْفَهُمْ ۖ وَلَا يُحِيطُونَ بِشَىْءٍۢ مِّنْ عِلْمِهِۦٓ إِلَّا بِمَا شَآءَ ۚ وَسِعَ كُرْسِيُّهُ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضَ ۖ وَلَا يَـُٔودُهُۥ حِفْظُهُمَا ۚ وَهُوَ ٱلْعَلِىُّ ٱلْعَظِيمُ","translation":"GOD - there is no deity save Him, the Ever-Living, the Self-Subsistent Fount of All Being. Neither slumber overtakes Him, nor sleep. His is all that is in the heavens and all that is on earth. Who is there that could intercede with Him, unless it be by His leave? He knows all that lies open before men and all that is hidden from them, whereas they cannot attain to aught of His knowledge save that which He wills [them to attain]. His eternal power overspreads the heavens and the earth, and their upholding wearies Him not. And he alone is truly exalted, tremendous.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/262.mp3","surahId":2,"words":[{"id":87148,"position":1,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/002_255_001.mp3","charTypeName":"word"},{"id":87149,"position":2,"arabic":"لَآ","translation":"নেই","audioUrl":"wbw/002_255_002.mp3","charTypeName":"word"},{"id":87150,"position":3,"arabic":"إِلَـٰهَ","translation":"কোনো ইলাহ","audioUrl":"wbw/002_255_003.mp3","charTypeName":"word"},{"id":87151,"position":4,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/002_255_004.mp3","charTypeName":"word"},{"id":87152,"position":5,"arabic":"هُوَ","translation":"তিনি","audioUrl":"wbw/002_255_005.mp3","charTypeName":"word"},{"id":87153,"position":6,"arabic":"ٱلْحَىُّ","translation":"চিরঞ্জীব","audioUrl":"wbw/002_255_006.mp3","charTypeName":"word"},{"id":87154,"position":7,"arabic":"ٱلْقَيُّومُ ۚ","translation":"সর্বসত্তার ধারক","audioUrl":"wbw/002_255_007.mp3","charTypeName":"word"},{"id":87156,"position":8,"arabic":"لَا","translation":"না","audioUrl":"wbw/002_255_009.mp3","charTypeName":"word"},{"id":87157,"position":9,"arabic":"تَأْخُذُهُۥ","translation":"তাকে স্পর্শ করতে পারে","audioUrl":"wbw/002_255_010.mp3","charTypeName":"word"},{"id":87158,"position":10,"arabic":"سِنَةٌۭ","translation":"তন্দ্রা","audioUrl":"wbw/002_255_011.mp3","charTypeName":"word"},{"id":87159,"position":11,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/002_255_012.mp3","charTypeName":"word"},{"id":87160,"position":12,"arabic":"نَوْمٌۭ ۚ","translation":"ঘুম","audioU