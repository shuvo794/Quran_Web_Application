{"id":115,"ayahs":[{"number":42,"arabic":"سَمَّٰعُونَ لِلْكَذِبِ أَكَّٰلُونَ لِلسُّحْتِ ۚ فَإِن جَآءُوكَ فَٱحْكُم بَيْنَهُمْ أَوْ أَعْرِضْ عَنْهُمْ ۖ وَإِن تُعْرِضْ عَنْهُمْ فَلَن يَضُرُّوكَ شَيْـًۭٔا ۖ وَإِنْ حَكَمْتَ فَٱحْكُم بَيْنَهُم بِٱلْقِسْطِ ۚ إِنَّ ٱللَّهَ يُحِبُّ ٱلْمُقْسِطِينَ","translation":"those who eagerly listen to any falsehood, greedily swallowing all that is evil! Hence, if they come to thee [for judgment], thou mayest either judge between them or leave them alone: for, if thou leave them alone, they cannot harm thee in any way. But if thou dost judge, judge between them with equity: verily, God knows those who act equitably.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/711.mp3","surahId":5,"words":[{"id":42921,"position":1,"arabic":"سَمَّـٰعُونَ","translation":"তারা শুনতে বেশি আগ্রহী","audioUrl":"wbw/005_042_001.mp3","charTypeName":"word"},{"id":42922,"position":2,"arabic":"لِلْكَذِبِ","translation":"প্রতি মিথ্যার","audioUrl":"wbw/005_042_002.mp3","charTypeName":"word"},{"id":42923,"position":3,"arabic":"أَكَّـٰلُونَ","translation":"অধিক ভক্ষণকারী","audioUrl":"wbw/005_042_003.mp3","charTypeName":"word"},{"id":42924,"position":4,"arabic":"لِلسُّحْتِ ۚ","translation":"জন্যে অবৈধ জিনিষের","audioUrl":"wbw/005_042_004.mp3","charTypeName":"word"},{"id":42926,"position":5,"arabic":"فَإِن","translation":"অতএব যদি","audioUrl":"wbw/005_042_006.mp3","charTypeName":"word"},{"id":42927,"position":6,"arabic":"جَآءُوكَ","translation":"তোমার কাছে আসে","audioUrl":"wbw/005_042_007.mp3","charTypeName":"word"},{"id":42928,"position":7,"arabic":"فَٱحْكُم","translation":"তবে বিচার করে দাও","audioUrl":"wbw/005_042_008.mp3","charTypeName":"word"},{"id":42929,"position":8,"arabic":"بَيْنَهُمْ","translation":"মাঝে তাদের","audioUrl":"wbw/005_042_009.mp3","charTypeName":"word"},{"id":42930,"position":9,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/005_042_010.mp3","charTypeName":"word"},{"id":42931,"position":10,"arabic":"أَعْرِضْ","translation":"উপেক্ষা করো","audioUrl":"wbw/005_042_011.mp3","charTypeName":"word"},{"id":42932,"position":11,"arabic":"عَنْهُمْ ۖ","translation":"থেকে তাদের (এটা তোমার ইচ্ছা)","audioUrl":"wbw/005_042_012.mp3","charTypeName":"word"},{"id":42934,"position":12,"arabic":"وَإِن","translation":"এবং যদি","audioUrl":"wbw/005_042_014.mp3","charTypeName":"word"},{"id":42935,"position":13,"arabic":"تُعْرِضْ","translation":"তুমি উপেক্ষা করো","audioUrl":"wbw/005_042_015.mp3","charTypeName":"word"},{"id":42936,"position":14,"arabic":"عَنْهُمْ","translation":"থেকে তাদের","audioUrl":"wbw/005_042_016.mp3","charTypeName":"word"},{"id":42937,"position":15,"arabic":"فَلَن","translation":"তবে কখনও না","audioUrl":"wbw/005_042_017.mp3","charTypeName":"word"},{"id":42938,"position":16,"arabic":"يَضُرُّوكَ","translation":"তারা তোমাকে ক্ষতি করতে পারবে","audioUrl":"wbw/005_042_018.mp3","charTypeName":"word"},{"id":42939,"position":17,"arabic":"شَيْـًۭٔا ۖ","translation":"কিছুমাত্র","audioUrl":"wbw/005_042_019.mp3","charTypeName":"word"},{"id":42941,"position":18,"arabic":"وَإِنْ","translation":"আর যদি","audioUrl":"wbw/005_042_021.mp3","charTypeName":"word"},{"id":42942,"position":19,"arabic":"حَكَمْتَ","translation":"তুমি বিচার করো","audioUrl":"wbw/005_042_022.mp3","charTypeName":"word"},{"id":42943,"position":20,"arabic":"فَٱحْكُم","translation":"তবে বিচার করো","audioUrl":"wbw/005_042_023.mp3","charTypeName":"word"},{"id":42944,"position":21,"arabic":"بَيْنَهُم","translation":"মাঝে তাদের","audioUrl":"wbw/005_042_024.mp3","charTypeName":"word"},{"id":42945,"position":22,"arabic":"بِٱلْقِسْطِ ۚ","translation":"সাথের ন্যায়ের","audioUrl":"wbw/005_042_025.mp3","charTypeName":"word"},{"id":42947,"position":23,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/005_042_027.mp3","charTypeName":"word"},{"id":42948,"position":24,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/005_042_028.mp3","charTypeName":"word"},{"id":42949,"position":25,"arabic":"يُحِبُّ","translation":"ভালবাসেন","audioUrl":"wbw/005_042_029.mp3","charTypeName":"word"},{"id":42950,"position":26,"arabic":"ٱلْمُقْسِطِينَ","translation":"ন্যায়বিচারকারীদেরকে","audioUrl":"wbw/005_042_030.mp3","charTypeName":"word"},{"id":42951,"position":27,"arabic":"٤٢","translation":"(৪২)","audioUrl":null,"charTypeName":"end"}]},{"number":43,"arabic":"وَكَيْفَ يُحَكِّمُونَكَ وَعِندَهُمُ ٱلتَّوْرَىٰةُ فِيهَا حُكْمُ ٱللَّهِ ثُمَّ يَتَوَلَّوْنَ مِنۢ بَعْدِ ذَٰلِكَ ۚ وَمَآ أُو۟لَٰٓئِكَ بِٱلْمُؤْمِنِينَ","translation":"But how is it that they ask thee for judgment seeing that they have the Torah, containing God's injunctions - and thereafter turn away [from thy judgment]? Such as these, then, are no [true] believers.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/712.mp3","surahId":5,"words":[{"id":43755,"position":1,"arabic":"وَكَيْفَ","translation":"এবং কিরূপে","audioUrl":"wbw/005_043_001.mp3","charTypeName":"word"},{"id":43756,"position":2,"arabic":"يُحَكِّمُونَكَ","translation":"তোমাকে তারা বিচারক মানবে","audioUrl":"wbw/005_043_002.mp3","charTypeName":"word"},{"id":43757,"position":3,"arabic":"وَعِندَهُمُ","translation":"অথচ কাছে (আছে)তাদের","audioUrl":"wbw/005_043_003.mp3","charTypeName":"word"},{"id":43758,"position":4,"arabic":"ٱلتَّوْرَىٰةُ","translation":"তাওরাত","audioUrl":"wbw/005_043_004.mp3","charTypeName":"word"},{"id":43759,"position":5,"arabic":"فِيهَا","translation":"মধ্যে তার(রয়েছে)","audioUrl":"wbw/005_043_005.mp3","charTypeName":"word"},{"id":43760,"position":6,"arabic":"حُكْمُ","translation":"নির্দেশ","audioUrl":"wbw/005_043_006.mp3","charTypeName":"word"},{"id":43761,"position":7,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/005_043_007.mp3","charTypeName":"word"},{"id":43762,"position":8,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/005_043_008.mp3","charTypeName":"word"},{"id":43763,"position":9,"arabic":"يَتَوَلَّوْنَ","translation":"তারা মুখ ফিরিয়ে নেয়","audioUrl":"wbw/005_043_009.mp3","charTypeName":"word"},{"id":43764,"position":10,"arabic":"مِنۢ","translation":"থেকেও","audioUrl":"wbw/005_043_010.mp3","charTypeName":"word"},{"id":43765,"position":11,"arabic":"بَعْدِ","translation":"পর","audioUrl":"wbw/005_043_011.mp3","charTypeName":"word"},{"id":43766,"position":12,"arabic":"ذَٰلِكَ ۚ","translation":"এর","audioUrl":"wbw/005_043_012.mp3","charTypeName":"word"},{"id":43768,"position":13,"arabic":"وَمَآ","translation":"এবং না","audioUrl":"wbw/005_043_014.mp3","charTypeName":"word"},{"id":43769,"position":14,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐসব লোক","audioUrl":"wbw/005_043_015.mp3","charTypeName":"word"},{"id":43770,"position":15,"arabic":"بِٱلْمُؤْمِنِينَ","translation":"মু’মিন","audioUrl":"wbw/005_043_016.mp3","charTypeName":"word"},{"id":43771,"position":16,"arabic":"٤٣","translation":"(৪৩)","audioUrl":null,"charTypeName":"end"}]},{"number":44,"arabic":"إِنَّآ أَنزَلْنَا ٱلتَّوْرَىٰةَ فِيهَا هُدًۭى وَنُورٌۭ ۚ يَحْكُمُ بِهَا ٱلنَّبِيُّونَ ٱلَّذِينَ أَسْلَمُوا۟ لِلَّذِينَ هَادُوا۟ وَٱلرَّبَّٰنِيُّونَ وَٱلْأَحْبَارُ بِمَا ٱسْتُحْفِظُوا۟ مِن كِتَٰبِ ٱللَّهِ وَكَانُوا۟ عَلَيْهِ شُهَدَآءَ ۚ فَلَا تَخْشَوُا۟ ٱلنَّاسَ وَٱخْشَوْنِ وَلَا تَشْتَرُوا۟ بِـَٔايَٰتِى ثَمَنًۭا قَلِيلًۭا ۚ وَمَن لَّمْ يَحْكُم بِمَآ أَنزَلَ ٱللَّهُ فَأُو۟لَٰٓئِكَ هُمُ ٱلْكَٰفِرُونَ","translation":"Verily, it is We who bestowed from on high the Torah, wherein there was guidance and light. On `its strength did the prophets, who had surrendered themselves unto God, deliver judgment unto those who followed the Jewish faith; and so did the [early] men of God and the rabbis, inasmuch as some of God's writ had been entrusted to their care; and they [all] bore witness to its truth. Therefore, [O children of Israel,] hold not men in awe, but stand in awe of Me; and do not barter away My messages for a trifling gain: for they who do not judge in accordance with what God has bestowed from on high are, indeed, deniers of the truth!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/713.mp3","surahId":5,"words":[{"id":44530,"position":1,"arabic":"إِنَّآ","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/005_044_001.mp3","charTypeName":"word"},{"id":44531,"position":2,"arabic":"أَنزَلْنَا","translation":"আমরা অবতীর্ণ করেছি","audioUrl":"wbw/005_044_002.mp3","charTypeName":"word"},{"id":44532,"position":3,"arabic":"ٱلتَّوْرَىٰةَ","translation":"তাওরাত","audioUrl":"wbw/005_044_003.mp3","charTypeName":"word"},{"id":44533,"position":4,"arabic":"فِيهَا","translation":"মধ্যে তার(ছিলো)","audioUrl":"wbw/005_044_004.mp3","charTypeName":"word"},{"id":44534,"position":5,"arabic":"هُدًۭى","translation":"পথনির্দেশ","audioUrl":"wbw/005_044_005.mp3","charTypeName":"word"},{"id":44535,"position":6,"arabic":"وَنُورٌۭ ۚ","translation":"ও আলো","audioUrl":"wbw/005_044_006.mp3","charTypeName":"word"},{"id":44537,"position":7,"arabic":"يَحْكُمُ","translation":"বিধান দিতেন","audioUrl":"wbw/005_044_008.mp3","charTypeName":"word"},{"id":44538,"position":8,"arabic":"بِهَا","translation":"দিয়ে তা","audioUrl":"wbw/005_044_009.mp3","charTypeName":"word"},{"id":44539,"position":9,"arabic":"ٱلنَّبِيُّونَ","translation":"নাবীগণ","audioUrl":"wbw/005_044_010.mp3","charTypeName":"word"},{"id":44540,"position":10,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/005_044_011.mp3","charTypeName":"word"},{"id":44541,"position":11,"arabic":"أَسْلَمُوا۟","translation":"আত্মসমর্পণ করেছিলো","audioUrl":"wbw/005_044_012.mp3","charTypeName":"word"},{"id":44542,"position":12,"arabic":"لِلَّذِينَ","translation":"জন্যে তাদের (যারা)","audioUrl":"wbw/005_044_013.mp3","charTypeName":"word"},{"id":44543,"position":13,"arabic":"هَادُوا۟","translation":"ইয়াহুদী হয়েছিলো","audioUrl":"wbw/005_044_014.mp3","charTypeName":"word"},{"id":44544,"position":14,"arabic":"وَٱلرَّبَّـٰنِيُّونَ","translation":"ও রব্বানিরা (বিধান দিতেন)","audioUrl":"wbw/005_044_015.mp3","charTypeName":"word"},{"id":44545,"position":15,"arabic":"وَٱلْأَحْبَارُ","translation":"ও পন্ডিতগণ","audioUrl":"wbw/005_044_016.mp3","charTypeName":"word"},{"id":44546,"position":16,