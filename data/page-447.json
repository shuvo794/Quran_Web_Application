,"translation":"(এই নাবী) এসেছে","audioUrl":"wbw/037_037_002.mp3","charTypeName":"word"},{"id":39398,"position":3,"arabic":"بِٱلْحَقِّ","translation":"সত্য নিয়ে","audioUrl":"wbw/037_037_003.mp3","charTypeName":"word"},{"id":39399,"position":4,"arabic":"وَصَدَّقَ","translation":"এবং সত্য বলে স্বীকার করেছে","audioUrl":"wbw/037_037_004.mp3","charTypeName":"word"},{"id":39400,"position":5,"arabic":"ٱلْمُرْسَلِينَ","translation":"(তাঁর পূর্বের) রাসূলদের","audioUrl":"wbw/037_037_005.mp3","charTypeName":"word"},{"id":39401,"position":6,"arabic":"٣٧","translation":"(৩৭)","audioUrl":null,"charTypeName":"end"}]},{"number":38,"arabic":"إِنَّكُمْ لَذَآئِقُوا۟ ٱلْعَذَابِ ٱلْأَلِيمِ","translation":"Behold, you will indeed taste grievous suffering [in the life to come],","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3826.mp3","surahId":37,"words":[{"id":40221,"position":1,"arabic":"إِنَّكُمْ","translation":"নিশ্চয়ই তোমার","audioUrl":"wbw/037_038_001.mp3","charTypeName":"word"},{"id":40222,"position":2,"arabic":"لَذَآئِقُوا۟","translation":"অবশ্যই স্বাদ ভোগকারী হবে","audioUrl":"wbw/037_038_002.mp3","charTypeName":"word"},{"id":40223,"position":3,"arabic":"ٱلْعَذَابِ","translation":"শাস্তির","audioUrl":"wbw/037_038_003.mp3","charTypeName":"word"},{"id":40224,"position":4,"arabic":"ٱلْأَلِيمِ","translation":"নিদারুণ","audioUrl":"wbw/037_038_004.mp3","charTypeName":"word"},{"id":40225,"position":5,"arabic":"٣٨","translation":"(৩৮)","audioUrl":null,"charTypeName":"end"}]},{"number":39,"arabic":"وَمَا تُجْزَوْنَ إِلَّا مَا كُنتُمْ تَعْمَلُونَ","translation":"although you shall not be requited for aught but what you were wont to do.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3827.mp3","surahId":37,"words":[{"id":40953,"position":1,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/037_039_001.mp3","charTypeName":"word"},{"id":40954,"position":2,"arabic":"تُجْزَوْنَ","translation":"প্রতিফল দেয়া হবে","audioUrl":"wbw/037_039_002.mp3","charTypeN