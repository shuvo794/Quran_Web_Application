3","charTypeName":"word"},{"id":4129,"position":28,"arabic":"يَكْفُرُونَ","translation":"তারা অস্বীকার করতে","audioUrl":"wbw/010_004_031.mp3","charTypeName":"word"},{"id":4130,"position":29,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"هُوَ ٱلَّذِى جَعَلَ ٱلشَّمْسَ ضِيَآءًۭ وَٱلْقَمَرَ نُورًۭا وَقَدَّرَهُۥ مَنَازِلَ لِتَعْلَمُوا۟ عَدَدَ ٱلسِّنِينَ وَٱلْحِسَابَ ۚ مَا خَلَقَ ٱللَّهُ ذَٰلِكَ إِلَّا بِٱلْحَقِّ ۚ يُفَصِّلُ ٱلْءَايَٰتِ لِقَوْمٍۢ يَعْلَمُونَ","translation":"He it is who has made the sun a [source of] radiant light and the moon a light [reflected], and has determined for it phases so that you might know how to compute the years and to measure [time]. None of this has God created without [an inner] truth. Clearly does He spell out these messages unto people of [innate] knowledge:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1369.mp3","surahId":10,"words":[{"id":5401,"position":1,"arabic":"هُوَ","translation":"তিনিই (আল্লাহ)","audioUrl":"wbw/010_005_001.mp3","charTypeName":"word"},{"id":5402,"position":2,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/010_005_002.mp3","charTypeName":"word"},{"id":5403,"position":3,"arabic":"جَعَلَ","translation":"বানিয়েছেন","audioUrl":"wbw/010_005_003.mp3","charTypeName":"word"},{"id":5404,"position":4,"arabic":"ٱلشَّمْسَ","translation":"সূর্যকে","audioUrl":"wbw/010_005_004.mp3","charTypeName":"word"},{"id":5405,"position":5,"arabic":"ضِيَآءًۭ","translation":"দীপ্তিময়","audioUrl":"wbw/010_005_005.mp3","charTypeName":"word"},{"id":5406,"position":6,"arabic":"وَٱلْقَمَرَ","translation":"ও চাঁদকে","audioUrl":"wbw/010_005_006.mp3","charTypeName":"word"},{"id":5407,"position":7,"arabic":"نُورًۭا","translation":"আলোকময়","audioUrl":"wbw/010_005_007.mp3","charTypeName":"word"},{"id":5408,"position":8,"arabic":"وَقَدَّرَهُۥ","translation":"ও তার জন্যে নির্দিষ্ট করেছেন","audioUrl":"wbw/010_005_008.mp3","charTypeName":"word"},{"id":5409,"position":9,"arabic":