,"charTypeName":"end"}]},{"number":6,"arabic":"إِنَّ فِى ٱخْتِلَٰفِ ٱلَّيْلِ وَٱلنَّهَارِ وَمَا خَلَقَ ٱللَّهُ فِى ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ لَءَايَٰتٍۢ لِّقَوْمٍۢ يَتَّقُونَ","translation":"for, verily, in the alternating of night and day, and in all that God has created in the heavens and on earth there are messages indeed for people who are conscious of Him!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1370.mp3","surahId":10,"words":[{"id":6633,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/010_006_001.mp3","charTypeName":"word"},{"id":6634,"position":2,"arabic":"فِى","translation":"মধ্যে (রয়েছে)","audioUrl":"wbw/010_006_002.mp3","charTypeName":"word"},{"id":6635,"position":3,"arabic":"ٱخْتِلَـٰفِ","translation":"পরিবর্তনে","audioUrl":"wbw/010_006_003.mp3","charTypeName":"word"},{"id":6636,"position":4,"arabic":"ٱلَّيْلِ","translation":"রাতের","audioUrl":"wbw/010_006_004.mp3","charTypeName":"word"},{"id":6637,"position":5,"arabic":"وَٱلنَّهَارِ","translation":"ও দিনের","audioUrl":"wbw/010_006_005.mp3","charTypeName":"word"},{"id":6638,"position":6,"arabic":"وَمَا","translation":"ও যা কিছু","audioUrl":"wbw/010_006_006.mp3","charTypeName":"word"},{"id":6639,"position":7,"arabic":"خَلَقَ","translation":"সৃষ্টি করেছেন","audioUrl":"wbw/010_006_007.mp3","charTypeName":"word"},{"id":6640,"position":8,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌","audioUrl":"wbw/010_006_008.mp3","charTypeName":"word"},{"id":6641,"position":9,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/010_006_009.mp3","charTypeName":"word"},{"id":6642,"position":10,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশসমূহের","audioUrl":"wbw/010_006_010.mp3","charTypeName":"word"},{"id":6643,"position":11,"arabic":"وَٱلْأَرْضِ","translation":"ও পৃথিবীর","audioUrl":"wbw/010_006_011.mp3","charTypeName":"word"},{"id":6644,"position":12,"arabic":"لَـَٔايَـٰتٍۢ","translation":"অবশ্যই নিদর্শনসমূহ","audioUrl":"wbw/010_006_012.mp3","charTypeName":"word"},{"id":6645,"posit