{"id":208,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ الٓر ۚ تِلْكَ ءَايَٰتُ ٱلْكِتَٰبِ ٱلْحَكِيمِ","translation":"Alif Lam. Ra. THESE ARE MESSAGES of the divine writ, full of wisdom.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1365.mp3","surahId":10,"words":[{"id":340,"position":1,"arabic":"الٓر ۚ","translation":"আলিফ- লাম- রা","audioUrl":"wbw/010_001_001.mp3","charTypeName":"word"},{"id":342,"position":2,"arabic":"تِلْكَ","translation":"এই","audioUrl":"wbw/010_001_003.mp3","charTypeName":"word"},{"id":343,"position":3,"arabic":"ءَايَـٰتُ","translation":"এই আয়াতগুলো","audioUrl":"wbw/010_001_004.mp3","charTypeName":"word"},{"id":344,"position":4,"arabic":"ٱلْكِتَـٰبِ","translation":"(এমন) কিতাবের","audioUrl":"wbw/010_001_005.mp3","charTypeName":"word"},{"id":345,"position":5,"arabic":"ٱلْحَكِيمِ","translation":"(যা)প্রজ্ঞাপূর্ণ","audioUrl":"wbw/010_001_006.mp3","charTypeName":"word"},{"id":346,"position":6,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"أَكَانَ لِلنَّاسِ عَجَبًا أَنْ أَوْحَيْنَآ إِلَىٰ رَجُلٍۢ مِّنْهُمْ أَنْ أَنذِرِ ٱلنَّاسَ وَبَشِّرِ ٱلَّذِينَ ءَامَنُوٓا۟ أَنَّ لَهُمْ قَدَمَ صِدْقٍ عِندَ رَبِّهِمْ ۗ قَالَ ٱلْكَٰفِرُونَ إِنَّ هَٰذَا لَسَٰحِرٌۭ مُّبِينٌ","translation":"Do people deem it strange that We should have inspired a man from their own midst [with this Our message]: \"Warn all mankind, and give unto those who have attained to faith the glad tiding that in their Sustainer's sight they surpass all others in that they are completely sincere-? [Only] they who deny the truth say, \"Behold. he is clearly but a spellbinder!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1366.mp3","surahId":10,"words":[{"id":1585,"position":1,"arabic":"أَكَانَ","translation":"কি হয়েছে","audioUrl":"wbw/010_002_001.mp3","charTypeName":"word"},{"id":1586,"position":2,"arabic":"لِلنَّاسِ","translation":"জন্যে মানুষের","audioUrl":"wbw/010_002_002.mp3","charTypeName":"word"},{"id":1587,"position":3,"arabic":"عَجَبًا","translation":"আশ্চর্যজনক","audioUrl":"wbw/010_002_003.mp3","charTypeName":"word"},{"id":1588,"position":4,"arabic":"أَنْ","translation":"যে","audioUrl":"wbw/010_002_004.mp3","charTypeName":"word"},{"id":1589,"position":5,"arabic":"أَوْحَيْنَآ","translation":"আমরা ওহী পাঠিয়েছি","audioUrl":"wbw/010_002_005.mp3","charTypeName":"word"},{"id":1590,"position":6,"arabic":"إِلَىٰ","translation":"প্রতি","audioUrl":"wbw/010_002_006.mp3","charTypeName":"word"},{"id":1591,"position":7,"arabic":"رَجُلٍۢ","translation":"একজন ব্যক্তির","audioUrl":"wbw/010_002_007.mp3","charTypeName":"word"},{"id":1592,"position":8,"arabic":"مِّنْهُمْ","translation":"মধ্য হতে তাদেরই","audioUrl":"wbw/010_002_008.mp3","charTypeName":"word"},{"id":1593,"position":9,"arabic":"أَنْ","translation":"যে","audioUrl":"wbw/010_002_009.mp3","charTypeName":"word"},{"id":1594,"position":10,"arabic":"أَنذِرِ","translation":"\"সতর্ক করো","audioUrl":"wbw/010_002_010.mp3","charTypeName":"word"},{"id":1595,"position":11,"arabic":"ٱلنَّاسَ","translation":"মানুষকে","audioUrl":"wbw/010_002_011.mp3","charTypeName":"word"},{"id":1596,"position":12,"arabic":"وَبَشِّرِ","translation":"ও সুসংবাদ দাও","audioUrl":"wbw/010_002_012.mp3","charTypeName":"word"},{"id":1597,"position":13,"arabic":"ٱلَّذِينَ","translation":"(তাদেরকে) যারা","audioUrl":"wbw/010_002_013.mp3","charTypeName":"word"},{"id":1598,"position":14,"arabic":"ءَامَنُوٓا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/010_002_014.mp3","charTypeName":"word"},{"id":1599,"position":15,"arabic":"أَنَّ","translation":"যে","audioUrl":"wbw/010_002_015.mp3","charTypeName":"word"},{"id":1600,"position":16,"arabic":"لَهُمْ","translation":"জন্যে তাদের (রয়েছে)","audioUrl":"wbw/010_002_016.mp3","charTypeName":"word"},{"id":1601,"position":17,"arabic":"قَدَمَ","translation":"পদ (মর্যাদা)","audioUrl":"wbw/010_002_017.mp3","charTypeName":"word"},{"id":1602,"position":18,"arabic":"صِدْقٍ","translation":"সত্যিকার","audioUrl":"wbw/010_002_018.mp3","charTypeName":"word"},{"id":1603,"position":19,"arabic":"عِندَ","translation":"কাছে","audioUrl":"wbw/010_002_019.mp3","charTypeName":"word"},{"id":1604,"position":20,"arabic":"رَبِّهِمْ ۗ","translation":"রবের তাদের\"","audioUrl":"wbw/010_002_020.mp3","charTypeName":"word"},{"id":1606,"position":21,"arabic":"قَالَ","translation":"(এ কথাই) বলেছে","audioUrl":"wbw/010_002_022.mp3","charTypeName":"word"},{"id":1607,"position":22,"arabic":"ٱلْكَـٰفِرُونَ","translation":"কাফিররা","audioUrl":"wbw/010_002_023.mp3","charTypeName":"word"},{"id":1608,"position":23,"arabic":"إِنَّ","translation":"\"নিশ্চয়ই","audioUrl":"wbw/010_002_024.mp3","charTypeName":"word"},{"id":1609,"position":24,"arabic":"هَـٰذَا","translation":"এই (ব্যক্তি)","audioUrl":"wbw/010_002_025.mp3","charTypeName":"word"},{"id":1610,"position":25,"arabic":"لَسَـٰحِرٌۭ","translation":"অবশ্যই জাদুকর","audioUrl":"wbw/010_002_026.mp3","charTypeName":"word"},{"id":1611,"position":26,"arabic":"مُّبِينٌ","translation":"সুস্পষ্ট\"","audioUrl":"wbw/010_002_027.mp3","charTypeName":"word"},{"id":1612,"position":27,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"إِنَّ رَبَّكُمُ ٱللَّهُ ٱلَّذِى خَلَقَ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضَ فِى سِتَّةِ أَيَّامٍۢ ثُمَّ ٱسْتَوَىٰ عَلَى ٱلْعَرْشِ ۖ يُدَبِّرُ ٱلْأَمْرَ ۖ مَا مِن شَفِيعٍ إِلَّا مِنۢ بَعْدِ إِذْنِهِۦ ۚ ذَٰلِكُمُ ٱللَّهُ رَبُّكُمْ فَٱعْبُدُوهُ ۚ أَفَلَا تَذَكَّرُونَ","translation":"VERILY, your Sustainer is God, who has created the heavens and the earth in six aeons, and is established on the throne of His almightiness, governing all that exists. There is none that could intercede with Him unless He grants leave therefor. Thus is God, your Sustainer: worship, therefore, Him [alone]: will you not, then, keep this in mind?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1367.mp3","surahId":10,"words":[{"id":2712,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/010_003_001.mp3","charTypeName":"word"},{"id":2713,"position":2,"arabic":"رَبَّكُمُ","translation":"রব তোমাদের","audioUrl":"wbw/010_003_002.mp3","charTypeName":"word"},{"id":2714,"position":3,"arabic":"ٱللَّهُ","translation":"(সেই) আল্লাহ","audioUrl":"wbw/010_003_003.mp3","charTypeName":"word"},{"id":2715,"position":4,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/010_003_004.mp3","charTypeName":"word"},{"id":2716,"position":5,"arabic":"خَلَقَ","translation":"সৃষ্টি করেছেন","audioUrl":"wbw/010_003_005.mp3","charTypeName":"word"},{"id":2717,"position":6,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশসমূহকে","audioUrl":"wbw/010_003_006.mp3","charTypeName":"word"},{"id":2718,"position":7,"arabic":"وَٱلْأَرْضَ","translation":"ও পৃথিবীকে","audioUrl":"wbw/010_003_007.mp3","charTypeName":"word"},{"id":2719,"position":8,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/010_003_008.mp3","charTypeName":"word"},{"id":2720,"position":9,"arabic":"سِتَّةِ","translation":"ছয়টি","audioUrl":"wbw/010_003_009.mp3","charTypeName":"word"},{"id":2721,"position":10,"arabic":"أَيَّامٍۢ","translation":"দিনে","audioUrl":"wbw/010_003_010.mp3","charTypeName":"word"},{"id":2722,"position":11,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/010_003_011.mp3","charTypeName":"word"},{"id":2723,"position":12,"arabic":"ٱسْتَوَىٰ","translation":"সমাসীন হয়েছেন","audioUrl":"wbw/010_003_012.mp3","charTypeName":"word"},{"id":2724,"position":13,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/010_003_013.mp3","charTypeName":"word"},{"id":2725,"position":14,"arabic":"ٱلْعَرْشِ ۖ","translation":"আরশের","audioUrl":"wbw/010_003_014.mp3","charTypeName":"word"},{"id":2727,"position":15,"arabic":"يُدَبِّرُ","translation":"পরিচালনা করেন","audioUrl":"wbw/010_003_016.mp3","charTypeName":"word"},{"id":2728,"position":16,"arabic":"ٱلْأَمْرَ ۖ","translation":"সকল (বিষয়)","audioUrl":"wbw/010_003_017.mp3","charTypeName":"word"},{"id":2730,"position":17,"arabic":"مَا","translation":"নেই","audioUrl":"wbw/010_003_019.m