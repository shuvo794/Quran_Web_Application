ation":"Unto Him you all must return: this is, in truth, God's promise-for, behold, He creates [man] in the first instance, and then brings him forth anew to the end that He may reward with equity all who attain to faith and do righteous deeds; whereas for those who are bent on denying the truth there is in store a draught of burning despair and grievous suffering because of their persistent refusal to acknowledge the truth.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1368.mp3","surahId":10,"words":[{"id":4099,"position":1,"arabic":"إِلَيْهِ","translation":"দিকে তাঁরই","audioUrl":"wbw/010_004_001.mp3","charTypeName":"word"},{"id":4100,"position":2,"arabic":"مَرْجِعُكُمْ","translation":"তোমাদের প্রত্যাবর্তন","audioUrl":"wbw/010_004_002.mp3","charTypeName":"word"},{"id":4101,"position":3,"arabic":"جَمِيعًۭا ۖ","translation":"সকলেরই","audioUrl":"wbw/010_004_003.mp3","charTypeName":"word"},{"id":4103,"position":4,"arabic":"وَعْدَ","translation":"(এটা)প্রতিশ্রুতি","audioUrl":"wbw/010_004_005.mp3","charTypeName":"word"},{"id":4104,"position":5,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/010_004_006.mp3","charTypeName":"word"},{"id":4105,"position":6,"arabic":"حَقًّا ۚ","translation":"সত্য","audioUrl":"wbw/010_004_007.mp3","charTypeName":"word"},{"id":4107,"position":7,"arabic":"إِنَّهُۥ","translation":"নিশ্চয়ই তিনি","audioUrl":"wbw/010_004_009.mp3","charTypeName":"word"},{"id":4108,"position":8,"arabic":"يَبْدَؤُا۟","translation":"প্রথম অস্তিত্বে আনেন","audioUrl":"wbw/010_004_010.mp3","charTypeName":"word"},{"id":4109,"position":9,"arabic":"ٱلْخَلْقَ","translation":"সৃষ্টিকে","audioUrl":"wbw/010_004_011.mp3","charTypeName":"word"},{"id":4110,"position":10,"arabic":"ثُمَّ","translation":"অতঃপর","audioUrl":"wbw/010_004_012.mp3","charTypeName":"word"},{"id":4111,"position":11,"arabic":"يُعِيدُهُۥ","translation":"পুনরাবর্তন করবেন তার","audioUrl":"wbw/010_004_013.mp3","charTypeName":"word"},{"id":4112,"position":12,"arabic":"لِيَجْزِىَ","tra