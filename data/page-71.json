id":81740,"position":31,"arabic":"١٥٩","translation":"(১৫৯)","audioUrl":null,"charTypeName":"end"}]},{"number":160,"arabic":"إِن يَنصُرْكُمُ ٱللَّهُ فَلَا غَالِبَ لَكُمْ ۖ وَإِن يَخْذُلْكُمْ فَمَن ذَا ٱلَّذِى يَنصُرُكُم مِّنۢ بَعْدِهِۦ ۗ وَعَلَى ٱللَّهِ فَلْيَتَوَكَّلِ ٱلْمُؤْمِنُونَ","translation":"If God succours you, none can ever overcome you; but if He should forsake you, who could succour you thereafter? In God, then, let the believers place their trust!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/453.mp3","surahId":3,"words":[{"id":81777,"position":1,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/003_160_001.mp3","charTypeName":"word"},{"id":81778,"position":2,"arabic":"يَنصُرْكُمُ","translation":"তোমাদের সাহায্য করেন","audioUrl":"wbw/003_160_002.mp3","charTypeName":"word"},{"id":81779,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/003_160_003.mp3","charTypeName":"word"},{"id":81780,"position":4,"arabic":"فَلَا","translation":"না তবে","audioUrl":"wbw/003_160_004.mp3","charTypeName":"word"},{"id":81781,"position":5,"arabic":"غَالِبَ","translation":"বিজয়ী হবে কেউ","audioUrl":"wbw/003_160_005.mp3","charTypeName":"word"},{"id":81782,"position":6,"arabic":"لَكُمْ ۖ","translation":"তোমাদের উপর","audioUrl":"wbw/003_160_006.mp3","charTypeName":"word"},{"id":81784,"position":7,"arabic":"وَإِن","translation":"আর যদি","audioUrl":"wbw/003_160_008.mp3","charTypeName":"word"},{"id":81785,"position":8,"arabic":"يَخْذُلْكُمْ","translation":"তোমাদের তিনি ত্যাগ করেন","audioUrl":"wbw/003_160_009.mp3","charTypeName":"word"},{"id":81786,"position":9,"arabic":"فَمَن","translation":"কে তবে","audioUrl":"wbw/003_160_010.mp3","charTypeName":"word"},{"id":81787,"position":10,"arabic":"ذَا","translation":"এমন","audioUrl":"wbw/003_160_011.mp3","charTypeName":"word"},{"id":81788,"position":11,"arabic":"ٱلَّذِى","translation":"(আছে) যে","audioUrl":"wbw/003_160_012.mp3","charTypeName":"word"},{"id":81789,"position":12,"arabic":"يَنصُرُكُم","translation":"তোমাদের সাাহায্য করতে পারে","audioUrl":"wbw/003_160_013.mp3","charTypeName":"word"},{"id":81790,"position":13,"arabic":"مِّنۢ","translation":"(থেকে)","audioUrl":"wbw/003_160_014.mp3","charTypeName":"word"},{"id":81791,"position":14,"arabic":"بَعْدِهِۦ ۗ","translation":"তারপরে","audioUrl":"wbw/003_160_015.mp3","charTypeName":"word"},{"id":81793,"position":15,"arabic":"وَعَلَى","translation":"এবং উপর","audioUrl":"wbw/003_160_017.mp3","charTypeName":"word"},{"id":81794,"position":16,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌রই","audioUrl":"wbw/003_160_018.mp3","charTypeName":"word"},{"id":81795,"position":17,"arabic":"فَلْيَتَوَكَّلِ","translation":"ভরসা করা উচিত","audioUrl":"wbw/003_160_019.mp3","charTypeName":"word"},{"id":81796,"position":18,"arabic":"ٱلْمُؤْمِنُونَ","translation":"ঈমানদারদের","audioUrl":"wbw/003_160_020.mp3","charTypeName":"word"},{"id":81797,"position":19,"arabic":"١٦٠","translation":"(১৬০)","audioUrl":null,"charTypeName":"end"}]},{"number":161,"arabic":"وَمَا كَانَ لِنَبِىٍّ أَن يَغُلَّ ۚ وَمَن يَغْلُلْ يَأْتِ بِمَا غَلَّ يَوْمَ ٱلْقِيَٰمَةِ ۚ ثُمَّ تُوَفَّىٰ كُلُّ نَفْسٍۢ مَّا كَسَبَتْ وَهُمْ لَا يُظْلَمُونَ","translation":"AND IT IS not conceivable that a prophet should deceive - since he who deceives shall be faced with his deceit on the Day of Resurrection, when every human being shall be repaid in full for whatever he has done, and none shall be wronged.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/454.mp3","surahId":3,"words":[{"id":81928,"position":1,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/003_161_001.mp3","charTypeName":"word"},{"id":81929,"position":2,"arabic":"كَانَ","translation":"(শোভনীয়) হতে পারে","audioUrl":"wbw/003_161_002.mp3","charTypeName":"word"},{"id":81930,"position":3,"arabic":"لِنَبِىٍّ","translation":"নবীর জন্য","audioUrl":"wbw/003_161_003.mp3","charTypeName":"word"},{"id":81931,"position":4,"arabic":"أَن","translation":"যে","audioUrl":"wbw/003_161_004.mp3","charTypeName":"word"},{"id":81932,"position":5,"arabic":"يَغُلَّ ۚ","translation":"সে খিয়ানত করবে","audioUrl":"wbw/003_161_005.mp3","charTypeName":"word"},{"id":81934,"position":6,"arabic":"وَمَن","translation":"এবং যে","audioUrl":"wbw/003_161_007.mp3","charTypeName":"word"},{"id":81935,"position":7,"arabic":"يَغْلُلْ","translation":"খিয়ানত করবে","audioUrl":"wbw/003_161_008.mp3","charTypeName":"word"},{"id":81936,"position":8,"arabic":"يَأْتِ","translation":"সে আসবে","audioUrl":"wbw/003_161_009.mp3","charTypeName":"word"},{"id":81937,"position":9,"arabic":"بِمَا","translation":"তা নিয়ে যা","audioUrl":"wbw/003_161_010.mp3","charTypeName":"word"},{"id":81938,"position":10,"arabic":"غَلَّ","translation":"খিয়ানত করেছিল","audioUrl":"wbw/003_161_011.mp3","charTypeName":"word"},{"id":81939,"position":11,"arabic":"يَوْمَ","translation":"দিনে","audioUrl":"wbw/003_161_012.mp3","charTypeName":"word"},{"id":81940,"position":12,"arabic":"ٱلْقِيَـٰمَةِ ۚ","translation":"কিয়ামাতের","audioUrl":"wbw/003_161_013.mp3","charTypeName":"word"},{"id":81942,"position":13,"arabic":"ثُمَّ","translation":"অতঃপর","audioUrl":"wbw/003_161_015.mp3","charTypeName":"word"},{"id":81943,"position":14,"arabic":"تُوَفَّىٰ","translation":"দেয়া হবে পুরাপুরি","audioUrl":"wbw/003_161_016.mp3","charTypeName":"word"},{"id":81944,"position":15,"arabic":"كُلُّ","translation":"প্রত্যেক","audioUrl":"wbw/003_161_017.mp3","charTypeName":"word"},{"id":81945,"position":16,"arabic":"نَفْسٍۢ","translation":"ব্যক্তিকে","audioUrl":"wbw/003_161_018.mp3","charTypeName":"word"},{"id":81946,"position":17,"arabic":"مَّا","translation":"যা","audioUrl":"wbw/003_161_019.mp3","charTypeName":"word"},{"id":81947,"position":18,"arabic":"كَسَبَتْ","translation":"সে অর্জন করেছে","audioUrl":"wbw/003_161_020.mp3","charTypeName":"word"},{"id":81948,"position":19,"arabic":"وَهُمْ","translation":"এবং তাদের উপর","audioUrl":"wbw/003_161_021.mp3","charTypeName":"word"},{"id":81949,"position":20,"arabic":"لَا","translation":"না","audioUrl":"wbw/003_161_022.mp3","charTypeName":"word"},{"id":81950,"position":21,"arabic":"يُظْلَمُونَ","translation":"জুলুম করা হবে","audioUrl":"wbw/003_161_023.mp3","charTypeName":"word"},{"id":81951,"position":22,"arabic":"١٦١","translation":"(১৬১)","audioUrl":null,"charTypeName":"end"}]},{"number":162,"arabic":"أَفَمَنِ ٱتَّبَعَ رِضْوَٰنَ ٱللَّهِ كَمَنۢ بَآءَ بِسَخَطٍۢ مِّنَ ٱللَّهِ وَمَأْوَىٰهُ جَهَنَّمُ ۚ وَبِئْسَ ٱلْمَصِيرُ","translation":"Is then he who strives after God's goodly acceptance like unto him who has earned the burden of God's condemnation and whose goal is hell? - and how vile a journey's end!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/455.mp3","surahId":3,"words":[{"id":81974,"position":1,"arabic":"أَفَمَنِ","translation":"তবে কি যে","audioUrl":"wbw/003_162_001.mp3","charTypeName":"word"},{"id":81975,"position":2,"arabic":"ٱتَّبَعَ","translation":"অনুসরণ করল","audioUrl":"wbw/003_162_002.mp3","charTypeName":"word"},{"id":81976,"position":3,"arabic":"رِضْوَٰنَ","translation":"সন্তুষ্টির","audioUrl":"wbw/003_162_003.mp3","charTypeName":"word"},{"id":81977,"position":4,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/003_162_004.mp3","charTypeName":"word"},{"id":81978,"position":5,"arabic":"كَمَنۢ","translation":"তার মত যে","audioUrl":"wbw/003_162_005.mp3","charTypeName":"word"},{"id":81979,"position":6,"arabic":"بَآءَ","translation":"পরিবেষ্টিত হয়েছে","audioUrl":"wbw/003_162_006.mp3","charTypeName":"word"},{"id":81980,"position":7,"arabic":"بِسَخَطٍۢ","translation":"অসন্তুষ্টি দ্বারা","audioUrl":"wbw/003_162_007.mp3","charTypeName":"word"},{"id":81981,"position":8,"arabic":"مِّنَ","translation":"পক্ষ হতে","audioUrl":"wbw/003_162_008.mp3","charTypeName":"word"},{"id":81982,"position":9,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/003_162_009.mp3","charTypeName":"word"},{"id":81983,"position":10,"arabic":"وَمَأْوَىٰهُ","translation":"এবং তার ঠিকানা","audioUrl":"wbw/003_162_010.mp3","charTypeName":"word"},{"id":81984,"position":11,"arabic":"جَهَنَّمُ ۚ","translation":"জাহান্নাম","audioUrl":"wbw/003_162_011.mp3","charTypeName":"word"},{"id":81986,"position":12,"arabic":"وَبِئْسَ","translation":"এবং (তা) অতি খারাপ","audioUrl":"wbw/003_162_013.mp3","charTypeName":"word"},{"id":81987,"position":13,"arabic":"ٱلْمَصِيرُ","translation":"গন্তব্যস্থান","audioUrl":"wbw/003_162_014.mp3","charTypeName":"word"},{"id":81988,"position":14,"arabic":"١٦٢","translation":"(১৬২)","audioUrl":null,"charTypeName":"end"}]},{"number":163,"arabic":"هُمْ دَرَجَٰتٌ عِندَ ٱللَّهِ ۗ وَٱللَّهُ بَصِيرٌۢ بِمَا يَعْمَلُونَ","translation":"They are on [entirely] different levels in the sight of God; for God sees all that they do.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/456.mp3","surahId":3,"words":[{"id":82146,"position":1,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/003_163_001.mp3","charTypeName":"word"},{"id":82147,"position":2,"arabic":"دَرَجَـٰتٌ","translation":"মর্যাদার (এক নয়)","audioUrl":"wbw/003_163_002.mp3","charTypeName":"word"},{"id":82148,"position":3,"arabic":"عِندَ","translation":"কাছে","audioUrl":"wbw/003_163_003.mp3","charTypeName":"word"},{"id":82149,"position":4,"arabic":"ٱللَّهِ ۗ","translation":"আল্লাহ","audioUrl":"wbw/003_163_004.mp3","charTypeName":"word"},{"id":82151,"position":5,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/003_163_006.mp3","charTypeName":"word"},{"id":82152,"position":6,"arabic":"بَصِيرٌۢ","translation":"খুব দেখেন","audioUrl":"wbw/003_163_007.mp3","charTypeName":"word"},{"id":82153,"position":7,"arabic":"بِمَا","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/003_163_008.mp3","charTypeName":"word"},{"id":82154,"position":8,"arabic":"يَعْمَلُونَ","translation":"তারা কাজ করছে","audioUrl":"wbw/003_163_009.mp3","charTypeName":"word"},{"id":82155,"position":9,"arabic":"١٦٣","translation":"(১৬৩)","audioUrl":null,"charTypeName":"end"}]},{"number":164,"arabic":"لَقَدْ مَنَّ ٱللَّهُ عَلَى ٱلْمُؤْمِنِينَ إِذْ بَعَثَ فِيهِمْ رَسُولًۭا مِّنْ أَنفُسِهِمْ يَتْلُوا۟ عَلَيْهِمْ ءَايَٰتِهِۦ وَيُزَكِّيهِمْ وَيُعَلِّمُهُمُ ٱلْكِتَٰبَ وَٱلْحِكْمَةَ وَإِن كَانُوا۟ مِن قَبْلُ لَفِى ضَلَٰلٍۢ مُّبِينٍ","translation":"Indeed, God bestowed a favour upon the believers when he raised up in their midst an apostle from among themselves, to convey His messages unto them, and to cause them to grow in purity, and to impart unto them the divine writ as well as wisdom - whereas before that they were indeed, most obviously, lost in error.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/457.mp3","surahId":3,"words":[{"id":82302,"position":1,"arabic":"لَقَدْ","translation":"নিশ্চয়","audioUrl":"wbw/003_164_001.mp3","charTypeName":"word"},{"id":82303,"position":2,"arabic":"مَنَّ","translation":"অনুগ্রহ করেছেন","audioUrl":"wbw/003_164_002.mp3","charTypeName":"word"},{"id":82304,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/003_164_003.mp3","charTypeName":"word"},{"id":82305,"position":4,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/003_164_004.mp3","charTypeName":"word"},{"id":82306,"position":5,"arabic":"ٱلْمُؤْمِنِينَ","translation":"মু'মিনদের","audioUrl":"wbw/003_164_005.mp3","charTypeName":"word"},{"id":82307,"position":6,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/003_164_006.mp3","charTypeName":"word"},{"id":82308,"position":7,"arabic":"بَعَثَ","translation":"প্রেরণ করেন","audioUrl":"wbw/003_164_007.mp3","charTypeName":"word"},{"id":82309,"position":8,"arabic":"فِيهِمْ","translation":"তাদের মধ্যে","audioUrl":"wbw/003_164_008.mp3","charTypeName":"word"},{"id":82310,"position":9,"arabic":"رَسُولًۭا","translation":"একজন রাসূল","audioUrl":"wbw/003_164_009.mp3","charTypeName":"word"},{"id":82311,"position":10,"arabic":"مِّنْ","translation":"মধ্য হতে","audioUrl":"wbw/003_164_010.mp3","charTypeName":"word"},{"id":82312,"position":11,"arabic":"أَنفُسِهِمْ","translation":"তাদের নিজেদের","audioUrl":"wbw/003_164_011.mp3","charTypeName":"word"},{"id":82313,"position":12,"arabic":"يَتْلُوا۟"