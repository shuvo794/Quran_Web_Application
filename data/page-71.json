{"id":71,"ayahs":[{"number":158,"arabic":"وَلَئِن مُّتُّمْ أَوْ قُتِلْتُمْ لَإِلَى ٱللَّهِ تُحْشَرُونَ","translation":"for, indeed, if you die or are slain, it will surely be unto God that you shall be gathered.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/451.mp3","surahId":3,"words":[{"id":81607,"position":1,"arabic":"وَلَئِن","translation":"এবং অবশ্যই যদি","audioUrl":"wbw/003_158_001.mp3","charTypeName":"word"},{"id":81608,"position":2,"arabic":"مُّتُّمْ","translation":"তোমরা মারা যাও","audioUrl":"wbw/003_158_002.mp3","charTypeName":"word"},{"id":81609,"position":3,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/003_158_003.mp3","charTypeName":"word"},{"id":81610,"position":4,"arabic":"قُتِلْتُمْ","translation":"তোমরা নিহত হও","audioUrl":"wbw/003_158_004.mp3","charTypeName":"word"},{"id":81611,"position":5,"arabic":"لَإِلَى","translation":"দিকে অবশ্যই","audioUrl":"wbw/003_158_005.mp3","charTypeName":"word"},{"id":81612,"position":6,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/003_158_006.mp3","charTypeName":"word"},{"id":81613,"position":7,"arabic":"تُحْشَرُونَ","translation":"তোমাদের একত্রিত করা হবে","audioUrl":"wbw/003_158_007.mp3","charTypeName":"word"},{"id":81614,"position":8,"arabic":"١٥٨","translation":"(১৫৮)","audioUrl":null,"charTypeName":"end"}]},{"number":159,"arabic":"فَبِمَا رَحْمَةٍۢ مِّنَ ٱللَّهِ لِنتَ لَهُمْ ۖ وَلَوْ كُنتَ فَظًّا غَلِيظَ ٱلْقَلْبِ لَٱنفَضُّوا۟ مِنْ حَوْلِكَ ۖ فَٱعْفُ عَنْهُمْ وَٱسْتَغْفِرْ لَهُمْ وَشَاوِرْهُمْ فِى ٱلْأَمْرِ ۖ فَإِذَا عَزَمْتَ فَتَوَكَّلْ عَلَى ٱللَّهِ ۚ إِنَّ ٱللَّهَ يُحِبُّ ٱلْمُتَوَكِّلِينَ","translation":"And it was by God's grace that thou [O Prophet] didst deal gently with thy followers: for if thou hadst been harsh and hard of heart, they would indeed have broken away from thee. Pardon them, then, and pray that they be forgiven. And take counsel with them in all matters of public concern; then, when thou hast decided upon a course of action, place thy trust in God: for, verily, God loves those who place their trust in Him.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/452.mp3","surahId":3,"words":[{"id":81706,"position":1,"arabic":"فَبِمَا","translation":"বস্তুত কারণে","audioUrl":"wbw/003_159_001.mp3","charTypeName":"word"},{"id":81707,"position":2,"arabic":"رَحْمَةٍۢ","translation":"অনুগ্রহের","audioUrl":"wbw/003_159_002.mp3","charTypeName":"word"},{"id":81708,"position":3,"arabic":"مِّنَ","translation":"পক্ষ হতে","audioUrl":"wbw/003_159_003.mp3","charTypeName":"word"},{"id":81709,"position":4,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/003_159_004.mp3","charTypeName":"word"},{"id":81710,"position":5,"arabic":"لِنتَ","translation":"তুমি নরম হয়েছ","audioUrl":"wbw/003_159_005.mp3","charTypeName":"word"},{"id":81711,"position":6,"arabic":"لَهُمْ ۖ","translation":"তাদের জন্য","audioUrl":"wbw/003_159_006.mp3","charTypeName":"word"},{"id":81713,"position":7,"arabic":"وَلَوْ","translation":"এবং যদি","audioUrl":"wbw/003_159_008.mp3","charTypeName":"word"},{"id":81714,"position":8,"arabic":"كُنتَ","translation":"তুমি হতে","audioUrl":"wbw/003_159_009.mp3","charTypeName":"word"},{"id":81715,"position":9,"arabic":"فَظًّا","translation":"উগ্র স্বভাব","audioUrl":"wbw/003_159_010.mp3","charTypeName":"word"},{"id":81716,"position":10,"arabic":"غَلِيظَ","translation":"পাষাণ","audioUrl":"wbw/003_159_011.mp3","charTypeName":"word"},{"id":81717,"position":11,"arabic":"ٱلْقَلْبِ","translation":"হৃদয়ের","audioUrl":"wbw/003_159_012.mp3","charTypeName":"word"},{"id":81718,"position":12,"arabic":"لَٱنفَضُّوا۟","translation":"তারা অবশ্যই সরে যেত","audioUrl":"wbw/003_159_013.mp3","charTypeName":"word"},{"id":81719,"position":13,"arabic":"مِنْ","translation":"হতে","audioUrl":"wbw/003_159_014.mp3","charTypeName":"word"},{"id":81720,"position":14,"arabic":"حَوْلِكَ ۖ","translation":"তোমার চতুর্দিক","audioUrl":"wbw/003_159_015.mp3","charTypeName":"word"},{"id":81722,"position":15,"arabic":"فَٱعْفُ","translation":"অতএব মাফকর","