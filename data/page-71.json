 هَٰذَا ۖ قُلْ هُوَ مِنْ عِندِ أَنفُسِكُمْ ۗ إِنَّ ٱللَّهَ عَلَىٰ كُلِّ شَىْءٍۢ قَدِيرٌۭ","translation":"AND DO YOU, now that a calamity has befallen you after you had inflicted twice as much [on your foes], ask yourselves, \"How has this come about?\" Say: \"It has come from your own selves.\" Verily, God has the power to will anything:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/458.mp3","surahId":3,"words":[{"id":82430,"position":1,"arabic":"أَوَلَمَّآ","translation":"না কি যখন","audioUrl":"wbw/003_165_001.mp3","charTypeName":"word"},{"id":82431,"position":2,"arabic":"أَصَـٰبَتْكُم","translation":"তোমাদের কাছে পৌঁছে","audioUrl":"wbw/003_165_002.mp3","charTypeName":"word"},{"id":82432,"position":3,"arabic":"مُّصِيبَةٌۭ","translation":"কোন মুসিবত","audioUrl":"wbw/003_165_003.mp3","charTypeName":"word"},{"id":82433,"position":4,"arabic":"قَدْ","translation":"(অথচ) নিশ্চয়","audioUrl":"wbw/003_165_004.mp3","charTypeName":"word"},{"id":82434,"position":5,"arabic":"أَصَبْتُم","translation":"তোমরা পৌঁছেছো (তাদের মুসিবতে)","audioUrl":"wbw/003_165_005.mp3","charTypeName":"word"},{"id":82435,"position":6,"arabic":"مِّثْلَيْهَا","translation":"তার দ্বিগুণ","audioUrl":"wbw/003_165_006.mp3","charTypeName":"word"},{"id":82436,"position":7,"arabic":"قُلْتُمْ","translation":"তোমরা বলেছিলে","audioUrl":"wbw/003_165_007.mp3","charTypeName":"word"},{"id":82437,"position":8,"arabic":"أَنَّىٰ","translation":"কোথা থেকে","audioUrl":"wbw/003_165_008.mp3","charTypeName":"word"},{"id":82438,"position":9,"arabic":"هَـٰذَا ۖ","translation":"''এটা (আসল)","audioUrl":"wbw/003_165_009.mp3","charTypeName":"word"},{"id":82440,"position":10,"arabic":"قُلْ","translation":"তুমি বল''","audioUrl":"wbw/003_165_011.mp3","charTypeName":"word"},{"id":82441,"position":11,"arabic":"هُوَ","translation":"তা (এসেছে)","audioUrl":"wbw/003_165_012.mp3","charTypeName":"word"},{"id":82442,"position":12,"arabic":"مِنْ","translation":"''থেকে","audioUrl":"wbw/003_165_013.mp3","charTypeName":"word"}