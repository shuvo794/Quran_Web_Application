{"id":486,"ayahs":[{"number":23,"arabic":"ذَٰلِكَ ٱلَّذِى يُبَشِّرُ ٱللَّهُ عِبَادَهُ ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ ۗ قُل لَّآ أَسْـَٔلُكُمْ عَلَيْهِ أَجْرًا إِلَّا ٱلْمَوَدَّةَ فِى ٱلْقُرْبَىٰ ۗ وَمَن يَقْتَرِفْ حَسَنَةًۭ نَّزِدْ لَهُۥ فِيهَا حُسْنًا ۚ إِنَّ ٱللَّهَ غَفُورٌۭ شَكُورٌ","translation":"that [bounty] whereof God gives the glad tiding to such of His servants as attain to faith and do righteous deeds. Say [O Prophet]: “No reward do I ask of you for this [message] other than [that you should] love your fellow-men.” For, if anyone gains [the merit of] a good deed, We shall grant him through it an increase of good: and, verily, God is much-forgiving, ever responsive to gratitude.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4295.mp3","surahId":42,"words":[{"id":25572,"position":1,"arabic":"ذَٰلِكَ","translation":"এটাই","audioUrl":"wbw/042_023_001.mp3","charTypeName":"word"},{"id":25573,"position":2,"arabic":"ٱلَّذِى","translation":"যার","audioUrl":"wbw/042_023_002.mp3","charTypeName":"word"},{"id":25574,"position":3,"arabic":"يُبَشِّرُ","translation":"সুসংবাদ দিয়েছেন","audioUrl":"wbw/042_023_003.mp3","charTypeName":"word"},{"id":25575,"position":4,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/042_023_004.mp3","charTypeName":"word"},{"id":25576,"position":5,"arabic":"عِبَادَهُ","translation":"তাঁর দাসদেরকে","audioUrl":"wbw/042_023_005.mp3","charTypeName":"word"},{"id":25577,"position":6,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/042_023_006.mp3","charTypeName":"word"},{"id":25578,"position":7,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/042_023_007.mp3","charTypeName":"word"},{"id":25579,"position":8,"arabic":"وَعَمِلُوا۟","translation":"ও কাজ করেছে","audioUrl":"wbw/042_023_008.mp3","charTypeName":"word"},{"id":25580,"position":9,"arabic":"ٱلصَّـٰلِحَـٰتِ ۗ","translation":"সৎ","audioUrl":"wbw/042_023_009.mp3","charTypeName":"word"},{"id":25582,"position":10,"arabic":"قُل","t