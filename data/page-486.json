ord"},{"id":25600,"position":26,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/042_023_029.mp3","charTypeName":"word"},{"id":25601,"position":27,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/042_023_030.mp3","charTypeName":"word"},{"id":25602,"position":28,"arabic":"غَفُورٌۭ","translation":"ক্ষমাশীল","audioUrl":"wbw/042_023_031.mp3","charTypeName":"word"},{"id":25603,"position":29,"arabic":"شَكُورٌ","translation":"গুণগ্রাহী","audioUrl":"wbw/042_023_032.mp3","charTypeName":"word"},{"id":25604,"position":30,"arabic":"٢٣","translation":"(২৩)","audioUrl":null,"charTypeName":"end"}]},{"number":24,"arabic":"أَمْ يَقُولُونَ ٱفْتَرَىٰ عَلَى ٱللَّهِ كَذِبًۭا ۖ فَإِن يَشَإِ ٱللَّهُ يَخْتِمْ عَلَىٰ قَلْبِكَ ۗ وَيَمْحُ ٱللَّهُ ٱلْبَٰطِلَ وَيُحِقُّ ٱلْحَقَّ بِكَلِمَٰتِهِۦٓ ۚ إِنَّهُۥ عَلِيمٌۢ بِذَاتِ ٱلصُّدُورِ","translation":"DO THEY, perchance, say, “[Muhammad] has attri­buted his own lying inventions to God”? But then, had God so willed, He could have sealed thy heart [forever]: for God blots out all falsehood, and by His words proves the truth to be true. Verily, He has full knowledge of what is in the hearts [of men];","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4296.mp3","surahId":42,"words":[{"id":26646,"position":1,"arabic":"أَمْ","translation":"তবে কি","audioUrl":"wbw/042_024_001.mp3","charTypeName":"word"},{"id":26647,"position":2,"arabic":"يَقُولُونَ","translation":"(এই লোকেরা) বলে","audioUrl":"wbw/042_024_002.mp3","charTypeName":"word"},{"id":26648,"position":3,"arabic":"ٱفْتَرَىٰ","translation":"\"সে রচনা করেছে","audioUrl":"wbw/042_024_003.mp3","charTypeName":"word"},{"id":26649,"position":4,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/042_024_004.mp3","charTypeName":"word"},{"id":26650,"position":5,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/042_024_005.mp3","charTypeName":"word"},{"id":26651,"position":6,"arabic":"كَذِبًۭا ۖ","translation":"মিথ্যা\"","audioUrl":"wbw/042_024_006.mp3","charTypeName":"word"},{"id":26653,"position":7,"arabic":"فَإِن","translation":"তবে যদি","audioUrl":"wbw/042_024_008.mp3","charTypeName":"word"},{"id":26654,"position":8,"arabic":"يَشَإِ","translation":"ইচ্ছে করতেন","audioUrl":"wbw/042_024_009.mp3","charTypeName":"word"},{"id":26655,"position":9,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/042_024_010.mp3","charTypeName":"word"},{"id":26656,"position":10,"arabic":"يَخْتِمْ","translation":"সীল করে দিতেন","audioUrl":"wbw/042_024_011.mp3","charTypeName":"word"},{"id":26657,"position":11,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/042_024_012.mp3","charTypeName":"word"},{"id":26658,"position":12,"arabic":"قَلْبِكَ ۗ","translation":"তোমার অন্তরের","audioUrl":"wbw/042_024_013.mp3","charTypeName":"word"},{"id":26660,"position":13,"arabic":"وَيَمْحُ","translation":"আর মুছে দেন","audioUrl":"wbw/042_024_015.mp3","charTypeName":"word"},{"id":26661,"position":14,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/042_024_016.mp3","charTypeName":"word"},{"id":26662,"position":15,"arabic":"ٱلْبَـٰطِلَ","translation":"অসত্যকে","audioUrl":"wbw/042_024_017.mp3","charTypeName":"word"},{"id":26663,"position":16,"arabic":"وَيُحِقُّ","translation":"এবং প্রতিষ্ঠিত করেন","audioUrl":"wbw/042_024_018.mp3","charTypeName":"word"},{"id":26664,"position":17,"arabic":"ٱلْحَقَّ","translation":"সত্যকে","audioUrl":"wbw/042_024_019.mp3","charTypeName":"word"},{"id":26665,"position":18,"arabic":"بِكَلِمَـٰتِهِۦٓ ۚ","translation":"তাঁর বাণী দিয়ে","audioUrl":"wbw/042_024_020.mp3","charTypeName":"word"},{"id":26667,"position":19,"arabic":"إِنَّهُۥ","translation":"তিনি নিশ্চয়ই","audioUrl":"wbw/042_024_022.mp3","charTypeName":"word"},{"id":26668,"position":20,"arabic":"عَلِيمٌۢ","translation":"খুব অবহিত","audioUrl":"wbw/042_024_023.mp3","charTypeName":"word"},{"id":26669,"position":21,"arabic":"بِذَاتِ","translation":"অবস্থা সম্পর্কে","audioUrl":"wbw/042_024_024.mp3","charTypeName":"word"},{"id":26670,"position":22,"arabic":"ٱلصُّدُورِ","tr