ৃশ্যের","audioUrl":"wbw/032_006_004.mp3","charTypeName":"word"},{"id":6973,"position":5,"arabic":"ٱلْعَزِيزُ","translation":"মহাপরাক্রমশালী","audioUrl":"wbw/032_006_005.mp3","charTypeName":"word"},{"id":6974,"position":6,"arabic":"ٱلرَّحِيمُ","translation":"পরম দয়ালু","audioUrl":"wbw/032_006_006.mp3","charTypeName":"word"},{"id":6975,"position":7,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"ٱلَّذِىٓ أَحْسَنَ كُلَّ شَىْءٍ خَلَقَهُۥ ۖ وَبَدَأَ خَلْقَ ٱلْإِنسَٰنِ مِن طِينٍۢ","translation":"who makes most excellent everything that He creates. Thus, He begins the creation of man out of clay;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3510.mp3","surahId":32,"words":[{"id":8278,"position":1,"arabic":"ٱلَّذِىٓ","translation":"যিনি","audioUrl":"wbw/032_007_001.mp3","charTypeName":"word"},{"id":8279,"position":2,"arabic":"أَحْسَنَ","translation":"অতি উত্তম করেছেন","audioUrl":"wbw/032_007_002.mp3","charTypeName":"word"},{"id":8280,"position":3,"arabic":"كُلَّ","translation":"প্রত্যেক","audioUrl":"wbw/032_007_003.mp3","charTypeName":"word"},{"id":8281,"position":4,"arabic":"شَىْءٍ","translation":"বস্তকে","audioUrl":"wbw/032_007_004.mp3","charTypeName":"word"},{"id":8282,"position":5,"arabic":"خَلَقَهُۥ ۖ","translation":"তিনি সৃষ্টি করেছেন তা","audioUrl":"wbw/032_007_005.mp3","charTypeName":"word"},{"id":8284,"position":6,"arabic":"وَبَدَأَ","translation":"এবং সূচনা করেছেন","audioUrl":"wbw/032_007_007.mp3","charTypeName":"word"},{"id":8285,"position":7,"arabic":"خَلْقَ","translation":"সৃষ্টি","audioUrl":"wbw/032_007_008.mp3","charTypeName":"word"},{"id":8286,"position":8,"arabic":"ٱلْإِنسَـٰنِ","translation":"মানুষের","audioUrl":"wbw/032_007_009.mp3","charTypeName":"word"},{"id":8287,"position":9,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/032_007_010.mp3","charTypeName":"word"},{"id":8288,"position":10,"arabic":"طِينٍۢ","translation":"কাদামাটি","audioUrl":"wbw/032_007_011.mp3","charTypeName":"word"},{"id":8289,"position":11,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"ثُمَّ جَعَلَ نَسْلَهُۥ مِن سُلَٰلَةٍۢ مِّن مَّآءٍۢ مَّهِينٍۢ","translation":"then He causes him to be begotten out of the essence of a humble fluid;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3511.mp3","surahId":32,"words":[{"id":9460,"position":1,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/032_008_001.mp3","charTypeName":"word"},{"id":9461,"position":2,"arabic":"جَعَلَ","translation":"সৃষ্টি করেছেন","audioUrl":"wbw/032_008_002.mp3","charTypeName":"word"},{"id":9462,"position":3,"arabic":"نَسْلَهُۥ","translation":"বংশধরকে তার","audioUrl":"wbw/032_008_003.mp3","charTypeName":"word"},{"id":9463,"position":4,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/032_008_004.mp3","charTypeName":"word"},{"id":9464,"position":5,"arabic":"سُلَـٰلَةٍۢ","translation":"নির্যাস","audioUrl":"wbw/032_008_005.mp3","charTypeName":"word"},{"id":9465,"position":6,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/032_008_006.mp3","charTypeName":"word"},{"id":9466,"position":7,"arabic":"مَّآءٍۢ","translation":"পানির","audioUrl":"wbw/032_008_007.mp3","charTypeName":"word"},{"id":9467,"position":8,"arabic":"مَّهِينٍۢ","translation":"তুচ্ছ","audioUrl":"wbw/032_008_008.mp3","charTypeName":"word"},{"id":9468,"position":9,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"ثُمَّ سَوَّىٰهُ وَنَفَخَ فِيهِ مِن رُّوحِهِۦ ۖ وَجَعَلَ لَكُمُ ٱلسَّمْعَ وَٱلْأَبْصَٰرَ وَٱلْأَفْـِٔدَةَ ۚ قَلِيلًۭا مَّا تَشْكُرُونَ","translation":"and then He forms him in accordance with what he is meant to be, and breathes into him of His spirit: and [thus, O men,] He endows you with hearing, and sight, and feelings as well as minds: [yet] how seldom are you grateful!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3512.mp3","surahId":32,"words":[{"id":10600,"position":1,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/032_009_001.mp3","charTypeName":"word"},{"id":10601,"position":2,"arabic":"سَوَّىٰهُ","translation":"সুঠাম করেছেন তাকে","audioUrl":"wbw/032_009_002.mp3","charTypeName":"word"},{"id":10602,"position":3,"arabic":"وَنَفَخَ","translation":"ও ফুঁকে দিয়েছেন","audioUrl":"wbw/032_009_003.mp3","charTypeName":"word"},{"id":10603,"position":4,"arabic":"فِيهِ","translation":"মধ্যে তার","audioUrl":"wbw/032_009_004.mp3","charTypeName":"word"},{"id":10604,"position":5,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/032_009_005.mp3","charTypeName":"word"},{"id":10605,"position":6,"arabic":"رُّوحِهِۦ ۖ","translation":"রূহ তার","audioUrl":"wbw/032_009_006.mp3","charTypeName":"word"},{"id":10607,"position":7,"arabic":"وَجَعَلَ","translation":"এবং দিয়েছেন","audioUrl":"wbw/032_009_008.mp3","charTypeName":"word"},{"id":10608,"position":8,"arabic":"لَكُمُ","translation":"জন্যে তোমাদের","audioUrl":"wbw/032_009_009.mp3","charTypeName":"word"},{"id":10609,"position":9,"arabic":"ٱلسَّمْعَ","translation":"শ্রবণশক্তিসমূহ","audioUrl":"wbw/032_009_010.mp3","charTypeName":"word"},{"id":10610,"position":10,"arabic":"وَٱلْأَبْصَـٰرَ","translation":"ও দর্শনশক্তিসমূহ","audioUrl":"wbw/032_009_011.mp3","charTypeName":"word"},{"id":10611,"position":11,"arabic":"وَٱلْأَفْـِٔدَةَ ۚ","translation":"ও অন্তরসমূহ","audioUrl":"wbw/032_009_012.mp3","charTypeName":"word"},{"id":10613,"position":12,"arabic":"قَلِيلًۭا","translation":"কমই","audioUrl":"wbw/032_009_014.mp3","charTypeName":"word"},{"id":10614,"position":13,"arabic":"مَّا","translation":"যা","audioUrl":"wbw/032_009_015.mp3","charTypeName":"word"},{"id":10615,"position":14,"arabic":"تَشْكُرُونَ","translation":"তোমরা কৃতজ্ঞতা স্বীকার করো","audioUrl":"wbw/032_009_016.mp3","charTypeName":"word"},{"id":10616,"position":15,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"وَقَالُوٓا۟ أَءِذَا ضَلَلْنَا فِى ٱلْأَرْضِ أَءِنَّا لَفِى خَلْقٍۢ جَدِيدٍۭ ۚ بَلْ هُم بِلِقَآءِ رَبِّهِمْ كَٰفِرُونَ","translation":"For, [many are] they [who] say, “What! After we have been [dead and] lost in the earth, shall we indeed be [restored to life] in a new act of crea­tion?” Nay, but [by saying this] they deny the truth that they are destined to meet their Sustainer!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3513.mp3","surahId":32,"words":[{"id":11880,"position":1,"arabic":"وَقَالُوٓا۟","translation":"এবং তারা বলে","audioUrl":"wbw/032_010_001.mp3","charTypeName":"word"},{"id":11881,"position":2,"arabic":"أَءِذَا","translation":"\"কি যখন","audioUrl":"wbw/032_010_002.mp3","charTypeName":"word"},{"id":11882,"position":3,"arabic":"ضَلَلْنَا","translation":"আমরা মিশে যাবো","audioUrl":"wbw/032_010_003.mp3","charTypeName":"word"},{"id":11883,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/032_010_004.mp3","charTypeName":"word"},{"id":11884,"position":5,"arabic":"ٱلْأَرْضِ","translation":"মাটির","audioUrl":"wbw/032_010_005.mp3","charTypeName":"word"},{"id":11885,"position":6,"arabic":"أَءِنَّا","translation":"কি নিশ্চয়ই আমরা (হবো)","audioUrl":"wbw/032_010_006.mp3","charTypeName":"word"},{"id":11886,"position":7,"arabic":"لَفِى","translation":"অবশ্যই মধ্যে","audioUrl":"wbw/032_010_007.mp3","charTypeName":"word"},{"id":11887,"position":8,"arabic":"خَلْقٍۢ","translation":"সৃষ্টি","audioUrl":"wbw/032_010_008.mp3","charTypeName":"word"},{"id":11888,"position":9,"arabic":"جَدِيدٍۭ ۚ","translation":"নতুন\"","audioUrl":"wbw/032_010_009.mp3","charTypeName":"word"},{"id":11890,"position":10,"arabic":"بَلْ","translation":"বরং","audioUrl":"wbw/032_010_011.mp3","charTypeName":"word"},{"id":11891,"position":11,"arabic":"هُم","translation":"তারা","audioUrl":"wbw/032_010_012.mp3","charTypeName":"word"},{"id":11892,"position":12,"arabic":"بِلِقَآءِ","translation":"সম্পর্কে সাক্ষাত","audioUrl":"wbw/032_010_013.mp3","charTypeName":"word"},{"id":11893,"position":13,"arabic":"رَبِّهِمْ","translation":"রবের তাদের","audioUrl":"wbw/032_010_014.mp3","charTypeName":"word"},{"id":11894,"position":14,"arabic":"كَـٰفِرُونَ","translation":"অস্বীকারকারী","audioUrl":"wbw/032_010_015.mp3","charTypeName":"word"},{"id":11895,"position":15,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"۞ قُلْ يَتَوَفَّىٰكُم مَّلَكُ ٱلْمَوْتِ ٱلَّذِى وُكِّلَ بِكُمْ ثُمَّ إِلَىٰ رَبِّكُمْ تُرْجَعُونَ","translation":"Say: “[One day,] the angel of death who has been given charge of you will gather you, and then unto your Sustainer you will be brought back.”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3514.mp3","surahId":32,"words":[{"id":13187,"position":1,"arabic":"۞ قُلْ","translation":"বলো","audioUrl":"wbw/032_011_002.mp3","charTypeName":"word"},{"id":13188,"position":2,"arabic":"يَتَوَفَّىٰكُم","translation":"\"প্রাণ নিবে তোমাদের","audioUrl":"wbw/032_011_003.mp3","charTypeName":"word"},{"id":13189,"position":3,"arabic":"مَّلَكُ","translation":"ফেরেশতারা","audioUrl":"wbw/032_011_004.mp3","charTypeName":"word"},{"id":13190,"position":4,"arabic":"ٱلْمَوْتِ","translation":"মৃত্যুর","audioUrl":"wbw/032_011_005.mp3","charTypeName":"word"},{"id":13191,"position":5,"arabic":"ٱلَّذِى","translation":"যাকে","audioUrl":"wbw/032_011_006.mp3","charTypeName":"word"},{"id":13192,"position":6,"arabic":"وُكِّلَ","translation":"নিয়োগ করা হয়েছে","audioUrl":"wbw/032_011_007.mp3","charTypeName":"word"},{"id":13193,"position":7,"arabic":"بِكُمْ","translation":"উপর তোমাদের","audioUrl":"wbw/032_011_008.mp3","charTypeName":"word"},{"id":13194,"position":8,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/032_011_009.mp3","charTypeName":"word"},{"id":13195,"position":9,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/032_011_010.mp3","charTypeName":"word"},{"id":13196,"position":10,"arabic":"رَبِّكُمْ","translation":"রবের তোমাদের","audioUrl":"wbw/032_011_011.mp3","charTypeName":"word"},{"id":13197,"position":11,"arabic":"تُرْجَعُونَ","translation":"তোমরা প্রত্যাবর্তিত হবে\"","audioUrl":"wbw/032_011_012.mp3","charTypeName":"word"},{"id":13198,"position":12,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]}]}