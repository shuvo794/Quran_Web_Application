{"id":415,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ الٓمٓ","translation":"Alif. Lam. Mim.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3504.mp3","surahId":32,"words":[{"id":796,"position":1,"arabic":"الٓمٓ","translation":"আলিফ লাম- মীম-","audioUrl":"wbw/032_001_001.mp3","charTypeName":"word"},{"id":797,"position":2,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"تَنزِيلُ ٱلْكِتَٰبِ لَا رَيْبَ فِيهِ مِن رَّبِّ ٱلْعَٰلَمِينَ","translation":"The bestowal from on high of this divine writ issues, beyond any doubt, from the Sustainer of all the worlds:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3505.mp3","surahId":32,"words":[{"id":1882,"position":1,"arabic":"تَنزِيلُ","translation":"অবতরণ (হয়েছে)","audioUrl":"wbw/032_002_001.mp3","charTypeName":"word"},{"id":1883,"position":2,"arabic":"ٱلْكِتَـٰبِ","translation":"(এই) কিতাবের","audioUrl":"wbw/032_002_002.mp3","charTypeName":"word"},{"id":1884,"position":3,"arabic":"لَا","translation":"নেই","audioUrl":"wbw/032_002_003.mp3","charTypeName":"word"},{"id":1885,"position":4,"arabic":"رَيْبَ","translation":"সন্দেহ","audioUrl":"wbw/032_002_004.mp3","charTypeName":"word"},{"id":1886,"position":5,"arabic":"فِيهِ","translation":"মধ্যে তার","audioUrl":"wbw/032_002_005.mp3","charTypeName":"word"},{"id":1887,"position":6,"arabic":"مِن","translation":"পক্ষ হ'তে","audioUrl":"wbw/032_002_006.mp3","charTypeName":"word"},{"id":1888,"position":7,"arabic":"رَّبِّ","translation":"রবের","audioUrl":"wbw/032_002_007.mp3","charTypeName":"word"},{"id":1889,"position":8,"arabic":"ٱلْعَـٰلَمِينَ","translation":"বিশ্বজগতের","audioUrl":"wbw/032_002_008.mp3","charTypeName":"word"},{"id":1890,"position":9,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"أَمْ يَقُولُونَ ٱفْتَرَىٰهُ ۚ بَلْ هُوَ ٱلْحَقُّ مِن رَّبِّكَ لِتُنذِرَ قَوْمًۭا مَّآ أَتَىٰهُم مِّن نَّذِيرٍۢ مِّن قَبْلِكَ لَعَلَّهُمْ يَهْتَدُونَ","translation":"and yet, they [who are bent on denying the truth] assert, “[Muhammad] has invented it!” Nay, but it is the truth from thy Sustainer, enabling thee to warn [this] people to whom no warner has come before thee, so that they might follow the right path.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3506.mp3","surahId":32,"words":[{"id":3051,"position":1,"arabic":"أَمْ","translation":"কি","audioUrl":"wbw/032_003_001.mp3","charTypeName":"word"},{"id":3052,"position":2,"arabic":"يَقُولُونَ","translation":"তারা বলেছে","audioUrl":"wbw/032_003_002.mp3","charTypeName":"word"},{"id":3053,"position":3,"arabic":"ٱفْتَرَىٰهُ ۚ","translation":"\"সে মিথ্যা রচনা করেছে তা\"","audioUrl":"wbw/032_003_003.mp3","charTypeName":"word"},{"id":3055,"position":4,"arabic":"بَلْ","translation":"বরং","audioUrl":"wbw/032_003_005.mp3","charTypeName":"word"},{"id":3056,"position":5,"arabic":"هُوَ","translation":"তা","audioUrl":"wbw/032_003_006.mp3","charTypeName":"word"},{"id":3057,"position":6,"arabic":"ٱلْحَقُّ","translation":"সত্য","audioUrl":"wbw/032_003_007.mp3","charTypeName":"word"},{"id":3058,"position":7,"arabic":"مِن","translation":"পক্ষ হ'তে","audioUrl":"wbw/032_003_008.mp3","charTypeName":"word"},{"id":3059,"position":8,"arabic":"رَّبِّكَ","translation":"রবের তোমার","audioUrl":"wbw/032_003_009.mp3","charTypeName":"word"},{"id":3060,"position":9,"arabic":"لِتُنذِرَ","translation":"যেন তুমি সতর্ক করো","audioUrl":"wbw/032_003_010.mp3","charTypeName":"word"},{"id":3061,"position":10,"arabic":"قَوْمًۭا","translation":"(এমন)এক জাতিকে","audioUrl":"wbw/032_003_011.mp3","charTypeName":"word"},{"id":3062,"position":11,"arabic":"مَّآ","translation":"না","audioUrl":"wbw/032_003_012.mp3","charTypeName":"word"},{"id":3063,"position":12,"arabic":"أَتَىٰهُم","translation":"কাছে এসেছে তাদের","audioUrl":"wbw/032_003_013.mp3","charTypeName":"word"},{"id":3064,"position":13,"arabic":"مِّن","translation":"কোনো","audioUrl":"wbw/032_003_014.mp3","charTypeName":"word"},{"id":3065,"position":14,"arabic":"نَّذِيرٍۢ","translation":"সতর্ককারী","audioUrl":"wbw/032_003_015.mp3","charTypeName":"word"},{"id":3066,"position":15,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/032_003_016.mp3","charTypeName":"word"},{"id":3067,"position":16,"arabic":"قَبْلِكَ","translation":"তোমার পূর্ব","audioUrl":"wbw/032_003_017.mp3","charTypeName":"word"},{"id":3068,"position":17,"arabic":"لَعَلَّهُمْ","translation":"সম্ভবত তারা","audioUrl":"wbw/032_003_018.mp3","charTypeName":"word"},{"id":3069,"position":18,"arabic":"يَهْتَدُونَ","translation":"সঠিক পথে চলবে","audioUrl":"wbw/032_003_019.mp3","charTypeName":"word"},{"id":3070,"position":19,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"ٱللَّهُ ٱلَّذِى خَلَقَ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضَ وَمَا بَيْنَهُمَا فِى سِتَّةِ أَيَّامٍۢ ثُمَّ ٱسْتَوَىٰ عَلَى ٱلْعَرْشِ ۖ مَا لَكُم مِّن دُونِهِۦ مِن وَلِىٍّۢ وَلَا شَفِيعٍ ۚ أَفَلَا تَتَذَكَّرُونَ","translation":"IT IS GOD who has created the heavens and the earth and all that is between them in six aeons, and is established on the throne of His almightiness. You have none to protect you from God, and none to intercede for you [on Judgment Day]: will you not, then, bethink yourselves?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3507.mp3","surahId":32,"words":[{"id":4409,"position":1,"arabic":"ٱللَّهُ","translation":"(তিনিই)আল্লাহ","audioUrl":"wbw/032_004_001.mp3","charTypeName":"word"},{"id":4410,"position":2,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/032_004_002.mp3","charTypeName":"word"},{"id":4411,"position":3,"arabic":"خَلَقَ","translation":"সৃষ্টি করেছেন","audioUrl":"wbw/032_004_003.mp3","charTypeName":"word"},{"id":4412,"position":4,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশসমূহকে","audioUrl":"wbw/032_004_004.mp3","charTypeName":"word"},{"id":4413,"position":5,"arabic":"وَٱلْأَرْضَ","translation":"ও পৃথিবীকে","audioUrl":"wbw/032_004_005.mp3","charTypeName":"word"},{"id":4414,"position":6,"arabic":"وَمَا","translation":"এবং যা কিছু","audioUrl":"wbw/032_004_006.mp3","charTypeName":"word"},{"id":4415,"position":7,"arabic":"بَيْنَهُمَا","translation":"উভয়ের মাঝে তাদের (আছে)","audioUrl":"wbw/032_004_007.mp3","charTypeName":"word"},{"id":4416,"position":8,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/032_004_008.mp3","charTypeName":"word"},{"id":4417,"position":9,"arabic":"سِتَّةِ","translation":"ছয়","audioUrl":"wbw/032_004_009.mp3","charTypeName":"word"},{"id":4418,"position":10,"arabic":"أَيَّامٍۢ","translation":"দিনের","audioUrl":"wbw/032_004_010.mp3","charTypeName":"word"},{"id":4419,"position":11,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/032_004_011.mp3","charTypeName":"word"},{"id":4420,"position":12,"arabic":"ٱسْتَوَىٰ","translation":"সমাসীন হন","audioUrl":"wbw/032_004_012.mp3","charTypeName":"word"},{"id":4421,"position":13,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/032_004_013.mp3","charTypeName":"word"},{"id":4422,"position":14,"arabic":"ٱلْعَرْشِ ۖ","translation":"আরশের","audioUrl":"wbw/032_004_014.mp3","charTypeName":"word"},{"id":4424,"position":15,"arabic":"مَا","translation":"নেই","audioUrl":"wbw/032_004_016.mp3","charTypeName":"word"},{"id":4425,"position":16,"arabic":"لَكُم","translation":"জন্যে তোমাদের","audioUrl":"wbw/032_004_017.mp3","charTypeName":"word"},{"id":4426,"position":17,"arabic":"مِّن","translation":"ছাড়া","audioUrl":"wbw/032_004_018.mp3","charTypeName":"word"},{"id":4427,"position":18,"arabic":"دُونِهِۦ","translation":"তিনি","audioUrl":"wbw/032_004_019.mp3","charTypeName":"word"},{"id":4428,"position":19,"arabic":"مِن","translation":"কোনো","audioUrl":"wbw/032_004_020.mp3","charTypeName":"word"},{"id":4429,"position":20,"arabic":"وَلِىٍّۢ","translation":"অভিভাবক","audioUrl":"wbw/032_004_021.mp3","charTypeName":"word"},{"id":4430,"position":21,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/032_004_022.mp3","charTypeName":"word"},{"id":4431,"position":22,"arabic":"شَفِيعٍ ۚ","translation":"সুপারিশকারী","audioUrl":"wbw/032_004_023.mp3","charTypeName":"word"},{"id":4433,"position":23,"arabic":"أَفَلَا","translation":"কি তবে না","audioUrl":"wbw/032_004_025.mp3","charTypeName":"word"},{"id":4434,"position":24,"arabic":"تَتَذَكَّرُونَ","translation":"তোমরা উপদেশ গ্রহণ করবে","audioUrl":"wbw/032_004_026.mp3","charTypeName":"word"},{"id":4435,"position":25,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"يُدَبِّرُ ٱلْأَمْرَ مِنَ ٱلسَّمَآءِ إِلَى ٱلْأَرْضِ ثُمَّ يَعْرُجُ إِلَيْهِ فِى يَوْمٍۢ كَانَ مِقْدَارُهُۥٓ أَلْفَ سَنَةٍۢ مِّمَّا تَعُدُّونَ","translation":"He governs all that exists, from the celestial space to the earth; and in the end all shall ascend unto Him [for judgment] on a Day the length whereof will be [like] a thousand years of your reckoning.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3508.mp3","surahId":32,"words":[{"id":5669,"position":1,"arabic":"يُدَبِّرُ","translation":"তিনি পরিচালনা করেন","audioUrl":"wbw/032_005_001.mp3","charTypeName":"word"},{"id":5670,"position":2,"arabic":"ٱلْأَمْرَ","translation":"সবকাজের","audioUrl":"wbw/032_005_002.mp3","charTypeName":"word"},{"id":5671,"position":3,"arabic":"مِنَ","translation":"থেকে","audioUrl":"wbw/032_005_003.mp3","charTypeName":"word"},{"id":5672,"position":4,"arabic":"ٱلسَّمَآءِ","translation":"আকাশ","audioUrl":"wbw/032_005_004.mp3","charTypeName":"word"},{"id":5673,"position":5,"arabic":"إِلَى","translation":"পর্যন্ত","audioUrl":"wbw/032_005_005.mp3","charTypeName":"word"},{"id":5674,"position":6,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবী","audioUrl":"wbw/032_005_006.mp3","charTypeName":"word"},{"id":5675,"position":7,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/032_005_007.mp3","charTypeName":"word"},{"id":5676,"position":8,"arabic":"يَعْرُجُ","translation":"উত্থিত হবে","audioUrl":"wbw/032_005_008.mp3","charTypeName":"word"},{"id":5677,"position":9,"arabic":"إِلَيْهِ","translation":"দিকে তাঁরই","