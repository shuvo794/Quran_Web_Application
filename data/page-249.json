{"id":249,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ الٓمٓر ۚ تِلْكَ ءَايَٰتُ ٱلْكِتَٰبِ ۗ وَٱلَّذِىٓ أُنزِلَ إِلَيْكَ مِن رَّبِّكَ ٱلْحَقُّ وَلَٰكِنَّ أَكْثَرَ ٱلنَّاسِ لَا يُؤْمِنُونَ","translation":"Alif. Lam. Mim. Ra. THESE ARE MESSAGES of revelation: and what has been bestowed upon thee from on high by thy Sustainer is the truth-yet most people will not believe [in it]?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1708.mp3","surahId":13,"words":[{"id":769,"position":1,"arabic":"الٓمٓر ۚ","translation":"আলিফ লা-ম মী-ম রা-","audioUrl":"wbw/013_001_001.mp3","charTypeName":"word"},{"id":771,"position":2,"arabic":"تِلْكَ","translation":"এই","audioUrl":"wbw/013_001_003.mp3","charTypeName":"word"},{"id":772,"position":3,"arabic":"ءَايَـٰتُ","translation":"আয়াতসমূহ","audioUrl":"wbw/013_001_004.mp3","charTypeName":"word"},{"id":773,"position":4,"arabic":"ٱلْكِتَـٰبِ ۗ","translation":"কিতাবের","audioUrl":"wbw/013_001_005.mp3","charTypeName":"word"},{"id":775,"position":5,"arabic":"وَٱلَّذِىٓ","translation":"এবং যা","audioUrl":"wbw/013_001_007.mp3","charTypeName":"word"},{"id":776,"position":6,"arabic":"أُنزِلَ","translation":"অবতীর্ণ হয়েছে","audioUrl":"wbw/013_001_008.mp3","charTypeName":"word"},{"id":777,"position":7,"arabic":"إِلَيْكَ","translation":"তোমার প্রতি","audioUrl":"wbw/013_001_009.mp3","charTypeName":"word"},{"id":778,"position":8,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/013_001_010.mp3","charTypeName":"word"},{"id":779,"position":9,"arabic":"رَّبِّكَ","translation":"তোমার রবের","audioUrl":"wbw/013_001_011.mp3","charTypeName":"word"},{"id":780,"position":10,"arabic":"ٱلْحَقُّ","translation":"(তা) সত্য","audioUrl":"wbw/013_001_012.mp3","charTypeName":"word"},{"id":781,"position":11,"arabic":"وَلَـٰكِنَّ","translation":"কিন্তু","audioUrl":"wbw/013_001_013.mp3","charTypeName":"word"},{"id":782,"position":12,"arabic":"أَكْثَرَ","translation":"অধিকাংশ","audioUrl":"wbw/013_001_014.mp3","charTypeName":"word"},{"id":783,"position":13,"arabic":"ٱلنَّاسِ","translation":"মানুষ","audioUrl":"wbw/013_001_015.mp3","charTypeName":"word"},{"id":784,"position":14,"arabic":"لَا","translation":"না","audioUrl":"wbw/013_001_016.mp3","charTypeName":"word"},{"id":785,"position":15,"arabic":"يُؤْمِنُونَ","translation":"ঈমান আনে","audioUrl":"wbw/013_001_017.mp3","charTypeName":"word"},{"id":786,"position":16,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"ٱللَّهُ ٱلَّذِى رَفَعَ ٱلسَّمَٰوَٰتِ بِغَيْرِ عَمَدٍۢ تَرَوْنَهَا ۖ ثُمَّ ٱسْتَوَىٰ عَلَى ٱلْعَرْشِ ۖ وَسَخَّرَ ٱلشَّمْسَ وَٱلْقَمَرَ ۖ كُلٌّۭ يَجْرِى لِأَجَلٍۢ مُّسَمًّۭى ۚ يُدَبِّرُ ٱلْأَمْرَ يُفَصِّلُ ٱلْءَايَٰتِ لَعَلَّكُم بِلِقَآءِ رَبِّكُمْ تُوقِنُونَ","translation":"It is God who has raised the heavens without any supports that you could see, and is established on the throne of His almightiness; and He [it is who] has made the sun and the moon subservient [to His laws], each running its course for a term set [by Him]. He governs all that exists. Clearly does He spell out these messages, so that you might be certain in your innermost that you are destined to meet your Sustainer [on Judgment Day].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1709.mp3","surahId":13,"words":[{"id":1846,"position":1,"arabic":"ٱللَّهُ","translation":"(তিনিই) আল্লাহ","audioUrl":"wbw/013_002_001.mp3","charTypeName":"word"},{"id":1847,"position":2,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/013_002_002.mp3","charTypeName":"word"},{"id":1848,"position":3,"arabic":"رَفَعَ","translation":"উপরে স্থাপন করেছেন","audioUrl":"wbw/013_002_003.mp3","charTypeName":"word"},{"id":1849,"position":4,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশমন্ডলী","audioUrl":"wbw/013_002_004.mp3","charTypeName":"word"},{"id":1850,"position":5,"arabic":"بِغَيْرِ","translation":"ছাড়া","audioUrl":"wbw/013_002_005.mp3","charTypeName":"word"},{"id":1851,"position":6,"arabic":"عَمَدٍۢ","translation":"কোন খুঁটি","audioUrl":"wbw/013_002_006.mp3","charTypeName":"word"},{"id":1852,"position":7,"arabic":"تَرَوْنَهَا ۖ","translation":"তা তোমরা দেখছো","audioUrl":"wbw/013_002_007.mp3","charTypeName":"word"},{"id":1854,"position":8,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/013_002_009.mp3","charTypeName":"word"},{"id":1855,"position":9,"arabic":"ٱسْتَوَىٰ","translation":"উঠেছেন","audioUrl":"wbw/013_002_010.mp3","charTypeName":"word"},{"id":1856,"position":10,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/013_002_011.mp3","charTypeName":"word"},{"id":1857,"position":11,"arabic":"ٱلْعَرْشِ ۖ","translation":"আরশের","audioUrl":"wbw/013_002_012.mp3","charTypeName":"word"},{"id":1859,"position":12,"arabic":"وَسَخَّرَ","translation":"এবং অধীন করেছেন","audioUrl":"wbw/013_002_014.mp3","charTypeName":"word"},{"id":1860,"position":13,"arabic":"ٱلشَّمْسَ","translation":"সূর্যকে (নিয়মের)","audioUrl":"wbw/013_002_015.mp3","charTypeName":"word"},{"id":1861,"position":14,"arabic":"وَٱلْقَمَرَ ۖ","translation":"ও চাঁদকে","audioUrl":"wbw/013_002_016.mp3","charTypeName":"word"},{"id":1863,"position":15,"arabic":"كُلٌّۭ","translation":"প্রত্যেকে","audioUrl":"wbw/013_002_018.mp3","charTypeName":"word"},{"id":1864,"position":16,"arabic":"يَجْرِى","translation":"চলছে","audioUrl":"wbw/013_002_019.mp3","charTypeName":"word"},{"id":1865,"position":17,"arabic":"لِأَجَلٍۢ","translation":"জন্যে সময়ের","audioUrl":"wbw/013_002_020.mp3","charTypeName":"word"},{"id":1866,"position":18,"arabic":"مُّسَمًّۭى ۚ","translation":"নির্দিষ্ট","audioUrl":"wbw/013_002_021.mp3","charTypeName":"word"},{"id":1868,"position":19,"arabic":"يُدَبِّرُ","translation":"তিনি পরিচালনা করেন","audioUrl":"wbw/013_002_023.mp3","charTypeName":"word"},{"id":1869,"position":20,"arabic":"ٱلْأَمْرَ","translation":"সকল বিষয়","audioUrl":"wbw/013_002_024.mp3","charTypeName":"word"},{"id":1870,"position":21,"arabic":"يُفَصِّلُ","translation":"বিশদ বর্ণনা করেন","audioUrl":"wbw/013_002_025.mp3","charTypeName":"word"},{"id":1871,"position":22,"arabic":"ٱلْـَٔايَـٰتِ","translation":"নিদর্শনসমূহ","audioUrl":"wbw/013_002_026.mp3","charTypeName":"word"},{"id":1872,"position":23,"arabic":"لَعَلَّكُم","translation":"তোমরা যাতে","audioUrl":"wbw/013_002_027.mp3","charTypeName":"word"},{"id":1873,"position":24,"arabic":"بِلِقَآءِ","translation":"সম্পর্কে সাক্ষাত","audioUrl":"wbw/013_002_028.mp3","charTypeName":"word"},{"id":1874,"position":25,"arabic":"رَبِّكُمْ","translation":"তোমাদের রবের","audioUrl":"wbw/013_002_029.mp3","charTypeName":"word"},{"id":1875,"position":26,"arabic":"تُوقِنُونَ","translation":"তোমরা দৃঢ় বিশ্বাস করো","audioUrl":"wbw/013_002_030.mp3","charTypeName":"word"},{"id":1876,"position":27,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"وَهُوَ ٱلَّذِى مَدَّ ٱلْأَرْضَ وَجَعَلَ فِيهَا رَوَٰسِىَ وَأَنْهَٰرًۭا ۖ وَمِن كُلِّ ٱلثَّمَرَٰتِ جَعَلَ فِيهَا زَوْجَيْنِ ٱثْنَيْنِ ۖ يُغْشِى ٱلَّيْلَ ٱلنَّهَارَ ۚ إِنَّ فِى ذَٰلِكَ لَءَايَٰتٍۢ لِّقَوْمٍۢ يَتَفَكَّرُونَ","translation":"And it is He who has spread the earth wide and placed on it firm mountains and running waters, and created thereon two sexes of every [kind of] plant; [and it is He who] causes the night to cover the day. Verily, in all this there are messages indeed for people who think!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1710.mp3","surahId":13,"words":[{"id":3019,"position":1,"arabic":"وَهُوَ","translation":"এবং তিনিই","audioUrl":"wbw/013_003_001.mp3","charTypeName":"word"},{"id":3020,"position":2,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/013_003_002.mp3","charTypeName":"word"},{"id":3021,"position":3,"arabic":"مَدَّ","translation":"বিস্তৃত করেছেন","audioUrl":"wbw/013_003_003.mp3","charTypeName":"word"},{"id":3022,"position":4,"arabic":"ٱلْأَرْضَ","translation":"জমিনকে","audioUrl":"wbw/013_003_004.mp3","charTypeName":"word"},{"id":3023,"position":5,"arabic":"وَجَعَلَ","translation":"ও সৃষ্টি করেছেন","audioUrl":"wbw/013_003_005.mp3","charTypeName":"word"},{"id":3024,"position":6,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/013_003_006.mp3","charTypeName":"word"},{"id":3025,"position":7,"arabic":"رَوَٰسِىَ","translation":"সুদৃঢ় পর্বত","audioUrl":"wbw/013_003_007.mp3","charTypeName":"word"},{"id":3026,"position":8,"arabic":"وَأَنْهَـٰرًۭا ۖ","translation":"ও নদীসমূহ","audioUrl":"wbw/013_003_008.mp3","charTypeName":"word"},{"id":3028,"position":9,"arabic":"وَمِن","translation":"এবং রকমের","audioUrl":"wbw/013_003_010.mp3","charTypeName":"word"},{"id":3029,"position":10,"arabic":"كُلِّ","translation":"সব","audioUrl":"wbw/013_003_011.mp3","charTypeName":"word"},{"id":3030,"position":11,"arabic":"ٱلثَّمَرَٰتِ","translation":"ফলমূলসমূহ","audioUrl":"wbw/013_003_012.mp3","charTypeName":"word"},{"id":3031,"position":12,"arabic":"جَعَلَ","translation":"সৃষ্টি করেছেন","audioUrl":"wbw/013_003_013.mp3","charTypeName":"word"},{"id":3032,"position":13,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/013_003_014.mp3","charTypeName":"word"},{"id":3033,"position":14,"arabic":"زَوْجَيْنِ","translation":"জোড়া","audioUrl":"wbw/013_003_015.mp3","charTypeName":"word"},{"id":3034,"position":15,"arabic":"ٱثْنَيْنِ ۖ","translation":"দুই (ধরণের)","audioUrl":"wbw/013_003_016.mp3","charTypeName":"word"},{"id":3036,"position":16,"arabic":"يُغْشِى","translation":"তিনি ঢেকে রেখেছেন","audioUrl":"wbw/013_003_018.mp3","charTypeName":"word"},{"id":3037,"position":17,"arabic":"ٱلَّيْلَ","translation":"রাত (দিয়ে)","audioUrl":"wbw/013_003_019.mp3","charTypeName":"word"},{"id":3038,"position":18,"arabic":"ٱلنَّهَارَ ۚ","translation":"দিনকে","audioUrl":"wbw/013_003_020.mp3","charTypeName":"word"},{"id":3040,"position":19,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/013_003_022.mp3","charTypeName":"word"},{"id":3041,"position":20,"arabic":"فِى","translation":"মধ্যে (আছে)","audioUrl":"wbw/013_003_023.mp3","charTypeName":"word"},{"id":3042,"position":21,"arabic":"ذَٰلِكَ","translation":"এর","audioUrl":"wbw/013_003_024.mp3","charTypeName":"word"},{"id":3043,"position":22,"arabic":"لَـَٔايَـٰتٍۢ","translation":"অবশ্যই নিদর্শনাবলী","audioUrl":"wbw/013_003_025.mp3","charTypeName":"word"},{"id":3044,"position":23,"arabic":"لِّقَوْمٍۢ","translation":"লোকদের জন্যে (যারা)","audioUrl":"wbw/013_003_026.mp3","charTypeName":"word"},{"id":3045,"position":24,"arabic":"يَتَفَكَّرُونَ","translation":"চিন্তা-ভাবনা করে","audioUrl":"wbw/013_003_027.mp3","charTypeName":"word"},{"id":3046,"position":25,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"وَفِى ٱلْأَرْضِ قِطَعٌۭ مُّتَجَٰوِرَٰتٌۭ وَجَنَّٰتٌۭ مِّنْ أَعْنَٰبٍۢ وَزَرْعٌۭ وَنَخِيلٌۭ صِنْوَانٌۭ وَغَيْرُ صِنْوَانٍۢ يُسْقَىٰ بِمَآءٍۢ وَٰحِدٍۢ وَنُفَضِّلُ بَعْضَهَا عَلَىٰ بَعْضٍۢ فِى ٱلْأُكُلِ ۚ إِنَّ فِى ذَٰلِكَ لَءَايَٰتٍۢ لِّقَوْمٍۢ يَعْقِلُونَ","translation":"And there are on earth [many] tracts of land close by one another [and yet widely differing from one another]; and [there are on it] vinyards, and fields of grain, and date-palms growing in clusters from one root or standing alone, [all] watered with the same water: and yet, some of them have We favoured above others by way of the food [which they provide for man and beast]. Verily, in all this there are messages indeed for people who use their reason!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1711.mp3","surahId":13,"words":[{"id":4360,"position":1,"arabic":"وَفِى","translation":"এবং মধ্যে","audioUrl":"wbw/013_004_001.mp3","charTypeName":"word"},{"id":4361,"position":2,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/013_004_002.mp3","charTypeName":"word"},{"id":4362,"position":3,"arabic":"قِطَعٌۭ","translation":"ভূখন্ড","audioUrl":"wbw/013_004_003.mp3","charTypeName":"word"},{"id":4363,"position":4,"arabic":"مُّتَجَـٰوِرَٰتٌۭ","translation":"পরস্পর সংলগ্ন","audioUrl":"wbw/013_004_004.mp3","charTypeName":"word"},{"id":4364,"position":5,"arabic":"وَجَنَّـٰتٌۭ","translation":"ও বাগানসমূহ","audioUrl":"wbw/013_004_005.mp3","charTypeName":"word"},{"id":4365,"position":6,"arabic":"مِّنْ","translation":"এর","audioUrl":"wbw/013_004_006.mp3","charTypeName":"word"},{"id":4366,"position":7,"arabic":"أَعْنَـٰبٍۢ","translation":"আঙ্গুর","audioUrl":"wbw/013_004_007.mp3","charTypeName":"word"},{"id":4367,"position":8,"arabic":"وَزَرْعٌۭ","translation":"ও শস্যক্ষেত","audioUrl":"wbw/013_004_008.mp3","charTypeName":"word"},{"id":4368,"position":9,"arabic":"وَنَخِيلٌۭ","translation":"ও খেজুর গাছসমূহ","audioUrl":"wbw/013_004_009.mp3","charTypeName":"word"},{"id":4369,"position":10,"arabic":"صِنْوَانٌۭ","translation":"একাধিক শিরবিশিষ্ট","audioUrl":"wbw/013_004_010.mp3","charTypeName":"word"},{"id":4370,"position":11,"arabic":"وَغَيْرُ","translation":"ও নয়","audioUrl":"wbw/013_004_011.mp3","charTypeName":"word"},{"id":4371,"position":12,"arabic":"صِنْوَانٍۢ","translation":"একাধিক শিরবিশিষ্ট","audioUrl":"wbw/013_004_012.mp3","charTypeName":"word"},{"id":4372,"position":13,"arabic":"يُسْقَىٰ","translation":"সেচ করা হয়","audioUrl":"wbw/013_004_013.mp3","charTypeName":"word"},{"id":4373,"position":14,"arabic":"بِمَآءٍۢ","translation":"দিয়ে পানি","audioUrl":"wbw/013_004_014.mp3","charTypeName":"word"},{"id":4374,"position":15,"arabic":"وَٰحِدٍۢ","translation":"একই","audioUrl":"wbw/013_004_015.mp3","charTypeName":"word"},{"id":4375,"position":16,"arabic":"وَنُفَضِّلُ","translation":"এবং শ্রেষ্ঠত্ব দিই আমরা","audioUrl":"wbw/013_004_016.mp3","charTypeName":"word"},{"id":4376,"position":17,"arabic":"بَعْضَهَا","translation":"কিছু সংখ্যককে তার","audioUrl":"wbw/013_004_017.mp3","charTypeName":"word"},{"id":4377,"position":18,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/013_004_018.mp3","charTypeName":"word"},{"id":4378,"position":19,"arabic":"بَعْضٍۢ","translation":"কিছু সংখ্যকের","audioUrl":"wbw/013_004_019.mp3","charTypeName":"word"},{"id":4379,"position":20,"arabic":"فِى","translation":"(স্বাদের) মধ্যে","audioUrl":"wbw/013_004_020.mp3","charTypeName":"word"},{"id":4380,"position":21,