{"id":288,"ayahs":[{"number":59,"arabic":"وَمَا مَنَعَنَآ أَن نُّرْسِلَ بِٱلْءَايَٰتِ إِلَّآ أَن كَذَّبَ بِهَا ٱلْأَوَّلُونَ ۚ وَءَاتَيْنَا ثَمُودَ ٱلنَّاقَةَ مُبْصِرَةًۭ فَظَلَمُوا۟ بِهَا ۚ وَمَا نُرْسِلُ بِٱلْءَايَٰتِ إِلَّا تَخْوِيفًۭا","translation":"And nothing has prevented Us from sending [this message, like the earlier ones,] with miraculous signs [in its wake], save [Our knowledge] that the people of olden times [only too often] gave the lie to them: thus, We provided for [the tribe of] Thamud the she-camel as a light-giving portent, and they sinned against it. And never did We send those signs for any other purpose than to convey a warning.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2088.mp3","surahId":17,"words":[{"id":53675,"position":1,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/017_059_001.mp3","charTypeName":"word"},{"id":53676,"position":2,"arabic":"مَنَعَنَآ","translation":"কেউ আমাদেরকে বিরত রেখেছে","audioUrl":"wbw/017_059_002.mp3","charTypeName":"word"},{"id":53677,"position":3,"arabic":"أَن","translation":"যে","audioUrl":"wbw/017_059_003.mp3","charTypeName":"word"},{"id":53678,"position":4,"arabic":"نُّرْسِلَ","translation":"আমরা পাঠাবো","audioUrl":"wbw/017_059_004.mp3","charTypeName":"word"},{"id":53679,"position":5,"arabic":"بِٱلْـَٔايَـٰتِ","translation":"দিয়ে নিদর্শনাদি","audioUrl":"wbw/017_059_005.mp3","charTypeName":"word"},{"id":53680,"position":6,"arabic":"إِلَّآ","translation":"এ ছাড়া","audioUrl":"wbw/017_059_006.mp3","charTypeName":"word"},{"id":53681,"position":7,"arabic":"أَن","translation":"যে","audioUrl":"wbw/017_059_007.mp3","charTypeName":"word"},{"id":53682,"position":8,"arabic":"كَذَّبَ","translation":"মিথ্যারোপ করেছে","audioUrl":"wbw/017_059_008.mp3","charTypeName":"word"},{"id":53683,"position":9,"arabic":"بِهَا","translation":"ব্যাপারে তার","audioUrl":"wbw/017_059_009.mp3","charTypeName":"word"},{"id":53684,"position":10,"arabic":"ٱلْأَوَّلُونَ ۚ","translation":"পূর্ববর্তীরা","audioUrl":"wbw/017_059_010.mp3","charTypeName":"word"},{"id":53686,"position":11,"arabic":"وَءَاتَيْنَا","translation":"এবং আমরা দিয়েছি","audioUrl":"wbw/017_059_012.mp3","charTypeName":"word"},{"id":53687,"position":12,"arabic":"ثَمُودَ","translation":"সামুদকে","audioUrl":"wbw/017_059_013.mp3","charTypeName":"word"},{"id":53688,"position":13,"arabic":"ٱلنَّاقَةَ","translation":"মাদি উট","audioUrl":"wbw/017_059_014.mp3","charTypeName":"word"},{"id":53689,"position":14,"arabic":"مُبْصِرَةًۭ","translation":"প্রকাশ্য","audioUrl":"wbw/017_059_015.mp3","charTypeName":"word"},{"id":53690,"position":15,"arabic":"فَظَلَمُوا۟","translation":"তখন তারা নির্যাতন করে","audioUrl":"wbw/017_059_016.mp3","charTypeName":"word"},{"id":53691,"position":16,"arabic":"بِهَا ۚ","translation":"সাথে তার","audioUrl":"wbw/017_059_017.mp3","charTypeName":"word"},{"id":53693,"position":17,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/017_059_019.mp3","charTypeName":"word"},{"id":53694,"position":18,"arabic":"نُرْسِلُ","translation":"আমরা পাঠাই","audioUrl":"wbw/017_059_020.mp3","charTypeName":"word"},{"id":53695,"position":19,"arabic":"بِٱلْـَٔايَـٰتِ","translation":"দিয়ে নিদের্শনাদি","audioUrl":"wbw/017_059_021.mp3","charTypeName":"word"},{"id":53696,"position":20,"arabic":"إِلَّا","translation":"এ ছাড়া যে","audioUrl":"wbw/017_059_022.mp3","charTypeName":"word"},{"id":53697,"position":21,"arabic":"تَخْوِيفًۭا","translation":"ভয় স্বরূপ","audioUrl":"wbw/017_059_023.mp3","charTypeName":"word"},{"id":53698,"position":22,"arabic":"٥٩","translation":"(৫৯)","audioUrl":null,"charTypeName":"end"}]},{"number":60,"arabic":"وَإِذْ قُلْنَا لَكَ إِنَّ رَبَّكَ أَحَاطَ بِٱلنَّاسِ ۚ وَمَا جَعَلْنَا ٱلرُّءْيَا ٱلَّتِىٓ أَرَيْنَٰكَ إِلَّا فِتْنَةًۭ لِّلنَّاسِ وَٱلشَّجَرَةَ ٱلْمَلْعُونَةَ فِى ٱلْقُرْءَانِ ۚ وَنُخَوِّفُهُمْ فَمَا يَزِيدُهُمْ إِلَّا طُغْيَٰنًۭا كَبِيرًۭا","translation":"And lo! We said unto thee, [O Prophet:] \"Behold, thy Sustainer encompasses all mankind [within His knowledge and might]: and so We have ordained that the vision which We have shown thee -as also the tree [of hell,] cursed in this Qur'an - shall be but a trial for men. Now [by Our mentioning hell] We convey a warning to them: but [if they are bent on denying the truth,] this [warning] only increases their gross, overweening arrogance.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2089.mp3","surahId":17,"words":[{"id":54248,"position":1,"arabic":"وَإِذْ","translation":"এবং যখন","audioUrl":"wbw/017_060_001.mp3","charTypeName":"word"},{"id":54249,"position":2,"arabic":"قُلْنَا","translation":"আমরা বলেছিলাম","audioUrl":"wbw/017_060_002.mp3","charTypeName":"word"},{"id":54250,"position":3,"arabic":"لَكَ","translation":"তোমাকে","audioUrl":"wbw/017_060_003.mp3","charTypeName":"word"},{"id":54251,"position":4,"arabic":"إِنَّ","translation":"\"নিশ্চয়ই","audioUrl":"wbw/017_060_004.mp3","charTypeName":"word"},{"id":54252,"position":5,"arabic":"رَبَّكَ","translation":"তোমার রব","audioUrl":"wbw/017_060_005.mp3","charTypeName":"word"},{"id":54253,"position":6,"arabic":"أَحَاطَ","translation":"ঘিরে রেখেছেন","audioUrl":"wbw/017_060_006.mp3","charTypeName":"word"},{"id":54254,"position":7,"arabic":"بِٱلنَّاسِ ۚ","translation":"নিয়ে মানুষকে\"","audioUrl":"wbw/017_060_007.mp3","charTypeName":"word"},{"id":54256,"position":8,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/017_060_009.mp3","charTypeName":"word"},{"id":54257,"position":9,"arabic":"جَعَلْنَا","translation":"আমরা করেছি","audioUrl":"wbw/017_060_010.mp3","charTypeName":"word"},{"id":54258,"position":10,"arabic":"ٱلرُّءْيَا","translation":"দৃশ্য","audioUrl":"wbw/017_060_011.mp3","charTypeName":"word"},{"id":54259,"position":11,"arabic":"ٱلَّتِىٓ","translation":"যা","audioUrl":"wbw/017_060_012.mp3","charTypeName":"word"},{"id":54260,"position":12,"arabic":"أَرَيْنَـٰكَ","translation":"তোমাকে আমরা দেখিয়েছি","audioUrl":"wbw/017_060_013.mp3","charTypeName":"word"},{"id":54261,"position":13,"arabic":"إِلَّا","translation":"এ ছাড়া যে","audioUrl":"wbw/017_060_014.mp3","charTypeName":"word"},{"id":54262,"position":14,"arabic":"فِتْنَةًۭ","translation":"পরীক্ষা","audioUrl":"wbw/017_060_015.mp3","charTypeName":"word"},{"id":54263,"position":15,"arabic":"لِّلنَّاسِ","translation":"মানুষের জন্যে","audioUrl":"wbw/017_060_016.mp3","charTypeName":"word"},{"id":54264,"position":16,"arabic":"وَٱلشَّجَرَةَ","translation":"এবং গাছটিকেও","audioUrl":"wbw/017_060_017.mp3","charTypeName":"word"},{"id":54265,"position":17,"arabic":"ٱلْمَلْعُونَةَ","translation":"অভিশপ্ত","audioUrl":"wbw/017_060_018.mp3","charTypeName":"word"},{"id":54266,"position":18,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/017_060_019.mp3","charTypeName":"word"},{"id":54267,"position":19,"arabic":"ٱلْقُرْءَانِ ۚ","translation":"কুরআনের","audioUrl":"wbw/017_060_020.mp3","charTypeName":"word"},{"id":54269,"position":20,"arabic":"وَنُخَوِّفُهُمْ","translation":"এবং ভয় দেখাই আমরা তাদের","audioUrl":"wbw/017_060_022.mp3","charTypeName":"word"},{"id":54270,"position":21,"arabic":"فَمَا","translation":"কিন্তু না","audioUrl":"wbw/017_060_023.mp3","charTypeName":"word"},{"id":54271,"position":22,"arabic":"يَزِيدُهُمْ","translation":"তাদের বৃদ্ধি করে","audioUrl":"wbw/017_060_024.mp3","charTypeName":"word"},{"id":54272,"position":23,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/017_060_025.mp3","charTypeName":"word"},{"id":54273,"position":24,"arabic":"طُغْيَـٰنًۭا","translation":"অবাধ্যতা","audioUrl":"wbw/017_060_026.mp3","charTypeName":"word"},{"id":54274,"position":25,"arabic":"كَبِيرًۭا","translation":"ঘোর","audioUrl":"wbw/017_060_027.mp3","charTypeName":"word"},{"id":54275,"position":26,"arabic":"٦٠","translation":"(৬০)","audioUrl":null,"charTypeName":"end"}]},{"number":61,"arabic":"وَإِذْ قُلْنَا لِلْمَلَٰٓئِكَةِ ٱسْجُدُوا۟ لِءَادَمَ فَسَجَدُوٓا۟ إِلَّآ إِبْلِيسَ قَالَ ءَأَسْجُدُ لِمَنْ خَلَقْتَ طِينًۭا","translation":"AND LO! We said unto the angels, \"Prostrate yourselves before Adam\"-whereupon they all prostrated themselves, save Iblis. Said he: \"Shall I prostrate myself before one whom Thou hast created out of clay?\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2090.mp3","surahId":17,"words":[{"id":54975,"position":1,"arabic":"وَإِذْ","translation":"এবং যখন","audioUrl":"wbw/017_061_001.mp3","charTypeName":"word"},{"id":54976,"position":2,"arabic":"قُلْنَا","translation":"আমরা বলেছিলাম","audioUrl":"wbw/017_061_002.mp3","charTypeName":"word"},{"id":54977,"position":3,"arabic":"لِلْمَلَـٰٓئِكَةِ","translation":"ফেরেশতাদেরকে","audioUrl":"wbw/017_061_003.mp3","charTypeName":"word"},{"id":54978,"position":4,"arabic":"ٱسْجُدُوا۟","translation":"\"তোমরা সিজদা করো","audioUrl":"wbw/017_061_004.mp3","charTypeName":"word"},{"id":54979,"position":5,"arabic":"لِـَٔادَمَ","translation":"আদমকে\"","audioUrl":"wbw/017_061_005.mp3","charTypeName":"word"},{"id":54980,"position":6,"arabic":"فَسَجَدُوٓا۟","translation":"অতঃপর তারা সিজদা করলো","audioUrl":"wbw/017_061_006.mp3","charTypeName":"word"},{"id":54981,"position":7,"arabic":"إِلَّآ","translation":"ছাড়া","audioUrl":"wbw/017_061_007.mp3","charTypeName":"word"},{"id":54982,"position":8,"arabic":"إِبْلِيسَ","translation":"ইবলীস","audioUrl":"wbw/017_061_008.mp3","charTypeName":"word"},{"id":54983,"position":9,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/017_061_009.mp3","charTypeName":"word"},{"id":54984,"position":10,"arabic":"ءَأَسْجُدُ","translation":"\"আমি কি সিজদা করবো","audioUrl":"wbw/017_061_010.mp3","charTypeName":"word"},{"id":54985,"position":11,"arabic":"لِمَنْ","translation":"জন্যে তার (যাকে)","audioUrl":"wbw/017_061_011.mp3","charTypeName":"word"},{"id":54986,"position":12,"arabic":"خَلَقْتَ","translation":"আপনি সৃষ্টি করেছেন","audioUrl":"wbw/017_061_012.mp3","charTypeName":"word"},{"id":54987,"position":13,"arabic":"طِينًۭا","translation":"কাদা মাটি (হ'তে)\"","audioUrl":"wbw/017_061_013.mp3","charTypeName":"word"},{"id":54988,"position":14,"arabic":"٦١","translation":"(৬১)","audioUrl":null,"charTypeName":"end"}]},{"number":62,"arabic":"قَالَ أَرَءَيْتَكَ هَٰذَا ٱلَّذِى كَرَّمْتَ عَلَىَّ لَئِنْ أَخَّرْتَنِ إِلَىٰ يَوْمِ ٱلْقِيَٰمَةِ لَأَحْتَنِكَنَّ ذُرِّيَّتَهُۥٓ إِلَّا قَلِيلًۭا","translation":"[And] he added: \"Tell me, is this [foolish being] the one whom Thou hast exalted above me? Indeed, if Thou wilt but allow me a respite till the Day of Resurrection, I shall most certainly cause his descendants-all but a few-to obey me blindly!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2091.mp3","surahId":17,"words":[{"id":55454,"position":1,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/017_062_001.mp3","charTypeName":"word"},{"id":55455,"position":2,"arabic":"أَرَءَيْتَكَ","translation":"\"কি আপনি মনে করেন","audioUrl":"wbw/017_062_002.mp3","charTypeName":"word"},{"id":55456,"position":3,"arabic":"هَـٰذَا","translation":"এই","audioUrl":"wbw/017_062_003.mp3","charTypeName":"word"},{"id":55457,"position":4,"arabic":"ٱلَّذِى","translation":"যাকে","audioUrl":"wbw/017_062_004.mp3","charTypeName":"word"},{"id":55458,"position":5,"arabic":"كَرَّمْتَ","translation":"আপনি মর্যাদা দিয়েছেন","audioUrl":"wbw/017_062_005.mp3","charTypeName":"word"},{"id":55459,"position":6,"arabic":"عَلَىَّ","translation":"আমার উপর","audioUrl":"wbw/017_062_006.mp3","charTypeName":"word"},{"id":55460,"position":7,"arabic":"لَئِنْ","translation":"অবশ্যই যদি","audioUrl":"wbw/017_062_007.mp3","charTypeName":"word"},{"id":55461,"position":8,"arabic":"أَخَّرْتَنِ","translation":"আমাকে আপনি অবকাশ দেন","audioUrl":"wbw/017_062_008.mp3","charTypeName":"word"},{"id":55462,"position":9,"arabic":"إِلَىٰ","translation":"পর্যন্ত","audioUrl":"wbw/017_062_009.mp3","charTypeName":"word"},{"id":55463,"position":10,"arabic":"يَوْمِ","translation":"দিন","audioUrl":"wbw/017_062_010.mp3","charTypeName":"word"},{"id":55464,"position":11,"arabic":"ٱلْقِيَـٰمَةِ","translation":"ক্বিয়ামাতের","audioUrl":"wbw/017_062_011.mp3","charTypeName":"word"},{"id":55465,"position":12,"arabic":"لَأَحْتَنِكَنَّ","translation":"আমি অবশ্যই সমূলে নষ্ট করবো","audioUrl":"wbw/017_062_012.mp3","charTypeName":"word"},{"id":55466,"position":13,"arabic":"ذُرِّيَّتَهُۥٓ","translation":"তার বংশধরদের","audioUrl":"wbw/017_062_013.mp3","charTypeName":"word"},{"id":55467,"position":14,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/017_062_014.mp3","charTypeName":"word"},{"id":55468,"position":15,"arabic":"قَلِيلًۭا","translation":"স্বল্প সংখ্যক\"","audioUrl":"wbw/017_062_015.mp3","charTypeName":"word"},{"id":55469,"position":16,"arabic":"٦٢","translation":"(৬২)","audioUrl":null,"charTypeName":"end"}]},{"number":63,"arabic":"قَالَ ٱذْهَبْ فَمَن تَبِعَكَ مِنْهُمْ فَإِنَّ جَهَنَّمَ جَزَآؤُكُمْ جَزَآءًۭ مَّوْفُورًۭا","translation":"[God] answered: \"Go [the way thou hast chosen]! But as for such of them as shall follow thee - behold, hell will be the recompense of you (all], a recompense most ample!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2092.mp3","surahId":17,"words":[{"id":55971,"position":1,"arabic":"قَالَ","translation":"তিনি বললেন","audioUrl":"wbw/017_063_001.mp3","charTypeName":"word"},{"id":55972,"position":2,"arabic":"ٱذْهَبْ","translation":"\"তুমি যাও","audioUrl":"wbw/017_063_002.mp3","charTypeName":"word"},{"id":55973,"position":3,"arabic":"فَمَن","translation":"অতঃপর যে","audioUrl":"wbw/017_063_003.mp3","charTypeName":"word"},{"id":55974,"position":4,"arabic":"تَبِعَكَ","translation":"তোমার অনুসরণ করবে","audioUrl":"wbw/017_063_004.mp3","charTypeName":"word"},{"id":55975,"position":5,"arabic":"مِنْهُمْ","translation":"তাদের মধ্যে থেকে","audioUrl":"wbw/017_063_005.mp3","charTypeName":"word"},{"id":55976,"position":6,"arabic":"فَإِنَّ","translation":"তাহ'লে  নিশ্চয়ই","audioUrl":"wbw/017_063_006.mp3","charTypeName":"word"},{"id":55977,"position":7,"arabic":"جَهَنَّمَ","translation":"জাহান্নাম হবে","audioUrl":"wbw/017_063_007.mp3","charTypeName":"word"},{"id":55978,"position":8,"arabic":"جَزَآؤُكُمْ","translation":"তোমাদের প্রতিফল","audioUrl":"wbw/017_063_008.mp3","charTypeName":"word"},{"id":55979,"position":9,"arabic":"جَزَآءًۭ","translation":"প্রতিফল","audioUrl":"wbw/017_063_009.mp3","charTypeName":"word"},{"id":55980,"position":10,"arabic":"مَّوْفُورًۭا","translation":"পূর্ণ","audioUrl":"wbw/017_063_010.mp3","charTypeName":"word"},{"id":55981,"position":11,"arabic":"٦٣","translation":"(৬৩)","audioUrl":null,"charTypeName":"end"}]},{"number":64,"arabic":"وَٱسْتَفْزِزْ مَنِ ٱسْتَطَعْتَ مِنْهُم بِصَوْتِكَ وَأَجْلِبْ عَلَيْهِم بِخَيْلِكَ وَرَجِلِكَ وَشَارِكْهُمْ فِى ٱلْأَمْوَٰلِ وَٱلْأَوْلَٰدِ وَعِدْهُمْ ۚ وَمَا يَعِدُهُمُ ٱلشَّيْطَٰنُ إِلَّا غُرُورًا","translation":"Entice, then, with thy voice such of them as thou canst, and bear upon them with all thy horses and all thy men, and be their partner in [all sins relating to] worldly goods and children, and hold out [all manner of] promises to them: and [they will not know that] whatever Satan promises them is but meant to delude the mind.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2093.mp3","surahId":17,"words":[{"id":56483,"position":1,"arabic":"وَٱسْتَفْزِزْ","translation":"এবং পদস্খলিত করো","audioUrl":"wbw/017_064_001.mp3","charTypeName":"word"},{"id":56484,"position":2,"arabic":"مَنِ","translation":"যাকে","audioUrl":"wbw/017_064_002.mp3","charTypeName":"word"},{"id":56485,"position":3,"arabic":"ٱسْتَطَعْتَ","translation":"তুমি পারো","audioUrl":"wbw/017_064_003.mp3","charTypeName":"word"},{"id":56486,"position":4,"arabic":"مِنْهُم","translation":"মধ্য হ'তে তাদের","audioUrl":"wbw/017_064_004.mp3","charTypeName":"word"},{"id":56487,"position":5,"arabic":"بِصَوْتِكَ","translation":"দিয়ে তোমার কন্ঠস্বর","audioUrl":"wbw/017_064_005.mp3","charTypeName":"word"},{"id":56488,"position":6,"arabic":"وَأَجْلِبْ","translation":"ও চড়াও হও","audioUrl":"wbw/017_064_006.mp3","charTypeName":"word"},{"id":56489,"position":7,"arabic":"عَلَيْهِم","translation":"উপর তাদের","audioUrl":"wbw/017_064_007.mp3","charTypeName":"word"},{"id":56490,"position":8,"arabic":"بِخَيْلِكَ","translation":"নিয়ে তোমার অশ্বারোহী বাহিনী","audioUrl":"wbw/017_064_008.mp3","charTypeName":"word"},{"id":56491,"position":9,"arabic":"وَرَجِلِكَ","translation":"ও তোমার পদাতিক বাহিনী","audioUrl":"wbw/017_064_009.mp3","charTypeName":"word"},{"id":56492,"position":10,"arabic":"وَشَارِكْهُمْ","translation":"এবং সহযোগী করো তাদের","audioUrl":"wbw/017_064_010.mp3","charTypeName":"word"},{"id":56493,"position":11,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/017_064_011.mp3","charTypeName":"word"},{"id":56494,"position":12,"arabic":"ٱلْأَمْوَٰلِ","translation":"সম্পদসমূহের","audioUrl":"wbw/017_064_012.mp3","charTypeName":"word"},{"id":56495,"position":13,"arabic":"وَٱلْأَوْلَـٰدِ","translation":"ও সন্তানদের","audioUrl":"wbw/017_064_013.mp3","charTypeName":"word"},{"id":56496,"position":14,"arabic":"وَعِدْهُمْ ۚ","translation":"এবং তাদের প্রতিশ্রুতি দাও\"","audioUrl":"wbw/017_064_014.mp3","charTypeName":"word"},{"id":56498,"position":15,"arabic":"وَمَا","translation":"আর না","audioUrl":"wbw/017_064_016.mp3","charTypeName":"word"},{"id":56499,"position":16,"arabic":"يَعِدُهُمُ","translation":"তাদেরকে প্রতিশ্রুতি দেয়","audioUrl":"wbw/017_064_017.mp3","charTypeName":"word"},{"id":56500,"position":17,"arabic":"ٱلشَّيْطَـٰنُ","translation":"শয়তান","audioUrl":"wbw/017_064_018.mp3","charTypeName":"word"},{"id":56501,"position":18,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/017_064_019.mp3","charTypeName":"word"},{"id":56502,"position":19,"arabic":"غُرُورًا","translation":"প্রতারণা","audioUrl":"wbw/017_064_020.mp3","charTypeName":"word"},{"id":56503,"position":20,"arabic":"٦٤","translation":"(৬৪)","audioUrl":null,"charTypeName":"end"}]},{"number":65,"arabic":"إِنَّ عِبَادِى لَيْسَ لَكَ عَلَيْهِمْ سُلْطَٰنٌۭ ۚ وَكَفَىٰ بِرَبِّكَ وَكِيلًۭا","translation":"\"(And yet,] behold, thou shalt have no power over [such of] My servants [as place their trust in Me]: for none is as worthy of trust as thy Sustainer.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2094.mp3","surahId":17,"words":[{"id":57046,"position":1,"arabic":"إِنَّ","translation":"\"নিশ্চয়ই","audioUrl":"wbw/017_065_001.mp3","charTypeName":"word"},{"id":57047,"position":2,"arabic":"عِبَادِى","translation":"আমার দাসদের","audioUrl":"wbw/017_065_002.mp3","charTypeName":"word"},{"id":57048,"position":3,"arabic":"لَيْسَ","translation":"নেই","audioUrl":"wbw/017_065_003.mp3","charTypeName":"word"},{"id":57049,"position":4,"arabic":"لَكَ","translation":"জন্যে তোমার","audioUrl":"wbw/017_065_004.mp3","charTypeName":"word"},{"id":57050,"position":5,"arabic":"عَلَيْهِمْ","translation":"উপর তাদের","audioUrl":"wbw/017_065_005.mp3","charTypeName":"word"},{"id":57051,"position":6,"arabic":"سُلْطَـٰنٌۭ ۚ","translation":"কোনো আধিপত্য","audioUrl":"wbw/017_065_006.mp3","charTypeName":"word"},{"id":57053,"position":7,"arabic":"وَكَفَىٰ","translation":"এবং যথেষ্ট","audioUrl":"wbw/017_065_008.mp3","charTypeName":"word"},{"id":57054,"position":8,"arabic":"بِرَبِّكَ","translation":"তোমার রব","audioUrl":"wbw/017_065_009.mp3","charTypeName":"word"},{"id":57055,"position":9,"arabic":"وَكِيلًۭا","translation":"কর্মবিধায়ক হিসেবে\"","audioUrl":"wbw/017_065_010.mp3","charTypeName":"word"},{"id":57056,"position":10,"arabic":"٦٥","translation":"(৬৫)","audioUrl":null,"charTypeName":"end"}]},{"number":66,"arabic":"رَّبُّكُمُ ٱلَّذِى يُزْجِى لَكُمُ ٱلْفُلْكَ فِى ٱلْبَحْرِ لِتَبْتَغُوا۟ مِن فَضْلِهِۦٓ ۚ إِنَّهُۥ كَانَ بِكُمْ رَحِيمًۭا","translation":"YOUR SUSTAINER is He who causes ships to move onward for you through the sea, so that you might go about in quest of some of His bounty: verily, a dispenser of grace is He unto you.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2095.mp3","surahId":17,"words":[{"id":57502,"position":1,"arabic":"رَّبُّكُمُ","translation":"তোমাদের রব","audioUrl":"wbw/017_066_001.mp3","charTypeName":"word"},{"id":57503,"position":2,"arabic":"ٱلَّذِى","translation":"(তিনিই) যিনি","audioUrl":"wbw/017_066_002.mp3","charTypeName":"word"},{"id":57504,"position":3,"arabic":"يُزْجِى","translation":"চালনা করেন","audioUrl":"wbw/017_066_003.mp3","charTypeName":"word"},{"id":57505,"position":4,"arabic":"لَكُمُ","translation":"জন্যে তোমাদের","audioUrl":"wbw/017_066_004.mp3","charTypeName":"word"},{"id":57506,"position":5,"arabic":"ٱلْفُلْكَ","translation":"নৌযান","audioUrl":"wbw/017_066_005.mp3","charTypeName":"word"},{"id":57507,"position":6,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/017_066_006.mp3","charTypeName":"word"},{"id":57508,"position":7,"arabic":"ٱلْبَحْرِ","translation":"সাগরের","audioUrl":"wbw/017_066_007.mp3","charTypeName":"word"},{"id":57509,"position":8,"arabic":"لِتَبْتَغُوا۟","translation":"যেন তোমরা সন্ধান করতে পারো","audioUrl":"wbw/017_066_008.mp3","charTypeName":"word"},{"id":57510,"position":9,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/017_066_009.mp3","charTypeName":"word"},{"id":57511,"position":10,"arabic":"فَضْلِهِۦٓ ۚ","translation":"তাঁর অনুগ্রহ","audioUrl":"wbw/017_066_010.mp3","charTypeName":"word"},{"id":57513,"position":11,"arabic":"إِنَّهُۥ","translation":"নিশ্চয়ই তিনি","audioUrl":"wbw/017_066_012.mp3","charTypeName":"word"},{"id":57514,"position":12,"arabic":"كَانَ","translation":"হলেন","audioUrl":"wbw/017_066_013.mp3","charTypeName":"word"},{"id":57515,"position":13,"arabic":"بِكُمْ","translation":"উপর তোমাদের","audioUrl":"wbw/017_066_014.mp3","charTypeName":"word"},{"id":57516,"position":14,"arabic":"رَحِيمًۭا","translation":"দয়াশীল","audioUrl":"wbw/017_066_015.mp3","charTypeName":"word"},{"id":57517,"position":15,"arabic":"٦٦","translation":"(৬৬)","audioUrl":null,"charTypeName":"end"}]}]}