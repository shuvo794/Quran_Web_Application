{"id":112,"ayahs":[{"number":24,"arabic":"قَالُوا۟ يَٰمُوسَىٰٓ إِنَّا لَن نَّدْخُلَهَآ أَبَدًۭا مَّا دَامُوا۟ فِيهَا ۖ فَٱذْهَبْ أَنتَ وَرَبُّكَ فَقَٰتِلَآ إِنَّا هَٰهُنَا قَٰعِدُونَ","translation":"[But] they said: \"O Moses! Behold, never shall we enter that [land] so long as those others are in it. Go forth, then, thou and thy Sustainer, and fight, both of you! We, behold, shall remain here!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/693.mp3","surahId":5,"words":[{"id":27122,"position":1,"arabic":"قَالُوا۟","translation":"(কিন্তু এ সত্ত্বেও) তারা বলেছিলো","audioUrl":"wbw/005_024_001.mp3","charTypeName":"word"},{"id":27123,"position":2,"arabic":"يَـٰمُوسَىٰٓ","translation":"হে মূসা","audioUrl":"wbw/005_024_002.mp3","charTypeName":"word"},{"id":27124,"position":3,"arabic":"إِنَّا","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/005_024_003.mp3","charTypeName":"word"},{"id":27125,"position":4,"arabic":"لَن","translation":"কখনও না","audioUrl":"wbw/005_024_004.mp3","charTypeName":"word"},{"id":27126,"position":5,"arabic":"نَّدْخُلَهَآ","translation":"প্রবেশ করবো আমরা তাতে","audioUrl":"wbw/005_024_005.mp3","charTypeName":"word"},{"id":27127,"position":6,"arabic":"أَبَدًۭا","translation":"কখনও","audioUrl":"wbw/005_024_006.mp3","charTypeName":"word"},{"id":27128,"position":7,"arabic":"مَّا","translation":"যতক্ষণ","audioUrl":"wbw/005_024_007.mp3","charTypeName":"word"},{"id":27129,"position":8,"arabic":"دَامُوا۟","translation":"তারা থাকবে","audioUrl":"wbw/005_024_008.mp3","charTypeName":"word"},{"id":27130,"position":9,"arabic":"فِيهَا ۖ","translation":"মধ্যে তার","audioUrl":"wbw/005_024_009.mp3","charTypeName":"word"},{"id":27132,"position":10,"arabic":"فَٱذْهَبْ","translation":"অতএব যাও","audioUrl":"wbw/005_024_011.mp3","charTypeName":"word"},{"id":27133,"position":11,"arabic":"أَنتَ","translation":"তুমি","audioUrl":"wbw/005_024_012.mp3","charTypeName":"word"},{"id":27134,"position":12,"arabic":"وَرَبُّكَ","translation":"ও রব তোমার","audioUrl":"wbw/005_024_013.mp3","charTypeName":"word"},{"id":27135,"position":13,"arabic":"فَقَـٰتِلَآ","translation":"অত:পর উভয়ে যুদ্ধ করো","audioUrl":"wbw/005_024_014.mp3","charTypeName":"word"},{"id":27136,"position":14,"arabic":"إِنَّا","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/005_024_015.mp3","charTypeName":"word"},{"id":27137,"position":15,"arabic":"هَـٰهُنَا","translation":"এখানে","audioUrl":"wbw/005_024_016.mp3","charTypeName":"word"},{"id":27138,"position":16,"arabic":"قَـٰعِدُونَ","translation":"বসে থাকবো\"","audioUrl":"wbw/005_024_017.mp3","charTypeName":"word"},{"id":27139,"position":17,"arabic":"٢٤","translation":"(২৪)","audioUrl":null,"charTypeName":"end"}]},{"number":25,"arabic":"قَالَ رَبِّ إِنِّى لَآ أَمْلِكُ إِلَّا نَفْسِى وَأَخِى ۖ فَٱفْرُقْ بَيْنَنَا وَبَيْنَ ٱلْقَوْمِ ٱلْفَٰسِقِينَ","translation":"Prayed [Moses]: \"O my Sustainer! Of none am I master but of myself and my brother [Aaron]: draw Thou, then, a dividing-line between us and these iniquitous folk!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/694.mp3","surahId":5,"words":[{"id":28133,"position":1,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/005_025_001.mp3","charTypeName":"word"},{"id":28134,"position":2,"arabic":"رَبِّ","translation":"\"হে আমার রব","audioUrl":"wbw/005_025_002.mp3","charTypeName":"word"},{"id":28135,"position":3,"arabic":"إِنِّى","translation":"নিশ্চয়ই আমি","audioUrl":"wbw/005_025_003.mp3","charTypeName":"word"},{"id":28136,"position":4,"arabic":"لَآ","translation":"না","audioUrl":"wbw/005_025_004.mp3","charTypeName":"word"},{"id":28137,"position":5,"arabic":"أَمْلِكُ","translation":"ক্ষমতা রাখি আমি","audioUrl":"wbw/005_025_005.mp3","charTypeName":"word"},{"id":28138,"position":6,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/005_025_006.mp3","charTypeName":"word"},{"id":28139,"position":7,"arabic":"نَفْسِى","translation":"আমার নিজের","audioUrl":"wbw/005_025_007.mp3","charTypeName":"word"},{"id":28140,"position":8,"arabic":"وَأَخِى ۖ","translation":"ও আমার ভাইয়ের","audioUrl":"wbw/005_025_008.mp3","charTypeName":"word"},{"id":28142,"position":9,"arabic":"فَٱفْرُقْ","translation":"তাই পৃথক করো","audioUrl":"wbw/005_025_010.mp3","charTypeName":"word"},{"id":28143,"position":10,"arabic":"بَيْنَنَا","translation":"মাঝে আমাদের","audioUrl":"wbw/005_025_011.mp3","charTypeName":"word"},{"id":28144,"position":11,"arabic":"وَبَيْنَ","translation":"ও মাঝে","audioUrl":"wbw/005_025_012.mp3","charTypeName":"word"},{"id":28145,"position":12,"arabic":"ٱلْقَوْمِ","translation":"সম্প্রদায়ের\"","audioUrl":"wbw/005_025_013.mp3","charTypeName":"word"},{"id":28146,"position":13,"arabic":"ٱلْفَـٰسِقِينَ","translation":"(যারা)সত্যত্যাগী\"","audioUrl":"wbw/005_025_014.mp3","charTypeName":"word"},{"id":28147,"position":14,"arabic":"٢٥","translation":"(২৫)","audioUrl":null,"charTypeName":"end"}]},{"number":26,"arabic":"قَالَ فَإِنَّهَا مُحَرَّمَةٌ عَلَيْهِمْ ۛ أَرْبَعِينَ سَنَةًۭ ۛ يَتِيهُونَ فِى ٱلْأَرْضِ ۚ فَلَا تَأْسَ عَلَى ٱلْقَوْمِ ٱلْفَٰسِقِينَ","translation":"Answered He: \"Then, verily, this [land] shall be forbidden to them for forty years, while they wander on earth, bewildered, to and fro; and sorrow thou not over these iniquitous folk.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/695.mp3","surahId":5,"words":[{"id":28896,"position":1,"arabic":"قَالَ","translation":"(আল্লাহ) বললেন","audioUrl":"wbw/005_026_001.mp3","charTypeName":"word"},{"id":28897,"position":2,"arabic":"فَإِنَّهَا","translation":"\"অত:পর নিশ্চয়ই তা","audioUrl":"wbw/005_026_002.mp3","charTypeName":"word"},{"id":28898,"position":3,"arabic":"مُحَرَّمَةٌ","translation":"নিষিদ্ধ (করা হলো)","audioUrl":"wbw/005_026_003.mp3","charTypeName":"word"},{"id":28899,"position":4,"arabic":"عَلَيْهِمْ ۛ","translation":"উপর তাদের","audioUrl":"wbw/005_026_004.mp3","charTypeName":"word"},{"id":28901,"position":5,"arabic":"أَرْبَعِينَ","translation":"চল্লিশ","audioUrl":"wbw/005_026_006.mp3","charTypeName":"word"},{"id":28902,"position":6,"arabic":"سَنَةًۭ ۛ","translation":"বছর (পর্যন্ত)","audioUrl":"wbw/005_026_007.mp3","charTypeName":"word"},{"id":28904,"position":7,"arabic":"يَتِيهُونَ","translation":"তারা উদ্ভ্রান্ত হয়ে ফিরবে","audioUrl":"wbw/005_026_009.mp3","charTypeName":"word"},{"id":28905,"position":8,"arabic":"فِى","translation":"উপর","audioUrl":"wbw/005_026_010.mp3","charTypeName":"word"},{"id":28906,"position":9,"arabic":"ٱلْأَرْضِ ۚ","translation":"পৃথিবীর","audioUrl":"wbw/005_026_011.mp3","charTypeName":"word"},{"id":28908,"position":10,"arabic":"فَلَا","translation":"অতএব না","audioUrl":"wbw/005_026_013.mp3","charTypeName":"word"},{"id":28909,"position":11,"arabic":"تَأْسَ","translation":"দু:খ করো","audioUrl":"wbw/005_026_014.mp3","charTypeName":"word"},{"id":28910,"position":12,"arabic":"عَلَى","translation":"জন্যে","audioUrl":"wbw/005_026_015.mp3","charTypeName":"word"},{"id":28911,"position":13,"arabic":"ٱلْقَوْمِ","translation":"(ঐসব)সম্প্রদায়ের\"","audioUrl":"wbw/005_026_016.mp3","charTypeName":"word"},{"id":28912,"position":14,"arabic":"ٱلْفَـٰسِقِينَ","translation":"(যারা)সত্যত্যাগী\"","audioUrl":"wbw/005_026_017.mp3","charTypeName":"word"},{"id":28913,"position":15,"arabic":"٢٦","translation":"(২৬)","audioUrl":null,"charTypeName":"end"}]},{"number":27,"arabic":"۞ وَٱتْلُ عَلَيْهِمْ نَبَأَ ٱبْنَىْ ءَادَمَ بِٱلْحَقِّ إِذْ قَرَّبَا قُرْبَانًۭا فَتُقُبِّلَ مِنْ أَحَدِهِمَا وَلَمْ يُتَقَبَّلْ مِنَ ٱلْءَاخَرِ قَالَ لَأَقْتُلَنَّكَ ۖ قَالَ إِنَّمَا يَتَقَبَّلُ ٱللَّهُ مِنَ ٱلْمُتَّقِينَ","translation":"AND CONVEY unto them, setting forth the truth, the story of the two sons of Adam -how each offered a sacrifice, and it was accepted from one of them whereas it was not accepted from the other. [And Cain] said: \"I will surely slay thee!\" [Abel] replied: \"Behold, God accepts only from those who are conscious of Him.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/696.mp3","surahId":5,"words":[{"id":29968,"position":1,"arabic":"۞ وَٱتْلُ","translation":"এবং তিলাওয়াত করে","audioUrl":"wbw/005_027_002.mp3","charTypeName":"word"},{"id":29969,"position":2,"arabic":"عَلَيْهِمْ","translation":"কাছে তাদের","audioUrl":"wbw/005_027_003.mp3","charTypeName":"word"},{"id":29970,"position":3,"arabic":"نَبَأَ","translation":"সংবাদ","audioUrl":"wbw/005_027_004.mp3","charTypeName":"word"},{"id":29971,"position":4,"arabic":"ٱبْنَىْ","translation":"দু’ছেলের","audioUrl":"wbw/005_027_005.mp3","charTypeName":"word"},{"id":29972,"position":5,"arabic":"ءَادَمَ","translation":"আদমের","audioUrl":"wbw/005_027_006.mp3","charTypeName":"word"},{"id":29973,"position":6,"arabic":"بِٱلْحَقِّ","translation":"ভাবে যথাযথ","audioUrl":"wbw/005_027_007.mp3","charTypeName":"word"},{"id":29974,"position":7,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/005_027_008.mp3","charTypeName":"word"},{"id":29975,"position":8,"arabic":"قَرَّبَا","translation":"দু’জনে পেশ করলো","audioUrl":"wbw/005_027_009.mp3","charTypeName":"word"},{"id":29976,"position":9,"arabic":"قُرْبَانًۭا","translation":"কুরবানি","audioUrl":"wbw/005_027_010.mp3","charTypeName":"word"},{"id":29977,"position":10,"arabic":"فَتُقُبِّلَ","translation":"তখন গ্রহণ করা হলো","audioUrl":"wbw/005_027_011.mp3","charTypeName":"word"},{"id":29978,"position":11,"arabic":"مِنْ","translation":"হতে","audioUrl":"wbw/005_027_012.mp3","charTypeName":"word"},{"id":29979,"position":12,"arabic":"أَحَدِهِمَا","translation":"দুু’জনের একজন তাদের","audioUrl":"wbw/005_027_013.mp3","charTypeName":"word"},{"id":29980,"position":13,"arabic":"وَلَمْ","translation":"এবং না","audioUrl":"wbw/005_027_014.mp3","charTypeName":"word"},{"id":29981,"position":14,"arabic":"يُتَقَبَّلْ","translation":"গ্রহণ করা হলো","audioUrl":"wbw/005_027_015.mp3","charTypeName":"word"},{"id":29982,"position":15,"arabic":"مِنَ","translation":"থেকে","audioUrl":"wbw/005_027_016.mp3","charTypeName":"word"},{"id":29983,"position":16,"arabic":"ٱلْـَٔاخَرِ","translation":"অন্য জনের","audioUrl":"wbw/005_027_017.mp3","charTypeName":"word"},{"id":29984,"position":17,"ar