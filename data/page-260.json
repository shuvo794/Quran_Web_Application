{"id":260,"ayahs":[{"number":34,"arabic":"وَءَاتَىٰكُم مِّن كُلِّ مَا سَأَلْتُمُوهُ ۚ وَإِن تَعُدُّوا۟ نِعْمَتَ ٱللَّهِ لَا تُحْصُوهَآ ۗ إِنَّ ٱلْإِنسَٰنَ لَظَلُومٌۭ كَفَّارٌۭ","translation":"And [always] does He give you something out of what you may be asking of Him; and should you try to count God's blessings, you could never compute them. [And yet,] behold, man is indeed most persistent in wrongdoing, stubbornly ingrate!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1784.mp3","surahId":14,"words":[{"id":36790,"position":1,"arabic":"وَءَاتَىٰكُم","translation":"এবং তোমাদের দিয়েছেন","audioUrl":"wbw/014_034_001.mp3","charTypeName":"word"},{"id":36791,"position":2,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/014_034_002.mp3","charTypeName":"word"},{"id":36792,"position":3,"arabic":"كُلِّ","translation":"সবকিছু","audioUrl":"wbw/014_034_003.mp3","charTypeName":"word"},{"id":36793,"position":4,"arabic":"مَا","translation":"যা","audioUrl":"wbw/014_034_004.mp3","charTypeName":"word"},{"id":36794,"position":5,"arabic":"سَأَلْتُمُوهُ ۚ","translation":"তাঁর কাছে তোমরা চেয়েছো","audioUrl":"wbw/014_034_005.mp3","charTypeName":"word"},{"id":36796,"position":6,"arabic":"وَإِن","translation":"এবং যদি","audioUrl":"wbw/014_034_007.mp3","charTypeName":"word"},{"id":36797,"position":7,"arabic":"تَعُدُّوا۟","translation":"তোমরা গণনা করো","audioUrl":"wbw/014_034_008.mp3","charTypeName":"word"},{"id":36798,"position":8,"arabic":"نِعْمَتَ","translation":"অনুগ্রহসমূহ","audioUrl":"wbw/014_034_009.mp3","charTypeName":"word"},{"id":36799,"position":9,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/014_034_010.mp3","charTypeName":"word"},{"id":36800,"position":10,"arabic":"لَا","translation":"না","audioUrl":"wbw/014_034_011.mp3","charTypeName":"word"},{"id":36801,"position":11,"arabic":"تُحْصُوهَآ ۗ","translation":"তার তোমরা সংখ্যা নির্ণয় করতে পারবে","audioUrl":"wbw/014_034_012.mp3","charTypeName":"word"},{"id":36803,"position":12,"arabic":"إِنَّ","tra