{"id":481,"ayahs":[{"number":39,"arabic":"وَمِنْ ءَايَٰتِهِۦٓ أَنَّكَ تَرَى ٱلْأَرْضَ خَٰشِعَةًۭ فَإِذَآ أَنزَلْنَا عَلَيْهَا ٱلْمَآءَ ٱهْتَزَّتْ وَرَبَتْ ۚ إِنَّ ٱلَّذِىٓ أَحْيَاهَا لَمُحْىِ ٱلْمَوْتَىٰٓ ۚ إِنَّهُۥ عَلَىٰ كُلِّ شَىْءٍۢ قَدِيرٌ","translation":"For among His signs is this: thou seest the earth lying desolate - and lo! when We send down water upon it, it stirs and swells [with life]! Verily, He who brings it to life can surely give life to the dead [of heart as well]: for, behold, He has the power to will anything.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4257.mp3","surahId":41,"words":[{"id":40339,"position":1,"arabic":"وَمِنْ","translation":"এবং মধ্য হ'তে","audioUrl":"wbw/041_039_001.mp3","charTypeName":"word"},{"id":40340,"position":2,"arabic":"ءَايَـٰتِهِۦٓ","translation":"তাঁর নিদর্শনাবলীর","audioUrl":"wbw/041_039_002.mp3","charTypeName":"word"},{"id":40341,"position":3,"arabic":"أَنَّكَ","translation":"(এগুলোও) যে","audioUrl":"wbw/041_039_003.mp3","charTypeName":"word"},{"id":40342,"position":4,"arabic":"تَرَى","translation":"তুমি দেখো","audioUrl":"wbw/041_039_004.mp3","charTypeName":"word"},{"id":40343,"position":5,"arabic":"ٱلْأَرْضَ","translation":"জমিকে","audioUrl":"wbw/041_039_005.mp3","charTypeName":"word"},{"id":40344,"position":6,"arabic":"خَـٰشِعَةًۭ","translation":"ঊষর (তৃণলতাহীন)","audioUrl":"wbw/041_039_006.mp3","charTypeName":"word"},{"id":40345,"position":7,"arabic":"فَإِذَآ","translation":"অতঃপর যখন","audioUrl":"wbw/041_039_007.mp3","charTypeName":"word"},{"id":40346,"position":8,"arabic":"أَنزَلْنَا","translation":"আমরা বর্ষণ করি","audioUrl":"wbw/041_039_008.mp3","charTypeName":"word"},{"id":40347,"position":9,"arabic":"عَلَيْهَا","translation":"তার উপর","audioUrl":"wbw/041_039_009.mp3","charTypeName":"word"},{"id":40348,"position":10,"arabic":"ٱلْمَآءَ","translation":"পানি","audioUrl":"wbw/041_039_010.mp3","charTypeName":"word"},{"id":40349,"position":11,"arabic":"ٱهْتَزَّتْ","translation":"উথলিয়ে  উঠে","audioUrl":"wbw/041_039_011.mp3","charTypeName":"word"},{"id":40350,"position":12,"arabic":"وَرَبَتْ ۚ","translation":"ও স্ফীত হয় (আর শস্য জন্মে)","audioUrl":"wbw/041_039_012.mp3","charTypeName":"word"},{"id":40352,"position":13,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/041_039_014.mp3","charTypeName":"word"},{"id":40353,"position":14,"arabic":"ٱلَّذِىٓ","translation":"যিনি","audioUrl":"wbw/041_039_015.mp3","charTypeName":"word"},{"id":40354,"position":15,"arabic":"أَحْيَاهَا","translation":"তা (অর্থাৎ যমীনকে) জীবিত করেন","audioUrl":"wbw/041_039_016.mp3","charTypeName":"word"},{"id":40355,"position":16,"arabic":"لَمُحْىِ","translation":"অবশ্যই জীবন দানকারী","audioUrl":"wbw/041_039_017.mp3","charTypeName":"word"},{"id":40356,"position":17,"arabic":"ٱلْمَوْتَىٰٓ ۚ","translation":"মৃতদেরকে","audioUrl":"wbw/041_039_018.mp3","charTypeName":"word"},{"id":40358,"position":18,"arabic":"إِنَّهُۥ","translation":"নিশ্চয়ই তিনি","audioUrl":"wbw/041_039_020.mp3","charTypeName":"word"},{"id":40359,"position":19,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/041_039_021.mp3","charTypeName":"word"},{"id":40360,"position":20,"arabic":"كُلِّ","translation":"সব","audioUrl":"wbw/041_039_022.mp3","charTypeName":"word"},{"id":40361,"position":21,"arabic":"شَىْءٍۢ","translation":"কিছুর","audioUrl":"wbw/041_039_023.mp3","charTypeName":"word"},{"id":40362,"position":22,"arabic":"قَدِيرٌ","translation":"সর্বশক্তিমান","audioUrl":"wbw/041_039_024.mp3","charTypeName":"word"},{"id":40363,"position":23,"arabic":"٣٩","translation":"(৩৯)","audioUrl":null,"charTypeName":"end"}]},{"number":40,"arabic":"إِنَّ ٱلَّذِينَ يُلْحِدُونَ فِىٓ ءَايَٰتِنَا لَا يَخْفَوْنَ عَلَيْنَآ ۗ أَفَمَن يُلْقَىٰ فِى ٱلنَّارِ خَيْرٌ أَم مَّن يَأْتِىٓ ءَامِنًۭا يَوْمَ ٱلْقِيَٰمَةِ ۚ ٱعْمَلُوا۟ مَا شِئْتُمْ ۖ إِنَّهُۥ بِمَا تَعْمَلُونَ بَصِيرٌ","translation":"VERILY, they who distort the meaning of Our mes­sages are not hidden from Us: hence, which [of the two] will be in a better state - he that is [destined to be] cast into the fire, or he that shall come secure [before Us] on Resurrection Day? Do what you will: verily, He sees all that you do.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4258.mp3","surahId":41,"words":[{"id":41073,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/041_040_001.mp3","charTypeName":"word"},{"id":41074,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/041_040_002.mp3","charTypeName":"word"},{"id":41075,"position":3,"arabic":"يُلْحِدُونَ","translation":"বিকৃত অর্থ নেয়","audioUrl":"wbw/041_040_003.mp3","charTypeName":"word"},{"id":41076,"position":4,"arabic":"فِىٓ","translation":"মধ্যে","audioUrl":"wbw/041_040_004.mp3","charTypeName":"word"},{"id":41077,"position":5,"arabic":"ءَايَـٰتِنَا","translation":"আমাদের আয়াতগুলোর","audioUrl":"wbw/041_040_005.mp3","charTypeName":"word"},{"id":41078,"position":6,"arabic":"لَا","translation":"নয়","audioUrl":"wbw/041_040_006.mp3","charTypeName":"word"},{"id":41079,"position":7,"arabic":"يَخْفَوْنَ","translation":"তারা অগোচরে","audioUrl":"wbw/041_040_007.mp3","charTypeName":"word"},{"id":41080,"position":8,"arabic":"عَلَيْنَآ ۗ","translation":"আমাদের কাছে","audioUrl":"wbw/041_040_008.mp3","charTypeName":"word"},{"id":41082,"position":9,"arabic":"أَفَمَن","translation":"তবে কি যাকে","audioUrl":"wbw/041_040_010.mp3","charTypeName":"word"},{"id":41083,"position":10,"arabic":"يُلْقَىٰ","translation":"ফেলা হবে","audioUrl":"wbw/041_040_011.mp3","charTypeName":"word"},{"id":41084,"position":11,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/041_040_012.mp3","charTypeName":"word"},{"id":41085,"position":12,"arabic":"ٱلنَّارِ","translation":"আগুনের","audioUrl":"wbw/041_040_013.mp3","charTypeName":"word"},{"id":41086,"position":13,"arabic":"خَيْرٌ","translation":"উত্তম","audioUrl":"wbw/041_040_014.mp3","charTypeName":"word"},{"id":41087,"position":14,"arabic":"أَم","translation":"নাকি","audioUrl":"wbw/041_040_015.mp3","charTypeName":"word"},{"id":41088,"position":15,"arabic":"مَّن","translation":"যে","audioUrl":"wbw/041_040_016.mp3","charTypeName":"word"},{"id":41089,"position":16,"arabic":"يَأْتِىٓ","translation":"আসবে","audioUrl":"wbw/041_040_017.mp3","charTypeName":"word"},{"id":41090,"position":17,"arabic":"ءَامِنًۭا","translation":"নিরাপদ অবস্থায়","audioUrl":"wbw/041_040_018.mp3","charTypeName":"word"},{"id":41091,"position":18,"arabic":"يَوْمَ","translation":"দিনে","audioUrl":"wbw/041_040_019.mp3","charTypeName":"word"},{"id":41092,"position":19,"arabic":"ٱلْقِيَـٰمَةِ ۚ","translation":"ক্বিয়ামাতের","audioUrl":"wbw/041_040_020.mp3","charTypeName":"word"},{"id":41094,"position":20,"arabic":"ٱعْمَلُوا۟","translation":"তোমরা কাজ করো","audioUrl":"wbw/041_040_022.mp3","charTypeName":"word"},{"id":41095,"position":21,"arabic":"مَا","translation":"যা","audioUrl":"wbw/041_040_023.mp3","charTypeName":"word"},{"id":41096,"position":22,"arabic":"شِئْتُمْ ۖ","translation":"তোমরা ইচ্ছে করো","audioUrl":"wbw/041_040_024.mp3","charTypeName":"word"},{"id":41098,"position":23,"arabic":"إِنَّهُۥ","translation":"নিশ্চয়ই তিনি","audioUrl":"wbw/041_040_026.mp3","charTypeName":"word"},{"id":41099,"position":24,"arabic":"بِمَا","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/041_040_027.mp3","charTypeName":"word"},{"id":41100,"position":25,"arabic":"تَعْمَلُونَ","translation":"তোমরা কাজ করছো","audioUrl":"wbw/041_040_028.mp3","charTypeName":"word"},{"id":41101,"position":26,"arabic":"بَصِيرٌ","translation":"খুব দেখছেন","audioUrl":"wbw/041_040_029.mp3","charTypeName":"word"},{"id":41102,"position":27,"arabic":"٤٠","translation":"(৪০)","audioUrl":null,"charTypeName":"end"}]},{"number":41,"arabic":"إِنَّ ٱلَّذِينَ كَفَرُوا۟ بِٱلذِّكْرِ لَمَّا جَآءَهُمْ ۖ وَإِنَّهُۥ لَكِتَٰبٌ عَزِيزٌۭ","translation":"Verily, they who are bent on denying the truth of this reminder as soon as it comes to them - [they are the losers]: for, behold, it is a sublime divine writ:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4259.mp3","surahId":41,"words":[{"id":41967,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/041_041_001.mp3","charTypeName":"word"},{"id":41968,"position":2,"arabic":"ٱلَّذِينَ","translation":"(তারা সেই লোক) যারা","audioUrl":"wbw/041_041_002.mp3","charTypeName":"word"},{"id":41969,"position":3,"arabic":"كَفَرُوا۟","translation":"মেনে নিতে অস্বীকার করেছে","audioUrl":"wbw/041_041_003.mp3","charTypeName":"word"},{"id":41970,"position":4,"arabic":"بِٱلذِّكْرِ","translation":"কুরআনকে","audioUrl":"wbw/041_041_004.mp3","charTypeName":"word"},{"id":41971,"position":5,"arabic":"لَمَّا","translation":"যখন","audioUrl":"wbw/041_041_005.mp3","charTypeName":"word"},{"id":41972,"position":6,"arabic":"جَآءَهُمْ ۖ","translation":"এসেছে তাদের কাছে","audioUrl":"wbw/041_041_006.mp3","charTypeName":"word"},{"id":41974,"position":7,"arabic":"وَإِنَّهُۥ","translation":"এবং নিশ্চয়ই তা","audioUrl":"wbw/041_041_008.mp3","charTypeName":"word"},{"id":41975,"position":8,"arabic":"لَكِتَـٰبٌ","translation":"অবশ্যই কিতাব","audioUrl":"wbw/041_041_009.mp3","charTypeName":"word"},{"id":41976,"position":9,"arabic":"عَزِيزٌۭ","translation":"শক্তিমান","audioUrl":"wbw/041_041_010.mp3","charTypeName":"word"},{"id":41977,"position":10,"arabic":"٤١","translation":"(৪১)","audioUrl":null,"charTypeName":"end"}]},{"number":42,"arabic":"لَّا يَأْتِيهِ ٱلْبَٰطِلُ مِنۢ بَيْنِ يَدَيْهِ وَلَا مِنْ خَلْفِهِۦ ۖ تَنزِيلٌۭ مِّنْ حَكِيمٍ حَمِيدٍۢ","translation":"no falsehood can ever attain to it openly, and neither in a stealthy manner, [since it is] bestowed from on high by One who is truly wise, ever to be praised.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4260.mp3","surahId":41,"words":[{"id":42699,"position":1,"arabic":"لَّا","translation":"না","audioUrl":"wbw/041_042_001.mp3","charTypeName":"word"},{"id":42700,"position":2,"arabic":"يَأْتِيهِ","translation":"তার কাছে আসতে পারে","audioUrl":"wbw/041_042_002.mp3","charTypeName":"word"},{"id":42701,"position":3,"arabic":"ٱلْبَـٰطِلُ","translation":"অসত্য","audioUrl":"wbw/041_042_003.mp3","charTypeName":"word"},{"id":42702,"position":4,"arabic":"مِنۢ","translation":"থেকে","audioUrl":"wbw/041_042_004.mp3","charTypeName":"word"},{"id":42703,"position":5,"arabic":"بَيْنِ","translation":"সামনে","audioUrl":"wbw/041_042_005.mp3","charTypeName":"word"},{"id":42704,"position":6,"arabic":"يَدَيْهِ","translation":"তার","audioUrl":"wbw/041_042_006.mp3","charTypeName":"word"},{"id":42705,"position":7,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/041_042_007.mp3","charTypeName":"word"},{"id":42706,"position":8,"arabic":"مِنْ","translation":"থেকে","audioUrl":"wbw/041_042_008.mp3","charTypeName":"word"},{"id":42707,"position":9,"arabic":"خَلْفِهِۦ ۖ","translation":"তার পিছন","audioUrl":"wbw/041_042_009.mp3","charTypeName":"word"},{"id":42709,"position":10,"arabic":"تَنزِيلٌۭ","translation":"অবতীর্ণ করা (এই কুরআন)","audioUrl":"wbw/041_042_011.mp3","charTypeName":"word"},{"id":42710,"position":11,"arabic":"مِّنْ","translation":"(আল্লাহর) পক্ষ হ'তে","audioUrl":"wbw/041_042_012.mp3","charTypeName":"word"},{"id":42711,"position":12,"arabic":"حَكِيمٍ","translation":"(যিনি) প্রজ্ঞাময়","audioUrl":"wbw/041_042_013.mp3","charTypeName":"word"},{"id":42712,"position":13,"arabic":"حَمِيدٍۢ","translation":"সুপ্রশংসিত","audioUrl":"wbw/041_042_014.mp3","charTypeName":"word"},{"id":42713,"position":14,"arabic":"٤٢","translation":"(৪২)","audioUrl":null,"charTypeName":"end"}]},{"number":43,"arabic":"مَّا يُقَالُ لَكَ إِلَّا مَا قَدْ قِيلَ لِلرُّسُلِ مِن قَبْلِكَ ۚ إِنَّ رَبَّكَ لَذُو مَغْفِرَةٍۢ وَذُو عِقَابٍ أَلِيمٍۢ","translation":"[And as for thee, O Prophet,] nothing is being said to thee but what was said to all [of God’s] apostles before thy time. Behold, thy Sustainer is indeed full of forgiveness - but He has also the power to requite most grie­vously!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4261.mp3","surahId":41,"words":[{"id":44006,"position":1,"arabic":"مَّا","translation":"(হে নাবী) না","audioUrl":"wbw/041_043_001.mp3","charTypeName":"word"},{"id":44007,"position":2,"arabic":"يُقَالُ","translation":"বলা হচ্ছে","audioUrl":"wbw/041_043_002.mp3","charTypeName":"word"},{"id":44008,"position":3,"arabic":"لَكَ","translation":"তোমাকে","audioUrl":"wbw/041_043_003.mp3","charTypeName":"word"},{"id":44009,"position":4,"arabic":"إِلَّا","translation":"এ ব্যতীত","audioUrl":"wbw/041_043_004.mp3","charTypeName":"word"},{"id":44010,"position":5,"arabic":"مَا","translation":"যা","audioUrl":"wbw/041_043_005.mp3","charTypeName":"word"},{"id":44011,"position":6,"arabic":"قَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/041_043_006.mp3","charTypeName":"word"},{"id":44012,"position":7,"arabic":"قِيلَ","translation":"বলা হয়েছে","audioUrl":"wbw/041_043_007.mp3","charTypeName":"word"},{"id":44013,"position":8,"arabic":"لِلرُّسُلِ","translation":"রাসূলগণকে","audioUrl":"wbw/041_043_008.mp3","charTypeName":"word"},{"id":44014,"position":9,"arabic":"مِن","translation":"পূর্বে","audioUrl":"wbw/041_043_009.mp3","charTypeName":"word"},{"id":44015,"position":10,"arabic":"قَبْلِكَ ۚ","translation":"তোমার","audioUrl":"wbw/041_043_010.mp3","charTypeName":"word"},{"id":44017,"position":11,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/041_043_012.mp3","charTypeName":"word"},{"id":44018,"position":12,"arabic":"رَبَّكَ","translation":"তোমার রব","audioUrl":"wbw/041_043_013.mp3","charTypeName":"word"},{"id":44019,"position":13,"arabic":"لَذُو","translation":"অধিকারী","audioUrl":"wbw/041_043_014.mp3","charTypeName":"word"},{"id":44020,"position":14,"arabic":"مَغْفِرَةٍۢ","translation":"ক্ষমার অবশ্যই","audioUrl":"wbw/041_043_015.mp3","charTypeName":"word"},{"id":44021,"position":15,"arabic":"وَذُو","translation":"আবার অধিকারী","audioUrl":"wbw/041_043_016.mp3","charTypeName":"word"},{"id":44022,"position":16,"arabic":"عِقَابٍ","translation":"শাস্তিদানের","audioUrl":"wbw/041_043_017.mp3","charTypeName":"word"},{"id":44023,"position":17,"arabic":"أَلِيمٍۢ","translation":"কষ্টদায়ক","audioUrl":"wbw/041_043_018.mp3","charTypeName":"word"},{"id":44024,"position":18,"arabic":"٤٣","translation":"(৪৩)","audioUrl":null,"charTypeName":"end"}]},{"number":44,"arabic":"وَلَوْ جَعَلْنَٰهُ قُرْءَانًا أَعْجَمِيًّۭا لَّقَالُوا۟ لَوْلَا فُصِّلَتْ ءَايَٰتُهُۥٓ ۖ ءَا۬عْجَمِىٌّۭ وَعَرَبِىٌّۭ ۗ قُلْ هُوَ لِلَّذِينَ ءَامَنُوا۟ هُدًۭى وَشِفَآءٌۭ ۖ وَٱلَّذِينَ لَا يُؤْمِنُونَ فِىٓ ءَاذَانِهِمْ وَقْرٌۭ وَهُوَ عَلَيْهِمْ عَمًى ۚ أُو۟لَٰٓئِكَ يُنَادَوْنَ مِن مَّكَانٍۭ بَعِيدٍۢ","translation":"Now if We had willed this [divine writ] to be a discourse in a non-Arabic tongue, they [who now reject it] would surely have said, “Why is it that its messages have not been spelled out clearly? Why - [a message in] a non-Arabic tongue, and [its bearer] an Arab?” Say: “Unto all who have attained to faith, this [divine writ] is a guidance and a source of health; but as for those who will not believe - in their ears is deafness, and so it remains obscure to them: they are [like people who are] being called from too far away.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4262.mp3","surahId":41,"words":[{"id":44233,"position":1,"arabic":"وَلَوْ","translation":"এবং যদি","audioUrl":"wbw/041_044_001.mp3","charTypeName":"word"},{"id":44234,"position":2,"arabic":"جَعَلْنَـٰهُ","translation":"তা আমরা অবতীর্ণ করতাম","audioUrl":"wbw/041_044_002.mp3","charTypeName":"word"},{"id":44235,"position":3,"arabic":"قُرْءَانًا","translation":"(অর্থাৎ) কুরআন","audioUrl":"wbw/041_044_003.mp3","charTypeName":"word"},{"id":44236,"position":4,"arabic":"أَعْجَمِيًّۭا","translation":"অনারবী (ভাষায়)","audioUrl":"wbw/041_044_004.mp3","charTypeName":"word"},{"id":44237,"position":5,"arabic":"لَّقَالُوا۟","translation":"অবশ্যই তারা বলতো","audioUrl":"wbw/041_044_005.mp3","charTypeName":"word"},{"id":44238,"position":6,"arabic":"لَوْلَا","translation":"\"কেন না","audioUrl":"wbw/041_044_006.mp3","charTypeName":"word"},{"id":44239,"position":7,"arabic":"فُصِّلَتْ","translation":"বিশদভাবে বিবৃত হলো","audioUrl":"wbw/041_044_007.mp3","charTypeName":"word"},{"id":44240,"position":8,"arabic":"ءَايَـٰتُهُۥٓ ۖ","translation":"তার আয়াতগুলো","audioUrl":"wbw/041_044_008.mp3","charTypeName":"word"},{"id":44242,"position":9,"arabic":"ءَا۬عْجَمِىٌّۭ","translation":"(আশ্চর্য নয়) কি অনারবী (কুরআন)","audioUrl":"wbw/041_044_010.mp3","charTypeName":"word"},{"id":44243,"position":10,"arabic":"وَعَرَبِىٌّۭ ۗ","translation":"আর আরবী (রাসূল ও তাঁর জাতি)\"","audioUrl":"wbw/041_044_011.mp3","charTypeName":"word"},{"id":44245,"position":11,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/041_044_013.mp3","charTypeName":"word"},{"id":44246,"position":12,"arabic":"هُوَ","translation":"\"তা (অর্থাৎ কুরআন)","audioUrl":"wbw/041_044_014.mp3","charTypeName":"word"},{"id":44247,"position":13,"arabic":"لِلَّذِينَ","translation":"(তাদের) জন্যে যারা","audioUrl":"wbw/041_044_015.mp3","charTypeName":"word"},{"id":44248,"position":14,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/041_044_016.mp3","charTypeName":"word"},{"id":44249,"position":15,"arabic":"هُدًۭى","translation":"পথনির্দেশনা","audioUrl":"wbw/041_044_017.mp3","charTypeName":"word"},{"id":44250,"position":16,"arabic":"وَشِفَآءٌۭ ۖ","translation":"ও ব্যাধির প্রতিকার\"","audioUrl":"wbw/041_044_018.mp3","charTypeName":"word"},{"id":44252,"position":17,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/041_044_020.mp3","charTypeName":"word"},{"id":44253,"position":18,"arabic":"لَا","translation":"না","audioUrl":"wbw/041_044_021.mp3","charTypeName":"word"},{"id":44254,"position":19,"arabic":"يُؤْمِنُونَ","translation":"ঈমান আনে","audioUrl":"wbw/041_044_022.mp3","charTypeName":"word"},{"id":44255,"position":20,"arabic":"فِىٓ","translation":"মধ্যে (আছে)","audioUrl":"wbw/041_044_023.mp3","charTypeName":"word"},{"id":44256,"position":21,"arabic":"ءَاذَانِهِمْ","translation":"তাদের কানগুলোর","audioUrl":"wbw/041_044_024.mp3","charTypeName":"word"},{"id":44257,"position":22,"arabic":"وَقْرٌ