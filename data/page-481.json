oUrl":"wbw/041_045_001.mp3","charTypeName":"word"},{"id":44956,"position":2,"arabic":"ءَاتَيْنَا","translation":"আমরা দিয়েছিলাম","audioUrl":"wbw/041_045_002.mp3","charTypeName":"word"},{"id":44957,"position":3,"arabic":"مُوسَى","translation":"মূসাকে","audioUrl":"wbw/041_045_003.mp3","charTypeName":"word"},{"id":44958,"position":4,"arabic":"ٱلْكِتَـٰبَ","translation":"কিতাব","audioUrl":"wbw/041_045_004.mp3","charTypeName":"word"},{"id":44959,"position":5,"arabic":"فَٱخْتُلِفَ","translation":"অতঃপর মতভেদ ঘটেছিলো","audioUrl":"wbw/041_045_005.mp3","charTypeName":"word"},{"id":44960,"position":6,"arabic":"فِيهِ ۗ","translation":"তার মধ্যে","audioUrl":"wbw/041_045_006.mp3","charTypeName":"word"},{"id":44962,"position":7,"arabic":"وَلَوْلَا","translation":"এবং না যদি (হতো)","audioUrl":"wbw/041_045_008.mp3","charTypeName":"word"},{"id":44963,"position":8,"arabic":"كَلِمَةٌۭ","translation":"একটি কথা","audioUrl":"wbw/041_045_009.mp3","charTypeName":"word"},{"id":44964,"position":9,"arabic":"سَبَقَتْ","translation":"পূর্ব নির্ধারিত","audioUrl":"wbw/041_045_010.mp3","charTypeName":"word"},{"id":44965,"position":10,"arabic":"مِن","translation":"পক্ষ হ'তে","audioUrl":"wbw/041_045_011.mp3","charTypeName":"word"},{"id":44966,"position":11,"arabic":"رَّبِّكَ","translation":"তোমার রবের","audioUrl":"wbw/041_045_012.mp3","charTypeName":"word"},{"id":44967,"position":12,"arabic":"لَقُضِىَ","translation":"মীমাংসা করেই দেওয়া হতো","audioUrl":"wbw/041_045_013.mp3","charTypeName":"word"},{"id":44968,"position":13,"arabic":"بَيْنَهُمْ ۚ","translation":"তাদের মাঝে","audioUrl":"wbw/041_045_014.mp3","charTypeName":"word"},{"id":44970,"position":14,"arabic":"وَإِنَّهُمْ","translation":"এবং তারা নিশ্চয়ই","audioUrl":"wbw/041_045_016.mp3","charTypeName":"word"},{"id":44971,"position":15,"arabic":"لَفِى","translation":"অবশ্যই মধ্যে আছে","audioUrl":"wbw/041_045_017.mp3","charTypeName":"word"},{"id":44972,"position":16,"arabic":"شَكٍّۢ","translation":"সন্দেহের","audioUrl":"wbw/041_045_018.mp3","charTypeName":"word"},{"id":44973,"position":17,"arabic":"مِّنْهُ","translation":"তা সম্বন্ধে","audioUrl":"wbw/041_045_019.mp3","charTypeName":"word"},{"id":44974,"position":18,"arabic":"مُرِيبٍۢ","translation":"বিভ্রান্তিকর","audioUrl":"wbw/041_045_020.mp3","charTypeName":"word"},{"id":44975,"position":19,"arabic":"٤٥","translation":"(৪৫)","audioUrl":null,"charTypeName":"end"}]},{"number":46,"arabic":"مَّنْ عَمِلَ صَٰلِحًۭا فَلِنَفْسِهِۦ ۖ وَمَنْ أَسَآءَ فَعَلَيْهَا ۗ وَمَا رَبُّكَ بِظَلَّٰمٍۢ لِّلْعَبِيدِ","translation":"WHOEVER does what is just and right, does so for his own good; and whoever does evil, does so to his own hurt: and never does God do the least wrong to His creatures.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4264.mp3","surahId":41,"words":[{"id":45716,"position":1,"arabic":"مَّنْ","translation":"যে","audioUrl":"wbw/041_046_001.mp3","charTypeName":"word"},{"id":45717,"position":2,"arabic":"عَمِلَ","translation":"কাজ করবে","audioUrl":"wbw/041_046_002.mp3","charTypeName":"word"},{"id":45718,"position":3,"arabic":"صَـٰلِحًۭا","translation":"সৎ","audioUrl":"wbw/041_046_003.mp3","charTypeName":"word"},{"id":45719,"position":4,"arabic":"فَلِنَفْسِهِۦ ۖ","translation":"(সে করবে) তা নিজের জন্যে","audioUrl":"wbw/041_046_004.mp3","charTypeName":"word"},{"id":45721,"position":5,"arabic":"وَمَنْ","translation":"এবং যে","audioUrl":"wbw/041_046_006.mp3","charTypeName":"word"},{"id":45722,"position":6,"arabic":"أَسَآءَ","translation":"মন্দকর্ম করবে","audioUrl":"wbw/041_046_007.mp3","charTypeName":"word"},{"id":45723,"position":7,"arabic":"فَعَلَيْهَا ۗ","translation":"(পড়বে) তা তার উপর","audioUrl":"wbw/041_046_008.mp3","charTypeName":"word"},{"id":45725,"position":8,"arabic":"وَمَا","translation":"আর নন","audioUrl":"wbw/041_046_010.mp3","charTypeName":"word"},{"id":45726,"position":9,"arabic":"رَبُّكَ","translation":"তোমার রব","audioUrl":"wbw/041_046_011.mp3","charTypeName":"word"},{"id":45727,"position":10,"arabic":"بِظَلَّـٰمٍۢ","translation":"অত্যাচারী","audioUrl":"wbw/041_046_012.mp3","charTypeName":"word"},{"id":45728,"position":11,"arabic":"لِّلْعَبِيدِ","translation":"দাসদের উপর","audioUrl":"wbw/041_046_013.mp3","charTypeName":"word"},{"id":45729,"position":12,"arabic":"٤٦","translation":"(৪৬)","audioUrl":null,"charTypeName":"end"}]}]}