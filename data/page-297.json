","charTypeName":"word"},{"id":31606,"position":4,"arabic":"رَّبِّكُمْ ۖ","translation":"রবের তোমার","audioUrl":"wbw/018_029_004.mp3","charTypeName":"word"},{"id":31608,"position":5,"arabic":"فَمَن","translation":"অতএব যে","audioUrl":"wbw/018_029_006.mp3","charTypeName":"word"},{"id":31609,"position":6,"arabic":"شَآءَ","translation":"ইচ্ছে করে","audioUrl":"wbw/018_029_007.mp3","charTypeName":"word"},{"id":31610,"position":7,"arabic":"فَلْيُؤْمِن","translation":"অতঃপর ঈমান আনুক","audioUrl":"wbw/018_029_008.mp3","charTypeName":"word"},{"id":31611,"position":8,"arabic":"وَمَن","translation":"এবং যে","audioUrl":"wbw/018_029_009.mp3","charTypeName":"word"},{"id":31612,"position":9,"arabic":"شَآءَ","translation":"ইচ্ছে করে","audioUrl":"wbw/018_029_010.mp3","charTypeName":"word"},{"id":31613,"position":10,"arabic":"فَلْيَكْفُرْ ۚ","translation":"অতঃপর অস্বীকার করুক\"","audioUrl":"wbw/018_029_011.mp3","charTypeName":"word"},{"id":31615,"position":11,"arabic":"إِنَّآ","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/018_029_013.mp3","charTypeName":"word"},{"id":31616,"position":12,"arabic":"أَعْتَدْنَا","translation":"আমরা প্রস্তুত করে রেখেছি","audioUrl":"wbw/018_029_014.mp3","charTypeName":"word"},{"id":31617,"position":13,"arabic":"لِلظَّـٰلِمِينَ","translation":"জন্যে সীমালঙ্ঘনকারীদের","audioUrl":"wbw/018_029_015.mp3","charTypeName":"word"},{"id":31618,"position":14,"arabic":"نَارًا","translation":"জাহান্নামের আগুন","audioUrl":"wbw/018_029_016.mp3","charTypeName":"word"},{"id":31619,"position":15,"arabic":"أَحَاطَ","translation":"পরিবেষ্টন করেছে","audioUrl":"wbw/018_029_017.mp3","charTypeName":"word"},{"id":31620,"position":16,"arabic":"بِهِمْ","translation":"সহ তাদেরকে","audioUrl":"wbw/018_029_018.mp3","charTypeName":"word"},{"id":31621,"position":17,"arabic":"سُرَادِقُهَا ۚ","translation":"তার শিখা","audioUrl":"wbw/018_029_019.mp3","charTypeName":"word"},{"id":31623,"position":18,"arabic":"وَإِن","translation":"এবং যদি","audioUrl":"wbw/018_029_021.mp3","charTypeName":"wo