{"id":297,"ayahs":[{"number":28,"arabic":"وَٱصْبِرْ نَفْسَكَ مَعَ ٱلَّذِينَ يَدْعُونَ رَبَّهُم بِٱلْغَدَوٰةِ وَٱلْعَشِىِّ يُرِيدُونَ وَجْهَهُۥ ۖ وَلَا تَعْدُ عَيْنَاكَ عَنْهُمْ تُرِيدُ زِينَةَ ٱلْحَيَوٰةِ ٱلدُّنْيَا ۖ وَلَا تُطِعْ مَنْ أَغْفَلْنَا قَلْبَهُۥ عَن ذِكْرِنَا وَٱتَّبَعَ هَوَىٰهُ وَكَانَ أَمْرُهُۥ فُرُطًۭا","translation":"And contain thyself in patience by the side of all who at morn and at evening invoke their Sustainer, seeking His countenance, and let not thine eyes pass beyond them in quest of the beauties of this world's life; and pay no heed to any whose heart We have rendered heedless of all remembrance of Us because he had always followed [only] his own desires, abandoning all that is good and true.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2168.mp3","surahId":18,"words":[{"id":30579,"position":1,"arabic":"وَٱصْبِرْ","translation":"এবং স্থিতিশীল রাখবে","audioUrl":"wbw/018_028_001.mp3","charTypeName":"word"},{"id":30580,"position":2,"arabic":"نَفْسَكَ","translation":"তোমার নিজেকে","audioUrl":"wbw/018_028_002.mp3","charTypeName":"word"},{"id":30581,"position":3,"arabic":"مَعَ","translation":"সাথে","audioUrl":"wbw/018_028_003.mp3","charTypeName":"word"},{"id":30582,"position":4,"arabic":"ٱلَّذِينَ","translation":"(তাদের) যারা","audioUrl":"wbw/018_028_004.mp3","charTypeName":"word"},{"id":30583,"position":5,"arabic":"يَدْعُونَ","translation":"ডাকে","audioUrl":"wbw/018_028_005.mp3","charTypeName":"word"},{"id":30584,"position":6,"arabic":"رَبَّهُم","translation":"রবকে তাদের","audioUrl":"wbw/018_028_006.mp3","charTypeName":"word"},{"id":30585,"position":7,"arabic":"بِٱلْغَدَوٰةِ","translation":"বেলায় সকাল","audioUrl":"wbw/018_028_007.mp3","charTypeName":"word"},{"id":30586,"position":8,"arabic":"وَٱلْعَشِىِّ","translation":"ও সন্ধ্যায়","audioUrl":"wbw/018_028_008.mp3","charTypeName":"word"},{"id":30587,"position":9,"arabic":"يُرِيدُونَ","translation":"তারা চায়","audioUrl":"wbw/018_028_009.mp3","charTypeName":"word"},{"id":30588,"p