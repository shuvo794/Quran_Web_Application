0.mp3","charTypeName":"word"},{"id":2475,"position":18,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/065_003_021.mp3","charTypeName":"word"},{"id":2476,"position":19,"arabic":"لِكُلِّ","translation":"সব জন্যে","audioUrl":"wbw/065_003_022.mp3","charTypeName":"word"},{"id":2477,"position":20,"arabic":"شَىْءٍۢ","translation":"কিছুর","audioUrl":"wbw/065_003_023.mp3","charTypeName":"word"},{"id":2478,"position":21,"arabic":"قَدْرًۭا","translation":"নির্দিষ্ট মাত্রা","audioUrl":"wbw/065_003_024.mp3","charTypeName":"word"},{"id":2479,"position":22,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"وَٱلَّٰٓـِٔى يَئِسْنَ مِنَ ٱلْمَحِيضِ مِن نِّسَآئِكُمْ إِنِ ٱرْتَبْتُمْ فَعِدَّتُهُنَّ ثَلَٰثَةُ أَشْهُرٍۢ وَٱلَّٰٓـِٔى لَمْ يَحِضْنَ ۚ وَأُو۟لَٰتُ ٱلْأَحْمَالِ أَجَلُهُنَّ أَن يَضَعْنَ حَمْلَهُنَّ ۚ وَمَن يَتَّقِ ٱللَّهَ يَجْعَل لَّهُۥ مِنْ أَمْرِهِۦ يُسْرًۭا","translation":"Now as for such of your women as are beyond, the age of monthly courses, as well as for such as do not have any courses, their waiting-period - if you have any doubt [about it] - shall be three [calendar] months; and as for those who are with child, the end of their waiting-term shall come when they deliver their burden. And for everyone who is conscious of God, He makes it easy to obey His commandment:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5221.mp3","surahId":65,"words":[{"id":3872,"position":1,"arabic":"وَٱلَّـٰٓـِٔى","translation":"এবং যারা","audioUrl":"wbw/065_004_001.mp3","charTypeName":"word"},{"id":3873,"position":2,"arabic":"يَئِسْنَ","translation":"নিরাশ হয়েছে","audioUrl":"wbw/065_004_002.mp3","charTypeName":"word"},{"id":3874,"position":3,"arabic":"مِنَ","translation":"হতে","audioUrl":"wbw/065_004_003.mp3","charTypeName":"word"},{"id":3875,"position":4,"arabic":"ٱلْمَحِيضِ","translation":"হায়েয","audioUrl":"wbw/065_004_004.mp3","charTypeName":"word"},{"id":3876,"position":5,"arabic":"مِن","translation":"মধ্য হতে","a