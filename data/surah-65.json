,"translation":"যথাবিধি","audioUrl":"wbw/065_002_005.mp3","charTypeName":"word"},{"id":1397,"position":6,"arabic":"أَوْ","translation":"বা","audioUrl":"wbw/065_002_006.mp3","charTypeName":"word"},{"id":1398,"position":7,"arabic":"فَارِقُوهُنَّ","translation":"তাদের তোমরা পৃথক করবে","audioUrl":"wbw/065_002_007.mp3","charTypeName":"word"},{"id":1399,"position":8,"arabic":"بِمَعْرُوفٍۢ","translation":"যথাবিধি","audioUrl":"wbw/065_002_008.mp3","charTypeName":"word"},{"id":1400,"position":9,"arabic":"وَأَشْهِدُوا۟","translation":"ও তোমরা সাক্ষী রাখ","audioUrl":"wbw/065_002_009.mp3","charTypeName":"word"},{"id":1401,"position":10,"arabic":"ذَوَىْ","translation":"আছে","audioUrl":"wbw/065_002_010.mp3","charTypeName":"word"},{"id":1402,"position":11,"arabic":"عَدْلٍۢ","translation":"ন্যায়পরায়ণ দু'জন","audioUrl":"wbw/065_002_011.mp3","charTypeName":"word"},{"id":1403,"position":12,"arabic":"مِّنكُمْ","translation":"তোমাদের মধ্য থেকে","audioUrl":"wbw/065_002_012.mp3","charTypeName":"word"},{"id":1404,"position":13,"arabic":"وَأَقِيمُوا۟","translation":"ও তোমরা সঠিক দিও","audioUrl":"wbw/065_002_013.mp3","charTypeName":"word"},{"id":1405,"position":14,"arabic":"ٱلشَّهَـٰدَةَ","translation":"সাক্ষী","audioUrl":"wbw/065_002_014.mp3","charTypeName":"word"},{"id":1406,"position":15,"arabic":"لِلَّهِ ۚ","translation":"আল্লাহর জন্যে","audioUrl":"wbw/065_002_015.mp3","charTypeName":"word"},{"id":1408,"position":16,"arabic":"ذَٰلِكُمْ","translation":"এসব","audioUrl":"wbw/065_002_017.mp3","charTypeName":"word"},{"id":1409,"position":17,"arabic":"يُوعَظُ","translation":"নসিহত করা হচ্ছে","audioUrl":"wbw/065_002_018.mp3","charTypeName":"word"},{"id":1410,"position":18,"arabic":"بِهِۦ","translation":"এ দিয়ে","audioUrl":"wbw/065_002_019.mp3","charTypeName":"word"},{"id":1411,"position":19,"arabic":"مَن","translation":"যে","audioUrl":"wbw/065_002_020.mp3","charTypeName":"word"},{"id":1412,"position":20,"arabic":"كَانَ","translation":"ছিল","audioUrl":"wbw/065_002_021.mp3","charTypeName":"word"}