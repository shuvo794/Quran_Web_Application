n to be with child, spend freely on them until they deliver their burden; and if they nurse your offspring [after the divorce has become final], give them their [due] recompense; and take counsel with one another in a fair manner [about the child's future]. And if both of you find it difficult [that the mother should nurse the child], let another woman nurse it on behalf of him [who has begotten it].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5223.mp3","surahId":65,"words":[{"id":6396,"position":1,"arabic":"أَسْكِنُوهُنَّ","translation":"তাদের বাস করতে দাও","audioUrl":"wbw/065_006_001.mp3","charTypeName":"word"},{"id":6397,"position":2,"arabic":"مِنْ","translation":"মধ্য হতে","audioUrl":"wbw/065_006_002.mp3","charTypeName":"word"},{"id":6398,"position":3,"arabic":"حَيْثُ","translation":"যেখানে","audioUrl":"wbw/065_006_003.mp3","charTypeName":"word"},{"id":6399,"position":4,"arabic":"سَكَنتُم","translation":"তোমরা বাস কর","audioUrl":"wbw/065_006_004.mp3","charTypeName":"word"},{"id":6400,"position":5,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/065_006_005.mp3","charTypeName":"word"},{"id":6401,"position":6,"arabic":"وُجْدِكُمْ","translation":"তোমাদের সামর্থ","audioUrl":"wbw/065_006_006.mp3","charTypeName":"word"},{"id":6402,"position":7,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/065_006_007.mp3","charTypeName":"word"},{"id":6403,"position":8,"arabic":"تُضَآرُّوهُنَّ","translation":"তাদের তোমরা কষ্ট দিও","audioUrl":"wbw/065_006_008.mp3","charTypeName":"word"},{"id":6404,"position":9,"arabic":"لِتُضَيِّقُوا۟","translation":"সঙ্কটে ফেলবার জন্যে","audioUrl":"wbw/065_006_009.mp3","charTypeName":"word"},{"id":6405,"position":10,"arabic":"عَلَيْهِنَّ ۚ","translation":"তাদেরকে","audioUrl":"wbw/065_006_010.mp3","charTypeName":"word"},{"id":6407,"position":11,"arabic":"وَإِن","translation":"এবং যদি","audioUrl":"wbw/065_006_012.mp3","charTypeName":"word"},{"id":6408,"position":12,"arabic":"كُنَّ","translation":"তারা হয়","audioUrl":"w