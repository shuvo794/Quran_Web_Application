{"id":343,"ayahs":[{"number":18,"arabic":"وَأَنزَلْنَا مِنَ ٱلسَّمَآءِ مَآءًۢ بِقَدَرٍۢ فَأَسْكَنَّٰهُ فِى ٱلْأَرْضِ ۖ وَإِنَّا عَلَىٰ ذَهَابٍۭ بِهِۦ لَقَٰدِرُونَ","translation":"And We send down water from the skies in accordance with a measure [set by Us], and then We cause it to lodge in the earth: but, behold, We are most certainly able to withdraw this [blessing]!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2691.mp3","surahId":23,"words":[{"id":20609,"position":1,"arabic":"وَأَنزَلْنَا","translation":"আর আমরা বর্ষণ করি","audioUrl":"wbw/023_018_001.mp3","charTypeName":"word"},{"id":20610,"position":2,"arabic":"مِنَ","translation":"হ'তে","audioUrl":"wbw/023_018_002.mp3","charTypeName":"word"},{"id":20611,"position":3,"arabic":"ٱلسَّمَآءِ","translation":"আকাশ","audioUrl":"wbw/023_018_003.mp3","charTypeName":"word"},{"id":20612,"position":4,"arabic":"مَآءًۢ","translation":"পানি","audioUrl":"wbw/023_018_004.mp3","charTypeName":"word"},{"id":20613,"position":5,"arabic":"بِقَدَرٍۢ","translation":"পরিমাণ মতো","audioUrl":"wbw/023_018_005.mp3","charTypeName":"word"},{"id":20614,"position":6,"arabic":"فَأَسْكَنَّـٰهُ","translation":"অতঃপর তা আমরা সংরক্ষণ করি","audioUrl":"wbw/023_018_006.mp3","charTypeName":"word"},{"id":20615,"position":7,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/023_018_007.mp3","charTypeName":"word"},{"id":20616,"position":8,"arabic":"ٱلْأَرْضِ ۖ","translation":"মাটির","audioUrl":"wbw/023_018_008.mp3","charTypeName":"word"},{"id":20618,"position":9,"arabic":"وَإِنَّا","translation":"আর নিশ্চয়ই আমরা","audioUrl":"wbw/023_018_010.mp3","charTypeName":"word"},{"id":20619,"position":10,"arabic":"عَلَىٰ","translation":"ব্যাপারে","audioUrl":"wbw/023_018_011.mp3","charTypeName":"word"},{"id":20620,"position":11,"arabic":"ذَهَابٍۭ","translation":"(অন্যত্র) যাওয়ার","audioUrl":"wbw/023_018_012.mp3","charTypeName":"word"},{"id":20621,"position":12,"arabic":"بِهِۦ","translation":"নিয়ে তা","audioUrl":"wbw/023_018_013.mp3","charTypeName":"word"},{"id":20622,"position":13,"arabic":"لَقَـٰدِرُونَ","translation":"অবশ্যই সক্ষম","audioUrl":"wbw/023_018_014.mp3","charTypeName":"word"},{"id":20623,"position":14,"arabic":"١٨","translation":"(১৮)","audioUrl":null,"charTypeName":"end"}]},{"number":19,"arabic":"فَأَنشَأْنَا لَكُم بِهِۦ جَنَّٰتٍۢ مِّن نَّخِيلٍۢ وَأَعْنَٰبٍۢ لَّكُمْ فِيهَا فَوَٰكِهُ كَثِيرَةٌۭ وَمِنْهَا تَأْكُلُونَ","translation":"And by means of this [water] We bring forth for you gardens of date-palms and vines, wherein you have fruit abundant and whereof you eat,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2692.mp3","surahId":23,"words":[{"id":21671,"position":1,"arabic":"فَأَنشَأْنَا","translation":"অতঃপর আমরা সৃষ্টি করি","audioUrl":"wbw/023_019_001.mp3","charTypeName":"word"},{"id":21672,"position":2,"arabic":"لَكُم","translation":"জন্যে তোমাদের","audioUrl":"wbw/023_019_002.mp3","charTypeName":"word"},{"id":21673,"position":3,"arabic":"بِهِۦ","translation":"দিয়ে তা","audioUrl":"wbw/023_019_003.mp3","charTypeName":"word"},{"id":21674,"position":4,"arabic":"جَنَّـٰتٍۢ","translation":"বাগান","audioUrl":"wbw/023_019_004.mp3","charTypeName":"word"},{"id":21675,"position":5,"arabic":"مِّن","translation":"(দিয়ে) তৈরি","audioUrl":"wbw/023_019_005.mp3","charTypeName":"word"},{"id":21676,"position":6,"arabic":"نَّخِيلٍۢ","translation":"খেজুরের (গাছ)","audioUrl":"wbw/023_019_006.mp3","charTypeName":"word"},{"id":21677,"position":7,"arabic":"وَأَعْنَـٰبٍۢ","translation":"ও আঙ্গুরের","audioUrl":"wbw/023_019_007.mp3","charTypeName":"word"},{"id":21678,"position":8,"arabic":"لَّكُمْ","translation":"জন্যে তোমাদের","audioUrl":"wbw/023_019_008.mp3","charTypeName":"word"},{"id":21679,"position":9,"arabic":"فِيهَا","translation":"তার মধ্যে (আছে)","audioUrl":"wbw/023_019_009.mp3","charTypeName":"word"},{"id":21680,"position":10,"arabic":"فَوَٰكِهُ","translation":"ফলমূল","audioUrl":"wbw/023_019_010.mp3","charTypeName":"word"},{"id":21681,"position":11,"arabic":"كَثِيرَةٌۭ","translation":"প্রচুর","audioUrl":"wbw/023_019_011.mp3","charTypeName":"word"},{"id":21682,"position":12,"arabic":"وَمِنْهَا","translation":"আর তা হ'তে","audioUrl":"wbw/023_019_012.mp3","charTypeName":"word"},{"id":21683,"position":13,"arabic":"تَأْكُلُونَ","translation":"তোমরা খাও","audioUrl":"wbw/023_019_013.mp3","charTypeName":"word"},{"id":21684,"position":14,"arabic":"١٩","translation":"(১৯)","audioUrl":null,"charTypeName":"end"}]},{"number":20,"arabic":"وَشَجَرَةًۭ تَخْرُجُ مِن طُورِ سَيْنَآءَ تَنۢبُتُ بِٱلدُّهْنِ وَصِبْغٍۢ لِّلْءَاكِلِينَ","translation":"as well as a tree that issues from [the lands adjoining] Mount Sinai, yielding oil and relish for all to eat.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2693.mp3","surahId":23,"words":[{"id":22756,"position":1,"arabic":"وَشَجَرَةًۭ","translation":"এবং গাছ (জয়তুনের)","audioUrl":"wbw/023_020_001.mp3","charTypeName":"word"},{"id":22757,"position":2,"arabic":"تَخْرُجُ","translation":"বের হয়","audioUrl":"wbw/023_020_002.mp3","charTypeName":"word"},{"id":22758,"position":3,"arabic":"مِن","translation":"হ'তে","audioUrl":"wbw/023_020_003.mp3","charTypeName":"word"},{"id":22759,"position":4,"arabic":"طُورِ","translation":"পাহাড়","audioUrl":"wbw/023_020_004.mp3","charTypeName":"word"},{"id":22760,"position":5,"arabic":"سَيْنَآءَ","translation":"সিনাইয়ের","audioUrl":"wbw/023_020_005.mp3","charTypeName":"word"},{"id":22761,"position":6,"arabic":"تَنۢبُتُ","translation":"উৎপন্ন হয়","audioUrl":"wbw/023_020_006.mp3","charTypeName":"word"},{"id":22762,"position":7,"arabic":"بِٱلدُّهْنِ","translation":"তেল নিয়ে","audioUrl":"wbw/023_020_007.mp3","charTypeName":"word"},{"id":22763,"position":8,"arabic":"وَصِبْغٍۢ","translation":"এবং খাবার (তরকারিসহ)","audioUrl":"wbw/023_020_008.mp3","charTypeName":"word"},{"id":22764,"position":9,"arabic":"لِّلْـَٔاكِلِينَ","translation":"জন্যে খাদ্যগ্রহণকারীদের","audioUrl":"wbw/023_020_009.mp3","charTypeName":"word"},{"id":22765,"position":10,"arabic":"٢٠","translation":"(২০)","audioUrl":null,"charTypeName":"end"}]},{"number":21,"arabic":"وَإِنَّ لَكُمْ فِى ٱلْأَنْعَٰمِ لَعِبْرَةًۭ ۖ نُّسْقِيكُم مِّمَّا فِى بُطُونِهَا وَلَكُمْ فِيهَا مَنَٰفِعُ كَثِيرَةٌۭ وَمِنْهَا تَأْكُلُونَ","translation":"And, behold, in the cattle [too] there is indeed a lesson for you: We give you to drink of that [milk] which is within their bellies; and you derive many [other] uses from them: for, you eat of their flesh,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2694.mp3","surahId":23,"words":[{"id":23928,"position":1,"arabic":"وَإِنَّ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/023_021_001.mp3","charTypeName":"word"},{"id":23929,"position":2,"arabic":"لَكُمْ","translation":"জন্যে তোমাদের","audioUrl":"wbw/023_021_002.mp3","charTypeName":"word"},{"id":23930,"position":3,"arabic":"فِى","translation":"মধ্যে (আছে)","audioUrl":"wbw/023_021_003.mp3","charTypeName":"word"},{"id":23931,"position":4,"arabic":"ٱلْأَنْعَـٰمِ","translation":"গৃহপালিত পশুদের","audioUrl":"wbw/023_021_004.mp3","charTypeName":"word"},{"id":23932,"position":5,"arabic":"لَعِبْرَةًۭ ۖ","translation":"অবশ্যই শিক্ষা","audioUrl":"wbw/023_021_005.mp3","charTypeName":"word"},{"id":23934,"position":6,"arabic":"نُّسْقِيكُم","translation":"তোমাদেরকে পান করাই আমরা","audioUrl":"wbw/023_021_007.mp3","charTypeName":"word"},{"id":23935,"position":7,"arabic":"مِّمَّا","translation":"তা হ'তে যা","audioUrl":"wbw/023_021_008.mp3","charTypeName":"word"},{"id":23936,"position":8,"arabic":"فِى","translation":"রয়েছে","audioUrl":"wbw/023_021_009.mp3","charTypeName":"word"},{"id":23937,"position":9,"arabic":"بُطُونِهَا","translation":"তাদের পেটে (অর্থাৎ দুধ)","audioUrl":"wbw/023_021_010.mp3","charTypeName":"word"},{"id":23938,"position":10,"arabic":"وَلَكُمْ","translation":"আর জন্যে তোমাদের (রয়েছে)","audioUrl":"wbw/023_021_011.mp3","charTypeName":"word"},{"id":23939,"position":11,"arabic":"فِيهَا","translation":"তাদের মধ্যে","audioUrl":"wbw/023_021_012.mp3","charTypeName":"word"},{"id":23940,"position":12,"arabic":"مَنَـٰفِعُ","translation":"উপকারিতা","audioUrl":"wbw/023_021_013.mp3","charTypeName":"word"},{"id":23941,"position":13,"arabic":"كَثِيرَةٌۭ","translation":"প্রচুর","audioUrl":"wbw/023_021_014.mp3","charTypeName":"word"},{"id":23942,"position":14,"arabic":"وَمِنْهَا","translation":"আর তাদের মধ্য হ'তে","audioUrl":"wbw/023_021_015.mp3","charTypeName":"word"},{"id":23943,"position":15,"arabic":"تَأْكُلُونَ","translation":"তোমরা খাও (গোশত)","audioUrl":"wbw/023_021_016.mp3","charTypeName":"word"},{"id":23944,"position":16,"arabic":"٢١","translation":"(২১)","audioUrl":null,"charTypeName":"end"}]},{"number":22,"arabic":"وَعَلَيْهَا وَعَلَى ٱلْفُلْكِ تُحْمَلُونَ","translation":"and by them - as by the ships [over the sea] - you are borne [overland].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2695.mp3","surahId":23,"words":[{"id":24912,"position":1,"arabic":"وَعَلَيْهَا","translation":"এবং তাদের উপর","audioUrl":"wbw/023_022_001.mp3","charTypeName":"word"},{"id":24913,"position":2,"arabic":"وَعَلَى","translation":"ও উপর","audioUrl":"wbw/023_022_002.mp3","charTypeName":"word"},{"id":24914,"position":3,"arabic":"ٱلْفُلْكِ","translation":"নৌযানের","audioUrl":"wbw/023_022_003.mp3","charTypeName":"word"},{"id":24915,"position":4,"arabic":"تُحْمَلُونَ","translation":"তোমাদের বহন করা হয়","audioUrl":"wbw/023_022_004.mp3","charTypeName":"word"},{"id":24916,"position":5,"arabic":"٢٢","translation":"(২২)","audioUrl":null,"charTypeName":"end"}]},{"number":23,"arabic":"وَلَقَدْ أَرْسَلْنَا نُوحًا إِلَىٰ قَوْمِهِۦ فَقَالَ يَٰقَوْمِ ٱعْبُدُوا۟ ٱللَّهَ مَا لَكُم مِّنْ إِلَٰهٍ غَيْرُهُۥٓ ۖ أَفَلَا تَتَّقُونَ","translation":"AND, INDEED, We sent forth Noah unto his people and he said: “O my people! Worship God alone]: you have no deity other than Him. Will you not, then, become conscious of Him?”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2696.mp3","surahId":23,"words":[{"id":25875,"position":1,"arabic":"وَلَقَدْ","translation":"আর নিশ্চয়ই","audioUrl":"wbw/023_023_001.mp3","charTypeName":"word"},{"id":25876,"position":2,"arabic":"أَرْسَلْنَا","translation":"আমরা পাঠিয়েছি","audioUrl":"wbw/023_023_002.mp3","charTypeName":"word"},{"id":25877,"position":3,"arabic":"نُوحًا","translation":"নূহকে","audioUrl":"wbw/023_023_003.mp3","charTypeName":"word"},{"id":25878,"position":4,"arabic":"إِلَىٰ","translation":"প্রতি","audioUrl":"wbw/023_023_004.mp3","charTypeName":"word"},{"id":25879,"position":5,"arabic":"قَوْمِهِۦ","translation":"তার জাতির","audioUrl":"wbw/023_023_005.mp3","charTypeName":"word"},{"id":25880,"position":6,"arabic":"فَقَالَ","translation":"তখন সে বলেছিলো","audioUrl":"wbw/023_023_006.mp3","charTypeName":"word"},{"id":25881,"position":7,"arabic":"يَـٰقَوْمِ","translation":"\"হে আমার জাতি","audioUrl":"wbw/023_023_007.mp3","charTypeName":"word"},{"id":25882,"position":8,"arabic":"ٱعْبُدُوا۟","translation":"তোমরা ইবাদাত করো","audioUrl":"wbw/023_023_008.mp3","charTypeName":"word"},{"id":25883,"position":9,"arabic":"ٱللَّهَ","translation":"আল্লাহর","audioUrl":"wbw/023_023_009.mp3","charTypeName":"word"},{"id":25884,"position":10,"arabic":"مَا","translation":"নেই","audioUrl":"wbw/023_023_010.mp3","charTypeName":"word"},{"id":25885,"position":11,"arabic":"لَكُم","translation":"জন্যে তোমাদের","audioUrl":"wbw/023_023_011.mp3","charTypeName":"word"},{"id":25886,"position":12,"arabic":"مِّنْ","translation":"কোন","audioUrl":"wbw/023_023_012.mp3","charTypeName":"word"},{"id":25887,"position":13,"arabic":"إِلَـٰهٍ","translation":"ইলাহ","audioUrl":"wbw/023_023_013.mp3","charTypeName":"word"},{"id":25888,"position":14,"arabic":"غَيْرُهُۥٓ ۖ","translation":"তিনি ছাড়া","audioUrl":"wbw/023_023_014.mp3","charTypeName":"word"},{"id":25890,"position":15,"arabic":"أَفَلَا","translation":"কি তবুও না","audioUrl":"wbw/023_023_016.mp3","charTypeName":"word"},{"id":25891,"position":16,"arabic":"تَتَّقُونَ","translation":"তোমরা সাবধান হবে\"","audioUrl":"wbw/023_023_017.mp3","charTypeName":"word"},{"id":25892,"position":17,"arabic":"٢٣","translation":"(২৩)","audioUrl":null,"charTypeName":"end"}]},{"number":24,"arabic":"فَقَالَ ٱلْمَلَؤُا۟ ٱلَّذِينَ كَفَرُوا۟ مِن قَوْمِهِۦ مَا هَٰذَآ إِلَّا بَشَرٌۭ مِّثْلُكُمْ يُرِيدُ أَن يَتَفَضَّلَ عَلَيْكُمْ وَلَوْ شَآءَ ٱللَّهُ لَأَنزَلَ مَلَٰٓئِكَةًۭ مَّا سَمِعْنَا بِهَٰذَا فِىٓ ءَابَآئِنَا ٱلْأَوَّلِينَ","translation":"But the great ones among his people, who refused to acknowledge the truth, replied: “This [man] is nothing but a mortal like yourselves who wants to make himself superior to you! For, if God had willed [to convey a message unto us], He would surely have sent down angels; [moreover,] we have never heard [any­thing like] this from our forebears of old!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2697.mp3","surahId":23,"words":[{"id":27045,"position":1,"arabic":"فَقَالَ","translation":"তখন বলেছিলো","audioUrl":"wbw/023_024_001.mp3","charTypeName":"word"},{"id":27046,"position":2,"arabic":"ٱلْمَلَؤُا۟","translation":"প্রধান ব্যক্তিরা","audioUrl":"wbw/023_024_002.mp3","charTypeName":"word"},{"id":27047,"position":3,"arabic":"ٱلَّذِينَ","translation":"(তাদের) যারা","audioUrl":"wbw/023_024_003.mp3","charTypeName":"word"},{"id":27048,"position":4,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করেছিলো","audioUrl":"wbw/023_024_004.mp3","charTypeName":"word"},{"id":27049,"position":5,"arabic":"مِن","translation":"মধ্য হ'তে","audioUrl":"wbw/023_024_005.mp3","charTypeName":"word"},{"id":27050,"position":6,"arabic":"قَوْمِهِۦ","translation":"তার জাতির","audioUrl":"wbw/023_024_006.mp3","charTypeName":"word"},{"id":27051,"position":7,"arabic":"مَا","translation":"\"নয়","audioUrl":"wbw/023_024_007.mp3","charTypeName":"word"},{"id":27052,"position":8,"arabic":"هَـٰذَآ","translation":"\"এই (ব্যক্তি)","audioUrl":"wbw/023_024_008.mp3","charTypeName":"word"},{"id":27053,"position":9,"arabic":"إِلَّا","translation":"এ ছাড়া যে","audioUrl":"wbw/023_024_009.mp3","charTypeName":"word"},{"id":27054,"position":10,"arabic":"بَشَرٌۭ","tra