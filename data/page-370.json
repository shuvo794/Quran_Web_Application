79_002.mp3","charTypeName":"word"},{"id":63946,"position":3,"arabic":"يُطْعِمُنِى","translation":"আমাকে খাওয়ান","audioUrl":"wbw/026_079_003.mp3","charTypeName":"word"},{"id":63947,"position":4,"arabic":"وَيَسْقِينِ","translation":"ও আমাকে পান করান","audioUrl":"wbw/026_079_004.mp3","charTypeName":"word"},{"id":63948,"position":5,"arabic":"٧٩","translation":"(৭৯)","audioUrl":null,"charTypeName":"end"}]},{"number":80,"arabic":"وَإِذَا مَرِضْتُ فَهُوَ يَشْفِينِ","translation":"and when I fall ill, is the One who restores me to health,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3012.mp3","surahId":26,"words":[{"id":64222,"position":1,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/026_080_001.mp3","charTypeName":"word"},{"id":64223,"position":2,"arabic":"مَرِضْتُ","translation":"আমি অসুস্থ হই","audioUrl":"wbw/026_080_002.mp3","charTypeName":"word"},{"id":64224,"position":3,"arabic":"فَهُوَ","translation":"তখন তিনিই","audioUrl":"wbw/026_080_003.mp3","charTypeName":"word"},{"id":64225,"position":4,"arabic":"يَشْفِينِ","translation":"আমাকে আরোগ্য দান করেন","audioUrl":"wbw/026_080_004.mp3","charTypeName":"word"},{"id":64226,"position":5,"arabic":"٨٠","translation":"(৮০)","audioUrl":null,"charTypeName":"end"}]},{"number":81,"arabic":"وَٱلَّذِى يُمِيتُنِى ثُمَّ يُحْيِينِ","translation":"and who will cause me to die and then will bring me back to life –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3013.mp3","surahId":26,"words":[{"id":64536,"position":1,"arabic":"وَٱلَّذِى","translation":"এবং (তিনিই) যিনি","audioUrl":"wbw/026_081_001.mp3","charTypeName":"word"},{"id":64537,"position":2,"arabic":"يُمِيتُنِى","translation":"আমাকে মৃত্যু দিবেন","audioUrl":"wbw/026_081_002.mp3","charTypeName":"word"},{"id":64538,"position":3,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/026_081_003.mp3","charTypeName":"word"},{"id":64539,"position":4,"arabic":"يُحْيِينِ","translation":"জীবিত করবেন","audioUrl":"wbw/026_081_004.mp3","charT