128/ar.alafasy/3007.mp3","surahId":26,"words":[{"id":62192,"position":1,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/026_075_001.mp3","charTypeName":"word"},{"id":62193,"position":2,"arabic":"أَفَرَءَيْتُم","translation":"\"কি তবে (ভেবে) দেখেছো তোমরা","audioUrl":"wbw/026_075_002.mp3","charTypeName":"word"},{"id":62194,"position":3,"arabic":"مَّا","translation":"(ঐগুলোকে) যার","audioUrl":"wbw/026_075_003.mp3","charTypeName":"word"},{"id":62195,"position":4,"arabic":"كُنتُمْ","translation":"তোমরা ছিলে","audioUrl":"wbw/026_075_004.mp3","charTypeName":"word"},{"id":62196,"position":5,"arabic":"تَعْبُدُونَ","translation":"তোমরা পূজা করো","audioUrl":"wbw/026_075_005.mp3","charTypeName":"word"},{"id":62197,"position":6,"arabic":"٧٥","translation":"(৭৫)","audioUrl":null,"charTypeName":"end"}]},{"number":76,"arabic":"أَنتُمْ وَءَابَآؤُكُمُ ٱلْأَقْدَمُونَ","translation":"you and those ancient forebears of yours?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3008.mp3","surahId":26,"words":[{"id":62695,"position":1,"arabic":"أَنتُمْ","translation":"তোমরা","audioUrl":"wbw/026_076_001.mp3","charTypeName":"word"},{"id":62696,"position":2,"arabic":"وَءَابَآؤُكُمُ","translation":"ও পিতৃ-পুরুষেরা তোমাদের","audioUrl":"wbw/026_076_002.mp3","charTypeName":"word"},{"id":62697,"position":3,"arabic":"ٱلْأَقْدَمُونَ","translation":"(যারা) অতীত হয়েছে","audioUrl":"wbw/026_076_003.mp3","charTypeName":"word"},{"id":62698,"position":4,"arabic":"٧٦","translation":"(৭৬)","audioUrl":null,"charTypeName":"end"}]},{"number":77,"arabic":"فَإِنَّهُمْ عَدُوٌّۭ لِّىٓ إِلَّا رَبَّ ٱلْعَٰلَمِينَ","translation":"“Now [as for me, I know that,] verily, these [false deities] are my enemies, [and that none is my helper] save the Sustainer of all the worlds,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3009.mp3","surahId":26,"words":[{"id":63036,"position":1,"arabic":"فَإِنَّهُمْ","translation":"সুতরাং নিশ্চয়ই তারা","audioUrl":"wbw/026_077_001.mp3","charTypeN