{"id":370,"ayahs":[{"number":61,"arabic":"فَلَمَّا تَرَٰٓءَا ٱلْجَمْعَانِ قَالَ أَصْحَٰبُ مُوسَىٰٓ إِنَّا لَمُدْرَكُونَ","translation":"and as soon as the two hosts came in sight of one another, the followers of Moses exclaimed: “Behold, we shall certainly be overtaken [and defeated]!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2993.mp3","surahId":26,"words":[{"id":55194,"position":1,"arabic":"فَلَمَّا","translation":"অতঃপর যখন","audioUrl":"wbw/026_061_001.mp3","charTypeName":"word"},{"id":55195,"position":2,"arabic":"تَرَٰٓءَا","translation":"পরস্পরকে দেখলো","audioUrl":"wbw/026_061_002.mp3","charTypeName":"word"},{"id":55196,"position":3,"arabic":"ٱلْجَمْعَانِ","translation":"দল দু'টো","audioUrl":"wbw/026_061_003.mp3","charTypeName":"word"},{"id":55197,"position":4,"arabic":"قَالَ","translation":"বললো","audioUrl":"wbw/026_061_004.mp3","charTypeName":"word"},{"id":55198,"position":5,"arabic":"أَصْحَـٰبُ","translation":"সাথীরা","audioUrl":"wbw/026_061_005.mp3","charTypeName":"word"},{"id":55199,"position":6,"arabic":"مُوسَىٰٓ","translation":"মূসার","audioUrl":"wbw/026_061_006.mp3","charTypeName":"word"},{"id":55200,"position":7,"arabic":"إِنَّا","translation":"\"নিশ্চয়ই আমরা","audioUrl":"wbw/026_061_007.mp3","charTypeName":"word"},{"id":55201,"position":8,"arabic":"لَمُدْرَكُونَ","translation":"অবশ্যই ধরা পড়ে গেলাম\"","audioUrl":"wbw/026_061_008.mp3","charTypeName":"word"},{"id":55202,"position":9,"arabic":"٦١","translation":"(৬১)","audioUrl":null,"charTypeName":"end"}]},{"number":62,"arabic":"قَالَ كَلَّآ ۖ إِنَّ مَعِىَ رَبِّى سَيَهْدِينِ","translation":"He replied: Nay indeed! My Sustainer is with me, [and] He will guide me!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2994.mp3","surahId":26,"words":[{"id":55785,"position":1,"arabic":"قَالَ","translation":"(মূসা) বললো","audioUrl":"wbw/026_062_001.mp3","charTypeName":"word"},{"id":55786,"position":2,"arabic":"كَلَّآ ۖ","translation":"\"কখনও না","audioUrl":"wbw/026_062_002.mp3","charTypeName":"word"},{"id":55788,"position":3,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/026_062_004.mp3","charTypeName":"word"},{"id":55789,"position":4,"arabic":"مَعِىَ","translation":"আমার সাথে (আছেন)","audioUrl":"wbw/026_062_005.mp3","charTypeName":"word"},{"id":55790,"position":5,"arabic":"رَبِّى","translation":"আমার রব","audioUrl":"wbw/026_062_006.mp3","charTypeName":"word"},{"id":55791,"position":6,"arabic":"سَيَهْدِينِ","translation":"শীঘ্রই তিনি আমাকে পথ দেখাবেন\"","audioUrl":"wbw/026_062_007.mp3","charTypeName":"word"},{"id":55792,"position":7,"arabic":"٦٢","translation":"(৬২)","audioUrl":null,"charTypeName":"end"}]},{"number":63,"arabic":"فَأَوْحَيْنَآ إِلَىٰ مُوسَىٰٓ أَنِ ٱضْرِب بِّعَصَاكَ ٱلْبَحْرَ ۖ فَٱنفَلَقَ فَكَانَ كُلُّ فِرْقٍۢ كَٱلطَّوْدِ ٱلْعَظِيمِ","translation":"Thereupon We inspired Moses thus: Strike the sea with thy staff!”- whereupon it parted, and each part appeared like a mountain vast.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2995.mp3","surahId":26,"words":[{"id":56210,"position":1,"arabic":"فَأَوْحَيْنَآ","translation":"অতঃপর আমরা ওহী পাঠালাম","audioUrl":"wbw/026_063_001.mp3","charTypeName":"word"},{"id":56211,"position":2,"arabic":"إِلَىٰ","translation":"প্রতি","audioUrl":"wbw/026_063_002.mp3","charTypeName":"word"},{"id":56212,"position":3,"arabic":"مُوسَىٰٓ","translation":"মূসার","audioUrl":"wbw/026_063_003.mp3","charTypeName":"word"},{"id":56213,"position":4,"arabic":"أَنِ","translation":"যে","audioUrl":"wbw/026_063_004.mp3","charTypeName":"word"},{"id":56214,"position":5,"arabic":"ٱضْرِب","translation":"\"আঘাত করো","audioUrl":"wbw/026_063_005.mp3","charTypeName":"word"},{"id":56215,"position":6,"arabic":"بِّعَصَاكَ","translation":"দিয়ে তোমার লাঠি","audioUrl":"wbw/026_063_006.mp3","charTypeName":"word"},{"id":56216,"position":7,"arabic":"ٱلْبَحْرَ ۖ","translation":"সমূদ্রকে\"","audioUrl":"wbw/026_063_007.mp3","charTypeName":"word"},{"id":56218,"position":8,"arabic":"فَٱنفَلَقَ","translation":"ফলে ফেটে গেল (সমুদ্র)","audioUrl":"wbw/026_063_009.mp3","charTypeName":"word"},{"id":56219,"position":9,"arabic":"فَكَانَ","translation":"অতঃপর হলো","audioUrl":"wbw/026_063_010.mp3","charTypeName":"word"},{"id":56220,"position":10,"arabic":"كُلُّ","translation":"প্রত্যেক","audioUrl":"wbw/026_063_011.mp3","charTypeName":"word"},{"id":56221,"position":11,"arabic":"فِرْقٍۢ","translation":"ভাগ","audioUrl":"wbw/026_063_012.mp3","charTypeName":"word"},{"id":56222,"position":12,"arabic":"كَٱلطَّوْدِ","translation":"মতো পর্বতের","audioUrl":"wbw/026_063_013.mp3","charTypeName":"word"},{"id":56223,"position":13,"arabic":"ٱلْعَظِيمِ","translation":"বিশাল","audioUrl":"wbw/026_063_014.mp3","charTypeName":"word"},{"id":56224,"position":14,"arabic":"٦٣","translation":"(৬৩)","audioUrl":null,"charTypeName":"end"}]},{"number":64,"arabic":"وَأَزْلَفْنَا ثَمَّ ٱلْءَاخَرِينَ","translation":"And We caused the pursuers to draw near unto that place:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2996.mp3","surahId":26,"words":[{"id":56682,"position":1,"arabic":"وَأَزْلَفْنَا","translation":"এবং আমরা নিকটে আনলাম","audioUrl":"wbw/026_064_001.mp3","charTypeName":"word"},{"id":56683,"position":2,"arabic":"ثَمَّ","translation":"সেখানেই","audioUrl":"wbw/026_064_002.mp3","charTypeName":"word"},{"id":56684,"position":3,"arabic":"ٱلْـَٔاخَرِينَ","translation":"অন্যান্যদেরকে (অপর দলকে)","audioUrl":"wbw/026_064_003.mp3","charTypeName":"word"},{"id":56685,"position":4,"arabic":"٦٤","translation":"(৬৪)","audioUrl":null,"charTypeName":"end"}]},{"number":65,"arabic":"وَأَنجَيْنَا مُوسَىٰ وَمَن مَّعَهُۥٓ أَجْمَعِينَ","translation":"and We saved Moses and all who were with him,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2997.mp3","surahId":26,"words":[{"id":57244,"position":1,"arabic":"وَأَنجَيْنَا","translation":"এবং আমরা উদ্ধার করলাম","audioUrl":"wbw/026_065_001.mp3","charTypeName":"word"},{"id":57245,"position":2,"arabic":"مُوسَىٰ","translation":"মূসাকে","audioUrl":"wbw/026_065_002.mp3","charTypeName":"word"},{"id":57246,"position":3,"arabic":"وَمَن","translation":"ও যারা (ছিলো)","audioUrl":"wbw/026_065_003.mp3","charTypeName":"word"},{"id":57247,"position":4,"arabic":"مَّعَهُۥٓ","translation":"তাঁর সাথে","audioUrl":"wbw/026_065_004.mp3","charTypeName":"word"},{"id":57248,"position":5,"arabic":"أَجْمَعِينَ","translation":"সবাইকে","audioUrl":"wbw/026_065_005.mp3","charTypeName":"word"},{"id":57249,"position":6,"arabic":"٦٥","translation":"(৬৫)","audioUrl":null,"charTypeName":"end"}]},{"number":66,"arabic":"ثُمَّ أَغْرَقْنَا ٱلْءَاخَرِينَ","translation":"and then We caused the others to drown.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2998.mp3","surahId":26,"words":[{"id":57797,"position":1,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/026_066_001.mp3","charTypeName":"word"},{"id":57798,"position":2,"arabic":"أَغْرَقْنَا","translation":"আমরা ডুবিয়ে দিলাম","audioUrl":"wbw/026_066_002.mp3","charTypeName":"word"},{"id":57799,"position":3,"arabic":"ٱلْـَٔاخَرِينَ","translation":"অন্যান্যদেরকে","audioUrl":"wbw/026_066_003.mp3","charTypeName":"word"},{"id":57800,"position":4,"arabic":"٦٦","translation":"(৬৬)","audioUrl":null,"charTypeName":"end"}]},{"number":67,"arabic":"إِنَّ فِى ذَٰلِكَ لَءَايَةًۭ ۖ وَمَا كَانَ أَكْثَرُهُم مُّؤْمِنِينَ","translation":"In this [story] behold, there is a message [unto all men], even though most of them will not believe [in it].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2999.mp3","surahId":26,"words":[{"id":58252,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/026_067_001.mp3","charTypeName":"word"},{"id":58253,"position":2,"arabic":"فِى","translation":"মধ্যে (আছে)","audioUrl":"wbw/026_067_002.mp3","charTypeName":"word"},{"id":58254,"position":3,"arabic":"ذَٰلِكَ","translation":"এর","audioUrl":"wbw/026_067_003.mp3","charTypeName":"word"},{"id":58255,"position":4,"arabic":"لَـَٔايَةًۭ ۖ","translation":"অবশ্যই একটি নিদর্শন","audioUrl":"wbw/026_067_004.mp3","charTypeName":"word"},{"id":58257,"position":5,"arabic":"وَمَا","translation":"কিন্তু না","audioUrl":"wbw/026_067_006.mp3","charTypeName":"word"},{"id":58258,"position":6,"arabic":"كَانَ","translation":"ছিলো","audioUrl":"wbw/026_067_007.mp3","charTypeName":"word"},{"id":58259,"position":7,"arabic":"أَكْثَرُهُم","translation":"অধিকাংশই তাদের","audioUrl":"wbw/026_067_008.mp3","charTypeName":"word"},{"id":58260,"position":8,"arabic":"مُّؤْمِنِينَ","translation":"বিশ্বাসী","audioUrl":"wbw/026_067_009.mp3","charTypeName":"word"},{"id":58261,"position":9,"arabic":"٦٧","translation":"(৬৭)","audioUrl":null,"charTypeName":"end"}]},{"number":68,"arabic":"وَإِنَّ رَبَّكَ لَهُوَ ٱلْعَزِيزُ ٱلرَّحِيمُ","translation":"And yet, verily, thy Sustainer - He alone - is almighty, a dispenser of grace!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3000.mp3","surahId":26,"words":[{"id":58459,"position":1,"arabic":"وَإِنَّ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/026_068_001.mp3","charTypeName":"word"},{"id":58460,"position":2,"arabic":"رَبَّكَ","translation":"তোমার রব","audioUrl":"wbw/026_068_002.mp3","charTypeName":"word"},{"id":58461,"position":3,"arabic":"لَهُوَ","translation":"অবশ্যই তিনিই","audioUrl":"wbw/026_068_003.mp3","charTypeName":"word"},{"id":58462,"position":4,"arabic":"ٱلْعَزِيزُ","translation":"পরাক্রমশালী","audioUrl":"wbw/026_068_004.mp3","charTypeName":"word"},{"id":58463,"position":5,"arabic":"ٱلرَّحِيمُ","translation":"পরম দয়ালু","audioUrl":"wbw/026_068_005.mp3","charTypeName":"word"},{"id":58464,"position":6,"arabic":"٦٨","translation":"(৬৮)","audioUrl":null,"charTypeName":"end"}]},{"number":69,"arabic":"وَٱتْلُ عَلَيْهِمْ نَبَأَ إِبْرَٰهِيمَ","translation":"And convey unto them the story of Abraham –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3001.mp3","surahId":26,"words":[{"id":59187,"position":1,"arabic":"وَٱتْلُ","translation":"আর পাঠ করে শুনাও","audioUrl":"wbw/026_069_001.mp3","charTypeName":"word"},{"id":59188,"position":2,"arabic":"عَلَيْهِمْ","translation":"কাছে তাদের","audioUrl":"wbw/026_069_002.mp3","charTypeName":"word"},{"id":59189,"position":3,"arabic":"نَبَأَ","translation":"সংবাদ","audioUrl":"wbw/026_069_003.mp3","charTypeName":"word"},{"id":59190,"position":4,"arabic":"إِبْرَٰهِيمَ","translation":"ইবরাহীমের","audioUrl":"wbw/026_069_004.mp3","charTypeName":"word"},{"id":59191,"position":5,"arabic":"٦٩","translation":"(৬৯)","audioUrl":null,"charTypeName":"end"}]},{"number":70,"arabic":"إِذْ قَالَ لِأَبِيهِ وَقَوْمِهِۦ مَا تَعْبُدُونَ","translation":"[how it was] when he asked his father and his people, “What is it that you worship?”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3002.mp3","surahId":26,"words":[{"id":59588,"position":1,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/026_070_001.mp3","charTypeName":"word"},{"id":59589,"position":2,"arabic":"قَالَ","translation":"সে বলেছিলো","audioUrl":"wbw/026_070_002.mp3","charTypeName":"word"},{"id":59590,"position":3,"arabic":"لِأَبِيهِ","translation":"উদ্দেশ্যে তার পিতার","audioUrl":"wbw/026_070_003.mp3","charTypeName":"word"},{"id":59591,"position":4,"arabic":"وَقَوْمِهِۦ","translation":"ও তার জাতির","audioUrl":"wbw/026_070_004.mp3","charTypeName":"word"},{"id":59592,"position":5,"arabic":"مَا","translation":"\"কিসের","audioUrl":"wbw/026_070_005.mp3","charTypeName":"word"},{"id":59593,"position":6,"arabic":"تَعْبُدُونَ","translation":"তোমরা পূজা করছো\"","audioUrl":"wbw/026_070_006.mp3","charTypeName":"word"},{"id":59594,"position":7,"arabic":"٧٠","translation":"(৭০)","audioUrl":null,"charTypeName":"end"}]},{"number":71,"arabic":"قَالُوا۟ نَعْبُدُ أَصْنَامًۭا فَنَظَلُّ لَهَا عَٰكِفِينَ","translation":"They answered: We worship idols, and we remain ever devoted to them.”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3003.mp3","surahId":26,"words":[{"id":60161,"position":1,"arabic":"قَالُوا۟","translation":"তারা বলেছিলো","audioUrl":"wbw/026_071_001.mp3","charTypeName":"word"},{"id":60162,"position":2,"arabic":"نَعْبُدُ","translation":"\"আমরা পূজা করি","audioUrl":"wbw/026_071_002.mp3","charTypeName":"word"},{"id":60163,"position":3,"arabic":"أَصْنَامًۭا","translation":"(কিছু) মূর্তির","audioUrl":"wbw/026_071_003.mp3","charTypeName":"word"},{"id":60164,"position":4,"arabic":"فَنَظَلُّ","translation":"অতঃপর আমরা লেগে থাকি","audioUrl":"wbw/026_071_004.mp3","charTypeName":"word"},{"id":60165,"position":5,"arabic":"لَهَا","translation":"জন্যে তাদের","audioUrl":"wbw/026_071_005.mp3","charTypeName":"word"},{"id":60166,"position":6,"arabic":"عَـٰكِفِينَ","translation":"নিষ্ঠাবান হয়ে\"","audioUrl":"wbw/026_071_006.mp3","charTypeName":"word"},{"id":60167,"position":7,"arabic":"٧١","translation":"(৭১)","audioUrl":null,"charTypeName":"end"}]},{"number":72,"arabic":"قَالَ هَلْ يَسْمَعُونَكُمْ إِذْ تَدْعُونَ","translation":"Said he: “Do [you really think that] they hear you when you invoke them,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3004.mp3","surahId":26,"words":[{"id":60690,"position":1,"arabic":"قَالَ","translation":"(ইবরাহীম) বললো","audioUrl":"wbw/026_072_001.mp3","charTypeName":"word"},{"id":60691,"position":2,"arabic":"هَلْ","translation":"\"কি","audioUrl":"wbw/026_072_002.mp3","charTypeName":"word"},{"id":60692,"position":3,"arabic":"يَسْمَعُونَكُمْ","translation":"তারা শুনতে পায় তোমাদেরকে","audioUrl":"wbw/026_072_003.mp3","charTypeName":"word"},{"id":60693,"position":4,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/026_072_004.mp3","charTypeName":"word"},{"id":60694,"position":5,"arabic":"تَدْعُونَ","translation":"তোমরা ডাকো","audioUrl":"wbw/026_072_005.mp3","charTypeName":"word"},{"id":60695,"position":6,"arabic":"٧٢","translation":"(৭২)","audioUrl":null,"charTypeName":"end"}]},{"number":73,"arabic":"أَوْ يَنفَعُونَكُمْ أَوْ يَضُرُّونَ","translation":"or benefit you or do you harm?”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3005.mp3","surahId":2