3.mp3","charTypeName":"word"},{"id":30128,"position":4,"arabic":"وُقِفُوا۟","translation":"তাদের দাঁড় করান হবে","audioUrl":"wbw/006_027_004.mp3","charTypeName":"word"},{"id":30129,"position":5,"arabic":"عَلَى","translation":"কাছে","audioUrl":"wbw/006_027_005.mp3","charTypeName":"word"},{"id":30130,"position":6,"arabic":"ٱلنَّارِ","translation":"(দোজখের) আগুনের","audioUrl":"wbw/006_027_006.mp3","charTypeName":"word"},{"id":30131,"position":7,"arabic":"فَقَالُوا۟","translation":"তখন তারা বলবে","audioUrl":"wbw/006_027_007.mp3","charTypeName":"word"},{"id":30132,"position":8,"arabic":"يَـٰلَيْتَنَا","translation":"\"হায়! আমাদের দুর্ভোগ","audioUrl":"wbw/006_027_008.mp3","charTypeName":"word"},{"id":30133,"position":9,"arabic":"نُرَدُّ","translation":"ফেরান হতো (সেখানে যদি) আমাদেরকে","audioUrl":"wbw/006_027_009.mp3","charTypeName":"word"},{"id":30134,"position":10,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/006_027_010.mp3","charTypeName":"word"},{"id":30135,"position":11,"arabic":"نُكَذِّبَ","translation":"মিথ্যারোপ করতাম আমরা","audioUrl":"wbw/006_027_011.mp3","charTypeName":"word"},{"id":30136,"position":12,"arabic":"بِـَٔايَـٰتِ","translation":"প্রতি নিদর্শনগুলোর","audioUrl":"wbw/006_027_012.mp3","charTypeName":"word"},{"id":30137,"position":13,"arabic":"رَبِّنَا","translation":"রবের আমাদের","audioUrl":"wbw/006_027_013.mp3","charTypeName":"word"},{"id":30138,"position":14,"arabic":"وَنَكُونَ","translation":"এবং  হতাম আমরা","audioUrl":"wbw/006_027_014.mp3","charTypeName":"word"},{"id":30139,"position":15,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/006_027_015.mp3","charTypeName":"word"},{"id":30140,"position":16,"arabic":"ٱلْمُؤْمِنِينَ","translation":"মু'মিনদের\"","audioUrl":"wbw/006_027_016.mp3","charTypeName":"word"},{"id":30141,"position":17,"arabic":"٢٧","translation":"(২৭)","audioUrl":null,"charTypeName":"end"}]}]}