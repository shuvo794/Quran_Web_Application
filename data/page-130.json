oretime know this as they know their own children; yet those [of them] who have squandered their own selves -it is they who refuse to believe.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/809.mp3","surahId":6,"words":[{"id":23036,"position":1,"arabic":"ٱلَّذِينَ","translation":"যাদেরকে","audioUrl":"wbw/006_020_001.mp3","charTypeName":"word"},{"id":23037,"position":2,"arabic":"ءَاتَيْنَـٰهُمُ","translation":"আমরা দিয়েছি তাদের","audioUrl":"wbw/006_020_002.mp3","charTypeName":"word"},{"id":23038,"position":3,"arabic":"ٱلْكِتَـٰبَ","translation":"কিতাব","audioUrl":"wbw/006_020_003.mp3","charTypeName":"word"},{"id":23039,"position":4,"arabic":"يَعْرِفُونَهُۥ","translation":"তারা চিনে তাকে","audioUrl":"wbw/006_020_004.mp3","charTypeName":"word"},{"id":23040,"position":5,"arabic":"كَمَا","translation":"যেমন","audioUrl":"wbw/006_020_005.mp3","charTypeName":"word"},{"id":23041,"position":6,"arabic":"يَعْرِفُونَ","translation":"তারা চিনে","audioUrl":"wbw/006_020_006.mp3","charTypeName":"word"},{"id":23042,"position":7,"arabic":"أَبْنَآءَهُمُ ۘ","translation":"সন্তানদের তাদের","audioUrl":"wbw/006_020_007.mp3","charTypeName":"word"},{"id":23044,"position":8,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/006_020_009.mp3","charTypeName":"word"},{"id":23045,"position":9,"arabic":"خَسِرُوٓا۟","translation":"ক্ষতিগ্রস্ত  করেছে","audioUrl":"wbw/006_020_010.mp3","charTypeName":"word"},{"id":23046,"position":10,"arabic":"أَنفُسَهُمْ","translation":"নিজেদেরকে তাদের","audioUrl":"wbw/006_020_011.mp3","charTypeName":"word"},{"id":23047,"position":11,"arabic":"فَهُمْ","translation":"অতঃপর তারা","audioUrl":"wbw/006_020_012.mp3","charTypeName":"word"},{"id":23048,"position":12,"arabic":"لَا","translation":"না","audioUrl":"wbw/006_020_013.mp3","charTypeName":"word"},{"id":23049,"position":13,"arabic":"يُؤْمِنُونَ","translation":"বিশ্বাস করবে","audioUrl":"wbw/006_020_014.mp3","charTypeName":"word"},{"id":23050,"position":14,"arabic":"٢٠","translation":"(২০)","au