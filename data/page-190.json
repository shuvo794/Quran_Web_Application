{"id":190,"ayahs":[{"number":21,"arabic":"يُبَشِّرُهُمْ رَبُّهُم بِرَحْمَةٍۢ مِّنْهُ وَرِضْوَٰنٍۢ وَجَنَّٰتٍۢ لَّهُمْ فِيهَا نَعِيمٌۭ مُّقِيمٌ","translation":"Their Sustainer gives them the glad tiding of the grace [that flows] from Him, and of [His] goodly acceptance, and of the gardens which await them, full of lasting bliss,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1256.mp3","surahId":9,"words":[{"id":23824,"position":1,"arabic":"يُبَشِّرُهُمْ","translation":"সুসংবাদ দিচ্ছেন তাদেরকে","audioUrl":"wbw/009_021_001.mp3","charTypeName":"word"},{"id":23825,"position":2,"arabic":"رَبُّهُم","translation":"তাদের রব","audioUrl":"wbw/009_021_002.mp3","charTypeName":"word"},{"id":23826,"position":3,"arabic":"بِرَحْمَةٍۢ","translation":"সাহায্যে দয়ার","audioUrl":"wbw/009_021_003.mp3","charTypeName":"word"},{"id":23827,"position":4,"arabic":"مِّنْهُ","translation":"পক্ষ হতে তাঁর","audioUrl":"wbw/009_021_004.mp3","charTypeName":"word"},{"id":23828,"position":5,"arabic":"وَرِضْوَٰنٍۢ","translation":"ও (তাঁর) সন্তুষ্টির","audioUrl":"wbw/009_021_005.mp3","charTypeName":"word"},{"id":23829,"position":6,"arabic":"وَجَنَّـٰتٍۢ","translation":"এবং জান্নাতের","audioUrl":"wbw/009_021_006.mp3","charTypeName":"word"},{"id":23830,"position":7,"arabic":"لَّهُمْ","translation":"জন্যে তাদের","audioUrl":"wbw/009_021_007.mp3","charTypeName":"word"},{"id":23831,"position":8,"arabic":"فِيهَا","translation":"মধ্যে তার(রয়েছে)","audioUrl":"wbw/009_021_008.mp3","charTypeName":"word"},{"id":23832,"position":9,"arabic":"نَعِيمٌۭ","translation":"সুখ","audioUrl":"wbw/009_021_009.mp3","charTypeName":"word"},{"id":23833,"position":10,"arabic":"مُّقِيمٌ","translation":"স্থায়ী","audioUrl":"wbw/009_021_010.mp3","charTypeName":"word"},{"id":23834,"position":11,"arabic":"٢١","translation":"(২১)","audioUrl":null,"charTypeName":"end"}]},{"number":22,"arabic":"خَٰلِدِينَ فِيهَآ أَبَدًا ۚ إِنَّ ٱللَّهَ عِندَهُۥٓ أَجْرٌ عَظِيمٌۭ","translation":"therein to abide beyond the count of time. Verily, with God is a mighty reward!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1257.mp3","surahId":9,"words":[{"id":24841,"position":1,"arabic":"خَـٰلِدِينَ","translation":"তারা চিরস্থায়ী হবে","audioUrl":"wbw/009_022_001.mp3","charTypeName":"word"},{"id":24842,"position":2,"arabic":"فِيهَآ","translation":"মধ্যে তার","audioUrl":"wbw/009_022_002.mp3","charTypeName":"word"},{"id":24843,"position":3,"arabic":"أَبَدًا ۚ","translation":"অনাগতকাল (পর্যন্ত)","audioUrl":"wbw/009_022_003.mp3","charTypeName":"word"},{"id":24845,"position":4,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/009_022_005.mp3","charTypeName":"word"},{"id":24846,"position":5,"arabic":"ٱللَّهَ","translation":"আল্লাহর","audioUrl":"wbw/009_022_006.mp3","charTypeName":"word"},{"id":24847,"position":6,"arabic":"عِندَهُۥٓ","translation":"কাছে (আছে) তাঁর","audioUrl":"wbw/009_022_007.mp3","charTypeName":"word"},{"id":24848,"position":7,"arabic":"أَجْرٌ","translation":"পুরস্কার","audioUrl":"wbw/009_022_008.mp3","charTypeName":"word"},{"id":24849,"position":8,"arabic":"عَظِيمٌۭ","translation":"বিরাট","audioUrl":"wbw/009_022_009.mp3","charTypeName":"word"},{"id":24850,"position":9,"arabic":"٢٢","translation":"(২২)","audioUrl":null,"charTypeName":"end"}]},{"number":23,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ لَا تَتَّخِذُوٓا۟ ءَابَآءَكُمْ وَإِخْوَٰنَكُمْ أَوْلِيَآءَ إِنِ ٱسْتَحَبُّوا۟ ٱلْكُفْرَ عَلَى ٱلْإِيمَٰنِ ۚ وَمَن يَتَوَلَّهُم مِّنكُمْ فَأُو۟لَٰٓئِكَ هُمُ ٱلظَّٰلِمُونَ","translation":"O YOU who have attained to faith! Do not take your fathers and your brothers for allies if a denial of the truth is dearer to them than faith: for those of you who ally themselves with them-it is they, they who are evildoers!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1258.mp3","surahId":9,"words":[{"id":25833,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/009_023_001.mp3","charTypeName":"word"},{"id":25834,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/009_023_002.mp3","charTypeName":"word"},{"id":25835,"position":3,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছো","audioUrl":"wbw/009_023_003.mp3","charTypeName":"word"},{"id":25836,"position":4,"arabic":"لَا","translation":"না","audioUrl":"wbw/009_023_004.mp3","charTypeName":"word"},{"id":25837,"position":5,"arabic":"تَتَّخِذُوٓا۟","translation":"তোমরা গ্রহণ করো","audioUrl":"wbw/009_023_005.mp3","charTypeName":"word"},{"id":25838,"position":6,"arabic":"ءَابَآءَكُمْ","translation":"বাপ-দাদাদেরকে তোমাদের","audioUrl":"wbw/009_023_006.mp3","charTypeName":"word"},{"id":25839,"position":7,"arabic":"وَإِخْوَٰنَكُمْ","translation":"ও ভাইদেরকে তোমাদের","audioUrl":"wbw/009_023_007.mp3","charTypeName":"word"},{"id":25840,"position":8,"arabic":"أَوْلِيَآءَ","translation":"বন্ধু্রূপে","audioUrl":"wbw/009_023_008.mp3","charTypeName":"word"},{"id":25841,"position":9,"arabic":"إِنِ","translation":"যদি","audioUrl":"wbw/009_023_009.mp3","charTypeName":"word"},{"id":25842,"position":10,"arabic":"ٱسْتَحَبُّوا۟","translation":"তারা অধিক ভালবাসে","audioUrl":"wbw/009_023_010.mp3","charTypeName":"word"},{"id":25843,"position":11,"arabic":"ٱلْكُفْرَ","translation":"অবিশ্বাসকে","audioUrl":"wbw/009_023_011.mp3","charTypeName":"word"},{"id":25844,"position":12,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/009_023_012.mp3","charTypeName":"word"},{"id":25845,"position":13,"arabic":"ٱلْإِيمَـٰنِ ۚ","translation":"ঈমানের (তুলনায়)","audioUrl":"wbw/009_023_013.mp3","charTypeName":"word"},{"id":25847,"position":14,"arabic":"وَمَن","translation":"এবং যে","audioUrl":"wbw/009_023_015.mp3","charTypeName":"word"},{"id":25848,"position":15,"arabic":"يَتَوَلَّهُم","translation":"ভালোবাসবে তাদেরকে","audioUrl":"wbw/009_023_016.mp3","charTypeName":"word"},{"id":25849,"position":16,"arabic":"مِّنكُمْ","translation":"মধ্য হতে তোমাদের","audioUrl":"wbw/009_023_017.mp3","charTypeName":"word"},{"id":25850,"position":17,"arabic":"فَأُو۟لَـٰٓئِكَ","translation":"তবে ঐসব লোক","audioUrl":"wbw/009_023_018.mp3","charTypeName":"word"},{"id":25851,"position":18,"arabic":"هُمُ","translation":"তারাই","audioUrl":"wbw/009_023_019.mp3","charTypeName":"word"},{"id":25852,"position":19,"arabic":"ٱلظَّـٰلِمُونَ","translation":"সীমালঙ্ঘনকারী","audioUrl":"wbw/009_023_020.mp3","charTypeName":"word"},{"id":25853,"position":20,"arabic":"٢٣","translation":"(২৩)","audioUrl":null,"charTypeName":"end"}]},{"number":24,"arabic":"قُلْ إِن كَانَ ءَابَآؤُكُمْ وَأَبْنَآؤُكُمْ وَإِخْوَٰنُكُمْ وَأَزْوَٰجُكُمْ وَعَشِيرَتُكُمْ وَأَمْوَٰلٌ ٱقْتَرَفْتُمُوهَا وَتِجَٰرَةٌۭ تَخْشَوْنَ كَسَادَهَا وَمَسَٰكِنُ تَرْضَوْنَهَآ أَحَبَّ إِلَيْكُم مِّنَ ٱللَّهِ وَرَسُولِهِۦ وَجِهَادٍۢ فِى سَبِيلِهِۦ فَتَرَبَّصُوا۟ حَتَّىٰ يَأْتِىَ ٱللَّهُ بِأَمْرِهِۦ ۗ وَٱللَّهُ لَا يَهْدِى ٱلْقَوْمَ ٱلْفَٰسِقِينَ","translation":"Say: \"If your fathers and your sons and your brothers and your spouses and your clan, and the worldly goods which you have acquired, and the commerce whereof you fear a decline, and the dwellings in which you take pleasure - [if all these] are dearer to you than God and His Apostle and the struggle in His cause, then wait until God makes manifest His will; and [know that] God does not grace iniquitous folk with His guidance.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1259.mp3","surahId":9,"words":[{"id":26916,"position":1,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/009_024_001.mp3","charTypeName":"word"},{"id":26917,"position":2,"arabic":"إِن","translation":"\"যদি","audioUrl":"wbw/009_024_002.mp3","charTypeName":"word"},{"id":26918,"position":3,"arabic":"كَانَ","translation":"হয়","audioUrl":"wbw/009_024_003.mp3","charTypeName":"word"},{"id":26919,"position":4,"arabic":"ءَابَآؤُكُمْ","translation":"বাপ-দাদারা তোমাদের","audioUrl":"wbw/009_024_004.mp3","charTypeName":"word"},{"id":26920,"position":5,"arabic":"وَأَبْنَآؤُكُمْ","translation":"ও সন্তানেরা তোমাদের","audioUrl":"wbw/009_024_005.mp3","charTypeName":"word"},{"id":26921,"position":6,"arabic":"وَإِخْوَٰنُكُمْ","translation":"ও ভাইয়েরা তোমাদের","audioUrl":"wbw/009_024_006.mp3","charTypeName":"word"},{"id":26922,"position":7,"arabic":"وَأَزْوَٰجُكُمْ","translation":"ও স্ত্রীরা তোমাদের","audioUrl":"wbw/009_024_007.mp3","charTypeName":"word"},{"id":26923,"position":8,"arabic":"وَعَشِيرَتُكُمْ","translation":"ও স্বজনগোষ্ঠি তোমাদের","audioUrl":"wbw/009_024_008.mp3","charTypeName":"word"},{"id":26924,"position":9,"arabic":"وَأَمْوَٰلٌ","translation":"ও ধনসম্পদ","audioUrl":"wbw/009_024_009.mp3","charTypeName":"word"},{"id":26925,"position":10,"arabic":"ٱقْتَرَفْتُمُوهَا","translation":"যা তোমরা অর্জন করেছো","audioUrl":"wbw/009_024_010.mp3","charTypeName":"word"},{"id":26926,"position":11,"arabic":"وَتِجَـٰرَةٌۭ","translation":"ও ব্যবসা-বাণিজ্য","audioUrl":"wbw/009_024_011.mp3","charTypeName":"word"},{"id":26927,"position":12,"arabic":"تَخْشَوْنَ","translation":"তোমরা ভয় করো","audioUrl":"wbw/009_024_012.mp3","charTypeName":"word"},{"id":26928,"position":13,"arabic":"كَسَادَهَا","translation":"মন্দা পড়ার যার","audioUrl":"wbw/009_024_013.mp3","charTypeName":"word"},{"id":26929,"position":14,"arabic":"وَمَسَـٰكِنُ","translation":"ও বাসগৃহসমূহ","audioUrl":"wbw/009_024_014.mp3","charTypeName":"word"},{"id":26930,"position":15,"arabic":"تَرْضَوْنَهَآ","translation":"তোমরা পছন্দ করো যা","audioUrl":"wbw/009_024_015.mp3","charTypeName":"word"},{"id":26931,"position":16,"arabic":"أَحَبَّ","translation":"অধিক প্রিয়","audioUrl":"wbw/009_024_016.mp3","charTypeName":"word"},{"id":26932,"position":17,"arabic":"إِلَيْكُم","translation":"কাছে তোমাদের","audioUrl":"wbw/009_024_017.mp3","charTypeName":"word"},{"id":26933,"position":18,"arabic":"مِّنَ","translation":"হতে","audioUrl":"wbw/009_024_018.mp3","charTypeName":"word"},{"id":26934,"position":19,"arabic":"ٱللَّهِ","translation":"আল্লাহ","audioUrl":"wbw/009_024_019.mp3","charTypeName":"word"},{"id":26935,"position":20,"arabic":"وَرَسُولِهِۦ","translation":"ও তাঁর রাসূল (হতে)","audioUrl":"wbw/009_024_020.mp3","charTypeName":"word"},{"id":26936,"position":21,"arabic":"وَجِهَادٍۢ","translation":"ও জিহাদ(হতে)","audioUrl":"wbw/009_024_021.mp3","charTypeName":"word"},{"id":26937,"position":22,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/009_024_022.mp3","charTypeName":"word"},{"id":26938,"position":23,"arabic":"سَبِيلِهِۦ","translation":"পথের তাঁর","audioUrl":"wbw/009_024_023.mp3","charTypeName":"word"},{"id":26939,"position":24,"arabic":"فَتَرَبَّصُوا۟","translation":"তবে তোমরা অপেক্ষা করো","audioUrl":"wbw/009_024_024.mp3","charTypeName":"word"},{"id":26940,"position":25,"arabic":"حَتَّىٰ","translation":"যতক্ষণ না","audioUrl":"wbw/009_024_025.mp3","charTypeName":"word"},{"id":26941,"position":26,"arabic":"يَأْتِىَ","translation":"আসেন","audioUrl":"wbw/009_024_026.mp3","charTypeName":"word"},{"id":26942,"position":27,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/009_024_027.mp3","charTypeName":"word"},{"id":26943,"position":28,"arabic":"بِأَمْرِهِۦ ۗ","translation":"নিয়ে তাঁর নির্দেশ","audioUrl":"wbw/009_024_028.mp3","charTypeName":"word"},{"id":26945,"position":29,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/009_024_030.mp3","charTypeName":"word"},{"id":26946,"position":30,"arabic":"لَا","translation":"না","audioUrl":"wbw/009_024_031.mp3","charTypeName":"word"},{"id":26947,"position":31,"arabic":"يَهْدِى","translation":"পথে দেখান","audioUrl":"wbw/009_024_032.mp3","charTypeName":"word"},{"id":26948,"position":32,"arabic":"ٱلْقَوْمَ","translation":"সম্প্রদায়কে","audioUrl":"wbw/009_024_033.mp3","charTypeName":"word"},{"id":26949,"position":33,"arabic":"ٱلْفَـٰسِقِينَ","translation":"(যারা) সত্যত্যাগী\"","audioUrl":"wbw/009_024_034.mp3","charTypeName":"word"},{"id":26950,"position":34,"arabic":"٢٤","translation":"(২৪)","audioUrl":null,"charTypeName":"end"}]},{"number":25,"arabic":"لَقَدْ نَصَرَكُمُ ٱللَّهُ فِى مَوَاطِنَ كَثِيرَةٍۢ ۙ وَيَوْمَ حُنَيْنٍ ۙ إِذْ أَعْجَبَتْكُمْ كَثْرَتُكُمْ فَلَمْ تُغْنِ عَنكُمْ شَيْـًۭٔا وَضَاقَتْ عَلَيْكُمُ ٱلْأَرْضُ بِمَا رَحُبَتْ ثُمَّ وَلَّيْتُم مُّدْبِرِينَ","translation":"Indeed, God has succoured you on many battlefields, [when you were few;] and [He did so, too,] on the Day of Hunayn, when you took pride in your great numbers and they proved of no avail whatever to you -for the earth, despite all its vastness, became [too] narrow for you and you turned back, retreating:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1260.mp3","surahId":9,"words":[{"id":28069,"position":1,"arabic":"لَقَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/009_025_001.mp3","charTypeName":"word"},{"id":28070,"position":2,"arabic":"نَصَرَكُمُ","translation":"সাহায্য করেছেন তোমাদের","audioUrl":"wbw/009_025_002.mp3","charTypeName":"word"},{"id":28071,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/009_025_003.mp3","charTypeName":"word"},{"id":28072,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/009_025_004.mp3","charTypeName":"word"},{"id":28073,"position":5,"arabic":"مَوَاطِنَ","translation":"জায়গায়","audioUrl":"wbw/009_025_005.mp3","charTypeName":"word"},{"id":28074,"position":6,"arabic":"كَثِيرَةٍۢ ۙ","translation":"অনেক","audioUrl":"wbw/009_025_006.mp3","charTypeName":"word"},{"id":28076,"position":7,"arabic":"وَيَوْمَ","translation":"ও দিনে","audioUrl":"wbw/009_025_008.mp3","charTypeName":"word"},{"id":28077,"position":8,"arabic":"حُنَيْنٍ ۙ","translation":"হুনায়নের (যুদ্ধে)","audioUrl":"wbw/009_025_009.mp3","charTypeName":"word"},{"id":28079,"position":9,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/009_025_011.mp3","charTypeName":"word"},{"id":28080,"position":10,"arabic":"أَعْجَبَتْكُمْ","translation":"উৎফুল্ল করেছিলো তোমাদের","audioUrl":"wbw/009_025_012.mp3","charTypeName":"word"},{"id":28081,"position":11,"arabic":"كَثْرَتُكُمْ","translation":"সংখ্যাধিক্য তোমাদের","audioUrl":"wbw/009_025_013.mp3","charTypeName":"word"},{"id":28082,"position":12,"arabic":"فَلَمْ","translation":"অতঃপর নি","audioUrl":"wbw/009_025_014.mp3","charTypeName":"word"},{"id":28083,"position":13,"arabic":"تُغْنِ","translation":"কাজে আসে","audioUrl":"wbw/009_025_015.mp3","charTypeName":"word"},{"id":28084,"position":14,"arabic":"عَنكُمْ","translation":"জন্যে তোমাদের","audioUrl":"wbw/009_025_016.mp3","charTypeName":"word"},{"id":28085,"position":15,"arabic":"شَيْـًۭٔا","translation":"কিছুমাত্র (সংখ্যাধিক্য)","audioUrl":"wbw/009_025_017.mp3","charTypeName":"word"},{"id":28086,"position":16,"arabic":"وَضَاقَتْ","translation":"এবং সংকীর্ণ হয়েছিলো","audioUrl":"wbw/009_025_018.mp3","charTypeName":"word"},{"id":28087,"position":17,"arabic":"عَلَيْكُمُ","translation":"তোমাদের উপর","audioUrl":"wbw/009_025_019.mp3","charTypeName":"word"},{"id":28088,"position":18,"arabic":"ٱلْأَرْضُ","translation":"পৃথিবী","audioUrl":"wbw/009_025_020.mp3","charTypeName":"word"},{"id":28089,"position":19,"arabic":"بِمَا","translation":"এ সত্ত্বেও যা","audioUrl":"wbw/009_025_021.mp3","charTypeName":"word"},{"id":28090,"position":20,"arabic":"رَحُبَتْ","translation":"প্রশস্ত ছিলো","audioUrl":"wbw/009_025_022.mp3","charTypeName":"word"},{"id":28091,"position":21,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/009_025_023.mp3","charTypeName":"word"},{"id":28092,"position":22,"arabic":"وَلَّيْتُم","translation":"তোমরা ফিরে গেলে","audioUrl":"wbw/009_025_024.mp3","charTypeName":"word"},{"id":28093,"position":23,"arabic":"مُّدْبِرِينَ","translation":"পিঠ প্রদর্শনকারী হয়ে","audioUrl":"wbw/009_025_025.mp3","charTypeName":"word"},{"id":28094,"position":24,"arabic":"٢٥","translation":"(২৫)","audioUrl":null,"charTypeName":"end"}]},{"number":26,"arabic":"ثُمَّ أَنزَلَ ٱللَّهُ سَكِينَتَهُۥ عَلَىٰ رَسُولِهِۦ وَعَلَى ٱلْمُؤْمِنِينَ وَأَنزَلَ جُنُودًۭا لَّمْ تَرَوْهَا وَعَذَّبَ ٱلَّذِينَ كَفَرُوا۟ ۚ وَذَٰلِكَ جَزَآءُ ٱلْكَٰفِرِينَ","translation":"whereupon God bestowed from on high His [gift of] inner peace upon His Apostle and upon the believers, and bestowed [upon you] from on high forces which you could not see, and chastised those who were