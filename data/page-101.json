ranslation":"(১৪৪)","audioUrl":null,"charTypeName":"end"}]},{"number":145,"arabic":"إِنَّ ٱلْمُنَٰفِقِينَ فِى ٱلدَّرْكِ ٱلْأَسْفَلِ مِنَ ٱلنَّارِ وَلَن تَجِدَ لَهُمْ نَصِيرًا","translation":"Verily, the hypocrites shall be in the lowest depth of the fire, and thou wilt find none who could succour them.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/638.mp3","surahId":4,"words":[{"id":79780,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/004_145_001.mp3","charTypeName":"word"},{"id":79781,"position":2,"arabic":"ٱلْمُنَـٰفِقِينَ","translation":"মুনাফিকরা","audioUrl":"wbw/004_145_002.mp3","charTypeName":"word"},{"id":79782,"position":3,"arabic":"فِى","translation":"(থাকবে) মধ্যে","audioUrl":"wbw/004_145_003.mp3","charTypeName":"word"},{"id":79783,"position":4,"arabic":"ٱلدَّرْكِ","translation":"স্তরের","audioUrl":"wbw/004_145_004.mp3","charTypeName":"word"},{"id":79784,"position":5,"arabic":"ٱلْأَسْفَلِ","translation":"নিম্নতম","audioUrl":"wbw/004_145_005.mp3","charTypeName":"word"},{"id":79785,"position":6,"arabic":"مِنَ","translation":"(থেকে)","audioUrl":"wbw/004_145_006.mp3","charTypeName":"word"},{"id":79786,"position":7,"arabic":"ٱلنَّارِ","translation":"জাহান্নামের","audioUrl":"wbw/004_145_007.mp3","charTypeName":"word"},{"id":79787,"position":8,"arabic":"وَلَن","translation":"এবং কক্ষনো না","audioUrl":"wbw/004_145_008.mp3","charTypeName":"word"},{"id":79788,"position":9,"arabic":"تَجِدَ","translation":"তুমি পাবে","audioUrl":"wbw/004_145_009.mp3","charTypeName":"word"},{"id":79789,"position":10,"arabic":"لَهُمْ","translation":"তাদের জন্য","audioUrl":"wbw/004_145_010.mp3","charTypeName":"word"},{"id":79790,"position":11,"arabic":"نَصِيرًا","translation":"কোন সাহায্যকারী","audioUrl":"wbw/004_145_011.mp3","charTypeName":"word"},{"id":79791,"position":12,"arabic":"١٤٥","translation":"(১৪৫)","audioUrl":null,"charTypeName":"end"}]},{"number":146,"arabic":"إِلَّا ٱلَّذِينَ تَابُوا۟ وَأَصْلَحُوا۟ وَٱعْتَصَمُوا۟ بِٱللَّهِ وَأَخْلَصُوا۟ دِينَهُمْ لِلَّهِ فَأُو۟لَٰٓئِكَ مَعَ ٱلْمُؤْمِنِينَ ۖ وَسَوْفَ يُؤْتِ ٱللَّهُ ٱلْمُؤْمِنِينَ أَجْرًا عَظِيمًۭا","translation":"But excepted shall be they who repent, and live righteously, and hold fast unto God, and grow sincere in their faith in God alone: for these shall be one with the believers - and in time God will grant to all believers a mighty reward.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/639.mp3","surahId":4,"words":[{"id":79963,"position":1,"arabic":"إِلَّا","translation":"তবে","audioUrl":"wbw/004_146_001.mp3","charTypeName":"word"},{"id":79964,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/004_146_002.mp3","charTypeName":"word"},{"id":79965,"position":3,"arabic":"تَابُوا۟","translation":"তওবা করে","audioUrl":"wbw/004_146_003.mp3","charTypeName":"word"},{"id":79966,"position":4,"arabic":"وَأَصْلَحُوا۟","translation":"ও সংশোধন করে (তাদের কর্মনীতি)","audioUrl":"wbw/004_146_004.mp3","charTypeName":"word"},{"id":79967,"position":5,"arabic":"وَٱعْتَصَمُوا۟","translation":"ও দৃঢ়ভাবে ধারণ করে","audioUrl":"wbw/004_146_005.mp3","charTypeName":"word"},{"id":79968,"position":6,"arabic":"بِٱللَّهِ","translation":"আল্লাহর (রজ্জুকে)","audioUrl":"wbw/004_146_006.mp3","charTypeName":"word"},{"id":79969,"position":7,"arabic":"وَأَخْلَصُوا۟","translation":"ও একনিষ্ঠভাবে গ্রহণ করে","audioUrl":"wbw/004_146_007.mp3","charTypeName":"word"},{"id":79970,"position":8,"arabic":"دِينَهُمْ","translation":"তাদের দ্বীনকে","audioUrl":"wbw/004_146_008.mp3","charTypeName":"word"},{"id":79971,"position":9,"arabic":"لِلَّهِ","translation":"আল্লাহরই জন্য","audioUrl":"wbw/004_146_009.mp3","charTypeName":"word"},{"id":79972,"position":10,"arabic":"فَأُو۟لَـٰٓئِكَ","translation":"ঐসব লোক সেক্ষেত্রে","audioUrl":"wbw/004_146_010.mp3","charTypeName":"word"},{"id":79973,"position":11,"arabic":"مَعَ","translation":"(থাকবে) সাথে","audioUrl":"wbw/004_146_011.mp3","charTypeName":"word"},{"id":79974,"position":12,"arabic":"ٱلْمُؤْمِنِينَ ۖ","trans