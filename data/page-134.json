arkness, nor anything: living or dead, but is recorded in [His] clear decree.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/848.mp3","surahId":6,"words":[{"id":54007,"position":1,"arabic":"۞ وَعِندَهُۥ","translation":"এবং কাছে তাঁর(আছে)","audioUrl":"wbw/006_059_002.mp3","charTypeName":"word"},{"id":54008,"position":2,"arabic":"مَفَاتِحُ","translation":"চাবিসমূহ","audioUrl":"wbw/006_059_003.mp3","charTypeName":"word"},{"id":54009,"position":3,"arabic":"ٱلْغَيْبِ","translation":"অদৃশ্যের","audioUrl":"wbw/006_059_004.mp3","charTypeName":"word"},{"id":54010,"position":4,"arabic":"لَا","translation":"না","audioUrl":"wbw/006_059_005.mp3","charTypeName":"word"},{"id":54011,"position":5,"arabic":"يَعْلَمُهَآ","translation":"জানে কেউ ত্","audioUrl":"wbw/006_059_006.mp3","charTypeName":"word"},{"id":54012,"position":6,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/006_059_007.mp3","charTypeName":"word"},{"id":54013,"position":7,"arabic":"هُوَ ۚ","translation":"তিনি","audioUrl":"wbw/006_059_008.mp3","charTypeName":"word"},{"id":54015,"position":8,"arabic":"وَيَعْلَمُ","translation":"এবং তিনি জানেন","audioUrl":"wbw/006_059_010.mp3","charTypeName":"word"},{"id":54016,"position":9,"arabic":"مَا","translation":"যা কিছু","audioUrl":"wbw/006_059_011.mp3","charTypeName":"word"},{"id":54017,"position":10,"arabic":"فِى","translation":"মধ্যে (আছে)","audioUrl":"wbw/006_059_012.mp3","charTypeName":"word"},{"id":54018,"position":11,"arabic":"ٱلْبَرِّ","translation":"স্থলভাগের","audioUrl":"wbw/006_059_013.mp3","charTypeName":"word"},{"id":54019,"position":12,"arabic":"وَٱلْبَحْرِ ۚ","translation":"ও জলভাগে","audioUrl":"wbw/006_059_014.mp3","charTypeName":"word"},{"id":54021,"position":13,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/006_059_016.mp3","charTypeName":"word"},{"id":54022,"position":14,"arabic":"تَسْقُطُ","translation":"পড়ে","audioUrl":"wbw/006_059_017.mp3","charTypeName":"word"},{"id":54023,"position":15,"arabic":"مِن","translation":"কোন",