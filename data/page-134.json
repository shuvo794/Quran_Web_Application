{"id":134,"ayahs":[{"number":53,"arabic":"وَكَذَٰلِكَ فَتَنَّا بَعْضَهُم بِبَعْضٍۢ لِّيَقُولُوٓا۟ أَهَٰٓؤُلَآءِ مَنَّ ٱللَّهُ عَلَيْهِم مِّنۢ بَيْنِنَآ ۗ أَلَيْسَ ٱللَّهُ بِأَعْلَمَ بِٱلشَّٰكِرِينَ","translation":"For it is in this way that We try men through one another - to the end that they might ask, \"Has God, then, bestowed His favour upon those others in preference to us?\" Does not God know best as to who is grateful [to Him]?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/842.mp3","surahId":6,"words":[{"id":50732,"position":1,"arabic":"وَكَذَٰلِكَ","translation":"এবং এভাবে","audioUrl":"wbw/006_053_001.mp3","charTypeName":"word"},{"id":50733,"position":2,"arabic":"فَتَنَّا","translation":"পরীক্ষা করেছি আমরা","audioUrl":"wbw/006_053_002.mp3","charTypeName":"word"},{"id":50734,"position":3,"arabic":"بَعْضَهُم","translation":"কাউকে তাদের","audioUrl":"wbw/006_053_003.mp3","charTypeName":"word"},{"id":50735,"position":4,"arabic":"بِبَعْضٍۢ","translation":"দিয়ে (অন্য) কাউকে","audioUrl":"wbw/006_053_004.mp3","charTypeName":"word"},{"id":50736,"position":5,"arabic":"لِّيَقُولُوٓا۟","translation":"যেন তারা বলে","audioUrl":"wbw/006_053_005.mp3","charTypeName":"word"},{"id":50737,"position":6,"arabic":"أَهَـٰٓؤُلَآءِ","translation":"\"কি এসব লোকদের","audioUrl":"wbw/006_053_006.mp3","charTypeName":"word"},{"id":50738,"position":7,"arabic":"مَنَّ","translation":"অনুগ্রহ করেছেন","audioUrl":"wbw/006_053_007.mp3","charTypeName":"word"},{"id":50739,"position":8,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/006_053_008.mp3","charTypeName":"word"},{"id":50740,"position":9,"arabic":"عَلَيْهِم","translation":"উপর তাদের","audioUrl":"wbw/006_053_009.mp3","charTypeName":"word"},{"id":50741,"position":10,"arabic":"مِّنۢ","translation":"হতে","audioUrl":"wbw/006_053_010.mp3","charTypeName":"word"},{"id":50742,"position":11,"arabic":"بَيْنِنَآ ۗ","translation":"মধ্যে আমাদের\"","audioUrl":"wbw/006_053_011.mp3","charTypeName":"word"},{"id":50744,"position":12,"arabic":"أَلَيْسَ","translation":"নন কি","audioUrl":"wbw/006_053_013.mp3","charTypeName":"word"},{"id":50745,"position":13,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/006_053_014.mp3","charTypeName":"word"},{"id":50746,"position":14,"arabic":"بِأَعْلَمَ","translation":"অধিক অবহিত","audioUrl":"wbw/006_053_015.mp3","charTypeName":"word"},{"id":50747,"position":15,"arabic":"بِٱلشَّـٰكِرِينَ","translation":"সম্পর্কে কৃতজ্ঞদের","audioUrl":"wbw/006_053_016.mp3","charTypeName":"word"},{"id":50748,"position":16,"arabic":"٥٣","translation":"(৫৩)","audioUrl":null,"charTypeName":"end"}]},{"number":54,"arabic":"وَإِذَا جَآءَكَ ٱلَّذِينَ يُؤْمِنُونَ بِـَٔايَٰتِنَا فَقُلْ سَلَٰمٌ عَلَيْكُمْ ۖ كَتَبَ رَبُّكُمْ عَلَىٰ نَفْسِهِ ٱلرَّحْمَةَ ۖ أَنَّهُۥ مَنْ عَمِلَ مِنكُمْ سُوٓءًۢا بِجَهَٰلَةٍۢ ثُمَّ تَابَ مِنۢ بَعْدِهِۦ وَأَصْلَحَ فَأَنَّهُۥ غَفُورٌۭ رَّحِيمٌۭ","translation":"And when those who believe in Our messages come unto thee, say: \"Peace be upon you. Your Sustainer has willed upon Himself the law of grace and mercy - so that if any of you does a bad deed out of ignorance, and thereafter repents and lives righteously, He shall be [found] much-forgiving, a dispenser of grace.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/843.mp3","surahId":6,"words":[{"id":51378,"position":1,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/006_054_001.mp3","charTypeName":"word"},{"id":51379,"position":2,"arabic":"جَآءَكَ","translation":"তোমার কাছে আসে","audioUrl":"wbw/006_054_002.mp3","charTypeName":"word"},{"id":51380,"position":3,"arabic":"ٱلَّذِينَ","translation":"(তারা) যারা","audioUrl":"wbw/006_054_003.mp3","charTypeName":"word"},{"id":51381,"position":4,"arabic":"يُؤْمِنُونَ","translation":"ঈমান এনেছে","audioUrl":"wbw/006_054_004.mp3","charTypeName":"word"},{"id":51382,"position":5,"arabic":"بِـَٔايَـٰتِنَا","translation":"উপর  নিদর্শনগুলোর আমাদের","audioUrl":"wbw/006_054_005.mp3","charTypeName":"word"},{"id":51383,"position":6,"arabic":"فَقُلْ","translation":"তখন বলো","audioUrl":"wbw/006_054_006.mp3","charTypeName":"word"},{"id":51384,"position":7,"arabic":"سَلَـٰمٌ","translation":"\"শান্তি (বর্ষিত হোক)","audioUrl":"wbw/006_054_007.mp3","charTypeName":"word"},{"id":51385,"position":8,"arabic":"عَلَيْكُمْ ۖ","translation":"উপর তোমাদের","audioUrl":"wbw/006_054_008.mp3","charTypeName":"word"},{"id":51387,"position":9,"arabic":"كَتَبَ","translation":"নির্ধারিত করে নিয়েছেন","audioUrl":"wbw/006_054_010.mp3","charTypeName":"word"},{"id":51388,"position":10,"arabic":"رَبُّكُمْ","translation":"রব তোমাদের","audioUrl":"wbw/006_054_011.mp3","charTypeName":"word"},{"id":51389,"position":11,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/006_054_012.mp3","charTypeName":"word"},{"id":51390,"position":12,"arabic":"نَفْسِهِ","translation":"নিজের তাঁর","audioUrl":"wbw/006_054_013.mp3","charTypeName":"word"},{"id":51391,"position":13,"arabic":"ٱلرَّحْمَةَ ۖ","translation":"দয়া করা","audioUrl":"wbw/006_054_014.mp3","charTypeName":"word"},{"id":51393,"position":14,"arabic":"أَنَّهُۥ","translation":"এমন যে তা","audioUrl":"wbw/006_054_016.mp3","charTypeName":"word"},{"id":51394,"position":15,"arabic":"مَنْ","translation":"কেউ","audioUrl":"wbw/006_054_017.mp3","charTypeName":"word"},{"id":51395,"position":16,"arabic":"عَمِلَ","translation":"কাজ করে বসে","audioUrl":"wbw/006_054_018.mp3","charTypeName":"word"},{"id":51396,"position":17,"arabic":"مِنكُمْ","translation":"মধ্য থেকে তোমাদের","audioUrl":"wbw/006_054_019.mp3","charTypeName":"word"},{"id":51397,"position":18,"arabic":"سُوٓءًۢا","translation":"মন্দ","audioUrl":"wbw/006_054_020.mp3","charTypeName":"word"},{"id":51398,"position":19,"arabic":"بِجَهَـٰلَةٍۢ","translation":"কারণে অজ্ঞতার","audioUrl":"wbw/006_054_021.mp3","charTypeName":"word"},{"id":51399,"position":20,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/006_054_022.mp3","charTypeName":"word"},{"id":51400,"position":21,"arabic":"تَابَ","translation":"তওবা করে","audioUrl":"wbw/006_054_023.mp3","charTypeName":"word"},{"id":51401,"position":22,"arabic":"مِنۢ","translation":"থেকে","audioUrl":"wbw/006_054_024.mp3","charTypeName":"word"},{"id":51402,"position":23,"arabic":"بَعْدِهِۦ","translation":"তারপর","audioUrl":"wbw/006_054_025.mp3","charTypeName":"word"},{"id":51403,"position":24,"arabic":"وَأَصْلَحَ","translation":"ও সংশোধিত হয়","audioUrl":"wbw/006_054_026.mp3","charTypeName":"word"},{"id":51404,"position":25,"arabic":"فَأَنَّهُۥ","translation":"তবে বাস্তবিকই তিনি","audioUrl":"wbw/006_054_027.mp3","charTypeName":"word"},{"id":51405,"position":26,"arabic":"غَفُورٌۭ","translation":"ক্ষমাশীল","audioUrl":"wbw/006_054_028.mp3","charTypeName":"word"},{"id":51406,"position":27,"arabic":"رَّحِيمٌۭ","translation":"পরম দয়ালু\"","audioUrl":"wbw/006_054_029.mp3","charTypeName":"word"},{"id":51407,"position":28,"arabic":"٥٤","translation":"(৫৪)","audioUrl":null,"charTypeName":"end"}]},{"number":55,"arabic":"وَكَذَٰلِكَ نُفَصِّلُ ٱلْءَايَٰتِ وَلِتَسْتَبِينَ سَبِيلُ ٱلْمُجْرِمِينَ","translation":"And thus clearly do We spell out Our messages: and [We do it] so that the path of those who are lost in sin might be distinct [from that of the righteous].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/844.mp3","surahId":6,"words":[{"id":51898,"position":1,"arabic":"وَكَذَٰلِكَ","translation":"এবং এভাবে","audioUrl":"wbw/006_055_001.mp3","charTypeName":"word"},{"id":51899,"position":2,"arabic":"نُفَصِّلُ","translation":"বিস্তারিত বর্ণনা করি আমরা","audioUrl":"wbw/006_055_002.mp3","charTypeName":"word"},{"id":51900,"position":3,"arabic":"ٱلْـَٔايَـٰتِ","translation":"নিদর্শনগুলোকে","audioUrl":"wbw/006_055_003.mp3","charTypeName":"word"},{"id":51901,"position":4,"arabic":"وَلِتَسْتَبِينَ","translation":"এবং যেন সুস্পষ্ট প্রকাশ হয়","audioUrl":"wbw/006_055_004.mp3","charTypeName":"word"},{"id":51902,"position":5,"arabic":"سَبِيلُ","translation":"পথ","audioUrl":"wbw/006_055_005.mp3","charTypeName":"word"},{"id":51903,"position":6,"arabic":"ٱلْمُجْرِمِينَ","translation":"অপরাধীদের","audioUrl":"wbw/006_055_006.mp3","charTypeName":"word"},{"id":51904,"position":7,"arabic":"٥٥","translation":"(৫৫)","audioUrl":null,"charTypeName":"end"}]},{"number":56,"arabic":"قُلْ إِنِّى نُهِيتُ أَنْ أَعْبُدَ ٱلَّذِينَ تَدْعُونَ مِن دُونِ ٱللَّهِ ۚ قُل لَّآ أَتَّبِعُ أَهْوَآءَكُمْ ۙ قَدْ ضَلَلْتُ إِذًۭا وَمَآ أَنَا۠ مِنَ ٱلْمُهْتَدِينَ","translation":"SAY [to the deniers of the truth]: \"Behold, I have been forbidden to worship those [beings] whom you invoke instead of God.\" Say: \"I do not follow your errant views -or else I should have gone astray, and should not be among those who have found the right path.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/845.mp3","surahId":6,"words":[{"id":52430,"position":1,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/006_056_001.mp3","charTypeName":"word"},{"id":52431,"position":2,"arabic":"إِنِّى","translation":"\"নিশ্চয়ই আমাকে","audioUrl":"wbw/006_056_002.mp3","charTypeName":"word"},{"id":52432,"position":3,"arabic":"نُهِيتُ","translation":"আমাকে নিষেধ করা হয়েছে","audioUrl":"wbw/006_056_003.mp3","charTypeName":"word"},{"id":52433,"position":4,"arabic":"أَنْ","translation":"যে","audioUrl":"wbw/006_056_004.mp3","charTypeName":"word"},{"id":52434,"position":5,"arabic":"أَعْبُدَ","translation":"(যেন না) আমি ইবাদাত করি","audioUrl":"wbw/006_056_005.mp3","charTypeName":"word"},{"id":52435,"position":6,"arabic":"ٱلَّذِينَ","translation":"(তাদেরকে) যাদের","audioUrl":"wbw/006_056_006.mp3","charTypeName":"word"},{"id":52436,"position":7,"arabic":"تَدْعُونَ","translation":"তোমরা ডাকো","audioUrl":"wbw/006_056_007.mp3","charTypeName":"word"},{"id":52437,"position":8,"arabic":"مِن","translation":"দিয়ে\"","audioUrl":"wbw/006_056_008.mp3","charTypeName":"word"},{"id":52438,"position":9,"arabic":"دُونِ","translation":"বাদ\"","audioUrl":"wbw/006_056_009.mp3","charTypeName":"word"},{"id":52439,"position":10,"arabic":"ٱللَّهِ ۚ","translation":"আল্লাহ\"","audioUrl":"wbw/006_056_010.mp3","charTypeName":"word"},{"id":52441,"position":11,"arabic":"قُل","translation":"বলো","audioUrl":"wbw/006_056_012.mp3","charTypeName":"word"},{"id":52442,"position":12,"arabic":"لَّآ","translation":"\"না","audioUrl":"wbw/006_056_013.mp3","charTypeName":"word"},{"id":52443,"position":13,"arabic":"أَتَّبِعُ","translation":"অনুসরণ করি আমি","audioUrl":"wbw/006_056_014.mp3","charTypeName":"word"},{"id":52444,"position":14,"arabic":"أَهْوَآءَكُمْ ۙ","translation":"খেয়ালখুশির তোমাদের","audioUrl":"wbw/006_056_015.mp3","charTypeName":"word"},{"id":52446,"position":15,"arabic":"قَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/006_056_017.mp3","charTypeName":"word"},{"id":52447,"position":16,"arabic":"ضَلَلْتُ","translation":"আমি পথভ্রষ্ট হবো","audioUrl":"wbw/006_056_018.mp3","charTypeName":"word"},{"id":52448,"position":17,"arabic":"إِذًۭا","translation":"তাহলে","audioUrl":"wbw/006_056_019.mp3","charTypeName":"word"},{"id":52449,"position":18,"arabic":"وَمَآ","translation":"এবং না (হবো)","audioUrl":"wbw/006_056_020.mp3","charTypeName":"word"},{"id":52450,"position":19,"arabic":"أَنَا۠","translation":"আমি","audioUrl":"wbw/006_056_021.mp3","charTypeName":"word"},{"id":52451,"position":20,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/006_056_022.mp3","charTypeName":"word"},{"id":52452,"position":21,"arabic":"ٱلْمُهْتَدِينَ","translation":"সঠিক পথপ্রাপ্তদের\"","audioUrl":"wbw/006_056_023.mp3","charTypeName":"word"},{"id":52453,"position":22,"arabic":"٥٦","translation":"(৫৬)","audioUrl":null,"charTypeName":"end"}]},{"number":57,"arabic":"قُلْ إِنِّى عَلَىٰ بَيِّنَةٍۢ مِّن رَّبِّى وَكَذَّبْتُم بِهِۦ ۚ مَا عِندِى مَا تَسْتَعْجِلُونَ بِهِۦٓ ۚ إِنِ ٱلْحُكْمُ إِلَّا لِلَّهِ ۖ يَقُصُّ ٱلْحَقَّ ۖ وَهُوَ خَيْرُ ٱلْفَٰصِلِينَ","translation":"Say: \"Behold, I take my stand on a clear evidence from my Sustainer-and [so] it is to Him that you are giving the lie! Not in my power is that which [in your ignorance] you so hastily demand: judgment rests with none but God. He shall decla