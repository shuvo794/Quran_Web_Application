{"id":100,"ayahs":[{"number":135,"arabic":"۞ يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ كُونُوا۟ قَوَّٰمِينَ بِٱلْقِسْطِ شُهَدَآءَ لِلَّهِ وَلَوْ عَلَىٰٓ أَنفُسِكُمْ أَوِ ٱلْوَٰلِدَيْنِ وَٱلْأَقْرَبِينَ ۚ إِن يَكُنْ غَنِيًّا أَوْ فَقِيرًۭا فَٱللَّهُ أَوْلَىٰ بِهِمَا ۖ فَلَا تَتَّبِعُوا۟ ٱلْهَوَىٰٓ أَن تَعْدِلُوا۟ ۚ وَإِن تَلْوُۥٓا۟ أَوْ تُعْرِضُوا۟ فَإِنَّ ٱللَّهَ كَانَ بِمَا تَعْمَلُونَ خَبِيرًۭا","translation":"O YOU who have attained to faith! Be ever steadfast in upholding equity, bearing witness to the truth for the sake of God, even though it be against your own selves or your parents and kinsfolk. Whether the person concerned be rich or poor, God's claim takes precedence over [the claims of] either of them. Do not, then, follow your own desires, lest you swerve from justice: for if you distort [the truth], behold, God is indeed aware of all that you do!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/628.mp3","surahId":4,"words":[{"id":78502,"position":1,"arabic":"۞ يَـٰٓأَيُّهَا","translation":"ওহে","audioUrl":"wbw/004_135_002.mp3","charTypeName":"word"},{"id":78503,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/004_135_003.mp3","charTypeName":"word"},{"id":78504,"position":3,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছ","audioUrl":"wbw/004_135_004.mp3","charTypeName":"word"},{"id":78505,"position":4,"arabic":"كُونُوا۟","translation":"তোমরা থাক","audioUrl":"wbw/004_135_005.mp3","charTypeName":"word"},{"id":78506,"position":5,"arabic":"قَوَّٰمِينَ","translation":"প্রতিষ্ঠিত","audioUrl":"wbw/004_135_006.mp3","charTypeName":"word"},{"id":78507,"position":6,"arabic":"بِٱلْقِسْطِ","translation":"ইনসাফের উপর","audioUrl":"wbw/004_135_007.mp3","charTypeName":"word"},{"id":78508,"position":7,"arabic":"شُهَدَآءَ","translation":"সাক্ষীদাতা হিসেবে","audioUrl":"wbw/004_135_008.mp3","charTypeName":"word"},{"id":78509,"position":8,"arabic":"لِلَّهِ","translation":"আল্লাহরই জন্য","audioUrl":"wbw/004_135_009.mp3","charTypeName":"word"},{"id":78510,"position":9,"arabic":"وَلَوْ","translation":"এবং যদিও","audioUrl":"wbw/004_135_010.mp3","charTypeName":"word"},{"id":78511,"position":10,"arabic":"عَلَىٰٓ","translation":"বিরুদ্ধে (যায়)","audioUrl":"wbw/004_135_011.mp3","charTypeName":"word"},{"id":78512,"position":11,"arabic":"أَنفُسِكُمْ","translation":"তোমাদের নিজেদের","audioUrl":"wbw/004_135_012.mp3","charTypeName":"word"},{"id":78513,"position":12,"arabic":"أَوِ","translation":"অথবা","audioUrl":"wbw/004_135_013.mp3","charTypeName":"word"},{"id":78514,"position":13,"arabic":"ٱلْوَٰلِدَيْنِ","translation":"পিতামাতার","audioUrl":"wbw/004_135_014.mp3","charTypeName":"word"},{"id":78515,"position":14,"arabic":"وَٱلْأَقْرَبِينَ ۚ","translation":"এবং আত্মীয়স্বজনদের (বিরুদ্ধেও)","audioUrl":"wbw/004_135_015.mp3","charTypeName":"word"},{"id":78517,"position":15,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/004_135_017.mp3","charTypeName":"word"},{"id":78518,"position":16,"arabic":"يَكُنْ","translation":"(তাদের কেউ) হয়","audioUrl":"wbw/004_135_018.mp3","charTypeName":"word"},{"id":78519,"position":17,"arabic":"غَنِيًّا","translation":"ধনী","audioUrl":"wbw/004_135_019.mp3","charTypeName":"word"},{"id":78520,"position":18,"arabic":"أَوْ","translation":"বা","audioUrl":"wbw/004_135_020.mp3","charTypeName":"word"},{"id":78521,"position":19,"arabic":"فَقِيرًۭا","translation":"গরীব","audioUrl":"wbw/004_135_021.mp3","charTypeName":"word"},{"id":78522,"position":20,"arabic":"فَٱللَّهُ","translation":"তবুও আল্লাহই","audioUrl":"wbw/004_135_022.mp3","charTypeName":"word"},{"id":78523,"position":21,"arabic":"أَوْلَىٰ","translation":"(তোমাদের চেয়ে) বেশী শুভাকাঙ্ক্ষী","audioUrl":"wbw/004_135_023.mp3","charTypeName":"word"},{"id":78524,"position":22,"arabic":"بِهِمَا ۖ","translation":"তাদের দুজনের","audioUrl":"wbw/004_135_024.mp3","charTypeName":"word"},{"id":78526,"position":23,"arabic":"فَلَا","translation":"অতএব না","audioUrl":"wbw/004_135_026.mp3","charTypeName":"word"},{"id":78527,"position":24,"arabic":"تَتَّبِعُوا۟","translation":"তোমরা অনুসরণ করো","audioUrl":"wbw/004_135_027.mp3","charTypeName":"word"},{"id":78528,"position":25,"arabic":"ٱلْهَوَىٰٓ","translation":"প্রবৃত্তির কামনার","audioUrl":"wbw/004_135_028.mp3","charTypeName":"word"},{"id":78529,"position":26,"arabic":"أَن","translation":"(যে)","audioUrl":"wbw/004_135_029.mp3","charTypeName":"word"},{"id":78530,"position":27,"arabic":"تَعْدِلُوا۟ ۚ","translation":"ন্যায় বিচার করতে","audioUrl":"wbw/004_135_030.mp3","charTypeName":"word"},{"id":78532,"position":28,"arabic":"وَإِن","translation":"এবং যদি","audioUrl":"wbw/004_135_032.mp3","charTypeName":"word"},{"id":78533,"position":29,"arabic":"تَلْوُۥٓا۟","translation":"তোমরা মন রাখা কথা বল","audioUrl":"wbw/004_135_033.mp3","charTypeName":"word"},{"id":78534,"position":30,"arabic":"أَوْ","translation":"বা","audioUrl":"wbw/004_135_034.mp3","charTypeName":"word"},{"id":78535,"position":31,"arabic":"تُعْرِضُوا۟","translation":"তোমরা পাশ কাটাও (সত্য হতে)","audioUrl":"wbw/004_135_035.mp3","charTypeName":"word"},{"id":78536,"position":32,"arabic":"فَإِنَّ","translation":"তবুও নিশ্চয়","audioUrl":"wbw/004_135_036.mp3","charTypeName":"word"},{"id":78537,"position":33,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/004_135_037.mp3","charTypeName":"word"},{"id":78538,"position":34,"arabic":"كَانَ","translation":"হলেন","audioUrl":"wbw/004_135_038.mp3","charTypeName":"word"},{"id":78539,"position":35,"arabic":"بِمَا","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/004_135_039.mp3","charTypeName":"word"},{"id":78540,"position":36,"arabic":"تَعْمَلُونَ","translation":"তোমরা কাজ করছ","audioUrl":"wbw/004_135_040.mp3","charTypeName":"word"},{"id":78541,"position":37,"arabic":"خَبِيرًۭا","translation":"খুব অবহিত","audioUrl":"wbw/004_135_041.mp3","charTypeName":"word"},{"id":78542,"position":38,"arabic":"١٣٥","translation":"(১৩৫)","audioUrl":null,"charTypeName":"end"}]},{"number":136,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوٓا۟ ءَامِنُوا۟ بِٱللَّهِ وَرَسُولِهِۦ وَٱلْكِتَٰبِ ٱلَّذِى نَزَّلَ عَلَىٰ رَسُولِهِۦ وَٱلْكِتَٰبِ ٱلَّذِىٓ أَنزَلَ مِن قَبْلُ ۚ وَمَن يَكْفُرْ بِٱللَّهِ وَمَلَٰٓئِكَتِهِۦ وَكُتُبِهِۦ وَرُسُلِهِۦ وَٱلْيَوْمِ ٱلْءَاخِرِ فَقَدْ ضَلَّ ضَلَٰلًۢا بَعِيدًا","translation":"O you who have attained to faith! Hold fast unto your belief in God and His Apostle, and in the divine writ which He has bestowed from on high upon His Apostle, step by step, as well as in the revelation which He sent down aforetime: for he who denies God, and His angels, and His revelations, and His apostles, and the Last Day, has indeed gone far astray.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/629.mp3","surahId":4,"words":[{"id":78659,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"ওহে","audioUrl":"wbw/004_136_001.mp3","charTypeName":"word"},{"id":78660,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/004_136_002.mp3","charTypeName":"word"},{"id":78661,"position":3,"arabic":"ءَامَنُوٓا۟","translation":"ঈমান এনেছ","audioUrl":"wbw/004_136_003.mp3","charTypeName":"word"},{"id":78662,"position":4,"arabic":"ءَامِنُوا۟","translation":"ঈমান আন","audioUrl":"wbw/004_136_004.mp3","charTypeName":"word"},{"id":78663,"position":5,"arabic":"بِٱللَّهِ","translation":"আল্লাহর উপর","audioUrl":"wbw/004_136_005.mp3","charTypeName":"word"},{"id":78664,"position":6,"arabic":"وَرَسُولِهِۦ","translation":"ও তাঁর রাসূলের","audioUrl":"wbw/004_136_006.mp3","charTypeName":"word"},{"id":78665,"position":7,"arabic":"وَٱلْكِتَـٰبِ","translation":"ও কিতাবের (উপর)","audioUrl":"wbw/004_136_007.mp3","charTypeName":"word"},{"id":78666,"position":8,"arabic":"ٱلَّذِى","translation":"যা","audioUrl":"wbw/004_136_008.mp3","charTypeName":"word"},{"id":78667,"position":9,"arabic":"نَزَّلَ","translation":"অবতীর্ণ করেছেন","audioUrl":"wbw/004_136_009.mp3","charTypeName":"word"},{"id":78668,"position":10,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/004_136_010.mp3","charTypeName":"word"},{"id":78669,"position":11,"arabic":"رَسُولِهِۦ","translation":"তাঁর রাসূলের","audioUrl":"wbw/004_136_011.mp3","charTypeName":"word"},{"id":78670,"position":12,"arabic":"وَٱلْكِتَـٰبِ","translation":"এবং ঐ কিতাবেরও","audioUrl":"wbw/004_136_012.mp3","charTypeName":"word"},{"id":78671,"position":13,"arabic":"ٱلَّذِىٓ","translation":"যা","audioUrl":"wbw/004_136_013.mp3","charTypeName":"word"},{"id":78672,"position":14,"arabic":"أَنزَلَ","translation":"অবতীর্ণ করেছেন","audioUrl":"wbw/004_136_014.mp3","charTypeName":"word"},{"id":78673,"position":15,"arabic":"مِن","translation":"(থেকে)","audioUrl":"wbw/004_136_015.mp3","charTypeName":"word"},{"id":78674,"position":16,"arabic":"قَبْلُ ۚ","translation":"ইতিপূর্বে","audioUrl":"wbw/004_136_016.mp3","charTypeName":"word"},{"id":78676,"position":17,"arabic":"وَمَن","translation":"এবং যে","audioUrl":"wbw/004_136_018.mp3","charTypeName":"word"},{"id":78677,"position":18,"arabic":"يَكْفُرْ","translation":"অস্বীকার করে","audioUrl":"wbw/004_136_019.mp3","charTypeName":"word"},{"id":78678,"position":19,"arabic":"بِٱللَّهِ","translation":"আল্লাহকে","audioUrl":"wbw/004_136_020.mp3","charTypeName":"word"},{"id":78679,"position":20,"arabic":"وَمَلَـٰٓئِكَتِهِۦ","translation":"ও তাঁর ফেরেশতাদেরকে","audioUrl":"wbw/004_136_021.mp3","charTypeName":"word"},{"id":78680,"position":21,"arabic":"وَكُتُبِهِۦ","translation":"ও তাঁর কিতাবগুলোকে","audioUrl":"wbw/004_136_022.mp3","charTypeName":"word"},{"id":78681,"position":22,"arabic":"وَرُسُلِهِۦ","translation":"ও তাঁর রাসূলদেরকে","audioUrl":"wbw/004_136_023.mp3","charTypeName":"word"},{"id":78682,"position":23,"arabic":"وَٱلْيَوْمِ","translation":"ও দিনকে","audioUrl":"wbw/004_136_024.mp3","charTypeName":"word"},{"id":78683,"position":24,"arabic":"ٱلْـَٔاخِرِ","translation":"আখিরাতের","audioUrl":"wbw/004_136_025.mp3","charTypeName":"word"},{"id":78684,"position":25,"arabic":"فَقَدْ","translation":"তবে নিশ্চয়ই","audioUrl":"wbw/004_136_026.mp3","charTypeName":"word"},{"id":78685,"position":26,"arabic":"ضَلَّ","translation":"সে পথভ্রষ্ট হয়েছে","audioUrl":"wbw/004_1