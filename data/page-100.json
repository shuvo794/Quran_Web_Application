"কুফুরী করেছে","audioUrl":"wbw/004_137_009.mp3","charTypeName":"word"},{"id":78813,"position":10,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/004_137_010.mp3","charTypeName":"word"},{"id":78814,"position":11,"arabic":"ٱزْدَادُوا۟","translation":"তারা বৃদ্ধি করেছে","audioUrl":"wbw/004_137_011.mp3","charTypeName":"word"},{"id":78815,"position":12,"arabic":"كُفْرًۭا","translation":"কুফুরী","audioUrl":"wbw/004_137_012.mp3","charTypeName":"word"},{"id":78816,"position":13,"arabic":"لَّمْ","translation":"না","audioUrl":"wbw/004_137_013.mp3","charTypeName":"word"},{"id":78817,"position":14,"arabic":"يَكُنِ","translation":"(নিশ্চয়) হবেন","audioUrl":"wbw/004_137_014.mp3","charTypeName":"word"},{"id":78818,"position":15,"arabic":"ٱللَّهُ","translation":"আল্লাহ (এমন যে)","audioUrl":"wbw/004_137_015.mp3","charTypeName":"word"},{"id":78819,"position":16,"arabic":"لِيَغْفِرَ","translation":"মাফ করবেন","audioUrl":"wbw/004_137_016.mp3","charTypeName":"word"},{"id":78820,"position":17,"arabic":"لَهُمْ","translation":"তাদেরকে","audioUrl":"wbw/004_137_017.mp3","charTypeName":"word"},{"id":78821,"position":18,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/004_137_018.mp3","charTypeName":"word"},{"id":78822,"position":19,"arabic":"لِيَهْدِيَهُمْ","translation":"তাদের হিদায়াত দিবেন","audioUrl":"wbw/004_137_019.mp3","charTypeName":"word"},{"id":78823,"position":20,"arabic":"سَبِيلًۢا","translation":"(সঠিক) পথের","audioUrl":"wbw/004_137_020.mp3","charTypeName":"word"},{"id":78824,"position":21,"arabic":"١٣٧","translation":"(১৩৭)","audioUrl":null,"charTypeName":"end"}]},{"number":138,"arabic":"بَشِّرِ ٱلْمُنَٰفِقِينَ بِأَنَّ لَهُمْ عَذَابًا أَلِيمًا","translation":"Announce thou to such hypocrites that grievous suffering awaits them.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/631.mp3","surahId":4,"words":[{"id":78945,"position":1,"arabic":"بَشِّرِ","translation":"সুসংবাদ দাও","audioUrl":"wbw/004_138_001.mp3","charTypeName":"word"},{"id":78946,"positio