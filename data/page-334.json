; and he whom God shall scorn [on Resur­rection Day] will have none who could bestow honour on him: for, verily, God does what He wills.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2613.mp3","surahId":22,"words":[{"id":20551,"position":1,"arabic":"أَلَمْ","translation":"নি কি","audioUrl":"wbw/022_018_001.mp3","charTypeName":"word"},{"id":20552,"position":2,"arabic":"تَرَ","translation":"তুমি দেখো","audioUrl":"wbw/022_018_002.mp3","charTypeName":"word"},{"id":20553,"position":3,"arabic":"أَنَّ","translation":"যে","audioUrl":"wbw/022_018_003.mp3","charTypeName":"word"},{"id":20554,"position":4,"arabic":"ٱللَّهَ","translation":"আল্লাহ (এমন সত্ত্বা)","audioUrl":"wbw/022_018_004.mp3","charTypeName":"word"},{"id":20555,"position":5,"arabic":"يَسْجُدُ","translation":"সিজদা করে","audioUrl":"wbw/022_018_005.mp3","charTypeName":"word"},{"id":20556,"position":6,"arabic":"لَهُۥ","translation":"তাঁর জন্যে","audioUrl":"wbw/022_018_006.mp3","charTypeName":"word"},{"id":20557,"position":7,"arabic":"مَن","translation":"যা কিছু","audioUrl":"wbw/022_018_007.mp3","charTypeName":"word"},{"id":20558,"position":8,"arabic":"فِى","translation":"আছে","audioUrl":"wbw/022_018_008.mp3","charTypeName":"word"},{"id":20559,"position":9,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশমন্ডলীতে","audioUrl":"wbw/022_018_009.mp3","charTypeName":"word"},{"id":20560,"position":10,"arabic":"وَمَن","translation":"ও যা কিছু","audioUrl":"wbw/022_018_010.mp3","charTypeName":"word"},{"id":20561,"position":11,"arabic":"فِى","translation":"আছে","audioUrl":"wbw/022_018_011.mp3","charTypeName":"word"},{"id":20562,"position":12,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীতে","audioUrl":"wbw/022_018_012.mp3","charTypeName":"word"},{"id":20563,"position":13,"arabic":"وَٱلشَّمْسُ","translation":"এবং সূর্য","audioUrl":"wbw/022_018_013.mp3","charTypeName":"word"},{"id":20564,"position":14,"arabic":"وَٱلْقَمَرُ","translation":"ও চাঁদ","audioUrl":"wbw/022_018_014.mp3","charTypeName":"word"},{"id":20565,"po