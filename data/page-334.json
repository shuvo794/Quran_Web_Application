{"id":334,"ayahs":[{"number":16,"arabic":"وَكَذَٰلِكَ أَنزَلْنَٰهُ ءَايَٰتٍۭ بَيِّنَٰتٍۢ وَأَنَّ ٱللَّهَ يَهْدِى مَن يُرِيدُ","translation":"And thus have We bestowed from on high this [divine writ] in the shape of clear messages: for [thus it is] that God guides him who wills [to be guided].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2611.mp3","surahId":22,"words":[{"id":18495,"position":1,"arabic":"وَكَذَٰلِكَ","translation":"আর এরূপেই","audioUrl":"wbw/022_016_001.mp3","charTypeName":"word"},{"id":18496,"position":2,"arabic":"أَنزَلْنَـٰهُ","translation":"তা আমরা অবতীর্ণ করেছি","audioUrl":"wbw/022_016_002.mp3","charTypeName":"word"},{"id":18497,"position":3,"arabic":"ءَايَـٰتٍۭ","translation":"আয়াত (রূপে)","audioUrl":"wbw/022_016_003.mp3","charTypeName":"word"},{"id":18498,"position":4,"arabic":"بَيِّنَـٰتٍۢ","translation":"সুস্পষ্ট","audioUrl":"wbw/022_016_004.mp3","charTypeName":"word"},{"id":18499,"position":5,"arabic":"وَأَنَّ","translation":"আর নিশ্চয়ই","audioUrl":"wbw/022_016_005.mp3","charTypeName":"word"},{"id":18500,"position":6,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/022_016_006.mp3","charTypeName":"word"},{"id":18501,"position":7,"arabic":"يَهْدِى","translation":"পথ দেখান","audioUrl":"wbw/022_016_007.mp3","charTypeName":"word"},{"id":18502,"position":8,"arabic":"مَن","translation":"যাকে","audioUrl":"wbw/022_016_008.mp3","charTypeName":"word"},{"id":18503,"position":9,"arabic":"يُرِيدُ","translation":"চান","audioUrl":"wbw/022_016_009.mp3","charTypeName":"word"},{"id":18504,"position":10,"arabic":"١٦","translation":"(১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":17,"arabic":"إِنَّ ٱلَّذِينَ ءَامَنُوا۟ وَٱلَّذِينَ هَادُوا۟ وَٱلصَّٰبِـِٔينَ وَٱلنَّصَٰرَىٰ وَٱلْمَجُوسَ وَٱلَّذِينَ أَشْرَكُوٓا۟ إِنَّ ٱللَّهَ يَفْصِلُ بَيْنَهُمْ يَوْمَ ٱلْقِيَٰمَةِ ۚ إِنَّ ٱللَّهَ عَلَىٰ كُلِّ شَىْءٍۢ شَهِيدٌ","translation":"Verily, as for those who have attained to faith [in this divine writ], and those who follow the Jewish 