othing to do with them. Behold, their case rests with God: and in time He will make them understand what they were doing.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/948.mp3","surahId":6,"words":[{"id":81636,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/006_159_001.mp3","charTypeName":"word"},{"id":81637,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/006_159_002.mp3","charTypeName":"word"},{"id":81638,"position":3,"arabic":"فَرَّقُوا۟","translation":"খন্ড বিখন্ড করেছে","audioUrl":"wbw/006_159_003.mp3","charTypeName":"word"},{"id":81639,"position":4,"arabic":"دِينَهُمْ","translation":"দীনকে তাদের","audioUrl":"wbw/006_159_004.mp3","charTypeName":"word"},{"id":81640,"position":5,"arabic":"وَكَانُوا۟","translation":"ও তারা হয়েছে (বিভক্ত)","audioUrl":"wbw/006_159_005.mp3","charTypeName":"word"},{"id":81641,"position":6,"arabic":"شِيَعًۭا","translation":"(বিভিন্ন) উপদলে","audioUrl":"wbw/006_159_006.mp3","charTypeName":"word"},{"id":81642,"position":7,"arabic":"لَّسْتَ","translation":"নও তুমি","audioUrl":"wbw/006_159_007.mp3","charTypeName":"word"},{"id":81643,"position":8,"arabic":"مِنْهُمْ","translation":"মধ্য হতে তাদের","audioUrl":"wbw/006_159_008.mp3","charTypeName":"word"},{"id":81644,"position":9,"arabic":"فِى","translation":"কোনো","audioUrl":"wbw/006_159_009.mp3","charTypeName":"word"},{"id":81645,"position":10,"arabic":"شَىْءٍ ۚ","translation":"কিছু","audioUrl":"wbw/006_159_010.mp3","charTypeName":"word"},{"id":81647,"position":11,"arabic":"إِنَّمَآ","translation":"মূলতঃ","audioUrl":"wbw/006_159_012.mp3","charTypeName":"word"},{"id":81648,"position":12,"arabic":"أَمْرُهُمْ","translation":"বিষয় তাদের(ন্যস্ত)","audioUrl":"wbw/006_159_013.mp3","charTypeName":"word"},{"id":81649,"position":13,"arabic":"إِلَى","translation":"উপর","audioUrl":"wbw/006_159_014.mp3","charTypeName":"word"},{"id":81650,"position":14,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌র","audioUrl":"wbw/006_159_015.mp3","charTypeNa