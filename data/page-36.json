{"id":36,"ayahs":[{"number":225,"arabic":"لَّا يُؤَاخِذُكُمُ ٱللَّهُ بِٱللَّغْوِ فِىٓ أَيْمَٰنِكُمْ وَلَٰكِن يُؤَاخِذُكُم بِمَا كَسَبَتْ قُلُوبُكُمْ ۗ وَٱللَّهُ غَفُورٌ حَلِيمٌۭ","translation":"God will not take you to task for oaths which you may have uttered without thought, but will take you to task [only] for what your hearts have conceived [in earnest]: for God is much-forgiving, forbearing.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/232.mp3","surahId":2,"words":[{"id":86161,"position":1,"arabic":"لَّا","translation":"না","audioUrl":"wbw/002_225_001.mp3","charTypeName":"word"},{"id":86162,"position":2,"arabic":"يُؤَاخِذُكُمُ","translation":"তোমাদেরকে ধরবেন","audioUrl":"wbw/002_225_002.mp3","charTypeName":"word"},{"id":86163,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/002_225_003.mp3","charTypeName":"word"},{"id":86164,"position":4,"arabic":"بِٱللَّغْوِ","translation":"অর্থহীন (শপথের) জন্য","audioUrl":"wbw/002_225_004.mp3","charTypeName":"word"},{"id":86165,"position":5,"arabic":"فِىٓ","translation":"মধ্যে","audioUrl":"wbw/002_225_005.mp3","charTypeName":"word"},{"id":86166,"position":6,"arabic":"أَيْمَـٰنِكُمْ","translation":"তোমাদের শপথগুলোর","audioUrl":"wbw/002_225_006.mp3","charTypeName":"word"},{"id":86167,"position":7,"arabic":"وَلَـٰكِن","translation":"কিন্তু","audioUrl":"wbw/002_225_007.mp3","charTypeName":"word"},{"id":86168,"position":8,"arabic":"يُؤَاخِذُكُم","translation":"তোমাদেরকে তিনি ধরবেন","audioUrl":"wbw/002_225_008.mp3","charTypeName":"word"},{"id":86169,"position":9,"arabic":"بِمَا","translation":"এ কারণে যা","audioUrl":"wbw/002_225_009.mp3","charTypeName":"word"},{"id":86170,"position":10,"arabic":"كَسَبَتْ","translation":"(অর্জন করেছে)","audioUrl":"wbw/002_225_010.mp3","charTypeName":"word"},{"id":86171,"position":11,"arabic":"قُلُوبُكُمْ ۗ","translation":"তোমাদের অন্তরগুলো","audioUrl":"wbw/002_225_011.mp3","charTypeName":"word"},{"id":86173,"position":12,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/002_225_013.mp3","charTypeName":"word"},{"id":86174,"position":13,"arabic":"غَفُورٌ","translation":"বড় ক্ষমাশীল","audioUrl":"wbw/002_225_014.mp3","charTypeName":"word"},{"id":86175,"position":14,"arabic":"حَلِيمٌۭ","translation":"বড় সহনশীল","audioUrl":"wbw/002_225_015.mp3","charTypeName":"word"},{"id":86176,"position":15,"arabic":"٢٢٥","translation":"(২২৫)","audioUrl":null,"charTypeName":"end"}]},{"number":226,"arabic":"لِّلَّذِينَ يُؤْلُونَ مِن نِّسَآئِهِمْ تَرَبُّصُ أَرْبَعَةِ أَشْهُرٍۢ ۖ فَإِن فَآءُو فَإِنَّ ٱللَّهَ غَفُورٌۭ رَّحِيمٌۭ","translation":"Those who take an oath that they will not approach their wives shall have four months of grace; and if they go back [on their oath] -behold, God is much-forgiving, a dispenser of grace.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/233.mp3","surahId":2,"words":[{"id":86185,"position":1,"arabic":"لِّلَّذِينَ","translation":"(তাদের) জন্য যারা","audioUrl":"wbw/002_226_001.mp3","charTypeName":"word"},{"id":86186,"position":2,"arabic":"يُؤْلُونَ","translation":"(সম্পর্ক না রাখার)শপথ করে","audioUrl":"wbw/002_226_002.mp3","charTypeName":"word"},{"id":86187,"position":3,"arabic":"مِن","translation":"হতে","audioUrl":"wbw/002_226_003.mp3","charTypeName":"word"},{"id":86188,"position":4,"arabic":"نِّسَآئِهِمْ","translation":"তাদের স্ত্রীদের","audioUrl":"wbw/002_226_004.mp3","charTypeName":"word"},{"id":86189,"position":5,"arabic":"تَرَبُّصُ","translation":"অপেক্ষা করবে","audioUrl":"wbw/002_226_005.mp3","charTypeName":"word"},{"id":86190,"position":6,"arabic":"أَرْبَعَةِ","translation":"চার","audioUrl":"wbw/002_226_006.mp3","charTypeName":"word"},{"id":86191,"position":7,"arabic":"أَشْهُرٍۢ ۖ","translation":"মাস","audioUrl":"wbw/002_226_007.mp3","charTypeName":"word"},{"id":86193,"position":8,"arabic":"فَإِن","translation":"অতঃপর যদি","audioUrl":"wbw/002_226_009.mp3","charTypeName":"word"},{"id":86194,"position":9,"arabic":"فَآءُو","translation":"তারা ফিরে আসে","audioUrl":"wbw/002_226_010.mp3","charTypeName":"word"},{"id":86195,"position":10,"arabic":"فَإِنَّ","translation":"নিশ্চয়ই তবে","audioUrl":"wbw/002_226_011.mp3","charTypeName":"word"},{"id":86196,"position":11,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/002_226_012.mp3","charTypeName":"word"},{"id":86197,"position":12,"arabic":"غَفُورٌۭ","translation":"ক্ষমাশীল","audioUrl":"wbw/002_226_013.mp3","charTypeName":"word"},{"id":86198,"position":13,"arabic":"رَّحِيمٌۭ","translation":"পরম দয়ালু","audioUrl":"wbw/002_226_014.mp3","charTypeName":"word"},{"id":86199,"position":14,"arabic":"٢٢٦","translation":"(২২৬)","audioUrl":null,"charTypeName":"end"}]},{"number":227,"arabic":"وَإِنْ عَزَمُوا۟ ٱلطَّلَٰقَ فَإِنَّ ٱللَّهَ سَمِيعٌ عَلِيمٌۭ","translation":"But if they are resolved on divorce -behold, God is all-hearing, all-knowing.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/234.mp3","surahId":2,"words":[{"id":86206,"position":1,"arabic":"وَإِنْ","translation":"এবং যদি","audioUrl":"wbw/002_227_001.mp3","charTypeName":"word"},{"id":86207,"position":2,"arabic":"عَزَمُوا۟","translation":"তারা সংকল্প করে","audioUrl":"wbw/002_227_002.mp3","charTypeName":"word"},{"id":86208,"position":3,"arabic":"ٱلطَّلَـٰقَ","translation":"তালাকের","audioUrl":"wbw/002_227_003.mp3","charTypeName":"word"},{"id":86209,"position":4,"arabic":"فَإِنَّ","translation":"তবে নিশ্চয়ই","audioUrl":"wbw/002_227_004.mp3","charTypeName":"word"},{"id":86210,"position":5,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/002_227_005.mp3","charTypeName":"word"},{"id":86211,"position":6,"arabic":"سَمِيعٌ","translation":"সবকিছু শুনেন","audioUrl":"wbw/002_227_006.mp3","charTypeName":"word"},{"id":86212,"position":7,"arabic":"عَلِيمٌۭ","translation":"সবকিছু জানেন","audioUrl":"wbw/002_227_007.mp3","charTypeName":"word"},{"id":86213,"position":8,"arabic":"٢٢٧","translation":"(২২৭)","audioUrl":null,"charTypeName":"end"}]},{"number":228,"arabic":"وَٱلْمُطَلَّقَٰتُ يَتَرَبَّصْنَ بِأَنفُسِهِنَّ ثَلَٰثَةَ قُرُوٓءٍۢ ۚ وَلَا يَحِلُّ لَهُنَّ أَن يَكْتُمْنَ مَا خَلَقَ ٱللَّهُ فِىٓ أَرْحَامِهِنَّ إِن كُنَّ يُؤْمِنَّ بِٱللَّهِ وَٱلْيَوْمِ ٱلْءَاخِرِ ۚ وَبُعُولَتُهُنَّ أَحَقُّ بِرَدِّهِنَّ فِى ذَٰلِكَ إِنْ أَرَادُوٓا۟ إِصْلَٰحًۭا ۚ وَلَهُنَّ مِثْلُ ٱلَّذِى عَلَيْهِنَّ بِٱلْمَعْرُوفِ ۚ وَلِلرِّجَالِ عَلَيْهِنَّ دَرَجَةٌۭ ۗ وَٱللَّهُ عَزِيزٌ حَكِيمٌ","translation":"And the divorced women shall undergo, without remarrying, a waiting-period of three monthly courses: for it is not lawful for them to conceal what God may have created in their wombs, if they believe in God and the Last Day. And during this period their husbands are fully entitled to take them back, if they desire reconciliation; but, in accordance with justice, the rights of the wives [with regard to their husbands] are equal to the [husbands'] rights with regard to them, although men have precedence over them [in this respect]. And God is almighty, wise.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/235.mp3","surahId":2,"words":[{"id":86235,"position":1,"arabic":"وَٱلْمُطَلَّقَـٰتُ","translation":"এবং তালাকপ্রাপ্তা স্ত্রীরা","audioUrl":"wbw/002_228_001.mp3","charTypeName":"word"},{"id":86236,"position":2,"arabic":"يَتَرَبَّصْنَ","translation":"অপেক্ষা করবে","audioUrl":"wbw/002_228_002.mp3","charTypeName":"word"},{"id":86237,"position":3,"arabic":"بِأَنفُسِهِنَّ","translation":"তাদের নিজেদের জন্যে","audioUrl":"wbw/002_228_003.mp3","charTypeName":"word"},{"id":86238,"position":4,"arabic":"ثَلَـٰثَةَ","translation":"তিন","audioUrl":"wbw/002_228_004.mp3","charTypeName":"word"},{"id":86239,"position":5,"arabic":"قُرُوٓءٍۢ ۚ","translation":"রজঃস্রাবকাল (পর্যন্ত)","audioUrl":"wbw/002_228_005.mp3","charTypeName":"word"},{"id":86241,"position":6,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/002_228_007.mp3","charTypeName":"word"},{"id":86242,"position":7,"arabic":"يَحِلُّ","translation":"বৈধ হবে","audioUrl":"wbw/002_228_008.mp3","charTypeName":"word"},{"id":86243,"position":8,"arabic":"لَهُنَّ","translation":"তাদের জন্যে","audioUrl":"wbw/002_228_009.mp3","charTypeName":"word"},{"id":86244,"position":9,"arabic":"أَن","translation":"যে","audioUrl":"wbw/002_228_010.mp3","charTypeName":"word"},{"id":86245,"position":10,"arabic":"يَكْتُمْنَ","translation":"তারা গোপন করবে","audioUrl":"wbw/002_228_011.mp3","charTypeName":"word"},{"id":86246,"position":11,"arabic":"مَا","translation":"যা","audioUrl":"wbw/002_228_012.mp3","charTypeName":"word"},{"id":86247,"position":12,"arabic":"خَلَقَ","translation":"সৃষ্টি করেছেন","audioUrl":"wbw/002_228_013.mp3","charTypeName":"word"},{"id":86248,"position":13,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/002_228_014.mp3","charTypeName":"word"},{"id":86249,"position":14,"arabic":"فِىٓ","translation":"মধ্যে","audioUrl":"wbw/002_228_015.mp3","charTypeName":"word"},{"id":86250,"position":15,"arabic":"أَرْحَامِهِنَّ","translation":"তাদের গর্ভাশয়ে","audioUrl":"wbw/002_228_016.mp3","charTypeName":"word"},{"id":86251,"position":16,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/002_228_017.mp3","charTypeName":"word"},{"id":86252,"position":17,"arabic":"كُنَّ","translation":"থাকে তারা","audioUrl":"wbw/002_228_018.mp3","charTypeName":"word"},{"id":86253,"position":18,"arabic":"يُؤْمِنَّ","translation":"ঈমান এনে","audioUrl":"wbw/002_228_019.mp3","charTypeName":"word"},{"id":86254,"position":19,"arabic":"بِٱللَّهِ","translation":"আল্লাহর উপর","audioUrl":"wbw/002_228_020.mp3","charTypeName":"word"},{"id":86255,"position":20,"arabic":"وَٱلْيَوْمِ","translation":"ও দিনে","audioUrl":"wbw/002_228_021.mp3","charTypeName":"word"},{"id":86256,"position":21,"arabic":"ٱلْـَٔاخِرِ ۚ","translation":"আখেরাতের (উপর)","audioUrl":"wbw/002_228_022.mp3","charTypeName":"word"},{"id":86258,"position":22,"arabic":"وَبُعُولَتُهُنَّ","translation":"এবং তাদের স্বামীরা","audioUrl":"wbw/002_228_024.mp3","charTypeName":"word"},{"id":86259,"position":23,"arabic":"أَحَقُّ","translation":"বেশি অধিকারী","audioUrl":"wbw/002_228_025.mp3","charTypeName":"word"},{"id":86260,"position":24,"arabic":"بِرَدِّهِنَّ","translation":"তাদেরকে ফিরিয়ে নেওয়ার ব্যাপারে","audioUrl":"wbw/002_228_026.mp3","charTypeName":"word"},{"id":86261,"position":25,"arabic":"فِى","translation":"ক্ষেত্রে","audioUrl":"wbw/002_228_027.mp3","charTypeName":"word"},{"id":86262,"position":26,"arabic":"ذَٰلِكَ","translation":"এই","audioUrl":"wbw/002_228_028.mp3","charTypeName":"word"},{"id":86263,"position":27,"arabic":"إِنْ","translation":"যদি","audioUrl":"wbw/002_228_029.mp3","charTypeName":"word"},{"id":86264,"position":28,"arabic":"أَرَادُوٓا۟","translation":"তারা চায়","audioUrl":"wbw/002_228_030.mp3","charTypeName":"word"},{"id":86265,"position":29,"arabic":"إِصْلَـٰحًۭا ۚ","translation":"আপোষ নিষ্পত্তি (করতে)","audioUrl":"wbw/002_228_031.mp3","charTypeName":"word"},{"id":86267,"position":30,"arabic":"وَلَهُنَّ","translation":"এবং তাদের (অর্থাৎ স্ত্রীদের অধিকার আছে)","audioUrl":"wbw/002_228_033.mp3","charTypeName":"word"},{"id":86268,"position":31,"arabic":"مِثْلُ","translation":"যেমন","audioUrl":"wbw/002_228_034.mp3","charTypeName":"word"},{"id":86269,"position":32,"arabic":"ٱلَّذِى","translation":"তার (অর্থাৎ স্বামীর)","audioUrl":"wbw/002_228_035.mp3","charTypeName":"word"},{"id":86270,"position":33,"arabic":"عَلَيْهِنَّ","translation":"তাদের উপর (অধিকার আছে)","audioUrl":"wbw/002_228_036.mp3","charTypeName":"word"},{"id":86271,"position":34,"arabic":"بِٱلْمَعْرُوفِ ۚ","translation":"ন্যায়সংগতভাবে","audioUrl":"wbw/002_228_037.mp3","charTypeName":"word"},{"id":86273,"position":35,"arabic":"وَلِلرِّجَالِ","translation":"এবং পুরুষদের জন্যে(আছে)","audioUrl":"wbw/002_228_039.mp3","charTypeName":"word"},{"id":86274,"position":36,"arabic":"عَلَيْهِنَّ","translation":"তাদের উপর","audioUrl":"wbw/002_228_040.mp3","charTypeName":"word"},{"id":86275,"position":37,"arabic":"دَرَجَةٌۭ ۗ","translation":"একটি মর্যাদা আছে","audioUrl":"wbw/002_228_041.mp3","charTypeName":"word"},{"id":86277,"position":38,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/002_228_043.mp3","charTypeName":"word"},{"id":86278,"position":39,"arabic":"عَزِيزٌ","translation":"মহাপরাক্রমশালী","audioUrl":"wbw/002_228_044.mp3","charTypeName":"word"},{"id":86279,"position":40,"arabic":"حَكِيمٌ","translation":"মহাবিজ্ঞ","audioUrl":"wbw/002_228_045.mp3","charTypeName":"word"},{"id":86280,"position":41,"arabic":"٢٢٨","translation":"(২২৮)","audioUrl":null,"charTypeName":"end"}]},{"number":229,"arabic":"ٱلطَّلَٰقُ مَرَّتَانِ ۖ فَإِمْسَاكٌۢ بِمَعْرُوفٍ أَوْ تَسْرِيحٌۢ بِإِحْسَٰنٍۢ ۗ وَلَا يَحِلُّ لَكُمْ أَن تَأْخُذُوا۟ مِمَّآ ءَاتَيْتُمُوهُنَّ شَيْـًٔا إِلَّآ أَن يَخَافَآ أَلَّا يُقِيمَا حُدُودَ ٱللَّهِ ۖ فَإِنْ خِفْتُمْ أَلَّا يُقِيمَا حُدُودَ ٱللَّهِ فَلَا جُنَاحَ عَلَيْهِمَا فِيمَا ٱفْتَدَتْ بِهِۦ ۗ تِلْكَ حُدُودُ ٱللَّهِ فَلَا تَعْتَدُوهَا ۚ وَمَن يَتَعَدَّ حُدُودَ ٱللَّهِ فَأُو۟لَٰٓئِكَ هُمُ ٱلظَّٰلِمُونَ","translation":"A divorce may be [revoked] twice, whereupon the marriage must either be resumed in fairness or dissolved in a goodly manner. And it is not lawful for you to take back anything of what you have ever given to your wives unless both [partners] have cause to fear that they may not be able to keep within the bounds set by God: hence, if you have cause to fear that the two may not be able to keep within the bounds set by God, there shall be no sin upon either of them for what the wife may give up [to her husband] in order to free herself. These are the bounds set by God; do not, then, transgress them: for they who transgress the bounds set by God-it is they, they who are evildoers!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/236.mp3","surahId":2,"words":[{"id":86281,"position":1,"arabic":"ٱلطَّلَـٰقُ","translation":"তালাক","audioUrl":"wbw/002_229_001.mp3","charTypeName":"word"},{"id":86282,"position":2,"arabic":"مَرَّتَانِ ۖ","translation":"দুইবার","audioUrl":"wbw/002_229_002.mp3","charTypeName":"word"},{"id":86284,"position":3,"arabic":"فَإِمْسَاكٌۢ","translation":"অতঃপর রেখে দেওয়া","audioUrl":"wbw/002_229_004.mp3","charTypeName":"word"},{"id":86285,"position":4,"arabic":"بِمَعْرُوفٍ","translation":"ন্যায়সংগত ভাবে","audioUrl":"wbw/002_229_005.mp3","charTypeName":"word"},{"id":86286,"position":5,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/002_229_006.mp3","charTypeName":"word"},{"id":86287,"position":6,"arabic":"تَسْرِيحٌۢ","translation":"মুক্ত করে দেয়া","audioUrl":"wbw/002_229_007.mp3","charTypeName":"word"},{"id":86288,"position":7,"arabic":"بِإِحْسَـٰنٍۢ ۗ","translation":"সদয়ভাবে (উত্তম)","audioUrl":"wbw/002_229_008.mp3","charTypeName":"word"},{"id":86290,"position":8,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/002_229_010.mp3","charTypeName":"word"},{"id":86291,"position":9,"arabic":"يَحِلُّ","translation":"বৈধ হবে","audioUrl":"wbw/002_229_011.mp3","charTypeName":"word"},{"id":86292,"position":10,"arabic":"لَكُمْ","translation":"তোমাদের জন্যে","audioUrl":"wbw/002_229_012.mp3","charTypeName":"word"},{"id":86293,"position":11,"arabic":"أَن","translation":"যে","audioUrl":"wbw/002_229_013.mp3","charTypeName":"word"},{"id":86294,"position":12,"arabic":"تَأْخُذُوا۟","translation":"তোমরা গ্রহণ করবে","audioUrl":"wbw/002_229_014.mp3","charTypeName":"word"},{"id":86295,"position":13,"arabic":"مِمَّآ","translation":"তা থেকে যা","audioUrl":"wbw/002_229_015.mp3","charTypeName":"word"},{"id":86296,"position":14,"arabic":"ءَاتَيْتُمُوهُنَّ","translation":"তোমরা দিয়েছ তাদেরকে","audioUrl":"wbw/002_229_016.mp3","charTypeName":"word"},{"id":86297,"position":15,"arabic":"شَيْـًٔا","translation":"কোনো কিছুই","audioUrl":"wbw/002_229_017.mp3","charTypeName":"word"},{"id":86298,"position":16,"arabic":"إِلَّآ","translation":"এছাড়া","audioUrl":"wbw/002_229_018.mp3","charTypeName":"word"},{"id":86299,"position":17,"arabic":"أَن","translation":"যদি","audioUrl":"wbw/002_229_019.mp3","charTypeName":"word"},{"id":86300,"position":18,"arabic":"يَخَافَآ","translation":"দু’জনে ভয় করে","audioUrl":"wbw/002_229_020.mp3","charTypeName":"word"},{"id":86301,"position":19,"ara