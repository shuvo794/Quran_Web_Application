{"id":539,"ayahs":[{"number":12,"arabic":"يَوْمَ تَرَى ٱلْمُؤْمِنِينَ وَٱلْمُؤْمِنَٰتِ يَسْعَىٰ نُورُهُم بَيْنَ أَيْدِيهِمْ وَبِأَيْمَٰنِهِم بُشْرَىٰكُمُ ٱلْيَوْمَ جَنَّٰتٌۭ تَجْرِى مِن تَحْتِهَا ٱلْأَنْهَٰرُ خَٰلِدِينَ فِيهَا ۚ ذَٰلِكَ هُوَ ٱلْفَوْزُ ٱلْعَظِيمُ","translation":"on the Day when thou shalt see all believing men and believing women, with their light spreading rapidly before them and on their right, [and with this wel­come awaiting them:] “A glad tiding for you today: gardens through which running waters flow, therein to abide! This, this is the triumph supreme!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5087.mp3","surahId":57,"words":[{"id":13848,"position":1,"arabic":"يَوْمَ","translation":"সেদিন","audioUrl":"wbw/057_012_001.mp3","charTypeName":"word"},{"id":13849,"position":2,"arabic":"تَرَى","translation":"তুমি দেখবে","audioUrl":"wbw/057_012_002.mp3","charTypeName":"word"},{"id":13850,"position":3,"arabic":"ٱلْمُؤْمِنِينَ","translation":"মুমিন পুরুষকে","audioUrl":"wbw/057_012_003.mp3","charTypeName":"word"},{"id":13851,"position":4,"arabic":"وَٱلْمُؤْمِنَـٰتِ","translation":"ও মুমিন নারীকে","audioUrl":"wbw/057_012_004.mp3","charTypeName":"word"},{"id":13852,"position":5,"arabic":"يَسْعَىٰ","translation":"ছুটে চলছে","audioUrl":"wbw/057_012_005.mp3","charTypeName":"word"},{"id":13853,"position":6,"arabic":"نُورُهُم","translation":"তাদের আলো","audioUrl":"wbw/057_012_006.mp3","charTypeName":"word"},{"id":13854,"position":7,"arabic":"بَيْنَ","translation":"তাদের সামনে","audioUrl":"wbw/057_012_007.mp3","charTypeName":"word"},{"id":13855,"position":8,"arabic":"أَيْدِيهِمْ","translation":"তাদের সামনে","audioUrl":"wbw/057_012_008.mp3","charTypeName":"word"},{"id":13856,"position":9,"arabic":"وَبِأَيْمَـٰنِهِم","translation":"ও তাদের ডানে","audioUrl":"wbw/057_012_009.mp3","charTypeName":"word"},{"id":13857,"position":10,"arabic":"بُشْرَىٰكُمُ","translation":"\"(বলা হবে) তোমাদের জন্যে সুসংবাদ","audioUrl":"wbw/057_012_010.mp3","charTypeName":"word"},{"id":13858,"position":11,"arabic":"ٱلْيَوْمَ","translation":"আজ","audioUrl":"wbw/057_012_011.mp3","charTypeName":"word"},{"id":13859,"position":12,"arabic":"جَنَّـٰتٌۭ","translation":"এক জান্নাতের","audioUrl":"wbw/057_012_012.mp3","charTypeName":"word"},{"id":13860,"position":13,"arabic":"تَجْرِى","translation":"প্রবাহিত হয়","audioUrl":"wbw/057_012_013.mp3","charTypeName":"word"},{"id":13861,"position":14,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/057_012_014.mp3","charTypeName":"word"},{"id":13862,"position":15,"arabic":"تَحْتِهَا","translation":"তার নিচ","audioUrl":"wbw/057_012_015.mp3","charTypeName":"word"},{"id":13863,"position":16,"arabic":"ٱلْأَنْهَـٰرُ","translation":"ঝর্ণাসমূহ","audioUrl":"wbw/057_012_016.mp3","charTypeName":"word"},{"id":13864,"position":17,"arabic":"خَـٰلِدِينَ","translation":"তারা স্থায়ী হবে","audioUrl":"wbw/057_012_017.mp3","charTypeName":"word"},{"id":13865,"position":18,"arabic":"فِيهَا ۚ","translation":"তার মধ্যে","audioUrl":"wbw/057_012_018.mp3","charTypeName":"word"},{"id":13867,"position":19,"arabic":"ذَٰلِكَ","translation":"এটাই","audioUrl":"wbw/057_012_020.mp3","charTypeName":"word"},{"id":13868,"position":20,"arabic":"هُوَ","translation":"সেই","audioUrl":"wbw/057_012_021.mp3","charTypeName":"word"},{"id":13869,"position":21,"arabic":"ٱلْفَوْزُ","translation":"সাফল্য","audioUrl":"wbw/057_012_022.mp3","charTypeName":"word"},{"id":13870,"position":22,"arabic":"ٱلْعَظِيمُ","translation":"মহা\"","audioUrl":"wbw/057_012_023.mp3","charTypeName":"word"},{"id":13871,"position":23,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]},{"number":13,"arabic":"يَوْمَ يَقُولُ ٱلْمُنَٰفِقُونَ وَٱلْمُنَٰفِقَٰتُ لِلَّذِينَ ءَامَنُوا۟ ٱنظُرُونَا نَقْتَبِسْ مِن نُّورِكُمْ قِيلَ ٱرْجِعُوا۟ وَرَآءَكُمْ فَٱلْتَمِسُوا۟ نُورًۭا فَضُرِبَ بَيْنَهُم بِسُورٍۢ لَّهُۥ بَابٌۢ بَاطِنُهُۥ فِيهِ ٱلرَّحْمَةُ وَظَٰهِرُهُۥ مِن قِبَلِهِ ٱلْعَذَابُ","translation":"On that Day shall the hypocrites, both men and women, speak [thus] unto those who have attained to faith: “Wait for us! Let us have a [ray of] light from your light!” [But] they will be told: “Turn back, and seek a light [of your own]!” And thereupon a wall will be raised between them [and the believers], with a gate in it: within it will be grace and mercy, and against the outside thereof, suffering.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5088.mp3","surahId":57,"words":[{"id":14990,"position":1,"arabic":"يَوْمَ","translation":"সেদিন","audioUrl":"wbw/057_013_001.mp3","charTypeName":"word"},{"id":14991,"position":2,"arabic":"يَقُولُ","translation":"বলবে","audioUrl":"wbw/057_013_002.mp3","charTypeName":"word"},{"id":14992,"position":3,"arabic":"ٱلْمُنَـٰفِقُونَ","translation":"মোনাফেক পুরুষরা","audioUrl":"wbw/057_013_003.mp3","charTypeName":"word"},{"id":14993,"position":4,"arabic":"وَٱلْمُنَـٰفِقَـٰتُ","translation":"ও মোনাফেক নারীরা","audioUrl":"wbw/057_013_004.mp3","charTypeName":"word"},{"id":14994,"position":5,"arabic":"لِلَّذِينَ","translation":"(তাদের) কে যারা","audioUrl":"wbw/057_013_005.mp3","charTypeName":"word"},{"id":14995,"position":6,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছিল","audioUrl":"wbw/057_013_006.mp3","charTypeName":"word"},{"id":14996,"position":7,"arabic":"ٱنظُرُونَا","translation":"\"আমাদের দিকে একটু দেখ","audioUrl":"wbw/057_013_007.mp3","charTypeName":"word"},{"id":14997,"position":8,"arabic":"نَقْتَبِسْ","translation":"(আলো নিয়ে) আমরা উপকৃত হব","audioUrl":"wbw/057_013_008.mp3","charTypeName":"word"},{"id":14998,"position":9,"arabic":"مِن","translation":"হতে","audioUrl":"wbw/057_013_009.mp3","charTypeName":"word"},{"id":14999,"position":10,"arabic":"نُّورِكُمْ","translation":"তোমাদের আলো\"","audioUrl":"wbw/057_013_010.mp3","charTypeName":"word"},{"id":15000,"position":11,"arabic":"قِيلَ","translation":"বলা হবে","audioUrl":"wbw/057_013_011.mp3","charTypeName":"word"},{"id":15001,"position":12,"arabic":"ٱرْجِعُوا۟","translation":"\"তোমরা ফিরে যাও","audioUrl":"wbw/057_013_012.mp3","charTypeName":"word"},{"id":15002,"position":13,"arabic":"وَرَآءَكُمْ","translation":"তোমাদের পিছনে","audioUrl":"wbw/057_013_013.mp3","charTypeName":"word"},{"id":15003,"position":14,"arabic":"فَٱلْتَمِسُوا۟","translation":"তোমরা অতঃপর খোঁজ করো","audioUrl":"wbw/057_013_014.mp3","charTypeName":"word"},{"id":15004,"position":15,"arabic":"نُورًۭا","translation":"আলো\"","audioUrl":"wbw/057_013_015.mp3","charTypeName":"word"},{"id":15005,"position":16,"arabic":"فَضُرِبَ","translation":"অতঃপর খাড়া করে দেওয়া হবে","audioUrl":"wbw/057_013_016.mp3","charTypeName":"word"},{"id":15006,"position":17,"arabic":"بَيْنَهُم","translation":"তাদের মাঝে","audioUrl":"wbw/057_013_017.mp3","charTypeName":"word"},{"id":15007,"position":18,"arabic":"بِسُورٍۢ","translation":"প্রাচীর","audioUrl":"wbw/057_013_018.mp3","charTypeName":"word"},{"id":15008,"position":19,"arabic":"لَّهُۥ","translation":"তার থাকবে","audioUrl":"wbw/057_013_019.mp3","charTypeName":"word"},{"id":15009,"position":20,"arabic":"بَابٌۢ","translation":"একটি দরজা","audioUrl":"wbw/057_013_020.mp3","charTypeName":"word"},{"id":15010,"position":21,"arabic":"بَاطِنُهُۥ","translation":"তার ভিতর দিকে","audioUrl":"wbw/057_013_021.mp3","charTypeName":"word"},{"id":15011,"position":22,"arabic":"فِيهِ","translation":"সেখানে আছে","audioUrl":"wbw/057_013_022.mp3","charTypeName":"word"},{"id":15012,"position":23,"arabic":"ٱلرَّحْمَةُ","translation":"অনুগ্রহ","audioUrl":"wbw/057_013_023.mp3","charTypeName":"word"},{"id":15013,"position":24,"arabic":"وَظَـٰهِرُهُۥ","translation":"এবং তার বাইরে","audioUrl":"wbw/057_013_024.mp3","charTypeName":"word"},{"id":15014,"position":25,"arabic":"مِن","translation":"হতে","audioUrl":"wbw/057_013_025.mp3","charTypeName":"word"},{"id":15015,"position":26,"arabic":"قِبَلِهِ","translation":"তার সামনের দিক","audioUrl":"wbw/057_013_026.mp3","charTypeName":"word"},{"id":15016,"position":27,"arabic":"ٱلْعَذَابُ","translation":"শাস্তি","audioUrl":"wbw/057_013_027.mp3","charTypeName":"word"},{"id":15017,"position":28,"arabic":"١٣","translation":"(১৩)","audioUrl":null,"charTypeName":"end"}]},{"number":14,"arabic":"يُنَادُونَهُمْ أَلَمْ نَكُن مَّعَكُمْ ۖ قَالُوا۟ بَلَىٰ وَلَٰكِنَّكُمْ فَتَنتُمْ أَنفُسَكُمْ وَتَرَبَّصْتُمْ وَٱرْتَبْتُمْ وَغَرَّتْكُمُ ٱلْأَمَانِىُّ حَتَّىٰ جَآءَ أَمْرُ ٱللَّهِ وَغَرَّكُم بِٱللَّهِ ٱلْغَرُورُ","translation":"They [who will remain without] will call out to those [within], “Were we not with you?” - [to which] the others will answer: “So it was! But you allowed yourselves to succumb to temptation, and you were hesitant [in your faith], and you were doubtful [of resurrection]; and your wishful thinking beguiled you until God’s command came to pass: for, [indeed, your own] deceptive thoughts about God deluded you","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5089.mp3","surahId":57,"words":[{"id":16048,"position":1,"arabic":"يُنَادُونَهُمْ","translation":"তাদেরকে ডেকে বলবে তারা","audioUrl":"wbw/057_014_001.mp3","charTypeName":"word"},{"id":16049,"position":2,"arabic":"أَلَمْ","translation":"\"নয় কি","audioUrl":"wbw/057_014_002.mp3","charTypeName":"word"},{"id":16050,"position":3,"arabic":"نَكُن","translation":"আমরা ছিলাম","audioUrl":"wbw/057_014_003.mp3","charTypeName":"word"},{"id":16051,"position":4,"arabic":"مَّعَكُمْ ۖ","translation":"তোমাদের সাথে\"","audioUrl":"wbw/057_014_004.mp3","charTypeName":"word"},{"id":16053,"position":5,"arabic":"قَالُوا۟","translation":"তারা বলবে","audioUrl":"wbw/057_014_006.mp3","charTypeName":"word"},{"id":16054,"position":6,"arabic":"بَلَىٰ","translation":"\"হ্যাঁ (তোমরা ছিলে)","audioUrl":"wbw/057_014_007.mp3","charTypeName":"word"},{"id":16055,"position":7,"arabic":"وَلَـٰكِنَّكُمْ","translation":"কিন্তু তোমরা","audioUrl":"wbw/057_014_008.mp3","charTypeName":"word"},{"id":16056,"position":8,"arabic":"فَتَنتُمْ","translation":"তোমরা বিপদে ফেলেছিলে","audioUrl":"wbw/057_014_009.mp3","charTypeName":"word"},{"id":16057,"position":9,"arabic":"أَنفُسَكُمْ","translation":"তোমাদের নিজেদেরকে","audioUrl":"wbw/057_014_010.mp3","charTypeName":"word"},{"id":16058,"position":10,"arabic":"وَتَرَبَّصْتُمْ","translation":"এবং তোমরা অপেক্ষা করেছিলে","audioUrl":"wbw/057_014_011.mp3","charTypeName":"word"},{"id":16059,"position":11,"arabic":"وَٱرْتَبْتُمْ","translation":"ও তোমরা সন্দেহ করেছিলে","audioUrl":"wbw/057_014_012.mp3","charTypeName":"word"},{"id":16060,"position":12,"arabic":"وَغَرَّتْكُمُ","translation":"এবং তোমাদেরকে ধোঁকা দিয়েছিল","audioUrl":"wbw/057_014_013.mp3","charTypeName":"word"},{"id":16061,"position":13,"arabic":"ٱلْأَمَانِىُّ","translation":"মিথ্যা আকাঙ্ক্ষা","audioUrl":"wbw/057_014_014.mp3","charTypeName":"word"},{"id":16062,"position":14,"arabic":"حَتَّىٰ","translation":"যতক্ষণ না","audioUrl":"wbw/057_014_015.mp3","charTypeName":"word"},{"id":16063,"position":15,"arabic":"جَآءَ","translation":"আসল","audioUrl":"wbw/057_014_016.mp3","charTypeName":"word"},{"id":16064,"position":16,"arabic":"أَمْرُ","translation":"নির্দেশ","audioUrl":"wbw/057_014_017.mp3","charTypeName":"word"},{"id":16065,"position":17,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/057_014_018.mp3","charTypeName":"word"},{"id":16066,"position":18,"arabic":"وَغَرَّكُم","translation":"এবং তোমাদেরকে ধোঁকা দিয়েছিল","audioUrl":"wbw/057_014_019.mp3","charTypeName":"word"},{"id":16067,"position":19,"arabic":"بِٱللَّهِ","translation":"আল্লাহ্‌ সম্পর্কে","audioUrl":"wbw/057_014_020.mp3","charTypeName":"word"},{"id":16068,"position":20,"arabic":"ٱلْغَرُورُ","translation":"প্রতারক (শয়তান)","audioUrl":"wbw/057_014_021.mp3","charTypeName":"word"},{"id":16069,"position":21,"arabic":"١٤","translation":"(১৪)","audioUrl":null,"charTypeName":"end"}]},{"number":15,"arabic":"فَٱلْيَوْمَ لَا يُؤْخَذُ مِنكُمْ فِدْيَةٌۭ وَلَا مِنَ ٱلَّذِينَ كَفَرُوا۟ ۚ مَأْوَىٰكُمُ ٱلنَّارُ ۖ هِىَ مَوْلَىٰكُمْ ۖ وَبِئْسَ ٱلْمَصِيرُ","translation":"“And so, no ransom shall be accepted today from you, and neither from those who were [openly] bent on denying the truth. Your goal is the fire: it is your [only] refuge - and how evil a journey’s end!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5090.mp3","surahId":57,"words":[{"id":17022,"position":1,"arabic":"فَٱلْيَوْمَ","translation":"অতঃএব আজ","audioUrl":"wbw/057_015_001.mp3","charTypeName":"word"},{"id":17023,"position":2,"arabic":"لَا","translation":"না","audioUrl":"wbw/057_015_002.mp3","charTypeName":"word"},{"id":17024,"position":3,"arabic":"يُؤْخَذُ","translation":"নেওয়া হবে","audioUrl":"wbw/057_015_003.mp3","charTypeName":"word"},{"id":17025,"position":4,"arabic":"مِنكُمْ","translation":"তোমাদের হতে","audioUrl":"wbw/057_015_004.mp3","charTypeName":"word"},{"id":17026,"position":5,"arabic":"فِدْيَةٌۭ","translation":"কোনো মুক্তিপণ","audioUrl":"wbw/057_015_005.mp3","charTypeName":"word"},{"id":17027,"position":6,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/057_015_006.mp3","charTypeName":"word"},{"id":17028,"position":7,"arabic":"مِنَ","translation":"হতে","audioUrl":"wbw/057_015_007.mp3","charTypeName":"word"},{"id":17029,"position":8,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/057_015_008.mp3","charTypeName":"word"},{"id":17030,"position":9,"arabic":"كَفَرُوا۟ ۚ","translation":"অস্বীকার করেছিল","audioUrl":"wbw/057_015_009.mp3","charTypeName":"word"},{"id":17032,"position":10,"arabic":"مَأْوَىٰكُمُ","translation":"তোমাদের আবাসস্থল","audioUrl":"wbw/057_015_011.mp3","charTypeName":"word"},{"id":17033,"position":11,"arabic":"ٱلنَّارُ ۖ","translation":"জাহান্নাম","audioUrl":"wbw/057_015_012.mp3","charTypeName":"word"},{"id":17035,"position":12,"arabic":"هِىَ","translation":"তা","audioUrl":"wbw/057_015_014.mp3","charTypeName":"word"},{"id":17036,"position":13,"arabic":"مَوْلَىٰكُمْ ۖ","translation":"তোমাদের সঙ্গী","audioUrl":"wbw/057_015_015.mp3","charTypeName":"word"},{"id":17038,"position":14,"arabic":"وَبِئْسَ","translation":"এবং অতি নিকৃষ্ট","audioUrl":"wbw/057_015_017.mp3","charTypeName":"word"},{"id":17039,"position":15,"arabic":"ٱلْمَصِيرُ","translation":"প্রত্যাব