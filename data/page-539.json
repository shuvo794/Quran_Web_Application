/057_018_006.mp3","charTypeName":"word"},{"id":20447,"position":7,"arabic":"حَسَنًۭا","translation":"উত্তম","audioUrl":"wbw/057_018_007.mp3","charTypeName":"word"},{"id":20448,"position":8,"arabic":"يُضَـٰعَفُ","translation":"বহুগুণ বাড়িয়ে দেওয়া হবে","audioUrl":"wbw/057_018_008.mp3","charTypeName":"word"},{"id":20449,"position":9,"arabic":"لَهُمْ","translation":"তাদের জন্যে","audioUrl":"wbw/057_018_009.mp3","charTypeName":"word"},{"id":20450,"position":10,"arabic":"وَلَهُمْ","translation":"এবং তাদের জন্যে রয়েছে","audioUrl":"wbw/057_018_010.mp3","charTypeName":"word"},{"id":20451,"position":11,"arabic":"أَجْرٌۭ","translation":"পুরস্কার","audioUrl":"wbw/057_018_011.mp3","charTypeName":"word"},{"id":20452,"position":12,"arabic":"كَرِيمٌۭ","translation":"সম্মানজনক","audioUrl":"wbw/057_018_012.mp3","charTypeName":"word"},{"id":20453,"position":13,"arabic":"١٨","translation":"(১৮)","audioUrl":null,"charTypeName":"end"}]}]}