"}]},{"number":4,"arabic":"عَلَّمَهُ ٱلْبَيَانَ","translation":"He has imparted unto him articulate thought and speech.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4905.mp3","surahId":55,"words":[{"id":3552,"position":1,"arabic":"عَلَّمَهُ","translation":"তাকে শিখিয়েছেন","audioUrl":"wbw/055_004_001.mp3","charTypeName":"word"},{"id":3553,"position":2,"arabic":"ٱلْبَيَانَ","translation":"ভাব প্রকাশ করতে","audioUrl":"wbw/055_004_002.mp3","charTypeName":"word"},{"id":3554,"position":3,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"ٱلشَّمْسُ وَٱلْقَمَرُ بِحُسْبَانٍۢ","translation":"[At His behest] the sun and the moon run their appointed courses;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4906.mp3","surahId":55,"words":[{"id":4871,"position":1,"arabic":"ٱلشَّمْسُ","translation":"সূর্য","audioUrl":"wbw/055_005_001.mp3","charTypeName":"word"},{"id":4872,"position":2,"arabic":"وَٱلْقَمَرُ","translation":"ও চাঁদ","audioUrl":"wbw/055_005_002.mp3","charTypeName":"word"},{"id":4873,"position":3,"arabic":"بِحُسْبَانٍۢ","translation":"একটি হিসাব অনুসরণ করেই চলে","audioUrl":"wbw/055_005_003.mp3","charTypeName":"word"},{"id":4874,"position":4,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"وَٱلنَّجْمُ وَٱلشَّجَرُ يَسْجُدَانِ","translation":"[before Him] prostrate them­selves the stars and the trees.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4907.mp3","surahId":55,"words":[{"id":6162,"position":1,"arabic":"وَٱلنَّجْمُ","translation":"এবং তারকা","audioUrl":"wbw/055_006_001.mp3","charTypeName":"word"},{"id":6163,"position":2,"arabic":"وَٱلشَّجَرُ","translation":"ও গাছপালা","audioUrl":"wbw/055_006_002.mp3","charTypeName":"word"},{"id":6164,"position":3,"arabic":"يَسْجُدَانِ","translation":"উভয়ে সিজদারত","audioUrl":"wbw/055_006_003.mp3","charTypeName":"word"},{"id":6165,"position":4,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"وَٱلسَّمَآءَ رَفَعَهَا وَوَضَعَ ٱلْمِيزَانَ","translation":"And the skies has He raised high, and has devised [for all things] a measure,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4908.mp3","surahId":55,"words":[{"id":7495,"position":1,"arabic":"وَٱلسَّمَآءَ","translation":"এবং আকাশকে","audioUrl":"wbw/055_007_001.mp3","charTypeName":"word"},{"id":7496,"position":2,"arabic":"رَفَعَهَا","translation":"তা সমুন্নত করেছেন তিনি","audioUrl":"wbw/055_007_002.mp3","charTypeName":"word"},{"id":7497,"position":3,"arabic":"وَوَضَعَ","translation":"ও স্থাপন করেছেন","audioUrl":"wbw/055_007_003.mp3","charTypeName":"word"},{"id":7498,"position":4,"arabic":"ٱلْمِيزَانَ","translation":"মানদণ্ড","audioUrl":"wbw/055_007_004.mp3","charTypeName":"word"},{"id":7499,"position":5,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"أَلَّا تَطْغَوْا۟ فِى ٱلْمِيزَانِ","translation":"so that you [too, O men,] might never transgress the measure [of what is right]:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4909.mp3","surahId":55,"words":[{"id":8741,"position":1,"arabic":"أَلَّا","translation":"(ঐকান্তিক দাবি) না যেন","audioUrl":"wbw/055_008_001.mp3","charTypeName":"word"},{"id":8742,"position":2,"arabic":"تَطْغَوْا۟","translation":"তোমরা সীমা লঙ্ঘন কর","audioUrl":"wbw/055_008_002.mp3","charTypeName":"word"},{"id":8743,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/055_008_003.mp3","charTypeName":"word"},{"id":8744,"position":4,"arabic":"ٱلْمِيزَانِ","translation":"মানদণ্ডের","audioUrl":"wbw/055_008_004.mp3","charTypeName":"word"},{"id":8745,"position":5,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"وَأَقِيمُوا۟ ٱلْوَزْنَ بِٱلْقِسْطِ وَلَا تُخْسِرُوا۟ ٱلْمِيزَانَ","translation":"weigh, therefore, [your deeds] with equity, and cut not the measure short!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4910.mp3","surahId":55,"words":[{"id":9969,"position":1,"arabic":"وَأَقِيمُوا۟","translation":"এবং তোমরা প্রতিষ্ঠা করো","audioUrl":"wbw/055_009_001.mp3","charTypeName":"word"},{"id":9970,"position":2,"arabic":"ٱلْوَزْنَ","translation":"ওজন","audioUrl":"wbw/055_009_002.mp3","charTypeName":"word"},{"id":9971,"position":3,"arabic":"بِٱلْقِسْطِ","translation":"ন্যায্য ভাবে","audioUrl":"wbw/055_009_003.mp3","charTypeName":"word"},{"id":9972,"position":4,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/055_009_004.mp3","charTypeName":"word"},{"id":9973,"position":5,"arabic":"تُخْسِرُوا۟","translation":"তোমরা কম দিয়ো","audioUrl":"wbw/055_009_005.mp3","charTypeName":"word"},{"id":9974,"position":6,"arabic":"ٱلْمِيزَانَ","translation":"দাঁড়িপাল্লায়/ পরিমাপে","audioUrl":"wbw/055_009_006.mp3","charTypeName":"word"},{"id":9975,"position":7,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"وَٱلْأَرْضَ وَضَعَهَا لِلْأَنَامِ","translation":"And the earth has He spread out for all living beings,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4911.mp3","surahId":55,"words":[{"id":11167,"position":1,"arabic":"وَٱلْأَرْضَ","translation":"এবং পৃথিবীকে","audioUrl":"wbw/055_010_001.mp3","charTypeName":"word"},{"id":11168,"position":2,"arabic":"وَضَعَهَا","translation":"তা তিনি স্থাপন করেছেন","audioUrl":"wbw/055_010_002.mp3","charTypeName":"word"},{"id":11169,"position":3,"arabic":"لِلْأَنَامِ","translation":"সৃষ্ট জীবের জন্যে","audioUrl":"wbw/055_010_003.mp3","charTypeName":"word"},{"id":11170,"position":4,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"فِيهَا فَٰكِهَةٌۭ وَٱلنَّخْلُ ذَاتُ ٱلْأَكْمَامِ","translation":"with fruit thereon, and palm trees with sheathed clusters [of dates],","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4912.mp3","surahId":55,"words":[{"id":12493,"position":1,"arabic":"فِيهَا","translation":"তা