{"id":531,"ayahs":[{"number":50,"arabic":"وَمَآ أَمْرُنَآ إِلَّا وَٰحِدَةٌۭ كَلَمْحٍۭ بِٱلْبَصَرِ","translation":"and Our ordaining [a thing and its coming into being] is but one [act], like the twinkling of an eye.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4896.mp3","surahId":54,"words":[{"id":48625,"position":1,"arabic":"وَمَآ","translation":"এবং না","audioUrl":"wbw/054_050_001.mp3","charTypeName":"word"},{"id":48626,"position":2,"arabic":"أَمْرُنَآ","translation":"আমাদের নির্দেশ (দেওয়া হয়)","audioUrl":"wbw/054_050_002.mp3","charTypeName":"word"},{"id":48627,"position":3,"arabic":"إِلَّا","translation":"এছাড়া যে","audioUrl":"wbw/054_050_003.mp3","charTypeName":"word"},{"id":48628,"position":4,"arabic":"وَٰحِدَةٌۭ","translation":"একবারই","audioUrl":"wbw/054_050_004.mp3","charTypeName":"word"},{"id":48629,"position":5,"arabic":"كَلَمْحٍۭ","translation":"পলকের মতো","audioUrl":"wbw/054_050_005.mp3","charTypeName":"word"},{"id":48630,"position":6,"arabic":"بِٱلْبَصَرِ","translation":"চোখের (তা কার্যকর হয়)","audioUrl":"wbw/054_050_006.mp3","charTypeName":"word"},{"id":48631,"position":7,"arabic":"٥٠","translation":"(৫০)","audioUrl":null,"charTypeName":"end"}]},{"number":51,"arabic":"وَلَقَدْ أَهْلَكْنَآ أَشْيَاعَكُمْ فَهَلْ مِن مُّدَّكِرٍۢ","translation":"Thus, indeed, did We destroy people like you [in the past]: who, then, is willing to take it to heart?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4897.mp3","surahId":54,"words":[{"id":49183,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/054_051_001.mp3","charTypeName":"word"},{"id":49184,"position":2,"arabic":"أَهْلَكْنَآ","translation":"আমরা ধ্বংস করেছি","audioUrl":"wbw/054_051_002.mp3","charTypeName":"word"},{"id":49185,"position":3,"arabic":"أَشْيَاعَكُمْ","translation":"তোমাদের (মত) দলগুলোকে","audioUrl":"wbw/054_051_003.mp3","charTypeName":"word"},{"id":49186,"position":4,"arabic":"فَهَلْ","translation":"কি তবে (আছে)","audioUrl":"wbw/054_051_004.mp3","charTypeName":"word"},{"id":49187,"position":5,"arabic":"مِن","translation":"কোনো","audioUrl":"wbw/054_051_005.mp3","charTypeName":"word"},{"id":49188,"position":6,"arabic":"مُّدَّكِرٍۢ","translation":"উপদেশগ্রহণকারী (এ হতে)","audioUrl":"wbw/054_051_006.mp3","charTypeName":"word"},{"id":49189,"position":7,"arabic":"٥١","translation":"(৫১)","audioUrl":null,"charTypeName":"end"}]},{"number":52,"arabic":"وَكُلُّ شَىْءٍۢ فَعَلُوهُ فِى ٱلزُّبُرِ","translation":"[They were truly guilty] because all [the evil] that they ever did had been [revealed to them as such] in the [ancient] books of [divine] wisdom;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4898.mp3","surahId":54,"words":[{"id":49857,"position":1,"arabic":"وَكُلُّ","translation":"এবং প্রত্যেক","audioUrl":"wbw/054_052_001.mp3","charTypeName":"word"},{"id":49858,"position":2,"arabic":"شَىْءٍۢ","translation":"জিনিস","audioUrl":"wbw/054_052_002.mp3","charTypeName":"word"},{"id":49859,"position":3,"arabic":"فَعَلُوهُ","translation":"যা তারা করেছে","audioUrl":"wbw/054_052_003.mp3","charTypeName":"word"},{"id":49860,"position":4,"arabic":"فِى","translation":"মধ্যে আছে","audioUrl":"wbw/054_052_004.mp3","charTypeName":"word"},{"id":49861,"position":5,"arabic":"ٱلزُّبُرِ","translation":"খাতাসমূহের (লিপিবদ্ধ)","audioUrl":"wbw/054_052_005.mp3","charTypeName":"word"},{"id":49862,"position":6,"arabic":"٥٢","translation":"(৫২)","audioUrl":null,"charTypeName":"end"}]},{"number":53,"arabic":"وَكُلُّ صَغِيرٍۢ وَكَبِيرٍۢ مُّسْتَطَرٌ","translation":"and everything [that man does], be it small or great, is recorded [with God].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4899.mp3","surahId":54,"words":[{"id":50529,"position":1,"arabic":"وَكُلُّ","translation":"এবং প্রত্যেক","audioUrl":"wbw/054_053_001.mp3","charTypeName":"word"},{"id":50530,"position":2,"arabic":"صَغِيرٍۢ","translation":"ছোট","audioUrl":"wbw/054_053_002.mp3","charTypeName":"word"},{"id":50531,"position":3,"arab