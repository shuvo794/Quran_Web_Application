লো","audioUrl":"wbw/007_149_002.mp3","charTypeName":"word"},{"id":80295,"position":3,"arabic":"فِىٓ","translation":"মধ্যে","audioUrl":"wbw/007_149_003.mp3","charTypeName":"word"},{"id":80296,"position":4,"arabic":"أَيْدِيهِمْ","translation":"হাতের তাদের","audioUrl":"wbw/007_149_004.mp3","charTypeName":"word"},{"id":80297,"position":5,"arabic":"وَرَأَوْا۟","translation":"ও তারা দেখলো","audioUrl":"wbw/007_149_005.mp3","charTypeName":"word"},{"id":80298,"position":6,"arabic":"أَنَّهُمْ","translation":"যে তারা","audioUrl":"wbw/007_149_006.mp3","charTypeName":"word"},{"id":80299,"position":7,"arabic":"قَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/007_149_007.mp3","charTypeName":"word"},{"id":80300,"position":8,"arabic":"ضَلُّوا۟","translation":"পথভ্রষ্ট হয়ে গিয়েছিলো","audioUrl":"wbw/007_149_008.mp3","charTypeName":"word"},{"id":80301,"position":9,"arabic":"قَالُوا۟","translation":"তারা বললো","audioUrl":"wbw/007_149_009.mp3","charTypeName":"word"},{"id":80302,"position":10,"arabic":"لَئِن","translation":"\"অবশ্যই যদি","audioUrl":"wbw/007_149_010.mp3","charTypeName":"word"},{"id":80303,"position":11,"arabic":"لَّمْ","translation":"না","audioUrl":"wbw/007_149_011.mp3","charTypeName":"word"},{"id":80304,"position":12,"arabic":"يَرْحَمْنَا","translation":"আমাদের উপর অনুগ্রহ করেন","audioUrl":"wbw/007_149_012.mp3","charTypeName":"word"},{"id":80305,"position":13,"arabic":"رَبُّنَا","translation":"আমাদের রব","audioUrl":"wbw/007_149_013.mp3","charTypeName":"word"},{"id":80306,"position":14,"arabic":"وَيَغْفِرْ","translation":"ও ক্ষমা (না) করেন","audioUrl":"wbw/007_149_014.mp3","charTypeName":"word"},{"id":80307,"position":15,"arabic":"لَنَا","translation":"আমাদের","audioUrl":"wbw/007_149_015.mp3","charTypeName":"word"},{"id":80308,"position":16,"arabic":"لَنَكُونَنَّ","translation":"অবশ্যই আমরা হবো","audioUrl":"wbw/007_149_016.mp3","charTypeName":"word"},{"id":80309,"position":17,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/007_149_017.mp3","charTypeName":"word"