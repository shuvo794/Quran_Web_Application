 مَا حَرَّمَ رَبُّكُمْ عَلَيْكُمْ ۖ أَلَّا تُشْرِكُوا۟ بِهِۦ شَيْـًۭٔا ۖ وَبِٱلْوَٰلِدَيْنِ إِحْسَٰنًۭا ۖ وَلَا تَقْتُلُوٓا۟ أَوْلَٰدَكُم مِّنْ إِمْلَٰقٍۢ ۖ نَّحْنُ نَرْزُقُكُمْ وَإِيَّاهُمْ ۖ وَلَا تَقْرَبُوا۟ ٱلْفَوَٰحِشَ مَا ظَهَرَ مِنْهَا وَمَا بَطَنَ ۖ وَلَا تَقْتُلُوا۟ ٱلنَّفْسَ ٱلَّتِى حَرَّمَ ٱللَّهُ إِلَّا بِٱلْحَقِّ ۚ ذَٰلِكُمْ وَصَّىٰكُم بِهِۦ لَعَلَّكُمْ تَعْقِلُونَ","translation":"Say: \"Come, let me convey unto you what God has [really] forbidden to you: \"Do not ascribe divinity, in any way, to aught beside Him; and [do not offend against but, rather,] do good unto your parents; and do not kill your children for fear of poverty - [for] it is We who shall provide sustenance for you as well as for them; and do not commit any shameful deeds, be they open or secret; and do not take any human being's life-[the life] which God has declared to be sacred -otherwise than in [the pursuit of] justice: this has He enjoined upon you so that you might use your reason;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/940.mp3","surahId":6,"words":[{"id":80514,"position":1,"arabic":"۞ قُلْ","translation":"বলো","audioUrl":"wbw/006_151_002.mp3","charTypeName":"word"},{"id":80515,"position":2,"arabic":"تَعَالَوْا۟","translation":"\"তোমরা আসো","audioUrl":"wbw/006_151_003.mp3","charTypeName":"word"},{"id":80516,"position":3,"arabic":"أَتْلُ","translation":"তিলাওয়াত করবো আমি","audioUrl":"wbw/006_151_004.mp3","charTypeName":"word"},{"id":80517,"position":4,"arabic":"مَا","translation":"যা","audioUrl":"wbw/006_151_005.mp3","charTypeName":"word"},{"id":80518,"position":5,"arabic":"حَرَّمَ","translation":"নিষেধ করেছেন","audioUrl":"wbw/006_151_006.mp3","charTypeName":"word"},{"id":80519,"position":6,"arabic":"رَبُّكُمْ","translation":"রব তোমাদের","audioUrl":"wbw/006_151_007.mp3","charTypeName":"word"},{"id":80520,"position":7,"arabic":"عَلَيْكُمْ ۖ","translation":"উপর তোমাদের","audioUrl":"wbw/006_151_008.mp3","charTypeName":"word"},{"id":80522,"position":8,"arabi