{"id":148,"ayahs":[{"number":147,"arabic":"فَإِن كَذَّبُوكَ فَقُل رَّبُّكُمْ ذُو رَحْمَةٍۢ وَٰسِعَةٍۢ وَلَا يُرَدُّ بَأْسُهُۥ عَنِ ٱلْقَوْمِ ٱلْمُجْرِمِينَ","translation":"And if they give thee the lie, say: \"Limitless is your Sustainer in His grace; but His punishment shall not be averted from people who are lost in sin.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/936.mp3","surahId":6,"words":[{"id":80121,"position":1,"arabic":"فَإِن","translation":"অতঃপর যদি","audioUrl":"wbw/006_147_001.mp3","charTypeName":"word"},{"id":80122,"position":2,"arabic":"كَذَّبُوكَ","translation":"তোমাকে তারা মিথ্যা প্রতিপন্ন করে","audioUrl":"wbw/006_147_002.mp3","charTypeName":"word"},{"id":80123,"position":3,"arabic":"فَقُل","translation":"তবে বলো","audioUrl":"wbw/006_147_003.mp3","charTypeName":"word"},{"id":80124,"position":4,"arabic":"رَّبُّكُمْ","translation":"\"রব তোমাদের","audioUrl":"wbw/006_147_004.mp3","charTypeName":"word"},{"id":80125,"position":5,"arabic":"ذُو","translation":"অধিকারী","audioUrl":"wbw/006_147_005.mp3","charTypeName":"word"},{"id":80126,"position":6,"arabic":"رَحْمَةٍۢ","translation":"দয়ার","audioUrl":"wbw/006_147_006.mp3","charTypeName":"word"},{"id":80127,"position":7,"arabic":"وَٰسِعَةٍۢ","translation":"সুপ্রশস্ত ও ব্যাপক","audioUrl":"wbw/006_147_007.mp3","charTypeName":"word"},{"id":80128,"position":8,"arabic":"وَلَا","translation":"কিন্তু না","audioUrl":"wbw/006_147_008.mp3","charTypeName":"word"},{"id":80129,"position":9,"arabic":"يُرَدُّ","translation":"ফিরানো যায়","audioUrl":"wbw/006_147_009.mp3","charTypeName":"word"},{"id":80130,"position":10,"arabic":"بَأْسُهُۥ","translation":"শাস্তি তাঁর","audioUrl":"wbw/006_147_010.mp3","charTypeName":"word"},{"id":80131,"position":11,"arabic":"عَنِ","translation":"থেকে","audioUrl":"wbw/006_147_011.mp3","charTypeName":"word"},{"id":80132,"position":12,"arabic":"ٱلْقَوْمِ","translation":"সম্প্রদায়ের","audioUrl":"wbw/006_147_012.mp3","charTypeName":"word"},{"id":80133,"position":13,"arabic":"ٱلْمُجْرِمِينَ","translation":"(যারা) অপরাধী\"","audioUrl":"wbw/006_147_013.mp3","charTypeName":"word"},{"id":80134,"position":14,"arabic":"١٤٧","translation":"(১৪৭)","audioUrl":null,"charTypeName":"end"}]},{"number":148,"arabic":"سَيَقُولُ ٱلَّذِينَ أَشْرَكُوا۟ لَوْ شَآءَ ٱللَّهُ مَآ أَشْرَكْنَا وَلَآ ءَابَآؤُنَا وَلَا حَرَّمْنَا مِن شَىْءٍۢ ۚ كَذَٰلِكَ كَذَّبَ ٱلَّذِينَ مِن قَبْلِهِمْ حَتَّىٰ ذَاقُوا۟ بَأْسَنَا ۗ قُلْ هَلْ عِندَكُم مِّنْ عِلْمٍۢ فَتُخْرِجُوهُ لَنَآ ۖ إِن تَتَّبِعُونَ إِلَّا ٱلظَّنَّ وَإِنْ أَنتُمْ إِلَّا تَخْرُصُونَ","translation":"THOSE who are bent on ascribing divinity to aught beside God will say, \"Had God so willed, we would not have ascribed divinity to aught but Him, nor would our forefathers [have done so]; and neither would we have declared as forbidden anything [that He has allowed].\" Even so did those who lived before them give the lie to the truth -until they came to taste Our punishment! Say: \"Have you any [certain] knowledge which you could proffer to us? You follow but [other people's] conjectures, and you yourselves do nothing but guess.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/937.mp3","surahId":6,"words":[{"id":80201,"position":1,"arabic":"سَيَقُولُ","translation":"শীঘ্রই বলবে","audioUrl":"wbw/006_148_001.mp3","charTypeName":"word"},{"id":80202,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/006_148_002.mp3","charTypeName":"word"},{"id":80203,"position":3,"arabic":"أَشْرَكُوا۟","translation":"শিরক করেছে","audioUrl":"wbw/006_148_003.mp3","charTypeName":"word"},{"id":80204,"position":4,"arabic":"لَوْ","translation":"\"যদি","audioUrl":"wbw/006_148_004.mp3","charTypeName":"word"},{"id":80205,"position":5,"arabic":"شَآءَ","translation":"ইচ্ছে করতেন","audioUrl":"wbw/006_148_005.mp3","charTypeName":"word"},{"id":80206,"position":6,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌","audioUrl":"wbw/006_148_006.mp3","charTypeName":"word"},{"id":80207,"position":7,"arabic":"مَآ","transl