{"id":218,"ayahs":[{"number":79,"arabic":"وَقَالَ فِرْعَوْنُ ٱئْتُونِى بِكُلِّ سَٰحِرٍ عَلِيمٍۢ","translation":"And Pharaoh commanded: \"Bring before me every sorcerer of great knowledge!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1443.mp3","surahId":10,"words":[{"id":63763,"position":1,"arabic":"وَقَالَ","translation":"এবং বললো","audioUrl":"wbw/010_079_001.mp3","charTypeName":"word"},{"id":63764,"position":2,"arabic":"فِرْعَوْنُ","translation":"ফিরাউন","audioUrl":"wbw/010_079_002.mp3","charTypeName":"word"},{"id":63765,"position":3,"arabic":"ٱئْتُونِى","translation":"\"আমার কাছে আসো","audioUrl":"wbw/010_079_003.mp3","charTypeName":"word"},{"id":63766,"position":4,"arabic":"بِكُلِّ","translation":"নিয়ে প্রত্যেক","audioUrl":"wbw/010_079_004.mp3","charTypeName":"word"},{"id":63767,"position":5,"arabic":"سَـٰحِرٍ","translation":"জাদুকরকে","audioUrl":"wbw/010_079_005.mp3","charTypeName":"word"},{"id":63768,"position":6,"arabic":"عَلِيمٍۢ","translation":"সুদক্ষ\"","audioUrl":"wbw/010_079_006.mp3","charTypeName":"word"},{"id":63769,"position":7,"arabic":"٧٩","translation":"(৭৯)","audioUrl":null,"charTypeName":"end"}]},{"number":80,"arabic":"فَلَمَّا جَآءَ ٱلسَّحَرَةُ قَالَ لَهُم مُّوسَىٰٓ أَلْقُوا۟ مَآ أَنتُم مُّلْقُونَ","translation":"And when the sorcerers came, Moses said unto them: \"Throw whatever you may [wish to] throw!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1444.mp3","surahId":10,"words":[{"id":64167,"position":1,"arabic":"فَلَمَّا","translation":"অতঃপর যখন","audioUrl":"wbw/010_080_001.mp3","charTypeName":"word"},{"id":64168,"position":2,"arabic":"جَآءَ","translation":"আসলো","audioUrl":"wbw/010_080_002.mp3","charTypeName":"word"},{"id":64169,"position":3,"arabic":"ٱلسَّحَرَةُ","translation":"জাদুকররা","audioUrl":"wbw/010_080_003.mp3","charTypeName":"word"},{"id":64170,"position":4,"arabic":"قَالَ","translation":"বললো","audioUrl":"wbw/010_080_004.mp3","charTypeName":"word"},{"id":64171,"position":5,"arabic":"لَهُم","translation":"উদ্দেশ্যে তাদের","audioUrl":"wbw/010_080_005.mp3","charTypeName":"word"},{"id":64172,"position":6,"arabic":"مُّوسَىٰٓ","translation":"মূসা","audioUrl":"wbw/010_080_006.mp3","charTypeName":"word"},{"id":64173,"position":7,"arabic":"أَلْقُوا۟","translation":"\"তোমরা নিক্ষেপ করো","audioUrl":"wbw/010_080_007.mp3","charTypeName":"word"},{"id":64174,"position":8,"arabic":"مَآ","translation":"যা","audioUrl":"wbw/010_080_008.mp3","charTypeName":"word"},{"id":64175,"position":9,"arabic":"أَنتُم","translation":"তোমরা","audioUrl":"wbw/010_080_009.mp3","charTypeName":"word"},{"id":64176,"position":10,"arabic":"مُّلْقُونَ","translation":"নিক্ষেপকারী\"","audioUrl":"wbw/010_080_010.mp3","charTypeName":"word"},{"id":64177,"position":11,"arabic":"٨٠","translation":"(৮০)","audioUrl":null,"charTypeName":"end"}]},{"number":81,"arabic":"فَلَمَّآ أَلْقَوْا۟ قَالَ مُوسَىٰ مَا جِئْتُم بِهِ ٱلسِّحْرُ ۖ إِنَّ ٱللَّهَ سَيُبْطِلُهُۥٓ ۖ إِنَّ ٱللَّهَ لَا يُصْلِحُ عَمَلَ ٱلْمُفْسِدِينَ","translation":"And when they threw down [their staffs and cast a spell upon the people's eyes], Moses said unto them: \"What you have contrived is [but] sorcery which, verily, God will bring to nought! Verily, God does not further the works of spreaders of corruption -","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1445.mp3","surahId":10,"words":[{"id":64461,"position":1,"arabic":"فَلَمَّآ","translation":"অতঃপর যখন","audioUrl":"wbw/010_081_001.mp3","charTypeName":"word"},{"id":64462,"position":2,"arabic":"أَلْقَوْا۟","translation":"তারা নিক্ষেপ করলো","audioUrl":"wbw/010_081_002.mp3","charTypeName":"word"},{"id":64463,"position":3,"arabic":"قَالَ","translation":"বললো","audioUrl":"wbw/010_081_003.mp3","charTypeName":"word"},{"id":64464,"position":4,"arabic":"مُوسَىٰ","translation":"মূসা","audioUrl":"wbw/010_081_004.mp3","charTypeName":"word"},{"id":64465,"position":5,"arabic":"مَا","translation":"\"(ঐসব) যা","audioUrl":"wbw/010_081_005.mp3","charTypeName":"word"},{"id":64466,"position":6,"arabic":"جِئْتُم","translation":"তোমরা এসেছো","audioUrl":"wbw/010_081_006.mp3","charTypeName":"word"},{"id":64467,"position":7,"arabic":"بِهِ","translation":"নিয়ে তা","audioUrl":"wbw/010_081_007.mp3","charTypeName":"word"},{"id":64468,"position":8,"arabic":"ٱلسِّحْرُ ۖ","translation":"জাদু","audioUrl":"wbw/010_081_008.mp3","charTypeName":"word"},{"id":64470,"position":9,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/010_081_010.mp3","charTypeName":"word"},{"id":64471,"position":10,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/010_081_011.mp3","charTypeName":"word"},{"id":64472,"position":11,"arabic":"سَيُبْطِلُهُۥٓ ۖ","translation":"শীঘ্রই ব্যর্থ করে দিবেন তা","audioUrl":"wbw/010_081_012.mp3","charTypeName":"word"},{"id":64474,"position":12,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/010_081_014.mp3","charTypeName":"word"},{"id":64475,"position":13,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/010_081_015.mp3","charTypeName":"word"},{"id":64476,"position":14,"arabic":"لَا","translation":"না","audioUrl":"wbw/010_081_016.mp3","charTypeName":"word"},{"id":64477,"position":15,"arabic":"يُصْلِحُ","translation":"পরিশুদ্ধ করেন","audioUrl":"wbw/010_081_017.mp3","charTypeName":"word"},{"id":64478,"position":16,"arabic":"عَمَلَ","translation":"কাজকে","audioUrl":"wbw/010_081_018.mp3","charTypeName":"word"},{"id":64479,"position":17,"arabic":"ٱلْمُفْسِدِينَ","translation":"বিপর্যয়সৃষ্টিকারীদের","audioUrl":"wbw/010_081_019.mp3","charTypeName":"word"},{"id":64480,"position":18,"arabic":"٨١","translation":"(৮১)","audioUrl":null,"charTypeName":"end"}]},{"number":82,"arabic":"وَيُحِقُّ ٱللَّهُ ٱلْحَقَّ بِكَلِمَٰتِهِۦ وَلَوْ كَرِهَ ٱلْمُجْرِمُونَ","translation":"whereas by His words God proves the truth to be true, however hateful this may be to those who are lost in sin!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1446.mp3","surahId":10,"words":[{"id":65229,"position":1,"arabic":"وَيُحِقُّ","translation":"এবং সত্যে পরিণত করবেন","audioUrl":"wbw/010_082_001.mp3","charTypeName":"word"},{"id":65230,"position":2,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/010_082_002.mp3","charTypeName":"word"},{"id":65231,"position":3,"arabic":"ٱلْحَقَّ","translation":"সত্যকে","audioUrl":"wbw/010_082_003.mp3","charTypeName":"word"},{"id":65232,"position":4,"arabic":"بِكَلِمَـٰتِهِۦ","translation":"মাধ্যমে বাণীর তাঁর","audioUrl":"wbw/010_082_004.mp3","charTypeName":"word"},{"id":65233,"position":5,"arabic":"وَلَوْ","translation":"এবং যদিও","audioUrl":"wbw/010_082_005.mp3","charTypeName":"word"},{"id":65234,"position":6,"arabic":"كَرِهَ","translation":"অপছন্দ করে (তা)","audioUrl":"wbw/010_082_006.mp3","charTypeName":"word"},{"id":65235,"position":7,"arabic":"ٱلْمُجْرِمُونَ","translation":"অপরাধীরা\"","audioUrl":"wbw/010_082_007.mp3","charTypeName":"word"},{"id":65236,"position":8,"arabic":"٨٢","translation":"(৮২)","audioUrl":null,"charTypeName":"end"}]},{"number":83,"arabic":"فَمَآ ءَامَنَ لِمُوسَىٰٓ إِلَّا ذُرِّيَّةٌۭ مِّن قَوْمِهِۦ عَلَىٰ خَوْفٍۢ مِّن فِرْعَوْنَ وَمَلَإِي۟هِمْ أَن يَفْتِنَهُمْ ۚ وَإِنَّ فِرْعَوْنَ لَعَالٍۢ فِى ٱلْأَرْضِ وَإِنَّهُۥ لَمِنَ ٱلْمُسْرِفِينَ","translation":"But none save a few of his people declared their faith in Moses, [while others held back] for fear of Pharaoh and their great ones, lest they persecute them: for, verily, Pharaoh was mighty on earth and was, verily, of those who are given to excesses.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1447.mp3","surahId":10,"words":[{"id":65532,"position":1,"arabic":"فَمَآ","translation":"এরপরও না","audioUrl":"wbw/010_083_001.mp3","charTypeName":"word"},{"id":65533,"position":2,"arabic":"ءَامَنَ","translation":"ঈমান আনলো","audioUrl":"wbw/010_083_002.mp3","charTypeName":"word"},{"id":65534,"position":3,"arabic":"لِمُوسَىٰٓ","translation":"প্রতি মূসার (সেদেশের লোক)","audioUrl":"wbw/010_083_003.mp3","charTypeName":"word"},{"id":65535,"position":4,"arabic":"إِلَّا","transla