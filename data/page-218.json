{"id":65552,"position":20,"arabic":"وَإِنَّهُۥ","translation":"এবং নিশ্চয়ই সে","audioUrl":"wbw/010_083_021.mp3","charTypeName":"word"},{"id":65553,"position":21,"arabic":"لَمِنَ","translation":"অবশ্যই অন্তর্ভুক্ত","audioUrl":"wbw/010_083_022.mp3","charTypeName":"word"},{"id":65554,"position":22,"arabic":"ٱلْمُسْرِفِينَ","translation":"সীমালঙ্ঘনকারীদের","audioUrl":"wbw/010_083_023.mp3","charTypeName":"word"},{"id":65555,"position":23,"arabic":"٨٣","translation":"(৮৩)","audioUrl":null,"charTypeName":"end"}]},{"number":84,"arabic":"وَقَالَ مُوسَىٰ يَٰقَوْمِ إِن كُنتُمْ ءَامَنتُم بِٱللَّهِ فَعَلَيْهِ تَوَكَّلُوٓا۟ إِن كُنتُم مُّسْلِمِينَ","translation":"And Moses said: \"O my people! If you believe in God, place your trust in Him -if you have [truly] surrendered yourselves unto Him!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1448.mp3","surahId":10,"words":[{"id":65926,"position":1,"arabic":"وَقَالَ","translation":"এবং বললো","audioUrl":"wbw/010_084_001.mp3","charTypeName":"word"},{"id":65927,"position":2,"arabic":"مُوسَىٰ","translation":"মূসা","audioUrl":"wbw/010_084_002.mp3","charTypeName":"word"},{"id":65928,"position":3,"arabic":"يَـٰقَوْمِ","translation":"\"হে আমার জাতি","audioUrl":"wbw/010_084_003.mp3","charTypeName":"word"},{"id":65929,"position":4,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/010_084_004.mp3","charTypeName":"word"},{"id":65930,"position":5,"arabic":"كُنتُمْ","translation":"থাকো তোমরা","audioUrl":"wbw/010_084_005.mp3","charTypeName":"word"},{"id":65931,"position":6,"arabic":"ءَامَنتُم","translation":"ঈমান এনে","audioUrl":"wbw/010_084_006.mp3","charTypeName":"word"},{"id":65932,"position":7,"arabic":"بِٱللَّهِ","translation":"উপর আল্লাহর","audioUrl":"wbw/010_084_007.mp3","charTypeName":"word"},{"id":65933,"position":8,"arabic":"فَعَلَيْهِ","translation":"তবে উপর তাঁরই","audioUrl":"wbw/010_084_008.mp3","charTypeName":"word"},{"id":65934,"position":9,"arabic":"تَوَكَّلُوٓا۟","translation":"তোমরা নির্ভর করো","audioUrl":"wbw/010_084_009.mp3","charTypeName":"word"},{"id":65935,"position":10,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/010_084_010.mp3","charTypeName":"word"},{"id":65936,"position":11,"arabic":"كُنتُم","translation":"হও তোমরা","audioUrl":"wbw/010_084_011.mp3","charTypeName":"word"},{"id":65937,"position":12,"arabic":"مُّسْلِمِينَ","translation":"আত্মসমর্পণকারী (অর্থাৎ মুসলমান)\"","audioUrl":"wbw/010_084_012.mp3","charTypeName":"word"},{"id":65938,"position":13,"arabic":"٨٤","translation":"(৮৪)","audioUrl":null,"charTypeName":"end"}]},{"number":85,"arabic":"فَقَالُوا۟ عَلَى ٱللَّهِ تَوَكَّلْنَا رَبَّنَا لَا تَجْعَلْنَا فِتْنَةًۭ لِّلْقَوْمِ ٱلظَّٰلِمِينَ","translation":"Whereupon they answered: \"In God have we placed our trust! O our Sustainer, make us not a plaything for evildoing folk,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1449.mp3","surahId":10,"words":[{"id":66293,"position":1,"arabic":"فَقَالُوا۟","translation":"অতঃপর তারা বললো","audioUrl":"wbw/010_085_001.mp3","charTypeName":"word"},{"id":66294,"position":2,"arabic":"عَلَى","translation":"\"উপর","audioUrl":"wbw/010_085_002.mp3","charTypeName":"word"},{"id":66295,"position":3,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/010_085_003.mp3","charTypeName":"word"},{"id":66296,"position":4,"arabic":"تَوَكَّلْنَا","translation":"নির্ভর করেছি আমরা","audioUrl":"wbw/010_085_004.mp3","charTypeName":"word"},{"id":66297,"position":5,"arabic":"رَبَّنَا","translation":"হে আমাদের রব","audioUrl":"wbw/010_085_005.mp3","charTypeName":"word"},{"id":66298,"position":6,"arabic":"لَا","translation":"না","audioUrl":"wbw/010_085_006.mp3","charTypeName":"word"},{"id":66299,"position":7,"arabic":"تَجْعَلْنَا","translation":"বানিয়ো আমাদের","audioUrl":"wbw/010_085_007.mp3","charTypeName":"word"},{"id":66300,"position":8,"arabic":"فِتْنَةًۭ","translation":"উৎপীড়নের পাত্র","audioUrl":"wbw/010_085_008.mp3","charTypeName":"word"},{"id":66301,"position":9,"arabic":"لِّلْقَوْمِ","translation":"জন্যে জাতির