087_001.mp3","charTypeName":"word"},{"id":66923,"position":2,"arabic":"إِلَىٰ","translation":"প্রতি","audioUrl":"wbw/010_087_002.mp3","charTypeName":"word"},{"id":66924,"position":3,"arabic":"مُوسَىٰ","translation":"মূসার","audioUrl":"wbw/010_087_003.mp3","charTypeName":"word"},{"id":66925,"position":4,"arabic":"وَأَخِيهِ","translation":"ও তার ভাইয়ের (প্রতি)","audioUrl":"wbw/010_087_004.mp3","charTypeName":"word"},{"id":66926,"position":5,"arabic":"أَن","translation":"যে","audioUrl":"wbw/010_087_005.mp3","charTypeName":"word"},{"id":66927,"position":6,"arabic":"تَبَوَّءَا","translation":"\"দু'জনে স্থাপন করো","audioUrl":"wbw/010_087_006.mp3","charTypeName":"word"},{"id":66928,"position":7,"arabic":"لِقَوْمِكُمَا","translation":"জন্যে তোমাদের দু'জনের জাতির","audioUrl":"wbw/010_087_007.mp3","charTypeName":"word"},{"id":66929,"position":8,"arabic":"بِمِصْرَ","translation":"মিশরে","audioUrl":"wbw/010_087_008.mp3","charTypeName":"word"},{"id":66930,"position":9,"arabic":"بُيُوتًۭا","translation":"কিছু ঘর","audioUrl":"wbw/010_087_009.mp3","charTypeName":"word"},{"id":66931,"position":10,"arabic":"وَٱجْعَلُوا۟","translation":"এবং তোমরা বানাও","audioUrl":"wbw/010_087_010.mp3","charTypeName":"word"},{"id":66932,"position":11,"arabic":"بُيُوتَكُمْ","translation":"ঘরগুলোকে তোমাদের","audioUrl":"wbw/010_087_011.mp3","charTypeName":"word"},{"id":66933,"position":12,"arabic":"قِبْلَةًۭ","translation":"ক্বিবলা","audioUrl":"wbw/010_087_012.mp3","charTypeName":"word"},{"id":66934,"position":13,"arabic":"وَأَقِيمُوا۟","translation":"এবং তোমরা প্রতিষ্ঠা করো","audioUrl":"wbw/010_087_013.mp3","charTypeName":"word"},{"id":66935,"position":14,"arabic":"ٱلصَّلَوٰةَ ۗ","translation":"সালাত","audioUrl":"wbw/010_087_014.mp3","charTypeName":"word"},{"id":66937,"position":15,"arabic":"وَبَشِّرِ","translation":"এবং সুসংবাদ দাও","audioUrl":"wbw/010_087_016.mp3","charTypeName":"word"},{"id":66938,"position":16,"arabic":"ٱلْمُؤْمِنِينَ","translation":"মু'মিনদেরকে\"","audioUrl":"wbw/010_087_017.mp3","charTypeName":"word"},{"id":66939,"position":17,"arabic":"٨٧","translation":"(৮৭)","audioUrl":null,"charTypeName":"end"}]},{"number":88,"arabic":"وَقَالَ مُوسَىٰ رَبَّنَآ إِنَّكَ ءَاتَيْتَ فِرْعَوْنَ وَمَلَأَهُۥ زِينَةًۭ وَأَمْوَٰلًۭا فِى ٱلْحَيَوٰةِ ٱلدُّنْيَا رَبَّنَا لِيُضِلُّوا۟ عَن سَبِيلِكَ ۖ رَبَّنَا ٱطْمِسْ عَلَىٰٓ أَمْوَٰلِهِمْ وَٱشْدُدْ عَلَىٰ قُلُوبِهِمْ فَلَا يُؤْمِنُوا۟ حَتَّىٰ يَرَوُا۟ ٱلْعَذَابَ ٱلْأَلِيمَ","translation":"And Moses prayed: \"O our Sustainer! Verily, splendour and riches hast Thou vouchsafed, in the life of this world, unto Pharaoh and his great ones-with the result, O our Sustainer, that they are leading [others] astray from Thy path! O our Sustainer! Wipe out their riches, and harden their hearts, so that they may not attain to faith ere they see the grievous suffering [that awaits them]!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1452.mp3","surahId":10,"words":[{"id":67125,"position":1,"arabic":"وَقَالَ","translation":"এবং বললো","audioUrl":"wbw/010_088_001.mp3","charTypeName":"word"},{"id":67126,"position":2,"arabic":"مُوسَىٰ","translation":"মূসা","audioUrl":"wbw/010_088_002.mp3","charTypeName":"word"},{"id":67127,"position":3,"arabic":"رَبَّنَآ","translation":"\"হে আমাদের রব","audioUrl":"wbw/010_088_003.mp3","charTypeName":"word"},{"id":67128,"position":4,"arabic":"إِنَّكَ","translation":"নিশ্চয়ই তুমি","audioUrl":"wbw/010_088_004.mp3","charTypeName":"word"},{"id":67129,"position":5,"arabic":"ءَاتَيْتَ","translation":"তুমি দিয়েছো","audioUrl":"wbw/010_088_005.mp3","charTypeName":"word"},{"id":67130,"position":6,"arabic":"فِرْعَوْنَ","translation":"ফিরাউনকে","audioUrl":"wbw/010_088_006.mp3","charTypeName":"word"},{"id":67131,"position":7,"arabic":"وَمَلَأَهُۥ","translation":"এবং পরিবারবর্গকে তার","audioUrl":"wbw/010_088_007.mp3","charTypeName":"word"},{"id":67132,"position":8,"arabic":"زِينَةًۭ","translation":"শোভা","audioUrl":"wbw/010_088_008.mp3","charTypeName":"word"},{"id":67133,"position":9,"arabic":"وَأ