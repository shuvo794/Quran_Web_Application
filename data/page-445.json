ame":"word"},{"id":65050,"position":10,"arabic":"فَيَكُونُ","translation":"তখনই হয়ে যায়","audioUrl":"wbw/036_082_010.mp3","charTypeName":"word"},{"id":65051,"position":11,"arabic":"٨٢","translation":"(৮২)","audioUrl":null,"charTypeName":"end"}]},{"number":83,"arabic":"فَسُبْحَٰنَ ٱلَّذِى بِيَدِهِۦ مَلَكُوتُ كُلِّ شَىْءٍۢ وَإِلَيْهِ تُرْجَعُونَ","translation":"Limitless, then, in His glory is He in whose hand rests the mighty dominion over all things; and unto Him you all will be brought back!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3788.mp3","surahId":36,"words":[{"id":65312,"position":1,"arabic":"فَسُبْحَـٰنَ","translation":"অতএব মহান পবিত্র","audioUrl":"wbw/036_083_001.mp3","charTypeName":"word"},{"id":65313,"position":2,"arabic":"ٱلَّذِى","translation":"(সেই সত্ত্বা) তিনিই","audioUrl":"wbw/036_083_002.mp3","charTypeName":"word"},{"id":65314,"position":3,"arabic":"بِيَدِهِۦ","translation":"যার হাতে (আছে)","audioUrl":"wbw/036_083_003.mp3","charTypeName":"word"},{"id":65315,"position":4,"arabic":"مَلَكُوتُ","translation":"সার্বভৌম ক্ষমতা","audioUrl":"wbw/036_083_004.mp3","charTypeName":"word"},{"id":65316,"position":5,"arabic":"كُلِّ","translation":"সব","audioUrl":"wbw/036_083_005.mp3","charTypeName":"word"},{"id":65317,"position":6,"arabic":"شَىْءٍۢ","translation":"জিনিসের","audioUrl":"wbw/036_083_006.mp3","charTypeName":"word"},{"id":65318,"position":7,"arabic":"وَإِلَيْهِ","translation":"এবং তাঁরই দিকে","audioUrl":"wbw/036_083_007.mp3","charTypeName":"word"},{"id":65319,"position":8,"arabic":"تُرْجَعُونَ","translation":"তোমাদেরকে ফিরিয়ে নেয়া হবে","audioUrl":"wbw/036_083_008.mp3","charTypeName":"word"},{"id":65320,"position":9,"arabic":"٨٣","translation":"(৮৩)","audioUrl":null,"charTypeName":"end"}]}]}