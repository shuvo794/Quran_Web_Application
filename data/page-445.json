{"id":445,"ayahs":[{"number":71,"arabic":"أَوَلَمْ يَرَوْا۟ أَنَّا خَلَقْنَا لَهُم مِّمَّا عَمِلَتْ أَيْدِينَآ أَنْعَٰمًۭا فَهُمْ لَهَا مَٰلِكُونَ","translation":"Are they, then, not aware that it is for them that We have created, among all the things which Our hands have wrought, the domestic animals of which they are [now] masters? –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3776.mp3","surahId":36,"words":[{"id":59964,"position":1,"arabic":"أَوَلَمْ","translation":"নি কি","audioUrl":"wbw/036_071_001.mp3","charTypeName":"word"},{"id":59965,"position":2,"arabic":"يَرَوْا۟","translation":"তারা দেখে","audioUrl":"wbw/036_071_002.mp3","charTypeName":"word"},{"id":59966,"position":3,"arabic":"أَنَّا","translation":"যে আমরা","audioUrl":"wbw/036_071_003.mp3","charTypeName":"word"},{"id":59967,"position":4,"arabic":"خَلَقْنَا","translation":"আমরা সৃষ্টি করেছি","audioUrl":"wbw/036_071_004.mp3","charTypeName":"word"},{"id":59968,"position":5,"arabic":"لَهُم","translation":"তাদের জন্যে","audioUrl":"wbw/036_071_005.mp3","charTypeName":"word"},{"id":59969,"position":6,"arabic":"مِّمَّا","translation":"সেসব থেকে যা","audioUrl":"wbw/036_071_006.mp3","charTypeName":"word"},{"id":59970,"position":7,"arabic":"عَمِلَتْ","translation":"সৃষ্টি করেছে","audioUrl":"wbw/036_071_007.mp3","charTypeName":"word"},{"id":59971,"position":8,"arabic":"أَيْدِينَآ","translation":"আমাদের হাতগুলো","audioUrl":"wbw/036_071_008.mp3","charTypeName":"word"},{"id":59972,"position":9,"arabic":"أَنْعَـٰمًۭا","translation":"(যেমন) গবাদি পশু","audioUrl":"wbw/036_071_009.mp3","charTypeName":"word"},{"id":59973,"position":10,"arabic":"فَهُمْ","translation":"এখন তারাই","audioUrl":"wbw/036_071_010.mp3","charTypeName":"word"},{"id":59974,"position":11,"arabic":"لَهَا","translation":"সেগুলোর","audioUrl":"wbw/036_071_011.mp3","charTypeName":"word"},{"id":59975,"position":12,"arabic":"مَـٰلِكُونَ","translation":"মালিক","audioUrl":"wbw/036_071_012.mp3","charTypeName":"word"},{"id":59976,"position":13,"arabic":"٧١","translation":"(৭১)","audioUrl":null,"charTypeName":"end"}]},{"number":72,"arabic":"وَذَلَّلْنَٰهَا لَهُمْ فَمِنْهَا رَكُوبُهُمْ وَمِنْهَا يَأْكُلُونَ","translation":"and that We have subjected them to men’s will, so that some of them they may use for riding and of some they may eat,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3777.mp3","surahId":36,"words":[{"id":60840,"position":1,"arabic":"وَذَلَّلْنَـٰهَا","translation":"এবং সেগুলোকে আমরা বশীভূত করেছি","audioUrl":"wbw/036_072_001.mp3","charTypeName":"word"},{"id":60841,"position":2,"arabic":"لَهُمْ","translation":"তাদের জন্যে","audioUrl":"wbw/036_072_002.mp3","charTypeName":"word"},{"id":60842,"position":3,"arabic":"فَمِنْهَا","translation":"অতঃপর (রয়েছে) সেগুলোর কিছু কিছু","audioUrl":"wbw/036_072_003.mp3","charTypeName":"word"},{"id":60843,"position":4,"arabic":"رَكُوبُهُمْ","translation":"তাদের বাহনও (যেমন উট)","audioUrl":"wbw/036_072_004.mp3","charTypeName":"word"},{"id":60844,"position":5,"arabic":"وَمِنْهَا","translation":"এবং সেগুলোর কিছু কিছু","audioUrl":"wbw/036_072_005.mp3","charTypeName":"word"},{"id":60845,"position":6,"arabic":"يَأْكُلُونَ","translation":"তারা আহারও করে","audioUrl":"wbw/036_072_006.mp3","charTypeName":"word"},{"id":60846,"position":7,"arabic":"٧٢","translation":"(৭২)","audioUrl":null,"charTypeName":"end"}]},{"number":73,"arabic":"وَلَهُمْ فِيهَا مَنَٰفِعُ وَمَشَارِبُ ۖ أَفَلَا يَشْكُرُونَ","translation":"and may have [yet other] benefits from them, and [milk] to drink? Will they not, then, be grateful? (","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3778.mp3","surahId":36,"words":[{"id":60926,"position":1,"arabic":"وَلَهُمْ","translation":"এবং তাদের জন্যে রয়েছে","audioUrl":"wbw/036_073_001.mp3","charTypeName":"word"},{"id":60927,"position":2,"arabic":"فِيهَا","translation":"সেগুলোর মধ্যে","audioUrl":"wbw/036_073_002.mp3","charTypeName":"word"},{"id":60928,"position":3,"arabic":"مَنَـٰفِعُ","translation":"(নানা রকম) উপকার","audioUrl":"wbw/036_073_003.mp3","charTypeName":"word"},{"id":60929,"position":4,"arabic":"وَمَشَارِبُ ۖ","translation":"এবং (নানা প্রকার) পানীয়","audioUrl":"wbw/036_073_004.mp3","charTypeName":"word"},{"id":60931,"position":5,"arabic":"أَفَلَا","translation":"তবুও কি না","audioUrl":"wbw/036_073_006.mp3","charTypeName":"word"},{"id":60932,"position":6,"arabic":"يَشْكُرُونَ","translation":"তারা কৃতজ্ঞ হবে","audioUrl":"wbw/036_073_007.mp3","charTypeName":"word"},{"id":60933,"position":7,"arabic":"٧٣","translation":"(৭৩)","audioUrl":null,"charTypeName":"end"}]},{"number":74,"arabic":"وَٱتَّخَذُوا۟ مِن دُونِ ٱللَّهِ ءَالِهَةًۭ لَّعَلَّهُمْ يُنصَرُونَ","translation":"But [nay,] they take to worshipping deities other than God, [hoping] to be succoured [by them, and not knowing that]","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3779.mp3","surahId":36,"words":[{"id":61426,"position":1,"arabic":"وَٱتَّخَذُوا۟","translation":"এবং (এ সত্ত্বেও) তারা গ্রহণ করেছে","audioUrl":"wbw/036_074_001.mp3","charTypeName":"word"},{"id":61427,"position":2,"arabic":"مِن","translation":"মধ্য হতে","audioUrl":"wbw/036_074_002.mp3","charTypeName":"word"},{"id":61428,"position":3,"arabic":"دُونِ","translation":"ছাড়া","audioUrl":"wbw/036_074_003.mp3","charTypeName":"word"},{"id":61429,"position":4,"arabic":"ٱللَّهِ","translation":"আল্লাহ","audioUrl":"wbw/036_074_004.mp3","charTypeName":"word"},{"id":61430,"position":5,"arabic":"ءَالِهَةًۭ","translation":"উপাস্যরূপে (অন্যদেরকে)","audioUrl":"wbw/036_074_005.mp3","charTypeName":"word"},{"id":61431,"position":6,"arabic":"لَّعَلَّهُمْ","translation":"তারা যাতে","audioUrl":"wbw/036_074_006.mp3","charTypeName":"word"},{"id":61432,"position":7,"arabic":"يُنصَرُونَ","translation":"তারা সাহায্য পাবে","audioUrl":"wbw/036_074_007.mp3","charTypeName":"word"},{"id":61433,"position":8,"arabic":"٧٤","translation":"(৭৪)","audioUrl":null,"charTypeName":"end"}]},{"number":75,"arabic":"لَا يَسْتَطِيعُونَ نَصْرَهُمْ وَهُمْ لَهُمْ جُندٌۭ مُّحْضَرُونَ","translation":"they are unable to succour their devotees, even though to them they may [appear to] be hosts drawn up [for succour].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3780.mp3","surahId":36,"words":[{"id":61951,"position":1,"arabic":"لَا","translation":"না","audioUrl":"wbw/036_075_001.mp3","charTypeName":"word"},{"id":61952,"position":2,"arabic":"يَسْتَطِيعُونَ","translation":"তারা সমর্থ হবে","audioUrl":"wbw/036_075_002.mp3","charTypeName":"word"},{"id":61953,"position":3,"arabic":"نَصْرَهُمْ","translation":"তাদের সাহায্য করতে","audioUrl":"wbw/036_075_003.mp3","charTypeName":"word"},{"id":61954,"position":4,"arabic":"وَهُمْ","translation":"বরং তারাই (হয়ে আছে)","audioUrl":"wbw/036_075_004.mp3","charTypeName":"word"},{"id":61955,"position":5,"arabic":"لَهُمْ","translation":"তাদের জন্যে","audioUrl":"wbw/036_075_005.mp3","charTypeName":"word"},{"id":61956,"position":6,"arabic":"جُندٌۭ","translation":"সৈন্য (রক্ষাকারী রূপে)","audioUrl":"wbw/036_075_006.mp3","charTypeName":"word"},{"id":61957,"position":7,"arabic":"مُّحْضَرُونَ","translation":"সদা উপস্থিত","audioUrl":"wbw/036_075_007.mp3","charTypeName":"word"},{"id":61958,"position":8,"arabic":"٧٥","translation":"(৭৫)","audioUrl":null,"charTypeName":"end"}]},{"number":76,"arabic":"فَلَا يَحْزُنكَ قَوْلُهُمْ ۘ إِنَّا نَعْلَمُ مَا يُسِرُّونَ وَمَا يُعْلِنُونَ","translation":"However, be not grieved by the sayings of those [who deny the truth]: verily, We know all that they keep secret as well as all that they bring into the open.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3781.mp3","surahId":36,"words":[{"id":62457,"position":1,"arabic":"فَلَا","translation":"কাজেই না (যেন)","audioUrl":"wbw/036_076_001.mp3","charTypeName":"word"},{"id":62458,"position":2,"arabic":"يَحْزُنكَ","translation":"তোমাকে দুঃখ দেয়","audioUrl":"wbw/036_076_002.mp3","charTypeName":"word"},{"id":62459,"position":3,"arabic":"قَوْلُهُمْ ۘ","translation":"তাদের কথা","audioUrl":"wbw/036_076_003.mp3","charTypeName":"word"},{"id":62461,"position":4,"arabic":"إِنَّا","translation":"আমরা নিশ্চয়ই","audioUrl":"wbw/036_076_005.mp3","charTypeName":"word"},{"id":62462,"position":5,"arabic":"نَعْلَمُ","translation":"জানি আমরা","audioUrl":"wbw/036_076_006.mp3","charTypeName":"word"},{"id":62463,"position":6,"arabic":"مَا","translation":"যা","audioUrl":"wbw/036_076_007.mp3","charTypeName":"word"},{"id":62464,"position":7,"arabic":"يُسِرُّونَ","translation":"তারা গোপন করে","audioUrl":"wbw/036_076_008.mp3","charTypeName":"word"},{"id":62465,"position":8,"arabic":"وَمَا","translation":"আর যা","audioUrl":"wbw/036_076_009.mp3","charTypeName":"word"},{"id":62466,"position":9,"arabic":"يُعْلِنُونَ","translation":"তারা প্রকাশ করে","audioUrl":"wbw/036_076_010.mp3","charTypeName":"word"},{"id":62467,"position":10,"arabic":"٧٦","translation":"(৭৬)","audioUrl":null,"charTypeName":"end"}]},{"number":77,"arabic":"أَوَلَمْ يَرَ ٱلْإِنسَٰنُ أَنَّا خَلَقْنَٰهُ مِن نُّطْفَةٍۢ فَإِذَا هُوَ خَصِيمٌۭ مُّبِينٌۭ","translation":"IS MAN, then, not aware that it is We who create him out of a [mere] drop of sperm - whereupon, lo! he shows himself endowed with the power to think and to argue?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3782.mp3","surahId":36,"words":[{"id":62862,"position":1,"arabic":"أَوَلَمْ","translation":"নি কি","audioUrl":"wbw/036_077_001.mp3","charTypeName":"word"},{"id":62863,"position":2,"arabic":"يَرَ","translation":"দেখে","audioUrl":"wbw/036_077_002.mp3","charTypeName":"word"},{"id":62864,"position":3,"arabic":"ٱلْإِنسَـٰنُ","translation":"মানুষ","audioUrl":"wbw/036_077_003.mp3","charTypeName":"word"},{"id":62865,"position":4,"arabic":"أَنَّا","translation":"যে আমরা","audioUrl":"wbw/036_077_004.mp3","charTypeName":"word"},{"id":62866,"position":5,"arabic":"خَلَقْنَـٰهُ","translation":"তাকে আমরা সৃষ্টি করেছি","audioUrl":"wbw/036_077_005.mp3","charTypeName":"word"},{"id":62867,"position":6,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/036_077_006.mp3","charTypeName":"word"},{"id":62868,"position":7,"arabic":"نُّطْفَةٍۢ","translation":"শুক্রবিন্দু","audioUrl":"wbw/036_077_007.mp3","charTypeName":"word"},{"id":62869,"position":8,"arabic":"فَإِذَا","translation":"অথচ পরে","audioUrl":"wbw/036_077_008.mp3","charTypeName":"word"},{"id":62870,"position":9,"arabic":"هُوَ","translation":"সে (হয়েছে)","audioUrl":"wbw/036_077_009.mp3","charTypeName":"word"},{"id":62871,"position":10,"arabic":"خَصِيمٌۭ","translation":"ঝগড়াটে","audioUrl":"wbw/036_077_010.mp3","charTypeName":"word"},{"id":62872,"position":11,"arabic":"مُّبِينٌۭ","translation":"প্রকাশ্য","audioUrl":"wbw/036_077_011.mp3","charTypeName":"word"},{"id":62873,"position":12,"arabic":"٧٧","translation":"(৭৭)","audioUrl":null,"charTypeName":"end"}]},{"number":78,"arabic":"وَضَرَبَ لَنَا مَثَلًۭا وَنَسِىَ خَلْقَهُۥ ۖ قَالَ مَن يُحْىِ ٱلْعِظَٰمَ وَهِىَ رَمِيمٌۭ","translation":"And [now] he [argues about Us, and] thinks of Us in terms of comparison, and is oblivious of how he himself was created! [And so] he says, “Who could give life to bones that have crumbled to dust?”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3783.mp3","surahId":36,"words":[{"id":63505,"position":1,"arabic":"وَضَرَبَ","translation":"এবং পেশ করে","audioUrl":"wbw/036_078_001.mp3","charTypeName":"word"},{"id":63506,"position":2,"arabic":"لَنَا","translation":"আমাদের জন্যে","audioUrl":"wbw/036_078_002.mp3","charTypeName":"word"},{"id":63507,"position":3,"arabic":"مَثَلًۭا","translation":"উপমা","audioUrl":"wbw/036_078_003.mp3","charTypeName":"word"},{"id":63508,"position":4,"arabic":"وَنَسِىَ","translation":"অথচ সে ভুলে যায়","audioUrl":"wbw/036_078_004.mp3","charTypeName":"word"},{"id":63509,"position":5,"arabic":"خَلْقَهُۥ ۖ","translation":"তার সৃষ্টিকে","audioUrl":"wbw/036_078_005.mp3","charTypeName":"word"},{"id":63511,"position":6,"arabic":"قَالَ","translation":"সে বলে","audioUrl":"wbw/036_078_007.mp3","charTypeName":"word"},{"id":63512,"position":7,"arabic":"مَن","translation":"\"কে","audioUrl":"wbw/036_078_008.mp3","charTypeName":"word"},{"id":63513,"position":8,"arabic":"يُحْىِ","translation":"প্রাণ দিবে","audioUrl":"wbw/036_078_009.mp3","charTypeName":"word"},{"id":63514,"position":9,"arabic":"ٱلْعِظَـٰمَ","translation":"হাড়ে","audioUrl":"wbw/036_078_010.mp3","charTypeName":"word"},{"id":63515,"position":10,"arabic":"وَهِىَ","translation":"যখন তা (হয়ে যাবে)","audioUrl":"wbw/036_078_011.mp3","charTypeName":"word"},{"id":63516,"position":11,"arabic":"رَمِيمٌۭ","translation":"পচাগলা জরাজীর্ণ\"","audioUrl":"wbw/036_078_012.mp3","charTypeName":"word"},{"id":63517,"position":12,"arabic":"٧٨","translation":"(৭৮)","audioUrl":null,"charTypeName":"end"}]},{"number":79,"arabic":"قُلْ يُحْيِيهَا ٱلَّذِىٓ أَنشَأَهَآ أَوَّلَ مَرَّةٍۢ ۖ وَهُوَ بِكُلِّ خَلْقٍ عَلِيمٌ","translation":"Say: “He who brought them into being in the first instance will give them life [once again], seeing that He has full knowledge of every act of creation:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3784.mp3","surahId":36,"words":[{"id":63978,"position":1,"arabic":"قُلْ","translation":"বলো (তাদেরকে)","audioUrl":"wbw/036_079_001.mp3","charTypeName":"word"},{"id":63979,"position":2,"arabic":"يُحْيِيهَا","translation":"\"তাতে প্রাণ দিবেন","audioUrl":"wbw/036_079_002.mp3","charTypeName":"word"},{"id":63980,"position":3,"arabic":"ٱلَّذِىٓ","translation":"(তিনিই) যিনি","audioUrl":"wbw/036_079_003.mp3","charTypeName":"word"},{"id":63981,"position":4,"arabic":"أَنشَأَهَآ","translation":"তা সৃষ্টি করেছেন","audioUrl":"wbw/036_079_004.mp3","charTypeName":"word"},{"id":63982,"position":5,"arabic":"أَوَّلَ","translation":"প্রথম","audioUrl":"wbw/036_079_005.mp3","charTypeName":"word"},{"id":63983,"position":6,"arabic":"مَرَّةٍۢ ۖ","translation":"বার","audioUrl":"wbw/036_079_006.mp3","charTypeName":"word"},{"id":63985,"position":7,"arabic":"وَهُوَ","translation":"এবং তিনি","audioUrl":"wbw/036_079_008.mp3","charTypeName":"word"},{"id":63986,"position":8,"arabic":"بِكُلِّ","translation":"সম্পর্কে সবকিছু","audioUrl":"wbw/036_079_009.mp3","charTypeName":"word"},{"id":63987,"position":9,"arabic":"خَلْقٍ","translation":"(তাঁর) সৃষ্টির","audioUrl":"wbw/036_079_010.mp3","charTypeName":"word"},{"id":63988,"position":10,"arabic":"عَلِيمٌ","translation":"সম্যক অবগত\"","audioUrl":"wbw/036_079_011.mp3","charTypeName":"word"},{"id":63989,"position":11,"arabic":"٧٩","translation":"(৭৯)","audioUrl":null,"charTypeName":"end"}]},{"number":80,"arabic":"ٱلَّذِى جَعَلَ لَكُم مِّنَ ٱلشَّجَرِ ٱلْأَخْضَرِ نَارًۭا فَإِذَآ أَنتُم مِّنْهُ تُوقِدُونَ","translation":"He who produces for you fire out of the green tree, so that, lo! you kindle [your fires] therewith.”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3785.mp3","surahId":36,"words":[{"id":64227,"position":1,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/036_080_001.mp3","charTypeName":"word"},{"id":64228,"position":2,"arabic":"جَعَلَ","translation":"সৃষ্টি করেছেন","audioUrl":"wbw/036_080_002.mp3","charTypeName":"word"},{"id":64229,"position":3,"arabic":"لَكُم","translation":"তোমাদের জন্যে","audioUrl":"wbw/036_080_003.mp3","charTypeName":"word"},{"id":64230,"position":4,"arabic":"مِّنَ","translation":"থেকে","audioUrl":"wbw/036_080_004.mp3","charTypeName":"word"},{"id":64231,"position":5,"arabic":"ٱلشَّجَرِ","translation":"গাছ","audioUrl":"wbw/036_080_005.mp3","charTypeName":"word"},{"id":64232,"position":6,"arabic":"ٱلْأَخْضَرِ","translation":"সবুজ","audioUrl":"wbw/036_080_006.mp3","charTypeName":"word"},{"id":64233,"position":7,"arabic":"نَارًۭا","translation":"আগুন","audioUrl":"wbw/036_080_007.mp3","charTypeName":"word"},{"id":64234,"position":8,"arabic":"فَإِذَآ","translation":"অতঃপর","audioUrl":"wbw/036_080_008.mp3","charTypeName":"word"},{"id":64235,"position":9,"arabic":"أَنتُم","translation":"তোমরা","audioUrl":"wbw/036_080_009.mp3","charTypeName":"word"},{"id":64236,"position":10,"arabic":"مِّنْهُ","translation":"তা থেকে","audioUrl":"wbw/036_080_010.mp3","charTypeName":"word"},{"id":64237,"position":11,"arabic":"تُوقِدُونَ","translation":"আগুন জ্বালো","audioUrl":"wbw/036_080_011.mp3","charTypeName":"word"},{"id":64238,"position":12,"arabic":"٨٠","translation":"(৮০)","audioUrl":null,"charTypeName":"end"}]},{"number":81,"arabic":"أَوَلَيْسَ ٱلَّذِى خَلَقَ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضَ بِقَٰدِرٍ عَلَىٰٓ أَن يَخْلُقَ مِثْلَهُم ۚ بَلَىٰ وَهُوَ ٱلْخَلَّٰقُ ٱلْعَلِيمُ","translation":"Is, then, He who has created the heavens and the earth not able to create [anew] the like of those [who have died]? Yea, indeed - for He alone is the all-knowing Crea­tor:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3786.mp3","surahId":36,"words":[{"id":64623,"position":1,"arabic":"أَوَلَيْسَ","translation":"নন কি (সেই আল্লাহ)","audioUrl":"wbw/036_081_001.mp3","charTypeName":"word"},{"id":64624,"position":2,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/036_081_002.mp3","charTypeName":"word"},{"id":64625,"position":3,"arabic":"خَلَقَ","translation":"সৃষ্টি করেছেন","audioUrl":"wbw/036_081_003.mp3","charTypeName":"word"},{"id":64626,"position":4,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশ সমূহ","audioUrl":"wbw/036_081_004.mp3","charTypeName":"word"},{"id":64627,"position":5,"arabic":"وَٱلْأَرْضَ","translation":"ও পৃথিবীকে","audioUrl":"wbw/036_081_005.mp3","charTypeName":"word"},{"id":64628,"position":6,"arabic":"بِقَـٰدِرٍ","translation":"সক্ষম","audioUrl":"wbw/036_081_006.mp3","charTypeName":"word"},{"id":64629,"position":7,"arabic":"عَلَىٰٓ","translation":"এক্ষেত্রে","audioUrl":"wbw/036_081_007.mp3","charTypeName":"word"},{"id":64630,"position":8,"arabic":"أَن","translation":"যে","audioUrl":"wbw/036_081_008.mp3","charTypeName":"word"},{"id":64631,"position":9,"arabic":"يَخْلُقَ","translation":"সৃষ্টি করবেন","audioUrl":"wbw/036_081_009.mp3","charTypeName":"word"},{"id":64632,"position":10,"arabic":"مِثْلَهُم ۚ","translation":"তাদের মতো","audioUrl":"wbw/036_081_010.mp3","charTypeName":"word"},{"id":64634,"position":1