{"id":285,"ayahs":[{"number":28,"arabic":"وَإِمَّا تُعْرِضَنَّ عَنْهُمُ ٱبْتِغَآءَ رَحْمَةٍۢ مِّن رَّبِّكَ تَرْجُوهَا فَقُل لَّهُمْ قَوْلًۭا مَّيْسُورًۭا","translation":"And if thou [must] turn aside from those [that are in want, because thou thyself art] seeking to obtain thy Sustainer's grace and hoping for it, at least speak unto them with gentle speech.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2057.mp3","surahId":17,"words":[{"id":30527,"position":1,"arabic":"وَإِمَّا","translation":"এবং যদি","audioUrl":"wbw/017_028_001.mp3","charTypeName":"word"},{"id":30528,"position":2,"arabic":"تُعْرِضَنَّ","translation":"পাশ কাটাতে চাও","audioUrl":"wbw/017_028_002.mp3","charTypeName":"word"},{"id":30529,"position":3,"arabic":"عَنْهُمُ","translation":"থেকে তাদের","audioUrl":"wbw/017_028_003.mp3","charTypeName":"word"},{"id":30530,"position":4,"arabic":"ٱبْتِغَآءَ","translation":"সন্ধানে","audioUrl":"wbw/017_028_004.mp3","charTypeName":"word"},{"id":30531,"position":5,"arabic":"رَحْمَةٍۢ","translation":"অনুগ্রহের","audioUrl":"wbw/017_028_005.mp3","charTypeName":"word"},{"id":30532,"position":6,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/017_028_006.mp3","charTypeName":"word"},{"id":30533,"position":7,"arabic":"رَّبِّكَ","translation":"তোমার রবের","audioUrl":"wbw/017_028_007.mp3","charTypeName":"word"},{"id":30534,"position":8,"arabic":"تَرْجُوهَا","translation":"তা তোমরা আশা করো","audioUrl":"wbw/017_028_008.mp3","charTypeName":"word"},{"id":30535,"position":9,"arabic":"فَقُل","translation":"তখন বলো","audioUrl":"wbw/017_028_009.mp3","charTypeName":"word"},{"id":30536,"position":10,"arabic":"لَّهُمْ","translation":"তাদেরকে","audioUrl":"wbw/017_028_010.mp3","charTypeName":"word"},{"id":30537,"position":11,"arabic":"قَوْلًۭا","translation":"কথা","audioUrl":"wbw/017_028_011.mp3","charTypeName":"word"},{"id":30538,"position":12,"arabic":"مَّيْسُورًۭا","translation":"সহজভাবে","audioUrl":"wbw/017_028_012.mp3","charTypeName":"word"},{"id":30539,"position":13,"arabic":"٢٨","translation":"(২৮)","audioUrl":null,"charTypeName":"end"}]},{"number":29,"arabic":"وَلَا تَجْعَلْ يَدَكَ مَغْلُولَةً إِلَىٰ عُنُقِكَ وَلَا تَبْسُطْهَا كُلَّ ٱلْبَسْطِ فَتَقْعُدَ مَلُومًۭا مَّحْسُورًا","translation":"And neither allow thy hand to remain shackled to thy neck, nor stretch it forth to the utmost limit [of thy capacity], lest thou find thyself blamed [by thy dependants], or even destitute.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2058.mp3","surahId":17,"words":[{"id":31513,"position":1,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/017_029_001.mp3","charTypeName":"word"},{"id":31514,"position":2,"arabic":"تَجْعَلْ","translation":"রেখো","audioUrl":"wbw/017_029_002.mp3","charTypeName":"word"},{"id":31515,"position":3,"arabic":"يَدَكَ","translation":"তোমার হাত","audioUrl":"wbw/017_029_003.mp3","charTypeName":"word"},{"id":31516,"position":4,"arabic":"مَغْلُولَةً","translation":"আবদ্ধ","audioUrl":"wbw/017_029_004.mp3","charTypeName":"word"},{"id":31517,"position":5,"arabic":"إِلَىٰ","translation":"সাথে","audioUrl":"wbw/017_029_005.mp3","charTypeName":"word"},{"id":31518,"position":6,"arabic":"عُنُقِكَ","translation":"তোমার গলার","audioUrl":"wbw/017_029_006.mp3","charTypeName":"word"},{"id":31519,"position":7,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/017_029_007.mp3","charTypeName":"word"},{"id":31520,"position":8,"arabic":"تَبْسُطْهَا","translation":"তা প্রসারিত করো","audioUrl":"wbw/017_029_008.mp3","charTypeName":"word"},{"id":31521,"position":9,"arabic":"كُلَّ","translation":"সম্পূর্ণ","audioUrl":"wbw/017_029_009.mp3","charTypeName":"word"},{"id":31522,"position":10,"arabic":"ٱلْبَسْطِ","translation":"প্রসারিত","audioUrl":"wbw/017_029_010.mp3","charTypeName":"word"},{"id":31523,"position":11,"arabic":"فَتَقْعُدَ","translation":"তাহ'লে বসে পড়বে","audioUrl":"wbw/017_029_011.mp3","charTypeName":"word"},{"id":31524,"position":12,"arabic":"مَلُومًۭا","translation":"নিন্দিত","audioUrl":"wbw/017_029_012.mp3","charTypeName":"word"},{"id":31525,"position":13,"arabic":"مَّحْسُورًا","translation":"অক্ষম অবস্হায়","audioUrl":"wbw/017_029_013.mp3","charTypeName":"word"},{"id":31526,"position":14,"arabic":"٢٩","translation":"(২৯)","audioUrl":null,"charTypeName":"end"}]},{"number":30,"arabic":"إِنَّ رَبَّكَ يَبْسُطُ ٱلرِّزْقَ لِمَن يَشَآءُ وَيَقْدِرُ ۚ إِنَّهُۥ كَانَ بِعِبَادِهِۦ خَبِيرًۢا بَصِيرًۭا","translation":"Behold, thy Sustainer grants abundant sustenance, or gives it in scant measure, unto whomever He wills: verily, fully aware is He of [the needs of] His creatures, and sees them all.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2059.mp3","surahId":17,"words":[{"id":32441,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/017_030_001.mp3","charTypeName":"word"},{"id":32442,"position":2,"arabic":"رَبَّكَ","translation":"তোমার রব","audioUrl":"wbw/017_030_002.mp3","charTypeName":"word"},{"id":32443,"position":3,"arabic":"يَبْسُطُ","translation":"প্রশস্ত করেন","audioUrl":"wbw/017_030_003.mp3","charTypeName":"word"},{"id":32444,"position":4,"arabic":"ٱلرِّزْقَ","translation":"জীবনের উপকরণ","audioUrl":"wbw/017_030_004.mp3","charTypeName":"word"},{"id":32445,"position":5,"arabic":"لِمَن","translation":"জন্যে যার","audioUrl":"wbw/017_030_005.mp3","charTypeName":"word"},{"id":32446,"position":6,"arabic":"يَشَآءُ","translation":"ইচ্ছে করেন","audioUrl":"wbw/017_030_006.mp3","charTypeName":"word"},{"id":32447,"position":7,"arabic":"وَيَقْدِرُ ۚ","translation":"এবং পরিমিত করেন","audioUrl":"wbw/017_030_007.mp3","charTypeName":"word"},{"id":32449,"position":8,"arabic":"إِنَّهُۥ","translation":"নিশ্চয়ই তিনি","audioUrl":"wbw/017_030_009.mp3","charTypeName":"word"},{"id":32450,"position":9,"arabic":"كَانَ","translation":"হলেন","audioUrl":"wbw/017_030_010.mp3","charTypeName":"word"},{"id":32451,"position":10,"arabic":"بِعِبَادِهِۦ","translation":"সম্পর্কে দাস তাঁর","audioUrl":"wbw/017_030_011.mp3","charTypeName":"word"},{"id":32452,"position":11,"arabic":"خَبِيرًۢا","translation":"খুব অবহিত","audioUrl":"wbw/017_030_012.mp3","charTypeName":"word"},{"id":32453,"position":12,"arabic":"بَصِيرًۭا","translation":"সর্বদ্রষ্টা","audioUrl":"wbw/017_030_013.mp3","charTypeName":"word"},{"id":32454,"position":13,"arabic":"٣٠","translation":"(৩০)","audioUrl":null,"charTypeName":"end"}]},{"number":31,"arabic":"وَلَا تَقْتُلُوٓا۟ أَوْلَٰدَكُمْ خَشْيَةَ إِمْلَٰقٍۢ ۖ نَّحْنُ نَرْزُقُهُمْ وَإِيَّاكُمْ ۚ إِنَّ قَتْلَهُمْ كَانَ خِطْـًۭٔا كَبِيرًۭا","translation":"Hence, do not kill your children for fear of poverty: it is We who shall provide sustenance for them as well as for you. Verily, killing them is a great sin.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2060.mp3","surahId":17,"words":[{"id":33289,"position":1,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/017_031_001.mp3","charTypeName":"word"},{"id":33290,"position":2,"arabic":"تَقْتُلُوٓا۟","translation":"হত্যা করো তোমরা","audioUrl":"wbw/017_031_002.mp3","charTypeName":"word"},{"id":33291,"position":3,"arabic":"أَوْلَـٰدَكُمْ","translation":"সন্তানদেরকে তোমাদের","audioUrl":"wbw/017_031_003.mp3","charTypeName":"word"},{"id":33292,"position":4,"arabic":"خَشْيَةَ","translation":"ভয়ে","audioUrl":"wbw/017_031_004.mp3","charTypeName":"word"},{"id":33293,"position":5,"arabic":"إِمْلَـٰقٍۢ ۖ","translation":"দারিদ্র্যের","audioUrl":"wbw/017_031_005.mp3","charTypeName":"word"},{"id":33295,"position":6,"arabic":"نَّحْنُ","translation":"আমরা","audioUrl":"wbw/017_031_007.mp3","charTypeName":"word"},{"id":33296,"position":7,"arabic":"نَرْزُقُهُمْ","translation":"জীবিকা‌ দিই তাদের","audioUrl":"wbw/017_031_008.mp3","charTypeName":"word"},{"id":33297,"position":8,"arabic":"وَإِيَّاكُمْ ۚ","translation":"এবং তোমাদেরকেও","audioUrl":"wbw/017_031_009.mp3","charTypeName":"word"},{"id":33299,"position":9,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/017_031_011.mp3","charTypeName":"word"},{"id":33300,"position":10,"arabic":"قَتْلَهُمْ","translation":"হত্যা করা তাদের","audioUrl":"wbw/017_031_012.mp3","charTypeName":"word"},{"id":33301,"position":11,"arabic":"كَانَ","translation":"হলো","audioUrl":"wbw/017_031_013.mp3","charTypeName":"word"},{"id":33302,"position":12,"arabic":"خِطْـًۭٔا","translation":"পাপ","audioUrl":"wbw/017_031_014.mp3","charTypeName":"word"},{"id":33303,"position":13,"arabic":"كَبِيرًۭا","translation":"মহা","audioUrl":"wbw/017_031_015.mp3","charTypeName":"word"},{"id":33304,"position":14,"arabic":"٣١","translation":"(৩১)","audioUrl":null,"charTypeName":"end"}]},{"number":32,"arabic":"وَلَا تَقْرَبُوا۟ ٱلزِّنَىٰٓ ۖ إِنَّهُۥ كَانَ فَٰحِشَةًۭ وَسَآءَ سَبِيلًۭا","translation":"And do not commit adultery -for, behold, it is an abomination and an evil way.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2061.mp3","surahId":17,"words":[{"id":34313,"position":1,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/017_032_001.mp3","charTypeName":"word"},{"id":34314,"position":2,"arabic":"تَقْرَبُوا۟","translation":"তোমরা নিকটে যেয়ো","audioUrl":"wbw/017_032_002.mp3","charTypeName":"word"},{"id":34315,"position":3,"arabic":"ٱلزِّنَىٰٓ ۖ","translation":"জিনার","audioUrl":"wbw/017_032_003.mp3","charTypeName":"word"},{"id":34317,"position":4,"arabic":"إِنَّهُۥ","translation":"নিশ্চয়ই তা","audioUrl":"wbw/017_032_005.mp3","charTypeName":"word"},{"id":34318,"position":5,"arabic":"كَانَ","translation":"হলো","audioUrl":"wbw/017_032_006.mp3","charTypeName":"word"},{"id":34319,"position":6,"arabic":"فَـٰحِشَةًۭ","translation":"অশ্লীল কাজ","audioUrl":"wbw/017_032_007.mp3","charTypeName":"word"},{"id":34320,"position":7,"arabic":"وَسَآءَ","translation":"ও নিকৃষ্ট","audioUrl":"wbw/017_032_008.mp3","charTypeName":"word"},{"id":34321,"position":8,"arabic":"سَبِيلًۭا","translation":"পথ","audioUrl":"wbw/017_032_009.mp3","charTypeName":"word"},{"id":34322,"position":9,"arabic":"٣٢","translation":"(৩২)","audioUrl":null,"charTypeName":"end"}]},{"number":33,"arabic":"وَلَا تَقْتُلُوا۟ ٱلنَّفْسَ ٱلَّتِى حَرَّمَ ٱللَّهُ إِلَّا بِٱلْحَقِّ ۗ وَمَن قُتِلَ مَظْلُومًۭا فَقَدْ جَعَلْنَا لِوَلِيِّهِۦ سُلْطَٰنًۭا فَلَا يُسْرِف فِّى ٱلْقَتْلِ ۖ إِنَّهُۥ كَانَ مَنصُورًۭا","translation":"And do not take any human being's life -[the life] which God has willed to be, sacred-otherwise than in [the pursuit of] justice. Hence, if anyone has been slain wrongfully, We have empowered the defender of his rights [to exact a just retribution]; but even so, let him not exceed the bounds of equity in [retributive] killing. [And as for him who has been slain wrongfully -] behold, he is indeed succoured [by God]!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2062.mp3","surahId":17,"words":[{"id":35219,"position":1,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/017_033_001.mp3","charTypeName":"word"},{"id":35220,"position":2,"arabic":"تَقْتُلُوا۟","translation":"তোমরা হত্যা করো","audioUrl":"wbw/017_033_002.mp3","charTypeName":"word"},{"id":35221,"position":3,"arabic":"ٱلنَّفْسَ","translation":"কোনো প্রাণকে","audioUrl":"wbw/017_033_003.mp3","charTypeName":"word"},{"id":35222,"position":4,"arabic":"ٱلَّتِى","translation":"যা","audioUrl":"wbw/017_033_004.mp3","charTypeName":"word"},{"id":35223,"position":5,"arabic":"حَرَّمَ","translation":"নিষিদ্ধ করেছেন","audioUrl":"wbw/017_033_005.mp3","charTypeName":"word"},{"id":35224,"position":6,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/017_033_006.mp3","charTypeName":"word"},{"id":35225,"position":7,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/017_033_007.mp3","charTypeName":"word"},{"id":35226,"position":8,"arabic":"بِٱلْحَقِّ ۗ","translation":"কারণ যথার্থ","audioUrl":"wbw/017_033_008.mp3","charTypeName":"word"},{"id":35228,"position":9,"arabic":"وَمَن","translation":"এবং যে","audioUrl":"wbw/017_033_010.mp3","charTypeName":"word"},{"id":35229,"position":10,"arabic":"قُتِلَ","translation":"নিহত হয়েছে","audioUrl":"wbw/017_033_011.mp3","charTypeName":"word"},{"id":35230,"position":11,"arabic":"مَظْلُومًۭا","translation":"নির্যাতিত হয়ে","audioUrl":"wbw/017_033_012.mp3","charTypeName":"word"},{"id":35231,"position":12,"arabic":"فَقَدْ","translation":"নিশ্চয়ই সেক্ষেত্রে","audioUrl":"wbw/017_033_013.mp3","charTypeName":"word"},{"id":35232,"position":13,"arabic":"جَعَلْنَا","translation":"আমরা দিয়েছি","audioUrl":"wbw/017_033_014.mp3","charTypeName":"word"},{"id":35233,"position":14,"arabic":"لِوَلِيِّهِۦ","translation":"তার উত্তরাধিকারীর","audioUrl":"wbw/017_033_015.mp3","charTypeName":"word"},{"id":35234,"position":15,"arabic":"سُلْطَـٰنًۭا","translation":"অধিকার","audioUrl":"wbw/017_033_016.mp3","charTypeName":"word"},{"id":35235,"position":16,"arabic":"فَلَا","translation":"সুতরাং না (যেন)","audioUrl":"wbw/017_033_017.mp3","charTypeName":"word"},{"id":35236,"position":17,"arabic":"يُسْرِف","translation":"সে সীমালঙ্ঘন করে","audioUrl":"wbw/017_033_018.mp3","charTypeName":"word"},{"id":35237,"position":18,"arabic":"فِّى","translation":"ব্যাপারে","audioUrl":"wbw/017_033_019.mp3","charTypeName":"word"},{"id":35238,"position":19,"arabic":"ٱلْقَتْلِ ۖ","translation":"হত্যার","audioUrl":"wbw/017_033_020.mp3","charTypeName":"word"},{"id":35240,"position":20,"arabic":"إِنَّهُۥ","translation":"নিশ্চয়ই সে","audioUrl":"wbw/017_033_022.mp3","charTypeName":"word"},{"id":35241,"position":21,"arabic":"كَانَ","translation":"হলো","audioUrl":"wbw/017_033_023.mp3","charTypeName":"word"},{"id":35242,"position":22,"arabic":"مَنصُورًۭا","translation":"সাহায্যপ্রাপ্ত","audioUrl":"wbw/017_033_024.mp3","charTypeName":"word"},{"id":35243,"position":23,"arabic":"٣٣","translation":"(৩৩)","audioUrl":null,"charTypeName":"end"}]},{"number":34,"arabic":"وَلَا تَقْرَبُوا۟ مَالَ ٱلْيَتِيمِ إِلَّا بِٱلَّتِى هِىَ أَحْسَنُ حَتَّىٰ يَبْلُغَ أَشُدَّهُۥ ۚ وَأَوْفُوا۟ بِٱلْعَهْدِ ۖ إِنَّ ٱلْعَهْدَ كَانَ مَسْـُٔولًۭا","translation":"And do not touch the substance of an orphan, save to improve it, before he comes of age. And be true to every promise - for, verily, [on Judgment Day] you will be called to account for every promise which you have made!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2063.mp3","surahId":17,"words":[{"id":36111,"position":1,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/017_034_001.mp3","charTypeName":"word"},{"id":36112,"position":2,"arabic":"تَقْرَبُوا۟","translation":"তোমরা নিকটে যেয়ো","audioUrl":"wbw/017_034_002.mp3","charTypeName":"word"},{"id":36113,"position":3,"arabic":"مَالَ","translation":"সম্পদের","audioUrl":"wbw/017_034_003.mp3","charTypeName":"word"},{"id":36114,"position":4,"arabic":"ٱلْيَتِيمِ","translation":"ইয়াতীমের","audioUrl":"wbw/017_034_004.mp3","charTypeName":"word"},{"id":36115,"position":5,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/017_034_005.mp3","charTypeName":"word"},{"id":36116,"position":6,"arabic":"بِٱلَّتِى","translation":"সাথে সেটার","audioUrl":"wbw/017_034_006.mp3","charTypeName":"word"},{"id":36117,"position":7,"arabic":"هِىَ","translation":"যা","audioUrl":"wbw/017_034_007.mp3","charTypeName":"word"},{"id":36118,"position":8,"arabic":"أَحْسَنُ","translation":"উত্তম","audioUrl":"wbw/017_034_008.mp3","charTypeName":"word"},{"id":36119,"position":9,"arabic":"حَتَّىٰ","translation":"যতক্ষণ না","audioUrl":"wbw/017_034_009.mp3","charTypeName":"word"},{"id":36120,"position":10,"arabic":"يَبْلُغَ","translation":"সে পৌঁছে","audioUrl":"wbw/017_034_010.mp3","charTypeName":"word"},{"id":36121,"position":11,"arabic":"أَشُدَّهُۥ ۚ","translation":"তার প্রাপ্ত বয়সে","audioUrl":"wbw/017_034_011.mp3","charTypeName":"word"},{"id":36123,"position":12,"arabic":"وَأَوْفُوا۟","translation":"এবং তোমরা পূর্ণ করবে","audioUrl":"wbw/017_034_013.mp3","charTypeName":"word"},{"id":36124,"position":13,"arabic":"بِٱلْعَهْدِ ۖ","translation":"অঙ্গীকার","audioUrl":"wbw/017_034_014.mp3","charTypeName":"word"},{"id":36126,"position":14,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/017_034_016.mp3","charTypeName":"word"},{"id":36127,"position":15,"arabic":"ٱلْعَهْدَ","translation":"