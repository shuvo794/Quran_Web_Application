uch wealth, to make bequests in favour of his parents and [other] near of kin in accordance with what is fair: I this is binding on all who are conscious of God.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/187.mp3","surahId":2,"words":[{"id":83812,"position":1,"arabic":"كُتِبَ","translation":"ফরজ করা হয়েছে","audioUrl":"wbw/002_180_001.mp3","charTypeName":"word"},{"id":83813,"position":2,"arabic":"عَلَيْكُمْ","translation":"তোমাদের উপর","audioUrl":"wbw/002_180_002.mp3","charTypeName":"word"},{"id":83814,"position":3,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/002_180_003.mp3","charTypeName":"word"},{"id":83815,"position":4,"arabic":"حَضَرَ","translation":"উপস্থিত হয়","audioUrl":"wbw/002_180_004.mp3","charTypeName":"word"},{"id":83816,"position":5,"arabic":"أَحَدَكُمُ","translation":"তোমাদের কারও","audioUrl":"wbw/002_180_005.mp3","charTypeName":"word"},{"id":83817,"position":6,"arabic":"ٱلْمَوْتُ","translation":"মৃত্যু","audioUrl":"wbw/002_180_006.mp3","charTypeName":"word"},{"id":83818,"position":7,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/002_180_007.mp3","charTypeName":"word"},{"id":83819,"position":8,"arabic":"تَرَكَ","translation":"সে ছেড়ে যায়","audioUrl":"wbw/002_180_008.mp3","charTypeName":"word"},{"id":83820,"position":9,"arabic":"خَيْرًا","translation":"ধনসম্পত্তি","audioUrl":"wbw/002_180_009.mp3","charTypeName":"word"},{"id":83821,"position":10,"arabic":"ٱلْوَصِيَّةُ","translation":"ওসীয়ত করা(জোর নির্দেশ)","audioUrl":"wbw/002_180_010.mp3","charTypeName":"word"},{"id":83822,"position":11,"arabic":"لِلْوَٰلِدَيْنِ","translation":"পিতা-মাতার জন্য","audioUrl":"wbw/002_180_011.mp3","charTypeName":"word"},{"id":83823,"position":12,"arabic":"وَٱلْأَقْرَبِينَ","translation":"ও আত্নীয়-স্বজনদের (জন্যে)","audioUrl":"wbw/002_180_012.mp3","charTypeName":"word"},{"id":83824,"position":13,"arabic":"بِٱلْمَعْرُوفِ ۖ","translation":"ন্যায় অনুযায়ী","audioUrl":"wbw/002_180_013.mp3","charTypeName":"word"},{"id":83826,"position":14,"arabic"