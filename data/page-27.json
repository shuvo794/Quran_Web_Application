{"id":27,"ayahs":[{"number":177,"arabic":"۞ لَّيْسَ ٱلْبِرَّ أَن تُوَلُّوا۟ وُجُوهَكُمْ قِبَلَ ٱلْمَشْرِقِ وَٱلْمَغْرِبِ وَلَٰكِنَّ ٱلْبِرَّ مَنْ ءَامَنَ بِٱللَّهِ وَٱلْيَوْمِ ٱلْءَاخِرِ وَٱلْمَلَٰٓئِكَةِ وَٱلْكِتَٰبِ وَٱلنَّبِيِّۦنَ وَءَاتَى ٱلْمَالَ عَلَىٰ حُبِّهِۦ ذَوِى ٱلْقُرْبَىٰ وَٱلْيَتَٰمَىٰ وَٱلْمَسَٰكِينَ وَٱبْنَ ٱلسَّبِيلِ وَٱلسَّآئِلِينَ وَفِى ٱلرِّقَابِ وَأَقَامَ ٱلصَّلَوٰةَ وَءَاتَى ٱلزَّكَوٰةَ وَٱلْمُوفُونَ بِعَهْدِهِمْ إِذَا عَٰهَدُوا۟ ۖ وَٱلصَّٰبِرِينَ فِى ٱلْبَأْسَآءِ وَٱلضَّرَّآءِ وَحِينَ ٱلْبَأْسِ ۗ أُو۟لَٰٓئِكَ ٱلَّذِينَ صَدَقُوا۟ ۖ وَأُو۟لَٰٓئِكَ هُمُ ٱلْمُتَّقُونَ","translation":"True piety does not consist in turning your faces towards the east or the west - but truly pious is he who believes in God, and the Last Day; and the angels, and revelation, and the prophets; and spends his substance - however much he himself may cherish - it - upon his near of kin, and the orphans, and the needy, and the wayfarer, and the beggars, and for the freeing of human beings from bondage; and is constant in prayer, and renders the purifying dues; and [truly pious are] they who keep their promises whenever they promise, and are patient in misfortune and hardship and in time of peril: it is they that have proved themselves true, and it is they, they who are conscious of God.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/184.mp3","surahId":2,"words":[{"id":83515,"position":1,"arabic":"۞ لَّيْسَ","translation":"নেই","audioUrl":"wbw/002_177_002.mp3","charTypeName":"word"},{"id":83516,"position":2,"arabic":"ٱلْبِرَّ","translation":"পূণ্য","audioUrl":"wbw/002_177_003.mp3","charTypeName":"word"},{"id":83517,"position":3,"arabic":"أَن","translation":"যে","audioUrl":"wbw/002_177_004.mp3","charTypeName":"word"},{"id":83518,"position":4,"arabic":"تُوَلُّوا۟","translation":"তোমরাও ফেরাবে","audioUrl":"wbw/002_177_005.mp3","charTypeName":"word"},{"id":83519,"position":5,"arabic":"وُجُوهَكُمْ","translation":"তোমাদের মুখ","audioUrl":"wbw/002_177_006.mp3","charTypeName":"word"},{"id":83520,"position":6,"arabic":"قِبَلَ","translation":"দিকে","audioUrl":"wbw/002_177_007.mp3","charTypeName":"word"},{"id":83521,"position":7,"arabic":"ٱلْمَشْرِقِ","translation":"পূর্ব","audioUrl":"wbw/002_177_008.mp3","charTypeName":"word"},{"id":83522,"position":8,"arabic":"وَٱلْمَغْرِبِ","translation":"অথবা পশ্চিমে","audioUrl":"wbw/002_177_009.mp3","charTypeName":"word"},{"id":83523,"position":9,"arabic":"وَلَـٰكِنَّ","translation":"কিন্তু","audioUrl":"wbw/002_177_010.mp3","charTypeName":"word"},{"id":83524,"position":10,"arabic":"ٱلْبِرَّ","translation":"পূণ্য (হল)","audioUrl":"wbw/002_177_011.mp3","charTypeName":"word"},{"id":83525,"position":11,"arabic":"مَنْ","translation":"যে কেউ","audioUrl":"wbw/002_177_012.mp3","charTypeName":"word"},{"id":83526,"position":12,"arabic":"ءَامَنَ","translation":"ঈমান আনল","audioUrl":"wbw/002_177_013.mp3","charTypeName":"word"},{"id":83527,"position":13,"arabic":"بِٱللَّهِ","translation":"আল্লাহর প্রতি","audioUrl":"wbw/002_177_014.mp3","charTypeName":"word"},{"id":83528,"position":14,"arabic":"وَٱلْيَوْمِ","translation":"ও দিনের","audioUrl":"wbw/002_177_015.mp3","charTypeName":"word"},{"id":83529,"position":15,"arabic":"ٱلْـَٔاخِرِ","translation":"আখিরাতের","audioUrl":"wbw/002_177_016.mp3","charTypeName":"word"},{"id":83530,"position":16,"arabic":"وَٱلْمَلَـٰٓئِكَةِ","translation":"ও ফেরেশতাদের","audioUrl":"wbw/002_177_017.mp3","charTypeName":"word"},{"id":83531,"position":17,"arabic":"وَٱلْكِتَـٰبِ","translation":"ও কিতাবের","audioUrl":"wbw/002_177_018.mp3","charTypeName":"word"},{"id":83532,"position":18,"arabic":"وَٱلنَّبِيِّـۧنَ","translation":"ও নবীদের (প্রতি)","audioUrl":"wbw/002_177_019.mp3","charTypeName":"word"},{"id":83533,"position":19,"arabic":"وَءَاتَى","translation":"এবং দান করল","audioUrl":"wbw/002_177_020.mp3","charTypeName":"word"},{"id":83534,"position":20,"arabic":"ٱلْمَالَ","translation":"সম্পদ","audioUrl":"wbw/002_177_021.mp3","charTypeName":"word"},{"id":83535,"position":21,"arabic":"عَلَىٰ","translation":"কারণে","audioUrl":"wbw/002_177_022.mp3","charTypeName":"word"},{"id":83536,"position":22,"arabic":"حُبِّهِۦ","translation":"তাঁরই ভালবাসার","audioUrl":"wbw/002_177_023.mp3","charTypeName":"word"},{"id":83537,"position":23,"arabic":"ذَوِى","translation":"সম্পন্ন","audioUrl":"wbw/002_177_024.mp3","charTypeName":"word"},{"id":83538,"position":24,"arabic":"ٱلْقُرْبَىٰ","translation":"নিকট আত্নীয়স্বজনদেরকে","audioUrl":"wbw/002_177_025.mp3","charTypeName":"word"},{"id":83539,"position":25,"arabic":"وَٱلْيَتَـٰمَىٰ","translation":"ও ইয়াতিমদেরকে","audioUrl":"wbw/002_177_026.mp3","charTypeName":"word"},{"id":83540,"position":26,"arabic":"وَٱلْمَسَـٰكِينَ","translation":"ও অভাবগ্রস্ত","audioUrl":"wbw/002_177_027.mp3","charTypeName":"word"},{"id":83541,"position":27,"arabic":"وَٱبْنَ","translation":"(এবং পুত্র)","audioUrl":"wbw/002_177_028.mp3","charTypeName":"word"},{"id":83542,"position":28,"arabic":"ٱلسَّبِيلِ","translation":"ও পথিকদেরকে","audioUrl":"wbw/002_177_029.mp3","charTypeName":"word"},{"id":83543,"position":29,"arabic":"وَٱلسَّآئِلِينَ","translation":"ও সাহায্যপ্রার্থীদেরকে","audioUrl":"wbw/002_177_030.mp3","charTypeName":"word"},{"id":83544,"position":30,"arabic":"وَفِى","translation":"এবং জন্যে","audioUrl":"wbw/002_177_031.mp3","charTypeName":"word"},{"id":83545,"position":31,"arabic":"ٱلرِّقَابِ","translation":"দাসমুক্তির","audioUrl":"wbw/002_177_032.mp3","charTypeName":"word"},{"id":83546,"position":32,"arabic":"وَأَقَامَ","translation":"এবং প্রতিষ্ঠা করে","audioUrl":"wbw/002_177_033.mp3","charTypeName":"word"},{"id":83547,"position":33,"arabic":"ٱلصَّلَوٰةَ","translation":"সলাত","audioUrl":"wbw/002_177_034.mp3","charTypeName":"word"},{"id":83548,"position":34,"arabic":"وَءَاتَى","translation":"ও প্রদান করে","audioUrl":"wbw/002_177_035.mp3","charTypeName":"word"},{"id":83549,"position":35,"arabic":"ٱلزَّكَوٰةَ","translation":"যাকাত","audioUrl":"wbw/002_177_036.mp3","charTypeName":"word"},{"id":83550,"position":36,"arabic":"وَٱلْمُ