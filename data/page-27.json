ْمُتَّقُونَ","translation":"মুত্তাকী","audioUrl":"wbw/002_177_055.mp3","charTypeName":"word"},{"id":83569,"position":52,"arabic":"١٧٧","translation":"(১৭৭)","audioUrl":null,"charTypeName":"end"}]},{"number":178,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ كُتِبَ عَلَيْكُمُ ٱلْقِصَاصُ فِى ٱلْقَتْلَى ۖ ٱلْحُرُّ بِٱلْحُرِّ وَٱلْعَبْدُ بِٱلْعَبْدِ وَٱلْأُنثَىٰ بِٱلْأُنثَىٰ ۚ فَمَنْ عُفِىَ لَهُۥ مِنْ أَخِيهِ شَىْءٌۭ فَٱتِّبَاعٌۢ بِٱلْمَعْرُوفِ وَأَدَآءٌ إِلَيْهِ بِإِحْسَٰنٍۢ ۗ ذَٰلِكَ تَخْفِيفٌۭ مِّن رَّبِّكُمْ وَرَحْمَةٌۭ ۗ فَمَنِ ٱعْتَدَىٰ بَعْدَ ذَٰلِكَ فَلَهُۥ عَذَابٌ أَلِيمٌۭ","translation":"O YOU who have attained to faith! Just retribution is ordained for you in cases of killing: the free for the free, and the slave for the slave, and the woman for the woman. And if something [of his guilt] is remitted to a guilty person by his brother, this [remission] shall be adhered to with fairness, and restitution to his fellow-man shall be made in a goodly manner. This is an alleviation from your Sustainer, and an act of His grace. And for him who, none the less, wilfully transgresses the bounds of what is right, there is grievous suffering in store:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/185.mp3","surahId":2,"words":[{"id":83610,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/002_178_001.mp3","charTypeName":"word"},{"id":83611,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/002_178_002.mp3","charTypeName":"word"},{"id":83612,"position":3,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছ","audioUrl":"wbw/002_178_003.mp3","charTypeName":"word"},{"id":83613,"position":4,"arabic":"كُتِبَ","translation":"ফরজ করা হয়েছে","audioUrl":"wbw/002_178_004.mp3","charTypeName":"word"},{"id":83614,"position":5,"arabic":"عَلَيْكُمُ","translation":"তোমাদের উপর","audioUrl":"wbw/002_178_005.mp3","charTypeName":"word"},{"id":83615,"position":6,"arabic":"ٱلْقِصَاصُ","translation":"কিসাস(বদলা)","audioUrl":"wbw/002_178_006.mp3","charTypeName":"word"},{"id":83616,"position":7,"arabic":"فِى","translation":"ব্যাপারে","audioUrl":"wbw/002_178_007.mp3","charTypeName":"word"},{"id":83617,"position":8,"arabic":"ٱلْقَتْلَى ۖ","translation":"(অন্যায়) হত্যার","audioUrl":"wbw/002_178_008.mp3","charTypeName":"word"},{"id":83619,"position":9,"arabic":"ٱلْحُرُّ","translation":"স্বাধীন ব্যাক্তি","audioUrl":"wbw/002_178_010.mp3","charTypeName":"word"},{"id":83620,"position":10,"arabic":"بِٱلْحُرِّ","translation":"স্বাধীন ব্যাক্তির পরিবর্তে","audioUrl":"wbw/002_178_011.mp3","charTypeName":"word"},{"id":83621,"position":11,"arabic":"وَٱلْعَبْدُ","translation":"ও ক্রীতদাস","audioUrl":"wbw/002_178_012.mp3","charTypeName":"word"},{"id":83622,"position":12,"arabic":"بِٱلْعَبْدِ","translation":"ক্রীতদাসের পরিবর্তে","audioUrl":"wbw/002_178_013.mp3","charTypeName":"word"},{"id":83623,"position":13,"arabic":"وَٱلْأُنثَىٰ","translation":"এবং মহিলা","audioUrl":"wbw/002_178_014.mp3","charTypeName":"word"},{"id":83624,"position":14,"arabic":"بِٱلْأُنثَىٰ ۚ","translation":"মহিলার পরিবর্তে","audioUrl":"wbw/002_178_015.mp3","charTypeName":"word"},{"id":83626,"position":15,"arabic":"فَمَنْ","translation":"অতঃপর তার (ক্ষেত্রে)","audioUrl":"wbw/002_178_017.mp3","charTypeName":"word"},{"id":83627,"position":16,"arabic":"عُفِىَ","translation":"ক্ষমা করে দেয়া হয়","audioUrl":"wbw/002_178_018.mp3","charTypeName":"word"},{"id":83628,"position":17,"arabic":"لَهُۥ","translation":"তার জন্য","audioUrl":"wbw/002_178_019.mp3","charTypeName":"word"},{"id":83629,"position":18,"arabic":"مِنْ","translation":"পক্ষ হতে","audioUrl":"wbw/002_178_020.mp3","charTypeName":"word"},{"id":83630,"position":19,"arabic":"أَخِيهِ","translation":"তার ভাইয়ের","audioUrl":"wbw/002_178_021.mp3","charTypeName":"word"},{"id":83631,"position":20,"arabic":"شَىْءٌۭ","translation":"কোনো কিছু","audioUrl":"wbw/002_178_022.mp3","charTypeName":"word"},{"id":83632,"position":21,"arabic":"فَٱتِّبَاعٌۢ","translation":"তবে অনুসরণ করা","audioUrl":"wbw/002_178_023.mp3","char