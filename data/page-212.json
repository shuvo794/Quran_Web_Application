{"id":212,"ayahs":[{"number":26,"arabic":"۞ لِّلَّذِينَ أَحْسَنُوا۟ ٱلْحُسْنَىٰ وَزِيَادَةٌۭ ۖ وَلَا يَرْهَقُ وُجُوهَهُمْ قَتَرٌۭ وَلَا ذِلَّةٌ ۚ أُو۟لَٰٓئِكَ أَصْحَٰبُ ٱلْجَنَّةِ ۖ هُمْ فِيهَا خَٰلِدُونَ","translation":"For those who persevere in doing good there is the ultimate good in store, and more [than that]. No darkness and no ignominy will overshadow their faces [on Resurrection Day]: it is they who are destined for paradise, therein to abide.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1390.mp3","surahId":10,"words":[{"id":29060,"position":1,"arabic":"۞ لِّلَّذِينَ","translation":"জন্যে তাদের (আছে)","audioUrl":"wbw/010_026_002.mp3","charTypeName":"word"},{"id":29061,"position":2,"arabic":"أَحْسَنُوا۟","translation":"(যারা) ভালো কাজ করে","audioUrl":"wbw/010_026_003.mp3","charTypeName":"word"},{"id":29062,"position":3,"arabic":"ٱلْحُسْنَىٰ","translation":"উত্তম ফল","audioUrl":"wbw/010_026_004.mp3","charTypeName":"word"},{"id":29063,"position":4,"arabic":"وَزِيَادَةٌۭ ۖ","translation":"এবং আরও বেশি (অনুগ্রহ)","audioUrl":"wbw/010_026_005.mp3","charTypeName":"word"},{"id":29065,"position":5,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/010_026_007.mp3","charTypeName":"word"},{"id":29066,"position":6,"arabic":"يَرْهَقُ","translation":"আচ্ছন্ন করবে","audioUrl":"wbw/010_026_008.mp3","charTypeName":"word"},{"id":29067,"position":7,"arabic":"وُجُوهَهُمْ","translation":"মুখমন্ডলসমূহকে তাদের","audioUrl":"wbw/010_026_009.mp3","charTypeName":"word"},{"id":29068,"position":8,"arabic":"قَتَرٌۭ","translation":"কালিমা","audioUrl":"wbw/010_026_010.mp3","charTypeName":"word"},{"id":29069,"position":9,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/010_026_011.mp3","charTypeName":"word"},{"id":29070,"position":10,"arabic":"ذِلَّةٌ ۚ","translation":"লাঞ্ছনা","audioUrl":"wbw/010_026_012.mp3","charTypeName":"word"},{"id":29072,"position":11,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐসব লোক","audioUrl":"wbw/010_026_014.mp3","charTypeName":"word"},{"id":29073,"position":12,"arabic":"أَصْحَـٰبُ","translation":"অধিবাসী (হবে)","audioUrl":"wbw/010_026_015.mp3","charTypeName":"word"},{"id":29074,"position":13,"arabic":"ٱلْجَنَّةِ ۖ","translation":"জান্নাতের","audioUrl":"wbw/010_026_016.mp3","charTypeName":"word"},{"id":29076,"position":14,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/010_026_018.mp3","charTypeName":"word"},{"id":29077,"position":15,"arabic":"فِيهَا","translation":"মধ্যে তার","audioUrl":"wbw/010_026_019.mp3","charTypeName":"word"},{"id":29078,"position":16,"arabic":"خَـٰلِدُونَ","translation":"স্থায়ী হবে","audioUrl":"wbw/010_026_020.mp3","charTypeName":"word"},{"id":29079,"position":17,"arabic":"٢٦","translation":"(২৬)","audioUrl":null,"charTypeName":"end"}]},{"number":27,"arabic":"وَٱلَّذِينَ كَسَبُوا۟ ٱلسَّيِّـَٔاتِ جَزَآءُ سَيِّئَةٍۭ بِمِثْلِهَا وَتَرْهَقُهُمْ ذِلَّةٌۭ ۖ مَّا لَهُم مِّنَ ٱللَّهِ مِنْ عَاصِمٍۢ ۖ كَأَنَّمَآ أُغْشِيَتْ وُجُوهُهُمْ قِطَعًۭا مِّنَ ٱلَّيْلِ مُظْلِمًا ۚ أُو۟لَٰٓئِكَ أَصْحَٰبُ ٱلنَّارِ ۖ هُمْ فِيهَا خَٰلِدُونَ","translation":"But us for those who have done evil deeds - the recompense of an evil, deed shall be the like thereof: and - since they will have none to defend them against God - ignominy will overshadow them as though their faces were veiled by the night's own darkness: it is they who are destined for the fire. therein to abide.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1391.mp3","surahId":10,"words":[{"id":29915,"position":1,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/010_027_001.mp3","charTypeName":"word"},{"id":29916,"position":2,"arabic":"كَسَبُوا۟","translation":"অর্জন করেছে","audioUrl":"wbw/010_027_002.mp3","charTypeName":"word"},{"id":29917,"position":3,"arabic":"ٱلسَّيِّـَٔاتِ","translation":"মন্দ কাজ","audioUrl":"wbw/010_027_003.mp3","charTypeName":"word"},{"id":29918,"position":4,"arabic":"جَزَآءُ","translation":"(তারা পাবে) প্রতিফল","audioUrl":"wbw/010_027_004.mp3","charTypeName":"word"},{"id":29919,"position":5,"arabic":"سَيِّئَةٍۭ","translation":"মন্দ কাজের","audioUrl":"wbw/010_027_005.mp3","charTypeName":"word"},{"id":29920,"position":6,"arabic":"بِمِثْلِهَا","translation":"অনুরূপ তার","audioUrl":"wbw/010_027_006.mp3","charTypeName":"word"},{"id":29921,"position":7,"arabic":"وَتَرْهَقُهُمْ","translation":"ও আচ্ছন্ন করবে তাদের","audioUrl":"wbw/010_027_007.mp3","charTypeName":"word"},{"id":29922,"position":8,"arabic":"ذِلَّةٌۭ ۖ","translation":"লাঞ্ছনা","audioUrl":"wbw/010_027_008.mp3","charTypeName":"word"},{"id":29924,"position":9,"arabic":"مَّا","translation":"নেই","audioUrl":"wbw/010_027_010.mp3","charTypeName":"word"},{"id":29925,"position":10,"arabic":"لَهُم","translation":"জন্যে তাদের","audioUrl":"wbw/010_027_011.mp3","charTypeName":"word"},{"id":29926,"position":11,"arabic":"مِّنَ","translation":"হতে","audioUrl":"wbw/010_027_012.mp3","charTypeName":"word"},{"id":29927,"position":12,"arabic":"ٱللَّهِ","translation":"আল্লাহ","audioUrl":"wbw/010_027_013.mp3","charTypeName":"word"},{"id":29928,"position":13,"arabic":"مِنْ","translation":"কোনো","audioUrl":"wbw/010_027_014.mp3","charTypeName":"word"},{"id":29929,"position":14,"arabic":"عَاصِمٍۢ ۖ","translation":"রক্ষাকারী","audioUrl":"wbw/010_027_015.mp3","charTypeName":"word"},{"id":29931,"position":15,"arabic":"كَأَنَّمَآ","translation":"যেন প্রকৃতপক্ষে","audioUrl":"wbw/010_027_017.mp3","charTypeName":"word"},{"id":29932,"position":16,"arabic":"أُغْشِيَتْ","translation":"ঢেকে ফেলেছে","audioUrl":"wbw/010_027_018.mp3","charTypeName":"word"},{"id":29933,"position":17,"arabic":"وُجُوهُهُمْ","translation":"মুখমন্ডলগুলো তাদের","audioUrl":"wbw/010_027_019.mp3","charTypeName":"word"},{"id":29934,"position":18,"arabic":"قِطَعًۭا","translation":"টুকরা","audioUrl":"wbw/010_027_020.mp3","charTypeName":"word"},{"id":29935,"position":19,"arabic":"مِّنَ","translation":"এর","audioUrl":"wbw/010_027_021.mp3","charTypeName":"word"},{"id":29936,"position":20,"arabic":"ٱلَّيْلِ","translation":"রাত","audioUrl":"wbw/010_027_022.mp3","charTypeName":"word"},{"id":29937,"position":21,"arabic":"مُظْلِمًا ۚ","translation":"অন্ধকার","audioUrl":"wbw/010_027_023.mp3","charTypeName":"word"},{"id":29939,"position":22,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐসবলোক","audioUrl":"wbw/010_027_025.mp3","charTypeName":"word"},{"id":29940,"position":23,"arabic":"أَصْحَـٰبُ","translation":"অধিবাসী (হবে)","audioUrl":"wbw/010_027_026.mp3","charTypeName":"word"},{"id":29941,"position":24,"arabic":"ٱلنَّارِ ۖ","translation":"আগুনের","audioUrl":"wbw/010_027_027.mp3","charTypeName":"word"},{"id":29943,"position":25,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/010_027_029.mp3","charTypeName":"word"},{"id":29944,"position":26,"arabic":"فِيهَا","translation":"মধ্যে তার","audioUrl":"wbw/010_027_030.mp3","charTypeName":"word"},{"id":29945,"position":27,"arabic":"خَـٰلِدُونَ","translation":"স্থায়ী হবে","audioUrl":"wbw/010_027_031.mp3","charTypeName":"word"},{"id":29946,"position":28,"arabic":"٢٧","translation":"(২৭)","audioUrl":null,"charTypeName":"end"}]},{"number":28,"arabic":"وَيَوْمَ نَحْشُرُهُمْ جَمِيعًۭا ثُمَّ نَقُولُ لِلَّذِينَ أَشْرَكُوا۟ مَكَانَكُمْ أَنتُمْ وَشُرَكَآؤُكُمْ ۚ فَزَيَّلْنَا بَيْنَهُمْ ۖ وَقَالَ شُرَكَآؤُهُم مَّا كُنتُمْ إِيَّانَا تَعْبُدُونَ","translation":"For, one Day We shall gather them all together, and then We shall say unto those who [in their lifetime] ascribed divinity to aught but God, \"Stand where you are, you and those [beings and powers] to whom you were wont to ascribe a share in God's divinity! -for by then We shall have [visibly] separated them from one another. And the beings to whom they had ascribed a share in God's divinity will say [to those who had worshipped them], \"It was not us that you were wont to worship;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1392.mp3","surahId":10,"words":[{"id":31011,"position":1,"arabic":"وَيَوْمَ","translation":"এবং যেদিন","audioUrl":"wbw/010_028_001.mp3","charTypeName":"word"},{"id":31012,"position":2,"arabic":"نَحْشُرُهُمْ","translation":"একত্র করবো আমরা তাদের","audioUrl":"wbw/010_028_002.mp3","charTypeName":"word"},{"id":31013,"position":3,"arabic":"جَمِيعًۭا","translation":"সকলকে (আমার আদালতে)","audioUrl":"wbw/010_028_003.mp3","charTypeName":"word"},{"id":31014,"position":4,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/010_028_004.mp3","charTypeName":"word"},{"id":31015,"position":5,"arabic":"نَقُولُ","translation":"আমরা বলবো","audioUrl":"wbw/010_028_005.mp3","charTypeName":"word"},{"id":31016,"position":6,"arabic":"لِلَّذِينَ","translation":"উদ্দেশ্যে তাদের (যারা)","audioUrl":"wbw/010_028_006.mp3","charTypeName":"word"},{"id":31017,"position":7,"arabic":"أَشْرَكُوا۟","translation":"শিরক করেছিলো","audioUrl":"wbw/010_028_007.mp3","charTypeName":"word"},{"id":31018,"position":8,"arabic":"مَكَانَكُمْ","translation":"\"তোমাদের স্থানে (অবস্হান করো)","audioUrl":"wbw/010_028_008.mp3","charTypeName":"word"},{"id":31019,"position":9,"arabic":"أَنتُمْ","translation":"তোমরা","audioUrl":"wbw/010_028_009.mp3","charTypeName":"word"},{"id":31020,"position":10,"arabic":"وَشُرَكَآؤُكُمْ ۚ","translation":"ও তোমাদের শরীকরা\"","audioUrl":"wbw/010_028_010.mp3","charTypeName":"word"},{"id":31022,"position":11,"arabic":"فَزَيَّلْنَا","translation":"অতঃপর পৃথক করে দিবো আমরা","audioUrl":"wbw/010_028_012.mp3","charTypeName":"word"},{"id":31023,"position":12,"arabic":"بَيْنَهُمْ ۖ","translation":"মাঝে তাদের","audioUrl":"wbw/010_028_013.mp3","charTypeName":"word"},{"id":31025,"position":13,"arabic":"وَقَالَ","translation":"এবং বলবে","audioUrl":"wbw/010_028_015.mp3","charTypeName":"word"},{"id":31026,"position":14,"arabic":"شُرَكَآؤُهُم","translation":"শরীকেরা তাদের","audioUrl":"wbw/010_028_016.mp3","charTypeName":"word"},{"id":31027,"position":15,"arabic":"مَّا","translation":"\"না","audioUrl":"wbw/010_028_017.mp3","charTypeName":"word"},{"id":31028,"position":16,"arabic":"كُنتُمْ","translation":"তোমরা ছিলে","audioUrl":"wbw/010_028_018.mp3","charTypeName":"word"},{"id":31029,"posi