/010_033_005.mp3","charTypeName":"word"},{"id":35195,"position":6,"arabic":"ٱلَّذِينَ","translation":"(তাদের) যারা","audioUrl":"wbw/010_033_006.mp3","charTypeName":"word"},{"id":35196,"position":7,"arabic":"فَسَقُوٓا۟","translation":"সত্যত্যাগ করেছে","audioUrl":"wbw/010_033_007.mp3","charTypeName":"word"},{"id":35197,"position":8,"arabic":"أَنَّهُمْ","translation":"যে তারা","audioUrl":"wbw/010_033_008.mp3","charTypeName":"word"},{"id":35198,"position":9,"arabic":"لَا","translation":"না","audioUrl":"wbw/010_033_009.mp3","charTypeName":"word"},{"id":35199,"position":10,"arabic":"يُؤْمِنُونَ","translation":"ঈমান আনবে","audioUrl":"wbw/010_033_010.mp3","charTypeName":"word"},{"id":35200,"position":11,"arabic":"٣٣","translation":"(৩৩)","audioUrl":null,"charTypeName":"end"}]}]}