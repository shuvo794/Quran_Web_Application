ition":11,"arabic":"٢٩","translation":"(২৯)","audioUrl":null,"charTypeName":"end"}]},{"number":30,"arabic":"هُنَالِكَ تَبْلُوا۟ كُلُّ نَفْسٍۢ مَّآ أَسْلَفَتْ ۚ وَرُدُّوٓا۟ إِلَى ٱللَّهِ مَوْلَىٰهُمُ ٱلْحَقِّ ۖ وَضَلَّ عَنْهُم مَّا كَانُوا۟ يَفْتَرُونَ","translation":"There and then will every human being clearly apprehend what he has done in the past; and all will be brought back unto God, their true Lord Supreme, and all their false imagery will have forsaken them.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1394.mp3","surahId":10,"words":[{"id":32893,"position":1,"arabic":"هُنَالِكَ","translation":"সেখানে","audioUrl":"wbw/010_030_001.mp3","charTypeName":"word"},{"id":32894,"position":2,"arabic":"تَبْلُوا۟","translation":"যাচাই করে নিতে পারবে","audioUrl":"wbw/010_030_002.mp3","charTypeName":"word"},{"id":32895,"position":3,"arabic":"كُلُّ","translation":"প্রত্যেক","audioUrl":"wbw/010_030_003.mp3","charTypeName":"word"},{"id":32896,"position":4,"arabic":"نَفْسٍۢ","translation":"ব্যক্তি","audioUrl":"wbw/010_030_004.mp3","charTypeName":"word"},{"id":32897,"position":5,"arabic":"مَّآ","translation":"যা","audioUrl":"wbw/010_030_005.mp3","charTypeName":"word"},{"id":32898,"position":6,"arabic":"أَسْلَفَتْ ۚ","translation":"অতীতে করেছে","audioUrl":"wbw/010_030_006.mp3","charTypeName":"word"},{"id":32900,"position":7,"arabic":"وَرُدُّوٓا۟","translation":"এবং তাদেরকে ফিরিয়ে নেয়া হবে","audioUrl":"wbw/010_030_008.mp3","charTypeName":"word"},{"id":32901,"position":8,"arabic":"إِلَى","translation":"দিকে","audioUrl":"wbw/010_030_009.mp3","charTypeName":"word"},{"id":32902,"position":9,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/010_030_010.mp3","charTypeName":"word"},{"id":32903,"position":10,"arabic":"مَوْلَىٰهُمُ","translation":"অভিভাবক তাদের","audioUrl":"wbw/010_030_011.mp3","charTypeName":"word"},{"id":32904,"position":11,"arabic":"ٱلْحَقِّ ۖ","translation":"প্রকৃত","audioUrl":"wbw/010_030_012.mp3","charTypeName":"word"},{"id":32906,"pos