{"id":251,"ayahs":[{"number":14,"arabic":"لَهُۥ دَعْوَةُ ٱلْحَقِّ ۖ وَٱلَّذِينَ يَدْعُونَ مِن دُونِهِۦ لَا يَسْتَجِيبُونَ لَهُم بِشَىْءٍ إِلَّا كَبَٰسِطِ كَفَّيْهِ إِلَى ٱلْمَآءِ لِيَبْلُغَ فَاهُ وَمَا هُوَ بِبَٰلِغِهِۦ ۚ وَمَا دُعَآءُ ٱلْكَٰفِرِينَ إِلَّا فِى ضَلَٰلٍۢ","translation":"Unto Him [alone] is due all prayer aiming at the Ultimate Truth, since those [other beings or powers] whom men invoke instead of God cannot respond to them in any way - [so that he who invokes them is] but like one who stretches his open hands towards water, [hoping] that it will reach his mouth, the while it never reaches him. Hence, the prayer of those who deny the truth amounts to no more than losing oneself in grievous error.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1721.mp3","surahId":13,"words":[{"id":16595,"position":1,"arabic":"لَهُۥ","translation":"তাঁরই জন্য","audioUrl":"wbw/013_014_001.mp3","charTypeName":"word"},{"id":16596,"position":2,"arabic":"دَعْوَةُ","translation":"আহবান","audioUrl":"wbw/013_014_002.mp3","charTypeName":"word"},{"id":16597,"position":3,"arabic":"ٱلْحَقِّ ۖ","translation":"সত্যের","audioUrl":"wbw/013_014_003.mp3","charTypeName":"word"},{"id":16599,"position":4,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/013_014_005.mp3","charTypeName":"word"},{"id":16600,"position":5,"arabic":"يَدْعُونَ","translation":"ডাকে","audioUrl":"wbw/013_014_006.mp3","charTypeName":"word"},{"id":16601,"position":6,"arabic":"مِن","translation":"ছাড়া","audioUrl":"wbw/013_014_007.mp3","charTypeName":"word"},{"id":16602,"position":7,"arabic":"دُونِهِۦ","translation":"তাঁকে (অন্য কাউকে)","audioUrl":"wbw/013_014_008.mp3","charTypeName":"word"},{"id":16603,"position":8,"arabic":"لَا","translation":"না","audioUrl":"wbw/013_014_009.mp3","charTypeName":"word"},{"id":16604,"position":9,"arabic":"يَسْتَجِيبُونَ","translation":"তারা সাড়া দেয়","audioUrl":"wbw/013_014_010.mp3","charTypeName":"word"},{"id":16605,"position":10,"arabic":"لَهُم","translation":"তাদেরকে","audioUrl":"wbw/013_014_011.mp3","charTypeName":"word"},{"id":16606,"position":11,"arabic":"بِشَىْءٍ","translation":"কোনো কিছুর","audioUrl":"wbw/013_014_012.mp3","charTypeName":"word"},{"id":16607,"position":12,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/013_014_013.mp3","charTypeName":"word"},{"id":16608,"position":13,"arabic":"كَبَـٰسِطِ","translation":"মতো সম্প্রসারণকারীর","audioUrl":"wbw/013_014_014.mp3","charTypeName":"word"},{"id":16609,"position":14,"arabic":"كَفَّيْهِ","translation":"তার দু'হাত","audioUrl":"wbw/013_014_015.mp3","charTypeName":"word"},{"id":16610,"position":15,"arabic":"إِلَى","translation":"প্রতি","audioUrl":"wbw/013_014_016.mp3","charTypeName":"word"},{"id":16611,"position":16,"arabic":"ٱلْمَآءِ","translation":"পানির","audioUrl":"wbw/013_014_017.mp3","charTypeName":"word"},{"id":16612,"position":17,"arabic":"لِيَبْلُغَ","translation":"যেন পৌঁছে","audioUrl":"wbw/013_014_018.mp3","charTypeName":"word"},{"id":16613,"position":18,"arabic":"فَاهُ","translation":"তার মুখে","audioUrl":"wbw/013_014_019.mp3","charTypeName":"word"},{"id":16614,"position":19,"arabic":"وَمَا","translation":"অথচ নয়","audioUrl":"wbw/013_014_020.mp3","charTypeName":"word"},{"id":16615,"position":20,"arabic":"هُوَ","translation":"তা","audioUrl":"wbw/013_014_021.mp3","charTypeName":"word"},{"id":16616,"position":21,"arabic":"بِبَـٰلِغِهِۦ ۚ","translation":"তার কাছে পৌঁছবার","audioUrl":"wbw/013_014_022.mp3","charTypeName":"word"},{"id":16618,"position":22,"arabic":"وَمَا","translation":"এবং নয়","audioUrl":"wbw/013_014_024.mp3","charTypeName":"word"},{"id":16619,"position":23,"arabic":"دُعَآءُ","translation":"ডাক","audioUrl":"wbw/013_014_025.mp3","charTypeName":"word"},{"id":16620,"position":24,"arabic":"ٱلْكَـٰفِرِينَ","translation":"কাফেরদের","audioUrl":"wbw/013_014_026.mp3","charTypeName":"word"},{"id":16621,"position":25,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/013_014_027.mp3","charTypeName":"word"},{"id":16622,"position":26,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/013_014_028.mp3","charTypeName":"word"},{"id":16623,"position":27,"arabic":"ضَلَـٰلٍۢ","translation":"ভ্রান্তির","audioUrl":"wbw/013_014_029.mp3","charTypeName":"word"},{"id":16624,"position":28,"arabic":"١٤","translation":"(১৪)","audioUrl":null,"charTypeName":"end"}]},{"number":15,"arabic":"وَلِلَّهِ يَسْجُدُ مَن فِى ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ طَوْعًۭا وَكَرْهًۭا وَظِلَٰلُهُم بِٱلْغُدُوِّ وَٱلْءَاصَالِ ۩","translation":"And before God prostrate themselves, willingly or unwillingly, all [things and beings] that are in the heavens and on earth, as do their shadows in the mornings and the evenings.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1722.mp3","surahId":13,"words":[{"id":17798,"position":1,"arabic":"وَلِلَّهِ","translation":"এবং আল্লাহকেই","audioUrl":"wbw/013_015_001.mp3","charTypeName":"word"},{"id":17799,"position":2,"arabic":"يَسْجُدُ","translation":"সিজদা করে","audioUrl":"wbw/013_015_002.mp3","charTypeName":"word"},{"id":17800,"position":3,"arabic":"مَن","translation":"যা কিছু","audioUrl":"wbw/013_015_003.mp3","charTypeName":"word"},{"id":17801,"position":4,"arabic":"فِى","translation":"মধ্যে আছে","audioUrl":"wbw/013_015_004.mp3","charTypeName":"word"},{"id":17802,"position":5,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশের","audioUrl":"wbw/013_015_005.mp3","charTypeName":"word"},{"id":17803,"position":6,"arabic":"وَٱلْأَرْضِ","translation":"ও পৃথিবীর","audioUrl":"wbw/013_015_006.mp3","charTypeName":"word"},{"id":17804,"position":7,"arabic":"طَوْعًۭا","translation":"ইচ্ছায়","audioUrl":"wbw/013_015_007.mp3","charTypeName":"word"},{"id":17805,"position":8,"arabic":"وَكَرْهًۭا","translation":"ও অনিচ্ছায়","audioUrl":"wbw/013_015_008.mp3","charTypeName":"word"},{"id":17806,"position":9,"arabic":"وَظِلَـٰلُهُم","translation":"এবং তাদের ছায়াগুলোও","audioUrl":"wbw/013_015_009.mp3","charTypeName":"word"},{"id":17807,"position":10,"arabic":"بِٱلْغُدُوِّ","translation":"বেলায় সকাল","audioUrl":"wbw/013_015_010.mp3","charTypeName":"word"},{"id":17808,"position":11,"arabic":"وَٱلْـَٔاصَالِ ۩","translation":"এবং সন্ধ্যায় (নত হয়)","audioUrl":"wbw/013_015_011.mp3","charTypeName":"word"},{"id":17810,"position":12,"arabic":"١٥","translation":"(১৫)","audioUrl":null,"charTypeName":"end"}]},{"number":16,"arabic":"قُلْ مَن رَّبُّ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ قُلِ ٱللَّهُ ۚ قُلْ أَفَٱتَّخَذْتُم مِّن دُونِهِۦٓ أَوْلِيَآءَ لَا يَمْلِكُونَ لِأَنفُسِهِمْ نَفْعًۭا وَلَا ضَرًّۭا ۚ قُلْ هَلْ يَسْتَوِى ٱلْأَعْمَىٰ وَٱلْبَصِيرُ أَمْ هَلْ تَسْتَوِى ٱلظُّلُمَٰتُ وَٱلنُّورُ ۗ أَمْ جَعَلُوا۟ لِلَّهِ شُرَكَآءَ خَلَقُوا۟ كَخَلْقِهِۦ فَتَشَٰبَهَ ٱلْخَلْقُ عَلَيْهِمْ ۚ قُلِ ٱللَّهُ خَٰلِقُ كُلِّ شَىْءٍۢ وَهُوَ ٱلْوَٰحِدُ ٱلْقَهَّٰرُ","translation":"Say: \"Who is the Sustainer of the heavens and the earth?\" Say: \"[It is] God.\" Say: \"[Why,] then, do you take for your protectors, instead of Him, such as have it not within their power to bring benefit to, or avert harm from, themselves?\" Say: \"Can the blind and the seeing be deemed equal? -or can the depths of darkness and the light be deemed equal?\" Or do they [really] believe that there are, side by side with God, other divine powers that have created the like of what He creates, so that this act of creation appears to them to be similar [to His]? Say: \"God is the Creator of all things; and He is the One who holds absolute sway over all that exists.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1723.mp3","surahId":13,"words":[{"id":18806,"position":1,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/013_016_001.mp3","charTypeName":"word"},{"id":18807,"position":2,"arabic":"مَن","translation":"\"কে","audioUrl":"wbw/013_016_002.mp3","charTypeName":"word"},{"id":18808,"position":3,"arabic":"رَّبُّ","translation":"রব","audioUrl":"wbw/013_016_003.mp3","charTypeName":"word"},{"id":18809,"position":4,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশের","audioUrl":"wbw/013_016_004.mp3","charTypeName":"word"},{"id":18810,"position":5,"arabic":"وَٱلْأَرْضِ","translation":"ও পৃথিবীর\"","audioUrl":"wbw/013_016_005.mp3","charTypeName":"word"},{"id":18811,"position":6,"arabic":"قُلِ","translation":"বলো","audioUrl":"wbw/013_016_006.mp3","charTypeName":"word"},{"id":18812,"position":7,"arabic":"ٱللَّهُ ۚ","translation":"\"(তিনিই) আল্লাহ\"","audioUrl":"wbw/013_016_007.mp3","charTypeName":"word"},{"id":18814,"position":8,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/013_016_009.mp3","charTypeName":"word"},{"id":18815,"position":9,"arabic":"أَفَٱتَّخَذْتُم","translation":"\"তোমরা তাহ'লে কি গ্রহণ করেছো","audioUrl":"wbw/013_016_010.mp3","charTypeName":"word"},{"id":18816,"position":10,"arabic":"مِّن","translation":"পরিবর্তে","audioUrl":"wbw/013_016_011.mp3","charTypeName":"word"},{"id":18817,"position":11,"arabic":"دُونِهِۦٓ","translation":"তার","audioUrl":"wbw/013_016_012.mp3","charTypeName":"word"},{"id":18818,"position":12,"arabic":"أَوْلِيَآءَ","translation":"অভিভাবকরূপে (অন্য অনেককে)","audioUrl":"wbw/013_016_013.mp3","charTypeName":"word"},{"id":18819,"position":13,"arabic":"لَا","translation":"না","audioUrl":"wbw/013_016_014.mp3","charTypeName":"word"},{"id":18820,"position":14,"arabic":"يَمْلِكُونَ","translation":"তারা সক্ষম হয়","audioUrl":"wbw/013_016_015.mp3","charTypeName":"word"},{"id":18821,"position":15,"arabic":"لِأَنفُسِهِمْ","translation":"তাদের নিজেদের জন্য","audioUrl":"wbw/013_016_016.mp3","charTypeName":"word"},{"id":18822,"position":16,"arabic":"نَفْعًۭا","translation":"কোনো উপকারের","audioUrl":"wbw/013_016_017.mp3","charTypeName":"word"},{"id":18823,"position":17,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/013_016_018.mp3","charTypeName":"word"},{"id":18824,"position":18,"arabic":"ضَرًّۭا ۚ","translation":"কোনো ক্ষতির\"","audioUrl":"wbw/013_016_019.mp3","charTypeName":"word"},{"id":18826,"position":19,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/013_016_021.mp3","charTypeName":"word"},{"id":18827,"position":20,"arabic":"هَلْ","translation":"\"কি