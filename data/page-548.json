ich men may ascribe a share in His divinity!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5149.mp3","surahId":59,"words":[{"id":25854,"position":1,"arabic":"هُوَ","translation":"তিনিই","audioUrl":"wbw/059_023_001.mp3","charTypeName":"word"},{"id":25855,"position":2,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/059_023_002.mp3","charTypeName":"word"},{"id":25856,"position":3,"arabic":"ٱلَّذِى","translation":"যে","audioUrl":"wbw/059_023_003.mp3","charTypeName":"word"},{"id":25857,"position":4,"arabic":"لَآ","translation":"নাই","audioUrl":"wbw/059_023_004.mp3","charTypeName":"word"},{"id":25858,"position":5,"arabic":"إِلَـٰهَ","translation":"কোনো ইলাহ","audioUrl":"wbw/059_023_005.mp3","charTypeName":"word"},{"id":25859,"position":6,"arabic":"إِلَّا","translation":"ব্যতীত","audioUrl":"wbw/059_023_006.mp3","charTypeName":"word"},{"id":25860,"position":7,"arabic":"هُوَ","translation":"তাঁর,","audioUrl":"wbw/059_023_007.mp3","charTypeName":"word"},{"id":25861,"position":8,"arabic":"ٱلْمَلِكُ","translation":"বাদশাহ,","audioUrl":"wbw/059_023_008.mp3","charTypeName":"word"},{"id":25862,"position":9,"arabic":"ٱلْقُدُّوسُ","translation":"অতীব প্রবিত্র,","audioUrl":"wbw/059_023_009.mp3","charTypeName":"word"},{"id":25863,"position":10,"arabic":"ٱلسَّلَـٰمُ","translation":"শান্তিদাতা,","audioUrl":"wbw/059_023_010.mp3","charTypeName":"word"},{"id":25864,"position":11,"arabic":"ٱلْمُؤْمِنُ","translation":"নিরাপত্তাদাতা,","audioUrl":"wbw/059_023_011.mp3","charTypeName":"word"},{"id":25865,"position":12,"arabic":"ٱلْمُهَيْمِنُ","translation":"সংরক্ষক,","audioUrl":"wbw/059_023_012.mp3","charTypeName":"word"},{"id":25866,"position":13,"arabic":"ٱلْعَزِيزُ","translation":"পরাক্রমশালী,","audioUrl":"wbw/059_023_013.mp3","charTypeName":"word"},{"id":25867,"position":14,"arabic":"ٱلْجَبَّارُ","translation":"প্রবল,","audioUrl":"wbw/059_023_014.mp3","charTypeName":"word"},{"id":25868,"position":15,"arabic":"ٱلْمُتَكَبِّرُ ۚ","translation":"মহিমান্বিত,","audioU