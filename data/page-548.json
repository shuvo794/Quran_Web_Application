":"থেকে","audioUrl":"wbw/059_021_010.mp3","charTypeName":"word"},{"id":23918,"position":11,"arabic":"خَشْيَةِ","translation":"ভয়","audioUrl":"wbw/059_021_011.mp3","charTypeName":"word"},{"id":23919,"position":12,"arabic":"ٱللَّهِ ۚ","translation":"আল্লাহর","audioUrl":"wbw/059_021_012.mp3","charTypeName":"word"},{"id":23921,"position":13,"arabic":"وَتِلْكَ","translation":"আর এই","audioUrl":"wbw/059_021_014.mp3","charTypeName":"word"},{"id":23922,"position":14,"arabic":"ٱلْأَمْثَـٰلُ","translation":"উদাহরণ ( সম্পূর্ণ ) ,","audioUrl":"wbw/059_021_015.mp3","charTypeName":"word"},{"id":23923,"position":15,"arabic":"نَضْرِبُهَا","translation":"আমরা তাদের উপস্থাপন করি","audioUrl":"wbw/059_021_016.mp3","charTypeName":"word"},{"id":23924,"position":16,"arabic":"لِلنَّاسِ","translation":"মানুষের কাছে","audioUrl":"wbw/059_021_017.mp3","charTypeName":"word"},{"id":23925,"position":17,"arabic":"لَعَلَّهُمْ","translation":"যেন তারা","audioUrl":"wbw/059_021_018.mp3","charTypeName":"word"},{"id":23926,"position":18,"arabic":"يَتَفَكَّرُونَ","translation":"চিন্তা-ভাবনা করে","audioUrl":"wbw/059_021_019.mp3","charTypeName":"word"},{"id":23927,"position":19,"arabic":"٢١","translation":"(২১)","audioUrl":null,"charTypeName":"end"}]},{"number":22,"arabic":"هُوَ ٱللَّهُ ٱلَّذِى لَآ إِلَٰهَ إِلَّا هُوَ ۖ عَٰلِمُ ٱلْغَيْبِ وَٱلشَّهَٰدَةِ ۖ هُوَ ٱلرَّحْمَٰنُ ٱلرَّحِيمُ","translation":"GOD IS HE save whom there is no deity: the One who knows all that is beyond the reach of a created being’s perception, as well as all that can be wit­nessed by a creature’s senses or mind: He, the Most Gracious, the Dispenser of Grace.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5148.mp3","surahId":59,"words":[{"id":24851,"position":1,"arabic":"هُوَ","translation":"তিনিই","audioUrl":"wbw/059_022_001.mp3","charTypeName":"word"},{"id":24852,"position":2,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/059_022_002.mp3","charTypeName":"word"},{"id":24853,"position":3,"arabic":"ٱلَّذِى