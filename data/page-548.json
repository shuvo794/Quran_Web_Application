{"id":548,"ayahs":[{"number":17,"arabic":"فَكَانَ عَٰقِبَتَهُمَآ أَنَّهُمَا فِى ٱلنَّارِ خَٰلِدَيْنِ فِيهَا ۚ وَذَٰلِكَ جَزَٰٓؤُا۟ ٱلظَّٰلِمِينَ","translation":"Thus, in the end, both [the deniers of the truth and the hypocrites] will find themselves in the fire, therein to abide: for such is the recompense of evil­doers.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5143.mp3","surahId":59,"words":[{"id":19562,"position":1,"arabic":"فَكَانَ","translation":"হল অতঃপর","audioUrl":"wbw/059_017_001.mp3","charTypeName":"word"},{"id":19563,"position":2,"arabic":"عَـٰقِبَتَهُمَآ","translation":"তাদের দুজনের পরিনতি","audioUrl":"wbw/059_017_002.mp3","charTypeName":"word"},{"id":19564,"position":3,"arabic":"أَنَّهُمَا","translation":"দুজনই যে হবে","audioUrl":"wbw/059_017_003.mp3","charTypeName":"word"},{"id":19565,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/059_017_004.mp3","charTypeName":"word"},{"id":19566,"position":5,"arabic":"ٱلنَّارِ","translation":"জাহান্নামের","audioUrl":"wbw/059_017_005.mp3","charTypeName":"word"},{"id":19567,"position":6,"arabic":"خَـٰلِدَيْنِ","translation":"দুজনে চিরকাল থাকবে","audioUrl":"wbw/059_017_006.mp3","charTypeName":"word"},{"id":19568,"position":7,"arabic":"فِيهَا ۚ","translation":"তার মধ্যে","audioUrl":"wbw/059_017_007.mp3","charTypeName":"word"},{"id":19570,"position":8,"arabic":"وَذَٰلِكَ","translation":"এবং এটা","audioUrl":"wbw/059_017_009.mp3","charTypeName":"word"},{"id":19571,"position":9,"arabic":"جَزَٰٓؤُا۟","translation":"প্রতিদান","audioUrl":"wbw/059_017_010.mp3","charTypeName":"word"},{"id":19572,"position":10,"arabic":"ٱلظَّـٰلِمِينَ","translation":"যালিমদের","audioUrl":"wbw/059_017_011.mp3","charTypeName":"word"},{"id":19573,"position":11,"arabic":"١٧","translation":"(১৭)","audioUrl":null,"charTypeName":"end"}]},{"number":18,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ ٱتَّقُوا۟ ٱللَّهَ وَلْتَنظُرْ نَفْسٌۭ مَّا قَدَّمَتْ لِغَدٍۢ ۖ وَٱتَّقُوا۟ ٱللَّهَ ۚ إِنَّ ٱللَّهَ خَبِيرٌۢ بِمَا تَعْمَلُونَ","translation":"O YOU who have attained to faith! Remain conscious of God; and let every human being look to what he sends ahead for the morrow! And [once again]: Remain conscious of God, for God is fully aware of all that you do;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5144.mp3","surahId":59,"words":[{"id":20499,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"ওহে","audioUrl":"wbw/059_018_001.mp3","charTypeName":"word"},{"id":20500,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/059_018_002.mp3","charTypeName":"word"},{"id":20501,"position":3,"arabic":"ءَامَنُوا۟","translation":"ইমান এনেছ","audioUrl":"wbw/059_018_003.mp3","charTypeName":"word"},{"id":20502,"position":4,"arabic":"ٱتَّقُوا۟","translation":"তোমরা ভয়কর","audioUrl":"wbw/059_018_004.mp3","charTypeName":"word"},{"id":20503,"position":5,"arabic":"ٱللَّهَ","translation":"আল্লাহকে","audioUrl":"wbw/059_018_005.mp3","charTypeName":"word"},{"id":20504,"position":6,"arabic":"وَلْتَنظُرْ","translation":"এবং যেন লক্ষ্য করে","audioUrl":"wbw/059_018_006.mp3","charTypeName":"word"},{"id":20505,"position":7,"arabic":"نَفْسٌۭ","translation":"প্রত্যেক ব্যক্তি","audioUrl":"wbw/059_018_007.mp3","charTypeName":"word"},{"id":20506,"position":8,"arabic":"مَّا","translation":"যা","audioUrl":"wbw/059_018_008.mp3","charTypeName":"word"},{"id":20507,"position":9,"arabic":"قَدَّمَتْ","translation":"আগে পাঠিয়েছে","audioUrl":"wbw/059_018_009.mp3","charTypeName":"word"},{"id":20508,"position":10,"arabic":"لِغَدٍۢ ۖ","translation":"আগামীকালে জন্যে","audioUrl":"wbw/059_018_010.mp3","charTypeName":"word"},{"id":20510,"position":11,"arabic":"وَٱتَّقُوا۟","translation":"ও তোমরা ভয়কর","audioUrl":"wbw/059_018_012.mp3","charTypeName":"word"},{"id":20511,"position":12,"arabic":"ٱللَّهَ ۚ","translation":"আল্লাহকে","audioUrl":"wbw/059_018_013.mp3","charTypeName":"word"},{"id":20513,"position":13,"arabic":"إِنَّ","translation":"নিশ্চয়","audioUrl":"wbw/059_018_015.mp3","charTypeNam