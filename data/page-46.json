{"id":46,"ayahs":[{"number":270,"arabic":"وَمَآ أَنفَقْتُم مِّن نَّفَقَةٍ أَوْ نَذَرْتُم مِّن نَّذْرٍۢ فَإِنَّ ٱللَّهَ يَعْلَمُهُۥ ۗ وَمَا لِلظَّٰلِمِينَ مِنْ أَنصَارٍ","translation":"For, whatever you may spend on others, or whatever you may vow [to spend], verily, God knows it; and those who do wrong [by withholding charity] shall have none to succour them.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/277.mp3","surahId":2,"words":[{"id":87670,"position":1,"arabic":"وَمَآ","translation":"এবং যা","audioUrl":"wbw/002_270_001.mp3","charTypeName":"word"},{"id":87671,"position":2,"arabic":"أَنفَقْتُم","translation":"তোমরা ব্যয় করেছ","audioUrl":"wbw/002_270_002.mp3","charTypeName":"word"},{"id":87672,"position":3,"arabic":"مِّن","translation":"কোনো","audioUrl":"wbw/002_270_003.mp3","charTypeName":"word"},{"id":87673,"position":4,"arabic":"نَّفَقَةٍ","translation":"খরচা খরচ","audioUrl":"wbw/002_270_004.mp3","charTypeName":"word"},{"id":87674,"position":5,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/002_270_005.mp3","charTypeName":"word"},{"id":87675,"position":6,"arabic":"نَذَرْتُم","translation":"তোমরা মানত কর","audioUrl":"wbw/002_270_006.mp3","charTypeName":"word"},{"id":87676,"position":7,"arabic":"مِّن","translation":"কোনো","audioUrl":"wbw/002_270_007.mp3","charTypeName":"word"},{"id":87677,"position":8,"arabic":"نَّذْرٍۢ","translation":"মানত","audioUrl":"wbw/002_270_008.mp3","charTypeName":"word"},{"id":87678,"position":9,"arabic":"فَإِنَّ","translation":"নিশ্চয়ই অতঃপর","audioUrl":"wbw/002_270_009.mp3","charTypeName":"word"},{"id":87679,"position":10,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/002_270_010.mp3","charTypeName":"word"},{"id":87680,"position":11,"arabic":"يَعْلَمُهُۥ ۗ","translation":"তা জানেন","audioUrl":"wbw/002_270_011.mp3","charTypeName":"word"},{"id":87682,"position":12,"arabic":"وَمَا","translation":"এবং নেই","audioUrl":"wbw/002_270_013.mp3","charTypeName":"word"},{"id":87683,"position":13,"arabic":"لِلظَّـٰلِمِينَ","translation":"সীমালঙ্ঘনকারীদের জন্য","audioUrl":"wbw/002_270_014.mp3","charTypeName":"word"},{"id":87684,"position":14,"arabic":"مِنْ","translation":"কোনো","audioUrl":"wbw/002_270_015.mp3","charTypeName":"word"},{"id":87685,"position":15,"arabic":"أَنصَارٍ","translation":"সাহায্যকারী","audioUrl":"wbw/002_270_016.mp3","charTypeName":"word"},{"id":87686,"position":16,"arabic":"٢٧٠","translation":"(২৭০)","audioUrl":null,"charTypeName":"end"}]},{"number":271,"arabic":"إِن تُبْدُوا۟ ٱلصَّدَقَٰتِ فَنِعِمَّا هِىَ ۖ وَإِن تُخْفُوهَا وَتُؤْتُوهَا ٱلْفُقَرَآءَ فَهُوَ خَيْرٌۭ لَّكُمْ ۚ وَيُكَفِّرُ عَنكُم مِّن سَيِّـَٔاتِكُمْ ۗ وَٱللَّهُ بِمَا تَعْمَلُونَ خَبِيرٌۭ","translation":"If you do deeds of charity openly, it is well; but if you bestow it upon the needy in secret, it will be even better for you, and it will atone for some of your bad deeds. And God is aware of all that you do.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/278.mp3","surahId":2,"words":[{"id":87687,"position":1,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/002_271_001.mp3","charTypeName":"word"},{"id":87688,"position":2,"arabic":"تُبْدُوا۟","translation":"তোমরা প্রকাশ্যে দাও","audioUrl":"wbw/002_271_002.mp3","charTypeName":"word"},{"id":87689,"position":3,"arabic":"ٱلصَّدَقَـٰتِ","translation":"সদকা সমূহ","audioUrl":"wbw/002_271_003.mp3","charTypeName":"word"},{"id":87690,"position":4,"arabic":"فَنِعِمَّا","translation":"উত্তম তবে","audioUrl":"wbw/002_271_004.mp3","charTypeName":"word"},{"id":87691,"position":5,"arabic":"هِىَ ۖ","translation":"তা","audioUrl":"wbw/002_271_005.mp3","charTypeName":"word"},{"id":87693,"position":6,"arabic":"وَإِن","translation":"আর যদি","audioUrl":"wbw/002_271_007.mp3","charTypeName":"word"},{"id":87694,"position":7,"arabic":"تُخْفُوهَا","translation":"তা তোমরা গোপনে কর","audioUrl":"wbw/002_271_008.mp3","charTypeName":"word"},{"id":87695,"position":8,"arabic":"وَتُؤْتُوهَا","translation":"ও তোমরা তা দাও","audioUrl":"wbw/002_271_009.mp3","charTypeName":"word"},{"id":87696,"position":9,"arabic":"ٱلْفُقَرَآءَ","translation":"অভাবগ্রস্তদেরকে","audioUrl":"wbw/002_271_010.mp3","charTypeName":"word"},{"id":87697,"position":10,"arabic":"فَهُوَ","translation":"তা তবে","audioUrl":"wbw/002_271_011.mp3","charTypeName":"word"},{"id":87698,"position":11,"arabic":"خَيْرٌۭ","translation":"(আরও) ভালো","audioUrl":"wbw/002_271_012.mp3","charTypeName":"word"},{"id":87699,"position":12,"arabic":"لَّكُمْ ۚ","translation":"তোমাদের জন্য","audioUrl":"wbw/002_271_013.mp3","charTypeName":"word"},{"id":87701,"position":13,"arabic":"وَيُكَفِّرُ","translation":"এবং দূর করবেন","audioUrl":"wbw/002_271_015.mp3","charTypeName":"word"},{"id":87702,"position":14,"arabic":"عَنكُم","translation":"তোমাদের থেকে","audioUrl":"wbw/002_271_016.mp3","charTypeName":"word"},{"id":87703,"position":15,"arabic":"مِّن","translation":"কিছু কিছু","audioUrl":"wbw/002_271_017.mp3","charTypeName":"word"},{"id":87704,"position":16,"arabic":"سَيِّـَٔاتِكُمْ ۗ","translation":"তোমাদের পাপগুলো","audioUrl":"wbw/002_271_018.mp3","charTypeName":"word"},{"id":87706,"position":17,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/002_271_020.mp3","charTypeName":"word"},{"id":87707,"position":18,"arabic":"بِمَا","translation":"ঐ বিষয় যা","audioUrl":"wbw/002_271_021.mp3","charTypeName":"word"},{"id":87708,"position":19,"arabic":"تَعْمَلُونَ","translation":"তোমরা কাজ কর","audioUrl":"wbw/002_271_022.mp3","charTypeName":"word"},{"id":87709,"position":20,"arabic":"خَبِيرٌۭ","translation":"ভালোভাবে অবহিত","audioUrl":"wbw/002_271_023.mp3","charTypeName":"word"},{"id":87710,"position":21,"arabic":"٢٧١","translation":"(২৭১)","audioUrl":null,"charTypeName":"end"}]},{"number":272,"arabic":"۞ لَّيْسَ عَلَيْكَ هُدَىٰهُمْ وَلَٰكِنَّ ٱللَّهَ يَهْدِى مَن يَشَآءُ ۗ وَمَا تُنفِقُوا۟ مِنْ خَيْرٍۢ فَلِأَنفُسِكُمْ ۚ وَمَا تُنفِقُونَ إِلَّا ٱبْتِغَآءَ وَجْهِ ٱللَّهِ ۚ وَمَا تُنفِقُوا۟ مِنْ خَيْرٍۢ يُوَفَّ إِلَيْكُمْ وَأَنتُمْ لَا تُظْلَمُونَ","translation":"It is not for thee [O Prophet] to make people follow the right path, since it is God [alone] who guides whom He wills. And whatever good you may spend on others is for your own good, provided that you spend only out of a longing for God's countenance: for, whatever good you may spend will be repaid unto you in full, and you shall not be wronged.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/279.mp3","surahId":2,"words":[{"id":87712,"position":1,"arabic":"۞ لَّيْسَ","translation":"নয়","audioUrl":"wbw/002_272_002.mp3","charTypeName":"word"},{"id":87713,"position":2,"arabic":"عَلَيْكَ","translation":"তোমার উপর (দায়িত্ব)","audioUrl":"wbw/002_272_003.mp3","charTypeName":"word"},{"id":87714,"position":3,"arabic":"هُدَىٰهُمْ","translation":"তাদের সৎপথ গ্রহণের","audioUrl":"wbw/002_272_004.mp3","charTypeName":"word"},{"id":87715,"position":4,"arabic":"وَلَـٰكِنَّ","translation":"কিন্তু","audioUrl":"wbw/002_272_005.mp3","charTypeName":"word"},{"id":87716,"position":5,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/002_272_006.mp3","charTypeName":"word"},{"id":87717,"position":6,"arabic":"يَهْدِى","translation":"পথ দেখান","audioUrl":"wbw/002_272_007.mp3","charTypeName":"word"},{"id":87718,"position":7,"arabic":"مَن","translation":"যাকে","audioUrl":"wbw/002_272_008.mp3","charTypeName":"word"},{"id":87719,"position":8,"arabic":"يَشَآءُ ۗ","translation":"তিনি চান","audioUrl":"wbw/002_272_009.mp3","charTypeName":"word"},{"id":87721,"position":9,"arabic":"وَمَا","translation":"এবং যা","audioUrl":"wbw/002_272_011.mp3","charTypeName":"word"},{"id":87722,"position":10,"arabic":"تُنفِقُوا۟","translation":"তোমরা ব্যয় কর","audioUrl":"wbw/002_272_012.mp3","charTypeName":"word"},{"id":87723,"position":11,"arabic":"مِنْ","translation":"কোনো","audioUrl":"wbw/002_272_013.mp3","charTypeName":"word"},{"id":87724,"position":12,"arabic":"خَيْرٍۢ","translation":"সম্পদ","audioUrl":"wbw/002_272_014.mp3","charTypeName":"word"},{"id":87725,"position":13,"arabic":"فَلِأَنفُسِكُمْ ۚ","translation":"তোমাদের তবে তা নিজেদের জন্য","audioUrl":"wbw/002_272_015.mp3","charTypeName":"word"},{"id":87727,"position":14,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/002_272_017.mp3","charTypeName":"word"},{"id":87728,"position":15,"arabic":"تُنفِقُونَ","translation":"তোমরা ব্যয় কর","audioUrl":"wbw/002_272_018.mp3","charTypeName":"word"},{"id":87729,"position":16,"arabic":"إِلَّا","translation":"এছাড়া যে","audioUrl":"wbw/002_272_019.mp3","charTypeName":"word"},{"id":87730,"position":17,"arabic":"ٱبْتِغَآءَ","translation":"সন্ধানে","audioUrl":"wbw/002_272_020.mp3","charTypeName":"word"},{"id":87731,"position":18,"arabic":"وَجْهِ","translation":"চেহারা","audioUrl":"wbw/002_272_021.mp3","charTypeName":"word"},{"id":87732,"position":19,"arabic":"ٱللَّهِ ۚ","translation":"আল্লাহর","audioUrl":"wbw/002_272_022.mp3","charTypeName":"word"},{"id":87734,"position":20,"arabic":"وَمَا","translation":"এবং যা","audioUrl":"wbw/002_272_024.mp3","charTypeName":"word"},{"id":87735,"position":21,"arabic":"تُنفِقُوا۟","translation":"তোমরা খরচ কর","audioUrl":"wbw/002_272_025.mp3","charTypeName":"word"},{"id":87736,"position":22,"arabic":"مِنْ","translation":"কোনো","audioUrl":"wbw/002_272_026.mp3","charTypeName":"word"},{"id":87737,"position":23,"arabic":"خَيْرٍۢ","translation":"সম্পদ","audioUrl":"wbw/002_272_027.mp3","charTypeName":"word"},{"id":87738,"position":24,"arabic":"يُوَفَّ","translation":"পূর্ণ দেয়া হবে","audioUrl":"wbw/002_272_028.mp3","charTypeName":"word"},{"id":87739,"position":25,"arabic":"إِلَيْكُمْ","translation":"তোমাদের প্রতি","audioUrl":"wbw/002_272_029.mp3","charTypeName":"word"},{"id":87740,"position":26,"arabic":"وَأَنتُمْ","translation":"ও তোমাদের (প্রতি)","audioUrl":"wbw/002_272_030.mp3","charTypeName":"word"},{"id":87741,"position":27,"arabic":"لَا","translation":"না","audioUrl":"wbw/002_272_031.mp3","charTypeName":"word"},{"id":87742,"position":28,"arabic":"تُظْلَمُونَ","translation":"অন্যায় করা হবে","audioUrl":"wbw/002_272_032.mp3","charTypeName":"word"},{"id":87743,"position":29,"arabic":"٢٧٢","translation":"(২৭২)","audioUrl":null,"charTypeName":"end"}]},{"number":273,"arabic":"لِلْفُقَرَآءِ ٱلَّذِينَ أُحْصِرُوا۟ فِى سَبِيلِ ٱللَّهِ لَا يَسْتَطِيعُونَ ضَرْبًۭا فِى ٱلْأَرْضِ يَحْسَبُهُمُ ٱلْجَاهِلُ أَغْنِيَآءَ مِنَ ٱلتَّعَفُّفِ تَعْرِفُهُم بِسِيمَٰهُمْ لَا يَسْـَٔلُونَ ٱلنَّاسَ إِلْحَافًۭا ۗ وَمَا تُنفِقُوا۟ مِنْ خَيْرٍۢ فَإِنَّ ٱللَّهَ بِهِۦ عَلِيمٌ","translation":"[And give] unto [such of] the needy who, being wholly wrapped up in God's cause, are unable to go about the earth [in search of livelihood]. He who is unaware [of their condition] might think that they are wealthy, because they abstain [from begging]; [but] thou canst recognize them by their special mark: they do not beg of men with importunity. And whatever good you may spend [on them], verily, God knows it all.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/280.mp3","surahId":2,"words":[{"id":87744,"position":1,"arabic":"لِلْفُقَرَآءِ","translation":"অভাবগ্রস্তদের জন্য","audioUrl":"wbw/002_273_001.mp3","charTypeName":"word"},{"id":87745,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/002_273_002.mp3","charTypeName":"word"},{"id":87746,"position":3,"arabic":"أُحْصِرُوا۟","translation":"আটকে পড়েছে (ব্যস্ততার কারণে)","audioUrl":"wbw/002_273_003.mp3","charTypeName":"word"},{"id":87747,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/002_273_004.mp3","charTypeName":"word"},{"id":87748,"position":5,"arabic":"سَبِيلِ","translation":"পথের","audioUrl":"wbw/002_273_005.mp3","charTypeName":"word"},{"id":87749,"position":6,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/002_273_006.mp3","charTypeName":"word"},{"id":87750,"position":7,"arabic":"لَا","translation":"না","audioUrl":"wbw/002_273_007.mp3","charTypeName":"word"},{"id":87751,"position":8,"arabic":"يَسْتَطِيعُونَ","translation":"তারা পারে","audioUrl":"wbw/002_273_008.mp3","charTypeName":"word"},{"id":87752,"position":9,"arabic":"ضَرْبًۭا","translation":"ঘোরাফিরা করতে","audioUrl":"wbw/002_273_009.mp3","charTypeName":"word"},{"id":87753,"position":10,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/002_273_010.mp3","charTypeName":"word"},{"id":87754,"position":11,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর (অর্থাৎ উপার্জন করতে)","audioUrl":"wbw/002_273_011.mp3","charTypeName":"word"},{"id":87755,"position":12,"arabic":"يَحْسَبُهُمُ","translation":"তাদেরকে মনে করে","audioUrl":"wbw/002_273_012.mp3","charTypeName":"word"},{"id":87756,"position":13,"arabic":"ٱلْجَاهِلُ","translation":"অজ্ঞ লোকেরা","audioUrl":"wbw/002_273_013.mp3","charTypeName":"word"},{"id":87757,"position":14,"arabic":"أَغْنِيَآءَ","translation":"অভাবমুক্ত","audioUrl":"wbw/002_273_014.mp3","charTypeName":"word"},{"id":87758,"position":15,"arabic":"مِنَ","translation":"কারণে","audioUrl":"wbw/002_273_015.mp3","charTypeName":"word"},{"id":87759,"position":16,"arabic":"ٱلتَّعَفُّفِ","translation":"না চাওয়ার","audioUrl":"wbw/002_273_016.mp3","charTypeName":"word"},{"id":87760,"position":17,"arabic":"تَعْرِفُهُم","translation":"তাদেরকে তুমি চিনবে","audioUrl":"wbw/002_273_017.mp3","charTypeName":"word"},{"id":87761,"position":18,"arabic":"بِسِيمَـٰهُمْ","translation":"তাদের লক্ষণ দিয়ে","audioUrl":"wbw/002_273_018.mp3","charTypeName":"word"},{"id":87762,"position":19,"arabic":"لَا","translation":"না","audioUrl":"wbw/002_273_019.mp3","charTypeName":"word"},{"id":87763,"position":20,"arabic":"يَسْـَٔلُونَ","translation":"তারা চায়","audioUrl":"wbw/002_273_020.mp3","charTypeName":"word"},{"id":87764,"position":21,"arabic":"ٱلنَّاسَ","translation":"মানুষ (থেকে)","audioUrl":"wbw/002_273_021.mp3","charTypeName":"word"},{"id":87765,"position":22,"arabic":"إِلْحَافًۭا ۗ","translation":"নাছোড় হয়ে","audioUrl":"wbw/002_273_022.mp3","charTypeName":"word"},{"id":87767,"position":23,"arabic":"وَمَا","translation":"এবং যা","audioUrl":"wbw/002_273_024.mp3","charTypeName":"word"},{"id":87768,"position":24,"arabic":"تُنفِقُوا۟","translation":"তো