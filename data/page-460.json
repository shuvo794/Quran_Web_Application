{"id":460,"ayahs":[{"number":11,"arabic":"قُلْ إِنِّىٓ أُمِرْتُ أَنْ أَعْبُدَ ٱللَّهَ مُخْلِصًۭا لَّهُ ٱلدِّينَ","translation":"Say [O Muhammad]: “Behold, I am bidden to worship God, sincere in my faith in Him alone;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4069.mp3","surahId":39,"words":[{"id":13374,"position":1,"arabic":"قُلْ","translation":"(হে নাবী) বলো","audioUrl":"wbw/039_011_001.mp3","charTypeName":"word"},{"id":13375,"position":2,"arabic":"إِنِّىٓ","translation":"\"নিশ্চয়ই আমি","audioUrl":"wbw/039_011_002.mp3","charTypeName":"word"},{"id":13376,"position":3,"arabic":"أُمِرْتُ","translation":"আমি আদিষ্ট হয়েছি","audioUrl":"wbw/039_011_003.mp3","charTypeName":"word"},{"id":13377,"position":4,"arabic":"أَنْ","translation":"যে","audioUrl":"wbw/039_011_004.mp3","charTypeName":"word"},{"id":13378,"position":5,"arabic":"أَعْبُدَ","translation":"আমি (যেন) ইবাদত করি","audioUrl":"wbw/039_011_005.mp3","charTypeName":"word"},{"id":13379,"position":6,"arabic":"ٱللَّهَ","translation":"আল্লাহর","audioUrl":"wbw/039_011_006.mp3","charTypeName":"word"},{"id":13380,"position":7,"arabic":"مُخْلِصًۭا","translation":"একনিষ্ঠভাবে","audioUrl":"wbw/039_011_007.mp3","charTypeName":"word"},{"id":13381,"position":8,"arabic":"لَّهُ","translation":"তাঁরই জন্যে","audioUrl":"wbw/039_011_008.mp3","charTypeName":"word"},{"id":13382,"position":9,"arabic":"ٱلدِّينَ","translation":"আনুগত্যকে (নির্দিষ্ট করে)","audioUrl":"wbw/039_011_009.mp3","charTypeName":"word"},{"id":13383,"position":10,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]},{"number":12,"arabic":"وَأُمِرْتُ لِأَنْ أَكُونَ أَوَّلَ ٱلْمُسْلِمِينَ","translation":"and I am bidden to be foremost among those who surrender themselves unto God.”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4070.mp3","surahId":39,"words":[{"id":14657,"position":1,"arabic":"وَأُمِرْتُ","translation":"এবং আমি আদিষ্ট হয়েছি","audioUrl":"wbw/039_012_001.mp3","charTypeName":"word"},{"id":1465