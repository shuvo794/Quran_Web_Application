w/039_015_019.mp3","charTypeName":"word"},{"id":17977,"position":18,"arabic":"ٱلْخُسْرَانُ","translation":"ক্ষতি","audioUrl":"wbw/039_015_020.mp3","charTypeName":"word"},{"id":17978,"position":19,"arabic":"ٱلْمُبِينُ","translation":"সুস্পষ্ট\"","audioUrl":"wbw/039_015_021.mp3","charTypeName":"word"},{"id":17979,"position":20,"arabic":"١٥","translation":"(১৫)","audioUrl":null,"charTypeName":"end"}]},{"number":16,"arabic":"لَهُم مِّن فَوْقِهِمْ ظُلَلٌۭ مِّنَ ٱلنَّارِ وَمِن تَحْتِهِمْ ظُلَلٌۭ ۚ ذَٰلِكَ يُخَوِّفُ ٱللَّهُ بِهِۦ عِبَادَهُۥ ۚ يَٰعِبَادِ فَٱتَّقُونِ","translation":"Clouds of fire will they have above them, and [similar] clouds beneath them…” In this way does God imbue His servants with fear. O you servants of Mine! Be, then, conscious of Me -","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4074.mp3","surahId":39,"words":[{"id":18968,"position":1,"arabic":"لَهُم","translation":"তাদের জন্যে (রয়েছে)","audioUrl":"wbw/039_016_001.mp3","charTypeName":"word"},{"id":18969,"position":2,"arabic":"مِّن","translation":"হ'তে","audioUrl":"wbw/039_016_002.mp3","charTypeName":"word"},{"id":18970,"position":3,"arabic":"فَوْقِهِمْ","translation":"তাদের উপর (দিক)","audioUrl":"wbw/039_016_003.mp3","charTypeName":"word"},{"id":18971,"position":4,"arabic":"ظُلَلٌۭ","translation":"আচ্ছাদন","audioUrl":"wbw/039_016_004.mp3","charTypeName":"word"},{"id":18972,"position":5,"arabic":"مِّنَ","translation":"তৈরী","audioUrl":"wbw/039_016_005.mp3","charTypeName":"word"},{"id":18973,"position":6,"arabic":"ٱلنَّارِ","translation":"আগুনের","audioUrl":"wbw/039_016_006.mp3","charTypeName":"word"},{"id":18974,"position":7,"arabic":"وَمِن","translation":"ও হ'তে","audioUrl":"wbw/039_016_007.mp3","charTypeName":"word"},{"id":18975,"position":8,"arabic":"تَحْتِهِمْ","translation":"তাদের নীচ","audioUrl":"wbw/039_016_008.mp3","charTypeName":"word"},{"id":18976,"position":9,"arabic":"ظُلَلٌۭ ۚ","translation":"(আগুনের) আচ্ছাদন","audioUrl":"wbw/039_016_009.mp3","charTypeName":"word"},{