{"id":66,"ayahs":[{"number":122,"arabic":"إِذْ هَمَّت طَّآئِفَتَانِ مِنكُمْ أَن تَفْشَلَا وَٱللَّهُ وَلِيُّهُمَا ۗ وَعَلَى ٱللَّهِ فَلْيَتَوَكَّلِ ٱلْمُؤْمِنُونَ","translation":"when two groups from among you were about to lose heart, although God was near unto them and it is in God that the believers must place their trust:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/415.mp3","surahId":3,"words":[{"id":76773,"position":1,"arabic":"إِذْ","translation":"(স্মরণ কর) যখন","audioUrl":"wbw/003_122_001.mp3","charTypeName":"word"},{"id":76774,"position":2,"arabic":"هَمَّت","translation":"মনস্থ করেছিলে","audioUrl":"wbw/003_122_002.mp3","charTypeName":"word"},{"id":76775,"position":3,"arabic":"طَّآئِفَتَانِ","translation":"দুইদল","audioUrl":"wbw/003_122_003.mp3","charTypeName":"word"},{"id":76776,"position":4,"arabic":"مِنكُمْ","translation":"তোমাদের মধ্যকার","audioUrl":"wbw/003_122_004.mp3","charTypeName":"word"},{"id":76777,"position":5,"arabic":"أَن","translation":"(যে)","audioUrl":"wbw/003_122_005.mp3","charTypeName":"word"},{"id":76778,"position":6,"arabic":"تَفْشَلَا","translation":"দুর্বলতা প্রদর্শনের","audioUrl":"wbw/003_122_006.mp3","charTypeName":"word"},{"id":76779,"position":7,"arabic":"وَٱللَّهُ","translation":"অথচ আল্লাহ","audioUrl":"wbw/003_122_007.mp3","charTypeName":"word"},{"id":76780,"position":8,"arabic":"وَلِيُّهُمَا ۗ","translation":"তাদের উভয়ের পৃষ্ঠপোষক (ছিলেন)","audioUrl":"wbw/003_122_008.mp3","charTypeName":"word"},{"id":76782,"position":9,"arabic":"وَعَلَى","translation":"এবং উপর","audioUrl":"wbw/003_122_010.mp3","charTypeName":"word"},{"id":76783,"position":10,"arabic":"ٱللَّهِ","translation":"আল্লাহরই","audioUrl":"wbw/003_122_011.mp3","charTypeName":"word"},{"id":76784,"position":11,"arabic":"فَلْيَتَوَكَّلِ","translation":"ভরসা করা উচিত","audioUrl":"wbw/003_122_012.mp3","charTypeName":"word"},{"id":76785,"position":12,"arabic":"ٱلْمُؤْمِنُونَ","translation":"ঈমানদারদের","audioUrl":"wbw/003_122_013.mp3","charTypeName":"word"},{"id":76786,"position":13,"arabic":"١٢٢","translation":"(১২২)","audioUrl":null,"charTypeName":"end"}]},{"number":123,"arabic":"وَلَقَدْ نَصَرَكُمُ ٱللَّهُ بِبَدْرٍۢ وَأَنتُمْ أَذِلَّةٌۭ ۖ فَٱتَّقُوا۟ ٱللَّهَ لَعَلَّكُمْ تَشْكُرُونَ","translation":"for, indeed, God did succour you at Badr, when you were utterly weak. Remain, then, conscious of God, so that you might have cause to be grateful.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/416.mp3","surahId":3,"words":[{"id":76863,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়","audioUrl":"wbw/003_123_001.mp3","charTypeName":"word"},{"id":76864,"position":2,"arabic":"نَصَرَكُمُ","translation":"তোমাদের সাহায্য করেছিলেন","audioUrl":"wbw/003_123_002.mp3","charTypeName":"word"},{"id":76865,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/003_123_003.mp3","charTypeName":"word"},{"id":76866,"position":4,"arabic":"بِبَدْرٍۢ","translation":"বদরে","audioUrl":"wbw/003_123_004.mp3","charTypeName":"word"},{"id":76867,"position":5,"arabic":"وَأَنتُمْ","translation":"অথচ তোমরা (ছিলে)","audioUrl":"wbw/003_123_005.mp3","charTypeName":"word"},{"id":76868,"position":6,"arabic":"أَذِلَّةٌۭ ۖ","translation":"দুর্বল","audioUrl":"wbw/003_123_006.mp3","charTypeName":"word"},{"id":76870,"position":7,"arabic":"فَٱتَّقُوا۟","translation":"তোমরা তাই ভয় কর","audioUrl":"wbw/003_123_008.mp3","charTypeName":"word"},{"id":76871,"position":8,"arabic":"ٱللَّهَ","translation":"আল্লাহ্‌কে","audioUrl":"wbw/003_123_009.mp3","charTypeName":"word"},{"id":76872,"position":9,"arabic":"لَعَلَّكُمْ","translation":"তোমরা সম্ভবত","audioUrl":"wbw/003_123_010.mp3","charTypeName":"word"},{"id":76873,"position":10,"arabic":"تَشْكُرُونَ","translation":"শোকর করবে","audioUrl":"wbw/003_123_011.mp3","charTypeName":"word"},{"id":76874,"position":11,"arabic":"١٢٣","translation":"(১২৩)","audioUrl":null,"charTypeName":"end"}]},{"number":124,"arabic":"إِذْ تَقُولُ لِلْمُؤْمِنِينَ أَلَن يَكْفِيَكُمْ أَن يُمِدَّكُمْ رَبُّكُم 