l":"wbw/003_124_013.mp3","charTypeName":"word"},{"id":77030,"position":14,"arabic":"١٢٤","translation":"(১২৪)","audioUrl":null,"charTypeName":"end"}]},{"number":125,"arabic":"بَلَىٰٓ ۚ إِن تَصْبِرُوا۟ وَتَتَّقُوا۟ وَيَأْتُوكُم مِّن فَوْرِهِمْ هَٰذَا يُمْدِدْكُمْ رَبُّكُم بِخَمْسَةِ ءَالَٰفٍۢ مِّنَ ٱلْمَلَٰٓئِكَةِ مُسَوِّمِينَ","translation":"Nay, but if you are patient in adversity and conscious of Him, and the enemy should fall upon you of a sudden, your Sustainer will aid you with five thousand angels swooping down!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/418.mp3","surahId":3,"words":[{"id":77179,"position":1,"arabic":"بَلَىٰٓ ۚ","translation":"হ্যাঁ (নিশ্চয়)","audioUrl":"wbw/003_125_001.mp3","charTypeName":"word"},{"id":77181,"position":2,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/003_125_003.mp3","charTypeName":"word"},{"id":77182,"position":3,"arabic":"تَصْبِرُوا۟","translation":"তোমরা সবর কর","audioUrl":"wbw/003_125_004.mp3","charTypeName":"word"},{"id":77183,"position":4,"arabic":"وَتَتَّقُوا۟","translation":"ও (আল্লাহ্‌কে) ভয় কর","audioUrl":"wbw/003_125_005.mp3","charTypeName":"word"},{"id":77184,"position":5,"arabic":"وَيَأْتُوكُم","translation":"আর (যদি) তোমাদের উপর আসবে (চড়াও হয়ে)","audioUrl":"wbw/003_125_006.mp3","charTypeName":"word"},{"id":77185,"position":6,"arabic":"مِّن","translation":"(থেকে)","audioUrl":"wbw/003_125_007.mp3","charTypeName":"word"},{"id":77186,"position":7,"arabic":"فَوْرِهِمْ","translation":"তাদের ত্বরিত গতিতে","audioUrl":"wbw/003_125_008.mp3","charTypeName":"word"},{"id":77187,"position":8,"arabic":"هَـٰذَا","translation":"এই (মুহূর্তে)","audioUrl":"wbw/003_125_009.mp3","charTypeName":"word"},{"id":77188,"position":9,"arabic":"يُمْدِدْكُمْ","translation":"তোমাদেরকে সাহায্য করবেন","audioUrl":"wbw/003_125_010.mp3","charTypeName":"word"},{"id":77189,"position":10,"arabic":"رَبُّكُم","translation":"তোমাদের রব","audioUrl":"wbw/003_125_011.mp3","charTypeName":"word"},{"id":77190,"position":11,"arabic":