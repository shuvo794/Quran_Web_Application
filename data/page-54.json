{"id":54,"ayahs":[{"number":30,"arabic":"يَوْمَ تَجِدُ كُلُّ نَفْسٍۢ مَّا عَمِلَتْ مِنْ خَيْرٍۢ مُّحْضَرًۭا وَمَا عَمِلَتْ مِن سُوٓءٍۢ تَوَدُّ لَوْ أَنَّ بَيْنَهَا وَبَيْنَهُۥٓ أَمَدًۢا بَعِيدًۭا ۗ وَيُحَذِّرُكُمُ ٱللَّهُ نَفْسَهُۥ ۗ وَٱللَّهُ رَءُوفٌۢ بِٱلْعِبَادِ","translation":"On the Day when every human being will find himself faced with all the good that he has done, and with all the evil that he has done, [many a one] will wish that there were a long span of time between himself and that [Day]. Hence, God warns you to beware of Him; but God is most compassionate towards His creatures.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/323.mp3","surahId":3,"words":[{"id":32833,"position":1,"arabic":"يَوْمَ","translation":"যেদিন","audioUrl":"wbw/003_030_001.mp3","charTypeName":"word"},{"id":32834,"position":2,"arabic":"تَجِدُ","translation":"পাবে","audioUrl":"wbw/003_030_002.mp3","charTypeName":"word"},{"id":32835,"position":3,"arabic":"كُلُّ","translation":"প্রত্যেক","audioUrl":"wbw/003_030_003.mp3","charTypeName":"word"},{"id":32836,"position":4,"arabic":"نَفْسٍۢ","translation":"ব্যক্তি","audioUrl":"wbw/003_030_004.mp3","charTypeName":"word"},{"id":32837,"position":5,"arabic":"مَّا","translation":"যা","audioUrl":"wbw/003_030_005.mp3","charTypeName":"word"},{"id":32838,"position":6,"arabic":"عَمِلَتْ","translation":"সে কাজ করেছে","audioUrl":"wbw/003_030_006.mp3","charTypeName":"word"},{"id":32839,"position":7,"arabic":"مِنْ","translation":"কোন","audioUrl":"wbw/003_030_007.mp3","charTypeName":"word"},{"id":32840,"position":8,"arabic":"خَيْرٍۢ","translation":"ভাল (কাজ)","audioUrl":"wbw/003_030_008.mp3","charTypeName":"word"},{"id":32841,"position":9,"arabic":"مُّحْضَرًۭا","translation":"বিদ্যমান (পাবে)","audioUrl":"wbw/003_030_009.mp3","charTypeName":"word"},{"id":32842,"position":10,"arabic":"وَمَا","translation":"আর যা কিছু","audioUrl":"wbw/003_030_010.mp3","charTypeName":"word"},{"id":32843,"position":11,"arabic":"عَمِلَتْ","translation":"কাজ করেছে","audioUrl":"wbw/003_030_011.mp3","charTypeName":"word"},{"id":32844,"position":12,"arabic":"مِن","translation":"কোন","audioUrl":"wbw/003_030_012.mp3","charTypeName":"word"},{"id":32845,"position":13,"arabic":"سُوٓءٍۢ","translation":"মন্দ","audioUrl":"wbw/003_030_013.mp3","charTypeName":"word"},{"id":32846,"position":14,"arabic":"تَوَدُّ","translation":"সে কামনা করবে","audioUrl":"wbw/003_030_014.mp3","charTypeName":"word"},{"id":32847,"position":15,"arabic":"لَوْ","translation":"যদি","audioUrl":"wbw/003_030_015.mp3","charTypeName":"word"},{"id":32848,"position":16,"arabic":"أَنَّ","translation":"(এমন হতো) যে","audioUrl":"wbw/003_030_016.mp3","charTypeName":"word"},{"id":32849,"position":17,"arabic":"بَيْنَهَا","translation":"তার মাঝে (ব্যক্তির)","audioUrl":"wbw/003_030_017.mp3","charTypeName":"word"},{"id":32850,"position":18,"arabic":"وَبَيْنَهُۥٓ","translation":"ও তার মাঝে (মন্দ কাজের)","audioUrl":"wbw/003_030_018.mp3","charTypeName":"word"},{"id":32851,"position":19,"arabic":"أَمَدًۢا","translation":"ব্যবধান","audioUrl":"wbw/003_030_019.mp3","charTypeName":"word"},{"id":32852,"position":20,"arabic":"بَعِيدًۭا ۗ","translation":"সুদূর","audioUrl":"wbw/003_030_020.mp3","charTypeName":"word"},{"id":32854,"position":21,"arabic":"وَيُحَذِّرُكُمُ","translation":"এবং তোমাদেরকে সাবধান করছেন","audioUrl":"wbw/003_030_022.mp3","charTypeName":"word"},{"id":32855,"position":22,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/003_030_023.mp3","charTypeName":"word"},{"id":32856,"position":23,"arabic":"نَفْسَهُۥ ۗ","translation":"তার নিজের (সম্পর্কে)","audioUrl":"wbw/003_030_024.mp3","charTypeName":"word"},{"id":32858,"position":24,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/003_030_026.mp3","charTypeName":"word"},{"id":32859,"position":25,"arabic":"رَءُوفٌۢ","translation":"দয়াশীল","audioUrl":"wbw/003_030_027.mp3","charTypeName":"word"},{"id":32860,"position":26,"arabic":"بِٱلْعِبَادِ","translation":"বান্দাদের উপর","audioUrl":"wbw/003_030_028.mp3","charTypeName":"word"},{"id":32861,"position":27,"arabic":"٣٠","translation":"(৩০)","audioUrl":null,"charTypeName":"end"}]},{"number":31,"arabic":"قُلْ إِن كُنتُمْ تُحِبُّونَ ٱللَّهَ فَٱتَّبِعُونِى يُحْبِبْكُمُ ٱللَّهُ وَيَغْفِرْ لَكُمْ ذُنُوبَكُمْ ۗ وَٱللَّهُ غَفُورٌۭ رَّحِيمٌۭ","translation":"Say [O Prophet]: \"If you love God, follow me, [and] God will love you and forgive you your sins; for God is much-forgiving, a dispenser of grace.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/324.mp3","surahId":3,"words":[{"id":33638,"position":1,"arabic":"قُلْ","translation":"(হে নবী) তুমি বল","audioUrl":"wbw/003_031_001.mp3","charTypeName":"word"},{"id":33639,"position":2,"arabic":"إِن","translation":"''যদি","audioUrl":"wbw/003_031_002.mp3","charTypeName":"word"},{"id":33640,"position":3,"arabic":"كُنتُمْ","translation":"তোমরা","audioUrl":"wbw/003_031_003.mp3","charTypeName":"word"},{"id":33641,"position":4,"arabic":"تُحِبُّونَ","translation":"ভালবেসে থাক","audioUrl":"wbw/003_031_004.mp3","charTypeName":"word"},{"id":33642,"position":5,"arabic":"ٱللَّهَ","translation":"আল্লাহকে","audioUrl":"wbw/003_031_005.mp3","charTypeName":"word"},{"id":33643,"position":6,"arabic":"فَٱتَّبِعُونِى","translation":"আমাকে তোমরা তবে অনুসরণ কর","audioUrl":"wbw/003_031_006.mp3","charTypeName":"word"},{"id":33644,"position":7,"arabic":"يُحْبِبْكُمُ","translation":"ভালোবাসবেন তোমাদেরকে","audioUrl":"wbw/003_031_007.mp3","charTypeName":"word"},{"id":33645,"position":8,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/003_031_008.mp3","charTypeName":"word"},{"id":33646,"position":9,"arabic":"وَيَغْفِرْ","translation":"এবং মাফ করবেন","audioUrl":"wbw/003_031_009.mp3","charTypeName":"word"},{"id":33647,"position":10,"arabic":"لَكُمْ","translation":"তোমাদের জন্য","audioUrl":"wbw/003_031_010.mp3","charTypeName":"word"},{"id":33648,"position":11,"arabic":"ذُنُوبَكُمْ ۗ","translation":"গুনাহ সমুহকে","audioUrl":"wbw/003_031_011.mp3","charTypeName":"word"},{"id":33650,"position":12,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/003_031_013.mp3","charTypeName":"word"},{"id":33651,"position":13,"arabic":"غَفُورٌۭ","translation":"বড় ক্ষমাশীল","audioUrl":"wbw/003_031_014.mp3","charTypeName":"word"},{"id":33652,"position":14,"arabic":"رَّحِيمٌۭ","translation":"মেহেরবান","audioUrl":"wbw/003_031_015.mp3","charTypeName":"word"},{"id":33653,"position":15,"arabic":"٣١","translation":"(৩১)","audioUrl":null,"charTypeName":"end"}]},{"number":32,"arabic":"قُلْ أَطِيعُوا۟ ٱللَّهَ وَٱلرَّسُولَ ۖ فَإِن تَوَلَّوْا۟ فَإِنَّ ٱللَّهَ لَا يُحِبُّ ٱلْكَٰفِرِينَ","translation":"Say: “Pay heed unto God and the Apostle.” And if they turn away - verely, God does not love those who deny the truth.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/325.mp3","surahId":3,"words":[{"id":34714,"position":1,"arabic":"قُلْ","translation":"তুমি বল","audioUrl":"wbw/003_032_001.mp3","charTypeName":"word"},{"id":34715,"position":2,"arabic":"أَطِيعُوا۟","translation":"''আনুগত্য কর তোমরা","audioUrl":"wbw/003_032_002.mp3","charTypeName":"word"},{"id":34716,"position":3,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/003_032_003.mp3","charTypeName":"word"},{"id":34717,"position":4,"arabic":"وَٱلرَّسُولَ ۖ","translation":"ও রাসূলের''","audioUrl":"wbw/003_032_004.mp3","charTypeName":"word"},{"id":34719,"position":5,"arabic":"فَإِن","translation":"আত্ঃপর যদি","audioUrl":"wbw/003_032_006.mp3","charTypeName":"word"},{"id":34720,"position":6,"arabic":"تَوَلَّوْا۟","translation":"তারা মুখ ফিরায়","audioUrl":"wbw/003_032_007.mp3","charTypeName":"word"},{"id":34721,"position":7,"arabic":"فَإِنَّ","translation":"তবে নিশ্চয়","audioUrl":"wbw/003_032_008.mp3","charTypeName":"word"},{"id":34722,"position":8,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/003_032_009.mp3","charTypeName":"word"},{"id":34723,"position":9,"arabic":"لَا","translation":"না","audioUrl":"wbw/003_032_010.mp3","charTypeName":"word"},{"id":34724,"position":10,"arabic":"يُحِبُّ","translation":"ভালোবাসেন","audioUrl":"wbw/003_032_011.mp3","charTypeName":"word"},{"id":34725,"position":11,"arabic":"ٱلْكَـٰفِرِينَ","translation":"কাফিরদের কে","audioUrl":"wbw/003_032_012.mp3","charTypeName":"word"},{"id":34726,"position":12,"arabic":"٣٢","translation":"(৩২)","audioUrl":null,"charTypeName":"end"}]},{"number":33,"arabic":"۞ إِنَّ ٱللَّهَ ٱصْطَفَىٰٓ ءَادَمَ وَنُوحًۭا وَءَالَ إِبْرَٰهِيمَ وَءَالَ عِمْرَٰنَ عَلَى ٱلْعَٰلَمِينَ","translation":"BEHOLD, God raised Adam, and Noah, and the House of Abraham, and the House of `Imran above all mankind,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/326.mp3","surahId":3,"words":[{"id":35540,"position":1,"arabic":"۞ إِنَّ","translation":"নিশ্চয়","audioUrl":"wbw/003_033_002.mp3","charTypeName":"word"},{"id":35541,"position":2,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/003_033_003.mp3","charTypeName":"word"},{"id":35542,"position":3,"arabic":"ٱصْطَفَىٰٓ","translation":"মনোনীত করেছেন","audioUrl":"wbw/003_033_004.mp3","charTypeName":"word"},{"id":35543,"position":4,"arabic":"ءَادَمَ","translation":"আদম কে","audioUrl":"wbw/003_033_005.mp3","charTypeName":"word"},{"id":35544,"position":5,"arabic":"وَنُوحًۭا","translation":"ও নূহকে","audioUrl":"wbw/003_033_006.mp3","charTypeName":"word"},{"id":35545,"position":6,"arabic":"وَءَالَ","translation":"ও বংশধরদেরকে","audioUrl":"wbw/003_033_007.mp3","charTypeName":"word"},{"id":35546,"position":7,"arabic":"إِبْرَٰهِيمَ","translation":"ইবরাহীমের","audioUrl":"wbw/003_033_008.mp3","charTypeName":"word"},{"id":35547,"position":8,"arabic":"وَءَالَ","translation":"ও বংশধরদেরকে","audioUrl":"wbw/003_033_009.mp3","charTypeName":"word"},{"id":35548,"position":9,"arabic":"عِمْرَٰنَ","translation":"ইমরানের","audioUrl":"wbw/003_033_010.mp3","charTypeName":"word"},{"id":35549,"position":10,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/003_033_011.mp3","charTypeName":"word"},{"id":35550,"position":11,"arabic":"ٱلْعَـٰلَمِينَ","translation":"সারা দুনিয়ার (লোকদেরকে)","audioUrl":"wbw/003_033_012.mp3","charTypeName":"word"},{"id":35551,"position":12,"arabic":"٣٣","translation":"(৩৩)","audioUrl":null,"charTypeName":"end"}]},{"number":34,"arabic":"ذُرِّيَّةًۢ بَعْضُهَا مِنۢ بَعْضٍۢ ۗ وَٱللَّهُ سَمِيعٌ عَلِيمٌ","translation":"in one line of descent. And God was all-hearing, all-knowing","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/327.mp3","surahId":3,"words":[{"id":36361,"position":1,"arabic":"ذُرِّيَّةًۢ","translation":"সন্তানসন্ততি","audioUrl":"wbw/003_034_001.mp3","charTypeName":"word"},{"id":36362,"position":2,"arabic":"بَعْضُهَا","translation":"তাদের একে","audioUrl":"wbw/003_034_002.mp3","charTypeName":"word"},{"id":36363,"position":3,"arabic":"مِنۢ","translation":"হতে","audioUrl":"wbw/003_034_003.mp3","charTypeName":"word"},{"id":36364,"position":4,"arabic":"بَعْضٍۢ ۗ","translation":"অন্যের","audioUrl":"wbw/003_034_004.mp3","charTypeName":"word"},{"id":36366,"position":5,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/003_034_006.mp3","charTypeName":"word"},{"id":36367,"position":6,"arabic":"سَمِيعٌ","translation":"সবকিছুই শুনেন","audioUrl":"wbw/003_034_007.mp3","charTypeName":"word"},{"id":36368,"position":7,"arabic":"عَلِيمٌ","translation":"সবকিছুই জানেন","audioUrl":"wbw/003_034_008.mp3","charTypeName":"word"},{"id":36369,"position":8,"arabic":"٣٤","translation":"(৩৪)","audioUrl":null,"charTypeName":"end"}]},{"number":35,"arabic":"إِذْ قَالَتِ ٱمْرَأَتُ عِمْرَٰنَ رَبِّ إِنِّى نَذَرْتُ لَكَ مَا فِى بَطْنِى مُحَرَّرًۭا فَتَقَبَّلْ مِنِّىٓ ۖ إِنَّكَ أَنتَ ٱلسَّمِيعُ ٱلْعَلِيمُ","translation":"when a woman of [the House of] `Imran prayed: \"O my Sustainer! Behold, unto Thee do I vow [the child] that is in, my womb, to be devoted to Thy service. Accept it, then, from me: verily, Thou alone art all-hearing, all-knowing!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/328.mp3","surahId":3,"words":[{"id":37127,"position":1,"arabic":"إِذْ","translation":"(স্মর