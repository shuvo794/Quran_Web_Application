{"id":337,"ayahs":[{"number":39,"arabic":"أُذِنَ لِلَّذِينَ يُقَٰتَلُونَ بِأَنَّهُمْ ظُلِمُوا۟ ۚ وَإِنَّ ٱللَّهَ عَلَىٰ نَصْرِهِمْ لَقَدِيرٌ","translation":"PERMISSION [to fight] is given to those against whom war is being wrongfully waged and, verily, God has indeed the power to succour them -:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2634.mp3","surahId":22,"words":[{"id":40583,"position":1,"arabic":"أُذِنَ","translation":"অনুমতি দেয়া হলো","audioUrl":"wbw/022_039_001.mp3","charTypeName":"word"},{"id":40584,"position":2,"arabic":"لِلَّذِينَ","translation":"জন্যে তাদের (যাদের বিরুদ্ধে)","audioUrl":"wbw/022_039_002.mp3","charTypeName":"word"},{"id":40585,"position":3,"arabic":"يُقَـٰتَلُونَ","translation":"যুদ্ধ করা হচ্ছে","audioUrl":"wbw/022_039_003.mp3","charTypeName":"word"},{"id":40586,"position":4,"arabic":"بِأَنَّهُمْ","translation":"কারণ তারা","audioUrl":"wbw/022_039_004.mp3","charTypeName":"word"},{"id":40587,"position":5,"arabic":"ظُلِمُوا۟ ۚ","translation":"নির্যাতিত","audioUrl":"wbw/022_039_005.mp3","charTypeName":"word"},{"id":40589,"position":6,"arabic":"وَإِنَّ","translation":"আর নিশ্চয়ই","audioUrl":"wbw/022_039_007.mp3","charTypeName":"word"},{"id":40590,"position":7,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/022_039_008.mp3","charTypeName":"word"},{"id":40591,"position":8,"arabic":"عَلَىٰ","translation":"ক্ষেত্রে","audioUrl":"wbw/022_039_009.mp3","charTypeName":"word"},{"id":40592,"position":9,"arabic":"نَصْرِهِمْ","translation":"সাহায্যের তাদের","audioUrl":"wbw/022_039_010.mp3","charTypeName":"word"},{"id":40593,"position":10,"arabic":"لَقَدِيرٌ","translation":"অবশ্যই ক্ষমতাবান","audioUrl":"wbw/022_039_011.mp3","charTypeName":"word"},{"id":40594,"position":11,"arabic":"٣٩","translation":"(৩৯)","audioUrl":null,"charTypeName":"end"}]},{"number":40,"arabic":"ٱلَّذِينَ أُخْرِجُوا۟ مِن دِيَٰرِهِم بِغَيْرِ حَقٍّ إِلَّآ أَن يَقُولُوا۟ رَبُّنَا ٱللَّهُ ۗ وَلَوْلَا دَفْعُ ٱللَّهِ ٱلنَّاسَ بَعْضَهُم بِبَعْضٍۢ لَّهُدِّمَتْ صَوَٰمِعُ وَبِيَعٌۭ وَصَلَوَٰتٌۭ وَمَسَٰجِدُ يُذْكَرُ فِيهَا ٱسْمُ ٱللَّهِ كَثِيرًۭا ۗ وَلَيَنصُرَنَّ ٱللَّهُ مَن يَنصُرُهُۥٓ ۗ إِنَّ ٱللَّهَ لَقَوِىٌّ عَزِيزٌ","translation":"those who have been driven from their homelands against all right for no other reason than their saying. “Our Sustainer is God!” For, if God had not enabled people to defend themselves against one another, all] monasteries and churches and synagogues and mosques - in [all of] which Gods name is abundantly extolled - would surely have been destroyed [ere now]. And God will most certainly succour him who suc­cours His cause: for, verily, God is most powerful, almighty,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2635.mp3","surahId":22,"words":[{"id":41407,"position":1,"arabic":"ٱلَّذِينَ","translation":"যাদেরকে","audioUrl":"wbw/022_040_001.mp3","charTypeName":"word"},{"id":41408,"position":2,"arabic":"أُخْرِجُوا۟","translation":"বের করে দেয়া হয়েছে","audioUrl":"wbw/022_040_002.mp3","charTypeName":"word"},{"id":41409,"position":3,"arabic":"مِن","translation":"হ'তে","audioUrl":"wbw/022_040_003.mp3","charTypeName":"word"},{"id":41410,"position":4,"arabic":"دِيَـٰرِهِم","translation":"তাদের ঘরবাড়িগুলো","audioUrl":"wbw/022_040_004.mp3","charTypeName":"word"},{"id":41411,"position":5,"arabic":"بِغَيْرِ","translation":"সঙ্গে নয়","audioUrl":"wbw/022_040_005.mp3","charTypeName":"word"},{"id":41412,"position":6,"arabic":"حَقٍّ","translation":"সত্যের (অন্যায়ভাবে)","audioUrl":"wbw/022_040_006.mp3","charTypeName":"word"},{"id":41413,"position":7,"arabic":"إِلَّآ","translation":"(তাদের অপরাধ) এছাড়া নয়","audioUrl":"wbw/022_040_007.mp3","charTypeName":"word"},{"id":41414,"position":8,"arabic":"أَن","translation":"যে","audioUrl":"wbw/022_040_008.mp3","charTypeName":"word"},{"id":41415,"position":9,"arabic":"يَقُولُوا۟","translation":"তারা বলে","audioUrl":"wbw/022_040_009.mp3","charTypeName":"word"},{"id":41416,"position":10,"arabic":"رَبُّنَا","translation":"\"আমাদের রব","audioUrl":"w