6,"arabic":"عَـٰقِبَةُ","translation":"পরিণতি (চূড়ান্ত)","audioUrl":"wbw/022_041_017.mp3","charTypeName":"word"},{"id":42214,"position":17,"arabic":"ٱلْأُمُورِ","translation":"সব ব্যাপারের","audioUrl":"wbw/022_041_018.mp3","charTypeName":"word"},{"id":42215,"position":18,"arabic":"٤١","translation":"(৪১)","audioUrl":null,"charTypeName":"end"}]},{"number":42,"arabic":"وَإِن يُكَذِّبُوكَ فَقَدْ كَذَّبَتْ قَبْلَهُمْ قَوْمُ نُوحٍۢ وَعَادٌۭ وَثَمُودُ","translation":"AND IF THEY [who are bent on denying the truth] give thee the lie, [O Muhammad, remember that, long] before their time, the people of Noah and [the tribes of] Ad and Thamud gave the lie [to their prophets],","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2637.mp3","surahId":22,"words":[{"id":43043,"position":1,"arabic":"وَإِن","translation":"আর (হে নাবী) যদি","audioUrl":"wbw/022_042_001.mp3","charTypeName":"word"},{"id":43044,"position":2,"arabic":"يُكَذِّبُوكَ","translation":"তোমাকে মিথ্যারোপ করে","audioUrl":"wbw/022_042_002.mp3","charTypeName":"word"},{"id":43045,"position":3,"arabic":"فَقَدْ","translation":"(তবে আশ্চর্য কি) নিশ্চয়ই","audioUrl":"wbw/022_042_003.mp3","charTypeName":"word"},{"id":43046,"position":4,"arabic":"كَذَّبَتْ","translation":"মিথ্যারোপ করেছিলো","audioUrl":"wbw/022_042_004.mp3","charTypeName":"word"},{"id":43047,"position":5,"arabic":"قَبْلَهُمْ","translation":"তাদের পূর্বেও","audioUrl":"wbw/022_042_005.mp3","charTypeName":"word"},{"id":43048,"position":6,"arabic":"قَوْمُ","translation":"জাতি","audioUrl":"wbw/022_042_006.mp3","charTypeName":"word"},{"id":43049,"position":7,"arabic":"نُوحٍۢ","translation":"নূহের","audioUrl":"wbw/022_042_007.mp3","charTypeName":"word"},{"id":43050,"position":8,"arabic":"وَعَادٌۭ","translation":"ও আদ","audioUrl":"wbw/022_042_008.mp3","charTypeName":"word"},{"id":43051,"position":9,"arabic":"وَثَمُودُ","translation":"ও সামূদ","audioUrl":"wbw/022_042_009.mp3","charTypeName":"word"},{"id":43052,"position":10,"arabic":"٤٢","translation":"(৪২)","audioUrl":null,"charTypeName":"end"}]},{"number":43,"arabic":"وَقَوْمُ إِبْرَٰهِيمَ وَقَوْمُ لُوطٍۢ","translation":"as did the people of Abraham, and the people of Lot,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2638.mp3","surahId":22,"words":[{"id":43692,"position":1,"arabic":"وَقَوْمُ","translation":"এবং জাতি","audioUrl":"wbw/022_043_001.mp3","charTypeName":"word"},{"id":43693,"position":2,"arabic":"إِبْرَٰهِيمَ","translation":"ইব্রাহীমের","audioUrl":"wbw/022_043_002.mp3","charTypeName":"word"},{"id":43694,"position":3,"arabic":"وَقَوْمُ","translation":"ও জাতি","audioUrl":"wbw/022_043_003.mp3","charTypeName":"word"},{"id":43695,"position":4,"arabic":"لُوطٍۢ","translation":"লূতের","audioUrl":"wbw/022_043_004.mp3","charTypeName":"word"},{"id":43696,"position":5,"arabic":"٤٣","translation":"(৪৩)","audioUrl":null,"charTypeName":"end"}]},{"number":44,"arabic":"وَأَصْحَٰبُ مَدْيَنَ ۖ وَكُذِّبَ مُوسَىٰ فَأَمْلَيْتُ لِلْكَٰفِرِينَ ثُمَّ أَخَذْتُهُمْ ۖ فَكَيْفَ كَانَ نَكِيرِ","translation":"and the dwellers of Madyan; and [so, too,] Moses was given the lie [by Pharaoh]. And [in every ease] I gave rein, for a while, to the deniers of the truth: but then I took them to task - and how awesome was My denial [of them,]!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2639.mp3","surahId":22,"words":[{"id":44460,"position":1,"arabic":"وَأَصْحَـٰبُ","translation":"এবং অধিবাসীরা","audioUrl":"wbw/022_044_001.mp3","charTypeName":"word"},{"id":44461,"position":2,"arabic":"مَدْيَنَ ۖ","translation":"মাদইয়ানের","audioUrl":"wbw/022_044_002.mp3","charTypeName":"word"},{"id":44463,"position":3,"arabic":"وَكُذِّبَ","translation":"এবং মিথ্যারোপ করা হয়েছিলো","audioUrl":"wbw/022_044_004.mp3","charTypeName":"word"},{"id":44464,"position":4,"arabic":"مُوسَىٰ","translation":"মূসাকেও","audioUrl":"wbw/022_044_005.mp3","charTypeName":"word"},{"id":44465,"position":5,"arabic":"فَأَمْلَيْتُ","translation":"অতঃএব আমি অবকাশ দিয়েছিলাম","audioUrl":"wbw/022_044_006.mp3","charTypeName":"word"},{"id":44466,"position":6,"arabic":"لِلْكَـٰفِرِينَ","translation":"জন্যে কাফিরদের","audioUrl":"wbw/022_044_007.mp3","charTypeName":"word"},{"id":44467,"position":7,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/022_044_008.mp3","charTypeName":"word"},{"id":44468,"position":8,"arabic":"أَخَذْتُهُمْ ۖ","translation":"তাদেরকে আমি পাকড়াও করেছিলাম","audioUrl":"wbw/022_044_009.mp3","charTypeName":"word"},{"id":44470,"position":9,"arabic":"فَكَيْفَ","translation":"(ভেবে দেখো) তখন কেমন","audioUrl":"wbw/022_044_011.mp3","charTypeName":"word"},{"id":44471,"position":10,"arabic":"كَانَ","translation":"ছিলো","audioUrl":"wbw/022_044_012.mp3","charTypeName":"word"},{"id":44472,"position":11,"arabic":"نَكِيرِ","translation":"আমার শাস্তি","audioUrl":"wbw/022_044_013.mp3","charTypeName":"word"},{"id":44473,"position":12,"arabic":"٤٤","translation":"(৪৪)","audioUrl":null,"charTypeName":"end"}]},{"number":45,"arabic":"فَكَأَيِّن مِّن قَرْيَةٍ أَهْلَكْنَٰهَا وَهِىَ ظَالِمَةٌۭ فَهِىَ خَاوِيَةٌ عَلَىٰ عُرُوشِهَا وَبِئْرٍۢ مُّعَطَّلَةٍۢ وَقَصْرٍۢ مَّشِيدٍ","translation":"And how many a township have We destroyed because it had been immersed in evildoing - and now they [all] lie deserted, with their roofs caved in! And how many a well lies abandoned, and how many a castle that [once] stood high!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2640.mp3","surahId":22,"words":[{"id":44921,"position":1,"arabic":"فَكَأَيِّن","translation":"অতঃপর কতই না","audioUrl":"wbw/022_045_001.mp3","charTypeName":"word"},{"id":44922,"position":2,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/022_045_002.mp3","charTypeName":"word"},{"id":44923,"position":3,"arabic":"قَرْيَةٍ","translation":"জনপদ","audioUrl":"wbw/022_045_003.mp3","charTypeName":"word"},{"id":44924,"position":4,"arabic":"أَهْلَكْنَـٰهَا","translation":"তা আমরা ধ্বংস করেছি","audioUrl":"wbw/022_045_004.mp3","charTypeName":"word"},{"id":44925,"position":5,"arabic":"وَهِىَ","translation":"যখন তা (ছিলো)","audioUrl":"wbw/022_045_005.mp3","charTypeName":"word"},{"id":44926,"position":6,"arabic":"ظَالِمَةٌۭ","translation":"অপরাধী","audioUrl":"wbw/022_045_006.mp3","charTypeName":"word"},{"id":44927,"position":7,"arabic":"فَهِىَ","translation":"ফলে তা","audioUrl":"wbw/022_045_007.mp3","charTypeName":"word"},{"id":44928,"position":8,"arabic":"خَاوِيَةٌ","translation":"ধ্বংসপ্রাপ্ত","audioUrl":"wbw/022_045_008.mp3","charTypeName":"word"},{"id":44929,"position":9,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/022_045_009.mp3","charTypeName":"word"},{"id":44930,"position":10,"arabic":"عُرُوشِهَا","translation":"তার ছাদসমূহের","audioUrl":"wbw/022_045_010.mp3","charTypeName":"word"},{"id":44931,"position":11,"arabic":"وَبِئْرٍۢ","translation":"এবং কূপ","audioUrl":"wbw/022_045_011.mp3","charTypeName":"word"},{"id":44932,"position":12,"arabic":"مُّعَطَّلَةٍۢ","translation":"পরিত্যক্ত (হয়েছে)","audioUrl":"wbw/022_045_012.mp3","charTypeName":"word"},{"id":44933,"position":13,"arabic":"وَقَصْرٍۢ","translation":"ও প্রাসাদ","audioUrl":"wbw/022_045_013.mp3","charTypeName":"word"},{"id":44934,"position":14,"arabic":"مَّشِيدٍ","translation":"সুদৃঢ় (বিধ্বস্ত হয়েছে)","audioUrl":"wbw/022_045_014.mp3","charTypeName":"word"},{"id":44935,"position":15,"arabic":"٤٥","translation":"(৪৫)","audioUrl":null,"charTypeName":"end"}]},{"number":46,"arabic":"أَفَلَمْ يَسِيرُوا۟ فِى ٱلْأَرْضِ فَتَكُونَ لَهُمْ قُلُوبٌۭ يَعْقِلُونَ بِهَآ أَوْ ءَاذَانٌۭ يَسْمَعُونَ بِهَا ۖ فَإِنَّهَا لَا تَعْمَى ٱلْأَبْصَٰرُ وَلَٰكِن تَعْمَى ٱلْقُلُوبُ ٱلَّتِى فِى ٱلصُّدُورِ","translation":"Have they, then, never journeyed about the earth, letting their hearts gain wisdom, and causing their ears to hear? Yet, verily, it is not their eyes that have become blind - but blind have become the hearts that are in their breasts!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2641.mp3","surahId":22,"words":[{"id":45922,"position":1,"arabic":"أَفَلَمْ","translation":"কি তবে নি","audioUrl":"wbw/022_046_001.mp3","charTypeName":"word"},{"id":45923,"position":2,"arabic":"يَسِيرُوا۟","translation":"তারা ভ্রমণ করে","audioUrl":"wbw/022_046_002.mp3","charTypeName":"word"},{"id":45924,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/022_046_003.mp3","charTypeName":"word"},{"id":45925,"position":4,"arabic":"ٱلْأَرْضِ","translation":"জমীনে","audioUrl":"wbw/022_046_004.mp3","charTypeName":"word"},{"id":45926,"position":5,"arabic":"فَتَكُونَ","translation":"তাহ'লে হতো","audioUrl":"wbw/022_046_005.mp3","charTypeName":"word"},{"id":45927,"position":6,"arabic":"لَهُمْ","translation":"জন্যে তাদের","audioUrl":"wbw/022_046_006.mp3","charTypeName":"word"},{"id":45928,"position":7,"arabic":"قُلُوبٌۭ","translation":"অন্তরসমূহ (এমন যে)","audioUrl":"wbw/022_046_007.mp3","charTypeName":"word"},{"id":45929,"position":8,"arabic":"يَعْقِلُونَ","translation":"বুঝতো","audioUrl":"wbw/022_046_008.mp3","charTypeName":"word"},{"id":45930,"position":9,"arabic":"بِهَآ","translation":"দিয়ে তা","audioUrl":"wbw/022_046_009.mp3","charTypeName":"word"},{"id":45931,"position":10,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/022_046_010.mp3","charTypeName":"word"},{"id":45932,"position":11,"arabic":"ءَاذَانٌۭ","translation":"কানগুলো","audioUrl":"wbw/022_046_011.mp3","charTypeName":"word"},{"id":45933,"position":12,"arabic":"يَسْمَعُونَ","translation":"শুনতো","audioUrl":"wbw/022_046_012.mp3","charTypeName":"word"},{"id":45934,"position":13,"arabic":"بِهَا ۖ","translation":"দিয়ে তা","audioUrl":"wbw/022_046_013.mp3","charTypeName":"word"},{"id":45936,"position":14,"arabic":"فَإِنَّهَا","translation":"বস্তুতঃ তা অবশ্যই (এমন যে)","audioUrl":"wbw/022_046_015.mp3","charTypeName":"word"},{"id":45937,"position":15,"arabic":"لَا","translation":"না","audioUrl":"wbw/022_046_016.mp3","charTypeName":"word"},{"id":45938,"position":16,"arabic":"تَعْمَى","translation":"অন্ধ হয়","audioUrl":"wbw/022_046_017.mp3","charTypeName":"word"},{"id":45939,"position":17,"arabic":"ٱلْأَبْصَـ