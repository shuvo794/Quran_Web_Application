{"id":96,"ayahs":[{"number":106,"arabic":"وَٱسْتَغْفِرِ ٱللَّهَ ۖ إِنَّ ٱللَّهَ كَانَ غَفُورًۭا رَّحِيمًۭا","translation":"but pray God to forgive [them]: behold, God is indeed much-forgiving, a dispenser of grace.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/599.mp3","surahId":4,"words":[{"id":73026,"position":1,"arabic":"وَٱسْتَغْفِرِ","translation":"এবং ক্ষমা চাও (কাছে)","audioUrl":"wbw/004_106_001.mp3","charTypeName":"word"},{"id":73027,"position":2,"arabic":"ٱللَّهَ ۖ","translation":"আল্লাহর","audioUrl":"wbw/004_106_002.mp3","charTypeName":"word"},{"id":73029,"position":3,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/004_106_004.mp3","charTypeName":"word"},{"id":73030,"position":4,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/004_106_005.mp3","charTypeName":"word"},{"id":73031,"position":5,"arabic":"كَانَ","translation":"হলেন","audioUrl":"wbw/004_106_006.mp3","charTypeName":"word"},{"id":73032,"position":6,"arabic":"غَفُورًۭا","translation":"ক্ষমাশীল","audioUrl":"wbw/004_106_007.mp3","charTypeName":"word"},{"id":73033,"position":7,"arabic":"رَّحِيمًۭا","translation":"মেহেরবান","audioUrl":"wbw/004_106_008.mp3","charTypeName":"word"},{"id":73034,"position":8,"arabic":"١٠٦","translation":"(১০৬)","audioUrl":null,"charTypeName":"end"}]},{"number":107,"arabic":"وَلَا تُجَٰدِلْ عَنِ ٱلَّذِينَ يَخْتَانُونَ أَنفُسَهُمْ ۚ إِنَّ ٱللَّهَ لَا يُحِبُّ مَن كَانَ خَوَّانًا أَثِيمًۭا","translation":"Yet do not argue in behalf of those who are false to their own selves: verily, God does not love those who betray their trust and persist in sinful ways.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/600.mp3","surahId":4,"words":[{"id":73288,"position":1,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/004_107_001.mp3","charTypeName":"word"},{"id":73289,"position":2,"arabic":"تُجَـٰدِلْ","translation":"তুমি বিসম্বাদ করো","audioUrl":"wbw/004_107_002.mp3","charTypeName":"word"},{"id":73290,"position":3,"arabic":"عَنِ