ۚ وَكَانَ ٱللَّهُ عَلِيمًا حَكِيمًۭا","translation":"for he who commits a sin, commits it only to his own hurt; and God is indeed all-knowing, wise.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/604.mp3","surahId":4,"words":[{"id":74434,"position":1,"arabic":"وَمَن","translation":"আর যে","audioUrl":"wbw/004_111_001.mp3","charTypeName":"word"},{"id":74435,"position":2,"arabic":"يَكْسِبْ","translation":"অর্জন করে","audioUrl":"wbw/004_111_002.mp3","charTypeName":"word"},{"id":74436,"position":3,"arabic":"إِثْمًۭا","translation":"গুনাহ","audioUrl":"wbw/004_111_003.mp3","charTypeName":"word"},{"id":74437,"position":4,"arabic":"فَإِنَّمَا","translation":"তাহলে মূলত","audioUrl":"wbw/004_111_004.mp3","charTypeName":"word"},{"id":74438,"position":5,"arabic":"يَكْسِبُهُۥ","translation":"তা অর্জন করে সে","audioUrl":"wbw/004_111_005.mp3","charTypeName":"word"},{"id":74439,"position":6,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/004_111_006.mp3","charTypeName":"word"},{"id":74440,"position":7,"arabic":"نَفْسِهِۦ ۚ","translation":"তার নিজের","audioUrl":"wbw/004_111_007.mp3","charTypeName":"word"},{"id":74442,"position":8,"arabic":"وَكَانَ","translation":"এবং হলেন","audioUrl":"wbw/004_111_009.mp3","charTypeName":"word"},{"id":74443,"position":9,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/004_111_010.mp3","charTypeName":"word"},{"id":74444,"position":10,"arabic":"عَلِيمًا","translation":"সর্বজ্ঞ","audioUrl":"wbw/004_111_011.mp3","charTypeName":"word"},{"id":74445,"position":11,"arabic":"حَكِيمًۭا","translation":"প্রজ্ঞাময়","audioUrl":"wbw/004_111_012.mp3","charTypeName":"word"},{"id":74446,"position":12,"arabic":"١١١","translation":"(১১১)","audioUrl":null,"charTypeName":"end"}]},{"number":112,"arabic":"وَمَن يَكْسِبْ خَطِيٓـَٔةً أَوْ إِثْمًۭا ثُمَّ يَرْمِ بِهِۦ بَرِيٓـًۭٔا فَقَدِ ٱحْتَمَلَ بُهْتَٰنًۭا وَإِثْمًۭا مُّبِينًۭا","translation":"But he who commits a fault or a sin and then throws the blame therefore on an innocent person, burdens himself with the guilt of calumny and [yet another] flagrant sin.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/605.mp3","surahId":4,"words":[{"id":74722,"position":1,"arabic":"وَمَن","translation":"এবং যে","audioUrl":"wbw/004_112_001.mp3","charTypeName":"word"},{"id":74723,"position":2,"arabic":"يَكْسِبْ","translation":"অর্জন করে","audioUrl":"wbw/004_112_002.mp3","charTypeName":"word"},{"id":74724,"position":3,"arabic":"خَطِيٓـَٔةً","translation":"অন্যায়","audioUrl":"wbw/004_112_003.mp3","charTypeName":"word"},{"id":74725,"position":4,"arabic":"أَوْ","translation":"বা","audioUrl":"wbw/004_112_004.mp3","charTypeName":"word"},{"id":74726,"position":5,"arabic":"إِثْمًۭا","translation":"পাপ কাজ","audioUrl":"wbw/004_112_005.mp3","charTypeName":"word"},{"id":74727,"position":6,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/004_112_006.mp3","charTypeName":"word"},{"id":74728,"position":7,"arabic":"يَرْمِ","translation":"চাপিয়ে দেয়","audioUrl":"wbw/004_112_007.mp3","charTypeName":"word"},{"id":74729,"position":8,"arabic":"بِهِۦ","translation":"তা","audioUrl":"wbw/004_112_008.mp3","charTypeName":"word"},{"id":74730,"position":9,"arabic":"بَرِيٓـًۭٔا","translation":"নির্দোষের (উপর)","audioUrl":"wbw/004_112_009.mp3","charTypeName":"word"},{"id":74731,"position":10,"arabic":"فَقَدِ","translation":"নিশ্চয় তবে","audioUrl":"wbw/004_112_010.mp3","charTypeName":"word"},{"id":74732,"position":11,"arabic":"ٱحْتَمَلَ","translation":"সে বহন করল","audioUrl":"wbw/004_112_011.mp3","charTypeName":"word"},{"id":74733,"position":12,"arabic":"بُهْتَـٰنًۭا","translation":"মিথ্যা অপবাদ","audioUrl":"wbw/004_112_012.mp3","charTypeName":"word"},{"id":74734,"position":13,"arabic":"وَإِثْمًۭا","translation":"ও পাপ","audioUrl":"wbw/004_112_013.mp3","charTypeName":"word"},{"id":74735,"position":14,"arabic":"مُّبِينًۭا","translation":"সুস্পষ্ট","audioUrl":"wbw/004_112_014.mp3","charTypeName":"word"},{"id":74736,"position":15,"arabic":"١١٢","translation":"(১১২)","audioUrl":null,"charTypeName":"end"}]},{"number":113,"arabic":"وَلَوْلَا فَضْلُ ٱللَّهِ عَلَيْكَ وَرَحْمَتُهُۥ لَهَمَّت طَّآئِفَةٌۭ مِّنْهُمْ أَن يُضِلُّوكَ وَمَا يُضِلُّونَ إِلَّآ أَنفُسَهُمْ ۖ وَمَا يَضُرُّونَكَ مِن شَىْءٍۢ ۚ وَأَنزَلَ ٱللَّهُ عَلَيْكَ ٱلْكِتَٰبَ وَٱلْحِكْمَةَ وَعَلَّمَكَ مَا لَمْ تَكُن تَعْلَمُ ۚ وَكَانَ فَضْلُ ٱللَّهِ عَلَيْكَ عَظِيمًۭا","translation":"And but for God's favour upon thee and His grace, some of those [who are false to themselves] would indeed endeavour to lead thee astray; yet none but themselves do they lead astray. Nor can they harm thee in any way, since God has bestowed upon thee from on high this divine writ and [given thee] wisdom, and has imparted unto thee the knowledge of what thou didst not know. And God's favour upon thee is tremendous indeed.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/606.mp3","surahId":4,"words":[{"id":74913,"position":1,"arabic":"وَلَوْلَا","translation":"এবং যদি না","audioUrl":"wbw/004_113_001.mp3","charTypeName":"word"},{"id":74914,"position":2,"arabic":"فَضْلُ","translation":"অনুগ্রহ (হত)","audioUrl":"wbw/004_113_002.mp3","charTypeName":"word"},{"id":74915,"position":3,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/004_113_003.mp3","charTypeName":"word"},{"id":74916,"position":4,"arabic":"عَلَيْكَ","translation":"তোমার উপর","audioUrl":"wbw/004_113_004.mp3","charTypeName":"word"},{"id":74917,"position":5,"arabic":"وَرَحْمَتُهُۥ","translation":"ও তাঁর রহমত (তবে)","audioUrl":"wbw/004_113_005.mp3","charTypeName":"word"},{"id":74918,"position":6,"arabic":"لَهَمَّت","translation":"সংকল্প করেই ফেলেছিল","audioUrl":"wbw/004_113_006.mp3","charTypeName":"word"},{"id":74919,"position":7,"arabic":"طَّآئِفَةٌۭ","translation":"একদল","audioUrl":"wbw/004_113_007.mp3","charTypeName":"word"},{"id":74920,"position":8,"arabic":"مِّنْهُمْ","translation":"তাদের মধ্য হতে","audioUrl":"wbw/004_113_008.mp3","charTypeName":"word"},{"id":74921,"position":9,"arabic":"أَن","translation":"যে","audioUrl":"wbw/004_113_009.mp3","charTypeName":"word"},{"id":74922,"position":10,"arabic":"يُضِلُّوكَ","translation":"তোমাকে পথভ্রষ্ট করবে","audioUrl":"wbw/004_113_010.mp3","charTypeName":"word"},{"id":74923,"position":11,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/004_113_011.mp3","charTypeName":"word"},{"id":74924,"position":12,"arabic":"يُضِلُّونَ","translation":"তারা পথভ্রষ্ট করবে","audioUrl":"wbw/004_113_012.mp3","charTypeName":"word"},{"id":74925,"position":13,"arabic":"إِلَّآ","translation":"এছাড়া","audioUrl":"wbw/004_113_013.mp3","charTypeName":"word"},{"id":74926,"position":14,"arabic":"أَنفُسَهُمْ ۖ","translation":"তাদের নিজেদেরকে","audioUrl":"wbw/004_113_014.mp3","charTypeName":"word"},{"id":74928,"position":15,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/004_113_016.mp3","charTypeName":"word"},{"id":74929,"position":16,"arabic":"يَضُرُّونَكَ","translation":"তোমাকে তারা ক্ষতি করতে পারে","audioUrl":"wbw/004_113_017.mp3","charTypeName":"word"},{"id":74930,"position":17,"arabic":"مِن","translation":"(থেকে)","audioUrl":"wbw/004_113_018.mp3","charTypeName":"word"},{"id":74931,"position":18,"arabic":"شَىْءٍۢ ۚ","translation":"কোন কিছুই","audioUrl":"wbw/004_113_019.mp3","charTypeName":"word"},{"id":74933,"position":19,"arabic":"وَأَنزَلَ","translation":"এবং নাযিল করেছেন","audioUrl":"wbw/004_113_021.mp3","charTypeName":"word"},{"id":74934,"position":20,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/004_113_022.mp3","charTypeName":"word"},{"id":74935,"position":21,"arabic":"عَلَيْكَ","translation":"তোমার উপর","audioUrl":"wbw/004_113_023.mp3","charTypeName":"word"},{"id":74936,"position":22,"arabic":"ٱلْكِتَـٰبَ","translation":"কিতাব","audioUrl":"wbw/004_113_024.mp3","charTypeName":"word"},{"id":74937,"position":23,"arabic":"وَٱلْحِكْمَةَ","translation":"ও বুদ্ধিমত্তা","audioUrl":"wbw/004_113_025.mp3","charTypeName":"word"},{"id":74938,"position":24,"arabic":"وَعَلَّمَكَ","translation":"ও তোমাকে শিক্ষা দিয়েছেন","audioUrl":"wbw/004_113_026.mp