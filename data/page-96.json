09_005.mp3","charTypeName":"word"},{"id":73785,"position":6,"arabic":"ٱلْحَيَوٰةِ","translation":"জীবনে","audioUrl":"wbw/004_109_006.mp3","charTypeName":"word"},{"id":73786,"position":7,"arabic":"ٱلدُّنْيَا","translation":"দুনিয়ায়","audioUrl":"wbw/004_109_007.mp3","charTypeName":"word"},{"id":73787,"position":8,"arabic":"فَمَن","translation":"কে অতঃপর","audioUrl":"wbw/004_109_008.mp3","charTypeName":"word"},{"id":73788,"position":9,"arabic":"يُجَـٰدِلُ","translation":"ঝগড়া করবে","audioUrl":"wbw/004_109_009.mp3","charTypeName":"word"},{"id":73789,"position":10,"arabic":"ٱللَّهَ","translation":"আল্লাহর (সাথে)","audioUrl":"wbw/004_109_010.mp3","charTypeName":"word"},{"id":73790,"position":11,"arabic":"عَنْهُمْ","translation":"তাদের পক্ষে","audioUrl":"wbw/004_109_011.mp3","charTypeName":"word"},{"id":73791,"position":12,"arabic":"يَوْمَ","translation":"দিনে","audioUrl":"wbw/004_109_012.mp3","charTypeName":"word"},{"id":73792,"position":13,"arabic":"ٱلْقِيَـٰمَةِ","translation":"কিয়ামাতের","audioUrl":"wbw/004_109_013.mp3","charTypeName":"word"},{"id":73793,"position":14,"arabic":"أَم","translation":"অথবা","audioUrl":"wbw/004_109_014.mp3","charTypeName":"word"},{"id":73794,"position":15,"arabic":"مَّن","translation":"কে","audioUrl":"wbw/004_109_015.mp3","charTypeName":"word"},{"id":73795,"position":16,"arabic":"يَكُونُ","translation":"হবে","audioUrl":"wbw/004_109_016.mp3","charTypeName":"word"},{"id":73796,"position":17,"arabic":"عَلَيْهِمْ","translation":"তাদের পক্ষে","audioUrl":"wbw/004_109_017.mp3","charTypeName":"word"},{"id":73797,"position":18,"arabic":"وَكِيلًۭا","translation":"উকিল","audioUrl":"wbw/004_109_018.mp3","charTypeName":"word"},{"id":73798,"position":19,"arabic":"١٠٩","translation":"(১০৯)","audioUrl":null,"charTypeName":"end"}]},{"number":110,"arabic":"وَمَن يَعْمَلْ سُوٓءًا أَوْ يَظْلِمْ نَفْسَهُۥ ثُمَّ يَسْتَغْفِرِ ٱللَّهَ يَجِدِ ٱللَّهَ غَفُورًۭا رَّحِيمًۭا","translation":"Yet he who does evil or [otherwise] sins against himself, and thereafter prays 