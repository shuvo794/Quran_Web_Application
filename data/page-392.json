{"id":392,"ayahs":[{"number":51,"arabic":"۞ وَلَقَدْ وَصَّلْنَا لَهُمُ ٱلْقَوْلَ لَعَلَّهُمْ يَتَذَكَّرُونَ","translation":"NOW, INDEED, We have caused this word [of Ours] to reach mankind step by step, so that they might [learn to] keep it in mind.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3303.mp3","surahId":28,"words":[{"id":49589,"position":1,"arabic":"۞ وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/028_051_002.mp3","charTypeName":"word"},{"id":49590,"position":2,"arabic":"وَصَّلْنَا","translation":"আমরা বারবার পাঠিয়েছি","audioUrl":"wbw/028_051_003.mp3","charTypeName":"word"},{"id":49591,"position":3,"arabic":"لَهُمُ","translation":"জন্যে তাদের","audioUrl":"wbw/028_051_004.mp3","charTypeName":"word"},{"id":49592,"position":4,"arabic":"ٱلْقَوْلَ","translation":"(হেদায়াতের) বাণী","audioUrl":"wbw/028_051_005.mp3","charTypeName":"word"},{"id":49593,"position":5,"arabic":"لَعَلَّهُمْ","translation":"যাতে তারা","audioUrl":"wbw/028_051_006.mp3","charTypeName":"word"},{"id":49594,"position":6,"arabic":"يَتَذَكَّرُونَ","translation":"উপদেশ গ্রহন করে","audioUrl":"wbw/028_051_007.mp3","charTypeName":"word"},{"id":49595,"position":7,"arabic":"٥١","translation":"(৫১)","audioUrl":null,"charTypeName":"end"}]},{"number":52,"arabic":"ٱلَّذِينَ ءَاتَيْنَٰهُمُ ٱلْكِتَٰبَ مِن قَبْلِهِۦ هُم بِهِۦ يُؤْمِنُونَ","translation":"As for those unto whom We have vouchsafed revelation aforetime - they [are bound to] believe in this one [as well];","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3304.mp3","surahId":28,"words":[{"id":50143,"position":1,"arabic":"ٱلَّذِينَ","translation":"যারা (অর্থাৎ আহলে কিতাবদেরকে)","audioUrl":"wbw/028_052_001.mp3","charTypeName":"word"},{"id":50144,"position":2,"arabic":"ءَاتَيْنَـٰهُمُ","translation":"আমরা দান করেছি তাদেরকে","audioUrl":"wbw/028_052_002.mp3","charTypeName":"word"},{"id":50145,"position":3,"arabic":"ٱلْكِتَـٰبَ","translation":"কিতাব","audioUrl":"wbw/028_052_003.mp3","charTypeName":"word"},{"id":50146,"position":4,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/028_052_004.mp3","charTypeName":"word"},{"id":50147,"position":5,"arabic":"قَبْلِهِۦ","translation":"এর (অর্থাৎ কোরআনের) পূর্ব","audioUrl":"wbw/028_052_005.mp3","charTypeName":"word"},{"id":50148,"position":6,"arabic":"هُم","translation":"তারা","audioUrl":"wbw/028_052_006.mp3","charTypeName":"word"},{"id":50149,"position":7,"arabic":"بِهِۦ","translation":"উপর এর","audioUrl":"wbw/028_052_007.mp3","charTypeName":"word"},{"id":50150,"position":8,"arabic":"يُؤْمِنُونَ","translation":"ঈমান আনে","audioUrl":"wbw/028_052_008.mp3","charTypeName":"word"},{"id":50151,"position":9,"arabic":"٥٢","translation":"(৫২)","audioUrl":null,"charTypeName":"end"}]},{"number":53,"arabic":"وَإِذَا يُتْلَىٰ عَلَيْهِمْ قَالُوٓا۟ ءَامَنَّا بِهِۦٓ إِنَّهُ ٱلْحَقُّ مِن رَّبِّنَآ إِنَّا كُنَّا مِن قَبْلِهِۦ مُسْلِمِينَ","translation":"and whenever it is [clearly] conveyed unto them, they [are bound to] profess, “We have come to believe in it, for, behold, it is the truth from our Sustainer - and, verily, even before this have we surrendered ourselves unto Him!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3305.mp3","surahId":28,"words":[{"id":50683,"position":1,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/028_053_001.mp3","charTypeName":"word"},{"id":50684,"position":2,"arabic":"يُتْلَىٰ","translation":"তিলাওয়াত করা হয়","audioUrl":"wbw/028_053_002.mp3","charTypeName":"word"},{"id":50685,"position":3,"arabic":"عَلَيْهِمْ","translation":"নিকট তাদের","audioUrl":"wbw/028_053_003.mp3","charTypeName":"word"},{"id":50686,"position":4,"arabic":"قَالُوٓا۟","translation":"তারা বলে","audioUrl":"wbw/028_053_004.mp3","charTypeName":"word"},{"id":50687,"position":5,"arabic":"ءَامَنَّا","translation":"\"আমরা ঈমান এনেছি","audioUrl":"wbw/028_053_005.mp3","charTypeName":"word"},{"id":50688,"position":6,"arabic":"بِهِۦٓ","translation":"উপর এর","audioUrl":"wbw/028_053_006.mp3","charTypeName":"word"},{"id":50689,"position":7,"arabic":"إِنَّهُ","translation":"নিশ্চয়ই তা","audioUrl":"wbw/028_053_007.mp3","charTypeName":"word"},{"id":50690,"position":8,"arabic":"ٱلْحَقُّ","translation":"সত্য","audioUrl":"wbw/028_053_008.mp3","charTypeName":"word"},{"id":50691,"position":9,"arabic":"مِن","translation":"পক্ষ হ'তে","audioUrl":"wbw/028_053_009.mp3","charTypeName":"word"},{"id":50692,"position":10,"arabic":"رَّبِّنَآ","translation":"আমাদের রবের","audioUrl":"wbw/028_053_010.mp3","charTypeName":"word"},{"id":50693,"position":11,"arabic":"إِنَّا","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/028_053_011.mp3","charTypeName":"word"},{"id":50694,"position":12,"arabic":"كُنَّا","translation":"ছিলাম","audioUrl":"wbw/028_053_012.mp3","charTypeName":"word"},{"id":50695,"position":13,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/028_053_013.mp3","charTypeName":"word"},{"id":50696,"position":14,"arabic":"قَبْلِهِۦ","translation":"পূর্ব এর","audioUrl":"wbw/028_053_014.mp3","charTypeName":"word"},{"id":50697,"position":15,"arabic":"مُسْلِمِينَ","translation":"মুসলমান\"","audioUrl":"wbw/028_053_015.mp3","charTypeName":"word"},{"id":50698,"position":16,"arabic":"٥٣","translation":"(৫৩)","audioUrl":null,"charTypeName":"end"}]},{"number":54,"arabic":"أُو۟لَٰٓئِكَ يُؤْتَوْنَ أَجْرَهُم مَّرَّتَيْنِ بِمَا صَبَرُوا۟ وَيَدْرَءُونَ بِٱلْحَسَنَةِ ٱلسَّيِّئَةَ وَمِمَّا رَزَقْنَٰهُمْ يُنفِقُونَ","translation":"These it is that shall receive a twofold reward for having been patient in adversity, and having repelled evil with good, and having spent on others out of what We provided for them as sus­tenance,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3306.mp3","surahId":28,"words":[{"id":51349,"position":1,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐসব (লোকদেরকে)","audioUrl":"wbw/028_054_001.mp3","charTypeName":"word"},{"id":51350,"position":2,"arabic":"يُؤْتَوْنَ","translation":"দেয়া হবে","audioUrl":"wbw/028_054_002.mp3","charTypeName":"word"},{"id":51351,"position":3,"arabic":"أَجْرَهُم","translation":"প্রতিফল তাদের","audioUrl":"wbw/028_054_003.mp3","charTypeName":"word"},{"id":51352,"position":4,"arabic":"مَّرَّتَيْنِ","translation":"দু'বার","audioUrl":"wbw/028_054_004.mp3","charTypeName":"word"},{"id":51353,"position":5,"arabic":"بِمَا","translation":"এ কারণে যা","audioUrl":"wbw/028_054_005.mp3","charTypeName":"word"},{"id":51354,"position":6,"arabic":"صَبَرُوا۟","translation":"তারা ধৈর্য ধরেছে","audioUrl":"wbw/028_054_006.mp3","charTypeName":"word"},{"id":51355,"position":7,"arabic":"وَيَدْرَءُونَ","translation":"ও তারা প্রতিরোধ করে","audioUrl":"wbw/028_054_007.mp3","charTypeName":"word"},{"id":51356,"position":8,"arabic":"بِٱلْحَسَنَةِ","translation":"দিয়ে ভালো","audioUrl":"wbw/028_054_008.mp3","charTypeName":"word"},{"id":51357,"position":9,"arabic":"ٱلسَّيِّئَةَ","translation":"মন্দকে","audioUrl":"wbw/028_054_009.mp3","charTypeName":"word"},{"id":51358,"position":10,"arabic":"وَمِمَّا","translation":"এবং (তা) হ'তে যা","audioUrl":"wbw/028_054_010.mp3","charTypeName":"word"},{"id":51359,"position":11,"arabic":"رَزَقْنَـٰهُمْ","translation":"আমরা জীবিকা দিয়েছি তাদেরকে","audioUrl":"wbw/028_054_011.mp3","charTypeName":"word"},{"id":51360,"position":12,"arabic":"يُنفِقُونَ","translation":"তারা ব্যয় করে","audioUrl":"wbw/028_054_012.mp3","charTypeName":"word"},{"id":51361,"position":13,"arabic":"٥٤","translation":"(৫৪)","audioUrl":null,"charTypeName":"end"}]},{"number":55,"arabic":"وَإِذَا سَمِعُوا۟ ٱللَّغْوَ أَعْرَضُوا۟ عَنْهُ وَقَالُوا۟ لَنَآ أَعْمَٰلُنَا وَلَكُمْ أَعْمَٰلُكُمْ سَلَٰمٌ عَلَيْكُمْ لَا نَبْتَغِى ٱلْجَٰهِلِينَ","translation":"and, whenever they heard frivolous talk, having turned away from it and said: “Unto us shall be accounted Our deeds, and unto you, your deeds. Peace be upon you - [but] we do not seek out such as are ignorant [of the meaning of right and wrong].”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3307.mp3","surahId":28,"words":[{"id":51868,"position":1,"arabic":"وَإِذَا","translation":"যখন","audioUrl":"wbw/028_055_001.mp3","charTypeName":"word"},{"id":51869,"position":2,"arabic":"سَمِعُوا۟","translation":"তারা শুনে","audioUrl":"wbw/028_055_002.mp3","charTypeName":"word"},{"id":51870,"position":3,"arabic":"ٱللَّغْوَ","translation":"অসার (উক্তি)","audioUrl":"wbw/028_055_003.mp3","charTypeName":"word"},{"id":51871,"position":4,"arabic":"أَعْرَضُوا۟","translation":"তারা মুখ ফিরিয়ে নেয়","audioUrl":"wbw/028_055_004.mp3","charTypeName":"word"},{"id":51872,"position":5,"arabic":"عَنْهُ","translation":"হ'তে তা","audioUrl":"wbw/028_055_005.mp3","charTypeName":"word"},{"id":51873,"position":6,"arabic":"وَقَالُوا۟","translation":"এবং তারা বলে","audioUrl":"wbw/028_055_006.mp3","charTypeName":"word"},{"id":51874,"position":7,"arabic":"لَنَآ","translation":"\"জন্যে (রয়েছে) আমাদের","audioUrl":"wbw/028_055_007.mp3","charTypeName":"word"},{"id":51875,"position":8,"arabic":"أَعْمَـٰلُنَا","translation":"কর্মসমূহ আমাদের","audioUrl":"wbw/028_055_008.mp3","charTypeName":"word"},{"id":51876,"position":9,"arabic":"وَلَكُمْ","translation":"আর জন্যে (রয়েছে) তোমাদের","audioUrl":"wbw/028_055_009.mp3","charTypeName":"word"},{"id":51877,"position":10,"arabic":"أَعْمَـٰلُكُمْ","translation":"কর্মসমূহ তোমাদের","audioUrl":"wbw/028_055_010.mp3","charTypeName":"word"},{"id":51878,"position":11,"arabic":"سَلَـٰمٌ","translation":"সালাম'","audioUrl":"wbw/028_055_011.mp3","charTypeName":"word"},{"id":51879,"position":12,"arabic":"عَلَيْكُمْ","translation":"উপর তোমাদের","audioUrl":"wbw/028_055_012.mp3","charTypeName":"word"},{"id":51880,"position":13,"arabic":"لَا","translation":"না","audioUrl":"wbw/028_055_013.mp3","charTypeName":"word"},{"id":51881,"position":14,"arabic":"نَبْتَغِى","translation":"চাই আমরা","audioUrl":"wbw/028_055_014.mp3","charTypeName":"word"},{"id":51882,"position":15,"arabic":"ٱلْجَـٰهِلِينَ","translation":"অজ্ঞদের (মতো পথ)\"","audioUrl":"wbw/028_055_015.mp3","charTypeName":"word"},{"id":51883,"position":16,"arabic":"٥٥","translation":"(৫৫)","audioUrl":null,"charTypeName":"end"}]},{"number":56,"arabic":"إِنَّكَ لَا تَهْدِى مَنْ أَحْبَبْتَ وَلَٰكِنَّ ٱللَّهَ يَهْدِى مَن يَشَآءُ ۚ وَهُوَ أَعْلَمُ بِٱلْمُهْتَدِينَ","translation":"VERILY, thou canst not guide aright everyone whom thou lovest: but it is God who guides him that wills [to be guided]; and He is fully aware of all who would let themselves be guided.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3308.mp3","surahId":28,"words":[{"id":52395,"position":1,"arabic":"إِنَّكَ","translation":"(হে নাবী) তুমি নিশ্চয়ই","audioUrl":"wbw/028_056_001.mp3","charTypeName":"word"},{"id":52396,"position":2,"arabic":"لَا","translation":"না","audioUrl":"wbw/028_056_002.mp3","charTypeName":"word"},{"id":52397,"position":3,"arabic":"تَهْدِى","translation":"পথ দেখাতে পারো","audioUrl":"wbw/028_056_003.mp3","charTypeName":"word"},{"id":52398,"position":4,"arabic":"مَنْ","translation":"যাকে","audioUrl":"wbw/028_056_004.mp3","charTypeName":"word"},{"id":52399,"position":5,"arabic":"أَحْبَبْتَ","translation":"তুমি ভালবাসো","audioUrl":"wbw/028_056_005.mp3","charTypeName":"word"},{"id":52400,"position":6,"arabic":"وَلَـٰكِنَّ","translation":"কিন্তু","audioUrl":"wbw/028_056_006.mp3","charTypeName":"word"},{"id":52401,"position":7,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/028_056_007.mp3","charTypeName":"word"},{"id":52402,"position":8,"arabic":"يَهْدِى","translation":"সৎপথ দেখান","audioUrl":"wbw/028_056_008.mp3","charTypeName":"word"},{"id":52403,"position":9,"arabic":"مَن","translation":"যাকে","audioUrl":"wbw/028_056_009.mp3","charTypeName":"word"},{"id":52404,"position":10,"arabic":"يَشَآءُ ۚ","translation":"ইচ্ছে করেন","audioUrl":"wbw/028_056_010.mp3","charTypeName":"word"},{"id":52406,"position":11,"arabic":"وَهُوَ","translation":"এবং তিনিই","audioUrl":"wbw/028_056_012.mp3","charTypeName":"word"},{"id":52407,"position":12,"arabic":"أَعْلَمُ","translation":"খুব জানেন","audioUrl":"wbw/028_056_013.mp3","charTypeName":"word"},{"id":52408,"position":13,"arabic":"بِٱلْمُهْتَدِينَ","translation":"সম্পর্কে সৎপথপ্রাপ্তদের","audioUrl":"wbw/028_056_014.mp3","charTypeName":"word"},{"id":52409,"position":14,"arabic":"٥٦","translation":"(৫৬)","audioUrl":null,"charTypeName":"end"}]},{"number":57,"arabic":"وَقَالُوٓا۟ إِن نَّتَّبِعِ ٱلْهُدَىٰ مَعَكَ نُتَخَطَّفْ مِنْ أَرْضِنَآ ۚ أَوَلَمْ نُمَكِّن لَّهُمْ حَرَمًا ءَامِنًۭا يُجْبَىٰٓ إِلَيْهِ ثَمَرَٰتُ كُلِّ شَىْءٍۢ رِّزْقًۭا مِّن لَّدُنَّا وَلَٰكِنَّ أَكْثَرَهُمْ لَا يَعْلَمُونَ","translation":"Now some say, “If we were to follow the guidance to which thou invitest us, we would be torn away from our very soil!” Why - have We not established for them a sanc­tuary secure, to which, as a provision from Us, shall be gathered the fruits of all (good) things? But most of them are unaware [of this truth].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3309.mp3","surahId":28,"words":[{"id":52918,"position":1,"arabic":"وَقَالُوٓا۟","translation":"এবং তারা বলে","audioUrl":"wbw/028_057_001.mp3","charTypeName":"word"},{"id":52919,"position":2,"arabic":"إِن","translation":"\"যদি","audioUrl":"wbw/028_057_002.mp3","charTypeName":"word"},{"id":52920,"position":3,"arabic":"نَّتَّبِعِ","translation":"আমরা অনুসরণ করি","audioUrl":"wbw/028_057_003.mp3","charTypeName":"word"},{"id":52921,"position":4,"arabic":"ٱلْهُدَىٰ","translation":"সৎপথের","audioUrl":"wbw/028_057_004.mp3","charTypeName":"word"},{"id":52922,"position":5,"arabic":"مَعَكَ","translation":"তোমার সাথে","audioUrl":"wbw/028_057_005.mp3","charTypeName":"word"},{"id":52923,"position":6,"arabic":"نُتَخَطَّفْ","translation":"আমাদেরকে উৎখাত করা হবে","audioUrl":"wbw/028_057_006.mp3","charTypeName":"word"},{"id":52924,"position":7,"arabic":"مِنْ","translation":"হ'তে","audioUrl":"wbw/028_057_007.mp3","charTypeName":"word"},{"id":52925,"position":8,"arabic":"أَرْضِنَآ ۚ","translation":"আমাদের দেশ\"","audioUrl":"wbw/028_057_008.mp3","charTypeName":"word"},{"id":52927,"position":9,"arabic":"أَوَلَمْ","translation":"করি  নি কি","audioUrl":"wbw/028_057_010.mp3","charTypeName":"word"},{"id":52928,"position":10,"arabic":"نُمَكِّن","translation":"আমরা প্রতিষ্ঠা","audioUrl":"wbw/028_057_011.mp3","charTypeName":"word"},{"id":52929,"position":11,"arabic":"لَّهُمْ","translation":"জন্যে তাদের","audioUrl":"wbw/028_057_012.mp3","charTypeName":"word"},{"id":52930,"position":12,"arabic":"حَرَمًا","translation":"হারাম","audioUrl":"wbw/028_057_013.mp3","charTypeName":"word"},{"id":52931,"position":13,"arabic":"ءَامِنًۭا","translation":"শান্তিপূর্ণ","audioUrl":"wbw/028_057_014.mp3","charTypeName":"word"},{"id":52932,"position":14,"arabic":"يُجْبَىٰٓ","translation":"আনা হয়","audioUrl":"wbw/028_057_015.mp3","charTypeName":"word"},{"id":52933,"position":15,"arabic":"إِلَيْهِ","translation":"দিকে তার","audioUrl":"wbw/028_057_016.mp3","charTypeName":"word"},{"id":52934,"position":16,"arabic":"ثَمَرَٰتُ","translation":"ফল-মূলসমূহ","audioUrl":"wbw/028_057_017.mp3","charTypeName":"word"},{"id":52935,"position":17,"arabic":"كُلِّ","translation":"প্রত্যেক","audioUrl":"wbw/028_057_018.mp3","charTypeName":"word"},{"id":52936,"position":18,"arabic":"شَىْءٍۢ","translation":"রকমের","audioUrl":"wbw/028_057_019.mp3","charTypeName":"word"},{"id":52937,"position":19,"arabic":"رِّزْقًۭا","translation":"জীবনের উপকরণ হিসেবে","audioUrl":"wbw/028_057_020.mp3","charTypeName":"word"},{"id":52938,"position":20,"arabic":"مِّن","translation":"হ'তে","audioUrl":"wbw/028_057_021.mp3","charTypeName":"word"},{"id":52939,"position":21,"arabic":"لَّدُنَّا","translation":"আমাদের পক্ষ","audioUrl":"wbw/028_057_022.mp3","charTypeName":"word"},{"id":52940,"position":22,"arabic":"وَلَـٰكِنَّ","translation":"কিন্তু","audioUrl":"wbw/028_057_023.mp3","charTypeName":"word"},{"id":52941,"position":23,"arabic":"أَكْثَرَهُمْ","translation":"অধিকাংশই তাদের","audioUrl":"wbw/028_057_024.mp3","charTypeName":"word"},{"id":52942,"position":24,"arabic":"لَا","translation":"না","audioUrl":"wbw/028_057_025.mp3","charTypeName":"word"},{"id":52943,"position":25,"arabic":"يَعْلَمُونَ","translation":"জানে","audioUrl":"wbw/028_057_026.mp3","charTypeName":"word"},{"id":52944,"position":26,"arabic":"٥٧","translation":"(৫৭)","audioUrl":null,"charTypeName":"end"}]},{"number":58,"arabic":"وَكَمْ أَهْلَكْنَا مِن قَرْيَةٍۭ بَطِرَتْ مَعِيشَتَهَا ۖ فَتِلْكَ مَسَٰكِنُهُمْ لَمْ تُسْكَن مِّنۢ بَعْدِهِمْ إِلَّا قَلِيلًۭا ۖ وَكُنَّا نَحْنُ ٱلْوَٰرِثِينَ","translation":"And how many a community that [once] exult­ed in its wanton wealth and ease of life have We destroyed, so that those dwelling-places of theirs – all but a few - have never been dwelt-in after them: for it is indeed We alone who shall remain when all else will have passed away!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3310.mp3","surahId":28,"words":[{"id":53445,"position":1,"arabic":"وَكَمْ","translation":"আর কতই না","audioUrl":"wbw/028_058_001.mp3","charTypeName":"word"},{"id":53446,"position":2,"arabic":"أَهْلَكْنَا","translation":"ধ্বংস করেছি আমরা","audioUrl":"wbw/028_058_002.mp3","charTypeName":"word"},{"id":53447,"position":3,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/028_058_003.mp3","charTypeName":"word"},{"id":53448,"position":4,"arabic":"قَرْيَةٍۭ","translation":"জনপদ","audioUrl":"wbw/028_058_004.mp3","charTypeName":"word"},{"id":53449,"position":5,"arabic":"بَطِرَتْ","translation":"অহংকার করতো (তার অধিবাসীরা)","audioUrl":"wbw/028_058_005.mp3","charTypeName":"word"},{"id":53450,"position":6,"arabic":"مَعِيشَتَهَا ۖ","translation":"তাদের জীবিকার","audioUrl":"wbw/028_058_006.mp3","charTypeName":"word"},{"id":53452,"position":7,"arabic":"فَتِلْكَ","translation":"অতঃপর ঐ","audioUrl":"wbw/028_058_008.mp3","charTypeName":"word"},{"id":53453,"position":8,"arabic":"مَسَـٰكِنُهُمْ","translation":"ঘরবাড়িসমূহ তাদের","audioUrl":"wbw/028_058_009.mp3","charTypeName":"word"},{"id":53454,"position":9,"arabic":"لَمْ","translation":"নি","audioUrl":"wbw/028_058_010.mp3","charTypeName":"word"},{"id":53455,"position":10,"arabic":"تُسْكَن","translation":"বসবাস করে","audioUrl":"wbw/028_058_011.mp3","charTypeName":"word"},{"id":53456,"position":11,"arabic":"مِّنۢ","translation":"থেকে","audioUrl":"wbw/028_058_012.mp3","charTypeName":"word"},{"id":53457,"position":12,"arabic":"بَعْدِهِمْ","translation":"পর তাদের","audioUrl":"wbw/028_058_013.mp3","charTypeName":"word"},{"id":53458,"position":13,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/028_058_014.mp3","charTypeName":"word"},{"id":53459,"position":14,"arabic":"قَلِيلًۭا ۖ","translation":"অতি অল্প","audioUrl":"wbw/028_058_015.mp3","charTypeName":"word"},{"id":53461,"position":15,"arabic":"وَكُنَّا","translation":"এবং আমরা হলাম","audioUrl":"wbw/028_058_017.mp3","charTypeName":"word"},{"id":53462,"position":16,"arabic":"نَحْنُ","translation":"আমরাই","audioUrl":"wbw/028_058_018.mp3","charTypeName":"word"},{"id":53463,"position":17,"arabic":"ٱلْوَٰرِثِينَ","translation":"(এসবের) উত্তরাধিকারী","audioUrl":"wbw/028_058_019.mp3","charTypeName":"word"},{"id":53464,"position":18,"arabic":"٥٨","translation":"(৫৮)","audioUrl":null,"charTypeName":"end"}]},{"number":59,"arabic":"وَمَا كَانَ رَبُّكَ مُهْلِكَ ٱلْقُرَىٰ حَتَّىٰ يَبْعَثَ فِىٓ أُمِّهَا رَسُولًۭا يَتْلُوا۟ عَلَيْهِمْ ءَايَٰتِنَا ۚ وَمَا كُنَّا مُهْلِكِى ٱلْقُرَىٰٓ إِلَّا وَأَهْلُهَا ظَٰلِمُونَ","translation":"Yet, withal, thy Sustainer would never destroy a community without having [first] raised in its midst an apostle who would convey unto them Our mes­sages; and never would We destroy a community unless its people are wont to do wrong [to one another].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3311.mp3","surahId":28,"words":[{"id":53975,"position":1,"arabic":"وَمَا","translation":"আর না","audioUrl":"wbw/028_059_001.mp3","charTypeName":"word"},{"id":53976,"position":2,"arabic":"كَانَ","translation":"ছিলেন","audioUrl":"wbw/028_059_002.mp3","charTypeName":"word"},{"id":53977,"position":3,"arabic":"رَبُّكَ","translation":"তোমার রব","audioUrl":"wbw/028_059_003.mp3","charTypeName":"word"},{"id":53978,"position":4,"arabic":"مُهْلِكَ","translation":"ধ্বংসকারী","audioUrl":"wbw/028_059_004.mp3","charTypeName":"word"},{"id":53979,"position":5,"arabic":"ٱلْقُرَىٰ","translation":"জনবসতিগুলোকে","audioUrl":"wbw/028_059_005.mp3","charTypeName":"word"},{"id":53980,"position":6,"arabic":"حَتَّىٰ","translation":"যতক্ষণ না","audioUrl":"wbw/028_059_006.mp3","charTypeName":"word"},{"id":53981,"position":7,"arabic":"يَبْعَثَ","translation":"তিনি পাঠান","audioUrl":"wbw/028_059_007.mp3","charTypeName":"word"},{"id":53982,"position":8,"arabic":"فِىٓ","translation":"মধ্যে","audioUrl":"wbw/028_059_008.mp3","charTypeName":"word"},{"id":53983,"position":9,"arabic":"أُمِّهَا","translation":"তার কেন্দ্রস্থলের","audioUrl":"wbw/028_059_009.mp3","charTypeName":"word"},{"id":53984,"position":10,"arabic":"رَسُولًۭا","translation":"কোনো রাসূলকে","audioUrl":"wbw/028_059_010.mp3","charTypeName":"word"},{"id":53985,"position":11,"arabic":"يَتْلُوا۟","translation":"(যে)তিলাওয়াত করেন","audioUrl":"wbw/028_059_011.mp3","charTypeName":"word"},{"id":53986,"position":12,"arabic":"عَلَيْهِمْ","translation":"নিকট তাদের","audioUrl":"wbw/028_059_012.mp3","charTypeName":"word"},{"id":53987,"position":13,"arabic":"ءَايَـٰتِنَا ۚ","translation":"আয়াতসমূহকে আমাদের","audioUrl":"wbw/028_059_013.mp3","charTypeName":"word"},{"id":53989,"position":14,"arabic":"وَمَا","translation":"ও না","audioUrl":"wbw/028_059_015.mp3","charTypeName":"word"},{"id":53990,"position":15,"arabic":"كُنَّا","translation":"আমরা ছিলাম","audioUrl":"wbw/028_059_016.mp3","charTypeName":"word"},{"id":53991,"position":16,"arabic":"مُهْلِكِى","translation":"ধ্বংসকারী","audioUrl":"wbw/028_059_017.mp3","charTypeName":"word"},{"id":53992,"position":17,"arabic":"ٱلْقُرَىٰٓ","translation":"জনপদসমূহকে","audioUrl":"wbw/028_059_018.mp3","charTypeName":"word"},{"id":53993,"position":18,"arabic":"إِلَّا","translation":"এ ছাড়া যে","audioUrl":"wbw/028_059_019.mp3","charTypeName":"word"},{"id":53994,"position":19,"arabic":"وَأَهْلُهَا","translation":"যখন