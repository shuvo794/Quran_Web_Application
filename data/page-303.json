{"id":303,"ayahs":[{"number":84,"arabic":"إِنَّا مَكَّنَّا لَهُۥ فِى ٱلْأَرْضِ وَءَاتَيْنَٰهُ مِن كُلِّ شَىْءٍۢ سَبَبًۭا","translation":"Behold, We established him securely on earth, and endowed him with [the knowledge of] the right means to achieve anything [that he might set out to achieve];","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2224.mp3","surahId":18,"words":[{"id":65880,"position":1,"arabic":"إِنَّا","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/018_084_001.mp3","charTypeName":"word"},{"id":65881,"position":2,"arabic":"مَكَّنَّا","translation":"আমরা কর্তৃত্ব দিয়েছিলাম","audioUrl":"wbw/018_084_002.mp3","charTypeName":"word"},{"id":65882,"position":3,"arabic":"لَهُۥ","translation":"তাকে","audioUrl":"wbw/018_084_003.mp3","charTypeName":"word"},{"id":65883,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/018_084_004.mp3","charTypeName":"word"},{"id":65884,"position":5,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/018_084_005.mp3","charTypeName":"word"},{"id":65885,"position":6,"arabic":"وَءَاتَيْنَـٰهُ","translation":"এবং তাকে আমরা দিয়েছিলাম","audioUrl":"wbw/018_084_006.mp3","charTypeName":"word"},{"id":65886,"position":7,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/018_084_007.mp3","charTypeName":"word"},{"id":65887,"position":8,"arabic":"كُلِّ","translation":"প্রত্যেক","audioUrl":"wbw/018_084_008.mp3","charTypeName":"word"},{"id":65888,"position":9,"arabic":"شَىْءٍۢ","translation":"বস্তু","audioUrl":"wbw/018_084_009.mp3","charTypeName":"word"},{"id":65889,"position":10,"arabic":"سَبَبًۭا","translation":"পথ নির্দেশ","audioUrl":"wbw/018_084_010.mp3","charTypeName":"word"},{"id":65890,"position":11,"arabic":"٨٤","translation":"(৮৪)","audioUrl":null,"charTypeName":"end"}]},{"number":85,"arabic":"فَأَتْبَعَ سَبَبًا","translation":"and so he chose the right means [in whatever he did].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2225.mp3","surahId":18,"words":[{"id":65990,"position":1,"arabic":"فَأَتْبَعَ","translation":"অতঃপর সে অনুসরণ করলো","audioUrl":"wbw/018_085_001.mp3","charTypeName":"word"},{"id":65991,"position":2,"arabic":"سَبَبًا","translation":"এক পথ","audioUrl":"wbw/018_085_002.mp3","charTypeName":"word"},{"id":65992,"position":3,"arabic":"٨٥","translation":"(৮৫)","audioUrl":null,"charTypeName":"end"}]},{"number":86,"arabic":"حَتَّىٰٓ إِذَا بَلَغَ مَغْرِبَ ٱلشَّمْسِ وَجَدَهَا تَغْرُبُ فِى عَيْنٍ حَمِئَةٍۢ وَوَجَدَ عِندَهَا قَوْمًۭا ۗ قُلْنَا يَٰذَا ٱلْقَرْنَيْنِ إِمَّآ أَن تُعَذِّبَ وَإِمَّآ أَن تَتَّخِذَ فِيهِمْ حُسْنًۭا","translation":"[And he marched westwards] till, when he came to the setting of the sun, it appeared to him that it was setting in a dark, turbid sea; and nearby he found a people [given to every kind of wrongdoing]. We said: \"O thou Two-Horned One! Thou mayest either cause [them] to suffer or treat them with kindness!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2226.mp3","surahId":18,"words":[{"id":66432,"position":1,"arabic":"حَتَّىٰٓ","translation":"শেষ পর্যন্ত","audioUrl":"wbw/018_086_001.mp3","charTypeName":"word"},{"id":66433,"position":2,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/018_086_002.mp3","charTypeName":"word"},{"id":66434,"position":3,"arabic":"بَلَغَ","translation":"পৌঁছলো","audioUrl":"wbw/018_086_003.mp3","charTypeName":"word"},{"id":66435,"position":4,"arabic":"مَغْرِبَ","translation":"অস্তাচলে","audioUrl":"wbw/018_086_004.mp3","charTypeName":"word"},{"id":66436,"position":5,"arabic":"ٱلشَّمْسِ","translation":"সূর্যের","audioUrl":"wbw/018_086_005.mp3","charTypeName":"word"},{"id":66437,"position":6,"arabic":"وَجَدَهَا","translation":"পেলো তা","audioUrl":"wbw/018_086_006.mp3","charTypeName":"word"},{"id":66438,"position":7,"arabic":"تَغْرُبُ","translation":"অস্ত যাচ্ছে","audioUrl":"wbw/018_086_007.mp3","charTypeName":"word"},{"id":66439,"position":8,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/018_086_008.mp3","charTypeName":"word"},{"id":66440,"position":9,"arabic":"عَيْنٍ","translation":"জলাশয়","audioUrl":"wbw/018_086_009.mp3","charTypeName":"word"},{"id":66441,"position":10,"arabic":"حَمِئَةٍۢ","translation":"পঙ্কিল","audioUrl":"wbw/018_086_010.mp3","charTypeName":"word"},{"id":66442,"position":11,"arabic":"وَوَجَدَ","translation":"এবং সে পেলো","audioUrl":"wbw/018_086_011.mp3","charTypeName":"word"},{"id":66443,"position":12,"arabic":"عِندَهَا","translation":"তার কাছে","audioUrl":"wbw/018_086_012.mp3","charTypeName":"word"},{"id":66444,"position":13,"arabic":"قَوْمًۭا ۗ","translation":"এক জাতিকে","audioUrl":"wbw/018_086_013.mp3","charTypeName":"word"},{"id":66446,"position":14,"arabic":"قُلْنَا","translation":"আমরা বললাম","audioUrl":"wbw/018_086_015.mp3","charTypeName":"word"},{"id":66447,"position":15,"arabic":"يَـٰذَا","translation":"\"","audioUrl":"wbw/018_086_016.mp3","charTypeName":"word"},{"id":66448,"position":16,"arabic":"ٱلْقَرْنَيْنِ","translation":"\"হে জুলকারনাইন","audioUrl":"wbw/018_086_017.mp3","charTypeName":"word"},{"id":66449,"position":17,"arabic":"إِمَّآ","translation":"হয়","audioUrl":"wbw/018_086_018.mp3","charTypeName":"word"},{"id":66450,"position":18,"arabic":"أَن","translation":"যে","audioUrl":"wbw/018_086_019.mp3","charTypeName":"word"},{"id":66451,"position":19,"arabic":"تُعَذِّبَ","translation":"তুমি শাস্তি দিবে","audioUrl":"wbw/018_086_020.mp3","charTypeName":"word"},{"id":66452,"position":20,"arabic":"وَإِمَّآ","translation":"আর না হয়","audioUrl":"wbw/018_086_021.mp3","charTypeName":"word"},{"id":66453,"position":21,"arabic":"أَن","translation":"যে","audioUrl":"wbw/018_086_022.mp3","charTypeName":"word"},{"id":66454,"position":22,"arabic":"تَتَّخِذَ","translation":"তুমি অবলম্বন করো","audioUrl":"wbw/018_086_023.mp3","charTypeName":"word"},{"id":66455,"position":23,"arabic":"فِيهِمْ","translation":"জন্যে তাদের","audioUrl":"wbw/018_086_024.mp3","charTypeName":"word"},{"id":66456,"position":24,"arabic":"حُسْنًۭا","translation":"সদ্ব্যবহার\"","audioUrl":"wbw/018_086_025.mp3","charTypeName":"word"},{"id":66457,"position":25,"arabic":"٨٦","translation":"(৮৬)","audioUrl":null,"charTypeName":"end"}]},{"number":87,"arabic":"قَالَ أَمَّا مَن ظَلَمَ فَسَوْفَ نُعَذِّبُهُۥ ثُمَّ يُرَدُّ إِلَىٰ رَبِّهِۦ فَيُعَذِّبُهُۥ عَذَابًۭا نُّكْرًۭا","translation":"He answered: \"As for him who does wrong [unto others] - him shall we, in time, cause to suffer; and thereupon he shall be referred to his Sustainer, and He will cause him to suffer with unnameable suffering.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2227.mp3","surahId":18,"words":[{"id":66828,"position":1,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/018_087_001.mp3","charTypeName":"word"},{"id":66829,"position":2,"arabic":"أَمَّا","translation":"\"ব্যাপারে","audioUrl":"wbw/018_087_002.mp3","charTypeName":"word"},{"id":66830,"position":3,"arabic":"مَن","translation":"(তার) যে","audioUrl":"wbw/018_087_003.mp3","charTypeName":"word"},{"id":66831,"position":4,"arabic":"ظَلَمَ","translation":"সীমালঙ্ঘন করেছে","audioUrl":"wbw/018_087_004.mp3","charTypeName":"word"},{"id":66832,"position":5,"arabic":"فَسَوْفَ","translation":"অতঃপর শীঘ্রই","audioUrl":"wbw/018_087_005.mp3","charTypeName":"word"},{"id":66833,"position":6,"arabic":"نُعَذِّبُهُۥ","translation":"তাকে আমরা শাস্তি দিবো","audioUrl":"wbw/018_087_006.mp3","charTypeName":"word"},{"id":66834,"position":7,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/018_087_007.mp3","charTypeName":"word"},{"id":66835,"position":8,"arabic":"يُرَدُّ","translation":"ফিরিয়ে আনা হবে","audioUrl":"wbw/018_087_008.mp3","charTypeName":"word"},{"id":66836,"position":9,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/018_087_009.mp3","charTypeName":"word"},{"id":66837,"position":10,"arabic":"رَبِّهِۦ","translation":"তার রবের","audioUrl":"wbw/018_087_010.mp3","charTypeName":"word"},{"id":66838,"position":11,"arabic":"فَيُعَذِّبُهُۥ","translation":"অতঃপর তিনি শাস্তি দিবেন তাকে","audioUrl":"wbw/018_087_011.mp3","charTypeName":"word"},{"id":66839,"position":12,"arabic":"عَذَابًۭا","translation":"শাস্তি","audioUrl":"wbw/018_087_012.mp3","charTypeName":"word"},{"id":66840,"position":13,"arabic":"نُّكْرًۭا","translation":"কঠিন","audioUrl":"wbw/018_087_013.mp3","charTypeName":"word"},{"id":66841,"position":14,"arabic":"٨٧","translation":"(৮৭)","audioUrl":null,"charTypeName":"end"}]},{"number":88,"arabic":"وَأَمَّا مَنْ ءَامَنَ وَعَمِلَ صَٰلِحًۭا فَلَهُۥ جَزَآءً ٱلْحُسْنَىٰ ۖ وَسَنَقُولُ لَهُۥ مِنْ أَمْرِنَا يُسْرًۭا","translation":"But as for him who believes and does righteous deeds - he will have the ultimate good [of the life to come] as his reward; and [as for us,] we shall make binding on him [only] that which is easy to fulfill.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2228.mp3","surahId":18,"words":[{"id":67110,"position":1,"arabic":"وَأَمَّا","translation":"আর ব্যাপারে","audioUrl":"wbw/018_088_001.mp3","charTypeName":"word"},{"id":67111,"position":2,"arabic":"مَنْ","translation":"(তার) যে","audioUrl":"wbw/018_088_002.mp3","charTypeName":"word"},{"id":67112,"position":3,"arabic":"ءَامَنَ","translation":"ঈমান আনবে","audioUrl":"wbw/018_088_003.mp3","charTypeName":"word"},{"id":67113,"position":4,"arabic":"وَعَمِلَ","translation":"ও কাজ করে","audioUrl":"wbw/018_088_004.mp3","charTypeName":"word"},{"id":67114,"position":5,"arabic":"صَـٰلِحًۭا","translation":"সৎ","audioUrl":"wbw/018_088_005.mp3","charTypeName":"word"},{"id":67115,"position":6,"arabic":"فَلَهُۥ","translation":"তবে তার জন্যে","audioUrl":"wbw/018_088_006.mp3","charTypeName":"word"},{"id":67116,"position":7,"arabic":"جَزَآءً","translation":"পুরস্কার (রয়েছে)","audioUrl":"wbw/018_088_007.mp3","charTypeName":"word"},{"id":67117,"position":8,"arabic":"ٱلْحُسْنَىٰ ۖ","translation":"উত্তম","audioUrl":"wbw/018_088_008.mp3","charTypeName":"word"},{"id":67119,"position":9,"arabic":"وَسَنَقُولُ","translation":"এবং অচিরেই আমরা বলবো","audioUrl":"wbw/018_088_010.mp3","charTypeName":"word"},{"id":67120,"position":10,"arabic":"لَهُۥ","translation":"তাকে","audioUrl":"wbw/018_088_011.mp3","charTypeName":"word"},{"id":67121,"position":11,"arabic":"مِنْ","translation":"মধ্য হ'তে","audioUrl":"wbw/018_088_012.mp3","charTypeName":"word"},{"id":67122,"position":12,"arabic":"أَمْرِنَا","translation":"আমাদের নির্দেশের","audioUrl":"wbw/018_088_013.mp3","charTypeName":"word"},{"id":67123,"position":13,"arabic":"يُسْرًۭا","translation":"যা সহজ\"","audioUrl":"wbw/018_088_014.mp3","charTypeName":"word"},{"id":67124,"position":14,"arabic":"٨٨","translation":"(৮৮)","audioUrl":null,"charTypeName":"end"}]},{"number":89,"arabic":"ثُمَّ أَتْبَعَ سَبَبًا","translation":"And once again he chose the right means [to achieve a right end].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2229.mp3","surahId":18,"words":[{"id":67670,"position":1,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/018_089_001.mp3","charTypeName":"word"},{"id":67671,"position":2,"arabic":"أَتْبَعَ","translation":"সে অনুসরণ করলো","audioUrl":"wbw/018_089_002.mp3","charTypeName":"word"},{"id":67672,"position":3,"arabic":"سَبَبًا","translation":"আরও এক পথ","audioUrl":"wbw/018_089_003.mp3","charTypeName":"word"},{"id":67673,"position":4,"arabic":"٨٩","translation":"(৮৯)","audioUrl":null,"charTypeName":"end"}]},{"number":90,"arabic":"حَتَّىٰٓ إِذَا بَلَغَ مَطْلِعَ ٱلشَّمْسِ وَجَدَهَا تَطْلُعُ عَلَىٰ قَوْمٍۢ لَّمْ نَجْعَل لَّهُم مِّن دُونِهَا سِتْرًۭا","translation":"[And then he marched eastwards] till, when he came to the rising of the sun he found that it was rising on a people for whom We had provided no coverings against it:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2230.mp3","surahId":18,"words":[{"id":67892,"position":1,"arabic":"حَتَّىٰٓ","translation":"শেষ পর্যন্ত","audioUrl":"wbw/018_090_001.mp3","charTypeName":"word"},{"id":67893,"position":2,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/018_090_002.mp3","charTypeName":"word"},{"id":67894,"position":3,"arabic":"بَلَغَ","translation":"পৌঁছে