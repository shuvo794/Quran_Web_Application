":"wbw/042_012_003.mp3","charTypeName":"word"},{"id":13568,"position":4,"arabic":"وَٱلْأَرْضِ ۖ","translation":"ও পৃথিবীর","audioUrl":"wbw/042_012_004.mp3","charTypeName":"word"},{"id":13570,"position":5,"arabic":"يَبْسُطُ","translation":"প্রশস্ত করে দেন","audioUrl":"wbw/042_012_006.mp3","charTypeName":"word"},{"id":13571,"position":6,"arabic":"ٱلرِّزْقَ","translation":"জীবনের উপকরণ","audioUrl":"wbw/042_012_007.mp3","charTypeName":"word"},{"id":13572,"position":7,"arabic":"لِمَن","translation":"(তার) জন্যে যাকে","audioUrl":"wbw/042_012_008.mp3","charTypeName":"word"},{"id":13573,"position":8,"arabic":"يَشَآءُ","translation":"তিনি ইচ্ছে করেন","audioUrl":"wbw/042_012_009.mp3","charTypeName":"word"},{"id":13574,"position":9,"arabic":"وَيَقْدِرُ ۚ","translation":"এবং পরিমিত দেন (যাকে ইচ্ছে করেন)","audioUrl":"wbw/042_012_010.mp3","charTypeName":"word"},{"id":13576,"position":10,"arabic":"إِنَّهُۥ","translation":"তিনি নিশ্চয়ই","audioUrl":"wbw/042_012_012.mp3","charTypeName":"word"},{"id":13577,"position":11,"arabic":"بِكُلِّ","translation":"সম্পর্কে সব","audioUrl":"wbw/042_012_013.mp3","charTypeName":"word"},{"id":13578,"position":12,"arabic":"شَىْءٍ","translation":"কিছু","audioUrl":"wbw/042_012_014.mp3","charTypeName":"word"},{"id":13579,"position":13,"arabic":"عَلِيمٌۭ","translation":"খুব অবহিত","audioUrl":"wbw/042_012_015.mp3","charTypeName":"word"},{"id":13580,"position":14,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]},{"number":13,"arabic":"۞ شَرَعَ لَكُم مِّنَ ٱلدِّينِ مَا وَصَّىٰ بِهِۦ نُوحًۭا وَٱلَّذِىٓ أَوْحَيْنَآ إِلَيْكَ وَمَا وَصَّيْنَا بِهِۦٓ إِبْرَٰهِيمَ وَمُوسَىٰ وَعِيسَىٰٓ ۖ أَنْ أَقِيمُوا۟ ٱلدِّينَ وَلَا تَتَفَرَّقُوا۟ فِيهِ ۚ كَبُرَ عَلَى ٱلْمُشْرِكِينَ مَا تَدْعُوهُمْ إِلَيْهِ ۚ ٱللَّهُ يَجْتَبِىٓ إِلَيْهِ مَن يَشَآءُ وَيَهْدِىٓ إِلَيْهِ مَن يُنِيبُ","translation":"In matters of faith, He has ordained for you that which He had enjoined upon Noah - and into which We gave thee [O Muhammad] insight through revelation as well as that which We had enjoined upon Abraham, and Moses, and Jesus: Steadfastly uphold the [true] faith, and do not break up your unity therein. [And even though] that [unity of faith] to which thou callest them appears oppressive to those who are wont to ascribe to other beings or forces a share in His divinity, God draws unto Himself everyone who is willing, and guides unto Himself everyone who turns unto Him.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4285.mp3","surahId":42,"words":[{"id":14726,"position":1,"arabic":"۞ شَرَعَ","translation":"তিনি বিধান দিয়েছেন","audioUrl":"wbw/042_013_002.mp3","charTypeName":"word"},{"id":14727,"position":2,"arabic":"لَكُم","translation":"তোমাদের জন্যে (একমাত্র)","audioUrl":"wbw/042_013_003.mp3","charTypeName":"word"},{"id":14728,"position":3,"arabic":"مِّنَ","translation":"থেকে","audioUrl":"wbw/042_013_004.mp3","charTypeName":"word"},{"id":14729,"position":4,"arabic":"ٱلدِّينِ","translation":"দ্বীনের","audioUrl":"wbw/042_013_005.mp3","charTypeName":"word"},{"id":14730,"position":5,"arabic":"مَا","translation":"যা","audioUrl":"wbw/042_013_006.mp3","charTypeName":"word"},{"id":14731,"position":6,"arabic":"وَصَّىٰ","translation":"আদেশ দিয়েছিলেন","audioUrl":"wbw/042_013_007.mp3","charTypeName":"word"},{"id":14732,"position":7,"arabic":"بِهِۦ","translation":"সে সম্পর্কে","audioUrl":"wbw/042_013_008.mp3","charTypeName":"word"},{"id":14733,"position":8,"arabic":"نُوحًۭا","translation":"নূহকে","audioUrl":"wbw/042_013_009.mp3","charTypeName":"word"},{"id":14734,"position":9,"arabic":"وَٱلَّذِىٓ","translation":"এবং (হে নাবী) যা","audioUrl":"wbw/042_013_010.mp3","charTypeName":"word"},{"id":14735,"position":10,"arabic":"أَوْحَيْنَآ","translation":"আমরা ওহী করেছি","audioUrl":"wbw/042_013_011.mp3","charTypeName":"word"},{"id":14736,"position":11,"arabic":"إِلَيْكَ","translation":"তোমার প্রতিও","audioUrl":"wbw/042_013_012.mp3","charTypeName":"word"},{"id":14737,"position":12,"arabic":"وَمَا","translation":"এবং যা","au