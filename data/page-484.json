{"id":484,"ayahs":[{"number":11,"arabic":"فَاطِرُ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ ۚ جَعَلَ لَكُم مِّنْ أَنفُسِكُمْ أَزْوَٰجًۭا وَمِنَ ٱلْأَنْعَٰمِ أَزْوَٰجًۭا ۖ يَذْرَؤُكُمْ فِيهِ ۚ لَيْسَ كَمِثْلِهِۦ شَىْءٌۭ ۖ وَهُوَ ٱلسَّمِيعُ ٱلْبَصِيرُ","translation":"The Originator [is He] of the heavens and the earth. He has given you mates of your own kind just as [He has willed that] among the beasts [there be] mates - to multiply you thereby: [but] there is nothing like unto Him, and He alone is all-hearing, all-seeing.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4283.mp3","surahId":42,"words":[{"id":12204,"position":1,"arabic":"فَاطِرُ","translation":"(আল্লাহ-ই) সৃষ্টিকর্তা","audioUrl":"wbw/042_011_001.mp3","charTypeName":"word"},{"id":12205,"position":2,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশের","audioUrl":"wbw/042_011_002.mp3","charTypeName":"word"},{"id":12206,"position":3,"arabic":"وَٱلْأَرْضِ ۚ","translation":"এবং পৃথিবীর","audioUrl":"wbw/042_011_003.mp3","charTypeName":"word"},{"id":12208,"position":4,"arabic":"جَعَلَ","translation":"তিনি সৃষ্টি করেছেন","audioUrl":"wbw/042_011_005.mp3","charTypeName":"word"},{"id":12209,"position":5,"arabic":"لَكُم","translation":"তোমাদের জন্যে","audioUrl":"wbw/042_011_006.mp3","charTypeName":"word"},{"id":12210,"position":6,"arabic":"مِّنْ","translation":"মধ্য হ'তে","audioUrl":"wbw/042_011_007.mp3","charTypeName":"word"},{"id":12211,"position":7,"arabic":"أَنفُسِكُمْ","translation":"তোমাদের নিজেদের","audioUrl":"wbw/042_011_008.mp3","charTypeName":"word"},{"id":12212,"position":8,"arabic":"أَزْوَٰجًۭا","translation":"জোড়া জোড়া","audioUrl":"wbw/042_011_009.mp3","charTypeName":"word"},{"id":12213,"position":9,"arabic":"وَمِنَ","translation":"এবং মধ্য হতে","audioUrl":"wbw/042_011_010.mp3","charTypeName":"word"},{"id":12214,"position":10,"arabic":"ٱلْأَنْعَـٰمِ","translation":"গবাদি পশুর","audioUrl":"wbw/042_011_011.mp3","charTypeName":"word"},{"id":12215,"position":11,"arabic":"أَزْوَٰجًۭا ۖ","translation":"জোড়া 