{"id":497,"ayahs":[{"number":19,"arabic":"وَأَن لَّا تَعْلُوا۟ عَلَى ٱللَّهِ ۖ إِنِّىٓ ءَاتِيكُم بِسُلْطَٰنٍۢ مُّبِينٍۢ","translation":"“And exalt not yourselves against God: for, verily, I come unto you with a manifest authority [from Him];","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4433.mp3","surahId":44,"words":[{"id":21347,"position":1,"arabic":"وَأَن","translation":"এবং (এও বলেছিল) যে","audioUrl":"wbw/044_019_001.mp3","charTypeName":"word"},{"id":21348,"position":2,"arabic":"لَّا","translation":"না","audioUrl":"wbw/044_019_002.mp3","charTypeName":"word"},{"id":21349,"position":3,"arabic":"تَعْلُوا۟","translation":"বড়াই করো","audioUrl":"wbw/044_019_003.mp3","charTypeName":"word"},{"id":21350,"position":4,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/044_019_004.mp3","charTypeName":"word"},{"id":21351,"position":5,"arabic":"ٱللَّهِ ۖ","translation":"আল্লাহ্‌র","audioUrl":"wbw/044_019_005.mp3","charTypeName":"word"},{"id":21353,"position":6,"arabic":"إِنِّىٓ","translation":"আমি নিশ্চয়ই","audioUrl":"wbw/044_019_007.mp3","charTypeName":"word"},{"id":21354,"position":7,"arabic":"ءَاتِيكُم","translation":"তোমাদের কাছে এসেছি","audioUrl":"wbw/044_019_008.mp3","charTypeName":"word"},{"id":21355,"position":8,"arabic":"بِسُلْطَـٰنٍۢ","translation":"নিয়ে প্রমাণ","audioUrl":"wbw/044_019_009.mp3","charTypeName":"word"},{"id":21356,"position":9,"arabic":"مُّبِينٍۢ","translation":"সুস্পষ্ট","audioUrl":"wbw/044_019_010.mp3","charTypeName":"word"},{"id":21357,"position":10,"arabic":"١٩","translation":"(১৯)","audioUrl":null,"charTypeName":"end"}]},{"number":20,"arabic":"وَإِنِّى عُذْتُ بِرَبِّى وَرَبِّكُمْ أَن تَرْجُمُونِ","translation":"and, behold, it is with my Sustainer - and your Sustainer - that I seek refuge against all your endeavours to revile me.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4434.mp3","surahId":44,"words":[{"id":22401,"position":1,"arabic":"وَإِنِّى","translation":"এবং নিশ্চয়ই আমি","audioUrl":"wbw/044_020_001.mp3","charTypeName":"word"},{"id":22402,"position":2,"arabic":"عُذْتُ","translation":"আশ্রয় নিয়েছি","audioUrl":"wbw/044_020_002.mp3","charTypeName":"word"},{"id":22403,"position":3,"arabic":"بِرَبِّى","translation":"আমার রবের (কাছে)","audioUrl":"wbw/044_020_003.mp3","charTypeName":"word"},{"id":22404,"position":4,"arabic":"وَرَبِّكُمْ","translation":"এবং তোমাদের (প্রকৃত রবের)","audioUrl":"wbw/044_020_004.mp3","charTypeName":"word"},{"id":22405,"position":5,"arabic":"أَن","translation":"(এ হ'তে) যে","audioUrl":"wbw/044_020_005.mp3","charTypeName":"word"},{"id":22406,"position":6,"arabic":"تَرْجُمُونِ","translation":"আমাকে তোমরা পাথর মেরে হত্যা করবে","audioUrl":"wbw/044_020_006.mp3","charTypeName":"word"},{"id":22407,"position":7,"arabic":"٢٠","translation":"(২০)","audioUrl":null,"charTypeName":"end"}]},{"number":21,"arabic":"وَإِن لَّمْ تُؤْمِنُوا۟ لِى فَٱعْتَزِلُونِ","translation":"And if you do not believe me, [at least] stand away from me!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4435.mp3","surahId":44,"words":[{"id":23533,"position":1,"arabic":"وَإِن","translation":"আর যদি","audioUrl":"wbw/044_021_001.mp3","charTypeName":"word"},{"id":23534,"position":2,"arabic":"لَّمْ","translation":"না","audioUrl":"wbw/044_021_002.mp3","charTypeName":"word"},{"id":23535,"position":3,"arabic":"تُؤْمِنُوا۟","translation":"তোমরা ঈমান আনো","audioUrl":"wbw/044_021_003.mp3","charTypeName":"word"},{"id":23536,"position":4,"arabic":"لِى","translation":"আমার উপর","audioUrl":"wbw/044_021_004.mp3","charTypeName":"word"},{"id":23537,"position":5,"arabic":"فَٱعْتَزِلُونِ","translation":"তবে আমার থেকে দূরে থাকো\"","audioUrl":"wbw/044_021_005.mp3","charTypeName":"word"},{"id":23538,"position":6,"arabic":"٢١","translation":"(২১)","audioUrl":null,"charTypeName":"end"}]},{"number":22,"arabic":"فَدَعَا رَبَّهُۥٓ أَنَّ هَٰٓؤُلَآءِ قَوْمٌۭ مُّجْرِمُونَ","translation":"But then, [when they beset him with their enmity,] he called out to his Sustainer, “These are [indeed] people lost in sin!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4436.mp3","surahId":44,"words":[{"id":24568,"position":1,"arabic":"فَدَعَا","translation":"অবশেষে সে ডাকলো","audioUrl":"wbw/044_022_001.mp3","charTypeName":"word"},{"id":24569,"position":2,"arabic":"رَبَّهُۥٓ","translation":"তার রবকে","audioUrl":"wbw/044_022_002.mp3","charTypeName":"word"},{"id":24570,"position":3,"arabic":"أَنَّ","translation":"\"(এবং বললো) যে","audioUrl":"wbw/044_022_003.mp3","charTypeName":"word"},{"id":24571,"position":4,"arabic":"هَـٰٓؤُلَآءِ","translation":"এসব","audioUrl":"wbw/044_022_004.mp3","charTypeName":"word"},{"id":24572,"position":5,"arabic":"قَوْمٌۭ","translation":"সম্প্রদায়","audioUrl":"wbw/044_022_005.mp3","charTypeName":"word"},{"id":24573,"position":6,"arabic":"مُّجْرِمُونَ","translation":"অপরাধী (তাদের মীমাংসা করো)\"","audioUrl":"wbw/044_022_006.mp3","charTypeName":"word"},{"id":24574,"position":7,"arabic":"٢٢","translation":"(২২)","audioUrl":null,"charTypeName":"end"}]},{"number":23,"arabic":"فَأَسْرِ بِعِبَادِى لَيْلًا إِنَّكُم مُّتَّبَعُونَ","translation":"And [God said]: “Go thou forth with My servants by night, for you will surely be pursued;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4437.mp3","surahId":44,"words":[{"id":25639,"position":1,"arabic":"فَأَسْرِ","translation":"(বলা হলো) রওনা হও তাহ'লে","audioUrl":"wbw/044_023_001.mp3","charTypeName":"word"},{"id":25640,"position":2,"arabic":"بِعِبَادِى","translation":"আমার দাসদের নিয়ে","audioUrl":"wbw/044_023_002.mp3","charTypeName":"word"},{"id":25641,"position":3,"arabic":"لَيْلًا","translation":"রাতে","audioUrl":"wbw/044_023_003.mp3","charTypeName":"word"},{"id":25642,"position":4,"arabic":"إِنَّكُم","translation":"নিশ্চয়ই তোমাদের","audioUrl":"wbw/044_023_004.mp3","charTypeName":"word"},{"id":25643,"position":5,"arabic":"مُّتَّبَعُونَ","translation":"পিছনে (ধাওয়া) করা হবে","audioUrl":"wbw/044_023_005.mp3","charTypeName":"word"},{"id":25644,"position":6,"arabic":"٢٣","translation":"(২৩)","audioUrl":null,"charTypeName":"end"}]},{"number":24,"arabic":"وَٱتْرُكِ ٱلْبَحْرَ رَهْوًا ۖ إِنَّهُمْ جُندٌۭ مُّغْرَقُونَ","translation":"and leave the sea becalmed [between thee and Pharaoh’s men]: for, verily, they are a host destined to be drowned!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4438.mp3","surahId":44,"words":[{"id":26708,"position":1,"arabic":"وَٱتْرُكِ","translation":"এবং ছেড়ে দাও","audioUrl":"wbw/044_024_001.mp3","charTypeName":"word"},{"id":26709,"position":2,"arabic":"ٱلْبَحْرَ","translation":"সাগরকে","audioUrl":"wbw/044_024_002.mp3","charTypeName":"word"},{"id":26710,"position":3,"arabic":"رَهْوًا ۖ","translation":"শান্ত অবস্হায়","audioUrl":"wbw/044_024_003.mp3","charTypeName":"word"},{"id":26712,"position":4,"arabic":"إِنَّهُمْ","translation":"তারা নিশ্চয়ই","audioUrl":"wbw/044_024_005.mp3","charTypeName":"word"},{"id":26713,"position":5,"arabic":"جُندٌۭ","translation":"(অর্থাৎ ধাওয়াকারী) সৈন্যবাহিনী","audioUrl":"wbw/044_024_006.mp3","charTypeName":"word"},{"id":26714,"position":6,"arabic":"مُّغْرَقُونَ","translation":"ডুবে যাবে\"","audioUrl":"wbw/044_024_007.mp3","charTypeName":"word"},{"id":26715,"position":7,"arabic":"٢٤","translation":"(২৪)","audioUrl":null,"charTypeName":"end"}]},{"number":25,"arabic":"كَمْ تَرَكُوا۟ مِن جَنَّٰتٍۢ وَعُيُونٍۢ","translation":"[And so they perished: and] how many gardens did they leave behind, and water-runnels,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4439.mp3","surahId":44,"words":[{"id":27726,"position":1,"arabic":"كَمْ","translation":"কতই না","audioUrl":"wbw/044_025_001.mp3","charTypeName":"word"},{"id":27727,"position":2,"arabic":"تَرَكُوا۟","translation":"তারা ছেড়েছিলো","audioUrl":"wbw/044_025_002.mp3","charTypeName":"word"},{"id":27728,"position":3,"arabic":"مِن","translation":"মধ্য হতে","audioUrl":"wbw/044_025_003.mp3","charTypeName":"word"},{"id":27729,"position":4,"arabic":"جَنَّـٰتٍۢ","translation":"বাগান","audioUrl":"wbw/044_025_004.mp3","charTypeName":"word"},{"id":27730,"position":5,"arabic":"وَعُيُونٍۢ","translation":"ও ঝর্ণাসমূহ","audioUrl":"wbw/044_025_005.mp3","charTypeName":"word"},{"id":27731,"position":6,"arabic":"٢٥","translation":"(২৫)","audioUrl":null,"charTypeName":"end"}]},{"number":26,"arabic":"وَزُرُوعٍۢ وَمَقَامٍۢ كَرِيمٍۢ","translation":"and fields of grain, and noble dwellings,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4440.mp3","surahId":44,"words":[{"id":29139,"position":1,"arabic":"وَزُرُوعٍۢ","translation":"এবং শস্যক্ষেত","audioUrl":"wbw/044_026_001.mp3","charTypeName":"word"},{"id":29140,"position":2,"arabic":"وَمَقَامٍۢ","translation":"ও বাসস্থান","audioUrl":"wbw/044_026_002.mp3","charTypeName":"word"},{"id":29141,"position":3,"arabic":"كَرِيمٍۢ","translation":"সুন্দর","audioUrl":"wbw/044_026_003.mp3","charTypeName":"word"},{"id":29142,"position":4,"arabic":"٢٦","translation":"(২৬)","audioUrl":null,"charTypeName":"end"}]},{"number":27,"arabic":"وَنَعْمَةٍۢ كَانُوا۟ فِيهَا فَٰكِهِينَ","translation":"and [all that] life of ease in which they used to delight!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4441.mp3","surahId":44,"words":[{"id":29582,"position":1,"arabic":"وَنَعْمَةٍۢ","translation":"এবং বিলাস","audioUrl":"wbw/044_027_001.mp3","charTypeName":"word"},{"id":29583,"position":2,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/044_027_002.mp3","charTypeName":"word"},{"id":29584,"position":3,"arabic":"فِيهَا","translation":"যার মধ্যে","audioUrl":"wbw/044_027_003.mp3","charTypeName":"word"},{"id":29585,"position":4,"arabic":"فَـٰكِهِينَ","translation":"আনন্দকারী (সব ছেড়ে চলে গেলো)","audioUrl":"wbw/044_027_004.mp3","charTypeName":"word"},{"id":29586,"position":5,"arabic":"٢٧","translation":"(২৭)","audioUrl":null,"charTypeName":"end"}]},{"number":28,"arabic":"كَذَٰلِكَ ۖ وَأَوْرَثْنَٰهَا قَوْمًا ءَاخَرِينَ","translation":"Thus it was. And [then] We made another people heirs [to what they had left],","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4442.mp3","surahId":44,"words":[{"id":30612,"position":1,"arabic":"كَذَٰلِكَ ۖ","translation":"এভাবেই (পরিণাম হয়েছিলো)","audioUrl":"wbw/044_028_001.mp3","charTypeName":"word"},{"id":30614,"position":2,"arabic":"وَأَوْرَثْنَـٰهَا","translation":"এবং তার আমরা উত্তরাধিকারী করেছিলাম","audioUrl":"wbw/044_028_003.mp3","charTypeName":"word"},{"id":30615,"position":3,"arabic":"قَوْمًا","translation":"সম্প্রদায়কে","audioUrl":"wbw/044_028_004.mp3","charTypeName":"word"},{"id":30616,"position":4,"arabic":"ءَاخَرِينَ","translation":"অন্য","audioUrl":"wbw/044_028_005.mp3","charTypeName":"word"},{"id":30617,"position":5,"arabic":"٢٨","translation":"(২৮)","audioUrl":null,"charTypeName":"end"}]},{"number":29,"arabic":"فَمَا بَكَتْ عَلَيْهِمُ ٱلسَّمَآءُ وَٱلْأَرْضُ وَمَا كَانُوا۟ مُنظَرِينَ","translation":"and neither sky nor earth shed tears over them, nor were they allowed a respite.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4443.mp3","surahId":44,"words":[{"id":31636,"position":1,"arabic":"فَمَا","translation":"না অতঃপর","audioUrl":"wbw/044_029_001.mp3","charTypeName":"word"},{"id":31637,"position":2,"arabic":"بَكَتْ","translation":"কাঁদলো","audioUrl":"wbw/044_029_002.mp3","charTypeName":"word"},{"id":31638,"position":3,"arabic":"عَلَيْهِمُ","translation":"তাদের উপর","audioUrl":"wbw/044_029_003.mp3","charTypeName":"word"},{"id":31639,"position":4,"arabic":"ٱلسَّمَآءُ","translation":"আকাশ","audioUrl":"wbw/044_029_004.mp3","charTypeName":"word"},{"id":31640,"position":5,"arabic":"وَٱلْأَرْضُ","translation":"আর (না) পৃথিবী","audioUrl":"wbw/044_029_005.mp3","charTypeName":"word"},{"id":31641,"position":6,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/044_029_006.mp3","charTypeName":"word"},{"id":31642,"position":7,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/044_029_007.mp3","charTypeName":"word"},{"id":31643,"position":8,"arabic":"مُنظَرِينَ","translation":"অবকাশপ্রাপ্ত","audioUrl":"wbw/044_029_008.mp3","charTypeName":"word"},{"id":31644,"position":9,"arabic":"٢٩","translation":"(২৯)","audioUrl":null,"charTypeName":"end"}]},{"number":30,"arabic":"وَلَقَدْ نَجَّيْنَا بَنِىٓ إِسْرَٰٓءِيلَ مِنَ ٱلْعَذَابِ ٱلْمُهِينِ","translation":"And, indeed, We delivered the children of Israel from the shameful suffering","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4444.mp3","surahId":44,"words":[{"id":32514,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/044_030_001.mp3","charTypeName":"word"},{"id":32515,"position":2,"arabic":"نَجَّيْنَا","translation":"আমরা উদ্ধার করেছিলাম","audioUrl":"wbw/044_030_002.mp3","charTypeName":"word"},{"id":32516,"position":3,"arabic":"بَنِىٓ","translation":"বনী","audioUrl":"wbw/044_030_003.mp3","charTypeName":"word"},{"id":32517,"position":4,"arabic":"إِسْرَٰٓءِيلَ","translation":"ইসরাঈলকে","audioUrl":"wbw/044_030_004.mp3","charTypeName":"word"},{"id":32518,"position":5,"arabic":"مِنَ","translation":"থেকে","audioUrl":"wbw/044_030_005.mp3","charTypeName":"word"},{"id":32519,"position":6,"arabic":"ٱلْعَذَابِ","translation":"শাস্তি","audioUrl":"wbw/044_030_006.mp3","charTypeName":"word"},{"id":32520,"position":7,"arabic":"ٱلْمُهِينِ","translation":"অপমানজনক","audioUrl":"wbw/044_030_007.mp3","charTypeName":"word"},{"id":32521,"position":8,"arabic":"٣٠","translation":"(৩০)","audioUrl":null,"charTypeName":"end"}]},{"number":31,"arabic":"مِن فِرْعَوْنَ ۚ إِنَّهُۥ كَانَ عَالِيًۭا مِّنَ ٱلْمُسْرِفِينَ","translation":"[inflicted on them] by Pharaoh, seeing that he was truly outstand­ing among those who waste their own selves;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4445.mp3","surahId":44,"words":[{"id":33393,"position":1,"arabic":"مِن","translation":"দেওয়া","audioUrl":"wbw/044_031_001.mp3","charTypeName":"word"},{"id":33394,"position":2,"arabic":"فِرْعَوْنَ ۚ","translation":"ফিরআউনের","audioUrl":"wbw/044_031_002.mp3","charTypeName":"word"},{"id":33396,"position":3,"arabic":"إِنَّهُۥ","translation":"সে নিশ্চয়ই","audioUrl":"wbw/044_031_004.mp3","charTypeName":"word"},{"id":33397,"position":4,"arabic":"كَانَ","translation":"ছিলো","audioUrl":"wbw/044_031_005.mp3","charTypeName":"word"},{"id":33398,"position":5,"arabic":"عَالِيًۭا","translation":"পরাক্রান্ত","audioUrl":"wbw/044_031_006.mp3","charTypeName":"word"},{"id":33399,"position":6,"arabic":"مِّنَ","translation":"মধ্য হতে","audioUrl":"wbw/044_031_007.mp3","charTypeName":"word"},{"id":33400,"position":7,"arabic":"ٱلْمُسْرِفِينَ","translation":"সীমালংঘনকারীদের","audioUrl":"wbw/044_031_008.mp3","charTypeName":"word"},{"id":33401,"position":8,"arabic":"٣١","translation":"(৩১)","audioUrl":null,"charTypeName":"end"}]},{"number":32,"arabic":"وَلَقَدِ ٱخْتَرْنَٰهُمْ عَلَىٰ عِلْمٍ عَلَى ٱلْعَٰلَمِينَ","translation":"and indeed, We chose them knowingly above all other people,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4446.mp3","surahId":44,"words":[{"id":34447,"position":1,"arabic":"وَلَقَدِ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/044_032_001.mp3","charTypeName":"word"},{"id":34448,"position":2,"arabic":"ٱخْتَرْنَـٰهُمْ","translation":"তাদেরকে (বনী ইসরাঈলকে) আমরা মনোনীত করেছিলাম","audioUrl":"wbw/044_032_002.mp3","charTypeName":"word"},{"id":34449,"position":3,"arabic":"عَلَىٰ","translation":"ভিত্তিতে","audioUrl":"wbw/044_032_003.mp3","charTypeName":"word"},{"id":34450,"position":4,"arabic":"عِلْمٍ","translation":"জ্ঞানের","audioUrl":"wbw/044_032_004.mp3","charTypeName":"word"},{"id":34451,"position":5,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/044_032_005.mp3","charTypeName":"word"},{"id":34452,"position":6,"arabic":"ٱلْعَـٰلَمِينَ","translation":"বিশ্ববাসীর (অন্যান্য জাতির)","audioUrl":"wbw/044_032_006.mp3","charTypeName":"word"},{"id":34453,"position":7,"arabic":"٣٢","translation":"(৩২)","audioUrl":null,"charTypeName":"end"}]},{"number":33,"arabic":"وَءَاتَيْنَٰهُم مِّنَ ٱلْءَايَٰتِ مَا فِيهِ بَلَٰٓؤٌۭا۟ مُّبِينٌ","translation":"and gave them such signs [of Our grace] as would clearly presage a test.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4447.mp3","surahId":44,"words":[{"id":35354,"position":1,"arabic":"وَءَاتَيْنَـٰهُم","translation":"এবং তাদেরকে আমরা দিয়েছিলাম","audioUrl":"wbw/044_033_001.mp3","charTypeName":"word"},{"id":35355,"position":2,"arabic":"مِّنَ","translation":"কিছু","audioUrl":"wbw/044_033_002.mp3","charTypeName":"word"},{"id":35356,"position":3,"arabic":"ٱلْـَٔايَـٰتِ","translation":"নিদর্শনাবলী","audioUrl":"wbw/044_033_003.mp3","charTypeName":"word"},{"id":35357,"position":4,"arabic":"مَا","translation":"যার","audioUrl":"wbw/044_033_004.mp3","charTypeName":"word"},{"id":35358,"position":5,"arabic":"فِيهِ","translation":"মধ্যে ছিলো","audioUrl":"wbw/044_033_005.mp3","charTypeName":"word"},{"id":35359,"position":6,"arabic":"بَلَـٰٓؤٌۭا۟","translation":"পরীক্ষা","audioUrl":"wbw/044_033_006.mp3","charTypeName":"word"},{"id":35360,"position":7,"arabic":"مُّبِينٌ","translation":"সুস্পষ্ট","audioUrl":"wbw/044_033_007.mp3","charTypeName":"word"},{"id":35361,"position":8,"arabic":"٣٣","translation":"(৩৩)","audioUrl":null,"charTypeName":"end"}]},{"number":34,"arabic":"إِنَّ هَٰٓؤُلَآءِ لَيَقُولُونَ","translation":"[Now,] behold, these [people] say indeed:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4448.mp3","surahId":44,"words":[{"id":36158,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/044_034_001.mp3","charTypeName":"word"},{"id":36159,"position":2,"arabic":"هَـٰٓؤُلَآءِ","translation":"এসব লোক","audioUrl":"wbw/044_034_002.mp3","charTypeName":"word"},{"id":36160,"position":3,"arabic":"لَيَقُولُونَ","translation":"অবশ্যই বলে","audioUrl":"wbw/044_034_003.mp3","charTypeName":"word"},{"id":36161,"position":4,"arabic":"٣٤","translation":"(৩৪)","audioUrl":null,"charTypeName":"end"}]},{"number":35,"arabic":"إِنْ هِىَ إِلَّا مَوْتَتُنَا ٱلْأُولَىٰ وَمَا نَحْنُ بِمُنشَرِينَ","translation":"“That [which is ahead of us] is but our first [and only] death, and we shall not be raised to life again.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4449.mp3","surahId":44,"words":[{"id":36898,"position":1,"arabic":"إِنْ","translation":"\"নেই","audioUrl":"wbw/044_035_001.mp3","charTypeName":"word"},{"id":36899,"position":2,"arabic":"هِىَ","translation":"তা","audioUrl":"wbw/044_035_002.mp3","charTypeName":"word"},{"id":36900,"position":3,"arabic":"إِلَّا","translation":"এ ব্যতীত","audioUrl":"wbw/044_035_003.mp3","charTypeName":"word"},{"id":36901,"position":4,"arabic":"مَوْتَتُنَا","translation":"আমাদের মৃত্যু","audioUrl":"wbw/044_035_004.mp3","charTypeName":"word"},{"id":36902,"position":5,"arabic":"ٱلْأُولَىٰ","translation":"প্রথম (অর্থাৎ মৃতই শেষ)","audioUrl":"wbw/044_035_005.mp3","charTypeName":"word"},{"id":36903,"position":6,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/044_035_006.mp3","charTypeName":"word"},{"id":36904,"position":7,"arabic":"نَحْنُ","translation":"আমরা","audioUrl":"wbw/044_035_007.mp3","charTypeName":"word"},{"id":36905,"position":8,"arabic":"بِمُنشَرِينَ","translation":"উত্থিত হবো","audioUrl":"wbw/044_035_008.mp3","charTypeName":"word"},{"id":36906,"position":9,"arabic":"٣٥","translation":"(৩৫)","audioUrl":null,"charTypeName":"end"}]},{"number":36,"arabic":"فَأْتُوا۟ بِـَٔابَآئِنَآ إِن كُنتُمْ صَٰدِقِينَ","translation":"So then, bring forth our forefathers [as witnesses], if what you claim is true!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4450.mp3","surahId":44,"words":[{"id":37775,"position":1,"arabic":"فَأْتُوا۟","translation":"তোমরা তবে আসো","audioUrl":"wbw/044_036_001.mp3","charTypeName":"word"},{"id":37776,"position":2,"arabic":"بِـَٔابَآئِنَآ","translation":"নিয়ে আমাদের পিতৃপুরুষদেরকে","audioUrl":"wbw/044_036_002.mp3","charTypeName":"word"},{"id":37777,"position":3,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/044_036_003.mp3","charTypeName":"word"},{"id":37778,"position":4,"arabic":"كُنتُمْ","translation":"তোমরা হও","audioUrl":"wbw/044_036_004.mp3","charTypeName":"word"},{"id":37779,"position":5,"arabic":"صَـٰدِقِينَ","translation":"সত্যবাদী\"","audioUrl":"wbw/044_036_005.mp3","charTypeName":"word"},{"id":37780,"position":6,"arabic":"٣٦","translation":"(৩৬)","audioUrl":null,"charTypeName":"end"}]},{"number":37,"arabic":"أَهُمْ خَيْرٌ أَمْ قَوْمُ تُبَّعٍۢ وَٱلَّذِينَ مِن قَبْلِهِمْ ۚ أَهْلَكْنَٰهُمْ ۖ إِنَّهُمْ كَانُوا۟ مُجْرِمِينَ","translation":"Are they, then, better than the people of Tubba and those before them, whom We destroyed because they were truly lost in [the same] sin?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4451.mp3","surahId":44,"words":[{"id":39025,"position":1,"arabic":"أَهُمْ","translation":"(তাদেরকে বলো) তারা কি","audioUrl":"wbw/044_037_001.mp3","charTypeName":"word"},{"id":39026,"position":2,"arabic":"خَيْرٌ","translation":"উত্তম","audioUrl":"wbw/044_037_002.mp3","charTypeName":"word"},{"id":39027,"position":3,"arabic":"أَمْ","translation":"অথবা","audioUrl":"wbw/044_037_003.mp3","charTypeName":"word"},{"id":39028,"position":4,"arabic":"قَوْمُ","translation":"জাতি","audioUrl":"wbw/044_037_004.mp3","charTypeName":"word"},{"id":39029,"position":5,"arabic":"تُبَّعٍۢ","translation":"তুব্বার","audioUrl":"wbw/044_037_005.mp3","charTypeName":"word"},{"id":39030,"position":6,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা (ছিলো)","audioUrl":"wbw/044_037_006.mp3","charTypeName":"word"},{"id":39031,"position":7,"arabic":"مِن","translation":"মধ্য হতে","audioUrl":"wbw/044_037_007.mp3","charTypeName":"word"},{"id":39032,"position":8,"arabic":"قَبْلِهِمْ ۚ","translation":"তাদের পূর্বে","audioUrl":"wbw/044_037_008.mp3","charTypeName":"word"},{"id":39034,"position":9,"arabic":"أَهْلَكْنَـٰهُمْ ۖ","translation":"তাদেরকে আমরা ধ্বংস করেছি","audioUrl":"wbw/044_037_010.mp3","charTypeName":"word"},{"id":39036,"position":10,"arabic":"إِنَّهُمْ","translation":"তারা নিশ্চয়ই","audioUrl":"wbw/044_037_012.mp3","charTypeName":"word"},{"id":39037,"position":11,"arabic":"كَانُوا۟","translation":"ছিলো","audioUrl":"wbw/044_037_013.mp3","charTypeName":"word"},{"id":39038,"position":12,"arabic":"مُجْرِمِينَ","translation":"অপরাধী","audioUrl":"wbw/044_037_014.mp3","charTypeName":"word"},{"id":39039,"position":13,"arabic":"٣٧","translation":"(৩৭)","audioUrl":null,"charTypeName":"end"}]},{"number":38,"arabic":"وَمَا خَلَقْنَا ٱلسَّمَٰوَٰتِ وَٱلْأَرْضَ وَمَا بَيْنَهُمَا لَٰعِبِينَ","translation":"For [thus it is:] We have not created the heavens and the earth and all that is between them in mere idle play:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4452.mp3","surahId":44,"words":[{"id":39586,"position":1,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/044_038_001.mp3","charTypeName":"word"},{"id":39587,"position":2,"arabic":"خَلَقْنَا","translation":"আমরা সৃষ্টি করেছি","audioUrl":"wbw/044_038_002.mp3","charTypeName":"word"},{"id":39588,"position":3,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশকে","audioUrl":"wbw/044_038_003.mp3","charTypeName":"word"},{"id":39589,"position":4,"arabic":"وَٱلْأَرْضَ","translation":"ও পৃথিবীকে","audioUrl":"wbw/044_038_004.mp3","charTypeName":"word"},{"id":39590,"position":5,"arabic":"وَمَا","translation":"এবং যা কিছু","audioUrl":"wbw/044_038_005.mp3","charTypeName":"word"},{"id":39591,"position":6,"arabic":"بَيْنَهُمَا","translation":"উভয়ের মাঝে আছে","audioUrl":"wbw/044_038_006.mp3","charTypeName":"word"},{"id":39592,"position":7,"arabic":"لَـٰعِبِينَ","translation":"খেলাচ্ছলে","audioUrl":"wbw/044_038_007.mp3","charTypeName":"word"},{"id":39593,"position":8,"arabic":"٣٨","translation":"(৩৮)","audioUrl":null,"charTypeName":"end"}]},{"number":39,"arabic":"مَا خَلَقْنَٰهُمَآ إِلَّا بِٱلْحَقِّ وَلَٰكِنَّ أَكْثَرَهُمْ لَا يَعْلَمُونَ","translation":"none of this have We created without [an inner] truth: but most of them under­stand it not.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4453.mp3","surahId":44,"words":[{"id":40430,"position":1,"arabic":"مَا","translation":"না","audioUrl":"wbw/044_039_001.mp3","charTypeName":"word"},{"id":40431,"position":2,"arabic":"خَلَقْنَـٰهُمَآ","translation":"উভয়কে আমরা সৃষ্টি করেছি","audioUrl":"wbw/044_039_002.mp3","charTypeName":"word"},{"id":40432,"position":3,"arabic":"إِلَّا","translation":"এ ব্যতীত","audioUrl":"wbw/044_039_003.mp3","charTypeName":"word"},{"id":40433,"position":4,"arabic":"بِٱلْحَقِّ","translation":"সত্যসহ","audioUrl":"wbw/044_039_004.mp3","charTypeName":"word"},{"id":40434,"position":5,"arabic":"وَلَـٰكِنَّ","translation":"কিন্তু","audioUrl":"wbw/044_039_005.mp3","charTypeName":"word"},{"id":40435,"position":6,"arabic":"أَكْثَرَهُمْ","translation":"তাদের অধিকাংশই","audioUrl":"wbw/044_039_006.mp3","charTypeName":"word"},{"id":40436,"position":7,"arabic":"لَا","translation":"না","audioUrl":"wbw/044_039_007.mp3","charTypeName":"word"},{"id":40437,"position":8,"arabic":"يَعْلَمُونَ","translation":"জানে","audioUrl":"wbw/044_039_008.mp3","charTypeName":"word"},{"id":40438,"position":9,"arabic":"٣٩","translation":"(৩৯)","audioUrl":null,"charTypeName":"end"}]}]}