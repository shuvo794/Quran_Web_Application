{"id":363,"ayahs":[{"number":33,"arabic":"وَلَا يَأْتُونَكَ بِمَثَلٍ إِلَّا جِئْنَٰكَ بِٱلْحَقِّ وَأَحْسَنَ تَفْسِيرًا","translation":"and [that] they [who deny the truth] might never taunt thee with any deceptive half-truth without Our conveying to thee the [full] truth and [providing thee] with the best explanation.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2888.mp3","surahId":25,"words":[{"id":35594,"position":1,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/025_033_001.mp3","charTypeName":"word"},{"id":35595,"position":2,"arabic":"يَأْتُونَكَ","translation":"তোমার (কাছে) তারা আসে","audioUrl":"wbw/025_033_002.mp3","charTypeName":"word"},{"id":35596,"position":3,"arabic":"بِمَثَلٍ","translation":"নিয়ে কোন সমস্যাকে","audioUrl":"wbw/025_033_003.mp3","charTypeName":"word"},{"id":35597,"position":4,"arabic":"إِلَّا","translation":"এ ছাড়া যে","audioUrl":"wbw/025_033_004.mp3","charTypeName":"word"},{"id":35598,"position":5,"arabic":"جِئْنَـٰكَ","translation":"তোমার কাছে আসি আমরা","audioUrl":"wbw/025_033_005.mp3","charTypeName":"word"},{"id":35599,"position":6,"arabic":"بِٱلْحَقِّ","translation":"ভাবে সঠিক (সমাধান)","audioUrl":"wbw/025_033_006.mp3","charTypeName":"word"},{"id":35600,"position":7,"arabic":"وَأَحْسَنَ","translation":"ও অতি উত্তম","audioUrl":"wbw/025_033_007.mp3","charTypeName":"word"},{"id":35601,"position":8,"arabic":"تَفْسِيرًا","translation":"ব্যাখ্যা (প্রদান করি)","audioUrl":"wbw/025_033_008.mp3","charTypeName":"word"},{"id":35602,"position":9,"arabic":"٣٣","translation":"(৩৩)","audioUrl":null,"charTypeName":"end"}]},{"number":34,"arabic":"ٱلَّذِينَ يُحْشَرُونَ عَلَىٰ وُجُوهِهِمْ إِلَىٰ جَهَنَّمَ أُو۟لَٰٓئِكَ شَرٌّۭ مَّكَانًۭا وَأَضَلُّ سَبِيلًۭا","translation":"[And so, tell those who are bent on denying the truth that] they who shall be gathered unto hell upon their faces – it is they who [in the life to come] will be worst in station and still farther astray from the path [of truth]!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2889.mp3","surahId":25,"words":[{"id":36415,"position":1,"arabic":"ٱلَّذِينَ","translation":"যাদেরকে","audioUrl":"wbw/025_034_001.mp3","charTypeName":"word"},{"id":36416,"position":2,"arabic":"يُحْشَرُونَ","translation":"একত্র করা হবে","audioUrl":"wbw/025_034_002.mp3","charTypeName":"word"},{"id":36417,"position":3,"arabic":"عَلَىٰ","translation":"উপর (ভর করে)","audioUrl":"wbw/025_034_003.mp3","charTypeName":"word"},{"id":36418,"position":4,"arabic":"وُجُوهِهِمْ","translation":"মুখমণ্ডলের তাদের","audioUrl":"wbw/025_034_004.mp3","charTypeName":"word"},{"id":36419,"position":5,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/025_034_005.mp3","charTypeName":"word"},{"id":36420,"position":6,"arabic":"جَهَنَّمَ","translation":"জাহান্নামের","audioUrl":"wbw/025_034_006.mp3","charTypeName":"word"},{"id":36421,"position":7,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐসব লোকের  (জন্যে হবে)","audioUrl":"wbw/025_034_007.mp3","charTypeName":"word"},{"id":36422,"position":8,"arabic":"شَرٌّۭ","translation":"নিকৃষ্ট","audioUrl":"wbw/025_034_008.mp3","charTypeName":"word"},{"id":36423,"position":9,"arabic":"مَّكَانًۭا","translation":"অবস্থান","audioUrl":"wbw/025_034_009.mp3","charTypeName":"word"},{"id":36424,"position":10,"arabic":"وَأَضَلُّ","translation":"ও চূড়ান্তভাবে ভ্রষ্ট হয়েছে","audioUrl":"wbw/025_034_010.mp3","charTypeName":"word"},{"id":36425,"position":11,"arabic":"سَبِيلًۭا","translation":"পথ","audioUrl":"wbw/025_034_011.mp3","charTypeName":"word"},{"id":36426,"position":12,"arabic":"٣٤","translation":"(৩৪)","audioUrl":null,"charTypeName":"end"}]},{"number":35,"arabic":"وَلَقَدْ ءَاتَيْنَا مُوسَى ٱلْكِتَٰبَ وَجَعَلْنَا مَعَهُۥٓ أَخَاهُ هَٰرُونَ وَزِيرًۭا","translation":"AND, INDEED, [long before Muhammad] We vouchsafed revelation unto Moses, and appointed his brother Aaron to help him to bear his burden;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2890.mp3","surahId":25,"words":[{"id":37378,"position":1,"arabic":"وَلَقَدْ","translation":"এবং  নিশ্চয়ই","audioUrl":"wbw/025_035_001.mp3","charTypeName":"word"},{"id":37379,"position":2,"arabic":"ءَاتَيْنَا","translation":"আমরা দিয়েছিলাম","audioUrl":"wbw/025_035_002.mp3","charTypeName":"word"},{"id":37380,"position":3,"arabic":"مُوسَى","translation":"মূসাকে","audioUrl":"wbw/025_035_003.mp3","charTypeName":"word"},{"id":37381,"position":4,"arabic":"ٱلْكِتَـٰبَ","translation":"কিতাব","audioUrl":"wbw/025_035_004.mp3","charTypeName":"word"},{"id":37382,"position":5,"arabic":"وَجَعَلْنَا","translation":"ও আমরা করেছিলাম","audioUrl":"wbw/025_035_005.mp3","charTypeName":"word"},{"id":37383,"position":6,"arabic":"مَعَهُۥٓ","translation":"তার সাথে","audioUrl":"wbw/025_035_006.mp3","charTypeName":"word"},{"id":37384,"position":7,"arabic":"أَخَاهُ","translation":"তার ভাই","audioUrl":"wbw/025_035_007.mp3","charTypeName":"word"},{"id":37385,"position":8,"arabic":"هَـٰرُونَ","translation":"হারুনকে","audioUrl":"wbw/025_035_008.mp3","charTypeName":"word"},{"id":37386,"position":9,"arabic":"وَزِيرًۭا","translation":"সাহায্যকারী","audioUrl":"wbw/025_035_009.mp3","charTypeName":"word"},{"id":37387,"position":10,"arabic":"٣٥","translation":"(৩৫)","audioUrl":null,"charTypeName":"end"}]},{"number":36,"arabic":"فَقُلْنَا ٱذْهَبَآ إِلَى ٱلْقَوْمِ ٱلَّذِينَ كَذَّبُوا۟ بِـَٔايَٰتِنَا فَدَمَّرْنَٰهُمْ تَدْمِيرًۭا","translation":"and We said, “Go you both unto the people who have given the lie to Our messages!” - and thereupon We broke those [sinners] to smithereens.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2891.mp3","surahId":25,"words":[{"id":38161,"position":1,"arabic":"فَقُلْنَا","translation":"অতঃপর আমরা বলেছিলাম","audioUrl":"wbw/025_036_001.mp3","charTypeName":"word"},{"id":38162,"position":2,"arabic":"ٱذْهَبَآ","translation":"\"দু'জনে যাও","audioUrl":"wbw/025_036_002.mp3","charTypeName":"word"},{"id":38163,"position":3,"arabic":"إِلَى","translation":"প্রতি","audioUrl":"wbw/025_036_003.mp3","charTypeName":"word"},{"id":38164,"position":4,"arabic":"ٱلْقَوْمِ","translation":"(সে জাতির) লোকদের","audioUrl":"wbw/025_036_004.mp3","charTypeName":"word"},{"id":38165,"position":5,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/025_036_005.mp3","charTypeName":"word"},{"id":38166,"position":6,"arabic":"كَذَّبُوا۟","translation":"মিথ্যারোপ করেছে","audioUrl":"wbw/025_036_006.mp3","charTypeName":"word"},{"id":38167,"position":7,"arabic":"بِـَٔايَـٰتِنَا","translation":"প্রতি আমার নির্দেশনাবলীর\"","audioUrl":"wbw/025_036_007.mp3","charTypeName":"word"},{"id":38168,"position":8,"arabic":"فَدَمَّرْنَـٰهُمْ","translation":"ফলে আমরা ধ্বংস করে দিয়েছি তাদেরকে","audioUrl":"wbw/025_036_008.mp3","charTypeName":"word"},{"id":38169,"position":9,"arabic":"تَدْمِيرًۭا","translation":"ধ্বংস (সম্পূর্ণ রূপে)","audioUrl":"wbw/025_036_009.mp3","charTypeName":"word"},{"id":38170,"position":10,"arabic":"٣٦","translation":"(৩৬)","audioUrl":null,"charTypeName":"end"}]},{"number":37,"arabic":"وَقَوْمَ نُوحٍۢ لَّمَّا كَذَّبُوا۟ ٱلرُّسُلَ أَغْرَقْنَٰهُمْ وَجَعَلْنَٰهُمْ لِلنَّاسِ ءَايَةًۭ ۖ وَأَعْتَدْنَا لِلظَّٰلِمِينَ عَذَابًا أَلِيمًۭا","translation":"And [think of] the people of Noah: when they gave the lie to [one of] the apostles, We caused them to drown, and made them a symbol for all mankind: for, grievous suffering have We readied for all who [knowingly] do wrong!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2892.mp3","surahId":25,"words":[{"id":38776,"position":1,"arabic":"وَقَوْمَ","translation":"এবং জাতি","audioUrl":"wbw/025_037_001.mp3","charTypeName":"word"},{"id":38777,"position":2,"arabic":"نُوحٍۢ","translation":"নূহের","audioUrl":"wbw/025_037_002.mp3","charTypeName":"word"},{"id":38778,"position":3,"arabic":"لَّمَّا","translation":"যখন","audioUrl":"wbw/025_037_003.mp3","charTypeName":"word"},{"id":38779,"position":4,"arabic":"كَذَّبُوا۟","translation":"মিথ্যারোপ করেছিলো","audioUrl":"wbw/025_037_004.mp3","charTypeName":"word"},{"id":38780,"position":5,"arabic":"ٱلرُّسُلَ","translation":"রাসুলদেরকে","audioUrl":"wbw/025_037_005.mp3","charTypeName":"word"},{"id":38781,"position":6,"arabic":"أَغْرَقْنَـٰهُمْ","translation":"আমরা ডুবিয়ে দিয়েছি তাদেরকে","audioUrl":"wbw/025_037_006.mp3","charTypeName":"word"},{"id":38782,"position":7,"arabic":"وَجَعَلْنَـٰهُمْ","translation":"এবং আমরা করেছিলাম তাদেরকে","audioUrl":"wbw/025_037_007.mp3","charTypeName":"word"},{"id":38783,"position":8,"arabic":"لِلنَّاسِ","translation":"জন্যে মানুষের","audioUrl":"wbw/025_037_008.mp3","charTypeName":"word"},{"id":38784,"position":9,"arabic":"ءَايَةًۭ ۖ","translation":"নিদর্শন","audioUrl":"wbw/025_037_009.mp3","charTypeName":"word"},{"id":38786,"position":10,"arabic":"وَأَعْتَدْنَا","translation":"আর আমরা প্রস্তুত করে রেখেছি","audioUrl":"wbw/025_037_011.mp3","charTypeName":"word"},{"id":38787,"position":11,"arabic":"لِلظَّـٰلِمِينَ","translation":"জন্যে সীমালঙ্ঘনকারীদের","audioUrl":"wbw/025_037_012.mp3","charTypeName":"word"},{"id":38788,"position":12,"arabic":"عَذَابًا","translation":"শাস্তি","audioUrl":"wbw/025_037_013.mp3","charTypeName":"word"},{"id":38789,"position":13,"arabic":"أَلِيمًۭا","translation":"নিদারুণ","audioUrl":"wbw/025_037_014.mp3","charTypeName":"word"},{"id":38790,"position":14,"arabic":"٣٧","translation":"(৩৭)","audioUrl":null,"charTypeName":"end"}]},{"number":38,"arabic":"وَعَادًۭا وَثَمُودَا۟ وَأَصْحَٰبَ ٱلرَّسِّ وَقُرُونًۢا بَيْنَ ذَٰلِكَ كَثِيرًۭا","translation":"And [remember how We punished the tribes of] Ad and Thamud and the people of Ar-Rass, and many generations [of sinners] in-between:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2893.mp3","surahId":25,"words":[{"id":39808,"position":1,"arabic":"وَعَادًۭا","translation":"এবং (ধ্বংস করেছি) আদ","audioUrl":"wbw/025_038_001.mp3","charTypeName":"word"},{"id":39809,"position":2,"arabic":"وَثَمُودَا۟","translation":"ও সামূদ","audioUrl":"wbw/025_038_002.mp3","charTypeName":"word"},{"id":39810,"position":3,"arabic":"وَأَصْحَـٰبَ","translation":"ও অধিবাসী","audioUrl":"wbw/025_038_003.mp3","charTypeName":"word"},{"id":39811,"position":4,"arabic":"ٱلرَّسِّ","translation":"রাস্‌","audioUrl":"wbw/025_038_004.mp3","charTypeName":"word"},{"id":39812,"position":5,"arabic":"وَقُرُونًۢا","translation":"এবং শতাব্দীসমূহে","audioUrl":"wbw/025_038_005.mp3","charTypeName":"word"},{"id":39813,"position":6,"arabic":"بَيْنَ","translation":"মাঝের","audioUrl":"wbw/025_038_006.mp3","charTypeName":"word"},{"id":39814,"position":7,"arabic":"ذَٰلِكَ","translation":"এদের","audioUrl":"wbw/025_038_007.mp3","charTypeName":"word"},{"id":39815,"position":8,"arabic":"كَثِيرًۭا","translation":"অনেক (লোক)","audioUrl":"wbw/025_038_008.mp3","charTypeName":"word"},{"id":39816,"position":9,"arabic":"٣٨","translation":"(৩৮)","audioUrl":null,"charTypeName":"end"}]},{"number":39,"arabic":"وَكُلًّۭا ضَرَبْنَا لَهُ ٱلْأَمْثَٰلَ ۖ وَكُلًّۭا تَبَّرْنَا تَتْبِيرًۭا","translation":"and unto each of them did We proffer lessons and each of them did We destroy with utter destruction.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2894.mp3","surahId":25,"words":[{"id":40667,"position":1,"arabic":"وَكُلًّۭا","translation":"এবং প্রত্যেক (জাতিকে)","audioUrl":"wbw/025_039_001.mp3","charTypeName":"word"},{"id":40668,"position":2,"arabic":"ضَرَبْنَا","translation":"আমরা বর্ণনা দিয়েছি","audioUrl":"wbw/025_039_002.mp3","charTypeName":"word"},{"id":40669,"position":3,"arabic":"لَهُ","translation":"জন্যে তার","audioUrl":"wbw/025_039_003.mp3","charTypeName":"word"},{"id":40670,"position":4,"arabic":"ٱلْأَمْثَـٰلَ ۖ","translation":"দৃষ্টান্তসমূহ (পুর্বের)","audioUrl":"wbw/025_039_004.mp3","charTypeName":"word"},{"id":40672,"position":5,"arabic":"وَكُلًّۭا","translation":"এবং প্রত্যেককে","audioUrl":"wbw/025_039_006.mp3","charTypeName":"word"},{"id":40673,"position":6,"arabic":"تَبَّرْنَا","translation":"আমরা ধ্বংস করেছি","audioUrl":"wbw/025_039_007.mp3","charTypeName":"word"},{"id":40674,"position":7,"arabic":"تَتْبِيرًۭا","translation":"ধ্বংস (সম্পূর্ণরূপে)","audioUrl":"wbw/025_039_008.mp3","charTypeName":"word"},{"id":40675,"position":8,"arabic":"٣٩","translation":"(৩৯)","audioUrl":null,"charTypeName":"end"}]},{"number":40,"arabic":"وَلَقَدْ أَتَوْا۟ عَلَى ٱلْقَرْيَةِ ٱلَّتِىٓ أُمْطِرَتْ مَطَرَ ٱلسَّوْءِ ۚ أَفَلَمْ يَكُونُوا۟ يَرَوْنَهَا ۚ بَلْ كَانُوا۟ لَا يَرْجُونَ نُشُورًۭا","translation":"And they [who now deny Our messages] must surely have come across that town which was rained upon by a rain of evil: have they, then, never beheld it [with their minds eye]? But nay, they would not believe in resurrection!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2895.mp3","surahId":25,"words":[{"id":41297,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/025_040_001.mp3","charTypeName":"word"},{"id":41298,"position":2,"arabic":"أَتَوْا۟","translation":"তারা আসা যাওয়া করে","audioUrl":"wbw/025_040_002.mp3","charTypeName":"word"},{"id":41299,"position":3,"arabic":"عَلَى","translation":"উপর (দিয়ে)","audioUrl":"wbw/025_040_003.mp3","charTypeName":"word"},{"id":41300,"position":4,"arabic":"ٱلْقَرْيَةِ","translation":"(সেই) জনপদের","audioUrl":"wbw/025_040_004.mp3","charTypeName":"word"},{"id":41301,"position":5,"arabic":"ٱلَّتِىٓ","translation":"যার (উপর)","audioUrl":"wbw/025_040_005.mp3","charTypeName":"word"},{"id":41302,"position":6,"arabic":"أُمْطِرَتْ","translation":"বৃষ্টি বর্ষিত হয়েছিল","audioUrl":"wbw/025_040_006.mp3","charTypeName":"word"},{"id":41303,"position":7,"arabic":"مَطَرَ","translation":"বৃষ্টি","audioUrl":"wbw/025_040_007.mp3","charTypeName":"word"},{"id":41304,"position":8,"arabic":"ٱلسَّوْءِ ۚ","translation":"নিকৃষ্ট রকমের","audioUrl":"wbw/025_040_008.mp3","charTypeName":"word"},{"id":41306,"position":9,"arabic":"أَفَلَمْ","translation":"কি তবে না","audioUrl":"wbw/025_040_010.mp3","charTypeName":"word"},{"id":41307,"position":10,"arabic":"يَكُونُوا۟","translation":"তারা থাকে","audioUrl":"wbw/025_040_011.mp3","charTypeName":"word"},{"id":41308,"position":11,"arabic":"يَرَوْنَهَا ۚ","translation":"তা তারা দেখে","audioUrl":"wbw/025_040_012.mp3","charTypeName":"word"},{"id":41310,"position":12,"arabic":"بَلْ","translation":"বরং","audioUrl":"wbw/025_040_014.mp3","charTypeName":"word"},{"id":41311,"position":13,"arabic":"كَانُوا۟","translation":"তারা হলো (এমন যে)","audioUrl":"wbw/025_040_015.mp3","charTypeName":"word"},{"id":41312,"position":14,"arabic":"لَا","translation":"না","audioUrl":"wbw/025_040_016.mp3","charTypeName":"word"},{"id":41313,"position":15,"arabic":"يَرْجُونَ","translation":"তারা আশা করে","audioUrl":"wbw/025_040_017.mp3","charTypeName":"word"},{"id":41314,"position":16,"arabic":"نُشُورًۭا","translation":"উত্থানের","audioUrl":"wbw/025_040_018.mp3","charTypeName":"word"},{"id":41315,"position":17,"arabic":"٤٠","translation":"(৪০)","audioUrl":null,"charTypeName":"end"}]},{"number":41,"arabic":"وَإِذَا رَأَوْكَ إِن يَتَّخِذُونَكَ إِلَّا هُزُوًا أَهَٰذَا ٱلَّذِى بَعَثَ ٱللَّهُ رَسُولًا","translation":"Hence, whenever they consider thee, [O Muhammad,] they but make thee a target of their mockery, [saying:] “Is this the one whom God has sent as an apostle?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2896.mp3","surahId":25,"words":[{"id":42167,"position":1,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/025_041_001.mp3","charTypeName":"word"},{"id":42168,"position":2,"arabic":"رَأَوْكَ","translation":"তোমাকে তারা দেখে","audioUrl":"wbw/025_041_002.mp3","charTypeName":"word"},{"id":42169,"position":3,"arabic":"إِن","translation":"না","audioUrl":"wbw/025_041_003.mp3","charTypeName":"word"},{"id":42170,"position":4,"arabic":"يَتَّخِذُونَكَ","translation":"তোমাকে তারা গ্রহণ করে","audioUrl":"wbw/025_041_004.mp3","charTypeName":"word"},{"id":42171,"position":5,"arabic":"إِلَّا","translation":"এ ছাড়া যে","audioUrl":"wbw/025_041_005.mp3","charTypeName":"word"},{"id":42172,"position":6,"arabic":"هُزُوًا","translation":"বিদ্রূপের পাত্ররূপে","audioUrl":"wbw/025_041_006.mp3","charTypeName":"word"},{"id":42173,"position":7,"arabic":"أَهَـٰذَا","translation":"\"(তারা বলে) কি এই","audioUrl":"wbw/025_041_007.mp3","charTypeName":"word"},{"id":42174,"position":8,"arabic":"ٱلَّذِى","translation":"যাকে","audioUrl":"wbw/025_041_008.mp3","charTypeName":"word"},{"id":42175,"position":9,"arabic":"بَعَثَ","translation":"পাঠিয়েছেন","audioUrl":"wbw/025_041_009.mp3","charTypeName":"word"},{"id":42176,"position":10,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/025_041_010.mp3","charTypeName":"word"},{"id":42177,"position":11,"arabic":"رَسُولًا","translation":"রাসূলরূপে","audioUrl":"wbw/025_041_011.mp3","charTypeName":"word"},{"id":42178,"position":12,"arabic":"٤١","translation":"(৪১)","audioUrl":null,"charTypeName":"end"}]},{"number":42,"arabic":"إِن كَادَ لَيُضِلُّنَا عَنْ ءَالِهَتِنَا لَوْلَآ أَن صَبَرْنَا عَلَيْهَا ۚ وَسَوْفَ يَعْلَمُونَ حِينَ يَرَوْنَ ٱلْعَذَابَ مَنْ أَضَلُّ سَبِيلًا","translation":"Indeed, he would well-nigh have led us astray from our deities, had we not been [so] steadfastly attached to them!” But in time, when they see the suffering [that awaits them], they will come to know who it was that went farthest astray from the path [of truth]!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2897.mp3","surahId":25,"words":[{"id":42985,"position":1,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/025_042_001.mp3","charTypeName":"word"},{"id":42986,"position":2,"arabic":"كَادَ","translation":"উপক্রম হয়েছিলো","audioUrl":"wbw/025_042_002.mp3","charTypeName":"word"},{"id":42987,"position":3,"arabic":"لَيُضِلُّنَا","translation":"অবশ্যই আমাদেরকে ভ্রষ্ট করে দিতো","audioUrl":"wbw/025_042_003.mp3","charTypeName":"word"},{"id":42988,"position":4,"arabic":"عَنْ","translation":"হ'তে","audioUrl":"wbw/025_042_004.mp3","charTypeName":"word"},{"id":42989,"position":5,"arabic":"ءَالِهَتِنَا","translation":"আমাদের দেবতাগুলো","audioUrl":"wbw/025_042_005.mp3","charTypeName":"word"},{"id":42990,"position":6,"arabic":"لَوْلَآ","translation":"যদি না","audioUrl":"wbw/025_042_006.mp3","charTypeName":"word"},{"id":42991,"position":7,"arabic":"أَن","translation":"যে","audioUrl":"wbw/025_042_007.mp3","charTypeName":"word"},{"id":42992,"position":8,"arabic":"صَبَرْنَا","translation":"আমরা ধৈর্য ধরতাম","audioUrl":"wbw/025_042_008.mp3","charTypeName":"word"},{"id":42993,"position":9,"arabic":"عَلَيْهَا ۚ","translation":"তাদের উপর\"","audioUrl":"wbw/025_042_009.mp3","charTypeName":"word"},{"id":42995,"position":10,"arabic":"وَسَوْفَ","translation":"আর শীঘ্রই","audioUrl":"wbw/025_042_011.mp3","charTypeName":"word"},{"id":42996,"position":11,"arabic":"يَعْلَمُونَ","translation":"তারা জানতে পারবে","audioUrl":"wbw/025_042_012.mp3","charTypeName":"word"},{"id":42997,"position":12,"arabic":"حِينَ","translation":"যখন","audioUrl":"wbw/025_042_013.mp3","charTypeName":"word"},{"id":42998,"position":13,"arabic":"يَرَوْنَ","translation":"তারা দেখবে","audioUrl":"wbw/025_042_014.mp3","charTypeName":"word"},{"id":42999,"position":14,"arabic":"ٱلْعَذَابَ","translation":"শাস্তি","audioUrl":"wbw/025_042_015.mp3","charTypeName":"word"},{"id":43000,"position":15,"arabic":"مَنْ","translation":"কে","audioUrl":"wbw/025_042_016.mp3","charTypeName":"word"},{"id":43001,"position":16,"arabic":"أَضَلُّ","translation":"চূড়ান্তরূপে ভ্রষ্ট হয়েছে","audioUrl":"wbw/025_042_017.mp3","charTypeName":"word"},{"id":43002,"position":17,"arabic":"سَبِيلًا","translation":"পথ","audioUrl":"wbw/025_042_018.mp3","charTypeName":"word"},{"id":43003,"position":18,"arabic":"٤٢","translation":"(৪২)","audioUrl":null,"charTypeName":"end"}]},{"number":43,"arabic":"أَرَءَيْتَ مَنِ ٱتَّخَذَ إِلَٰهَهُۥ هَوَىٰهُ أَفَأَنتَ تَكُونُ عَلَيْهِ وَكِيلًا","translation":"Hast thou ever considered [the kind of man] who makes his own desires his deity? Couldst thou, then, [O Prophet,] be held responsible for him?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2898.mp3","surahId":25,"words":[{"id":43678,"position":1,"arabic":"أَرَءَيْتَ","translation":"কি তুমি (ভেবে) দেখেছো","audioUrl":"wbw/025_043_001.mp3","charTypeName":"word"},{"id":43679,"position":2,"arabic":"مَنِ","translation":"যে","audioUrl":"wbw/025_043_002.mp3","charTypeName":"word"},{"id":43680,"position":3,"arabic":"ٱتَّخَذَ","translation":"গ্রহণ করেছে","audioUrl":"wbw/025_043_003.mp3","charTypeName":"word"},{"id":43681,"position":4,"arabic":"إِلَـٰهَهُۥ","translation":"উপাস্যরূপে","audioUrl":"wbw/025_043_004.mp3","charTypeName":"word"},{"id":43682,"position":5,"arabic":"هَوَىٰهُ","translation":"তার বাসনা লালসাকে","audioUrl":"wbw/025_043_005.mp3","charTypeName":"word"},{"id":43683,"position":6,"arabic":"أَفَأَنتَ","translation":"কি তবে তুমি","audioUrl":"wbw/025_043_006.mp3","charTypeName":"word"},{"id":43684,"position":7,"arabic":"تَكُونُ","translation":"তুমি হবে","audioUrl":"wbw/025_043_007.mp3","charTypeName":"word"},{"id":43685,"position":8,"arabic":"عَلَيْهِ","translation":"তার উপর","audioUrl":"wbw/025_043_008.mp3","charTypeName":"word"},{"id":43686,"position":9,"arabic":"وَكِيلًا","translation":"কর্মবিধায়ক","audioUrl":"wbw/025_043_009.mp3","charTypeName":"word"},{"id":43687,"position":10,"arabic":"٤٣","translation":"(৪৩)","audioUrl":null,"charTypeName":"end"}]}]}