{"id":469,"ayahs":[{"number":17,"arabic":"ٱلْيَوْمَ تُجْزَىٰ كُلُّ نَفْسٍۭ بِمَا كَسَبَتْ ۚ لَا ظُلْمَ ٱلْيَوْمَ ۚ إِنَّ ٱللَّهَ سَرِيعُ ٱلْحِسَابِ","translation":"On that Day will every human being be requited for what he has earned: no wrong [will be done] on that Day: verily, swift in reckoning is God!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4150.mp3","surahId":40,"words":[{"id":19002,"position":1,"arabic":"ٱلْيَوْمَ","translation":"(বলা হবে) আজ","audioUrl":"wbw/040_017_001.mp3","charTypeName":"word"},{"id":19003,"position":2,"arabic":"تُجْزَىٰ","translation":"প্রতিফল দেওয়া হবে","audioUrl":"wbw/040_017_002.mp3","charTypeName":"word"},{"id":19004,"position":3,"arabic":"كُلُّ","translation":"প্রত্যেক","audioUrl":"wbw/040_017_003.mp3","charTypeName":"word"},{"id":19005,"position":4,"arabic":"نَفْسٍۭ","translation":"ব্যক্তিকে","audioUrl":"wbw/040_017_004.mp3","charTypeName":"word"},{"id":19006,"position":5,"arabic":"بِمَا","translation":"ঐ বিষয়ের যা","audioUrl":"wbw/040_017_005.mp3","charTypeName":"word"},{"id":19007,"position":6,"arabic":"كَسَبَتْ ۚ","translation":"সে কামাই করেছে","audioUrl":"wbw/040_017_006.mp3","charTypeName":"word"},{"id":19009,"position":7,"arabic":"لَا","translation":"নেই","audioUrl":"wbw/040_017_008.mp3","charTypeName":"word"},{"id":19010,"position":8,"arabic":"ظُلْمَ","translation":"অত্যাচার","audioUrl":"wbw/040_017_009.mp3","charTypeName":"word"},{"id":19011,"position":9,"arabic":"ٱلْيَوْمَ ۚ","translation":"আজ","audioUrl":"wbw/040_017_010.mp3","charTypeName":"word"},{"id":19013,"position":10,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/040_017_012.mp3","charTypeName":"word"},{"id":19014,"position":11,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/040_017_013.mp3","charTypeName":"word"},{"id":19015,"position":12,"arabic":"سَرِيعُ","translation":"তৎপর","audioUrl":"wbw/040_017_014.mp3","charTypeName":"word"},{"id":19016,"position":13,"arabic":"ٱلْحِسَابِ","translation":"হিসাব গ্রহণে","audioUrl":"wbw/040_017_015.mp3","charTypeName":"word"},{"id":19017,"position":14,"arabic":"١٧","translation":"(১৭)","audioUrl":null,"charTypeName":"end"}]},{"number":18,"arabic":"وَأَنذِرْهُمْ يَوْمَ ٱلْءَازِفَةِ إِذِ ٱلْقُلُوبُ لَدَى ٱلْحَنَاجِرِ كَٰظِمِينَ ۚ مَا لِلظَّٰلِمِينَ مِنْ حَمِيمٍۢ وَلَا شَفِيعٍۢ يُطَاعُ","translation":"Hence, warn them of that Day which draws ever nearer, when the hearts will chokingly come up to the throats: no loving friend will the evildoers have, nor any intercessor who would be heeded:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4151.mp3","surahId":40,"words":[{"id":20121,"position":1,"arabic":"وَأَنذِرْهُمْ","translation":"এবং (হে নাবী) তাদেরকে সতর্ক করো","audioUrl":"wbw/040_018_001.mp3","charTypeName":"word"},{"id":20122,"position":2,"arabic":"يَوْمَ","translation":"সেই দিন (সম্পর্কে)","audioUrl":"wbw/040_018_002.mp3","charTypeName":"word"},{"id":20123,"position":3,"arabic":"ٱلْـَٔازِفَةِ","translation":"(যা) আসন্ন","audioUrl":"wbw/040_018_003.mp3","charTypeName":"word"},{"id":20124,"position":4,"arabic":"إِذِ","translation":"যখন","audioUrl":"wbw/040_018_004.mp3","charTypeName":"word"},{"id":20125,"position":5,"arabic":"ٱلْقُلُوبُ","translation":"অন্তরসমূহ (কলিজাসমূহ)","audioUrl":"wbw/040_018_005.mp3","charTypeName":"word"},{"id":20126,"position":6,"arabic":"لَدَى","translation":"নিকট (আসবে)","audioUrl":"wbw/040_018_006.mp3","charTypeName":"word"},{"id":20127,"position":7,"arabic":"ٱلْحَنَاجِرِ","translation":"কন্ঠসমূহের","audioUrl":"wbw/040_018_007.mp3","charTypeName":"word"},{"id":20128,"position":8,"arabic":"كَـٰظِمِينَ ۚ","translation":"দুঃখ-কষ্টে","audioUrl":"wbw/040_018_008.mp3","charTypeName":"word"},{"id":20130,"position":9,"arabic":"مَا","translation":"না","audioUrl":"wbw/040_018_010.mp3","charTypeName":"word"},{"id":20131,"position":10,"arabic":"لِلظَّـٰلِمِينَ","translation":"সীমালঙ্ঘনকারীদের জন্যে (থাকবে)","audioUrl":"wbw/040_018_011.mp3","charTypeName":"word"},{"id":20132,"position":11,"arabic":"مِنْ","translation":"কোনো","audioUrl":"wbw/040_018_012.mp3","charTypeName":"word"},{"id":20133,"position":12,"arabic":"حَمِيمٍۢ","translation":"অন্তরঙ্গ","audioUrl":"wbw/040_018_013.mp3","charTypeName":"word"},{"id":20134,"position":13,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/040_018_014.mp3","charTypeName":"word"},{"id":20135,"position":14,"arabic":"شَفِيعٍۢ","translation":"কোনো সুপারিশকারী","audioUrl":"wbw/040_018_015.mp3","charTypeName":"word"},{"id":20136,"position":15,"arabic":"يُطَاعُ","translation":"মেনে নেওয়া হবে (যার কথা)","audioUrl":"wbw/040_018_016.mp3","charTypeName":"word"},{"id":20137,"position":16,"arabic":"١٨","translation":"(১৮)","audioUrl":null,"charTypeName":"end"}]},{"number":19,"arabic":"يَعْلَمُ خَآئِنَةَ ٱلْأَعْيُنِ وَمَا تُخْفِى ٱلصُّدُورُ","translation":"[for] He is aware of the [most] stealthy glance, and of all that the hearts would conceal.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4152.mp3","surahId":40,"words":[{"id":21189,"position":1,"arabic":"يَعْلَمُ","translation":"(আল্লাহ) জানেন","audioUrl":"wbw/040_019_001.mp3","charTypeName":"word"},{"id":21190,"position":2,"arabic":"خَآئِنَةَ","translation":"প্রতারণা","audioUrl":"wbw/040_019_002.mp3","charTypeName":"word"},{"id":21191,"position":3,"arabic":"ٱلْأَعْيُنِ","translation":"চোখের (অর্থাৎ চোখের চুরিও)","audioUrl":"wbw/040_019_003.mp3","charTypeName":"word"},{"id":21192,"position":4,"arabic":"وَمَا","translation":"এবং যা","audioUrl":"wbw/040_019_004.mp3","charTypeName":"word"},{"id":21193,"position":5,"arabic":"تُخْفِى","translation":"গোপন করে রাখে","audioUrl":"wbw/040_019_005.mp3","charTypeName":"word"},{"id":21194,"position":6,"arabic":"ٱلصُّدُورُ","translation":"অন্তরসমূহ","audioUrl":"wbw/040_019_006.mp3","charTypeName":"word"},{"id":21195,"position":7,"arabic":"١٩","translation":"(১৯)","audioUrl":null,"charTypeName":"end"}]},{"number":20,"arabic":"وَٱللَّهُ يَقْضِى بِٱلْحَقِّ ۖ وَٱلَّذِينَ يَدْعُونَ مِن دُونِهِۦ لَا يَقْضُونَ بِشَىْءٍ ۗ إِنَّ ٱللَّهَ هُوَ ٱلسَّمِيعُ ٱلْبَصِيرُ","translation":"And God will judge in accordance with truth and justice, whereas those [beings] whom they invoke beside Him cannot judge at all: for, verily, God alone is all-hearing, all-seeing.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4153.mp3","surahId":40,"words":[{"id":22293,"position":1,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/040_020_001.mp3","charTypeName":"word"},{"id":22294,"position":2,"arabic":"يَقْضِى","translation":"মীমাংসা করবেন","audioUrl":"wbw/040_020_002.mp3","charTypeName":"word"},{"id":22295,"position":3,"arabic":"بِٱلْحَقِّ ۖ","translation":"সঠিকভাবে","audioUrl":"wbw/040_020_003.mp3","charTypeName":"word"},{"id":22297,"position":4,"arabic":"وَٱلَّذِينَ","translation":"এবং যাদেরকে","audioUrl":"wbw/040_020_005.mp3","charTypeName":"word"},{"id":22298,"position":5,"arabic":"يَدْعُونَ","translation":"তারা ডাকে","audioUrl":"wbw/040_020_006.mp3","charTypeName":"word"},{"id":22299,"position":6,"arabic":"مِن","translation":"ছাড়া","audioUrl":"wbw/040_020_007.mp3","charTypeName":"word"},{"id":22300,"position":7,"arabic":"دُونِهِۦ","translation":"তাঁকে","audioUrl":"wbw/040_020_008.mp3","charTypeName":"word"},{"id":22301,"position":8,"arabic":"لَا","translation":"না","audioUrl":"wbw/040_020_009.mp3","charTypeName":"word"},{"id":22302,"position":9,"arabic":"يَقْضُونَ","translation":"মীমাংসা করবে তারা","audioUrl":"wbw/040_020_010.mp3","charTypeName":"word"},{"id":22303,"position":10,"arabic":"بِشَىْءٍ ۗ","translation":"কোনো কিছুরই","audioUrl":"wbw/040_020_011.mp3","charTypeName":"word"},{"id":22305,"position":11,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/040_020_013.mp3","charTypeName":"word"},{"id":22306,"position":12,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/040_020_014.mp3","charTypeName":"word"},{"id":22307,"position":13,"arabic":"هُوَ","translation":"তিনিই","audioUrl":"wbw/040_020_015.mp3","charTypeName":"word"},{"id":22308,"position":14,"arabic":"ٱلسَّمِيعُ","translation":"সবকিছু শুনেন","audioUrl":"wbw/040_020_016.mp3","charTypeName":"word"},{"id":22309,"position":15,"arabic":"ٱلْبَصِيرُ","translation":"সবকিছু দেখেন","audioUrl":"wbw/040_020_017.mp3","charTypeName":"word"},{"id":22310,"position":16,"arabic":"٢٠","translation":"(২০)","audioUrl":null,"charTypeName":"end"}]},{"number":21,"arabic":"۞ أَوَلَمْ يَسِيرُوا۟ فِى ٱلْأَرْضِ فَيَنظُرُوا۟ كَيْفَ كَانَ عَٰقِبَةُ ٱلَّذِينَ كَانُوا۟ مِن قَبْلِهِمْ ۚ كَانُوا۟ هُمْ أَشَدَّ مِنْهُمْ قُوَّةًۭ وَءَاثَارًۭا فِى ٱلْأَرْضِ فَأَخَذَهُمُ ٱللَّهُ بِذُنُوبِهِمْ وَمَا كَانَ لَهُم مِّنَ ٱللَّهِ مِن وَاقٍۢ","translation":"Have they, then, never journeyed about the earth and beheld what happened in the end to those [deniers of the truth] who lived before their time? Greater were they in power than they are, and in the impact which they left on earth: but God took them to task for their sins, and they had none to defend them against God:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4154.mp3","surahId":40,"words":[{"id":23398,"position":1,"arabic":"۞ أَوَلَمْ","translation":"কি নি","audioUrl":"wbw/040_021_002.mp3","charTypeName":"word"},{"id":23399,"position":2,"arabic":"يَسِيرُوا۟","translation":"তারা ভ্রমণ করে","audioUrl":"wbw/040_021_003.mp3","charTypeName":"word"},{"id":23400,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/040_021_004.mp3","charTypeName":"word"},{"id":23401,"position":4,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/040_021_005.mp3","charTypeName":"word"},{"id":23402,"position":5,"arabic":"فَيَنظُرُوا۟","translation":"তাহ'লে তারা দেখতে পেতো","audioUrl":"wbw/040_021_006.mp3","charTypeName":"word"},{"id":23403,"position":6,"arabic":"كَيْفَ","translation":"কেমন","audioUrl":"wbw/040_021_007.mp3","charTypeName":"word"},{"id":23404,"position":7,"arabic":"كَانَ","translation":"ছিলো","audioUrl":"wbw/040_021_008.mp3","charTypeName":"word"},{"id":23405,"position":8,"arabic":"عَـٰقِبَةُ","translation":"পরিণাম","audioU