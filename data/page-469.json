/040_022_005.mp3","charTypeName":"word"},{"id":24404,"position":6,"arabic":"بِٱلْبَيِّنَـٰتِ","translation":"নিদর্শনাবলীসহ","audioUrl":"wbw/040_022_006.mp3","charTypeName":"word"},{"id":24405,"position":7,"arabic":"فَكَفَرُوا۟","translation":"কিন্তু তারা অস্বীকার করতো","audioUrl":"wbw/040_022_007.mp3","charTypeName":"word"},{"id":24406,"position":8,"arabic":"فَأَخَذَهُمُ","translation":"তখন তাদেরকে শাস্তি দিলেন","audioUrl":"wbw/040_022_008.mp3","charTypeName":"word"},{"id":24407,"position":9,"arabic":"ٱللَّهُ ۚ","translation":"আল্লাহ","audioUrl":"wbw/040_022_009.mp3","charTypeName":"word"},{"id":24409,"position":10,"arabic":"إِنَّهُۥ","translation":"তিনি নিশ্চয়ই","audioUrl":"wbw/040_022_011.mp3","charTypeName":"word"},{"id":24410,"position":11,"arabic":"قَوِىٌّۭ","translation":"শক্তিশালী","audioUrl":"wbw/040_022_012.mp3","charTypeName":"word"},{"id":24411,"position":12,"arabic":"شَدِيدُ","translation":"কঠোর","audioUrl":"wbw/040_022_013.mp3","charTypeName":"word"},{"id":24412,"position":13,"arabic":"ٱلْعِقَابِ","translation":"শাস্তিদানে","audioUrl":"wbw/040_022_014.mp3","charTypeName":"word"},{"id":24413,"position":14,"arabic":"٢٢","translation":"(২২)","audioUrl":null,"charTypeName":"end"}]},{"number":23,"arabic":"وَلَقَدْ أَرْسَلْنَا مُوسَىٰ بِـَٔايَٰتِنَا وَسُلْطَٰنٍۢ مُّبِينٍ","translation":"THUS, INDEED, did We send Moses with Our mes­sages and a manifest authority [from Us]","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4156.mp3","surahId":40,"words":[{"id":25471,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/040_023_001.mp3","charTypeName":"word"},{"id":25472,"position":2,"arabic":"أَرْسَلْنَا","translation":"আমরা পাঠিয়েছি","audioUrl":"wbw/040_023_002.mp3","charTypeName":"word"},{"id":25473,"position":3,"arabic":"مُوسَىٰ","translation":"মূসাকে","audioUrl":"wbw/040_023_003.mp3","charTypeName":"word"},{"id":25474,"position":4,"arabic":"بِـَٔايَـٰتِنَا","translation":"আমাদের নিদর্শনাবলীসহ","audioUrl":"wbw/040_023_004.mp3","charTypeName":"word"},{"id":25475,"position":5,"arabic":"وَسُلْطَـٰنٍۢ","translation":"ও প্রমাণ (সহ)","audioUrl":"wbw/040_023_005.mp3","charTypeName":"word"},{"id":25476,"position":6,"arabic":"مُّبِينٍ","translation":"সুস্পষ্ট","audioUrl":"wbw/040_023_006.mp3","charTypeName":"word"},{"id":25477,"position":7,"arabic":"٢٣","translation":"(২৩)","audioUrl":null,"charTypeName":"end"}]},{"number":24,"arabic":"إِلَىٰ فِرْعَوْنَ وَهَٰمَٰنَ وَقَٰرُونَ فَقَالُوا۟ سَٰحِرٌۭ كَذَّابٌۭ","translation":"unto Pharaoh, and Haman, and Qarun; but they [only] said, “A spellbinder is he, a liar!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4157.mp3","surahId":40,"words":[{"id":26555,"position":1,"arabic":"إِلَىٰ","translation":"নিকটে","audioUrl":"wbw/040_024_001.mp3","charTypeName":"word"},{"id":26556,"position":2,"arabic":"فِرْعَوْنَ","translation":"ফিরআউনের","audioUrl":"wbw/040_024_002.mp3","charTypeName":"word"},{"id":26557,"position":3,"arabic":"وَهَـٰمَـٰنَ","translation":"ও হামানের","audioUrl":"wbw/040_024_003.mp3","charTypeName":"word"},{"id":26558,"position":4,"arabic":"وَقَـٰرُونَ","translation":"ও কারূনের","audioUrl":"wbw/040_024_004.mp3","charTypeName":"word"},{"id":26559,"position":5,"arabic":"فَقَالُوا۟","translation":"তারা কিন্তু বলেছিলো","audioUrl":"wbw/040_024_005.mp3","charTypeName":"word"},{"id":26560,"position":6,"arabic":"سَـٰحِرٌۭ","translation":"\"(সে একজন) যাদুকর","audioUrl":"wbw/040_024_006.mp3","charTypeName":"word"},{"id":26561,"position":7,"arabic":"كَذَّابٌۭ","translation":"মিথ্যাবাদী\"","audioUrl":"wbw/040_024_007.mp3","charTypeName":"word"},{"id":26562,"position":8,"arabic":"٢٤","translation":"(২৪)","audioUrl":null,"charTypeName":"end"}]},{"number":25,"arabic":"فَلَمَّا جَآءَهُم بِٱلْحَقِّ مِنْ عِندِنَا قَالُوا۟ ٱقْتُلُوٓا۟ أَبْنَآءَ ٱلَّذِينَ ءَامَنُوا۟ مَعَهُۥ وَٱسْتَحْيُوا۟ نِسَآءَهُمْ ۚ وَمَا كَيْدُ ٱلْكَٰفِرِينَ إِلَّا فِى ضَلَٰلٍۢ","translation":"Now [as for Pharaoh and his followers,] when he came to them, setting forth the truth from Us, they said, “Slay the sons of those who share his beliefs, and spare [only] their women!” - but the guile of those deniers of the truth could not lead to aught but failure.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4158.mp3","surahId":40,"words":[{"id":27550,"position":1,"arabic":"فَلَمَّا","translation":"পরে যখন","audioUrl":"wbw/040_025_001.mp3","charTypeName":"word"},{"id":27551,"position":2,"arabic":"جَآءَهُم","translation":"তাদের কাছে নিয়ে এলো","audioUrl":"wbw/040_025_002.mp3","charTypeName":"word"},{"id":27552,"position":3,"arabic":"بِٱلْحَقِّ","translation":"প্রকৃত সত্যসহ","audioUrl":"wbw/040_025_003.mp3","charTypeName":"word"},{"id":27553,"position":4,"arabic":"مِنْ","translation":"হ'তে","audioUrl":"wbw/040_025_004.mp3","charTypeName":"word"},{"id":27554,"position":5,"arabic":"عِندِنَا","translation":"আমাদের নিকট","audioUrl":"wbw/040_025_005.mp3","charTypeName":"word"},{"id":27555,"position":6,"arabic":"قَالُوا۟","translation":"তারা বললো","audioUrl":"wbw/040_025_006.mp3","charTypeName":"word"},{"id":27556,"position":7,"arabic":"ٱقْتُلُوٓا۟","translation":"\"তোমরা হত্যা করো","audioUrl":"wbw/040_025_007.mp3","charTypeName":"word"},{"id":27557,"position":8,"arabic":"أَبْنَآءَ","translation":"পুত্র সন্তানদেরকে","audioUrl":"wbw/040_025_008.mp3","charTypeName":"word"},{"id":27558,"position":9,"arabic":"ٱلَّذِينَ","translation":"(তাদের) যারা","audioUrl":"wbw/040_025_009.mp3","charTypeName":"word"},{"id":27559,"position":10,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/040_025_010.mp3","charTypeName":"word"},{"id":27560,"position":11,"arabic":"مَعَهُۥ","translation":"তার সাথে","audioUrl":"wbw/040_025_011.mp3","charTypeName":"word"},{"id":27561,"position":12,"arabic":"وَٱسْتَحْيُوا۟","translation":"এবং তোমরা জীবিত রাখো","audioUrl":"wbw/040_025_012.mp3","charTypeName":"word"},{"id":27562,"position":13,"arabic":"نِسَآءَهُمْ ۚ","translation":"তাদের নারীদেরকে\"","audioUrl":"wbw/040_025_013.mp3","charTypeNam