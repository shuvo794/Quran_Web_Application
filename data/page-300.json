{"id":300,"ayahs":[{"number":54,"arabic":"وَلَقَدْ صَرَّفْنَا فِى هَٰذَا ٱلْقُرْءَانِ لِلنَّاسِ مِن كُلِّ مَثَلٍۢ ۚ وَكَانَ ٱلْإِنسَٰنُ أَكْثَرَ شَىْءٍۢ جَدَلًۭا","translation":"THUS, INDEED, have We given in this Qur'an many facets to every kind of lesson [designed] for [the benefit of] mankind. However, man is, above all else, always given to contention:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2194.mp3","surahId":18,"words":[{"id":51267,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/018_054_001.mp3","charTypeName":"word"},{"id":51268,"position":2,"arabic":"صَرَّفْنَا","translation":"আমরা বিশদভাবে বর্ণনা করেছি","audioUrl":"wbw/018_054_002.mp3","charTypeName":"word"},{"id":51269,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/018_054_003.mp3","charTypeName":"word"},{"id":51270,"position":4,"arabic":"هَـٰذَا","translation":"এই","audioUrl":"wbw/018_054_004.mp3","charTypeName":"word"},{"id":51271,"position":5,"arabic":"ٱلْقُرْءَانِ","translation":"কুরআনের","audioUrl":"wbw/018_054_005.mp3","charTypeName":"word"},{"id":51272,"position":6,"arabic":"لِلنَّاسِ","translation":"জন্যে মানুষদের","audioUrl":"wbw/018_054_006.mp3","charTypeName":"word"},{"id":51273,"position":7,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/018_054_007.mp3","charTypeName":"word"},{"id":51274,"position":8,"arabic":"كُلِّ","translation":"প্রত্যেক","audioUrl":"wbw/018_054_008.mp3","charTypeName":"word"},{"id":51275,"position":9,"arabic":"مَثَلٍۢ ۚ","translation":"দৃষ্টান্ত","audioUrl":"wbw/018_054_009.mp3","charTypeName":"word"},{"id":51277,"position":10,"arabic":"وَكَانَ","translation":"অথচ হলো","audioUrl":"wbw/018_054_011.mp3","charTypeName":"word"},{"id":51278,"position":11,"arabic":"ٱلْإِنسَـٰنُ","translation":"মানুষ","audioUrl":"wbw/018_054_012.mp3","charTypeName":"word"},{"id":51279,"position":12,"arabic":"أَكْثَرَ","translation":"অধিকাংশ","audioUrl":"wbw/018_054_013.mp3","charTypeName":"word"},{"id":51280,"position":13,"arabic":"شَىْءٍۢ","translation":"বিষয়ে","audioUrl":"wbw/018_054_014.mp3","charTypeName":"word"},{"id":51281,"position":14,"arabic":"جَدَلًۭا","translation":"ঝগড়াটে","audioUrl":"wbw/018_054_015.mp3","charTypeName":"word"},{"id":51282,"position":15,"arabic":"٥٤","translation":"(৫৪)","audioUrl":null,"charTypeName":"end"}]},{"number":55,"arabic":"وَمَا مَنَعَ ٱلنَّاسَ أَن يُؤْمِنُوٓا۟ إِذْ جَآءَهُمُ ٱلْهُدَىٰ وَيَسْتَغْفِرُوا۟ رَبَّهُمْ إِلَّآ أَن تَأْتِيَهُمْ سُنَّةُ ٱلْأَوَّلِينَ أَوْ يَأْتِيَهُمُ ٱلْعَذَابُ قُبُلًۭا","translation":"for, what is there to keep people from attaining to faith now that guidance has come unto them, and from asking their Sustainer to forgive them their sins - unless it be [their wish] that the fate of the [sinful] people of ancient times should befall them [as well], or that the [ultimate] suffering should befall them in the hereafter?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2195.mp3","surahId":18,"words":[{"id":51608,"position":1,"arabic":"وَمَا","translation":"এবং কি (জিনিস)","audioUrl":"wbw/018_055_001.mp3","charTypeName":"word"},{"id":51609,"position":2,"arabic":"مَنَعَ","translation":"বাদা দেয়","audioUrl":"wbw/018_055_002.mp3","charTypeName":"word"},{"id":51610,"position":3,"arabic":"ٱلنَّاسَ","translation":"মানুষদেরকে","audioUrl":"wbw/018_055_003.mp3","charTypeName":"word"},{"id":51611,"position":4,"arabic":"أَن","translation":"যে","audioUrl":"wbw/018_055_004.mp3","charTypeName":"word"},{"id":51612,"position":5,"arabic":"يُؤْمِنُوٓا۟","translation":"তারা ঈমান আনবে","audioUrl":"wbw/018_055_005.mp3","charTypeName":"word"},{"id":51613,"position":6,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/018_055_006.mp3","charTypeName":"word"},{"id":51614,"position":7,"arabic":"جَآءَهُمُ","translation":"এসেছে তাদের কাছে","audioUrl":"wbw/018_055_007.mp3","charTypeName":"word"},{"id":51615,"position":8,"arabic":"ٱلْهُدَىٰ","translation":"পথ নির্দেশ","audioUrl":"wbw/018_055_008.mp3","charTypeName":"word"},{"id":51616,"position":9,"arabic":"وَيَسْتَغْفِرُوا۟","translation":"এবং তারা ক্ষমা চাইতে","audioUrl":"wbw/018_055_009.mp3","charTypeName":"word"},{"id":51617,"position":10,"arabic":"رَبَّهُمْ","translation":"রবের কাছে তাদের","audioUrl":"wbw/018_055_010.mp3","charTypeName":"word"},{"id":51618,"position":11,"arabic":"إِلَّآ","translation":"ছাড়া","audioUrl":"wbw/018_055_011.mp3","charTypeName":"word"},{"id":51619,"position":12,"arabic":"أَن","translation":"যে","audioUrl":"wbw/018_055_012.mp3","charTypeName":"word"},{"id":51620,"position":13,"arabic":"تَأْتِيَهُمْ","translation":"কাছ আসবে তাদের","audioUrl":"wbw/018_055_013.mp3","charTypeName":"word"},{"id":51621,"position":14,"arabic":"سُنَّةُ","translation":"অনুসৃত রীতি","audioUrl":"wbw/018_055_014.mp3","charTypeName":"word"},{"id":51622,"position":15,"arabic":"ٱلْأَوَّلِينَ","translation":"পূর্ববর্তীদের","audioUrl":"wbw/018_055_015.mp3","charTypeName":"word"},{"id":51623,"position":16,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/018_055_016.mp3","charTypeName":"word"},{"id":51624,"position":17,"arabic":"يَأْتِيَهُمُ","translation":"কাছে আসবে তাদের","audioUrl":"wbw/018_055_017.mp3","charTypeName":"word"},{"id":51625,"position":18,"arabic":"ٱلْعَذَابُ","translation":"শাস্তি","audioUrl":"wbw/018_055_018.mp3","charTypeName":"word"},{"id":51626,"position":19,"arabic":"قُبُلًۭا","translation":"সামনাসামনি","audioUrl":"wbw/018_055_019.mp3","charTypeName":"word"},{"id":51627,"position":20,"arabic":"٥٥","translation":"(৫৫)","audioUrl":null,"charTypeName":"end"}]},{"number":56,"arabic":"وَمَا نُرْسِلُ ٱلْمُرْسَلِينَ إِلَّا مُبَشِّرِينَ وَمُنذِرِينَ ۚ وَيُجَٰدِلُ ٱلَّذِينَ كَفَرُوا۟ بِٱلْبَٰطِلِ لِيُدْحِضُوا۟ بِهِ ٱلْحَقَّ ۖ وَٱتَّخَذُوٓا۟ ءَايَٰتِى وَمَآ أُنذِرُوا۟ هُزُوًۭا","translation":"But We send [Our] message-bearers only as heralds of glad tidings and as warners - whereas those who are bent on denying the truth contend [against them] with fallacious arguments, so as to render void the truth thereby, and to make My messages and warnings a target of their mockery.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2196.mp3","surahId":18,"words":[{"id":52220,"position":1,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/018_056_001.mp3","charTypeName":"word"},{"id":52221,"position":2,"arabic":"نُرْسِلُ","translation":"আমরা প্রেরণ করি","audioUrl":"wbw/018_056_002.mp3","charTypeName":"word"},{"id":52222,"position":3,"arabic":"ٱلْمُرْسَلِينَ","translation":"রাসূলদেরকে","audioUrl":"wbw/018_056_003.mp3","charTypeName":"word"},{"id":52223,"position":4,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/018_056_004.mp3","charTypeName":"word"},{"id":52224,"position":5,"arabic":"مُبَشِّرِينَ","translation":"সুসংবাদদাতা","audioUrl":"wbw/018_056_005.mp3","charTypeName":"word"},{"id":52225,"position":6,"arabic":"وَمُنذِرِينَ ۚ","translation":"এবং সতর্ককারী (রূপে)","audioUrl":"wbw/018_056_006.mp3","charTypeName":"word"},{"id":52227,"position":7,"arabic":"وَيُجَـٰدِلُ","translation":"এবং বিতর্ক করে","audioUrl":"wbw/018_056_008.mp3","charTypeName":"word"},{"id":52228,"position":8,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/018_056_009.mp3","charTypeName":"word"},{"id":52229,"position":9,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/018_056_010.mp3","charTypeName":"word"},{"id":52230,"position":10,"arabic":"بِٱلْبَـٰطِلِ","translation":"দিয়ে মিথ্যা","audioUrl":"wbw/018_056_011.mp3","charTypeName":"word"},{"id":52231,"position":11,"arabic":"لِيُدْحِضُوا۟","translation":"যেন তারা ব্যর্থ করতে পারে","audioUrl":"wbw/018_056_012.mp3","charTypeName":"word"},{"id":52232,"position":12,"arabic":"بِهِ","translation":"দিয়ে তা","audioUrl":"wbw/018_056_013.mp3","charTypeName":"word"},{"id":52233,"position":13,"arabic":"ٱلْحَقَّ ۖ","translation":"সত্যকে","audioUrl":"wbw/018_056_014.mp3","charTypeName":"word"},{"id":52235,"position":14,"arabic":"وَٱتَّخَذُوٓا۟","translation":"এবং তারা গ্রহণ করেছে","audioUrl":"wbw/018_056_016.mp3","charTypeName":"word"},{"id":52236,"position":15,"arabic":"ءَايَـٰتِى","translation":"আমার নিদর্শনগুলোকে","audioUrl":"wbw/018_056_017.mp3","charTypeName":"word"},{"id":52237,"position":16,"arabic":"وَمَآ","translation":"এবং (সেগুলোকে) যার","audioUrl":"wbw/018_056_018.mp3","charTypeName":"word"},{"id":52238,"position":17,"arabic":"أُنذِرُوا۟","translation":"সতর্ক করা হয়েছে","audioUrl":"wbw/018_056_019.mp3","charTypeName":"word"},{"id":52239,"position":18,"arabic":"هُزُوًۭا","translation":"বিদ্রূপরূপে","audioUrl":"wbw/018_056_020.mp3","charTypeName":"word"},{"id":52240,"position":19,"arabic":"٥٦","translation":"(৫৬)","audioUrl":null,"charTypeName":"end"}]},{"number":57,"arabic":"وَمَنْ أَظْلَمُ مِمَّن ذُكِّرَ بِـَٔايَٰتِ رَبِّهِۦ فَأَعْرَضَ عَنْهَا وَنَسِىَ مَا قَدَّمَتْ يَدَاهُ ۚ إِنَّا جَعَلْنَا عَلَىٰ قُلُوبِهِمْ أَكِنَّةً أَن يَفْقَهُوهُ وَفِىٓ ءَاذَانِهِمْ وَقْرًۭا ۖ وَإِن تَدْعُهُمْ إِلَى ٱلْهُدَىٰ فَلَن يَهْتَدُوٓا۟ إِذًا أَبَدًۭا","translation":"And who could be more wicked than he to whom his Sustainer's messages are conveyed and who thereupon turns away from them, forgetting all [the evil] that his hands may have wrought? Behold, over their hearts have We laid veils which prevent them from grasping the truth, and into their ears, deafness; and though thou call them onto the right path, they will never allow themselves to be guided.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2197.mp3","surahId":18,"words":[{"id":52632,"position":1,"arabic":"وَمَنْ","translation":"এবং কে","audioUrl":"wbw/018_057_001.mp3","charTypeName":"word"},{"id":52633,"position":2,"arabic":"أَظْلَمُ","translation":"অধিক সীমালঙ্ঘনকারী","audioUrl":"wbw/018_057_002.mp3","charTypeName":"word"},{"id":52634,"position":3,"arabic":"مِمَّن","translation":"(তার) চেয়ে যাকে","audioUrl":"wbw/018_057_003.mp3","charTypeName":"word"},{"id":52635,"position":4,"arabic":"ذُكِّرَ","translation":"স্মরণ করিয়ে দেয়া হয়েছে","audioUrl":"wbw/018_057_004.mp3","charTypeName":"word"},{"id":52636,"position":5,"arabic":"بِـٔ