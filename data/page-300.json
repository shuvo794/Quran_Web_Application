harTypeName":"word"},{"id":52653,"position":21,"arabic":"ءَاذَانِهِمْ","translation":"কানগুলোর তাদের","audioUrl":"wbw/018_057_022.mp3","charTypeName":"word"},{"id":52654,"position":22,"arabic":"وَقْرًۭا ۖ","translation":"বধিরতা (দিয়েছি)","audioUrl":"wbw/018_057_023.mp3","charTypeName":"word"},{"id":52656,"position":23,"arabic":"وَإِن","translation":"এবং যদি","audioUrl":"wbw/018_057_025.mp3","charTypeName":"word"},{"id":52657,"position":24,"arabic":"تَدْعُهُمْ","translation":"তুমি ডাকো তাদেরকে","audioUrl":"wbw/018_057_026.mp3","charTypeName":"word"},{"id":52658,"position":25,"arabic":"إِلَى","translation":"দিকে","audioUrl":"wbw/018_057_027.mp3","charTypeName":"word"},{"id":52659,"position":26,"arabic":"ٱلْهُدَىٰ","translation":"সৎপথে","audioUrl":"wbw/018_057_028.mp3","charTypeName":"word"},{"id":52660,"position":27,"arabic":"فَلَن","translation":"তবুও না","audioUrl":"wbw/018_057_029.mp3","charTypeName":"word"},{"id":52661,"position":28,"arabic":"يَهْتَدُوٓا۟","translation":"তারা সঠিক পথ পাবে","audioUrl":"wbw/018_057_030.mp3","charTypeName":"word"},{"id":52662,"position":29,"arabic":"إِذًا","translation":"তাহ'লে","audioUrl":"wbw/018_057_031.mp3","charTypeName":"word"},{"id":52663,"position":30,"arabic":"أَبَدًۭا","translation":"কখনও","audioUrl":"wbw/018_057_032.mp3","charTypeName":"word"},{"id":52664,"position":31,"arabic":"٥٧","translation":"(৫৭)","audioUrl":null,"charTypeName":"end"}]},{"number":58,"arabic":"وَرَبُّكَ ٱلْغَفُورُ ذُو ٱلرَّحْمَةِ ۖ لَوْ يُؤَاخِذُهُم بِمَا كَسَبُوا۟ لَعَجَّلَ لَهُمُ ٱلْعَذَابَ ۚ بَل لَّهُم مَّوْعِدٌۭ لَّن يَجِدُوا۟ مِن دُونِهِۦ مَوْئِلًۭا","translation":"Yet, [withal,] thy Sustainer is the Truly-Forgiving One, limitless in His grace. Were He to take them [at once] to task for whatever [wrong] they commit, He would indeed bring about their speedy punishment [then and there]: but nay, they have a time-limit beyond which they shall find no redemption","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2198.mp3","surahId":18,"