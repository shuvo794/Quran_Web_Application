করতে পারো","audioUrl":"wbw/007_123_016.mp3","charTypeName":"word"},{"id":76822,"position":16,"arabic":"مِنْهَآ","translation":"থেকে তা","audioUrl":"wbw/007_123_017.mp3","charTypeName":"word"},{"id":76823,"position":17,"arabic":"أَهْلَهَا ۖ","translation":"অধিবাসীদেরকে তার","audioUrl":"wbw/007_123_018.mp3","charTypeName":"word"},{"id":76825,"position":18,"arabic":"فَسَوْفَ","translation":"অতএব শীঘ্রই","audioUrl":"wbw/007_123_020.mp3","charTypeName":"word"},{"id":76826,"position":19,"arabic":"تَعْلَمُونَ","translation":"তোমরা জানতে পারবে","audioUrl":"wbw/007_123_021.mp3","charTypeName":"word"},{"id":76827,"position":20,"arabic":"١٢٣","translation":"(১২৩)","audioUrl":null,"charTypeName":"end"}]},{"number":124,"arabic":"لَأُقَطِّعَنَّ أَيْدِيَكُمْ وَأَرْجُلَكُم مِّنْ خِلَٰفٍۢ ثُمَّ لَأُصَلِّبَنَّكُمْ أَجْمَعِينَ","translation":"most certainly shall I cut off your hands and your feet in great numbers, because of [your] perverseness, and then I shall most certainly crucify you, in great numbers, all together! \"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1078.mp3","surahId":7,"words":[{"id":76984,"position":1,"arabic":"لَأُقَطِّعَنَّ","translation":"অবশ্যই কাটবো আমি","audioUrl":"wbw/007_124_001.mp3","charTypeName":"word"},{"id":76985,"position":2,"arabic":"أَيْدِيَكُمْ","translation":"হাতগুলোকে তোমাদের","audioUrl":"wbw/007_124_002.mp3","charTypeName":"word"},{"id":76986,"position":3,"arabic":"وَأَرْجُلَكُم","translation":"ও পাগুলোকে তোমাদের","audioUrl":"wbw/007_124_003.mp3","charTypeName":"word"},{"id":76987,"position":4,"arabic":"مِّنْ","translation":"হতে","audioUrl":"wbw/007_124_004.mp3","charTypeName":"word"},{"id":76988,"position":5,"arabic":"خِلَـٰفٍۢ","translation":"বিপরীত দিক","audioUrl":"wbw/007_124_005.mp3","charTypeName":"word"},{"id":76989,"position":6,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/007_124_006.mp3","charTypeName":"word"},{"id":76990,"position":7,"arabic":"لَأُصَلِّبَنَّكُمْ","translation":"অবশ্যই শুলে চড়াবো আমি তোমাদেরকে","audioUrl":"wbw/007_124_007.mp3","charTypeName":"word"},{"id":76991,"position":8,"arabic":"أَجْمَعِينَ","translation":"সবাইকে\"","audioUrl":"wbw/007_124_008.mp3","charTypeName":"word"},{"id":76992,"position":9,"arabic":"١٢٤","translation":"(১২৪)","audioUrl":null,"charTypeName":"end"}]},{"number":125,"arabic":"قَالُوٓا۟ إِنَّآ إِلَىٰ رَبِّنَا مُنقَلِبُونَ","translation":"They answered: \"Verily, unto our Sustainer do we turn-","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1079.mp3","surahId":7,"words":[{"id":77271,"position":1,"arabic":"قَالُوٓا۟","translation":"তারা বললো","audioUrl":"wbw/007_125_001.mp3","charTypeName":"word"},{"id":77272,"position":2,"arabic":"إِنَّآ","translation":"\"নিশ্চয়ই আমরা","audioUrl":"wbw/007_125_002.mp3","charTypeName":"word"},{"id":77273,"position":3,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/007_125_003.mp3","charTypeName":"word"},{"id":77274,"position":4,"arabic":"رَبِّنَا","translation":"রবের আমাদের","audioUrl":"wbw/007_125_004.mp3","charTypeName":"word"},{"id":77275,"position":5,"arabic":"مُنقَلِبُونَ","translation":"প্রত্যাবর্তন কারী","audioUrl":"wbw/007_125_005.mp3","charTypeName":"word"},{"id":77276,"position":6,"arabic":"١٢٥","translation":"(১২৫)","audioUrl":null,"charTypeName":"end"}]},{"number":126,"arabic":"وَمَا تَنقِمُ مِنَّآ إِلَّآ أَنْ ءَامَنَّا بِـَٔايَٰتِ رَبِّنَا لَمَّا جَآءَتْنَا ۚ رَبَّنَآ أَفْرِغْ عَلَيْنَا صَبْرًۭا وَتَوَفَّنَا مُسْلِمِينَ","translation":"for thou takest vengeance on us only because we have come to believe in our Sustainer's messages as soon as they came to us. O our Sustainer! Shower us with patience in adversity, and make us die as men who have surrendered themselves unto Thee!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1080.mp3","surahId":7,"words":[{"id":77333,"position":1,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/007_126_001.mp3","charTypeName":"word"},{"id":77334,"position":2,"arabic":"تَنقِمُ","translation":"প্রতিশোধ নিচ্ছো তুমি","audioUrl":"wbw/007_126_002.mp3","charTypeName":"word"},{"id":77335,"position":3,"arabic":"مِنَّآ","translation":"হতে আমাদের","audioUrl":"wbw/007_126_003.mp3","charTypeName":"word"},{"id":77336,"position":4,"arabic":"إِلَّآ","translation":"এ ছাড়া (অন্য কোনো কারণে)","audioUrl":"wbw/007_126_004.mp3","charTypeName":"word"},{"id":77337,"position":5,"arabic":"أَنْ","translation":"যে","audioUrl":"wbw/007_126_005.mp3","charTypeName":"word"},{"id":77338,"position":6,"arabic":"ءَامَنَّا","translation":"ঈমান এনেছি আমরা","audioUrl":"wbw/007_126_006.mp3","charTypeName":"word"},{"id":77339,"position":7,"arabic":"بِـَٔايَـٰتِ","translation":"প্রতি নিদর্শনগুলোর","audioUrl":"wbw/007_126_007.mp3","charTypeName":"word"},{"id":77340,"position":8,"arabic":"رَبِّنَا","translation":"রবের আমাদের","audioUrl":"wbw/007_126_008.mp3","charTypeName":"word"},{"id":77341,"position":9,"arabic":"لَمَّا","translation":"যখন","audioUrl":"wbw/007_126_009.mp3","charTypeName":"word"},{"id":77342,"position":10,"arabic":"جَآءَتْنَا ۚ","translation":"কাছে এসেছে তা আমাদের","audioUrl":"wbw/007_126_010.mp3","charTypeName":"word"},{"id":77344,"position":11,"arabic":"رَبَّنَآ","translation":"হে আমার রব","audioUrl":"wbw/007_126_012.mp3","charTypeName":"word"},{"id":77345,"position":12,"arabic":"أَفْرِغْ","translation":"তুমি ঢেলে দাও","audioUrl":"wbw/007_126_013.mp3","charTypeName":"word"},{"id":77346,"position":13,"arabic":"عَلَيْنَا","translation":"উপর আমাদের","audioUrl":"wbw/007_126_014.mp3","charTypeName":"word"},{"id":77347,"position":14,"arabic":"صَبْرًۭا","translation":"ধৈর্য","audioUrl":"wbw/007_126_015.mp3","charTypeName":"word"},{"id":77348,"position":15,"arabic":"وَتَوَفَّنَا","translation":"ও মৃত্যু দাও আমাদের","audioUrl":"wbw/007_126_016.mp3","charTypeName":"word"},{"id":77349,"position":16,"arabic":"مُسْلِمِينَ","translation":"(অনুগত) মুসলমান হিসেবে\"","audioUrl":"wbw/007_126_017.mp3","charTypeName":"word"},{"id":77350,"position":17,"arabic":"١٢٦","translation":"(১২৬)","audioUrl":null,"charTypeName":"end"}]},{"number":127,"arabic":"وَقَالَ ٱلْمَلَأُ مِن قَوْمِ فِرْعَوْنَ أَتَذَرُ مُوسَىٰ وَقَوْمَهُۥ لِيُفْسِدُوا۟ فِى ٱلْأَرْضِ وَيَذَرَكَ وَءَالِهَتَكَ ۚ قَالَ سَنُقَتِّلُ أَبْنَآءَهُمْ وَنَسْتَحْىِۦ نِسَآءَهُمْ وَإِنَّا فَوْقَهُمْ قَٰهِرُونَ","translation":"And the great ones among Pharaoh's people said: \"Wilt thou allow Moses and his people to spread corruption on earth, and to [cause thy people to] forsake thee and thy gods?\" [Pharaoh] replied: \"We shall slay their sons in great numbers and shall spare [only] their women: for, verily, we hold sway over them!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1081.mp3","surahId":7,"words":[{"id":77519,"position":1,"arabic":"وَقَالَ","translation":"এবং বললো","audioUrl":"wbw/007_127_001.mp3","charTypeName":"word"},{"id":77520,"position":2,"arabic":"ٱلْمَلَأُ","translation":"প্রধানরা","audioUrl":"wbw/007_127_002.mp3","charTypeName":"word"},{"id":77521,"position":3,"arabic":"مِن","translation":"মধ্য হতে","audioUrl":"wbw/007_127_003.mp3","charTypeName":"word"},{"id":77522,"position":4,"arabic":"قَوْمِ","translation":"জাতির","audioUrl":"wbw/007_127_004.mp3","charTypeName":"word"},{"id":77523,"position":5,"arabic":"فِرْعَوْنَ","translation":"ফিরাউনের","audioUrl":"wbw/007_127_005.mp3","charTypeName":"word"},{"id":77524,"position":6,"arabic":"أَتَذَرُ","translation":"\"কি ছেড়ে দিবেন","audioUrl":"wbw/007_127_006.mp3","charTypeName":"word"},{"id":77525,"position":7,"arabic":"مُوسَىٰ","translation":"মূসাকে","audioUrl":"wbw/007_127_007.mp3","charTypeName":"word"},{"id":77526,"position":8,"arabic":"وَقَوْمَهُۥ","translation":"ও জাতিকে তার","audioUrl":"wbw/007_127_008.mp3","charTypeName":"word"},{"id":77527,"position":9,"arabic":"لِيُفْسِدُوا۟","translation":"যেন তারা বিপর্যয় সৃষ্টি করে","audioUrl":"wbw/007_127_009.mp3","charTypeName":"word"},{"id":77528,"position":10,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/007_127_010.mp3","charTypeName":"word"},{"id":77529,"position":11,"arabic":"ٱلْأَرْضِ","translation":"দেশের","audioUrl":"wbw/007_127_011.mp3","charTypeName":"word"},{"id":77530,"position":12,"arabic":"وَيَذَرَكَ","translation":"ও আপনাকে পরিত্যাগ করবে","audioUrl":"wbw/007_127_012.mp3","charTypeName":"word"},{"id":77531,"position":13,"arabic":"وَءَالِهَتَكَ ۚ","translation":"এবং আপনার দেবতাদেরকে\"","audioUrl":"wbw/007_127_013.mp3","charTypeName":"word"},{"id":77533,"position":14,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/007_127_015.mp3","charTypeName":"word"},{"id":77534,"position":15,"arabic":"سَنُقَتِّلُ","translation":"\"অচিরেই আমরা হত্যা করবো","audioUrl":"wbw/007_127_016.mp3","charTypeName":"word"},{"id":77535,"position":16,"arabic":"أَبْنَآءَهُمْ","translation":"পুত্রদেরকে তাদের","audioUrl":"wbw/007_127_017.mp3","charTypeName":"word"},{"id":77536,"position":17,"arabic":"وَنَسْتَحْىِۦ","translation":"ও জীবিত রাখবো","audioUrl":"wbw/007_127_018.mp3","charTypeName":"word"},{"id":77537,"position":18,"arabic":"نِسَآءَهُمْ","translation":"নারীদেরকে তাদের","audioUrl":"wbw/007_127_019.mp3","charTypeName":"word"},{"id":77538,"position":19,"arabic":"وَإِنَّا","translation":"এবং নিশ্চয়ই আমরা","audioUrl":"wbw/007_127_020.mp3","charTypeName":"word"},{"id":77539,"position":20,"arabic":"فَوْقَهُمْ","translation":"উপর তাদের","audioUrl":"wbw/007_127_021.mp3","charTypeName":"word"},{"id":77540,"position":21,"arabic":"قَـٰهِرُونَ","translation":"পরাক্রমশালী\"","audioUrl":"wbw/007_127_022.mp3","charTypeName":"word"},{"id":77541,"position":22,"arabic":"١٢٧","translation":"(১২৭)","audioUrl":null,"charTypeName":"end"}]},{"number":128,"arabic":"قَالَ مُوسَىٰ لِقَوْمِهِ ٱسْتَعِينُوا۟ بِٱللَّهِ وَٱصْبِرُوٓا۟ ۖ إِنَّ ٱلْأَرْضَ لِلَّهِ يُورِثُهَا مَن يَشَآءُ مِنْ عِبَادِهِۦ ۖ وَٱلْعَٰقِبَةُ لِلْمُتَّقِينَ","translation":"[And] Moses said unto his people: \"Turn unto God for aid, and have patience in adversity. Verily, all the earth belongs to God: He gives it as a heritage - to such as He wills of His servants; and the future belongs to the God-conscious!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1082.mp3","surahId":7,"words":[{"id":77637,"position":1,"arabic":"قَالَ","translation":"বললো","audioUrl":"wbw/007_128_001.mp3","charTypeName":"word"},{"id":77638,"position":2,"arabic":"مُوسَىٰ","translation":"মূসা","audioUrl":"wbw/007_128_002.mp3","charTypeName":"word"},{"id":77639,"position":3,"arabic":"لِقَوْمِهِ","translation":"উদ্দেশ্যে জাতির তার","audioUrl":"wbw/007_128_003.mp3","charTypeName":"word"},{"id":77640,"position":4,"arabic":"ٱسْتَعِينُوا۟","translation":"\"তোমরা সাহায্য চাও","audioUrl":"wbw/007_128_004.mp3","charTypeName":"word"},{"id":77641,"position":5,"arabic":"بِٱللَّهِ","translation":"কাছে আল্লাহর","audioUrl":"wbw/007_128_005.mp3","charTypeName":"word"},{"id":77642,"position":6,"arabic":"وَٱصْبِرُوٓا۟ ۖ","translation":"ও তোমরা ধৈর্য ধরো","audioUrl":"wbw/007_128_006.mp3","charTypeName":"word"},{"id":77644,"position":7,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/007_128_008.mp3","charTypeName":"word"},{"id":77645,"position":8,"arabic":"ٱلْأَرْضَ","translation":"পৃথিবী","audioUrl":"wbw/007_128_009.mp3","charTypeName":"word"},{"id":77646,"position":9,"arabic":"لِلَّهِ","translation":"জন্যে আল্লাহরই","audioUrl":"wbw/007_128_010.mp3","charTypeName":"word"},{"id":77647,"position":10,"arabic":"يُورِثُهَا","translation":"তার উত্তরাধীকারী করেন","audioUrl":"wbw/007_128_011.mp3","charTypeName":"word"},{"id":77648,"position":11,"arabic":"مَن","translation":"(তাকে) যাকে","audioUrl":"wbw/007_128_012.mp3","charTypeName":"word"},{"id":77649,"position":12,"arabic":"يَشَآءُ","translation":"তিনি ইচ্ছে করবেন","audioUrl":"wbw/007_128_013.mp3","charTypeName":"word"},{"id":77650,"position":13,"arabic":"مِنْ","translation":"মধ্য হতে","audioUrl":"wbw/007_128_014.mp3","charTypeName":"word"},{"id":77651,"position":14,"arabic":"عِبَادِهِۦ ۖ","translation":"তার দাসদের","audioUrl":"wbw/007_128_015.mp3","charTypeName":"word"},{"id":77653,"position":15,"arabic":"وَٱلْعَـٰقِبَةُ","translation":"এবং (উত্তম) পরিণাম","audioUrl":"wbw/007_128_017.mp3","charTypeName":"word"},{"id":77654,"position":16,"arabic":"لِلْمُتَّقِينَ","translation":"জন্যে মুত্তাকীদের\"","audioUrl":"wbw/007_128_018.mp3","charTypeName":"word"},{"id":77655,"position":17,"arabic":"١٢٨","translation":"(১২৮)","audioUrl":null,"charTypeName":"end"}]},{"number":129,"arabic":"قَالُوٓا۟ أُوذِينَا مِن قَبْلِ أَن تَأْتِيَنَا وَمِنۢ بَعْدِ مَا جِئْتَنَا ۚ قَالَ عَسَىٰ رَبُّكُمْ أَن يُهْلِكَ عَدُوَّكُمْ وَيَسْتَخْلِفَكُمْ فِى ٱلْأَرْضِ فَيَنظُرَ كَيْفَ تَعْمَلُونَ","translation":"[But the children of Israel] said: \"We have suffered hurt ere thou camest to us and since thou hast come to us!\" [Moses] replied: \"It may well be that your Sustainer will destroy your foe and make you inherit the earth: and thereupon he will behold how you act.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1083.mp3","surahId":7,"words":[{"id":77775,"position":1,"arabic":"قَالُوٓا۟","translation":"তারা বললো","audioUrl":"wbw/007_129_001.mp3","charTypeName":"word"},{"id":77776,"position":2,"arabic":"أُوذِينَا","translation":"\"নির্যাতিত হয়েছি আমরা","audioUrl":"wbw/007_129_002.mp3","charTypeName":"word"},{"id":77777,"position":3,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/007_129_003.mp3","charTypeName":"word"},{"id":77778,"position":4,"arabic":"قَبْلِ","translation":"(এর) পূর্ব","audioUrl":"wbw/007_129_004.mp3","charTypeName":"word"},{"id":77779,"position":5,"arabic":"أَن","translation":"যে","audioUrl":"wbw/007_129_005.mp3","charTypeName":"word"},{"id":77780,"position":6,"arabic":"تَأْتِيَنَا","translation":"আমাদের কাছে তুমি আসবে","audioUrl":"wbw/007_129_006.mp3","charTypeName":"word"},{"id":77781,"position":7,"arabic":"وَمِنۢ","translation":"এবং থেকে","audioUrl":"wbw/007_129_007.mp3","charTypeName":"word"},{"id":77782,"position":8,"arabic":"بَعْدِ","translation":"পর","audioUrl":"wbw/007_129_008.mp3","charTypeName":"word"},{"id":77783,"position":9,"arabic":"مَا","translation":"তার","audioUrl":"wbw/007_129_009.mp3","charTypeName":"word"},{"id":77784,"position":10,"arabic":"جِئْتَنَا ۚ","translation":"আমাদের কাছে তুমি এসেছো\"","audioUrl":"wbw/007_129_010.mp3","charTypeName":"word"},{"id":77786,"position":11,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/007_129_012.mp3","charTypeName":"word"},{"id":77787,"position":12,"arabic":"عَسَىٰ","translation":"\"শীঘ্রই","audioUrl":"wbw/007_129_013.mp3","charTypeName":"word"},{"id":77788,"position":13,"arabic":"رَبُّكُمْ","translation":"তোমাদের রব","audioUrl":"wbw/007_129_014.mp3","charTypeName":"word"},{"id":77789,"position":14,"arabic":"أَن","translation":"যে","audioUrl":"wbw/007_129_015.mp3","charTypeName":"word"},{"id":77790,"position":15,"arabic":"يُهْلِكَ","translation":"ধ্বংস করবেন","audioUrl":"wbw/007_129_016.mp3","charTypeName":"word"},{"id":77791,"position":16,"arabic":"عَدُوَّكُمْ","translation":"শত্রুকে তোমাদের","audioUrl":"wbw/007_129_017.mp3","charTypeName":"word"},{"id":77792,"position":17,"arabic":"وَيَسْتَخْلِفَكُمْ","translation":"ও স্থলাভিষিক্ত করবেন তোমাদেরকে","audioUrl":"wbw/007_129_018.mp3","charTypeName":"word"},{"id":77793,"position":18,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/007_129_019.mp3","charTypeName":"word"},{"id":77794,"position":19,"arabic":"ٱلْأَرْضِ","translation":"জমিনের","audioUrl":"wbw/007_129_020.mp3","charTypeName":"word"},{"id":77795,"position":20,"arabic":"فَيَنظُرَ","translation":"অতঃপর  তিনি দেখবেন","audioUrl":"wbw/007_129_021.mp3","charTypeName":"word"},{"id":77796,"position":21,"arabic":"كَيْفَ","translation":"কিরূপ","audioUrl":"wbw/007_129_022.mp3","charTypeName":"word"},{"id":77797,"position":22,"arabic":"تَعْمَلُونَ","translation":"তোমরা কাজ করো\"","audioUrl":"wbw/007_129_023.mp3","charTypeName":"word"},{"id":77798,"position":23,"arabic":"١٢٩","translation":"(১২৯)","audioUrl":null,"charTypeName":"end"}]},{"number":130,"arabic":"وَلَقَدْ أَخَذْنَآ ءَالَ فِرْعَوْنَ بِٱلسِّنِينَ وَنَقْصٍۢ مِّنَ ٱلثَّمَرَٰتِ لَعَلَّهُمْ يَذَّكَّرُونَ","translation":"And most certainly did We overwhelm Pharaoh's people with drought and scarcity of fruits, so that they might take it to heart.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1084.mp3","surahId":7,"words":[{"id":77991,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/007_130_001.mp3","charTypeName":"word"},{"id":77992,"position":2,"arabic":"أَخَذْنَآ","translation":"আমরা ধরেছিলাম","audioUrl":"wbw/007_130_002.mp3","charTypeName":"word"},{"id":77993,"position":3,"arabic":"ءَالَ","translation":"অনুসারীদেরকে","audioUrl":"wbw/007_130_003.mp3","charTypeName":"word"},{"id":77994,"position":4,"arabic":"فِرْعَوْنَ","translation":"ফিরাউনের","audioUrl":"wbw/007_130_004.mp3","charTypeName":"word"},{"id":77995,"position":5,"arabic":"بِٱلسِّنِينَ","translation":"দ্বারা দুর্ভিক্ষের","audioUrl":"wbw/007_130_005.mp3","charTypeName":"word"},{"id":77996,"position":6,"arabic":"وَنَقْصٍۢ","translation":"ও ক্ষতির (দ্বারা)","audioUrl":"wbw/007_130_006.mp3","charTypeName":"word"},{"id":77997,"position":7,"arabic":"مِّنَ","translation":"কিছু","audioUrl":"wbw/007_130_007.mp3","charTypeName":"word"},{"id":77998,"position":8,"arabic":"ٱلثَّمَرَٰتِ","translation":"ফল-ফসলের","audioUrl":"wbw/007_130_008.mp3","charTypeName":"word"},{"id":77999,"position":9,"arabic":"لَعَلَّهُمْ","translation":"যাতে তারা","audioUrl":"wbw/007_130_009.mp3","charTypeName":"word"},{"id":78000,"position":10,"arabic":"يَذَّكَّرُونَ","translation":"উপদেশ গ্রহণ করে","audioUrl":"wbw/007_130_010.mp3","charTypeName":"word"},{"id":78001,"position":11,"arabic":"١٣٠","translation":"(১৩০)","audioUrl":null,"charTypeName":"end"}]}]}