{"id":165,"ayahs":[{"number":121,"arabic":"قَالُوٓا۟ ءَامَنَّا بِرَبِّ ٱلْعَٰلَمِينَ","translation":"[and] exclaiming: \"We have come to believe in the Sustainer of all the worlds,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1075.mp3","surahId":7,"words":[{"id":76583,"position":1,"arabic":"قَالُوٓا۟","translation":"তারা বললো","audioUrl":"wbw/007_121_001.mp3","charTypeName":"word"},{"id":76584,"position":2,"arabic":"ءَامَنَّا","translation":"\"ঈমান আনলাম আমরা","audioUrl":"wbw/007_121_002.mp3","charTypeName":"word"},{"id":76585,"position":3,"arabic":"بِرَبِّ","translation":"উপর রবের","audioUrl":"wbw/007_121_003.mp3","charTypeName":"word"},{"id":76586,"position":4,"arabic":"ٱلْعَـٰلَمِينَ","translation":"বিশ্বজগতের","audioUrl":"wbw/007_121_004.mp3","charTypeName":"word"},{"id":76587,"position":5,"arabic":"١٢١","translation":"(১২১)","audioUrl":null,"charTypeName":"end"}]},{"number":122,"arabic":"رَبِّ مُوسَىٰ وَهَٰرُونَ","translation":"the Sustainer of Moses and Aaron!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1076.mp3","surahId":7,"words":[{"id":76655,"position":1,"arabic":"رَبِّ","translation":"রব","audioUrl":"wbw/007_122_001.mp3","charTypeName":"word"},{"id":76656,"position":2,"arabic":"مُوسَىٰ","translation":"মূসার","audioUrl":"wbw/007_122_002.mp3","charTypeName":"word"},{"id":76657,"position":3,"arabic":"وَهَـٰرُونَ","translation":"ও হারূনের\"","audioUrl":"wbw/007_122_003.mp3","charTypeName":"word"},{"id":76658,"position":4,"arabic":"١٢٢","translation":"(১২২)","audioUrl":null,"charTypeName":"end"}]},{"number":123,"arabic":"قَالَ فِرْعَوْنُ ءَامَنتُم بِهِۦ قَبْلَ أَنْ ءَاذَنَ لَكُمْ ۖ إِنَّ هَٰذَا لَمَكْرٌۭ مَّكَرْتُمُوهُ فِى ٱلْمَدِينَةِ لِتُخْرِجُوا۟ مِنْهَآ أَهْلَهَا ۖ فَسَوْفَ تَعْلَمُونَ","translation":"Said Pharaoh: \"Have you come to believe in him ere I have given you permission? Behold, this is indeed a plot which you have cunningly devised in this [my] city in order to drive out its people hence! But in time y