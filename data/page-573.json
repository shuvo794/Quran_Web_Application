{"id":573,"ayahs":[{"number":14,"arabic":"وَأَنَّا مِنَّا ٱلْمُسْلِمُونَ وَمِنَّا ٱلْقَٰسِطُونَ ۖ فَمَنْ أَسْلَمَ فَأُو۟لَٰٓئِكَ تَحَرَّوْا۟ رَشَدًۭا","translation":"\"'Yet [it is true] that among us are such as have surrendered themselves to God - just as there are among us such as have abandoned themselves to wrongdoing. Now as for those who surrender themselves to Him - it is they that have attained to consciousness of what is right;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5461.mp3","surahId":72,"words":[{"id":16271,"position":1,"arabic":"وَأَنَّا","translation":"এবং যে","audioUrl":"wbw/072_014_001.mp3","charTypeName":"word"},{"id":16272,"position":2,"arabic":"مِنَّا","translation":"আমাদের মধ্যে","audioUrl":"wbw/072_014_002.mp3","charTypeName":"word"},{"id":16273,"position":3,"arabic":"ٱلْمُسْلِمُونَ","translation":"মুসলমান (আছে)","audioUrl":"wbw/072_014_003.mp3","charTypeName":"word"},{"id":16274,"position":4,"arabic":"وَمِنَّا","translation":"আবার আমাদের মধ্যে","audioUrl":"wbw/072_014_004.mp3","charTypeName":"word"},{"id":16275,"position":5,"arabic":"ٱلْقَـٰسِطُونَ ۖ","translation":"সত্যবিমুখও (আছে)","audioUrl":"wbw/072_014_005.mp3","charTypeName":"word"},{"id":16277,"position":6,"arabic":"فَمَنْ","translation":"যে অতএব","audioUrl":"wbw/072_014_007.mp3","charTypeName":"word"},{"id":16278,"position":7,"arabic":"أَسْلَمَ","translation":"ইসলাম গ্রহণও করেছে","audioUrl":"wbw/072_014_008.mp3","charTypeName":"word"},{"id":16279,"position":8,"arabic":"فَأُو۟لَـٰٓئِكَ","translation":"ঐসব লোক তবে","audioUrl":"wbw/072_014_009.mp3","charTypeName":"word"},{"id":16280,"position":9,"arabic":"تَحَرَّوْا۟","translation":"বেছে নিয়েছে","audioUrl":"wbw/072_014_010.mp3","charTypeName":"word"},{"id":16281,"position":10,"arabic":"رَشَدًۭا","translation":"সত্য পথ","audioUrl":"wbw/072_014_011.mp3","charTypeName":"word"},{"id":16282,"position":11,"arabic":"١٤","translation":"(১৪)","audioUrl":null,"charTypeName":"end"}]},{"number":15,"arabic":"وَأَمَّا ٱلْقَٰسِطُونَ فَكَانُوا۟ لِجَهَنَّمَ حَطَبًۭا","translation":"but as for those who abandon themselves to wrongdoing - they are indeed but fuel for [the fires of] hell!’\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5462.mp3","surahId":72,"words":[{"id":17139,"position":1,"arabic":"وَأَمَّا","translation":"অপরপক্ষে","audioUrl":"wbw/072_015_001.mp3","charTypeName":"word"},{"id":17140,"position":2,"arabic":"ٱلْقَـٰسِطُونَ","translation":"সত্য বিমুখরা","audioUrl":"wbw/072_015_002.mp3","charTypeName":"word"},{"id":17141,"position":3,"arabic":"فَكَانُوا۟","translation":"তারা অতঃপর হলো","audioUrl":"wbw/072_015_003.mp3","charTypeName":"word"},{"id":17142,"position":4,"arabic":"لِجَهَنَّمَ","translation":"জাহান্নামের জন্য","audioUrl":"wbw/072_015_004.mp3","charTypeName":"word"},{"id":17143,"position":5,"arabic":"حَطَبًۭا","translation":"ইন্ধন\"","audioUrl":"wbw/072_015_005.mp3","charTypeName":"word"},{"id":17144,"position":6,"arabic":"١٥","translation":"(১৫)","audioUrl":null,"charTypeName":"end"}]},{"number":16,"arabic":"وَأَلَّوِ ٱسْتَقَٰمُوا۟ عَلَى ٱلطَّرِيقَةِ لَأَسْقَيْنَٰهُم مَّآءً غَدَقًۭا","translation":"[KNOW,] THEN, that if they [who have heard Our call] keep firmly to the [right] path, We shall certainly shower them with blessings abundant,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5463.mp3","surahId":72,"words":[{"id":18533,"position":1,"arabic":"وَأَلَّوِ","translation":"এবং যদি","audioUrl":"wbw/072_016_001.mp3","charTypeName":"word"},{"id":18534,"position":2,"arabic":"ٱسْتَقَـٰمُوا۟","translation":"তারা দৃঢ় থাকতো","audioUrl":"wbw/072_016_002.mp3","charTypeName":"word"},{"id":18535,"position":3,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/072_016_003.mp3","charTypeName":"word"},{"id":18536,"position":4,"arabic":"ٱلطَّرِيقَةِ","translation":"সত্য পথের","audioUrl":"wbw/072_016_004.mp3","charTypeName":"word"},{"id":18537,"position":5,"arabic":"لَأَسْقَيْنَـٰهُم","translation":"তাদের আমরা পান অবশ্যই করাতাম","audioUrl":"wbw/072_016_005.mp3","charTypeName":"word"},{"id":18538,"position":6,"arabic":"مَّآءً","translation":"পানি","audioUrl":"wbw/072_016_006.mp3","charTypeName":"word"},{"id":18539,"position":7,"arabic":"غَدَقًۭا","translation":"প্রচুর","audioUrl":"wbw/072_016_007.mp3","charTypeName":"word"},{"id":18540,"position":8,"arabic":"١٦","translation":"(১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":17,"arabic":"لِّنَفْتِنَهُمْ فِيهِ ۚ وَمَن يُعْرِضْ عَن ذِكْرِ رَبِّهِۦ يَسْلُكْهُ عَذَابًۭا صَعَدًۭا","translation":"so as to test them by this means: for he who shall turn away from the remembrance of his Sustainer, him will He cause to undergo suffering most grievous.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5464.mp3","surahId":72,"words":[{"id":19533,"position":1,"arabic":"لِّنَفْتِنَهُمْ","translation":"তাদের পরীক্ষা আমরা যেন করি","audioUrl":"wbw/072_017_001.mp3","charTypeName":"word"},{"id":19534,"position":2,"arabic":"فِيهِ ۚ","translation":"তার মধ্যে","audioUrl":"wbw/072_017_002.mp3","charTypeName":"word"},{"id":19536,"position":3,"arabic":"وَمَن","translation":"এবং যে","audioUrl":"wbw/072_017_004.mp3","charTypeName":"word"},{"id":19537,"position":4,"arabic":"يُعْرِضْ","translation":"মুখ ফেরাবে","audioUrl":"wbw/072_017_005.mp3","charTypeName":"word"},{"id":19538,"position":5,"arabic":"عَن","translation":"থেকে","audioUrl":"wbw/072_017_006.mp3","charTypeName":"word"},{"id":19539,"position":6,"arabic":"ذِكْرِ","translation":"স্মরণ","audioUrl":"wbw/072_017_007.mp3","charTypeName":"word"},{"id":19540,"position":7,"arabic":"رَبِّهِۦ","translation":"তার রবের উপর","audioUrl":"wbw/072_017_008.mp3","charTypeName":"word"},{"id":19541,"position":8,"arabic":"يَسْلُكْهُ","translation":"তাকে প্রবেশ করাবে","audioUrl":"wbw/072_017_009.mp3","charTypeName":"word"},{"id":19542,"position":9,"arabic":"عَذَابًۭا","translation":"আযাবে","audioUrl":"wbw/072_017_010.mp3","charTypeName":"word"},{"id":19543,"position":10,"arabic":"صَعَدًۭا","translation":"দুঃসহ","audioUrl":"wbw/072_017_011.mp3","charTypeName":"word"},{"id":19544,"position":11,"arabic":"١٧","translation":"(১৭)","audioUrl":null,"charTypeName":"end"}]},{"number":18,"arabic":"وَأَنَّ ٱلْمَسَٰجِدَ لِلَّهِ فَلَا تَدْعُوا۟ مَعَ ٱللَّهِ أَحَدًۭا","translation":"And [know] that all worship is due to God [alone]: hence, do not invoke anyone side by side with God!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5465.mp3","surahId":72,"words":[{"id":20624,"position":1,"arabic":"وَأَنَّ","translation":"এবং যে","audioUrl":"wbw/072_018_001.mp3","charTypeName":"word"},{"id":20625,"position":2,"arabic":"ٱلْمَسَـٰجِدَ","translation":"মসজিদ সমূহ","audioUrl":"wbw/072_018_002.mp3","charTypeName":"word"},{"id":20626,"position":3,"arabic":"لِلَّهِ","translation":"আল্লাহর জন্যে","audioUrl":"wbw/072_018_003.mp3","charTypeName":"word"},{"id":20627,"position":4,"arabic":"فَلَا","translation":"না অতএব","audioUrl":"wbw/072_018_004.mp3","charTypeName":"word"},{"id":20628,"position":5,"arabic":"تَدْعُوا۟","translation":"তোমরা ডেকো","audioUrl":"wbw/072_018_005.mp3","charTypeName":"word"},{"id":20629,"position":6,"arabic":"مَعَ","translation":"সাথে","audioUrl":"wbw/072_018_006.mp3","charTypeName":"word"},{"id":20630,"position":7,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/072_018_007.mp3","charTypeName":"word"},{"id":20631,"position":8,"arabic":"أَحَدًۭا","translation":"কাউকে","audioUrl":"wbw/072_018_008.mp3","charTypeName":"word"},{"id":20632,"position":9,"arabic":"١٨","translation":"(১৮)","audioUrl":null,"charTypeName":"end"}]},{"number":19,"arabic":"وَأَنَّهُۥ لَمَّا قَامَ عَبْدُ ٱللَّهِ يَدْعُوهُ كَادُوا۟ يَكُونُونَ عَلَيْهِ لِبَدًۭا","translation":"Yet [thus it is] that whenever a servant of God stands up in prayer to Him, they [who are bent on denying the truth] would gladly overwhelm him with their crowds.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5466.mp3","surahId":72,"words":[{"id":21451,"position":1,"arabic":"وَأَنَّهُۥ","translation":"এবং যে","audioUrl":"wbw/072_019_001.mp3","charTypeName":"word"},{"id":21452,"position":2,"arabic":"لَمَّا","translation":"যখন","audioUrl":"wbw/072_019_002.mp3","charTypeName":"word"},{"id":21453,"position":3,"arabic":"قَامَ","translation":"দাঁড়াল","audioUrl":"wbw/072_019_003.mp3","charTypeName":"word"},{"id":21454,"position":4,"arabic":"عَبْدُ","translation":"বান্দা","audioUrl":"wbw/072_019_004.mp3","charTypeName":"word"},{"id":21455,"position":5,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/072_019_005.mp3","charTypeName":"word"},{"id":21456,"position":6,"arabic":"يَدْعُوهُ","translation":"তাঁকে ডাকতে","audioUrl":"wbw/072_019_006.mp3","charTypeName":"word"},{"id":21457,"position":7,"arabic":"كَادُوا۟","translation":"করল (যেন)","audioUrl":"wbw/072_019_007.mp3","charTypeName":"word"},{"id":21458,"position":8,"arabic":"يَكُونُونَ","translation":"তারা উপক্রম","audioUrl":"wbw/072_019_008.mp3","charTypeName":"word"},{"id":21459,"position":9,"arabic":"عَلَيْهِ","translation":"তার উপর","audioUrl":"wbw/072_019_009.mp3","charTypeName":"word"},{"id":21460,"position":10,"arabic":"لِبَدًۭا","translation":"ঘিরে ধরার","audioUrl":"wbw/072_019_010.mp3","charTypeName":"word"},{"id":21461,"position":11,"arabic":"١٩","translation":"(১৯)","audioUrl":null,"charTypeName":"end"}]},{"number":20,"arabic":"قُلْ إِنَّمَآ أَدْعُوا۟ رَبِّى وَلَآ أُشْرِكُ بِهِۦٓ أَحَدًۭا","translation":"Say: \"I invoke my Sustainer alone, for I do not ascribe divinity to anyone beside Him.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5467.mp3","surahId":72,"words":[{"id":22766,"position":1,"arabic":"قُلْ","translation":"বল","audioUrl":"wbw/072_020_001.mp3","charTypeName":"word"},{"id":22767,"position":2,"arabic":"إِنَّمَآ","translation":"\"মুলত","audioUrl":"wbw/072_020_002.mp3","charTypeName":"word"},{"id":22768,"position":3,"arabic":"أَدْعُوا۟","translation":"আমি ডাকি","audioUrl":"wbw/072_020_003.mp3","charTypeName":"word"},{"id":22769,"position":4,"arabic":"رَبِّى","translation":"আমার রবকে","audioUrl":"wbw/072_020_004.mp3","charTypeName":"word"},{"id":22770,"position":5,"arabic":"وَلَآ","translation":"এবং না","audioUrl":"wbw/072_020_005.mp3","charTypeName":"word"},{"id":22771,"position":6,"arabic":"أُشْرِكُ","translation":"শরীক করি","audioUrl":"wbw/072_020_006.mp3","charTypeName":"word"},{"id":22772,"position":7,"arabic":"بِهِۦٓ","translation":"তার সাথে","audioUrl":"wbw/072_020_007.mp3","charTypeName":"word"},{"id":22773,"position":8,"arabic":"أَحَدًۭا","translation":"কাউকে\"","audioUrl":"wbw/072_020_008.mp3","charTypeName":"word"},{"id":22774,"position":9,"arabic":"٢٠","translation":"(২০)","audioUrl":null,"charTypeName":"end"}]},{"number":21,"arabic":"قُلْ إِنِّى لَآ أَمْلِكُ لَكُمْ ضَرًّۭا وَلَا رَشَدًۭا","translation":"Say: \"Verily, it is not in my power to cause you harm or to endow you with consciousness of what is right.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5468.mp3","surahId":72,"words":[{"id":23945,"position":1,"arabic":"قُلْ","translation":"বল","audioUrl":"wbw/072_021_001.mp3","charTypeName":"word"},{"id":23946,"position":2,"arabic":"إِنِّى","translation":"\"আমি নিশ্চয়","audioUrl":"wbw/072_021_002.mp3","charTypeName":"word"},{"id":23947,"position":3,"arabic":"لَآ","translation":"না","audioUrl":"wbw/072_021_003.mp3","charTypeName":"word"},{"id":23948,"position":4,"arabic":"أَمْلِكُ","translation":"ক্ষমতা রাখি আমি","audioUrl":"wbw/072_021_004.mp3","charTypeName":"word"},{"id":23949,"position":5,"arabic":"لَكُمْ","translation":"তোমাদের জন্যে","audioUrl":"wbw/072_021_005.mp3","charTypeName":"word"},{"id":23950,"position":6,"arabic":"ضَرًّۭا","translation":"ক্ষতির","audioUrl":"wbw/072_021_006.mp3","charTypeName":"word"},{"id":23951,"position":7,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/072_021_007.mp3","charTypeName":"word"},{"id":23952,"position":8,"arabic":"رَشَدًۭا","translation":"কল্যাণের\"","audioUrl":"wbw/072_021_008.mp3","charTypeName":"word"},{"id":23953,"position":9,"arabic":"٢١","translation":"(২১)","audioUrl":null,"charTypeName":"end"}]},{"number":22,"arabic":"قُلْ إِنِّى لَن يُجِيرَنِى مِنَ ٱللَّهِ أَحَدٌۭ وَلَنْ أَجِدَ مِن دُونِهِۦ مُلْتَحَدًا","translation":"Say: \"Verily, no one could ever protect me from God, nor could I ever find a place to hide from Him","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5469.mp3","surahId":72,"words":[{"id":24921,"position":1,"arabic":"قُلْ","translation":"বল","audioUrl":"wbw/072_022_001.mp3","charTypeName":"word"},{"id":24922,"position":2,"arabic":"إِنِّى","translation":"\"আমি নিশ্চয়","audioUrl":"wbw/072_022_002.mp3","charTypeName":"word"},{"id":24923,"position":3,"arabic":"لَن","translation":"কখন না","audioUrl":"wbw/072_022_003.mp3","charTypeName":"word"},{"id":24924,"position":4,"arabic":"يُجِيرَنِى","translation":"আশ্রয় দিতে পারে আমাকে","audioUrl":"wbw/072_022_004.mp3","charTypeName":"word"},{"id":24925,"position":5,"arabic":"مِنَ","translation":"থেকে","audioUrl":"wbw/072_022_005.mp3","charTypeName":"word"},{"id":24926,"position":6,"arabic":"ٱللَّهِ","translation":"আল্লাহ","audioUrl":"wbw/072_022_006.mp3","charTypeName":"word"},{"id":24927,"position":7,"arabic":"أَحَدٌۭ","translation":"কেউ","audioUrl":"wbw/072_022_007.mp3","charTypeName":"word"},{"id":24928,"position":8,"arabic":"وَلَنْ","translation":"এবং কখন না","audioUrl":"wbw/072_022_008.mp3","charTypeName":"word"},{"id":24929,"position":9,"arabic":"أَجِدَ","translation":"পাব আমি","audioUrl":"wbw/072_022_009.mp3","charTypeName":"word"},{"id":24930,"position":10,"arabic":"مِن","translation":"তাঁকে","audioUrl":"wbw/072_022_010.mp3","charTypeName":"word"},{"id":24931,"position":11,"arabic":"دُونِهِۦ","translation":"ছাড়া","audioUrl":"wbw/072_022_011.mp3","charTypeName":"word"},{"id":24932,"position":12,"arabic":"مُلْتَحَدًا","translation":"আশ্রয়স্থল","audioUrl":"wbw/072_022_012.mp3","charTypeName":"word"},{"id":24933,"position":13,"arabic":"٢٢","translation":"(২২)","audioUrl":null,"charTypeName":"end"}]},{"number":23,"arabic":"إِلَّا بَلَٰغًۭا مِّنَ ٱللَّهِ وَرِسَٰلَٰتِهِۦ ۚ وَمَن يَعْصِ ٱللَّهَ وَرَسُولَهُۥ فَإِنَّ لَهُۥ نَارَ جَهَنَّمَ خَٰلِدِينَ فِيهَآ أَبَدًا","translation":"if I should fail to convey [to the world whatever illumination comes to me] from God and His messages.\" Now as for him who rebels against God and His Apostle - verily, the fire of hell awaits him, therein to abide beyond the count of time.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5470.mp3","surahId":72,"words":[{"id":25983,"position":1,"arabic":"إِلَّا","translation":"এছাড়া নয় (আমার কাজ)","audioUrl":"wbw/072_023_001.mp3","charTypeName":"word"},{"id":25984,"position":2,"arabic":"بَلَـٰغًۭا","translation":"পৌঁছান","audioUrl":"wbw/072_023_002.mp3","charTypeName":"word"},{"id":25985,"position":3,"arabic":"مِّنَ","translation":"হতে","audioUrl":"wbw/072_023_003.mp3","charTypeName":"word"},{"id":25986,"position":4,"arabic":"ٱللَّهِ","translation":"আল্লাহ","audioUrl":"wbw/072_023_004.mp3","charTypeName":"word"},{"id":25987,"position":5,"arabic":"وَرِسَـٰلَـٰتِهِۦ ۚ","translation":"ও তাঁর পয়গাম সমূহ\"","audioUrl":"wbw/072_023_005.mp3","charTypeName":"word"},{"id":25989,"position":6,"arabic":"وَمَن","translation":"এবং যে","audioUrl":"wbw/072_023_007.mp3","charTypeName":"word"},{"id":25990,"position":7,"arabic":"يَعْصِ","translation":"অমান্য করবে","audioUrl":"wbw/072_023_008.mp3","charTypeName":"word"},{"id":25991,"position":8,"arabic":"ٱللَّهَ","translation":"আল্লাহর","audioUrl":"wbw/072_023_009.mp3","charTypeName":"word"},{"id":25992,"position":9,"arabic":"وَرَسُولَهُۥ","translation":"ও তাঁর রাসূলের","audioUrl":"wbw/072_023_010.mp3","charTypeName":"word"},{"id":25993,"position":10,"arabic":"فَإِنَّ","translation":"নিশ্চয় অতঃপর","audioUrl":"wbw/072_023_011.mp3","charTypeName":"word"},{"id":25994,"position":11,"arabic":"لَهُۥ","translation":"তার জন্যে","audioUrl":"wbw/072_023_012.mp3","charTypeName":"word"},{"id":25995,"position":12,"arabic":"نَارَ","translation":"আগুন","audioUrl":"wbw/072_023_013.mp3","charTypeName":"word"},{"id":25996,"position":13,"arabic":"جَهَنَّمَ","translation":"জাহান্নামের জন্য","audioUrl":"wbw/072_023_014.mp3","charTypeName":"word"},{"id":25997,"position":14,"arabic":"خَـٰلِدِينَ","translation":"তারা স্থায়ী হবে","audioUrl":"wbw/072_023_015.mp3","charTypeName":"word"},{"id":25998,"position":15,"arabic":"فِيهَآ","translation":"তার মধ্যে","audioUrl":"wbw/072_023_016.mp3","charTypeName":"word"},{"id":25999,"position":16,"arabic":"أَبَدًا","translation":"চিরকাল","audioUrl":"wbw/072_023_017.mp3","charTypeName":"word"},{"id":26000,"position":17,"arabic":"٢٣","translation":"(২৩)","audioUrl":null,"charTypeName":"end"}]},{"number":24,"arabic":"حَتَّىٰٓ إِذَا رَأَوْا۟ مَا يُوعَدُونَ فَسَيَعْلَمُونَ مَنْ أَضْعَفُ نَاصِرًۭا وَأَقَلُّ عَدَدًۭا","translation":"[Let them, then, wait] until the time when they behold that [doom] of which they were forewarned: for then they will come to understand which [kind of man] is more helpless and counts for less!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5471.mp3","surahId":72,"words":[{"id":27072,"position":1,"arabic":"حَتَّىٰٓ","translation":"যতক্ষণ না","audioUrl":"wbw/072_024_001.mp3","charTypeName":"word"},{"id":27073,"position":2,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/072_024_002.mp3","charTypeName":"word"},{"id":27074,"position":3,"arabic":"رَأَوْا۟","translation":"তারা দেখবে","audioUrl":"wbw/072_024_003.mp3","charTypeName":"word"},{"id":27075,"position":4,"arabic":"مَا","translation":"যা","audioUrl":"wbw/072_024_004.mp3","charTypeName":"word"},{"id":27076,"position":5,"arabic":"يُوعَدُونَ","translation":"তাদের ওয়াদা হয়েছে করা","audioUrl":"wbw/072_024_005.mp3","charTypeName":"word"},{"id":27077,"position":6,"arabic":"فَسَيَعْلَمُونَ","translation":"তারা জানতে শীঘ্রই অতঃপর পারবে","audioUrl":"wbw/072_024_006.mp3","charTypeName":"word"},{"id":27078,"position":7,"arabic":"مَنْ","translation":"কেউ","audioUrl":"wbw/072_024_007.mp3","charTypeName":"word"},{"id":27079,"position":8,"arabic":"أَضْعَفُ","translation":"অধিক দুর্বল","audioUrl":"wbw/072_024_008.mp3","charTypeName":"word"},{"id":27080,"position":9,"arabic":"نَاصِرًۭا","translation":"সাহায্যকারী","audioUrl":"wbw/072_024_009.mp3","charTypeName":"word"},{"id":27081,"position":10,"arabic":"وَأَقَلُّ","translation":"এবং অতি কম","audioUrl":"wbw/072_024_010.mp3","charTypeName":"word"},{"id":27082,"position":11,"arabic":"عَدَدًۭا","translation":"সংখ্যায়","audioUrl":"wbw/072_024_011.mp3","charTypeName":"word"},{"id":27083,"position":12,"arabic":"٢٤","translation":"(২৪)","audioUrl":null,"charTypeName":"end"}]},{"number":25,"arabic":"قُلْ إِنْ أَدْرِىٓ أَقَرِيبٌۭ مَّا تُوعَدُونَ أَمْ يَجْعَلُ لَهُۥ رَبِّىٓ أَمَدًا","translation":"Say: \"I do not know whether that [doom] of which you were forewarned is near, or whether my Sustainer has set for it a distant term.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5472.mp3","surahId":72,"words":[{"id":28057,"position":1,"arabic":"قُلْ","translation":"বল","audioUrl":"wbw/072_025_001.mp3","charTypeName":"word"},{"id":28058,"position":2,"arabic":"إِنْ","translation":"\"না","audioUrl":"wbw/072_025_002.mp3","charTypeName":"word"},{"id":28059,"position":3,"arabic":"أَدْرِىٓ","translation":"জানি আমি","audioUrl":"wbw/072_025_003.mp3","charTypeName":"word"},{"id":28060,"position":4,"arabic":"أَقَرِيبٌۭ","translation":"নিকটবর্তী কী","audioUrl":"wbw/072_025_004.mp3","charTypeName":"word"},{"id":28061,"position":5,"arabic":"مَّا","translation":"যা","audioUrl":"wbw/072_025_005.mp3","charTypeName":"word"},{"id":28062,"position":6,"arabic":"تُوعَدُونَ","translation":"তোমাদের ওয়াদা হচ্ছে করা","audioUrl":"wbw/072_025_006.mp3","charTypeName":"word"},{"id":28063,"position":7,"arabic":"أَمْ","translation":"অথবা","audioUrl":"wbw/072_025_007.mp3","charTypeName":"word"},{"id":28064,"position":8,"arabic":"يَجْعَلُ","translation":"করেছেন","audioUrl":"wbw/072_025_008.mp3","charTypeName":"word"},{"id":28065,"position":9,"arabic":"لَهُۥ","translation":"তার জন্যে","audioUrl":"wbw/072_025_009.mp3","charTypeName":"word"},{"id":28066,"position":10,"arabic":"رَبِّىٓ","translation":"আমার রব","audioUrl":"wbw/072_025_010.mp3","charTypeName":"word"},{"id":28067,"position":11,"arabic":"أَمَدًا","translation":"দীর্ঘ মেয়াদ","audioUrl":"wbw/072_025_011.mp3","charTypeName":"word"},{"id":28068,"position":12,"arabic":"٢٥","translation":"(২৫)","audioUrl":null,"charTypeName":"end"}]},{"number":26,"arabic":"عَٰلِمُ ٱلْغَيْبِ فَلَا يُظْهِرُ عَلَىٰ غَيْبِهِۦٓ أَحَدًا","translation":"He [alone] knows that which is beyond the reach of a created being's perception, and to none does He disclose aught of the mysteries of His Own unfathomable knowledge,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5473.mp3","surahId":72,"words":[{"id":28717,"position":1,"arabic":"عَـٰلِمُ","translation":"আবহিত তিনি","audioUrl":"wbw/072_026_001.mp3","charTypeName":"word"},{"id":28718,"position":2,"arabic":"ٱلْغَيْبِ","translation":"গায়েব","audioUrl":"wbw/072_026_002.mp3","charTypeName":"word"},{"id":28719,"position":3,"arabic":"فَلَا","translation":"না অতএব","audioUrl":"wbw/072_026_003.mp3","charTypeName":"word"},{"id":28720,"position":4,"arabic":"يُظْهِرُ","translation":"তিনি প্রকাশ করেন","audioUrl":"wbw/072_026_004.mp3","charTypeName":"word"},{"id":28721,"position":5,"arabic":"عَلَىٰ","translation":"সম্পর্কে","audioUrl":"wbw/072_026_005.mp3","charTypeName":"word"},{"id":28722,"position":6,"arabic":"غَيْبِهِۦٓ","translation":"তাঁর গায়েব","audioUrl":"wbw/072_026_006.mp3","charTypeName":"word"},{"id":28723,"position":7,"arabic":"أَحَدًا","translation":"কাউকে","audioUrl":"wbw/072_026_007.mp3","charTypeName":"word"},{"id":28724,"position":8,"arabic":"٢٦","translation":"(২৬)","audioUrl":null,"charTypeName":"end"}]},{"number":27,"arabic":"إِلَّا مَنِ ٱرْتَضَىٰ مِن رَّسُولٍۢ فَإِنَّهُۥ يَسْلُكُ مِنۢ بَيْنِ يَدَيْهِ وَمِنْ خَلْفِهِۦ رَصَدًۭا","translation":"unless it be to an apostle whom He has been pleased to elect [there for]: and then He sends forth [the forces of heaven] to watch over him in whatever lies open before him and in what is beyond his ken –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5474.mp3","surahId":72,"words":[{"id":29848,"position":1,"arabic":"إِلَّا","translation":"কিন্তু","audioUrl":"wbw/072_027_001.mp3","charTypeName":"word"},{"id":29849,"position":2,"arabic":"مَنِ","translation":"যাকে","audioUrl":"wbw/072_027_002.mp3","charTypeName":"word"},{"id":29850,"position":3,"arabic":"ٱرْتَضَىٰ","translation":"তিনি রাজী হন","audioUrl":"wbw/072_027_003.mp3","charTypeName":"word"},{"id":29851,"position":4,"arabic":"مِن","translation":"মধ্যে","audioUrl":"wbw/072_027_004.mp3","charTypeName":"word"},{"id":29852,"position":5,"arabic":"رَّسُولٍۢ","translation":"রসূলের","audioUrl":"wbw/072_027_005.mp3","charTypeName":"word"},{"id":29853,"position":6,"arabic":"فَإِنَّهُۥ","translation":"তিনি নিশ্চয় অতঃপর","audioUrl":"wbw/072_027_006.mp3","charTypeName":"word"},{"id":29854,"position":7,"arabic":"يَسْلُكُ","translation":"লাগিয়ে দেন","audioUrl":"wbw/072_027_007.mp3","charTypeName":"word"},{"id":29855,"position":8,"arabic":"مِنۢ","translation":"থেকে কর","audioUrl":"wbw/072_027_008.mp3","charTypeName":"word"},{"id":29856,"position":9,"arabic":"بَيْنِ","translation":"তার আগে","audioUrl":"wbw/072_027_009.mp3","charTypeName":"word"},{"id":29857,"position":10,"arabic":"يَدَيْهِ","translation":"তার আগে","audioUrl":"wbw/072_027_010.mp3","charTypeName":"word"},{"id":29858,"position":11,"arabic":"وَمِنْ","translation":"এবং...","audioUrl":"wbw/072_027_011.mp3","charTypeName":"word"},{"id":29859,"position":12,"arabic":"خَلْفِهِۦ","translation":"তার পিছনে","audioUrl":"wbw/072_027_012.mp3","charTypeName":"word"},{"id":29860,"position":13,"arabic":"رَصَدًۭا","translation":"প্রহরা","audioUrl":"wbw/072_027_013.mp3","charTypeName":"word"},{"id":29861,"position":14,"arabic":"٢٧","translation":"(২৭)","audioUrl":null,"charTypeName":"end"}]},{"number":28,"arabic":"لِّيَعْلَمَ أَن قَدْ أَبْلَغُوا۟ رِسَ