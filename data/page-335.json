{"id":335,"ayahs":[{"number":24,"arabic":"وَهُدُوٓا۟ إِلَى ٱلطَّيِّبِ مِنَ ٱلْقَوْلِ وَهُدُوٓا۟ إِلَىٰ صِرَٰطِ ٱلْحَمِيدِ","translation":"for they were [willing to be] guided towards the best of all tenets, and so they were guided onto the way that leads to the One unto whom all praise is due.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2619.mp3","surahId":22,"words":[{"id":27019,"position":1,"arabic":"وَهُدُوٓا۟","translation":"এবং তাদেরকে সৎপথের দিশা দেয়া হয়েছে","audioUrl":"wbw/022_024_001.mp3","charTypeName":"word"},{"id":27020,"position":2,"arabic":"إِلَى","translation":"প্রতি","audioUrl":"wbw/022_024_002.mp3","charTypeName":"word"},{"id":27021,"position":3,"arabic":"ٱلطَّيِّبِ","translation":"পবিত্র","audioUrl":"wbw/022_024_003.mp3","charTypeName":"word"},{"id":27022,"position":4,"arabic":"مِنَ","translation":"থেকে","audioUrl":"wbw/022_024_004.mp3","charTypeName":"word"},{"id":27023,"position":5,"arabic":"ٱلْقَوْلِ","translation":"বাণীর (কবুলের)","audioUrl":"wbw/022_024_005.mp3","charTypeName":"word"},{"id":27024,"position":6,"arabic":"وَهُدُوٓا۟","translation":"পরিচালিত করা হয়েছে","audioUrl":"wbw/022_024_006.mp3","charTypeName":"word"},{"id":27025,"position":7,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/022_024_007.mp3","charTypeName":"word"},{"id":27026,"position":8,"arabic":"صِرَٰطِ","translation":"পথের","audioUrl":"wbw/022_024_008.mp3","charTypeName":"word"},{"id":27027,"position":9,"arabic":"ٱلْحَمِيدِ","translation":"প্রশংসিতের (অর্থাৎ আল্লাহর)","audioUrl":"wbw/022_024_009.mp3","charTypeName":"word"},{"id":27028,"position":10,"arabic":"٢٤","translation":"(২৪)","audioUrl":null,"charTypeName":"end"}]},{"number":25,"arabic":"إِنَّ ٱلَّذِينَ كَفَرُوا۟ وَيَصُدُّونَ عَن سَبِيلِ ٱللَّهِ وَٱلْمَسْجِدِ ٱلْحَرَامِ ٱلَّذِى جَعَلْنَٰهُ لِلنَّاسِ سَوَآءً ٱلْعَٰكِفُ فِيهِ وَٱلْبَادِ ۚ وَمَن يُرِدْ فِيهِ بِإِلْحَادٍۭ بِظُلْمٍۢ نُّذِقْهُ مِنْ عَذَابٍ أَلِيمٍۢ","translation":"BEHOLD, as for those who are bent on denying the truth and bar [others] from the path of God and from the Inviolable House of Worship which We have set up for all people alike - [both] those who dwell there and those who come from abroad - and all who seek to profane it by [deliberate] evildoing: [all] such shall We cause to taste grievous suffering in the life to come.]","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2620.mp3","surahId":22,"words":[{"id":28005,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/022_025_001.mp3","charTypeName":"word"},{"id":28006,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/022_025_002.mp3","charTypeName":"word"},{"id":28007,"position":3,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/022_025_003.mp3","charTypeName":"word"},{"id":28008,"position":4,"arabic":"وَيَصُدُّونَ","translation":"ও বাদা দেয়","audioUrl":"wbw/022_025_004.mp3","charTypeName":"word"},{"id":28009,"position":5,"arabic":"عَن","translation":"হ'তে","audioUrl":"wbw/022_025_005.mp3","charTypeName":"word"},{"id":28010,"position":6,"arabic":"سَبِيلِ","translation":"পথ","audioUrl":"wbw/022_025_006.mp3","charTypeName":"word"},{"id":28011,"position":7,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/022_025_007.mp3","charTypeName":"word"},{"id":28012,"position":8,"arabic":"وَٱلْمَسْجِدِ","translation":"ও মাসজিদে","audioUrl":"wbw/022_025_008.mp3","charTypeName":"word"},{"id":28013,"position":9,"arabic":"ٱلْحَرَامِ","translation":"হারাম (হ'তে)","audioUrl":"wbw/022_025_009.mp3","charTypeName":"word"},{"id":28014,"position":10,"arabic":"ٱلَّذِى","translation":"যা","audioUrl":"wbw/022_025_010.mp3","charTypeName":"word"},{"id":28015,"position":11,"arabic":"جَعَلْنَـٰهُ","translation":"আমরা করেছি তা","audioUrl":"wbw/022_025_011.mp3","charTypeName":"word"},{"id":28016,"position":12,"arabic":"لِلنَّاسِ","translation":"জন্যে মানুষের","audioUrl":"wbw/022_025_012.mp3","charTypeName":"word"},{"id":28017,"position":13,"arabic":"سَوَآءً","translation":"সমান (অধিকার)","audioUrl":"wbw/022_025_013.mp3","charTypeName":"word"},{"id":28018,"position":14,"arabic":"ٱلْعَـٰكِفُ","translation":"(অর্থাৎ যারা) স্থানীয় বাসিন্দা","audioUrl":"wbw/022_025_014.mp3","charTypeName":"word"},{"id":28019,"position":15,"arabic":"فِيهِ","translation":"তার মধ্যে","audioUrl":"wbw/022_025_015.mp3","charTypeName":"word"},{"id":28020,"position":16,"arabic":"وَٱلْبَادِ ۚ","translation":"ও বহিরাগত","audioUrl":"wbw/022_025_016.mp3","charTypeName":"word"},{"id":28022,"position":17,"arabic":"وَمَن","translation":"আর যে","audioUrl":"wbw/022_025_018.mp3","charTypeName":"word"},{"id":28023,"position":18,"arabic":"يُرِدْ","translation":"ইচ্ছে করে","audioUrl":"wbw/022_025_019.mp3","charTypeName":"word"},{"id":28024,"position":19,"arabic":"فِيهِ","translation":"তার মধ্যে","audioUrl":"wbw/022_025_020.mp3","charTypeName":"word"},{"id":28025,"position":20,"arabic":"بِإِلْحَادٍۭ","translation":"ব্যাপারে পাপ কাজের","audioUrl":"wbw/022_025_021.mp3","charTypeName":"word"},{"id":28026,"position":21,"arabic":"بِظُلْمٍۢ","translation":"অন্যায়ভাবে","audioUrl":"wbw/022_025_022.mp3","charTypeName":"word"},{"id":28027,"position":22,"arabic":"نُّذِقْهُ","translation":"তাকে আস্বাদন করাবো আমরা","audioUrl":"wbw/022_025_023.mp3","charTypeName":"word"},{"id":28028,"position":23,"arabic":"مِنْ","translation":"থেকে","audioUrl":"wbw/022_025_024.mp3","charTypeName":"word"},{"id":28029,"position":24,"arabic":"عَذَابٍ","translation":"শাস্তি","audioUrl":"wbw/022_025_025.mp3","charTypeName":"word"},{"id":28030,"position":25,"arabic":"أَلِيمٍۢ","translation":"নিদারুণ","audioUrl":"wbw/022_025_026.mp3","charTypeName":"word"},{"id":28031,"position":26,"arabic":"٢٥","translation":"(২৫)","audioUrl":null,"charTypeName":"end"}]},{"number":26,"arabic":"وَإِذْ بَوَّأْنَا لِإِبْرَٰهِيمَ مَكَانَ ٱلْبَيْتِ أَن لَّا تُشْرِكْ بِى شَيْـًۭٔا وَطَهِّرْ بَيْتِىَ لِلطَّآئِفِينَ وَٱلْقَآئِمِينَ وَٱلرُّكَّعِ ٱلسُّجُودِ","translation":"For, when We assigned unto Abraham the site of this Temple, [We said unto him:] “Do not ascribe divinity to aught beside Me!” and: “Purify My Temple for those who will walk around it, and those who will stand before it [in meditation], and those who will bow down and prostrate themselves [in prayer].”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2621.mp3","surahId":22,"words":[{"id":28920,"position":1,"arabic":"وَإِذْ","translation":"এবং (স্মরণ করো) যখন","audioUrl":"wbw/022_026_001.mp3","charTypeName":"word"},{"id":28921,"position":2,"arabic":"بَوَّأْنَا","translation":"আমরা নির্দিষ্ট করেছিলাম","audioUrl":"wbw/022_026_002.mp3","charTypeName":"word"},{"id":28922,"position":3,"arabic":"لِإِبْرَٰهِيمَ","translation":"জন্যে ইব্রাহীমের","audioUrl":"wbw/022_026_003.mp3","charTypeName":"word"},{"id":28923,"position":4,"arabic":"مَكَانَ","translation":"স্থান","audioUrl":"wbw/022_026_004.mp3","charTypeName":"word"},{"id":28924,"position":5,"arabic":"ٱلْبَيْتِ","translation":"(কা'বা) ঘরের","audioUrl":"wbw/022_026_005.mp3","charTypeName":"word"},{"id":28925,"position":6,"arabic":"أَن","translation":"\"যে","audioUrl":"wbw/022_026_006.mp3","charTypeName":"word"},{"id":28926,"position":7,"arabic":"لَّا","translation":"না","audioUrl":"wbw/022_026_007.mp3","charTypeName":"word"},{"id":28927,"position":8,"arabic":"تُشْرِكْ","translation":"শিরক করো","audioUrl":"wbw/022_026_008.mp3","charTypeName":"word"},{"id":28928,"position":9,"arabic":"بِى","translation":"সাথে আমার","audioUrl":"wbw/022_026_009.mp3","charTypeName":"word"},{"id":28929,"position":10,"arabic":"شَيْـًۭٔا","translation":"কোন কিছুর","audioUrl":"wbw/022_026_010.mp3","charTypeName":"word"},{"id":28930,"position":11,"arabic":"وَطَهِّرْ","translation":"ও পবিত্র রাখো","audioUrl":"wbw/022_026_011.mp3","charTypeName":"word"},{"id":28931,"position":12,"arabic":"بَيْتِىَ","translation":"আমার ঘরকে","audioUrl":"wbw/022_026_012.mp3","charTypeName":"word"},{"id":28932,"position":13,"arabic":"لِلطَّآئِفِينَ","translation":"জন্যে তওয়াফকারীদের","audioUrl":"wbw/022_026_013.mp3","charTypeName":"word"},{"id":28933,"position":14,"arabic":"وَٱلْقَآئِمِينَ","translation":"ও (সালাতে) দন্ডায়মানদের","audioUrl":"wbw/022_026_014.mp3","charTypeName":"word"},{"id":28934,"position":15,"arabic":"وَٱلرُّكَّعِ","translation":"ও রুকুকারীদের","audioUrl":"wbw/022_026_015.mp3","charTypeName":"word"},{"id":28935,"position":16,"arabic":"ٱلسُّجُودِ","translation":"সিজদাকারীদের (জন্যে)","audioUrl":"wbw/022_026_016.mp3","charTypeName":"word"},{"id":28936,"position":17,"arabic":"٢٦","translation":"(২৬)","audioUrl":null,"charTypeName":"end"}]},{"number":27,"arabic":"وَأَذِّن فِى ٱلنَّاسِ بِٱلْحَجِّ يَأْتُوكَ رِجَالًۭا وَعَلَىٰ كُلِّ ضَامِرٍۢ يَأْتِينَ مِن كُلِّ فَجٍّ عَمِيقٍۢ","translation":"Hence, [O Muhammad,] proclaim thou unto all people the [duty of] pilgrimage: they will come unto thee on foot and on every [kind of] fast mount, coming from every far-away point [on earth],","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2622.mp3","surahId":22,"words":[{"id":29788,"position":1,"arabic":"وَأَذِّن","translation":"এবং ঘোষণা দাও","audioUrl":"wbw/022_027_001.mp3","charTypeName":"word"},{"id":29789,"position":2,"arabic":"فِى","translation":"নিকট","audioUrl":"wbw/022_027_002.mp3","charTypeName":"word"},{"id":29790,"position":3,"arabic":"ٱلنَّاسِ","translation":"মানুষের","audioUrl":"wbw/022_027_003.mp3","charTypeName":"word"},{"id":29791,"position":4,"arabic":"بِٱلْحَجِّ","translation":"ব্যাপারে হজ্জের","audioUrl":"wbw/022_027_004.mp3","charTypeName":"word"},{"id":29792,"position":5,"arabic":"يَأْتُوكَ","translation":"তোমার নিকট আসবে","audioUrl":"wbw/022_027_005.mp3","charTypeName":"word"},{"id":29793,"position":6,"arabic":"رِجَالًۭا","translation":"পায়ে হেঁটে","audioUrl":"wbw/022_027_006.mp3","charTypeName":"word"},{"id":29794,"position":7,"arabic":"وَعَلَىٰ","translation":"ও (চড়ে) উপর","audioUrl":"wbw/022_027_007.mp3","charTypeName":"word"},{"id":29795,"position":8,"arabic":"كُلِّ","translation":"সর্ব (প্রকার)","audioUrl":"wbw/022_027_008.mp3","charTypeName":"word"},{"id":29796,"position":9,"arabic":"ضَامِرٍۢ","translation":"ক্ষীণকায় উটের","audioUrl":"wbw/022_027_009.mp3","charTypeName":"word"},{"id":29797,"position":10,"arabic":"يَأْتِينَ","translation":"তারা আসবে","audioUrl":"wbw/022_027_010.mp3","charTypeName":"word"},{"id":29798,"position":11,"arabic":"مِن","translation":"হ'তে","audioUrl":"wbw/022_027_011.mp3","charTypeName":"word"},{"id":29799,"position":12,"arabic":"كُلِّ","translation":"সব","audioUrl":"wbw/022_027_012.mp3","charTypeName":"word"},{"id":29800,"position":13,"arabic":"فَجٍّ","translation":"পথ","audioUrl":"wbw/022_027_013.mp3","charTypeName":"word"},{"id":29801,"position":14,"arabic":"عَمِيقٍۢ","translation":"দূরদূরান্তের","audioUrl":"wbw/022_027_014.mp3","charTypeName":"word"},{"id":29802,"position":15,"arabic":"٢٧","translation":"(২৭)","audioUrl":null,"charTypeName":"end"}]},{"number":28,"arabic":"لِّيَشْهَدُوا۟ مَنَٰفِعَ لَهُمْ وَيَذْكُرُوا۟ ٱسْمَ ٱللَّهِ فِىٓ أَيَّامٍۢ مَّعْلُومَٰتٍ عَلَىٰ مَا رَزَقَهُم مِّنۢ بَهِيمَةِ ٱلْأَنْعَٰمِ ۖ فَكُلُوا۟ مِنْهَا وَأَطْعِمُوا۟ ٱلْبَآئِسَ ٱلْفَقِيرَ","translation":"so that they might experience much that shall be of benefit to them, and that they might extol the name of God on the days appointed [for sacrifice], over whatever heads of cattle He may have provided for them [to this end]: eat, then, thereof, and feed the unfortunate poor.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2623.mp3","surahId":22,"words":[{"id":30913,"position":1,"arabic":"لِّيَشْهَدُوا۟","translation":"যেন তারা প্রত্যক্ষ করে","audioUrl":"wbw/022_028_001.mp3","charTypeName":"word"},{"id":30914,"position":2,"arabic":"مَنَـٰفِعَ","translation":"উপকারসমূহকে","audioUrl":"wbw/022_028_002.mp3","charTypeName":"word"},{"id":30915,"position":3,"arabic":"لَهُمْ","translation":"তাদের জন্যে (এখানে রাখা)","audioUrl":"wbw/022_028_003.mp3","charTypeName":"word"},{"id":30916,"position":4,"arabic":"وَيَذْكُرُوا۟","translation":"ও স্মরণ করে (যেন)","audioUrl":"wbw/022_028_004.mp3","charTypeName":"word"},{"id":30917,"position":5,"arabic":"ٱسْمَ","translation":"নাম","audioUrl":"wbw/022_028_005.mp3","charTypeName":"word"},{"id":30918,"position":6,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/022_028_006.mp3","charTypeName":"word"},{"id":30919,"position":7,"arabic":"فِىٓ","translation":"মধ্যে","audioUrl":"wbw/022_028_007.mp3","charTypeName":"word"},{"id":30920,"position":8,"arabic":"أَيَّامٍۢ","translation":"দিনগুলোর","audioUrl":"wbw/022_028_008.mp3","charTypeName":"word"},{"id":30921,"position":9,"arabic":"مَّعْلُومَـٰتٍ","translation":"নির্দিষ্ট","audioUrl":"wbw/022_028_009.mp3","charTypeName":"word"},{"id":30922,"position":10,"arabic":"عَلَىٰ","translation":"(কুরবানির জন্তুর) উপর","audioUrl":"wbw/022_028_010.mp3","charTypeName":"word"},{"id":30923,"position":11,"arabic":"مَا","translation":"যা","audioUrl":"wbw/022_028_011.mp3","charTypeName":"word"},{"id":30924,"position":12,"arabic":"رَزَقَهُم","translation":"তাদেরকে জীবিকা (হিসেবে) দিয়েছেন","audioUrl":"wbw/022_028_012.mp3","charTypeName":"word"},{"id":30925,"position":13,"arabic":"مِّنۢ","translation":"হ'তে","audioUrl":"wbw/022_028_013.mp3","charTypeName":"word"},{"id":30926,"position":14,"arabic":"بَهِيمَةِ","translation":"চতুষ্পদ জন্তু","audioUrl":"wbw/022_028_014.mp3","charTypeName":"word"},{"id":30927,"position":15,"arabic":"ٱلْأَنْعَـٰمِ ۖ","translation":"গৃহপালিত","audioUrl":"wbw/022_028_015.mp3","charTypeName":"word"},{"id":30929,"position":16,"arabic":"فَكُلُوا۟","translation":"অতঃপর তোমরা খাও","audioUrl":"wbw/022_028_017.mp3","charTypeName":"word"},{"id":30930,"position":17,"arabic":"مِنْهَا","translation":"তা হ'তে","audioUrl":"wbw/022_028_018.mp3","charTypeName":"word"},{"id":30931,"position":18,"arabic":"وَأَطْعِمُوا۟","translation":"ও খাওয়াও","audioUrl":"wbw/022_028_019.mp3","charTypeName":"word"},{"id":30932,"position":19,"arabic":"ٱلْبَآئِسَ","translation":"দুস্থদেরকে","audioUrl":"wbw/022_028_020.mp3","charTypeName":"word"},{"id":30933,"position":20,"arabic":"ٱلْفَقِيرَ","translation":"অভাবগ্রস্তদেরকে","audioUrl":"wbw/022_028_021.mp3","charTypeName":"word"},{"id":30934,"position":21,"arabic":"٢٨","translation":"(২৮)","audioUrl":null,"charTypeName":"end"}]},{"number":29,"arabic":"ثُمَّ لْيَقْضُوا۟ تَفَثَهُمْ وَلْيُوفُوا۟ نُذُورَهُمْ وَلْيَطَّوَّفُوا۟ بِٱلْبَيْتِ ٱلْعَتِيقِ","translation":"Thereafter let them bring to an end their state of self-denial, and let them fulfill the vows which they [may] have made, and let them walk [once again] around the Most Ancient Temple.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2624.mp3","surahId":22,"words":[{"id":31920,"position":1,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/022_029_001.mp3","charTypeName":"word"},{"id":31921,"position":2,"arabic":"لْيَقْضُوا۟","translation":"যেন তারা দূর করে","audioUrl":"wbw/022_029_002.mp3","charTypeName":"word"},{"id":31922,"position":3,"arabic":"تَفَثَهُمْ","translation":"তাদের অপরিচ্ছন্নতা","audioUrl":"wbw/022_029_003.mp3","charTypeName":"word"},{"id":31923,"position":4,"arabic":"وَلْيُوفُوا۟","translation":"ও যেন তারা পূর্ণ করে","audioUrl":"wbw/022_029_004.mp3","charTypeName":"word"},{"id":31924,"position":5,"arabic":"نُذُورَهُمْ","translation":"তাদের মানতগুলোকে","audioUrl":"wbw/022_029_005.mp3","charTypeName":"word"},{"id":31925,"position":6,"arabic":"وَلْيَطَّوَّفُوا۟","translation":"ও যেন তারা তওয়াফ করে","audioUrl":"wbw/022_029_006.mp3","charTypeName":"word"},{"id":31926,"position":7,"arabic":"بِٱلْبَيْتِ","translation":"ঘরের","audioUrl":"wbw/022_029_007.mp3","charTypeName":"word"},{"id":31927,"position":8,"arabic":"ٱلْعَتِيقِ","translation":"প্রাচীন\"","audioUrl":"wbw/022_029_008.mp3","charTypeName":"word"},{"id":31928,"position":9,"arabic":"٢٩","translation":"(২৯)","audioUrl":null,"charTypeName":"end"}]},{"number":30,"arabic":"ذَٰلِكَ وَمَن يُعَظِّمْ حُرُمَٰتِ ٱللَّهِ فَهُوَ خَيْرٌۭ لَّهُۥ عِندَ رَبِّهِۦ ۗ وَأُحِلَّتْ لَكُمُ ٱلْأَنْعَٰمُ إِلَّا مَا يُتْلَىٰ عَلَيْكُمْ ۖ فَٱجْتَنِبُوا۟ ٱلرِّجْسَ مِنَ ٱلْأَوْثَٰنِ وَٱجْتَنِبُوا۟ قَوْلَ ٱلزُّورِ","translation":"All this [is ordained by God]; and if one houours God’s sacred commandments, it will redound to his own good in his Sustainer’s sight. And all [kinds of] cattle have been made lawful to you [for sacrifice and food], save what is mentioned to you [as forbidden]. Shun, then, [all that God has forbidden and, most of all,] the loathsome evil of idolatrous beliefs and practices; and shun every word that is untrue,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2625.mp3","surahId":22,"words":[{"id":32785,"position":1,"arabic":"ذَٰلِكَ","translation":"এটাই (বিধান)","audioUrl":"wbw/022_030_001.mp3","charTypeName":"word"},{"id":32786,"position":2,"arabic":"وَمَن","translation":"আর যে","audioUrl":"wbw/022_030_002.mp3","charTypeName":"word"},{"id":32787,"position":3,"arabic":"يُعَظِّمْ","translation":"সম্মান করে","audioUrl":"wbw/022_030_003.mp3","charTypeName":"word"},{"id":32788,"position":4,"arabic":"حُرُمَـٰتِ","translation":"(নির্ধারিত) মর্যাদাসমূহের","audioUrl":"wbw/022_030_004.mp3","charTypeName":"word"},{"id":32789,"position":5,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/022_030_005.mp3","charTypeName":"word"},{"id":32790,"position":6,"arabic":"فَهُوَ","translation":"তবেই তা (হবে)","audioUrl":"wbw/022_030_006.mp3","charTypeName":"word"},{"id":32791,"position":7,"arabic":"خَيْرٌۭ","translation":"উত্তম","audioUrl":"wbw/022_030_007.mp3","charTypeName":"word"},{"id":32792,"position":8,"arabic":"لَّهُۥ","translation":"জন্যে তার","audioUrl":"wbw/022_030_008.mp3","charTypeName":"word"},{"id":32793,"position":9,"arabic":"عِندَ","translation":"নিকট","audioUrl":"wbw/022_030_009.mp3","charTypeName":"word"},{"id":32794,"position":10,"arabic":"رَبِّهِۦ ۗ","translation":"তার রবের","audioUrl":"wbw/022_030_010.mp3","charTypeName":"word"},{"id":32796,"position":11,"arabic":"وَأُحِلَّتْ","translation":"আর হালাল করা হয়েছে","audioUrl":"wbw/022_030_012.mp3","charTypeName":"word"},{"id":32797,"position":12,