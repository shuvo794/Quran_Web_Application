{"id":84,"ayahs":[{"number":34,"arabic":"ٱلرِّجَالُ قَوَّٰمُونَ عَلَى ٱلنِّسَآءِ بِمَا فَضَّلَ ٱللَّهُ بَعْضَهُمْ عَلَىٰ بَعْضٍۢ وَبِمَآ أَنفَقُوا۟ مِنْ أَمْوَٰلِهِمْ ۚ فَٱلصَّٰلِحَٰتُ قَٰنِتَٰتٌ حَٰفِظَٰتٌۭ لِّلْغَيْبِ بِمَا حَفِظَ ٱللَّهُ ۚ وَٱلَّٰتِى تَخَافُونَ نُشُوزَهُنَّ فَعِظُوهُنَّ وَٱهْجُرُوهُنَّ فِى ٱلْمَضَاجِعِ وَٱضْرِبُوهُنَّ ۖ فَإِنْ أَطَعْنَكُمْ فَلَا تَبْغُوا۟ عَلَيْهِنَّ سَبِيلًا ۗ إِنَّ ٱللَّهَ كَانَ عَلِيًّۭا كَبِيرًۭا","translation":"MEN SHALL take full care of women with the bounties which God has bestowed more abundantly on the former than on the latter, and with what they may spend out of their possessions. And the right­eous women are the truly devout ones, who guard the intimacy which God has [ordained to be] guar­ded. And as for those women whose ill-will you have reason to fear, admonish them [first]; then leave them alone in bed; then beat them; and if thereupon they pay you heed, do not seek to harm them. Behold, God is indeed most high, great!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/527.mp3","surahId":4,"words":[{"id":36370,"position":1,"arabic":"ٱلرِّجَالُ","translation":"পুরুষেরা","audioUrl":"wbw/004_034_001.mp3","charTypeName":"word"},{"id":36371,"position":2,"arabic":"قَوَّٰمُونَ","translation":"পরিচালক","audioUrl":"wbw/004_034_002.mp3","charTypeName":"word"},{"id":36372,"position":3,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/004_034_003.mp3","charTypeName":"word"},{"id":36373,"position":4,"arabic":"ٱلنِّسَآءِ","translation":"নারীদের","audioUrl":"wbw/004_034_004.mp3","charTypeName":"word"},{"id":36374,"position":5,"arabic":"بِمَا","translation":"এ জন্য যে","audioUrl":"wbw/004_034_005.mp3","charTypeName":"word"},{"id":36375,"position":6,"arabic":"فَضَّلَ","translation":"বিশিষ্টতা দিয়েছেন","audioUrl":"wbw/004_034_006.mp3","charTypeName":"word"},{"id":36376,"position":7,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/004_034_007.mp3","charTypeName":"word"},{"id":36377,"position":8,"arabic":"بَعْضَهُمْ","translation":"তাদের কাউকে","audioUrl":"wbw/004_034_008.mp3","charTypeName":"word"},{"id":36378,"position":9,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/004_034_009.mp3","charTypeName":"word"},{"id":36379,"position":10,"arabic":"بَعْضٍۢ","translation":"কারও","audioUrl":"wbw/004_034_010.mp3","charTypeName":"word"},{"id":36380,"position":11,"arabic":"وَبِمَآ","translation":"এবং এ জন্যও যে","audioUrl":"wbw/004_034_011.mp3","charTypeName":"word"},{"id":36381,"position":12,"arabic":"أَنفَقُوا۟","translation":"তারা খরচ করে","audioUrl":"wbw/004_034_012.mp3","charTypeName":"word"},{"id":36382,"position":13,"arabic":"مِنْ","translation":"থেকে","audioUrl":"wbw/004_034_013.mp3","charTypeName":"word"},{"id":36383,"position":14,"arabic":"أَمْوَٰلِهِمْ ۚ","translation":"তাদের মাল সম্পদ","audioUrl":"wbw/004_034_014.mp3","charTypeName":"word"},{"id":36385,"position":15,"arabic":"فَٱلصَّـٰلِحَـٰتُ","translation":"অতএব (যারা) সৎ মহিলা","audioUrl":"wbw/004_034_016.mp3","charTypeName":"word"},{"id":36386,"position":16,"arabic":"قَـٰنِتَـٰتٌ","translation":"আনুগত্য পরায়না (হয়ে থাকে)","audioUrl":"wbw/004_034_017.mp3","charTypeName":"word"},{"id":36387,"position":17,"arabic":"حَـٰفِظَـٰتٌۭ","translation":"(তারা) রক্ষণাবেক্ষণ কারিনী","audioUrl":"wbw/004_034_018.mp3","charTypeName":"word"},{"id":36388,"position":18,"arabic":"لِّلْغَيْبِ","translation":"লোক চক্ষুর অন্তরালে","audioUrl":"wbw/004_034_019.mp3","charTypeName":"word"},{"id":36389,"position":19,"arabic":"بِمَا","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/004_034_020.mp3","charTypeName":"word"},{"id":36390,"position":20,"arabic":"حَفِظَ","translation":"হিফাজত করেছেন","audioUrl":"wbw/004_034_021.mp3","charTypeName":"word"},{"id":36391,"position":21,"arabic":"ٱللَّهُ ۚ","translation":"আল্লাহ","audioUrl":"wbw/004_034_022.mp3","charTypeName":"word"},{"id":36393,"position":22,"arabic":"وَٱلَّـٰتِى","translation":"এবং যাদেরকে","audioUrl":"wbw/004_034_024.mp3","charTypeName":"word"},{"id":36394,"position":23,"arabic":"تَخَافُونَ","translation":"তোমরা ভয় কর","audioUrl":"wbw/004_034_025.mp3","charTypeName":"word"},{"id":36395,"position":24,"arabic":"نُشُوزَهُنَّ","translation":"তাদের অবাধ্যতার","audioUrl":"wbw/004_034_026.mp3","charTypeName":"word"},{"id":36396,"position":25,"arabic":"فَعِظُوهُنَّ","translation":"তোমরা তবে উপদেশ দাও তাদেরকে","audioUrl":"wbw/004_034_027.mp3","charTypeName":"word"},{"id":36397,"position":26,"arabic":"وَٱهْجُرُوهُنَّ","translation":"ও তাদেরকে তোমরা ত্যাগ কর (একাকী)","audioUrl":"wbw/004_034_028.mp3","charTypeName":"word"},{"id":36398,"position":27,"arabic":"فِى","translation":"উপর","audioUrl":"wbw/004_034_029.mp3","charTypeName":"word"},{"id":36399,"position":28,"arabic":"ٱلْمَضَاجِعِ","translation":"শয্যার","audioUrl":"wbw/004_034_030.mp3","charTypeName":"word"},{"id":36400,"position":29,"arabic":"وَٱضْرِبُوهُنَّ ۖ","translation":"ও তোমরা মার তাদেরকে","audioUrl":"wbw/004_034_031.mp3","charTypeName":"word"},{"id":36402,"position":30,"arabic":"فَإِنْ","translation":"যদি অতঃপর","audioUrl":"wbw/004_034_033.mp3","charTypeName":"word"},{"id":36403,"position":31,"arabic":"أَطَعْنَكُمْ","translation":"তোমাদের তারা অনুগত হয়","audioUrl":"wbw/004_034_034.mp3","charTypeName":"word"},{"id":36404,"position":32,"arabic":"فَلَا","translation":"না তবে","audioUrl":"wbw/004_034_035.mp3","charTypeName":"word"},{"id":36405,"position":33,"arabic":"تَبْغُوا۟","translation":"তোমরা তালাশ করো","audioUrl":"wbw/004_034_036.mp3","charTypeName":"word"},{"id":36406,"position":34,"arabic":"عَلَيْهِنَّ","translation":"তাদের বিরুদ্ধে","audioUrl":"wbw/004_034_037.mp3","charTypeName":"word"},{"id":36407,"position":35,"arabic":"سَبِيلًا ۗ","translation":"কোন বাহানা","audioUrl":"wbw/004_034_038.mp3","charTypeName":"word"},{"id":36409,"position":36,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/004_034_040.mp3","charTypeName":"word"},{"id":36410,"position":37,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/004_034_041.mp3","charTypeName":"word"},{"id":36411,"position":38,"arabic":"كَانَ","translation":"হলেন","audioUrl":"wbw/004_034_042.mp3","charTypeName":"word"},{"id":36412,"position":39,"arabic":"عَلِيًّۭا","translation":"উচ্চতর","audioUrl":"wbw/004_034_043.mp3","charTypeName":"word"},{"id":36413,"position":40,"arabic":"كَبِيرًۭا","translation":"শ্রেষ্ট","audioUrl":"wbw/004_034_044.mp3","charTypeName":"word"},{"id":36414,"position":41,"arabic":"٣٤","translation":"(৩৪)","audioUrl":null,"charTypeName":"end"}]},{"number":35,"arabic":"وَإِنْ خِفْتُمْ شِقَاقَ بَيْنِهِمَا فَٱبْعَثُوا۟ حَكَمًۭا مِّنْ أَهْلِهِۦ وَحَكَمًۭا مِّنْ أَهْلِهَآ إِن يُرِيدَآ إِصْلَٰحًۭا يُوَفِّقِ ٱللَّهُ بَيْنَهُمَآ ۗ إِنَّ ٱللَّهَ كَانَ عَلِيمًا خَبِيرًۭا","translation":"And if you have reason to fear that a breach might occur between a [married] couple, appoint an arbiter from among his people and an arbiter from among her people; if they both want to set things aright, God may bring about their reconciliation. Be­hold, God is indeed all-knowing, aware.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/528.mp3","surahId":4,"words":[{"id":36976,"position":1,"arabic":"وَإِنْ","translation":"এবং যদি","audioUrl":"wbw/004_035_001.mp3","charTypeName":"word"},{"id":36977,"position":2,"arabic":"خِفْتُمْ","translation":"তোমরা আশঙ্কা কর","audioUrl":"wbw/004_035_002.mp3","charTypeName":"word"},{"id":36978,"position":3,"arabic":"شِقَاقَ","translation":"সম্পর্কচ্ছেদের","audioUrl":"wbw/004_035_003.mp3","charTypeName":"word"},{"id":36979,"position":4,"arabic":"بَيْنِهِمَا","translation":"তাদের দুজনের মাঝে","audioUrl":"wbw/004_035_004.mp3","charTypeName":"word"},{"id":36980,"position":5,"arabic":"فَٱبْعَثُوا۟","translation":"তোমরা তবে নিযুক্ত কর","audioUrl":"wbw/004_035_005.mp3","charTypeName":"word"},{"id":36981,"position":6,"arabic":"حَكَمًۭا","translation":"একজন সালিশ","audioUrl":"wbw/004_035_006.mp3","charTypeName":"word"},{"id":36982,"position":7,"arabic":"مِّنْ","translation":"মধ্যহতে","audioUrl":"wbw/004_035_007.mp3","charTypeName":"word"},{"id":36983,"position":8,"arabic":"أَهْلِهِۦ","translation":"তাঁর পরিবারের (অর্থাৎ স্বামীর)","audioUrl":"wbw/004_035_008.mp3","charTypeName":"word"},{"id":36984,"position":9,"arabic":"وَحَكَمًۭا","translation":"ও একজন সালিশ","audioUrl":"wbw/004_035_009.mp3","charTypeName":"word"},{"id":36985,"position":10,"arabic":"مِّنْ","translation":"মধ্যে হতে","audioUrl":"wbw/004_035_010.mp3","charTypeName":"word"},{"id":36986,"position":11,"arabic":"أَهْلِهَآ","translation":"তার পরিবারের (অর্থাৎ স্ত্রীর)","audioUrl":"wbw/004_035_011.mp3","charTypeName":"word"},{"id":36987,"position":12,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/004_035_012.mp3","charTypeName":"word"},{"id":36988,"position":13,"arabic":"يُرِيدَآ","translation":"দুজনে চায়","audioUrl":"wbw/004_035_013.mp3","charTypeName":"word"},{"id":36989,"position":14,"arabic":"إِصْلَـٰحًۭا","translation":"মীমাংসা","audioUrl":"wbw/004_035_014.mp3","charTypeName":"word"},{"id":36990,"position":15,"arabic":"يُوَفِّقِ","translation":"তৌফিক দিবেন","audioUrl":"wbw/004_035_015.mp3","charTypeName":"word"},{"id":36991,"position":16,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/004_035_016.mp3","charTypeName":"word"},{"id":36992,"position":17,"arabic":"بَيْنَهُمَآ ۗ","translation":"তাদের দুজনের মাঝে","audioUrl":"wbw/004_035_017.mp3","charTypeName":"word"},{"id":36994,"position":18,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/004_035_019.mp3","charTypeName":"word"},{"id":36995,"position":19,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/004_035_020.mp3","charTypeName":"word"},{"id":36996,"position":20,"arabic":"كَانَ","translation":"হলেন","audioUrl":"wbw/004_035_021.mp3","charTypeName":"word"},{"id":36997,"position":21,"arabic":"عَلِيمًا","translation":"সর্বজ্ঞ","audioUrl":"wbw/004_035_022.mp3","charTypeName":"word"},{"id":36998,"position":22,"arabic":"خَبِيرًۭا","translation":"খুব অবহিত","audioUrl":"wbw/004_035_023.mp3","charTypeName":"word"},{"id":36999,"position":23,"arabic":"٣٥","translation":"(৩৫)","audioUrl":null,"charTypeName":"end"}]},{"number":36,"arabic":"۞ وَٱعْبُدُوا۟ ٱللَّهَ وَلَا تُشْرِكُوا۟ بِهِۦ شَيْـًۭٔا ۖ وَبِٱلْوَٰلِدَيْنِ إِحْسَٰنًۭا وَبِذِى ٱلْقُرْبَىٰ وَٱلْيَتَٰمَىٰ وَٱلْمَسَٰكِينِ وَٱلْجَارِ ذِى ٱلْقُرْبَىٰ وَٱلْجَارِ ٱلْجُنُبِ وَٱلصَّاحِبِ بِٱلْجَنۢبِ وَٱبْنِ ٱلسَّبِيلِ وَمَا مَلَكَتْ أَيْمَٰنُكُمْ ۗ إِنَّ ٱللَّهَ لَا يُحِبُّ مَن كَانَ مُخْتَالًۭا فَخُورًا","translation":"AND WORSHIP God [alone], and do not ascribe divinity, in any way, to aught beside Him. And do good unto your parents, and near of kin, and unto orphans, and the needy, and the neighbour from among your own people, and the neighbour who is a stranger, and the friend by your side, and the wayfarer, and those whom you rightfully possess. Verily, God does not love any of those who, full of self-conceit, act in a boastful manner;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/529.mp3","surahId":4,"words":[{"id":37800,"position":1,"arabic":"۞ وَٱعْبُدُوا۟","translation":"এবং তোমরা ইবাদাত কর","audioUrl":"wbw/004_036_002.mp3","charTypeName":"word"},{"id":37801,"position":2,"arabic":"ٱللَّهَ","translation":"আল্লাহর","audioUrl":"wbw/004_036_003.mp3","charTypeName":"word"},{"id":37802,"position":3,"arabic":"وَلَا","translation":"ও না","audioUrl":"wbw/004_036_004.mp3","charTypeName":"word"},{"id":37803,"position":4,"arabic":"تُشْرِكُوا۟","translation":"তোমরা শিরক করো","audioUrl":"wbw/004_036_005.mp3","charTypeName":"word"},{"id":37804,"position":5,"arabic":"بِهِۦ","translation":"তাঁর সাথে","audioUrl":"wbw/004_036_006.mp3","charTypeName":"word"},{"id":37805,"position":6,"arabic":"شَيْـًۭٔا ۖ","translation":"কোন কিছুকে","audioUrl":"wbw/004_036_007.mp3","charTypeName":"word"},{"id":37807,"position":7,"arabic":"وَبِٱلْوَٰلِدَيْنِ","translation":"ও পিতা মাতার সাথে","audioUrl":"wbw/004_036_009.mp3","charTypeName":"word"},{"id":37808,"position":8,"arabic":"إِحْسَـٰنًۭا","translation":"সৎ ব্যবহার (করবে)","audioUrl":"wbw/004_036_010.mp3","charTypeName":"word"},{"id":37809,"position":9,"arabic":"وَبِذِى","translation":"এবং সাথে","audioUrl":"wbw/004_036_011.mp3","charTypeName":"word"},{"id":37810,"position":10,"arabic":"ٱلْقُرْبَىٰ","translation":"আত্মীয়-স্বজনদের সাথে","audioUrl":"wbw/004_036_012.mp3","charTypeName":"word"},{"id":37811,"position":11,"arabic":"وَٱلْيَتَـٰمَىٰ","translation":"ও ইয়াতীমদের","audioUrl":"wbw/004_036_013.mp3","charTypeName":"word"},{"id":37812,"position":12,"arabic":"وَٱلْمَسَـٰكِينِ","translation":"ও অভাবগ্রস্তদের","audioUrl":"wbw/004_036_014.mp3","charTypeName":"word"},{"id":37813,"position":13,"arabic":"وَٱلْجَارِ","translation":"ও প্রতিবেশী","audioUrl":"wbw/004_036_015.mp3","charTypeName":"word"},{"id":37814,"position":14,"arabic":"ذِى","translation":"(চিরকাল)","audioUrl":"wbw/004_036_016.mp3","charTypeName":"word"},{"id":37815,"position":15,"arabic":"ٱلْقُرْبَىٰ","translation":"আত্মীয়","audioUrl":"wbw/004_036_017.mp3","charTypeName":"word"},{"id":37816,"position":16,"arabic":"وَٱلْجَارِ","translation":"ও প্রতিবেশী","audioUrl":"wbw/004_036_018.mp3","charTypeName":"word"},{"id":37817,"position":17,"arabic":"ٱلْجُنُبِ","translation":"দূরের (অর্থাৎ অনাত্মীয়ও)","audioUrl":"wbw/004_036_019.mp3","charTypeName":"word"},{"id":37818,"position":18,"arabic":"وَٱلصَّاحِبِ","translation":"ও সাথী","audioUrl":"wbw/004_036_020.mp3","charTypeName":"word"},{"id":37819,"position":19,"arabic":"بِٱلْجَنۢبِ","translation":"পাশাপাশি চলার","audioUrl":"wbw/004_036_021.mp3","charTypeName":"word"},{"id":37820,"position":20,"arabic":"وَٱبْنِ","translation":"ও","audioUrl":"wbw/004_036_022.mp3","charTypeName":"word"},{"id":37821,"position":21,"arabic":"ٱلسَّبِيلِ","translation":"পথ চারী","audioUrl":"wbw/004_036_023.mp3","charTypeName":"word"},{"id":37822,"position":22,"arabic":"وَمَا","translation":"ও যা","audioUrl":"wbw/004_036_024.mp3","charTypeName":"word"},{"id":37823,"position":23,"arabic":"مَلَكَتْ","translation":"মালিক হয়েছে","audioUrl":"wbw/004_036_025.mp3","charTypeName":"word"},{"id":37824,"position":24,"arabic":"أَيْمَـٰنُكُمْ ۗ","translation":"তোমাদের ডান হাত (সবার সাথে ভাল ব্যবহার করবে)","audioUrl":"wbw/004_036_026.mp3","charTypeName":"word"},{"id":37826,"position":25,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/004_036_028.mp3","charTypeName":"word"},{"id":37827,"position":26,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/004_036_029.mp3","charTypeName":"word"},{"id":37828,"position":27,"arabic":"لَا","translation":"না","audioUrl":"wbw/004_036_030.mp3","charTypeName":"word"},{"id":37829,"position":28,"arabic":"يُحِبُّ","translation":"পছন্দ করেন","audioUrl":"wbw/004_036_031.mp3","charTypeName":"word"},{"id":37830,"position":29,"arabic":"مَن","translation":"(তাকে) যে","audioUrl":"wbw/004_036_032.mp3","charTypeName":"word"},{"id":37831,"position":30,"arabic":"كَانَ","translation":"হল","audioUrl":"wbw/004_036_033.mp3","charTypeName":"word"},{"id":37832,"position":31,"arabic":"مُخْتَالًۭا","translation":"দাম্ভিক","audioUrl":"wbw/004_036_034.mp3","charTypeName":"word"},{"id":37833,"position":32,"arabic":"فَخُورًا","translation":"গর্বকারী","audioUrl":"wbw/004_036_035.mp3","charTypeName":"word"},{"id":37834,"position":33,"arabic":"٣٦","translation":"(৩৬)","audioUrl":null,"charTypeName":"end"}]},{"number":37,"arabic":"ٱلَّذِينَ يَبْخَلُونَ وَيَأْمُرُونَ ٱلنَّاسَ بِٱلْبُخْلِ وَيَكْتُمُونَ مَآ ءَاتَىٰهُمُ ٱللَّهُ مِن فَضْلِهِۦ ۗ وَأَعْتَدْنَا لِلْكَٰفِرِينَ عَذَابًۭا مُّهِينًۭا","translation":"[nor] those who are niggardly, and bid others to be niggardly, and conceal whatever God has bestowed upon them out of His bounty; and so We have readied shameful suffering for all who thus deny the truth.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/530.mp3","surahId":4,"words":[{"id":38693,"position":1,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/004_037_001.mp3","charTypeName":"word"},{"id":38694,"position":2,"arabic":"يَبْخَلُونَ","translation":"কৃপণতা করে","audioUrl":"wbw/004_037_002.mp3","charTypeName":"word"},{"id":38695,"position":3,"arabic":"وَيَأْمُرُونَ","translation":"ও নির্দেশ দেয়","audioUrl":"wbw/004_037_003.mp3","charTypeName":"word"},{"id":38696,"position":4,"arabic":"ٱلنَّاسَ","translation":"মানুষকে","audioUrl":"wbw/004_037_004.mp3","charTypeName":"word"},{"id":38697,"position":5,"arabic":"بِٱلْبُخْلِ","translation":"কৃপণতার জন্য","audioUrl":"wbw/004_037_005.mp3","charTypeName":"word"},{"id":38698,"position":6,"arabic":"وَيَكْتُمُونَ","translation":"ও গোপন করে","audioUrl":"wbw/004_037_006.mp3","charTypeName":"word"},{"id":38699,"position":7,"arabic":"مَآ","translation":"যা","audioUrl":"wbw/004_037_007.mp3","charTypeName":"word"},{"id":38700,"position":8,"arabic":"ءَاتَىٰهُمُ","translation":"তাদের দিয়েছেন","audioUrl":"wbw/004_037_008.mp3","charTypeName":"word"},{"id":38701,"position":9,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/004_037_009.mp3","charTypeName":"word"},{"id":38702,"position":10,"arabic":"مِن","translation":"হতে","audioUrl":"wbw/004_037_010.mp3","charTypeName":"word"},{"id":38703,"position":11,"arabic":"فَضْلِهِۦ ۗ","translation":"তাঁর অনুগ্রহ","audioUrl":"wbw/004_037_011.mp3","charTypeName":"word"},{"id":38705,"position":12,"arabic":"وَأَعْتَدْنَا","translation":"এবং আমরা প্রস্তুত করে রেখেছি","audioUrl":"wbw/004_037_013.mp3","charTypeName":"word"},{"id":38706,"position":13,"arabic":"لِلْكَـٰفِرِينَ","translation":"এমন অকৃতজ্ঞদের জন্য","audioUrl":"wbw/004_037_014.mp3","charTypeName":"word"},{"id":38707,"position":14,"arabic":"عَذَابًۭا","translation":"আজাব","audioUrl":"wbw/004_037_015.mp3","charTypeName":"word"},{"id":38708,"position":15,"arabic":"مُّهِينًۭا","translation":"অপমানকর","audioUrl":"wbw/004_037_016.mp3","charTypeName":"word"},{"id":38709,"position":16,"arabic":"٣٧","translation":"(৩৭)","audioUrl":null,"charTypeName":"end"}]}]}