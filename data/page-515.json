e":"word"},{"id":31733,"position":50,"arabic":"ٱلصَّـٰلِحَـٰتِ","translation":"সৎকর্ম","audioUrl":"wbw/048_029_056.mp3","charTypeName":"word"},{"id":31734,"position":51,"arabic":"مِنْهُم","translation":"তাদের মধ্য হতে","audioUrl":"wbw/048_029_057.mp3","charTypeName":"word"},{"id":31735,"position":52,"arabic":"مَّغْفِرَةًۭ","translation":"ক্ষমা","audioUrl":"wbw/048_029_058.mp3","charTypeName":"word"},{"id":31736,"position":53,"arabic":"وَأَجْرًا","translation":"ও পুরস্কার","audioUrl":"wbw/048_029_059.mp3","charTypeName":"word"},{"id":31737,"position":54,"arabic":"عَظِيمًۢا","translation":"মহা","audioUrl":"wbw/048_029_060.mp3","charTypeName":"word"},{"id":31738,"position":55,"arabic":"٢٩","translation":"(২৯)","audioUrl":null,"charTypeName":"end"}]},{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ لَا تُقَدِّمُوا۟ بَيْنَ يَدَىِ ٱللَّهِ وَرَسُولِهِۦ ۖ وَٱتَّقُوا۟ ٱللَّهَ ۚ إِنَّ ٱللَّهَ سَمِيعٌ عَلِيمٌۭ","translation":"O YOU who have attained to faith! Do not put yourselves forward in the presence of [what] God and His Apostle [may have ordained], but remain conscious of God: for, verily, God is all-hearing, all-knowing!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4613.mp3","surahId":49,"words":[{"id":238,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/049_001_001.mp3","charTypeName":"word"},{"id":239,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/049_001_002.mp3","charTypeName":"word"},{"id":240,"position":3,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছ","audioUrl":"wbw/049_001_003.mp3","charTypeName":"word"},{"id":241,"position":4,"arabic":"لَا","translation":"না","audioUrl":"wbw/049_001_004.mp3","charTypeName":"word"},{"id":242,"position":5,"arabic":"تُقَدِّمُوا۟","translation":"তোমরা অগ্রসর হয়ো (কোন বিষয়ে)","audioUrl":"wbw/049_001_005.mp3","charTypeName":"word"},{"id":243,"position":6,"arabic":"بَيْنَ","translation":"আগে","audioUrl":"wbw/049_001_006.m