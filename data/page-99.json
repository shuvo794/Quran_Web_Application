e":"word"},{"id":77751,"position":26,"arabic":"كَانَ","translation":"হলেন","audioUrl":"wbw/004_128_029.mp3","charTypeName":"word"},{"id":77752,"position":27,"arabic":"بِمَا","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/004_128_030.mp3","charTypeName":"word"},{"id":77753,"position":28,"arabic":"تَعْمَلُونَ","translation":"তোমরা কাজ কর","audioUrl":"wbw/004_128_031.mp3","charTypeName":"word"},{"id":77754,"position":29,"arabic":"خَبِيرًۭا","translation":"খুব অবহিত","audioUrl":"wbw/004_128_032.mp3","charTypeName":"word"},{"id":77755,"position":30,"arabic":"١٢٨","translation":"(১২৮)","audioUrl":null,"charTypeName":"end"}]},{"number":129,"arabic":"وَلَن تَسْتَطِيعُوٓا۟ أَن تَعْدِلُوا۟ بَيْنَ ٱلنِّسَآءِ وَلَوْ حَرَصْتُمْ ۖ فَلَا تَمِيلُوا۟ كُلَّ ٱلْمَيْلِ فَتَذَرُوهَا كَٱلْمُعَلَّقَةِ ۚ وَإِن تُصْلِحُوا۟ وَتَتَّقُوا۟ فَإِنَّ ٱللَّهَ كَانَ غَفُورًۭا رَّحِيمًۭا","translation":"And it will not be within your power to treat your wives with equal fairness, however much you may desire it; and so, do not allow yourselves to incline towards one to the exclusion of the other, leaving her in a state, as it were, of having and not having a husband. But if you put things to rights and are conscious of Him - behold, God is indeed much-forgiving, a dispenser of grace.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/622.mp3","surahId":4,"words":[{"id":77860,"position":1,"arabic":"وَلَن","translation":"এবং কক্ষনো না","audioUrl":"wbw/004_129_001.mp3","charTypeName":"word"},{"id":77861,"position":2,"arabic":"تَسْتَطِيعُوٓا۟","translation":"তোমরা পারবে","audioUrl":"wbw/004_129_002.mp3","charTypeName":"word"},{"id":77862,"position":3,"arabic":"أَن","translation":"করতে","audioUrl":"wbw/004_129_003.mp3","charTypeName":"word"},{"id":77863,"position":4,"arabic":"تَعْدِلُوا۟","translation":"তোমরা পূর্ণ সমতা","audioUrl":"wbw/004_129_004.mp3","charTypeName":"word"},{"id":77864,"position":5,"arabic":"بَيْنَ","translation":"মাঝে","audioUrl":"wbw/004_129_005.mp3","charTypeName":"word"},{"id":77865,"position":6,"arabic":"ٱلنِّسَآءِ","translation":"(একাধিক) স্ত্রীর","audioUrl":"wbw/004_129_006.mp3","charTypeName":"word"},{"id":77866,"position":7,"arabic":"وَلَوْ","translation":"এবং যদিও","audioUrl":"wbw/004_129_007.mp3","charTypeName":"word"},{"id":77867,"position":8,"arabic":"حَرَصْتُمْ ۖ","translation":"তোমরা আকাঙ্ক্ষা কর","audioUrl":"wbw/004_129_008.mp3","charTypeName":"word"},{"id":77869,"position":9,"arabic":"فَلَا","translation":"তবে না","audioUrl":"wbw/004_129_010.mp3","charTypeName":"word"},{"id":77870,"position":10,"arabic":"تَمِيلُوا۟","translation":"তোমরা ঝুঁকে পড়ো (একজনের দিকে)","audioUrl":"wbw/004_129_011.mp3","charTypeName":"word"},{"id":77871,"position":11,"arabic":"كُلَّ","translation":"একেবারেই","audioUrl":"wbw/004_129_012.mp3","charTypeName":"word"},{"id":77872,"position":12,"arabic":"ٱلْمَيْلِ","translation":"ঝুঁকা","audioUrl":"wbw/004_129_013.mp3","charTypeName":"word"},{"id":77873,"position":13,"arabic":"فَتَذَرُوهَا","translation":"তোমরা অতঃপর রেখো (না) তাকে (অর্থাৎ অপরকে)","audioUrl":"wbw/004_129_014.mp3","charTypeName":"word"},{"id":77874,"position":14,"arabic":"كَٱلْمُعَلَّقَةِ ۚ","translation":"ঝুলানো অবস্থা যেমন","audioUrl":"wbw/004_129_015.mp3","charTypeName":"word"},{"id":77876,"position":15,"arabic":"وَإِن","translation":"এবং যদি","audioUrl":"wbw/004_129_017.mp3","charTypeName":"word"},{"id":77877,"position":16,"arabic":"تُصْلِحُوا۟","translation":"তোমরা সংশোধিত হও","audioUrl":"wbw/004_129_018.mp3","charTypeName":"word"},{"id":77878,"position":17,"arabic":"وَتَتَّقُوا۟","translation":"ও তোমরা ভয় কর","audioUrl":"wbw/004_129_019.mp3","charTypeName":"word"},{"id":77879,"position":18,"arabic":"فَإِنَّ","translation":"নিশ্চয়ই তবে","audioUrl":"wbw/004_129_020.mp3","charTypeName":"word"},{"id":77880,"position":19,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/004_129_021.mp3","charTypeName":"word"},{"id":77881,"position":20,"arabic":"كَانَ","translation":"হলেন","audioUrl":"wbw/004_129_022.mp3","charTypeName":"word"},{"id":77882,"position":21,"arabic":"غَفُورًۭا","translation":"ক্ষমাশীল","audioUrl":"wbw/004_129_023.mp3","charTypeName":"word"},{"id":77883,"position":22,"arabic":"رَّحِيمًۭا","translation":"মেহেরবান","audioUrl":"wbw/004_129_024.mp3","charTypeName":"word"},{"id":77884,"position":23,"arabic":"١٢٩","translation":"(১২৯)","audioUrl":null,"charTypeName":"end"}]},{"number":130,"arabic":"وَإِن يَتَفَرَّقَا يُغْنِ ٱللَّهُ كُلًّۭا مِّن سَعَتِهِۦ ۚ وَكَانَ ٱللَّهُ وَٰسِعًا حَكِيمًۭا","translation":"And if husband and wife do separate, God shall provide for each of them out of His abundance: for God is indeed infinite, wise,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/623.mp3","surahId":4,"words":[{"id":77978,"position":1,"arabic":"وَإِن","translation":"আর যদি","audioUrl":"wbw/004_130_001.mp3","charTypeName":"word"},{"id":77979,"position":2,"arabic":"يَتَفَرَّقَا","translation":"তারা দুজনে পৃথক হয়","audioUrl":"wbw/004_130_002.mp3","charTypeName":"word"},{"id":77980,"position":3,"arabic":"يُغْنِ","translation":"অভাবমুক্ত করবেন","audioUrl":"wbw/004_130_003.mp3","charTypeName":"word"},{"id":77981,"position":4,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/004_130_004.mp3","charTypeName":"word"},{"id":77982,"position":5,"arabic":"كُلًّۭا","translation":"প্রত্যেককে","audioUrl":"wbw/004_130_005.mp3","charTypeName":"word"},{"id":77983,"position":6,"arabic":"مِّن","translation":"দ্বারা","audioUrl":"wbw/004_130_006.mp3","charTypeName":"word"},{"id":77984,"position":7,"arabic":"سَعَتِهِۦ ۚ","translation":"তাঁর প্রাচুর্য","audioUrl":"wbw/004_130_007.mp3","charTypeName":"word"},{"id":77986,"position":8,"arabic":"وَكَانَ","translation":"এবং হলেন","audioUrl":"wbw/004_130_009.mp3","charTypeName":"word"},{"id":77987,"position":9,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/004_130_010.mp3","charTypeName":"word"},{"id":77988,"position":10,"arabic":"وَٰسِعًا","translation":"প্রাচুর্যময়","audioUrl":"wbw/004_130_011.mp3","charTypeName":"word"},{"id":7