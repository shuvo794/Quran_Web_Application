{"id":316,"ayahs":[{"number":65,"arabic":"قَالُوا۟ يَٰمُوسَىٰٓ إِمَّآ أَن تُلْقِىَ وَإِمَّآ أَن نَّكُونَ أَوَّلَ مَنْ أَلْقَىٰ","translation":"Said [the sorcerers]: \"O Moses! Either thou throw (thy staff first], or we shall be the first to throw.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2413.mp3","surahId":20,"words":[{"id":57178,"position":1,"arabic":"قَالُوا۟","translation":"(জাদুকররা) বললো","audioUrl":"wbw/020_065_001.mp3","charTypeName":"word"},{"id":57179,"position":2,"arabic":"يَـٰمُوسَىٰٓ","translation":"\"হে মূসা","audioUrl":"wbw/020_065_002.mp3","charTypeName":"word"},{"id":57180,"position":3,"arabic":"إِمَّآ","translation":"হয়","audioUrl":"wbw/020_065_003.mp3","charTypeName":"word"},{"id":57181,"position":4,"arabic":"أَن","translation":"যে","audioUrl":"wbw/020_065_004.mp3","charTypeName":"word"},{"id":57182,"position":5,"arabic":"تُلْقِىَ","translation":"তুমি নিক্ষেপ করবে","audioUrl":"wbw/020_065_005.mp3","charTypeName":"word"},{"id":57183,"position":6,"arabic":"وَإِمَّآ","translation":"আর (না) হয়","audioUrl":"wbw/020_065_006.mp3","charTypeName":"word"},{"id":57184,"position":7,"arabic":"أَن","translation":"যে","audioUrl":"wbw/020_065_007.mp3","charTypeName":"word"},{"id":57185,"position":8,"arabic":"نَّكُونَ","translation":"আমরা হবো","audioUrl":"wbw/020_065_008.mp3","charTypeName":"word"},{"id":57186,"position":9,"arabic":"أَوَّلَ","translation":"প্রথম","audioUrl":"wbw/020_065_009.mp3","charTypeName":"word"},{"id":57187,"position":10,"arabic":"مَنْ","translation":"যে","audioUrl":"wbw/020_065_010.mp3","charTypeName":"word"},{"id":57188,"position":11,"arabic":"أَلْقَىٰ","translation":"নিক্ষেপ করবে\"","audioUrl":"wbw/020_065_011.mp3","charTypeName":"word"},{"id":57189,"position":12,"arabic":"٦٥","translation":"(৬৫)","audioUrl":null,"charTypeName":"end"}]},{"number":66,"arabic":"قَالَ بَلْ أَلْقُوا۟ ۖ فَإِذَا حِبَالُهُمْ وَعِصِيُّهُمْ يُخَيَّلُ إِلَيْهِ مِن سِحْرِهِمْ أَنَّهَا تَسْعَىٰ","translation":"He answered: \"Nay, you throw [first].\" And lo! by virtue of their sorcery, their [magic] ropes and staffs seemed to him to be moving rapidly:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2414.mp3","surahId":20,"words":[{"id":57722,"position":1,"arabic":"قَالَ","translation":"(মূসা) বললো","audioUrl":"wbw/020_066_001.mp3","charTypeName":"word"},{"id":57723,"position":2,"arabic":"بَلْ","translation":"\"বরং","audioUrl":"wbw/020_066_002.mp3","charTypeName":"word"},{"id":57724,"position":3,"arabic":"أَلْقُوا۟ ۖ","translation":"তোমরা নিক্ষেপ করো\"","audioUrl":"wbw/020_066_003.mp3","charTypeName":"word"},{"id":57726,"position":4,"arabic":"فَإِذَا","translation":"অতঃপর তখন","audioUrl":"wbw/020_066_005.mp3","charTypeName":"word"},{"id":57727,"position":5,"arabic":"حِبَالُهُمْ","translation":"তাদের দড়াদড়ি","audioUrl":"wbw/020_066_006.mp3","charTypeName":"word"},{"id":57728,"position":6,"arabic":"وَعِصِيُّهُمْ","translation":"ও তাদের লাঠিসোটাগুলো","audioUrl":"wbw/020_066_007.mp3","charTypeName":"word"},{"id":57729,"position":7,"arabic":"يُخَيَّلُ","translation":"মনে হলো","audioUrl":"wbw/020_066_008.mp3","charTypeName":"word"},{"id":57730,"position":8,"arabic":"إِلَيْهِ","translation":"তার দিকে","audioUrl":"wbw/020_066_009.mp3","charTypeName":"word"},{"id":57731,"position":9,"arabic":"مِن","translation":"কারণে","audioUrl":"wbw/020_066_010.mp3","charTypeName":"word"},{"id":57732,"position":10,"arabic":"سِحْرِهِمْ","translation":"তাদের জাদুর","audioUrl":"wbw/020_066_011.mp3","charTypeName":"word"},{"id":57733,"position":11,"arabic":"أَنَّهَا","translation":"তা যে","audioUrl":"wbw/020_066_012.mp3","charTypeName":"word"},{"id":57734,"position":12,"arabic":"تَسْعَىٰ","translation":"ছুটোছুটি","audioUrl":"wbw/020_066_013.mp3","charTypeName":"word"},{"id":57735,"position":13,"arabic":"٦٦","translation":"(৬৬)","audioUrl":null,"charTypeName":"end"}]},{"number":67,"arabic":"فَأَوْجَسَ فِى نَفْسِهِۦ خِيفَةًۭ مُّوسَىٰ","translation":"and in his heart Moses became apprehensive.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2415.mp3","surahId":20,"words":[{"id":58115,"position":1,"arabic":"فَأَوْجَسَ","translation":"অতঃপর অনুভব করলো","audioUrl":"wbw/020_067_001.mp3","charTypeName":"word"},{"id":58116,"position":2,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/020_067_002.mp3","charTypeName":"word"},{"id":58117,"position":3,"arabic":"نَفْسِهِۦ","translation":"তার নিজের","audioUrl":"wbw/020_067_003.mp3","charTypeName":"word"},{"id":58118,"position":4,"arabic":"خِيفَةًۭ","translation":"ভয়","audioUrl":"wbw/020_067_004.mp3","charTypeName":"word"},{"id":58119,"position":5,"arabic":"مُّوسَىٰ","translation":"মূসা (নিজেও)","audioUrl":"wbw/020_067_005.mp3","charTypeName":"word"},{"id":58120,"position":6,"arabic":"٦٧","translation":"(৬৭)","audioUrl":null,"charTypeName":"end"}]},{"number":68,"arabic":"قُلْنَا لَا تَخَفْ إِنَّكَ أَنتَ ٱلْأَعْلَىٰ","translation":"[But] We said: \"Fear not! Verily, it is thou who shalt prevail!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2416.mp3","surahId":20,"words":[{"id":58533,"position":1,"arabic":"قُلْنَا","translation":"আমরা বললাম","audioUrl":"wbw/020_068_001.mp3","charTypeName":"word"},{"id":58534,"position":2,"arabic":"لَا","translation":"\"না","audioUrl":"wbw/020_068_002.mp3","charTypeName":"word"},{"id":58535,"position":3,"arabic":"تَخَفْ","translation":"ভয় করো","audioUrl":"wbw/020_068_003.mp3","charTypeName":"word"},{"id":58536,"position":4,"arabic":"إِنَّكَ","translation":"তুমি নিশ্চয়ই","audioUrl":"wbw/020_068_004.mp3","charTypeName":"word"},{"id":58537,"position":5,"arabic":"أَنتَ","translation":"তুমিই","audioUrl":"wbw/020_068_005.mp3","charTypeName":"word"},{"id":58538,"position":6,"arabic":"ٱلْأَعْلَىٰ","translation":"বিজয়ী (হবে)","audioUrl":"wbw/020_068_006.mp3","charTypeName":"word"},{"id":58539,"position":7,"arabic":"٦٨","translation":"(৬৮)","audioUrl":null,"charTypeName":"end"}]},{"number":69,"arabic":"وَأَلْقِ مَا فِى يَمِينِكَ تَلْقَفْ مَا صَنَعُوٓا۟ ۖ إِنَّمَا صَنَعُوا۟ كَيْدُ سَٰحِرٍۢ ۖ وَلَا يُفْلِحُ ٱلسَّاحِرُ حَيْثُ أَتَىٰ","translation":"And [now] throw that [staff] which is in thy right hand -it shall swallow up all that they have wrought: [for] they have wrought only a sorcerer's artifice, and the sorcerer can never come to any good, whatever he may aim at!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2417.mp3","surahId":20,"words":[{"id":59072,"position":1,"arabic":"وَأَلْقِ","translation":"এবং নিক্ষেপ করো","audioUrl":"wbw/020_069_001.mp3","charTypeName":"word"},{"id":59073,"position":2,"arabic":"مَا","translation":"যা","audioUrl":"wbw/020_069_002.mp3","charTypeName":"word"},{"id":59074,"position":3,"arabic":"فِى","translation":"মধ্যে (আছে)","audioUrl":"wbw/020_069_003.mp3","charTypeName":"word"},{"id":59075,"position":4,"arabic":"يَمِينِكَ","translation":"তোমার ডান হাতের","audioUrl":"wbw/020_069_004.mp3","charTypeName":"word"},{"id":59076,"position":5,"arabic":"تَلْقَفْ","translation":"গ্রাস করবে","audioUrl":"wbw/020_069_005.mp3","charTypeName":"word"},{"id":59077,"position":6,"arabic":"مَا","translation":"যা কিছু","audioUrl":"wbw/020_069_006.mp3","charTypeName":"word"},{"id":59078,"position":7,"arabic":"صَنَعُوٓا۟ ۖ","translation":"তারা বানিয়েছে","audioUrl":"wbw/020_069_007.mp3","charTypeName":"word"},{"id":59080,"position":8,"arabic":"إِنَّمَا","translation":"মূলতঃ","audioUrl":"wbw/020_069_009.mp3","charTypeName":"word"},{"id":59081,"position":9,"arabic":"صَنَعُوا۟","translation":"তারা বানিয়েছে","audioUrl":"wbw/020_069_010.mp3","charTypeName":"word"},{"id":59082,"position":10,"arabic":"كَيْدُ","translation":"কলাকৌশল","audioUrl":"wbw/020_069_011.mp3","charTypeName":"word"},{"id":59083,"position":11,"arabic":"سَـٰحِرٍۢ ۖ","translation":"জাদুকরের","audioUrl":"wbw/020_069_012.mp3","charTypeName":"word"},{"id":59085,"position":12,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/020_069_014.mp3","charTypeName":"word"},{"id":59086,"position":13,"arabic":"يُفْلِحُ","translation":"সফল হয়","audioUrl":"wbw/020_069_015.mp3","charTypeName":"word"},{"id":59087,"position":14,"arabic":"ٱلسَّاحِرُ","translation":"জাদুকর","audioUrl":"wbw/020_069_016.mp3","charTypeName":"word"},{"id":59088,"position":15,"arabic":"حَيْثُ","translation":"যেখান থেকেই","audioUrl":"wbw/020_069_017.mp3","charTypeName":"word"},{"id":59089,"position":16,"arabic":"أَتَىٰ","translation":"আসুক (না কেন)\"","audioUrl":"wbw/020_069_018.mp3","charTypeName":"word"},{"id":59090,"position":17,"arabic":"٦٩","translation":"(৬৯)","audioUrl":null,"charTypeName":"end"}]},{"number":70,"arabic":"فَأُلْقِىَ ٱلسَّحَرَةُ سُجَّدًۭا قَالُوٓا۟ ءَامَنَّا بِرَبِّ هَٰرُونَ وَمُوسَىٰ","translation":"[And so it happened and down fell the sorcerers, prostrating themselves in adoration, [and] exclaimed: \"We have come to believe in the Sustainer of Moses and Aaron!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2418.mp3","surahId":20,"words":[{"id":59456,"position":1,"arabic":"فَأُلْقِىَ","translation":"অতঃপর পড়ে গেল","audioUrl":"wbw/020_070_001.mp3","charTypeName":"word"},{"id":59457,"position":2,"arabic":"ٱلسَّحَرَةُ","translation":"জাদুকররা","audioUrl":"wbw/020_070_002.mp3","charTypeName":"word"},{"id":59458,"position":3,"arabic":"سُجَّدًۭا","translation":"সিজদায়","audioUrl":"wbw/020_070_003.mp3","charTypeName":"word"},{"id":59459,"position":4,"arabic":"قَالُوٓا۟","translation":"তারা বললো","audioUrl":"wbw/020_070_004.mp3","charTypeName":"word"},{"id":59460,"position":5,"arabic":"ءَامَنَّا","translation":"\"আমরা ঈমান আনলাম","audioUrl":"wbw/020_070_005.mp3","charTypeName":"word"},{"id":59461,"position":6,"arabic":"بِرَبِّ","translation":"রবের উপর","audioUrl":"wbw/020_070_006.mp3","charTypeName":"word"},{"id":59462,"position":7,"arabic":"هَـٰرُونَ","translation":"হারূনের","audioUrl":"wbw/020_070_007.mp3","charTypeName":"word"},{"id":59463,"position":8,"arabic":"وَمُوسَىٰ","translation":"ও মূসার\"","audioUrl":"wbw/020_070_008.mp3","charTypeName":"word"},{"id":59464,"position":9,"arabic":"٧٠","translation":"(৭০)","audioUrl":null,"charTypeName":"end"}]},{"number":71,"arabic":"قَالَ ءَامَنتُمْ لَهُۥ قَبْلَ أَنْ ءَاذَنَ لَكُمْ ۖ إِنَّهُۥ لَكَبِيرُكُمُ ٱلَّذِى عَلَّمَكُمُ ٱلسِّحْرَ ۖ فَلَأُقَطِّعَنَّ أَيْدِيَكُمْ وَأَرْجُلَكُم مِّنْ خِلَٰفٍۢ وَلَأُصَلِّبَنَّكُمْ فِى جُذُوعِ ٱلنَّخْلِ وَلَتَعْلَمُنَّ أَيُّنَآ أَشَدُّ عَذَابًۭا وَأَبْقَىٰ","translation":"Said [Pharaoh]: \"Have you come to believe in him ere I have given you permission? Verily, he must be your master who has taught you magic! But I shall most certainly cut off your hands and feet in great numbers, because of [your] perverseness, and I shall most certainly crucify you in great numbers on trunks of palm-trees: and [I shall do this] so that you might come to know for certain as to which of us [two] can inflict a more severe chastisement, and [which] is the more abiding!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2419.mp3","surahId":20,"words":[{"id":59819,"position":1,"arabic":"قَالَ","translation":"(ফিরআউন) বললো","audioUrl":"wbw/020_071_001.mp3","charTypeName":"word"},{"id":59820,"position":2,"arabic":"ءَامَنتُمْ","translation":"\"তোমরা ঈমান এনেছো","audioUrl":"wbw/020_071_002.mp3","charTypeName":"word"},{"id":59821,"position":3,"arabic":"لَهُۥ","translation":"তার উপর","audioUrl":"wbw/020_071_003.mp3","charTypeName":"word"},{"id":59822,"position":4,"arabic":"قَبْلَ","translation":"পূর্বেই","audioUrl":"wbw/020_071_004.mp3","charTypeName":"word"},{"id":59823,"position":5,"arabic":"أَنْ","translation":"যে","audioUrl":"wbw/020_071_005.mp3","charTypeName":"word"},{"id":59824,"position":6,"arabic":"ءَاذَنَ","translation":"আমি অনুমতি দিবো","audioUrl":"wbw/020_071_006.mp3","charTypeName":"word"},{"id":59825,"position":7,"arabic":"لَكُمْ ۖ","translation":"তোমাদেরকে","audioUrl":"wbw/020_071_007.mp3","charTypeName":"word"},{"id":59827,"position":8,"arabic":"إِنَّهُۥ","translation":"সে নিশ্চয়ই","audioUrl":"wbw/020_071_009.mp3","charTypeName":"word"},{"id":59828,"position":9,"arabic":"لَكَبِيرُكُمُ",