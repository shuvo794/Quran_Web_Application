{"id":228,"ayahs":[{"number":54,"arabic":"إِن نَّقُولُ إِلَّا ٱعْتَرَىٰكَ بَعْضُ ءَالِهَتِنَا بِسُوٓءٍۢ ۗ قَالَ إِنِّىٓ أُشْهِدُ ٱللَّهَ وَٱشْهَدُوٓا۟ أَنِّى بَرِىٓءٌۭ مِّمَّا تُشْرِكُونَ","translation":"We can say no more than that one of our gods may have smitten thee with something evil!\" Answered [Hud]: \"Behold, I call God to witness - and you, too, be [my] witnesses - that, verily, it is not in me to ascribe divinity, as you do, to aught","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1527.mp3","surahId":11,"words":[{"id":51304,"position":1,"arabic":"إِن","translation":"না","audioUrl":"wbw/011_054_001.mp3","charTypeName":"word"},{"id":51305,"position":2,"arabic":"نَّقُولُ","translation":"আমরা বলি","audioUrl":"wbw/011_054_002.mp3","charTypeName":"word"},{"id":51306,"position":3,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/011_054_003.mp3","charTypeName":"word"},{"id":51307,"position":4,"arabic":"ٱعْتَرَىٰكَ","translation":"তোমাকে আচ্ছন্ন করেছে","audioUrl":"wbw/011_054_004.mp3","charTypeName":"word"},{"id":51308,"position":5,"arabic":"بَعْضُ","translation":"কেউ","audioUrl":"wbw/011_054_005.mp3","charTypeName":"word"},{"id":51309,"position":6,"arabic":"ءَالِهَتِنَا","translation":"আমাদের উপাস্যদের","audioUrl":"wbw/011_054_006.mp3","charTypeName":"word"},{"id":51310,"position":7,"arabic":"بِسُوٓءٍۢ ۗ","translation":"দিয়ে মন্দ\"","audioUrl":"wbw/011_054_007.mp3","charTypeName":"word"},{"id":51312,"position":8,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/011_054_009.mp3","charTypeName":"word"},{"id":51313,"position":9,"arabic":"إِنِّىٓ","translation":"\"নিশ্চয়ই আমি","audioUrl":"wbw/011_054_010.mp3","charTypeName":"word"},{"id":51314,"position":10,"arabic":"أُشْهِدُ","translation":"সাক্ষী করছি","audioUrl":"wbw/011_054_011.mp3","charTypeName":"word"},{"id":51315,"position":11,"arabic":"ٱللَّهَ","translation":"আল্লাহকে","audioUrl":"wbw/011_054_012.mp3","charTypeName":"word"},{"id":51316,"position":12,"arabic":"وَٱشْهَدُوٓا۟","translation":"এবং তোমরাও সাক্ষী থাকো","audioUrl":"wbw/011_054_013.mp3","charTypeName":"word"},{"id":51317,"position":13,"arabic":"أَنِّى","translation":"নিশ্চয়ই আমি","audioUrl":"wbw/011_054_014.mp3","charTypeName":"word"},{"id":51318,"position":14,"arabic":"بَرِىٓءٌۭ","translation":"সম্পর্ক মুক্ত","audioUrl":"wbw/011_054_015.mp3","charTypeName":"word"},{"id":51319,"position":15,"arabic":"مِّمَّا","translation":"তা হ'তে যা","audioUrl":"wbw/011_054_016.mp3","charTypeName":"word"},{"id":51320,"position":16,"arabic":"تُشْرِكُونَ","translation":"তোমরা শরিক করছো","audioUrl":"wbw/011_054_017.mp3","charTypeName":"word"},{"id":51321,"position":17,"arabic":"٥٤","translation":"(৫৪)","audioUrl":null,"charTypeName":"end"}]},{"number":55,"arabic":"مِن دُونِهِۦ ۖ فَكِيدُونِى جَمِيعًۭا ثُمَّ لَا تُنظِرُونِ","translation":"beside Him! Contrive, then, [anything that you may wish] against me, all of you, and give me no respite!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1528.mp3","surahId":11,"words":[{"id":51919,"position":1,"arabic":"مِن","translation":"ছাড়া","audioUrl":"wbw/011_055_001.mp3","charTypeName":"word"},{"id":51920,"position":2,"arabic":"دُونِهِۦ ۖ","translation":"তাঁকে","audioUrl":"wbw/011_055_002.mp3","charTypeName":"word"},{"id":51922,"position":3,"arabic":"فَكِيدُونِى","translation":"আমার বিরুদ্ধে এখন তোমরা ষড়যন্ত্র করো","audioUrl":"wbw/011_055_004.mp3","charTypeName":"word"},{"id":51923,"position":4,"arabic":"جَمِيعًۭا","translation":"সকলে (মিলে)","audioUrl":"wbw/011_055_005.mp3","charTypeName":"word"},{"id":51924,"position":5,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/011_055_006.mp3","charTypeName":"word"},{"id":51925,"position":6,"arabic":"لَا","translation":"না","audioUrl":"wbw/011_055_007.mp3","charTypeName":"word"},{"id":51926,"position":7,"arabic":"تُنظِرُونِ","translation":"আমাকে তোমরা অবকাশ দিও","audioUrl":"wbw/011_055_008.mp3","charTypeName":"word"},{"id":51927,"position":8,"arabic":"٥٥","translation":"(৫৫)","audioUrl":null,"charTypeName":"end"}]},{"number":56,"arabic":"إِنِّى تَوَكَّلْتُ عَلَى ٱللَّهِ رَبِّى وَرَبِّكُم ۚ مَّا مِن دَآبَّةٍ إِلَّا هُوَ ءَاخِذٌۢ بِنَاصِيَتِهَآ ۚ إِنَّ رَبِّى عَلَىٰ صِرَٰطٍۢ مُّسْتَقِيمٍۢ","translation":"Behold, I have placed my trust in God, [who is] my Sustainer as well as your Sustainer: for there is no living creature which He does not hold by its forelock. Verily, straight is my Sustainer's way!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1529.mp3","surahId":11,"words":[{"id":52346,"position":1,"arabic":"إِنِّى","translation":"নিশ্চয়ই আমি","audioUrl":"wbw/011_056_001.mp3","charTypeName":"word"},{"id":52347,"position":2,"arabic":"تَوَكَّلْتُ","translation":"নির্ভর করছি","audioUrl":"wbw/011_056_002.mp3","charTypeName":"word"},{"id":52348,"position":3,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/011_056_003.mp3","charTypeName":"word"},{"id":52349,"position":4,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/011_056_004.mp3","charTypeName":"word"},{"id":52350,"position":5,"arabic":"رَبِّى","translation":"(যিনি) আমার রব","audioUrl":"wbw/011_056_005.mp3","charTypeName":"word"},{"id":52351,"position":6,"arabic":"وَرَبِّكُم ۚ","translation":"ও তোমাদের রব","audioUrl":"wbw/011_056_006.mp3","charTypeName":"word"},{"id":52353,"position":7,"arabic":"مَّا","translation":"নেই","audioUrl":"wbw/011_056_008.mp3","charTypeName":"word"},{"id":52354,"position":8,"arabic":"مِن","translation":"কোন","audioUrl":"wbw/011_056_009.mp3","charTypeName":"word"},{"id":52355,"position":9,"arabic":"دَآبَّةٍ","translation":"বিচরণশীল প্রণী","audioUrl":"wbw/011_056_010.mp3","charTypeName":"word"},{"id":52356,"position":10,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/011_056_011.mp3","charTypeName":"word"},{"id":52357,"position":11,"arabic":"هُوَ","translation":"তিনি","audioUrl":"wbw/011_056_012.mp3","charTypeName":"word"},{"id":52358,"position":12,"arabic":"ءَاخِذٌۢ","translation":"ধারণকারী","audioUrl":"wbw/011_056_013.mp3","charTypeName":"word"},{"id":52359,"position":13,"arabic":"بِنَاصِيَتِهَآ ۚ","translation":"তার সামনের কেশগুচ্ছকে","audioUrl":"wbw/011_056_014.mp3","charTypeName":"word"},{"id":52361,"position":14,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/011_056_016.mp3","charTypeName":"word"},{"id":52362,"position":15,"arabic":"رَبِّى","translation":"আমার রব","audioUrl":"wbw/011_056_017.mp3","charTypeName":"word"},{"id":52363,"position":16,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/011_056_018.mp3","charTypeName":"word"},{"id":52364,"position":17,"arabic":"صِرَٰطٍۢ","translation":"পথের","audioUrl":"wbw/011_056_019.mp3","charTypeName":"word"},{"id":52365,"position":18,"arabic":"مُّسْتَقِيمٍۢ","translation":"সরল-সঠিক (অর্থাৎ এই পথেই তাঁকে পাবে)","audioUrl":"wbw/011_056_020.mp3","charTypeName":"word"},{"id":52366,"position":19,"arabic":"٥٦","translation":"(৫৬)","audioUrl":null,"charTypeName":"end"}]},{"number":57,"arabic":"فَإِن تَوَلَّوْا۟ فَقَدْ أَبْلَغْتُكُم مَّآ أُرْسِلْتُ بِهِۦٓ إِلَيْكُمْ ۚ وَيَسْتَخْلِفُ رَبِّى قَوْمًا غَيْرَكُمْ وَلَا تَضُرُّونَهُۥ شَيْـًٔا ۚ إِنَّ رَبِّى عَلَىٰ كُلِّ شَىْءٍ حَفِيظٌۭ","translation":"\"But if you choose to turn away, then [know that] I have delivered to you the message with which I was sent unto you, and [that] my Sustainer may cause another people to take your place, whereas you will in no wise harm Him. Verily, my Sustainer watches over all things!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1530.mp3","surahId":11,"words":[{"id":52886,"position":1,"arabic":"فَإِن","translation":"অতঃপর যদি","audioUrl":"wbw/011_057_001.mp3","charTypeName":"word"},{"id":52887,"position":2,"arabic":"تَوَلَّوْا۟","translation":"মুখ ফিরিয়ে নাও","audioUrl":"wbw/011_057_002.mp3","charTypeName":"word"},{"id":52888,"position":3,"arabic":"فَقَدْ","translation":"তবে নিশ্চয়ই","audioUrl":"wbw/011_057_003.mp3","charTypeName":"word"},{"id":52889,"position":4,"arabic":"أَبْلَغْتُكُم","translation":"তোমাদেরকে আমি পৌঁছিয়েছি","audioUrl":"wbw/011_057_004.mp3","charTypeName":"word"},{"id":52890,"position":5,"arabic":"مَّآ","translation":"তাই","audioUrl":"wbw/011_057_005.mp3","charTypeName":"word"},{"id":52891,"position":6,"arabic":"أُرْسِلْتُ","translation":"আমি প্রেরিত হয়েছি","audioUrl":"wbw/011_057_006.mp3","charTypeName":"word"},{"id":52892,"position":7,"arabic":"بِهِۦٓ","translation":"নিয়ে যা","audioUrl":"wbw/011_057_007.mp3","charTypeName":"word"},{"id":52893,"position":8,"arabic":"إِلَيْكُمْ ۚ","translation":"তোমাদের প্রতি","audioUrl":"wbw/011_057_008.mp3","charTypeName":"word"},{"id":52895,"position":9,"arabic":"وَيَسْتَخْلِفُ","translation":"স্থলাভিষিক্ত করবেন","audioUrl":"wbw/011_057_010.mp3","charTypeName":"word"},{"id":52896,"position":10,"arabic":"رَبِّى","translation":"আমার রব","audioUrl":"wbw/011_057_011.mp3","charTypeName":"word"},{"id":52897,"position":11,"arabic":"قَوْمًا","translation":"(অন্য) সম্প্ররদায়কে","audioUrl":"wbw/011_057_012.mp3","charTypeName":"word"},{"id":52898,"position":12,"arabic":"غَيْرَكُمْ","translation":"তোমাদের ছাড়া","audioUrl":"wbw/011_057_013.mp3","charTypeName":"word"},{"id":52899,"position":13,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/011_057_014.mp3","charTypeName":"word"},{"id":52900,"position":14,"arabic":"تَضُرُّونَهُۥ","translation":"তাঁকে তোমরা ক্ষতি করতে পারবে","audioUrl":"wbw/011_057_015.mp3","charTypeName":"word"},{"id":52901,"position":15,"arabic":"شَيْـًٔا ۚ","translation":"কিছুমাত্র","audioUrl":"wbw/011_057_016.mp3","charTypeName":"word"},{"id":52903,"position":16,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/011_057_018.mp3","charTypeName":"word"},{"id":52904,"position":17,"arabic":"رَبِّى","translation":"আমার রব","audioUrl":"wbw/011_057_019.mp3","charTypeName":"word"},{"id":52905,"position":18,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/011_057_020.mp3","charTypeName":"word"},{"id":52906,"position":19,"arabic":"كُلِّ","translation":"সব","audioUrl":"wbw/011_057_021.mp3","charTypeName":"word"},{"id":52907,"position":20,"arabic":"شَىْءٍ","translation":"কিছুর","audioUrl":"wbw/011_057_022.mp3","charTypeName":"word"},{"id":52908,"position":21,"arabic":"حَفِيظٌۭ","translation":"রক্ষণাবেক্ষণকারী (নিয়ন্ত্রনকারী)\"","audioUrl":"wbw/011_057_023.mp3","charTypeName":"word"},{"id":52909,"position":22,"arabic":"٥٧","translation":"(৫৭)","audioUrl":null,"charTypeName":"end"}]},{"number":58,"arabic":"وَلَمَّا جَآءَ أَمْرُنَا نَجَّيْنَا هُودًۭا وَٱلَّذِينَ ءَامَنُوا۟ مَعَهُۥ بِرَحْمَةٍۢ مِّنَّا وَنَجَّيْنَٰهُم مِّنْ عَذَابٍ غَلِيظٍۢ","translation":"And so, when Our judgment came to pass, by Our grace We saved Hud and those who shared his faith; and We saved them [too] from suffering severe [in the life to come].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1531.mp3","surahId":11,"words":[{"id":53422,"position":1,"arabic":"وَلَمَّا","translation":"এবং যখন","audioUrl":"wbw/011_058_001.mp3","charTypeName":"word"},{"id":53423,"position":2,"arabic":"جَآءَ","translation":"আসলো","audioUrl":"wbw/011_058_002.mp3","charTypeName":"word"},{"id":53424,"position":3,"arabic":"أَمْرُنَا","translation":"আমাদের নির্দেশ","audioUrl":"wbw/011_058_003.mp3","charTypeName":"word"},{"id":53425,"position":4,"arabic":"نَجَّيْنَا","translation":"আমরা রক্ষা করলাম","audioUrl":"wbw/011_058_004.mp3","charTypeName":"word"},{"id":53426,"position":5,"arabic":"هُودًۭا","translation":"হূদকে","audioUrl":"wbw/011_058_005.mp3","charTypeName":"word"},{"id":53427,"position":6,"arabic":"وَٱلَّذِينَ","translation":"ও যারা","audioUrl":"wbw/011_058_006.mp3","charTypeName":"word"},{"id":53428,"position":7,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছিলো","audioUrl":"wbw/011_058_007.mp3","charTypeName":"word"},{"id":53429,"position":8,"arabic":"مَعَهُۥ","translation":"তার সাথে","audioUrl":"wbw/011_058_008.mp3","charTypeName":"word"},{"id":53430,"position":9,"arabic":"بِرَحْمَةٍۢ","translation":"অনুগ্রহ দিয়ে","audioUrl":"wbw/011_058_009.mp3","charTypeName":"word"},{"id":53431,"position":10,"arabic":"مِّنَّا","translation":"আমাদের পক্ষ থেকে","audioUrl":"wbw/011_058_010.mp3","charTypeName":"word"},{"id":53432,"position":11,"arabic":"وَنَجَّيْنَـٰهُم","translation":"এবং তাদেরকে আমরা রক্ষা করলাম","audioUrl":"wbw/011_058_011.mp3","charTypeName":"word"},{"id":53433,"position":12,"arabic":"مِّنْ","translation":"হ'তে","audioUrl":"wbw/011_058_012.mp3","charTypeName":"word"},{"id":53434,"position":13,"arabic":"عَذَابٍ","translation":"শাস্তি","audioUrl":"wbw/011_058_013.mp3","charTypeName":"word"},{"id":53435,"position":14,"arabic":"غَلِيظٍۢ","translation":"কঠিন","audioUrl":"wbw/011_058_014.mp3","charTypeName":"word"},{"id":53436,"position":15,"arabic":"٥٨","translation":"(৫৮)","audioUrl":null,"charTypeName":"end"}]},{"number":59,"arabic":"وَتِلْكَ عَادٌۭ ۖ جَحَدُوا۟ بِـَٔايَٰتِ رَبِّهِمْ وَعَصَوْا۟ رُسُلَهُۥ وَٱتَّبَعُوٓا۟ أَمْرَ كُلِّ جَبَّارٍ عَنِيدٍۢ","translation":"And that was [the end of the tribe of] `Ad, [who] had rejected their Sustainer's messages, and rebelled against His apostles, and followed the bidding of every arrogant enemy of the truth.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1532.mp3","surahId":11,"words":[{"id":53908,"position":1,"arabic":"وَتِلْكَ","translation":"এবং এই (ছিলো)","audioUrl":"wbw/011_059_001.mp3","charTypeName":"word"},{"id":53909,"position":2,"arabic":"عَادٌۭ ۖ","translation":"আদ জাতি","audioUrl":"wbw/011_059_002.mp3","charTypeName":"word"},{"id":53911,"position":3,"arabic":"جَحَدُوا۟","translation":"অস্বীকার করেছিল","audioUrl":"wbw/011_059_004.mp3","charTypeName":"word"},{"id":53912,"position":4,"arabic":"بِـَٔايَـٰتِ","translation":"নিদর্শনাবলীকে","audioUrl":"wbw/011_059_005.mp3","charTypeName":"word"},{"id":53913,"position":5,"arabic":"رَبِّهِمْ","translation":"তাদের রবের","audioUrl":"wbw/011_059_006.mp3","charTypeName":"word"},{"id":53914,"position":6,"arabic":"وَعَصَوْا۟","translation":"এবং তারা অমান্য করেছিলো","audioUrl":"wbw/011_059_007.mp3","charTypeName":"word"},{"id":53915,"position":7,"arabic":"رُسُلَهُۥ","translation":"তাঁর রাসূলদেরকে","audioUrl":"wbw/011_059_008.mp3","charTypeName":"word"},{"id":53916,"position":8,"arabic":"وَٱتَّبَعُوٓا۟","translation":"এবং তারা অনুসরণ করেছিলো","audioUrl":"wbw/011_059_009.mp3","charTypeName":"word"},{"id":53917,"position":9,"arabic":"أَمْرَ","translation":"নির্দেশের","audioUrl":"wbw/011_059_010.mp3","charTypeName":"word"},{"id":53918,"position":10,"arabic":"كُلِّ","translation":"প্রত্যেক","audioUrl":"wbw/011_059_011.mp3","charTypeName":"word"},{"id":53919,"position":11,"arabic":"جَبَّارٍ","translation":"উদ্ধত","audioUrl":"wbw/011_059_012.mp3","charTypeName":"word"},{"id":53920,"position":12,"arabic":"عَنِيدٍۢ","translation":"স্বৈরাচারীর","audioUrl":"wbw/011_059_013.mp3","charTypeName":"word"},{"id":53921,"position":13,"arabic":"٥٩","translation":"(৫৯)","audioUrl":null,"charTypeName":"end"}]},{"number":60,"arabic":"وَأُتْبِعُوا۟ فِى هَٰذِهِ ٱلدُّنْيَا لَعْنَةًۭ وَيَوْمَ ٱلْقِيَٰمَةِ ۗ أَلَآ إِنَّ عَادًۭا كَفَرُوا۟ رَبَّهُمْ ۗ أَلَا بُعْدًۭا لِّعَادٍۢ قَوْمِ هُودٍۢ","translation":"And they were pursued in this world by [God's] rejection, and [shall finally be overtaken by it] on the Day of Resurrection. Oh, verily, [the tribe of] `Ad denied their Sustainer! Oh, away with the `Ad, the people of Hud!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1533.mp3","surahId":11,"words":[{"id":54565,"position":1,"arabic":"وَأُتْبِعُوا۟","translation":"এবং তাদের পিছনে লাগিয়ে দেয়া হলো","audioUrl":"wbw/011_060_001.mp3","charTypeName":"word"},{"id":54566,"position":2,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/011_060_002.mp3","charTypeName":"word"},{"id":54567,"position":3,"arabic":"هَـٰذِهِ","translation":"এই","audioUrl":"wbw/011_060_003.mp3","charTypeName":"word"},{"id":54568,"position":4,"arabic":"ٱلدُّنْيَا","translation":"পৃথিবীর","audioUrl":"wbw/011_060_004.mp3","charTypeName":"word"},{"id":54569,"position":5,"arabic":"لَعْنَةًۭ","translation":"অভিশাপ","audioUrl":"wbw/011_060_005.mp3","charTypeName":"word"},{"id":54570,"posit