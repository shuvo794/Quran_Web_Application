mp3","charTypeName":"word"},{"id":24816,"position":37,"arabic":"فِيهَا ۚ","translation":"তার মধ্যে","audioUrl":"wbw/058_022_039.mp3","charTypeName":"word"},{"id":24818,"position":38,"arabic":"رَضِىَ","translation":"সন্তুষ্ট/ প্রসন্ন হয়েছেন","audioUrl":"wbw/058_022_041.mp3","charTypeName":"word"},{"id":24819,"position":39,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/058_022_042.mp3","charTypeName":"word"},{"id":24820,"position":40,"arabic":"عَنْهُمْ","translation":"তাদের প্রতি","audioUrl":"wbw/058_022_043.mp3","charTypeName":"word"},{"id":24821,"position":41,"arabic":"وَرَضُوا۟","translation":"ও তারা সন্তুষ্ট হয়েছে","audioUrl":"wbw/058_022_044.mp3","charTypeName":"word"},{"id":24822,"position":42,"arabic":"عَنْهُ ۚ","translation":"তাঁর প্রতি","audioUrl":"wbw/058_022_045.mp3","charTypeName":"word"},{"id":24824,"position":43,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐসব লোক(অন্তর্ভুক্ত)","audioUrl":"wbw/058_022_047.mp3","charTypeName":"word"},{"id":24825,"position":44,"arabic":"حِزْبُ","translation":"দলের","audioUrl":"wbw/058_022_048.mp3","charTypeName":"word"},{"id":24826,"position":45,"arabic":"ٱللَّهِ ۚ","translation":"আল্লাহর","audioUrl":"wbw/058_022_049.mp3","charTypeName":"word"},{"id":24828,"position":46,"arabic":"أَلَآ","translation":"জেনে রাখ","audioUrl":"wbw/058_022_051.mp3","charTypeName":"word"},{"id":24829,"position":47,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/058_022_052.mp3","charTypeName":"word"},{"id":24830,"position":48,"arabic":"حِزْبَ","translation":"দল","audioUrl":"wbw/058_022_053.mp3","charTypeName":"word"},{"id":24831,"position":49,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/058_022_054.mp3","charTypeName":"word"},{"id":24832,"position":50,"arabic":"هُمُ","translation":"তারাই","audioUrl":"wbw/058_022_055.mp3","charTypeName":"word"},{"id":24833,"position":51,"arabic":"ٱلْمُفْلِحُونَ","translation":"সফলকাম","audioUrl":"wbw/058_022_056.mp3","charTypeName":"word"},{"id":24834,"position":52,"arabic":"٢٢","translation":"(২২)","audioUrl":null,"charTypeName":"end"}]},{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ سَبَّحَ لِلَّهِ مَا فِى ٱلسَّمَٰوَٰتِ وَمَا فِى ٱلْأَرْضِ ۖ وَهُوَ ٱلْعَزِيزُ ٱلْحَكِيمُ","translation":"ALL THAT IS in the heavens and all that is on earth extols God’s limitless glory: for He alone is almighty, truly wise.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5127.mp3","surahId":59,"words":[{"id":378,"position":1,"arabic":"سَبَّحَ","translation":"তাসবিহ করে","audioUrl":"wbw/059_001_001.mp3","charTypeName":"word"},{"id":379,"position":2,"arabic":"لِلَّهِ","translation":"আল্লাহর জন্য","audioUrl":"wbw/059_001_002.mp3","charTypeName":"word"},{"id":380,"position":3,"arabic":"مَا","translation":"যা কিছু","audioUrl":"wbw/059_001_003.mp3","charTypeName":"word"},{"id":381,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/059_001_004.mp3","charTypeName":"word"},{"id":382,"position":5,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশসমূহের","audioUrl":"wbw/059_001_005.mp3","charTypeName":"word"},{"id":383,"position":6,"arabic":"وَمَا","translation":"ও যা কিছু","audioUrl":"wbw/059_001_006.mp3","charTypeName":"word"},{"id":384,"position":7,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/059_001_007.mp3","charTypeName":"word"},{"id":385,"position":8,"arabic":"ٱلْأَرْضِ ۖ","translation":"পৃথিবীর","audioUrl":"wbw/059_001_008.mp3","charTypeName":"word"},{"id":387,"position":9,"arabic":"وَهُوَ","translation":"এবং তিনিই","audioUrl":"wbw/059_001_010.mp3","charTypeName":"word"},{"id":388,"position":10,"arabic":"ٱلْعَزِيزُ","translation":"পরাক্রমশালী","audioUrl":"wbw/059_001_011.mp3","charTypeName":"word"},{"id":389,"position":11,"arabic":"ٱلْحَكِيمُ","translation":"মহাবিজ্ঞ","audioUrl":"wbw/059_001_012.mp3","charTypeName":"word"},{"id":390,"position":12,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"هُوَ ٱلَّذِىٓ أَخْرَجَ ٱلَّذِينَ كَفَرُوا۟ مِنْ أَهْلِ ٱلْكِتَٰبِ مِن دِيَٰرِهِمْ لِأَوَّلِ ٱلْحَشْرِ ۚ مَا ظَنَنتُمْ أَن يَخْرُجُوا۟ ۖ وَظَنُّوٓا۟ أَنَّهُم مَّانِعَتُهُمْ حُصُونُهُم مِّنَ ٱللَّهِ فَأَتَىٰهُمُ ٱللَّهُ مِنْ حَيْثُ لَمْ يَحْتَسِبُوا۟ ۖ وَقَذَفَ فِى قُلُوبِهِمُ ٱلرُّعْبَ ۚ يُخْرِبُونَ بُيُوتَهُم بِأَيْدِيهِمْ وَأَيْدِى ٱلْمُؤْمِنِينَ فَٱعْتَبِرُوا۟ يَٰٓأُو۟لِى ٱلْأَبْصَٰرِ","translation":"He it is who turned out of their homes, at the time of [their] first gathering [for war], such of the followers of earlier revelation as were bent on denying the truth. You did not think [O believers] that they would depart [without resistance] - just as they thought that their strongholds would protect them against God: but God came upon them in a manner which they had not expected, and cast terror into their hearts; [and thus] they destroyed their homes by their own hands as well as the hands of the believers. Learn a lesson, then, O you who are endowed with insight!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5128.mp3","surahId":59,"words":[{"id":1271,"position":1,"arabic":"هُوَ","translation":"তিনিই","audioUrl":"wbw/059_002_001.mp3","charTypeName":"word"},{"id":1272,"position":2,"arabic":"ٱلَّذِىٓ","translation":"যিনি","audioUrl":"wbw/059_002_002.mp3","charTypeName":"word"},{"id":1273,"position":3,"arabic":"أَخْرَجَ","translation":"বের করেছেন","audioUrl":"wbw/059_002_003.mp3","charTypeName":"word"},{"id":1274,"position":4,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/059_002_004.mp3","charTypeName":"word"},{"id":1275,"position":5,"arabic":"كَفَرُوا۟","translation":"কুফুরি করেছিল","audioUrl":"wbw/059_002_005.mp3","charTypeName":"word"},{"id":1276,"position":6,"arabic":"مِنْ","translation":"মধ্যে","audioUrl":"wbw/059_002_006.mp3","charTypeName":"word"},{"id":1277,"position":7,"arabic":"أَهْلِ","translation":"আহলে","audioUrl":"wbw/059_002_007.mp3","charTypeName":"word"},{"id":1278,"position":8,"arabic":"ٱلْكِتَـٰبِ","translation":"কিতাবদের","audioUrl":"wbw/059_002_008.mp3","charTypeName":"word"},{"id":1279,"p