id":1314,"position":40,"arabic":"ٱلْأَبْصَـٰرِ","translation":"দৃষ্টিবানরা","audioUrl":"wbw/059_002_044.mp3","charTypeName":"word"},{"id":1315,"position":41,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"وَلَوْلَآ أَن كَتَبَ ٱللَّهُ عَلَيْهِمُ ٱلْجَلَآءَ لَعَذَّبَهُمْ فِى ٱلدُّنْيَا ۖ وَلَهُمْ فِى ٱلْءَاخِرَةِ عَذَابُ ٱلنَّارِ","translation":"And had it not been for God’s having ordained banishment for them, He would indeed have imposed [yet greater] suffering on them in this world: still, in the life to come there awaits them suffering through fire:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5129.mp3","surahId":59,"words":[{"id":2366,"position":1,"arabic":"وَلَوْلَآ","translation":"এবং যদি না","audioUrl":"wbw/059_003_001.mp3","charTypeName":"word"},{"id":2367,"position":2,"arabic":"أَن","translation":"যে","audioUrl":"wbw/059_003_002.mp3","charTypeName":"word"},{"id":2368,"position":3,"arabic":"كَتَبَ","translation":"লিখতেন","audioUrl":"wbw/059_003_003.mp3","charTypeName":"word"},{"id":2369,"position":4,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/059_003_004.mp3","charTypeName":"word"},{"id":2370,"position":5,"arabic":"عَلَيْهِمُ","translation":"তাদের উপর","audioUrl":"wbw/059_003_005.mp3","charTypeName":"word"},{"id":2371,"position":6,"arabic":"ٱلْجَلَآءَ","translation":"নির্বাসন","audioUrl":"wbw/059_003_006.mp3","charTypeName":"word"},{"id":2372,"position":7,"arabic":"لَعَذَّبَهُمْ","translation":"তাদের শাস্তি অবশ্যই দিতেন","audioUrl":"wbw/059_003_007.mp3","charTypeName":"word"},{"id":2373,"position":8,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/059_003_008.mp3","charTypeName":"word"},{"id":2374,"position":9,"arabic":"ٱلدُّنْيَا ۖ","translation":"দুনিয়ার","audioUrl":"wbw/059_003_009.mp3","charTypeName":"word"},{"id":2376,"position":10,"arabic":"وَلَهُمْ","translation":"এবং তাদের জন্য","audioUrl":"wbw/059_003_011.mp3","charTypeName":"word"},{"id":2377,"position":11,"ara