dioUrl":"wbw/002_246_058.mp3","charTypeName":"word"},{"id":86864,"position":55,"arabic":"٢٤٦","translation":"(২৪৬)","audioUrl":null,"charTypeName":"end"}]},{"number":247,"arabic":"وَقَالَ لَهُمْ نَبِيُّهُمْ إِنَّ ٱللَّهَ قَدْ بَعَثَ لَكُمْ طَالُوتَ مَلِكًۭا ۚ قَالُوٓا۟ أَنَّىٰ يَكُونُ لَهُ ٱلْمُلْكُ عَلَيْنَا وَنَحْنُ أَحَقُّ بِٱلْمُلْكِ مِنْهُ وَلَمْ يُؤْتَ سَعَةًۭ مِّنَ ٱلْمَالِ ۚ قَالَ إِنَّ ٱللَّهَ ٱصْطَفَىٰهُ عَلَيْكُمْ وَزَادَهُۥ بَسْطَةًۭ فِى ٱلْعِلْمِ وَٱلْجِسْمِ ۖ وَٱللَّهُ يُؤْتِى مُلْكَهُۥ مَن يَشَآءُ ۚ وَٱللَّهُ وَٰسِعٌ عَلِيمٌۭ","translation":"And their prophet said unto those elders: \"Behold, now God has raised up Saul to be your king.\" They said: \"How can he have dominion over us when we have a better claim to dominion than he, and he has not [even] been endowed with abundant wealth?\" [The prophet] replied: \"Behold, God has exalted him above you, and endowed him abundantly with knowledge and bodily perfection. And God bestows His dominion upon whom He wills: for God is infinite, all-knowing.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/254.mp3","surahId":2,"words":[{"id":86865,"position":1,"arabic":"وَقَالَ","translation":"এবং বলেছিল","audioUrl":"wbw/002_247_001.mp3","charTypeName":"word"},{"id":86866,"position":2,"arabic":"لَهُمْ","translation":"তাদের উদ্দেশে","audioUrl":"wbw/002_247_002.mp3","charTypeName":"word"},{"id":86867,"position":3,"arabic":"نَبِيُّهُمْ","translation":"তাদের নবী","audioUrl":"wbw/002_247_003.mp3","charTypeName":"word"},{"id":86868,"position":4,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/002_247_004.mp3","charTypeName":"word"},{"id":86869,"position":5,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/002_247_005.mp3","charTypeName":"word"},{"id":86870,"position":6,"arabic":"قَدْ","translation":"অবশ্যই","audioUrl":"wbw/002_247_006.mp3","charTypeName":"word"},{"id":86871,"position":7,"arabic":"بَعَثَ","translation":"পাঠিয়েছেন","audioUrl":"wbw/002_247_007.mp3","charTypeName":"word"}