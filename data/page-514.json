3","charTypeName":"word"},{"id":29892,"position":24,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/048_027_026.mp3","charTypeName":"word"},{"id":29893,"position":25,"arabic":"دُونِ","translation":"ছাড়া","audioUrl":"wbw/048_027_027.mp3","charTypeName":"word"},{"id":29894,"position":26,"arabic":"ذَٰلِكَ","translation":"সেটা","audioUrl":"wbw/048_027_028.mp3","charTypeName":"word"},{"id":29895,"position":27,"arabic":"فَتْحًۭا","translation":"একটি বিজয়","audioUrl":"wbw/048_027_029.mp3","charTypeName":"word"},{"id":29896,"position":28,"arabic":"قَرِيبًا","translation":"আসন্ন","audioUrl":"wbw/048_027_030.mp3","charTypeName":"word"},{"id":29897,"position":29,"arabic":"٢٧","translation":"(২৭)","audioUrl":null,"charTypeName":"end"}]},{"number":28,"arabic":"هُوَ ٱلَّذِىٓ أَرْسَلَ رَسُولَهُۥ بِٱلْهُدَىٰ وَدِينِ ٱلْحَقِّ لِيُظْهِرَهُۥ عَلَى ٱلدِّينِ كُلِّهِۦ ۚ وَكَفَىٰ بِٱللَّهِ شَهِيدًۭا","translation":"He it is who has sent forth His Apostle with the [task of spreading] guidance and the religion of truth, to the end that He make it prevail over every [false] religion; and none can bear witness [to the truth] as God does.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4611.mp3","surahId":48,"words":[{"id":30664,"position":1,"arabic":"هُوَ","translation":"তিনিই","audioUrl":"wbw/048_028_001.mp3","charTypeName":"word"},{"id":30665,"position":2,"arabic":"ٱلَّذِىٓ","translation":"যিনি","audioUrl":"wbw/048_028_002.mp3","charTypeName":"word"},{"id":30666,"position":3,"arabic":"أَرْسَلَ","translation":"প্রেরণ করেছেন","audioUrl":"wbw/048_028_003.mp3","charTypeName":"word"},{"id":30667,"position":4,"arabic":"رَسُولَهُۥ","translation":"তাঁর রাসুলকে","audioUrl":"wbw/048_028_004.mp3","charTypeName":"word"},{"id":30668,"position":5,"arabic":"بِٱلْهُدَىٰ","translation":"দিয়ে দিক-নির্দেশনা","audioUrl":"wbw/048_028_005.mp3","charTypeName":"word"},{"id":30669,"position":6,"arabic":"وَدِينِ","translation":"ও দীন","audioUrl":"wbw/048_028_006.mp3","charTypeName":"word"},{"id":30670,"position":7,"arabic":"ٱلْحَقِّ","translation":"সত্য (দিয়ে)","audioUrl":"wbw/048_028_007.mp3","charTypeName":"word"},{"id":30671,"position":8,"arabic":"لِيُظْهِرَهُۥ","translation":"তা বিজয়ী করার জন্যে","audioUrl":"wbw/048_028_008.mp3","charTypeName":"word"},{"id":30672,"position":9,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/048_028_009.mp3","charTypeName":"word"},{"id":30673,"position":10,"arabic":"ٱلدِّينِ","translation":"দীনের","audioUrl":"wbw/048_028_010.mp3","charTypeName":"word"},{"id":30674,"position":11,"arabic":"كُلِّهِۦ ۚ","translation":"অন্যান্য সব","audioUrl":"wbw/048_028_011.mp3","charTypeName":"word"},{"id":30676,"position":12,"arabic":"وَكَفَىٰ","translation":"এবং যথেষ্ট","audioUrl":"wbw/048_028_013.mp3","charTypeName":"word"},{"id":30677,"position":13,"arabic":"بِٱللَّهِ","translation":"আল্লাহই এ বিষয়ে","audioUrl":"wbw/048_028_014.mp3","charTypeName":"word"},{"id":30678,"position":14,"arabic":"شَهِيدًۭا","translation":"সাক্ষী হিসেবে","audioUrl":"wbw/048_028_015.mp3","charTypeName":"word"},{"id":30679,"position":15,"arabic":"٢٨","translation":"(২৮)","audioUrl":null,"charTypeName":"end"}]}]}