ُوٓا۟ أَحَقَّ بِهَا وَأَهْلَهَا ۚ وَكَانَ ٱللَّهُ بِكُلِّ شَىْءٍ عَلِيمًۭا","translation":"Whereas they who are bent on denying the truth harboured a stubborn disdain in their hearts - the stubborn disdain [born] of ignorance God bestowed from on high His [gift of] inner peace upon His Apostle and the believers, and bound them to the spirit of God-consciousness: for they were most worthy of this [divine gift], and deserved it well. And God has full knowledge of all things.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4609.mp3","surahId":48,"words":[{"id":28762,"position":1,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/048_026_001.mp3","charTypeName":"word"},{"id":28763,"position":2,"arabic":"جَعَلَ","translation":"পোষণ করল","audioUrl":"wbw/048_026_002.mp3","charTypeName":"word"},{"id":28764,"position":3,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/048_026_003.mp3","charTypeName":"word"},{"id":28765,"position":4,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করেছিল","audioUrl":"wbw/048_026_004.mp3","charTypeName":"word"},{"id":28766,"position":5,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/048_026_005.mp3","charTypeName":"word"},{"id":28767,"position":6,"arabic":"قُلُوبِهِمُ","translation":"তাদের অন্তরগুলোর","audioUrl":"wbw/048_026_006.mp3","charTypeName":"word"},{"id":28768,"position":7,"arabic":"ٱلْحَمِيَّةَ","translation":"হঠকারিতা","audioUrl":"wbw/048_026_007.mp3","charTypeName":"word"},{"id":28769,"position":8,"arabic":"حَمِيَّةَ","translation":"হঠকারিতা","audioUrl":"wbw/048_026_008.mp3","charTypeName":"word"},{"id":28770,"position":9,"arabic":"ٱلْجَـٰهِلِيَّةِ","translation":"অজ্ঞতার","audioUrl":"wbw/048_026_009.mp3","charTypeName":"word"},{"id":28771,"position":10,"arabic":"فَأَنزَلَ","translation":"তখন অবতীর্ণ করলেন","audioUrl":"wbw/048_026_010.mp3","charTypeName":"word"},{"id":28772,"position":11,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌","audioUrl":"wbw/048_026_011.mp3","charTypeName":"word"},{"id":28773,"positi