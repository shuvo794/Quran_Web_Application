udioUrl":"wbw/048_026_028.mp3","charTypeName":"word"},{"id":28790,"position":28,"arabic":"عَلِيمًۭا","translation":"খুব জ্ঞাত","audioUrl":"wbw/048_026_029.mp3","charTypeName":"word"},{"id":28791,"position":29,"arabic":"٢٦","translation":"(২৬)","audioUrl":null,"charTypeName":"end"}]},{"number":27,"arabic":"لَّقَدْ صَدَقَ ٱللَّهُ رَسُولَهُ ٱلرُّءْيَا بِٱلْحَقِّ ۖ لَتَدْخُلُنَّ ٱلْمَسْجِدَ ٱلْحَرَامَ إِن شَآءَ ٱللَّهُ ءَامِنِينَ مُحَلِّقِينَ رُءُوسَكُمْ وَمُقَصِّرِينَ لَا تَخَافُونَ ۖ فَعَلِمَ مَا لَمْ تَعْلَمُوا۟ فَجَعَلَ مِن دُونِ ذَٰلِكَ فَتْحًۭا قَرِيبًا","translation":"Indeed, God has shown the truth in His Apostle’s true vision: most certainly shall you enter the Inviolable House of Worship, if God so wills, in full security, with your heads shaved or your hair cut short, without any fear: for He has [always] known that which you yourselves could not know. And He has ordained [for you], besides this, a victory soon to come.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4610.mp3","surahId":48,"words":[{"id":29867,"position":1,"arabic":"لَّقَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/048_027_001.mp3","charTypeName":"word"},{"id":29868,"position":2,"arabic":"صَدَقَ","translation":"সত্য করে দেখিয়েছেন","audioUrl":"wbw/048_027_002.mp3","charTypeName":"word"},{"id":29869,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌","audioUrl":"wbw/048_027_003.mp3","charTypeName":"word"},{"id":29870,"position":4,"arabic":"رَسُولَهُ","translation":"তাঁর রাসুলের","audioUrl":"wbw/048_027_004.mp3","charTypeName":"word"},{"id":29871,"position":5,"arabic":"ٱلرُّءْيَا","translation":"স্বপ্নকে","audioUrl":"wbw/048_027_005.mp3","charTypeName":"word"},{"id":29872,"position":6,"arabic":"بِٱلْحَقِّ ۖ","translation":"সঠিকভাবে","audioUrl":"wbw/048_027_006.mp3","charTypeName":"word"},{"id":29874,"position":7,"arabic":"لَتَدْخُلُنَّ","translation":"অবশ্যই তোমরা প্রবেশ করবে","audioUrl":"wbw/048_027_008.mp3","charTypeName":"word"},{"id":29875,"position":8,"arabic":"ٱلْمَسْ