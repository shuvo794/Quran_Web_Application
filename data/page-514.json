{"id":514,"ayahs":[{"number":24,"arabic":"وَهُوَ ٱلَّذِى كَفَّ أَيْدِيَهُمْ عَنكُمْ وَأَيْدِيَكُمْ عَنْهُم بِبَطْنِ مَكَّةَ مِنۢ بَعْدِ أَنْ أَظْفَرَكُمْ عَلَيْهِمْ ۚ وَكَانَ ٱللَّهُ بِمَا تَعْمَلُونَ بَصِيرًا","translation":"And He it is who, in the valley of Mecca, stayed their hands from you, and your hands from them, after He had enabled you to vanquish them; and God saw indeed what you were doing.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4607.mp3","surahId":48,"words":[{"id":26772,"position":1,"arabic":"وَهُوَ","translation":"এবং তিনিই","audioUrl":"wbw/048_024_001.mp3","charTypeName":"word"},{"id":26773,"position":2,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/048_024_002.mp3","charTypeName":"word"},{"id":26774,"position":3,"arabic":"كَفَّ","translation":"বিরত রেখেছিলেন","audioUrl":"wbw/048_024_003.mp3","charTypeName":"word"},{"id":26775,"position":4,"arabic":"أَيْدِيَهُمْ","translation":"তাদের হাতগুলোকে","audioUrl":"wbw/048_024_004.mp3","charTypeName":"word"},{"id":26776,"position":5,"arabic":"عَنكُمْ","translation":"তোমাদের হতে","audioUrl":"wbw/048_024_005.mp3","charTypeName":"word"},{"id":26777,"position":6,"arabic":"وَأَيْدِيَكُمْ","translation":"ও তোমাদের হাতগুলোকে","audioUrl":"wbw/048_024_006.mp3","charTypeName":"word"},{"id":26778,"position":7,"arabic":"عَنْهُم","translation":"তাদের হতে","audioUrl":"wbw/048_024_007.mp3","charTypeName":"word"},{"id":26779,"position":8,"arabic":"بِبَطْنِ","translation":"উপকণ্ঠে","audioUrl":"wbw/048_024_008.mp3","charTypeName":"word"},{"id":26780,"position":9,"arabic":"مَكَّةَ","translation":"মক্কার","audioUrl":"wbw/048_024_009.mp3","charTypeName":"word"},{"id":26781,"position":10,"arabic":"مِنۢ","translation":"থেকে","audioUrl":"wbw/048_024_010.mp3","charTypeName":"word"},{"id":26782,"position":11,"arabic":"بَعْدِ","translation":"এরপরেও","audioUrl":"wbw/048_024_011.mp3","charTypeName":"word"},{"id":26783,"position":12,"arabic":"أَنْ","translation":"যে","audioUrl":"wbw/048_024_012.mp3","charTypeName":"word"},{"id":26784,"position":13,"arabic":"أَظْفَرَكُمْ","translation":"তোমাদের বিজয় দিয়েছিলেন","audioUrl":"wbw/048_024_013.mp3","charTypeName":"word"},{"id":26785,"position":14,"arabic":"عَلَيْهِمْ ۚ","translation":"তাদের বিরুদ্ধে","audioUrl":"wbw/048_024_014.mp3","charTypeName":"word"},{"id":26787,"position":15,"arabic":"وَكَانَ","translation":"এবং হলেন","audioUrl":"wbw/048_024_016.mp3","charTypeName":"word"},{"id":26788,"position":16,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌","audioUrl":"wbw/048_024_017.mp3","charTypeName":"word"},{"id":26789,"position":17,"arabic":"بِمَا","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/048_024_018.mp3","charTypeName":"word"},{"id":26790,"position":18,"arabic":"تَعْمَلُونَ","translation":"তোমরা কাজ কর","audioUrl":"wbw/048_024_019.mp3","charTypeName":"word"},{"id":26791,"position":19,"arabic":"بَصِيرًا","translation":"খুব দেখছেন","audioUrl":"wbw/048_024_020.mp3","charTypeName":"word"},{"id":26792,"position":20,"arabic":"٢٤","translation":"(২৪)","audioUrl":null,"charTypeName":"end"}]},{"number":25,"arabic":"هُمُ ٱلَّذِينَ كَفَرُوا۟ وَصَدُّوكُمْ عَنِ ٱلْمَسْجِدِ ٱلْحَرَامِ وَٱلْهَدْىَ مَعْكُوفًا أَن يَبْلُغَ مَحِلَّهُۥ ۚ وَلَوْلَا رِجَالٌۭ مُّؤْمِنُونَ وَنِسَآءٌۭ مُّؤْمِنَٰتٌۭ لَّمْ تَعْلَمُوهُمْ أَن تَطَـُٔوهُمْ فَتُصِيبَكُم مِّنْهُم مَّعَرَّةٌۢ بِغَيْرِ عِلْمٍۢ ۖ لِّيُدْخِلَ ٱللَّهُ فِى رَحْمَتِهِۦ مَن يَشَآءُ ۚ لَوْ تَزَيَّلُوا۟ لَعَذَّبْنَا ٱلَّذِينَ كَفَرُوا۟ مِنْهُمْ عَذَابًا أَلِيمًا","translation":"[It was not for your enemies sake that He stayed your hands from them: for] it was they who were bent on denying the truth, and who debarred you from the Inviolable House of Worship and prevented your offering from reaching its destina­tion. And had it not been for the believing men and believing women [in Mecca], whom you might have unwittingly trampled underfoot, and on whose account you might have become guilty, without knowing it, of a grievous wrong-: [had it not been for this, you would have been allowed to fight your way into the city: but you were forbidden to fight] so that [in time] God might admit to His grace whomever He wills. Had they [who deserve Our mercy and they whom We have condemned] been clearly discernible [to you], We would indeed have imposed grievous suffering [at your hands] on such of them as were bent on denying the truth.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4608.mp3","surahId":48,"words":[{"id":27799,"position":1,"arabic":"هُمُ","translation":"তিনিই","audioUrl":"wbw/048_025_001.mp3","charTypeName":"word"},{"id":27800,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/048_025_002.mp3","charTypeName":"word"},{"id":27801,"position":3,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/048_025_003.mp3","charTypeName":"word"},{"id":27802,"position":4,"arabic":"وَصَدُّوكُمْ","translation":"ও তোমাদের বাধা দিয়েছে","audioUrl":"wbw/048_025_004.mp3","charTypeName":"word"},{"id":27803,"position":5,"arabic":"عَنِ","translation":"হতে","audioUrl":"wbw/048_025_005.mp3","charTypeName":"word"},{"id":27804,"position":6,"arabic":"ٱلْمَسْجِدِ","translation":"মসজিদে","audioUrl":"wbw/048_025_006.mp3","charTypeName":"word"},{"id":27805,"position":7,"arabic":"ٱلْحَرَامِ","translation":"হারাম","audioUrl":"wbw/048_025_007.mp3","charTypeName":"word"},{"id":27806,"position":8,"arabic":"وَٱلْهَدْىَ","translation":"এবং কুরবানির পশুগুলোকে","audioUrl":"wbw/048_025_008.mp3","charTypeName":"word"},{"id":27807,"position":9,"arabic":"مَعْكُوفًا","translation":"(যা ছিল) 'আবদ্ধ'","audioUrl":"wbw/048_025_009.mp3","charTypeName":"word"},{"id":27808,"position":10,"arabic":"أَن","translation":"যে","audioUrl":"wbw/048_025_010.mp3","charTypeName":"word"},{"id":27809,"position":11,"arabic":"يَبْلُغَ","translation":"পৌঁছবে","audioUrl":"wbw/048_025_011.mp3","charTypeName":"word"},{"id":27810,"position":12,"arabic":"مَحِلَّهُۥ ۚ","translation":"তার কুরবানির জায়গায়","audioUrl":"wbw/048_025_012.mp3","charTypeName":"word"},{"id":27812,"posi