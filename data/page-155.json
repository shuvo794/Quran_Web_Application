,"translation":"না","audioUrl":"wbw/007_038_042.mp3","charTypeName":"word"},{"id":40294,"position":40,"arabic":"تَعْلَمُونَ","translation":"তোমরা জানো\"","audioUrl":"wbw/007_038_043.mp3","charTypeName":"word"},{"id":40295,"position":41,"arabic":"٣٨","translation":"(৩৮)","audioUrl":null,"charTypeName":"end"}]},{"number":39,"arabic":"وَقَالَتْ أُولَىٰهُمْ لِأُخْرَىٰهُمْ فَمَا كَانَ لَكُمْ عَلَيْنَا مِن فَضْلٍۢ فَذُوقُوا۟ ٱلْعَذَابَ بِمَا كُنتُمْ تَكْسِبُونَ","translation":"And the first of them will say unto the last of them: \"So you were in no wise superior to us! Taste, then, this suffering for all [the evil] that you were wont to do!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/993.mp3","surahId":7,"words":[{"id":41003,"position":1,"arabic":"وَقَالَتْ","translation":"এবং বলবে","audioUrl":"wbw/007_039_001.mp3","charTypeName":"word"},{"id":41004,"position":2,"arabic":"أُولَىٰهُمْ","translation":"পূর্ববর্তীরা তাদের","audioUrl":"wbw/007_039_002.mp3","charTypeName":"word"},{"id":41005,"position":3,"arabic":"لِأُخْرَىٰهُمْ","translation":"উদ্দেশ্যে পরবর্তীদের তাদের","audioUrl":"wbw/007_039_003.mp3","charTypeName":"word"},{"id":41006,"position":4,"arabic":"فَمَا","translation":"\"মূলতঃ না","audioUrl":"wbw/007_039_004.mp3","charTypeName":"word"},{"id":41007,"position":5,"arabic":"كَانَ","translation":"ছিলো","audioUrl":"wbw/007_039_005.mp3","charTypeName":"word"},{"id":41008,"position":6,"arabic":"لَكُمْ","translation":"জন্যে তোমাদের","audioUrl":"wbw/007_039_006.mp3","charTypeName":"word"},{"id":41009,"position":7,"arabic":"عَلَيْنَا","translation":"উপর আমাদের","audioUrl":"wbw/007_039_007.mp3","charTypeName":"word"},{"id":41010,"position":8,"arabic":"مِن","translation":"কোনো","audioUrl":"wbw/007_039_008.mp3","charTypeName":"word"},{"id":41011,"position":9,"arabic":"فَضْلٍۢ","translation":"শ্রেষ্ঠত্ব","audioUrl":"wbw/007_039_009.mp3","charTypeName":"word"},{"id":41012,"position":10,"arabic":"فَذُوقُوا۟","translation":"অতএব তোমরা স্বাদ নাও","audioUrl":"wbw/007_039_010.mp3","charTypeName":"word"},{"id":41013,"position":11,"arabic":"ٱلْعَذَابَ","translation":"শাস্তির","audioUrl":"wbw/007_039_011.mp3","charTypeName":"word"},{"id":41014,"position":12,"arabic":"بِمَا","translation":"এ কারণে যা","audioUrl":"wbw/007_039_012.mp3","charTypeName":"word"},{"id":41015,"position":13,"arabic":"كُنتُمْ","translation":"তোমরা ছিলে তোমরা অর্জন করতে","audioUrl":"wbw/007_039_013.mp3","charTypeName":"word"},{"id":41016,"position":14,"arabic":"تَكْسِبُونَ","translation":"\"","audioUrl":"wbw/007_039_014.mp3","charTypeName":"word"},{"id":41017,"position":15,"arabic":"٣٩","translation":"(৩৯)","audioUrl":null,"charTypeName":"end"}]},{"number":40,"arabic":"إِنَّ ٱلَّذِينَ كَذَّبُوا۟ بِـَٔايَٰتِنَا وَٱسْتَكْبَرُوا۟ عَنْهَا لَا تُفَتَّحُ لَهُمْ أَبْوَٰبُ ٱلسَّمَآءِ وَلَا يَدْخُلُونَ ٱلْجَنَّةَ حَتَّىٰ يَلِجَ ٱلْجَمَلُ فِى سَمِّ ٱلْخِيَاطِ ۚ وَكَذَٰلِكَ نَجْزِى ٱلْمُجْرِمِينَ","translation":"VERILY, unto those who give the lie to Our messages and scorn them in their pride, the gates of heaven shall not be opened; and they shall not enter paradise any more than a twisted rope can pass through a needle's eye: for thus do We requite such as are lost in sin.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/994.mp3","surahId":7,"words":[{"id":41890,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/007_040_001.mp3","charTypeName":"word"},{"id":41891,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/007_040_002.mp3","charTypeName":"word"},{"id":41892,"position":3,"arabic":"كَذَّبُوا۟","translation":"মিথ্যা মনে করে","audioUrl":"wbw/007_040_003.mp3","charTypeName":"word"},{"id":41893,"position":4,"arabic":"بِـَٔايَـٰتِنَا","translation":"সম্পর্কে আমাদের নিদর্শনাবলী","audioUrl":"wbw/007_040_004.mp3","charTypeName":"word"},{"id":41894,"position":5,"arabic":"وَٱسْتَكْبَرُوا۟","translation":"ও অহংকার করে","audioUrl":"wbw/007_040_005.mp3","charTypeName":"word"},{"id":41895,"position":6,"arabic":"عَن