{"id":195,"ayahs":[{"number":48,"arabic":"لَقَدِ ٱبْتَغَوُا۟ ٱلْفِتْنَةَ مِن قَبْلُ وَقَلَّبُوا۟ لَكَ ٱلْأُمُورَ حَتَّىٰ جَآءَ ٱلْحَقُّ وَظَهَرَ أَمْرُ ٱللَّهِ وَهُمْ كَٰرِهُونَ","translation":"Indeed, even before this time have they tried to stir up discord and devised all manner of plots against thee, [O Prophet,] until the truth was revealed and God's will became manifest, however hateful this may have been to them.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1283.mp3","surahId":9,"words":[{"id":47165,"position":1,"arabic":"لَقَدِ","translation":"নিশ্চয়ই","audioUrl":"wbw/009_048_001.mp3","charTypeName":"word"},{"id":47166,"position":2,"arabic":"ٱبْتَغَوُا۟","translation":"তারা চেয়েছিলো","audioUrl":"wbw/009_048_002.mp3","charTypeName":"word"},{"id":47167,"position":3,"arabic":"ٱلْفِتْنَةَ","translation":"বিপর্যয়(সৃষ্টি করতে)","audioUrl":"wbw/009_048_003.mp3","charTypeName":"word"},{"id":47168,"position":4,"arabic":"مِن","translation":"থেকেও","audioUrl":"wbw/009_048_004.mp3","charTypeName":"word"},{"id":47169,"position":5,"arabic":"قَبْلُ","translation":"পূর্ব","audioUrl":"wbw/009_048_005.mp3","charTypeName":"word"},{"id":47170,"position":6,"arabic":"وَقَلَّبُوا۟","translation":"এবং উল্টাপাল্টা করেছে","audioUrl":"wbw/009_048_006.mp3","charTypeName":"word"},{"id":47171,"position":7,"arabic":"لَكَ","translation":"জন্যে তোমার","audioUrl":"wbw/009_048_007.mp3","charTypeName":"word"},{"id":47172,"position":8,"arabic":"ٱلْأُمُورَ","translation":"কাজ-কর্ম","audioUrl":"wbw/009_048_008.mp3","charTypeName":"word"},{"id":47173,"position":9,"arabic":"حَتَّىٰ","translation":"যতক্ষণ না","audioUrl":"wbw/009_048_009.mp3","charTypeName":"word"},{"id":47174,"position":10,"arabic":"جَآءَ","translation":"এসেছে","audioUrl":"wbw/009_048_010.mp3","charTypeName":"word"},{"id":47175,"position":11,"arabic":"ٱلْحَقُّ","translation":"সত্য","audioUrl":"wbw/009_048_011.mp3","charTypeName":"word"},{"id":47176,"position":12,"arabic":"وَظَهَرَ","translation":"ও বিজয়ী হয়েছে","audioUrl":"wbw/009_048_012.mp3","charTypeName":"word"},{"id":47177,"position":13,"arabic":"أَمْرُ","translation":"নির্দেশ","audioUrl":"wbw/009_048_013.mp3","charTypeName":"word"},{"id":47178,"position":14,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/009_048_014.mp3","charTypeName":"word"},{"id":47179,"position":15,"arabic":"وَهُمْ","translation":"অথচ তারা","audioUrl":"wbw/009_048_015.mp3","charTypeName":"word"},{"id":47180,"position":16,"arabic":"كَـٰرِهُونَ","translation":"অপছন্দকারী","audioUrl":"wbw/009_048_016.mp3","charTypeName":"word"},{"id":47181,"position":17,"arabic":"٤٨","translation":"(৪৮)","audioUrl":null,"charTypeName":"end"}]},{"number":49,"arabic":"وَمِنْهُم مَّن يَقُولُ ٱئْذَن لِّى وَلَا تَفْتِنِّىٓ ۚ أَلَا فِى ٱلْفِتْنَةِ سَقَطُوا۟ ۗ وَإِنَّ جَهَنَّمَ لَمُحِيطَةٌۢ بِٱلْكَٰفِرِينَ","translation":"And among them there was [many a one] who said,\" Grant me permission [to remain at home], and do not put me to too hard a test!\" Oh, verily, [by making such a request] they had [already failed in their test and] succumbed to a temptation to evil: and, behold, hell will indeed encompass all who refuse to acknowledge the truth!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1284.mp3","surahId":9,"words":[{"id":47899,"position":1,"arabic":"وَمِنْهُم","translation":"ও মধ্যে তাদের(এমনও আছে)","audioUrl":"wbw/009_049_001.mp3","charTypeName":"word"},{"id":47900,"position":2,"arabic":"مَّن","translation":"যে","audioUrl":"wbw/009_049_002.mp3","charTypeName":"word"},{"id":47901,"position":3,"arabic":"يَقُولُ","translation":"বলে","audioUrl":"wbw/009_049_003.mp3","charTypeName":"word"},{"id":47902,"position":4,"arabic":"ٱئْذَن","translation":"\"অব্যাহতি দিন","audioUrl":"wbw/009_049_004.mp3","charTypeName":"word"},{"id":47903,"position":5,"arabic":"لِّى","translation":"\"আমাকে","audioUrl":"wbw/009_049_005.mp3","charTypeName":"word"},{"id":47904,"position":6,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/009_049_006.mp3","charTypeName":"word"},{"id":47905,"position":7,"arabic":"تَفْتِنِّىٓ ۚ","translation":"আমাকে বিপর্যয়ে ফেলবেন\"","audioUrl":"wbw/009_049_007.mp3","charTypeName":"word"},{"id":47907,"position":8,"arabic":"أَلَا","translation":"সাবধান (শুনে রাখো)","audioUrl":"wbw/009_049_009.mp3","charTypeName":"word"},{"id":47908,"position":9,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/009_049_010.mp3","charTypeName":"word"},{"id":47909,"position":10,"arabic":"ٱلْفِتْنَةِ","translation":"বিপর্যয়ের","audioUrl":"wbw/009_049_011.mp3","charTypeName":"word"},{"id":47910,"position":11,"arabic":"سَقَطُوا۟ ۗ","translation":"তারা পড়েছে","audioUrl":"wbw/009_049_012.mp3","charTypeName":"word"},{"id":47912,"position":12,"arabic":"وَإِنَّ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/009_049_014.mp3","charTypeName":"word"},{"id":47913,"position":13,"arabic":"جَهَنَّمَ","translation":"জাহান্নাম","audioUrl":"wbw/009_049_015.mp3","charTypeName":"word"},{"id":47914,"position":14,"arabic":"لَمُحِيطَةٌۢ","translation":"অবশ্যই পরিবেষ্টনকারী","audioUrl":"wbw/009_049_016.mp3","charTypeName":"word"},{"id":47915,"position":15,"arabic":"بِٱلْكَـٰفِرِينَ","translation":"নিয়ে কাফেরদেরকে","audioUrl":"wbw/009_049_017.mp3","charTypeName":"word"},{"id":47916,"position":16,"arabic":"٤٩","translation":"(৪৯)","audioUrl":null,"charTypeName":"end"}]},{"number":50,"arabic":"إِن تُصِبْكَ حَسَنَةٌۭ تَسُؤْهُمْ ۖ وَإِن تُصِبْكَ مُصِيبَةٌۭ يَقُولُوا۟ قَدْ أَخَذْنَآ أَمْرَنَا مِن قَبْلُ وَيَتَوَلَّوا۟ وَّهُمْ فَرِحُونَ","translation":"Should good fortune alight on thee, [O Prophet,] it will grieve them; and should misfortune befall thee, they will say [to themselves], \"We have already taken our precautions beforehand!\" - and will turn away, and will rejoice.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1285.mp3","surahId":9,"words":[{"id":48632,"position":1,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/009_050_001.mp3","charTypeName":"word"},{"id":48633,"position":2,"arabic":"تُصِبْكَ","translation":"তোমার পৌঁছে","audioUrl":"wbw/009_050_002.mp3","charTypeName":"word"},{"id":48634,"position":3,"arabic":"حَسَنَةٌۭ","translation":"কোনো কল্যাণ","audioUrl":"wbw/009_050_003.mp3","charTypeName":"word"},{"id":48635,"position":4,"arabic":"تَسُؤْهُمْ ۖ","translation":"তা পীড়া দেয় তাদেরকে","audioUrl":"wbw/009_050_004.mp3","charTypeName":"word"},{"id":48637,"position":5,"arabic":"وَإِن","translation":"এবং যদি","audioUrl":"wbw/009_050_006.mp3","charTypeName":"word"},{"id":48638,"position":6,"arabic":"تُصِبْكَ","translation":"তোমার পৌঁছে","audioUrl":"wbw/009_050_007.mp3","charTypeName":"word"},{"id":48639,"position":7,"arabic":"مُصِيبَةٌۭ","translation":"কোনো বিপদ","audioUrl":"wbw/009_050_008.mp3","charTypeName":"word"},{"id":48640,"position":8,"arabic":"يَقُولُوا۟","translation":"তারা বলে","audioUrl":"wbw/009_050_009.mp3","charTypeName":"word"},{"id":48641,"position":9,"arabic":"قَدْ","translation":"\"নিশ্চয়ই","audioUrl":"wbw/009_050_010.mp3","charTypeName":"word"},{"id":48642,"position":10,"arabic":"أَخَذْنَآ","translation":"আমরা (সামলে নিয়েছি)","audioUrl":"wbw/009_050_011.mp3","charTypeName":"word"},{"id":48643,"position":11,"arabic":"أَمْرَنَا","translation":"কাজ আমাদের","audioUrl":"wbw/009_050_012.mp3","charTypeName":"word"},{"id":48644,"position":12,"arabic":"مِن","translation":"থেকেই\"","audioUrl":"wbw/009_050_013.mp3","charTypeName":"word"},{"id":48645,"position":13,"arabic":"قَبْلُ","translation":"পূর্ব\"","audioUrl":"wbw/009_050_014.mp3","charTypeName":"word"},{"id":48646,"position":14,"arabic":"وَيَتَوَلَّوا۟","translation":"ও তারা ফিরে যায়","audioUrl":"wbw/009_050_015.mp3","charTypeName":"word"},{"id":48647,"position":15,"arabic":"وَّهُمْ","translation":"এ অবস্থায় যে তারা","audioUrl":"wbw/009_050_016.mp3","charTypeName":"word"},{"id":48648,"position":16,"arabic":"فَرِحُونَ","translation":"উৎফুল্ল","audioUrl":"wbw/009_050_017.mp3","charTypeName":"word"},{"id":48649,"position":17,"arabic":"٥٠","translation":"(৫০)","audioUrl":null,"charTypeName":"end"}]},{"number":51,"arabic":"قُل لَّن يُصِيبَنَآ إِلَّا مَا كَتَبَ ٱللَّهُ لَنَا هُوَ مَوْلَىٰنَا ۚ وَعَلَى ٱللَّهِ فَلْيَتَوَكَّلِ ٱلْمُؤْمِنُونَ","translation":"Say: \"Never can anything befall us save what God has decreed! He is our Lord Supreme; and in God let the believers place their trust!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1286.mp3","surahId":9,"words":[{"id":49214,"position":1,"arabic":"قُل","translation":"বলো","audioUrl":"wbw/009_051_001.mp3","charTypeName":"word"},{"id":49215,"position":2,"arabic":"لَّن","translation":"\"কখনও না","audioUrl":"wbw/009_051_002.mp3","charTypeName":"word"},{"id":49216,"position":3,"arabic":"يُصِيبَنَآ","translation":"কাছে পৌঁছুবে আমাদের","audioUrl":"wbw/009_051_003.mp3","charTypeName":"word"},{"id":49217,"position":4,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/009_051_004.mp3","charTypeName":"word"},{"id":49218,"position":5,"arabic":"مَا","translation":"যা","audioUrl":"wbw/009_051_005.mp3","charTypeName":"word"},{"id":49219,"position":6,"arabic":"كَتَبَ","translation":"নির্ধারিত করেছেন","audioUrl":"wbw/009_051_006.mp3","charTypeName":"word"},{"id":49220,"position":7,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/009_051_007.mp3","charTypeName":"word"},{"id":49221,"position":8,"arabic":"لَنَا","translation":"জন্যে আমাদের","audioUrl":"wbw/009_051_008.mp3","charTypeName":"word"},{"id":49222,"position":9,"arabic":"هُوَ","translation":"তিনিই","audioUrl":"wbw/009_051_009.mp3","charTypeName":"word"},{"id":49223,"position":10,"arabic":"مَوْلَىٰنَا ۚ","translation":"অভিভাবক আমাদের\"","audioUrl":"wbw/009_051_010.mp3","charTypeName":"word"},{"id":49225,"position":11,"arabic":"وَعَلَى","translation":"এবং উপর","audioUrl":"wbw/009_051_012.mp3","charTypeName":"word"},{"id":49226,"position":12,"arabic":"ٱللَّهِ","translation":"আল্লাহরই","audioUrl":"wbw/009_051_013.mp3","charTypeName":"word"},{"id":49227,"position":13,"arabic":"فَلْيَتَوَكَّلِ","translation":"নির্ভর করা উচিৎ","audioUrl":"wbw/009_051_014.mp3","charTypeName":"word"},{"id":49228,"position":14,"arabic":"ٱلْمُؤْمِنُونَ","translation":"মু'মিনদের","audioUrl":"wbw/009_051_015.mp3","charTypeName":"word"},{"id":49229,"position":15,"arabic":"٥١","translation":"(৫১)","audioUrl":null,"charTypeName":"end"}]},{"number":52,"arabic":"قُلْ هَلْ تَرَبَّصُونَ بِنَآ إِلَّآ إِحْدَى ٱلْحُسْنَيَيْنِ ۖ وَنَحْنُ نَتَرَبَّصُ بِكُمْ أَن يُصِيبَكُمُ ٱللَّهُ بِعَذَابٍۢ مِّنْ عِندِهِۦٓ أَوْ بِأَيْدِينَا ۖ فَتَرَبَّصُوٓا۟ إِنَّا مَعَكُم مُّتَرَبِّصُونَ","translation":"Say: \"Are you, perchance, hopefully waiting for something [bad] to happen to us-[the while nothing can happen to us] save one of the two best things? But as far as you are concerned, we are hopefully waiting for God to inflict chastisement upon you, [either] from Himself or by our hands! Wait, then, hopefully; behold, we shall hopefully wait with you!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1287.mp3","surahId":9,"words":[{"id":49680,"position":1,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/009_052_001.mp3","charTypeName":"word"},{"id":49681,"position":2,"arabic":"هَلْ","translation":"\"কি","audioUrl":"wbw/009_052_002.mp3","charTypeName":"word"},{"id":49682,"position":3,"arabic":"تَرَبَّصُونَ","translation":"তোমরা অপেক্ষা করছো","audioUrl":"wbw/009_052_003.mp3","charTypeName":"word"},{"id":49683,"position":4,"arabic":"بِنَآ","translation":"জন্যে আমাদের","audioUrl":"wbw/009_052_004.mp3","charTypeName":"word"},{"id":49684,"position":5,"arabic":"إِلَّآ","translation":"এ ছাড়া","audioUrl":"wbw/009_052_005.mp3","charTypeName":"word"},{"id":49685,"position":6,"arabic":"إِحْدَى","translation":"একটি","audioUrl":"wbw/009_052_006.mp3","charTypeName":"word"},{"id":49686,"position":7,"arabic":"ٱلْحُسْنَيَيْنِ ۖ","translation":"দুই কল্যাণের (অর্থাৎ শাহাদাত বা বিজয়)","audioUrl":"wbw/009_052_007.mp3","charTypeName":"word"},{"id":49688,"position":8,"arabic":"وَنَحْنُ","translation":"এবং আমরা","audioUrl":"wbw/009_052_009.mp3","charTypeName":"word"},{"id":49689,"position":9,"arabic":"نَتَرَبَّصُ","translation":"অপেক্ষা করছি","audioUrl":"wbw/009_052_010.mp3","charTypeName":"word"},{"id":49690,"position":10,"arabic":"بِكُمْ","translation":"জন্যে তোমাদের","audioUrl":"wbw/009_052_011.mp3","charTypeName":"word"},{"id":49691,"position":11,"arabic":"أَن","translation":"যে","audioUrl":"wbw/009_052_012.mp3","charTypeName":"word"},{"id":49692,"position":12,"arabic":"يُصِيبَكُمُ","translation":"কাছে পৌঁছাবেন তোমাদের","audioUrl":"wbw/009_052_013.mp3","charTypeName":"word"},{"id":49693,"position":13,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/009_052_014.mp3","charTypeName":"word"},{"id":49694,"position":14,"arabic":"بِعَذَابٍۢ","translation":"শাস্তি","audioUrl":"wbw/009_052_015.mp3","charTypeName":"word"},{"id":49695,"position":15,"arabic":"مِّنْ","translation":"হতে","audioUrl":"wbw/009_052_016.mp3","charTypeName":"word"},{"id":49696,"position":16,"arabic":"عِندِهِۦٓ","translation":"তাঁর নিজের নিকট","audioUrl":"wbw/009_052_017.mp3","charTypeName":"word"},{"id":49697,"position":17,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/009_052_018.mp3","charTypeName":"word"},{"id":49698,"position":18,"arabic":"بِأَيْدِينَا ۖ","translation":"দিয়ে হাত আমাদের(শাস্তি দিবেন)","audioUrl":"wbw/009_052_019.mp3","charTypeName":"word"},{"id":49700,"position":19,"arabic":"فَتَرَبَّصُوٓا۟","translation":"তাই তোমরা অপেক্ষা করো","audioUrl":"wbw/009_052_021.mp3","charTypeName":"word"},{"id":49701,"position":20,"arabic":"إِنَّا","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/009_052_022.mp3","charTypeName":"word"},{"id":49702,"position":21,"arabic":"مَعَكُم","translation":"সাথে তোমাদের","audioUrl":"wbw/009_052_023.mp3","charTypeName":"word"},{"id":49703,"position":22,"arabic":"مُّتَرَبِّصُونَ","translation":"অপেক্ষাকারী\"","audioUrl":"wbw/009_052_024.mp3","charTypeName":"word"},{"id":49704,"position":23,"arabic":"٥٢","translation":"(৫২)","audioUrl":null,"charTypeName":"end"}]},{"number":53,"arabic":"قُلْ أَنفِقُوا۟ طَوْعًا أَوْ كَرْهًۭا لَّن يُتَقَبَّلَ مِنكُمْ ۖ إِنَّكُمْ كُنتُمْ قَوْمًۭا فَٰسِقِينَ","translation":"Say: \"You may spend [anything], willingly-or unwillingly, [pretending that you do it for the sake of God:] it shall never be accepted from you -for, verily, you are people bent on iniquity!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1288.mp3","surahId":9,"words":[{"id":50471,"position":1,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/009_053_001.mp3","charTypeName":"word"},{"id":50472,"position":2,"arabic":"أَنفِقُوا۟","translation":"\"তোমরা ব্যয় করো","audioUrl":"wbw/009_053_002.mp3","charTypeName":"word"},{"id":50473,"position":3,"arabic":"طَوْعًا","translation":"ইচ্ছায়","audioUrl":"wbw/009_053_003.mp3","charTypeName":"word"},{"id":50474,"position":4,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/009_053_004.mp3","charTypeName":"word"},{"id":50475,"position":5,"arabic":"كَرْهًۭا","translation":"অনিচ্ছায়","audioUrl":"wbw/009_053_005.mp3","charTypeName":"word"},{"id":50476,"position":6,"arabic":"لَّن","translation":"কখনও না","audioUrl":"wbw/009_053_006.mp3","charTypeName":"word"},{"id":50477,"position":7,"arabic":"يُتَقَبَّلَ","translation":"গ্রহণ করা হবে (তা)","audioUrl":"wbw/009_053_007.mp3","charTypeName":"word"},{"id":50478,"position":8,"arabic":"مِنكُمْ ۖ","translation":"হতে তোমাদের","audioUrl":"wbw/009_053_008.mp3","charTypeName":"word"},{"id":50480,"position":9,"arabic":"إِنَّكُمْ","translation":"নিশ্চয়ই তোমরা","audioUrl":"wbw/009_053_010.mp3","charTypeName":"word"},{"id":50481,"position":10,"arabic":"كُنتُمْ","translation":"হলে","audioUrl":"wbw/009_053_011.mp3","charTypeName":"word"},{"id":50482,"position":11,"arabic":"قَوْمًۭا","translation":"সম্প্রদায়","audioUrl":"wbw/009_053_012.mp3","charTypeName":"word"},{"id":50483,"position":12,"arabic":"فَـٰسِقِينَ","translation":"সত্যত্যাগী\"","audioUrl":"wbw/009_053_013.mp3","charTypeName":"word"},{"id":50484,"position":13,"arabic":"٥٣","translation":"(৫৩)","audioUrl":null,"charTypeName":"end"}]},{"number":54,"arabic":"وَمَا مَنَعَهُمْ أَن تُقْبَلَ مِنْهُمْ نَفَقَٰتُهُمْ إِلَّآ أَنَّهُمْ كَفَرُوا۟ بِٱللَّهِ وَبِرَسُولِهِۦ وَلَا يَأْتُونَ ٱلصَّلَوٰةَ إِلَّا وَهُمْ كُسَالَىٰ وَلَا يُنفِقُونَ إِلَّا وَهُمْ كَٰرِهُونَ","translation":"For, only this prevents their spending from being accepted from them: they are bent on refusing to acknowledge God and His Apostle, and never pray without reluctance, and never spend [on righteous causes] without resentment.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1289.mp3","surahId":9,"words":[{"id":51185,"position":1,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/009_054_001.mp3","charTypeName":"word"},{"id":51186,"position":2,"arabic":"مَنَعَهُمْ","translation":"নিষেধ করা হয়েছে তাদেরকে","audioUrl":"wbw/009_054_002.mp3","charTypeName":"word"},{"id":51187,"position":3,"arabic":"أَن","translation":"যে","audioUrl":"wbw/009_054_003.mp3","charTypeName":"word"},{"id":51188,"position":4,"arabic":"تُقْبَلَ","translation":"গ্রহণ করা হবে","audioUrl":"wbw/009_054_004.mp3","charTypeName":"word"},{"id":51189,"position":5,"arabic":"مِنْهُمْ","translation":"থেকে তাদের","audioUrl":"wbw/009_054_005.mp3","charTypeName":"word"},{"id":51190,"position":6,"arabic":"نَفَقَـٰتُهُمْ","translation":"অর্থ সাহায্য তাদের","audioUrl":"wbw/009_054_006.mp3","charTypeName":"word"},{"id":51191,"position":7,"arabic":"إِلَّآ","translation":"এ ছাড়া (অন্য কোনো কারণে)","audioUrl":"wbw/009_054_007.mp3","charTypeName":"word"},{"id":51192,"position":8,"arabic":"أَنَّهُمْ","translation":"যে তারা","audioUrl":"wbw/009_054_008.mp3","charTypeName":"word"},{"id":51193,"position":9,"arabic":"كَفَرُوا۟","translation":"অবিশ্বাস করেছে","audioUrl":"wbw/009_054_009.mp3","charTypeName":"word"},{"id":51194,"position":10,"arabic":"بِٱللَّهِ","translation":"উপর আল্লাহর","audioUrl":"wbw/009_054_010.mp3","charTypeName":"word"},{"id":51195,"position":11,"arabic":"وَبِرَسُولِهِۦ","translation":"ও উপর রাসূলের তাঁর","audioUrl":"wbw/0