{"id":385,"ayahs":[{"number":89,"arabic":"مَن جَآءَ بِٱلْحَسَنَةِ فَلَهُۥ خَيْرٌۭ مِّنْهَا وَهُم مِّن فَزَعٍۢ يَوْمَئِذٍ ءَامِنُونَ","translation":"Whoever shall come [before Him] with a good deed will gain [further] good there from; and they will be secure from the terror of that Day.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3248.mp3","surahId":27,"words":[{"id":67499,"position":1,"arabic":"مَن","translation":"যে","audioUrl":"wbw/027_089_001.mp3","charTypeName":"word"},{"id":67500,"position":2,"arabic":"جَآءَ","translation":"আসবে (সেদিন)","audioUrl":"wbw/027_089_002.mp3","charTypeName":"word"},{"id":67501,"position":3,"arabic":"بِٱلْحَسَنَةِ","translation":"নিয়ে সৎ-কর্ম","audioUrl":"wbw/027_089_003.mp3","charTypeName":"word"},{"id":67502,"position":4,"arabic":"فَلَهُۥ","translation":"তখন তার জন্যে (থাকবে)","audioUrl":"wbw/027_089_004.mp3","charTypeName":"word"},{"id":67503,"position":5,"arabic":"خَيْرٌۭ","translation":"উত্তম","audioUrl":"wbw/027_089_005.mp3","charTypeName":"word"},{"id":67504,"position":6,"arabic":"مِّنْهَا","translation":"তার চেয়েও","audioUrl":"wbw/027_089_006.mp3","charTypeName":"word"},{"id":67505,"position":7,"arabic":"وَهُم","translation":"আর তারা","audioUrl":"wbw/027_089_007.mp3","charTypeName":"word"},{"id":67506,"position":8,"arabic":"مِّن","translation":"হ'তে","audioUrl":"wbw/027_089_008.mp3","charTypeName":"word"},{"id":67507,"position":9,"arabic":"فَزَعٍۢ","translation":"শঙ্কা","audioUrl":"wbw/027_089_009.mp3","charTypeName":"word"},{"id":67508,"position":10,"arabic":"يَوْمَئِذٍ","translation":"সেদিন","audioUrl":"wbw/027_089_010.mp3","charTypeName":"word"},{"id":67509,"position":11,"arabic":"ءَامِنُونَ","translation":"নিরাপদ থাকবে","audioUrl":"wbw/027_089_011.mp3","charTypeName":"word"},{"id":67510,"position":12,"arabic":"٨٩","translation":"(৮৯)","audioUrl":null,"charTypeName":"end"}]},{"number":90,"arabic":"وَمَن جَآءَ بِٱلسَّيِّئَةِ فَكُبَّتْ وُجُوهُهُمْ فِى ٱلنَّارِ هَلْ تُجْزَوْنَ إِلَّا مَا كُنتُمْ تَعْمَلُونَ","translation":"But they who shall come with evil deeds – their faces will be thrust into the fire, [and they will be asked:] “Is this aught but a just requital for what you were doing [in life]?”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3249.mp3","surahId":27,"words":[{"id":68097,"position":1,"arabic":"وَمَن","translation":"এবং যে","audioUrl":"wbw/027_090_001.mp3","charTypeName":"word"},{"id":68098,"position":2,"arabic":"جَآءَ","translation":"আসবে","audioUrl":"wbw/027_090_002.mp3","charTypeName":"word"},{"id":68099,"position":3,"arabic":"بِٱلسَّيِّئَةِ","translation":"নিয়ে অসৎকর্ম","audioUrl":"wbw/027_090_003.mp3","charTypeName":"word"},{"id":68100,"position":4,"arabic":"فَكُبَّتْ","translation":"তখন নিক্ষেপ করা হবে","audioUrl":"wbw/027_090_004.mp3","charTypeName":"word"},{"id":68101,"position":5,"arabic":"وُجُوهُهُمْ","translation":"মুখ তাদের (উল্টোভাবে)","audioUrl":"wbw/027_090_005.mp3","charTypeName":"word"},{"id":68102,"position":6,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/027_090_006.mp3","charTypeName":"word"},{"id":68103,"position":7,"arabic":"ٱلنَّارِ","translation":"আগুনের","audioUrl":"wbw/027_090_007.mp3","charTypeName":"word"},{"id":68104,"position":8,"arabic":"هَلْ","translation":"\"(তাদের বলা হবে) কি","audioUrl":"wbw/027_090_008.mp3","charTypeName":"word"},{"id":68105,"position":9,"arabic":"تُجْزَوْنَ","translation":"প্রতিফল দেয়া হয়েছে তোমাদেরকে","audioUrl":"wbw/027_090_009.mp3","charTypeName":"word"},{"id":68106,"position":10,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/027_090_010.mp3","charTypeName":"word"},{"id":68107,"position":11,"arabic":"مَا","translation":"যা","audioUrl":"wbw/027_090_011.mp3","charTypeName":"word"},{"id":68108,"position":12,"arabic":"كُنتُمْ","translation":"তোমরা ছিলে","audioUrl":"wbw/027_090_012.mp3","charTypeName":"word"},{"id":68109,"position":13,"arabic":"تَعْمَلُونَ","translation":"তোমরা কাজ করতে\"","audioUrl":"wbw/027_090_013.mp3","charTypeName":"word"},{"id":68110,"position":14,"arabic":"٩٠","translation":"(৯০)","audioUrl":null,"charTypeName":"end"}]},{"number":91,"arabic":"إِنَّمَآ أُمِرْتُ أَنْ أَعْبُدَ رَبَّ هَٰذِهِ ٱلْبَلْدَةِ ٱلَّذِى حَرَّمَهَا وَلَهُۥ كُلُّ شَىْءٍۢ ۖ وَأُمِرْتُ أَنْ أَكُونَ مِنَ ٱلْمُسْلِمِينَ","translation":"[SAY, O Muhammad:] “I have been bidden to worship the Sustainer of this City – Him who has made it sacred, and unto whom all things belong: and I have been bidden to be of those who surrender themselves to Him,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3250.mp3","surahId":27,"words":[{"id":68527,"position":1,"arabic":"إِنَّمَآ","translation":"\"মূলত","audioUrl":"wbw/027_091_001.mp3","charTypeName":"word"},{"id":68528,"position":2,"arabic":"أُمِرْتُ","translation":"আমি আদিষ্ট হয়েছি","audioUrl":"wbw/027_091_002.mp3","charTypeName":"word"},{"id":68529,"position":3,"arabic":"أَنْ","translation":"যেন","audioUrl":"wbw/027_091_003.mp3","charTypeName":"word"},{"id":68530,"position":4,"arabic":"أَعْبُدَ","translation":"ইবাদত করি আমি","audioUrl":"wbw/027_091_004.mp3","charTypeName":"word"},{"id":68531,"position":5,"arabic":"رَبَّ","translation":"রবের","audioUrl":"wbw/027_091_005.mp3","charTypeName":"word"},{"id":68532,"position":6,"arabic":"هَـٰذِهِ","translation":"এই","audioUrl":"wbw/027_091_006.mp3","charTypeName":"word"},{"id":68533,"position":7,"arabic":"ٱلْبَلْدَةِ","translation":"শহরের (অর্থাৎ মাক্কার)","audioUrl":"wbw/027_091_007.mp3","charTypeName":"word"},{"id":68534,"position":8,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/027_091_008.mp3","charTypeName":"word"},{"id":68535,"position":9,"arabic":"حَرَّمَهَا","translation":"সম্মানিত করেছেন তা","audioUrl":"wbw/027_091_009.mp3","charTypeName":"word"},{"id":68536,"position":10,"arabic":"وَلَهُۥ","translation":"এবং জন্যে  তাঁরই (মালিকানায়)","audioUrl":"wbw/027_091_010.mp3","charTypeName":"word"},{"id":68537,"position":11,"arabic":"كُلُّ","translation":"প্রত্যেক","audioUrl":"wbw/027_091_011.mp3","charTypeName":"word"},{"id":68538,"position":12,"arabic":"شَىْءٍۢ ۖ","translation":"বস্তু","audioUrl":"wbw/027_091_012.mp3","charTypeName":"word"},{"id":68540,"position":13,"arabic":"وَأُمِرْتُ","translation":"এবং আমি আদিষ্ট হয়েছি","audioUrl":"wbw/027_091_014.mp3","charTypeName":"word"},{"id":68541,"position":14,"arabic":"أَنْ","translation":"যেন","audioUrl":"wbw/027_091_015.mp3","charTypeName":"word"},{"id":68542,"position":15,"arabic":"أَكُونَ","translation":"আমি হই","audioUrl":"wbw/027_091_016.mp3","charTypeName":"word"},{"id":68543,"position":16,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/027_091_017.mp3","charTypeName":"word"},{"id":68544,"position":17,"arabic":"ٱلْمُسْلِمِينَ","translation":"আত্মসমর্পণকারীদের","audioUrl":"wbw/027_091_018.mp3","charTypeName":"word"},{"id":68545,"position":18,"arabic":"٩١","translation":"(৯১)","audioUrl":null,"charTypeName":"end"}]},{"number":92,"arabic":"وَأَنْ أَتْلُوَا۟ ٱلْقُرْءَانَ ۖ فَمَنِ ٱهْتَدَىٰ فَإِنَّمَا يَهْتَدِى لِنَفْسِهِۦ ۖ وَمَن ضَلَّ فَقُلْ إِنَّمَآ أَنَا۠ مِنَ ٱلْمُنذِرِينَ","translation":"and to convey this Qur’an [to the world].” Whoever, therefore, chooses to follow the right path, follows it but for his own good; and if any wills to go astray, say [unto him]: “I am only a warner.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3251.mp3","surahId":27,"words":[{"id":68794,"position":1,"arabic":"وَأَنْ","translation":"(এও)এবং যে","audioUrl":"wbw/027_092_001.mp3","charTypeName":"word"},{"id":68795,"position":2,"arabic":"أَتْلُوَا۟","translation":"আমি তিলাওয়াত করবো","audioUrl":"wbw/027_092_002.mp3","charTypeName":"word"},{"id":68796,"position":3,"arabic":"ٱلْقُرْءَانَ ۖ","translation":"কুরআন\"","audioUrl":"wbw/027_092_003.mp3","charTypeName":"word"},{"id":68798,"position":4,"arabic":"فَمَنِ","translation":"অতএব যে","audioUrl":"wbw/027_092_005.mp3","charTypeName":"word"},{"id":68799,"position":5,"arabic":"ٱهْتَدَىٰ","translation":"সৎপথ অবলম্বন করবে","audioUrl":"wbw/027_092_006.mp3","charTypeName":"word"},{"id":68800,"position":6,"arabic":"فَإِنَّمَا","translation":"শুধুমাত্র","audioUrl":"wbw/027_092_007.mp3","charTypeName":"word"},{"id":68801,"position":7,"arabic":"يَهْتَدِى","translation":"সে সৎপথ অবলম্বন করবে","audioUrl":"wbw/027_092_008.mp3","charTypeName":"word"},{"id":68802,"position":8,"arabic":"لِنَفْسِهِۦ ۖ","translation":"জন্যে নিজের তার","audioUrl":"wbw/027_092_009.mp3","charTypeName":"word"},{"id":68804,"position":9,"arabic":"وَمَن","translation":"আর যে","audioUrl":"wbw/027_092_011.mp3","charTypeName":"word"},{"id":68805,"position":10,"arabic":"ضَلَّ","translation":"ভ্রান্তপথ অবলম্বন করবে","audioUrl":"wbw/027_092_012.mp3","charTypeName":"word"},{"id":68806,"position":11,"arabic":"فَقُلْ","translation":"অতঃপর বলো","audioUrl":"wbw/027_092_013.mp3","charTypeName":"word"},{"id":68807,"position":12,"arabic":"إِنَّمَآ","translation":"\"শুধুমাত্র","audioUrl":"wbw/027_092_014.mp3","charTypeName":"word"},{"id":68808,"position":13,"arabic":"أَنَا۠","translation":"আমি","audioUrl":"wbw/027_092_015.mp3","charTypeName":"word"},{"id":68809,"position":14,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/027_092_016.mp3","charTypeName":"word"},{"id":68810,"position":15,"arabic":"ٱلْمُنذِرِينَ","translation":"সতর্ককারীদের\"","audioUrl":"wbw/027_092_017.mp3","charTypeName":"word"},{"id":68811,"position":16,"arabic":"٩٢","translation":"(৯২)","audioUrl":null,"charTypeName":"end"}]},{"number":93,"arabic":"وَقُلِ ٱلْحَمْدُ لِلَّهِ سَيُرِيكُمْ ءَايَٰتِهِۦ فَتَعْرِفُونَهَا ۚ وَمَا رَبُّكَ بِغَٰفِلٍ عَمَّا تَعْمَلُونَ","translation":"And say: “All praise is due to God! In time He will make you see [the truth of] His messages, and then you shall know them [for what they are].” And thy Sustainer is not unmindful of whatever you all may do.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3252.mp3","surahId":27,"words":[{"id":68960,"position":1,"arabic":"وَقُلِ","translation":"এবং বলো","audioUrl":"wbw/027_093_001.mp3","charTypeName":"word"},{"id":68961,"position":2,"arabic":"ٱلْحَمْدُ","translation":"\"সব প্রশংসা","audioUrl":"wbw/027_093_002.mp3","charTypeName":"word"},{"id":68962,"position":3,"arabic":"لِلَّهِ","translation":"জন্যে আল্লাহরই","audioUrl":"wbw/027_093_003.mp3","charTypeName":"word"},{"id":68963,"position":4,"arabic":"سَيُرِيكُمْ","translation":"শীঘ্রই তিনি দেখাবেন তোমাদেরকে","audioUrl":"wbw/027_093_004.mp3","charTypeName":"word"},{"id":68964,"position":5,"arabic":"ءَايَـٰتِهِۦ","translation":"নিদের্শনাবলী তাঁর","audioUrl":"wbw/027_093_005.mp3","charTypeName":"word"},{"id":68965,"position":6,"arabic":"فَتَعْرِفُونَهَا ۚ","translation":"তখন তোমরা চিনে নিবে সব তা","audioUrl":"wbw/027_093_006.mp3","charTypeName":"word"},{"id":68967,"position":7,"arabic":"وَمَا","translation":"আর নন","audioUrl":"wbw/027_093_008.mp3","charTypeName":"word"},{"id":68968,"position":8,"arabic":"رَبُّكَ","translation":"তোমার রব","audioUrl":"wbw/027_093_009.mp3","charTypeName":"word"},{"id":68969,"position":9,"arabic":"بِغَـٰفِلٍ","translation":"অমনোযোগী","audioUrl":"wbw/027_093_010.mp3","charTypeName":"word"},{"id":68970,"position":10,"arabic":"عَمَّا","translation":"সে সম্পর্কে যা","audioUrl":"wbw/027_093_011.mp3","charTypeName":"word"},{"id":68971,"position":11,"arabic":"تَعْمَلُونَ","translation":"তোমরা কাজ করছো\"","audioUrl":"wbw/027_093_012.mp3","charTypeName":"word"},{"id":68972,"position":12,"arabic":"٩٣","translation":"(৯৩)","audioUrl":null,"charTypeName":"end"}]},{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ طسٓمٓ","translation":"Ta. Sin. Mim.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3253.mp3","surahId":28,"words":[{"id":767,"position":1,"arabic":"طسٓمٓ","translation":"ত্বা-সীন-মীম","audioUrl":"wbw/028_001_001.mp3","charTypeName":"word"},{"id":768,"position":2,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"تِلْكَ ءَايَٰتُ ٱلْكِتَٰبِ ٱلْمُبِينِ","translation":"These are messages of a divine writ clear in itself and clearly showing the truth.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3254.mp3","surahId":28,"words":[{"id":1823,"position":1,"arabic":"تِلْكَ","translation":"এই","audioUrl":"wbw/028_002_001.mp3","charTypeName":"word"},{"id":1824,"position":2,"arabic":"ءَايَـٰتُ","translation":"আয়াতগুলো","audioUrl":"wbw/028_002_002.mp3","charTypeName":"word"},{"id":1825,"position":3,"arabic":"ٱلْكِتَـٰبِ","translation":"কিতাবের","audioUrl":"wbw/028_002_003.mp3","charTypeName":"word"},{"id":1826,"position":4,"arabic":"ٱلْمُبِينِ","translation":"(যা) সুস্পষ্ট","audioUrl":"wbw/028_002_004.mp3","charTypeName":"word"},{"id":1827,"position":5,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"نَتْلُوا۟ عَلَيْكَ مِن نَّبَإِ مُوسَىٰ وَفِرْعَوْنَ بِٱلْحَقِّ لِقَوْمٍۢ يُؤْمِنُونَ","translation":"We [now] convey unto thee some of the story of Moses and Pharaoh, setting forth the truth for [the benefit of] people who will believe.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3255.mp3","surahId":28,"words":[{"id":2987,"position":1,"arabic":"نَتْلُوا۟","translation":"আমরা তিলাওয়াত করছি","audioUrl":"wbw/028_003_001.mp3","charTypeName":"word"},{"id":2988,"position":2,"arabic":"عَلَيْكَ","translation":"নিকট তোমার","audioUrl":"wbw/028_003_002.mp3","charTypeName":"word"},{"id":2989,"position":3,"arabic":"مِن","translation":"কিছু","audioUrl":"wbw/028_003_003.mp3","charTypeName":"word"},{"id":2990,"position":4,"arabic":"نَّبَإِ","translation":"বৃত্তান্ত","audioUrl":"wbw/028_003_004.mp3","charTypeName":"word"},{"id":2991,"position":5,"arabic":"مُوسَىٰ","translation":"মূসার","audioUrl":"wbw/028_003_005.mp3","charTypeName":"word"},{"id":2992,"position":6,"arabic":"وَفِرْعَوْنَ","translation":"ও ফিরআউনের","audioUrl":"wbw/028_003_006.mp3","charTypeName":"word"},{"id":2993,"position":7,"arabic":"بِٱلْحَقِّ","translation":"ভাবে যথাযথ","audioUrl":"wbw/028_003_007.mp3","charTypeName":"word"},{"id":2994,"position":8,"arabic":"لِقَوْمٍۢ","translation":"জন্যে (এমন) সম্প্রদায়ের (যারা)","audioUrl":"wbw/028_003_008.mp3","charTypeName":"word"},{"id":2995,"position":9,"arabic":"يُؤْمِنُونَ","translation":"ঈমান আনে","audioUrl":"wbw/028_003_009.mp3","charTypeName":"word"},{"id":2996,"position":10,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"إِنَّ فِرْعَوْنَ عَلَا فِى ٱلْأَرْضِ وَجَعَلَ أَهْلَهَا شِيَعًۭا يَسْتَضْعِفُ طَآئِفَةًۭ مِّنْهُمْ يُذَبِّحُ أَبْنَآءَهُمْ وَيَسْتَحْىِۦ نِسَآءَهُمْ ۚ إِنَّهُۥ كَانَ مِنَ ٱلْمُفْسِدِينَ","translation":"Behold, Pharaoh exalted himself in the land and divided its people into castes. One group of them he deemed utterly low; he would slaughter their sons and spare (only) their women: for, behold, he was one of those who spread corruption [on earth].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3256.mp3","surahId":28,"words":[{"id":4308,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/028_004_001.mp3","charTypeName":"word"},{"id":4309,"position":2,"arabic":"فِرْعَوْنَ","translation":"ফিরআউন","audioUrl":"wbw/028_004_002.mp3","charTypeName":"word"},{"id":4310,"position":3,"arabic":"عَلَا","translation":"উদ্ধৃত হয়েছিলো","audioUrl":"wbw/028_004_003.mp3","charTypeName":"word"},{"id":4311,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/028_004_004.mp3","charTypeName":"word"},{"id":4312,"position":5,"arabic":"ٱلْأَرْضِ","translation":"দেশের (অর্থাৎ মিশরে)","audioUrl":"wbw/028_004_005.mp3","charTypeName":"word"},{"id":4313,"position":6,"arabic":"وَجَعَلَ","translation":"এবং (বিভক্ত) করেছিলো","audioUrl":"wbw/028_004_006.mp3","charTypeName":"word"},{"id":4314,"position":7,"arabic":"أَهْلَهَا","translation":"অধিবাসীদেরকে তার","audioUrl":"wbw/028_004_007.mp3","charTypeName":"word"},{"id":4315,"position":8,"arabic":"شِيَعًۭا","translation":"(বিভিন্ন) দলে","audioUrl":"wbw/028_004_008.mp3","charTypeName":"word"},{"id":4316,"position":9,"arabic":"يَسْتَضْعِفُ","translation":"দূর্বল করে রেখে","audioUrl":"wbw/028_004_009.mp3","charTypeName":"word"},{"id":4317,"position":10,"arabic":"طَآئِفَةًۭ","translation":"একটি দলকে","audioUrl":"wbw/028_004_010.mp3","charTypeName":"word"},{"id":4318,"position":11,"arabic":"مِّنْهُمْ","translation":"মধ্যে হ'তে তাদের","audioUrl":"wbw/028_004_011.mp3","charTypeName":"word"},{"id":4319,"position":12,"arabic":"يُذَبِّحُ","translation":"সে জবেহ করতো","audioUrl":"wbw/028_004_012.mp3","charTypeName":"word"},{"id":4320,"position":13,"arabic":"أَبْنَآءَهُمْ","translation":"পুত্রসন্তানদেরকে তাদের","audioUrl":"wbw/028_004_013.mp3","charTypeName":"word"},{"id":4321,"position":14,"arabic":"وَيَسْتَحْىِۦ","translation":"ও জীবিত রাখতো","audioUrl":"wbw/028_004_014.mp3","charTypeName":"word"},{"id":4322,"position":15,"arabic":"نِسَآءَهُمْ ۚ","translation":"নারীদেরকে তাদের","audioUrl":"wbw/028_004_015.mp3","charTypeName":"word"},{"id":4324,"position":16,"arabic":"إِنَّهُۥ","translation":"নিশ্চয়ই সে","audioUrl":"wbw/028_004_017.mp3","charTypeName":"word"},{"id":4325,"position":17,"arabic":"كَانَ","translation":"ছিলো","audioUrl":"wbw/028_004_018.mp3","charTypeName":"word"},{"id":4326,"position":18,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/028_004_019.mp3","charTypeName":"word"},{"id":4327,"position":19,"arabic":"ٱلْمُفْسِدِينَ","translation":"বিপর্যয় সৃষ্টিকারীদের","audioUrl":"wbw/028_004_020.mp3","charTypeName":"word"},{"id":4328,"position":20,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"وَنُرِيدُ أَن نَّمُنَّ عَلَى ٱلَّذِينَ ٱسْتُضْعِفُوا۟ فِى ٱلْأَرْضِ وَنَجْعَلَهُمْ أَئِمَّةًۭ وَنَجْعَلَهُمُ ٱلْوَٰرِثِينَ","translation":"But it was Our will to bestow Our favour upon those [very people] who were deemed [so] utterly low in the land, and to make them forerunners in faith. and to make them heirs [to Pharaoh’s glory],","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3257.mp3","surahId":28,"words":[{"id":5571,"position":1,"arabic":"وَنُرِيدُ","tr