"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5569.mp3","surahId":75,"words":[{"id":20644,"position":1,"arabic":"فَإِذَا","translation":"যখন অতঃপর","audioUrl":"wbw/075_018_001.mp3","charTypeName":"word"},{"id":20645,"position":2,"arabic":"قَرَأْنَـٰهُ","translation":"তা আমরা পড়ি","audioUrl":"wbw/075_018_002.mp3","charTypeName":"word"},{"id":20646,"position":3,"arabic":"فَٱتَّبِعْ","translation":"অনিুসরণ তখন করো","audioUrl":"wbw/075_018_003.mp3","charTypeName":"word"},{"id":20647,"position":4,"arabic":"قُرْءَانَهُۥ","translation":"তা পাঠের","audioUrl":"wbw/075_018_004.mp3","charTypeName":"word"},{"id":20648,"position":5,"arabic":"١٨","translation":"(১৮)","audioUrl":null,"charTypeName":"end"}]},{"number":19,"arabic":"ثُمَّ إِنَّ عَلَيْنَا بَيَانَهُۥ","translation":"and then, behold, it will be for Us to make its meaning clear.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5570.mp3","surahId":75,"words":[{"id":21700,"position":1,"arabic":"ثُمَّ","translation":"অতঃপর","audioUrl":"wbw/075_019_001.mp3","charTypeName":"word"},{"id":21701,"position":2,"arabic":"إِنَّ","translation":"নিশ্চয়","audioUrl":"wbw/075_019_002.mp3","charTypeName":"word"},{"id":21702,"position":3,"arabic":"عَلَيْنَا","translation":"আমাদের দায়িত্ব","audioUrl":"wbw/075_019_003.mp3","charTypeName":"word"},{"id":21703,"position":4,"arabic":"بَيَانَهُۥ","translation":"তা ব্যাখ্যা দেয়া","audioUrl":"wbw/075_019_004.mp3","charTypeName":"word"},{"id":21704,"position":5,"arabic":"١٩","translation":"(১৯)","audioUrl":null,"charTypeName":"end"}]}]}