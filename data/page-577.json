8/ar.alafasy/5560.mp3","surahId":75,"words":[{"id":10117,"position":1,"arabic":"وَجُمِعَ","translation":"এবং একত্রিত করা হবে","audioUrl":"wbw/075_009_001.mp3","charTypeName":"word"},{"id":10118,"position":2,"arabic":"ٱلشَّمْسُ","translation":"সূর্য","audioUrl":"wbw/075_009_002.mp3","charTypeName":"word"},{"id":10119,"position":3,"arabic":"وَٱلْقَمَرُ","translation":"ও চাঁদ","audioUrl":"wbw/075_009_003.mp3","charTypeName":"word"},{"id":10120,"position":4,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"يَقُولُ ٱلْإِنسَٰنُ يَوْمَئِذٍ أَيْنَ ٱلْمَفَرُّ","translation":"on that Day will man exclaim \"Whither to flee?\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5561.mp3","surahId":75,"words":[{"id":11556,"position":1,"arabic":"يَقُولُ","translation":"বলবে","audioUrl":"wbw/075_010_001.mp3","charTypeName":"word"},{"id":11557,"position":2,"arabic":"ٱلْإِنسَـٰنُ","translation":"মানুষ","audioUrl":"wbw/075_010_002.mp3","charTypeName":"word"},{"id":11558,"position":3,"arabic":"يَوْمَئِذٍ","translation":"সেই দিন","audioUrl":"wbw/075_010_003.mp3","charTypeName":"word"},{"id":11559,"position":4,"arabic":"أَيْنَ","translation":"\"কোথায়","audioUrl":"wbw/075_010_004.mp3","charTypeName":"word"},{"id":11560,"position":5,"arabic":"ٱلْمَفَرُّ","translation":"পালাবার জায়গা\"","audioUrl":"wbw/075_010_005.mp3","charTypeName":"word"},{"id":11561,"position":6,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"كَلَّا لَا وَزَرَ","translation":"But nay: no refuge [for thee, O man]!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5562.mp3","surahId":75,"words":[{"id":12877,"position":1,"arabic":"كَلَّا","translation":"কক্ষন না","audioUrl":"wbw/075_011_001.mp3","charTypeName":"word"},{"id":12878,"position":2,"arabic":"لَا","translation":"নাই","audioUrl":"wbw/075_011_002.mp3","charTypeName":"word"},{"id":12879,"position":3,"arabic":"وَزَرَ","translation":"আশ্রয় স্থল"