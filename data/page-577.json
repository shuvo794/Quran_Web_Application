{"id":577,"ayahs":[{"number":48,"arabic":"فَمَا تَنفَعُهُمْ شَفَٰعَةُ ٱلشَّٰفِعِينَ","translation":"And so, of no benefit to them could be the intercession of any that would intercede for them.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5543.mp3","surahId":74,"words":[{"id":47377,"position":1,"arabic":"فَمَا","translation":"না অতঃপর","audioUrl":"wbw/074_048_001.mp3","charTypeName":"word"},{"id":47378,"position":2,"arabic":"تَنفَعُهُمْ","translation":"তাদের কাজে আসবে","audioUrl":"wbw/074_048_002.mp3","charTypeName":"word"},{"id":47379,"position":3,"arabic":"شَفَـٰعَةُ","translation":"সুপারিশ","audioUrl":"wbw/074_048_003.mp3","charTypeName":"word"},{"id":47380,"position":4,"arabic":"ٱلشَّـٰفِعِينَ","translation":"সুপারিশকারীদের","audioUrl":"wbw/074_048_004.mp3","charTypeName":"word"},{"id":47381,"position":5,"arabic":"٤٨","translation":"(৪৮)","audioUrl":null,"charTypeName":"end"}]},{"number":49,"arabic":"فَمَا لَهُمْ عَنِ ٱلتَّذْكِرَةِ مُعْرِضِينَ","translation":"WHAT, THEN, is amiss with them that they turn away from all admonition","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5544.mp3","surahId":74,"words":[{"id":47947,"position":1,"arabic":"فَمَا","translation":"অতঃপর","audioUrl":"wbw/074_049_001.mp3","charTypeName":"word"},{"id":47948,"position":2,"arabic":"لَهُمْ","translation":"তাদের হয়েছে কি","audioUrl":"wbw/074_049_002.mp3","charTypeName":"word"},{"id":47949,"position":3,"arabic":"عَنِ","translation":"থেকে","audioUrl":"wbw/074_049_003.mp3","charTypeName":"word"},{"id":47950,"position":4,"arabic":"ٱلتَّذْكِرَةِ","translation":"নসীহত","audioUrl":"wbw/074_049_004.mp3","charTypeName":"word"},{"id":47951,"position":5,"arabic":"مُعْرِضِينَ","translation":"মুখ ফিরিয়ে নেয়","audioUrl":"wbw/074_049_005.mp3","charTypeName":"word"},{"id":47952,"position":6,"arabic":"٤٩","translation":"(৪৯)","audioUrl":null,"charTypeName":"end"}]},{"number":50,"arabic":"كَأَنَّهُمْ حُمُرٌۭ مُّسْتَنفِرَةٌۭ","translation":"as though they were terrified asses","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5545.mp3","surahId":74,"words":[{"id":48675,"position":1,"arabic":"كَأَنَّهُمْ","translation":"তারা যেন","audioUrl":"wbw/074_050_001.mp3","charTypeName":"word"},{"id":48676,"position":2,"arabic":"حُمُرٌۭ","translation":"গর্দভসমূহ","audioUrl":"wbw/074_050_002.mp3","charTypeName":"word"},{"id":48677,"position":3,"arabic":"مُّسْتَنفِرَةٌۭ","translation":"ভীতত্রস্ত","audioUrl":"wbw/074_050_003.mp3","charTypeName":"word"},{"id":48678,"position":4,"arabic":"٥٠","translation":"(৫০)","audioUrl":null,"charTypeName":"end"}]},{"number":51,"arabic":"فَرَّتْ مِن قَسْوَرَةٍۭ","translation":"fleeing from a lion?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5546.mp3","surahId":74,"words":[{"id":49281,"position":1,"arabic":"فَرَّتْ","translation":"পলায়ন করছে","audioUrl":"wbw/074_051_001.mp3","charTypeName":"word"},{"id":49282,"position":2,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/074_051_002.mp3","charTypeName":"word"},{"id":49283,"position":3,"arabic":"قَسْوَرَةٍۭ","translation":"সিংহ","audioUrl":"wbw/074_051_003.mp3","charTypeName":"word"},{"id":49284,"position":4,"arabic":"٥١","translation":"(৫১)","audioUrl":null,"charTypeName":"end"}]},{"number":52,"arabic":"بَلْ يُرِيدُ كُلُّ ٱمْرِئٍۢ مِّنْهُمْ أَن يُؤْتَىٰ صُحُفًۭا مُّنَشَّرَةًۭ","translation":"Yea, everyone of them claims that he [himself] ought to have been given revelations unfolded!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5547.mp3","surahId":74,"words":[{"id":49933,"position":1,"arabic":"بَلْ","translation":"বরং","audioUrl":"wbw/074_052_001.mp3","charTypeName":"word"},{"id":49934,"position":2,"arabic":"يُرِيدُ","translation":"চায়","audioUrl":"wbw/074_052_002.mp3","charTypeName":"word"},{"id":49935,"position":3,"arabic":"كُلُّ","translation":"প্রত্যেক","audioUrl":"wbw/074_052_003.mp3","charTypeName":"word"},{"id":49936,"position":4,"arabic":"ٱمْرِئٍۢ","translation":"ব্যক্তি","audioUrl":"wbw/074_052_004.mp3","charTypeName":"word"},{"id":49937,"position":5,"arabic":"مِّنْهُمْ","translation":"তাদের মধ্যে","audioUrl":"wbw/074_052_005.mp3","charTypeName":"word"},{"id":49938,"position":6,"arabic":"أَن","translation":"যে","audioUrl":"wbw/074_052_006.mp3","charTypeName":"word"},{"id":49939,"position":7,"arabic":"يُؤْتَىٰ","translation":"দেয়া হোক","audioUrl":"wbw/074_052_007.mp3","charTypeName":"word"},{"id":49940,"position":8,"arabic":"صُحُفًۭا","translation":"গ্রন্থসমূহ","audioUrl":"wbw/074_052_008.mp3","charTypeName":"word"},{"id":49941,"position":9,"arabic":"مُّنَشَّرَةًۭ","translation":"উন্মুক্ত","audioUrl":"wbw/074_052_009.mp3","charTypeName":"word"},{"id":49942,"position":10,"arabic":"٥٢","translation":"(৫২)","audioUrl":null,"charTypeName":"end"}]},{"number":53,"arabic":"كَلَّا ۖ بَل لَّا يَخَافُونَ ٱلْءَاخِرَةَ","translation":"Nay, but they do not [believe in and, hence, do not] fear the life to come.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5548.mp3","surahId":74,"words":[{"id":50558,"position":1,"arabic":"كَلَّا ۖ","translation":"কক্ষণও না","audioUrl":"wbw/074_053_001.mp3","charTypeName":"word"},{"id":50560,"position":2,"arabic":"بَل","translation":"বরং","audioUrl":"wbw/074_053_003.mp3","charTypeName":"word"},{"id":50561,"position":3,"arabic":"لَّا","translation":"না","audioUrl":"wbw/074_053_004.mp3","charTypeName":"word"},{"id":50562,"position":4,"arabic":"يَخَافُونَ","translation":"তারা ভয় করে না","audioUrl":"wbw/074_053_005.mp3","charTypeName":"word"},{"id":50563,"position":5,"arabic":"ٱلْـَٔاخِرَةَ","translation":"আখেরাতকে","audioUrl":"wbw/074_053_006.mp3","charTypeName":"word"},{"id":50564,"position":6,"arabic":"٥٣","translation":"(৫৩)","audioUrl":null,"charTypeName":"end"}]},{"number":54,"arabic":"كَلَّآ إِنَّهُۥ تَذْكِرَةٌۭ","translation":"Nay, verily, this is an admonition –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5549.mp3","surahId":74,"words":[{"id":51345,"position":1,"arabic":"كَلَّآ","translation":"কক্ষণও না","audioUrl":"wbw/074_054_001.mp3","charTypeName":"word"},{"id":51346,"position":2,"arabic":"إِنَّهُۥ","translation":"তা নিশ্চয়","audioUrl":"wbw/074_054_002.mp3","charTypeName":"word"},{"id":51347,"position":3,"arabic":"تَذْكِرَةٌۭ","translation":"উপদেশ","audioUrl":"wbw/074_054_003.mp3","charTypeName":"word"},{"id":51348,"position":4,"arabic":"٥٤","translation":"(৫৪)","audioUrl":null,"charTypeName":"end"}]},{"number":55,"arabic":"فَمَن شَآءَ ذَكَرَهُۥ","translation":"and whoever wills may take it to heart.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5550.mp3","surahId":74,"words":[{"id":51729,"position":1,"arabic":"فَمَن","translation":"যে অতএব","audioUrl":"wbw/074_055_001.mp3","charTypeName":"word"},{"id":51730,"position":2,"arabic":"شَآءَ","translation":"ইচ্ছা করে","audioUrl":"wbw/074_055_002.mp3","charTypeName":"word"},{"id":51731,"position":3,"arabic":"ذَكَرَهُۥ","translation":"তার শিক্ষা নিক","audioUrl":"wbw/074_055_003.mp3","charTypeName":"word"},{"id":51732,"position":4,"arabic":"٥٥","translation":"(৫৫)","audioUrl":null,"charTypeName":"end"}]},{"number":56,"arabic":"وَمَا يَذْكُرُونَ إِلَّآ أَن يَشَآءَ ٱللَّهُ ۚ هُوَ أَهْلُ ٱلتَّقْوَىٰ وَأَهْلُ ٱلْمَغْفِرَةِ","translation":"But they [who do not believe in the life to come] will not take it to heart unless God so wills: [for] He is the Fount of all God-consciousness, and the Fount of all forgiveness.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5551.mp3","surahId":74,"words":[{"id":52267,"position":1,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/074_056_001.mp3","charTypeName":"word"},{"id":52268,"position":2,"arabic":"يَذْكُرُونَ","translation":"তারা শিক্ষা নেবে","audioUrl":"wbw/074_056_002.mp3","charTypeName":"word"},{"id":52269,"position":3,"arabic":"إِلَّآ","translation":"এ ছাড়া","audioUrl":"wbw/074_056_003.mp3","charTypeName":"word"},{"id":52270,"position":4,"arabic":"أَن","translation":"যে","audioUrl":"wbw/074_056_004.mp3","charTypeName":"word"},{"id":52271,"position":5,"arabic":"يَشَآءَ","translation":"ইচ্ছা করেন","audioUrl":"wbw/074_056_005.mp3","charTypeName":"word"},{"id":52272,"position":6,"arabic":"ٱللَّهُ ۚ","translation":"আল্লাহ","audioUrl":"wbw/074_056_006.mp3","charTypeName":"word"},{"id":52274,"position":7,"arabic":"هُوَ","translation":"তিনিই","audioUrl":"wbw/074_056_008.mp3","charTypeName":"word"},{"id":52275,"position":8,"arabic":"أَهْلُ","translation":"যোগ্য","audioUrl":"wbw/074_056_009.mp3","charTypeName":"word"},{"id":52276,"position":9,"arabic":"ٱلتَّقْوَىٰ","translation":"ভয়ের","audioUrl":"wbw/074_056_010.mp3","charTypeName":"word"},{"id":52277,"position":10,"arabic":"وَأَهْلُ","translation":"এবং অধিকারী","audioUrl":"wbw/074_056_011.mp3","charTypeName":"word"},{"id":52278,"position":11,"arabic":"ٱلْمَغْفِرَةِ","translation":"মাফ করার","audioUrl":"wbw/074_056_012.mp3","charTypeName":"word"},{"id":52279,"position":12,"arabic":"٥٦","translation":"(৫৬)","audioUrl":null,"charTypeName":"end"}]},{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ لَآ أُقْسِمُ بِيَوْمِ ٱلْقِيَٰمَةِ","translation":"NAY! I call to witness the Day of Resurrection!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5552.mp3","surahId":75,"words":[{"id":634,"position":1,"arabic":"لَآ","translation":"না","audioUrl":"wbw/075_001_001.mp3","charTypeName":"word"},{"id":635,"position":2,"arabic":"أُقْسِمُ","translation":"কসম খাচ্ছি","audioUrl":"wbw/075_001_002.mp3","charTypeName":"word"},{"id":636,"position":3,"arabic":"بِيَوْمِ","translation":"দিনের","audioUrl":"wbw/075_001_003.mp3","charTypeName":"word"},{"id":637,"position":4,"arabic":"ٱلْقِيَـٰمَةِ","translation":"কিয়ামাতের","audioUrl":"wbw/075_001_004.mp3","charTypeName":"word"},{"id":638,"position":5,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"وَلَآ أُقْسِمُ بِٱلنَّفْسِ ٱللَّوَّامَةِ","translation":"But nay! I call to witness the accusing voice of man's own conscience!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5553.mp3","surahId":75,"words":[{"id":1616,"position":1,"arabic":"وَلَآ","translation":"এবং না","audioUrl":"wbw/075_002_001.mp3","charTypeName":"word"},{"id":1617,"position":2,"arabic":"أُقْسِمُ","translation":"শপথ করছি আমি","audioUrl":"wbw/075_002_002.mp3","charTypeName":"word"},{"id":1618,"position":3,"arabic":"بِٱلنَّفْسِ","translation":"মনের","audioUrl":"wbw/075_002_003.mp3","charTypeName":"word"},{"id":1619,"position":4,"arabic":"ٱللَّوَّامَةِ","translation":"তিরস্কারকারী","audioUrl":"wbw/075_002_004.mp3","charTypeName":"word"},{"id":1620,"position":5,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"أَيَحْسَبُ ٱلْإِنسَٰنُ أَلَّن نَّجْمَعَ عِظَامَهُۥ","translation":"Does man think that We cannot [resurrect him and] bring his bones together again?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5554.mp3","surahId":75,"words":[{"id":2639,"position":1,"arabic":"أَيَحْسَبُ","translation":"মনে করেছে কি","audioUrl":"wbw/075_003_001.mp3","charTypeName":"word"},{"id":2640,"position":2,"arabic":"ٱلْإِنسَـٰنُ","translation":"মানুষ","audioUrl":"wbw/075_003_002.mp3","charTypeName":"word"},{"id":2641,"position":3,"arabic":"أَلَّن","translation":"কখন না","audioUrl":"wbw/075_003_003.mp3","charTypeName":"word"},{"id":2642,"position":4,"arabic":"نَّجْمَعَ","translation":"একত্রিত আমরা করব","audioUrl":"wbw/075_003_004.mp3","charTypeName":"word"},{"id":2643,"position":5,"arabic":"عِظَامَهُۥ","translation":"তার অস্তিগুলকে","audioUrl":"wbw/075_003_005.mp3","charTypeName":"word"},{"id":2644,"position":6,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"بَلَىٰ قَٰدِرِينَ عَلَىٰٓ أَن نُّسَوِّىَ بَنَانَهُۥ","translation":"Yea indeed, We are able to make whole his very finger-tips!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5555.mp3","surahId":75,"words":[{"id":4048,"position":1,"arabic":"بَلَىٰ","translation":"কােনো না","audioUrl":"wbw/075_004_001.mp3","charTypeName":"word"},{"id":4049,"position":2,"arabic":"قَـٰدِرِينَ","translation":"সক্ষম","audioUrl":"wbw/075_004_002.mp3","charTypeName":"word"},{"id":4050,"position":3,"arabic":"عَلَىٰٓ","translation":"এতে","audioUrl":"wbw/075_004_003.mp3","charTypeName":"word"},{"id":4051,"position":4,"arabic":"أَن","translation":"যে","audioUrl":"wbw/075_004_004.mp3","charTypeName":"word"},{"id":4052,"position":5,"arabic":"نُّسَوِّىَ","translation":"পূর্ণবিন্যস্ত আমরা করবো","audioUrl":"wbw/075_004_005.mp3","charTypeName":"word"},{"id":4053,"position":6,"arabic":"بَنَانَهُۥ","translation":"তার আঙ্গুলির অগ্রভাগ","audioUrl":"wbw/075_004_006.mp3","charTypeName":"word"},{"id":4054,"position":7,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"بَلْ يُرِيدُ ٱلْإِنسَٰنُ لِيَفْجُرَ أَمَامَهُۥ","translation":"None the less man chooses to deny what lies ahead of him,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5556.mp3","surahId":75,"words":[{"id":5339,"position":1,"arabic":"بَلْ","translation":"বরং","audioUrl":"wbw/075_005_001.mp3","charTypeName":"word"},{"id":5340,"position":2,"arabic":"يُرِيدُ","translation":"চায়ে","audioUrl":"wbw/075_005_002.mp3","charTypeName":"word"},{"id":5341,"position":3,"arabic":"ٱلْإِنسَـٰنُ","translation":"মানুষ","audioUrl":"wbw/075_005_003.mp3","charTypeName":"word"},{"id":5342,"position":4,"arabic":"لِيَفْجُرَ","translation":"কুকর্ম করার জন্য","audioUrl":"wbw/075_005_004.mp3","charTypeName":"word"},{"id":5343,"position":5,"arabic":"أَمَامَهُۥ","translation":"তার ভবিষ্যতেও","audioUrl":"wbw/075_005_005.mp3","charTypeName":"word"},{"id":5344,"position":6,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"يَسْـَٔلُ أَيَّانَ يَوْمُ ٱلْقِيَٰمَةِ","translation":"asking [derisively], \"When is that Resurrection Day to be?\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5557.mp3","surahId":75,"wo