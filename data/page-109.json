েকে তোমাদের","audioUrl":"wbw/005_012_032.mp3","charTypeName":"word"},{"id":14173,"position":30,"arabic":"سَيِّـَٔاتِكُمْ","translation":"পাপসমূহ তোমাদের","audioUrl":"wbw/005_012_033.mp3","charTypeName":"word"},{"id":14174,"position":31,"arabic":"وَلَأُدْخِلَنَّكُمْ","translation":"এবং অবশ্যই প্রবেশ করাবো তোমাদের","audioUrl":"wbw/005_012_034.mp3","charTypeName":"word"},{"id":14175,"position":32,"arabic":"جَنَّـٰتٍۢ","translation":"জান্নাতে","audioUrl":"wbw/005_012_035.mp3","charTypeName":"word"},{"id":14176,"position":33,"arabic":"تَجْرِى","translation":"প্রবাহিত হয়","audioUrl":"wbw/005_012_036.mp3","charTypeName":"word"},{"id":14177,"position":34,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/005_012_037.mp3","charTypeName":"word"},{"id":14178,"position":35,"arabic":"تَحْتِهَا","translation":"নিচ তার","audioUrl":"wbw/005_012_038.mp3","charTypeName":"word"},{"id":14179,"position":36,"arabic":"ٱلْأَنْهَـٰرُ ۚ","translation":"ঝর্ণাধারাসমূহ","audioUrl":"wbw/005_012_039.mp3","charTypeName":"word"},{"id":14181,"position":37,"arabic":"فَمَن","translation":"অত:পর যে","audioUrl":"wbw/005_012_041.mp3","charTypeName":"word"},{"id":14182,"position":38,"arabic":"كَفَرَ","translation":"অবিশ্বাস করেছে","audioUrl":"wbw/005_012_042.mp3","charTypeName":"word"},{"id":14183,"position":39,"arabic":"بَعْدَ","translation":"পরেও","audioUrl":"wbw/005_012_043.mp3","charTypeName":"word"},{"id":14184,"position":40,"arabic":"ذَٰلِكَ","translation":"এর","audioUrl":"wbw/005_012_044.mp3","charTypeName":"word"},{"id":14185,"position":41,"arabic":"مِنكُمْ","translation":"মধ্য হতে তোমাদের","audioUrl":"wbw/005_012_045.mp3","charTypeName":"word"},{"id":14186,"position":42,"arabic":"فَقَدْ","translation":"ফলে নিশ্চয়ই","audioUrl":"wbw/005_012_046.mp3","charTypeName":"word"},{"id":14187,"position":43,"arabic":"ضَلَّ","translation":"সে হারিয়ে ফেলেছে","audioUrl":"wbw/005_012_047.mp3","charTypeName":"word"},{"id":14188,"position":44,"arabic":"سَوَآءَ","translation":"সরল সোজা","audioUrl":"wbw/005_012_048.mp3","charTypeName":"word"},{"id":14189,"position":45,"arabic":"ٱلسَّبِيلِ","translation":"পথ","audioUrl":"wbw/005_012_049.mp3","charTypeName":"word"},{"id":14190,"position":46,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]},{"number":13,"arabic":"فَبِمَا نَقْضِهِم مِّيثَٰقَهُمْ لَعَنَّٰهُمْ وَجَعَلْنَا قُلُوبَهُمْ قَٰسِيَةًۭ ۖ يُحَرِّفُونَ ٱلْكَلِمَ عَن مَّوَاضِعِهِۦ ۙ وَنَسُوا۟ حَظًّۭا مِّمَّا ذُكِّرُوا۟ بِهِۦ ۚ وَلَا تَزَالُ تَطَّلِعُ عَلَىٰ خَآئِنَةٍۢ مِّنْهُمْ إِلَّا قَلِيلًۭا مِّنْهُمْ ۖ فَٱعْفُ عَنْهُمْ وَٱصْفَحْ ۚ إِنَّ ٱللَّهَ يُحِبُّ ٱلْمُحْسِنِينَ","translation":"Then, for having broken their solemn pledge, We rejected them and caused their hearts to harden-[so that now] they distort the meaning of the [re-vealed] words, taking them out of their context; and they have forgotten much of what they had been told to bear in mind; and from all but a few of them thou wilt always experience treachery. But pardon them, and forbear: verily, God loves the doers of good.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/682.mp3","surahId":5,"words":[{"id":15302,"position":1,"arabic":"فَبِمَا","translation":"অতএব কারণে","audioUrl":"wbw/005_013_001.mp3","charTypeName":"word"},{"id":15303,"position":2,"arabic":"نَقْضِهِم","translation":"ভঙ্গের তাদের","audioUrl":"wbw/005_013_002.mp3","charTypeName":"word"},{"id":15304,"position":3,"arabic":"مِّيثَـٰقَهُمْ","translation":"অংগীকারের তাদের","audioUrl":"wbw/005_013_003.mp3","charTypeName":"word"},{"id":15305,"position":4,"arabic":"لَعَنَّـٰهُمْ","translation":"অভিশাপ দিয়েছি আমরা তাদের","audioUrl":"wbw/005_013_004.mp3","charTypeName":"word"},{"id":15306,"position":5,"arabic":"وَجَعَلْنَا","translation":"ও আমরা করেছি","audioUrl":"wbw/005_013_005.mp3","charTypeName":"word"},{"id":15307,"position":6,"arabic":"قُلُوبَهُمْ","translation":"অন্তরসমূহকে তাদের","audioUrl":"wbw/005_013_006.mp3","charTypeName":"word"},{"id":15308,"position":7,"arabic":"قَـٰسِيَةًۭ ۖ","translation":"কঠিন","audioUrl":"wbw/005_013_007.mp3","charTypeName":"word"},{"id":15310,"position":8,"arabic":"يُحَرِّفُونَ","translation":"তারা বিকৃত করে","audioUrl":"wbw/005_013_009.mp3","charTypeName":"word"},{"id":15311,"position":9,"arabic":"ٱلْكَلِمَ","translation":"কথাকে","audioUrl":"wbw/005_013_010.mp3","charTypeName":"word"},{"id":15312,"position":10,"arabic":"عَن","translation":"থেকে","audioUrl":"wbw/005_013_011.mp3","charTypeName":"word"},{"id":15313,"position":11,"arabic":"مَّوَاضِعِهِۦ ۙ","translation":"তার (প্রসঙ্গ) স্থান","audioUrl":"wbw/005_013_012.mp3","charTypeName":"word"},{"id":15315,"position":12,"arabic":"وَنَسُوا۟","translation":"ও তারা ভুলে গিয়েছে","audioUrl":"wbw/005_013_014.mp3","charTypeName":"word"},{"id":15316,"position":13,"arabic":"حَظًّۭا","translation":"এক অংশ","audioUrl":"wbw/005_013_015.mp3","charTypeName":"word"},{"id":15317,"position":14,"arabic":"مِّمَّا","translation":"তা হতে যা","audioUrl":"wbw/005_013_016.mp3","charTypeName":"word"},{"id":15318,"position":15,"arabic":"ذُكِّرُوا۟","translation":"তাদের উপদেশ দেওয়া হয়েছিলো","audioUrl":"wbw/005_013_017.mp3","charTypeName":"word"},{"id":15319,"position":16,"arabic":"بِهِۦ ۚ","translation":"ব্যাপারে সে","audioUrl":"wbw/005_013_018.mp3","charTypeName":"word"},{"id":15321,"position":17,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/005_013_020.mp3","charTypeName":"word"},{"id":15322,"position":18,"arabic":"تَزَالُ","translation":"তুমি সর্বদাই","audioUrl":"wbw/005_013_021.mp3","charTypeName":"word"},{"id":15323,"position":19,"arabic":"تَطَّلِعُ","translation":"অবগত হতে থাকবে","audioUrl":"wbw/005_013_022.mp3","charTypeName":"word"},{"id":15324,"position":20,"arabic":"عَلَىٰ","translation":"সম্পর্কে","audioUrl":"wbw/005_013_023.mp3","charTypeName":"word"},{"id":15325,"position":21,"arabic":"خَآئِنَةٍۢ","translation":"বিশ্বাস ভঙ্গ করা","audioUrl":"wbw/005_013_024.mp3","charTypeName":"word"},{"id":15326,"position":22,"arabic":"مِّنْهُمْ","translation":"মধ্য হতে তাদের","audioUrl":"wbw/005_013_025