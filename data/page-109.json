{"id":109,"ayahs":[{"number":10,"arabic":"وَٱلَّذِينَ كَفَرُوا۟ وَكَذَّبُوا۟ بِـَٔايَٰتِنَآ أُو۟لَٰٓئِكَ أَصْحَٰبُ ٱلْجَحِيمِ","translation":"whereas they who are bent on denying the truth and giving the lie to Our messages-they are destined for the blazing fire.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/679.mp3","surahId":5,"words":[{"id":11613,"position":1,"arabic":"وَٱلَّذِينَ","translation":"কিন্তু যারা","audioUrl":"wbw/005_010_001.mp3","charTypeName":"word"},{"id":11614,"position":2,"arabic":"كَفَرُوا۟","translation":"অবিশ্বাস করেছে","audioUrl":"wbw/005_010_002.mp3","charTypeName":"word"},{"id":11615,"position":3,"arabic":"وَكَذَّبُوا۟","translation":"ও মিথ্যা সাব্যস্ত করেছে","audioUrl":"wbw/005_010_003.mp3","charTypeName":"word"},{"id":11616,"position":4,"arabic":"بِـَٔايَـٰتِنَآ","translation":"প্রতি আয়াতগুলোর আমাদের","audioUrl":"wbw/005_010_004.mp3","charTypeName":"word"},{"id":11617,"position":5,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐসব লোক","audioUrl":"wbw/005_010_005.mp3","charTypeName":"word"},{"id":11618,"position":6,"arabic":"أَصْحَـٰبُ","translation":"অধিবাসী","audioUrl":"wbw/005_010_006.mp3","charTypeName":"word"},{"id":11619,"position":7,"arabic":"ٱلْجَحِيمِ","translation":"জাহান্নামের","audioUrl":"wbw/005_010_007.mp3","charTypeName":"word"},{"id":11620,"position":8,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ ٱذْكُرُوا۟ نِعْمَتَ ٱللَّهِ عَلَيْكُمْ إِذْ هَمَّ قَوْمٌ أَن يَبْسُطُوٓا۟ إِلَيْكُمْ أَيْدِيَهُمْ فَكَفَّ أَيْدِيَهُمْ عَنكُمْ ۖ وَٱتَّقُوا۟ ٱللَّهَ ۚ وَعَلَى ٱللَّهِ فَلْيَتَوَكَّلِ ٱلْمُؤْمِنُونَ","translation":"O you who have attained to faith! Remember the blessings which God bestowed upon you when [hostile] people were about to lay hands on you and He stayed their hands from you. Remain, then, conscious of God: and in God let the believers place their trust.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/680.mp3","surahId":5,"words":[{"id":12895,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/005_011_001.mp3","charTypeName":"word"},{"id":12896,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/005_011_002.mp3","charTypeName":"word"},{"id":12897,"position":3,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছো","audioUrl":"wbw/005_011_003.mp3","charTypeName":"word"},{"id":12898,"position":4,"arabic":"ٱذْكُرُوا۟","translation":"স্মরণ করো","audioUrl":"wbw/005_011_004.mp3","charTypeName":"word"},{"id":12899,"position":5,"arabic":"نِعْمَتَ","translation":"অনুগ্রহসমূহের","audioUrl":"wbw/005_011_005.mp3","charTypeName":"word"},{"id":12900,"position":6,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/005_011_006.mp3","charTypeName":"word"},{"id":12901,"position":7,"arabic":"عَلَيْكُمْ","translation":"উপর তোমাদের","audioUrl":"wbw/005_011_007.mp3","charTypeName":"word"},{"id":12902,"position":8,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/005_011_008.mp3","charTypeName":"word"},{"id":12903,"position":9,"arabic":"هَمَّ","translation":"সংকল্প করেছিলো","audioUrl":"wbw/005_011_009.mp3","charTypeName":"word"},{"id":12904,"position":10,"arabic":"قَوْمٌ","translation":"একটি সম্প্রদায়","audioUrl":"wbw/005_011_010.mp3","charTypeName":"word"},{"id":12905,"position":11,"arabic":"أَن","translation":"যে","audioUrl":"wbw/005_011_011.mp3","charTypeName":"word"},{"id":12906,"position":12,"arabic":"يَبْسُطُوٓا۟","translation":"সম্প্রসারিত করবে","audioUrl":"wbw/005_011_012.mp3","charTypeName":"word"},{"id":12907,"position":13,"arabic":"إِلَيْكُمْ","translation":"দিকে তোমাদের","audioUrl":"wbw/005_011_013.mp3","charTypeName":"word"},{"id":12908,"position":14,"arabic":"أَيْدِيَهُمْ","translation":"হাতগুলো তাদের","audioUrl":"wbw/005_011_014.mp3","charTypeName":"word"},{"id":12909,"position":15,"arabic":"فَكَفَّ","translation":"তখন ঠেকিয়ে দিয়েছেন (আল্লাহ)","audioUrl":"wbw/005_011_015.mp3","charTypeName":"word"},{"id":12910,"position":16,"arabic":"أَيْدِيَهُمْ","translation":"হাতগুলোকে তাদের","audioUrl":"wbw/005_011_016.mp3","charTypeName":"word"},{"id":12911,"position":17,"arabic":"عَنكُمْ ۖ","translation":"থেকে তোমাদের","audioUrl":"wbw/005_011_017.mp3","charTypeName":"word"},{"id":12913,"position":18,"arabic":"وَٱتَّقُوا۟","translation":"এবং তোমরা ভয় করো","audioUrl":"wbw/005_011_019.mp3","charTypeName":"word"},{"id":12914,"position":19,"arabic":"ٱللَّهَ ۚ","translation":"আল্লাহকে","audioUrl":"wbw/005_011_020.mp3","charTypeName":"word"},{"id":12916,"position":20,"arabic":"وَعَلَى","translation":"এবং উপর","audioUrl":"wbw/005_011_022.mp3","charTypeName":"word"},{"id":12917,"position":21,"arabic":"ٱللَّهِ","translation":"আল্লাহরই","audioUrl":"wbw/005_011_023.mp3","charTypeName":"word"},{"id":12918,"position":22,"arabic":"فَلْيَتَوَكَّلِ","translation":"উচিত নির্ভর করা","audioUrl":"wbw/005_011_024.mp3","charTypeName":"word"},{"id":12919,"position":23,"arabic":"ٱلْمُؤْمِنُونَ","translation":"মু’মিনদের","audioUrl":"wbw/005_011_025.mp3","charTypeName":"word"},{"id":12920,"position":24,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]},{"number":12,"arabic":"۞ وَلَقَدْ أَخَذَ ٱللَّهُ مِيثَٰقَ بَنِىٓ إِسْرَٰٓءِيلَ وَبَعَثْنَا مِنْهُمُ ٱثْنَىْ عَشَرَ نَقِيبًۭا ۖ وَقَالَ ٱللَّهُ إِنِّى مَعَكُمْ ۖ لَئِنْ أَقَمْتُمُ ٱلصَّلَوٰةَ وَءَاتَيْتُمُ ٱلزَّكَوٰةَ وَءَامَنتُم بِرُسُلِى وَعَزَّرْتُمُوهُمْ وَأَقْرَضْتُمُ ٱللَّهَ قَرْضًا حَسَنًۭا لَّأُكَفِّرَنَّ عَنكُمْ سَيِّـَٔاتِكُمْ وَلَأُدْخِلَنَّكُمْ جَنَّٰتٍۢ تَجْرِى مِن تَحْتِهَا ٱلْأَنْهَٰرُ ۚ فَمَن كَفَرَ بَعْدَ ذَٰلِكَ مِنكُمْ فَقَدْ ضَلَّ سَوَآءَ ٱلسَّبِيلِ","translation":"AND, INDEED, God accepted a [similar] solemn pledge from the children of Israel when We caused twelve of their leaders to be sent [to Canaan as spies]. And God said: \"Behold, I shall be with you! If you are constant in prayer, and spend in charity, and believe in My apostles and aid them, and offer up unto God a goodly loan, I will surely efface your bad deeds and bring you into gardens through which running waters flow. But he from among you who, after this, denies the truth, will indeed have strayed from the right path!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/681.mp3","surahId":5,"words":[{"id":14142,"position":1,"arabic":"۞ وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/005_012_002.mp3","charTypeName":"word"},{"id":14143,"position":2,"arabic":"أَخَذَ","translation":"নিয়েছিলেন","audioUrl":"wbw/005_012_003.mp3","charTypeName":"word"},{"id":14144,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/005_012_004.mp3","charTypeName":"word"},{"id":14145,"position":4,"arabic":"مِيثَـٰقَ","translation":"অঙ্গীকার","audioUrl":"wbw/005_012_005.mp3","charTypeName":"word"},{"id":14146,"position":5,"arabic":"بَنِىٓ","translation":"(হতে) বনী","audioUrl":"wbw/005_012_006.mp3","charTypeName":"word"},{"id":14147,"position":6,"arabic":"إِسْرَٰٓءِيلَ","translation":"ইসরাঈলদের","audioUrl":"wbw/005_012_007.mp3","charTypeName":"word"},{"id":14148,"position":7,"arabic":"وَبَعَثْنَا","translation":"ও নিযুক্ত করেছিলাম আমরা","audioUrl":"wbw/005_012_008.mp3","charTypeName":"word"},{"id":14149,"position":8,"arabic":"مِنْهُمُ","translation":"মধ্য হতে তাদের","audioUrl":"wbw/005_012_009.mp3","charTypeName":"word"},{"id":14150,"position":9,"arabic":"ٱثْنَىْ","translation":"বার (জন)","audioUrl":"wbw/005_012_010.mp3","charTypeName":"word"},{"id":14151,"position":10,"arabic":"عَشَرَ","translation":"বার (জন)","audioUrl":"wbw/005_012_011.mp3","charTypeName":"word"},{"id":14152,"position":11,"arabic":"نَقِيبًۭا ۖ","translation":"দলনেতা","audioUrl":"wbw/005_012_012.mp3","charTypeName":"word"},{"id":14154,"position":12,"arabic":"وَقَالَ","translation":"এবং বলেছিলেন","audioUrl":"wbw/005_012_014.mp3","charTypeName":"word"},{"id":14155,"position":13,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/005_012_015.mp3","charTypeName":"word"},{"id":14156,"position":14,"arabic":"إِنِّى","translation":"\"নিশ্চয়ই আমি","audi