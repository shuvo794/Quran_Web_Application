network/quran/audio/128/ar.alafasy/1463.mp3","surahId":10,"words":[{"id":70981,"position":1,"arabic":"وَلَوْ","translation":"এবং যদি","audioUrl":"wbw/010_099_001.mp3","charTypeName":"word"},{"id":70982,"position":2,"arabic":"شَآءَ","translation":"ইচ্ছে করতেন","audioUrl":"wbw/010_099_002.mp3","charTypeName":"word"},{"id":70983,"position":3,"arabic":"رَبُّكَ","translation":"রব তোমার","audioUrl":"wbw/010_099_003.mp3","charTypeName":"word"},{"id":70984,"position":4,"arabic":"لَـَٔامَنَ","translation":"অবশ্যই ঈমান আনতো","audioUrl":"wbw/010_099_004.mp3","charTypeName":"word"},{"id":70985,"position":5,"arabic":"مَن","translation":"যারা","audioUrl":"wbw/010_099_005.mp3","charTypeName":"word"},{"id":70986,"position":6,"arabic":"فِى","translation":"মধ্যে (আছে)","audioUrl":"wbw/010_099_006.mp3","charTypeName":"word"},{"id":70987,"position":7,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/010_099_007.mp3","charTypeName":"word"},{"id":70988,"position":8,"arabic":"كُلُّهُمْ","translation":"সবাই তাদের","audioUrl":"wbw/010_099_008.mp3","charTypeName":"word"},{"id":70989,"position":9,"arabic":"جَمِيعًا ۚ","translation":"একসাথে","audioUrl":"wbw/010_099_009.mp3","charTypeName":"word"},{"id":70991,"position":10,"arabic":"أَفَأَنتَ","translation":"কি তবে তুমি","audioUrl":"wbw/010_099_011.mp3","charTypeName":"word"},{"id":70992,"position":11,"arabic":"تُكْرِهُ","translation":"জবরদস্তি করবে","audioUrl":"wbw/010_099_012.mp3","charTypeName":"word"},{"id":70993,"position":12,"arabic":"ٱلنَّاسَ","translation":"মানুষদেরকে","audioUrl":"wbw/010_099_013.mp3","charTypeName":"word"},{"id":70994,"position":13,"arabic":"حَتَّىٰ","translation":"যতক্ষণ না","audioUrl":"wbw/010_099_014.mp3","charTypeName":"word"},{"id":70995,"position":14,"arabic":"يَكُونُوا۟","translation":"তারা হবে","audioUrl":"wbw/010_099_015.mp3","charTypeName":"word"},{"id":70996,"position":15,"arabic":"مُؤْمِنِينَ","translation":"মু'মিন","audioUrl":"wbw/010_099_016.mp3","charTypeName":"word"},{"id":70997,"position":16,"arabic":"٩٩","translation":"(৯৯)","audioUrl":null,"charTypeName":"end"}]},{"number":100,"arabic":"وَمَا كَانَ لِنَفْسٍ أَن تُؤْمِنَ إِلَّا بِإِذْنِ ٱللَّهِ ۚ وَيَجْعَلُ ٱلرِّجْسَ عَلَى ٱلَّذِينَ لَا يَعْقِلُونَ","translation":"notwithstanding that no human being can ever attain to faith otherwise than by God's leave, and [that] it is He who lays the loathsome evil [of disbelief] upon those who will not use -their reason?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1464.mp3","surahId":10,"words":[{"id":71200,"position":1,"arabic":"وَمَا","translation":"এবং নয়","audioUrl":"wbw/010_100_001.mp3","charTypeName":"word"},{"id":71201,"position":2,"arabic":"كَانَ","translation":"সম্ভব","audioUrl":"wbw/010_100_002.mp3","charTypeName":"word"},{"id":71202,"position":3,"arabic":"لِنَفْسٍ","translation":"জন্যে কোনো ব্যক্তির","audioUrl":"wbw/010_100_003.mp3","charTypeName":"word"},{"id":71203,"position":4,"arabic":"أَن","translation":"যে","audioUrl":"wbw/010_100_004.mp3","charTypeName":"word"},{"id":71204,"position":5,"arabic":"تُؤْمِنَ","translation":"সে ঈমান আনবে","audioUrl":"wbw/010_100_005.mp3","charTypeName":"word"},{"id":71205,"position":6,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/010_100_006.mp3","charTypeName":"word"},{"id":71206,"position":7,"arabic":"بِإِذْنِ","translation":"নিয়ে অনুমতি","audioUrl":"wbw/010_100_007.mp3","charTypeName":"word"},{"id":71207,"position":8,"arabic":"ٱللَّهِ ۚ","translation":"আল্লাহর","audioUrl":"wbw/010_100_008.mp3","charTypeName":"word"},{"id":71209,"position":9,"arabic":"وَيَجْعَلُ","translation":"এবং তিনি রাখবেন","audioUrl":"wbw/010_100_010.mp3","charTypeName":"word"},{"id":71210,"position":10,"arabic":"ٱلرِّجْسَ","translation":"অপবিত্রতা","audioUrl":"wbw/010_100_011.mp3","charTypeName":"word"},{"id":71211,"position":11,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/010_100_012.mp3","charTypeName":"word"},{"id":71212,"position":12,"arabic":"ٱلَّذِينَ","translation":"(তাদের) যারা","audioUrl":"wbw/010_100_013.mp3","charTypeName":"word"},{"id":71213,"position":13,"arabic":"لَا","translation":"না","audioUrl":"wbw/010_100_014.mp3","charTypeName":"word"},{"id":71214,"position":14,"arabic":"يَعْقِلُونَ","translation":"বুঝতে পারে","audioUrl":"wbw/010_100_015.mp3","charTypeName":"word"},{"id":71215,"position":15,"arabic":"١٠٠","translation":"(১০০)","audioUrl":null,"charTypeName":"end"}]},{"number":101,"arabic":"قُلِ ٱنظُرُوا۟ مَاذَا فِى ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ ۚ وَمَا تُغْنِى ٱلْءَايَٰتُ وَٱلنُّذُرُ عَن قَوْمٍۢ لَّا يُؤْمِنُونَ","translation":"Say: \"Consider whatever there is in the heavens and on earth!\" But of what avail could all the messages and all the warnings be to people who will not believe?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1465.mp3","surahId":10,"words":[{"id":71666,"position":1,"arabic":"قُلِ","translation":"(তুমি) বলো","audioUrl":"wbw/010_101_001.mp3","charTypeName":"word"},{"id":71667,"position":2,"arabic":"ٱنظُرُوا۟","translation":"\"তোমরা লক্ষ্য করো","audioUrl":"wbw/010_101_002.mp3","charTypeName":"word"},{"id":71668,"position":3,"arabic":"مَاذَا","translation":"কি","audioUrl":"wbw/010_101_003.mp3","charTypeName":"word"},{"id":71669,"position":4,"arabic":"فِى","translation":"মধ্যে (আছে)","audioUrl":"wbw/010_101_004.mp3","charTypeName":"word"},{"id":71670,"position":5,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশসমূহের","audioUrl":"wbw/010_101_005.mp3","charTypeName":"word"},{"id":71671,"position":6,"arabic":"وَٱلْأَرْضِ ۚ","translation":"এবং পৃথিবীর\"","audioUrl":"wbw/010_101_006.mp3","charTypeName":"word"},{"id":71673,"position":7,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/010_101_008.mp3","charTypeName":"word"},{"id":71674,"position":8,"arabic":"تُغْنِى","translation":"উপকারে আসে","audioUrl":"wbw/010_101_009.mp3","charTypeName":"word"},{"id":71675,"position":9,"arabic":"ٱلْـَٔايَـٰتُ","translation":"নিদর্শনসমূহ","audioUrl":"wbw/010_101_010.mp3","charTypeName":"word"},{"id":71676,"position":10,"arabic":"وَٱلنُّذُرُ","translation":"আর (না) সতর্কীকরণ","audioUrl":"wbw/010_101_011.mp3","charTypeName":"word"},{"id":71677,"position":11,"arabic":"عَن","translation":"জন্যে","audioUrl":"wbw/010_101_012.mp3","charTypeName":"word"},{"id":71678,"position":12,"arabic":"قَوْمٍۢ","translation":"(সেই) জাতির","audioUrl":"wbw/010_101_013.mp3","charTypeName":"word"},{"id":71679,"position":13,"arabic":"لَّا","translation":"না","audioUrl":"wbw/010_101_014.mp3","charTypeName":"word"},{"id":71680,"position":14,"arabic":"يُؤْمِنُونَ","translation":"(যারা) ঈমান আনে","audioUrl":"wbw/010_101_015.mp3","charTypeName":"word"},{"id":71681,"position":15,"arabic":"١٠١","translation":"(১০১)","audioUrl":null,"charTypeName":"end"}]},{"number":102,"arabic":"فَهَلْ يَنتَظِرُونَ إِلَّا مِثْلَ أَيَّامِ ٱلَّذِينَ خَلَوْا۟ مِن قَبْلِهِمْ ۚ قُلْ فَٱنتَظِرُوٓا۟ إِنِّى مَعَكُم مِّنَ ٱلْمُنتَظِرِينَ","translation":"Can such, then, expect anything else [to befall them] but the like of the days of [calamity which befell] those [deniers of the truth] who passed away before them? Say: \"Wait, then, [for what will happen) verily, I shall wait with you!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1466.mp3","surahId":10,"words":[{"id":71766,"position":1,"arabic":"فَهَلْ","translation":"তবে কি","audioUrl":"wbw/010_102_001.mp3","charTypeName":"word"},{"id":71767,"position":2,"arabic":"يَنتَظِرُونَ","translation":"তারা অপেক্ষা করছে","audioUrl":"wbw/010_102_002.mp3","charTypeName":"word"},{"id":71768,"position":3,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/010_102_003.mp3","charTypeName":"word"},{"id":71769,"position":4,"arabic":"مِثْلَ","translation":"অনুরূপ (খারাপ)","audioUrl":"wbw/010_102_004.mp3","charTypeName":"word"},{"id":71770,"position":5,"arabic":"أَيَّامِ","translation":"দিনগুলোর","audioUrl":"wbw/010_102_005.mp3","charTypeName":"word"},{"id":71771,"position":6,"arabic":"ٱلَّذِينَ","translation":"(তাদের) যারা","audioUrl":"wbw/010_102_006.mp3","charTypeName":"word"},{"id":71772,"position":7,"arabic":"خَلَوْا۟","translation":"অতিবাহিত হয়েছে","audioUrl":"wbw/010_102_007.mp3","charTypeName":"word"},{"id":71773,"position":8,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/010_102_008.mp3","charTypeName":"word"},{"id":71774,"position":9,"arabic":"قَبْلِهِمْ ۚ","translation":"পূর্ব তাদের","audioUrl":"wbw/010_102_009.mp3","charTypeName":"word"},{"id":71776,"position":10,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/010_102_011.mp3","charTypeName":"word"},{"id":71777,"position":11,"arabic":"فَٱنتَظِرُوٓا۟","translation":"\"তবে তোমরা অপেক্ষা করো","audioUrl":"wbw/010_102_012.mp3","charTypeName":"word"},{"id":71778,"position":12,"arabic":"إِنِّى","translation":"নিশ্চয়ই আমি","audioUrl":"wbw/010_102_013.mp3","charTypeName":"word"},{"id":71779,"position":13,"arabic":"مَعَكُم","translation":"সাথে তোমাদের","audioUrl":"wbw/010_102_014.mp3","charTypeName":"word"},{"id":71780,"position":14,"arabic":"مِّنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/010_102_015.mp3","charTypeName":"word"},{"id":71781,"position":15,"arabic":"ٱلْمُنتَظِرِينَ","translation":"অপেক্ষাকারীদের\"","audioUrl":"wbw/010_102_016.mp3","charTypeName":"word"},{"id":71782,"position":16,"arabic":"١٠٢","translation":"(১০২)","audioUrl":null,"charTypeName":"end"}]},{"number":103,"arabic":"ثُمَّ نُنَجِّى رُسُلَنَا وَٱلَّذِينَ ءَامَنُوا۟ ۚ كَذَٰلِكَ حَقًّا عَلَيْنَا نُنجِ ٱلْمُؤْمِنِينَ","translation":"[For thus it always happens: We seal the doom of all who deny the truth and give the lie to Our messages;] and thereupon We save Our apostles and those who have attained to faith. Thus have We willed it upon Ourselves: We save all who believe [in Us],","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1467.mp3","surahId":10,"words":[{"id":72224,"position":1,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/010_103_001.mp3","charTypeName":"word"},{"id":72225,"position":2,"arabic":"نُنَجِّى","translation":"উদ্বার করবো আমরা","audioUrl":"wbw/010_103_002.mp3","charTypeName":"word"},{"id":72226,"position":3,"arabic":"رُسُلَنَا","translation":"রাসূলদেরকে আমাদের","audioUrl":"wbw/010_103_003.mp3","charTypeName":"word"},{"id":72227,"position":4,"arabic":"وَٱلَّذِينَ","translation":"ও যারা","audioUrl":"wbw/010_103_004.mp3","charTypeName":"word"},{"id":72228,"position":5,"arabic":"ءَامَنُوا۟ ۚ","translation":"ঈমান এনেছিলো (তাদের সাথে)","audioUrl":"wbw/010_103_005.mp3","charTypeName":"word"},{"id":72230,"position":6,"arabic":"كَذَٰلِكَ","translation":"এভাবে","audioUrl":"wbw/010_103_007.mp3","charTypeName":"word"},{"id":72231,"position":7,"arabic":"حَقًّا","translation":"(এটা) দায়িত্ব","audioUrl":"wbw/010_103_008.mp3","charTypeName":"word"},{"id":72232,"position":8,"arabic":"عَلَيْنَا","translation":"উপর আমাদের","audioUrl":"wbw/010_103_009.mp3","charTypeName":"word"},{"id":72233,"position":9,"arabic":"نُنجِ","translation":"উদ্ধার করা","audioUrl":"wbw/010_103_010.mp3","charTypeName":"word"},{"id":72234,"position":10,"arabic":"ٱلْمُؤْمِنِينَ","translation":"মু'মিনদেরকে","audioUrl":"wbw/010_103_011.mp3","charTypeName":"word"},{"id":72235,"position":11,"arabic":"١٠٣","translation":"(১০৩)","audioUrl":null,"charTypeName":"end"}]},{"number":104,"arabic":"قُلْ يَٰٓأَيُّهَا ٱلنَّاسُ إِن كُنتُمْ فِى شَكٍّۢ مِّن دِينِى فَلَآ أَعْبُدُ ٱلَّذِينَ تَعْبُدُونَ مِن دُونِ ٱللَّهِ وَلَٰكِنْ أَعْبُدُ ٱللَّهَ ٱلَّذِى يَتَوَفَّىٰكُمْ ۖ وَأُمِرْتُ أَنْ أَكُونَ مِنَ ٱلْمُؤْمِنِينَ","translation":"SAY [O Prophet]: \"O mankind! If you are in doubt as to what my faith is, then [know that] I do not worship those beings whom you worship beside God, but [that] I worship God alone, who shall cause you [all] to die: for I have been bidden to be among those who believe [in Him alone].\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1468.mp3","surahId":10,"words":[{"id":72577,"position":1,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/010_104_001.mp3","charTypeName":"word"},{"id":72578,"position":2,"arabic":"يَـٰٓأَيُّهَا","translation":"\"হে","audioUrl":"wbw/010_104_002.mp3","charTypeName":"word"},{"id":72579,"position":3,"arabic":"ٱلنَّاسُ","translation":"\"মানুষ","audioUrl":"wbw/010_104_003.mp3","charTypeName":"word"},{"id":72580,"position":4,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/010_104_004.mp3","charTypeName":"word"},{"id":72581,"position":5,"arabic":"كُنتُمْ","translation":"তোমরা হয়ে থাকো","audioUrl":"wbw/010_104_005.mp3","charTypeName":"word"},{"id":72582,"position":6,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/010_104_006.mp3","charTypeName":"word"},{"id":72583,"position":7,"arabic":"شَكٍّۢ","translation":"সন্দেহের","audioUrl":"wbw/010_104_007.mp3","charTypeName":"word"},{"id":72584,"position":8,"arabic":"مِّن","translation":"সম্পর্কে","audioUrl":"wbw/010_104_008.mp3","charTypeName":"word"},{"id":72585,"position":9,"arabic":"دِينِى","translation":"আমার দীন","audioUrl":"wbw/010_104_009.mp3","charTypeName":"word"},{"id":72586,"position":10,"arabic":"فَلَآ","translation":"তবে (জেনে রাখো) না","audioUrl":"wbw/010_104_010.mp3","charTypeName":"word"},{"id":72587,"position":11,"arabic":"أَعْبُدُ","translation":"আমি ইবাদত করি","audioUrl":"wbw/010_104_011.mp3","charTypeName":"word"},{"id":72588,"position":12,"arabic":"ٱلَّذِينَ","translation":"(তাদেরকে) যাদের","audioUrl":"wbw/010_104_012.mp3","charTypeName":"word"},{"id":72589,"position":13,"arabic":"تَعْبُدُونَ","translation":"তোমরা উপাসনা করো","audioUrl":"wbw/010_104_013.mp3","charTypeName":"word"},{"id":72590,"position":14,"arabic":"مِن","translation":"দিয়ে","audioUrl":"wbw/010_104_014.mp3","charTypeName":"word"},{"id":72591,"position":15,"arabic":"دُونِ","translation":"বাদ","audioUrl":"wbw/010_104_015.mp3","charTypeName":"word"},{"id":72592,"position":16,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/010_104_016.mp3","charTypeName":"word"},{"id":72593,"position":17,"arabic":"وَلَـٰكِنْ","translation":"বরং","audioUrl":"wbw/010_104_017.mp3","charTypeName":"word"},{"id":72594,"position":18,"arabic":"أَعْبُدُ","translation":"আমি ইব