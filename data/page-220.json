},{"id":72756,"position":4,"arabic":"لِلدِّينِ","translation":"জন্যে দীনের","audioUrl":"wbw/010_105_004.mp3","charTypeName":"word"},{"id":72757,"position":5,"arabic":"حَنِيفًۭا","translation":"একনিষ্ঠভাবে","audioUrl":"wbw/010_105_005.mp3","charTypeName":"word"},{"id":72758,"position":6,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/010_105_006.mp3","charTypeName":"word"},{"id":72759,"position":7,"arabic":"تَكُونَنَّ","translation":"তোমরা হয়ো","audioUrl":"wbw/010_105_007.mp3","charTypeName":"word"},{"id":72760,"position":8,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/010_105_008.mp3","charTypeName":"word"},{"id":72761,"position":9,"arabic":"ٱلْمُشْرِكِينَ","translation":"মুশরিকদের","audioUrl":"wbw/010_105_009.mp3","charTypeName":"word"},{"id":72762,"position":10,"arabic":"١٠٥","translation":"(১০৫)","audioUrl":null,"charTypeName":"end"}]},{"number":106,"arabic":"وَلَا تَدْعُ مِن دُونِ ٱللَّهِ مَا لَا يَنفَعُكَ وَلَا يَضُرُّكَ ۖ فَإِن فَعَلْتَ فَإِنَّكَ إِذًۭا مِّنَ ٱلظَّٰلِمِينَ","translation":"Thus, do not invoke, side by side with God, anything that can neither benefit thee nor harm thee: for, behold, if thou do it, thou wilt surely be among the evildoers!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1470.mp3","surahId":10,"words":[{"id":72970,"position":1,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/010_106_001.mp3","charTypeName":"word"},{"id":72971,"position":2,"arabic":"تَدْعُ","translation":"তুমি ডেকো (অন্য কাউকে)","audioUrl":"wbw/010_106_002.mp3","charTypeName":"word"},{"id":72972,"position":3,"arabic":"مِن","translation":"দিয়ে","audioUrl":"wbw/010_106_003.mp3","charTypeName":"word"},{"id":72973,"position":4,"arabic":"دُونِ","translation":"বাদ","audioUrl":"wbw/010_106_004.mp3","charTypeName":"word"},{"id":72974,"position":5,"arabic":"ٱللَّهِ","translation":"আল্লাহ","audioUrl":"wbw/010_106_005.mp3","charTypeName":"word"},{"id":72975,"position":6,"arabic":"مَا","translation":"যা","audioUrl":"wbw/010_106_006.mp3","charTypeName":"word"},{"id":72976,"position":7,"arabic":"لَا","translation":"না","audioUrl":"wbw/010_106_007.mp3","charTypeName":"word"},{"id":72977,"position":8,"arabic":"يَنفَعُكَ","translation":"তোমার উপকার করতে পারে","audioUrl":"wbw/010_106_008.mp3","charTypeName":"word"},{"id":72978,"position":9,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/010_106_009.mp3","charTypeName":"word"},{"id":72979,"position":10,"arabic":"يَضُرُّكَ ۖ","translation":"তোমার অপকার করতে পারে","audioUrl":"wbw/010_106_010.mp3","charTypeName":"word"},{"id":72981,"position":11,"arabic":"فَإِن","translation":"অতঃপর যদি","audioUrl":"wbw/010_106_012.mp3","charTypeName":"word"},{"id":72982,"position":12,"arabic":"فَعَلْتَ","translation":"তুমি করো (তা)","audioUrl":"wbw/010_106_013.mp3","charTypeName":"word"},{"id":72983,"position":13,"arabic":"فَإِنَّكَ","translation":"তবে নিশ্চয়ই তুমি","audioUrl":"wbw/010_106_014.mp3","charTypeName":"word"},{"id":72984,"position":14,"arabic":"إِذًۭا","translation":"তখন","audioUrl":"wbw/010_106_015.mp3","charTypeName":"word"},{"id":72985,"position":15,"arabic":"مِّنَ","translation":"অন্তর্ভুক্ত হবে","audioUrl":"wbw/010_106_016.mp3","charTypeName":"word"},{"id":72986,"position":16,"arabic":"ٱلظَّـٰلِمِينَ","translation":"সীমালঙ্ঘনকারীদের\"","audioUrl":"wbw/010_106_017.mp3","charTypeName":"word"},{"id":72987,"position":17,"arabic":"١٠٦","translation":"(১০৬)","audioUrl":null,"charTypeName":"end"}]}]}