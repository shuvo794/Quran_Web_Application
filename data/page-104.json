eName":"word"},{"id":82095,"position":26,"arabic":"١٦٣","translation":"(১৬৩)","audioUrl":null,"charTypeName":"end"}]},{"number":164,"arabic":"وَرُسُلًۭا قَدْ قَصَصْنَٰهُمْ عَلَيْكَ مِن قَبْلُ وَرُسُلًۭا لَّمْ نَقْصُصْهُمْ عَلَيْكَ ۚ وَكَلَّمَ ٱللَّهُ مُوسَىٰ تَكْلِيمًۭا","translation":"and as [We inspired other] apostles whom We have mentioned to thee ere this, as well as apostles whom We have not mentioned to thee; and as God spoke His word unto Moses:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/657.mp3","surahId":4,"words":[{"id":82200,"position":1,"arabic":"وَرُسُلًۭا","translation":"এবং (এসব) রাসূলদেরকে","audioUrl":"wbw/004_164_001.mp3","charTypeName":"word"},{"id":82201,"position":2,"arabic":"قَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/004_164_002.mp3","charTypeName":"word"},{"id":82202,"position":3,"arabic":"قَصَصْنَـٰهُمْ","translation":"তাদের আমরা বর্ণনা করেছি","audioUrl":"wbw/004_164_003.mp3","charTypeName":"word"},{"id":82203,"position":4,"arabic":"عَلَيْكَ","translation":"তোমার নিকট","audioUrl":"wbw/004_164_004.mp3","charTypeName":"word"},{"id":82204,"position":5,"arabic":"مِن","translation":"(থেকে)","audioUrl":"wbw/004_164_005.mp3","charTypeName":"word"},{"id":82205,"position":6,"arabic":"قَبْلُ","translation":"ইতিপূর্বে","audioUrl":"wbw/004_164_006.mp3","charTypeName":"word"},{"id":82206,"position":7,"arabic":"وَرُسُلًۭا","translation":"এবং (এমন সব) রাসূলও (ছিলেন)","audioUrl":"wbw/004_164_007.mp3","charTypeName":"word"},{"id":82207,"position":8,"arabic":"لَّمْ","translation":"না","audioUrl":"wbw/004_164_008.mp3","charTypeName":"word"},{"id":82208,"position":9,"arabic":"نَقْصُصْهُمْ","translation":"তাদের আমরা বর্ণনা করেছি","audioUrl":"wbw/004_164_009.mp3","charTypeName":"word"},{"id":82209,"position":10,"arabic":"عَلَيْكَ ۚ","translation":"তোমার কাছে","audioUrl":"wbw/004_164_010.mp3","charTypeName":"word"},{"id":82211,"position":11,"arabic":"وَكَلَّمَ","translation":"এবং কথা বলেছেন","audioUrl":"wbw/004_164_012.mp3","charTypeName":"word"},{"id":82212,"position":12,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/004_164_013.mp3","charTypeName":"word"},{"id":82213,"position":13,"arabic":"مُوسَىٰ","translation":"মূসার (সাথে)","audioUrl":"wbw/004_164_014.mp3","charTypeName":"word"},{"id":82214,"position":14,"arabic":"تَكْلِيمًۭا","translation":"(সরাসরি) কথাবার্তা","audioUrl":"wbw/004_164_015.mp3","charTypeName":"word"},{"id":82215,"position":15,"arabic":"١٦٤","translation":"(১৬৪)","audioUrl":null,"charTypeName":"end"}]},{"number":165,"arabic":"رُّسُلًۭا مُّبَشِّرِينَ وَمُنذِرِينَ لِئَلَّا يَكُونَ لِلنَّاسِ عَلَى ٱللَّهِ حُجَّةٌۢ بَعْدَ ٱلرُّسُلِ ۚ وَكَانَ ٱللَّهُ عَزِيزًا حَكِيمًۭا","translation":"[We sent all these] apostles as heralds of glad tidings and as warners, so that men might have no excuse before God after [the coming of] these apostles: and God is indeed al­mighty, wise.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/658.mp3","surahId":4,"words":[{"id":82333,"position":1,"arabic":"رُّسُلًۭا","translation":"(এসব) রাসূল","audioUrl":"wbw/004_165_001.mp3","charTypeName":"word"},{"id":82334,"position":2,"arabic":"مُّبَشِّرِينَ","translation":"সুসংবাদদাতা","audioUrl":"wbw/004_165_002.mp3","charTypeName":"word"},{"id":82335,"position":3,"arabic":"وَمُنذِرِينَ","translation":"ও সতর্ককারী (ছিলেন)","audioUrl":"wbw/004_165_003.mp3","charTypeName":"word"},{"id":82336,"position":4,"arabic":"لِئَلَّا","translation":"না যেন","audioUrl":"wbw/004_165_004.mp3","charTypeName":"word"},{"id":82337,"position":5,"arabic":"يَكُونَ","translation":"থাকে","audioUrl":"wbw/004_165_005.mp3","charTypeName":"word"},{"id":82338,"position":6,"arabic":"لِلنَّاسِ","translation":"লোকদের জন্য","audioUrl":"wbw/004_165_006.mp3","charTypeName":"word"},{"id":82339,"position":7,"arabic":"عَلَى","translation":"বিরুদ্ধে","audioUrl":"wbw/004_165_007.mp3","charTypeName":"word"},{"id":82340,"position":8,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/004_165_008.mp3","charTypeName":"word"},{"id