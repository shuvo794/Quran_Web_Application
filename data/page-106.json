{"id":106,"ayahs":[{"number":176,"arabic":"يَسْتَفْتُونَكَ قُلِ ٱللَّهُ يُفْتِيكُمْ فِى ٱلْكَلَٰلَةِ ۚ إِنِ ٱمْرُؤٌا۟ هَلَكَ لَيْسَ لَهُۥ وَلَدٌۭ وَلَهُۥٓ أُخْتٌۭ فَلَهَا نِصْفُ مَا تَرَكَ ۚ وَهُوَ يَرِثُهَآ إِن لَّمْ يَكُن لَّهَا وَلَدٌۭ ۚ فَإِن كَانَتَا ٱثْنَتَيْنِ فَلَهُمَا ٱلثُّلُثَانِ مِمَّا تَرَكَ ۚ وَإِن كَانُوٓا۟ إِخْوَةًۭ رِّجَالًۭا وَنِسَآءًۭ فَلِلذَّكَرِ مِثْلُ حَظِّ ٱلْأُنثَيَيْنِ ۗ يُبَيِّنُ ٱللَّهُ لَكُمْ أَن تَضِلُّوا۟ ۗ وَٱللَّهُ بِكُلِّ شَىْءٍ عَلِيمٌۢ","translation":"THEY WILL ASK thee to enlighten them. Say: \"God enlightens you [thus] about the laws concerning [inheritance from] those who leave no heir in the direct line: If a man dies childless and has a sister, she shall inherit one-half of what he has left, just as he shall inherit from her if she dies childless. But if there are two sisters, both [together] shall have two-thirds of what he has left; and if there are brothers and sisters, then the male shall have the equal of two females' share.\" God makes [all this] clear unto you, lest you go astray; and God knows everything.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/669.mp3","surahId":4,"words":[{"id":83385,"position":1,"arabic":"يَسْتَفْتُونَكَ","translation":"তোমার কাছে সমাধান চায় তারা","audioUrl":"wbw/004_176_001.mp3","charTypeName":"word"},{"id":83386,"position":2,"arabic":"قُلِ","translation":"বল","audioUrl":"wbw/004_176_002.mp3","charTypeName":"word"},{"id":83387,"position":3,"arabic":"ٱللَّهُ","translation":"''আল্লাহ","audioUrl":"wbw/004_176_003.mp3","charTypeName":"word"},{"id":83388,"position":4,"arabic":"يُفْتِيكُمْ","translation":"তোমাদেরকে সমাধান দিচ্ছেন","audioUrl":"wbw/004_176_004.mp3","charTypeName":"word"},{"id":83389,"position":5,"arabic":"فِى","translation":"ব্যাপারে","audioUrl":"wbw/004_176_005.mp3","charTypeName":"word"},{"id":83390,"position":6,"arabic":"ٱلْكَلَـٰلَةِ ۚ","translation":"মাতা-পিতাহীনও নিঃসন্তান ব্যক্তির","audioUrl":"wbw/004_176_006.mp3","charTypeName":"word"},{"id":83392,"position":7,"arabic":"إِنِ","translation":"যদি","audioUrl":"wbw/004_176_008.mp3","charTypeName":"word"},{"id":83393,"position":8,"arabic":"ٱمْرُؤٌا۟","translation":"কোন পুরুষ (এ ধরনের)","audioUrl":"wbw/004_176_009.mp3","charTypeName":"word"},{"id":83394,"position":9,"arabic":"هَلَكَ","translation":"মারা যায়","audioUrl":"wbw/004_176_010.mp3","charTypeName":"word"},{"id":83395,"position":10,"arabic":"لَيْسَ","translation":"না (থাকে)","audioUrl":"wbw/004_176_011.mp3","charTypeName":"word"},{"id":83396,"position":11,"arabic":"لَهُۥ","translation":"তার","audioUrl":"wbw/004_176_012.mp3","charTypeName":"word"},{"id":83397,"position":12,"arabic":"وَلَدٌۭ","translation":"কোন সন্তান","audioUrl":"wbw/004_176_013.mp3","charTypeName":"word"},{"id":83398,"position":13,"arabic":"وَلَهُۥٓ","translation":"ও তার থাকে","audioUrl":"wbw/004_176_014.mp3","charTypeName":"word"},{"id":83399,"position":14,"arabic":"أُخْتٌۭ","translation":"এক বোন (বৈমাত্রেয় বা সহোদর)","audioUrl":"wbw/004_176_015.mp3","charTypeName":"word"},{"id":83400,"position":15,"arabic":"فَلَهَا","translation":"তার জন্য তবে (অর্থাৎ সেই বোন)","audioUrl":"wbw/004_176_016.mp3","charTypeName":"word"},{"id":83401,"position":16,"arabic":"نِصْفُ","translation":"(পাবে) অর্ধেক","audioUrl":"wbw/004_176_017.mp3","charTypeName":"word"},{"id":83402,"position":17,"arabic":"مَا","translation":"যা আছে","audioUrl":"wbw/004_176_018.mp3","charTypeName":"word"},{"id":83403,"position":18,"arabic":"تَرَكَ ۚ","translation":"পরিত্যক্ত সম্পত্তি","audioUrl":"wbw/004_176_019.mp3","charTypeName":"word"},{"id":83405,"position":19,"arabic":"وَهُوَ","translation":"এবং সে (অর্থাৎ ভাই)","audioUrl":"wbw/004_176_021.mp3","charTypeName":"word"},{"id":83406,"position":20,"arabic":"يَرِثُهَآ","translation":"তার (অর্থাৎ মৃত বোনের) উত্তরাধিকারী হবে","audioUrl":"wbw/004_176_022.mp3","charTypeName":"word"},{"id":83407,"position":21,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/004_176_023.mp3","charTypeName":"word"},{"id":83408,"position":22,"arabic":"لَّمْ","translation":"না","audioUrl":"wbw/004_176_024.mp3","charTypeName":"word"},{"id":83409,"position":23,"arabic":"يَكُن","translation":"থাকে","audioUrl":"wbw/004_176_025.mp3","charTypeName":"word"},{"id":83410,"position":24,"arabic":"لَّهَا","translation":"তার (অর্থাৎ বোনের)","audioUrl":"wbw/004_176_026.mp3","charTypeName":"word"},{"id":83411,"position":25,"arabic":"وَلَدٌۭ ۚ","translation":"কোন সন্তান","audioUrl":"wbw/004_176_027.mp3","charTypeName":"word"},{"id":83413,"position":26,"arabic":"فَإِن","translation":"যদি তবে","audioUrl":"wbw/004_176_029.mp3","charTypeName":"word"},{"id":83414,"position":27,"arabic":"كَانَتَا","translation":"তারা হয়","audioUrl":"wbw/004_176_030.mp3","charTypeName":"word"},{"id":83415,"position":28,"arabic":"ٱثْنَتَيْنِ","translation":"দুই (বোন মৃতের উত্তরাধিকারী)","audioUrl":"wbw/004_176_031.mp3","charTypeName":"word"},{"id":83416,"position":29,"arabic":"فَلَهُمَا","translation":"তবে জন্য তাদের দুজনের","audioUrl":"wbw/004_176_032.mp3","charTypeName":"word"},{"id":83417,"position":30,"arabic":"ٱلثُّلُثَانِ","translation":"দুই তৃতীয়াংশ","audioUrl":"wbw/004_176_033.mp3","charTypeName":"word"},{"id":83418,"position":31,"arabic":"مِمَّا","translation":"তা হতে যা","audioUrl":"wbw/004_176_034.mp3","charTypeName":"word"},{"id":83419,"position":32,"arabic":"تَرَكَ ۚ","translation":"পরিত্যক্ত সম্পত্তি","audioUrl":"wbw/004_176_035.mp3","charTypeName":"word"},{"id":83421,"position":33,"arabic":"وَإِن","translation":"এবং যদি","audioUrl":"wbw/004_176_037.mp3","charTypeName":"word"},{"id":83422,"position":34,"arabic":"كَانُوٓا۟","translation":"তারা হয়","audioUrl":"wbw/004_176_038.mp3","charTypeName":"word"},{"id":83423,"position":35,"arabic":"إِخْوَةًۭ","translation":"ভাই-বোন","audioUrl":"wbw/004_176_039.mp3","charTypeName":"word"},{"id":83424,"position":36,"arabic":"رِّجَالًۭا","translation":"পুরুষ (কয়েকজন)","audioUrl":"wbw/004_176_040.mp3","charTypeName":"word"},{"id":83425,"position":37,"arabic":"وَنِسَآءًۭ","translation":"ও নারী (কয়েকজন)","audioUrl":"wbw/004_176_041.mp3","charTypeName":"word"},{"id":83426,"position":38,"arabic":"فَلِلذَّكَرِ","translation":"জন্য তবে একজন পুরুষের","audioUrl":"wbw/004_176_042.mp3","charTypeName":"word"},{"id":83427,"position":39,"arabic":"مِثْلُ","translation":"সমান","audioUrl":"wbw/004_176_043.mp3","charTypeName":"word"},{"id":83428,"position":40,"arabic":"حَظِّ","translation":"অংশ","audioUrl":"wbw/004_176_044.mp3","charTypeName":"word"},{"id":83429,"position":41,"arabic":"ٱلْأُنثَيَيْنِ ۗ","translation":"দুই নারীর","audioUrl":"wbw/004_176_045.mp3","charTypeName":"word"},{"id":83431,"position":42,"arabic":"يُبَيِّنُ","translation":"বর্ণনা করেন","audioUrl":"wbw/004_176_047.mp3","charTypeName":"word"},{"id":83432,"position":43,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/004_176_048.mp3","charTypeName":"word"},{"id":83433,"position":44,"arabic":"لَكُمْ","translation":"তোমাদের জন্য","audioUrl":"wbw/004_176_049.mp3","charTypeName":"word"},{"id":83434,"position":45,"arabic":"أَن","translation":"যেন","audioUrl":"wbw/004_176_050.mp3","charTypeName":"word"},{"id":83435,"position":46,"arabic":"تَضِلُّوا۟ ۗ","translation":"তোমরা বিভ্রান্ত (না) হও","audioUrl":"wbw/004_176_051.mp3","charTypeName":"word"},{"id":83437,"position":47,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/004_176_053.mp3","charTypeName":"word"},{"id":83438,"position":48,"arabic":"بِكُلِّ","translation":"সম্পর্কে সব","audioUrl":"wbw/004_176_054.mp3","charTypeName":"word"},{"id":83439,"position":49,"arabic":"شَىْءٍ","translation":"কিছুর","audioUrl":"wbw/004_176_055.mp3","charTypeName":"word"},{"id":83440,"position":50,"arabic":"عَلِيمٌۢ","translation":"খুব অবহিত","audioUrl":"wbw/004_176_056.mp3","charTypeName":"word"},{"id":83441,"position":51,"arabic":"١٧٦","translation":"(১৭৬)","audioUrl":null,"charTypeName":"end"}]},{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوٓا۟ أَوْفُوا۟ بِٱلْعُقُودِ ۚ أُحِلَّتْ لَكُم بَهِيمَةُ ٱلْأَنْعَٰمِ إِلَّا مَا يُتْلَىٰ عَلَيْكُمْ غَيْرَ مُحِلِّى ٱلصَّيْدِ وَأَنتُمْ حُرُمٌ ۗ إِنَّ ٱللَّهَ يَحْكُمُ مَا يُرِيدُ","translation":"O YOU who have attained to faith! Be true to your covenants! Lawful to you is the [flesh of every] beast that feeds on plants, save what is mentioned to you [hereinafter]: but you are not allowed to hunt while you are in the state of pilgrimage. Behold, God ordains in accordance with His will.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/670.mp3","surahId":5,"words":[{"id":314,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/005_001_001.mp3","charTypeName":"word"},{"id":315,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/005_001_002.mp3","charTypeName":"word"},{"id":316,"position":3,"arabic":"ءَامَنُوٓا۟","translation":"ঈমান এনেছো","audioUrl":"wbw/005_001_003.mp3","charTypeName":"word"},{"id":317,"position":4,"arabic":"أَوْفُوا۟","translation":"তোমরা পূর্ণ করো","audioUrl":"wbw/005_001_004.mp3","charTypeName":"word"},{"id":318,"position":5,"arabic":"بِٱلْعُقُودِ ۚ","translation":"অঙ্গীকারসমূহকে","audioUrl":"wbw/005_001_005.mp3","charTypeName":"word"},{"id":320,"position":6,"arabic":"أُحِلَّتْ","translation":"বৈধ করা হয়েছে","audioUrl":"wbw/005_001_007.mp3","charTypeName":"word"},{"id":321,"position":7,"arabic":"لَكُم","translation":"জন্যে তোমাদের","audioUrl":"wbw/005_001_008.mp3","charTypeName":"word"},{"id":322,"position":8,"arabic":"بَهِيمَةُ","translation":"চতুষ্পদ","audioUrl":"wbw/005_001_009.mp3","charTypeName":"word"},{"id":323,"position":9,"arabic":"ٱلْأَنْعَـٰمِ","translation":"গবাদিপশু","audioUrl":"wbw/005_001_010.mp3","charTypeName":"word"},{"id":324,"position":10,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/005_001_011.mp3","charTypeName":"word"},{"id":325,"position":11,"arabic":"مَا","translation":"যা","audioUrl":"wbw/005_001_012.mp3","charTypeName":"word"},{"id":326,"position":12,"arabic":"يُتْلَىٰ","translation":"বর্ণিত হচ্ছে","audioUrl":"wbw/005_001_013.mp3","charTypeName":"word"},{"id":327,"position":13,"arabic":"عَلَيْكُمْ","translation":"নিকট তোমাদের","audioUrl":"wbw/005_001_014.mp3","charTypeName":"word"},{"id":328,"position":14,"arabic":"غَيْرَ","translation":"নয়","audioUrl":"wbw/005_001_015.mp3","charTypeName":"word"},{"id":329,"position":15,"arabic":"مُحِلِّى","translation":"হালালকারী","audioUrl":"wbw/005_001_016.mp3","charTypeName":"word"},{"id":330,"position":16,"arabic":"ٱلصَّيْدِ","translation":"শিকার","audioUrl":"wbw/005_001_017.mp3","charTypeName":"word"},{"id":331,"position":17,"arabic":"وَأَنتُمْ","translation":"এমতাবস্হায় যে তোমরা (থাকো)","audioUrl":"wbw/005_001_018.mp3","charTypeName":"word"},{"id":332,"position":18,"arabic":"حُرُمٌ ۗ","translation":"ইহরাম অবস্থায়","audioUrl":"wbw/005_001_019.mp3","charTypeName":"word"},{"id":334,"position":19,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/005_001_021.mp3","charTypeName":"word"},{"id":335,"position":20,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/005_001_022.mp3","charTypeName":"word"},{"id":336,"position":21,"arabic":"يَحْكُمُ","translation":"আদেশ করেন","audioUrl":"wbw/005_001_023.mp3","charTypeName":"word"},{"id":337,"position":22,"arabic":"مَا","translation":"যা","audioUrl":"wbw/005_001_024.mp3","charTypeName":"word"},{"id":338,"position":23,"arabic":"يُرِيدُ","translation":"তিনি চান","audioUrl":"wbw/005_001_025.mp3","charTypeName":"word"},{"id":339,"position":24,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ لَا تُحِلُّوا۟ شَعَٰٓئِرَ ٱللَّهِ وَلَا ٱلشَّهْرَ ٱلْحَرَامَ وَلَا ٱلْهَدْىَ وَلَا ٱلْقَلَٰٓئِدَ وَلَآ ءَآمِّينَ ٱلْبَيْتَ ٱلْحَرَامَ يَبْتَغُونَ فَضْلًۭا مِّن رَّبِّهِمْ وَرِضْوَٰنًۭا ۚ وَإِذَا حَلَلْتُمْ فَٱصْطَادُوا۟ ۚ وَلَا يَجْرِمَنَّكُمْ شَنَـَٔانُ قَوْمٍ أَن صَدُّوكُمْ عَنِ ٱلْمَسْجِدِ ٱلْحَرَامِ أَن تَعْتَدُوا۟ ۘ وَتَعَاوَنُوا۟ عَلَى ٱلْبِرِّ وَٱلتَّقْوَىٰ ۖ وَلَا تَعَاوَنُوا۟ عَلَى ٱلْإِثْمِ وَٱلْعُدْوَٰنِ ۚ وَٱتَّقُوا۟ ٱللَّهَ ۖ إِنَّ ٱللَّهَ شَدِيدُ ٱلْعِقَابِ","translation":"O you who have attained to faith! Offend not against the symbols set up by God, nor against the sacred month [of pilgrimage], nor against the garlanded offerings, nor against those who flock to the Inviolable Temple, seeking favour with their Sustainer and His goodly acceptance; and [only] after your pilgrimage is over are you free to hunt. And never let your hatred of people who would bar you from the Inviolable House of Worship lead you into the sin of aggression: but rather help one another in furthering virtue and God-consciousness, and do not help one another in furthering evil and enmity; and remain conscious of God: for, behold, God is severe in retribution!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/671.mp3","surahId":5,"words":[{"id":1487,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/005_002_001.mp3","charTypeName":"word"},{"id":1488,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/005_002_002.mp3","charTypeName":"word"},{"id":1489,"position":3,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছো","audioUrl":"wbw/005_002_003.mp3","charTypeName":"word"},{"id":1490,"position":4,"arabic":"لَا","translation":"না","audioUrl":"wbw/005_002_004.mp3","charTypeName":"word"},{"id":1491,"position":5,"arabic":"تُحِلُّوا۟","translation":"তোমরা বৈধ মনে করো","audioUrl":"wbw/005_002_005.mp3","charTypeName":"word"},{"id":1492,"position":6,"arabic":"شَعَـٰٓئِرَ","translation":"নিদর্শনসমূহকে","audioUrl":"wbw/005_002_006.mp3","charTypeName":"word"},{"id":1493,"position":7,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/005_002_007.mp3","charTypeName":"word"},{"id":1494,"position":8,"arabic":"وَلَا","translation":"এবং না (বৈধ করো)","audioUrl":"wbw/005_002_008.mp3","charTypeName":"word"},{"id":1495,"position":9,"arabic":"ٱلشَّهْرَ","translation":"মাসকে","audioUrl":"wbw/005_002_009.mp3","charTypeName":"word"},{"id":1496,"position":10,"arabic":"ٱلْحَرَامَ","transla