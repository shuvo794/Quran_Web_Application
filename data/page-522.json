e":"word"},{"id":37884,"position":5,"arabic":"بَيْتٍۢ","translation":"একটি ঘর","audioUrl":"wbw/051_036_005.mp3","charTypeName":"word"},{"id":37885,"position":6,"arabic":"مِّنَ","translation":"থেকে","audioUrl":"wbw/051_036_006.mp3","charTypeName":"word"},{"id":37886,"position":7,"arabic":"ٱلْمُسْلِمِينَ","translation":"মুসলমানদের","audioUrl":"wbw/051_036_007.mp3","charTypeName":"word"},{"id":37887,"position":8,"arabic":"٣٦","translation":"(৩৬)","audioUrl":null,"charTypeName":"end"}]},{"number":37,"arabic":"وَتَرَكْنَا فِيهَآ ءَايَةًۭ لِّلَّذِينَ يَخَافُونَ ٱلْعَذَابَ ٱلْأَلِيمَ","translation":"And so We left therein a message for those who fear the grievous suffering [which awaits all evildoers].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4712.mp3","surahId":51,"words":[{"id":38741,"position":1,"arabic":"وَتَرَكْنَا","translation":"এবং আমরা রেখেছি","audioUrl":"wbw/051_037_001.mp3","charTypeName":"word"},{"id":38742,"position":2,"arabic":"فِيهَآ","translation":"সেখানে","audioUrl":"wbw/051_037_002.mp3","charTypeName":"word"},{"id":38743,"position":3,"arabic":"ءَايَةًۭ","translation":"একটি নিদর্শন","audioUrl":"wbw/051_037_003.mp3","charTypeName":"word"},{"id":38744,"position":4,"arabic":"لِّلَّذِينَ","translation":"(তাদের) জন্যে যারা","audioUrl":"wbw/051_037_004.mp3","charTypeName":"word"},{"id":38745,"position":5,"arabic":"يَخَافُونَ","translation":"ভয় করে","audioUrl":"wbw/051_037_005.mp3","charTypeName":"word"},{"id":38746,"position":6,"arabic":"ٱلْعَذَابَ","translation":"শাস্তির","audioUrl":"wbw/051_037_006.mp3","charTypeName":"word"},{"id":38747,"position":7,"arabic":"ٱلْأَلِيمَ","translation":"যন্ত্রণাদায়ক","audioUrl":"wbw/051_037_007.mp3","charTypeName":"word"},{"id":38748,"position":8,"arabic":"٣٧","translation":"(৩৭)","audioUrl":null,"charTypeName":"end"}]},{"number":38,"arabic":"وَفِى مُوسَىٰٓ إِذْ أَرْسَلْنَٰهُ إِلَىٰ فِرْعَوْنَ بِسُلْطَٰنٍۢ مُّبِينٍۢ","translation":"AND IN [the story of Pharaoh and] Moses, too, [We left the same messa