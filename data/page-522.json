word"},{"id":40467,"position":4,"arabic":"سَـٰحِرٌ","translation":"\"(সে একজন) জাদুকর","audioUrl":"wbw/051_039_004.mp3","charTypeName":"word"},{"id":40468,"position":5,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/051_039_005.mp3","charTypeName":"word"},{"id":40469,"position":6,"arabic":"مَجْنُونٌۭ","translation":"পাগল (জ্বিন আশ্রিত)\"","audioUrl":"wbw/051_039_006.mp3","charTypeName":"word"},{"id":40470,"position":7,"arabic":"٣٩","translation":"(৩৯)","audioUrl":null,"charTypeName":"end"}]},{"number":40,"arabic":"فَأَخَذْنَٰهُ وَجُنُودَهُۥ فَنَبَذْنَٰهُمْ فِى ٱلْيَمِّ وَهُوَ مُلِيمٌۭ","translation":"We seized him and his hosts, and cast them all into the sea: and [none but Pharaoh] himself was to blame [for what happened].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4715.mp3","surahId":51,"words":[{"id":41163,"position":1,"arabic":"فَأَخَذْنَـٰهُ","translation":"অবশেষে তাকে আমরা পাকড়াও করলাম","audioUrl":"wbw/051_040_001.mp3","charTypeName":"word"},{"id":41164,"position":2,"arabic":"وَجُنُودَهُۥ","translation":"ও তার সৈন্যদেরকে","audioUrl":"wbw/051_040_002.mp3","charTypeName":"word"},{"id":41165,"position":3,"arabic":"فَنَبَذْنَـٰهُمْ","translation":"এরপর তাদের আমরা নিক্ষেপ করেছিলাম","audioUrl":"wbw/051_040_003.mp3","charTypeName":"word"},{"id":41166,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/051_040_004.mp3","charTypeName":"word"},{"id":41167,"position":5,"arabic":"ٱلْيَمِّ","translation":"সমুদ্রের","audioUrl":"wbw/051_040_005.mp3","charTypeName":"word"},{"id":41168,"position":6,"arabic":"وَهُوَ","translation":"এবং সে (হয়েছিল)","audioUrl":"wbw/051_040_006.mp3","charTypeName":"word"},{"id":41169,"position":7,"arabic":"مُلِيمٌۭ","translation":"নিন্দিত","audioUrl":"wbw/051_040_007.mp3","charTypeName":"word"},{"id":41170,"position":8,"arabic":"٤٠","translation":"(৪০)","audioUrl":null,"charTypeName":"end"}]},{"number":41,"arabic":"وَفِى عَادٍ إِذْ أَرْسَلْنَا عَلَيْهِمُ ٱلرِّيحَ ٱلْعَقِيمَ","translation":"And [you have the same message] in [what happened to the tribe of] Ad, when We let loose against them that life-destroying wind","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4716.mp3","surahId":51,"words":[{"id":42063,"position":1,"arabic":"وَفِى","translation":"এবং (আছে) মধ্যে (নিদর্শন)","audioUrl":"wbw/051_041_001.mp3","charTypeName":"word"},{"id":42064,"position":2,"arabic":"عَادٍ","translation":"আ'দ জাতির (ঘটনায়)","audioUrl":"wbw/051_041_002.mp3","charTypeName":"word"},{"id":42065,"position":3,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/051_041_003.mp3","charTypeName":"word"},{"id":42066,"position":4,"arabic":"أَرْسَلْنَا","translation":"আমরা পাঠিয়ে ছিলাম","audioUrl":"wbw/051_041_004.mp3","charTypeName":"word"},{"id":42067,"position":5,"arabic":"عَلَيْهِمُ","translation":"তাদের বিরুদ্ধে","audioUrl":"wbw/051_041_005.mp3","charTypeName":"word"},{"id":42068,"position":6,"arabic":"ٱلرِّيحَ","translation":"বায়ুপ্রবাহ","audioUrl":"wbw/051_041_006.mp3","charTypeName":"word"},{"id":42069,"position":7,"arabic":"ٱلْعَقِيمَ","translation":"অকল্যাণকর/ বিধ্বংসী","audioUrl":"wbw/051_041_007.mp3","charTypeName":"word"},{"id":42070,"position":8,"arabic":"٤١","translation":"(৪১)","audioUrl":null,"charTypeName":"end"}]},{"number":42,"arabic":"مَا تَذَرُ مِن شَىْءٍ أَتَتْ عَلَيْهِ إِلَّا جَعَلَتْهُ كَٱلرَّمِيمِ","translation":"which spared nothing of what it came upon, but caused [all of] it to become like bones dead and decayed.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4717.mp3","surahId":51,"words":[{"id":42805,"position":1,"arabic":"مَا","translation":"না","audioUrl":"wbw/051_042_001.mp3","charTypeName":"word"},{"id":42806,"position":2,"arabic":"تَذَرُ","translation":"ছেড়েছিল","audioUrl":"wbw/051_042_002.mp3","charTypeName":"word"},{"id":42807,"position":3,"arabic":"مِن","translation":"কোনো","audioUrl":"wbw/051_042_003.mp3","charTypeName":"word"},{"id":42808,"position":4,"arabic":"شَىْءٍ","translation":"কিছুই","audioUrl":"wbw/051_042_004.mp3","charTypeName":"word"},{"id":42809,"position":5,"arabic":"أَتَتْ","translation":"বয়ে গিয়েছিল","audioUrl":"wbw/051_042_005.mp3","charTypeName":"word"},{"id":42810,"position":6,"arabic":"عَلَيْهِ","translation":"যার উপর (দিয়ে)","audioUrl":"wbw/051_042_006.mp3","charTypeName":"word"},{"id":42811,"position":7,"arabic":"إِلَّا","translation":"এছাড়া","audioUrl":"wbw/051_042_007.mp3","charTypeName":"word"},{"id":42812,"position":8,"arabic":"جَعَلَتْهُ","translation":"তাকে করেছিল","audioUrl":"wbw/051_042_008.mp3","charTypeName":"word"},{"id":42813,"position":9,"arabic":"كَٱلرَّمِيمِ","translation":"যেন চূর্ণবিচূর্ণ","audioUrl":"wbw/051_042_009.mp3","charTypeName":"word"},{"id":42814,"position":10,"arabic":"٤٢","translation":"(৪২)","audioUrl":null,"charTypeName":"end"}]},{"number":43,"arabic":"وَفِى ثَمُودَ إِذْ قِيلَ لَهُمْ تَمَتَّعُوا۟ حَتَّىٰ حِينٍۢ","translation":"And in [the story of the tribe of] Thamud, too, when they were told, “You shall enjoy your life for [but] a little while,”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4718.mp3","surahId":51,"words":[{"id":43593,"position":1,"arabic":"وَفِى","translation":"এবং (আছে) মধ্যে (নিদর্শন)","audioUrl":"wbw/051_043_001.mp3","charTypeName":"word"},{"id":43594,"position":2,"arabic":"ثَمُودَ","translation":"সামূদ জাতির (ঘটনায়)","audioUrl":"wbw/051_043_002.mp3","charTypeName":"word"},{"id":43595,"position":3,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/051_043_003.mp3","charTypeName":"word"},{"id":43596,"position":4,"arabic":"قِيلَ","translation":"বলা হয়েছিল","audioUrl":"wbw/051_043_004.mp3","charTypeName":"word"},{"id":43597,"position":5,"arabic":"لَهُمْ","translation":"তাদেরকে","audioUrl":"wbw/051_043_005.mp3","charTypeName":"word"},{"id":43598,"position":6,"arabic":"تَمَتَّعُوا۟","translation":"\"তোমরা উপভোগ করো","audioUrl":"wbw/051_043_006.mp3","charTypeName":"word"},{"id":43599,"position":7,"arabic":"حَتَّىٰ","translation":"পর্যন্ত","audioUrl":"wbw/051_043_007.mp3","charTypeName":"wo