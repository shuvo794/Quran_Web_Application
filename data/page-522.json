{"id":522,"ayahs":[{"number":31,"arabic":"۞ قَالَ فَمَا خَطْبُكُمْ أَيُّهَا ٱلْمُرْسَلُونَ","translation":"Said [Abraham]: “And what [else] may you have in view, O you [heavenly] messengers?”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4706.mp3","surahId":51,"words":[{"id":33563,"position":1,"arabic":"۞ قَالَ","translation":"সে বলল","audioUrl":"wbw/051_031_002.mp3","charTypeName":"word"},{"id":33564,"position":2,"arabic":"فَمَا","translation":"\"কি তাহলে","audioUrl":"wbw/051_031_003.mp3","charTypeName":"word"},{"id":33565,"position":3,"arabic":"خَطْبُكُمْ","translation":"তোমাদের উদ্দেশ্য","audioUrl":"wbw/051_031_004.mp3","charTypeName":"word"},{"id":33566,"position":4,"arabic":"أَيُّهَا","translation":"হে\"","audioUrl":"wbw/051_031_005.mp3","charTypeName":"word"},{"id":33567,"position":5,"arabic":"ٱلْمُرْسَلُونَ","translation":"প্রেরিত (ফেরেশতা) গণ\"","audioUrl":"wbw/051_031_006.mp3","charTypeName":"word"},{"id":33568,"position":6,"arabic":"٣١","translation":"(৩১)","audioUrl":null,"charTypeName":"end"}]},{"number":32,"arabic":"قَالُوٓا۟ إِنَّآ أُرْسِلْنَآ إِلَىٰ قَوْمٍۢ مُّجْرِمِينَ","translation":"They answered: “Behold, we have been sent unto a people lost in sin,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4707.mp3","surahId":51,"words":[{"id":34571,"position":1,"arabic":"قَالُوٓا۟","translation":"তারা বলল","audioUrl":"wbw/051_032_001.mp3","charTypeName":"word"},{"id":34572,"position":2,"arabic":"إِنَّآ","translation":"\"নিশ্চয়ই আমরা","audioUrl":"wbw/051_032_002.mp3","charTypeName":"word"},{"id":34573,"position":3,"arabic":"أُرْسِلْنَآ","translation":"আমরা প্রেরিত হয়েছি","audioUrl":"wbw/051_032_003.mp3","charTypeName":"word"},{"id":34574,"position":4,"arabic":"إِلَىٰ","translation":"প্রতি","audioUrl":"wbw/051_032_004.mp3","charTypeName":"word"},{"id":34575,"position":5,"arabic":"قَوْمٍۢ","translation":"জাতির","audioUrl":"wbw/051_032_005.mp3","charTypeName":"word"},{"id":34576,"position":6,"arabic":"مُّجْرِمِينَ","tr