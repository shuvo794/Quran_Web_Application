an/audio/128/ar.alafasy/4720.mp3","surahId":51,"words":[{"id":45105,"position":1,"arabic":"فَمَا","translation":"অতঃপর না","audioUrl":"wbw/051_045_001.mp3","charTypeName":"word"},{"id":45106,"position":2,"arabic":"ٱسْتَطَـٰعُوا۟","translation":"তারা পেরেছিল","audioUrl":"wbw/051_045_002.mp3","charTypeName":"word"},{"id":45107,"position":3,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/051_045_003.mp3","charTypeName":"word"},{"id":45108,"position":4,"arabic":"قِيَامٍۢ","translation":"উঠে দাঁড়াতে","audioUrl":"wbw/051_045_004.mp3","charTypeName":"word"},{"id":45109,"position":5,"arabic":"وَمَا","translation":"আর না","audioUrl":"wbw/051_045_005.mp3","charTypeName":"word"},{"id":45110,"position":6,"arabic":"كَانُوا۟","translation":"তারা ছিল","audioUrl":"wbw/051_045_006.mp3","charTypeName":"word"},{"id":45111,"position":7,"arabic":"مُنتَصِرِينَ","translation":"আত্মরক্ষা করতে সক্ষম","audioUrl":"wbw/051_045_007.mp3","charTypeName":"word"},{"id":45112,"position":8,"arabic":"٤٥","translation":"(৪৫)","audioUrl":null,"charTypeName":"end"}]},{"number":46,"arabic":"وَقَوْمَ نُوحٍۢ مِّن قَبْلُ ۖ إِنَّهُمْ كَانُوا۟ قَوْمًۭا فَٰسِقِينَ","translation":"And [thus, too, We destroyed] Noah’s people aforetime: for they were iniquitous folk.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4721.mp3","surahId":51,"words":[{"id":45839,"position":1,"arabic":"وَقَوْمَ","translation":"এবং জাতিকে","audioUrl":"wbw/051_046_001.mp3","charTypeName":"word"},{"id":45840,"position":2,"arabic":"نُوحٍۢ","translation":"নূহের","audioUrl":"wbw/051_046_002.mp3","charTypeName":"word"},{"id":45841,"position":3,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/051_046_003.mp3","charTypeName":"word"},{"id":45842,"position":4,"arabic":"قَبْلُ ۖ","translation":"ইতিপূর্বে (ধ্বংস করেছি)","audioUrl":"wbw/051_046_004.mp3","charTypeName":"word"},{"id":45844,"position":5,"arabic":"إِنَّهُمْ","translation":"তারা নিশ্চয়ই","audioUrl":"wbw/051_046_006.mp3","charTypeName":"word"},{"id":45845,"positi