{"id":323,"ayahs":[{"number":11,"arabic":"وَكَمْ قَصَمْنَا مِن قَرْيَةٍۢ كَانَتْ ظَالِمَةًۭ وَأَنشَأْنَا بَعْدَهَا قَوْمًا ءَاخَرِينَ","translation":"For, how many a community that persisted in evildoing have We dashed into fragments, and raised another people in its stead!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2494.mp3","surahId":21,"words":[{"id":12502,"position":1,"arabic":"وَكَمْ","translation":"এবং কত","audioUrl":"wbw/021_011_001.mp3","charTypeName":"word"},{"id":12503,"position":2,"arabic":"قَصَمْنَا","translation":"আমরা ধ্বংস করেছি","audioUrl":"wbw/021_011_002.mp3","charTypeName":"word"},{"id":12504,"position":3,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/021_011_003.mp3","charTypeName":"word"},{"id":12505,"position":4,"arabic":"قَرْيَةٍۢ","translation":"জনবসতি","audioUrl":"wbw/021_011_004.mp3","charTypeName":"word"},{"id":12506,"position":5,"arabic":"كَانَتْ","translation":"যা ছিল","audioUrl":"wbw/021_011_005.mp3","charTypeName":"word"},{"id":12507,"position":6,"arabic":"ظَالِمَةًۭ","translation":"সীমালঙ্ঘনকারী","audioUrl":"wbw/021_011_006.mp3","charTypeName":"word"},{"id":12508,"position":7,"arabic":"وَأَنشَأْنَا","translation":"এবং আমরা সৃষ্টি করেছি","audioUrl":"wbw/021_011_007.mp3","charTypeName":"word"},{"id":12509,"position":8,"arabic":"بَعْدَهَا","translation":"পরে তার","audioUrl":"wbw/021_011_008.mp3","charTypeName":"word"},{"id":12510,"position":9,"arabic":"قَوْمًا","translation":"জাতি","audioUrl":"wbw/021_011_009.mp3","charTypeName":"word"},{"id":12511,"position":10,"arabic":"ءَاخَرِينَ","translation":"অপর","audioUrl":"wbw/021_011_010.mp3","charTypeName":"word"},{"id":12512,"position":11,"arabic":"١١","translation":"(১১)","audioUrl":null,"charTypeName":"end"}]},{"number":12,"arabic":"فَلَمَّآ أَحَسُّوا۟ بَأْسَنَآ إِذَا هُم مِّنْهَا يَرْكُضُونَ","translation":"And [every time,] as soon as they began to feel Our punishing might, lo! they tried to flee from it","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2495.mp3","surahId":21,"words":[{"id":13829,"position":1,"arabic":"فَلَمَّآ","translation":"অতঃপর যখন","audioUrl":"wbw/021_012_001.mp3","charTypeName":"word"},{"id":13830,"position":2,"arabic":"أَحَسُّوا۟","translation":"তারা অনুভবব করলো","audioUrl":"wbw/021_012_002.mp3","charTypeName":"word"},{"id":13831,"position":3,"arabic":"بَأْسَنَآ","translation":"আমাদের শাস্তি","audioUrl":"wbw/021_012_003.mp3","charTypeName":"word"},{"id":13832,"position":4,"arabic":"إِذَا","translation":"তখন","audioUrl":"wbw/021_012_004.mp3","charTypeName":"word"},{"id":13833,"position":5,"arabic":"هُم","translation":"তারা","audioUrl":"wbw/021_012_005.mp3","charTypeName":"word"},{"id":13834,"position":6,"arabic":"مِّنْهَا","translation":"তা থেকে","audioUrl":"wbw/021_012_006.mp3","charTypeName":"word"},{"id":13835,"position":7,"arabic":"يَرْكُضُونَ","translation":"পালাতে লাগলো","audioUrl":"wbw/021_012_007.mp3","charTypeName":"word"},{"id":13836,"position":8,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]},{"number":13,"arabic":"لَا تَرْكُضُوا۟ وَٱرْجِعُوٓا۟ إِلَىٰ مَآ أُتْرِفْتُمْ فِيهِ وَمَسَٰكِنِكُمْ لَعَلَّكُمْ تُسْـَٔلُونَ","translation":"[and at the same time they seemed to hear a scornful voice]: “Do not try to flee, but return to all that [once] gave you pleasure and corrupted your whole being. and [return] to your homes, so that you might be called to account [for what you have done]!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2496.mp3","surahId":21,"words":[{"id":14979,"position":1,"arabic":"لَا","translation":"(বলা হলো) না","audioUrl":"wbw/021_013_001.mp3","charTypeName":"word"},{"id":14980,"position":2,"arabic":"تَرْكُضُوا۟","translation":"তোমরা পালাবে","audioUrl":"wbw/021_013_002.mp3","charTypeName":"word"},{"id":14981,"position":3,"arabic":"وَٱرْجِعُوٓا۟","translation":"বরং তোমরা ফিরে যাও","audioUrl":"wbw/021_013_003.mp3","charTypeName":"word"},{"id":14982,"position":4,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/021_013_004.mp3","charTypeName":"word"},{"id":14983,"position":5,"arabic":"مَآ","translation":"তার","audioUrl":"wbw/021_013_005.mp3","charTypeName":"word"},{"id":14984,"position":6,"arabic":"أُتْرِفْتُمْ","translation":"তোমাদের সম্ভোগ দেয়া হয়েছিলো","audioUrl":"wbw/021_013_006.mp3","charTypeName":"word"},{"id":14985,"position":7,"arabic":"فِيهِ","translation":"যার মধ্যে","audioUrl":"wbw/021_013_007.mp3","charTypeName":"word"},{"id":14986,"position":8,"arabic":"وَمَسَـٰكِنِكُمْ","translation":"ও ঘরবাড়িগুলোতে তোমাদের","audioUrl":"wbw/021_013_008.mp3","charTypeName":"word"},{"id":14987,"position":9,"arabic":"لَعَلَّكُمْ","translation":"যাতে তোমাদের","audioUrl":"wbw/021_013_009.mp3","charTypeName":"word"},{"id":14988,"position":10,"arabic":"تُسْـَٔلُونَ","translation":"জিজ্ঞাসাবাদ করা যেতে পারে","audioUrl":"wbw/021_013_010.mp3","charTypeName":"word"},{"id":14989,"position":11,"arabic":"١٣","translation":"(১৩)","audioUrl":null,"charTypeName":"end"}]},{"number":14,"arabic":"قَالُوا۟ يَٰوَيْلَنَآ إِنَّا كُنَّا ظَٰلِمِينَ","translation":"And they could only cry: “Oh, woe unto us! Verily, we were wrongdoers!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2497.mp3","surahId":21,"words":[{"id":16625,"position":1,"arabic":"قَالُوا۟","translation":"তারা বলেছিলো","audioUrl":"wbw/021_014_001.mp3","charTypeName":"word"},{"id":16626,"position":2,"arabic":"يَـٰوَيْلَنَآ","translation":"\"হায় আমাদের দুর্ভোগ","audioUrl":"wbw/021_014_002.mp3","charTypeName":"word"},{"id":16627,"position":3,"arabic":"إِنَّا","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/021_014_003.mp3","charTypeName":"word"},{"id":16628,"position":4,"arabic":"كُنَّا","translation":"ছিলাম","audioUrl":"wbw/021_014_004.mp3","charTypeName":"word"},{"id":16629,"position":5,"arabic":"ظَـٰلِمِينَ","translation":"অত্যাচারী\"","audioUrl":"wbw/021_014_005.mp3","charTypeName":"word"},{"id":16630,"position":6,"arabic":"١٤","translation":"(১৪)","audioUrl":null,"charTypeName":"end"}]},{"number":15,"arabic":"فَمَا زَالَت تِّلْكَ دَعْوَىٰهُمْ حَتَّىٰ جَعَلْنَٰهُمْ حَصِيدًا خَٰمِدِينَ","translation":"And that cry of theirs did not cease until We caused them to become [like] a field mown down, still and silent as ashes.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2498.mp3","surahId":21,"words":[{"id":17296,"position":1,"arabic":"فَمَا","translation":"অতঃপর","audioUrl":"wbw/021_015_001.mp3","charTypeName":"word"},{"id":17297,"position":2,"arabic":"زَالَت","translation":"চলতে থাকে","audioUrl":"wbw/021_015_002.mp3","charTypeName":"word"},{"id":17298,"position":3,"arabic":"تِّلْكَ","translation":"এই","audioUrl":"wbw/021_015_003.mp3","charTypeName":"word"},{"id":17299,"position":4,"arabic":"دَعْوَىٰهُمْ","translation":"তাদের আর্তনাদ","audioUrl":"wbw/021_015_004.mp3","charTypeName":"word"},{"id":17300,"position":5,"arabic":"حَتَّىٰ","translation":"যতক্ষণ না","audioUrl":"wbw/021_015_005.mp3","charTypeName":"word"},{"id":17301,"position":6,"arabic":"جَعَلْنَـٰهُمْ","translation":"তাদেরকে আমরা পরিণত করি","audioUrl":"wbw/021_015_006.mp3","charTypeName":"word"},{"id":17302,"position":7,"arabic":"حَصِيدًا","translation":"কাটা শস্য","audioUrl":"wbw/021_015_007.mp3","charTypeName":"word"},{"id":17303,"position":8,"arabic":"خَـٰمِدِينَ","translation":"নেভানো আগুনের মতো","audioUrl":"wbw/021_015_008.mp3","charTypeName":"word"},{"id":17304,"position":9,"arabic":"١٥","translation":"(১৫)","audioUrl":null,"charTypeName":"end"}]},{"number":16,"arabic":"وَمَا خَلَقْنَا ٱلسَّمَآءَ وَٱلْأَرْضَ وَمَا بَيْنَهُمَا لَٰعِبِينَ","translation":"AND [know that] We have not created the heavens and the earth and all that is between them in mere idle play:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2499.mp3","surahId":21,"words":[{"id":18349,"position":1,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/021_016_001.mp3","charTypeName":"word"},{"id":18350,"position":2,"arabic":"خَلَقْنَا","translation":"আমরা সৃষ্টি করেছি","audioUrl":"wbw/021_016_002.mp3","charTypeName":"word"},{"id":18351,"position":3,"arabic":"ٱلسَّمَآءَ","translation":"আকাশ","audioUrl":"wbw/021_016_003.mp3","charTypeName":"word"},{"id":18352,"position":4,"arabic":"وَٱلْأَرْضَ","translation":"ও পৃথিবীকে","audioUrl":"wbw/021_016_004.mp3","charTypeName":"word"},{"id":18353,"position":5,"arabic":"وَمَا","translation":"আর যা কিছু","audioUrl":"wbw/021_016_005.mp3","charTypeName":"word"},{"id":18354,"position":6,"arabic":"بَيْنَهُمَا","translation":"উভয়ের মাঝে","audioUrl":"wbw/021_016_006.mp3","charTypeName":"word"},{"id":18355,"position":7,"arabic":"لَـٰعِبِينَ","translation":"খেলার ছলে","audioUrl":"wbw/021_016_007.mp3","charTypeName":"word"},{"id":18356,"position":8,"arabic":"١٦","translation":"(১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":17,"arabic":"لَوْ أَرَدْنَآ أَن نَّتَّخِذَ لَهْوًۭا لَّٱتَّخَذْنَٰهُ مِن لَّدُنَّآ إِن كُنَّا فَٰعِلِينَ","translation":"[for,] had We willed to indulge in a pastime, We would indeed have produced it from within Ourselves - if such had been Our will at all!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2500.mp3","surahId":21,"words":[{"id":19369,"position":1,"arabic":"لَوْ","translation":"যদি","audioUrl":"wbw/021_017_001.mp3","charTypeName":"word"},{"id":19370,"position":2,"arabic":"أَرَدْنَآ","translation":"আমরা চাইতাম","audioUrl":"wbw/021_017_002.mp3","charTypeName":"word"},{"id":19371,"position":3,"arabic":"أَن","translation":"যে","audioUrl":"wbw/021_017_003.mp3","charTypeName":"word"},{"id":19372,"position":4,"arabic":"نَّتَّخِذَ","translation":"আমরা গ্রহণ করবো","audioUrl":"wbw/021_017_004.mp3","charTypeName":"word"},{"id":19373,"position":5,"arabic":"لَهْوًۭا","translation":"(এসব সৃষ্টি) খেলা রূপে","audioUrl":"wbw/021_017_005.mp3","charTypeName":"word"},{"id":19374,"position":6,"arabic":"لَّٱتَّخَذْنَـٰهُ","translation":"অবশ্যই তা আমরা (খেলা হিসেবে) নিতাম","audioUrl":"wbw/021_017_006.mp3","charTypeName":"word"},{"id":19375,"position":7,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/021_017_007.mp3","charTypeName":"word"},{"id":19376,"position":8,"arabic":"لَّدُنَّآ","translation":"আমাদের কাছ (সীমাবদ্ধ রেখে)","audioUrl":"wbw/021_017_008.mp3","charTypeName":"word"},{"id":19377,"position":9,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/021_017_009.mp3","charTypeName":"word"},{"id":19378,"position":10,"arabic":"كُنَّا","translation":"আমরা হতাম","audioUrl":"wbw/021_017_010.mp3","charTypeName":"word"},{"id":19379,"position":11,"arabic":"فَـٰعِلِينَ","translation":"(খেলা) করার","audioUrl":"wbw/021_017_011.mp3","charTypeName":"word"},{"id":19380,"position":12,"arabic":"١٧","translation":"(১৭)","audioUrl":null,"charTypeName":"end"}]},{"number":18,"arabic":"بَلْ نَقْذِفُ بِٱلْحَقِّ عَلَى ٱلْبَٰطِلِ فَيَدْمَغُهُۥ فَإِذَا هُوَ زَاهِقٌۭ ۚ وَلَكُمُ ٱلْوَيْلُ مِمَّا تَصِفُونَ","translation":"Nay, but [by the very act of creation] We hurl the truth against falsehood, and it crushes the latter: and lo! it withers away. But woe unto you for all your [attempts at] defining [God] –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2501.mp3","surahId":21,"words":[{"id":20426,"position":1,"arabic":"بَلْ","translation":"(ব্যাপার তা নয়) বরং","audioUrl":"wbw/021_018_001.mp3","charTypeName":"word"},{"id":20427,"position":2,"arabic":"نَقْذِفُ","translation":"আঘাত হানি আমরা","audioUrl":"wbw/021_018_002.mp3","charTypeName":"word"},{"id":20428,"position":3,"arabic":"بِٱلْحَقِّ","translation":"দিয়ে সত্য","audioUrl":"wbw/021_018_003.mp3","charTypeName":"word"},{"id":20429,"position":4,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/021_018_004.mp3","charTypeName":"word"},{"id":20430,"position":5,"arabic":"ٱلْبَـٰطِلِ","translation":"মিথ্যার","audioUrl":"wbw/021_018_005.mp3","charTypeName":"word"},{"id":20431,"position":6,"arabic":"فَيَدْمَغُهُۥ","translation":"ফলে তাকে চূর্ণবিচূর্ণ করে দেয়","audioUrl":"wbw/021_018_006.mp3","charTypeName":"word"},{"id":20432,"position":7,"arabic":"فَإِذَا","translation":"অতঃপর তখন","audioUrl":"wbw/021_018_007.mp3","charTypeName":"word"},{"id":20433,"position":8,"arabic":"هُوَ","translation":"তা","audioUrl":"wbw/021_018_008.mp3","charTypeName":"word"},{"id":20434,"position":9,"arabic":"زَاهِقٌۭ ۚ","translation":"নিশ্চিহ্ন হয়ে যায়","audioUrl":"wbw/021_018_009.mp3","charTypeName":"word"},{"id":20436,"position":10,"arabic":"وَلَكُمُ","translation":"আর তোমাদের জন্যে আছে","audioUrl":"wbw/021_018_011.mp3","charTypeName":"word"},{"id":20437,"position":11,"arabic":"ٱلْوَيْلُ","translation":"দুর্ভোগ","audioUrl":"wbw/021_018_012.mp3","charTypeName":"word"},{"id":20438,"position":12,"arabic":"مِمَّا","translation":"সে কারণে যা","audioUrl":"wbw/021_018_013.mp3","charTypeName":"word"},{"id":20439,"position":13,"arabic":"تَصِفُونَ","translation":"তোমরা রচনা করছো","audioUrl":"wbw/021_018_014.mp3","charTypeName":"word"},{"id":20440,"position":14,"arabic":"١٨","translation":"(১৮)","audioUrl":null,"charTypeName":"end"}]},{"number":19,"arabic":"وَلَهُۥ مَن فِى ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ ۚ وَمَنْ عِندَهُۥ لَا يَسْتَكْبِرُونَ عَنْ عِبَادَتِهِۦ وَلَا يَسْتَحْسِرُونَ","translation":"for, unto Him belong all [beings] that are in the heavens and on earth; and those that are with Him are never too proud to worship Him and never grow weary [thereof]:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2502.mp3","surahId":21,"words":[{"id":21529,"position":1,"arabic":"وَلَهُۥ","translation":"এবং তাঁরই (রয়েছে)","audioUrl":"wbw/021_019_001.mp3","charTypeName":"word"},{"id":21530,"position":2,"arabic":"مَن","translation":"যা কিছু","audioUrl":"wbw/021_019_002.mp3","charTypeName":"word"},{"id":21531,"position":3,"arabic":"فِى","translation":"মধ্যে আছে","audioUrl":"wbw/021_019_003.mp3","charTypeName":"word"},{"id":21532,"position":4,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশমন্ডলীর","audioUrl":"wbw/021_019_004.mp3","charTypeName":"word"},{"id":21533,"position":5,"arabic":"وَٱلْأَرْضِ ۚ","translation":"এবং পৃথিবীর","audioUrl":"wbw/021_019_005.mp3","charTypeName":"word"},{"id":21535,"posi