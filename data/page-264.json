{"id":264,"ayahs":[{"number":32,"arabic":"قَالَ يَٰٓإِبْلِيسُ مَا لَكَ أَلَّا تَكُونَ مَعَ ٱلسَّٰجِدِينَ","translation":"Said He: \"O Iblis! What is thy reason for not being among those who have prostrated themselves?\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1834.mp3","surahId":15,"words":[{"id":35104,"position":1,"arabic":"قَالَ","translation":"তিনি বললেন","audioUrl":"wbw/015_032_001.mp3","charTypeName":"word"},{"id":35105,"position":2,"arabic":"يَـٰٓإِبْلِيسُ","translation":"\"হে ইবলীস","audioUrl":"wbw/015_032_002.mp3","charTypeName":"word"},{"id":35106,"position":3,"arabic":"مَا","translation":"কি","audioUrl":"wbw/015_032_003.mp3","charTypeName":"word"},{"id":35107,"position":4,"arabic":"لَكَ","translation":"তোমার হয়েছে","audioUrl":"wbw/015_032_004.mp3","charTypeName":"word"},{"id":35108,"position":5,"arabic":"أَلَّا","translation":"যে না","audioUrl":"wbw/015_032_005.mp3","charTypeName":"word"},{"id":35109,"position":6,"arabic":"تَكُونَ","translation":"তুমি হ'লে","audioUrl":"wbw/015_032_006.mp3","charTypeName":"word"},{"id":35110,"position":7,"arabic":"مَعَ","translation":"সাথে","audioUrl":"wbw/015_032_007.mp3","charTypeName":"word"},{"id":35111,"position":8,"arabic":"ٱلسَّـٰجِدِينَ","translation":"সিজদাকারীদের\"","audioUrl":"wbw/015_032_008.mp3","charTypeName":"word"},{"id":35112,"position":9,"arabic":"٣٢","translation":"(৩২)","audioUrl":null,"charTypeName":"end"}]},{"number":33,"arabic":"قَالَ لَمْ أَكُن لِّأَسْجُدَ لِبَشَرٍ خَلَقْتَهُۥ مِن صَلْصَٰلٍۢ مِّنْ حَمَإٍۢ مَّسْنُونٍۢ","translation":"[Iblis] replied: \"It is not for me to prostrate myself before mortal man whom Thou hast created out of sounding clay, out of dark slime transmuted!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1835.mp3","surahId":15,"words":[{"id":35960,"position":1,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/015_033_001.mp3","charTypeName":"word"},{"id":35961,"position":2,"arabic":"لَمْ","translation":"\"নি","audioUrl":"wbw/015_033_002.mp3","charTypeName":"word"},{"id":35962,"position":3,"arabic":"أَكُن","translation":"\"আমি হই","audioUrl":"wbw/015_033_003.mp3","charTypeName":"word"},{"id":35963,"position":4,"arabic":"لِّأَسْجُدَ","translation":"জন্যে আমি সিজদা করার","audioUrl":"wbw/015_033_004.mp3","charTypeName":"word"},{"id":35964,"position":5,"arabic":"لِبَشَرٍ","translation":"মানুষকে","audioUrl":"wbw/015_033_005.mp3","charTypeName":"word"},{"id":35965,"position":6,"arabic":"خَلَقْتَهُۥ","translation":"আপনি সৃষ্টি করেছেন তাকে","audioUrl":"wbw/015_033_006.mp3","charTypeName":"word"},{"id":35966,"position":7,"arabic":"مِن","translation":"হ'তে","audioUrl":"wbw/015_033_007.mp3","charTypeName":"word"},{"id":35967,"position":8,"arabic":"صَلْصَـٰلٍۢ","translation":"শুকনো ঠনঠনে মাটি","audioUrl":"wbw/015_033_008.mp3","charTypeName":"word"},{"id":35968,"position":9,"arabic":"مِّنْ","translation":"তৈরী (থেকে)","audioUrl":"wbw/015_033_009.mp3","charTypeName":"word"},{"id":35969,"position":10,"arabic":"حَمَإٍۢ","translation":"কাদা","audioUrl":"wbw/015_033_010.mp3","charTypeName":"word"},{"id":35970,"position":11,"arabic":"مَّسْنُونٍۢ","translation":"দুর্গন্ধযুক্ত\"","audioUrl":"wbw/015_033_011.mp3","charTypeName":"word"},{"id":35971,"position":12,"arabic":"٣٣","translation":"(৩৩)","audioUrl":null,"charTypeName":"end"}]},{"number":34,"arabic":"قَالَ فَٱخْرُجْ مِنْهَا فَإِنَّكَ رَجِيمٌۭ","translation":"Said He: \"Go forth, then, from this [angelic state]: for, behold, thou art [henceforth] accursed,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1836.mp3","surahId":15,"words":[{"id":36836,"position":1,"arabic":"قَالَ","translation":"তিনি বললেন","audioUrl":"wbw/015_034_001.mp3","charTypeName":"word"},{"id":36837,"position":2,"arabic":"فَٱخْرُجْ","translation":"\"তাহ'লে বের হও","audioUrl":"wbw/015_034_002.mp3","charTypeName":"word"},{"id":36838,"position":3,"arabic":"مِنْهَا","translation":"তা থেকে","audioUrl":"wbw/015_034_003.mp3","charTypeName":"word"},{"id":36839,"position":4,"arabic":"فَإِنَّكَ","translation":"কারণ নিশ্চয়ই তুমি","audioUrl":"wbw/015_034_004.mp3","charTypeName":"word"},{"id":36840,"position":5,"arabic":"رَجِيمٌۭ","translation":"বিতাড়িত","audioUrl":"wbw/015_034_005.mp3","charTypeName":"word"},{"id":36841,"position":6,"arabic":"٣٤","translation":"(৩৪)","audioUrl":null,"charTypeName":"end"}]},{"number":35,"arabic":"وَإِنَّ عَلَيْكَ ٱللَّعْنَةَ إِلَىٰ يَوْمِ ٱلدِّينِ","translation":"and [My] rejection shall be thy due until the Day of Judgment!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1837.mp3","surahId":15,"words":[{"id":37632,"position":1,"arabic":"وَإِنَّ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/015_035_001.mp3","charTypeName":"word"},{"id":37633,"position":2,"arabic":"عَلَيْكَ","translation":"তোমার উপর","audioUrl":"wbw/015_035_002.mp3","charTypeName":"word"},{"id":37634,"position":3,"arabic":"ٱللَّعْنَةَ","translation":"অভিশাপ","audioUrl":"wbw/015_035_003.mp3","charTypeName":"word"},{"id":37635,"position":4,"arabic":"إِلَىٰ","translation":"পর্যন্ত","audioUrl":"wbw/015_035_004.mp3","charTypeName":"word"},{"id":37636,"position":5,"arabic":"يَوْمِ","translation":"দিন","audioUrl":"wbw/015_035_005.mp3","charTypeName":"word"},{"id":37637,"position":6,"arabic":"ٱلدِّينِ","translation":"বিচারের\"","audioUrl":"wbw/015_035_006.mp3","charTypeName":"word"},{"id":37638,"position":7,"arabic":"٣٥","translation":"(৩৫)","audioUrl":null,"charTypeName":"end"}]},{"number":36,"arabic":"قَالَ رَبِّ فَأَنظِرْنِىٓ إِلَىٰ يَوْمِ يُبْعَثُونَ","translation":"Said [Iblis]: \"Then, O my Sustainer, grant me a respite till the Day when all shall be raised from the dead!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1838.mp3","surahId":15,"words":[{"id":38507,"position":1,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/015_036_001.mp3","charTypeName":"word"},{"id":38508,"position":2,"arabic":"رَبِّ","translation":"\"হে আমার রব","audioUrl":"wbw/015_036_002.mp3","charTypeName":"word"},{"id":38509,"position":3,"arabic":"فَأَنظِرْنِىٓ","translation":"তবে আমাকে অবকাশ দিন","audioUrl":"wbw/015_036_003.mp3","charTypeName":"word"},{"id":38510,"position":4,"arabic":"إِلَىٰ","translation":"পর্যন্ত","audioUrl":"wbw/015_036_004.mp3","charTypeName":"word"},{"id":38511,"position":5,"arabic":"يَوْمِ","translation":"দিবস","audioUrl":"wbw/015_036_005.mp3","charTypeName":"word"},{"id":38512,"position":6,"arabic":"يُبْعَثُونَ","translation":"উত্থান\"","audioUrl":"wbw/015_036_006.mp3","charTypeName":"word"},{"id":38513,"position":7,"arabic":"٣٦","translation":"(৩৬)","audioUrl":null,"charTypeName":"end"}]},{"number":37,"arabic":"قَالَ فَإِنَّكَ مِنَ ٱلْمُنظَرِينَ","translation":"Answered He: \"Verily, so be it: thou shalt be among those who are granted respite","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1839.mp3","surahId":15,"words":[{"id":39378,"position":1,"arabic":"قَالَ","translation":"তিনি বললেন","audioUrl":"wbw/015_037_001.mp3","charTypeName":"word"},{"id":39379,"position":2,"arabic":"فَإِنَّكَ","translation":"\"তাহ'লে নিশ্চয়ই তুমি","audioUrl":"wbw/015_037_002.mp3","charTypeName":"word"},{"id":39380,"position":3,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/015_037_003.mp3","charTypeName":"word"},{"id":39381,"position":4,"arabic":"ٱلْمُنظَرِينَ","translation":"অবকাশপ্রাপ্তদের","audioUrl":"wbw/015_037_004.mp3","charTypeName":"word"},{"id":39382,"position":5,"arabic":"٣٧","translation":"(৩৭)","audioUrl":null,"charTypeName":"end"}]},{"number":38,"arabic":"إِلَىٰ يَوْمِ ٱلْوَقْتِ ٱلْمَعْلُومِ","translation":"till the Day the time whereof is known [to Me alone].\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1840.mp3","surahId":15,"words":[{"id":40207,"position":1,"arabic":"إِلَىٰ","translation":"পর্যন্ত","audioUrl":"wbw/015_038_001.mp3","charTypeName":"word"},{"id":40208,"position":2,"arabic":"يَوْمِ","translation":"(ক্বিয়ামাতের) দিন","audioUrl":"wbw/015_038_002.mp3","charTypeName":"word"},{"id":40209,"position":3,"arabic":"ٱلْوَقْتِ","translation":"(যার) সময়","audioUrl":"wbw/015_038_003.mp3","charTypeName":"word"},{"id":40210,"position":4,"arabic":"ٱلْمَعْلُومِ","translation":"অবধারিত\"","audioUrl":"wbw/015_038_004.mp3","charTypeName":"word"},{"id":40211,"position":5,"arabic":"٣٨","translation":"(৩৮)","audioUrl":null,"charTypeName":"end"}]},{"number":39,"arabic":"قَالَ رَبِّ بِمَآ أَغْوَيْتَنِى لَأُزَيِّنَنَّ لَهُمْ فِى ٱلْأَرْضِ وَلَأُغْوِيَنَّهُمْ أَجْمَعِينَ","translation":"[Whereupon Iblis] said: \"O my Sustainer! Since Thou hast thwarted me, I shall indeed make [all that is evil] on earth seem goodly to them, and shall most certainly beguile them-into grievous error -","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1841.mp3","surahId":15,"words":[{"id":40942,"position":1,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/015_039_001.mp3","charTypeName":"word"},{"id":40943,"position":2,"arabic":"رَبِّ","translation":"\"হে আমার রব","audioUrl":"wbw/015_039_002.mp3","charTypeName":"word"},{"id":40944,"position":3,"arabic":"بِمَآ","translation":"যে কারণে","audioUrl":"wbw/015_039_003.mp3","charTypeName":"word"},{"id":40945,"position":4,"arabic":"أَغْوَيْتَنِى","translation":"আমাকে আপনি বিপথগামী করলেন","audioUrl":"wbw/015_039_004.mp3","charTypeName":"word"},{"id":40946,"position":5,"arabic":"لَأُزَيِّنَنَّ","translation":"অবশ্যই আমি সুশোভন করবো","audioUrl":"wbw/015_039_005.mp3","charTypeName":"word"},{"id":40947,"position":6,"arabic":"لَهُمْ","translation":"জন্যে তাদের","audioUrl":"wbw/015_039_006.mp3","charTypeName":"word"},{"id":40948,"position":7,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/015_039_007.mp3","charTypeName":"word"},{"id":40949,"position":8,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর","audioUrl":"wbw/015_039_008.mp3","charTypeName":"word"},{"id":40950,"position":9,"arabic":"وَلَأُغْوِيَنَّهُمْ","translation":"এবং অবশ্যই আমি বিপথগামী করবো তাদেরকে","audioUrl":"wbw/015_039_009.mp3","charTypeName":"word"},{"id":40951,"position":10,"arabic":"أَجْمَعِينَ","translation":"সকলকে","audioUrl":"wbw/015_039_010.mp3","charTypeName":"word"},{"id":40952,"position":11,"arabic":"٣٩","translation":"(৩৯)","audioUrl":null,"charTypeName":"end"}]},{"number":40,"arabic":"إِلَّا عِبَادَكَ مِنْهُمُ ٱلْمُخْلَصِينَ","translation":"[all] save such of them as are truly Thy servants!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1842.mp3","surahId":15,"words":[{"id":41841,"position":1,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/015_040_001.mp3","charTypeName":"word"},{"id":41842,"position":2,"arabic":"عِبَادَكَ","translation":"আপনার দাসদের","audioUrl":"wbw/015_040_002.mp3","charTypeName":"word"},{"id":41843,"position":3,"arabic":"مِنْهُمُ","translation":"তাদের মধ্য হ'তে","audioUrl":"wbw/015_040_003.mp3","charTypeName":"word"},{"id":41844,"position":4,"arabic":"ٱلْمُخْلَصِينَ","translation":"একনিষ্ঠ\"","audioUrl":"wbw/015_040_004.mp3","charTypeName":"word"},{"id":41845,"position":5,"arabic":"٤٠","translation":"(৪০)","audioUrl":null,"charTypeName":"end"}]},{"number":41,"arabic":"قَالَ هَٰذَا صِرَٰطٌ عَلَىَّ مُسْتَقِيمٌ","translation":"Said He: \"This is, with Me. a straight way:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1843.mp3","surahId":15,"words":[{"id":42129,"position":1,"arabic":"قَالَ","translation":"তিনি বললেন","audioUrl":"wbw/015_041_001.mp3","charTypeName":"word"},{"id":42130,"position":2,"arabic":"هَـٰذَا","translation":"\"এটা","audioUrl":"wbw/015_041_002.mp3","charTypeName":"word"},{"id":42131,"position":3,"arabic":"صِرَٰطٌ","translation":"পথ","audioUrl":"wbw/015_041_003.mp3","charTypeName":"word"},{"id":42132,"position":4,"arabic":"عَلَىَّ","translation":"আমার দিকে","audioUrl":"wbw/015_041_004.mp3","charTypeName":"word"},{"id":42133,"position":5,"arabic":"مُسْتَقِيمٌ","translation":"সরল","audioUrl":"wbw/015_041_005.mp3","charTypeName":"word"},{"id":42134,"position":6,"arabic":"٤١","translation":"(৪১)","audioUrl":null,"charTypeName":"end"}]},{"number":42,"arabic":"إِنَّ عِبَادِى لَيْسَ لَكَ عَلَيْهِمْ سُلْطَٰنٌ إِلَّا مَنِ ٱتَّبَعَكَ مِنَ ٱلْغَاوِينَ","translation":"verily, thou shalt have no power over My creatures- unless it be such as are [already] lost in grievous error and follow thee [of their own will]:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1844.mp3","surahId":15,"words":[{"id":43315,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই (যারা)","audioUrl":"wbw/015_042_001.mp3","charTypeName":"word"},{"id":43316,"position":2,"arabic":"عِبَادِى","translation":"আমার দাসরা","audioUrl":"wbw/015_042_002.mp3","charTypeName":"word"},{"id":43317,"position":3,"arabic":"لَيْسَ","translation":"নেই","audioUrl":"wbw/015_042_003.mp3","charTypeName":"word"},{"id":43318,"position":4,"arabic":"لَكَ","translation":"তোমার জন্যে","audioUrl":"wbw/015_042_004.mp3","charTypeName":"word"},{"id":43319,"position":5,"arabic":"عَلَيْهِمْ","translation":"তাদের উপর","audioUrl":"wbw/015_042_005.mp3","charTypeName":"word"},{"id":43320,"position":6,"arabic":"سُلْطَـٰنٌ","translation":"কোন প্রভাব","audioUrl":"wbw/015_042_006.mp3","charTypeName":"word"},{"id":43321,"position":7,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/015_042_007.mp3","charTypeName":"word"},{"id":43322,"position":8,"arabic":"مَنِ","translation":"যে","audioUrl":"wbw/015_042_008.mp3","charTypeName":"word"},{"id":43323,"position":9,"arabic":"ٱتَّبَعَكَ","translation":"তোমার অনুসরণ করবে","audioUrl":"wbw/015_042_009.mp3","charTypeName":"word"},{"id":43324,"position":10,"arabic":"مِنَ","translation":"থেকে","audioUrl":"wbw/015_042_010.mp3","charTypeName":"word"},{"id":43325,"position":11,"arabic":"ٱلْغَاوِينَ","translation":"পথভ্রষ্ট\"","audioUrl":"wbw/015_042_011.mp3","charTypeName":"word"},{"id":43326,"position":12,"arabic":"٤٢","translation":"(৪২)","audioUrl":null,"charTypeName":"end"}]},{"number":43,"arabic":"وَإِنَّ جَهَنَّمَ لَمَوْعِدُهُمْ أَجْمَعِينَ","translation":"and for all such, behold, hell is the promised goal.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1845.mp3","surahId":15,"words":[{"id":44076,"position":1,"arabic":"وَإِنَّ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/015_043_001.mp3","charTypeName":"word"},{"id":44077,"position":2,"arabic":"جَهَنَّمَ","translation":"জাহান্নাম","audioUrl":"wbw/015_043_002.mp3","charTypeName":"word"},{"id":44078,"position":3,"arabic":"لَمَوْعِدُهُمْ","translation":"অবশ্যই প্রতিশ্রুত স্হান তাদের","audioUrl":"wbw/015_043_003.mp3","charTypeName":"word"},{"id":44079,"position":4,"arabic":"أَجْمَعِينَ","translation":"সকলের","audioUrl":"wbw/015_043_004.mp3","charTypeName":"word"},{"id":44080,"position":5,"arabic":"٤٣","translation":"(৪৩)","audioUrl":null,"charTypeName":"end"}]},{"number":44,"arabic":"لَهَا سَبْعَةُ أَبْوَٰبٍۢ لِّكُلِّ بَابٍۢ مِّنْهُمْ جُزْءٌۭ مَّقْسُومٌ","translation":"with seven gates leading into it, each gate receiving its allotted share of sinners. -","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1846.mp3","surahId":15,"words":[{"id":44878,"position":1,"arabic":"لَهَا","translation":"তার আছে","audioUrl":"wbw/015_044_001.mp3","charTypeName":"word"},{"id":44879,"position":2,"arabic":"سَبْعَةُ","translation":"সাতটি","audioUrl":"wbw/015_044_002.mp3","charTypeName":"word"},{"id":44880,"position":3,"arabic":"أَبْوَٰبٍۢ","translation":"দরজা","audioUrl":"wbw/015_044_003.mp3","charTypeName":"word"},{"id":44881,"position":4,"arabic":"لِّكُلِّ","translation":"জন্যে প্রত্যেকটির","audioUrl":"wbw/015_044_004.mp3","charTypeName":"word"},{"id":44882,"position":5,"arabic":"بَابٍۢ","translation":"দরজার","audioUrl":"wbw/015_044_005.mp3","charTypeName":"word"},{"id":44883,"position":6,"arabic":"مِّنْهُمْ","translation":"তাদের থেকে","audioUrl":"wbw/015_044_006.mp3","charTypeName":"word"},{"id":44884,"position":7,"arabic":"جُزْءٌۭ","translation":"অংশ (দল)","audioUrl":"wbw/015_044_007.mp3","charTypeName":"word"},{"id":44885,"position":8,"arabic":"مَّقْسُومٌ","translation":"পৃথক পৃথক","audioUrl":"wbw/015_044_008.mp3","charTypeName":"word"},{"id":44886,"position":9,"arabic":"٤٤","translation":"(৪৪)","audioUrl":null,"charTypeName":"end"}]},{"number":45,"arabic":"إِنَّ ٱلْمُتَّقِينَ فِى جَنَّٰتٍۢ وَعُيُونٍ","translation":"VERILY, those who are conscious of God [shall find themselves in the hereafter] amidst gardens and springs,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1847.mp3","surahId":15,"words":[{"id":45550,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/015_045_001.mp3","charTypeName":"word"},{"id":45551,"position":2,"arabic":"ٱلْمُتَّقِينَ","translation":"মুত্তাকীরা","audioUrl":"wbw/015_045_002.mp3","charTypeName":"word"},{"id":45552,"position":3,"arabic":"فِى","translation":"মধ্যে (থাকবে)","audioUrl":"wbw/015_045_003.mp3","charTypeName":"word"},{"id":45553,"position":4,"arabic":"جَنَّـٰتٍۢ","translation":"জান্নাতের","audioUrl":"wbw/015_045_004.mp3","charTypeName":"word"},{"id":45554,"position":5,"arabic":"وَعُيُونٍ","translation":"ও ঝর্ণাধারাসমূহের","audioUrl":"wbw/015_045_005.mp3","charTypeName":"word"},{"id":45555,"position":6,"arabic":"٤٥","translation":"(৪৫)","audioUrl":null,"charTypeName":"end"}]},{"number":46,"arabic":"ٱدْخُلُوهَا بِسَلَٰمٍ ءَامِنِينَ","translation":"[having been received with the greeting,] \"Enter here in peace, secure!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1848.mp3","surahId":15,"words":[{"id":46242,"position":1,"arabic":"ٱدْخُلُوهَا","translation":"\"তাতে তোমরা প্রবেশ করো","audioUrl":"wbw/015_046_001.mp3","charTypeName":"word"},{"id":46243,"position":2,"arabic":"بِسَلَـٰمٍ","translation":"সাথে শান্তির","audioUrl":"wbw/015_046_002.mp3","charTypeName":"word"},{"id":46244,"position":3,"arabic":"ءَامِنِينَ","translation":"নিরাপদে\"","audioUrl":"wbw/015_046_003.mp3","charTypeName":"word"},{"id":46245,"position":4,"arabic":"٤٦","translation":"(৪৬)","audioUrl":null,"charTypeName":"end"}]},{"number":47,"arabic":"وَنَزَعْنَا مَا فِى صُدُورِهِم مِّنْ غِلٍّ إِخْوَٰنًا عَلَىٰ سُرُرٍۢ مُّتَقَٰبِلِينَ","translation":"And [by then] We shall have removed whatever unworthy thoughts or feelings may have been [lingering] in their breasts, [and they shall rest] as brethren, facing one another [in love] upon thrones of happiness.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1849.mp3","surahId":15,"words":[{"id":46911,"position":1,"arabic":"وَنَزَعْنَا","translation":"এবং আমরা দূর করে দিবো","audioUrl":"wbw/015_047_001.mp3","charTypeName":"word"},{"id":46912,"position":2,"arabic":"مَا","translation":"যা","audioUrl":"wbw/015_047_002.mp3","charTypeName":"word"},{"id":46913,"position":3,"arabic":"فِى","translation":"মধ্যে আছে","audioUrl":"wbw/015_047_003.mp3","charTypeName":"word"},{"id":46914,"position":4,"arabic":"صُدُورِهِم","translation":"তাদের অন্তরসমূহের","audioUrl":"wbw/015_047_004.mp3","charTypeName":"word"},{"id":46915,"position":5,"arabic":"مِّنْ","translation":"থেকে","audioUrl":"wbw/015_047_005.mp3","charTypeName":"word"},{"id":46916,"position":6,"arabic":"غِلٍّ","translation":"ঈর্ষা","audioUrl":"wbw/015_047_006.mp3","charTypeName":"word"},{"id":46917,"position":7,"arabic":"إِخْوَٰنًا","translation":"ভাই ভাই হয়ে (তারা বসবে)","audioUrl":"wbw/015_047_007.mp3","charTypeName":"word"},{"id":46918,"position":8,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/015_047_008.mp3","charTypeName":"word"},{"id":46919,"position":9,"arabic":"سُرُرٍۢ","translation":"আসনসমূহের","audioUrl":"wbw/015_047_009.mp3","charTypeName":"word"},{"id":46920,"position":10,"arabic":"مُّتَقَـٰبِلِينَ","translation":"মুখোমুখি হয়ে","audioUrl":"wbw/015_047_010.mp3","charTypeName":"word"},{"id":46921,"position":11,"arabic":"٤٧","translation":"(৪৭)","audioUrl":null,"charTypeName":"end"}]},{"number":48,"arabic":"لَا يَمَسُّهُمْ فِيهَا نَصَبٌۭ وَمَا هُم مِّنْهَا بِمُخْرَجِينَ","translation":"No weariness shall ever touch them in this [state of bliss], and never shall they have to forgo it.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1850.mp3","surahId":15,"word