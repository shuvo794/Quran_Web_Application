{"id":203,"ayahs":[{"number":100,"arabic":"وَٱلسَّٰبِقُونَ ٱلْأَوَّلُونَ مِنَ ٱلْمُهَٰجِرِينَ وَٱلْأَنصَارِ وَٱلَّذِينَ ٱتَّبَعُوهُم بِإِحْسَٰنٍۢ رَّضِىَ ٱللَّهُ عَنْهُمْ وَرَضُوا۟ عَنْهُ وَأَعَدَّ لَهُمْ جَنَّٰتٍۢ تَجْرِى تَحْتَهَا ٱلْأَنْهَٰرُ خَٰلِدِينَ فِيهَآ أَبَدًۭا ۚ ذَٰلِكَ ٱلْفَوْزُ ٱلْعَظِيمُ","translation":"And as for the first and foremost of those who have forsaken the domain of evil and of those who have sheltered and succoured the Faith, as well as those who follow them in [the way of] righteousness - God is well-pleased with them, and well--pleased are they with Him. And for them has He readied gardens through which running waters flow, therein to abide beyond the count of time: this is the triumph supreme!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1335.mp3","surahId":9,"words":[{"id":71221,"position":1,"arabic":"وَٱلسَّـٰبِقُونَ","translation":"ও অগ্রগামীরা","audioUrl":"wbw/009_100_001.mp3","charTypeName":"word"},{"id":71222,"position":2,"arabic":"ٱلْأَوَّلُونَ","translation":"প্রথম","audioUrl":"wbw/009_100_002.mp3","charTypeName":"word"},{"id":71223,"position":3,"arabic":"مِنَ","translation":"মধ্য হতে","audioUrl":"wbw/009_100_003.mp3","charTypeName":"word"},{"id":71224,"position":4,"arabic":"ٱلْمُهَـٰجِرِينَ","translation":"মুহাজেরদের","audioUrl":"wbw/009_100_004.mp3","charTypeName":"word"},{"id":71225,"position":5,"arabic":"وَٱلْأَنصَارِ","translation":"ও আনসারদের","audioUrl":"wbw/009_100_005.mp3","charTypeName":"word"},{"id":71226,"position":6,"arabic":"وَٱلَّذِينَ","translation":"ও যারা","audioUrl":"wbw/009_100_006.mp3","charTypeName":"word"},{"id":71227,"position":7,"arabic":"ٱتَّبَعُوهُم","translation":"অনুসরণ করেছে তাদের","audioUrl":"wbw/009_100_007.mp3","charTypeName":"word"},{"id":71228,"position":8,"arabic":"بِإِحْسَـٰنٍۢ","translation":"সাথে সততার","audioUrl":"wbw/009_100_008.mp3","charTypeName":"word"},{"id":71229,"position":9,"arabic":"رَّضِىَ","translation":"সন্তুষ্ট হয়েছেন","audioUrl":"wbw/009_100_009.mp3","charTypeName":"word"},{"id":71230,"position":10,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/009_100_010.mp3","charTypeName":"word"},{"id":71231,"position":11,"arabic":"عَنْهُمْ","translation":"উপর তাদের","audioUrl":"wbw/009_100_011.mp3","charTypeName":"word"},{"id":71232,"position":12,"arabic":"وَرَضُوا۟","translation":"ও তারা খুশি হয়েছে","audioUrl":"wbw/009_100_012.mp3","charTypeName":"word"},{"id":71233,"position":13,"arabic":"عَنْهُ","translation":"উপর তাঁর","audioUrl":"wbw/009_100_013.mp3","charTypeName":"word"},{"id":71234,"position":14,"arabic":"وَأَعَدَّ","translation":"ও প্রস্তুত করে তিনি রেখেছেন","audioUrl":"wbw/009_100_014.mp3","charTypeName":"word"},{"id":71235,"position":15,"arabic":"لَهُمْ","translation":"জন্যে তাদের","audioUrl":"wbw/009_100_015.mp3","charTypeName":"word"},{"id":71236,"position":16,"arabic":"جَنَّـٰتٍۢ","translation":"জান্নাত","audioUrl":"wbw/009_100_016.mp3","charTypeName":"word"},{"id":71237,"position":17,"arabic":"تَجْرِى","translation":"প্রবাহিত হয়","audioUrl":"wbw/009_100_017.mp3","charTypeName":"word"},{"id":71238,"position":18,"arabic":"تَحْتَهَا","translation":"নিচে তার","audioUrl":"wbw/009_100_018.mp3","charTypeName":"word"},{"id":71239,"position":19,"arabic":"ٱلْأَنْهَـٰرُ","translation":"ঝর্নাধারা","audioUrl":"wbw/009_100_019.mp3","charTypeName":"word"},{"id":71240,"position":20,"arabic":"خَـٰلِدِينَ","translation":"তারা স্হায়ী হবে","audioUrl":"wbw/009_100_020.mp3","charTypeName":"word"},{"id":71241,"position":21,"arabic":"فِيهَآ","translation":"মধ্যে তার","audioUrl":"wbw/009_100_021.mp3","charTypeName":"word"},{"id":71242,"position":22,"arabic":"أَبَدًۭا ۚ","translation":"চিরকাল","audioUrl":"wbw/009_100_022.mp3","charTypeName":"word"},{"id":71244,"position":23,"arabic":"ذَٰلِكَ","translation":"এটাই","audioUrl":"wbw/009_100_024.mp3","charTypeName":"word"},{"id":71245,"position":24,"arabic":"ٱلْفَوْزُ","translation":"সফলতা","audioUrl":"wbw/009_100_025.mp3","charTypeName":"word"},{"id":71246,"position":25,"arabic":"ٱلْعَظِيمُ","translation":"মহা","audioUrl":"wbw/009_100_026.mp3","charTypeName":"word"},{"id":71247,"position":26,"arabic":"١٠٠","translation":"(১০০)","audioUrl":null,"charTypeName":"end"}]},{"number":101,"arabic":"وَمِمَّنْ حَوْلَكُم مِّنَ ٱلْأَعْرَابِ مُنَٰفِقُونَ ۖ وَمِنْ أَهْلِ ٱلْمَدِينَةِ ۖ مَرَدُوا۟ عَلَى ٱلنِّفَاقِ لَا تَعْلَمُهُمْ ۖ نَحْنُ نَعْلَمُهُمْ ۚ سَنُعَذِّبُهُم مَّرَّتَيْنِ ثُمَّ يُرَدُّونَ إِلَىٰ عَذَابٍ عَظِيمٍۢ","translation":"But among the bedouin who dwell around you there are hypocrites; and among the people of the [Prophet's] City [too] there are such as have grown insolent in [their] hypocrisy. Thou dost not [always] know them, [O Muhammad - but] We know them. We shall cause them to suffer doubly [in this world]; and then they will be given over to awesome suffering [in the life to come].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1336.mp3","surahId":9,"words":[{"id":71639,"position":1,"arabic":"وَمِمَّنْ","translation":"এবং মধ্যে তাদের যারা","audioUrl":"wbw/009_101_001.mp3","charTypeName":"word"},{"id":71640,"position":2,"arabic":"حَوْلَكُم","translation":"তোমাদের আশপাশে(আছে)","audioUrl":"wbw/009_101_002.mp3","charTypeName":"word"},{"id":71641,"position":3,"arabic":"مِّنَ","translation":"কেউ কেউ","audioUrl":"wbw/009_101_003.mp3","charTypeName":"word"},{"id":71642,"position":4,"arabic":"ٱلْأَعْرَابِ","translation":"বেদুঈনদের","audioUrl":"wbw/009_101_004.mp3","charTypeName":"word"},{"id":71643,"position":5,"arabic":"مُنَـٰفِقُونَ ۖ","translation":"(অনেকেই) মুনাফেক","audioUrl":"wbw/009_101_005.mp3","charTypeName":"word"},{"id":71645,"position":6,"arabic":"وَمِنْ","translation":"এবং কেউ কেউ","audioUrl":"wbw/009_101_007.mp3","charTypeName":"word"},{"id":71646,"position":7,"arabic":"أَهْلِ","translation":"অধিবাসী","audioUrl":"wbw/009_101_008.mp3","charTypeName":"word"},{"id":71647,"position":8,"arabic":"ٱلْمَدِينَةِ ۖ","translation":"মাদীনাহ","audioUrl":"wbw/009_101_009.mp3","charTypeName":"word"},{"id":71649,"position":9,"arabic":"مَرَدُوا۟","translation":"তারা চরমে পৌঁছে গিয়েছে","audioUrl":"wbw/009_101_011.mp3","charTypeName":"word"},{"id":71650,"position":10,"arabic":"عَلَى","translation":"ক্ষেত্রে","audioUrl":"wbw/009_101_012.mp3","charTypeName":"word"},{"id":71651,"position":11,"arabic":"ٱلنِّفَاقِ","translation":"কপটতার","audioUrl":"wbw/009_101_013.mp3","charTypeName":"word"},{"id":71652,"position":12,"arabic":"لَا","translation":"না","audioUrl":"wbw/009_101_014.mp3","charTypeName":"word"},{"id":71653,"position":13,"arabic":"تَعْلَمُهُمْ ۖ","translation":"জানো তুমি তাদের","audioUrl":"wbw/009_101_015.mp3","charTypeName":"word"},{"id":71655,"position":14,"arabic":"نَحْنُ","translation":"আমরা","audioUrl":"wbw/009_101_017.mp3","charTypeName":"word"},{"id":71656,"position":15,"arabic":"نَعْلَمُهُمْ ۚ","translation":"জানি তাদের","audioUrl":"wbw/009_101_018.mp3","charTypeName":"word"},{"id":71658,"position":16,"arabic":"سَنُعَذِّبُهُم","translation":"শীঘ্রই আমরা শাস্তি দিবো তাদের","audioUrl":"wbw/009_101_020.mp3","charTypeName":"word"},{"id":71659,"position":17,"arabic":"مَّرَّتَيْنِ","translation":"দু'বার","audioUrl":"wbw/009_101_021.mp3","charTypeName":"word"},{"id":71660,"position":18,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/009_101_022.mp3","charTypeName":"word"},{"id":71661,"position":19,"arabic":"يُرَدُّونَ","translation":"তাদের ফিরিয়ে নেয়া হবে","audioUrl":"wbw/009_101_023.mp3","charTypeName":"word"},{"id":71662,"position":20,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/009_101_024.mp3","charTypeName":"word"},{"id":71663,"position":21,"arabic":"عَذَابٍ","translation":"শাস্তির","audioUrl":"wbw/009_101_025.mp3","charTypeName":"word"},{"id":71664,"position":22,"arabic":"عَظِيمٍۢ","translation":"কঠোর","audioUrl":"wbw/009_101_026.mp3","charTypeName":"word"},{"id":71665,"position":23,"arabic":"١٠١","translation":"(১০১)","audioUrl":null,"charTypeName":"end"}]},{"number":102,"arabic":"وَءَاخَرُونَ ٱعْتَرَفُوا۟ بِذُنُوبِهِمْ خَلَطُوا۟ عَمَلًۭا صَٰلِحًۭا وَءَاخَرَ سَيِّئًا عَسَى ٱللَّهُ أَن يَتُوبَ عَلَيْهِمْ ۚ إِنَّ ٱللَّهَ غَفُورٌۭ رَّحِيمٌ","translation":"And [there are] others - [people who] have become conscious of their sinning after having done righteous deeds side by side with evil ones; [and] it may well be that God will accept their repentance: for, verily, God is much-forgiving, a dispenser' of grace.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1337.mp3","surahId":9,"words":[{"id":71875,"position":1,"arabic":"وَءَاخَرُونَ","translation":"এবং আরো কিছু লোক (আছে)","audioUrl":"wbw/009_102_001.mp3","charTypeName":"word"},{"id":71876,"position":2,"arabic":"ٱعْتَرَفُوا۟","translation":"তারা স্বীকার করেছে","audioUrl":"wbw/009_102_002.mp3","charTypeName":"word"},{"id":71877,"position":3,"arabic":"بِذُنُوبِهِمْ","translation":"অপরাধ তাদের","audioUrl":"wbw/009_102_003.mp3","charTypeName":"word"},{"id":71878,"position":4,"arabic":"خَلَطُوا۟","translation":"তারা মিশিয়ে ফেলেছে","audioUrl":"wbw/009_102_004.mp3","charTypeName":"word"},{"id":71879,"position":5,"arabic":"عَمَلًۭا","translation":"(কিছু) কাজ","audioUrl":"wbw/009_102_005.mp3","charTypeName":"word"},{"id":71880,"position":6,"arabic":"صَـٰلِحًۭا","translation":"ভালো","audioUrl":"wbw/009_102_006.mp3","charTypeName":"word"},{"id":71881,"position":7,"arabic":"وَءَاخَرَ","translation":"ও অন্য কিছু","audioUrl":"wbw/009_102_007.mp3","charTypeName":"word"},{"id":71882,"position":8,"arabic":"سَيِّئًا","translation":"(কাজ) মন্দ","audioUrl":"wbw/009_102_008.mp3","charTypeName":"word"},{"id":71883,"position":9,"arabic":"عَسَى","translation":"আশা করা যায়","audioUrl":"wbw/009_102_009.mp3","charTypeName":"word"},{"id":71884,"position":10,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/009_102_010.mp3","charTypeName":"word"},{"id":71885,"position":11,"arabic":"أَن","translation":"যে","audioUrl":"wbw/009_102_011.mp3","charTypeName":"word"},{"id":71886,"position":12,"arabic":"يَتُوبَ","translation":"ক্ষমা করবেন","audioUrl":"wbw/009_102_012.mp3","charTypeName":"word"},{"id":71887,"position":13,"arabic":"عَلَيْهِمْ ۚ","translation":"প্রতি তাদের","audioUrl":"wbw/009_102_013.mp3","charTypeName":"word"},{"id":71889,"position":14,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/009_102_015.mp3","charTypeName":"word"},{"id":71890,"position":15,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/009_102_016.mp3","charTypeName":"word"},{"id":71891,"position":16,"arabic":"غَفُورٌۭ","translation":"ক্ষমাশীল","audioUrl":"wbw/009_102_017.mp3","charTypeName":"word"},{"id":71892,"position":17,"arabic":"رَّحِيمٌ","translation":"পরম দয়ালু","audioUrl":"wbw/009_102_018.mp3","charTypeName":"word"},{"id":71893,"position":18,"arabic":"١٠٢","translation":"(১০২)","audioUrl":null,"charTypeName":"end"}]},{"number":103,"arabic":"خُذْ مِنْ أَمْوَٰلِهِمْ صَدَقَةًۭ تُطَهِّرُهُمْ وَتُزَكِّيهِم بِهَا وَصَلِّ عَلَيْهِمْ ۖ إِنَّ صَلَوٰتَكَ سَكَنٌۭ لَّهُمْ ۗ وَٱللَّهُ سَمِيعٌ عَلِيمٌ","translation":"[Hence, O Prophet,] accept that [part] of their possessions which is offered for the sake of God, so that thou mayest cleanse them thereby and cause them to grow in purity, and pray for them: behold, thy prayer will be [a source of] comfort to them-for God is all-hearing, all-knowing.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1338.mp3","surahId":9,"words":[{"id":72271,"position":1,"arabic":"خُذْ","translation":"গ্রহণ করো","audioUrl":"wbw/009_103_001.mp3","charTypeName":"word"},{"id":72272,"position":2,"arabic":"مِنْ","translation":"হতে","audioUrl":"wbw/009_103_002.mp3","charTypeName":"word"},{"id":72273,"position":3,"arabic":"أَمْوَٰلِهِمْ","translation":"ধনসম্পদ তাদের","audioUrl":"wbw/009_103_003.mp3","charTypeName":"word"},{"id":72274,"position":4,"arabic":"صَدَقَةًۭ","translation":"সদকা","audioUrl":"wbw/009_103_004.mp3","charTypeName":"word"},{"id":72275,"position":5,"arabic":"تُطَهِّرُهُمْ","translation":"তুমি পবিত্র করবে তাদের","audioUrl":"wbw/009_103_005.mp3","charTypeName":"word"},{"id":72276,"position":6,"arabic":"وَتُزَكِّيهِم","translation":"ও পরিশুদ্ধি করবে তাদের","audioUrl":"wbw/009_103_006.mp3","charTypeName":"word"},{"id":72277,"position":7,"arabic":"بِهَا","translation":"দিয়ে তা","audioUrl":"wbw/009_103_007.mp3","charTypeName":"word"},{"id":72278,"position":8,"arabic":"وَصَلِّ","translation":"ও দোয়া করো তুমি","audioUrl":"wbw/009_103_008.mp3","charTypeName":"word"},{"id":72279,"position":9,"arabic":"عَلَيْهِمْ ۖ","translation":"জন্যে তাদের","audioUrl":"wbw/009_103_009.mp3","charTypeName":"word"},{"id":72281,"position":10,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/009_103_011.mp3","charTypeName":"word"},{"id":72282,"position":11,"arabic":"صَلَوٰتَكَ","translation":"দোয়া তোমার","audioUrl":"wbw/009_103_012.mp3","charTypeName":"word"},{"id":72283,"position":12,"arabic":"سَكَنٌۭ","translation":"প্রশান্তি","audioUrl":"wbw/009_103_013.mp3","charTypeName":"word"},{"id":72284,"position":13,"arabic":"لَّهُمْ ۗ","translation":"জন্যে তাদের","audioUrl":"wbw/009_103_014.mp3","charTypeName":"word"},{"id":72286,"position":14,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/009_103_016.mp3","charTypeName":"word"},{"id":72287,"position":15,"arabic":"سَمِيعٌ","translation":"সব শুনেন","audioUrl":"wbw/009_103_017.mp3","charTypeName":"word"},{"id":72288,"position":16,"arabic":"عَلِيمٌ","translation":"সব জানেন","audioUrl":"wbw/009_103_018.mp3","charTypeName":"word"},{"id":72289,"position":17,"arabic":"١٠٣","translation":"(১০৩)","audioUrl":null,"charTypeName":"end"}]},{"number":104,"arabic":"أَلَمْ يَعْلَمُوٓا۟ أَنَّ ٱللَّهَ هُوَ يَقْبَلُ ٱلتَّوْبَةَ عَنْ عِبَادِهِۦ وَيَأْخُذُ ٱلصَّدَقَٰتِ وَأَنَّ ٱللَّهَ هُوَ ٱلتَّوَّابُ ٱلرَّحِيمُ","translation":"Do they not know that it is God alone who can accept the repentance of His servants and is the [true] recipient of whatever is offered for His sake - and that God alone is an acceptor of repentance, a dispenser of grace?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1339.mp3","surahId":9,"words":[{"id":72645,"position":1,"arabic":"أَلَمْ","translation":"কি না","audioUrl":"wbw/009_104_001.mp3","charTypeName":"word"},{"id":72646,"position":2,"arabic":"يَعْلَمُوٓا۟","translation":"তারা জানে","audioUrl":"wbw/009_104_002.mp3","charTypeName":"word"},{"id":72647,"position":3,"arabic":"أَنَّ","translation":"যে","audioUrl":"wbw/009_104_003.mp3","charTypeName":"word"},{"id":72648,"position":4,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/009_104_004.mp3","charTypeName":"word"},{"id":72649,"position":5,"arabic":"هُوَ","translation":"তিনিই (যিনি)","audioUrl":"wbw/009_104_005.mp3","charTypeName":"word"},{"id":72650,"position":6,"arabic":"يَقْبَلُ","translation":"গ্রহণ করেন","audioUrl":"wbw/009_104_006.mp3","charTypeName":"word"},{"id":72651,"position":7,"arabic":"ٱلتَّوْبَةَ","translation":"তওবা","audioUrl":"wbw/009_104_007.mp3","charTypeName":"word"},{"id":72652,"position":8,"arabic":"عَنْ","translation":"হতে","audioUrl":"wbw/009_104_008.mp3","charTypeName":"word"},{"id":72653,"position":9,"arabic":"عِبَادِهِۦ","translation":"দাসদের তাঁর","audioUrl":"wbw/009_104_009.mp3","charTypeName":"word"},{"id":72654,"position":10,"arabic":"وَيَأْخُذُ","translation":"ও গ্রহণ করেন","audioUrl":"wbw/009_104_010.mp3","charTypeName":"word"},{"id":72655,"position":11,"arabic":"ٱلصَّدَقَـٰتِ","translation":"সদকা","audioUrl":"wbw/009_104_011.mp3","charTypeName":"word"},{"id":72656,"position":12,"arabic":"وَأَنَّ","translation":"এবং (এও) যে","audioUrl":"wbw/009_104_012.mp3","charTypeName":"word"},{"id":72657,"position":13,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/009_104_013.mp3","charTypeName":"word"},{"id":72658,"position":14,"arabic":"هُوَ","translation":"তিনিই","audioUrl":"wbw/009_104_014.mp3","charTypeName":"word"},{"id":72659,"position":15,"arabic":"ٱلتَّوَّابُ","translation":"ক্ষমাশীল","audioUrl":"wbw/009_104_015.mp3","charTypeName":"word"},{"id":72660,"position":16,"arabic":"ٱلرَّحِيمُ","translation":"পরম দয়ালু","audioUrl":"wbw/009_104_016.mp3","charTypeName":"word"},{"id":72661,"position":17,"arabic":"١٠٤","translation":"(১০৪)","audioUrl":null,"charTypeName":"end"}]},{"number":105,"arabic":"وَقُلِ ٱعْمَلُوا۟ فَسَيَرَى ٱللَّهُ عَمَلَكُمْ وَرَسُولُهُۥ وَٱلْمُؤْمِنُونَ ۖ وَسَتُرَدُّونَ إِلَىٰ عَٰلِمِ ٱلْغَيْبِ وَٱلشَّهَٰدَةِ فَيُنَبِّئُكُم بِمَا كُنتُمْ تَعْمَلُونَ","translation":"And say [unto them, O Prophet]: \"Act! And God will behold your deeds, and [so will] His Apostle, and the believers: and [in the end] you will be brought before Him who knows all that is beyond the reach of a created being's perception as well as all that can be witnessed by a creature's senses or mind -and then He will make you understand what you have been doing.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1340.mp3","surahId":9,"words":[{"id":72864,"position":1,"arabic":"وَقُلِ","translation":"এবং বলো","audioUrl":"wbw/009_105_001.mp3","charTypeName":"word"},{"id":72865,"position":2,"arabic":"ٱعْمَلُوا۟","translation":"\"তোমরা কাজ করো","audioUrl":"wbw/009_105_002.mp3","charTypeName":"word"},{"id":72866,"position":3,"arabic":"فَسَيَرَى","translation":"অতঃপর শীঘ্রই দেখবেন","audioUrl":"wbw/009_105_003.mp3","charTypeName":"word"},{"id":72867,"position":4,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/009_105_004.mp3","charTypeName":"word"},{"id":72868,"position":5,"arabic":"عَمَلَكُمْ","translation":"কাজ তোমাদের","audioUrl":"wbw/009_105_005.mp3","charTypeName":"word"},{"id":72869,"position":6,"arabic":"وَرَسُولُهُۥ","translation":"এবং  রাসূল তাঁর","audioUrl":"wbw/009_105_006.mp3","charTypeName":"word"},{"id":72870,"position":7,"arabic":"وَٱلْمُؤْمِنُونَ ۖ","translation":"এবং মু'মিনরাও (দেখবে)","audioUrl":"wbw/009_105_007.mp3","charTypeName":"word"},{"id":72872,"position":8,"arabic":"وَسَتُرَدُّونَ","translation":"এবং অচিরেই তোমাদের ফিরিয়ে নেয়া হবে","audioUrl":"wbw/009_105_009.mp3","charTypeName":"word"},{"id":72873,"position":9,"arabic":"إِلَىٰ","translation":"(তাঁর) দিকে","audioUrl":"wbw/009_105_010.mp3",