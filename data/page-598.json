{"id":598,"ayahs":[{"number":1,"arabic":"بِّسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ إِنَّآ أَنزَلْنَٰهُ فِى لَيْلَةِ ٱلْقَدْرِ","translation":"BEHOLD, from on high have We bestowed this [divine writ] on Night of Destiny.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6126.mp3","surahId":97,"words":[{"id":169,"position":1,"arabic":"إِنَّآ","translation":"নিশ্চয়ই","audioUrl":"wbw/097_001_001.mp3","charTypeName":"word"},{"id":170,"position":2,"arabic":"أَنزَلْنَـٰهُ","translation":"তা আমরা অবতীর্ণ করেছি","audioUrl":"wbw/097_001_002.mp3","charTypeName":"word"},{"id":171,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/097_001_003.mp3","charTypeName":"word"},{"id":172,"position":4,"arabic":"لَيْلَةِ","translation":"রাতের","audioUrl":"wbw/097_001_004.mp3","charTypeName":"word"},{"id":173,"position":5,"arabic":"ٱلْقَدْرِ","translation":"কদরের/ মহিমার","audioUrl":"wbw/097_001_005.mp3","charTypeName":"word"},{"id":174,"position":6,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"وَمَآ أَدْرَىٰكَ مَا لَيْلَةُ ٱلْقَدْرِ","translation":"And what could make thee conceive what it is, that Night of Destiny?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6127.mp3","surahId":97,"words":[{"id":1789,"position":1,"arabic":"وَمَآ","translation":"এবং কিসে","audioUrl":"wbw/097_002_001.mp3","charTypeName":"word"},{"id":1790,"position":2,"arabic":"أَدْرَىٰكَ","translation":"তোমাকে জানাবে","audioUrl":"wbw/097_002_002.mp3","charTypeName":"word"},{"id":1791,"position":3,"arabic":"مَا","translation":"কি সেই","audioUrl":"wbw/097_002_003.mp3","charTypeName":"word"},{"id":1792,"position":4,"arabic":"لَيْلَةُ","translation":"রাত","audioUrl":"wbw/097_002_004.mp3","charTypeName":"word"},{"id":1793,"position":5,"arabic":"ٱلْقَدْرِ","translation":"কদরের","audioUrl":"wbw/097_002_005.mp3","charTypeName":"word"},{"id":1794,"position":6,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"لَيْلَةُ ٱلْقَدْرِ خَيْرٌۭ مِّنْ أَلْفِ شَهْرٍۢ","translation":"The Night of Destiny is better than a thousand months:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6128.mp3","surahId":97,"words":[{"id":2900,"position":1,"arabic":"لَيْلَةُ","translation":"রাত","audioUrl":"wbw/097_003_001.mp3","charTypeName":"word"},{"id":2901,"position":2,"arabic":"ٱلْقَدْرِ","translation":"কদরের","audioUrl":"wbw/097_003_002.mp3","charTypeName":"word"},{"id":2902,"position":3,"arabic":"خَيْرٌۭ","translation":"শ্রেষ্ঠ","audioUrl":"wbw/097_003_003.mp3","charTypeName":"word"},{"id":2903,"position":4,"arabic":"مِّنْ","translation":"হতেও","audioUrl":"wbw/097_003_004.mp3","charTypeName":"word"},{"id":2904,"position":5,"arabic":"أَلْفِ","translation":"হাজার","audioUrl":"wbw/097_003_005.mp3","charTypeName":"word"},{"id":2905,"position":6,"arabic":"شَهْرٍۢ","translation":"মাস","audioUrl":"wbw/097_003_006.mp3","charTypeName":"word"},{"id":2906,"position":7,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"تَنَزَّلُ ٱلْمَلَٰٓئِكَةُ وَٱلرُّوحُ فِيهَا بِإِذْنِ رَبِّهِم مِّن كُلِّ أَمْرٍۢ","translation":"in hosts descend in it the angels, bearing divine inspiration by their Sustainer's leave; from all [evil] that may happen","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6129.mp3","surahId":97,"words":[{"id":4399,"position":1,"arabic":"تَنَزَّلُ","translation":"অবতীর্ণ হয়","audioUrl":"wbw/097_004_001.mp3","charTypeName":"word"},{"id":4400,"position":2,"arabic":"ٱلْمَلَـٰٓئِكَةُ","translation":"ফেরেশতারা","audioUrl":"wbw/097_004_002.mp3","charTypeName":"word"},{"id":4401,"position":3,"arabic":"وَٱلرُّوحُ","translation":"এবং রূহ (জিব্রাঈল)","audioUrl":"wbw/097_004_003.mp3","charTypeName":"word"},{"id":4402,"position":4,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/097_004_004.mp3","charTypeName":"word"},{"id":4403,"position":5,"arabic":"بِإِذْنِ","translation":"অনুমতিক্রমে","audioUrl":"wbw/097_004_005.mp3","charTypeName":"word"},{"id":4404,"position":6,"arabic":"رَبِّهِم","translation":"তাদের রবের","audioUrl":"wbw/097_004_006.mp3","charTypeName":"word"},{"id":4405,"position":7,"arabic":"مِّن","translation":"প্রত্যেক","audioUrl":"wbw/097_004_007.mp3","charTypeName":"word"},{"id":4406,"position":8,"arabic":"كُلِّ","translation":"সব","audioUrl":"wbw/097_004_008.mp3","charTypeName":"word"},{"id":4407,"position":9,"arabic":"أَمْرٍۢ","translation":"কাজে","audioUrl":"wbw/097_004_009.mp3","charTypeName":"word"},{"id":4408,"position":10,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"سَلَٰمٌ هِىَ حَتَّىٰ مَطْلَعِ ٱلْفَجْرِ","translation":"does it make secure, until the rise of dawn.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6130.mp3","surahId":97,"words":[{"id":4984,"position":1,"arabic":"سَلَـٰمٌ","translation":"শান্তির","audioUrl":"wbw/097_005_001.mp3","charTypeName":"word"},{"id":4985,"position":2,"arabic":"هِىَ","translation":"সেই (রাত)","audioUrl":"wbw/097_005_002.mp3","charTypeName":"word"},{"id":4986,"position":3,"arabic":"حَتَّىٰ","translation":"পর্যন্ত","audioUrl":"wbw/097_005_003.mp3","charTypeName":"word"},{"id":4987,"position":4,"arabic":"مَطْلَعِ","translation":"উদয়","audioUrl":"wbw/097_005_004.mp3","charTypeName":"word"},{"id":4988,"position":5,"arabic":"ٱلْفَجْرِ","translation":"ঊষার","audioUrl":"wbw/097_005_005.mp3","charTypeName":"word"},{"id":4989,"position":6,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ لَمْ يَكُنِ ٱلَّذِينَ كَفَرُوا۟ مِنْ أَهْلِ ٱلْكِتَٰبِ وَٱلْمُشْرِكِينَ مُنفَكِّينَ حَتَّىٰ تَأْتِيَهُمُ ٱلْبَيِّنَةُ","translation":"IT IS NOT [conceivable] that such as are bent on denying the truth - [be they] from among the followers of earlier revelation or from among those who ascribe divinity to aught beside God should ever be abandoned [by Him] ere there comes unto them the [full] evidence of the truth:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6131.mp3","surahId":98,"words":[{"id":122,"position":1,"arabic":"لَمْ","translation":"না","audioUrl":"wbw/098_001_001.mp3","charTypeName":"word"},{"id":123,"position":2,"arabic":"يَكُنِ","translation":"ছিল (প্রস্তুত)","audioUrl":"wbw/098_001_002.mp3","charTypeName":"word"},{"id":124,"position":3,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/098_001_003.mp3","charTypeName":"word"},{"id":125,"position":4,"arabic":"كَفَرُوا۟","translation":"কুফরি করেছে","audioUrl":"wbw/098_001_004.mp3","charTypeName":"word"},{"id":126,"position":5,"arabic":"مِنْ","translation":"মধ্য হতে","audioUrl":"wbw/098_001_005.mp3","charTypeName":"word"},{"id":127,"position":6,"arabic":"أَهْلِ","translation":"অধিকারী","audioUrl":"wbw/098_001_006.mp3","charTypeName":"word"},{"id":128,"position":7,"arabic":"ٱلْكِتَـٰبِ","translation":"কিতাবের","audioUrl":"wbw/098_001_007.mp3","charTypeName":"word"},{"id":129,"position":8,"arabic":"وَٱلْمُشْرِكِينَ","translation":"এবং মুশরিকদের (মধ্য হতে)","audioUrl":"wbw/098_001_008.mp3","charTypeName":"word"},{"id":130,"position":9,"arabic":"مُنفَكِّينَ","translation":"(কুফরী হতে) বিরত","audioUrl":"wbw/098_001_009.mp3","charTypeName":"word"},{"id":131,"position":10,"arabic":"حَتَّىٰ","translation":"যতক্ষণ না","audioUrl":"wbw/098_001_010.mp3","charTypeName":"word"},{"id":132,"position":11,"arabic":"تَأْتِيَهُمُ","translation":"তাদের কাছে আসবে","audioUrl":"wbw/098_001_011.mp3","charTypeName":"word"},{"id":133,"position":12,"arabic":"ٱلْبَيِّنَةُ","translation":"অকাট্য প্রমাণ (অর্থাৎ)","audioUrl":"wbw/098_001_012.mp3","charTypeName":"word"},{"id":134,"position":13,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"رَسُولٌۭ مِّنَ ٱللَّهِ يَتْلُوا۟ صُحُفًۭا مُّطَهَّرَةًۭ","translation":"an apostle from God, conveying [unto them] revelations blest with purity,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6132.mp3","surahId":98,"words":[{"id":1795,"position":1,"arabic":"رَسُولٌۭ","translation":"একজন রাসূল","audioUrl":"wbw/098_002_001.mp3","charTypeName":"word"},{"id":1796,"position":2,"arabic":"مِّنَ","translation":"পক্ষ হতে","audioUrl":"wbw/098_002_002.mp3","charTypeName":"word"},{"id":1797,"position":3,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/098_002_003.mp3","charTypeName":"word"},{"id":1798,"position":4,"arabic":"يَتْلُوا۟","translation":"যে আবৃত্তি করবে","audioUrl":"wbw/098_002_004.mp3","charTypeName":"word"},{"id":1799,"position":5,"arabic":"صُحُفًۭا","translation":"সহীফাসমূহ","audioUrl":"wbw/098_002_005.mp3","charTypeName":"word"},{"id":1800,"position":6,"arabic":"مُّطَهَّرَةًۭ","translation":"পবিত্র","audioUrl":"wbw/098_002_006.mp3","charTypeName":"word"},{"id":1801,"position":7,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"فِيهَا كُتُبٌۭ قَيِّمَةٌۭ","translation":"wherein there are ordinances of ever-true soundness and clarity.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6133.mp3","surahId":98,"words":[{"id":2907,"position":1,"arabic":"فِيهَا","translation":"তার মধ্যে (থাকবে)","audioUrl":"wbw/098_003_001.mp3","charTypeName":"word"},{"id":2908,"position":2,"arabic":"كُتُبٌۭ","translation":"বিধানাবলী","audioUrl":"wbw/098_003_002.mp3","charTypeName":"word"},{"id":2909,"position":3,"arabic":"قَيِّمَةٌۭ","translation":"সঠিক","audioUrl":"wbw/098_003_003.mp3","charTypeName":"word"},{"id":2910,"position":4,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"وَمَا تَفَرَّقَ ٱلَّذِينَ أُوتُوا۟ ٱلْكِتَٰبَ إِلَّا مِنۢ بَعْدِ مَا جَآءَتْهُمُ ٱلْبَيِّنَةُ","translation":"Now those who have been vouchsafed revelation aforetime did break up their unity [of faith] after such an evidence of the truth had come to them.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6134.mp3","surahId":98,"words":[{"id":3300,"position":1,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/098_004_001.mp3","charTypeName":"word"},{"id":3301,"position":2,"arabic":"تَفَرَّقَ","translation":"বিভেদে লিপ্ত হয়েছে","audioUrl":"wbw/098_004_002.mp3","charTypeName":"word"},{"id":3302,"position":3,"arabic":"ٱلَّذِينَ","translation":"(তারা) যাদের","audioUrl":"wbw/098_004_003.mp3","charTypeName":"word"},{"id":3303,"position":4,"arabic":"أُوتُوا۟","translation":"দেয়া হয়েছিল","audioUrl":"wbw/098_004_004.mp3","charTypeName":"word"},{"id":3304,"position":5,"arabic":"ٱلْكِتَـٰبَ","translation":"কিতাব","audioUrl":"wbw/098_004_005.mp3","charTypeName":"word"},{"id":3305,"position":6,"arabic":"إِلَّا","translation":"তবে","audioUrl":"wbw/098_004_006.mp3","charTypeName":"word"},{"id":3306,"position":7,"arabic":"مِنۢ","translation":"থেকে","audioUrl":"wbw/098_004_007.mp3","charTypeName":"word"},{"id":3307,"position":8,"arabic":"بَعْدِ","translation":"পরে","audioUrl":"wbw/098_004_008.mp3","charTypeName":"word"},{"id":3308,"position":9,"arabic":"مَا","translation":"যা","audioUrl":"wbw/098_004_009.mp3","charTypeName":"word"},{"id":3309,"position":10,"arabic":"جَآءَتْهُمُ","translation":"তাদের কাছে এসেছিল","audioUrl":"wbw/098_004_010.mp3","charTypeName":"word"},{"id":3310,"position":11,"arabic":"ٱلْبَيِّنَةُ","translation":"সুস্পষ্ট প্রমাণ","audioUrl":"wbw/098_004_011.mp3","charTypeName":"word"},{"id":3311,"position":12,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"وَمَآ أُمِرُوٓا۟ إِلَّا لِيَعْبُدُوا۟ ٱللَّهَ مُخْلِصِينَ لَهُ ٱلدِّينَ حُنَفَآءَ وَيُقِيمُوا۟ ٱلصَّلَوٰةَ وَيُؤْتُوا۟ ٱلزَّكَوٰةَ ۚ وَذَٰلِكَ دِينُ ٱلْقَيِّمَةِ","translation":"And withal, they were not enjoined aught but that they should worship God, sincere in their faith in Him alone, turning away from all that is false; and that they should be constant in prayer; and that they should spend in charity: for this is a moral law endowed with ever-true soundness and clarity.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6135.mp3","surahId":98,"words":[{"id":4610,"position":1,"arabic":"وَمَآ","translation":"এবং না","audioUrl":"wbw/098_005_001.mp3","charTypeName":"word"},{"id":4611,"position":2,"arabic":"أُمِرُوٓا۟","translation":"তারা আদিষ্ট হয়েছে","audioUrl":"wbw/098_005_002.mp3","charTypeName":"word"},{"id":4612,"position":3,"arabic":"إِلَّا","translation":"এ ছাড়া যে","audioUrl":"wbw/098_005_003.mp3","charTypeName":"word"},{"id":4613,"position":4,"arabic":"لِيَعْبُدُوا۟","translation":"তারা ইবাদত করুক","audioUrl":"wbw/098_005_004.mp3","charTypeName":"word"},{"id":4614,"position":5,"arabic":"ٱللَّهَ","translation":"আল্লাহর","audioUrl":"wbw/098_005_005.mp3","charTypeName":"word"},{"id":4615,"position":6,"arabic":"مُخْلِصِينَ","translation":"একনিষ্ঠভাবে","audioUrl":"wbw/098_005_006.mp3","charTypeName":"word"},{"id":4616,"position":7,"arabic":"لَهُ","translation":"তাঁরই জন্যে","audioUrl":"wbw/098_005_007.mp3","charTypeName":"word"},{"id":4617,"position":8,"arabic":"ٱلدِّينَ","translation":"আনুগত্যকে","audioUrl":"wbw/098_005_008.mp3","charTypeName":"word"},{"id":4618,"position":9,"arabic":"حُنَفَآءَ","translation":"খাঁটি মনে","audioUrl":"wbw/098_005_009.mp3","charTypeName":"word"},{"id":4619,"position":10,"arabic":"وَيُقِيمُوا۟","translation":"এবং তারা কায়েম করবে","audioUrl":"wbw/098_005_010.mp3","charTypeName":"word"},{"id":4620,"position":11,"arabic":"ٱلصَّلَوٰةَ","translation":"সালাত","audioUrl":"wbw/098_005_011.mp3","charTypeName":"word"},{"id":4621,"position":12,"arabic":"وَيُؤْتُوا۟","translation":"ও তারা দেবে","audioUrl":"wbw/098_005_012.mp3","charTypeName":"word"},{"id":4622,"position":13,"arabic":"ٱلزَّكَوٰةَ ۚ","translation":"যাকাত","audioUrl":"wbw/098_005_013.mp3","charTypeName":"word"},{"id":4624,"position":14,"arabic":"وَذَٰلِكَ","translation":"এবং এটাই","audioUrl":"wbw/098_005_015.mp3","charTypeName":"word"},{"id":4625,"position":15,"arabic":"دِينُ","translation":"দীন","audioUrl":"wbw/098_005_016.mp3","charTypeName":"word"},{"id":4626,"position":16,"arabic":"ٱلْقَيِّمَةِ","translation":"সঠিক","audioUrl":"wbw/098_005_017.mp3","charTypeName":"word"},{"id":4627,"position":17,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"إِنَّ ٱلَّذِينَ كَفَرُوا۟ مِنْ أَهْلِ ٱلْكِتَٰبِ وَٱلْمُشْرِكِينَ فِى نَارِ جَهَنَّمَ خَٰلِدِينَ فِيهَآ ۚ أُو۟لَٰٓئِكَ هُمْ شَرُّ ٱلْبَرِيَّةِ","translation":"Verily, those who [despite all evidence] are bent on denying the truth - [be they] from among the followers of earlier revelation or from among those who ascribe divinity to aught beside God - will find themselves in the fire of hell, therein to abide: they are the worst of all creatures.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/6136.mp3","surahId":98,"words":[{"id":6766,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/098_006_001.mp3","charTypeName":"word"},{"id":6767,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/098_006_002.mp3","charTypeName":"word"},{"id":6768,"position":3,"arabic":"كَفَرُوا۟","translation":"কুফরি করেছে","audioUrl":"wbw/098_006_003.mp3","charTypeName":"word"},{"id":6769,"position":4,"arabic":"مِنْ","translation":"মধ্য হতে","audioUrl":"wbw/098_006_004.mp3","charTypeName":"word"},{"id":6770,"position":5,"arabic":"أَهْلِ","translation":"অধিকারী","audioUrl":"wbw/098_006_005.mp3","charTypeName":"word"},{"id":6771,"position":6,"arabic":"ٱلْكِتَـٰبِ","translation":"কিতাবের","audioUrl":"wbw/098_006_006.mp3","charTypeName":"word"},{"id":6772,"position":7,"arabic":"وَٱلْمُشْرِكِينَ","translation":"এবং মুশরিকদের","audioUrl":"wbw/098_006_007.mp3","charTypeName":"word"},{"id":6773,"position":8,"arabic":"فِى","translation":"মধ্যে (থাকবে)","audioUrl":"wbw/098_006_008.mp3","charTypeName":"word"},{"id":6774,"position":9,"arabic":"نَارِ","translation":"আগুনের","audioUrl":"wbw/098_006_009.mp3","charTypeName":"word"},{"id":6775,"position":10,"arabic":"جَهَنَّمَ","translation":"জাহান্নামের","audioUrl":"wbw/098_006