translation":"(৩৫)","audioUrl":null,"charTypeName":"end"}]},{"number":36,"arabic":"وَٱلَّذِينَ كَذَّبُوا۟ بِـَٔايَٰتِنَا وَٱسْتَكْبَرُوا۟ عَنْهَآ أُو۟لَٰٓئِكَ أَصْحَٰبُ ٱلنَّارِ ۖ هُمْ فِيهَا خَٰلِدُونَ","translation":"but they who give the lie to Our messages and scorn them in their pride-these are destined for the fire, therein to abide.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/990.mp3","surahId":7,"words":[{"id":38585,"position":1,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/007_036_001.mp3","charTypeName":"word"},{"id":38586,"position":2,"arabic":"كَذَّبُوا۟","translation":"মিথ্যা সাব্যস্ত করবে","audioUrl":"wbw/007_036_002.mp3","charTypeName":"word"},{"id":38587,"position":3,"arabic":"بِـَٔايَـٰتِنَا","translation":"ব্যাপারে আয়াতগুলোর আমাদের","audioUrl":"wbw/007_036_003.mp3","charTypeName":"word"},{"id":38588,"position":4,"arabic":"وَٱسْتَكْبَرُوا۟","translation":"ও অহংকার করবে","audioUrl":"wbw/007_036_004.mp3","charTypeName":"word"},{"id":38589,"position":5,"arabic":"عَنْهَآ","translation":"হতে তা","audioUrl":"wbw/007_036_005.mp3","charTypeName":"word"},{"id":38590,"position":6,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐসব লোক","audioUrl":"wbw/007_036_006.mp3","charTypeName":"word"},{"id":38591,"position":7,"arabic":"أَصْحَـٰبُ","translation":"অধিবাসী (হবে)","audioUrl":"wbw/007_036_007.mp3","charTypeName":"word"},{"id":38592,"position":8,"arabic":"ٱلنَّارِ ۖ","translation":"আগুনের","audioUrl":"wbw/007_036_008.mp3","charTypeName":"word"},{"id":38594,"position":9,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/007_036_010.mp3","charTypeName":"word"},{"id":38595,"position":10,"arabic":"فِيهَا","translation":"মধ্যে তার (থাকবে)","audioUrl":"wbw/007_036_011.mp3","charTypeName":"word"},{"id":38596,"position":11,"arabic":"خَـٰلِدُونَ","translation":"চিরকাল","audioUrl":"wbw/007_036_012.mp3","charTypeName":"word"},{"id":38597,"position":12,"arabic":"٣٦","translation":"(৩৬)","audioUrl":null,"charTypeName":"end"}]},{"number":37,"arabic":"فَمَنْ أَظْلَمُ مِمَّنِ ٱفْتَرَىٰ عَلَى ٱللَّهِ كَذِبًا أَوْ كَذَّبَ بِـَٔايَٰتِهِۦٓ ۚ أُو۟لَٰٓئِكَ يَنَالُهُمْ نَصِيبُهُم مِّنَ ٱلْكِتَٰبِ ۖ حَتَّىٰٓ إِذَا جَآءَتْهُمْ رُسُلُنَا يَتَوَفَّوْنَهُمْ قَالُوٓا۟ أَيْنَ مَا كُنتُمْ تَدْعُونَ مِن دُونِ ٱللَّهِ ۖ قَالُوا۟ ضَلُّوا۟ عَنَّا وَشَهِدُوا۟ عَلَىٰٓ أَنفُسِهِمْ أَنَّهُمْ كَانُوا۟ كَٰفِرِينَ","translation":"And who could be more wicked than they who attribute their own lying inventions to God or give the lie to His messages? Whatever has been decreed to be their lot [in life] will be theirs -till there shall come _ unto them Our messengers to cause them to die, [and] shall say, \"Where, now, are those beings whom you were wont to invoke beside God?\" And [those sinners] will reply, \"They have forsaken us!\" -and [thus] they will bear witness against themselves that they had been denying the truth.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/991.mp3","surahId":7,"words":[{"id":39435,"position":1,"arabic":"فَمَنْ","translation":"অতঃপর কে","audioUrl":"wbw/007_037_001.mp3","charTypeName":"word"},{"id":39436,"position":2,"arabic":"أَظْلَمُ","translation":"অধিক সীমালঙ্ঘনকারী (হতে পারে)","audioUrl":"wbw/007_037_002.mp3","charTypeName":"word"},{"id":39437,"position":3,"arabic":"مِمَّنِ","translation":"(তার) চেয়ে যে","audioUrl":"wbw/007_037_003.mp3","charTypeName":"word"},{"id":39438,"position":4,"arabic":"ٱفْتَرَىٰ","translation":"রচনা করে","audioUrl":"wbw/007_037_004.mp3","charTypeName":"word"},{"id":39439,"position":5,"arabic":"عَلَى","translation":"সম্বন্ধে","audioUrl":"wbw/007_037_005.mp3","charTypeName":"word"},{"id":39440,"position":6,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/007_037_006.mp3","charTypeName":"word"},{"id":39441,"position":7,"arabic":"كَذِبًا","translation":"মিথ্যা","audioUrl":"wbw/007_037_007.mp3","charTypeName":"word"},{"id":39442,"position":8,"arabic":"أَوْ","translation":"বা","audioUrl":"wbw/007_037_008.mp3","charTypeName":"word"},{"id":39443,"po