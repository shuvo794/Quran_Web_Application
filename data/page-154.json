{"id":154,"ayahs":[{"number":31,"arabic":"۞ يَٰبَنِىٓ ءَادَمَ خُذُوا۟ زِينَتَكُمْ عِندَ كُلِّ مَسْجِدٍۢ وَكُلُوا۟ وَٱشْرَبُوا۟ وَلَا تُسْرِفُوٓا۟ ۚ إِنَّهُۥ لَا يُحِبُّ ٱلْمُسْرِفِينَ","translation":"O CHILDREN of Adam! Beautify yourselves for every act of worship, and eat and drink [freely], but do not waste: verily, He does not love the wasteful!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/985.mp3","surahId":7,"words":[{"id":34296,"position":1,"arabic":"۞ يَـٰبَنِىٓ","translation":"হে সন্তান","audioUrl":"wbw/007_031_002.mp3","charTypeName":"word"},{"id":34297,"position":2,"arabic":"ءَادَمَ","translation":"আদমের","audioUrl":"wbw/007_031_003.mp3","charTypeName":"word"},{"id":34298,"position":3,"arabic":"خُذُوا۟","translation":"তোমরা গ্রহণ করো","audioUrl":"wbw/007_031_004.mp3","charTypeName":"word"},{"id":34299,"position":4,"arabic":"زِينَتَكُمْ","translation":"সুন্দর পোশাক তোমাদের","audioUrl":"wbw/007_031_005.mp3","charTypeName":"word"},{"id":34300,"position":5,"arabic":"عِندَ","translation":"সময়","audioUrl":"wbw/007_031_006.mp3","charTypeName":"word"},{"id":34301,"position":6,"arabic":"كُلِّ","translation":"প্রত্যেক","audioUrl":"wbw/007_031_007.mp3","charTypeName":"word"},{"id":34302,"position":7,"arabic":"مَسْجِدٍۢ","translation":"মাসজীদের (সালাতের)","audioUrl":"wbw/007_031_008.mp3","charTypeName":"word"},{"id":34303,"position":8,"arabic":"وَكُلُوا۟","translation":"এবং তোমরা খাও","audioUrl":"wbw/007_031_009.mp3","charTypeName":"word"},{"id":34304,"position":9,"arabic":"وَٱشْرَبُوا۟","translation":"ও তোমরা পান কর","audioUrl":"wbw/007_031_010.mp3","charTypeName":"word"},{"id":34305,"position":10,"arabic":"وَلَا","translation":"কিন্তু না","audioUrl":"wbw/007_031_011.mp3","charTypeName":"word"},{"id":34306,"position":11,"arabic":"تُسْرِفُوٓا۟ ۚ","translation":"তোমরা সীমালঙ্ঘন করো","audioUrl":"wbw/007_031_012.mp3","charTypeName":"word"},{"id":34308,"position":12,"arabic":"إِنَّهُۥ","translation":"নিশ্চয়ই তিনি","audioUrl":"wbw/007_031_014.mp3","ch