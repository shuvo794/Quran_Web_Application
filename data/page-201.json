{"id":201,"ayahs":[{"number":87,"arabic":"رَضُوا۟ بِأَن يَكُونُوا۟ مَعَ ٱلْخَوَالِفِ وَطُبِعَ عَلَىٰ قُلُوبِهِمْ فَهُمْ لَا يَفْقَهُونَ","translation":"They were well-pleased to remain with those who were left behind - where for their hearts have been sealed, so that they cannot grasp the truth.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1322.mp3","surahId":9,"words":[{"id":66995,"position":1,"arabic":"رَضُوا۟","translation":"তারা পছন্দ করেছে","audioUrl":"wbw/009_087_001.mp3","charTypeName":"word"},{"id":66996,"position":2,"arabic":"بِأَن","translation":"নিয়ে যে","audioUrl":"wbw/009_087_002.mp3","charTypeName":"word"},{"id":66997,"position":3,"arabic":"يَكُونُوا۟","translation":"তারা থাকবে","audioUrl":"wbw/009_087_003.mp3","charTypeName":"word"},{"id":66998,"position":4,"arabic":"مَعَ","translation":"সাথে","audioUrl":"wbw/009_087_004.mp3","charTypeName":"word"},{"id":66999,"position":5,"arabic":"ٱلْخَوَالِفِ","translation":"অন্তঃপুরবাসিনীদের","audioUrl":"wbw/009_087_005.mp3","charTypeName":"word"},{"id":67000,"position":6,"arabic":"وَطُبِعَ","translation":"ও সীল করা হয়েছে","audioUrl":"wbw/009_087_006.mp3","charTypeName":"word"},{"id":67001,"position":7,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/009_087_007.mp3","charTypeName":"word"},{"id":67002,"position":8,"arabic":"قُلُوبِهِمْ","translation":"অন্তরসমূহের তাদের","audioUrl":"wbw/009_087_008.mp3","charTypeName":"word"},{"id":67003,"position":9,"arabic":"فَهُمْ","translation":"অতএব তারা","audioUrl":"wbw/009_087_009.mp3","charTypeName":"word"},{"id":67004,"position":10,"arabic":"لَا","translation":"না","audioUrl":"wbw/009_087_010.mp3","charTypeName":"word"},{"id":67005,"position":11,"arabic":"يَفْقَهُونَ","translation":"তারা বুঝে","audioUrl":"wbw/009_087_011.mp3","charTypeName":"word"},{"id":67006,"position":12,"arabic":"٨٧","translation":"(৮৭)","audioUrl":null,"charTypeName":"end"}]},{"number":88,"arabic":"لَٰكِنِ ٱلرَّسُولُ وَٱلَّذِينَ ءَامَنُوا۟ مَعَهُۥ جَٰهَدُوا۟ بِأَمْوَٰلِهِمْ وَأَنفُسِهِمْ ۚ وَأُو۟لَٰٓئِكَ لَهُمُ ٱلْخَيْرَٰتُ ۖ وَأُو۟لَٰٓئِكَ هُمُ ٱلْمُفْلِحُونَ","translation":"The Apostle, however, and all who share his faith strive hard [in God's cause] with, their possessions and their lives: and it is they whom the most excellent things await [in the life to come], and it is they, they who shall attain to a happy state!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1323.mp3","surahId":9,"words":[{"id":67093,"position":1,"arabic":"لَـٰكِنِ","translation":"কিন্তু","audioUrl":"wbw/009_088_001.mp3","charTypeName":"word"},{"id":67094,"position":2,"arabic":"ٱلرَّسُولُ","translation":"রাসূল","audioUrl":"wbw/009_088_002.mp3","charTypeName":"word"},{"id":67095,"position":3,"arabic":"وَٱلَّذِينَ","translation":"ও যারা","audioUrl":"wbw/009_088_003.mp3","charTypeName":"word"},{"id":67096,"position":4,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছে","audioUrl":"wbw/009_088_004.mp3","charTypeName":"word"},{"id":67097,"position":5,"arabic":"مَعَهُۥ","translation":"সাথে তার","audioUrl":"wbw/009_088_005.mp3","charTypeName":"word"},{"id":67098,"position":6,"arabic":"جَـٰهَدُوا۟","translation":"জিহাদ করেছে","audioUrl":"wbw/009_088_006.mp3","charTypeName":"word"},{"id":67099,"position":7,"arabic":"بِأَمْوَٰلِهِمْ","translation":"দিয়ে ধনসম্পদ তাদের","audioUrl":"wbw/009_088_007.mp3","charTypeName":"word"},{"id":67100,"position":8,"arabic":"وَأَنفُسِهِمْ ۚ","translation":"ও প্রাণ (দিয়ে)তাদের","audioUrl":"wbw/009_088_008.mp3","charTypeName":"word"},{"id":67102,"position":9,"arabic":"وَأُو۟لَـٰٓئِكَ","translation":"ও ঐসব লোক","audioUrl":"wbw/009_088_010.mp3","charTypeName":"word"},{"id":67103,"position":10,"arabic":"لَهُمُ","translation":"জন্যে তাদের (রয়েছে)","audioUrl":"wbw/009_088_011.mp3","charTypeName":"word"},{"id":67104,"position":11,"arabic":"ٱلْخَيْرَٰتُ ۖ","translation":"সব কল্যাণ","audioUrl":"wbw/009_088_012.mp3","charTypeName":"word"},{"id":67106,"position":12,"arabic":"وَأُو۟لَـٰٓئِكَ","translation":"ও ঐসব লোক","audioUrl":"wbw/009_088_014.mp3","charTypeName":"word"},{"id":67107,"position":13,"arabic":"هُمُ","translation":"তারাই","audioUrl":"wbw/009_088_015.mp3","charTypeName":"word"},{"id":67108,"position":14,"arabic":"ٱلْمُفْلِحُونَ","translation":"সফলকাম","audioUrl":"wbw/009_088_016.mp3","charTypeName":"word"},{"id":67109,"position":15,"arabic":"٨٨","translation":"(৮৮)","audioUrl":null,"charTypeName":"end"}]},{"number":89,"arabic":"أَعَدَّ ٱللَّهُ لَهُمْ جَنَّٰتٍۢ تَجْرِى مِن تَحْتِهَا ٱلْأَنْهَٰرُ خَٰلِدِينَ فِيهَا ۚ ذَٰلِكَ ٱلْفَوْزُ ٱلْعَظِيمُ","translation":"God has readied for them gardens through which running waters flow, therein to abide: and this is the triumph supreme!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1324.mp3","surahId":9,"words":[{"id":67801,"position":1,"arabic":"أَعَدَّ","translation":"প্রস্তুত করে রেখেছেন","audioUrl":"wbw/009_089_001.mp3","charTypeName":"word"},{"id":67802,"position":2,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/009_089_002.mp3","charTypeName":"word"},{"id":67803,"position":3,"arabic":"لَهُمْ","translation":"জন্যে তাদের","audioUrl":"wbw/009_089_003.mp3","charTypeName":"word"},{"id":67804,"position":4,"arabic":"جَنَّـٰتٍۢ","translation":"জান্নাত","audioUrl":"wbw/009_089_004.mp3","charTypeName":"word"},{"id":67805,"position":5,"arabic":"تَجْرِى","translation":"প্রবাহিত হয়","audioUrl":"wbw/009_089_005.mp3","charTypeName":"word"},{"id":67806,"position":6,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/009_089_006.mp3","charTypeName":"word"},{"id":67807,"position":7,"arabic":"تَحْتِهَا","translation":"নিচ তার","audioUrl":"wbw/009_089_007.mp3","charTypeName":"word"},{"id":67808,"position":8,"arabic":"ٱلْأَنْهَـٰرُ","translation":"ঝর্ণাধারা","audioUrl":"wbw/009_089_008.mp3","charTypeName":"word"},{"id":67809,"position":9,"arabic":"خَـٰلِدِينَ","translation":"তারা চিরিস্থায়ী হবে","audioUrl":"wbw/009_089_009.mp3","charTypeName":"word"},{"id":67810,"position":10,"arabic":"فِيهَا ۚ","translation":"মধ্যে তার","audioUrl":"wbw/009_089_010.mp3","charTypeName":"word"},{"id":67812,"position":11,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/009_089_012.mp3","charTypeName":"word"},{"id":67813,"position":12,"arabic":"ٱلْفَوْزُ","translation":"সাফল্য","audioUrl":"wbw/009_089_013.mp3","charTypeName":"word"},{"id":67814,"position":13,"arabic":"ٱلْعَظِيمُ","translation":"মহা","audioUrl":"wbw/009_089_014.mp3","charTypeName":"word"},{"id":67815,"position":14,"arabic":"٨٩","translation":"(৮৯)","audioUrl":null,"charTypeName":"end"}]},{"number":90,"arabic":"وَجَآءَ ٱلْمُعَذِّرُونَ مِنَ ٱلْأَعْرَابِ لِيُؤْذَنَ لَهُمْ وَقَعَدَ ٱلَّذِينَ كَذَبُوا۟ ٱللَّهَ وَرَسُولَهُۥ ۚ سَيُصِيبُ ٱلَّذِينَ كَفَرُوا۟ مِنْهُمْ عَذَابٌ أَلِيمٌۭ","translation":"AND THERE came [unto the Apostle] such of the bedouin as had some excuse to offer, [with the request] that they be granted exemption, whereas those who were bent on giving the lie to God and His Apostle [simply] remained at home. [And] grievous suffering is bound to befall such of them as are bent on denying the truth!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1325.mp3","surahId":9,"words":[{"id":68159,"position":1,"arabic":"وَجَآءَ","translation":"এবং আসলো","audioUrl":"wbw/009_090_001.mp3","charTypeName":"word"},{"id":68160,"position":2,"arabic":"ٱلْمُعَذِّرُونَ","translation":"অজুহাত পেশকারীরা","audioUrl":"wbw/009_090_002.mp3","charTypeName":"word"},{"id":68161,"position":3,"arabic":"مِنَ","translation":"মধ্যে হতে","audioUrl":"wbw/009_090_003.mp3","charTypeName":"word"},{"id":68162,"position":4,"arabic":"ٱلْأَعْرَابِ","translation":"বেদুঈনদের","audioUrl":"wbw/009_090_004.mp3","charTypeName":"word"},{"id":68163,"position":5,"arabic":"لِيُؤْذَنَ","translation":"অব্যাহতি দেয়া হয়","audioUrl":"wbw/009_090_005.mp3","charTypeName":"word"},{"id":68164,"position":6,"arabic":"لَهُمْ","translation":"জন্যে তাদের","audioUrl":"wbw/009_090_006.mp3","charTypeName":"word"},{"id":68165,"position":7,"arabic":"وَقَعَدَ","translation":"এবং (এভা