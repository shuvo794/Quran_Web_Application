{"id":159,"ayahs":[{"number":68,"arabic":"أُبَلِّغُكُمْ رِسَٰلَٰتِ رَبِّى وَأَنَا۠ لَكُمْ نَاصِحٌ أَمِينٌ","translation":"I am delivering unto you my Sustainer's messages and advising you truly and wells.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1022.mp3","surahId":7,"words":[{"id":58521,"position":1,"arabic":"أُبَلِّغُكُمْ","translation":"আমি পৌঁছাই তোমাদেরকে","audioUrl":"wbw/007_068_001.mp3","charTypeName":"word"},{"id":58522,"position":2,"arabic":"رِسَـٰلَـٰتِ","translation":"রিসালাত (বাণী)সমূহ","audioUrl":"wbw/007_068_002.mp3","charTypeName":"word"},{"id":58523,"position":3,"arabic":"رَبِّى","translation":"আমার রবের","audioUrl":"wbw/007_068_003.mp3","charTypeName":"word"},{"id":58524,"position":4,"arabic":"وَأَنَا۠","translation":"এবং আমি","audioUrl":"wbw/007_068_004.mp3","charTypeName":"word"},{"id":58525,"position":5,"arabic":"لَكُمْ","translation":"জন্যে তোমাদের","audioUrl":"wbw/007_068_005.mp3","charTypeName":"word"},{"id":58526,"position":6,"arabic":"نَاصِحٌ","translation":"হিতাকাঙ্খী","audioUrl":"wbw/007_068_006.mp3","charTypeName":"word"},{"id":58527,"position":7,"arabic":"أَمِينٌ","translation":"বিশ্বস্ত","audioUrl":"wbw/007_068_007.mp3","charTypeName":"word"},{"id":58528,"position":8,"arabic":"٦٨","translation":"(৬৮)","audioUrl":null,"charTypeName":"end"}]},{"number":69,"arabic":"أَوَعَجِبْتُمْ أَن جَآءَكُمْ ذِكْرٌۭ مِّن رَّبِّكُمْ عَلَىٰ رَجُلٍۢ مِّنكُمْ لِيُنذِرَكُمْ ۚ وَٱذْكُرُوٓا۟ إِذْ جَعَلَكُمْ خُلَفَآءَ مِنۢ بَعْدِ قَوْمِ نُوحٍۢ وَزَادَكُمْ فِى ٱلْخَلْقِ بَصْۜطَةًۭ ۖ فَٱذْكُرُوٓا۟ ءَالَآءَ ٱللَّهِ لَعَلَّكُمْ تُفْلِحُونَ","translation":"Why, do you deem it strange that a tiding from your Sustainer should have come unto you through a man from among yourselves, so that he might warn you? Do but remember how He made you heirs to Noah's people, and endowed you abundantly with power: remember, then, God's blessings, so that you might attain to a happy state!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1023.mp3","surahId":7,"words":[{"id":58876,"position":1,"arabic":"أَوَعَجِبْتُمْ","translation":"কি তোমরা অবাক হয়েছো","audioUrl":"wbw/007_069_001.mp3","charTypeName":"word"},{"id":58877,"position":2,"arabic":"أَن","translation":"যে","audioUrl":"wbw/007_069_002.mp3","charTypeName":"word"},{"id":58878,"position":3,"arabic":"جَآءَكُمْ","translation":"কাছে এসেছে তোমাদের","audioUrl":"wbw/007_069_003.mp3","charTypeName":"word"},{"id":58879,"position":4,"arabic":"ذِكْرٌۭ","translation":"উপদেশ","audioUrl":"wbw/007_069_004.mp3","charTypeName":"word"},{"id":58880,"position":5,"arabic":"مِّن","translation":"পক্ষ হতে","audioUrl":"wbw/007_069_005.mp3","charTypeName":"word"},{"id":58881,"position":6,"arabic":"رَّبِّكُمْ","translation":"রবের তোমাদের","audioUrl":"wbw/007_069_006.mp3","charTypeName":"word"},{"id":58882,"position":7,"arabic":"عَلَىٰ","translation":"মাধ্যমে","audioUrl":"wbw/007_069_007.mp3","charTypeName":"word"},{"id":58883,"position":8,"arabic":"رَجُلٍۢ","translation":"একজন ব্যক্তির","audioUrl":"wbw/007_069_008.mp3","charTypeName":"word"},{"id":58884,"position":9,"arabic":"مِّنكُمْ","translation":"মধ্যকার তোমাদেরই","audioUrl":"wbw/007_069_009.mp3","charTypeName":"word"},{"id":58885,"position":10,"arabic":"لِيُنذِرَكُمْ ۚ","translation":"যেন সতর্ক করে তোমাদেরকে","audioUrl":"wbw/007_069_010.mp3","charTypeName":"word"},{"id":58887,"position":11,"arabic":"وَٱذْكُرُوٓا۟","translation":"এবং তোমরা স্মরণ করো","audioUrl":"wbw/007_069_012.mp3","charTypeName":"word"},{"id":58888,"position":12,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/007_069_013.mp3","charTypeName":"word"},{"id":58889,"position":13,"arabic":"جَعَلَكُمْ","translation":"তিনি করেছিলেন তোমাদের","audioUrl":"wbw/007_069_014.mp3","charTypeName":"word"},{"id":58890,"position":14,"arabic":"خُلَفَآءَ","translation":"স্থলাভিষিক্ত","audioUrl":"wbw/007_069_015.mp3","charTypeName":"word"},{"id":58891,"position":15,"arabic":"مِنۢ","translation":"থেকে","audioUrl":"wbw/007_069_016.mp3","charTypeName":"word"},{"id":58892,"position":16,"arabic":"بَعْدِ","translation":"পর","audioUrl":"wbw/007_069_017.mp3","charTypeName":"word"},{"id":58893,"position":17,"arabic":"قَوْمِ","translation":"জাতির","audioUrl":"wbw/007_069_018.mp3","charTypeName":"word"},{"id":58894,"position":18,"arabic":"نُوحٍۢ","translation":"নূহের","audioUrl":"wbw/007_069_019.mp3","charTypeName":"word"},{"id":58895,"position":19,"arabic":"وَزَادَكُمْ","translation":"ও বাড়িয়ে দিয়েছিলেন তোমাদেরকে","audioUrl":"wbw/007_069_020.mp3","charTypeName":"word"},{"id":58896,"position":20,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/007_069_021.mp3","charTypeName":"word"},{"id":58897,"position":21,"arabic":"ٱلْخَلْقِ","translation":"সৃষ্টির","audioUrl":"wbw/007_069_022.mp3","charTypeName":"word"},{"id":58898,"position":22,"arabic":"بَصْۜطَةًۭ ۖ","translation":"(শক্তির) প্রাচুর্য","audioUrl":"wbw/007_069_023.mp3","charTypeName":"word"},{"id":58900,"position":23,"arabic":"فَٱذْكُرُوٓا۟","translation":"অতএব তোমরা স্মরণ করো","audioUrl":"wbw/007_069_025.mp3","charTypeName":"word"},{"id":58901,"position":24,"arabic":"ءَالَآءَ","translation":"অনুগ্রহসমূহের","audioUrl":"wbw/007_069_026.mp3","charTypeName":"word"},{"id":58902,"position":25,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/007_069_027.mp3","charTypeName":"word"},{"id":58903,"position":26,"arabic":"لَعَلَّكُمْ","translation":"হয়ত তোমরা","audioUrl":"wbw/007_069_028.mp3","charTypeName":"word"},{"id":58904,"position":27,"arabic":"تُفْلِحُونَ","translation":"সফলকাম হবে\"","audioUrl":"wbw/007_069_029.mp3","charTypeName":"word"},{"id":58905,"position":28,"arabic":"٦٩","translation":"(৬৯)","audioUrl":null,"charTypeName":"end"}]},{"number":70,"arabic":"قَالُوٓا۟ أَجِئْتَنَا لِنَعْبُدَ ٱللَّهَ وَحْدَهُۥ وَنَذَرَ مَا كَانَ يَعْبُدُ ءَابَآؤُنَا ۖ فَأْتِنَا بِمَا تَعِدُنَآ إِن كُنتَ مِنَ ٱلصَّٰدِقِينَ","translation":"They answered: \"Hast thou come to us [with the demand] that we worship God alone, and give up all that our forefathers were wont to worship? Bring about, then, that [punishment] with which thou hast threatened us, if thou art a man of truth!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1024.mp3","surahId":7,"words":[{"id":59569,"position":1,"arabic":"قَالُوٓا۟","translation":"তারা বললো","audioUrl":"wbw/007_070_001.mp3","charTypeName":"word"},{"id":59570,"position":2,"arabic":"أَجِئْتَنَا","translation":"\"কি তুমি এসেছো কাছে আমাদের","audioUrl":"wbw/007_070_002.mp3","charTypeName":"word"},{"id":59571,"position":3,"arabic":"لِنَعْبُدَ","translation":"যেন আমরা ইবাদত করি","audioUrl":"wbw/007_070_003.mp3","charTypeName":"word"},{"id":59572,"position":4,"arabic":"ٱللَّهَ","translation":"আল্লাহর","audioUrl":"wbw/007_070_004.mp3","charTypeName":"word"},{"id":59573,"position":5,"arabic":"وَحْدَهُۥ","translation":"এবং তাঁর একারই","audioUrl":"wbw/007_070_005.mp3","charTypeName":"word"},{"id":59574,"position":6,"arabic":"وَنَذَرَ","translation":"ত্যাগ করি (অন্য সবকিছু)","audioUrl":"wbw/007_070_006.mp3","charTypeName":"word"},{"id":59575,"position":7,"arabic":"مَا","translation":"যার","audioUrl":"wbw/007_070_007.mp3","charTypeName":"word"},{"id":59576,"position":8,"arabic":"كَانَ","translation":"ছিলো","audioUrl":"wbw/007_070_008.mp3","charTypeName":"word"},{"id":59577,"position":9,"arabic":"يَعْبُدُ","translation":"ইবাদত করতে","audioUrl":"wbw/007_070_009.mp3","charTypeName":"word"},{"id":59578,"position":10,"arabic":"ءَابَآؤُنَا ۖ","translation":"পূর্বপুরুষরা আমাদের","audioUrl":"wbw/007_070_010.mp3","charTypeName":"word"},{"id":59580,"position":11,"arabic":"فَأْتِنَا","translation":"সুতরাং এসো কাছে আমাদের","audioUrl":"wbw/007_070_012.mp3","charTypeName":"word"},{"id":59581,"position":12,"arabic":"بِمَا","translation":"নিয়ে ঐসব যা","audioUrl":"wbw/007_070_013.mp3","charTypeName":"word"},{"id":59582,"position":13,"arabic":"تَعِدُنَآ","translation":"তুমি ভয় দেখাচ্ছো আমাদেরকে","audioUrl":"wbw/007_070_014.mp3","charTypeName":"word"},{"id":59583,"position":14,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/007_070_015.mp3","charTypeName":"word"},{"id":59584,"position":15,"arabic":"كُنتَ","translation":"হও তুমি","audioUrl":"wbw/007_070_016.mp3","charTypeName":"word"},{"id":59585,"position":16,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/007_070_017.mp3","charTypeName":"word"},{"id":59586,"position":17,"arabic":"ٱلصَّـٰدِقِينَ","translation":"সত্যবাদীদের\"","audioUrl":"wbw/007_070_018.mp3","charTypeName":"word"},{"id":59587,"position":18,"arabic":"٧٠","translation":"(৭০)","audioUrl":null,"charTypeName":"end"}]},{"number":71,"arabic":"قَالَ قَدْ وَقَعَ عَلَيْكُم مِّن رَّبِّكُمْ رِجْسٌۭ وَغَضَبٌ ۖ أَتُجَٰدِلُونَنِى فِىٓ أَسْمَآءٍۢ سَمَّيْتُمُوهَآ أَنتُمْ وَءَابَآؤُكُم مَّا نَزَّلَ ٱللَّهُ بِهَا مِن سُلْطَٰنٍۢ ۚ فَٱنتَظِرُوٓا۟ إِنِّى مَعَكُم مِّنَ ٱلْمُنتَظِرِينَ","translation":"Said [Hud]: \"You are already beset by loath some evils and by your Sustainer's condemnation! Do you argue with me about the [empty] names which you have invented - you and your forefathers - for which God has bestowed no warrant from on high? Wait, then, [for what will happen:] verily, I shall wait with you!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1025.mp3","surahId":7,"words":[{"id":60298,"position":1,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/007_071_001.mp3","charTypeName":"word"},{"id":60299,"position":2,"arabic":"قَدْ","translation":"\"নিশ্চয়ই","audioUrl":"wbw/007_071_002.mp3","charTypeName":"word"},{"id":60300,"position":3,"arabic":"وَقَعَ","translation":"পড়েছে","audioUrl":"wbw/007_071_003.mp3","charTypeName":"word"},{"id":60301,"position":4,"arabic":"عَلَيْكُم","translation":"উপর তোমাদের","audioUrl":"wbw/007_071_004.mp3","charTypeName":"word"},{"id":60302,"position":5,"arabic":"مِّن","translation":"পক্ষ হতে","audioUrl":"wbw/007_071_005.mp3","charTypeName":"word"},{"id":60303,"position":6,"arabic":"رَّبِّكُمْ","translation":"রবের তোমাদের","audioUrl":"wbw/007_071_006.mp3","charTypeName":"word"},{"id":60304,"position":7,"ar