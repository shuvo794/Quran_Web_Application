:"তাদেরই ভাই","audioUrl":"wbw/007_073_003.mp3","charTypeName":"word"},{"id":61196,"position":4,"arabic":"صَـٰلِحًۭا ۗ","translation":"সালেহ-কে (পাঠিয়েছিলাম)","audioUrl":"wbw/007_073_004.mp3","charTypeName":"word"},{"id":61198,"position":5,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/007_073_006.mp3","charTypeName":"word"},{"id":61199,"position":6,"arabic":"يَـٰقَوْمِ","translation":"\"হে আমার জাতি","audioUrl":"wbw/007_073_007.mp3","charTypeName":"word"},{"id":61200,"position":7,"arabic":"ٱعْبُدُوا۟","translation":"তোমরা ইবাদত করো","audioUrl":"wbw/007_073_008.mp3","charTypeName":"word"},{"id":61201,"position":8,"arabic":"ٱللَّهَ","translation":"আল্লাহর","audioUrl":"wbw/007_073_009.mp3","charTypeName":"word"},{"id":61202,"position":9,"arabic":"مَا","translation":"নেই","audioUrl":"wbw/007_073_010.mp3","charTypeName":"word"},{"id":61203,"position":10,"arabic":"لَكُم","translation":"জন্যে তোমাদের","audioUrl":"wbw/007_073_011.mp3","charTypeName":"word"},{"id":61204,"position":11,"arabic":"مِّنْ","translation":"কোনো","audioUrl":"wbw/007_073_012.mp3","charTypeName":"word"},{"id":61205,"position":12,"arabic":"إِلَـٰهٍ","translation":"ইলাহ","audioUrl":"wbw/007_073_013.mp3","charTypeName":"word"},{"id":61206,"position":13,"arabic":"غَيْرُهُۥ ۖ","translation":"ছাড়া তিনি","audioUrl":"wbw/007_073_014.mp3","charTypeName":"word"},{"id":61208,"position":14,"arabic":"قَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/007_073_016.mp3","charTypeName":"word"},{"id":61209,"position":15,"arabic":"جَآءَتْكُم","translation":"কাছে এসেছে তোমাদের","audioUrl":"wbw/007_073_017.mp3","charTypeName":"word"},{"id":61210,"position":16,"arabic":"بَيِّنَةٌۭ","translation":"সুস্পষ্ট প্রমাণ","audioUrl":"wbw/007_073_018.mp3","charTypeName":"word"},{"id":61211,"position":17,"arabic":"مِّن","translation":"পক্ষ হতে","audioUrl":"wbw/007_073_019.mp3","charTypeName":"word"},{"id":61212,"position":18,"arabic":"رَّبِّكُمْ ۖ","translation":"রবের তোমাদের","audioUrl":"wbw/007_073_020.mp3","charTypeName":"w