102_052.mp3","charTypeName":"word"},{"id":72078,"position":51,"arabic":"مَّرْضَىٰٓ","translation":"অসুস্থ","audioUrl":"wbw/004_102_053.mp3","charTypeName":"word"},{"id":72079,"position":52,"arabic":"أَن","translation":"(যে)","audioUrl":"wbw/004_102_054.mp3","charTypeName":"word"},{"id":72080,"position":53,"arabic":"تَضَعُوٓا۟","translation":"তোমাদের সংবরণ করায়","audioUrl":"wbw/004_102_055.mp3","charTypeName":"word"},{"id":72081,"position":54,"arabic":"أَسْلِحَتَكُمْ ۖ","translation":"তোমাদের অস্ত্রশস্ত্র","audioUrl":"wbw/004_102_056.mp3","charTypeName":"word"},{"id":72083,"position":55,"arabic":"وَخُذُوا۟","translation":"কিন্তু তোমরা অবলম্বন করবে","audioUrl":"wbw/004_102_058.mp3","charTypeName":"word"},{"id":72084,"position":56,"arabic":"حِذْرَكُمْ ۗ","translation":"তোমাদের সতর্কতা","audioUrl":"wbw/004_102_059.mp3","charTypeName":"word"},{"id":72086,"position":57,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/004_102_061.mp3","charTypeName":"word"},{"id":72087,"position":58,"arabic":"ٱللَّهَ","translation":"আল্লাহ্‌","audioUrl":"wbw/004_102_062.mp3","charTypeName":"word"},{"id":72088,"position":59,"arabic":"أَعَدَّ","translation":"প্রস্তুত করে রেখেছেন","audioUrl":"wbw/004_102_063.mp3","charTypeName":"word"},{"id":72089,"position":60,"arabic":"لِلْكَـٰفِرِينَ","translation":"কাফিরদের জন্য","audioUrl":"wbw/004_102_064.mp3","charTypeName":"word"},{"id":72090,"position":61,"arabic":"عَذَابًۭا","translation":"আজাব","audioUrl":"wbw/004_102_065.mp3","charTypeName":"word"},{"id":72091,"position":62,"arabic":"مُّهِينًۭا","translation":"লাঞ্ছনাকর","audioUrl":"wbw/004_102_066.mp3","charTypeName":"word"},{"id":72092,"position":63,"arabic":"١٠٢","translation":"(১০২)","audioUrl":null,"charTypeName":"end"}]},{"number":103,"arabic":"فَإِذَا قَضَيْتُمُ ٱلصَّلَوٰةَ فَٱذْكُرُوا۟ ٱللَّهَ قِيَٰمًۭا وَقُعُودًۭا وَعَلَىٰ جُنُوبِكُمْ ۚ فَإِذَا ٱطْمَأْنَنتُمْ فَأَقِيمُوا۟ ٱلصَّلَوٰةَ ۚ إِنَّ ٱلصَّلَوٰةَ كَانَتْ عَلَى ٱلْمُؤْمِنِينَ كِتَٰبًۭا مَّوْقُوتًۭا","translation":"And when you have finished your prayer, remember God - standing and sitting and lying down; and when you are once again secure, observe your prayers [fully]. Verily, for all believers prayer is indeed a sacred duty linked to particular times [of day].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/596.mp3","surahId":4,"words":[{"id":72201,"position":1,"arabic":"فَإِذَا","translation":"অতঃপর যখন","audioUrl":"wbw/004_103_001.mp3","charTypeName":"word"},{"id":72202,"position":2,"arabic":"قَضَيْتُمُ","translation":"তোমরা সমাপ্ত কর","audioUrl":"wbw/004_103_002.mp3","charTypeName":"word"},{"id":72203,"position":3,"arabic":"ٱلصَّلَوٰةَ","translation":"সলাত","audioUrl":"wbw/004_103_003.mp3","charTypeName":"word"},{"id":72204,"position":4,"arabic":"فَٱذْكُرُوا۟","translation":"তোমরা তখন স্মরণ কর","audioUrl":"wbw/004_103_004.mp3","charTypeName":"word"},{"id":72205,"position":5,"arabic":"ٱللَّهَ","translation":"আল্লাহকে","audioUrl":"wbw/004_103_005.mp3","charTypeName":"word"},{"id":72206,"position":6,"arabic":"قِيَـٰمًۭا","translation":"দাঁড়িয়ে","audioUrl":"wbw/004_103_006.mp3","charTypeName":"word"},{"id":72207,"position":7,"arabic":"وَقُعُودًۭا","translation":"ও বসে","audioUrl":"wbw/004_103_007.mp3","charTypeName":"word"},{"id":72208,"position":8,"arabic":"وَعَلَىٰ","translation":"ও উপর","audioUrl":"wbw/004_103_008.mp3","charTypeName":"word"},{"id":72209,"position":9,"arabic":"جُنُوبِكُمْ ۚ","translation":"তোমাদের পাশগুলোর (অর্থাৎ শুয়ে)","audioUrl":"wbw/004_103_009.mp3","charTypeName":"word"},{"id":72211,"position":10,"arabic":"فَإِذَا","translation":"যখন অতঃপর","audioUrl":"wbw/004_103_011.mp3","charTypeName":"word"},{"id":72212,"position":11,"arabic":"ٱطْمَأْنَنتُمْ","translation":"তোমরা নিরাপদ হও","audioUrl":"wbw/004_103_012.mp3","charTypeName":"word"},{"id":72213,"position":12,"arabic":"فَأَقِيمُوا۟","translation":"তোমরা তখন কায়েম কর","audioUrl":"wbw/004_103_013.mp3","charTypeName":"word"},{"id":72214,"position":13,"arabic":"ٱلصَّلَوٰةَ ۚ","translation":"সলাত","au