{"id":215,"ayahs":[{"number":54,"arabic":"وَلَوْ أَنَّ لِكُلِّ نَفْسٍۢ ظَلَمَتْ مَا فِى ٱلْأَرْضِ لَٱفْتَدَتْ بِهِۦ ۗ وَأَسَرُّوا۟ ٱلنَّدَامَةَ لَمَّا رَأَوُا۟ ٱلْعَذَابَ ۖ وَقُضِىَ بَيْنَهُم بِٱلْقِسْطِ ۚ وَهُمْ لَا يُظْلَمُونَ","translation":"And all human beings that have been doing evil's would surely, if they possessed all that is on earth, offer it as ransom [on Judgment Day]; and when they see the suffering [that awaits them], they will be unable to express their remorse. But judgment will be passed on them in all equity; and they will not be wronged.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1418.mp3","surahId":10,"words":[{"id":50996,"position":1,"arabic":"وَلَوْ","translation":"এবং যদি (এমন হতো)","audioUrl":"wbw/010_054_001.mp3","charTypeName":"word"},{"id":50997,"position":2,"arabic":"أَنَّ","translation":"অবশ্যই","audioUrl":"wbw/010_054_002.mp3","charTypeName":"word"},{"id":50998,"position":3,"arabic":"لِكُلِّ","translation":"জন্যে প্রত্যেক","audioUrl":"wbw/010_054_003.mp3","charTypeName":"word"},{"id":50999,"position":4,"arabic":"نَفْسٍۢ","translation":"ব্যক্তির","audioUrl":"wbw/010_054_004.mp3","charTypeName":"word"},{"id":51000,"position":5,"arabic":"ظَلَمَتْ","translation":"(যে) সীমালঙ্ঘন করেছে","audioUrl":"wbw/010_054_005.mp3","charTypeName":"word"},{"id":51001,"position":6,"arabic":"مَا","translation":"যা কিছু","audioUrl":"wbw/010_054_006.mp3","charTypeName":"word"},{"id":51002,"position":7,"arabic":"فِى","translation":"মধ্যে (আছে)","audioUrl":"wbw/010_054_007.mp3","charTypeName":"word"},{"id":51003,"position":8,"arabic":"ٱلْأَرْضِ","translation":"পৃথিবীর (সব তারই)","audioUrl":"wbw/010_054_008.mp3","charTypeName":"word"},{"id":51004,"position":9,"arabic":"لَٱفْتَدَتْ","translation":"অবশ্যই মুক্তিপণ হিসেবে দিতো(বাঁচার জন্য)","audioUrl":"wbw/010_054_009.mp3","charTypeName":"word"},{"id":51005,"position":10,"arabic":"بِهِۦ ۗ","translation":"দিয়ে তা","audioUrl":"wbw/010_054_010.mp3","charTypeName":"word"},{"id":51007,"position":11,"arabic":"وَأَسَرُّوا۟","translation":"এবং তারা গোপনে করবে","audioUrl":"wbw/010_054_012.mp3","charTypeName":"word"},{"id":51008,"position":12,"arabic":"ٱلنَّدَامَةَ","translation":"অনুতাপ","audioUrl":"wbw/010_054_013.mp3","charTypeName":"word"},{"id":51009,"position":13,"arabic":"لَمَّا","translation":"যখন","audioUrl":"wbw/010_054_014.mp3","charTypeName":"word"},{"id":51010,"position":14,"arabic":"رَأَوُا۟","translation":"দেখবে","audioUrl":"wbw/010_054_015.mp3","charTypeName":"word"},{"id":51011,"position":15,"arabic":"ٱلْعَذَابَ ۖ","translation":"শাস্তি","audioUrl":"wbw/010_054_016.mp3","charTypeName":"word"},{"id":51013,"position":16,"arabic":"وَقُضِىَ","translation":"এবং মীমাংসা করা হবে","audioUrl":"wbw/010_054_018.mp3","charTypeName":"word"},{"id":51014,"position":17,"arabic":"بَيْنَهُم","translation":"মাঝে তাদের","audioUrl":"wbw/010_054_019.mp3","charTypeName":"word"},{"id":51015,"position":18,"arabic":"بِٱلْقِسْطِ ۚ","translation":"সাথে ন্যায়বিচারের","audioUrl":"wbw/010_054_020.mp3","charTypeName":"word"},{"id":51017,"position":19,"arabic":"وَهُمْ","translation":"এবং তাদের (উপর)","audioUrl":"wbw/010_054_022.mp3","charTypeName":"word"},{"id":51018,"position":20,"arabic":"لَا","translation":"না","audioUrl":"wbw/010_054_023.mp3","charTypeName":"word"},{"id":51019,"position":21,"arabic":"يُظْلَمُونَ","translation":"অবিচার করা হবে","audioUrl":"wbw/010_054_024.mp3","charTypeName":"word"},{"id":51020,"position":22,"arabic":"٥٤","translation":"(৫৪)","audioUrl":null,"charTypeName":"end"}]},{"number":55,"arabic":"أَلَآ إِنَّ لِلَّهِ مَا فِى ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ ۗ أَلَآ إِنَّ وَعْدَ ٱللَّهِ حَقٌّۭ وَلَٰكِنَّ أَكْثَرَهُمْ لَا يَعْلَمُونَ","translation":"Oh, verily, unto God belongs all that is in the heavens and on earth! Oh, verily, God's promise always comes true-but most of them know it not!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1419.mp3","surahId":10,"words":[{"id":52009,"position":1,"arabic":"أَلَآ","translation":"সাবধান (শুনে রাখো)","audioUrl":"wbw/010_055_001.mp3","charTypeName":"word"},{"id":52010,"position":2,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/010_055_002.mp3","charTypeName":"word"},{"id":52011,"position":3,"arabic":"لِلَّهِ","translation":"জন্যে আল্লাহরই","audioUrl":"wbw/010_055_003.mp3","charTypeName":"word"},{"id":52012,"position":4,"arabic":"مَا","translation":"যাকিছু","audioUrl":"wbw/010_055_004.mp3","charTypeName":"word"},{"id":52013,"position":5,"arabic":"فِى","translation":"মধ্যে (আছে)","audioUrl":"wbw/010_055_005.mp3","charTypeName":"word"},{"id":52014,"position":6,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশসমূহের","audioUrl":"wbw/010_055_006.mp3","charTypeName":"word"},{"id":52015,"position":7,"arabic":"وَٱلْأَرْضِ ۗ","translation":"ও পৃথিবীর","audioUrl":"wbw/010_055_007.mp3","charTypeName":"word"},{"id":52017,"position":8,"arabic":"أَلَآ","translation":"সাবধান (শুনে রাখো)","audioUrl":"wbw/010_055_009.mp3","charTypeName":"word"},{"id":52018,"position":9,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/010_055_010.mp3","charTypeName":"word"},{"id":52019,"position":10,"arabic":"وَعْدَ","translation":"প্রতিশ্রুতি","audioUrl":"wbw/010_055_011.mp3","charTypeName":"word"},{"id":52020,"position":11,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/010_055_012.mp3","charTypeName":"word"},{"id":52021,"position":12,"arabic":"حَقٌّۭ","translation":"সত্য","audioUrl":"wbw/010_055_013.mp3","charTypeName":"word"},{"id":52022,"position":13,"arabic":"وَلَـٰكِنَّ","translation":"কিন্তু","audioUrl":"wbw/010_055_014.mp3","charTypeName":"word"},{"id":52023,"position":14,"arabic":"أَكْثَرَهُمْ","translation":"অধিকাংশই তাদের","audioUrl":"wbw/010_055_015.mp3","charTypeName":"word"},{"id":52024,"position":15,"arabic":"لَا","translation":"না","audioUrl":"wbw/010_055_016.mp3","charTypeName":"word"},{"id":52025,"position":16,"arabic":"يَعْلَمُونَ","translation":"তারা জানে","audioUrl":"wbw/010_055_017.mp3","charTypeName":"word"},{"id":52026,"position":17,"arabic":"٥٥","translation":"(৫৫)","audioUrl":null,"charTypeName":"end"}]},{"number":56,"arabic":"هُوَ يُحْىِۦ وَيُمِيتُ وَإِلَيْهِ تُرْجَعُونَ","translation":"He alone grants life and deals death; and unto Him you all must return.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1420.mp3","surahId":10,"words":[{"id":52550,"position":1,"arabic":"هُوَ","translation":"তিনিই","audioUrl":"wbw/010_056_001.mp3","charTypeName":"word"},{"id":52551,"position":2,"arabic":"يُحْىِۦ","translation":"জীবনদান করেন","audioUrl":"wbw/010_056_002.mp3","charTypeName":"word"},{"id":52552,"position":3,"arabic":"وَيُمِيتُ","translation":"ও মৃত্যু ঘটান","audioUrl":"wbw/010_056_003.mp3","charTypeName":"word"},{"id":52553,"position":4,"arabic":"وَإِلَيْهِ","translation":"এবং দিকে তাঁরই","audioUrl":"wbw/010_056_004.mp3","charTypeName":"word"},{"id":52554,"position":5,"arabic":"تُرْجَعُونَ","translation":"তোমরা প্রত্যাবর্তিত হবে","audioUrl":"wbw/010_056_005.mp3","charTypeName":"word"},{"id":52555,"position":6,"arabic":"٥٦","translation":"(৫৬)","audioUrl":null,"charTypeName":"end"}]},{"number":57,"arabic":"يَٰٓأَيُّهَا ٱلنَّاسُ قَدْ جَآءَتْكُم مَّوْعِظَةٌۭ مِّن رَّبِّكُمْ وَشِفَآءٌۭ لِّمَا فِى ٱلصُّدُورِ وَهُدًۭى وَرَحْمَةٌۭ لِّلْمُؤْمِنِينَ","translation":"O MANKIND! There has now come unto you an admonition from your Sustainer, and a cure for all [the ill] that may be in men's hearts, and guidance and grace unto all who believe [in Him].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1421.mp3","surahId":10,"words":[{"id":52962,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/010_057_001.mp3","charTypeName":"word"},{"id":52963,"position":2,"arabic":"ٱلنَّاسُ","translation":"মানব সমাজ","audioUrl":"wbw/010_057_002.mp3","charTypeName":"word"},{"id":52964,"position":3,"arabic":"قَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/010_057_003.mp3","charTypeName":"word"},{"id":52965,"position":4,"arabic":"جَآءَتْكُم","translation":"কাছে এসেছে তোমাদের","audioUrl":"wbw/010_057_004.mp3","charTypeName":"word"},{"id":52966,"position":5,"arabic":"مَّوْعِظَةٌۭ","translation":"উপদেশ","audioUrl":"wbw/010_057_005.mp3","charTypeName":"word"},{"id":52967,"position":6,"arabic":"مِّن","translation":"পক্ষ হতে","audioUrl":"wbw/010_057_006.mp3","charTypeName":"word"},{"id":52968,"position":7,"arabic":"رَّبِّكُمْ","translation":"রবের তোমাদের","audioUrl":"wbw/010_057_007.mp3","charTypeName":"word"},{"id":52969,"position":8,"arabic":"وَشِفَآءٌۭ","translation":"ও আরোগ্য","audioUrl":"wbw/010_057_008.mp3","charTypeName":"word"},{"id":52970,"position":9,"arabic":"لِّمَا","translation":"তার জন্যে যা","audioUrl":"wbw/010_057_009.mp3","charTypeName":"word"},{"id":52971,"position":10,"arabic":"فِى","translation":"মধ্যে (আছে)","audioUrl":"wbw/010_057_010.mp3","charTypeName":"word"},{"id":52972,"position":11,"arabic":"ٱلصُّدُورِ","translation":"অন্তরসমূহের","audioUrl":"wbw/010_057_011.mp3","charTypeName":"word"},{"id":52973,"position":12,"arabic":"وَهُدًۭى","translation":"এবং পথনির্দেশ","audioUrl":"wbw/010_057_012.mp3","charTypeName":"word"},{"id":52974,"position":13,"arabic":"وَرَحْمَةٌۭ","translation":"ও দয়া","audioUrl":"wbw/010_057_013.mp3","charTypeName":"word"},{"id":52975,"position":14,"arabic":"لِّلْمُؤْمِنِينَ","translation":"জন্য মু'মিনদের","audioUrl":"wbw/010_057_014.mp3","charTypeName":"word"},{"id":52976,"position":15,"arabic":"٥٧","translation":"(৫৭)","audioUrl":null,"charTypeName":"end"}]},{"number":58,"arabic":"قُلْ بِفَضْلِ ٱللَّهِ وَبِرَحْمَتِهِۦ فَبِذَٰلِكَ فَلْيَفْرَحُوا۟ هُوَ خَيْرٌۭ مِّمَّا يَجْمَعُونَ","translation":"Say: \"In [this] bounty of God and in His grace-in this, then, let them rejoice: it is better than all [the worldly wealth] that they may amass!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1422.mp3","surahId":10,"words":[{"id":53542,"position":1,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/010_058_001.mp3","charTypeName":"word"},{"id":53543,"position":2,"arabic":"بِفَضْلِ","translation":"\"মাধ্যমে অনুগ্রহের","audioUrl":"wbw/010_058_002.mp3","charTypeName":"word"},{"id":53544,"position":3,"arabic":"ٱللَّهِ","translation":"\"আল্লাহর","audioUrl":"wbw/010_058_003.mp3","charTypeName":"word"},{"id":53545,"position":4,"arabic":"وَبِرَحْمَتِهِۦ","translation":"ও মাধ্যমে দয়ার তাঁর (এটা পাঠিয়েছেন)","audioUrl":"wbw/010_058_004.mp3","charTypeName":"word"},{"id":53546,"position":5,"arabic":"فَبِذَٰلِكَ","translation":"সুতরা এজন্যে","audioUrl":"wbw/010_058_005.mp3","charTypeName":"word"},{"id":53547,"position":6,"arabic":"فَلْيَفْرَحُوا۟","translation":"অতএব তাদের আনন্দ করা উচিত\"","audioUrl":"wbw/010_058_006.mp3","charTypeName":"word"},{"id":53548,"position":7,"arabic":"هُوَ","translation":"এটা","audioUrl":"wbw/010_058_007.mp3","charTypeName":"word"},{"id":53549,"position":8,"arabic":"خَيْرٌۭ","translation":"উত্তম","audioUrl":"wbw/010_058_008.mp3","charTypeName":"word"},{"id":53550,"position":9,"arabic":"مِّمَّا","translation":"তা হতে যা","audioUrl":"wbw/010_058_009.mp3","charTypeName":"word"},{"id":53551,"position":10,"arabic":"يَجْمَعُونَ","translation":"তারা জমা করছে","audioUrl":"wbw/010_058_010.mp3","charTypeName":"word"},{"id":53552,"position":11,"arabic":"٥٨","translation":"(৫৮)","audioUrl":null,"charTypeName":"end"}]},{"number":59,"arabic":"قُلْ أَرَءَيْتُم مَّآ أَنزَلَ ٱللَّهُ لَكُم مِّن رِّزْقٍۢ فَجَعَلْتُم مِّنْهُ حَرَامًۭا وَحَلَٰلًۭا قُلْ ءَآللَّهُ أَذِنَ لَكُمْ ۖ أَمْ عَلَى ٱللَّهِ تَفْتَرُونَ","translation":"Say: \"Have you ever considered all the means of sustenance which God has bestowed upon you from on high -and which you thereupon divide into 'things forbidden' and 'things lawful? Say: \"Has God given you leave [to do this] -or do you, perchance, attribute your own guesswork to God?\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1423.mp3","surahId":10,"words":[{"id":53922,"position":1,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/010_059_001.mp3","charTypeName":"word"},{"id":53923,"position":2,"arabic":"أَرَءَ