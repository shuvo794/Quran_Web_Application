,{"id":53940,"position":18,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/010_059_019.mp3","charTypeName":"word"},{"id":53941,"position":19,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/010_059_020.mp3","charTypeName":"word"},{"id":53942,"position":20,"arabic":"تَفْتَرُونَ","translation":"তোমরা মিথ্যারোপ করছো\"","audioUrl":"wbw/010_059_021.mp3","charTypeName":"word"},{"id":53943,"position":21,"arabic":"٥٩","translation":"(৫৯)","audioUrl":null,"charTypeName":"end"}]},{"number":60,"arabic":"وَمَا ظَنُّ ٱلَّذِينَ يَفْتَرُونَ عَلَى ٱللَّهِ ٱلْكَذِبَ يَوْمَ ٱلْقِيَٰمَةِ ۗ إِنَّ ٱللَّهَ لَذُو فَضْلٍ عَلَى ٱلنَّاسِ وَلَٰكِنَّ أَكْثَرَهُمْ لَا يَشْكُرُونَ","translation":"But what do they think-they who attribute their own lying inventions to God-[what do they think will happen to them]. on the Day of Resurrection? Behold, God is indeed limitless in His bounty unto men -but most of them are ungrateful.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1424.mp3","surahId":10,"words":[{"id":54202,"position":1,"arabic":"وَمَا","translation":"এবং কি","audioUrl":"wbw/010_060_001.mp3","charTypeName":"word"},{"id":54203,"position":2,"arabic":"ظَنُّ","translation":"ধারণা (করে)","audioUrl":"wbw/010_060_002.mp3","charTypeName":"word"},{"id":54204,"position":3,"arabic":"ٱلَّذِينَ","translation":"(তারা) যারা","audioUrl":"wbw/010_060_003.mp3","charTypeName":"word"},{"id":54205,"position":4,"arabic":"يَفْتَرُونَ","translation":"রচনা করে","audioUrl":"wbw/010_060_004.mp3","charTypeName":"word"},{"id":54206,"position":5,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/010_060_005.mp3","charTypeName":"word"},{"id":54207,"position":6,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/010_060_006.mp3","charTypeName":"word"},{"id":54208,"position":7,"arabic":"ٱلْكَذِبَ","translation":"মিথ্যা","audioUrl":"wbw/010_060_007.mp3","charTypeName":"word"},{"id":54209,"position":8,"arabic":"يَوْمَ","translation":"(সম্বন্ধে) দিন","audioUrl":"wbw/010_060_008.mp3","charTypeName":"word"},{"id":54210,"position":9,"arabic":"ٱلْقِيَـٰمَةِ ۗ","translation":"ক্বিয়ামাতের","audioUrl":"wbw/010_060_009.mp3","charTypeName":"word"},{"id":54212,"position":10,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/010_060_011.mp3","charTypeName":"word"},{"id":54213,"position":11,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/010_060_012.mp3","charTypeName":"word"},{"id":54214,"position":12,"arabic":"لَذُو","translation":"অবশ্যই","audioUrl":"wbw/010_060_013.mp3","charTypeName":"word"},{"id":54215,"position":13,"arabic":"فَضْلٍ","translation":"অনুগ্রহসম্পন্ন","audioUrl":"wbw/010_060_014.mp3","charTypeName":"word"},{"id":54216,"position":14,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/010_060_015.mp3","charTypeName":"word"},{"id":54217,"position":15,"arabic":"ٱلنَّاسِ","translation":"মানুষের","audioUrl":"wbw/010_060_016.mp3","charTypeName":"word"},{"id":54218,"position":16,"arabic":"وَلَـٰكِنَّ","translation":"কিন্তু","audioUrl":"wbw/010_060_017.mp3","charTypeName":"word"},{"id":54219,"position":17,"arabic":"أَكْثَرَهُمْ","translation":"অধিকাংশই তাদের","audioUrl":"wbw/010_060_018.mp3","charTypeName":"word"},{"id":54220,"position":18,"arabic":"لَا","translation":"না","audioUrl":"wbw/010_060_019.mp3","charTypeName":"word"},{"id":54221,"position":19,"arabic":"يَشْكُرُونَ","translation":"কৃতজ্ঞতা প্রকাশ করে","audioUrl":"wbw/010_060_020.mp3","charTypeName":"word"},{"id":54222,"position":20,"arabic":"٦٠","translation":"(৬০)","audioUrl":null,"charTypeName":"end"}]},{"number":61,"arabic":"وَمَا تَكُونُ فِى شَأْنٍۢ وَمَا تَتْلُوا۟ مِنْهُ مِن قُرْءَانٍۢ وَلَا تَعْمَلُونَ مِنْ عَمَلٍ إِلَّا كُنَّا عَلَيْكُمْ شُهُودًا إِذْ تُفِيضُونَ فِيهِ ۚ وَمَا يَعْزُبُ عَن رَّبِّكَ مِن مِّثْقَالِ ذَرَّةٍۢ فِى ٱلْأَرْضِ وَلَا فِى ٱلسَّمَآءِ وَلَآ أَصْغَرَ مِن ذَٰلِكَ وَلَآ أَكْبَرَ إِلَّا فِى كِتَٰبٍۢ مُّبِينٍ","translation":"AND IN whatever condition thou mayest find thyself, [O Prophet,] and whatever discourse of this [divine writ] thou mayest be reciting, and whatever work you [all, O men,] may do -[remember that] We are your witness [from the moment] when you enter upon it: for, not even an atom's weight [of whatever there is] on earth or in heaven escapes thy Sustainer's knowledge; and neither is there anything smaller than that, or larger, but is recorded in [His] clear decree.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1425.mp3","surahId":10,"words":[{"id":55102,"position":1,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/010_061_001.mp3","charTypeName":"word"},{"id":55103,"position":2,"arabic":"تَكُونُ","translation":"তুমি থাকো","audioUrl":"wbw/010_061_002.mp3","charTypeName":"word"},{"id":55104,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/010_061_003.mp3","charTypeName":"word"},{"id":55105,"position":4,"arabic":"شَأْنٍۢ","translation":"(যে কোনো) অবস্থার","audioUrl":"wbw/010_061_004.mp3","charTypeName":"word"},{"id":55106,"position":5,"arabic":"وَمَا","translation":"এবং যা কিছু","audioUrl":"wbw/010_061_005.mp3","charTypeName":"word"},{"id":55107,"position":6,"arabic":"تَتْلُوا۟","translation":"তুমি তিলাওয়াত করো","audioUrl":"wbw/010_061_006.mp3","charTypeName":"word"},{"id":55108,"position":7,"arabic":"مِنْهُ","translation":"সম্পর্কে তা(কিছু)","audioUrl":"wbw/010_061_007.mp3","charTypeName":"word"},{"id":55109,"position":8,"arabic":"مِن","translation":"হতে","audioUrl":"wbw/010_061_008.mp3","charTypeName":"word"},{"id":55110,"position":9,"arabic":"قُرْءَانٍۢ","translation":"কুর'আন","audioUrl":"wbw/010_061_009.mp3","charTypeName":"word"},{"id":55111,"position":10,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/010_061_010.mp3","charTypeName":"word"},{"id":55112,"position":11,"arabic":"تَعْمَلُونَ","translation":"তোমরা কাজ করো","audioUrl":"wbw/010_061_011.mp3","charTypeName":"word"},{"id":55113,"position":12,"arabic":"مِنْ","translation":"কোনো","audioUrl":"wbw/010_061_012.mp3","charTypeName":"word"},{"id":55114,"position":13,"arabic":"عَمَلٍ