{"id":266,"ayahs":[{"number":71,"arabic":"قَالَ هَٰٓؤُلَآءِ بَنَاتِىٓ إِن كُنتُمْ فَٰعِلِينَ","translation":"[Lot] said: \"[Take instead] these daughters of mine, if you must do [whatever you intend to do]!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1873.mp3","surahId":15,"words":[{"id":60243,"position":1,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/015_071_001.mp3","charTypeName":"word"},{"id":60244,"position":2,"arabic":"هَـٰٓؤُلَآءِ","translation":"\"এইসব","audioUrl":"wbw/015_071_002.mp3","charTypeName":"word"},{"id":60245,"position":3,"arabic":"بَنَاتِىٓ","translation":"আমার মেয়েরা","audioUrl":"wbw/015_071_003.mp3","charTypeName":"word"},{"id":60246,"position":4,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/015_071_004.mp3","charTypeName":"word"},{"id":60247,"position":5,"arabic":"كُنتُمْ","translation":"তোমরা হও","audioUrl":"wbw/015_071_005.mp3","charTypeName":"word"},{"id":60248,"position":6,"arabic":"فَـٰعِلِينَ","translation":"সম্পাদনকারী\"","audioUrl":"wbw/015_071_006.mp3","charTypeName":"word"},{"id":60249,"position":7,"arabic":"٧١","translation":"(৭১)","audioUrl":null,"charTypeName":"end"}]},{"number":72,"arabic":"لَعَمْرُكَ إِنَّهُمْ لَفِى سَكْرَتِهِمْ يَعْمَهُونَ","translation":"[But the angels spoke thus:] \"As thou livest, [O Lot, they will not listen to thee:] behold, in their delirium [of lust] they are but blindly stumbling to and fro!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1874.mp3","surahId":15,"words":[{"id":60516,"position":1,"arabic":"لَعَمْرُكَ","translation":"শপথ তোমার জীবনের","audioUrl":"wbw/015_072_001.mp3","charTypeName":"word"},{"id":60517,"position":2,"arabic":"إِنَّهُمْ","translation":"নিশ্চয়ই তারা","audioUrl":"wbw/015_072_002.mp3","charTypeName":"word"},{"id":60518,"position":3,"arabic":"لَفِى","translation":"অবশ্যই মধ্যে (ছিলো)","audioUrl":"wbw/015_072_003.mp3","charTypeName":"word"},{"id":60519,"position":4,"arabic":"سَكْرَتِهِمْ","translation":"তাদের নেশার","audioUrl":"wbw/015_072_004.mp3","charTypeName":"word"},{"id":60520,"position":5,"arabic":"يَعْمَهُونَ","translation":"উদভ্রান্ত হয়ে ফিরছিলো","audioUrl":"wbw/015_072_005.mp3","charTypeName":"word"},{"id":60521,"position":6,"arabic":"٧٢","translation":"(৭২)","audioUrl":null,"charTypeName":"end"}]},{"number":73,"arabic":"فَأَخَذَتْهُمُ ٱلصَّيْحَةُ مُشْرِقِينَ","translation":"And thereupon the blast [of Our punishment] overtook them at the time of sunrise,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1875.mp3","surahId":15,"words":[{"id":61109,"position":1,"arabic":"فَأَخَذَتْهُمُ","translation":"অতঃপর তাদের ধরলো","audioUrl":"wbw/015_073_001.mp3","charTypeName":"word"},{"id":61110,"position":2,"arabic":"ٱلصَّيْحَةُ","translation":"বিরাট আওয়াজ","audioUrl":"wbw/015_073_002.mp3","charTypeName":"word"},{"id":61111,"position":3,"arabic":"مُشْرِقِينَ","translation":"সূর্যোদয় হ'তেই","audioUrl":"wbw/015_073_003.mp3","charTypeName":"word"},{"id":61112,"position":4,"arabic":"٧٣","translation":"(৭৩)","audioUrl":null,"charTypeName":"end"}]},{"number":74,"arabic":"فَجَعَلْنَا عَٰلِيَهَا سَافِلَهَا وَأَمْطَرْنَا عَلَيْهِمْ حِجَارَةًۭ مِّن سِجِّيلٍ","translation":"and We turned those [sinful towns} upside down, and rained down upon them stone-hard blows of chastisement pre-ordained.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1876.mp3","surahId":15,"words":[{"id":61822,"position":1,"arabic":"فَجَعَلْنَا","translation":"অতঃপর আমরা রাখলাম","audioUrl":"wbw/015_074_001.mp3","charTypeName":"word"},{"id":61823,"position":2,"arabic":"عَـٰلِيَهَا","translation":"তার উপরভাগকে","audioUrl":"wbw/015_074_002.mp3","charTypeName":"word"},{"id":61824,"position":3,"arabic":"سَافِلَهَا","translation":"তার নীচেরভাগে","audioUrl":"wbw/015_074_003.mp3","charTypeName":"word"},{"id":61825,"position":4,"arabic":"وَأَمْطَرْنَا","translation":"এবং আমরা বর্ষণ করলাম","audioUrl":"wbw/015_074_004.mp3","charTypeName":"word"},{"id":61826,"position":5,"arabic":"عَلَيْهِمْ","translation":"তাদের উপর","audioUrl":"wbw/015_074_005.mp3","charTypeName":"word"},{"id":61827,"position":6,"arabic":"حِجَارَةًۭ","translation":"পাথরসমূহ","audioUrl":"wbw/015_074_006.mp3","charTypeName":"word"},{"id":61828,"position":7,"arabic":"مِّن","translation":"তৈরী","audioUrl":"wbw/015_074_007.mp3","charTypeName":"word"},{"id":61829,"position":8,"arabic":"سِجِّيلٍ","translation":"পোড়া মাটির","audioUrl":"wbw/015_074_008.mp3","charTypeName":"word"},{"id":61830,"position":9,"arabic":"٧٤","translation":"(৭৪)","audioUrl":null,"charTypeName":"end"}]},{"number":75,"arabic":"إِنَّ فِى ذَٰلِكَ لَءَايَٰتٍۢ لِّلْمُتَوَسِّمِينَ","translation":"Verily, in all this there are messages indeed for those who can read the signs:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1877.mp3","surahId":15,"words":[{"id":62016,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/015_075_001.mp3","charTypeName":"word"},{"id":62017,"position":2,"arabic":"فِى","translation":"মধ্যে আছে","audioUrl":"wbw/015_075_002.mp3","charTypeName":"word"},{"id":62018,"position":3,"arabic":"ذَٰلِكَ","translation":"এর","audioUrl":"wbw/015_075_003.mp3","charTypeName":"word"},{"id":62019,"position":4,"arabic":"لَـَٔايَـٰتٍۢ","translation":"অবশ্যই নিদর্শনসমূহ","audioUrl":"wbw/015_075_004.mp3","charTypeName":"word"},{"id":62020,"position":5,"arabic":"لِّلْمُتَوَسِّمِينَ","translation":"অন্তর্দৃষ্টি-সম্পন্নদের জন্য","audioUrl":"wbw/015_075_005.mp3","charTypeName":"word"},{"id":62021,"position":6,"arabic":"٧٥","translation":"(৭৫)","audioUrl":null,"charTypeName":"end"}]},{"number":76,"arabic":"وَإِنَّهَا لَبِسَبِيلٍۢ مُّقِيمٍ","translation":"for, behold, those [towns] stood by a road that still exists.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1878.mp3","surahId":15,"words":[{"id":62717,"position":1,"arabic":"وَإِنَّهَا","translation":"এবং নিশ্চয়ই তা","audioUrl":"wbw/015_076_001.mp3","charTypeName":"word"},{"id":62718,"position":2,"arabic":"لَبِسَبِيلٍۢ","translation":"অবশ্যই পথের সাথে","audioUrl":"wbw/015_076_002.mp3","charTypeName":"word"},{"id":62719,"position":3,"arabic":"مُّقِيمٍ","translation":"অবস্থিত","audioUrl":"wbw/015_076_003.mp3","charTypeName":"word"},{"id":62720,"position":4,"arabic":"٧٦","translation":"(৭৬)","audioUrl":null,"charTypeName":"end"}]},{"number":77,"arabic":"إِنَّ فِى ذَٰلِكَ لَءَايَةًۭ لِّلْمُؤْمِنِينَ","translation":"Verily, herein lies a message indeed for all who believe [in God].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1879.mp3","surahId":15,"words":[{"id":62818,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/015_077_001.mp3","charTypeName":"word"},{"id":62819,"position":2,"arabic":"فِى","translation":"(রয়েছে) মধ্যে","audioUrl":"wbw/015_077_002.mp3","charTypeName":"word"},{"id":62820,"position":3,"arabic":"ذَٰلِكَ","translation":"এর","audioUrl":"wbw/015_077_003.mp3","charTypeName":"word"},{"id":62821,"position":4,"arabic":"لَـَٔايَةًۭ","translation":"অবশ্যই নিদর্শন","audioUrl":"wbw/015_077_004.mp3","charTypeName":"word"},{"id":62822,"position":5,"arabic":"لِّلْمُؤْمِنِينَ","translation":"ঈমানদারদের জন্যে","audioUrl":"wbw/015_077_005.mp3","charTypeName":"word"},{"id":62823,"position":6,"arabic":"٧٧","translation":"(৭৭)","audioUrl":null,"charTypeName":"end"}]},{"number":78,"arabic":"وَإِن كَانَ أَصْحَٰبُ ٱلْأَيْكَةِ لَظَٰلِمِينَ","translation":"AND THE DWELLERS of the wooded dales [of Madyan, too,] were inveterate evildoers,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1880.mp3","surahId":15,"words":[{"id":63643,"position":1,"arabic":"وَإِن","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/015_078_001.mp3","charTypeName":"word"},{"id":63644,"position":2,"arabic":"كَانَ","translation":"ছিলো","audioUrl":"wbw/015_078_002.mp3","charTypeName":"word"},{"id":63645,"position":3,"arabic":"أَصْحَـٰبُ","translation":"অধিবাসীরা","audioUrl":"wbw/015_078_003.mp3","charTypeName":"word"},{"id":63646,"position":4,"arabic":"ٱلْأَيْكَةِ","translation":"আইকার","audioUrl":"wbw/015_078_004.mp3","charTypeName":"word"},{"id":63647,"position":5,"arabic":"لَظَـٰلِمِينَ","translation":"অবশ্যই সীমালঙ্ঘনকারী","audioUrl":"wbw/015_078_005.mp3","charTypeName":"word"},{"id":63648,"position":6,"arabic":"٧٨","translation":"(৭৮)","audioUrl":null,"charTypeName":"end"}]},{"number":79,"arabic":"فَٱنتَقَمْنَا مِنْهُمْ وَإِنَّهُمَا لَبِإِمَامٍۢ مُّبِينٍۢ","translation":"and so We inflicted Our retribution on them. And, behold, both these [sinful communities] lived by a highway, [to this day] plain to see","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1881.mp3","surahId":15,"words":[{"id":63852,"position":1,"arabic":"فَٱنتَقَمْنَا","translation":"অতঃপর আমরা প্রতিশোধ নিই","audioUrl":"wbw/015_079_001.mp3","charTypeName":"word"},{"id":63853,"position":2,"arabic":"مِنْهُمْ","translation":"থেকে তাদের","audioUrl":"wbw/015_079_002.mp3","charTypeName":"word"},{"id":63854,"position":3,"arabic":"وَإِنَّهُمَا","translation":"এবং নিশ্চয়ই উভয়েই","audioUrl":"wbw/015_079_003.mp3","charTypeName":"word"},{"id":63855,"position":4,"arabic":"لَبِإِمَامٍۢ","translation":"অবশ্যই পথের সাথে","audioUrl":"wbw/015_079_004.mp3","charTypeName":"word"},{"id":63856,"position":5,"arabic":"مُّبِينٍۢ","translation":"প্রকাশ্য","audioUrl":"wbw/015_079_005.mp3","charTypeName":"word"},{"id":63857,"position":6,"arabic":"٧٩","translation":"(৭৯)","audioUrl":null,"charTypeName":"end"}]},{"number":80,"arabic":"وَلَقَدْ كَذَّبَ أَصْحَٰبُ ٱلْحِجْرِ ٱلْمُرْسَلِينَ","translation":"AND, [likewise,] indeed, the people of Al-Hijr gave the lie to [Our] message-bearers:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1882.mp3","surahId":15,"words":[{"id":64444,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/015_080_001.mp3","charTypeName":"word"},{"id":64445,"position":2,"arabic":"كَذَّبَ","translation":"মিথ্যারোপ করেছিলো","audioUrl":"wbw/015_080_002.mp3","charTypeName":"word"},{"id":64446,"position":3,"arabic":"أَصْحَـٰبُ","translation":"অধিবাসীরা","audioUrl":"wbw/015_080_003.mp3","charTypeName":"word"},{"id":64447,"position":4,"arabic":"ٱلْحِجْرِ","translation":"হিজরের","audioUrl":"wbw/015_080_004.mp3","charTypeName":"word"},{"id":64448,"position":5,"arabic":"ٱلْمُرْسَلِينَ","translation":"রাসূলদেরকে","audioUrl":"wbw/015_080_005.mp3","charTypeName":"word"},{"id":64449,"position":6,"arabic":"٨٠","translation":"(৮০)","audioUrl":null,"charTypeName":"end"}]},{"number":81,"arabic":"وَءَاتَيْنَٰهُمْ ءَايَٰتِنَا فَكَانُوا۟ عَنْهَا مُعْرِضِينَ","translation":"for We did vouchsafe them Our messages, but they obstinately turned their backs upon them-","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1883.mp3","surahId":15,"words":[{"id":64455,"position":1,"arabic":"وَءَاتَيْنَـٰهُمْ","translation":"এবং তাদের আমরা দিয়েছিলাম","audioUrl":"wbw/015_081_001.mp3","charTypeName":"word"},{"id":64456,"position":2,"arabic":"ءَايَـٰتِنَا","translation":"আমাদের নিদর্শনাবলী","audioUrl":"wbw/015_081_002.mp3","charTypeName":"word"},{"id":64457,"position":3,"arabic":"فَكَانُوا۟","translation":"তবুও তারা ছিলো","audioUrl":"wbw/015_081_003.mp3","charTypeName":"word"},{"id":64458,"position":4,"arabic":"عَنْهَا","translation":"তা সম্পর্কে","audioUrl":"wbw/015_081_004.mp3","charTypeName":"word"},{"id":64459,"position":5,"arabic":"مُعْرِضِينَ","translation":"উপেক্ষাকারী","audioUrl":"wbw/015_081_005.mp3","charTypeName":"word"},{"id":64460,"position":6,"arabic":"٨١","translation":"(৮১)","audioUrl":null,"charTypeName":"end"}]},{"number":82,"arabic":"وَكَانُوا۟ يَنْحِتُونَ مِنَ ٱلْجِبَالِ بُيُوتًا ءَامِنِينَ","translation":"notwithstanding that they had been wont [to enjoy Our blessings and] to hew out dwellings from the mountains, [wherein they could live] in security","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1884.mp3","surahId":15,"words":[{"id":65222,"position":1,"arabic":"وَكَانُوا۟","translation":"এবং তারা ছিলো","audioUrl":"wbw/015_082_001.mp3","charTypeName":"word"},{"id":65223,