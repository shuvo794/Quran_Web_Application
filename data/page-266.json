651,"position":3,"arabic":"عَنْهُم","translation":"জন্যে তাদের","audioUrl":"wbw/015_084_003.mp3","charTypeName":"word"},{"id":65652,"position":4,"arabic":"مَّا","translation":"যা","audioUrl":"wbw/015_084_004.mp3","charTypeName":"word"},{"id":65653,"position":5,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/015_084_005.mp3","charTypeName":"word"},{"id":65654,"position":6,"arabic":"يَكْسِبُونَ","translation":"তারা উপার্জন করে","audioUrl":"wbw/015_084_006.mp3","charTypeName":"word"},{"id":65655,"position":7,"arabic":"٨٤","translation":"(৮৪)","audioUrl":null,"charTypeName":"end"}]},{"number":85,"arabic":"وَمَا خَلَقْنَا ٱلسَّمَٰوَٰتِ وَٱلْأَرْضَ وَمَا بَيْنَهُمَآ إِلَّا بِٱلْحَقِّ ۗ وَإِنَّ ٱلسَّاعَةَ لَءَاتِيَةٌۭ ۖ فَٱصْفَحِ ٱلصَّفْحَ ٱلْجَمِيلَ","translation":"AND [remember:] We have not created the heavens and the earth and all that is between them without [an inner] truth; but, behold, the Hour [when this will become clear to all] is indeed yet to come. Hence, forgive [men's failings] with fair forbearance:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1887.mp3","surahId":15,"words":[{"id":66318,"position":1,"arabic":"وَمَا","translation":"এবং নি","audioUrl":"wbw/015_085_001.mp3","charTypeName":"word"},{"id":66319,"position":2,"arabic":"خَلَقْنَا","translation":"আমরা সৃষ্টি করেছি","audioUrl":"wbw/015_085_002.mp3","charTypeName":"word"},{"id":66320,"position":3,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশ মন্ডলী","audioUrl":"wbw/015_085_003.mp3","charTypeName":"word"},{"id":66321,"position":4,"arabic":"وَٱلْأَرْضَ","translation":"এবং পৃথিবী","audioUrl":"wbw/015_085_004.mp3","charTypeName":"word"},{"id":66322,"position":5,"arabic":"وَمَا","translation":"এবং যা (আছে)","audioUrl":"wbw/015_085_005.mp3","charTypeName":"word"},{"id":66323,"position":6,"arabic":"بَيْنَهُمَآ","translation":"উভয়ের মাঝে","audioUrl":"wbw/015_085_006.mp3","charTypeName":"word"},{"id":66324,"position":7,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/015_085_007.mp3","charTypeName":"word"},{"id":66325,"position":8,"arabic":"بِٱلْحَقِّ ۗ","translation":"মহাসত্যসহকারে","audioUrl":"wbw/015_085_008.mp3","charTypeName":"word"},{"id":66327,"position":9,"arabic":"وَإِنَّ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/015_085_010.mp3","charTypeName":"word"},{"id":66328,"position":10,"arabic":"ٱلسَّاعَةَ","translation":"ক্বিয়ামাত","audioUrl":"wbw/015_085_011.mp3","charTypeName":"word"},{"id":66329,"position":11,"arabic":"لَـَٔاتِيَةٌۭ ۖ","translation":"অবশ্যই আসবে","audioUrl":"wbw/015_085_012.mp3","charTypeName":"word"},{"id":66331,"position":12,"arabic":"فَٱصْفَحِ","translation":"সুতরাং ক্ষমা করো","audioUrl":"wbw/015_085_014.mp3","charTypeName":"word"},{"id":66332,"position":13,"arabic":"ٱلصَّفْحَ","translation":"সৌজন্যে","audioUrl":"wbw/015_085_015.mp3","charTypeName":"word"},{"id":66333,"position":14,"arabic":"ٱلْجَمِيلَ","translation":"পরম","audioUrl":"wbw/015_085_016.mp3","charTypeName":"word"},{"id":66334,"position":15,"arabic":"٨٥","translation":"(৮৫)","audioUrl":null,"charTypeName":"end"}]},{"number":86,"arabic":"إِنَّ رَبَّكَ هُوَ ٱلْخَلَّٰقُ ٱلْعَلِيمُ","translation":"verily, thy Sustainer is the all-knowing Creator of all things!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1888.mp3","surahId":15,"words":[{"id":66681,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/015_086_001.mp3","charTypeName":"word"},{"id":66682,"position":2,"arabic":"رَبَّكَ","translation":"তোমার রব","audioUrl":"wbw/015_086_002.mp3","charTypeName":"word"},{"id":66683,"position":3,"arabic":"هُوَ","translation":"তিনিই","audioUrl":"wbw/015_086_003.mp3","charTypeName":"word"},{"id":66684,"position":4,"arabic":"ٱلْخَلَّـٰقُ","translation":"মহাস্রষ্টা","audioUrl":"wbw/015_086_004.mp3","charTypeName":"word"},{"id":66685,"position":5,"arabic":"ٱلْعَلِيمُ","translation":"মহাজ্ঞানী","audioUrl":"wbw/015_086_005.mp3","charTypeName":"word"},{"id":66686,"position":6,"arabic":"٨٦","translation":"(৮৬)","audioUrl":nu