:4,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশ মন্ডলীর","audioUrl":"wbw/030_018_004.mp3","charTypeName":"word"},{"id":20931,"position":5,"arabic":"وَٱلْأَرْضِ","translation":"ও পৃথিবীতে","audioUrl":"wbw/030_018_005.mp3","charTypeName":"word"},{"id":20932,"position":6,"arabic":"وَعَشِيًّۭا","translation":"এবং (মহিমা ঘোষণা করো) বিকেলে  (অর্থাৎ আসরে)","audioUrl":"wbw/030_018_006.mp3","charTypeName":"word"},{"id":20933,"position":7,"arabic":"وَحِينَ","translation":"ও যখন","audioUrl":"wbw/030_018_007.mp3","charTypeName":"word"},{"id":20934,"position":8,"arabic":"تُظْهِرُونَ","translation":"তোমরা দুপুরে উপনীত হও","audioUrl":"wbw/030_018_008.mp3","charTypeName":"word"},{"id":20935,"position":9,"arabic":"١٨","translation":"(১৮)","audioUrl":null,"charTypeName":"end"}]},{"number":19,"arabic":"يُخْرِجُ ٱلْحَىَّ مِنَ ٱلْمَيِّتِ وَيُخْرِجُ ٱلْمَيِّتَ مِنَ ٱلْحَىِّ وَيُحْىِ ٱلْأَرْضَ بَعْدَ مَوْتِهَا ۚ وَكَذَٰلِكَ تُخْرَجُونَ","translation":"He [it is who] brings forth the living out of that which is dead, and brings forth the dead out of that which is alive, and gives life to the earth after it had been lifeless: and even thus will you be brought forth [from death to life]","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3428.mp3","surahId":30,"words":[{"id":22048,"position":1,"arabic":"يُخْرِجُ","translation":"তিনি বের করেন","audioUrl":"wbw/030_019_001.mp3","charTypeName":"word"},{"id":22049,"position":2,"arabic":"ٱلْحَىَّ","translation":"জীবন্তকে","audioUrl":"wbw/030_019_002.mp3","charTypeName":"word"},{"id":22050,"position":3,"arabic":"مِنَ","translation":"হ'তে","audioUrl":"wbw/030_019_003.mp3","charTypeName":"word"},{"id":22051,"position":4,"arabic":"ٱلْمَيِّتِ","translation":"মৃত","audioUrl":"wbw/030_019_004.mp3","charTypeName":"word"},{"id":22052,"position":5,"arabic":"وَيُخْرِجُ","translation":"ও তিনি বের করেন","audioUrl":"wbw/030_019_005.mp3","charTypeName":"word"},{"id":22053,"position":6,"arabic":"ٱلْمَيِّتَ","translation":"মৃতকে","audioUrl":"wbw/030_019_006.mp3","charTypeName":"word"},{"id":22054,"position":7,"arabic":"مِنَ","translation":"হ'তে","audioUrl":"wbw/030_019_007.mp3","charTypeName":"word"},{"id":22055,"position":8,"arabic":"ٱلْحَىِّ","translation":"জীবন্ত","audioUrl":"wbw/030_019_008.mp3","charTypeName":"word"},{"id":22056,"position":9,"arabic":"وَيُحْىِ","translation":"এবং জীবিত করেন","audioUrl":"wbw/030_019_009.mp3","charTypeName":"word"},{"id":22057,"position":10,"arabic":"ٱلْأَرْضَ","translation":"পৃথিবীকে","audioUrl":"wbw/030_019_010.mp3","charTypeName":"word"},{"id":22058,"position":11,"arabic":"بَعْدَ","translation":"পরে","audioUrl":"wbw/030_019_011.mp3","charTypeName":"word"},{"id":22059,"position":12,"arabic":"مَوْتِهَا ۚ","translation":"মৃত্যুর তার","audioUrl":"wbw/030_019_012.mp3","charTypeName":"word"},{"id":22061,"position":13,"arabic":"وَكَذَٰلِكَ","translation":"এবং এরূপেই","audioUrl":"wbw/030_019_014.mp3","charTypeName":"word"},{"id":22062,"position":14,"arabic":"تُخْرَجُونَ","translation":"তোমাদের বের করা হবে","audioUrl":"wbw/030_019_015.mp3","charTypeName":"word"},{"id":22063,"position":15,"arabic":"١٩","translation":"(১৯)","audioUrl":null,"charTypeName":"end"}]},{"number":20,"arabic":"وَمِنْ ءَايَٰتِهِۦٓ أَنْ خَلَقَكُم مِّن تُرَابٍۢ ثُمَّ إِذَآ أَنتُم بَشَرٌۭ تَنتَشِرُونَ","translation":"And among His wonders is this: He creates you out of dust – and then, lo! you become human beings ranging far and wide!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3429.mp3","surahId":30,"words":[{"id":23106,"position":1,"arabic":"وَمِنْ","translation":"এবং মধ্যে (রয়েছে)","audioUrl":"wbw/030_020_001.mp3","charTypeName":"word"},{"id":23107,"position":2,"arabic":"ءَايَـٰتِهِۦٓ","translation":"নিদর্শনাবলীর তাঁর","audioUrl":"wbw/030_020_002.mp3","charTypeName":"word"},{"id":23108,"position":3,"arabic":"أَنْ","translation":"(এও) যে","audioUrl":"wbw/030_020_003.mp3","charTypeName":"word"},{"id":23109,"position":4,"arabic":"خَلَقَكُم","translation":"তিনি সৃষ্টি করেছেন তোমাদেরকে","audioUrl":"wbw/030_020_004.mp3","charTypeName":"word"},{"id":23110,"position":5,"arabic":"مِّن","translation":"হ'তে","audioUrl":"wbw/030_020_005.mp3","charTypeName":"word"},{"id":23111,"position":6,"arabic":"تُرَابٍۢ","translation":"মাটি","audioUrl":"wbw/030_020_006.mp3","charTypeName":"word"},{"id":23112,"position":7,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/030_020_007.mp3","charTypeName":"word"},{"id":23113,"position":8,"arabic":"إِذَآ","translation":"এখন","audioUrl":"wbw/030_020_008.mp3","charTypeName":"word"},{"id":23114,"position":9,"arabic":"أَنتُم","translation":"তোমরা","audioUrl":"wbw/030_020_009.mp3","charTypeName":"word"},{"id":23115,"position":10,"arabic":"بَشَرٌۭ","translation":"মানুষ (হিসেবে)","audioUrl":"wbw/030_020_010.mp3","charTypeName":"word"},{"id":23116,"position":11,"arabic":"تَنتَشِرُونَ","translation":"তোমরা ছড়িয়ে পড়ছো","audioUrl":"wbw/030_020_011.mp3","charTypeName":"word"},{"id":23117,"position":12,"arabic":"٢٠","translation":"(২০)","audioUrl":null,"charTypeName":"end"}]},{"number":21,"arabic":"وَمِنْ ءَايَٰتِهِۦٓ أَنْ خَلَقَ لَكُم مِّنْ أَنفُسِكُمْ أَزْوَٰجًۭا لِّتَسْكُنُوٓا۟ إِلَيْهَا وَجَعَلَ بَيْنَكُم مَّوَدَّةًۭ وَرَحْمَةً ۚ إِنَّ فِى ذَٰلِكَ لَءَايَٰتٍۢ لِّقَوْمٍۢ يَتَفَكَّرُونَ","translation":"And among His wonders is this: He creates for you mates out of your own kind. so that you might incline towards them, and He engenders love and tenderness between you: in this, behold, there are messages indeed for people who think!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3430.mp3","surahId":30,"words":[{"id":24108,"position":1,"arabic":"وَمِنْ","translation":"এবং মধ্য হ'তে","audioUrl":"wbw/030_021_001.mp3","charTypeName":"word"},{"id":24109,"position":2,"arabic":"ءَايَـٰتِهِۦٓ","translation":"নিদর্শনাবলীর তাঁর","audioUrl":"wbw/030_021_002.mp3","charTypeName":"word"},{"id":24110,"position":3,"arabic":"أَنْ","translation":"এও (যে)","audioUrl":"wbw/030_021_003.mp3","charTypeName":"word"},{"id":24111,"position":4