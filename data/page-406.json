anslation":"জন্যে সম্প্রদায়ের","audioUrl":"wbw/030_021_020.mp3","charTypeName":"word"},{"id":24128,"position":20,"arabic":"يَتَفَكَّرُونَ","translation":"(যারা ) চিন্তা ভাবনা করে","audioUrl":"wbw/030_021_021.mp3","charTypeName":"word"},{"id":24129,"position":21,"arabic":"٢١","translation":"(২১)","audioUrl":null,"charTypeName":"end"}]},{"number":22,"arabic":"وَمِنْ ءَايَٰتِهِۦ خَلْقُ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ وَٱخْتِلَٰفُ أَلْسِنَتِكُمْ وَأَلْوَٰنِكُمْ ۚ إِنَّ فِى ذَٰلِكَ لَءَايَٰتٍۢ لِّلْعَٰلِمِينَ","translation":"And among his wonders is the creation of the heavens and the earth, and the diversity of your tongues and colours: for in this, behold, there are messages indeed for all who are possessed of [innate] knowledge!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3431.mp3","surahId":30,"words":[{"id":25114,"position":1,"arabic":"وَمِنْ","translation":"এবং মধ্যে হ'তে","audioUrl":"wbw/030_022_001.mp3","charTypeName":"word"},{"id":25115,"position":2,"arabic":"ءَايَـٰتِهِۦ","translation":"নিদর্শনাবলীর তাঁর","audioUrl":"wbw/030_022_002.mp3","charTypeName":"word"},{"id":25116,"position":3,"arabic":"خَلْقُ","translation":"সৃষ্টি","audioUrl":"wbw/030_022_003.mp3","charTypeName":"word"},{"id":25117,"position":4,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশমন্ডলীর","audioUrl":"wbw/030_022_004.mp3","charTypeName":"word"},{"id":25118,"position":5,"arabic":"وَٱلْأَرْضِ","translation":"ও পৃথিবীর","audioUrl":"wbw/030_022_005.mp3","charTypeName":"word"},{"id":25119,"position":6,"arabic":"وَٱخْتِلَـٰفُ","translation":"এবং বৈচিত্র্য","audioUrl":"wbw/030_022_006.mp3","charTypeName":"word"},{"id":25120,"position":7,"arabic":"أَلْسِنَتِكُمْ","translation":"ভাষাসমূহের তোমাদের","audioUrl":"wbw/030_022_007.mp3","charTypeName":"word"},{"id":25121,"position":8,"arabic":"وَأَلْوَٰنِكُمْ ۚ","translation":"ও বর্ণসমূহের তোমাদের","audioUrl":"wbw/030_022_008.mp3","charTypeName":"word"},{"id":25123,"position":9,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/030_022_0