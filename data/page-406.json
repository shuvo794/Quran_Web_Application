{"id":406,"ayahs":[{"number":16,"arabic":"وَأَمَّا ٱلَّذِينَ كَفَرُوا۟ وَكَذَّبُوا۟ بِـَٔايَٰتِنَا وَلِقَآئِ ٱلْءَاخِرَةِ فَأُو۟لَٰٓئِكَ فِى ٱلْعَذَابِ مُحْضَرُونَ","translation":"but as for those who refused to acknowledge the truth and gave the lie to Our messages - and (thus) to the announce­ment of a life to come - they will be given over to suffering.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3425.mp3","surahId":30,"words":[{"id":18765,"position":1,"arabic":"وَأَمَّا","translation":"আর (তাদের) ব্যাপার","audioUrl":"wbw/030_016_001.mp3","charTypeName":"word"},{"id":18766,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/030_016_002.mp3","charTypeName":"word"},{"id":18767,"position":3,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করেছে","audioUrl":"wbw/030_016_003.mp3","charTypeName":"word"},{"id":18768,"position":4,"arabic":"وَكَذَّبُوا۟","translation":"ও মিথ্যারোপ করেছে","audioUrl":"wbw/030_016_004.mp3","charTypeName":"word"},{"id":18769,"position":5,"arabic":"بِـَٔايَـٰتِنَا","translation":"প্রতি নিদর্শনাবলীর আমাদের","audioUrl":"wbw/030_016_005.mp3","charTypeName":"word"},{"id":18770,"position":6,"arabic":"وَلِقَآئِ","translation":"ও সাক্ষাতকে","audioUrl":"wbw/030_016_006.mp3","charTypeName":"word"},{"id":18771,"position":7,"arabic":"ٱلْـَٔاخِرَةِ","translation":"পরকালের","audioUrl":"wbw/030_016_007.mp3","charTypeName":"word"},{"id":18772,"position":8,"arabic":"فَأُو۟لَـٰٓئِكَ","translation":"তখন ঐসব (লোককে)","audioUrl":"wbw/030_016_008.mp3","charTypeName":"word"},{"id":18773,"position":9,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/030_016_009.mp3","charTypeName":"word"},{"id":18774,"position":10,"arabic":"ٱلْعَذَابِ","translation":"শাস্তির","audioUrl":"wbw/030_016_010.mp3","charTypeName":"word"},{"id":18775,"position":11,"arabic":"مُحْضَرُونَ","translation":"উপস্থিত করা হবে","audioUrl":"wbw/030_016_011.mp3","charTypeName":"word"},{"id":18776,"position":12,"arabic":"١٦","translation":"(১৬)","audioUrl":null,"