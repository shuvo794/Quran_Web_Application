{"id":544,"ayahs":[{"number":12,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوٓا۟ إِذَا نَٰجَيْتُمُ ٱلرَّسُولَ فَقَدِّمُوا۟ بَيْنَ يَدَىْ نَجْوَىٰكُمْ صَدَقَةًۭ ۚ ذَٰلِكَ خَيْرٌۭ لَّكُمْ وَأَطْهَرُ ۚ فَإِن لَّمْ تَجِدُوا۟ فَإِنَّ ٱللَّهَ غَفُورٌۭ رَّحِيمٌ","translation":"O YOU who have attained to faith! Whenever you [intend to] consult the Apostle, offer up something in charity on the occasion of your consultation: this will be for your own good, and more conducive to your [inner] purity. Yet if you are unable to do so, [know that,] verily, God is much-forgiving, a dispen­ser of grace.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5116.mp3","surahId":58,"words":[{"id":13897,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/058_012_001.mp3","charTypeName":"word"},{"id":13898,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/058_012_002.mp3","charTypeName":"word"},{"id":13899,"position":3,"arabic":"ءَامَنُوٓا۟","translation":"ঈমান এনেছ","audioUrl":"wbw/058_012_003.mp3","charTypeName":"word"},{"id":13900,"position":4,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/058_012_004.mp3","charTypeName":"word"},{"id":13901,"position":5,"arabic":"نَـٰجَيْتُمُ","translation":"তোমরা একান্তে কথা বলবে","audioUrl":"wbw/058_012_005.mp3","charTypeName":"word"},{"id":13902,"position":6,"arabic":"ٱلرَّسُولَ","translation":"রাসূলের সাথে","audioUrl":"wbw/058_012_006.mp3","charTypeName":"word"},{"id":13903,"position":7,"arabic":"فَقَدِّمُوا۟","translation":"তোমরা পেশ করবে","audioUrl":"wbw/058_012_007.mp3","charTypeName":"word"},{"id":13904,"position":8,"arabic":"بَيْنَ","translation":"(মাঝে)","audioUrl":"wbw/058_012_008.mp3","charTypeName":"word"},{"id":13905,"position":9,"arabic":"يَدَىْ","translation":"পূর্বে","audioUrl":"wbw/058_012_009.mp3","charTypeName":"word"},{"id":13906,"position":10,"arabic":"نَجْوَىٰكُمْ","translation":"তোমার একান্তে কথা বলার","audioUrl":"wbw/058_012_010.mp3","charTypeName":"word"},{"id":13907,"posi