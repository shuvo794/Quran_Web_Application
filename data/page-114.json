{"id":114,"ayahs":[{"number":37,"arabic":"يُرِيدُونَ أَن يَخْرُجُوا۟ مِنَ ٱلنَّارِ وَمَا هُم بِخَٰرِجِينَ مِنْهَا ۖ وَلَهُمْ عَذَابٌۭ مُّقِيمٌۭ","translation":"They will wish to come out of the fire, but they shall not come out of it; and long-lasting suffering awaits them.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/706.mp3","surahId":5,"words":[{"id":39044,"position":1,"arabic":"يُرِيدُونَ","translation":"তারা চাইবে","audioUrl":"wbw/005_037_001.mp3","charTypeName":"word"},{"id":39045,"position":2,"arabic":"أَن","translation":"যে","audioUrl":"wbw/005_037_002.mp3","charTypeName":"word"},{"id":39046,"position":3,"arabic":"يَخْرُجُوا۟","translation":"তারা বের হবে","audioUrl":"wbw/005_037_003.mp3","charTypeName":"word"},{"id":39047,"position":4,"arabic":"مِنَ","translation":"থেকে","audioUrl":"wbw/005_037_004.mp3","charTypeName":"word"},{"id":39048,"position":5,"arabic":"ٱلنَّارِ","translation":"আগুন","audioUrl":"wbw/005_037_005.mp3","charTypeName":"word"},{"id":39049,"position":6,"arabic":"وَمَا","translation":"কিন্তু না","audioUrl":"wbw/005_037_006.mp3","charTypeName":"word"},{"id":39050,"position":7,"arabic":"هُم","translation":"তারা","audioUrl":"wbw/005_037_007.mp3","charTypeName":"word"},{"id":39051,"position":8,"arabic":"بِخَـٰرِجِينَ","translation":"বের হতে পারবে","audioUrl":"wbw/005_037_008.mp3","charTypeName":"word"},{"id":39052,"position":9,"arabic":"مِنْهَا ۖ","translation":"থেকে তা","audioUrl":"wbw/005_037_009.mp3","charTypeName":"word"},{"id":39054,"position":10,"arabic":"وَلَهُمْ","translation":"এবং জন্যে তাদের (রয়েছে)","audioUrl":"wbw/005_037_011.mp3","charTypeName":"word"},{"id":39055,"position":11,"arabic":"عَذَابٌۭ","translation":"শাস্তি","audioUrl":"wbw/005_037_012.mp3","charTypeName":"word"},{"id":39056,"position":12,"arabic":"مُّقِيمٌۭ","translation":"স্থায়ী","audioUrl":"wbw/005_037_013.mp3","charTypeName":"word"},{"id":39057,"position":13,"arabic":"٣٧","translation":"(৩৭)","audioUrl":null,"charTypeName":"end"}]},{"number":38,"arabic":"وَٱلسَّارِقُ وَٱلسَّارِقَةُ فَٱقْطَعُوٓا۟ أَيْدِيَهُمَا جَزَآءًۢ بِمَا كَسَبَا نَكَٰلًۭا مِّنَ ٱللَّهِ ۗ وَٱللَّهُ عَزِيزٌ حَكِيمٌۭ","translation":"NOW AS FOR the man who steals and the woman who steals, cut off the hand of either of them in requital for what they have wrought, as a deterrent ordained by God: for God is almighty, wise.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/707.mp3","surahId":5,"words":[{"id":39883,"position":1,"arabic":"وَٱلسَّارِقُ","translation":"এবং পুরুষ চোর (হউক)","audioUrl":"wbw/005_038_001.mp3","charTypeName":"word"},{"id":39884,"position":2,"arabic":"وَٱلسَّارِقَةُ","translation":"বা নারী চোর","audioUrl":"wbw/005_038_002.mp3","charTypeName":"word"},{"id":39885,"position":3,"arabic":"فَٱقْطَعُوٓا۟","translation":"অত:পর তোমরা কেটে দাও","audioUrl":"wbw/005_038_003.mp3","charTypeName":"word"},{"id":39886,"position":4,"arabic":"أَيْدِيَهُمَا","translation":"হাত উভয়ের","audioUrl":"wbw/005_038_004.mp3","charTypeName":"word"},{"id":39887,"position":5,"arabic":"جَزَآءًۢ","translation":"প্রতিফলস্বরূপ","audioUrl":"wbw/005_038_005.mp3","charTypeName":"word"},{"id":39888,"position":6,"arabic":"بِمَا","translation":"এ কারণে যা","audioUrl":"wbw/005_038_006.mp3","charTypeName":"word"},{"id":39889,"position":7,"arabic":"كَسَبَا","translation":"অর্জন করেছে উভয়ে","audioUrl":"wbw/005_038_007.mp3","charTypeName":"word"},{"id":39890,"position":8,"arabic":"نَكَـٰلًۭا","translation":"দন্ড হিসেবে","audioUrl":"wbw/005_038_008.mp3","charTypeName":"word"},{"id":39891,"position":9,"arabic":"مِّنَ","translation":"পক্ষ হতে","audioUrl":"wbw/005_038_009.mp3","charTypeName":"word"},{"id":39892,"position":10,"arabic":"ٱللَّهِ ۗ","translation":"আল্লাহর","audioUrl":"wbw/005_038_010.mp3","charTypeName":"word"},{"id":39894,"position":11,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/005_038_012.mp3","charTypeName":"word"},{"id":39895,"position":12,"arabic":"عَزِيزٌ","translation":"পরাক্রমশালী","audioUrl":"wbw/005_038_013.mp3","charTypeName":"word"},{"id":39896,"position":13,"arabic":"حَكِيمٌۭ","translation":"প্রজ্ঞাময়","audioUrl":"wbw/005_038_014.mp3","charTypeName":"word"},{"id":39897,"position":14,"arabic":"٣٨","translation":"(৩৮)","audioUrl":null,"charTypeName":"end"}]},{"number":39,"arabic":"فَمَن تَابَ مِنۢ بَعْدِ ظُلْمِهِۦ وَأَصْلَحَ فَإِنَّ ٱللَّهَ يَتُوبُ عَلَيْهِ ۗ إِنَّ ٱللَّهَ غَفُورٌۭ رَّحِيمٌ","translation":"But as for him who repents after having thus done wrong, and makes amends, behold, God will accept his repentance: verily, God is much-forgiving, a dispenser of grace.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/708.mp3","surahId":5,"words":[{"id":40703,"position":1,"arabic":"فَمَن","translation":"তবে যে","audioUrl":"wbw/005_039_001.mp3","charTypeName":"word"},{"id":40704,"position":2,"arabic":"تَابَ","translation":"তওবা করে","audioUrl":"wbw/005_039_002.mp3","charTypeName":"word"},{"id":40705,"position":3,"arabic":"مِنۢ","translation":"থেকে","audioUrl":"wbw/005_039_003.mp3","charTypeName":"word"},{"id":40706,"position":4,"arabic":"بَعْدِ","translation":"পর","audioUrl":"wbw/005_039_004.mp3","charTypeName":"word"},{"id":40707,"position":5,"arabic":"ظُلْمِهِۦ","translation":"অন্যায়ের তার","audioUrl":"wbw/005_039_005.mp3","charTypeName":"word"},{"id":40708,"position":6,"arabic":"وَأَصْلَحَ","translation":"ও সংশোধন হয়","audioUrl":"wbw/005_039_006.mp3","charTypeName":"word"},{"id":40709,"position":7,"arabic":"فَإِنَّ","translation":"তবে নিশ্চয়ই","audioUrl":"wbw/005_039_007.mp3","charTypeName":"word"},{"id":40710,"position":8,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/005_039_008.mp3","charTypeName":"word"},{"id":40711,"position":9,"arabic":"يَتُوبُ","translation":"ক্ষমা করবেন","audioUrl":"wbw/005_039_009.mp3","charTypeName":"word"},{"id":40712,"position":10,"arabic":"عَلَيْهِ ۗ","translation":"উপর তার","audioUrl":"wbw/005_039_010.mp3","charTypeName":"word"},{"id":40714,"position":11,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/005_039_012.mp3","charTypeName":"word"},{"id":40715,"position":12,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/005_039_013.mp3","charTypeName":"word"},{"id":40716,"position":13,"arabic":"غَفُورٌۭ","translation":"ক্ষমাশীল","audioUrl":"wbw/005_039_014.mp3","charTypeName":"word"},{"id":40717,"position":14,"arabic":"رَّحِيمٌ","translation":"পরম দয়ালু","audioUrl":"wbw/005_039_015.mp3","charTypeName":"word"},{"id":40718,"position":15,"arabic":"٣٩","translation":"(৩৯)","audioUrl":null,"charTypeName":"end"}]},{"number":40,"arabic":"أَلَمْ تَعْلَمْ أَنَّ ٱللَّهَ لَهُۥ مُلْكُ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ يُعَذِّبُ مَن يَشَآءُ وَيَغْفِرُ لِمَن يَشَآءُ ۗ وَٱللَّهُ عَلَىٰ كُلِّ شَىْءٍۢ قَدِيرٌۭ","translation":"Dost thou not know that God's is the dominion over the heavens and the earth? He chastises whom He wills, and He forgives whom He wills: for God has the power to will anything.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/709.mp3","surahId":5,"words":[{"id":41538,"position":1,"arabic":"أَلَمْ","translation":"কি না","audioUrl":"wbw/005_040_001.mp3","charTypeName":"word"},{"id":41539,"position":2,"arabic":"تَعْلَمْ","translation":"তুমি জানো","audioUrl":"wbw/005_040_002.mp3","charTypeName":"word"},{"id":41540,"position":3,"arabic":"أَنَّ","translation":"যে","audioUrl":"wbw/005_040_003.mp3","charTypeName":"word"},{"id":41541,"position":4,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/005_040_004.mp3","charTypeName":"word"},{"id":41542,"position":5,"arabic":"لَهُۥ","translation":"জন্যে তাঁরই","audioUrl":"wbw/005_040_005.mp3","charTypeName":"word"},{"id":41543,"position":6,"arabic":"مُلْكُ","translation":"সার্বভৌমত্ব","audioUrl":"wbw/005_040_006.mp3","charTypeName":"word"},{"id":41544,"position":7,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশসমূহের","audioUrl":"wbw/005_040_007.mp3","charTypeName":"word"},{"id":41545,"position":8,"arabic":"وَٱلْأَرْضِ","translation":"ও পৃথিবীর","audioUrl":"wbw/005_040_008.mp3","charTypeName":"word"},{"id":41546,"position":9,"arabic":"يُعَذِّبُ","translation":"তিনি শাস্তি দেন","audioUrl":"wbw/005_040_009.mp3","charTypeName":"word"},{"id":41547,"position":10,"arabic":"مَن","translation":"যাকে","audioUrl":"wbw/005_040_010.mp3","charTypeName":"word"},{"id":41548,"position":11,"arabic":"يَشَآءُ","translation":"ইচ্ছে করেন","audioUrl":"wbw/005_040_011.mp3","charTypeName":"word"},{"id":41549,"position":12,"arabic":"وَيَغْفِرُ","translation":"ও ক্ষমা করেন","audioUrl":"wbw/005_040_012.mp3","charTypeName":"word"},{"id":41550,"position":13,"arabic":"لِمَن","translation":"যাকে","audioUrl":"wbw/005_040_013.mp3","charTypeName":"word"},{"id":41551,"position":14,"arabic":"يَشَآءُ ۗ","translation":"তিনি ইচ্ছে করেন","audioUrl":"wbw/005_040_014.mp3","charTypeName":"word"},{"id":41553,"position":15,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/005_040_016.mp3","charTypeName":"word"},{"id":41554,"position":16,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/005_040_017.mp3","charTypeName":"word"},{"id":41555,"position":17,"arabic":"كُلِّ","translation":"সব","audioUrl":"wbw/005_040_018.mp3","charTypeName":"word"},{"id":41556,"position":18,"arabic":"شَىْءٍۢ","translation":"কিছুরই","audioUrl":"wbw/005_040_019.mp3","charTypeName":"word"},{"id":41557,"position":19,"arabic":"قَدِيرٌۭ","translation":"সর্বশক্তিমান","audioUrl":"wbw/005_040_020.mp3","charTypeName":"word"},{"id":41558,"position":20,"arabic":"٤٠","translation":"(৪০)","audioUrl":null,"charTypeName":"end"}]},{"number":41,"arabic":"۞ يَٰٓأَيُّهَا ٱلرَّسُولُ لَا يَحْزُنكَ ٱلَّذِينَ يُسَٰرِعُونَ فِى ٱلْكُفْرِ مِنَ ٱلَّذِينَ قَالُوٓا۟ ءَامَنَّا بِأَفْوَٰهِهِمْ وَلَمْ تُؤْمِن قُلُوبُهُمْ ۛ وَمِنَ ٱلَّذِينَ هَادُوا۟ ۛ سَمَّٰعُونَ لِلْكَذِبِ سَمَّٰعُونَ لِقَوْمٍ ءَاخَرِينَ لَمْ يَأْتُوكَ ۖ يُحَرِّفُونَ ٱلْكَلِمَ مِنۢ بَعْدِ مَوَاضِعِهِۦ ۖ يَقُولُونَ إِنْ أُوتِيتُمْ هَٰذَا فَخُذُوهُ وَإِن لَّمْ تُؤْتَوْهُ فَٱحْذَرُوا۟ ۚ وَمَن يُرِدِ ٱللَّهُ فِتْنَتَهُۥ فَلَن تَمْلِكَ لَهُۥ مِنَ ٱللَّهِ شَيْـًٔا ۚ أُو۟لَٰٓئِكَ ٱلَّذِينَ لَمْ يُرِدِ ٱللَّهُ أَن يُطَهِّرَ قُلُوبَهُمْ ۚ لَهُمْ فِى ٱلدُّنْيَا خِزْىٌۭ ۖ وَلَهُمْ فِى ٱلْءَاخِرَةِ عَذَابٌ عَظِيمٌۭ","translation":"O APOSTLE! Be not grieved by those who vie with one another in denying the truth: such as those who say with their mouths, \"We believe,\" the while their hearts do not believe; and such of the Jewish faith as eagerly listen to any falsehood, eagerly listen to other people without having come to thee [for enlightenment]. They distort the meaning of the [revealed] words, taking them out of their context, saying [to themselves], \"If such-and-such [teaching] is vouchsafed unto you, accept it; but if it is not vouchsafed unto you, be on your guard!\" [Be not grieved by them-] for if God wills anyone to be tempted to evil, thou canst in no wise prevail with God in his behalf. It is they whose hearts God is not willing to cleanse. Theirs shall be ignominy in this world, and awesome suffering in the life to come-","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/710.mp3","surahId":5,"words":[{"id":42313,"position":1,"arabic":"۞ يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/005_041_002.mp3","charTypeName":"word"},{"id":42314,"position":2,"arabic":"ٱلرَّسُولُ","translation":"রাসূল","audioUrl":"wbw/005_041_003.mp3","charTypeName":"word"},{"id":42315,"position":3,"arabic":"لَا","translation":"(যেন) না","audioUrl":"wbw/005_041_004.mp3","charTypeName":"word"},{"id":42316,"position":4,"arabic":"يَحْزُنكَ","translation":"তোমাকে দুঃখ দেয়","audioUrl":"wbw/005_041_005.mp3","charTypeName":"word"},{"id":42317,"position":5,"arabic":"ٱلَّذِينَ","translation":"(তাদের কার্যক্রম) যারা","audioUrl":"wbw/005_041_006.mp3","charTypeName":"word"},{"id":42318,"position":6,"arabic":"يُسَـٰرِعُونَ","translation":"দ্রুত ধাবিত হয়","audioUrl":"wbw/005_041_007.mp3","charTypeName":"word"},{"id":42319,"position":7,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/005_041_008.mp3","charTypeName":"word"},{"id":42320,"position":8,"arabic":"ٱلْكُفْرِ","translation":"অবিশ্বাসের","audioUrl":"wbw/005_041_009.mp3","charTypeName":"word"},{"id":42321,"position":9,"arabic":"مِنَ","translation":"মধ্য হতে","audioUrl":"wbw/005_041_010.mp3","charTypeName":"word"},{"id":42322,"position":10,"arabic":"ٱلَّذِينَ","translation":"(তাদের) যারা","audioUrl":"wbw/005_041_011.mp3","charTypeName":"word"},{"id":42323,"position":11,"arabic":"قَالُوٓا۟","translation":"বলে","audioUrl":"wbw/005_041_012.mp3","charTypeName":"word"},{"id":42324,"position":12,"arabic":"ءَامَنَّا","translation":"\"ঈমান এনেছি আমরা\"","audioUrl":"wbw/005_041_013.mp3","charTypeName":"word"},{"id":42325,"position":13,"arabic":"بِأَفْوَٰهِهِمْ","translation":"দিয়ে মুখগুলো তাদের","audioUrl":"wbw/005_041_014.mp3","charTypeName":"word"},{"id":42326,"position":14,"arabic":"وَلَمْ","translation":"কিন্তু নি","audioUrl":"wbw/005_041_015.mp3","charTypeName":"word"},{"id":42327,"position":15,"arabic":"تُؤْمِن","translation":"ঈমান আনে","audioUrl":"wbw/005_041_016.mp3","charTypeName":"word"},{"id":42328,"position":16,"arabic":"قُلُوبُهُمْ ۛ","translation":"অন্তরগুলো তাদের","audioUrl":"wbw/005_041_017.mp3","charTypeName":"word"},{"id":42330,"position":17,"arabic":"وَمِنَ","translation":"এবং মধ্য হতে","audioUrl":"wbw/005_041_019.mp3","charTypeName":"word"},{"id":42331,"position":18,"arabic":"ٱلَّذِينَ","translation":"(তাদের) যারা","audioUrl":"wbw/005_041_020.mp3","charTypeName":"word"},{"id":42332,"position":19,"arabic":"هَادُوا۟ ۛ","translation":"ইয়াহুদী হয়েছে","audioUrl":"wbw/005_041_021.mp3","charTypeName":"word"},{"id":42334,"position":20,"arabic":"سَمَّـٰعُونَ","translation":"শুনতে বেশি আগ্রহী","audioUrl":"wbw/005_041_023.mp3","charTypeName":"word"},{"id":42335,"position":21,"arabic":"لِلْكَذِبِ","translation":"প্রতি মিথ্যার","audioUrl":"wbw/005_041_024.mp3","charTypeName":"word"},{"id":42336,"position":22,"arabic":"سَمَّـٰعُونَ","translation":"শুনতে বেশি আগ্রহী","audioUrl":"wbw/005_041_025.mp3","charTypeName":"word"},{"id":42337,"position":23,"arabic":"لِقَوْمٍ"