{"id":45,"ayahs":[{"number":265,"arabic":"وَمَثَلُ ٱلَّذِينَ يُنفِقُونَ أَمْوَٰلَهُمُ ٱبْتِغَآءَ مَرْضَاتِ ٱللَّهِ وَتَثْبِيتًۭا مِّنْ أَنفُسِهِمْ كَمَثَلِ جَنَّةٍۭ بِرَبْوَةٍ أَصَابَهَا وَابِلٌۭ فَـَٔاتَتْ أُكُلَهَا ضِعْفَيْنِ فَإِن لَّمْ يُصِبْهَا وَابِلٌۭ فَطَلٌّۭ ۗ وَٱللَّهُ بِمَا تَعْمَلُونَ بَصِيرٌ","translation":"And the parable of those who spend their possessions out of a longing to please God, and out of their own inner certainty, is that of a garden on high, fertile ground: a rainstorm smites it, and thereupon it brings forth its fruit twofold; and if no rainstorm smites it, soft rain [falls upon it]. And God sees all that you do.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/272.mp3","surahId":2,"words":[{"id":87537,"position":1,"arabic":"وَمَثَلُ","translation":"এবং উপমা","audioUrl":"wbw/002_265_001.mp3","charTypeName":"word"},{"id":87538,"position":2,"arabic":"ٱلَّذِينَ","translation":"(তাদের) যারা","audioUrl":"wbw/002_265_002.mp3","charTypeName":"word"},{"id":87539,"position":3,"arabic":"يُنفِقُونَ","translation":"ব্যয় করে","audioUrl":"wbw/002_265_003.mp3","charTypeName":"word"},{"id":87540,"position":4,"arabic":"أَمْوَٰلَهُمُ","translation":"তাদের সম্পদগুলো","audioUrl":"wbw/002_265_004.mp3","charTypeName":"word"},{"id":87541,"position":5,"arabic":"ٱبْتِغَآءَ","translation":"সন্ধানে","audioUrl":"wbw/002_265_005.mp3","charTypeName":"word"},{"id":87542,"position":6,"arabic":"مَرْضَاتِ","translation":"সন্তুষ্টির","audioUrl":"wbw/002_265_006.mp3","charTypeName":"word"},{"id":87543,"position":7,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/002_265_007.mp3","charTypeName":"word"},{"id":87544,"position":8,"arabic":"وَتَثْبِيتًۭا","translation":"এবং সুদৃঢ় করতে","audioUrl":"wbw/002_265_008.mp3","charTypeName":"word"},{"id":87545,"position":9,"arabic":"مِّنْ","translation":"বিষয়টিকে","audioUrl":"wbw/002_265_009.mp3","charTypeName":"word"},{"id":87546,"position":10,"arabic":"أَنفُسِهِمْ","translation":"তাদের আত্মার","audioUrl":"wbw/002_265_010.mp3","charTypeName":"word"},{"id":87547,"position":11,"arabic":"كَمَثَلِ","translation":"(তাদের) উপমা যেমন","audioUrl":"wbw/002_265_011.mp3","charTypeName":"word"},{"id":87548,"position":12,"arabic":"جَنَّةٍۭ","translation":"একটি বাগানের","audioUrl":"wbw/002_265_012.mp3","charTypeName":"word"},{"id":87549,"position":13,"arabic":"بِرَبْوَةٍ","translation":"উঁচু ভূমিতে অবস্থিত","audioUrl":"wbw/002_265_013.mp3","charTypeName":"word"},{"id":87550,"position":14,"arabic":"أَصَابَهَا","translation":"তাতে বর্ষিত হয়","audioUrl":"wbw/002_265_014.mp3","charTypeName":"word"},{"id":87551,"position":15,"arabic":"وَابِلٌۭ","translation":"প্রবল বৃষ্টি","audioUrl":"wbw/002_265_015.mp3","charTypeName":"word"},{"id":87552,"position":16,"arabic":"فَـَٔاتَتْ","translation":"আসে অতঃপর","audioUrl":"wbw/002_265_016.mp3","charTypeName":"word"},{"id":87553,"position":17,"arabic":"أُكُلَهَا","translation":"তার ফলমূল","audioUrl":"wbw/002_265_017.mp3","charTypeName":"word"},{"id":87554,"position":18,"arabic":"ضِعْفَيْنِ","translation":"দ্বিগুণ","audioUrl":"wbw/002_265_018.mp3","charTypeName":"word"},{"id":87555,"position":19,"arabic":"فَإِن","translation":"যদি তবে","audioUrl":"wbw/002_265_019.mp3","charTypeName":"word"},{"id":87556,"position":20,"arabic":"لَّمْ","translation":"না","audioUrl":"wbw/002_265_020.mp3","charTypeName":"word"},{"id":87557,"position":21,"arabic":"يُصِبْهَا","translation":"তাতে বর্ষিত হয়","audioUrl":"wbw/002_265_021.mp3","charTypeName":"word"},{"id":87558,"position":22,"arabic":"وَابِلٌۭ","translation":"প্রবল বৃষ্টি","audioUrl":"wbw/002_265_022.mp3","charTypeName":"word"},{"id":87559,"position":23,"arabic":"فَطَلٌّۭ ۗ","translation":"সামান্য তবে বৃষ্টিই (যথেষ্ট)","audioUrl":"wbw/002_265_023.mp3","charTypeName":"word"},{"id":87561,"position":24,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/002_265_025.mp3","charTypeName":"word"},{"id":87562,"position":25,"arabic":"بِمَا","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/002_265_026.mp3","charTypeName":"word"},{"id":87563,"position":26,"arabic":"تَعْمَلُونَ","translation":"তোমরা কাজ করছ","audioUrl":"wbw/002_265_027.mp3","charTypeName":"word"},{"id":87564,"position":27,"arabic":"بَصِيرٌ","translation":"সম্যক দ্রষ্টা","audioUrl":"wbw/002_265_028.mp3","charTypeName":"word"},{"id":87565,"position":28,"arabic":"٢٦٥","translation":"(২৬৫)","audioUrl":null,"charTypeName":"end"}]},{"number":266,"arabic":"أَيَوَدُّ أَحَدُكُمْ أَن تَكُونَ لَهُۥ جَنَّةٌۭ مِّن نَّخِيلٍۢ وَأَعْنَابٍۢ تَجْرِى مِن تَحْتِهَا ٱلْأَنْهَٰرُ لَهُۥ فِيهَا مِن كُلِّ ٱلثَّمَرَٰتِ وَأَصَابَهُ ٱلْكِبَرُ وَلَهُۥ ذُرِّيَّةٌۭ ضُعَفَآءُ فَأَصَابَهَآ إِعْصَارٌۭ فِيهِ نَارٌۭ فَٱحْتَرَقَتْ ۗ كَذَٰلِكَ يُبَيِّنُ ٱللَّهُ لَكُمُ ٱلْءَايَٰتِ لَعَلَّكُمْ تَتَفَكَّرُونَ","translation":"Would any of you like to have a garden of date-palms and vines, through which running waters flow, and have all manner of fruit therein - and then be overtaken by old age, with only weak children to [look after] him-and then [see] it smitten by a fiery whirlwind and utterly scorched? In this way God makes clear His messages unto you, so that you might take thought.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/273.mp3","surahId":2,"words":[{"id":87566,"position":1,"arabic":"أَيَوَدُّ","translation":"কামনা করে কি","audioUrl":"wbw/002_266_001.mp3","charTypeName":"word"},{"id":87567,"position":2,"arabic":"أَحَدُكُمْ","translation":"তোমাদের কেউ","audioUrl":"wbw/002_266_002.mp3","charTypeName":"word"},{"id":87568,"position":3,"arabic":"أَن","translation":"যে","audioUrl":"wbw/002_266_003.mp3","charTypeName":"word"},{"id":87569,"position":4,"arabic":"تَكُونَ","translation":"হবে","audioUrl":"wbw/002_266_004.mp3","charTypeName":"word"},{"id":87570,"position":5,"arabic":"لَهُۥ","translation":"তার জন্য","audioUrl":"wbw/002_266_005.mp3","charTypeName":"word"},{"id":87571,"position":6,"arabic":"جَنَّةٌۭ","translation":"একটি বাগান","audioUrl":"wbw/002_266_006.mp3","charTypeName":"word"},{"id":87572,"position":7,"arabic":"مِّن","translation":"এর","audioUrl":"wbw/002_266_007.mp3","charTypeName":"word"},{"id":87573,"position":8,"arabic":"نَّخِيلٍۢ","translation":"খেজুর","audioUrl":"wbw/002_266_008.mp3","charTypeName":"word"},{"id":87574,"position":9,"arabic":"وَأَعْنَابٍۢ","translation":"ও আঙ্গুরের","audioUrl":"wbw/002_266_009.mp3","charTypeName":"word"},{"id":87575,"position":10,"arabic":"تَجْرِى","translation":"প্রবাহিত হয়","audioUrl":"wbw/002_266_010.mp3","charTypeName":"word"},{"id":87576,"position":11,"arabic":"مِن","translation":"দিয়ে","audioUrl":"wbw/002_266_011.mp3","charTypeName":"word"},{"id":87577,"position":12,"arabic":"تَحْتِهَا","translation":"তার নিচ","audioUrl":"wbw/002_266_012.mp3","charTypeName":"word"},{"id":87578,"position":13,"arabic":"ٱلْأَنْهَـٰرُ","translation":"ঝর্ণাসমূহ","audioUrl":"wbw/002_266_013.mp3","charTypeName":"word"},{"id":87579,"position":14,"arabic":"لَهُۥ","translation":"তার (আছে)","audioUrl":"wbw/002_266_014.mp3","charTypeName":"word"},{"id":87580,"position":15,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/002_266_015.mp3","charTypeName":"word"},{"id":87581,"position":16,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/002_266_016.mp3","charTypeName":"word"},{"id":87582,"position":17,"arabic":"كُلِّ","translation":"সব ধরণের","audioUrl":"wbw/002_266_017.mp3","charTypeName":"word"},{"id":87583,"position":18,"arabic":"ٱلثَّمَرَٰتِ","translation":"ফলমূল","audioUrl":"wbw/002_266_018.mp3","charTypeName":"word"},{"id":87584,"position":19,"arabic":"وَأَصَابَهُ","translation":"এবং তার আপতিত হল","audioUrl":"wbw/002_266_019.mp3","charTypeName":"word"},{"id":87585,"position":20,"arabic":"ٱلْكِبَرُ","translation":"বার্ধক্য","audioUrl":"wbw/002_266_020.mp3","charTypeName":"word"},{"id":87586,"position":21,"arabic":"وَلَهُۥ","translation":"যখন তার আছে","audioUrl":"wbw/002_266_021.mp3","charTypeName":"word"},{"id":87587,"position":22,"arabic":"ذُرِّيَّةٌۭ","translation":"সন্তান সন্ততি","audioUrl":"wbw/002_266_022.mp3","charTypeName":"word"},{"id":8