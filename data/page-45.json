/002_267_029.mp3","charTypeName":"word"},{"id":87632,"position":28,"arabic":"غَنِىٌّ","translation":"অভাবমুক্ত","audioUrl":"wbw/002_267_030.mp3","charTypeName":"word"},{"id":87633,"position":29,"arabic":"حَمِيدٌ","translation":"প্রশংসিত","audioUrl":"wbw/002_267_031.mp3","charTypeName":"word"},{"id":87634,"position":30,"arabic":"٢٦٧","translation":"(২৬৭)","audioUrl":null,"charTypeName":"end"}]},{"number":268,"arabic":"ٱلشَّيْطَٰنُ يَعِدُكُمُ ٱلْفَقْرَ وَيَأْمُرُكُم بِٱلْفَحْشَآءِ ۖ وَٱللَّهُ يَعِدُكُم مَّغْفِرَةًۭ مِّنْهُ وَفَضْلًۭا ۗ وَٱللَّهُ وَٰسِعٌ عَلِيمٌۭ","translation":"Satan threatens you with the prospect of poverty and bids you to be niggardly, whereas God promises you His forgiveness and bounty; and God is infinite, all-knowing,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/275.mp3","surahId":2,"words":[{"id":87635,"position":1,"arabic":"ٱلشَّيْطَـٰنُ","translation":"শয়তান","audioUrl":"wbw/002_268_001.mp3","charTypeName":"word"},{"id":87636,"position":2,"arabic":"يَعِدُكُمُ","translation":"তোমাদের ভয় দেখায়","audioUrl":"wbw/002_268_002.mp3","charTypeName":"word"},{"id":87637,"position":3,"arabic":"ٱلْفَقْرَ","translation":"দারিদ্র্যের","audioUrl":"wbw/002_268_003.mp3","charTypeName":"word"},{"id":87638,"position":4,"arabic":"وَيَأْمُرُكُم","translation":"এবং নির্দেশ দেয়","audioUrl":"wbw/002_268_004.mp3","charTypeName":"word"},{"id":87639,"position":5,"arabic":"بِٱلْفَحْشَآءِ ۖ","translation":"অশ্লীলতার","audioUrl":"wbw/002_268_005.mp3","charTypeName":"word"},{"id":87641,"position":6,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/002_268_007.mp3","charTypeName":"word"},{"id":87642,"position":7,"arabic":"يَعِدُكُم","translation":"তোমাদের প্রতিশ্রুতি দেন","audioUrl":"wbw/002_268_008.mp3","charTypeName":"word"},{"id":87643,"position":8,"arabic":"مَّغْفِرَةًۭ","translation":"ক্ষমার","audioUrl":"wbw/002_268_009.mp3","charTypeName":"word"},{"id":87644,"position":9,"arabic":"مِّنْهُ","translation":"তাঁর থেকে","audioUrl":"wbw/00