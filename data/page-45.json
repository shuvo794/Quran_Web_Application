تُنفِقُونَ وَلَسْتُم بِـَٔاخِذِيهِ إِلَّآ أَن تُغْمِضُوا۟ فِيهِ ۚ وَٱعْلَمُوٓا۟ أَنَّ ٱللَّهَ غَنِىٌّ حَمِيدٌ","translation":"O you who have attained to faith! Spend on others out of the good things which you may have acquired, and out of that which We bring forth for you from the earth; and choose not for your spending the bad things which you yourselves would not accept without averting your eyes in disdain. And know that God is self-sufficient, ever to be praised.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/274.mp3","surahId":2,"words":[{"id":87603,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/002_267_001.mp3","charTypeName":"word"},{"id":87604,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/002_267_002.mp3","charTypeName":"word"},{"id":87605,"position":3,"arabic":"ءَامَنُوٓا۟","translation":"ঈমান এনেছ","audioUrl":"wbw/002_267_003.mp3","charTypeName":"word"},{"id":87606,"position":4,"arabic":"أَنفِقُوا۟","translation":"ব্যয় কর তোমরা","audioUrl":"wbw/002_267_004.mp3","charTypeName":"word"},{"id":87607,"position":5,"arabic":"مِن","translation":"হতে","audioUrl":"wbw/002_267_005.mp3","charTypeName":"word"},{"id":87608,"position":6,"arabic":"طَيِّبَـٰتِ","translation":"পবিত্র জিনিসগুলো","audioUrl":"wbw/002_267_006.mp3","charTypeName":"word"},{"id":87609,"position":7,"arabic":"مَا","translation":"যা","audioUrl":"wbw/002_267_007.mp3","charTypeName":"word"},{"id":87610,"position":8,"arabic":"كَسَبْتُمْ","translation":"তোমরা অর্জন করেছ","audioUrl":"wbw/002_267_008.mp3","charTypeName":"word"},{"id":87611,"position":9,"arabic":"وَمِمَّآ","translation":"এবং তা হতেও যা","audioUrl":"wbw/002_267_009.mp3","charTypeName":"word"},{"id":87612,"position":10,"arabic":"أَخْرَجْنَا","translation":"বের করেছি আমরা","audioUrl":"wbw/002_267_010.mp3","charTypeName":"word"},{"id":87613,"position":11,"arabic":"لَكُم","translation":"তোমাদের জন্য","audioUrl":"wbw/002_267_011.mp3","charTypeName":"word"},{"id":87614,"positi