,{"id":29771,"position":9,"arabic":"فَاجِرًۭا","translation":"পাপাচারী","audioUrl":"wbw/071_027_009.mp3","charTypeName":"word"},{"id":29772,"position":10,"arabic":"كَفَّارًۭا","translation":"কট্টর কাফির","audioUrl":"wbw/071_027_010.mp3","charTypeName":"word"},{"id":29773,"position":11,"arabic":"٢٧","translation":"(২৭)","audioUrl":null,"charTypeName":"end"}]},{"number":28,"arabic":"رَّبِّ ٱغْفِرْ لِى وَلِوَٰلِدَىَّ وَلِمَن دَخَلَ بَيْتِىَ مُؤْمِنًۭا وَلِلْمُؤْمِنِينَ وَٱلْمُؤْمِنَٰتِ وَلَا تَزِدِ ٱلظَّٰلِمِينَ إِلَّا تَبَارًۢا","translation":"\"O my Sustainer! Grant Thy forgiveness unto me and unto my parents, and unto everyone who enters my house as a believer, and unto all believing men and believing women [of later times]; and grant Thou that the doers of evil shall increasingly meet with destruction!\"'","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5447.mp3","surahId":71,"words":[{"id":30858,"position":1,"arabic":"رَّبِّ","translation":"হে আমার রব","audioUrl":"wbw/071_028_001.mp3","charTypeName":"word"},{"id":30859,"position":2,"arabic":"ٱغْفِرْ","translation":"মাফ করুন","audioUrl":"wbw/071_028_002.mp3","charTypeName":"word"},{"id":30860,"position":3,"arabic":"لِى","translation":"আমাকে","audioUrl":"wbw/071_028_003.mp3","charTypeName":"word"},{"id":30861,"position":4,"arabic":"وَلِوَٰلِدَىَّ","translation":"ও আমার পিতা-মাতাকে","audioUrl":"wbw/071_028_004.mp3","charTypeName":"word"},{"id":30862,"position":5,"arabic":"وَلِمَن","translation":"ও যে (তার) জন্য","audioUrl":"wbw/071_028_005.mp3","charTypeName":"word"},{"id":30863,"position":6,"arabic":"دَخَلَ","translation":"প্রবেশ করেছে","audioUrl":"wbw/071_028_006.mp3","charTypeName":"word"},{"id":30864,"position":7,"arabic":"بَيْتِىَ","translation":"আমার ঘরে","audioUrl":"wbw/071_028_007.mp3","charTypeName":"word"},{"id":30865,"position":8,"arabic":"مُؤْمِنًۭا","translation":"মু'মিন রূপে","audioUrl":"wbw/071_028_008.mp3","charTypeName":"word"},{"id":30866,"position":9,"arabic":"وَلِلْمُؤْمِنِينَ","translation":"এবং মু'মিনপুরুষদের জন্যে","audioUrl":"wbw/071_028_009.mp3","charTypeName":"word"},{"id":30867,"position":10,"arabic":"وَٱلْمُؤْمِنَـٰتِ","translation":"মুমিন স্ত্রীলোকদের","audioUrl":"wbw/071_028_010.mp3","charTypeName":"word"},{"id":30868,"position":11,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/071_028_011.mp3","charTypeName":"word"},{"id":30869,"position":12,"arabic":"تَزِدِ","translation":"বাড়াবেন","audioUrl":"wbw/071_028_012.mp3","charTypeName":"word"},{"id":30870,"position":13,"arabic":"ٱلظَّـٰلِمِينَ","translation":"জালেমদের অন্যকিছু","audioUrl":"wbw/071_028_013.mp3","charTypeName":"word"},{"id":30871,"position":14,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/071_028_014.mp3","charTypeName":"word"},{"id":30872,"position":15,"arabic":"تَبَارًۢا","translation":"ধ্বংস\"","audioUrl":"wbw/071_028_015.mp3","charTypeName":"word"},{"id":30873,"position":16,"arabic":"٢٨","translation":"(২৮)","audioUrl":null,"charTypeName":"end"}]}]}