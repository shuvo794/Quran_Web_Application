{"id":199,"ayahs":[{"number":73,"arabic":"يَٰٓأَيُّهَا ٱلنَّبِىُّ جَٰهِدِ ٱلْكُفَّارَ وَٱلْمُنَٰفِقِينَ وَٱغْلُظْ عَلَيْهِمْ ۚ وَمَأْوَىٰهُمْ جَهَنَّمُ ۖ وَبِئْسَ ٱلْمَصِيرُ","translation":"O PROPHET! Strive hard against the deniers of the truth and the hypocrites, and be adamant with them. And [if they do not repent,] their goal shall be hell -and how vile a journey's end!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1308.mp3","surahId":9,"words":[{"id":60912,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/009_073_001.mp3","charTypeName":"word"},{"id":60913,"position":2,"arabic":"ٱلنَّبِىُّ","translation":"নাবী","audioUrl":"wbw/009_073_002.mp3","charTypeName":"word"},{"id":60914,"position":3,"arabic":"جَـٰهِدِ","translation":"জিহাদ করো","audioUrl":"wbw/009_073_003.mp3","charTypeName":"word"},{"id":60915,"position":4,"arabic":"ٱلْكُفَّارَ","translation":"কাফেরদের বিরুদ্ধে","audioUrl":"wbw/009_073_004.mp3","charTypeName":"word"},{"id":60916,"position":5,"arabic":"وَٱلْمُنَـٰفِقِينَ","translation":"ও মুনাফিকদের (বিরুদ্ধে)","audioUrl":"wbw/009_073_005.mp3","charTypeName":"word"},{"id":60917,"position":6,"arabic":"وَٱغْلُظْ","translation":"ও কঠোর হও","audioUrl":"wbw/009_073_006.mp3","charTypeName":"word"},{"id":60918,"position":7,"arabic":"عَلَيْهِمْ ۚ","translation":"প্রতি তাদের","audioUrl":"wbw/009_073_007.mp3","charTypeName":"word"},{"id":60920,"position":8,"arabic":"وَمَأْوَىٰهُمْ","translation":"এবং তাদের ঠিকানা","audioUrl":"wbw/009_073_009.mp3","charTypeName":"word"},{"id":60921,"position":9,"arabic":"جَهَنَّمُ ۖ","translation":"জাহান্নাম","audioUrl":"wbw/009_073_010.mp3","charTypeName":"word"},{"id":60923,"position":10,"arabic":"وَبِئْسَ","translation":"ও (তা) অতি নিকৃষ্ট","audioUrl":"wbw/009_073_012.mp3","charTypeName":"word"},{"id":60924,"position":11,"arabic":"ٱلْمَصِيرُ","translation":"প্রত্যাবর্তন স্হান","audioUrl":"wbw/009_073_013.mp3","charTypeName":"word"},{"id":60925,"position":12,"arabic":"٧٣","translation":"(৭৩)","audioUrl":null,"charTypeName":"end"}]},{"number":74,"arabic":"يَحْلِفُونَ بِٱللَّهِ مَا قَالُوا۟ وَلَقَدْ قَالُوا۟ كَلِمَةَ ٱلْكُفْرِ وَكَفَرُوا۟ بَعْدَ إِسْلَٰمِهِمْ وَهَمُّوا۟ بِمَا لَمْ يَنَالُوا۟ ۚ وَمَا نَقَمُوٓا۟ إِلَّآ أَنْ أَغْنَىٰهُمُ ٱللَّهُ وَرَسُولُهُۥ مِن فَضْلِهِۦ ۚ فَإِن يَتُوبُوا۟ يَكُ خَيْرًۭا لَّهُمْ ۖ وَإِن يَتَوَلَّوْا۟ يُعَذِّبْهُمُ ٱللَّهُ عَذَابًا أَلِيمًۭا فِى ٱلدُّنْيَا وَٱلْءَاخِرَةِ ۚ وَمَا لَهُمْ فِى ٱلْأَرْضِ مِن وَلِىٍّۢ وَلَا نَصِيرٍۢ","translation":"[The hypocrites] swear by God that they have said nothing [wrong]; yet most certainly have they uttered a saying which amounts to a denial of the truth, and have [thus] denied the truth after [having professed] their self-surrender to God: for they were aiming at something which was beyond their reach. And they could find no fault [with the Faith] save that God had enriched them and [caused] His Apostle [to enrich them] out of His bounty! Hence, if they repent, it will be for their own good. But if they turn away, God will cause them to suffer grievous suffering in this world and in the life to come, and they will find no helper on earth, and none to give [them] succour.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1309.mp3","surahId":9,"words":[{"id":61671,"position":1,"arabic":"يَحْلِفُونَ","translation":"তারা শপথ করে (বলে)","audioUrl":"wbw/009_074_001.mp3","charTypeName":"word"},{"id":61672,"position":2,"arabic":"بِٱللَّهِ","translation":"নামে আল্লাহর","audioUrl":"wbw/009_074_002.mp3","charTypeName":"word"},{"id":61673,"position":3,"arabic":"مَا","translation":"না","audioUrl":"wbw/009_074_003.mp3","charTypeName":"word"},{"id":61674,"position":4,"arabic":"قَالُوا۟","translation":"তারা বলেছে","audioUrl":"wbw/009_074_004.mp3","charTypeName":"word"},{"id":61675,"position":5,"arabic":"وَلَقَدْ","translation":"অথচ নিশ্চয়ই","audioUrl":"wbw/009_074_005.mp3","charTypeName":"word"},{"id":61676,"position":6,"arabic":"قَالُوا۟","translation":"তারা বলেছে","audioUrl":"wbw/009_074_006.mp3","charTypeName":"word"},{"id":61677,"position":7,"arabic":"كَلِمَةَ","translation":"কথা","audioUrl":"wbw/009_074_007.mp3","charTypeName":"word"},{"id":61678,"position":8,"arabic":"ٱلْكُفْرِ","translation":"অবিশ্বাসের","audioUrl":"wbw/009_074_008.mp3","charTypeName":"word"},{"id":61679,"position":9,"arabic":"وَكَفَرُوا۟","translation":"এবং তারা অবিশ্বাস করেছে","audioUrl":"wbw/009_074_009.mp3","charTypeName":"word"},{"id":61680,"position":10,"arabic":"بَعْدَ","translation":"পরেও","audioUrl":"wbw/009_074_010.mp3","charTypeName":"word"},{"id":61681,"position":11,"arabic":"إِسْلَـٰمِهِمْ","translation":"তাদের ইসলাম গ্রহণের","audioUrl":"wbw/009_074_011.mp3","charTypeName":"word"},{"id":61682,"position":12,"arabic":"وَهَمُّوا۟","translation":"ও তারা ইচ্ছে করেছিলো","audioUrl":"wbw/009_074_012.mp3","charTypeName":"word"},{"id":61683,"position":13,"arabic":"بِمَا","translation":"বিষয়ে এমন যা","audioUrl":"wbw/009_074_013.mp3","charTypeName":"word"},{"id":61684,"position":14,"arabic":"لَمْ","translation":"নি","audioUrl":"wbw/009_074_014.mp3","charTypeName":"word"},{"id":61685,"position":15,"arabic":"يَنَالُوا۟ ۚ","translation":"তাদের হাতে পৌঁছে","audioUrl":"wbw/009_074_015.mp3","charTypeName":"word"},{"id":61687,"position":16,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/009_074_017.mp3","charTypeName":"word"},{"id":61688,"position":17,"arabic":"نَقَمُوٓا۟","translation":"তারা প্রতিশোধ নিচ্ছে","audioUrl":"wbw/009_074_018.mp3","charTypeName":"word"},{"id":61689,"position":18,"arabic":"إِلَّآ","translation":"এছাড়া (অন্যকিছুর)","audioUrl":"wbw/009_074_019.mp3","charTypeName":"word"},{"id":61690,"position":19,"arabic":"أَنْ","translation":"যে","audioUrl":"wbw/009_074_020.mp3","charTypeName":"word"},{"id":61691,"position":20,"arabic":"أَغْنَىٰهُمُ","translation":"ধনী করেছিলেন তাদের","audioUrl":"wbw/009_074_021.mp3","charTypeName":"word"},{"id":61692,"position":21,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/009_074_022.mp3","charTypeName":"word"},{"id":61693,"position":22,"arabic":"وَرَسُولُهُۥ","translation":"ও  রাসূল তাঁর","audioUrl":"wbw/009_074_023.mp3","charTypeName":"word"},{"id":61694,"position":23,"arabic":"مِن","translation":"দিয়ে","audioUrl":"wbw/009_074_024.mp3","charTypeName":"word"},{"id":61695,"position":24,"arabic":"فَضْلِهِۦ ۚ","translation":"অনুগ্রহ তাঁর","audioUrl":"wbw/009_074_025.mp3","charTypeName":"word"},{"id":61697,"position":25,"arabic":"فَإِن","translation":"অতএব যদি","audioUrl":"wbw/009_074_027.mp3","charTypeName":"word"},{"id":61698,"position":26,"arabic":"يَتُوبُوا۟","translation":"তারা তওবা করে","audioUrl":"wbw/009_074_028.mp3","charTypeName":"word"},{"id":61699,"position":27,"arabic":"يَكُ","translation":"তা হবে","audioUrl":"wbw/009_074_029.mp3","charTypeName":"word"},{"id":61700,"position":28,"arabic":"خَيْرًۭا","translation":"উত্তম","audioUrl":"wbw/009_074_030.mp3","charTypeName":"word"},{"id":61701,"position":29,"arabic":"لَّهُمْ ۖ","translation":"জন্যে তাদের","audioUrl":"wbw/009_074_031.mp3","charTypeName":"word"},{"id":61703,"position":30,"arabic":"وَإِن","translation":"এবং যদি","audioUrl":"wbw/009_074_033.mp3","charTypeName":"word"},{"id":61704,"position":31,"arabic":"يَتَوَلَّوْا۟","translation":"তারা ফিরে যায়","audioUrl":"wbw/009_074_034.mp3","charTypeName":"word"},{"id":61705,"position":32,"arabic":"يُعَذِّبْهُمُ","translation":"শাস্তি দিবেন তাদেরকে","audioUrl":"wbw/009_074_035.mp3","charTypeName":"word"},{"id":61706,"position":33,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/009_074_036.mp3","charTypeName":"word"},{"id":61707,"position":34,"arabic":"عَذَابًا","translation":"শাস্তি","audioUrl":"wbw/009_074_037.mp3","charTypeName":"word"},{"id":61708,"position":35,"arabic":"أَلِيمًۭا","translation":"অতি কষ্টদায়ক","audioUrl":"wbw/009_074_038.mp3","charTypeName":"word"},{"id":61709,"position":36,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/009_074_039.mp3","charTypeName":"word"},{"id":61710,"position":37,"arabic":"ٱلدُّنْيَا","translation":"পৃ