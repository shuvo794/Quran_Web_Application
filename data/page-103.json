rTypeName":"word"},{"id":81876,"position":9,"arabic":"بِٱلْبَـٰطِلِ ۚ","translation":"অন্যায়ভাবে (এ কঠোরতা দিয়েছিলাম)","audioUrl":"wbw/004_161_009.mp3","charTypeName":"word"},{"id":81878,"position":10,"arabic":"وَأَعْتَدْنَا","translation":"ও আমরা প্রস্তুত করে রেখেছি","audioUrl":"wbw/004_161_011.mp3","charTypeName":"word"},{"id":81879,"position":11,"arabic":"لِلْكَـٰفِرِينَ","translation":"কাফিরদের জন্য","audioUrl":"wbw/004_161_012.mp3","charTypeName":"word"},{"id":81880,"position":12,"arabic":"مِنْهُمْ","translation":"তাদের মধ্যকার","audioUrl":"wbw/004_161_013.mp3","charTypeName":"word"},{"id":81881,"position":13,"arabic":"عَذَابًا","translation":"শাস্তি","audioUrl":"wbw/004_161_014.mp3","charTypeName":"word"},{"id":81882,"position":14,"arabic":"أَلِيمًۭا","translation":"মর্মন্তুদ","audioUrl":"wbw/004_161_015.mp3","charTypeName":"word"},{"id":81883,"position":15,"arabic":"١٦١","translation":"(১৬১)","audioUrl":null,"charTypeName":"end"}]},{"number":162,"arabic":"لَّٰكِنِ ٱلرَّٰسِخُونَ فِى ٱلْعِلْمِ مِنْهُمْ وَٱلْمُؤْمِنُونَ يُؤْمِنُونَ بِمَآ أُنزِلَ إِلَيْكَ وَمَآ أُنزِلَ مِن قَبْلِكَ ۚ وَٱلْمُقِيمِينَ ٱلصَّلَوٰةَ ۚ وَٱلْمُؤْتُونَ ٱلزَّكَوٰةَ وَٱلْمُؤْمِنُونَ بِٱللَّهِ وَٱلْيَوْمِ ٱلْءَاخِرِ أُو۟لَٰٓئِكَ سَنُؤْتِيهِمْ أَجْرًا عَظِيمًا","translation":"But as for those from among them who are deeply rooted in knowledge, and the believers who believe in that which has been bestowed upon thee from on high as well as that which was bestowed from on high before thee, and those who are [es­pecially] constant in prayer, and spend in charity, and all who believe in God and the Last Day - these it is unto whom We shall grant a mighty reward.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/655.mp3","surahId":4,"words":[{"id":82012,"position":1,"arabic":"لَّـٰكِنِ","translation":"কিন্তু","audioUrl":"wbw/004_162_001.mp3","charTypeName":"word"},{"id":82013,"position":2,"arabic":"ٱلرَّٰسِخُونَ","translation":"সুগভীর ব্যক্তিরা","audioUrl":"wbw/004_162_002.mp3","c