{"id":230,"ayahs":[{"number":72,"arabic":"قَالَتْ يَٰوَيْلَتَىٰٓ ءَأَلِدُ وَأَنَا۠ عَجُوزٌۭ وَهَٰذَا بَعْلِى شَيْخًا ۖ إِنَّ هَٰذَا لَشَىْءٌ عَجِيبٌۭ","translation":"Said she: \"Oh, woe is me! Shall I bear a child, now that I am an old woman and this husband of mine is an old man? Verily, that would be a strange thing indeed!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1545.mp3","surahId":11,"words":[{"id":60388,"position":1,"arabic":"قَالَتْ","translation":"সে বললো","audioUrl":"wbw/011_072_001.mp3","charTypeName":"word"},{"id":60389,"position":2,"arabic":"يَـٰوَيْلَتَىٰٓ","translation":"\"হায়, কি আশ্চর্য!","audioUrl":"wbw/011_072_002.mp3","charTypeName":"word"},{"id":60390,"position":3,"arabic":"ءَأَلِدُ","translation":"আমি কি সন্তান প্রসব করবো","audioUrl":"wbw/011_072_003.mp3","charTypeName":"word"},{"id":60391,"position":4,"arabic":"وَأَنَا۠","translation":"অথচ আমি","audioUrl":"wbw/011_072_004.mp3","charTypeName":"word"},{"id":60392,"position":5,"arabic":"عَجُوزٌۭ","translation":"বৃদ্ধা","audioUrl":"wbw/011_072_005.mp3","charTypeName":"word"},{"id":60393,"position":6,"arabic":"وَهَـٰذَا","translation":"এবং এই","audioUrl":"wbw/011_072_006.mp3","charTypeName":"word"},{"id":60394,"position":7,"arabic":"بَعْلِى","translation":"আমার স্বামী","audioUrl":"wbw/011_072_007.mp3","charTypeName":"word"},{"id":60395,"position":8,"arabic":"شَيْخًا ۖ","translation":"বৃদ্ধ","audioUrl":"wbw/011_072_008.mp3","charTypeName":"word"},{"id":60397,"position":9,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/011_072_010.mp3","charTypeName":"word"},{"id":60398,"position":10,"arabic":"هَـٰذَا","translation":"এটা","audioUrl":"wbw/011_072_011.mp3","charTypeName":"word"},{"id":60399,"position":11,"arabic":"لَشَىْءٌ","translation":"অবশ্যই ব্যাপার","audioUrl":"wbw/011_072_012.mp3","charTypeName":"word"},{"id":60400,"position":12,"arabic":"عَجِيبٌۭ","translation":"অদ্ভুত\"","audioUrl":"wbw/011_072_013.mp3","charTypeName":"word"},{"id":60401,"position":13,"arabic":"٧٢","translation":"(৭২)","audioUrl":null,"charTypeName":"end"}]},{"number":73,"arabic":"قَالُوٓا۟ أَتَعْجَبِينَ مِنْ أَمْرِ ٱللَّهِ ۖ رَحْمَتُ ٱللَّهِ وَبَرَكَٰتُهُۥ عَلَيْكُمْ أَهْلَ ٱلْبَيْتِ ۚ إِنَّهُۥ حَمِيدٌۭ مَّجِيدٌۭ","translation":"Answered [the messengers]: \"Dost thou deem it strange that God should decree what He wills? The grace of God and His blessings be upon you, O people of this house! Verily, ever to be praised, sublime is He!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1546.mp3","surahId":11,"words":[{"id":61176,"position":1,"arabic":"قَالُوٓا۟","translation":"তারা বলেছিলো","audioUrl":"wbw/011_073_001.mp3","charTypeName":"word"},{"id":61177,"position":2,"arabic":"أَتَعْجَبِينَ","translation":"\"তুমি বিস্মিত হচ্ছো কি","audioUrl":"wbw/011_073_002.mp3","charTypeName":"word"},{"id":61178,"position":3,"arabic":"مِنْ","translation":"সম্পর্কে","audioUrl":"wbw/011_073_003.mp3","charTypeName":"word"},{"id":61179,"position":4,"arabic":"أَمْرِ","translation":"নির্দেশ","audioUrl":"wbw/011_073_004.mp3","charTypeName":"word"},{"id":61180,"position":5,"arabic":"ٱللَّهِ ۖ","translation":"আল্লাহর","audioUrl":"wbw/011_073_005.mp3","charTypeName":"word"},{"id":61182,"position":6,"arabic":"رَحْمَتُ","translation":"অনুগ্রহ","audioUrl":"wbw/011_073_007.mp3","charTypeName":"word"},{"id":61183,"position":7,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/011_073_008.mp3","charTypeName":"word"},{"id":61184,"position":8,"arabic":"وَبَرَكَـٰتُهُۥ","translation":"এবং তার কল্যাণসমূহ (হ'তেও)","audioUrl":"wbw/011_073_009.mp3","charTypeName":"word"},{"id":61185,"position":9,"arabic":"عَلَيْكُمْ","translation":"তোমাদের উপর","audioUrl":"wbw/011_073_010.mp3","charTypeName":"word"},{"id":61186,"position":10,"arabic":"أَهْلَ","translation":"বাসিন্দারা","audioUrl":"wbw/011_073_011.mp3","charTypeName":"word"},{"id":61187,"position":11,"arabic":"ٱلْبَيْتِ ۚ","translation":"ঘরের","audioUrl":"wbw/011_073_012.mp3","charTypeName":"word"},{"id":61189,"positio