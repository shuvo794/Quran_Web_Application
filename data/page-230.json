rl":"wbw/011_079_012.mp3","charTypeName":"word"},{"id":64002,"position":13,"arabic":"نُرِيدُ","translation":"চাই আমরা\"","audioUrl":"wbw/011_079_013.mp3","charTypeName":"word"},{"id":64003,"position":14,"arabic":"٧٩","translation":"(৭৯)","audioUrl":null,"charTypeName":"end"}]},{"number":80,"arabic":"قَالَ لَوْ أَنَّ لِى بِكُمْ قُوَّةً أَوْ ءَاوِىٓ إِلَىٰ رُكْنٍۢ شَدِيدٍۢ","translation":"Exclaimed [Lot]: \"Would that I had the strength to defeat you, or that I could lean upon some mightier support!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1553.mp3","surahId":11,"words":[{"id":64192,"position":1,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/011_080_001.mp3","charTypeName":"word"},{"id":64193,"position":2,"arabic":"لَوْ","translation":"\"যদি","audioUrl":"wbw/011_080_002.mp3","charTypeName":"word"},{"id":64194,"position":3,"arabic":"أَنَّ","translation":"নিশ্চিত","audioUrl":"wbw/011_080_003.mp3","charTypeName":"word"},{"id":64195,"position":4,"arabic":"لِى","translation":"আমার জন্যে","audioUrl":"wbw/011_080_004.mp3","charTypeName":"word"},{"id":64196,"position":5,"arabic":"بِكُمْ","translation":"তোমাদের উপর","audioUrl":"wbw/011_080_005.mp3","charTypeName":"word"},{"id":64197,"position":6,"arabic":"قُوَّةً","translation":"কোন শক্তি","audioUrl":"wbw/011_080_006.mp3","charTypeName":"word"},{"id":64198,"position":7,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/011_080_007.mp3","charTypeName":"word"},{"id":64199,"position":8,"arabic":"ءَاوِىٓ","translation":"আমি আশ্রয় পেতাম","audioUrl":"wbw/011_080_008.mp3","charTypeName":"word"},{"id":64200,"position":9,"arabic":"إِلَىٰ","translation":"কাছে","audioUrl":"wbw/011_080_009.mp3","charTypeName":"word"},{"id":64201,"position":10,"arabic":"رُكْنٍۢ","translation":"কোন (আশ্রয়ের) স্তম্ভের","audioUrl":"wbw/011_080_010.mp3","charTypeName":"word"},{"id":64202,"position":11,"arabic":"شَدِيدٍۢ","translation":"শক্তিশালী\"","audioUrl":"wbw/011_080_011.mp3","charTypeName":"word"},{"id":64203,"position":12,"arabic":"٨٠","translation":"(৮০)","audioUrl":null,"charTypeName":"end"}]},{"number":81,"arabic":"قَالُوا۟ يَٰلُوطُ إِنَّا رُسُلُ رَبِّكَ لَن يَصِلُوٓا۟ إِلَيْكَ ۖ فَأَسْرِ بِأَهْلِكَ بِقِطْعٍۢ مِّنَ ٱلَّيْلِ وَلَا يَلْتَفِتْ مِنكُمْ أَحَدٌ إِلَّا ٱمْرَأَتَكَ ۖ إِنَّهُۥ مُصِيبُهَا مَآ أَصَابَهُمْ ۚ إِنَّ مَوْعِدَهُمُ ٱلصُّبْحُ ۚ أَلَيْسَ ٱلصُّبْحُ بِقَرِيبٍۢ","translation":"[Whereupon the angels] said: \"O Lot! Behold, we are messengers from thy Sustainer! Never shall [thy enemies] attain to thee! Depart, then, with thy household while it is yet night, and let none of you look back; [and take with thee all thy family] with the exception of thy wife: for, behold, that which is to befall these [people of Sodom] shall befall her [as well]. Verily, their appointed time is the morning [and] is not the morning nigh?\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1554.mp3","surahId":11,"words":[{"id":64810,"position":1,"arabic":"قَالُوا۟","translation":"(আগন্তুকরা) বললো","audioUrl":"wbw/011_081_001.mp3","charTypeName":"word"},{"id":64811,"position":2,"arabic":"يَـٰلُوطُ","translation":"\"হে লুত","audioUrl":"wbw/011_081_002.mp3","charTypeName":"word"},{"id":64812,"position":3,"arabic":"إِنَّا","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/011_081_003.mp3","charTypeName":"word"},{"id":64813,"position":4,"arabic":"رُسُلُ","translation":"(সবাই) ফেরেশতা","audioUrl":"wbw/011_081_004.mp3","charTypeName":"word"},{"id":64814,"position":5,"arabic":"رَبِّكَ","translation":"তোমাদের রবের","audioUrl":"wbw/011_081_005.mp3","charTypeName":"word"},{"id":64815,"position":6,"arabic":"لَن","translation":"কখনও না","audioUrl":"wbw/011_081_006.mp3","charTypeName":"word"},{"id":64816,"position":7,"arabic":"يَصِلُوٓا۟","translation":"তারা পৌঁছতে পারবে","audioUrl":"wbw/011_081_007.mp3","charTypeName":"word"},{"id":64817,"position":8,"arabic":"إِلَيْكَ ۖ","translation":"তোমার কাছে","audioUrl":"wbw/011_081_008.mp3","charTypeName":"word"},{"id":64819,"position":9,"arabic":"ف