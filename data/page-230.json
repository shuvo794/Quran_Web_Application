1632,"position":10,"arabic":"قَوْمِ","translation":"জাতির","audioUrl":"wbw/011_074_010.mp3","charTypeName":"word"},{"id":61633,"position":11,"arabic":"لُوطٍ","translation":"লুতের","audioUrl":"wbw/011_074_011.mp3","charTypeName":"word"},{"id":61634,"position":12,"arabic":"٧٤","translation":"(৭৪)","audioUrl":null,"charTypeName":"end"}]},{"number":75,"arabic":"إِنَّ إِبْرَٰهِيمَ لَحَلِيمٌ أَوَّٰهٌۭ مُّنِيبٌۭ","translation":"for, behold, Abraham was most clement, most tender-hearted, intent upon turning to God again and again.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1548.mp3","surahId":11,"words":[{"id":62271,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/011_075_001.mp3","charTypeName":"word"},{"id":62272,"position":2,"arabic":"إِبْرَٰهِيمَ","translation":"ইবরাহীম (ছিলো)","audioUrl":"wbw/011_075_002.mp3","charTypeName":"word"},{"id":62273,"position":3,"arabic":"لَحَلِيمٌ","translation":"সহনশীল অবশ্যই","audioUrl":"wbw/011_075_003.mp3","charTypeName":"word"},{"id":62274,"position":4,"arabic":"أَوَّٰهٌۭ","translation":"কোমল হৃদয়ের","audioUrl":"wbw/011_075_004.mp3","charTypeName":"word"},{"id":62275,"position":5,"arabic":"مُّنِيبٌۭ","translation":"(আল্লাহ) অভিমূখী","audioUrl":"wbw/011_075_005.mp3","charTypeName":"word"},{"id":62276,"position":6,"arabic":"٧٥","translation":"(৭৫)","audioUrl":null,"charTypeName":"end"}]},{"number":76,"arabic":"يَٰٓإِبْرَٰهِيمُ أَعْرِضْ عَنْ هَٰذَآ ۖ إِنَّهُۥ قَدْ جَآءَ أَمْرُ رَبِّكَ ۖ وَإِنَّهُمْ ءَاتِيهِمْ عَذَابٌ غَيْرُ مَرْدُودٍۢ","translation":"[But God's messengers replied:] \"O Abraham! Desist from this [pleading]! Behold, thy Sustainer's judgment has already gone forth: and, verily, there shall fall upon them a chastisement which none can avert!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1549.mp3","surahId":11,"words":[{"id":62551,"position":1,"arabic":"يَـٰٓإِبْرَٰهِيمُ","translation":"(বলা হলো) হে ইবরাহীম","audioUrl":"wbw/011_076_001.mp3","charTypeName":"word"},{"id":62552,"position":2,"arabic":"أَعْرِضْ","translation":"বিরত হও","audioUrl":"wbw/011_076_002.mp3","charTypeName":"word"},{"id":62553,"position":3,"arabic":"عَنْ","translation":"থেকে","audioUrl":"wbw/011_076_003.mp3","charTypeName":"word"},{"id":62554,"position":4,"arabic":"هَـٰذَآ ۖ","translation":"এটা","audioUrl":"wbw/011_076_004.mp3","charTypeName":"word"},{"id":62556,"position":5,"arabic":"إِنَّهُۥ","translation":"নিশ্চয়ই তা","audioUrl":"wbw/011_076_006.mp3","charTypeName":"word"},{"id":62557,"position":6,"arabic":"قَدْ","translation":"অবশ্যই","audioUrl":"wbw/011_076_007.mp3","charTypeName":"word"},{"id":62558,"position":7,"arabic":"جَآءَ","translation":"এসে গেছে","audioUrl":"wbw/011_076_008.mp3","charTypeName":"word"},{"id":62559,"position":8,"arabic":"أَمْرُ","translation":"নির্দেশ","audioUrl":"wbw/011_076_009.mp3","charTypeName":"word"},{"id":62560,"position":9,"arabic":"رَبِّكَ ۖ","translation":"তোমার রবের","audioUrl":"wbw/011_076_010.mp3","charTypeName":"word"},{"id":62562,"position":10,"arabic":"وَإِنَّهُمْ","translation":"এবং তারা নিশ্চয়ই (এমন যে)","audioUrl":"wbw/011_076_012.mp3","charTypeName":"word"},{"id":62563,"position":11,"arabic":"ءَاتِيهِمْ","translation":"তাদের উপর অাসবে","audioUrl":"wbw/011_076_013.mp3","charTypeName":"word"},{"id":62564,"position":12,"arabic":"عَذَابٌ","translation":"শাস্তি","audioUrl":"wbw/011_076_014.mp3","charTypeName":"word"},{"id":62565,"position":13,"arabic":"غَيْرُ","translation":"নয়","audioUrl":"wbw/011_076_015.mp3","charTypeName":"word"},{"id":62566,"position":14,"arabic":"مَرْدُودٍۢ","translation":"প্রতিহত হবার","audioUrl":"wbw/011_076_016.mp3","charTypeName":"word"},{"id":62567,"position":15,"arabic":"٧٦","translation":"(৭৬)","audioUrl":null,"charTypeName":"end"}]},{"number":77,"arabic":"وَلَمَّا جَآءَتْ رُسُلُنَا لُوطًۭا سِىٓءَ بِهِمْ وَضَاقَ بِهِمْ ذَرْعًۭا وَقَالَ هَٰذَا يَوْمٌ عَصِيبٌۭ","translation":"AND WHEN Our messengers came unto Lot, he was sorely grieved on their account, seeing that it was beyond his power to shield them; and he exclaimed: \"This is a woeful day!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1550.mp3","surahId":11,"words":[{"id":63108,"position":1,"arabic":"وَلَمَّا","translation":"এবং যখন","audioUrl":"wbw/011_077_001.mp3","charTypeName":"word"},{"id":63109,"position":2,"arabic":"جَآءَتْ","translation":"আসলো","audioUrl":"wbw/011_077_002.mp3","charTypeName":"word"},{"id":63110,"position":3,"arabic":"رُسُلُنَا","translation":"আমাদের ফেরেশতারা","audioUrl":"wbw/011_077_003.mp3","charTypeName":"word"},{"id":63111,"position":4,"arabic":"لُوطًۭا","translation":"লুতের কাছে","audioUrl":"wbw/011_077_004.mp3","charTypeName":"word"},{"id":63112,"position":5,"arabic":"سِىٓءَ","translation":"সে মন খারাপ করলো","audioUrl":"wbw/011_077_005.mp3","charTypeName":"word"},{"id":63113,"position":6,"arabic":"بِهِمْ","translation":"ব্যাপারে তাদের","audioUrl":"wbw/011_077_006.mp3","charTypeName":"word"},{"id":63114,"position":7,"arabic":"وَضَاقَ","translation":"ও সে অসমর্থ মনে করলো","audioUrl":"wbw/011_077_007.mp3","charTypeName":"word"},{"id":63115,"position":8,"arabic":"بِهِمْ","translation":"তাদের ব্যাপারে","audioUrl":"wbw/011_077_008.mp3","charTypeName":"word"},{"id":63116,"position":9,"arabic":"ذَرْعًۭا","translation":"রক্ষা করতে","audioUrl":"wbw/011_077_009.mp3","charTypeName":"word"},{"id":63117,"position":10,"arabic":"وَقَالَ","translation":"এবং বললো","audioUrl":"wbw/011_077_010.mp3","charTypeName":"word"},{"id":63118,"position":11,"arabic":"هَـٰذَا","translation":"\"এই","audioUrl":"wbw/011_077_011.mp3","charTypeName":"word"},{"id":63119,"position":12,"arabic":"يَوْمٌ","translation":"দিন","audioUrl":"wbw/011_077_012.mp3","charTypeName":"word"},{"id":63120,"position":13,"arabic":"عَصِيبٌۭ","translation":"ভয়ানক\"","audioUrl":"wbw/011_077_013.mp3","charTypeName":"word"},{"id":63121,"position":14,"arabic":"٧٧","translation":"(৭৭)","audioUrl":null,"charTypeName":"end"}]},{"number":78,"arabic":"وَجَآءَهُۥ قَوْمُهُۥ يُهْرَعُونَ إِلَيْهِ وَمِن قَبْلُ كَانُوا۟ يَعْمَلُونَ ٱلسَّيِّـَٔاتِ ۚ قَالَ يَٰقَوْمِ هَٰٓؤُلَآءِ بَنَاتِى هُنَّ أَطْهَرُ لَكُمْ ۖ فَٱتَّقُوا۟ ٱللَّهَ وَلَا تُخْزُونِ فِى ضَيْفِىٓ ۖ أَلَيْسَ مِنكُمْ رَجُلٌۭ رَّشِيدٌۭ","translation":"And his people came running to him, impelled towards his house [by their desire]: for they had ever been wont to commit [such], abominations. Said [Lot]: \"O my people! [Take instead] these daughters of mine: they are purer for you [than men]! Be, then, conscious of God, and disgrace me not by [assaulting] my guests. Is there not among you even one right-minded man?\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1551.mp3","surahId":11,"words":[{"id":63548,"position":1,"arabic":"وَجَآءَهُۥ","translation":"এবং তার কাছে আসলো","audioUrl":"wbw/011_078_001.mp3","charTypeName":"word"},{"id":63549,"position":2,"arabic":"قَوْمُهُۥ","translation":"তার (জাতির) লোকেরা","audioUrl":"wbw/011_078_002.mp3","charTypeName":"word"},{"id":63550,"position":3,"arabic":"يُهْرَعُونَ","translation":"দ্রুত ছুটে","audioUrl":"wbw/011_078_003.mp3","charTypeName":"word"},{"id":63551,"position":4,"arabic":"إِلَيْهِ","translation":"তার দিকে","audioUrl":"wbw/011_078_004.mp3","charTypeName":"word"},{"id":63552,"position":5,"arabic":"وَمِن","translation":"এবং থেকে","audioUrl":"wbw/011_078_005.mp3","charTypeName":"word"},{"id":63553,"position":6,"arabic":"قَبْلُ","translation":"পূর্ব","audioUrl":"wbw/011_078_006.mp3","charTypeName":"word"},{"id":63554,"position":7,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/011_078_007.mp3","charTypeName":"word"},{"id":63555,"position":8,"arabic":"يَعْمَلُونَ","translation":"তারা কাজ করে","audioUrl":"wbw/011_078_008.mp3","charTypeName":"word"},{"id":63556,"position":9,"arabic":"ٱلسَّيِّـَٔاتِ ۚ","translation":"কুকর্ম (অর্থাৎ সমকামিতা)","audioUrl":"wbw/011_078_009.mp3","charTypeName":"word"},{"id":63558,"position":10,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/011_078_011.mp3","charTypeName":"word"},{"id":63559,"