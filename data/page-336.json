{"id":336,"ayahs":[{"number":31,"arabic":"حُنَفَآءَ لِلَّهِ غَيْرَ مُشْرِكِينَ بِهِۦ ۚ وَمَن يُشْرِكْ بِٱللَّهِ فَكَأَنَّمَا خَرَّ مِنَ ٱلسَّمَآءِ فَتَخْطَفُهُ ٱلطَّيْرُ أَوْ تَهْوِى بِهِ ٱلرِّيحُ فِى مَكَانٍۢ سَحِيقٍۢ","translation":"[inclining] towards God, [and] turning away from all that is false, without ascribing divine qualities to aught beside Him: for he who ascribes divinity to aught but God is like one who is hurtling down from the skies - whereupon the birds carry him off, or the wind blows him away onto a far-off place.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2626.mp3","surahId":22,"words":[{"id":33611,"position":1,"arabic":"حُنَفَآءَ","translation":"একনিষ্ঠ হয়ে","audioUrl":"wbw/022_031_001.mp3","charTypeName":"word"},{"id":33612,"position":2,"arabic":"لِلَّهِ","translation":"জন্যে আল্লাহরই","audioUrl":"wbw/022_031_002.mp3","charTypeName":"word"},{"id":33613,"position":3,"arabic":"غَيْرَ","translation":"ছাড়া","audioUrl":"wbw/022_031_003.mp3","charTypeName":"word"},{"id":33614,"position":4,"arabic":"مُشْرِكِينَ","translation":"মুশরিক (হওয়া)","audioUrl":"wbw/022_031_004.mp3","charTypeName":"word"},{"id":33615,"position":5,"arabic":"بِهِۦ ۚ","translation":"তাঁর সাথে","audioUrl":"wbw/022_031_005.mp3","charTypeName":"word"},{"id":33617,"position":6,"arabic":"وَمَن","translation":"আর যে","audioUrl":"wbw/022_031_007.mp3","charTypeName":"word"},{"id":33618,"position":7,"arabic":"يُشْرِكْ","translation":"শরীক করে","audioUrl":"wbw/022_031_008.mp3","charTypeName":"word"},{"id":33619,"position":8,"arabic":"بِٱللَّهِ","translation":"আল্লাহর সাথে","audioUrl":"wbw/022_031_009.mp3","charTypeName":"word"},{"id":33620,"position":9,"arabic":"فَكَأَنَّمَا","translation":"অতঃপর যেন","audioUrl":"wbw/022_031_010.mp3","charTypeName":"word"},{"id":33621,"position":10,"arabic":"خَرَّ","translation":"সে পড়ে গেলো","audioUrl":"wbw/022_031_011.mp3","charTypeName":"word"},{"id":33622,"position":11,"arabic":"مِنَ","translation":"হ'তে","audioUrl":"wbw/022_031_012.mp3","charTypeName":"word"},{"id":33623,"position":12,"arabic":"ٱلسَّمَآءِ","translation":"আকাশ","audioUrl":"wbw/022_031_013.mp3","charTypeName":"word"},{"id":33624,"position":13,"arabic":"فَتَخْطَفُهُ","translation":"অতঃপর তাকে ছোঁ মেরে নিয়ে যাবে","audioUrl":"wbw/022_031_014.mp3","charTypeName":"word"},{"id":33625,"position":14,"arabic":"ٱلطَّيْرُ","translation":"পাখি","audioUrl":"wbw/022_031_015.mp3","charTypeName":"word"},{"id":33626,"position":15,"arabic":"أَوْ","translation":"অথবা","audioUrl":"wbw/022_031_016.mp3","charTypeName":"word"},{"id":33627,"position":16,"arabic":"تَهْوِى","translation":"উড়িয়ে যাবে","audioUrl":"wbw/022_031_017.mp3","charTypeName":"word"},{"id":33628,"position":17,"arabic":"بِهِ","translation":"নিয়ে তাকে","audioUrl":"wbw/022_031_018.mp3","charTypeName":"word"},{"id":33629,"position":18,"arabic":"ٱلرِّيحُ","translation":"বাতাস","audioUrl":"wbw/022_031_019.mp3","charTypeName":"word"},{"id":33630,"position":19,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/022_031_020.mp3","charTypeName":"word"},{"id":33631,"position":20,"arabic":"مَكَانٍۢ","translation":"স্থানের","audioUrl":"wbw/022_031_021.mp3","charTypeName":"word"},{"id":33632,"position":21,"arabic":"سَحِيقٍۢ","translation":"দূরবর্তী","audioUrl":"wbw/022_031_022.mp3","charTypeName":"word"},{"id":33633,"position":22,"arabic":"٣١","translation":"(৩১)","audioUrl":null,"charTypeName":"end"}]},{"number":32,"arabic":"ذَٰلِكَ وَمَن يُعَظِّمْ شَعَٰٓئِرَ ٱللَّهِ فَإِنَّهَا مِن تَقْوَى ٱلْقُلُوبِ","translation":"This is [to be borne in mind]. And anyone who honours the symbols set up by God [shall know that] verily, these [symbols derive their value] from the God-consciousness in the [believers’] hearts.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2627.mp3","surahId":22,"words":[{"id":34698,"position":1,"arabic":"ذَٰلِكَ","translation":"এটাই (আসল ব্যাপার)","audioUrl":"wbw/022_032_001.mp3","charTypeName":"word"},{"id":34699,"position":2,"arabic":"وَمَن","translation":"আর যে","audioUrl":"wbw/022_032_002.mp3","charTypeName":"word"},{"id":34700,"position":3,"arabic":"يُعَظِّمْ","translation":"সম্মান করে","audioUrl":"wbw/022_032_003.mp3","charTypeName":"word"},{"id":34701,"position":4,"arabic":"شَعَـٰٓئِرَ","translation":"নিদর্শনাবলী কে","audioUrl":"wbw/022_032_004.mp3","charTypeName":"word"},{"id":34702,"position":5,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/022_032_005.mp3","charTypeName":"word"},{"id":34703,"position":6,"arabic":"فَإِنَّهَا","translation":"তবে তা নিশ্চয়ই (উৎসারিত হয়)","audioUrl":"wbw/022_032_006.mp3","charTypeName":"word"},{"id":34704,"position":7,"arabic":"مِن","translation":"হ'তে","audioUrl":"wbw/022_032_007.mp3","charTypeName":"word"},{"id":34705,"position":8,"arabic":"تَقْوَى","translation":"তাক্বওয়া","audioUrl":"wbw/022_032_008.mp3","charTypeName":"word"},{"id":34706,"position":9,"arabic":"ٱلْقُلُوبِ","translation":"অন্তরসমূহের","audioUrl":"wbw/022_032_009.mp3","charTypeName":"word"},{"id":34707,"position":10,"arabic":"٣٢","translation":"(৩২)","audioUrl":null,"charTypeName":"end"}]},{"number":33,"arabic":"لَكُمْ فِيهَا مَنَٰفِعُ إِلَىٰٓ أَجَلٍۢ مُّسَمًّۭى ثُمَّ مَحِلُّهَآ إِلَى ٱلْبَيْتِ ٱلْعَتِيقِ","translation":"In that [God-consciousness] you shall find benefits until a term set [by Him is fulfilled], and [you shall know that] its goal and end is the Most Ancient Temple.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2628.mp3","surahId":22,"words":[{"id":35444,"position":1,"arabic":"لَكُمْ","translation":"জন্যে তোমাদের","audioUrl":"wbw/022_033_001.mp3","charTypeName":"word"},{"id":35445,"position":2,"arabic":"فِيهَا","translation":"মধ্যে এর","audioUrl":"wbw/022_033_002.mp3","charTypeName":"word"},{"id":35446,"position":3,"arabic":"مَنَـٰفِعُ","translation":"নানা উপকার","audioUrl":"wbw/022_033_003.mp3","charTypeName":"word"},{"id":35447,"position":4,"arabic":"إِلَىٰٓ","translation":"পর্যন্ত","audioUrl":"wbw/022_033_004.mp3","charTypeName":"word"},{"id":35448,"position":5,"arabic":"أَجَلٍۢ","translation":"সময়","audioUrl":"wbw/022_033_005.mp3","charTypeName":"word"},{"id":35449,"position":6,"arabic":"مُّسَمًّۭى","translation":"নির্দিষ্ট","audioUrl":"wbw/022_033_006.mp3","charTypeName":"word"},{"id":35450,"position":7,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/022_033_007.mp3","charTypeName":"word"},{"id":35451,"position":8,"arabic":"مَحِلُّهَآ","translation":"তার (কুরবানির জায়গা)","audioUrl":"wbw/022_033_008.mp3","charTypeName":"word"},{"id":35452,"position":9,"arabic":"إِلَى","translation":"নিকট (অবস্থিত)","audioUrl":"wbw/022_033_009.mp3","charTypeName":"word"},{"id":35453,"position":10,"arabic":"ٱلْبَيْتِ","translation":"ঘরের","audioUrl":"wbw/022_033_010.mp3","charTypeName":"word"},{"id":35454,"position":11,"arabic":"ٱلْعَتِيقِ","translation":"প্রাচীন","audioUrl":"wbw/022_033_011.mp3","charTypeName":"word"},{"id":35455,"position":12,"arabic":"٣٣","translation":"(৩৩)","audioUrl":null,"charTypeName":"end"}]},{"number":34,"arabic":"وَلِكُلِّ أُمَّةٍۢ جَعَلْنَا مَنسَكًۭا لِّيَذْكُرُوا۟ ٱسْمَ ٱللَّهِ عَلَىٰ مَا رَزَقَهُم مِّنۢ بَهِيمَةِ ٱلْأَنْعَٰمِ ۗ فَإِلَٰهُكُمْ إِلَٰهٌۭ وَٰحِدٌۭ فَلَهُۥٓ أَسْلِمُوا۟ ۗ وَبَشِّرِ ٱلْمُخْبِتِينَ","translation":"And [thus it is:] unto every community [that has ever believed in Us] have We appointed [sacrifice as] an act of worship, so that they might extol the name of God over whatever heads of cattle He may have provided for them [to this end]. And (always bear in mind:) your God is the One and Only God: hence, surrender yourselves unto Him. And give thou the glad tiding [of God’s acceptance] unto all who are humble –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2629.mp3","surahId":22,"words":[{"id":36736,"position":1,"arabic":"وَلِكُلِّ","translation":"এবং জন্যে প্রত্যেক","audioUrl":"wbw/022_034_001.mp3","charTypeName":"word"},{"id":36737,"position":2,"arabic":"أُمَّةٍۢ","translation":"জাতির","audioUrl":"wbw/022_034_002.mp3","charTypeName":"word"},{"id":36738,"position":3,"arabic":"جَعَلْنَا","translation":"আমরা নির্দিষ্ট করে দিয়েছি","audioUrl":"wbw/022_034_003.mp3","charTypeName":"word"},{"id":36739,"position":4,"arabic":"مَنسَكًۭا","translation":"কুরবানির নিয়ম","audioUrl":"wbw/022_034_004.mp3","charTypeName":"word"},{"id":36740,"position":5,"arabic":"لِّيَذْكُرُوا۟","translation":"যেন তারা স্মরণ করে","audioUrl":"wbw/022_034_005.mp3","charTypeName":"word"},{"id":36741,"position":6,"arabic":"ٱسْمَ","translation":"নাম","audioUrl":"wbw/022_034_006.mp3","charTypeName":"word"},{"id":36742,"position":7,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/022_034_007.mp3","charTypeName":"word"},{"id":36743,"position":8,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/022_034_008.mp3","charTypeName":"word"},{"id":36744,"position":9,"arabic":"مَا","translation":"যা","audioUrl":"wbw/022_034_009.mp3","charTypeName":"word"},{"id":36745,"position":10,"arabic":"رَزَقَهُم","translation":"তাদেরকে জীবিকা দিয়েছেন","audioUrl":"wbw/022_034_010.mp3","charTypeName":"word"},{"id":36746,"position":11,"arabic":"مِّنۢ","translation":"মধ্য হ'তে","audioUrl":"wbw/022_034_011.mp3","charTypeName":"word"},{"id":36747,"position":12,"arabic":"بَهِيمَةِ","translation":"চতুষ্পদজন্তুর","audioUrl":"wbw/022_034_012.mp3","charTypeName":"word"},{"id":36748,"position":13,"arabic":"ٱلْأَنْعَـٰمِ ۗ","translation":"গৃহপালিত","audioUrl":"wbw/022_034_013.mp3","charTypeName":"word"},{"id":36750,"position":14,"arabic":"فَإِلَـٰهُكُمْ","translation":"অতএব তোমাদের ইলাহ","audioUrl":"wbw/022_034_015.mp3","charTypeName":"word"},{"id":36751,"position":15,"arabic":"إِلَـٰهٌۭ","translation":"ইলাহ","audioUrl":"wbw/022_034_016.mp3","charTypeName":"word"},{"id":36752,"position":16,"arabic":"وَٰحِدٌۭ","translation":"একই","audioUrl":"wbw/022_034_017.mp3","charTypeName":"word"},{"id":36753,"position":17,"arabic":"فَلَهُۥٓ","translation":"সুতরাং তাঁরই নিকট","audioUrl":"wbw/022_034_018.mp3","charTypeName":"word"},{"id":36754,"position":18,"arabic":"أَسْلِمُوا۟ ۗ","translation":"আত্মসমর্পণ করো","audioUrl":"wbw/022_034_019.mp3","charTypeName":"word"},{"id":36756,"position":19,"arabic":"وَبَشِّرِ","translation":"আর সুসংবাদ দাও","audioUrl":"wbw/022_034_021.mp3","charTypeName":"word"},{"id":36757,"position":20,"arabic":"ٱلْمُخْبِتِينَ","translation":"(আল্লাহর হুকুমের কাছে) অবনতকারীদের","audioUrl":"wbw/022_034_022.mp3","charTypeName":"word"},{"id":36758,"position":21,"arabic":"٣٤","translation":"(৩৪)","audioUrl":null,"charTypeName":"end"}]},{"number":35,"arabic":"ٱلَّذِينَ إِذَا ذُكِرَ ٱللَّهُ وَجِلَتْ قُلُوبُهُمْ وَٱلصَّٰبِرِينَ عَلَىٰ مَآ أَصَابَهُمْ وَٱلْمُقِيمِى ٱلصَّلَوٰةِ وَمِمَّا رَزَقْنَٰهُمْ يُنفِقُونَ","translation":"all whose hearts tremble with awe whenever God is mentioned, and all who patiently bear whatever ill befalls them, and all who are constant in prayer and spend on others out of what We provide for them as sustenance.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2630.mp3","surahId":22,"words":[{"id":37147,"position":1,"arabic":"ٱلَّذِينَ","translation":"যারা (এরূপ যে)","audioUrl":"wbw/022_035_001.mp3","charTypeName":"word"},{"id":37148,"position":2,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/022_035_002.mp3","charTypeName":"word"},{"id":37149,"position":3,"arabic":"ذُكِرَ","translation":"উল্লেখ করা হয়","audioUrl":"wbw/022_035_003.mp3","charTypeName":"word"},{"id":37150,"position":4,"arabic":"ٱللَّهُ","translation":"আল্লাহর (নাম)","audioUrl":"wbw/022_035_004.mp3","charTypeName":"word"},{"id":37151,"position":5,"arabic":"وَجِلَتْ","translation":"কেঁপে উঠে","audioUrl":"wbw/022_035_005.mp3","charTypeName":"word"},{"id":37152,"position":6,"arabic":"قُلُوبُهُمْ","translation":"তাদের অন্তরগুলো","audioUrl":"wbw/022_035_006.mp3","charTypeName":"word"},{"id":37153,"position":7,"arabic":"وَٱلصَّـٰبِرِينَ","translation":"ধৈর্য্যধারণকারী (হয়)","audioUrl":"wbw/022_035_007.mp3","charTypeName":"word"},{"id":37154,"position":8,"arabic":"عَلَىٰ","translation":"(এর) উপর","audioUrl":"wbw/022_035_008.mp3","charTypeName":"word"},{"id":37155,"position":9,"arabic":"مَآ","translation":"যা","audioUrl":"wbw/022_035_009.mp3","charTypeName":"word"},{"id":37156,"position":10,"arabic":"أَصَابَهُمْ","translation":"তাদের উপর আপতিত হয়","audioUrl":"wbw/022_035_010.mp3","charTypeName":"word"},{"id":37157,"position":11,"arabic":"وَٱلْمُقِيمِى","translation":"ও প্রতিষ্ঠাকারী (হয়)","audioUrl":"wbw/022_035_011.mp3","charTypeName":"word"},{"id":37158,"position":12,"arabic":"ٱلصَّلَوٰةِ","translation":"সালাত","audioUrl":"wbw/022_035_012.mp3","charTypeName":"word"},{"id":37159,"position":13,"arabic":"وَمِمَّا","translation":"এবং (তা) হ'তে যা","audioUrl":"wbw/022_035_013.mp3","charTypeName":"word"},{"id":37160,"position":14,"arabic":"رَزَقْنَـٰهُمْ","translation":"তাদের আমরা জীবিকা দিয়েছি","audioUrl":"wbw/022_035_014.mp3","charTypeName":"word"},{"id":37161,"position":15,"arabic":"يُنفِقُونَ","translation":"তারা খরচ করে","audioUrl":"wbw/022_035_015.mp3","charTypeName":"word"},{"id":37162,"position":16,"arabic":"٣٥","translation":"(৩৫)","audioUrl":null,"charTypeName":"end"}]},{"number":36,"arabic":"وَٱلْبُدْنَ جَعَلْنَٰهَا لَكُم مِّن شَعَٰٓئِرِ ٱللَّهِ لَكُمْ فِيهَا خَيْرٌۭ ۖ فَٱذْكُرُوا۟ ٱسْمَ ٱللَّهِ عَلَيْهَا صَوَآفَّ ۖ فَإِذَا وَجَبَتْ جُنُوبُهَا فَكُلُوا۟ مِنْهَا وَأَطْعِمُوا۟ ٱلْقَانِعَ وَٱلْمُعْتَرَّ ۚ كَذَٰلِكَ سَخَّرْنَٰهَا لَكُمْ لَعَلَّكُمْ تَشْكُرُونَ","translation":"And as for the sacrifice of cattle, We have ordained it for you as one of the symbols set up by God, in which there is [much] good for you. Hence, extol the name of God over them when they are lined up [for sacrifice]; and after they have fallen lifeless to the ground, eat of their flesh, and feed the poor who is contented with his lot (and does not beg), as well as him who is forced to beg. It is to this end that We have made them subservient to your needs, so that you might have cause to be grateful.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2631.mp3","surahId":22,"words":[{"id":381