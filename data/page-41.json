{"id":41,"ayahs":[{"number":249,"arabic":"فَلَمَّا فَصَلَ طَالُوتُ بِٱلْجُنُودِ قَالَ إِنَّ ٱللَّهَ مُبْتَلِيكُم بِنَهَرٍۢ فَمَن شَرِبَ مِنْهُ فَلَيْسَ مِنِّى وَمَن لَّمْ يَطْعَمْهُ فَإِنَّهُۥ مِنِّىٓ إِلَّا مَنِ ٱغْتَرَفَ غُرْفَةًۢ بِيَدِهِۦ ۚ فَشَرِبُوا۟ مِنْهُ إِلَّا قَلِيلًۭا مِّنْهُمْ ۚ فَلَمَّا جَاوَزَهُۥ هُوَ وَٱلَّذِينَ ءَامَنُوا۟ مَعَهُۥ قَالُوا۟ لَا طَاقَةَ لَنَا ٱلْيَوْمَ بِجَالُوتَ وَجُنُودِهِۦ ۚ قَالَ ٱلَّذِينَ يَظُنُّونَ أَنَّهُم مُّلَٰقُوا۟ ٱللَّهِ كَم مِّن فِئَةٍۢ قَلِيلَةٍ غَلَبَتْ فِئَةًۭ كَثِيرَةًۢ بِإِذْنِ ٱللَّهِ ۗ وَٱللَّهُ مَعَ ٱلصَّٰبِرِينَ","translation":"And when Saul set out with his forces, he said: \"Behold, God will now try you by a river: he who shall drink of it will not belong to me, whereas he who shall refrain from tasting it - he, indeed, will belong to me; but forgiven shall be he who shall scoop up but a single handful.\" However, save for a few of them, they all drank [their fill] of it. And as soon as he and those who had kept faith with him had crossed the river, the others said: \"No strength have we today [to stand up] against Goliath and his forces!\" [Yet] those who knew with certainty that they were destined to meet God, replied: \"How often has a small host overcome a great host by God's leave! For God is with those who are patient in adversity.\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/256.mp3","surahId":2,"words":[{"id":86945,"position":1,"arabic":"فَلَمَّا","translation":"যখন অতঃপর","audioUrl":"wbw/002_249_001.mp3","charTypeName":"word"},{"id":86946,"position":2,"arabic":"فَصَلَ","translation":"রওনা হল","audioUrl":"wbw/002_249_002.mp3","charTypeName":"word"},{"id":86947,"position":3,"arabic":"طَالُوتُ","translation":"তালুত","audioUrl":"wbw/002_249_003.mp3","charTypeName":"word"},{"id":86948,"position":4,"arabic":"بِٱلْجُنُودِ","translation":"সৈন্যদের নিয়ে","audioUrl":"wbw/002_249_004.mp3","charTypeName":"word"},{"id":86949,"position":5,"arabic":"قَالَ","translation":"বলল","audioUrl":"wbw/002_249_005.mp3","charTypeName":"word"},{"id":86950,"position":6,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/002_249_006.mp3","charTypeName":"word"},{"id":86951,"position":7,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/002_249_007.mp3","charTypeName":"word"},{"id":86952,"position":8,"arabic":"مُبْتَلِيكُم","translation":"তোমাদের পরীক্ষা করবেন","audioUrl":"wbw/002_249_008.mp3","charTypeName":"word"},{"id":86953,"position":9,"arabic":"بِنَهَرٍۢ","translation":"একটা নদী দিয়ে","audioUrl":"wbw/002_249_009.mp3","charTypeName":"word"},{"id":86954,"position":10,"arabic":"فَمَن","translation":"যে অতঃপর","audioUrl":"wbw/002_249_010.mp3","charTypeName":"word"},{"id":86955,"position":11,"arabic":"شَرِبَ","translation":"পান করবে","audioUrl":"wbw/002_249_011.mp3","charTypeName":"word"},{"id":86956,"position":12,"arabic":"مِنْهُ","translation":"তা থেকে","audioUrl":"wbw/002_249_012.mp3","charTypeName":"word"},{"id":86957,"position":13,"arabic":"فَلَيْسَ","translation":"সে নয় তখন","audioUrl":"wbw/002_249_013.mp3","charTypeName":"word"},{"id":86958,"position":14,"arabic":"مِنِّى","translation":"আমার দলে","audioUrl":"wbw/002_249_014.mp3","charTypeName":"word"},{"id":86959,"position":15,"arabic":"وَمَن","translation":"এবং যে","audioUrl":"wbw/002_249_015.mp3","charTypeName":"word"},{"id":86960,"position":16,"arabic":"لَّمْ","translation":"না","audioUrl":"wbw/002_249_016.mp3","charTypeName":"word"},{"id":86961,"position":17,"arabic":"يَطْعَمْهُ","translation":"তার স্বাদ নেবে","audioUrl":"wbw/002_249_017.mp3","charTypeName":"word"},{"id":86962,"position":18,"arabic":"فَإِنَّهُۥ","translation":"নিশ্চয়ই তবে সে","audioUrl":"wbw/002_249_018.mp3","charTypeName":"word"},{"id":86963,"position":19,"arabic":"مِنِّىٓ","translation":"আমার দলভুক্ত (থাকবে)","audioUrl":"wbw/002_249_019.mp3","charTypeName":"word"},{"id":86964,"position":20,"arabic":"إِلَّا","translation":"কিন্তু","audioUrl":"wbw/002_249_020.mp3","charTypeName":"word"},{"id":86965,"position":21,"arabic":"مَنِ","translation":"যে","audioUrl":"wbw/002_249_021.mp3","charTypeName":"word"},{"id":86966,"position":22,"arabic":"ٱغْتَرَفَ","translation":"আঁজলা ভরে নেবে (পানি)","audioUrl":"wbw/002_249_022.mp3","charTypeName":"word"},{"id":86967,"position":23,"arabic":"غُرْفَةًۢ","translation":"এক আঁজলা","audioUrl":"wbw/002_249_023.mp3","charTypeName":"word"},{"id":86968,"position":24,"arabic":"بِيَدِهِۦ ۚ","translation":"তার হাত দিয়ে (সেটা ভিন্ন)","audioUrl":"wbw/002_249_024.mp3","charTypeName":"word"},{"id":86970,"position":25,"arabic":"فَشَرِبُوا۟","translation":"তারা অতঃপর পান করল","audioUrl":"wbw/002_249_026.mp3","charTypeName":"word"},{"id":86971,"position":26,"arabic":"مِنْهُ","translation":"তা থেকে","audioUrl":"wbw/002_249_027.mp3","charTypeName":"word"},{"id":86972,"position":27,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/002_249_028.mp3","charTypeName":"word"},{"id":86973,"position":28,"arabic":"قَلِيلًۭا","translation":"স্বল্প সংখ্যক","audioUrl":"wbw/002_249_029.mp3","charTypeName":"word"},{"id":86974,"position":29,"arabic":"مِّنْهُمْ ۚ","translation":"তাদের মধ্য হতে","audioUrl":"wbw/002_249_030.mp3","charTypeName":"word"},{"id":86976,"position":30,"arabic":"فَلَمَّا","translation":"অতঃপর যখন","audioUrl":"wbw/002_249_032.mp3","charTypeName":"word"},{"id":86977,"position":31,"arabic":"جَاوَزَهُۥ","translation":"তা অতিক্রম করল","audioUrl":"wbw/002_249_033.mp3","charTypeName":"word"},{"id":86978,"position":32,"arabic":"هُوَ","translation":"সে","audioUrl":"wbw/002_249_034.mp3","charTypeName":"word"},{"id":86979,"position":33,"arabic":"وَٱلَّذِينَ","translation":"ও যারা","audioUrl":"wbw/002_249_035.mp3","charTypeName":"word"},{"id":86980,"position":34,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছিল","audioUrl":"wbw/002_249_036.mp3","charTypeName":"word"},{"id":86981,"position":35,"arabic":"مَعَهُۥ","translation":"তার সাথে","audioUrl":"wbw/002_249_037.mp3","charTypeName":"word"},{"id":86982,"position":36,"arabic":"قَالُوا۟","translation":"তারা বলেছিল","audioUrl":"wbw/002_249_038.mp3","charTypeName":"word"},{"id":86983,"position":37,"arabic":"لَا","translation":"নেই","audioUrl":"wbw/002_249_039.mp3","charTypeName":"word"},{"id":86984,"position":38,"arabic":"طَاقَةَ","translation":"শক্তি","audioUrl":"wbw/002_249_040.mp3","charTypeName":"word"},{"id":86985,"position":39,"arabic":"لَنَا","translation":"আমাদের কাছে","audioUrl":"wbw/002_249_041.mp3","charTypeName":"word"},{"id":86986,"position":40,"arabic":"ٱلْيَوْمَ","translation":"আজ","audioUrl":"wbw/002_249_042.mp3","charTypeName":"word"},{"id":86987,"position":41,"arabic":"بِجَالُوتَ","translation":"জালুতের সাথে","audioUrl":"wbw/002_249_043.mp3","charTypeName":"word"},{"id":86988,"position":42,"arabic":"وَجُنُودِهِۦ ۚ","translation":"ও তার সৈন্যদের (সাথে যুদ্ধের)","audioUrl":"wbw/002_249_044.mp3","charTypeName":"word"},{"id":86990,"position":43,"arabic":"قَالَ","translation":"বলল","audioUrl":"wbw/002_249_046.mp3","charTypeName":"word"},{"id":86991,"position":44,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/002_249_047.mp3","charTypeName":"word"},{"id":86992,"position":45,"arabic":"يَظُنُّونَ","translation":"মনে করত","audioUrl":"wbw/002_249_048.mp3","charTypeName":"word"},{"id":86993,"position":46,"arabic":"أَنَّهُم","translation":"তারা যে","audioUrl":"wbw/002_249_049.mp3","charTypeName":"word"},{"id":86994,"position":47,"arabic":"مُّلَـٰقُوا۟","translation":"সাক্ষাৎকারী","audioUrl":"wbw/002_249_050.mp3","charTypeName":"word"},{"id":86995,"position":48,"arabic":"ٱللَّهِ","translation":"আল্লাহর সাথে","audioUrl":"wbw/002_249_051.mp3","charTypeName":"word"},{"id":86996,"position":49,"arabic":"كَم","translation":"কত","audioUrl":"wbw/002_249_052.mp3","charTypeName":"word"},{"id":86997,"position":50,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/002_249_053.mp3","charTypeName":"word"},{"id":86998,"position":51,"arabic":"فِئَةٍۢ","translation":"দল (রয়েছে)","audioUrl":"wbw/002_249_054.mp3","charTypeName":"word"},{"id":86999,"position":52,"arabic":"قَلِيلَةٍ","translation":"ছো