{"id":546,"ayahs":[{"number":4,"arabic":"ذَٰلِكَ بِأَنَّهُمْ شَآقُّوا۟ ٱللَّهَ وَرَسُولَهُۥ ۖ وَمَن يُشَآقِّ ٱللَّهَ فَإِنَّ ٱللَّهَ شَدِيدُ ٱلْعِقَابِ","translation":"this, because they cut themselves off from God and His Apostle: and as for him who cuts himself off from God and His Apostle - verily, God is severe in retribution!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5130.mp3","surahId":59,"words":[{"id":3678,"position":1,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/059_004_001.mp3","charTypeName":"word"},{"id":3679,"position":2,"arabic":"بِأَنَّهُمْ","translation":"তারা যে এজন্যে","audioUrl":"wbw/059_004_002.mp3","charTypeName":"word"},{"id":3680,"position":3,"arabic":"شَآقُّوا۟","translation":"বিরুদ্ধচারণ করেছিল","audioUrl":"wbw/059_004_003.mp3","charTypeName":"word"},{"id":3681,"position":4,"arabic":"ٱللَّهَ","translation":"আল্লাহর","audioUrl":"wbw/059_004_004.mp3","charTypeName":"word"},{"id":3682,"position":5,"arabic":"وَرَسُولَهُۥ ۖ","translation":"ও তার রসুলের","audioUrl":"wbw/059_004_005.mp3","charTypeName":"word"},{"id":3684,"position":6,"arabic":"وَمَن","translation":"এবং যে","audioUrl":"wbw/059_004_007.mp3","charTypeName":"word"},{"id":3685,"position":7,"arabic":"يُشَآقِّ","translation":"বিরুদ্ধচারণ করে","audioUrl":"wbw/059_004_008.mp3","charTypeName":"word"},{"id":3686,"position":8,"arabic":"ٱللَّهَ","translation":"আল্লাহর","audioUrl":"wbw/059_004_009.mp3","charTypeName":"word"},{"id":3687,"position":9,"arabic":"فَإِنَّ","translation":"নিশ্চয় অতঃপর","audioUrl":"wbw/059_004_010.mp3","charTypeName":"word"},{"id":3688,"position":10,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/059_004_011.mp3","charTypeName":"word"},{"id":3689,"position":11,"arabic":"شَدِيدُ","translation":"কঠোর","audioUrl":"wbw/059_004_012.mp3","charTypeName":"word"},{"id":3690,"position":12,"arabic":"ٱلْعِقَابِ","translation":"শাস্তিদানে","audioUrl":"wbw/059_004_013.mp3","charTypeName":"word"},{"id":3691,"position":13,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"مَا قَطَعْتُم مِّن لِّينَةٍ أَوْ تَرَكْتُمُوهَا قَآئِمَةً عَلَىٰٓ أُصُولِهَا فَبِإِذْنِ ٱللَّهِ وَلِيُخْزِىَ ٱلْفَٰسِقِينَ","translation":"Whatever [of their] palm trees you may have cut down, [O believers,] or left standing on their roots, was [done] by God’s leave, and in order that He might confound the iniquitous.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5131.mp3","surahId":59,"words":[{"id":4990,"position":1,"arabic":"مَا","translation":"যা","audioUrl":"wbw/059_005_001.mp3","charTypeName":"word"},{"id":4991,"position":2,"arabic":"قَطَعْتُم","translation":"তোমরা কেটেছ","audioUrl":"wbw/059_005_002.mp3","charTypeName":"word"},{"id":4992,"position":3,"arabic":"مِّن","translation":"মধ্য হতে","audioUrl":"wbw/059_005_003.mp3","charTypeName":"word"},{"id":4993,"position":4,"arabic":"لِّينَةٍ","translation":"খেজুর গাছের","audioUrl":"wbw/059_005_004.mp3","charTypeName":"word"},{"id":4994,"position":5,"arabic":"أَوْ","translation":"বা","audioUrl":"wbw/059_005_005.mp3","charTypeName":"word"},{"id":4995,"position":6,"arabic":"تَرَكْتُمُوهَا","translation":"তা তোমরা ছেড়ে দিয়েছ","audioUrl":"wbw/059_005_006.mp3","charTypeName":"word"},{"id":4996,"position":7,"arabic":"قَآئِمَةً","translation":"দাঁড়ান অবস্থায়","audioUrl":"wbw/059_005_007.mp3","charTypeName":"word"},{"id":4997,"position":8,"arabic":"عَلَىٰٓ","translation":"উপর","audioUrl":"wbw/059_005_008.mp3","charTypeName":"word"},{"id":4998,"position":9,"arabic":"أُصُولِهَا","translation":"তারা শিকড়গুলোর","audioUrl":"wbw/059_005_009.mp3","charTypeName":"word"},{"id":4999,"position":10,"arabic":"فَبِإِذْنِ","translation":"অনুমতিক্রমে তা'তো","audioUrl":"wbw/059_005_010.mp3","charTypeName":"word"},{"id":5000,"position":11,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/059_005_011.mp3","charTypeName":"word"},{"id":5001,"position":12,"arabic":"وَلِيُخْزِىَ","translation":"এবং লাঞ্ছিত করার জন্যে","audioUrl":"wbw/059_005_012.mp3","charTypeName":"word"},{"id":5002,"position":13,"arabic":"ٱلْفَـٰسِقِينَ","translation":"ফাসেকদের","audioUrl":"wbw/059_005_013.mp3","charTypeName":"word"},{"id":5003,"position":14,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"وَمَآ أَفَآءَ ٱللَّهُ عَلَىٰ رَسُولِهِۦ مِنْهُمْ فَمَآ أَوْجَفْتُمْ عَلَيْهِ مِنْ خَيْلٍۢ وَلَا رِكَابٍۢ وَلَٰكِنَّ ٱللَّهَ يُسَلِّطُ رُسُلَهُۥ عَلَىٰ مَن يَشَآءُ ۚ وَٱللَّهُ عَلَىٰ كُلِّ شَىْءٍۢ قَدِيرٌۭ","translation":"Yet [remember:] whatever [spoils taken] from the enemy God has turned over to His Apostle, you did not have to spur horse or riding-camel for its sake: but God gives His apostles mastery over whomever He wills - for God has the power to will anything.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5132.mp3","surahId":59,"words":[{"id":6247,"position":1,"arabic":"وَمَآ","translation":"এবং যা","audioUrl":"wbw/059_006_001.mp3","charTypeName":"word"},{"id":6248,"position":2,"arabic":"أَفَآءَ","translation":"ফায় দিয়েছে","audioUrl":"wbw/059_006_002.mp3","charTypeName":"word"},{"id":6249,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/059_006_003.mp3","charTypeName":"word"},{"id":6250,"position":4,"arabic":"عَلَىٰ","translation":"নিকট","audioUrl":"wbw/059_006_004.mp3","charTypeName":"word"},{"id":6251,"position":5,"arabic":"رَسُولِهِۦ","translation":"তার রসূলের","audioUrl":"wbw/059_006_005.mp3","charTypeName":"word"},{"id":6252,"position":6,"arabic":"مِنْهُمْ","translation":"তাদের থেকে","audioUrl":"wbw/059_006_006.mp3","charTypeName":"word"},{"id":6253,"position":7,"arabic":"فَمَآ","translation":"নাই এ জন্য","audioUrl":"wbw/059_006_007.mp3","charTypeName":"word"},{"id":6254,"position":8,"arabic":"أَوْجَفْتُمْ","translation":"তোমরা দৌড়াও","audioUrl":"wbw/059_006_008.mp3","charTypeName":"word"},{"id":6255,"position":9,"arabic":"عَلَيْهِ","translation":"তার উপর","audioUrl":"wbw/059_006_009.mp3","charTypeName":"word"},{"id":6256,"position":10,"arabic":"مِنْ","translation":"কোন","audioUrl":"wbw/059_006_010.mp3","charTypeName":"word"},{"id":6257,"position":11,"arabic":"خَيْلٍۢ","translation":"ঘোড়া","audioUrl":"wbw/059_006_011.mp3","charTypeName":"word"},{"id":6258,"position":12,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/059_006_012.mp3","charTypeName":"word"},{"id":6259,"position":13,"arabic":"رِكَابٍۢ","translation":"উট","audioUrl":"wbw/059_006_013.mp3","charTypeName":"word"},{"id":6260,"position":14,"arabic":"وَلَـٰكِنَّ","translation":"কিন্তু","audioUrl":"wbw/059_006_014.mp3","charTypeName":"word"},{"id":6261,"position":15,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/059_006_015.mp3","charTypeName":"word"},{"id":6262,"position":16,"arabic":"يُسَلِّطُ","translation":"আধিপত্য দেন","audioUrl":"wbw/059_006_016.mp3","charTypeName":"word"},{"id":6263,"position":17,"arabic":"رُسُلَهُۥ","translation":"তার রসূলদেরকে","audioUrl":"wbw/059_006_017.mp3","charTypeName":"word"},{"id":6264,"position":18,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/059_006_018.mp3","charTypeName":"word"},{"id":6265,"position":19,"arabic":"مَن","translation":"যার","audioUrl":"wbw/059_006_019.mp3","charTypeName":"word"},{"id":6266,"position":20,"arabic":"يَشَآءُ ۚ","translation":"তিনি ইচ্ছে করেন","audioUrl":"wbw/059_006_020.mp3","charTypeName":"word"},{"id":6268,"position":21,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/059_006_022.mp3","charTypeName":"word"},{"id":6269,"position":22,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/059_006_023.mp3","charTypeName":"word"},{"id":6270,"position":23,"arabic":"كُلِّ","translation":"সব","audioUrl":"wbw/059_006_024.mp3","charTypeName":"word"},{"id":6271,"position":24,"arabic":"شَىْءٍۢ","translation":"কিছুুর","audioUrl":"wbw/059_006_025.mp3","charTypeName":"word"},{"id":6272,"position":25,"arabic":"قَدِيرٌۭ","translation":"ক্ষমতাবান","audioUrl":"wbw/059_006_026.mp3","charTypeName":"word"},{"id":6273,"position":26,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"مَّآ أَفَآءَ ٱللَّهُ عَلَىٰ رَسُولِهِۦ مِنْ أَهْلِ ٱلْقُرَىٰ فَلِلَّهِ وَلِلرَّسُولِ وَلِذِى ٱلْقُرْبَىٰ وَٱلْيَتَٰمَىٰ وَٱلْمَسَٰكِينِ وَٱبْنِ ٱلسَّبِيلِ كَىْ لَا يَكُونَ دُولَةًۢ بَيْنَ ٱلْأَغْنِيَآءِ مِنكُمْ ۚ وَمَآ ءَاتَىٰكُمُ ٱلرَّسُولُ فَخُذُوهُ وَمَا نَهَىٰكُمْ عَنْهُ فَٱنتَهُوا۟ ۚ وَٱتَّقُوا۟ ٱللَّهَ ۖ إِنَّ ٱللَّهَ شَدِيدُ ٱلْعِقَابِ","translation":"Whatever [spoils taken] from the people of those villages God has turned over to His Apostle - [all of it] belongs to God and the Apostle, and the near of kin [of deceased believers], and the orphans, and the needy, and the wayfarer, so that it may not be [a benefit] going round and round among such of you as may [already] be rich. Hence, accept [willing­ly] whatever the Apostle* gives you [thereof], and refrain from [demanding] anything that he withholds from you; and remain conscious of God: for, verily, God is severe in retribution.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5133.mp3","surahId":59,"words":[{"id":7672,"position":1,"arabic":"مَّآ","translation":"যা","audioUrl":"wbw/059_007_001.mp3","charTypeName":"word"},{"id":7673,"position":2,"arabic":"أَفَآءَ","translation":"ফায় দিয়েছেন","audioUrl":"wbw/059_007_002.mp3","charTypeName":"word"},{"id":7674,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/059_007_003.mp3","charTypeName":"word"},{"id":7675,"position":4,"arabic":"عَلَىٰ","translation":"(উপর)","audioUrl":"wbw/059_007_004.mp3","charTypeName":"word"},{"id":7676,"position":5,"arabic":"رَسُولِهِۦ","translation":"তার রাসূলকে","audioUrl":"wbw/059_007_005.mp3","charTypeName":"word"},{"id":7677,"position":6,"arabic":"مِنْ","translation":"হতে","audioUrl":"wbw/059_007_006.mp3","charTypeName":"word"},{"id":7678,"position":7,"arabic":"أَهْلِ","translation":"বাসীদের","audioUrl":"wbw/059_007_007.mp3","charTypeName":"word"},{"id":7679,"position":8,"arabic":"ٱلْقُرَىٰ","t