وَٰلِهِمْ يَبْتَغُونَ فَضْلًۭا مِّنَ ٱللَّهِ وَرِضْوَٰنًۭا وَيَنصُرُونَ ٱللَّهَ وَرَسُولَهُۥٓ ۚ أُو۟لَٰٓئِكَ هُمُ ٱلصَّٰدِقُونَ","translation":"[Thus, part of such war-gains shall be given] to the poor among those who have forsaken the domain of evil: those who have been driven from their homelands and their possessions, seeking favour with God and [His] goodly acceptance, and who aid [the cause of] God and His Apostle: it is they, they who are true to their word!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5134.mp3","surahId":59,"words":[{"id":8862,"position":1,"arabic":"لِلْفُقَرَآءِ","translation":"অভাবগ্রস্তদের জন্যে","audioUrl":"wbw/059_008_001.mp3","charTypeName":"word"},{"id":8863,"position":2,"arabic":"ٱلْمُهَـٰجِرِينَ","translation":"মাোহাজিরদের","audioUrl":"wbw/059_008_002.mp3","charTypeName":"word"},{"id":8864,"position":3,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/059_008_003.mp3","charTypeName":"word"},{"id":8865,"position":4,"arabic":"أُخْرِجُوا۟","translation":"বহিষ্কৃত হয়েছে","audioUrl":"wbw/059_008_004.mp3","charTypeName":"word"},{"id":8866,"position":5,"arabic":"مِن","translation":"হতে","audioUrl":"wbw/059_008_005.mp3","charTypeName":"word"},{"id":8867,"position":6,"arabic":"دِيَـٰرِهِمْ","translation":"তাদের ঘোড়বাড়ী গুলো","audioUrl":"wbw/059_008_006.mp3","charTypeName":"word"},{"id":8868,"position":7,"arabic":"وَأَمْوَٰلِهِمْ","translation":"ও তাদের সম্পদগুলো","audioUrl":"wbw/059_008_007.mp3","charTypeName":"word"},{"id":8869,"position":8,"arabic":"يَبْتَغُونَ","translation":"তারা পেতে চা্য়","audioUrl":"wbw/059_008_008.mp3","charTypeName":"word"},{"id":8870,"position":9,"arabic":"فَضْلًۭا","translation":"অনুগ্রহ","audioUrl":"wbw/059_008_009.mp3","charTypeName":"word"},{"id":8871,"position":10,"arabic":"مِّنَ","translation":"থেকে","audioUrl":"wbw/059_008_010.mp3","charTypeName":"word"},{"id":8872,"position":11,"arabic":"ٱللَّهِ","translation":"আল্লাহ","audioUrl":"wbw/059_008_011.mp3","charTypeName":"word"},{