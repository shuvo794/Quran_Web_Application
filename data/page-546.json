1.mp3","charTypeName":"word"},{"id":10062,"position":2,"arabic":"تَبَوَّءُو","translation":"বসবাস করেছে","audioUrl":"wbw/059_009_002.mp3","charTypeName":"word"},{"id":10063,"position":3,"arabic":"ٱلدَّارَ","translation":"(এই) নগরীতে","audioUrl":"wbw/059_009_003.mp3","charTypeName":"word"},{"id":10064,"position":4,"arabic":"وَٱلْإِيمَـٰنَ","translation":"এবং ঈমান (এনেছে)","audioUrl":"wbw/059_009_004.mp3","charTypeName":"word"},{"id":10065,"position":5,"arabic":"مِن","translation":"মধ্য হতে","audioUrl":"wbw/059_009_005.mp3","charTypeName":"word"},{"id":10066,"position":6,"arabic":"قَبْلِهِمْ","translation":"তাদের  পূর্বে","audioUrl":"wbw/059_009_006.mp3","charTypeName":"word"},{"id":10067,"position":7,"arabic":"يُحِبُّونَ","translation":"তারা ভালোবাসে","audioUrl":"wbw/059_009_007.mp3","charTypeName":"word"},{"id":10068,"position":8,"arabic":"مَنْ","translation":"(তাদেরকে) যারা","audioUrl":"wbw/059_009_008.mp3","charTypeName":"word"},{"id":10069,"position":9,"arabic":"هَاجَرَ","translation":"হিজরত করেছে","audioUrl":"wbw/059_009_009.mp3","charTypeName":"word"},{"id":10070,"position":10,"arabic":"إِلَيْهِمْ","translation":"তাদের দিকে","audioUrl":"wbw/059_009_010.mp3","charTypeName":"word"},{"id":10071,"position":11,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/059_009_011.mp3","charTypeName":"word"},{"id":10072,"position":12,"arabic":"يَجِدُونَ","translation":"তারাপায়","audioUrl":"wbw/059_009_012.mp3","charTypeName":"word"},{"id":10073,"position":13,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/059_009_013.mp3","charTypeName":"word"},{"id":10074,"position":14,"arabic":"صُدُورِهِمْ","translation":"তাদের অন্তরগুলোর","audioUrl":"wbw/059_009_014.mp3","charTypeName":"word"},{"id":10075,"position":15,"arabic":"حَاجَةًۭ","translation":"প্রয়োজনের (অনুভূতি)","audioUrl":"wbw/059_009_015.mp3","charTypeName":"word"},{"id":10076,"position":16,"arabic":"مِّمَّآ","translation":"(যা) তা থেকে","audioUrl":"wbw/059_009_016.mp3","charTypeName":"word"},{"id":10077,"positi