{"id":536,"ayahs":[{"number":51,"arabic":"ثُمَّ إِنَّكُمْ أَيُّهَا ٱلضَّآلُّونَ ٱلْمُكَذِّبُونَ","translation":"and then, verily, O you who have gone astray and called the truth a lie,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5030.mp3","surahId":56,"words":[{"id":49200,"position":1,"arabic":"ثُمَّ","translation":"\"এরপর","audioUrl":"wbw/056_051_001.mp3","charTypeName":"word"},{"id":49201,"position":2,"arabic":"إِنَّكُمْ","translation":"নিশ্চয়ই তোমরা","audioUrl":"wbw/056_051_002.mp3","charTypeName":"word"},{"id":49202,"position":3,"arabic":"أَيُّهَا","translation":"হে","audioUrl":"wbw/056_051_003.mp3","charTypeName":"word"},{"id":49203,"position":4,"arabic":"ٱلضَّآلُّونَ","translation":"পথভ্রষ্টরা","audioUrl":"wbw/056_051_004.mp3","charTypeName":"word"},{"id":49204,"position":5,"arabic":"ٱلْمُكَذِّبُونَ","translation":"মিথ্যারোপকারীরা","audioUrl":"wbw/056_051_005.mp3","charTypeName":"word"},{"id":49205,"position":6,"arabic":"٥١","translation":"(৫১)","audioUrl":null,"charTypeName":"end"}]},{"number":52,"arabic":"لَءَاكِلُونَ مِن شَجَرٍۢ مِّن زَقُّومٍۢ","translation":"you will indeed have to taste of the tree of deadly fruit,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5031.mp3","surahId":56,"words":[{"id":50165,"position":1,"arabic":"لَـَٔاكِلُونَ","translation":"অবশ্যই আহার করবে","audioUrl":"wbw/056_052_001.mp3","charTypeName":"word"},{"id":50166,"position":2,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/056_052_002.mp3","charTypeName":"word"},{"id":50167,"position":3,"arabic":"شَجَرٍۢ","translation":"গাছ","audioUrl":"wbw/056_052_003.mp3","charTypeName":"word"},{"id":50168,"position":4,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/056_052_004.mp3","charTypeName":"word"},{"id":50169,"position":5,"arabic":"زَقُّومٍۢ","translation":"যাক্কুমের","audioUrl":"wbw/056_052_005.mp3","charTypeName":"word"},{"id":50170,"position":6,"arabic":"٥٢","translation":"(৫২)","audioUrl":null,"charTypeName":"end"}]},{"number":53,"arabic":"فَمَالِـُٔونَ مِنْهَا ٱلْبُطُونَ","translation":"and will have to fill your bellies therewith,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5032.mp3","surahId":56,"words":[{"id":50554,"position":1,"arabic":"فَمَالِـُٔونَ","translation":"অতঃপর পূর্ণ করবে","audioUrl":"wbw/056_053_001.mp3","charTypeName":"word"},{"id":50555,"position":2,"arabic":"مِنْهَا","translation":"তা দিয়ে","audioUrl":"wbw/056_053_002.mp3","charTypeName":"word"},{"id":50556,"position":3,"arabic":"ٱلْبُطُونَ","translation":"পেট সমূহকে","audioUrl":"wbw/056_053_003.mp3","charTypeName":"word"},{"id":50557,"position":4,"arabic":"٥٣","translation":"(৫৩)","audioUrl":null,"charTypeName":"end"}]},{"number":54,"arabic":"فَشَٰرِبُونَ عَلَيْهِ مِنَ ٱلْحَمِيمِ","translation":"and will thereupon have to drink [many a draught] of burning despair -","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5033.mp3","surahId":56,"words":[{"id":51340,"position":1,"arabic":"فَشَـٰرِبُونَ","translation":"অতঃপর পান করবে","audioUrl":"wbw/056_054_001.mp3","charTypeName":"word"},{"id":51341,"position":2,"arabic":"عَلَيْهِ","translation":"তার উপর","audioUrl":"wbw/056_054_002.mp3","charTypeName":"word"},{"id":51342,"position":3,"arabic":"مِنَ","translation":"থেকে","audioUrl":"wbw/056_054_003.mp3","charTypeName":"word"},{"id":51343,"position":4,"arabic":"ٱلْحَمِيمِ","translation":"ফুটন্ত পানি","audioUrl":"wbw/056_054_004.mp3","charTypeName":"word"},{"id":51344,"position":5,"arabic":"٥٤","translation":"(৫৪)","audioUrl":null,"charTypeName":"end"}]},{"number":55,"arabic":"فَشَٰرِبُونَ شُرْبَ ٱلْهِيمِ","translation":"drink it as the most insatiably thirsty camels drink!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5034.mp3","surahId":56,"words":[{"id":51704,"position":1,"arabic":"فَشَـٰرِبُونَ","translation":"অতঃপর পান করবে","audioUrl":"wbw/056_055_001.mp3","charTypeName":"word"},{"id":51705,"position":2,"arabic":"شُرْبَ","translation":"পান করার (মত)","audioUrl":"wbw/056_055_002.mp3","charTypeName":"word"},{"id":51706,"position":3,"arabic":"ٱلْهِيمِ","translation":"পিপাসার্ত উট সমূহের\"","audioUrl":"wbw/056_055_003.mp3","charTypeName":"word"},{"id":51707,"position":4,"arabic":"٥٥","translation":"(৫৫)","audioUrl":null,"charTypeName":"end"}]},{"number":56,"arabic":"هَٰذَا نُزُلُهُمْ يَوْمَ ٱلدِّينِ","translation":"Such will be their welcome on Judgment Day!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5035.mp3","surahId":56,"words":[{"id":52122,"position":1,"arabic":"هَـٰذَا","translation":"এটা","audioUrl":"wbw/056_056_001.mp3","charTypeName":"word"},{"id":52123,"position":2,"arabic":"نُزُلُهُمْ","translation":"তাদের আপ্যায়ন (হবে)","audioUrl":"wbw/056_056_002.mp3","charTypeName":"word"},{"id":52124,"position":3,"arabic":"يَوْمَ","translation":"দিনে","audioUrl":"wbw/056_056_003.mp3","charTypeName":"word"},{"id":52125,"position":4,"arabic":"ٱلدِّينِ","translation":"কিয়ামতের","audioUrl":"wbw/056_056_004.mp3","charTypeName":"word"},{"id":52126,"position":5,"arabic":"٥٦","translation":"(৫৬)","audioUrl":null,"charTypeName":"end"}]},{"number":57,"arabic":"نَحْنُ خَلَقْنَٰكُمْ فَلَوْلَا تُصَدِّقُونَ","translation":"WE who have created you, [O men:] why, then, do you not accept the truth?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5036.mp3","surahId":56,"words":[{"id":52801,"position":1,"arabic":"نَحْنُ","translation":"আমরা","audioUrl":"wbw/056_057_001.mp3","charTypeName":"word"},{"id":52802,"position":2,"arabic":"خَلَقْنَـٰكُمْ","translation":"তোমাদেরকে সৃষ্টি করেছি","audioUrl":"wbw/056_057_002.mp3","charTypeName":"word"},{"id":52803,"position":3,"arabic":"فَلَوْلَا","translation":"কেন তবুও না","audioUrl":"wbw/056_057_003.mp3","charTypeName":"word"},{"id":52804,"position":4,"arabic":"تُصَدِّقُونَ","translation":"তোমার বিশ্বাস কর","audioUrl":"wbw/056_057_004.mp3","charTypeName":"word"},{"id":52805,"position":5,"arabic":"٥٧","translation":"(৫৭)","audioUrl":null,"charTypeName":"end"}]},{"number":58,"arabic":"أَفَرَءَيْتُم مَّا تُمْنُونَ","translation":"Have you ever considered that [seed] which you emit?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5037.mp3","surahId":56,"words":[{"id":53393,"position":1,"arabic":"أَفَرَءَيْتُم","translation":"তোমরা (ভেবে) দেখেছ কি তাহলে","audioUrl":"wbw/056_058_001.mp3","charTypeName":"word"},{"id":53394,"position":2,"arabic":"مَّا","translation":"যা","audioUrl":"wbw/056_058_002.mp3","charTypeName":"word"},{"id":53395,"position":3,"arabic":"تُمْنُونَ","translation":"তোমরা বীর্যপাত কর","audioUrl":"wbw/056_058_003.mp3","charTypeName":"word"},{"id":53396,"position":4,"arabic":"٥٨","translation":"(৫৮)","audioUrl":null,"charTypeName":"end"}]},{"number":59,"arabic":"ءَأَنتُمْ تَخْلُقُونَهُۥٓ أَمْ نَحْنُ ٱلْخَٰلِقُونَ","translation":"Is it you who create it - or are We the source of its creation?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5038.mp3","surahId":56,"words":[{"id":53814,"position":1,"arabic":"ءَأَنتُمْ","translation":"তোমরা কি","audioUrl":"wbw/056_059_001.mp3","charTypeName":"word"},{"id":53815,"position":2,"arabic":"تَخْلُقُونَهُۥٓ","translation":"তা সৃষ্টি কর","audioUrl":"wbw/056_059_002.mp3","charTypeName":"word"},{"id":53816,"position":3,"arabic":"أَمْ","translation":"না","audioUrl":"wbw/056_059_003.mp3","charTypeName":"word"},{"id":53817,"position":4,"arabic":"نَحْنُ","translation":"আমরা","audioUrl":"wbw/056_059_004.mp3","charTypeName":"word"},{"id":53818,"position":5,"arabic":"ٱلْخَـٰلِقُونَ","translation":"সৃষ্টিকারী","audioUrl":"wbw/056_059_005.mp3","charTypeName":"word"},{"id":53819,"position":6,"arabic":"٥٩","translation":"(৫৯)","audioUrl":null,"charTypeName":"end"}]},{"number":60,"arabic":"نَحْنُ قَدَّرْنَا بَيْنَكُمُ ٱلْمَوْتَ وَمَا نَحْنُ بِمَسْبُوقِينَ","translation":"We have [indeed] decreed that death shall be [ever-present] among you: but there is nothing to prevent Us","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5039.mp3","surahId":56,"words":[{"id":54557,"position":1,"arabic":"نَحْنُ","translation":"আমরা","audioUrl":"wbw/056_060_001.mp3","charTypeName":"word"},{"id":54558,"position":2,"arabic":"قَدَّرْنَا","translation":"নির্ধারণ করেছি","audioUrl":"wbw/056_060_002.mp3","charTypeName":"word"},{"id":54559,"position":3,"arabic":"بَيْنَكُمُ","translation":"তোমাদের মাঝে","audioUrl":"wbw/056_060_003.mp3","charTypeName":"word"},{"id":54560,"position":4,"arabic":"ٱلْمَوْتَ","translation":"মৃত্যু","audioUrl":"wbw/056_060_004.mp3","charTypeName":"word"},{"id":54561,"position":5,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/056_060_005.mp3","charTypeName":"word"},{"id":54562,"position":6,"arabic":"نَحْنُ","translation":"আমরা","audioUrl":"wbw/056_060_006.mp3","charTypeName":"word"},{"id":54563,"position":7,"arabic":"بِمَسْبُوقِينَ","translation":"অক্ষম","audioUrl":"wbw/056_060_007.mp3","charTypeName":"word"},{"id":54564,"position":8,"arabic":"٦٠","translation":"(৬০)","audioUrl":null,"charTypeName":"end"}]},{"number":61,"arabic":"عَلَىٰٓ أَن نُّبَدِّلَ أَمْثَٰلَكُمْ وَنُنشِئَكُمْ فِى مَا لَا تَعْلَمُونَ","translation":"from changing the nature of your existence and bringing you into being [anew] in a manner [as yet] unknown to you.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5040.mp3","surahId":56,"words":[{"id":55004,"position":1,"arabic":"عَلَىٰٓ","translation":"এক্ষেত্রে","audioUrl":"wbw/056_061_001.mp3","charTypeName":"word"},{"id":55005,"position":2,"arabic":"أَن","translation":"যে","audioUrl":"wbw/056_061_002.mp3","charTypeName":"word"},{"id":55006,"position":3,"arabic":"نُّبَدِّلَ","translation":"পরিবর্তন করব আমরা","audioUrl":"wbw/056_061_003.mp3","charTypeName":"word"},{"id":55007,"position":4,"arabic":"أَمْثَـٰلَكُمْ","translation":"তোমাদের আকৃতি","audioUrl":"wbw/056_061_004.mp3","charTypeName":"word"},{"id":55008,"position":5,"arabic":"وَنُنشِئَكُمْ","translation":"এবং তোমাদের সৃষ্টি করব আমরা","audioUrl":"wbw/056_061_005.mp3","charTypeName":"word"},{"id":55009,"position":6,"arabic":"فِى","translation":"(এমন আকৃতির) মধ্যে","audioUrl":"wbw/056_061_006.mp3","charTypeName":"word"},{"id":55010,"position":7,"arabic":"مَا","translation":"যা","audioUrl":"wbw/056_061_007.mp3","charTypeName":"word"},{"id":55011,"position":8,"arabic":"لَا","translation":"না","audioUrl":"wbw/056_061_008.mp3","charTypeName":"word"},{"id":55012,"position":9,"arabic":"تَعْلَمُونَ","translation":"তোমরা জান","audioUrl":"wbw/056_061_009.mp3","charTypeName":"word"},{"id":55013,"position":10,"arabic":"٦١","translation":"(৬১)","audioUrl":null,"charTypeName":"end"}]},{"number":62,"arabic":"وَلَقَدْ عَلِمْتُمُ ٱلنَّشْأَةَ ٱلْأُولَىٰ فَلَوْلَا تَذَكَّرُونَ","translation":"And [since] you are indeed aware of the [miracle of your] coming into being in the first instance - why, then, do you not bethink yourselves [of Us]?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5041.mp3","surahId":56,"words":[{"id":55553,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/056_062_001.mp3","charTypeName":"word"},{"id":55554,"position":2,"arabic":"عَلِمْتُمُ","translation":"তোমরা জেনেছ","audioUrl":"wbw/056_062_002.mp3","charTypeName":"word"},{"id":55555,"position":3,"arabic":"ٱلنَّشْأَةَ","translation":"সৃষ্টিকে","audioUrl":"wbw/056_062_003.mp3","charTypeName":"word"},{"id":55556,"position":4,"arabic":"ٱلْأُولَىٰ","translation":"প্রথমবার","audioUrl":"wbw/056_062_004.mp3","charTypeName":"word"},{"id":55557,"position":5,"arabic":"فَلَوْلَا","translation":"কেন তবে না","audioUrl":"wbw/056_062_005.mp3","charTypeName":"word"},{"id":55558,"position":6,"arabic":"تَذَكَّرُونَ","translation":"তোমরা শিক্ষা গ্রহণ কর","audioUrl":"wbw/056_062_006.mp3","charTypeName":"word"},{"id":55559,"position":7,"arabic":"٦٢","translation":"(৬২)","audioUrl":null,"charTypeName":"end"}]},{"number":63,"arabic":"أَفَرَءَيْتُم مَّا تَحْرُثُونَ","translation":"Have you ever considered the seed which you cast upon the soil?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5042.mp3","surahId":56,"words":[{"id":56163,"position":1,"arabic":"أَفَرَءَيْتُم","translation":"তোমরা তবে কি (ভেবে) দেখেছ","audioUrl":"wbw/056_063_001.mp3","charTypeName":"word"},{"id":56164,"position":2,"arabic":"مَّا","translation":"যা","audioUrl":"wbw/056_063_002.mp3","charTypeName":"word"},{"id":56165,"position":3,"arabic":"تَحْرُثُونَ","translation":"তোমরা বীজবপণ কর","audioUrl":"wbw/056_063_003.mp3","charTypeName":"word"},{"id":56166,"position":4,"arabic":"٦٣","translation":"(৬৩)","audioUrl":null,"charTypeName":"end"}]},{"number":64,"arabic":"ءَأَنتُمْ تَزْرَعُونَهُۥٓ أَمْ نَحْنُ ٱلزَّٰرِعُونَ","translation":"Is it you who cause it to grow - or are We the cause of its growth?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5043.mp3","surahId":56,"words":[{"id":56676,"position":1,"arabic":"ءَأَنتُمْ","translation":"তোমরা কি","audioUrl":"wbw/056_064_001.mp3","charTypeName":"word"},{"id":56677,"position":2,"arabic":"تَزْرَعُونَهُۥٓ","translation":"সেই ফসল ফলাও","audioUrl":"wbw/056_064_002.mp3","charTypeName":"word"},{"id":56678,"position":3,"arabic":"أَمْ","translation":"না","audioUrl":"wbw/056_064_003.mp3","charTypeName":"word"},{"id":56679,"position":4,"arabic":"نَحْنُ","translation":"আমরা","audioUrl":"wbw/056_064_004.mp3","charTypeName":"word"},{"id":56680,"position":5,"arabic":"ٱلزَّٰرِعُونَ","translation":"উৎপাদনকারী","audioUrl":"wbw/056_064_005.mp3","charTypeName":"word"},{"id":56681,"position":6,"arabic":"٦٤","translation":"(৬৪)","audioUrl":null,"charTypeName":"end"}]},{"number":65,"arabic":"لَوْ نَشَآءُ لَجَعَلْنَٰهُ حُطَٰمًۭا فَظَلْتُمْ تَفَكَّهُونَ","translation":"[For,] were it Our will, We could indeed turn it into chaff, and you would be left to wonder [and to lament],","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5044.mp3","surahId":56,"words":[{"id":57219,"position":1,"arabic":"لَوْ","translation":"যদি","audioUrl":"wbw/056_065_001.mp3","charTypeName":"word"},{"id":57220,"position":2,"arabic":"نَشَآءُ","tran