":"أَفَرَءَيْتُمُ ٱلْمَآءَ ٱلَّذِى تَشْرَبُونَ","translation":"Have you ever considered the water which you drink?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5047.mp3","surahId":56,"words":[{"id":58585,"position":1,"arabic":"أَفَرَءَيْتُمُ","translation":"তোমরা তবে কি (ভেবে) দেখেছ","audioUrl":"wbw/056_068_001.mp3","charTypeName":"word"},{"id":58586,"position":2,"arabic":"ٱلْمَآءَ","translation":"পানি (সম্পর্কে)","audioUrl":"wbw/056_068_002.mp3","charTypeName":"word"},{"id":58587,"position":3,"arabic":"ٱلَّذِى","translation":"যা","audioUrl":"wbw/056_068_003.mp3","charTypeName":"word"},{"id":58588,"position":4,"arabic":"تَشْرَبُونَ","translation":"তোমরা পান কর","audioUrl":"wbw/056_068_004.mp3","charTypeName":"word"},{"id":58589,"position":5,"arabic":"٦٨","translation":"(৬৮)","audioUrl":null,"charTypeName":"end"}]},{"number":69,"arabic":"ءَأَنتُمْ أَنزَلْتُمُوهُ مِنَ ٱلْمُزْنِ أَمْ نَحْنُ ٱلْمُنزِلُونَ","translation":"Is it you who cause it to come down from the clouds - or are We the cause of its coming down?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5048.mp3","surahId":56,"words":[{"id":59031,"position":1,"arabic":"ءَأَنتُمْ","translation":"তোমরা কি","audioUrl":"wbw/056_069_001.mp3","charTypeName":"word"},{"id":59032,"position":2,"arabic":"أَنزَلْتُمُوهُ","translation":"তা নামিয়ে আন","audioUrl":"wbw/056_069_002.mp3","charTypeName":"word"},{"id":59033,"position":3,"arabic":"مِنَ","translation":"থেকে","audioUrl":"wbw/056_069_003.mp3","charTypeName":"word"},{"id":59034,"position":4,"arabic":"ٱلْمُزْنِ","translation":"মেঘ","audioUrl":"wbw/056_069_004.mp3","charTypeName":"word"},{"id":59035,"position":5,"arabic":"أَمْ","translation":"না","audioUrl":"wbw/056_069_005.mp3","charTypeName":"word"},{"id":59036,"position":6,"arabic":"نَحْنُ","translation":"আমরা","audioUrl":"wbw/056_069_006.mp3","charTypeName":"word"},{"id":59037,"position":7,"arabic":"ٱلْمُنزِلُونَ","translation":"বর্ষণকারী","audioUrl":"wbw/056_069_007.mp3","charTy