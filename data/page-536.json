"position":4,"arabic":"ٱلنُّجُومِ","translation":"তারকা গুলোর","audioUrl":"wbw/056_075_005.mp3","charTypeName":"word"},{"id":62203,"position":5,"arabic":"٧٥","translation":"(৭৫)","audioUrl":null,"charTypeName":"end"}]},{"number":76,"arabic":"وَإِنَّهُۥ لَقَسَمٌۭ لَّوْ تَعْلَمُونَ عَظِيمٌ","translation":"and, behold, this is indeed a most solemn affirmation, if you but knew it!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5055.mp3","surahId":56,"words":[{"id":62468,"position":1,"arabic":"وَإِنَّهُۥ","translation":"এবং তা নিশ্চয়ই","audioUrl":"wbw/056_076_001.mp3","charTypeName":"word"},{"id":62469,"position":2,"arabic":"لَقَسَمٌۭ","translation":"শপথ অবশ্যই","audioUrl":"wbw/056_076_002.mp3","charTypeName":"word"},{"id":62470,"position":3,"arabic":"لَّوْ","translation":"যদি","audioUrl":"wbw/056_076_003.mp3","charTypeName":"word"},{"id":62471,"position":4,"arabic":"تَعْلَمُونَ","translation":"তোমরা জান","audioUrl":"wbw/056_076_004.mp3","charTypeName":"word"},{"id":62472,"position":5,"arabic":"عَظِيمٌ","translation":"(শপথ) বিরাট","audioUrl":"wbw/056_076_005.mp3","charTypeName":"word"},{"id":62473,"position":6,"arabic":"٧٦","translation":"(৭৬)","audioUrl":null,"charTypeName":"end"}]}]}