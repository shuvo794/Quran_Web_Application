{"id":140,"ayahs":[{"number":95,"arabic":"۞ إِنَّ ٱللَّهَ فَالِقُ ٱلْحَبِّ وَٱلنَّوَىٰ ۖ يُخْرِجُ ٱلْحَىَّ مِنَ ٱلْمَيِّتِ وَمُخْرِجُ ٱلْمَيِّتِ مِنَ ٱلْحَىِّ ۚ ذَٰلِكُمُ ٱللَّهُ ۖ فَأَنَّىٰ تُؤْفَكُونَ","translation":"VERILY, God is the One who cleaves the grain and the fruit-kernel asunder, bringing forth the living out of that which is dead, and He is the One who brings forth the dead out of that which is alive. This, then, is God: and yet, how perverted are your minds!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/884.mp3","surahId":6,"words":[{"id":69698,"position":1,"arabic":"۞ إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/006_095_002.mp3","charTypeName":"word"},{"id":69699,"position":2,"arabic":"ٱللَّهَ","translation":"আল্লাহ্‌","audioUrl":"wbw/006_095_003.mp3","charTypeName":"word"},{"id":69700,"position":3,"arabic":"فَالِقُ","translation":"বিদীর্ণকারী","audioUrl":"wbw/006_095_004.mp3","charTypeName":"word"},{"id":69701,"position":4,"arabic":"ٱلْحَبِّ","translation":"শস্য-বীজ","audioUrl":"wbw/006_095_005.mp3","charTypeName":"word"},{"id":69702,"position":5,"arabic":"وَٱلنَّوَىٰ ۖ","translation":"ও আঁটি","audioUrl":"wbw/006_095_006.mp3","charTypeName":"word"},{"id":69704,"position":6,"arabic":"يُخْرِجُ","translation":"বের করেন তিনি","audioUrl":"wbw/006_095_008.mp3","charTypeName":"word"},{"id":69705,"position":7,"arabic":"ٱلْحَىَّ","translation":"জীবন্তকে","audioUrl":"wbw/006_095_009.mp3","charTypeName":"word"},{"id":69706,"position":8,"arabic":"مِنَ","translation":"থেকে","audioUrl":"wbw/006_095_010.mp3","charTypeName":"word"},{"id":69707,"position":9,"arabic":"ٱلْمَيِّتِ","translation":"মৃতকে","audioUrl":"wbw/006_095_011.mp3","charTypeName":"word"},{"id":69708,"position":10,"arabic":"وَمُخْرِجُ","translation":"ও নির্গতকারী","audioUrl":"wbw/006_095_012.mp3","charTypeName":"word"},{"id":69709,"position":11,"arabic":"ٱلْمَيِّتِ","translation":"প্রাণহীনকে","audioUrl":"wbw/006_095_013.mp3","charTypeName":"word"},{"id":69710,"position":12,"arabic":"مِنَ","translation":"থেকে","audioUrl":"wbw/006_095_014.mp3","charTypeName":"word"},{"id":69711,"position":13,"arabic":"ٱلْحَىِّ ۚ","translation":"জীবন্ত","audioUrl":"wbw/006_095_015.mp3","charTypeName":"word"},{"id":69713,"position":14,"arabic":"ذَٰلِكُمُ","translation":"এই (হচ্ছেন)","audioUrl":"wbw/006_095_017.mp3","charTypeName":"word"},{"id":69714,"position":15,"arabic":"ٱللَّهُ ۖ","translation":"আল্লাহ্‌","audioUrl":"wbw/006_095_018.mp3","charTypeName":"word"},{"id":69716,"position":16,"arabic":"فَأَنَّىٰ","translation":"অতএব কোথায়","audioUrl":"wbw/006_095_020.mp3","charTypeName":"word"},{"id":69717,"position":17,"arabic":"تُؤْفَكُونَ","translation":"তোমাদের ফিরিয়ে নেয়া হচ্ছে","audioUrl":"wbw/006_095_021.mp3","charTypeName":"word"},{"id":69718,"position":18,"arabic":"٩٥","translation":"(৯৫)","audioUrl":null,"charTypeName":"end"}]},{"number":96,"arabic":"فَالِقُ ٱلْإِصْبَاحِ وَجَعَلَ ٱلَّيْلَ سَكَنًۭا وَٱلشَّمْسَ وَٱلْقَمَرَ حُسْبَانًۭا ۚ ذَٰلِكَ تَقْدِيرُ ٱلْعَزِيزِ ٱلْعَلِيمِ","translation":"[He is] the One who causes the dawn to break; and He has made the night to be [a source of] stillness, and the sun and the moon to run their appointed courses: [all] this is laid down by the will of the Almighty, the All-Knowing.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/885.mp3","surahId":6,"words":[{"id":70243,"position":1,"arabic":"فَالِقُ","translation":"তিনিই বিদীর্ণকারী (অন্ধকারের আবরণ)","audioUrl":"wbw/006_096_001.mp3","charTypeName":"word"},{"id":70244,"position":2,"arabic":"ٱلْإِصْبَاحِ","translation":"প্রভাতের (জন্যে)","audioUrl":"wbw/006_096_002.mp3","charTypeName":"word"},{"id":70245,"position":3,"arabic":"وَجَعَلَ","translation":"ও সৃষ্টি করেছেন","audioUrl":"wbw/006_096_003.mp3","charTypeName":"word"},{"id":70246,"position":4,"arabic":"ٱلَّيْلَ","translation":"রাতকে","audioUrl":"wbw/006_096_004.mp3","charTypeName":"word"},{"id":70247,"position":5,"arabic":"سَكَنًۭا","translation":"বিশ্রামের (জন্যে)","audioUrl":"wbw/006_096_005.mp3","charTypeName":"word"},{"id":70248,"position":6,"arabic":"وَٱلشَّمْسَ","translation":"ও (নির্ধারিত করেছেন) সূর্য","audioUrl":"wbw/006_096_006.mp3","charTypeName":"word"},{"id":70249,"position":7,"arabic":"وَٱلْقَمَرَ","translation":"ও চাঁদের","audioUrl":"wbw/006_096_007.mp3","charTypeName":"word"},{"id":70250,"position":8,"arabic":"حُسْبَانًۭا ۚ","translation":"(উদয় অস্তের)গণনার জন্যে","audioUrl":"wbw/006_096_008.mp3","charTypeName":"word"},{"id":70252,"position":9,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/006_096_010.mp3","charTypeName":"word"},{"id":70253,"position":10,"arabic":"تَقْدِيرُ","translation":"নির্ধারিত","audioUrl":"wbw/006_096_011.mp3","charTypeName":"word"},{"id":70254,"position":11,"arabic":"ٱلْعَزِيزِ","translation":"পরাক্রমশালী","audioUrl":"wbw/006_096_012.mp3","charTypeName":"word"},{"id":70255,"position":12,"arabic":"ٱلْعَلِيمِ","translation":"মহাজ্ঞানীর (পক্ষ থেকে)","audioUrl":"wbw/006_096_013.mp3","charTypeName":"word"},{"id":70256,"position":13,"arabic":"٩٦","translation":"(৯৬)","audioUrl":null,"charTypeName":"end"}]},{"number":97,"arabic":"وَهُوَ ٱلَّذِى جَعَلَ لَكُمُ ٱلنُّجُومَ لِتَهْتَدُوا۟ بِهَا فِى ظُلُمَٰتِ ٱلْبَرِّ وَٱلْبَحْرِ ۗ قَدْ فَصَّلْنَا ٱلْءَايَٰتِ لِقَوْمٍۢ يَعْلَمُونَ","translation":"And He it is who has set up for you the stars so that you might be guided by them in the midst of the deep darkness of land and sea: clearly, indeed, have We spelled out these messages unto people of [innate] knowledge!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/886.mp3","surahId":6,"words":[{"id":70553,"position":1,"arabic":"وَهُوَ","translation":"এবং তিনিই","audioUrl":"wbw/006_097_001.mp3","charTypeName":"word"},{"id":70554,"position":2,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/006_097_002.mp3","charTypeName":"word"},{"id":70555,"position":3,"arabic":"جَعَلَ","translation":"সৃষ্টি করেছেন","audioUrl":"wbw/006_097_003.mp3","charTypeName":"word"},{"id":70556,"position":4,"arabic":"لَكُمُ","translation":"জন্যে তোমাদের","audioUrl":"wbw/006_097_004.mp3","charTypeName":"word"},{"id":70557,"position":5,"arabic":"ٱلنُّجُومَ","translation":"নক্ষত্রগুলো","audioUrl":"wbw/006_097_005.mp3","charTypeName":"word"},{"id":70558,"position":6,"arabic":"لِتَهْتَدُوا۟","translation":"যেন তোমরা পথ পাও","audioUrl":"wbw/006_097_006.mp3","charTypeName":"word"},{"id":70559,"position":7,"arabic":"بِهَا","translation":"সাহায্যে তার","audioUrl":"wbw/006_097_007.mp3","charTypeName":"word"},{"id":70560,"position":8,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/006_097_008.mp3","charTypeName":"word"},{"id":70561,"position":9,"arabic":"ظُلُمَـٰتِ","translation":"অন্ধকারে সমূহের","audioUrl":"wbw/006_097_009.mp3","charTypeName":"word"},{"id":70562,"position":10,"arabic":"ٱلْبَرِّ","translation":"স্থলে","audioUrl":"wbw/006_097_010.mp3","charTypeName":"word"},{"id":70563,"position":11,"arabic":"وَٱلْبَحْرِ ۗ","translation":"ও সাগরে","audioUrl":"wbw/006_097_011.mp3","charTypeName":"word"},{"id":70565,"position":12,"arabic":"قَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/006_097_013.mp3","charTypeName":"word"},{"id":70566,"position":13,"arabic":"فَصَّلْنَا","translation":"বিশদ বর্ণনা করেছি আমরা","audioUrl":"wbw/006_097_014.mp3","charTypeName":"word"},{"id":70567,"position":14,"arabic":"ٱلْـَٔايَـٰتِ","translation":"নিদর্শনগুলোকে","audioUrl":"wbw/006_097_015.mp3","charTypeName":"word"},{"id":70568,"position":15,"arabic":"لِقَوْمٍۢ","translation":"জন্যে সম্প্রদায়ের","audioUrl":"wbw/006_097_016.mp3","charTypeName":"word"},{"id":70569,"position":16,"arabic":"يَعْلَمُونَ","translation":"(যারা) জ্ঞান রাখে","audioUrl":"wbw/006_097_017.mp3","charTypeName":"word"},{"id":70570,"position":17,"arabic":"٩٧","translation":"(৯৭)","audioUrl":null,"charTypeName":"end"}]},{"number":98,"arabic":"وَهُوَ ٱلَّذِىٓ أَنشَأَكُم مِّن نَّفْسٍۢ وَٰحِدَةٍۢ فَمُسْتَقَرٌّۭ وَمُسْتَوْدَعٌۭ ۗ قَدْ فَصَّلْنَا ٱلْءَايَٰتِ لِقَوْمٍۢ يَفْقَهُونَ","translation":"And He it is who has brought you [all] into being out of one living entity, and [has appointed for each of you] a time-limit [on earth] and a resting-place [after death]: clearly, indeed, have We spelled out these messages unto people who can grasp the truth!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/887.mp3","surahId":6,"words":[{"id":70609,"position":1,"arabic":"وَهُوَ","translation":"এবং তিনিই","audioUrl":"wbw/006_098_001.mp3","charTypeName":"word"},{"id":70610,"position":2,"arabic":"ٱلَّذِىٓ","translation":"যিনি","audioUrl":"wbw/006_098_002.mp3","charTypeName":"word"},{"id":70611,"position":3,"arabic":"أَنشَأَكُم","translation":"সৃষ্টি করেছেন তোমাদের","audioUrl":"wbw/006_098_003.mp3","charTypeName":"word"},{"id":70612,"position":4,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/006_098_004.mp3","charTypeName":"word"},{"id":70613,"position":5,"arabic":"نَّفْسٍۢ","translation":"ব্যক্তি","audioUrl":"wbw/006_098_005.mp3","charTypeName":"word"},{"id":70614,"position":6,"arabic":"وَٰحِدَةٍۢ","translation":"এক","audioUrl":"wbw/006_098_006.mp3","charTypeName":"word"},{"id":70615,"position":7,"arabic":"فَمُسْتَقَرٌّۭ","translation":"অতঃপর বাসস্হান","audioUrl":"wbw/006_098_007.mp3","charTypeName":"word"},{"id":70616,"position":8,"arabic":"وَمُسْتَوْدَعٌۭ ۗ","translation":"ও গচ্ছিত রাখার স্থান (নির্ধারিত করেছেন)","audioUrl":"wbw/006_098_008.mp3","charTypeName":"word"},{"id":70618,"position":9,"arabic":"قَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/006_098_010.mp3","charTypeName":"word"},{"id":70619,"position":10,"arabic":"فَصَّلْنَا","translation":"বিশদ বর্ণনা করেছি আমরা","audioUrl":"wbw/006_098_011.mp3","charTypeName":"word"},{"id":70620,"position":11,"arabic":"ٱلْـَٔايَـٰتِ","translation":"নিদর্শনগুলোকে","audioUrl":"wbw/006_098_012.mp3","charTypeName":"word"},{"id":70621,"position":12,"arabic":"لِقَوْمٍۢ","translation":"জন্যে সম্প্রদায়ের","audioUrl":"wbw/006_098_013.mp3","charTypeName":"word"},{"id":70622,"position":13,"arabic":"يَفْقَهُونَ","translation":"(যারা)অনুধাবন করে","audioUrl":"wbw/006_098_014.mp3","charTypeName":"word"},{"id":70623,"position":14,"arabic":"٩٨","translation":"(৯৮)","audioUrl":null,"charTypeName":"end"}]},{"number":99,"arabic":"وَهُوَ ٱلَّذِىٓ أَنزَلَ مِنَ ٱلسَّمَآءِ مَآءًۭ فَأَخْرَجْنَا بِهِۦ نَبَاتَ كُلِّ شَىْءٍۢ فَأَخْرَجْنَا مِنْهُ خَضِرًۭا نُّخْرِجُ مِنْهُ حَبًّۭا مُّتَرَاكِبًۭا وَمِنَ ٱلنَّخْلِ مِن طَلْعِهَا قِنْوَانٌۭ دَانِيَةٌۭ وَجَنَّٰتٍۢ مِّنْ أَعْنَابٍۢ وَٱلزَّيْتُونَ وَٱلرُّمَّانَ مُشْتَبِهًۭا وَغَيْرَ مُتَشَٰبِهٍ ۗ ٱنظُرُوٓا۟ إِلَىٰ ثَمَرِهِۦٓ إِذَآ أَثْمَرَ وَيَنْعِهِۦٓ ۚ إِنَّ فِى ذَٰلِكُمْ لَءَايَٰتٍۢ لِّقَوْمٍۢ يُؤْمِنُونَ","translation":"And He it is who has caused waters to come down from the sky; and by this means have We brought forth all living growth, and out of this have We brought forth verdure. Out of this do We bring forth close-growing grain; and out of the spathe of the palm tree, dates in thick clusters; and gardens of vines, and the olive tree, and the pomegranate: [all] so alike, and yet so different! Behold their fruit when it comes to fruition and ripens! Verily, in all this there are messages indeed for people who will believe!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/888.mp3","surahId":6,"words":[{"id":71058,"position":1,"arabic":"وَهُوَ","translation":"এবং তিনিই","audioUrl":"wbw/006_099_001.mp3","charTypeName":"word"},{"id":71059,"position":2,"arabic":"ٱلَّذِىٓ","translation":"যিনি","audioUrl":"wbw/006_099_002.mp3","charTypeName":"word"},{"id":71060,"position":3,"arabic":"أَنزَلَ","translation":"বর্ষণ করেন","audioUrl":"wbw/006_099_003.mp3","charTypeName":"word"},{"id":71061,"position":4,"arabic":"مِنَ","translation":"থেকে","audioUrl":"wbw/006_099_004.mp3","charTypeName":"word"},{"id":71062,"position":5,"arabic":"ٱلسَّمَآءِ","translation":"আকাশ","audioUrl":"wbw/006_099_005.mp3","charTypeName":"word"},{"id":71063,"position":6,"arabic":"مَآءًۭ","translation":"পানি","audioUrl":"wbw/006_099_006.mp3","charTypeName":"word"},{"id":71064,"position":7,"arabic":"فَأَخْرَجْنَا","transla