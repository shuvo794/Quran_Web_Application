{"id":322,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ ٱقْتَرَبَ لِلنَّاسِ حِسَابُهُمْ وَهُمْ فِى غَفْلَةٍۢ مُّعْرِضُونَ","translation":"CLOSER DRAWS unto men their reckoning: and yet they remain stubbornly heedless [of its approach].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2484.mp3","surahId":21,"words":[{"id":284,"position":1,"arabic":"ٱقْتَرَبَ","translation":"নিকটে এসেছে","audioUrl":"wbw/021_001_001.mp3","charTypeName":"word"},{"id":285,"position":2,"arabic":"لِلنَّاسِ","translation":"জন্যে মানুষের","audioUrl":"wbw/021_001_002.mp3","charTypeName":"word"},{"id":286,"position":3,"arabic":"حِسَابُهُمْ","translation":"তাদের হিসাব (নেয়ার সময়)","audioUrl":"wbw/021_001_003.mp3","charTypeName":"word"},{"id":287,"position":4,"arabic":"وَهُمْ","translation":"অথচ তারা","audioUrl":"wbw/021_001_004.mp3","charTypeName":"word"},{"id":288,"position":5,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/021_001_005.mp3","charTypeName":"word"},{"id":289,"position":6,"arabic":"غَفْلَةٍۢ","translation":"উদাসীনতার","audioUrl":"wbw/021_001_006.mp3","charTypeName":"word"},{"id":290,"position":7,"arabic":"مُّعْرِضُونَ","translation":"পড়ে আছে বিমুখ হয়ে","audioUrl":"wbw/021_001_007.mp3","charTypeName":"word"},{"id":291,"position":8,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"مَا يَأْتِيهِم مِّن ذِكْرٍۢ مِّن رَّبِّهِم مُّحْدَثٍ إِلَّا ٱسْتَمَعُوهُ وَهُمْ يَلْعَبُونَ","translation":"Whenever there comes unto them any new re­minder from their Sustainer, they but listen to it with playful amusement,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2485.mp3","surahId":21,"words":[{"id":1225,"position":1,"arabic":"مَا","translation":"না","audioUrl":"wbw/021_002_001.mp3","charTypeName":"word"},{"id":1226,"position":2,"arabic":"يَأْتِيهِم","translation":"তাদের কাছে আসে","audioUrl":"wbw/021_002_002.mp3","charTypeName":"word"},{"id":1227,"position":3,"arabic":"مِّن","translation":"কোন","audioUrl":"wbw/021_002_003.mp3","charTypeName":"word"},{"id":1228,"position":4,"arabic":"ذِكْرٍۢ","translation":"উপদেশ","audioUrl":"wbw/021_002_004.mp3","charTypeName":"word"},{"id":1229,"position":5,"arabic":"مِّن","translation":"পক্ষ হ'তে","audioUrl":"wbw/021_002_005.mp3","charTypeName":"word"},{"id":1230,"position":6,"arabic":"رَّبِّهِم","translation":"তাদের রবের","audioUrl":"wbw/021_002_006.mp3","charTypeName":"word"},{"id":1231,"position":7,"arabic":"مُّحْدَثٍ","translation":"নতুন","audioUrl":"wbw/021_002_007.mp3","charTypeName":"word"},{"id":1232,"position":8,"arabic":"إِلَّا","translation":"এ ছাড়া যে","audioUrl":"wbw/021_002_008.mp3","charTypeName":"word"},{"id":1233,"position":9,"arabic":"ٱسْتَمَعُوهُ","translation":"তা তারা শুনে","audioUrl":"wbw/021_002_009.mp3","charTypeName":"word"},{"id":1234,"position":10,"arabic":"وَهُمْ","translation":"এমতাবস্হায় যে তারা","audioUrl":"wbw/021_002_010.mp3","charTypeName":"word"},{"id":1235,"position":11,"arabic":"يَلْعَبُونَ","translation":"খেলায় মেতে থাকে","audioUrl":"wbw/021_002_011.mp3","charTypeName":"word"},{"id":1236,"position":12,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"لَاهِيَةًۭ قُلُوبُهُمْ ۗ وَأَسَرُّوا۟ ٱلنَّجْوَى ٱلَّذِينَ ظَلَمُوا۟ هَلْ هَٰذَآ إِلَّا بَشَرٌۭ مِّثْلُكُمْ ۖ أَفَتَأْتُونَ ٱلسِّحْرَ وَأَنتُمْ تُبْصِرُونَ","translation":"their hearts set on passing ­delights; yet they who are [thus] bent on wrongdoing conceal their innermost thoughts [when they say to one another], “Is this [Muhammad] anything but a mortal like yourselves? Will you, then, yield to [his] spellbinding eloquence with your eyes open?”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2486.mp3","surahId":21,"words":[{"id":2260,"position":1,"arabic":"لَاهِيَةًۭ","translation":"অমনোযোগী থাকে","audioUrl":"wbw/021_003_001.mp3","charTypeName":"word"},{"id":2261,"position":2,"arabic":"قُلُوبُهُمْ ۗ","translation":"তাদের অন্তরগুলো","audioUrl":"wbw/021_003_002.mp3","charTypeName":"word"},{"id":2263,"position":3,"arabic":"وَأَسَرُّوا۟","translation":"এবং তারা গোপনে করে","audioUrl":"wbw/021_003_004.mp3","charTypeName":"word"},{"id":2264,"position":4,"arabic":"ٱلنَّجْوَى","translation":"পরামর্শ","audioUrl":"wbw/021_003_005.mp3","charTypeName":"word"},{"id":2265,"position":5,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/021_003_006.mp3","charTypeName":"word"},{"id":2266,"position":6,"arabic":"ظَلَمُوا۟","translation":"সীমালঙ্ঘন করেছে","audioUrl":"wbw/021_003_007.mp3","charTypeName":"word"},{"id":2267,"position":7,"arabic":"هَلْ","translation":"\"(তারা বলে) নয় কি","audioUrl":"wbw/021_003_008.mp3","charTypeName":"word"},{"id":2268,"position":8,"arabic":"هَـٰذَآ","translation":"এই (ব্যক্তি)","audioUrl":"wbw/021_003_009.mp3","charTypeName":"word"},{"id":2269,"position":9,"arabic":"إِلَّا","translation":"এছাড়া","audioUrl":"wbw/021_003_010.mp3","charTypeName":"word"},{"id":2270,"position":10,"arabic":"بَشَرٌۭ","translation":"একজন মানুষ","audioUrl":"wbw/021_003_011.mp3","charTypeName":"word"},{"id":2271,"position":11,"arabic":"مِّثْلُكُمْ ۖ","translation":"তোমাদেরই মতো","audioUrl":"wbw/021_003_012.mp3","charTypeName":"word"},{"id":2273,"position":12,"arabic":"أَفَتَأْتُونَ","translation":"তবে কি তোমরা এসে পড়বে","audioUrl":"wbw/021_003_014.mp3","charTypeName":"word"},{"id":2274,"position":13,"arabic":"ٱلسِّحْرَ","translation":"জাদুর (খপ্পরে)","audioUrl":"wbw/021_003_015.mp3","charTypeName":"word"},{"id":2275,"position":14,"arabic":"وَأَنتُمْ","translation":"অথচ তোমরা","audioUrl":"wbw/021_003_016.mp3","charTypeName":"word"},{"id":2276,"position":15,"arabic":"تُبْصِرُونَ","translation":"দেখছো\"","audioUrl":"wbw/021_003_017.mp3","charTypeName":"word"},{"id":2277,"position":16,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"قَالَ رَبِّى يَعْلَمُ ٱلْقَوْلَ فِى ٱلسَّمَآءِ وَٱلْأَرْضِ ۖ وَهُوَ ٱلسَّمِيعُ ٱلْعَلِيمُ","translation":"Say: “My Sustainer knows whatever is spoken in heaven and on earth; and He alone is all-hearing, all-knowing.”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2487.mp3","surahId":21,"words":[{"id":3587,"position":1,"arabic":"قَالَ","translation":"(নাবী) বললো","audioUrl":"wbw/021_004_001.mp3","charTypeName":"word"},{"id":3588,"position":2,"arabic":"رَبِّى","translation":"\"আমার রব","audioUrl":"wbw/021_004_002.mp3","charTypeName":"word"},{"id":3589,"position":3,"arabic":"يَعْلَمُ","translation":"জানেন","audioUrl":"wbw/021_004_003.mp3","charTypeName":"word"},{"id":3590,"position":4,"arabic":"ٱلْقَوْلَ","translation":"(সেই সব) কথা","audioUrl":"wbw/021_004_004.mp3","charTypeName":"word"},{"id":3591,"position":5,"arabic":"فِى","translation":"(যা হয়) মধ্যে","audioUrl":"wbw/021_004_005.mp3","charTypeName":"word"},{"id":3592,"position":6,"arabic":"ٱلسَّمَآءِ","translation":"আকাশমন্ডলীর","audioUrl":"wbw/021_004_006.mp3","charTypeName":"word"},{"id":3593,"position":7,"arabic":"وَٱلْأَرْضِ ۖ","translation":"ও পৃথিবীর","audioUrl":"wbw/021_004_007.mp3","charTypeName":"word"},{"id":3595,"position":8,"arabic":"وَهُوَ","translation":"এবং তিনিই","audioUrl":"wbw/021_004_009.mp3","charTypeName":"word"},{"id":3596,"position":9,"arabic":"ٱلسَّمِيعُ","translation":"সবকিছু শুনেন","audioUrl":"wbw/021_004_010.mp3","charTypeName":"word"},{"id":3597,"position":10,"arabic":"ٱلْعَلِيمُ","translation":"সবকিছু জানেন\"","audioUrl":"wbw/021_004_011.mp3","charTypeName":"word"},{"id":3598,"position":11,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"بَلْ قَالُوٓا۟ أَضْغَٰثُ أَحْلَٰمٍۭ بَلِ ٱفْتَرَىٰهُ بَلْ هُوَ شَاعِرٌۭ فَلْيَأْتِنَا بِـَٔايَةٍۢ كَمَآ أُرْسِلَ ٱلْأَوَّلُونَ","translation":"“Nay,” they say, “[Muhammad propounds] the most involved and confusing of dreams!” “Nay, but he has invented [all] this!” - “Nay, but he is [only] a poet!” - [and,] “Let him, then, come unto us with a miracle, just as those [prophets] of old were sent [with miracles]?”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2488.mp3","surahId":21,"words":[{"id":4930,"position":1,"arabic":"بَلْ","translation":"বরং","audioUrl":"wbw/021_005_001.mp3","charTypeName":"word"},{"id":4931,"position":2,"arabic":"قَالُوٓا۟","translation":"তারা বলে","audioUrl":"wbw/021_005_002.mp3","charTypeName":"word"},{"id":4932,"position":3,"arabic":"أَضْغَـٰثُ","translation":"\"(এসব) অলীক","audioUrl":"wbw/021_005_003.mp3","charTypeName":"word"},{"id":4933,"position":4,"arabic":"أَحْلَـٰمٍۭ","translation":"স্বপ্নসমূহ","audioUrl":"wbw/021_005_004.mp3","charTypeName":"word"},{"id":4934,"position":5,"arabic":"بَلِ","translation":"বরং","audioUrl":"wbw/021_005_005.mp3","charTypeName":"word"},{"id":4935,"position":6,"arabic":"ٱفْتَرَىٰهُ","translation":"তা সে উদ্ভাবন করেছে","audioUrl":"wbw/021_005_006.mp3","charTypeName":"word"},{"id":4936,"position":7,"arabic":"بَلْ","translation":"বরং","audioUrl":"wbw/021_005_007.mp3","charTypeName":"word"},{"id":4937,"position":8,"arabic":"هُوَ","translation":"সে","audioUrl":"wbw/021_005_008.mp3","charTypeName":"word"},{"id":4938,"position":9,"arabic":"شَاعِرٌۭ","translation":"একজন কবি","audioUrl":"wbw/021_005_009.mp3","charTypeName":"word"},{"id":4939,"position":10,"arabic":"فَلْيَأْتِنَا","translation":"তাহ'লে আসুক আমাদের কাছে","audioUrl":"wbw/021_005_010.mp3","charTypeName":"word"},{"id":4940,"position":11,"arabic":"بِـَٔايَةٍۢ","translation":"কোন নিদর্শন","audioUrl":"wbw/021_005_011.mp3","charTypeName":"word"},{"id":4941,"position":12,"arabic":"كَمَآ","translation":"যেমন","audioUrl":"wbw/021_005_012.mp3","charTypeName":"word"},{"id":4942,"position":13,"arabic":"أُرْسِلَ","translation":"পাঠানো হয়েছিলো","audioUrl":"wbw/021_005_013.mp3","charTypeName":"word"},{"id":4943,"position":14,"arabic":"ٱلْأَوَّلُونَ","translation":"পূর্ববর্তীগণকে (নিদর্শনসহ)\"","audioUrl":"wbw/021_005_014.mp3","charTypeName":"word"},{"id":4944,"position":15,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"مَآ ءَامَنَتْ قَبْلَهُم مِّن قَرْيَةٍ أَهْلَكْنَٰهَآ ۖ أَفَهُمْ يُؤْمِنُونَ","translation":"Not one of the communities that We destroyed in bygone times would ever believe [their prophets]: will these, then, [be more willing to] believe?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2489.mp3","surahId":21,"words":[{"id":6185,"position":1,"arabic":"مَآ","translation":"নি","audioUrl":"wbw/021_006_001.mp3","charTypeName":"word"},{"id":6186,"position":2,"arabic":"ءَامَنَتْ","translation":"ঈমান আনে","audioUrl":"wbw/021_006_002.mp3","charTypeName":"word"},{"id":6187,"position":3,"arabic":"قَبْلَهُم","translation":"তাদের পূর্বে","audioUrl":"wbw/021_006_003.mp3","charTypeName":"word"},{"id":6188,"position":4,"arabic":"مِّن","translation":"কোন","audioUrl":"wbw/021_006_004.mp3","charTypeName":"word"},{"id":6189,"position":5,"arabic":"قَرْيَةٍ","translation":"জনবসতিই","audioUrl":"wbw/021_006_005.mp3","charTypeName":"word"},{"id":6190,"position":6,"arabic":"أَهْلَكْنَـٰهَآ ۖ","translation":"যাকে আমরা ধ্বংস করেছি","audioUrl":"wbw/021_006_006.mp3","charTypeName":"word"},{"id":6192,"position":7,"arabic":"أَفَهُمْ","translation":"তবে কি এরা","audioUrl":"wbw/021_006_008.mp3","charTypeName":"word"},{"id":6193,"position":8,"arabic":"يُؤْمِنُونَ","translation":"ঈমান আনবে (এখন)","audioUrl":"wbw/021_006_009.mp3","charTypeName":"word"},{"id":6194,"position":9,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"وَمَآ أَرْسَلْنَا قَبْلَكَ إِلَّا رِجَالًۭا نُّوحِىٓ إِلَيْهِمْ ۖ فَسْـَٔلُوٓا۟ أَهْلَ ٱلذِّكْرِ إِن كُنتُمْ لَا تَعْلَمُونَ","translation":"For [even] before thy time, [O Muhammad,] We never sent [as Our apostles] any but [mortal] men, whom We inspired - hence, [tell the deniers of the truth,] “If you do not know this, ask the followers of earlier revelation”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2490.mp3","surahId":21,"words":[{"id":7555,"position":1,"arabic":"وَمَآ","translation":"এবং না (হে নবী)","audioUrl":