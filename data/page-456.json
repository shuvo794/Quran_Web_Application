{"id":456,"ayahs":[{"number":43,"arabic":"وَوَهَبْنَا لَهُۥٓ أَهْلَهُۥ وَمِثْلَهُم مَّعَهُمْ رَحْمَةًۭ مِّنَّا وَذِكْرَىٰ لِأُو۟لِى ٱلْأَلْبَٰبِ","translation":"And We bestowed upon him new offspring, doubling their number as an act of grace from Us, and as a reminder unto all who are endowed with insight.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4013.mp3","surahId":38,"words":[{"id":44116,"position":1,"arabic":"وَوَهَبْنَا","translation":"এবং আমরা (ফিরিয়ে) দিলাম","audioUrl":"wbw/038_043_001.mp3","charTypeName":"word"},{"id":44117,"position":2,"arabic":"لَهُۥٓ","translation":"তার কাছে","audioUrl":"wbw/038_043_002.mp3","charTypeName":"word"},{"id":44118,"position":3,"arabic":"أَهْلَهُۥ","translation":"তার পরিবারকে","audioUrl":"wbw/038_043_003.mp3","charTypeName":"word"},{"id":44119,"position":4,"arabic":"وَمِثْلَهُم","translation":"আরও তাদের মতো","audioUrl":"wbw/038_043_004.mp3","charTypeName":"word"},{"id":44120,"position":5,"arabic":"مَّعَهُمْ","translation":"তাদের সাথে","audioUrl":"wbw/038_043_005.mp3","charTypeName":"word"},{"id":44121,"position":6,"arabic":"رَحْمَةًۭ","translation":"অনুগ্রহ স্বরূপ","audioUrl":"wbw/038_043_006.mp3","charTypeName":"word"},{"id":44122,"position":7,"arabic":"مِّنَّا","translation":"আমাদের থেকে","audioUrl":"wbw/038_043_007.mp3","charTypeName":"word"},{"id":44123,"position":8,"arabic":"وَذِكْرَىٰ","translation":"এবং শিক্ষা","audioUrl":"wbw/038_043_008.mp3","charTypeName":"word"},{"id":44124,"position":9,"arabic":"لِأُو۟لِى","translation":"সম্পন্নদের জন্যে","audioUrl":"wbw/038_043_009.mp3","charTypeName":"word"},{"id":44125,"position":10,"arabic":"ٱلْأَلْبَـٰبِ","translation":"বিবেক-বুদ্ধি","audioUrl":"wbw/038_043_010.mp3","charTypeName":"word"},{"id":44126,"position":11,"arabic":"٤٣","translation":"(৪৩)","audioUrl":null,"charTypeName":"end"}]},{"number":44,"arabic":"وَخُذْ بِيَدِكَ ضِغْثًۭا فَٱضْرِب بِّهِۦ وَلَا تَحْنَثْ ۗ إِنَّا وَجَدْنَٰهُ صَابِرًۭا ۚ نِّعْمَ ٱلْعَبْدُ ۖ إِنَّهُۥٓ أَوَّابٌۭ","translation":"[And finally We told him:] “Now take in thy hand a small bunch of grass, and strike therewith, and thou wilt not break thine oath!” for, verily, We found him full of patience in adversity: how excellent a servant [of Ours], who, behold, would always turn unto Us!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4014.mp3","surahId":38,"words":[{"id":44295,"position":1,"arabic":"وَخُذْ","translation":"\"এবং (তাকে বললাম) ধরো","audioUrl":"wbw/038_044_001.mp3","charTypeName":"word"},{"id":44296,"position":2,"arabic":"بِيَدِكَ","translation":"তোমার হাত দিয়ে","audioUrl":"wbw/038_044_002.mp3","charTypeName":"word"},{"id":44297,"position":3,"arabic":"ضِغْثًۭا","translation":"একমুঠো ঘাস","audioUrl":"wbw/038_044_003.mp3","charTypeName":"word"},{"id":44298,"position":4,"arabic":"فَٱضْرِب","translation":"অতঃপর আঘাত করো","audioUrl":"wbw/038_044_004.mp3","charTypeName":"word"},{"id":44299,"position":5,"arabic":"بِّهِۦ","translation":"তা দিয়ে (তোমার স্ত্রীকে)","audioUrl":"wbw/038_044_005.mp3","charTypeName":"word"},{"id":44300,"position":6,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/038_044_006.mp3","charTypeName":"word"},{"id":44301,"position":7,"arabic":"تَحْنَثْ ۗ","translation":"তুমি শপথ ভঙ্গ করো\"","audioUrl":"wbw/038_044_007.mp3","charTypeName":"word"},{"id":44303,"position":8,"arabic":"إِنَّا","translation":"নিশ্চযই় আমরা","audioUrl":"wbw/038_044_009.mp3","charTypeName":"word"},{"id":44304,"position":9,"arabic":"وَجَدْنَـٰهُ","translation":"তাকে আমরা পেয়েছি","audioUrl":"wbw/038_044_010.mp3","charTypeName":"word"},{"id":44305,"position":10,"arabic":"صَابِرًۭا ۚ","translation":"ধৈর্য্যশীল","audioUrl":"wbw/038_044_011.mp3","charTypeName":"word"},{"id":44307,"position":11,"arabic":"نِّعْمَ","translation":"অতি উত্তম","audioUrl":"wbw/038_044_013.mp3","charTypeName":"word"},{"id":44308,"position":12,"arabic":"ٱلْعَبْدُ ۖ","translation":"দাস","audioUrl":"wbw/038_044_014.mp3","charTypeName":"word"},{"id":44310,"position":13,"arabic":"إِنَّهُۥٓ","translation":"সে নিশ্চয়ই  ছিলো","audioUrl":"wbw/038_044_016.mp3","charTypeName":"word"},{"id":44311,"position":14,"arabic":"أَوَّابٌۭ","translation":"বড় (আল্লাহ) অভিমুখী","audioUrl":"wbw/038_044_017.mp3","charTypeName":"word"},{"id":44312,"position":15,"arabic":"٤٤","translation":"(৪৪)","audioUrl":null,"charTypeName":"end"}]},{"number":45,"arabic":"وَٱذْكُرْ عِبَٰدَنَآ إِبْرَٰهِيمَ وَإِسْحَٰقَ وَيَعْقُوبَ أُو۟لِى ٱلْأَيْدِى وَٱلْأَبْصَٰرِ","translation":"AND CALL to mind Our servants Abraham and Isaac and Jacob, [all of them] endowed with inner strength and vision:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4015.mp3","surahId":38,"words":[{"id":45597,"position":1,"arabic":"وَٱذْكُرْ","translation":"এবং স্মরণ করো","audioUrl":"wbw/038_045_001.mp3","charTypeName":"word"},{"id":45598,"position":2,"arabic":"عِبَـٰدَنَآ","translation":"আমাদের দাসদেরকে","audioUrl":"wbw/038_045_002.mp3","charTypeName":"word"},{"id":45599,"position":3,"arabic":"إِبْرَٰهِيمَ","translation":"(যেমন) ইবরাহীম","audioUrl":"wbw/038_045_003.mp3","charTypeName":"word"},{"id":45600,"position":4,"arabic":"وَإِسْحَـٰقَ","translation":"ও ইসহাক","audioUrl":"wbw/038_045_004.mp3","charTypeName":"word"},{"id":45601,"position":5,"arabic":"وَيَعْقُوبَ","translation":"ও ইয়াকূব","audioUrl":"wbw/038_045_005.mp3","charTypeName":"word"},{"id":45602,"position":6,"arabic":"أُو۟لِى","translation":"সম্পন্ন","audioUrl":"wbw/038_045_006.mp3","charTypeName":"word"},{"id":45603,"position":7,"arabic":"ٱلْأَيْدِى","translation":"কর্মক্ষমতা","audioUrl":"wbw/038_045_007.mp3","charTypeName":"word"},{"id":45604,"position":8,"arabic":"وَٱلْأَبْصَـٰرِ","translation":"ও সূক্ষ্মদৃষ্টি (সম্পন্ন)","audioUrl":"wbw/038_045_008.mp3","charTypeName":"word"},{"id":45605,"position":9,"arabic":"٤٥","translation":"(৪৫)","audioUrl":null,"charTypeName":"end"}]},{"number":46,"arabic":"إِنَّآ أَخْلَصْنَٰهُم بِخَالِصَةٍۢ ذِكْرَى ٱلدَّارِ","translation":"for, verily, We purified them by means of a thought most pure: the remembrance of the life to come.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4016.mp3","surahId":38,"words":[{"id":46282,"position":1,"arabic":"إِنَّآ","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/038_046_001.mp3","charTypeName":"word"},{"id":46283,"position":2,"arabic":"أَخْلَصْنَـٰهُم","translation":"তাদেরকে আমরা  মর্যাদা দিয়েছিলাম","audioUrl":"wbw/038_046_002.mp3","charTypeName":"word"},{"id":46284,"position":3,"arabic":"بِخَالِصَةٍۢ","translation":"একটি স্বতন্ত্রগুণের কারণে","audioUrl":"wbw/038_046_003.mp3","charTypeName":"word"},{"id":46285,"position":4,"arabic":"ذِكْرَى","translation":"(তা ছিলো) স্মরণ","audioUrl":"wbw/038_046_004.mp3","charTypeName":"word"},{"id":46286,"position":5,"arabic":"ٱلدَّارِ","translation":"পরকালের","audioUrl":"wbw/038_046_005.mp3","charTypeName":"word"},{"id":46287,"position":6,"arabic":"٤٦","translation":"(৪৬)","audioUrl":null,"charTypeName":"end"}]},{"number":47,"arabic":"وَإِنَّهُمْ عِندَنَا لَمِنَ ٱلْمُصْطَفَيْنَ ٱلْأَخْيَارِ","translation":"And, behold, in Our sight they were indeed among the elect, the truly good!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4017.mp3","surahId":38,"words":[{"id":46995,"position":1,"arabic":"وَإِنَّهُمْ","translation":"এবং তারা নিশ্চয়ই","audioUrl":"wbw/038_047_001.mp3","charTypeName":"word"},{"id":46996,"position":2,"arabic":"عِندَنَا","translation":"আমাদের কাছে","audioUrl":"wbw/038_047_002.mp3","charTypeName":"word"},{"id":46997,"position":3,"arabic":"لَمِنَ","translation":"অবশ্যই অন্তর্ভুক্ত","audioUrl":"wbw/038_047_003.mp3","charTypeName":"word"},{"id":46998,"position":4,"arabic":"ٱلْمُصْطَفَيْنَ","translation":"মনোনীত  (বান্দাদের)","audioUrl":"wbw/038_047_004.mp3","charTypeName":"word"},{"id":46999,"position":5,"arabic":"ٱلْأَخْيَارِ","translation":"উত্তম (বান্দাদের)","audioUrl":"wbw/038_047_005.mp3","charTypeName":"word"},{"id":47000,"position":6,"arabic":"٤٧","translation":"(৪৭)","audioUrl":null,"charTypeName":"end"}]},{"number":48,"arabic":"وَٱذْكُرْ إِ