/cdn.islamic.network/quran/audio/128/ar.alafasy/4023.mp3","surahId":38,"words":[{"id":50922,"position":1,"arabic":"هَـٰذَا","translation":"এই (সব নিয়ামাত)","audioUrl":"wbw/038_053_001.mp3","charTypeName":"word"},{"id":50923,"position":2,"arabic":"مَا","translation":"যা","audioUrl":"wbw/038_053_002.mp3","charTypeName":"word"},{"id":50924,"position":3,"arabic":"تُوعَدُونَ","translation":"তোমাদের প্রতিশ্রুতি দেওয়া হচ্ছে","audioUrl":"wbw/038_053_003.mp3","charTypeName":"word"},{"id":50925,"position":4,"arabic":"لِيَوْمِ","translation":"দিনের জন্যে","audioUrl":"wbw/038_053_004.mp3","charTypeName":"word"},{"id":50926,"position":5,"arabic":"ٱلْحِسَابِ","translation":"বিচারের","audioUrl":"wbw/038_053_005.mp3","charTypeName":"word"},{"id":50927,"position":6,"arabic":"٥٣","translation":"(৫৩)","audioUrl":null,"charTypeName":"end"}]},{"number":54,"arabic":"إِنَّ هَٰذَا لَرِزْقُنَا مَا لَهُۥ مِن نَّفَادٍ","translation":"this, verily, shall be Our provision [for you], with no end to it!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4024.mp3","surahId":38,"words":[{"id":51539,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/038_054_001.mp3","charTypeName":"word"},{"id":51540,"position":2,"arabic":"هَـٰذَا","translation":"এটা","audioUrl":"wbw/038_054_002.mp3","charTypeName":"word"},{"id":51541,"position":3,"arabic":"لَرِزْقُنَا","translation":"অবশ্যই আমাদের জীবিকা","audioUrl":"wbw/038_054_003.mp3","charTypeName":"word"},{"id":51542,"position":4,"arabic":"مَا","translation":"নেই","audioUrl":"wbw/038_054_004.mp3","charTypeName":"word"},{"id":51543,"position":5,"arabic":"لَهُۥ","translation":"তার","audioUrl":"wbw/038_054_005.mp3","charTypeName":"word"},{"id":51544,"position":6,"arabic":"مِن","translation":"কোনো","audioUrl":"wbw/038_054_006.mp3","charTypeName":"word"},{"id":51545,"position":7,"arabic":"نَّفَادٍ","translation":"শেষ","audioUrl":"wbw/038_054_007.mp3","charTypeName":"word"},{"id":51546,"position":8,"arabic":"٥٤","translation":"(৫৪)","audioUrl":null,"charTypeName":"end"}]},{"number":55,"arabic":"هَٰذَا ۚ وَإِنَّ لِلطَّٰغِينَ لَشَرَّ مَـَٔابٍۢ","translation":"All this [for the righteous]: but, verily, the most evil of all goals awaits those who are wont to transgress the bounds of what is right:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4025.mp3","surahId":38,"words":[{"id":52037,"position":1,"arabic":"هَـٰذَا ۚ","translation":"এটাই (মুত্তাকীদের পরিণাম)","audioUrl":"wbw/038_055_001.mp3","charTypeName":"word"},{"id":52039,"position":2,"arabic":"وَإِنَّ","translation":"আর নিশ্চয়ই (রয়েছে)","audioUrl":"wbw/038_055_003.mp3","charTypeName":"word"},{"id":52040,"position":3,"arabic":"لِلطَّـٰغِينَ","translation":"সীমালংঘনকারীদের জন্যে","audioUrl":"wbw/038_055_004.mp3","charTypeName":"word"},{"id":52041,"position":4,"arabic":"لَشَرَّ","translation":"অবশ্যই নিকৃষ্ট","audioUrl":"wbw/038_055_005.mp3","charTypeName":"word"},{"id":52042,"position":5,"arabic":"مَـَٔابٍۢ","translation":"প্রত্যাবর্তন স্থান","audioUrl":"wbw/038_055_006.mp3","charTypeName":"word"},{"id":52043,"position":6,"arabic":"٥٥","translation":"(৫৫)","audioUrl":null,"charTypeName":"end"}]},{"number":56,"arabic":"جَهَنَّمَ يَصْلَوْنَهَا فَبِئْسَ ٱلْمِهَادُ","translation":"hell will they have to endure - and how vile a resting-place!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4026.mp3","surahId":38,"words":[{"id":52127,"position":1,"arabic":"جَهَنَّمَ","translation":"জাহান্নাম","audioUrl":"wbw/038_056_001.mp3","charTypeName":"word"},{"id":52128,"position":2,"arabic":"يَصْلَوْنَهَا","translation":"তাতে তারা প্রবেশ জ্বলবে","audioUrl":"wbw/038_056_002.mp3","charTypeName":"word"},{"id":52129,"position":3,"arabic":"فَبِئْسَ","translation":"আর কত নিকৃষ্ট","audioUrl":"wbw/038_056_003.mp3","charTypeName":"word"},{"id":52130,"position":4,"arabic":"ٱلْمِهَادُ","translation":"ঠিকানা","audioUrl":"wbw/038_056_004.mp3","charTypeName":"word"},{"id":52131,"position":5,"arabic":"٥٦","translation":"(৫৬)","audioUrl":null,"charTypeName":"end"}]},{"number":57,"arabic":"هَٰذَا فَلْيَذُوقُوهُ حَمِيمٌۭ وَغَسَّاقٌۭ","translation":"This, [then, for them -] so let them taste it: burning despair and ice-cold darkness","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4027.mp3","surahId":38,"words":[{"id":53055,"position":1,"arabic":"هَـٰذَا","translation":"এটাই (তাদের পরিণাম)","audioUrl":"wbw/038_057_001.mp3","charTypeName":"word"},{"id":53056,"position":2,"arabic":"فَلْيَذُوقُوهُ","translation":"সুতরাং  তার তারা স্বাদ নিক","audioUrl":"wbw/038_057_002.mp3","charTypeName":"word"},{"id":53057,"position":3,"arabic":"حَمِيمٌۭ","translation":"ফুটন্ত পানির","audioUrl":"wbw/038_057_003.mp3","charTypeName":"word"},{"id":53058,"position":4,"arabic":"وَغَسَّاقٌۭ","translation":"ও পূঁজের","audioUrl":"wbw/038_057_004.mp3","charTypeName":"word"},{"id":53059,"position":5,"arabic":"٥٧","translation":"(৫৭)","audioUrl":null,"charTypeName":"end"}]},{"number":58,"arabic":"وَءَاخَرُ مِن شَكْلِهِۦٓ أَزْوَٰجٌ","translation":"and, coupled with it, further [suffering] of a similar nature.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4028.mp3","surahId":38,"words":[{"id":53619,"position":1,"arabic":"وَءَاخَرُ","translation":"এবং অন্য কিছু","audioUrl":"wbw/038_058_001.mp3","charTypeName":"word"},{"id":53620,"position":2,"arabic":"مِن","translation":"মধ্যে","audioUrl":"wbw/038_058_002.mp3","charTypeName":"word"},{"id":53621,"position":3,"arabic":"شَكْلِهِۦٓ","translation":"সে ধরণের","audioUrl":"wbw/038_058_003.mp3","charTypeName":"word"},{"id":53622,"position":4,"arabic":"أَزْوَٰجٌ","translation":"বিভিন্ন প্রকার (কষ্টের)","audioUrl":"wbw/038_058_004.mp3","charTypeName":"word"},{"id":53623,"position":5,"arabic":"٥٨","translation":"(৫৮)","audioUrl":null,"charTypeName":"end"}]},{"number":59,"arabic":"هَٰذَا فَوْجٌۭ مُّقْتَحِمٌۭ مَّعَكُمْ ۖ لَا مَرْحَبًۢا بِهِمْ ۚ إِنَّهُمْ صَالُوا۟ ٱلنَّارِ","translation":"[And they will say to one another: “Do you see] this crowd of people who rushed headlong [into sin] with you? No welcome to them! Verily, they [too] shall have to endure the fire!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4029.mp3","surahId":38,"words":[{"id":54159,"position":1,"arabic":"هَـٰذَا","translation":"(তারা বলবে) এই তো","audioUrl":"wbw/038_059_001.mp3","charTypeName":"word"},{"id":54160,"position":2,"arabic":"فَوْجٌۭ","translation":"একটি দল","audioUrl":"wbw/038_059_002.mp3","charTypeName":"word"},{"id":54161,"position":3,"arabic":"مُّقْتَحِمٌۭ","translation":"প্রবেশকারী","audioUrl":"wbw/038_059_003.mp3","charTypeName":"word"},{"id":54162,"position":4,"arabic":"مَّعَكُمْ ۖ","translation":"তোমাদের সাথে","audioUrl":"wbw/038_059_004.mp3","charTypeName":"word"},{"id":54164,"position":5,"arabic":"لَا","translation":"নেই","audioUrl":"wbw/038_059_006.mp3","charTypeName":"word"},{"id":54165,"position":6,"arabic":"مَرْحَبًۢا","translation":"কোনো অভিনন্দন","audioUrl":"wbw/038_059_007.mp3","charTypeName":"word"},{"id":54166,"position":7,"arabic":"بِهِمْ ۚ","translation":"তাদের জন্যে","audioUrl":"wbw/038_059_008.mp3","charTypeName":"word"},{"id":54168,"position":8,"arabic":"إِنَّهُمْ","translation":"তারা নিশ্চয়ই","audioUrl":"wbw/038_059_010.mp3","charTypeName":"word"},{"id":54169,"position":9,"arabic":"صَالُوا۟","translation":"জ্বলবে","audioUrl":"wbw/038_059_011.mp3","charTypeName":"word"},{"id":54170,"position":10,"arabic":"ٱلنَّارِ","translation":"(জাহান্নামের) আগুনে","audioUrl":"wbw/038_059_012.mp3","charTypeName":"word"},{"id":54171,"position":11,"arabic":"٥٩","translation":"(৫৯)","audioUrl":null,"charTypeName":"end"}]},{"number":60,"arabic":"قَالُوا۟ بَلْ أَنتُمْ لَا مَرْحَبًۢا بِكُمْ ۖ أَنتُمْ قَدَّمْتُمُوهُ لَنَا ۖ فَبِئْسَ ٱلْقَرَارُ","translation":"[And] they [who had been seduced] will exclaim: “Nay, but it is you! No welcome to you! It is you who have prepared this for us: and how vile a state to abide in!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4030.mp3","surahId":38,"words":[{"id":54172,"position":1,"arabic":"قَالُوا۟","translation":"(অনুসারীরা) বলবে","audioUrl":"wbw/038_060_001.mp3","charTypeName":"word"},{"id":54173,"position":2,"arabic":"بَلْ","translation":"\"বরং","audioUrl":"wbw/038_060_002.mp3","charTypeName":"word"},{"id":54174,"position":3,"arabic":"أَنتُمْ","translation":"তোমরাও (তাতে জ্বলছো)","audioUrl":"wbw/038_060_003.mp3","charTypeName":"word"},{"id":54175,"position":4,"arabic":"لَا","translation":"নেই","audioUrl":"wbw/038_060_004.mp3","charTypeName":"word"},{"id":54176,"position":5,"arabic":"مَرْحَبًۢا","translation":"কোনো অভিনন্দন","audioUrl":"wbw/038_060_005.mp3","charTypeName":"word"},{"id":54177,"position":6,"arabic":"بِكُمْ ۖ","translation":"তোমাদের জন্যও","audioUrl":"wbw/038_060_006.mp3","charTypeName":"word"},{"id":54179,"position":7,"arabic":"أَنتُمْ","translation":"তোমরাই","audioUrl":"wbw/038_060_008.mp3","charTypeName":"word"},{"id":54180,"position":8,"arabic":"قَدَّمْتُمُوهُ","translation":"তা তোমরাই সামনে এনেছো","audioUrl":"wbw/038_060_009.mp3","charTypeName":"word"},{"id":54181,"position":9,"arabic":"لَنَا ۖ","translation":"আমাদের জন্যে","audioUrl":"wbw/038_060_010.mp3","charTypeName":"word"},{"id":54183,"position":10,"arabic":"فَبِئْسَ","translation":"অতএব কত নিকৃষ্ট","audioUrl":"wbw/038_060_012.mp3","charTypeName":"word"},{"id":54184,"position":11,"arabic":"ٱلْقَرَارُ","translation":"আবাসস্থল\"","audioUrl":"wbw/038_060_013.mp3","charTypeName":"word"},{"id":54185,"position":12,"arabic":"٦٠","translation":"(৬০)","audioUrl":null,"charTypeName":"end"}]},{"number":61,"arabic":"قَالُوا۟ رَبَّنَا مَن قَدَّمَ لَنَا هَٰذَا فَزِدْهُ عَذَابًۭا ضِعْفًۭا فِى ٱلنَّارِ","translation":"[And] they will pray: “O our Sustainer! Who­ever has prepared this for us, double Thou his suffering in the fire!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4031.mp3","surahId":38,"words":[{"id":55398,"position":1,"arabic":"قَالُوا۟","translation":"তারা বলবে","audioUrl":"wbw/038_061_001.mp3","charTypeName":"word"},{"id":55399,"position":2,"arabic":"رَبَّنَا","translation":"\"হে আমাদের রব","audioUrl":"wbw/038_061_002.mp3","charTypeName":"word"},{"id":55400,"position":3,"arabic":"مَن","translation":"যে","audioUrl":"wbw/038_061_003.mp3","charTypeName":"word"},{"id":55401,"position":4,"arabic":"قَدَّمَ","translation":"সম্মুখীন করেছে","audioUrl":"wbw/038_061_004.mp3","charTypeName":"word"},{"id":55402,"position":5,"arabic":"لَنَا","translation":"আমাদের জন্যে","audioUrl":"wbw/038_061_005.mp3","charTypeName":"word"},{"id":55403,"position":6,"arabic":"هَـٰذَا","translation":"এটা","audioUrl":"wbw/038_061_006.mp3","charTypeName":"word"},{"id":55404,"position":7,"arabic":"فَزِدْهُ","translation":"তাকে বাড়িয়ে দাও এজন্যে","audioUrl":"wbw/038_061_007.mp3","charTypeName":"word"},{"id":55405,"position":8,"arabic":"عَذَابًۭا","translation":"শাস্তি","audioUrl":"wbw/038_061_008.mp3","charTypeName":"word"},{"id":55406,"position":9,"arabic":"ضِعْفًۭا","translation":"দ্বিগুণ","audioUrl":"wbw/038_061_009.mp3","charTypeName":"word"},{"id":55407,"position":10,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/038_061_010.mp3","charTypeName":"word"},{"id":55408,"position":11,"arabic":"ٱلنَّارِ","translation":"জাহান্নামের\"","audioUrl":"wbw/038_061_011.mp3","charTypeName":"word"},{"id":55409,"position":12,"arabic":"٦١","translation":"(৬১)","audioUrl":null,"charTypeName":"end"}]}]}