038_049_002.mp3","charTypeName":"word"},{"id":48337,"position":3,"arabic":"وَإِنَّ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/038_049_004.mp3","charTypeName":"word"},{"id":48338,"position":4,"arabic":"لِلْمُتَّقِينَ","translation":"মুত্তাকীদের জন্যে (রয়েছে)","audioUrl":"wbw/038_049_005.mp3","charTypeName":"word"},{"id":48339,"position":5,"arabic":"لَحُسْنَ","translation":"অবশ্যই উত্তম","audioUrl":"wbw/038_049_006.mp3","charTypeName":"word"},{"id":48340,"position":6,"arabic":"مَـَٔابٍۢ","translation":"আবাস","audioUrl":"wbw/038_049_007.mp3","charTypeName":"word"},{"id":48341,"position":7,"arabic":"٤٩","translation":"(৪৯)","audioUrl":null,"charTypeName":"end"}]},{"number":50,"arabic":"جَنَّٰتِ عَدْنٍۢ مُّفَتَّحَةًۭ لَّهُمُ ٱلْأَبْوَٰبُ","translation":"gardens of perpetual bliss, with gates wide-open to them,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4020.mp3","surahId":38,"words":[{"id":49006,"position":1,"arabic":"جَنَّـٰتِ","translation":"জান্নাত","audioUrl":"wbw/038_050_001.mp3","charTypeName":"word"},{"id":49007,"position":2,"arabic":"عَدْنٍۢ","translation":"চিরস্থায়ী","audioUrl":"wbw/038_050_002.mp3","charTypeName":"word"},{"id":49008,"position":3,"arabic":"مُّفَتَّحَةًۭ","translation":"খোলা (রয়েছে)","audioUrl":"wbw/038_050_003.mp3","charTypeName":"word"},{"id":49009,"position":4,"arabic":"لَّهُمُ","translation":"তাদের জন্যে","audioUrl":"wbw/038_050_004.mp3","charTypeName":"word"},{"id":49010,"position":5,"arabic":"ٱلْأَبْوَٰبُ","translation":"দরজাসমূহ","audioUrl":"wbw/038_050_005.mp3","charTypeName":"word"},{"id":49011,"position":6,"arabic":"٥٠","translation":"(৫০)","audioUrl":null,"charTypeName":"end"}]},{"number":51,"arabic":"مُتَّكِـِٔينَ فِيهَا يَدْعُونَ فِيهَا بِفَٰكِهَةٍۢ كَثِيرَةٍۢ وَشَرَابٍۢ","translation":"wherein they will recline, [and] wherein they may [freely] call for many a fruit and drink,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4021.mp3","surahId":38,"words":[{"id":49640,"position":1,"arabic":