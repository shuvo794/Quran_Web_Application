"wbw/033_070_007.mp3","charTypeName":"word"},{"id":59730,"position":8,"arabic":"سَدِيدًۭا","translation":"সঠিক","audioUrl":"wbw/033_070_008.mp3","charTypeName":"word"},{"id":59731,"position":9,"arabic":"٧٠","translation":"(৭০)","audioUrl":null,"charTypeName":"end"}]},{"number":71,"arabic":"يُصْلِحْ لَكُمْ أَعْمَٰلَكُمْ وَيَغْفِرْ لَكُمْ ذُنُوبَكُمْ ۗ وَمَن يُطِعِ ٱللَّهَ وَرَسُولَهُۥ فَقَدْ فَازَ فَوْزًا عَظِيمًا","translation":"[whereupon] He will cause your deeds to be virtuous, and will forgive you your sins. And [know that] whoever pays heed unto God and His Apostle has already attained to a mighty triumph.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3604.mp3","surahId":33,"words":[{"id":60227,"position":1,"arabic":"يُصْلِحْ","translation":"তিনি সংশোধন করবেন","audioUrl":"wbw/033_071_001.mp3","charTypeName":"word"},{"id":60228,"position":2,"arabic":"لَكُمْ","translation":"জন্যে তোমাদের","audioUrl":"wbw/033_071_002.mp3","charTypeName":"word"},{"id":60229,"position":3,"arabic":"أَعْمَـٰلَكُمْ","translation":"কর্মসমূহকে তোমাদের","audioUrl":"wbw/033_071_003.mp3","charTypeName":"word"},{"id":60230,"position":4,"arabic":"وَيَغْفِرْ","translation":"এবং ক্ষমা করে দিবেন","audioUrl":"wbw/033_071_004.mp3","charTypeName":"word"},{"id":60231,"position":5,"arabic":"لَكُمْ","translation":"জন্যে তোমাদের","audioUrl":"wbw/033_071_005.mp3","charTypeName":"word"},{"id":60232,"position":6,"arabic":"ذُنُوبَكُمْ ۗ","translation":"পাপগুলোকে তোমাদের","audioUrl":"wbw/033_071_006.mp3","charTypeName":"word"},{"id":60234,"position":7,"arabic":"وَمَن","translation":"এবং যে","audioUrl":"wbw/033_071_008.mp3","charTypeName":"word"},{"id":60235,"position":8,"arabic":"يُطِعِ","translation":"আনুগত্য করে","audioUrl":"wbw/033_071_009.mp3","charTypeName":"word"},{"id":60236,"position":9,"arabic":"ٱللَّهَ","translation":"আল্লাহর","audioUrl":"wbw/033_071_010.mp3","charTypeName":"word"},{"id":60237,"position":10,"arabic":"وَرَسُولَهُۥ","translation":"ও রাসূলের তাঁর","audioUrl":"wbw/0