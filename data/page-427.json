{"id":427,"ayahs":[{"number":63,"arabic":"يَسْـَٔلُكَ ٱلنَّاسُ عَنِ ٱلسَّاعَةِ ۖ قُلْ إِنَّمَا عِلْمُهَا عِندَ ٱللَّهِ ۚ وَمَا يُدْرِيكَ لَعَلَّ ٱلسَّاعَةَ تَكُونُ قَرِيبًا","translation":"PEOPLE will ask thee about the Last Hour. Say: “Knowledge thereof rests with God alone; yet for all thou knowest, the Last Hour may well be near!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3596.mp3","surahId":33,"words":[{"id":56399,"position":1,"arabic":"يَسْـَٔلُكَ","translation":"তোমাকে প্রশ্ন করছে","audioUrl":"wbw/033_063_001.mp3","charTypeName":"word"},{"id":56400,"position":2,"arabic":"ٱلنَّاسُ","translation":"মানুষ","audioUrl":"wbw/033_063_002.mp3","charTypeName":"word"},{"id":56401,"position":3,"arabic":"عَنِ","translation":"সম্পর্কে","audioUrl":"wbw/033_063_003.mp3","charTypeName":"word"},{"id":56402,"position":4,"arabic":"ٱلسَّاعَةِ ۖ","translation":"ক্বিয়ামাত","audioUrl":"wbw/033_063_004.mp3","charTypeName":"word"},{"id":56404,"position":5,"arabic":"قُلْ","translation":"বলো","audioUrl":"wbw/033_063_006.mp3","charTypeName":"word"},{"id":56405,"position":6,"arabic":"إِنَّمَا","translation":"\"কেবল","audioUrl":"wbw/033_063_007.mp3","charTypeName":"word"},{"id":56406,"position":7,"arabic":"عِلْمُهَا","translation":"জ্ঞান তার","audioUrl":"wbw/033_063_008.mp3","charTypeName":"word"},{"id":56407,"position":8,"arabic":"عِندَ","translation":"কাছে","audioUrl":"wbw/033_063_009.mp3","charTypeName":"word"},{"id":56408,"position":9,"arabic":"ٱللَّهِ ۚ","translation":"আল্লাহর","audioUrl":"wbw/033_063_010.mp3","charTypeName":"word"},{"id":56410,"position":10,"arabic":"وَمَا","translation":"এবং কিসে","audioUrl":"wbw/033_063_012.mp3","charTypeName":"word"},{"id":56411,"position":11,"arabic":"يُدْرِيكَ","translation":"তোমাকে জানাবে","audioUrl":"wbw/033_063_013.mp3","charTypeName":"word"},{"id":56412,"position":12,"arabic":"لَعَلَّ","translation":"সম্ভবত","audioUrl":"wbw/033_063_014.mp3","charTypeName":"word"},{"id":56413,"position":13,"arabic":"ٱلسَّاعَةَ","translation":"ক্বিয়ামাত","audioUrl":"wbw/033_063_015.mp3","charTypeName":"word"},{"id":56414,"position":14,"arabic":"تَكُونُ","translation":"হবে","audioUrl":"wbw/033_063_016.mp3","charTypeName":"word"},{"id":56415,"position":15,"arabic":"قَرِيبًا","translation":"নিকটে\"","audioUrl":"wbw/033_063_017.mp3","charTypeName":"word"},{"id":56416,"position":16,"arabic":"٦٣","translation":"(৬৩)","audioUrl":null,"charTypeName":"end"}]},{"number":64,"arabic":"إِنَّ ٱللَّهَ لَعَنَ ٱلْكَٰفِرِينَ وَأَعَدَّ لَهُمْ سَعِيرًا","translation":"Verily, God has rejected the deniers of the truth, and has readied for them a blazing fire,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3597.mp3","surahId":33,"words":[{"id":56903,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/033_064_001.mp3","charTypeName":"word"},{"id":56904,"position":2,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/033_064_002.mp3","charTypeName":"word"},{"id":56905,"position":3,"arabic":"لَعَنَ","translation":"অভিশাপ দেন","audioUrl":"wbw/033_064_003.mp3","charTypeName":"word"},{"id":56906,"position":4,"arabic":"ٱلْكَـٰفِرِينَ","translation":"কাফিরদেরকে","audioUrl":"wbw/033_064_004.mp3","charTypeName":"word"},{"id":56907,"position":5,"arabic":"وَأَعَدَّ","translation":"এবং প্রস্তুত করে রেখেছেন","audioUrl":"wbw/033_064_005.mp3","charTypeName":"word"},{"id":56908,"position":6,"arabic":"لَهُمْ","translation":"জন্যে তাদের","audioUrl":"wbw/033_064_006.mp3","charTypeName":"word"},{"id":56909,"position":7,"arabic":"سَعِيرًا","translation":"জ্বলন্ত আগুন","audioUrl":"wbw/033_064_007.mp3","charTypeName":"word"},{"id":56910,"position":8,"arabic":"٦٤","translation":"(৬৪)","audioUrl":null,"charTypeName":"end"}]},{"number":65,"arabic":"خَٰلِدِينَ فِيهَآ أَبَدًۭا ۖ لَّا يَجِدُونَ وَلِيًّۭا وَلَا نَصِيرًۭا","translation":"therein to abide beyond the count of time: no protec­tor will they find, and none to bring them succour.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3598.mp3","surahId":33,"words":[{"id":57408,"position":1,"arabic":"خَـٰلِدِينَ","translation":"তারা স্থায়ীভাবে থাকবে","audioUrl":"wbw/033_065_001.mp3","charTypeName":"word"},{"id":57409,"position":2,"arabic":"فِيهَآ","translation":"মধ্যে তার","audioUrl":"wbw/033_065_002.mp3","charTypeName":"word"},{"id":57410,"position":3,"arabic":"أَبَدًۭا ۖ","translation":"চিরকাল","audioUrl":"wbw/033_065_003.mp3","charTypeName":"word"},{"id":57412,"position":4,"arabic":"لَّا","translation":"না","audioUrl":"wbw/033_065_005.mp3","charTypeName":"word"},{"id":57413,"position":5,"arabic":"يَجِدُونَ","translation":"তারা পাবে","audioUrl":"wbw/033_065_006.mp3","charTypeName":"word"},{"id":57414,"position":6,"arabic":"وَلِيًّۭا","translation":"কোনো অভিভাবক","audioUrl":"wbw/033_065_007.mp3","charTypeName":"word"},{"id":57415,"position":7,"arabic":"وَلَا","translation":"আর না","audioUrl":"wbw/033_065_008.mp3","charTypeName":"word"},{"id":57416,"position":8,"arabic":"نَصِيرًۭا","translation":"কোনো সাহায্যকারী","audioUrl":"wbw/033_065_009.mp3","charTypeName":"word"},{"id":57417,"position":9,"arabic":"٦٥","translation":"(৬৫)","audioUrl":null,"charTypeName":"end"}]},{"number":66,"arabic":"يَوْمَ تُقَلَّبُ وُجُوهُهُمْ فِى ٱلنَّارِ يَقُولُونَ يَٰلَيْتَنَآ أَطَعْنَا ٱللَّهَ وَأَطَعْنَا ٱلرَّسُولَا۠","translation":"On the Day when their faces shall be tossed about in the fire, they will exclaim, “Oh, would that we had paid heed unto God, and paid heed unto the Apostle!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3599.mp3","surahId":33,"words":[{"id":57872,"position":1,"arabic":"يَوْمَ","translation":"যে দিন","audioUrl":"wbw/033_066_001.mp3","charTypeName":"word"},{"id":57873,"position":2,"arabic":"تُقَلَّبُ","translation":"উলট-পালট করা হবে","audioUrl":"wbw/033_066_002.mp3","charTypeName":"word"},{"id":57874,"position":3,"arabic":"وُجُوهُهُمْ","translation":"মুখমণ্ডল তাদের","audioUrl":"wbw/033_066_003.mp3","charTypeName":"word"},{"id":57875,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/033_066_004.mp3","charTypeName":"word"},{"id":57876,"position":5,"arabic":"ٱلنَّارِ","translation":"আগুনের","audioUrl":"wbw/033_066_005.mp3","charTypeName":"word"},{"id":57877,"position":6,"arabic":"يَقُولُونَ","translation":"তারা বলবে","audioUrl":"wbw/033_066_006.mp3","charTypeName":"word"},{"id":57878,"position":7,"arabic":"يَـٰلَيْتَنَآ","translation":"\"হায়! আমাদের পরিতাপ","audioUrl":"wbw/033_066_007.mp3","charTypeName":"word"},{"id":57879,"position":8,"arabic":"أَطَعْنَا","translation":"আমরা আনুগত্য করতাম (যদি)","audioUrl":"wbw/033_066_008.mp3","charTypeName":"word"},{"id":57880,"position":9,"arabic":"ٱللَّهَ","translation":"আল্লাহর","audioUrl":"wbw/033_066_009.mp3","charTypeName":"word"},{"id":57881,"position":10,"arabic":"وَأَطَعْنَا","translation":"ও আমরা আনুগত্য করতাম (যদি)","audioUrl":"wbw/033_066_010.mp3","charTypeName":"word"},{"id":57882,"position":11,"arabic":"ٱلرَّسُولَا۠","translation":"রাসূলের\"","audioUrl":"wbw/033_066_011.mp3","charTypeName":"word"},{"id":57883,"position":12,"arabic":"٦٦","translation":"(৬৬)","audioUrl":null,"charTypeName":"end"}]},{"number":67,"arabic":"وَقَالُوا۟ رَبَّنَآ إِنَّآ أَطَعْنَا سَادَتَنَا وَكُبَرَآءَنَا فَأَضَلُّونَا ٱلسَّبِيلَا۠","translation":"And they will say: “O our Sustainer! Behold, we paid heed unto our leaders and our great men, and it is they who have led us astray from the right path!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3600.mp3","surahId":33,"words":[{"id":58336,"position":1,"arabic":"وَقَالُوا۟","translation":"এবং তারা বলবে","audioUrl":"wbw/033_067_001.mp3","charTypeName":"word"},{"id":58337,"position":2,"arabic":"رَبَّنَآ","translation":"\"হে আমাদের রব","audioUrl":"wbw/033_067_002.mp3","charTypeName":"word"},{"id":58338,"position":3,"arabic":"إِنَّآ","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/033_067_003.mp3","charTypeName":"word"},{"id":58339,"position":4,"arabic":"أَطَعْنَا","translation":"আনুগত্য করেছি আমরা","audioUrl":"wbw/033_067_004.mp3","charTypeName":"word"},{"id":58340,"position":5,"arabic":"سَادَتَنَا","translation":"নেতাদের আমাদের","audioUrl":"wbw/033_067_005.mp3","charTypeName":"word"},{"id":58341,"position":6,"arabic":"وَكُبَرَآءَنَا","translation":"ও বড়দের আমাদের","audioUrl":"wbw/033_067_006.mp3","charTypeName":"word"},{"id":58342,"position":7,"arabic":"فَأَضَلُّونَا","translation":"অতঃপর তারা ভ্রষ্ট করেছে আমাদেরকে","audioUrl":"wbw/033_067_007.mp3","charTypeName":"word"},{"id":58343,"position":8,"arabic":"ٱلسَّبِيلَا۠","translation":"পথ","audioUrl":"wbw/033_067_008.mp3","charTypeName":"word"},{"id":58344,"position":9,"arabic":"٦٧","translation":"(৬৭)","audioUrl":null,"charTypeName":"end"}]},{"number":68,"arabic":"رَبَّنَآ ءَاتِهِمْ ضِعْفَيْنِ مِنَ ٱلْعَذَابِ وَٱلْعَنْهُمْ لَعْنًۭا كَبِيرًۭا","translation":"O our Sustainer! Give them double suffering, and banish them utterly from Thy grace!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3601.mp3","surahId":33,"words":[{"id":58807,"position":1,"arabic":"رَبَّنَآ","translation":"হে আমাদের রব","audioUrl":"wbw/033_068_001.mp3","charTypeName":"word"},{"id":58808,"position":2,"arabic":"ءَاتِهِمْ","translation":"দিন তাদের","audioUrl":"wbw/033_068_002.mp3","charTypeName":"word"},{"id":58809,"position":3,"arabic":"ضِعْفَيْنِ","translation":"দ্বিগুণ","audioUrl":"wbw/033_068_003.mp3","charTypeName":"word"},{"id":58810,"position":4,"arabic":"مِنَ","translation":"থেকে","audioUrl":"wbw/033_068_004.mp3","charTypeName":"word"},{"id":58811,"position":5,"arabic":"ٱلْعَذَابِ","translation":"শাস্তি","audioUrl":"wbw/033_068_005.mp3","charTypeName":"word"},{"id":58812,"position":6,"arabic":"وَٱلْعَنْهُمْ","translation":"এবং অভিশপ্ত করুন তাদেরকে","audioUrl":"wbw/033_068_006.mp3","charTypeName":"word"},{"id":58813,"position":7,"arabic":"لَعْنًۭا","translation":"অভিশাপে","audioUrl":"wbw/033_068_007.mp3","charTypeName":"word"},{"id":58814,"position":8,"arabic":"كَبِيرًۭا","translation":"বড়\"","audioUrl":"wbw/033_068_008.mp3","charTypeName":"word"},{"id":58815,"position":9,"arabic":"٦٨","translation":"(৬৮)","audioUrl":null,"charTypeName":"end"}]},{"number":69,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ لَا تَكُونُوا۟ كَٱلَّذِينَ ءَاذَوْا۟ مُوسَىٰ فَبَرَّأَهُ ٱللَّهُ مِمَّا قَالُوا۟ ۚ وَكَانَ عِندَ ٱللَّهِ وَجِيهًۭا","translation":"O YOU who have attained to faith! Be not like those [children of Israel] who gave offence to Moses, and [remember that] God showed him to be innocent of whatever they alleged [against him or demanded of him]: for of great honour was he in the sight of God.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3602.mp3","surahId":33,"words":[{"id":59297,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"হে","audioUrl":"wbw/033_069_001.mp3","charTypeName":"word"},{"id":59298,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/033_069_002.mp3","charTypeName":"word"},{"id":59299,"position":3,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছো","audioUrl":"wbw/033_069_003.mp3","charTypeName":"word"},{"id":59300,"position":4,"arabic":"لَا","translation":"না","audioUrl":"wbw/033_069_004.mp3","charTypeName":"word"},{"id":59301,"position":5,"arabic":"تَكُونُوا۟","translation":"তোমরা হয়ো","audioUrl":"wbw/033_069_005.mp3","charTypeName":"word"},{"id":59302,"position":6,"arabic":"كَٱلَّذِينَ","translation":"(তাদের) মতো যারা","audioUrl":"wbw/033_069_006.mp3","charTypeName":"word"},{"id":59303,"position":7,"arabic":"ءَاذَوْا۟","translation":"কষ্ট দিয়েছিলো","audioUrl":"wbw/033_069_007.mp3","charTypeName":"word"},{"id":59304,"position":8,"arabic":"مُوسَىٰ","translation":"মূসাকে","audioUrl":"wbw/033_069_008.mp3","charTypeName":"word"},{"id":59305,"position":9,"arabic":"فَبَرَّأَهُ","translation":"অতঃপর নির্দোষ প্রমাণ করলেন তাকে","audioUrl":"wbw/033_069_009.mp3","charTypeName":"word"},{"id":59306,"position":10,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/033_069_010.mp3","charTypeName":"word"},{"id":59307,"position":11,"arabic":"مِمَّا","translation":"ঐ বিষ