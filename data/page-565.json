{"id":565,"ayahs":[{"number":16,"arabic":"سَنَسِمُهُۥ عَلَى ٱلْخُرْطُومِ","translation":"[For this] We shall brand him with indelible disgrace!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5287.mp3","surahId":68,"words":[{"id":18491,"position":1,"arabic":"سَنَسِمُهُۥ","translation":"তাকে দাগাব শিঘ্র","audioUrl":"wbw/068_016_001.mp3","charTypeName":"word"},{"id":18492,"position":2,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/068_016_002.mp3","charTypeName":"word"},{"id":18493,"position":3,"arabic":"ٱلْخُرْطُومِ","translation":"শুড়ের","audioUrl":"wbw/068_016_003.mp3","charTypeName":"word"},{"id":18494,"position":4,"arabic":"١٦","translation":"(১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":17,"arabic":"إِنَّا بَلَوْنَٰهُمْ كَمَا بَلَوْنَآ أَصْحَٰبَ ٱلْجَنَّةِ إِذْ أَقْسَمُوا۟ لَيَصْرِمُنَّهَا مُصْبِحِينَ","translation":"[As for such sinners,] behold, We [but] try them as We tried the owners of a certain garden who vowed that they would surely harvest its fruit on the morrow,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5288.mp3","surahId":68,"words":[{"id":19055,"position":1,"arabic":"إِنَّا","translation":"নিশ্চয়,আমরা","audioUrl":"wbw/068_017_001.mp3","charTypeName":"word"},{"id":19056,"position":2,"arabic":"بَلَوْنَـٰهُمْ","translation":"তাদের পরীক্ষায় ফেলেছি","audioUrl":"wbw/068_017_002.mp3","charTypeName":"word"},{"id":19057,"position":3,"arabic":"كَمَا","translation":"যেমন","audioUrl":"wbw/068_017_003.mp3","charTypeName":"word"},{"id":19058,"position":4,"arabic":"بَلَوْنَآ","translation":"আমরা পরীক্ষা করেছিলাম","audioUrl":"wbw/068_017_004.mp3","charTypeName":"word"},{"id":19059,"position":5,"arabic":"أَصْحَـٰبَ","translation":"মালিকদের","audioUrl":"wbw/068_017_005.mp3","charTypeName":"word"},{"id":19060,"position":6,"arabic":"ٱلْجَنَّةِ","translation":"বাগানটির","audioUrl":"wbw/068_017_006.mp3","charTypeName":"word"},{"id":19061,"position":7,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/068_017_007.mp3","charTypeName":"word"},{"id":19062,"position":8,"arabic":"أَقْسَمُوا۟","translation":"তারা শপথ করেছিল","audioUrl":"wbw/068_017_008.mp3","charTypeName":"word"},{"id":19063,"position":9,"arabic":"لَيَصْرِمُنَّهَا","translation":"তারা অবশ্যই তা কাটবে(পাড়িবে)","audioUrl":"wbw/068_017_009.mp3","charTypeName":"word"},{"id":19064,"position":10,"arabic":"مُصْبِحِينَ","translation":"সকাল(হতে)","audioUrl":"wbw/068_017_010.mp3","charTypeName":"word"},{"id":19065,"position":11,"arabic":"١٧","translation":"(১৭)","audioUrl":null,"charTypeName":"end"}]},{"number":18,"arabic":"وَلَا يَسْتَثْنُونَ","translation":"and made no allowance [for the will of God]:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5289.mp3","surahId":68,"words":[{"id":20548,"position":1,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/068_018_001.mp3","charTypeName":"word"},{"id":20549,"position":2,"arabic":"يَسْتَثْنُونَ","translation":"তারা ব্যাতিক্রম রাখলো","audioUrl":"wbw/068_018_002.mp3","charTypeName":"word"},{"id":20550,"position":3,"arabic":"١٨","translation":"(১৮)","audioUrl":null,"charTypeName":"end"}]},{"number":19,"arabic":"فَطَافَ عَلَيْهَا طَآئِفٌۭ مِّن رَّبِّكَ وَهُمْ نَآئِمُونَ","translation":"whereupon a visitation for thy Sustainer came upon that [garden] while they were asleep,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5290.mp3","surahId":68,"words":[{"id":22185,"position":1,"arabic":"فَطَافَ","translation":"অতএব বিপদ আসলো","audioUrl":"wbw/068_019_001.mp3","charTypeName":"word"},{"id":22186,"position":2,"arabic":"عَلَيْهَا","translation":"তার উপর","audioUrl":"wbw/068_019_002.mp3","charTypeName":"word"},{"id":22187,"position":3,"arabic":"طَآئِفٌۭ","translation":"বিপদ","audioUrl":"wbw/068_019_003.mp3","charTypeName":"word"},{"id":22188,"position":4,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/068_019_004.mp3","charTypeName":"word"},{"id":22189,"position":5,"arabic":"رَّبِّكَ","translation":"তোমার রবের,","audioUrl":"wbw/068_019_005.mp3","charTypeName":"word"},{"id":22190,"position":6,"arabic":"وَهُمْ","translation":"এবং তারা(ছিল)","audioUrl":"wbw/068_019_006.mp3","charTypeName":"word"},{"id":22191,"position":7,"arabic":"نَآئِمُونَ","translation":"ঘুমন্ত অবস্থায়","audioUrl":"wbw/068_019_007.mp3","charTypeName":"word"},{"id":22192,"position":8,"arabic":"١٩","translation":"(১৯)","audioUrl":null,"charTypeName":"end"}]},{"number":20,"arabic":"فَأَصْبَحَتْ كَٱلصَّرِيمِ","translation":"so that by the morrow it became barren and bleak.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5291.mp3","surahId":68,"words":[{"id":23281,"position":1,"arabic":"فَأَصْبَحَتْ","translation":"ফলে হয়ে গেল","audioUrl":"wbw/068_020_001.mp3","charTypeName":"word"},{"id":23282,"position":2,"arabic":"كَٱلصَّرِيمِ","translation":"কর্তিত ফসলের মত","audioUrl":"wbw/068_020_002.mp3","charTypeName":"word"},{"id":23283,"position":3,"arabic":"٢٠","translation":"(২০)","audioUrl":null,"charTypeName":"end"}]},{"number":21,"arabic":"فَتَنَادَوْا۟ مُصْبِحِينَ","translation":"Now when they rose at early morn, they called unto one another,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5292.mp3","surahId":68,"words":[{"id":24346,"position":1,"arabic":"فَتَنَادَوْا۟","translation":"অতঃপর পরস্পরে ডাকলো","audioUrl":"wbw/068_021_001.mp3","charTypeName":"word"},{"id":24347,"position":2,"arabic":"مُصْبِحِينَ","translation":"সকাল(হতে)","audioUrl":"wbw/068_021_002.mp3","charTypeName":"word"},{"id":24348,"position":3,"arabic":"٢١","translation":"(২১)","audioUrl":null,"charTypeName":"end"}]},{"number":22,"arabic":"أَنِ ٱغْدُوا۟ عَلَىٰ حَرْثِكُمْ إِن كُنتُمْ صَٰرِمِينَ","translation":"\"Go early to your tilth if you want to harvest the fruit!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5293.mp3","surahId":68,"words":[{"id":24880,"position":1,"arabic":"أَنِ","translation":"যে","audioUrl":"wbw/068_022_001.mp3","charTypeName":"word"},{"id":24881,"position":2,"arabic":"ٱغْدُوا۟","translation":"\"সকালে চলো","audioUrl":"wbw/068_022_002.mp3","charTypeName":"word"},{"id":24882,"position":3,"arabic":"عَلَىٰ","translation":"দিকে","audioUrl":"wbw/068_022_003.mp3","charTypeName":"word"},{"id":24883,"position":4,"arabic":"حَرْثِكُمْ","translation":"তোমাদের ক্ষেতের","audioUrl":"wbw/068_022_004.mp3","charTypeName":"word"},{"id":24884,"position":5,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/068_022_005.mp3","charTypeName":"word"},{"id":24885,"position":6,"arabic":"كُنتُمْ","translation":"তোমরা হও","audioUrl":"wbw/068_022_006.mp3","charTypeName":"word"},{"id":24886,"position":7,"arabic":"صَـٰرِمِينَ","translation":"ফসল কর্তনকারী\"","audioUrl":"wbw/068_022_007.mp3","charTypeName":"word"},{"id":24887,"position":8,"arabic":"٢٢","translation":"(২২)","audioUrl":null,"charTypeName":"end"}]},{"number":23,"arabic":"فَٱنطَلَقُوا۟ وَهُمْ يَتَخَٰفَتُونَ","translation":"Thus they launched forth, whispering unto one another,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5294.mp3","surahId":68,"words":[{"id":25942,"position":1,"arabic":"فَٱنطَلَقُوا۟","translation":"অতঃপর তারা চললো","audioUrl":"wbw/068_023_001.mp3","charTypeName":"word"},{"id":25943,"position":2,"arabic":"وَهُمْ","translation":"এবং তারা","audioUrl":"wbw/068_023_002.mp3","charTypeName":"word"},{"id":25944,"position":3,"arabic":"يَتَخَـٰفَتُونَ","translation":"নিচু স্বরে বলছিল","audioUrl":"wbw/068_023_003.mp3","charTypeName":"word"},{"id":25945,"position":4,"arabic":"٢٣","translation":"(২৩)","audioUrl":null,"charTypeName":"end"}]},{"number":24,"arabic":"أَن لَّا يَدْخُلَنَّهَا ٱلْيَوْمَ عَلَيْكُم مِّسْكِينٌۭ","translation":"\"Indeed, no needy person shall enter it today [and come] upon you [unawares],\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5295.mp3","surahId":68,"words":[{"id":26995,"position":1,"arabic":"أَن","translation":"যে","audioUrl":"wbw/068_024_001.mp3","charTypeName":"word"},{"id":26996,"position":2,"arabic":"لَّا","translation":"\"না","audioUrl":"wbw/068_024_002.mp3","charTypeName":"word"},{"id":26997,"position":3,"arabic":"يَدْخُلَنَّهَا","translation":"এতে নিশ্চয়ই প্রবেশ করবে","audioUrl":"wbw/068_024_003.mp3","charTypeName":"word"},{"id":26998,"position":4,"arabic":"ٱلْيَوْمَ","translation":"আজ","audioUrl":"wbw/068_024_004.mp3","charTypeName":"word"},{"id":26999,"position":5,"arabic":"عَلَيْكُم","translation":"তোমাদের কাছে","audioUrl":"wbw/068_024_005.mp3","charTypeName":"word"},{"id":27000,"position":6,"arabic":"مِّسْكِينٌۭ","translation":"ভিখারী\"","audioUrl":"wbw/068_024_006.mp3","charTypeName":"word"},{"id":27001,"position":7,"arabic":"٢٤","translation":"(২৪)","audioUrl":null,"charTypeName":"end"}]},{"number":25,"arabic":"وَغَدَوْا۟ عَلَىٰ حَرْدٍۢ قَٰدِرِينَ","translation":"– and early they went, strongly bent upon their purpose.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5296.mp3","surahId":68,"words":[{"id":28445,"position":1,"arabic":"وَغَدَوْا۟","translation":"এবং তারা চললো","audioUrl":"wbw/068_025_001.mp3","charTypeName":"word"},{"id":28446,"position":2,"arabic":"عَلَىٰ","translation":"ব্যাপারে(যেন)","audioUrl":"wbw/068_025_002.mp3","charTypeName":"word"},{"id":28447,"position":3,"arabic":"حَرْدٍۢ","translation":"নিবৃত্ত করার","audioUrl":"wbw/068_025_003.mp3","charTypeName":"word"},{"id":28448,"position":4,"arabic":"قَـٰدِرِينَ","translation":"সক্ষম","audioUrl":"wbw/068_025_004.mp3","charTypeName":"word"},{"id":28449,"position":5,"arabic":"٢٥","translation":"(২৫)","audioUrl":null,"charTypeName":"end"}]},{"number":26,"arabic":"فَلَمَّا رَأَوْهَا قَالُوٓا۟ إِنَّا لَضَآلُّونَ","translation":"But as soon as they beheld [the garden and could not recognize] it, they exclaimed, \"Surely we have lost our way!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5297.mp3","surahId":68,"words":[{"id":28914,"position":1,"arabic":"فَلَمَّا","translation":"কিন্তু যখন","audioUrl":"wbw/068_026_001.mp3","charTypeName":"word"},{"id":28915,"position":2,"arabic":"رَأَوْهَا","translation":"তারা তা দেখলো","audioUrl":"wbw/068_026_002.mp3","charTypeName":"word"},{"id":28916,"position":3,"arabic":"قَالُوٓا۟","translation":"তারা বলল,","audioUrl":"wbw/068_026_003.mp3","charTypeName":"word"},{"id":28917,"position":4,"arabic":"إِنَّا","translation":"\"নিশ্চয় আমরা","audioUrl":"wbw/068_026_004.mp3","charTypeName":"word"},{"id":28918,"position":5,"arabic":"لَضَآلُّونَ","translation":"অবশ্যই পথভ্রষ্ট","audioUrl":"wbw/068_026_005.mp3","charTypeName":"word"},{"id":28919,"position":6,"arabic":"٢٦","translation":"(২৬)","audioUrl":null,"charTypeName":"end"}]},{"number":27,"arabic":"بَلْ نَحْنُ مَحْرُومُونَ","translation":"- [and then,] \"Nay, but we have been rendered destitute!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5298.mp3","surahId":68,"words":[{"id":30379,"position":1,"arabic":"بَلْ","translation":"বরং","audioUrl":"wbw/068_027_001.mp3","charTypeName":"word"},{"id":30380,"position":2,"arabic":"نَحْنُ","translation":"আমরা","audioUrl":"wbw/068_027_002.mp3","charTypeName":"word"},{"id":30381,"position":3,"arabic":"مَحْرُومُونَ","translation":"বঞ্চিত\"","audioUrl":"wbw/068_027_003.mp3","charTypeName":"word"},{"id":30382,"position":4,"arabic":"٢٧","translation":"(২৭)","audioUrl":null,"charTypeName":"end"}]},{"number":28,"arabic":"قَالَ أَوْسَطُهُمْ أَلَمْ أَقُل لَّكُمْ لَوْلَا تُسَبِّحُونَ","translation":"Said the most right-minded among them: \"Did I not tell you, 'Will you not extol God's limitless glory?’\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5299.mp3","surahId":68,"words":[{"id":30905,"position":1,"arabic":"قَالَ","translation":"বললো","audioUrl":"wbw/068_028_001.mp3","charTypeName":"word"},{"id":30906,"position":2,"arabic":"أَوْسَطُهُمْ","translation":"তাদের শ্রেষ্ঠ ব্যাক্তি","audioUrl":"wbw/068_028_002.mp3","charTypeName":"word"},{"id":30907,"position":3,"arabic":"أَلَمْ","translation":"\"নাই কি","audioUrl":"wbw/068_028_003.mp3","charTypeName":"word"},{"id":30908,"position":4,"arabic":"أَقُل","translation":"আমি বলি","audioUrl":"wbw/068_028_004.mp3","charTypeName":"word"},{"id":30909,"position":5,"arabic":"لَّكُمْ","translation":"তোমাদেরকে","audioUrl":"wbw/068_028_005.mp3","charTypeName":"word"},{"id":30910,"position":6,"arabic":"لَوْلَا","translation":"না কেন","audioUrl":"wbw/068_028_006.mp3","charTypeName":"word"},{"id":30911,"position":7,"arabic":"تُسَبِّحُونَ","translation":"তোমরা তসবিহ করো","audioUrl":"wbw/068_028_007.mp3","charTypeName":"word"},{"id":30912,"position":8,"arabic":"٢٨","translation":"(২৮)","audioUrl":null,"charTypeName":"end"}]},{"number":29,"arabic":"قَالُوا۟ سُبْحَٰنَ رَبِّنَآ إِنَّا كُنَّا ظَٰلِمِينَ","translation":"They answered: \"Limitless in His glory is our Sustainer! Verily, we were doing wrong!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5300.mp3","surahId":68,"words":[{"id":32292,"position":1,"arabic":"قَالُوا۟","translation":"তারা বললো","audioUrl":"wbw/068_029_001.mp3","charTypeName":"word"},{"id":32293,"position":2,"arabic":"سُبْحَـٰنَ","translation":"\"পবিত্র","audioUrl":"wbw/068_029_002.mp3","charTypeName":"word"},{"id":32294,"position":3,"arabic":"رَبِّنَآ","translation":"আমাদের রব","audioUrl":"wbw/068_029_003.mp3","charTypeName":"word"},{"id":32295,"position":4,"arabic":"إِنَّا","translation":"নিশ্চিত","audioUrl":"wbw/068_029_004.mp3","charTypeName":"word"},{"id":32296,"position":5,"arabic":"كُنَّا","translation":"(আমরা)ছিলাম","audioUrl":"wbw/068_029_005.mp3","charTypeName":"word"},{"id":32297,"position":6,"arabic":"ظَـٰلِمِينَ","translation":"যালেম\"","audioUrl":"wbw/068_029_006.mp3","charTypeName":"word"},{"id":32298,"position":7,"arabic":"٢٩","translation":"(২৯)","audioUrl":null,"charTypeName":"end"}]},{"number":30,"arabic":"فَأَقْبَلَ بَعْضُهُمْ عَلَىٰ بَعْضٍۢ يَتَلَٰوَمُونَ","translation":"- and then they turned upon one another with mutual reproaches.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5301.mp3","surahId":68,"words":[{"id":32779,"position":1,"arabic":"فَأَقْبَلَ","translation":"অতএব তারা মুখোমুখি হলো","audioUrl":"wbw/068_030_001.mp3","charTypeName":"word"},{"id":32780,"position":2,"arabic":"بَعْضُهُمْ","translation":"তাদের একে","audioUrl":"wbw/068_030_002.mp3","charTypeName":"word"},{"id":32781,"position":3,"arabic":"عَلَىٰ","translation":"প্রতি","audioUrl":"wbw/068_030_003.mp3","charTypeName":"word"},{"id":32782,"position":4,"arabic":"بَعْضٍۢ","translation":"অপরের","audioUrl":"wbw/068_030_004.mp3","charTypeName":"word"},{"id":32783,"position":5,"arabic":"يَتَلَـٰوَمُونَ","translation":"তিরস্কার করতে লাগলো","audioUrl":"wbw/068_030_005.mp3","charTypeName":"word"},{"id":32784,"position":6,"arabic":"٣٠","translation":"(৩০)","audioUrl":null,"charTypeName":"end"}]},{"number":31,"arabic":"قَالُوا۟ يَٰوَيْلَنَآ إِنَّا كُنَّا طَٰغِينَ","translation":"[In the end] they said: \"Oh, woe unto us! Verily, we did behave outrageously!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5302.mp3","surahId":68,"words":[{"id":33975,"position":1,"arabic":"قَالُوا۟","translation":"তারা বললো","audioUrl":"wbw/068_031_001.mp3","charTypeName":"word"},{"id":33976,"position":2,"arabic":"يَـٰوَيْلَنَآ","translation":"\"আমাদের আফসোস","audioUrl":"wbw/068_031_002.mp3","charTypeName":"word"},{"id":33977,"position":3,"arabic":"إِنَّا","translation":"আমরা নিশ্চয়","audioUrl":"wbw/068_031_003.mp3","charTypeName":"word"},{"id":33978,"position":4,"arabic":"كُنَّا","translation":"ছিলাম","audioUrl":"wbw/068_031_004.mp3","charTypeName":"word"},{"id":33979,"position":5,"arabic":"طَـٰغِينَ","translation":"সিমালংঘনকারী","audioUrl":"wbw/068_031_005.mp3","charTypeName":"word"},{"id":33980,"position":6,"arabic":"٣١","translation":"(৩১)","audioUrl":null,"charTypeName":"end"}]},{"number":32,"arabic":"عَسَىٰ رَبُّنَآ أَن يُبْدِلَنَا خَيْرًۭا مِّنْهَآ إِنَّآ إِلَىٰ رَبِّنَا رَٰغِبُونَ","translation":"[But] it may be that our Sustainer will grant us something better instead: for, verily, unto our Sustainer do we turn with hope!\"","audio":"https://cdn.islamic.net