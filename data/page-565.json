"translation":"(৪১)","audioUrl":null,"charTypeName":"end"}]},{"number":42,"arabic":"يَوْمَ يُكْشَفُ عَن سَاقٍۢ وَيُدْعَوْنَ إِلَى ٱلسُّجُودِ فَلَا يَسْتَطِيعُونَ","translation":"on the Day when man's very being shall be bared to the bone, and when they [who now deny the truth] shall be called upon to prostrate themselves [before God], and shall be unable to do so:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5313.mp3","surahId":68,"words":[{"id":43008,"position":1,"arabic":"يَوْمَ","translation":"সসেদিন","audioUrl":"wbw/068_042_001.mp3","charTypeName":"word"},{"id":43009,"position":2,"arabic":"يُكْشَفُ","translation":"উন্মোচিত হবে","audioUrl":"wbw/068_042_002.mp3","charTypeName":"word"},{"id":43010,"position":3,"arabic":"عَن","translation":"থেকে","audioUrl":"wbw/068_042_003.mp3","charTypeName":"word"},{"id":43011,"position":4,"arabic":"سَاقٍۢ","translation":"পিণ্ডলী","audioUrl":"wbw/068_042_004.mp3","charTypeName":"word"},{"id":43012,"position":5,"arabic":"وَيُدْعَوْنَ","translation":"এবং তাদের ডাকা হবে","audioUrl":"wbw/068_042_005.mp3","charTypeName":"word"},{"id":43013,"position":6,"arabic":"إِلَى","translation":"দিকে","audioUrl":"wbw/068_042_006.mp3","charTypeName":"word"},{"id":43014,"position":7,"arabic":"ٱلسُّجُودِ","translation":"সিজদাসমূহের","audioUrl":"wbw/068_042_007.mp3","charTypeName":"word"},{"id":43015,"position":8,"arabic":"فَلَا","translation":"না তখন","audioUrl":"wbw/068_042_008.mp3","charTypeName":"word"},{"id":43016,"position":9,"arabic":"يَسْتَطِيعُونَ","translation":"তারা পারবে","audioUrl":"wbw/068_042_009.mp3","charTypeName":"word"},{"id":43017,"position":10,"arabic":"٤٢","translation":"(৪২)","audioUrl":null,"charTypeName":"end"}]}]}