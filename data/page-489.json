{"id":489,"ayahs":[{"number":52,"arabic":"وَكَذَٰلِكَ أَوْحَيْنَآ إِلَيْكَ رُوحًۭا مِّنْ أَمْرِنَا ۚ مَا كُنتَ تَدْرِى مَا ٱلْكِتَٰبُ وَلَا ٱلْإِيمَٰنُ وَلَٰكِن جَعَلْنَٰهُ نُورًۭا نَّهْدِى بِهِۦ مَن نَّشَآءُ مِنْ عِبَادِنَا ۚ وَإِنَّكَ لَتَهْدِىٓ إِلَىٰ صِرَٰطٍۢ مُّسْتَقِيمٍۢ","translation":"And thus, too, [O Muhammad,] have We revealed unto thee a life-giving message, [coming] at Our behest. [Ere this message came unto thee,] thou didst not know what revelation is, nor what faith [implies]: but [now] We have caused this [message] to be a light, whereby We guide whom We will of Our ser­vants: and, verily, [on the strength thereof] thou, too, shalt guide [men] onto the straight way –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4324.mp3","surahId":42,"words":[{"id":49768,"position":1,"arabic":"وَكَذَٰلِكَ","translation":"এবং এভাবে","audioUrl":"wbw/042_052_001.mp3","charTypeName":"word"},{"id":49769,"position":2,"arabic":"أَوْحَيْنَآ","translation":"আমরা ওহী পাঠিয়েছি","audioUrl":"wbw/042_052_002.mp3","charTypeName":"word"},{"id":49770,"position":3,"arabic":"إِلَيْكَ","translation":"তোমার প্রতি","audioUrl":"wbw/042_052_003.mp3","charTypeName":"word"},{"id":49771,"position":4,"arabic":"رُوحًۭا","translation":"রূহ (অর্থাৎ ওহী) বা কোরআন","audioUrl":"wbw/042_052_004.mp3","charTypeName":"word"},{"id":49772,"position":5,"arabic":"مِّنْ","translation":"থেকে","audioUrl":"wbw/042_052_005.mp3","charTypeName":"word"},{"id":49773,"position":6,"arabic":"أَمْرِنَا ۚ","translation":"আমাদের নির্দেশ","audioUrl":"wbw/042_052_006.mp3","charTypeName":"word"},{"id":49775,"position":7,"arabic":"مَا","translation":"না","audioUrl":"wbw/042_052_008.mp3","charTypeName":"word"},{"id":49776,"position":8,"arabic":"كُنتَ","translation":"তুমি","audioUrl":"wbw/042_052_009.mp3","charTypeName":"word"},{"id":49777,"position":9,"arabic":"تَدْرِى","translation":"জানতে","audioUrl":"wbw/042_052_010.mp3","charTypeName":"word"},{"id":49778,"position":10,"arabic":"مَا","translation":"কি","audioUrl":"wbw/042_052_011.mp3","charTypeName":"word"},{"id":49779,"position":11,"arabic":"ٱلْكِتَـٰبُ","translation":"কিতাব","audioUrl":"wbw/042_052_012.mp3","charTypeName":"word"},{"id":49780,"position":12,"arabic":"وَلَا","translation":"আর না (জানতে)","audioUrl":"wbw/042_052_013.mp3","charTypeName":"word"},{"id":49781,"position":13,"arabic":"ٱلْإِيمَـٰنُ","translation":"ঈমান","audioUrl":"wbw/042_052_014.mp3","charTypeName":"word"},{"id":49782,"position":14,"arabic":"وَلَـٰكِن","translation":"কিন্তু","audioUrl":"wbw/042_052_015.mp3","charTypeName":"word"},{"id":49783,"position":15,"arabic":"جَعَلْنَـٰهُ","translation":"তাকে আমরা করেছি","audioUrl":"wbw/042_052_016.mp3","charTypeName":"word"},{"id":49784,"position":16,"arabic":"نُورًۭا","translation":"আলো'","audioUrl":"wbw/042_052_017.mp3","charTypeName":"word"},{"id":49785,"position":17,"arabic":"نَّهْدِى","translation":"পথ দেখাই আমরা","audioUrl":"wbw/042_052_018.mp3","charTypeName":"word"},{"id":49786,"position":18,"arabic":"بِهِۦ","translation":"তা দিয়ে","audioUrl":"wbw/042_052_019.mp3","charTypeName":"word"},{"id":49787,"position":19,"arabic":"مَن","translation":"যাকে","audioUrl":"wbw/042_052_020.mp3","charTypeName":"word"},{"id":49788,"position":20,"arabic":"نَّشَآءُ","translation":"ইচ্ছে করি আমরা","audioUrl":"wbw/042_052_021.mp3","charTypeName":"word"},{"id":49789,"position":21,"arabic":"مِنْ","translation":"মধ্য হ'তে","audioUrl":"wbw/042_052_022.mp3","charTypeName":"word"},{"id":49790,"position":22,"arabic":"عِبَادِنَا ۚ","translation":"আমাদের দাসদের","audioUrl":"wbw/042_052_023.mp3","charTypeName":"word"},{"id":49792,"position":23,"arabic":"وَإِنَّكَ","translation":"এবং তুমি নিশ্চয়ই","audioUrl":"wbw/042_052_025.mp3","charTypeName":"word"},{"id":49793,"position":24,"arabic":"لَتَهْدِىٓ","translation":"পথ দেখাচ্ছো তুমি অবশ্যই","audioUrl":"wbw/042_052_026.mp3","charTypeName":"word"},{"id":49794,"position":25,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/042_052_027.mp3","charTypeName":"word"},{"id":49795,"position":26,"arabic":"صِرَٰطٍۢ","translation":"পথের","audioUrl":"wbw/042_052_028.mp3","charTypeName":"word"},{"id":49796,"position":27,"arabic":"مُّسْتَقِيمٍۢ","translation":"সরল-সঠিক","audioUrl":"wbw/042_052_029.mp3","charTypeName":"word"},{"id":49797,"position":28,"arabic":"٥٢","translation":"(৫২)","audioUrl":null,"charTypeName":"end"}]},{"number":53,"arabic":"صِرَٰطِ ٱللَّهِ ٱلَّذِى لَهُۥ مَا فِى ٱلسَّمَٰوَٰتِ وَمَا فِى ٱلْأَرْضِ ۗ أَلَآ إِلَى ٱللَّهِ تَصِيرُ ٱلْأُمُورُ","translation":"the way that leads to God, to whom all that is in the heavens and all that is on earth belongs. Oh, verily, with God is the beginning and the end of all things!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4325.mp3","surahId":42,"words":[{"id":50398,"position":1,"arabic":"صِرَٰطِ","translation":"পথ","audioUrl":"wbw/042_053_001.mp3","charTypeName":"word"},{"id":50399,"position":2,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/042_053_002.mp3","charTypeName":"word"},{"id":50400,"position":3,"arabic":"ٱلَّذِى","translation":"যিনি (এমন সত্ত্বা যে)","audioUrl":"wbw/042_053_003.mp3","charTypeName":"word"},{"id":50401,"position":4,"arabic":"لَهُۥ","translation":"তাঁরই জন্যে","audioUrl":"wbw/042_053_004.mp3","charTypeName":"word"},{"id":50402,"position":5,"arabic":"مَا","translation":"যা কিছু","audioUrl":"wbw/042_053_005.mp3","charTypeName":"word"},{"id":50403,"position":6,"arabic":"فِى","translation":"মধ্যে আছে","audioUrl":"wbw/042_053_006.mp3","charTypeName":"word"},{"id":50404,"position":7,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশের","audioUrl":"wbw/042_053_007.mp3","charTypeName":"word"},{"id":50405,"position":8,"arabic":"وَمَا","translation":"এবং যা কিছু","audioUrl":"wbw/042_053_008.mp3","charTypeName":"word"},{"id":50406,"position":9,"arabic":"فِى","translation":"মধ্যে আছে","audioUrl":"wbw/042_053_009.mp3","charTypeName":"word"},{"id":50407,"position":10,"arabic":"ٱلْأَرْضِ ۗ","translation":"পৃথিবীর","audioUrl":"wbw/042_053_010.mp3","charTypeName":"word"},{"id":50409,"position":11,"arabic":"أَلَآ","translation":"জেনে রাখো","audioUrl":"wbw/042_053_012.mp3","charTypeName":"word"},{"id":50410,"position":12,"arabic":"إِلَى","translation":"দিকে","audioUrl":"wbw/042_053_013.mp3","charTypeName":"word"},{"id":50411,"position":13,"arabic":"ٱللَّهِ","translation":"আল্লাহরই","audioUrl":"wbw/042_053_014.mp3","charTypeName":"word"},{"id":50412,"position":14,"arabic":"تَصِيرُ","translation":"ফিরে যায়","audioUrl":"wbw/042_053_015.mp3","charTypeName":"word"},{"id":50413,"position":15,"arabic":"ٱلْأُمُورُ","translation":"সকল বিষয়","audioUrl":"wbw/042_053_016.mp3","charTypeName":"word"},{"id":50414,"position":16,"arabic":"٥٣","translation":"(৫৩)","audioUrl":null,"charTypeName":"end"}]},{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ حمٓ","translation":"Ha. Mim.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4326.mp3","surahId":43,"words":[{"id":135,"position":1,"arabic":"حمٓ","translation":"হা-মীম","audioUrl":"wbw/043_001_001.mp3","charTypeName":"word"},{"id":136,"position":2,"arabic":"١","translation":"(১)","audioUrl":null,"charTypeName":"end"}]},{"number":2,"arabic":"وَٱلْكِتَٰبِ ٱلْمُبِينِ","translation":"CONSIDER this divine writ, clear in itself and clearly showing the truth:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4327.mp3","surahId":43,"words":[{"id":974,"position":1,"arabic":"وَٱلْكِتَـٰبِ","translation":"শপথ (এই) কিতাবের","audioUrl":"wbw/043_002_001.mp3","charTypeName":"word"},{"id":975,"position":2,"arabic":"ٱلْمُبِينِ","translation":"সুস্পষ্ট","audioUrl":"wbw/043_002_002.mp3","charTypeName":"word"},{"id":976,"position":3,"arabic":"٢","translation":"(২)","audioUrl":null,"charTypeName":"end"}]},{"number":3,"arabic":"إِنَّا جَعَلْنَٰهُ قُرْءَٰنًا عَرَبِيًّۭا لَّعَلَّكُمْ تَعْقِلُونَ","translation":"behold, We have caused it to be a discourse in the Arabic tongue, so that you might encompass it with your reason.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4328.mp3","surahId":43,"words":[{"id":2076,"position":1,"arabic":"إِنَّا","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/043_003_001.mp3","charTypeName":"word"},{"id":2077,"position":2,"arabic":"جَعَلْنَـٰهُ","translation":"তা আমরা বানিয়েছি","audioUrl":"wbw/043_003_002.mp3","charTypeName":"word"},{"id":2078,"position":3,"arabic":"قُرْءَٰنًا","translation":"(অর্থাৎ) কুরআন","audioUrl":"wbw/043_003_003.mp3","charTypeName":"word"},{"id":2079,"position":4,"arabic":"عَرَبِيًّۭا","translation":"আরবী (ভাষায়)","audioUrl":"wbw/043_003_004.mp3","charTypeName":"word"},{"id":2080,"position":5,"arabic":"لَّعَلَّكُمْ","translation":"তোমরা যাতে","audioUrl":"wbw/043_003_005.mp3","charTypeName":"word"},{"id":2081,"position":6,"arabic":"تَعْقِلُونَ","translation":"বুঝতে পারো","audioUrl":"wbw/043_003_006.mp3","charTypeName":"word"},{"id":2082,"position":7,"arabic":"٣","translation":"(৩)","audioUrl":null,"charTypeName":"end"}]},{"number":4,"arabic":"وَإِنَّهُۥ فِىٓ أُمِّ ٱلْكِتَٰبِ لَدَيْنَا لَعَلِىٌّ حَكِيمٌ","translation":"And, verily, [originating as it does] in the source, with Us, of all revelation, it is indeed sublime, full of wisdom.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4329.mp3","surahId":43,"words":[{"id":3343,"position":1,"arabic":"وَإِنَّهُۥ","translation":"এবং তা নিশ্চয়ই","audioUrl":"wbw/043_004_001.mp3","charTypeName":"word"},{"id":3344,"position":2,"arabic":"فِىٓ","translation":"মধ্যে আছে","audioUrl":"wbw/043_004_002.mp3","charTypeName":"word"},{"id":3345,"position":3,"arabic":"أُمِّ","translation":"মূল","audioUrl":"wbw/043_004_003.mp3","charTypeName":"word"},{"id":3346,"position":4,"arabic":"ٱلْكِتَـٰبِ","translation":"কিতাবের","audioUrl":"wbw/043_004_004.mp3","charTypeName":"word"},{"id":3347,"position":5,"arabic":"لَدَيْنَا","translation":"আমাদের কাছে","audioUrl":"wbw/043_004_005.mp3","charTypeName":"word"},{"id":3348,"position":6,"arabic":"لَعَلِىٌّ","translation":"অতীব উচ্চ মর্যাদার","audioUrl":"wbw/043_004_006.mp3","charTypeName":"word"},{"id":3349,"position":7,"arabic":"حَكِيمٌ","translation":"অবশ্যই মহান","audioUrl":"wbw/043_004_007.mp3","charTypeName":"word"},{"id":3350,"position":8,"arabic":"٤","translation":"(৪)","audioUrl":null,"charTypeName":"end"}]},{"number":5,"arabic":"أَفَنَضْرِبُ عَنكُمُ ٱلذِّكْرَ صَفْحًا أَن كُنتُمْ قَوْمًۭا مُّسْرِفِينَ","translation":"[O YOU who deny the truth!] Should We, perchance, withdraw this reminder from you altogether, seeing that you are people bent on wasting your own selves?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4330.mp3","surahId":43,"words":[{"id":4710,"position":1,"arabic":"أَفَنَضْرِبُ","translation":"তবে কি আমরা করবো","audioUrl":"wbw/043_005_001.mp3","charTypeName":"word"},{"id":4711,"position":2,"arabic":"عَنكُمُ","translation":"তোমাদের থেকে","audioUrl":"wbw/043_005_002.mp3","charTypeName":"word"},{"id":4712,"position":3,"arabic":"ٱلذِّكْرَ","translation":"উপদেশ","audioUrl":"wbw/043_005_003.mp3","charTypeName":"word"},{"id":4713,"position":4,"arabic":"صَفْحًا","translation":"প্রত্যাহার","audioUrl":"wbw/043_005_004.mp3","charTypeName":"word"},{"id":4714,"position":5,"arabic":"أَن","translation":"(এ জন্যে) যে","audioUrl":"wbw/043_005_005.mp3","charTypeName":"word"},{"id":4715,"position":6,"arabic":"كُنتُمْ","translation":"তোমরা হ'লে","audioUrl":"wbw/043_005_006.mp3","charTypeName":"word"},{"id":4716,"position":7,"arabic":"قَوْمًۭا","translation":"সম্প্রদায়","audioUrl":"wbw/043_005_007.mp3","charTypeName":"word"},{"id":4717,"position":8,"arabic":"مُّسْرِفِينَ","translation":"অসংযমী","audioUrl":"wbw/043_005_008.mp3","charTypeName":"word"},{"id":4718,"position":9,"arabic":"٥","translation":"(৫)","audioUrl":null,"charTypeName":"end"}]},{"number":6,"arabic":"وَكَمْ أَرْسَلْنَا مِن نَّبِىٍّۢ فِى ٱلْأَوَّلِينَ","translation":"And how many a prophet did We send to people of olden times!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4331.mp3","surahId":43,"words":[{"id":5980,"position":1,"arabic":"وَكَمْ","translation":"এবং কত (বার)","audioUrl":"wbw/043_006_001.mp3","charTypeName":"word"},{"id":5981,"position":2,"arabic":"أَرْسَلْنَا","translation":"আমরা পাঠিয়েছি","audioUrl":"wbw/043_006_002.mp3","charTypeName":"word"},{"id":5982,"position":3,"arabic":"مِن","translation":"থেকে","audioUrl":"wbw/043_006_003.mp3","charTypeName":"word"},{"id":5983,"position":4,"arabic":"نَّبِىٍّۢ","translation":"নাবী","audioUrl":"wbw/043_006_004.mp3","charTypeName":"word"},{"id":5984,"position":5,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/043_006_005.mp3","charTypeName":"word"},{"id":5985,"position":6,"arabic":"ٱلْأَوَّلِينَ","translation":"পূর্ববর্তীদের","audioUrl":"wbw/043_006_006.mp3","charTypeName":"word"},{"id":5986,"position":7,"arabic":"٦","translation":"(৬)","audioUrl":null,"charTypeName":"end"}]},{"number":7,"arabic":"وَمَا يَأْتِيهِم مِّن نَّبِىٍّ إِلَّا كَانُوا۟ بِهِۦ يَسْتَهْزِءُونَ","translation":"But never yet came a prophet to them without their deriding him –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4332.mp3","surahId":43,"words":[{"id":7292,"position":1,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/043_007_001.mp3","charTypeName":"word"},{"id":7293,"position":2,"arabic":"يَأْتِيهِم","translation":"তাদের কাছে এসেছে","audioUrl":"wbw/043_007_002.mp3","charTypeName":"word"},{"id":7294,"position":3,"arabic":"مِّن","translation":"(এমন) কোনো","audioUrl":"wbw/043_007_003.mp3","charTypeName":"word"},{"id":7295,"position":4,"arabic":"نَّبِىٍّ","translation":"নাবী","audioUrl":"wbw/043_007_004.mp3","charTypeName":"word"},{"id":7296,"position":5,"arabic":"إِلَّا","translation":"এ ব্যতীত যে","audioUrl":"wbw/043_007_005.mp3","charTypeName":"word"},{"id":7297,"position":6,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/043_007_006.mp3","charTypeName":"word"},{"id":7298,"position":7,"arabic":"بِهِۦ","translation":"তার সাথে","audioUrl":"wbw/043_007_007.mp3","charTypeName":"word"},{"id":7299,"position":8,"arabic":"يَسْتَهْزِءُونَ","translation":"ঠাট্টা-বিদ্রুপ করতো","audioUrl":"wbw/043_007_008.mp3","charTypeName":"word"},{"id":7300,"position":9,"arabic":"٧","translation":"(৭)","audioUrl":null,"charTypeName":"end"}]},{"number":8,"arabic":"فَأَهْلَكْنَآ أَشَدَّ مِنْهُم بَطْشًۭا وَمَضَىٰ مَثَلُ ٱلْأَوَّلِينَ","translation":"and so, [in the end,] We destroyed them [even though they were] of greater might than these: and the [very] image of those people of old became a thing of the past.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4333.mp3","surahId":43,"words":[{"id":8563,"position":1,"arabic":"فَأَهْلَكْنَآ","translation":"আমরা তাই ধ্বংস করে দিয়েছি","audioUrl":"wbw/043_008_001.mp3","charTypeName":"word"},{"id":8564,"position":2,"arabic":"أَشَدَّ","translation":"(যারা ছিলো) প্রবল","audioUrl":"wbw/043_008_002.mp3","charTypeName":"word"},{"id":8565,"position":3,"arabic":"مِنْهُم","translation":"তাদের মধ্য থেকে","audioUrl":"wbw/043_008_003.mp3","charTypeName":"word"},{"id":8566,"position":4,"arabic":"بَطْشًۭا","translation":"শক্তিতে","audioUrl":"wbw/043_008_004.mp3","charTypeName":"word"},{"id":8567,"position":5,"arabic":"وَمَضَىٰ","translation":"এবং অতীত হয়েছে","audioUrl":"wbw/043_008_005.mp3","charTypeName":"word"},{"id":8568,"position":6,"arabic":"مَثَلُ","translation":"অনুরূপ দৃষ্টান্ত","audioUrl":"wbw/043_008_006.mp3","charTypeName":"word"},{"id":8569,"position":7,"arabic":"ٱلْأَوَّلِينَ","translation":"পূর্ববর্তীদের","audioUrl":"wbw/043_008_007.mp3","charTypeName":"word"},{"id":8570,"position":8,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"وَلَئِن سَأَلْتَهُم مَّنْ خَلَقَ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضَ لَيَقُولُنَّ خَلَقَهُنَّ ٱلْعَزِيزُ ٱلْعَلِيمُ","translation":"Yet thus it is [with most people]: if thou ask them, “Who is it that has created the heavens and the earth?” - they will surely answer, “The Almighty, the All-Knowing has created them.”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4334.mp3","surahId":43,"words":[{"id":9771,"position":1,"arabic":"وَلَئِن","translation":"এবং অবশ্যই যদি","audioUrl":"wbw/043_009_001.mp3","charTypeName":"word"},{"id":9772,"position":2,"arabic":"سَأَلْتَهُم","translation":"তাদের তুমি প্রশ্ন করো","audioUrl":"wbw/043_009_002.mp3","charTypeName":"word"},{"id":9773,"position":3,"arabic":"مَّنْ","translation":"\"কে","audioUrl":"wbw/043_009_003.mp3","charTypeName":"word"},{"id":9774,"position":4,"arabic":"خَلَقَ","translation":"সৃষ্টি করেছেন","audioUrl":"wbw/043_009_004.mp3","charTypeName":"word"},{"id":9775,"position":5,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আকাশকে","audioUrl":"wbw/043_009_005.mp3","charTypeName":"word"},{"id":9776,"position":6,"arabic":"وَٱلْأَرْضَ","translation":"ও পৃথিবীকে\"","audioUrl":"wbw/043_009_006.mp3","charTypeName":"word"},{"id":9777,"position":7,"arabic":"لَيَقُولُنَّ","translation":"তারা বলবে অবশ্যই","audioUrl":"wbw/043_009_007.mp3","charTypeName":"word"},{"id":9778,"position":8,"arabic":"خَلَقَهُنَّ","translation":"\"তাদের সৃষ্টি করেছেন","audioUrl":"wbw/043_009_008.mp3","charTypeName":"word"},{"id":9779,"position":9,"arabic":"ٱلْعَزِيزُ","translation":"পরাক্রমশালী","audioUrl":"wbw/043_009_009.mp3","charTypeName":"word"},{"id":9780,"position":10,"arabic":"ٱلْعَلِيمُ","translation":"মহাজ্ঞানী (আল্লাহ)\"","audioUrl":"wbw/043_009_010.mp3","charTypeName":"word"},{"id":9781,"position":11,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"ٱلَّذِى جَعَلَ لَكُمُ ٱلْأَرْضَ مَهْدًۭا وَجَعَلَ لَكُمْ فِيهَا سُبُلًۭا لَّعَلَّكُمْ تَهْتَدُونَ","translation":"He it is who has made the earth a cradle for you, and has provided for you ways [of livelihood] thereon, so that you might follow the right path.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/4335.mp3","surahId":43,"words":[{"id":10903,"position":1,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/043_010_001.mp3","charTypeName":"word"},{"id":10904,"position":2,"arabic":"جَعَلَ","translation":"করেছেন","audioUrl":"wbw/043_010_002.mp3","charTypeName":"word"},{"id":10905,"position":3,"arabic":"لَكُمُ","translation":"তোমাদের জন্যে","audioUrl":"wbw/043_010_003.mp3","charTypeName":"word"},{"id":10906,"position":4,"arabic":"ٱلْأَرْضَ","translation":"জমিকে","audioUrl":"wbw/043_010_004.mp3","charTypeName":"word"},{"id":10907,"position":5,"arabic":"مَهْدًۭا","translation":"শয্যা (আশ্রয়স্থল)","audioUrl":"wbw/043_010_005.mp3","charTypeName":"word"},{"id":10908,"position":6,"arabic":"وَجَعَلَ","translation":"এবং করে দিয়েছেন","audioUrl":"wbw/043_010_006.mp3","charTypeName":"word"},{"id":10909,"position":7,"arabic":"لَكُمْ","translation":"তোমাদের জন্যে","audioUrl":"wbw/043_010_007.mp3","charTypeName":"word"},{"id":10910,"position":8,"arabic":"فِيهَا","translation":"তার মধ্যে","audioUrl":"wbw/043_010_008.mp3","charTypeName":"word"},{"id":10911,"position":9,"arabic":"سُبُلًۭا","translation":"পথসমূহ","audioUrl":"wbw/043_010_009.mp3","charTypeName":"word"},{"id":10912,"position":10,"arabic":"لَّعَلَّكُمْ","translation":"তোমরা যাতে","audioUrl":"wbw/043_010_010.mp3","charTypeName":"word"},{"id":10913,"position":11,"arabic":"تَهْتَدُونَ","translation":"(গন্তব্যস্থলের) পথ পেতে পারো","audioUrl":"wbw/043_010_011.mp3","charTypeName":"word"},{"id":10914,"position":12,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]}]}