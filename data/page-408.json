{"id":408,"ayahs":[{"number":33,"arabic":"وَإِذَا مَسَّ ٱلنَّاسَ ضُرٌّۭ دَعَوْا۟ رَبَّهُم مُّنِيبِينَ إِلَيْهِ ثُمَّ إِذَآ أَذَاقَهُم مِّنْهُ رَحْمَةً إِذَا فَرِيقٌۭ مِّنْهُم بِرَبِّهِمْ يُشْرِكُونَ","translation":"NOW [thus it is:] when affliction befalls men, they cry out unto their Sustainer, turning unto Him [for help]; but as soon as He lets them taste of His grace, lo! some of them [begin to] ascribe to other powers a share in their Sustainer’s divinity,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3442.mp3","surahId":30,"words":[{"id":35709,"position":1,"arabic":"وَإِذَا","translation":"এবং যখন","audioUrl":"wbw/030_033_001.mp3","charTypeName":"word"},{"id":35710,"position":2,"arabic":"مَسَّ","translation":"স্পর্শ করে","audioUrl":"wbw/030_033_002.mp3","charTypeName":"word"},{"id":35711,"position":3,"arabic":"ٱلنَّاسَ","translation":"মানুষকে","audioUrl":"wbw/030_033_003.mp3","charTypeName":"word"},{"id":35712,"position":4,"arabic":"ضُرٌّۭ","translation":"দুঃখ-দৈন্যে","audioUrl":"wbw/030_033_004.mp3","charTypeName":"word"},{"id":35713,"position":5,"arabic":"دَعَوْا۟","translation":"তারা ডাকে","audioUrl":"wbw/030_033_005.mp3","charTypeName":"word"},{"id":35714,"position":6,"arabic":"رَبَّهُم","translation":"রবকে তাদের","audioUrl":"wbw/030_033_006.mp3","charTypeName":"word"},{"id":35715,"position":7,"arabic":"مُّنِيبِينَ","translation":"বিশুদ্ধচিত্তে","audioUrl":"wbw/030_033_007.mp3","charTypeName":"word"},{"id":35716,"position":8,"arabic":"إِلَيْهِ","translation":"দিকে তাঁরই","audioUrl":"wbw/030_033_008.mp3","charTypeName":"word"},{"id":35717,"position":9,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/030_033_009.mp3","charTypeName":"word"},{"id":35718,"position":10,"arabic":"إِذَآ","translation":"যখন","audioUrl":"wbw/030_033_010.mp3","charTypeName":"word"},{"id":35719,"position":11,"arabic":"أَذَاقَهُم","translation":"তিনি আস্বাদন করান তাদেরকে","audioUrl":"wbw/030_033_011.mp3","charTypeName":"word"},{"id":35720,"position":12,"arabic":"مِّنْهُ","translation":"পক্ষ হ'তে তাঁর","audioUrl":"wbw/030_033_012.mp3","charTypeName":"word"},{"id":35721,"position":13,"arabic":"رَحْمَةً","translation":"অনুগ্রহ","audioUrl":"wbw/030_033_013.mp3","charTypeName":"word"},{"id":35722,"position":14,"arabic":"إِذَا","translation":"তখন","audioUrl":"wbw/030_033_014.mp3","charTypeName":"word"},{"id":35723,"position":15,"arabic":"فَرِيقٌۭ","translation":"একদল","audioUrl":"wbw/030_033_015.mp3","charTypeName":"word"},{"id":35724,"position":16,"arabic":"مِّنْهُم","translation":"মধ্য থেকে তাদের","audioUrl":"wbw/030_033_016.mp3","charTypeName":"word"},{"id":35725,"position":17,"arabic":"بِرَبِّهِمْ","translation":"সাথে রবের তাদের","audioUrl":"wbw/030_033_017.mp3","charTypeName":"word"},{"id":35726,"position":18,"arabic":"يُشْرِكُونَ","translation":"তারা শিরক করে","audioUrl":"wbw/030_033_018.mp3","charTypeName":"word"},{"id":35727,"position":19,"arabic":"٣٣","translation":"(৩৩)","audioUrl":null,"charTypeName":"end"}]},{"number":34,"arabic":"لِيَكْفُرُوا۟ بِمَآ ءَاتَيْنَٰهُمْ ۚ فَتَمَتَّعُوا۟ فَسَوْفَ تَعْلَمُونَ","translation":"[as if] to prove their ingratitude for all that We have granted them! Enjoy, then, your [brief] life: but in time you will come to know [the truth]!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3443.mp3","surahId":30,"words":[{"id":36655,"position":1,"arabic":"لِيَكْفُرُوا۟","translation":"যেন তারা অকৃতজ্ঞতা করে","audioUrl":"wbw/030_034_001.mp3","charTypeName":"word"},{"id":36656,"position":2,"arabic":"بِمَآ","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/030_034_002.mp3","charTypeName":"word"},{"id":36657,"position":3,"arabic":"ءَاتَيْنَـٰهُمْ ۚ","translation":"আমরা দান করেছি তাদেরকে","audioUrl":"wbw/030_034_003.mp3","charTypeName":"word"},{"id":36659,"position":4,"arabic":"فَتَمَتَّعُوا۟","translation":"সুতরাং তোমরা (ঠিক আছে) ভোগ করো","audioUrl":"wbw/030_034_005.mp3","charTypeName":"word"},{"id":36660,"position":5,"arabic":"فَسَوْفَ","translation":"অতঃপর শীঘ্রই","audioUrl":"wbw/030_034_006.mp3","charTypeName":"word"},{"id":36661,"position":6,"arabic":"تَعْلَمُونَ","translation":"তোমরা জানবে","audioUrl":"wbw/030_034_007.mp3","charTypeName":"word"},{"id":36662,"position":7,"arabic":"٣٤","translation":"(৩৪)","audioUrl":null,"charTypeName":"end"}]},{"number":35,"arabic":"أَمْ أَنزَلْنَا عَلَيْهِمْ سُلْطَٰنًۭا فَهُوَ يَتَكَلَّمُ بِمَا كَانُوا۟ بِهِۦ يُشْرِكُونَ","translation":"Have We ever bestowed upon them from on high a divine writ which would speak [with appro­val] of their worshipping aught beside Us?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3444.mp3","surahId":30,"words":[{"id":37523,"position":1,"arabic":"أَمْ","translation":"কি","audioUrl":"wbw/030_035_001.mp3","charTypeName":"word"},{"id":37524,"position":2,"arabic":"أَنزَلْنَا","translation":"অবতীর্ণ করেছি আমরা","audioUrl":"wbw/030_035_002.mp3","charTypeName":"word"},{"id":37525,"position":3,"arabic":"عَلَيْهِمْ","translation":"উপর তাদের","audioUrl":"wbw/030_035_003.mp3","charTypeName":"word"},{"id":37526,"position":4,"arabic":"سُلْطَـٰنًۭا","translation":"কোনো প্রমাণ","audioUrl":"wbw/030_035_004.mp3","charTypeName":"word"},{"id":37527,"position":5,"arabic":"فَهُوَ","translation":"সুতরাং তা","audioUrl":"wbw/030_035_005.mp3","charTypeName":"word"},{"id":37528,"position":6,"arabic":"يَتَكَلَّمُ","translation":"বলে","audioUrl":"wbw/030_035_006.mp3","charTypeName":"word"},{"id":37529,"position":7,"arabic":"بِمَا","translation":"ঐ বিষয়ে যা","audioUrl":"wbw/030_035_007.mp3","charTypeName":"word"},{"id":37530,"position":8,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/030_035_008.mp3","charTypeName":"word"},{"id":37531,"position":9,"arabic":"بِهِۦ","translation":"সাথে তাঁর","audioUrl":"wbw/030_035_009.mp3","charTypeName":"word"},{"id":37532,"position":10,"arabic":"يُشْرِكُونَ","translation":"শিরক করতো","audioUrl":"wbw/030_035_010.mp3","charTypeName":"word"},{"id":37533,"position":11,"arabic":"٣٥","translation":"(৩৫)","audioUrl":null,"charTypeName":"end"}]},{"number":36,"arabic":"وَإِذَآ أَذَقْنَا ٱلنَّاسَ رَحْمَةًۭ فَرِحُوا۟ بِهَا ۖ وَإِن تُصِبْهُمْ سَيِّئَةٌۢ بِمَا قَدَّمَتْ أَيْدِيهِمْ إِذَا هُمْ يَقْنَطُونَ","translation":"And [thus it is:] when we let men taste [Our] grace, they rejoice in it; but if evil befalls them as an outcome of what their own hands have wrought lo! they lose all hope!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3445.mp3","surahId":30,"words":[{"id":38398,"position":1,"arabic":"وَإِذَآ","translation":"এবং যখন","audioUrl":"wbw/030_036_001.mp3","charTypeName":"word"},{"id":38399,"position":2,"arabic":"أَذَقْنَا","translation":"আস্বাদন করাই আমরা","audioUrl":"wbw/030_036_002.mp3","charTypeName":"word"},{"id":38400,"position":3,"arabic":"ٱلنَّاسَ","translation":"মানুষকে","audioUrl":"wbw/030_036_003.mp3","charTypeName":"word"},{"id":38401,"position":4,"arabic":"رَحْمَةًۭ","translation":"অনুগ্রহের","audioUrl":"wbw/030_036_004.mp3","charTypeName":"word"},{"id":38402,"position":5,"arabic":"فَرِحُوا۟","translation":"ফলে তারা উৎফুল্ল হয়","audioUrl":"wbw/030_036_005.mp3","charTypeName":"word"},{"id":38403,"position":6,"arabic":"بِهَا ۖ","translation":"কারণে তার","audioUrl":"wbw/030_036_006.mp3","charTypeName":"word"},{"id":38405,"position":7,"arabic":"وَإِن","translation":"এবং যদি","audioUrl":"wbw/030_036_008.mp3","charTypeName":"word"},{"id":38406,"position":8,"arabic":"تُصِبْهُمْ","translation":"পৌঁছে তাদের","audioUrl":"wbw/030_036_009.mp3","charTypeName":"word"},{"id":38407,"position":9,"arabic":"سَيِّئَةٌۢ","translation":"কোনো দুর্দশা","audioUrl":"wbw/030_036_010.mp3","charTypeName":"word"},{"id":38408,"position":10,"arabic":"بِمَا","translation":"এ কারণে যা","audioUrl":"wbw/030_036_011.mp3","charTypeName":"word"},{"id":38409,"position":11,"arabic":"قَدَّمَتْ","translation":"আগে পাঠিয়েছে","audioUrl":"wbw/030_036_012.mp3","charTypeName":"word"},{"id":38410,"position":12,"arabic":"أَيْدِيهِمْ","translation":"হাত তাদের","audioUrl":"wbw/030_036_013.mp3","charTypeName":"word"},{"id":38411,"position":13,"arabic":"إِذَا","translation":"তখন","audioUrl":"wbw/030_036_014.mp3","charTypeName":"word"},{"id":38412,"position":14,"arabic":"هُمْ","translation":"তারা","audioUrl":"wbw/030_036_015.mp3","charTypeName":"word"},{"id":38413,"position":15,"arabic":"يَقْنَطُونَ","translation":"হতাশ হয়ে পড়ে","audioUrl":"wbw/030_036_016.mp3","charTypeName":"word"},{"id":38414,"position":16,"arabic":"٣٦","translation":"(৩৬)","audioUrl":null,"charTypeName":"end"}]},{"number":37,"arabic":"أَوَلَمْ يَرَوْا۟ أَنَّ ٱللَّهَ يَبْسُطُ ٱلرِّزْقَ لِمَن يَشَآءُ وَيَقْدِرُ ۚ إِنَّ فِى ذَٰلِكَ لَءَايَٰتٍۢ لِّقَوْمٍۢ يُؤْمِنُونَ","translation":"Are they, then, not aware that it is God who grants abundant sustenance, or gives it in scant measure, unto whomever He wills? In this, behold, there are messages indeed for peo­ple who will believe!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3446.mp3","surahId":30,"words":[{"id":39254,"position":1,"arabic":"أَوَلَمْ","translation":"কি না","audioUrl":"wbw/030_037_001.mp3","charTypeName":"word"},{"id":39255,"position":2,"arabic":"يَرَوْا۟","translation":"তারা দেখে","audioUrl":"wbw/030_037_002.mp3","charTypeName":"word"},{"id":39256,"position":3,"arabic":"أَنَّ","translation":"যে","audioUrl":"wbw/030_037_003.mp3","charTypeName":"word"},{"id":39257,"position":4,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/030_037_004.mp3","charTypeName":"word"},{"id":39258,"position":5,"arabic":"يَبْسُطُ","translation":"প্রশস্ত করে দেন","audioUrl":"wbw/030_037_005.mp3","charTypeName":"word"},{"id":39259,"position":6,"arabic":"ٱلرِّزْقَ","translation":"জীবিকা","audioUrl":"wbw/030_037_006.mp3","charTypeName":"word"},{"id":39260,"position":7,"arabic":"لِمَن","translation":"(তার) জন্যে যাকে","audioUrl":"wbw/030_037_007.mp3","charTypeName":"word"},{"id":39261,"position":8,"arabic":"يَشَآءُ","translation":"তিনি চান","audioUrl":"wbw/030_037_008.mp3","charTypeName":"word"},{"id":39262,"position":9,"arabic":"وَيَقْدِرُ ۚ","translation":"আবার সীমিতও করেন","audioUrl":"wbw/030_037_009.mp3","charTypeName":"word"},{"id":39264,"position":10,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/030_037_011.mp3","charTypeName":"word"},{"id":39265,"position":11,"arabic":"فِى","translation":"মধ্যে (রয়েছে)","audioUrl":"wbw/030_037_012.mp3","charTypeName":"word"},{"id":39266,"position":12,"arabic":"ذَٰلِكَ","translation":"এর","audioUrl":"wbw/030_037_013.mp3","charTypeName":"word"},{"id":39267,"position":13,"arabic":"لَـَٔايَـٰتٍۢ","translation":"অবশ্যই নিদর্শনাবলী","audioUrl":"wbw/030_037_014.mp3","charTypeName":"word"},{"id":39268,"position":14,"arabic":"لِّقَوْمٍۢ","translation":"জন্যে সম্প্রদায়ের","audioUrl":"wbw/030_037_015.mp3","charTypeName":"word"},{"id":39269,"position":15,"arabic":"يُؤْمِنُونَ","translation":"(যারা) ঈমান আনে","audioUrl":"wbw/030_037_016.mp3","charTypeName":"word"},{"id":39270,"position":16,"arabic":"٣٧","translation":"(৩৭)","audioUrl":null,"charTypeName":"end"}]},{"number":38,"arabic":"فَـَٔاتِ ذَا ٱلْقُرْبَىٰ حَقَّهُۥ وَٱلْمِسْكِينَ وَٱبْنَ ٱلسَّبِيلِ ۚ ذَٰلِكَ خَيْرٌۭ لِّلَّذِينَ يُرِيدُونَ وَجْهَ ٱللَّهِ ۖ وَأُو۟لَٰٓئِكَ هُمُ ٱلْمُفْلِحُونَ","translation":"Hence, give his due to the near of kin, as well as to the needy and the wayfarer; this is best for all who seek God’s countenance: for it is they, they that shall attain to a happy state!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3447.mp3","surahId":30,"words":[{"id":40081,"position":1,"arabic":"فَـَٔاتِ","translation":"অতএব দাও","audioUrl":"wbw/030_038_001.mp3","charTypeName":"word"},{"id":40082,"position":2,"arabic":"ذَا","translation":"সম্পন্নকে","audioUrl":"wbw/030_038_002.mp3","charTypeName":"word"},{"id":40083,"position":3,"arabic":"ٱلْقُرْبَىٰ","translation":"নৈকট্য  (নিকট আত্নীয়কে)","audioUrl":"wbw/030_038_003.mp3","charTypeName":"word"},{"id":40084,"position":4,"arabic":"حَقَّهُۥ","translation":"তার প্রাপ্য","audioUrl":"wbw/030_038_004.mp3","charTypeName":"word"},{"id":40085,"position":5,"arabic":"وَٱلْمِسْكِينَ","translation":"ও অভাবগ্রস্তকে","audioUrl":"wbw/030_038_005.mp3","charTypeName":"word"},{"id":40086,"position":6,"arabic":"وَٱبْنَ","translation":"ও ছেলেকে","audioUrl":"wbw/030_038_006.mp3","charTypeName":"word"},{"id":40087,"position":7,"arabic":"ٱلسَّبِيلِ ۚ","translation":"পথের (পথিককে)","audioUrl":"wbw/030_038_007.mp3","charTypeName":"word"},{"id":40089,"position":8,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/030_038_009.mp3","charTypeName":"word"},{"id":40090,"position":9,"arabic":"خَيْرٌۭ","translation":"উত্তম","audioUrl":"wbw/030_038_010.mp3","charTypeName":"word"},{"id":40091,"position":10,"arabic":"لِّلَّذِينَ","translation":"(তাদের) জন্যে যারা","audioUrl":"wbw/030_038_011.mp3","charTypeName":"word"},{"id":40092,"position":11,"arabic":"يُرِيدُونَ","translation":"তারা চায়","audioUrl":"wbw/030_038_012.mp3","charTypeName":"word"},{"id":40093,"position":12,"arabic":"وَجْهَ","translation":"চেহারা (সন্তুষ্টি)","audioUrl":"wbw/030_038_013.mp3","charTypeName":"word"},{"id":40094,"position":13,"arabic":"ٱللَّهِ ۖ","translation":"আল্লাহর","audioUrl":"wbw/030_038_014.mp3","charTypeName":"word"},{"id":40096,"position":14,"arabic":"وَأُو۟لَـٰٓئِكَ","translation":"এবং ঐ সব লোক","audioUrl":"wbw/030_038_016.mp3","charTypeName":"word"},{"id":40097,"position":15,"arabic":"هُمُ","translation":"তারাই","audioUrl":"wbw/030_038_017.mp3","charTypeName":"word"},{"id":40098,"position":16,"arabic":"ٱلْمُفْلِحُونَ","translation":"সফলকাম","audioUrl":"wbw/030_038_018.mp3","charTypeName":"word"},{"id":40099,"position":17,"arabic":"٣٨","translation":"(৩৮)","audioUrl":null,"charTypeName":"end"}]},{"number":39,"arabic":"وَمَآ ءَاتَيْتُم مِّن رِّبًۭا لِّيَرْبُوَا۟ فِىٓ أَمْوَٰلِ ٱلنَّاسِ فَلَا يَرْبُوا۟ عِندَ ٱللَّهِ ۖ وَمَآ ءَاتَيْتُم مِّن زَكَوٰةٍۢ تُرِيدُونَ وَجْهَ ٱللَّهِ فَأُو۟لَٰٓئِكَ هُمُ ٱلْمُضْعِفُونَ","translation":"And [remember:] whatever you may give out in usury so that it might increase through [other] people’s possessions will bring [you] no increase in the sight of God whereas all that you give out in charity, seeking God’s countenance, [will be blessed by Him:] for it is they, they [who thus seek His countenance] that shall have their recompense mul­tiplied!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3448.mp3","surahId":30,"words":[{"id":40833,"position":1,"arabic":"وَمَآ","translation":"এবং যা কিছু","audioUrl":"wbw/030_039_001.mp3","charTypeName":"word"},{"id":40834,"position":2,"arabic":"ءَاتَيْتُم","translation":"দিয়ে থাকো তোমরা","audioUrl":"wbw/030_039_002.mp3","charTypeName":"word"},{"id":40835,"position":3,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/030_039_003.mp3","charTypeName":"word"},{"id":40836,"position":4,"arabic":"رِّبًۭا","translation":"সূদ","audioUrl":"wbw/030_039_004.mp3","charTypeName":"word"},{"id":40837,"position":5,"arabic":"لِّيَرْبُوَا۟","translation":"যেন বৃদ্ধি পায়","audioUrl":"wbw/030_039_005.mp3","charTypeName":"word"},{"id":40838,"position":6,"arabic":"فِىٓ","translation":"মধ্যে","audioUrl":"wbw/030_039_006.mp3","charTypeName":"word"},{"id":40839,"position":7,"arabic":"أَمْوَٰلِ","translation":"ধনসম্পদের","audioUrl":"wbw/030_039_007.mp3","charTypeName":"word"},{"id":40840,"position":8,"arabic":"ٱلنَّاسِ","translation":"মানুষের","audioUrl":"wbw/030_039_008.mp3","charTypeName":"word"},{"id":40841,"position":9,"arabic":"فَلَا","translation":"প্রকৃতপক্ষে না","audioUrl":"wbw/030_039_009.mp3","charTypeName":"word"},{"id":40842,"position":10,"arabic":"يَرْبُوا۟","translation":"বৃদ্ধি পায়","audioUrl":"wbw/030_039_010.mp3","charTypeName":"word"},{"id":40843,"position":11,"arabic":"عِندَ","translation":"কাছে","audioUrl":"wbw/030_039_011.mp3","charTypeName":"word"},{"id":40844,"position":12,"arabic":"ٱللَّهِ ۖ","translation":"আল্লাহর","audioUrl":"wbw/030_039_012.mp3","charTypeName":"word"},{"id":40846,"position":13,"arabic":"وَمَآ","translation":"এবং যা কিছু","audioUrl":"wbw/030_039_014.mp3","charTypeName":"word"},{"id":40847,"position":