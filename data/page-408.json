","charTypeName":"word"},{"id":41385,"position":17,"arabic":"مِّن","translation":"কোনো","audioUrl":"wbw/030_040_018.mp3","charTypeName":"word"},{"id":41386,"position":18,"arabic":"شَىْءٍۢ ۚ","translation":"কিছু","audioUrl":"wbw/030_040_019.mp3","charTypeName":"word"},{"id":41388,"position":19,"arabic":"سُبْحَـٰنَهُۥ","translation":"তিনি পবিত্র মহান","audioUrl":"wbw/030_040_021.mp3","charTypeName":"word"},{"id":41389,"position":20,"arabic":"وَتَعَـٰلَىٰ","translation":"এবং অনেক উর্দ্ধে","audioUrl":"wbw/030_040_022.mp3","charTypeName":"word"},{"id":41390,"position":21,"arabic":"عَمَّا","translation":"(তা) হ'তে যা","audioUrl":"wbw/030_040_023.mp3","charTypeName":"word"},{"id":41391,"position":22,"arabic":"يُشْرِكُونَ","translation":"তারা শিরক করে","audioUrl":"wbw/030_040_024.mp3","charTypeName":"word"},{"id":41392,"position":23,"arabic":"٤٠","translation":"(৪০)","audioUrl":null,"charTypeName":"end"}]},{"number":41,"arabic":"ظَهَرَ ٱلْفَسَادُ فِى ٱلْبَرِّ وَٱلْبَحْرِ بِمَا كَسَبَتْ أَيْدِى ٱلنَّاسِ لِيُذِيقَهُم بَعْضَ ٱلَّذِى عَمِلُوا۟ لَعَلَّهُمْ يَرْجِعُونَ","translation":"[Since they have become oblivious of God,] corruption has appeared on land and in the sea as an outcome of what men’s hands have wrought: and so He will let them taste [the evil of] some of their doings, so that they might return [to the right path].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3450.mp3","surahId":30,"words":[{"id":42517,"position":1,"arabic":"ظَهَرَ","translation":"ছড়িয়ে পড়েছে","audioUrl":"wbw/030_041_001.mp3","charTypeName":"word"},{"id":42518,"position":2,"arabic":"ٱلْفَسَادُ","translation":"বিপর্যয়","audioUrl":"wbw/030_041_002.mp3","charTypeName":"word"},{"id":42519,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/030_041_003.mp3","charTypeName":"word"},{"id":42520,"position":4,"arabic":"ٱلْبَرِّ","translation":"স্থলের (স্হলভাগে)","audioUrl":"wbw/030_041_004.mp3","charTypeName":"word"},{"id":42521,"position":5,"arabic":"وَٱلْبَحْرِ","translat