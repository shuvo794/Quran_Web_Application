-স্বজনরা","audioUrl":"wbw/004_008_004.mp3","charTypeName":"word"},{"id":8522,"position":5,"arabic":"ٱلْقُرْبَىٰ","translation":"দুর আত্মীয় -স্বজনরা","audioUrl":"wbw/004_008_005.mp3","charTypeName":"word"},{"id":8523,"position":6,"arabic":"وَٱلْيَتَـٰمَىٰ","translation":"ও ইয়াতীমরা","audioUrl":"wbw/004_008_006.mp3","charTypeName":"word"},{"id":8524,"position":7,"arabic":"وَٱلْمَسَـٰكِينُ","translation":"ও দরিদ্ররা","audioUrl":"wbw/004_008_007.mp3","charTypeName":"word"},{"id":8525,"position":8,"arabic":"فَٱرْزُقُوهُم","translation":"সেক্ষেত্রে তাদের দান কর","audioUrl":"wbw/004_008_008.mp3","charTypeName":"word"},{"id":8526,"position":9,"arabic":"مِّنْهُ","translation":"তা হতে","audioUrl":"wbw/004_008_009.mp3","charTypeName":"word"},{"id":8527,"position":10,"arabic":"وَقُولُوا۟","translation":"এবং তোমরা বল","audioUrl":"wbw/004_008_010.mp3","charTypeName":"word"},{"id":8528,"position":11,"arabic":"لَهُمْ","translation":"তাদের","audioUrl":"wbw/004_008_011.mp3","charTypeName":"word"},{"id":8529,"position":12,"arabic":"قَوْلًۭا","translation":"কথা","audioUrl":"wbw/004_008_012.mp3","charTypeName":"word"},{"id":8530,"position":13,"arabic":"مَّعْرُوفًۭا","translation":"সদ্ভাবে","audioUrl":"wbw/004_008_013.mp3","charTypeName":"word"},{"id":8531,"position":14,"arabic":"٨","translation":"(৮)","audioUrl":null,"charTypeName":"end"}]},{"number":9,"arabic":"وَلْيَخْشَ ٱلَّذِينَ لَوْ تَرَكُوا۟ مِنْ خَلْفِهِمْ ذُرِّيَّةًۭ ضِعَٰفًا خَافُوا۟ عَلَيْهِمْ فَلْيَتَّقُوا۟ ٱللَّهَ وَلْيَقُولُوا۟ قَوْلًۭا سَدِيدًا","translation":"And let them stand in awe [of God], those [legal heirs] - who, if they [themselves] had to leave behind weak offspring, would feel fear on their account - and let them remain conscious of God, and let them speak [to the poor] in a just manner.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/502.mp3","surahId":4,"words":[{"id":9720,"position":1,"arabic":"وَلْيَخْشَ","translation":"এবং ভয় করুক","audioUrl":"wbw/004_009_001.mp3","charTypeName":"word"},{"id":9721,"position":2,"arabic":"ٱلَّذِينَ","translation":"তারা","audioUrl":"wbw/004_009_002.mp3","charTypeName":"word"},{"id":9722,"position":3,"arabic":"لَوْ","translation":"যদি","audioUrl":"wbw/004_009_003.mp3","charTypeName":"word"},{"id":9723,"position":4,"arabic":"تَرَكُوا۟","translation":"ছেড়ে যায়","audioUrl":"wbw/004_009_004.mp3","charTypeName":"word"},{"id":9724,"position":5,"arabic":"مِنْ","translation":"(থেকে)","audioUrl":"wbw/004_009_005.mp3","charTypeName":"word"},{"id":9725,"position":6,"arabic":"خَلْفِهِمْ","translation":"তাদের পিছনে","audioUrl":"wbw/004_009_006.mp3","charTypeName":"word"},{"id":9726,"position":7,"arabic":"ذُرِّيَّةًۭ","translation":"সন্তান","audioUrl":"wbw/004_009_007.mp3","charTypeName":"word"},{"id":9727,"position":8,"arabic":"ضِعَـٰفًا","translation":"অসহায় অবস্থায়","audioUrl":"wbw/004_009_008.mp3","charTypeName":"word"},{"id":9728,"position":9,"arabic":"خَافُوا۟","translation":"তারা ভয় পায়","audioUrl":"wbw/004_009_009.mp3","charTypeName":"word"},{"id":9729,"position":10,"arabic":"عَلَيْهِمْ","translation":"তাদের জন্য","audioUrl":"wbw/004_009_010.mp3","charTypeName":"word"},{"id":9730,"position":11,"arabic":"فَلْيَتَّقُوا۟","translation":"তারা অতএব ভয় করে যেন","audioUrl":"wbw/004_009_011.mp3","charTypeName":"word"},{"id":9731,"position":12,"arabic":"ٱللَّهَ","translation":"আল্লাহকে","audioUrl":"wbw/004_009_012.mp3","charTypeName":"word"},{"id":9732,"position":13,"arabic":"وَلْيَقُولُوا۟","translation":"এবং তারা যেন বলে","audioUrl":"wbw/004_009_013.mp3","charTypeName":"word"},{"id":9733,"position":14,"arabic":"قَوْلًۭا","translation":"কথা","audioUrl":"wbw/004_009_014.mp3","charTypeName":"word"},{"id":9734,"position":15,"arabic":"سَدِيدًا","translation":"সঠিক","audioUrl":"wbw/004_009_015.mp3","charTypeName":"word"},{"id":9735,"position":16,"arabic":"٩","translation":"(৯)","audioUrl":null,"charTypeName":"end"}]},{"number":10,"arabic":"إِنَّ ٱلَّذِينَ يَأْكُلُونَ أَمْوَٰلَ ٱلْيَتَٰمَىٰ ظُلْمًا إِنَّمَا يَأْكُلُونَ فِى بُطُونِهِمْ نَارًۭا ۖ وَسَيَصْلَوْنَ سَعِيرًۭا","translation":"Behold, those who sinfully devour the posses­sions of orphans but fill their bellies with fire: for [in the life to come] they will have to endure a blazing flame!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/503.mp3","surahId":4,"words":[{"id":10855,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/004_010_001.mp3","charTypeName":"word"},{"id":10856,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/004_010_002.mp3","charTypeName":"word"},{"id":10857,"position":3,"arabic":"يَأْكُلُونَ","translation":"খায়","audioUrl":"wbw/004_010_003.mp3","charTypeName":"word"},{"id":10858,"position":4,"arabic":"أَمْوَٰلَ","translation":"মালসমূহ","audioUrl":"wbw/004_010_004.mp3","charTypeName":"word"},{"id":10859,"position":5,"arabic":"ٱلْيَتَـٰمَىٰ","translation":"ইয়াতীমদের","audioUrl":"wbw/004_010_005.mp3","charTypeName":"word"},{"id":10860,"position":6,"arabic":"ظُلْمًا","translation":"অন্যায়ভাবে","audioUrl":"wbw/004_010_006.mp3","charTypeName":"word"},{"id":10861,"position":7,"arabic":"إِنَّمَا","translation":"মূলত","audioUrl":"wbw/004_010_007.mp3","charTypeName":"word"},{"id":10862,"position":8,"arabic":"يَأْكُلُونَ","translation":"তারা খায়","audioUrl":"wbw/004_010_008.mp3","charTypeName":"word"},{"id":10863,"position":9,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/004_010_009.mp3","charTypeName":"word"},{"id":10864,"position":10,"arabic":"بُطُونِهِمْ","translation":"তাদের পেটগুলোর","audioUrl":"wbw/004_010_010.mp3","charTypeName":"word"},{"id":10865,"position":11,"arabic":"نَارًۭا ۖ","translation":"আগুন","audioUrl":"wbw/004_010_011.mp3","charTypeName":"word"},{"id":10867,"position":12,"arabic":"وَسَيَصْلَوْنَ","translation":"এবং জ্বলবে","audioUrl":"wbw/004_010_013.mp3","charTypeName":"word"},{"id":10868,"position":13,"arabic":"سَعِيرًۭا","translation":"আগুনে","audioUrl":"wbw/004_010_014.mp3","charTypeName":"word"},{"id":10869,"position":14,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"يُوصِيكُمُ ٱللَّهُ فِىٓ أَوْلَٰدِكُمْ ۖ لِلذَّكَرِ مِثْلُ حَظِّ ٱلْأُنثَيَيْنِ ۚ فَإِن كُنَّ نِسَآءًۭ فَوْقَ ٱثْنَتَيْنِ فَلَهُنَّ ثُلُثَا مَا تَرَكَ ۖ وَإِن كَانَتْ وَٰحِدَةًۭ فَلَهَا ٱلنِّصْفُ ۚ وَلِأَبَوَيْهِ لِكُلِّ وَٰحِدٍۢ مِّنْهُمَا ٱلسُّدُسُ مِمَّا تَرَكَ إِن كَانَ لَهُۥ وَلَدٌۭ ۚ فَإِن لَّمْ يَكُن لَّهُۥ وَلَدٌۭ وَوَرِثَهُۥٓ أَبَوَاهُ فَلِأُمِّهِ ٱلثُّلُثُ ۚ فَإِن كَانَ لَهُۥٓ إِخْوَةٌۭ فَلِأُمِّهِ ٱلسُّدُسُ ۚ مِنۢ بَعْدِ وَصِيَّةٍۢ يُوصِى بِهَآ أَوْ دَيْنٍ ۗ ءَابَآؤُكُمْ وَأَبْنَآؤُكُمْ لَا تَدْرُونَ أَيُّهُمْ أَقْرَبُ لَكُمْ نَفْعًۭا ۚ فَرِيضَةًۭ مِّنَ ٱللَّهِ ۗ إِنَّ ٱللَّهَ كَانَ عَلِيمًا حَكِيمًۭا","translation":"CONCERNING [the inheritance of] your children, God enjoins [this] upon you: The male shall have the equal of two females’ share; but if there are more than two females, they shall have two-thirds of what [their parents] leave behind; and if there is only one daughter, she shall have one-half thereof. And as for the parents [of the deceased], each of them shall have one-sixth of what he leaves behind, in the event of his having [left] a child; but if he has left no child and his parents are his [only] heirs, then his mother shall have one-third; and if he has brothers and sisters, then his mother shall have one-sixth after [the deduction of] any bequest he may have made, or any debt [he may have incurred]. As for your parents and your children - you know not which of them is more deserving of benefit from you: [therefore this] ordinance from God. Verily, God is all-knowing, wise.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/504.mp3","surahId":4,"words":[{"id":12105,"position":1,"arabic":"يُوصِيكُمُ","translation":"তোমাদের নির্দেশ দিচ্ছেন","audioUrl":"wbw/004_011_001.mp3","charTypeName":"word"},{"id":12106,"position":2,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/004_011_002.mp3","charTypeName":"word"},{"id":12107,"position":3,"arabic":"فِىٓ","translation":"সম্বন্ধে","audioUrl":"wbw/004_011_003.mp3","charTypeName":"word"},{"id":12108,"position":4,"arabic":"أَوْلَـٰدِكُمْ ۖ","translation":"তোমাদের সন্তানদের","audioUrl":"wbw/004_011_004.mp3","charTypeName":"word"},{"id":12110,"position":5,"arabic":"لِلذَّكَرِ","translation":"এক পুত্রের জন্য","audioUrl":"wbw/004_011_006.mp3","charTypeName":"word"},{"id":12111,"position":6,"arabic":"مِثْلُ","translation":"বরাবর","audioUrl":"wbw/004_011_007.mp3","charTypeName":"word"},{"id":12112,"position":7,"arabic":"حَظِّ","translation":"অংশ","audioUrl":"wbw/004_011_008.mp3","charTypeName":"word"},{"id":12113,"position":8,"arabic":"ٱلْأُنثَيَيْنِ ۚ","translation":"দুই কন্যার","audioUrl":"wbw/004_011_009.mp3","charTypeName":"word"},{"id":12115,"position":9,"arabic":"فَإِن","translation":"যদি অতএব","audioUrl":"wbw/004_011_011.mp3","charTypeName":"word"},{"id":12116,"position":10,"arabic":"كُنَّ","translation":"তারা হয়","audioUrl":"wbw/004_011_012.mp3","charTypeName":"word"},{"id":12117,"position":11,"arabic":"نِسَآءًۭ","translation":"কন্যা","audioUrl":"wbw/004_011_013.mp3","charTypeName":"word"},{"id":12118,"position":12,"arabic":"فَوْقَ","translation":"উর্ধ্বে","audioUrl":"wbw/004_011_014.mp3","charTypeName":"word"},{"id":12119,"position":13,"arabic":"ٱثْنَتَيْنِ","translation":"দুই এর","audioUrl":"wbw/004_011_015.mp3","charTypeName":"word"},{"id":12120,"position":14,"arabic":"فَلَهُنَّ","translation":"তবে তাদের জন্য","audioUrl":"wbw/004_011_016.mp3","charTypeName":"word"},{"id":12121,"position":15,"arabic":"ثُلُثَا","translation":"দুই-তৃতীয়াংশ","audioUrl":"wbw/004_011_017.mp3","charTypeName":"word"},{"id":12122,"position":16,"arabic":"مَا","translation":"যা","audioUrl":"wbw/004_011_018.mp3","charTypeName":"word"},{"id":12123,"position":17,"arabic":"تَرَكَ ۖ","translation":"ছেড়ে গিয়েছে","audioUrl":"wbw/004_011_019.mp3","charTypeName":"word"},{"id":12125,"position":18,"arabic":"وَإِن","translation":"এবং যদি","audioUrl":"wbw/004_011_021.mp3","charTypeName":"word"},{"id"