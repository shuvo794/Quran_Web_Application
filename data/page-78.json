{"id":78,"ayahs":[{"number":7,"arabic":"لِّلرِّجَالِ نَصِيبٌۭ مِّمَّا تَرَكَ ٱلْوَٰلِدَانِ وَٱلْأَقْرَبُونَ وَلِلنِّسَآءِ نَصِيبٌۭ مِّمَّا تَرَكَ ٱلْوَٰلِدَانِ وَٱلْأَقْرَبُونَ مِمَّا قَلَّ مِنْهُ أَوْ كَثُرَ ۚ نَصِيبًۭا مَّفْرُوضًۭا","translation":"MEN SHALL have a share in what parents and kinsfolk leave behind, and women shall have a share in what parents and kinsfolk leave behind, whether it be little or much - a share ordained [by God].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/500.mp3","surahId":4,"words":[{"id":7204,"position":1,"arabic":"لِّلرِّجَالِ","translation":"পুরুষদের জন্য","audioUrl":"wbw/004_007_001.mp3","charTypeName":"word"},{"id":7205,"position":2,"arabic":"نَصِيبٌۭ","translation":"অংশ","audioUrl":"wbw/004_007_002.mp3","charTypeName":"word"},{"id":7206,"position":3,"arabic":"مِّمَّا","translation":"তা হতে যা","audioUrl":"wbw/004_007_003.mp3","charTypeName":"word"},{"id":7207,"position":4,"arabic":"تَرَكَ","translation":"ছেড়ে গেছে (সম্পত্তি)","audioUrl":"wbw/004_007_004.mp3","charTypeName":"word"},{"id":7208,"position":5,"arabic":"ٱلْوَٰلِدَانِ","translation":"পিতা-মাতা","audioUrl":"wbw/004_007_005.mp3","charTypeName":"word"},{"id":7209,"position":6,"arabic":"وَٱلْأَقْرَبُونَ","translation":"ও আত্মীয়-স্বজনরা","audioUrl":"wbw/004_007_006.mp3","charTypeName":"word"},{"id":7210,"position":7,"arabic":"وَلِلنِّسَآءِ","translation":"এবং নারীদের জন্য","audioUrl":"wbw/004_007_007.mp3","charTypeName":"word"},{"id":7211,"position":8,"arabic":"نَصِيبٌۭ","translation":"অংশ","audioUrl":"wbw/004_007_008.mp3","charTypeName":"word"},{"id":7212,"position":9,"arabic":"مِّمَّا","translation":"তা হতে যা","audioUrl":"wbw/004_007_009.mp3","charTypeName":"word"},{"id":7213,"position":10,"arabic":"تَرَكَ","translation":"ছেড়ে গেছে (সম্পত্তি)","audioUrl":"wbw/004_007_010.mp3","charTypeName":"word"},{"id":7214,"position":11,"arabic":"ٱلْوَٰلِدَانِ","translation":"পিতা-মাতা","audioUrl":"wbw/004_007_011.mp3","charTypeName":"word"},{"id":7215,"position