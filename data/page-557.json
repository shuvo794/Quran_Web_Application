charTypeName":"word"},{"id":14026,"position":9,"arabic":"رَسُولِنَا","translation":"আমাদের রাসূলের","audioUrl":"wbw/064_012_010.mp3","charTypeName":"word"},{"id":14027,"position":10,"arabic":"ٱلْبَلَـٰغُ","translation":"পৌঁছান (দায়িত্ব)","audioUrl":"wbw/064_012_011.mp3","charTypeName":"word"},{"id":14028,"position":11,"arabic":"ٱلْمُبِينُ","translation":"সুস্পষ্টভাবে","audioUrl":"wbw/064_012_012.mp3","charTypeName":"word"},{"id":14029,"position":12,"arabic":"١٢","translation":"(১২)","audioUrl":null,"charTypeName":"end"}]},{"number":13,"arabic":"ٱللَّهُ لَآ إِلَٰهَ إِلَّا هُوَ ۚ وَعَلَى ٱللَّهِ فَلْيَتَوَكَّلِ ٱلْمُؤْمِنُونَ","translation":"God - there is no deity save Him! In God then let the believers place their trust.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5212.mp3","surahId":64,"words":[{"id":15169,"position":1,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌","audioUrl":"wbw/064_013_001.mp3","charTypeName":"word"},{"id":15170,"position":2,"arabic":"لَآ","translation":"নেই","audioUrl":"wbw/064_013_002.mp3","charTypeName":"word"},{"id":15171,"position":3,"arabic":"إِلَـٰهَ","translation":"ইলাহ","audioUrl":"wbw/064_013_003.mp3","charTypeName":"word"},{"id":15172,"position":4,"arabic":"إِلَّا","translation":"ছাড়া","audioUrl":"wbw/064_013_004.mp3","charTypeName":"word"},{"id":15173,"position":5,"arabic":"هُوَ ۚ","translation":"তিনি","audioUrl":"wbw/064_013_005.mp3","charTypeName":"word"},{"id":15175,"position":6,"arabic":"وَعَلَى","translation":"এবং উপর","audioUrl":"wbw/064_013_007.mp3","charTypeName":"word"},{"id":15176,"position":7,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌র","audioUrl":"wbw/064_013_008.mp3","charTypeName":"word"},{"id":15177,"position":8,"arabic":"فَلْيَتَوَكَّلِ","translation":"সুতরাং ভরসা করুক","audioUrl":"wbw/064_013_009.mp3","charTypeName":"word"},{"id":15178,"position":9,"arabic":"ٱلْمُؤْمِنُونَ","translation":"মু'মিনগণ","audioUrl":"wbw/064_013_010.mp3","charTypeName":"word"},{"id":15179,"position":10,"arabic":"١٣","translation":"(১৩)","audioUrl":null,"charTypeName":"end"}]},{"number":14,"arabic":"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوٓا۟ إِنَّ مِنْ أَزْوَٰجِكُمْ وَأَوْلَٰدِكُمْ عَدُوًّۭا لَّكُمْ فَٱحْذَرُوهُمْ ۚ وَإِن تَعْفُوا۟ وَتَصْفَحُوا۟ وَتَغْفِرُوا۟ فَإِنَّ ٱللَّهَ غَفُورٌۭ رَّحِيمٌ","translation":"O YOU who have attained to faith! Behold, some of your spouses and your children are enemies unto you: so beware of them! But if you pardon [their faults] and forbear, and forgive-then, behold, God will be much-forgiving, a dispenser of grace.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5213.mp3","surahId":64,"words":[{"id":16210,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"ওহে","audioUrl":"wbw/064_014_001.mp3","charTypeName":"word"},{"id":16211,"position":2,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/064_014_002.mp3","charTypeName":"word"},{"id":16212,"position":3,"arabic":"ءَامَنُوٓا۟","translation":"ঈমান এনেছো","audioUrl":"wbw/064_014_003.mp3","charTypeName":"word"},{"id":16213,"position":4,"arabic":"إِنَّ","translation":"নিশ্চয়","audioUrl":"wbw/064_014_004.mp3","charTypeName":"word"},{"id":16214,"position":5,"arabic":"مِنْ","translation":"মধ্যে","audioUrl":"wbw/064_014_005.mp3","charTypeName":"word"},{"id":16215,"position":6,"arabic":"أَزْوَٰجِكُمْ","translation":"তোমাদের স্ত্রীদের","audioUrl":"wbw/064_014_006.mp3","charTypeName":"word"},{"id":16216,"position":7,"arabic":"وَأَوْلَـٰدِكُمْ","translation":"ও তোমাদের সন্তান সন্ততিদের (কেউ কেউ)","audioUrl":"wbw/064_014_007.mp3","charTypeName":"word"},{"id":16217,"position":8,"arabic":"عَدُوًّۭا","translation":"শত্রু","audioUrl":"wbw/064_014_008.mp3","charTypeName":"word"},{"id":16218,"position":9,"arabic":"لَّكُمْ","translation":"তোমাদের জন্যে","audioUrl":"wbw/064_014_009.mp3","charTypeName":"word"},{"id":16219,"position":10,"arabic":"فَٱحْذَرُوهُمْ ۚ","translation":"অতএব তাদের থেকে সতর্ক হও","audioUrl":"wbw/064_014_010.mp3","charTypeName":"word"},{"id":16221,"position":11,"arabic":"وَإِن","translation":"এবং যদি","audioUrl":"wbw/064_014_012.mp3","charTypeName":"word"},{"id":16222,"position":12,"arabic":"تَعْفُوا۟","translation":"তোমরা মার্জনা কর","audioUrl":"wbw/064_014_013.mp3","charTypeName":"word"},{"id":16223,"position":13,"arabic":"وَتَصْفَحُوا۟","translation":"ও তোমরা উপেক্ষা কর","audioUrl":"wbw/064_014_014.mp3","charTypeName":"word"},{"id":16224,"position":14,"arabic":"وَتَغْفِرُوا۟","translation":"এবং তোমরা মাফ কর","audioUrl":"wbw/064_014_015.mp3","charTypeName":"word"},{"id":16225,"position":15,"arabic":"فَإِنَّ","translation":"তবে নিশ্চয়","audioUrl":"wbw/064_014_016.mp3","charTypeName":"word"},{"id":16226,"position":16,"arabic":"ٱللَّهَ","translation":"আল্লাহ্‌","audioUrl":"wbw/064_014_017.mp3","charTypeName":"word"},{"id":16227,"position":17,"arabic":"غَفُورٌۭ","translation":"ক্ষমাশীল","audioUrl":"wbw/064_014_018.mp3","charTypeName":"word"},{"id":16228,"position":18,"arabic":"رَّحِيمٌ","translation":"মেহেরবান","audioUrl":"wbw/064_014_019.mp3","charTypeName":"word"},{"id":16229,"position":19,"arabic":"١٤","translation":"(১৪)","audioUrl":null,"charTypeName":"end"}]},{"number":15,"arabic":"إِنَّمَآ أَمْوَٰلُكُمْ وَأَوْلَٰدُكُمْ فِتْنَةٌۭ ۚ وَٱللَّهُ عِندَهُۥٓ أَجْرٌ عَظِيمٌۭ","translation":"Your worldly goods and your children are but a trial and a temptation, whereas with God there is a tremendous reward.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5214.mp3","surahId":64,"words":[{"id":17379,"position":1,"arabic":"إِنَّمَآ","translation":"মূলতঃ","audioUrl":"wbw/064_015_001.mp3","charTypeName":"word"},{"id":17380,"position":2,"arabic":"أَمْوَٰلُكُمْ","translation":"তোমাদের মালগুলো","audioUrl":"wbw/064_015_002.mp3","charTypeName":"word"},{"id":17381,"position":3,"arabic":"وَأَوْلَـٰدُكُمْ","translation":"ও তোমাদের সন্তান সন্ততিরা","audioUrl":"wbw/064_015_003.mp3","charTypeName":"word"},{"id":17382,"position":4,"arabic":"فِتْنَةٌۭ ۚ","translation":"পরীক্ষা","audioUrl":"wbw/064_015_004.mp3","charTypeName":"word"},{"id":17384,"position":5,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ্‌","audioUrl":"wbw/064_015_006.mp3","charTypeName":"word"},{"id":17385,"position":6,"arabic":"عِندَهُۥٓ","translation":"তাঁর কাছে (আছে)","audioUrl":"wbw/064_015_007.mp3","charTypeName":"word"},{"id":17386,"position":7,"arabic":"أَجْرٌ","translation":"প্রতিফল","audioUrl":"wbw/064_015_008.mp3","charTypeName":"word"},{"id":17387,"position":8,"arabic":"عَظِيمٌۭ","translation":"বড়","audioUrl":"wbw/064_015_009.mp3","charTypeName":"word"},{"id":17388,"position":9,"arabic":"١٥","translation":"(১৫)","audioUrl":null,"charTypeName":"end"}]},{"number":16,"arabic":"فَٱتَّقُوا۟ ٱللَّهَ مَا ٱسْتَطَعْتُمْ وَٱسْمَعُوا۟ وَأَطِيعُوا۟ وَأَنفِقُوا۟ خَيْرًۭا لِّأَنفُسِكُمْ ۗ وَمَن يُوقَ شُحَّ نَفْسِهِۦ فَأُو۟لَٰٓئِكَ هُمُ ٱلْمُفْلِحُونَ","translation":"Remain, then, conscious of God as best you can, and listen [to Him], and pay heed. And spend in charity for the good of your own selves: for, such as from their own covetousness are saved – it is they, they that shall attain to a happy state!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5215.mp3","surahId":64,"words":[{"id":18461,"position":1,"arabic":"فَٱتَّقُوا۟","translation":"অতএব তোমরা ভয় করো","audioUrl":"wbw/064_016_001.mp3","charTypeName":"word"},{"id":18462,"position":2,"arabic":"ٱللَّهَ","translation":"আল্লাহকে","audioUrl":"wbw/064_016_002.mp3","charTypeName":"word"},{"id":18463,"position":3,"arabic":"مَا","translation":"যতটা","audioUrl":"wbw/064_016_003.mp3","charTypeName":"word"},{"id":18464,"position":4,"arabic":"ٱسْتَطَعْتُمْ","translation":"তোমরা পারো","audioUrl":"wbw/064_016_004.mp3","charTypeName":"word"},{"id":18465,"position":5,"arabic":"وَٱسْمَعُوا۟","translation":"ও তোমরা শুনো","audioUrl":"wbw/064_016_005.mp3","charTypeName":"word"},{"id":18466,"position":6,"arabic":"وَأَطِيعُوا۟","translation":"ও তোমরা আনুগত্য করো","audioUrl":"wbw/064_016_006.mp3","charTypeName":"word"},{"id":18467,"position":7,"arabic":"وَأَنفِقُوا۟","translation":"তোমরা খরচ