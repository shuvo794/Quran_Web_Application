{"id":557,"ayahs":[{"number":10,"arabic":"وَٱلَّذِينَ كَفَرُوا۟ وَكَذَّبُوا۟ بِـَٔايَٰتِنَآ أُو۟لَٰٓئِكَ أَصْحَٰبُ ٱلنَّارِ خَٰلِدِينَ فِيهَا ۖ وَبِئْسَ ٱلْمَصِيرُ","translation":"But as for those who are bent on denying the truth and on giving the lie to Our messages - they are destined for the fire, therein to abide: and how vile a journey’s end!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5209.mp3","surahId":64,"words":[{"id":11426,"position":1,"arabic":"وَٱلَّذِينَ","translation":"এবং যারা","audioUrl":"wbw/064_010_001.mp3","charTypeName":"word"},{"id":11427,"position":2,"arabic":"كَفَرُوا۟","translation":"কুফরি করেছে","audioUrl":"wbw/064_010_002.mp3","charTypeName":"word"},{"id":11428,"position":3,"arabic":"وَكَذَّبُوا۟","translation":"ও মিথ্যারোপ করেছে","audioUrl":"wbw/064_010_003.mp3","charTypeName":"word"},{"id":11429,"position":4,"arabic":"بِـَٔايَـٰتِنَآ","translation":"আমাদের আয়াত গুলোকে","audioUrl":"wbw/064_010_004.mp3","charTypeName":"word"},{"id":11430,"position":5,"arabic":"أُو۟لَـٰٓئِكَ","translation":"ঐসব লোক","audioUrl":"wbw/064_010_005.mp3","charTypeName":"word"},{"id":11431,"position":6,"arabic":"أَصْحَـٰبُ","translation":"অধিবাসী","audioUrl":"wbw/064_010_006.mp3","charTypeName":"word"},{"id":11432,"position":7,"arabic":"ٱلنَّارِ","translation":"দোজখের","audioUrl":"wbw/064_010_007.mp3","charTypeName":"word"},{"id":11433,"position":8,"arabic":"خَـٰلِدِينَ","translation":"বসবাসকারী স্থায়ী","audioUrl":"wbw/064_010_008.mp3","charTypeName":"word"},{"id":11434,"position":9,"arabic":"فِيهَا ۖ","translation":"তার মধ্যে","audioUrl":"wbw/064_010_009.mp3","charTypeName":"word"},{"id":11436,"position":10,"arabic":"وَبِئْسَ","translation":"এবং কত নিকৃষ্ট","audioUrl":"wbw/064_010_011.mp3","charTypeName":"word"},{"id":11437,"position":11,"arabic":"ٱلْمَصِيرُ","translation":"প্রত্যাবর্তন স্থল","audioUrl":"wbw/064_010_012.mp3","charTypeName":"word"},{"id":11438,"position":12,"arabic":"١٠","translation":"(১০)","audioUrl":null,"charTypeName":"end"}]},{"number":11,"arabic":"مَآ أَصَابَ مِن مُّصِيبَةٍ إِلَّا بِإِذْنِ ٱللَّهِ ۗ وَمَن يُؤْمِنۢ بِٱللَّهِ يَهْدِ قَلْبَهُۥ ۚ وَٱللَّهُ بِكُلِّ شَىْءٍ عَلِيمٌۭ","translation":"NO CALAMITY can ever befall [man] unless it be by God's leave: hence, whoever believes in God guides his [own] heart [towards this truth]; and God has full knowledge of everything.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/5210.mp3","surahId":64,"words":[{"id":12714,"position":1,"arabic":"مَآ","translation":"না","audioUrl":"wbw/064_011_001.mp3","charTypeName":"word"},{"id":12715,"position":2,"arabic":"أَصَابَ","translation":"আপতিত হয়","audioUrl":"wbw/064_011_002.mp3","charTypeName":"word"},{"id":12716,"position":3,"arabic":"مِن","translation":"কোন","audioUrl":"wbw/064_011_003.mp3","charTypeName":"word"},{"id":12717,"position":4,"arabic":"مُّصِيبَةٍ","translation":"মুসিবত","audioUrl":"wbw/064_011_004.mp3","charTypeName":"word"},{"id":12718,"position":5,"arabic":"إِلَّا","translation":"ব্যতিরেকে","audioUrl":"wbw/064_011_005.mp3","charTypeName":"word"},{"id":12719,"position":6,"arabic":"بِإِذْنِ","translation":"অনুমতি","audioUrl":"wbw/064_011_006.mp3","charTypeName":"word"},{"id":12720,"position":7,"arabic":"ٱللَّهِ ۗ","translation":"আল্লাহ্‌র","audioUrl":"wbw/064_011_007.mp3","charTypeName":"word"},{"id":12722,"position":8,"arabic":"وَمَن","translation":"এবং যে","audioUrl":"wbw/064_011_009.mp3","charTypeName":"word"},{"id":12723,"position":9,"arabic":"يُؤْمِنۢ","translation":"ঈমান আনে","audioUrl":"wbw/064_011_010.mp3","charTypeName":"word"},{"id":12724,"position":10,"arabic":"بِٱللَّهِ","translation":"আল্লাহ্‌র উপরে","audioUrl":"wbw/064_011_011.mp3","charTypeName":"word"},{"id":12725,"position":11,"arabic":"يَهْدِ","translation":"হেদায়াত দেন তিনি","audioUrl":"wbw/064_011_012.mp3","charTypeName":"word"},{"id":12726,"position":12,"arabic":"قَلْبَهُۥ ۚ","translation":"তার অন্তরকে","audioUrl":"wbw/064_011_013.mp3","charTypeName":"word"},{"id":12728,"position":13,"arabic":"