{"id":387,"ayahs":[{"number":14,"arabic":"وَلَمَّا بَلَغَ أَشُدَّهُۥ وَٱسْتَوَىٰٓ ءَاتَيْنَٰهُ حُكْمًۭا وَعِلْمًۭا ۚ وَكَذَٰلِكَ نَجْزِى ٱلْمُحْسِنِينَ","translation":"Now when [Moses] reached full manhood and had become mature [of mind]. We bestowed upon him the ability to judge [between right and wrong] as well as [innate] knowledge: for thus do We reward the doers of good.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3266.mp3","surahId":28,"words":[{"id":16505,"position":1,"arabic":"وَلَمَّا","translation":"এবং যখন","audioUrl":"wbw/028_014_001.mp3","charTypeName":"word"},{"id":16506,"position":2,"arabic":"بَلَغَ","translation":"সে পৌঁছে","audioUrl":"wbw/028_014_002.mp3","charTypeName":"word"},{"id":16507,"position":3,"arabic":"أَشُدَّهُۥ","translation":"পূর্ণ যৌবনে তার","audioUrl":"wbw/028_014_003.mp3","charTypeName":"word"},{"id":16508,"position":4,"arabic":"وَٱسْتَوَىٰٓ","translation":"ও পরিণত বয়স্ক হলো","audioUrl":"wbw/028_014_004.mp3","charTypeName":"word"},{"id":16509,"position":5,"arabic":"ءَاتَيْنَـٰهُ","translation":"আমরা দান করলাম তাকে","audioUrl":"wbw/028_014_005.mp3","charTypeName":"word"},{"id":16510,"position":6,"arabic":"حُكْمًۭا","translation":"প্রজ্ঞা","audioUrl":"wbw/028_014_006.mp3","charTypeName":"word"},{"id":16511,"position":7,"arabic":"وَعِلْمًۭا ۚ","translation":"ও জ্ঞান","audioUrl":"wbw/028_014_007.mp3","charTypeName":"word"},{"id":16513,"position":8,"arabic":"وَكَذَٰلِكَ","translation":"এবং এভাবে","audioUrl":"wbw/028_014_009.mp3","charTypeName":"word"},{"id":16514,"position":9,"arabic":"نَجْزِى","translation":"আমরা পুরস্কার দিই","audioUrl":"wbw/028_014_010.mp3","charTypeName":"word"},{"id":16515,"position":10,"arabic":"ٱلْمُحْسِنِينَ","translation":"সৎকর্মশীলদেরকে","audioUrl":"wbw/028_014_011.mp3","charTypeName":"word"},{"id":16516,"position":11,"arabic":"١٤","translation":"(১৪)","audioUrl":null,"charTypeName":"end"}]},{"number":15,"arabic":"وَدَخَلَ ٱلْمَدِينَةَ عَلَىٰ حِينِ غَفْلَةٍۢ مِّنْ أَهْلِهَا فَوَجَدَ فِيهَا رَجُلَيْنِ يَقْتَتِلَانِ هَٰذَا مِن شِيعَتِهِۦ وَهَٰذَا مِنْ عَدُوِّهِۦ ۖ فَٱسْتَغَٰثَهُ ٱلَّذِى مِن شِيعَتِهِۦ عَلَى ٱلَّذِى مِنْ عَدُوِّهِۦ فَوَكَزَهُۥ مُوسَىٰ فَقَضَىٰ عَلَيْهِ ۖ قَالَ هَٰذَا مِنْ عَمَلِ ٱلشَّيْطَٰنِ ۖ إِنَّهُۥ عَدُوٌّۭ مُّضِلٌّۭ مُّبِينٌۭ","translation":"And [one day] he entered the city at a time when [most of] its people were [resting in their houses,] unaware of what was going on [in the streets]; and there he encountered two men fighting with one another - one of his own people, and the other of his enemies. And the one who belonged to his own people cried out to him for help against him who was of his enemies - whereupon Moses struck him down with his fist, and [thus] brought about his end. [But then] he said [to himself]: “This is of Satan’s doing! Verily, he is an open foe, leading [man] astray!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3267.mp3","surahId":28,"words":[{"id":17673,"position":1,"arabic":"وَدَخَلَ","translation":"এবং সে প্রবেশ করলো","audioUrl":"wbw/028_015_001.mp3","charTypeName":"word"},{"id":17674,"position":2,"arabic":"ٱلْمَدِينَةَ","translation":"শহরে","audioUrl":"wbw/028_015_002.mp3","charTypeName":"word"},{"id":17675,"position":3,"arabic":"عَلَىٰ","translation":"এমন","audioUrl":"wbw/028_015_003.mp3","charTypeName":"word"},{"id":17676,"position":4,"arabic":"حِينِ","translation":"এক সময়ে (যখন)","audioUrl":"wbw/028_015_004.mp3","charTypeName":"word"},{"id":17677,"position":5,"arabic":"غَفْلَةٍۢ","translation":"অসতর্ক (ছিলো)","audioUrl":"wbw/028_015_005.mp3","charTypeName":"word"},{"id":17678,"position":6,"arabic":"مِّنْ","translation":"থেকে","audioUrl":"wbw/028_015_006.mp3","charTypeName":"word"},{"id":17679,"position":7,"arabic":"أَهْلِهَا","translation":"অধিবাসীদের তার","audioUrl":"wbw/028_015_007.mp3","charTypeName":"word"},{"id":17680,"position":8,"arabic":"فَوَجَدَ","translation":"অতঃপর সে পেলো","audioUrl":"wbw/028_015_008.mp3","charTypeName":"word"},{"id":17681,"position":9,"arabic":"فِيهَا","translation":"মধ্যে তার","audioUrl":"wbw/028_015_009.mp3","charTypeName":"word"},{"id":17682,"position":10,"arabic":"رَجُلَيْنِ","translation":"দু'ব্যক্তিকে","audioUrl":"wbw/028_015_010.mp3","charTypeName":"word"},{"id":17683,"position":11,"arabic":"يَقْتَتِلَانِ","translation":"তারা দু'জনে মারামারি করছে","audioUrl":"wbw/028_015_011.mp3","charTypeName":"word"},{"id":17684,"position":12,"arabic":"هَـٰذَا","translation":"এই (এক ব্যক্তি)","audioUrl":"wbw/028_015_012.mp3","charTypeName":"word"},{"id":17685,"position":13,"arabic":"مِن","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/028_015_013.mp3","charTypeName":"word"},{"id":17686,"position":14,"arabic":"شِيعَتِهِۦ","translation":"দলের তার","audioUrl":"wbw/028_015_014.mp3","charTypeName":"word"},{"id":17687,"position":15,"arabic":"وَهَـٰذَا","translation":"এবং এই (অন্য ব্যক্তি)","audioUrl":"wbw/028_015_015.mp3","charTypeName":"word"},{"id":17688,"position":16,"arabic":"مِنْ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/028_015_016.mp3","charTypeName":"word"},{"id":17689,"position":17,"arabic":"عَدُوِّهِۦ ۖ","translation":"শত্রু তার (দলের)","audioUrl":"wbw/028_015_017.mp3","charTypeName":"word"},{"id":17691,"position":18,"arabic":"فَٱسْتَغَـٰثَهُ","translation":"অতঃপর সাহায্য চাইলো (নিকট) তার","audioUrl":"wbw/028_015_019.mp3","charTypeName":"word"},{"id":17692,"position":19,"arabic":"ٱلَّذِى","translation":"(সে) যে (ছিলো)","audioUrl":"wbw/028_015_020.mp3","charTypeName":"word"},{"id":17693,"position":20,"arabic":"مِن","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/028_015_021.mp3","charTypeName":"word"},{"id":17694,"position":21,"arabic":"شِيعَتِهِۦ","translation":"দলের তার","audioUrl":"wbw/028_015_022.mp3","charTypeName":"word"},{"id":17695,"position":22,"arabic":"عَلَى","translation":"বিরুদ্ধে","audioUrl":"wbw/028_015_023.mp3","charTypeName":"word"},{"id":17696,"position":23,"arabic":"ٱلَّذِى","translation":"(তার) যে ছিলো","audioUrl":"wbw/028_015_024.mp3","charTypeName":"word"},{"id":17697,"position":24,"arabic":"مِنْ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/028_015_025.mp3","charTypeName":"word"},{"id":17698,"position":25,"arabic":"عَدُوِّهِۦ","translation":"শত্রুর তার","audioUrl":"wbw/028_015_026.mp3","charTypeName":"word"},{"id":17699,"position":26,"arabic":"فَوَكَزَهُۥ","translation":"তখন ঘুষি মারলো তাকে","audioUrl":"wbw/028_015_027.mp3","charTypeName":"word"},{"id":17700,"position":27,"arabic":"مُوسَىٰ","translation":"মূসা","audioUrl":"wbw/028_015_028.mp3","charTypeName":"word"},{"id":17701,"position":28,"arabic":"فَقَضَىٰ","translation":"অতঃপর শেষ করলেন","audioUrl":"wbw/028_015_029.mp3","charTypeName":"word"},{"id":17702,"position":29,"arabic":"عَلَيْهِ ۖ","translation":"ব্যাপার তার (অর্থাৎ সে মারা গেলো)","audioUrl":"wbw/028_015_030.mp3","charTypeName":"word"},{"id":17704,"position":30,"arabic":"قَالَ","translation":"(সাথে সাথেই) সে বললো","audioUrl":"wbw/028_015_032.mp3","charTypeName":"word"},{"id":17705,"position":31,"arabic":"هَـٰذَا","translation":"\"এটা","audioUrl":"wbw/028_015_033.mp3","charTypeName":"word"},{"id":17706,"position":32,"arabic":"مِنْ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/028_015_034.mp3","charTypeName":"word"},{"id":17707,"position":33,"arabic":"عَمَلِ","translation":"কাজের","audioUrl":"wbw/028_015_035.mp3","charTypeName":"word"},{"id":17708,"position":34,"arabic":"ٱلشَّيْطَـٰنِ ۖ","translation":"শয়তানের","audioUrl":"wbw/028_015_036.mp3","charTypeName":"word"},{"id":17710,"position":35,"arabic":"إِنَّهُۥ","translation":"নিশ্চয়ই সে","audioUrl":"wbw/028_015_038.mp3","charTypeName":"word"},{"id":17711,"position":36,"arabic":"عَدُوٌّۭ","translation":"শ্ত্রু","audioUrl":"wbw/028_015_039.mp3","charTypeName":"word"},{"id":17712,"position":37,"arabic":"مُّضِلٌّۭ","translation":"বিভ্রান্তকারী","audioUrl":"wbw/028_015_040.mp3","charTypeName":"word"},{"id":17713,"position":38,"arabic":"مُّبِينٌۭ","translation":"সুস্পষ্ট\"","audioUrl":"wbw/028_015_041.mp3","charTypeName":"word"},{"id":17714,"position":39,"arabic":"١٥","translation":"(১৫)","audioUrl":null,"charTypeName":"end"}]},{"number":16,"arabic":"قَالَ رَبِّ إِنِّى ظَلَمْتُ نَفْسِى فَٱغْفِرْ لِى فَغَفَرَ لَهُۥٓ ۚ إِنَّهُۥ هُوَ ٱلْغَفُورُ ٱلرَّحِيمُ","translation":"[And] he prayed: O my Sustainer! Verily, I have sinned against myself! Grant me, then, Thy forgiveness!” And He forgave him - for, verily, He alone is truly forgiving, a dispenser of grace.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3268.mp3","surahId":28,"words":[{"id":18709,"position":1,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/028_016_001.mp3","charTypeName":"word"},{"id":18710,"position":2,"arabic":"رَبِّ","translation":"\"হে আমার রব","audioUrl":"wbw/028_016_002.mp3","charTypeName":"word"},{"id":18711,"position":3,"arabic":"إِنِّى","translation":"নিশ্চয়ই আমি","audioUrl":"wbw/028_016_003.mp3","charTypeName":"word"},{"id":18712,"position":4,"arabic":"ظَلَمْتُ","translation":"অন্যায় করেছি","audioUrl":"wbw/028_016_004.mp3","charTypeName":"word"},{"id":18713,"position":5,"arabic":"نَفْسِى","translation":"আমার নিজের (উপর)","audioUrl":"wbw/028_016_005.mp3","charTypeName":"word"},{"id":18714,"position":6,"arabic":"فَٱغْفِرْ","translation":"অতএব ক্ষমা করো","audioUrl":"wbw/028_016_006.mp3","charTypeName":"word"},{"id":18715,"position":7,"arabic":"لِى","translation":"আমাকে\"","audioUrl":"wbw/028_016_007.mp3","charTypeName":"word"},{"id":18716,"position":8,"arabic":"فَغَفَرَ","translation":"অতঃপর ক্ষমা করলেন তিনি","audioUrl":"wbw/028_016_008.mp3","charTypeName":"word"},{"id":18717,"position":9,"arabic":"لَهُۥٓ ۚ","translation":"তাকে","audioUrl":"wbw/028_016_009.mp3","charTypeName":"word"},{"id":18719,"position":10,"arabic":"إِنَّهُۥ","translation":"নিশ্চয়ই তিনি","audioUrl":"wbw/028_016_011.mp3","charTypeName":"word"},{"id":18720,"position":11,"arabic":"هُوَ","translation":"তিনিই","audioUrl":"wbw/028_016_012.mp3","charTypeName":"word"},{"id":18721,"position":12,"arabic":"ٱلْغَفُورُ","translation":"ক্ষমাশীল","audioUrl":"wbw/028_016_013.mp3","charTypeName":"word"},{"id":18722,"position":13,"arabic":"ٱلرَّحِيمُ","translation":"পরম দয়ালু","audioUrl":"wbw/028_016_014.mp3","charTypeName":"word"},{"id":18723,"position":14,"arabic":"١٦","translation":"(১৬)","audioUrl":null,"charTypeName":"end"}]},{"number":17,"arabic":"قَالَ رَبِّ بِمَآ أَنْعَمْتَ عَلَىَّ فَلَنْ أَكُونَ ظَهِيرًۭا لِّلْمُجْرِمِينَ","translation":"Said he: “O my Sustainer! [I vow] by all the blessings which Thou hast bestowed on me: Never­more shall I aid such as are lost in sin!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3269.mp3","surahId":28,"words":[{"id":19794,"position":1,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/028_017_001.mp3","charTypeName":"word"},{"id":19795,"position":2,"arabic":"رَبِّ","translation":"\"হে আমার রব","audioUrl":"wbw/028_017_002.mp3","charTypeName":"word"},{"id":19796,"position":3,"arabic":"بِمَآ","translation":"শপথ ঐ বিষয়ের যা","audioUrl":"wbw/028_017_003.mp3","charTypeName":"word"},{"id":19797,"position":4,"arabic":"أَنْعَمْتَ","translation":"তুমি অনুগ্রহ করেছো","audioUrl":"wbw/028_017_004.mp3","charTypeName":"word"},{"id":19798,"position":5,"arabic":"عَلَىَّ","translation":"উপর আমার","audioUrl":"wbw/028_017_005.mp3","charTypeName":"word"},{"id":19799,"position":6,"arabic":"فَلَنْ","translation":"অতঃপর কখনও না","audioUrl":"wbw/028_017_006.mp3","charTypeName":"word"},{"id":19800,"position":7,"arabic":"أَكُونَ","translation":"হবো আমি","audioUrl":"wbw/028_017_007.mp3","charTypeName":"word"},{"id":19801,"position":8,"arabic":"ظَهِيرًۭا","translation":"সাহায্যকারী","audioUrl":"wbw/028_017_008.mp3","charTypeName":"word"},{"id":19802,"position":9,"arabic":"لِّلْمُجْرِمِينَ","translation":"জন্যে অপরাধীদের\"","audioUrl":"wbw/028_017_009.mp3","charTypeName":"word"},{"id":19803,"position":10,"arabic":"١٧","translation":"(১৭)","audioUrl":null,"charTypeName":"end"}]},{"number":18,"arabic":"فَأَصْبَحَ فِى ٱلْمَدِينَةِ خَآئِفًۭا يَتَرَقَّبُ فَإِذَا ٱلَّذِى ٱسْتَنصَرَهُۥ بِٱلْأَمْسِ يَسْتَصْرِخُهُۥ ۚ قَالَ لَهُۥ مُوسَىٰٓ إِنَّكَ لَغَوِىٌّۭ مُّبِينٌۭ","translation":"And next morning he found himself in the city, looking fearfully about him, when lo! the one who had sought his help the day before [once again] cried out to him [for help whereupon] Moses said unto him: “Behold, thou art indeed, most clearly, deeply in the wrong!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3270.mp3","surahId":28,"words":[{"id":20863,"position":1,"arabic":"فَأَصْبَحَ","translation":"অতঃপর সকালে উঠলো","audioUrl":"wbw/028_018_001.mp3","charTypeName":"word"},{"id":20864,"position":2,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/028_018_002.mp3","charTypeName":"word"},{"id":20865,"position":3,"arabic":"ٱلْمَدِينَةِ","translation":"শহরের","audioUrl":"wbw/028_018_003.mp3","charTypeName":"word"},{"id":20866,"position":4,"arabic":"خَآئِفًۭا","translation":"ভীতসন্ত্রস্ত অবস্থায়","audioUrl":"wbw/028_018_004.mp3","charTypeName":"word"},{"id":20867,"position":5,"arabic":"يَتَرَقَّبُ","translation":"সতর্ক হয়ে","audioUrl":"wbw/028_018_005.mp3","charTypeName":"word"},{"id":20868,"position":6,"arabic":"فَإِذَا","translation":"অতঃপর তখন (দেখলো)","audioUrl":"wbw/028_018_006.mp3","charTypeName":"word"},{"id":20869,"position":7,"arabic":"ٱلَّذِى","translation":"যে","audioUrl":"wbw/028_018_007.mp3","charTypeName":"word"},{"id":20870,"position":8,"arabic":"ٱسْتَنصَرَهُۥ","translation":"তার (কাছে) সাহায্য চেয়েছিলো","audioUrl":"wbw/028_018_008.mp3","charTypeName":"word"},{"id":20871,"position":9,"arabic":"بِٱلْأَمْسِ","translation":"গতকাল","audioUrl":"wbw/028_018_009.mp3","charTypeName":"word"},{"id":20872,"position":10,"arabic":"يَسْتَصْرِخُهُۥ ۚ","translation":"(আজও) তাকে চিৎকার করে ডাকছে","audioUrl":"wbw/028_018_010.mp3","charTypeName":"word"},{"id":20874,"position":11,"arabic":"قَالَ","translation":"বললো","audioUrl":"wbw/028_018_012.mp3","charTypeName":"word"},{"id":20875,"position":12,"arabic":"لَهُۥ","translation":"উদ্দেশ্যে তার","audioUrl":"wbw/028_018_013.mp3","charTypeName":"word"},{"id":208