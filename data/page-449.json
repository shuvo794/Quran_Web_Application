{"id":449,"ayahs":[{"number":77,"arabic":"وَجَعَلْنَا ذُرِّيَّتَهُۥ هُمُ ٱلْبَاقِينَ","translation":"and caused his offspring to endure [on earth];","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3865.mp3","surahId":37,"words":[{"id":63163,"position":1,"arabic":"وَجَعَلْنَا","translation":"এবং আমরা রাখলাম","audioUrl":"wbw/037_077_001.mp3","charTypeName":"word"},{"id":63164,"position":2,"arabic":"ذُرِّيَّتَهُۥ","translation":"তার বংশধরকে (এমন যে)","audioUrl":"wbw/037_077_002.mp3","charTypeName":"word"},{"id":63165,"position":3,"arabic":"هُمُ","translation":"তারাই","audioUrl":"wbw/037_077_003.mp3","charTypeName":"word"},{"id":63166,"position":4,"arabic":"ٱلْبَاقِينَ","translation":"অবশিষ্ট","audioUrl":"wbw/037_077_004.mp3","charTypeName":"word"},{"id":63167,"position":5,"arabic":"٧٧","translation":"(৭৭)","audioUrl":null,"charTypeName":"end"}]},{"number":78,"arabic":"وَتَرَكْنَا عَلَيْهِ فِى ٱلْءَاخِرِينَ","translation":"and We left him thus to be remembered among later generations:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3866.mp3","surahId":37,"words":[{"id":63683,"position":1,"arabic":"وَتَرَكْنَا","translation":"এবং আমরা ছেড়েছি (প্রশংসা)","audioUrl":"wbw/037_078_001.mp3","charTypeName":"word"},{"id":63684,"position":2,"arabic":"عَلَيْهِ","translation":"তার সম্বন্ধে","audioUrl":"wbw/037_078_002.mp3","charTypeName":"word"},{"id":63685,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/037_078_003.mp3","charTypeName":"word"},{"id":63686,"position":4,"arabic":"ٱلْـَٔاخِرِينَ","translation":"পরবর্তীদের","audioUrl":"wbw/037_078_004.mp3","charTypeName":"word"},{"id":63687,"position":5,"arabic":"٧٨","translation":"(৭৮)","audioUrl":null,"charTypeName":"end"}]},{"number":79,"arabic":"سَلَٰمٌ عَلَىٰ نُوحٍۢ فِى ٱلْعَٰلَمِينَ","translation":"“Peace be upon Noah throughout all the worlds!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3867.mp3","surahId":37,"words":[{"id":63744,"position":1,"arabic":"سَلَـٰمٌ","translation":"\"শান্তি (বর্ষিত হোক)","audioUrl":"wbw/037_079_001.mp3","charTypeName":"word"},{"id":63745,"position":2,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/037_079_002.mp3","charTypeName":"word"},{"id":63746,"position":3,"arabic":"نُوحٍۢ","translation":"নূহের","audioUrl":"wbw/037_079_003.mp3","charTypeName":"word"},{"id":63747,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/037_079_004.mp3","charTypeName":"word"},{"id":63748,"position":5,"arabic":"ٱلْعَـٰلَمِينَ","translation":"সমগ্র বিশ্বের\"","audioUrl":"wbw/037_079_005.mp3","charTypeName":"word"},{"id":63749,"position":6,"arabic":"٧٩","translation":"(৭৯)","audioUrl":null,"charTypeName":"end"}]},{"number":80,"arabic":"إِنَّا كَذَٰلِكَ نَجْزِى ٱلْمُحْسِنِينَ","translation":"Verily, thus do We reward the doers of good –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3868.mp3","surahId":37,"words":[{"id":64162,"position":1,"arabic":"إِنَّا","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/037_080_001.mp3","charTypeName":"word"},{"id":64163,"position":2,"arabic":"كَذَٰلِكَ","translation":"এভাবে","audioUrl":"wbw/037_080_002.mp3","charTypeName":"word"},{"id":64164,"position":3,"arabic":"نَجْزِى","translation":"পুরস্কার দিই আমরা","audioUrl":"wbw/037_080_003.mp3","charTypeName":"word"},{"id":64165,"position":4,"arabic":"ٱلْمُحْسِنِينَ","translation":"সৎকর্মপরায়ণদেরকে","audioUrl":"wbw/037_080_004.mp3","charTypeName":"word"},{"id":64166,"position":5,"arabic":"٨٠","translation":"(৮০)","audioUrl":null,"charTypeName":"end"}]},{"number":81,"arabic":"إِنَّهُۥ مِنْ عِبَادِنَا ٱلْمُؤْمِنِينَ","translation":"for he was truly one of our believing servants:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3869.mp3","surahId":37,"words":[{"id":64867,"position":1,"arabic":"إِنَّهُۥ","translation":"সে নিশ্চয়ই (ছিলো)","audioUrl":"wbw/037_081_001.mp3","charTypeName":"word"},{"id":64868,"position":2,"arabic":"مِنْ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/037_081_002.mp3","charTypeName":"word"},{"id":64869,"position":3,"arabic":"عِبَادِنَا","translation":"আমাদের দাসদের","audioUrl":"wbw/037_081_003.mp3","charTypeName":"word"},{"id":64870,"position":4,"arabic":"ٱلْمُؤْمِنِينَ","translation":"মু'মিন","audioUrl":"wbw/037_081_004.mp3","charTypeName":"word"},{"id":64871,"position":5,"arabic":"٨١","translation":"(৮১)","audioUrl":null,"charTypeName":"end"}]},{"number":82,"arabic":"ثُمَّ أَغْرَقْنَا ٱلْءَاخَرِينَ","translation":"[and so We saved him and those who followed him] and then We caused the others to drown.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3870.mp3","surahId":37,"words":[{"id":65037,"position":1,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/037_082_001.mp3","charTypeName":"word"},{"id":65038,"position":2,"arabic":"أَغْرَقْنَا","translation":"আমরা ডুবিয়ে দিই","audioUrl":"wbw/037_082_002.mp3","charTypeName":"word"},{"id":65039,"position":3,"arabic":"ٱلْـَٔاخَرِينَ","translation":"অন্যদেরকে","audioUrl":"wbw/037_082_003.mp3","charTypeName":"word"},{"id":65040,"position":4,"arabic":"٨٢","translation":"(৮২)","audioUrl":null,"charTypeName":"end"}]},{"number":83,"arabic":"۞ وَإِنَّ مِن شِيعَتِهِۦ لَإِبْرَٰهِيمَ","translation":"AND, BEHOLD, of his persuasion was Abraham, too,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3871.mp3","surahId":37,"words":[{"id":65354,"position":1,"arabic":"۞ وَإِنَّ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/037_083_002.mp3","charTypeName":"word"},{"id":65355,"position":2,"arabic":"مِن","translation":"মধ্য হ'তে","audioUrl":"wbw/037_083_003.mp3","charTypeName":"word"},{"id":65356,"position":3,"arabic":"شِيعَتِهِۦ","translation":"তার পথের অনুসারীদের","audioUrl":"wbw/037_083_004.mp3","charTypeName":"word"},{"id":65357,"position":4,"arabic":"لَإِبْرَٰهِيمَ","translation":"ইব্রাহীম অবশ্যই (অন্তর্ভক্ত ছিলো)","audioUrl":"wbw/037_083_005.mp3","charTypeName":"word"},{"id":65358,"position":5,"arabic":"٨٣","translation":"(৮৩)","audioUrl":null,"charTypeName":"end"}]},{"number":84,"arabic":"إِذْ جَآءَ رَبَّهُۥ بِقَلْبٍۢ سَلِيمٍ","translation":"when he turned to his Sustainer with a heart free of evil,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3872.mp3","surahId":37,"words":[{"id":65615,"position":1,"arabic":"إِذْ","translation":"(স্মরণ করো) যখন","audioUrl":"wbw/037_084_001.mp3","charTypeName":"word"},{"id":65616,"position":2,"arabic":"جَآءَ","translation":"সে এসেছিলো","audioUrl":"wbw/037_084_002.mp3","charTypeName":"word"},{"id":65617,"position":3,"arabic":"رَبَّهُۥ","translation":"তার রবের (কাছে)","audioUrl":"wbw/037_084_003.mp3","charTypeName":"word"},{"id":65618,"position":4,"arabic":"بِقَلْبٍۢ","translation":"নিয়ে অন্তর","audioUrl":"wbw/037_084_004.mp3","charTypeName":"word"},{"id":65619,"position":5,"arabic":"سَلِيمٍ","translation":"বিশুদ্ধ","audioUrl":"wbw/037_084_005.mp3","charTypeName":"word"},{"id":65620,"position":6,"arabic":"٨٤","translation":"(৮৪)","audioUrl":null,"charTypeName":"end"}]},{"number":85,"arabic":"إِذْ قَالَ لِأَبِيهِ وَقَوْمِهِۦ مَاذَا تَعْبُدُونَ","translation":"and [thus] spoke to his father and his people: “What is it that you worship?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3873.mp3","surahId":37,"words":[{"id":66335,"position":1,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/037_085_001.mp3","charTypeName":"word"},{"id":66336,"position":2,"arabic":"قَالَ","translation":"সে বলেছিলো","audioUrl":"wbw/037_085_002.mp3","charTypeName":"word"},{"id":66337,"position":3,"arabic":"لِأَبِيهِ","translation":"তার পিতাকে","audioUrl":"wbw/037_085_003.mp3","charTypeName":"word"},{"id":66338,"position":4,"arabic":"وَقَوْمِهِۦ","translation":"ও তার জাতিকে","audioUrl":"wbw/037_085_004.mp3","charTypeName":"word"},{"id":66339,"position":5,"arabic":"مَاذَا","translation":"\"কিসের","audioUrl":"wbw/037_085_005.mp3","charTypeName":"word"},{"id":66340,"position":6,"arabic":"تَعْبُدُونَ","translation":"তোমরা উপাসনা করছো","audioUrl":"wbw/037_085_006.mp3","charTypeName":"word"},{"id":66341,"position":7,"arabic":"٨٥","translation":"(৮৫)","audioUrl":null,"charTypeName":"end"}]},{"number":86,"arabic":"أَئِفْكًا ءَالِهَةًۭ دُونَ ٱللَّهِ تُرِيدُونَ","translation":"Do you want [to bow down before] a lie - [before] deities other than God?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3874.mp3","surahId":37,"words":[{"id":66426,"position":1,"arabic":"أَئِفْكًا","translation":"কি মিথ্যা","audioUrl":"wbw/037_086_001.mp3","charTypeName":"word"},{"id":66427,"position":2,"arabic":"ءَالِهَةًۭ","translation":"উপাস্যদের","audioUrl":"wbw/037_086_002.mp3","charTypeName":"word"},{"id":66428,"position":3,"arabic":"دُونَ","translation":"ব্যতীত","audioUrl":"wbw/037_086_003.mp3","charTypeName":"word"},{"id":66429,"position":4,"arabic":"ٱللَّهِ","translation":"আল্লাহকে","audioUrl":"wbw/037_086_004.mp3","charTypeName":"word"},{"id":66430,"position":5,"arabic":"تُرِيدُونَ","translation":"তোমরা পেতে চাও","audioUrl":"wbw/037_086_005.mp3","charTypeName":"word"},{"id":66431,"position":6,"arabic":"٨٦","translation":"(৮৬)","audioUrl":null,"charTypeName":"end"}]},{"number":87,"arabic":"فَمَا ظَنُّكُم بِرَبِّ ٱلْعَٰلَمِينَ","translation":"What, then, do you think of the Sustainer of all the worlds?”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3875.mp3","surahId":37,"words":[{"id":66746,"position":1,"arabic":"فَمَا","translation":"কি তাহ'লে","audioUrl":"wbw/037_087_001.mp3","charTypeName":"word"},{"id":66747,"position":2,"arabic":"ظَنُّكُم","translation":"তোমরা মনে করো","audioUrl":"wbw/037_087_002.mp3","charTypeName":"word"},{"id":66748,"position":3,"arabic":"بِرَبِّ","translation":"রব সম্বন্ধে","audioUrl":"wbw/037_087_003.mp3","charTypeName":"word"},{"id":66749,"position":4,"arabic":"ٱلْعَـٰلَمِينَ","translation":"বিশ্বজগতের\"","audioUrl":"wbw/037_087_004.mp3","charTypeName":"word"},{"id":66750,"position":5,"arabic":"٨٧","translation":"(৮৭)","audioUrl":null,"charTypeName":"end"}]},{"number":88,"arabic":"فَنَظَرَ نَظْرَةًۭ فِى ٱلنُّجُومِ","translation":"Then he cast a glance at the stars,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3876.mp3","surahId":37,"words":[{"id":67395,"position":1,"arabic":"فَنَظَرَ","translation":"অতঃপর সে তাকালো","audioUrl":"wbw/037_088_001.mp3","charTypeName":"word"},{"id":67396,"position":2,"arabic":"نَظْرَةًۭ","translation":"একবার","audioUrl":"wbw/037_088_002.mp3","charTypeName":"word"},{"id":67397,"position":3,"arabic":"فِى","translation":"দিকে","audioUrl":"wbw/037_088_003.mp3","charTypeName":"word"},{"id":67398,"position":4,"arabic":"ٱلنُّجُومِ","translation":"তারকাদের","audioUrl":"wbw/037_088_004.mp3","charTypeName":"word"},{"id":67399,"position":5,"arabic":"٨٨","translation":"(৮৮)","audioUrl":null,"charTypeName":"end"}]},{"number":89,"arabic":"فَقَالَ إِنِّى سَقِيمٌۭ","translation":"and said, “Verily, I am sick [at heart]!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3877.mp3","surahId":37,"words":[{"id":67558,"position":1,"arabic":"فَقَالَ","translation":"অতঃপর বললো","audioUrl":"wbw/037_089_001.mp3","charTypeName":"word"},{"id":67559,"position":2,"arabic":"إِنِّى","translation":"\"নিশ্চয়ই আমি","audioUrl":"wbw/037_089_002.mp3","charTypeName":"word"},{"id":67560,"position":3,"arabic":"سَقِيمٌۭ","translation":"অসুস্থ\"","audioUrl":"wbw/037_089_003.mp3","charTypeName":"word"},{"id":67561,"position":4,"arabic":"٨٩","translation":"(৮৯)","audioUrl":null,"charTypeName":"end"}]},{"number":90,"arabic":"فَتَوَلَّوْا۟ عَنْهُ مُدْبِرِينَ","translation":"and at that they turned their backs on him and went away.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3878.mp3","surahId":37,"words":[{"id":68093,"position":1,"arabic":"فَتَوَلَّوْا۟","translation":"তারা অতঃপর ফিরে গেল","audioUrl":"wbw/037_090_001.mp3","charTypeName":"word"},{"id":68094,"position":2,"arabic":"عَنْهُ","translation":"তার থেকে","audioUrl":"wbw/037_090_002.mp3","charTypeName":"word"},{"id":68095,"position":3,"arabic":"مُدْبِرِينَ","translation":"পিঠ ফিরিয়ে","audioUrl":"wbw/037_090_003.mp3","charTypeName":"word"},{"id":68096,"position":4,"arabic":"٩٠","translation":"(৯০)","audioUrl":null,"charTypeName":"end"}]},{"number":91,"arabic":"فَرَاغَ إِلَىٰٓ ءَالِهَتِهِمْ فَقَالَ أَلَا تَأْكُلُونَ","translation":"Thereupon he approached their gods stealthily and said, “What! You do not eat [of the offerings placed before you]?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3879.mp3","surahId":37,"words":[{"id":68563,"position":1,"arabic":"فَرَاغَ","translation":"সে অতঃপর চুপিসারে  গেলো","audioUrl":"wbw/037_091_001.mp3","charTypeName":"word"},{"id":68564,"position":2,"arabic":"إِلَىٰٓ","translation":"দিকে","audioUrl":"wbw/037_091_002.mp3","charTypeName":"word"},{"id":68565,"position":3,"arabic":"ءَالِهَتِهِمْ","translation":"তাদের দেবতাগুলোর","audioUrl":"wbw/037_091_003.mp3","charTypeName":"word"},{"id":68566,"position":4,"arabic":"فَقَالَ","translation":"অতঃপর বললো","audioUrl":"wbw/037_091_004.mp3","charTypeName":"word"},{"id":68567,"position":5,"arabic":"أَلَا","translation":"\"কেন না","audioUrl":"wbw/037_091_005.mp3","charTypeName":"word"},{"id":68568,"position":6,"arabic":"تَأْكُلُونَ","translation":"তোমরা খাচ্ছো","audioUrl":"wbw/037_091_006.mp3","charTypeName":"word"},{"id":68569,"position":7,"arabic":"٩١","translation":"(৯১)","audioUrl":null,"charTypeName":"end"}]},{"number":92,"arabic":"مَا لَكُمْ لَا تَنطِقُونَ","translation":"What is amiss with you that you do not speak?”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3880.mp3","surahId":37,"words":[{"id":68613,"position":1,"arabic":"مَا","translation":"কি","audioUrl":"wbw/037_092_001.mp3","charTypeName":"word"},{"id":68614,"position":2,"arabic":"لَكُمْ","translation":"তোমাদের হয়েছে","audioUrl":"wbw/037_092_002.mp3","charTypeName":"word"},{"id":68615,"position":3,"arabic":"لَا","translation":"না","audioUrl":"wbw/037_092_003.mp3","charTypeName":"word"},{"id":68616,"position":4,"arabic":"تَنطِقُونَ","translation":"তোমরা কথা বলো\"","audioUrl":"wbw/037_092_004.mp3","charTypeName":"word"},{"id":68617,"position":5,"arabic":"٩٢","translation":"(৯২)","audioUrl":null,"charTypeName":"end"}]},{"number":93,"arabic":"فَرَاغَ عَلَيْهِمْ ضَرْبًۢا بِٱلْيَمِينِ","translation":"And then he fell upon them, smiting them with his right hand.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3881.mp3","surahId":37,"words":[{"id":68938,"position":1,"arabic":"فَرَاغَ","translation":"সে অতঃপর ঝাঁপিয়ে পড়লো","audioUrl":"wbw/037_093_001.mp3","charTypeName":"word"},{"id":68939,"position":2,"arabic":"عَلَيْهِمْ","translation":"তাদের উপর","audioUrl":"wbw/037_093_002.mp3","charTypeName":"word"},{"id":68940,"position":3,"arabic":"ضَرْبًۢا","translation":"আঘাত","audioUrl":"wbw/037_093_003.mp3","charTypeName":"word"},{"id":68941,"position":4,"arabic":"بِٱلْيَمِينِ","translation":"দিয়ে ডান হাত","audioUrl":"wbw/037_093_004.mp3","charTypeName":"word"},{"id":68942,"position":5,"arabic":"٩٣","translation":"(৯৩)","audioUrl":null,"charTypeName":"end"}]},{"number":94,"arabic":"فَأَقْبَلُوٓا۟ إِلَيْهِ يَزِفُّونَ","translation":"[But] then the others came towards him hur­riedly [and accused him of his deed].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3882.mp3","surahId":37,"words":[{"id":69660,"position":1,"arabic":"فَأَقْبَلُوٓا۟","translation":"তারা অতঃপর এগিয়ে এলো","audioUrl":"wbw/037_094_001.mp3","charTypeName":"word"},{"id":69661,"position":2,"arabic":"إِلَيْهِ","translation":"তার দিকে","audioUrl":"wbw/037_094_002.mp3","charTypeName":"word"},{"id":69662,"position":3,"arabic":"يَزِفُّونَ","translation":"ছুটে","audioUrl":"wbw/037_094_003.mp3","charTypeName":"word"},{"id":69663,"position":4,"arabic":"٩٤","translation":"(৯৪)","audioUrl":null,"charTypeName":"end"}]},{"number":95,"arabic":"قَالَ أَتَعْبُدُونَ مَا تَنْحِتُونَ","translation":"He answered: “Do you worship something that you [yourselves] have carved,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3883.mp3","surahId":37,"words":[{"id":69958,"position":1,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/037_095_001.mp3","charTypeName":"word"},{"id":69959,"position":2,"arabic":"أَتَعْبُدُونَ","translation":"\"তোমরা পূজা করো কি","audioUrl":"wbw/037_095_002.mp3","charTypeName":"word"},{"id":69960,"position":3,"arabic":"مَا","translation":"যাকে","audioUrl":"wbw/037_095_003.mp3","charTypeName":"word"},{"id":69961,"position":4,"arabic":"تَنْحِتُونَ","translation":"তোমরা খোদাই করে তৈরী কর","audioUrl":"wbw/037_095_004.mp3","charTypeName":"word"},{"id":69962,"position":5,"arabic":"٩٥","translation":"(৯৫)","audioUrl":null,"charTypeName":"end"}]},{"number":96,"arabic":"وَٱللَّهُ خَلَقَكُمْ وَمَا تَعْمَلُونَ","translation":"the while it is God who has created you and all your handiwork?”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3884.mp3","surahId":37,"words":[{"id":69988,"position":1,"arabic":"وَٱللَّهُ","translation":"অথচ আল্লাহই","audioUrl":"wbw/037_096_001.mp3","charTypeName":"word"},{"id":69989,"position":2,"arabic":"خَلَقَكُمْ","translation":"তোমাদেরকে সৃষ্টি করেছেন","audioUrl":"wbw/037_096_002.mp3","charTypeName":"word"},{"id":69990,"position":3,"arabic":"وَمَا","translation":"এবং (তাদেরকেও) যাদের","audioUrl":"wbw/037_096_003.mp3","charTypeName":"word"},{"id":69991,"position":4,"arabic":"تَعْمَلُونَ","translation":"তোমরা তৈরী করো\"","audioUrl":"wbw/037_096_004.mp3","charTypeName":"word"},{"id":69992,"position":5,"arabic":"٩٦","translation":"(৯৬)","audioUrl":null,"charTypeName":"end"}]},{"number":97,"arabic":"قَالُوا۟ ٱبْنُوا۟ لَهُۥ بُنْيَٰنًۭا فَأَلْقُوهُ فِى ٱلْجَحِيمِ","translation":"They exclaimed: “Build a pyre for him, and cast him into the blazing fire!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3885.mp3","surahId":37,"words":[{"id":70571,"position":1,"arabic":"قَالُوا۟","translation":"তারা বললো","audioUrl":"wbw/037_097_001.mp3","charTypeName":"word"},{"id":70572,"position":2,"arabic":"ٱبْنُوا۟","translation