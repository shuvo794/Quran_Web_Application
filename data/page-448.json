{"id":448,"ayahs":[{"number":52,"arabic":"يَقُولُ أَءِنَّكَ لَمِنَ ٱلْمُصَدِّقِينَ","translation":"who was wont to ask [me], ‘Why - art thou really one of those who believe it to be true","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3840.mp3","surahId":37,"words":[{"id":50196,"position":1,"arabic":"يَقُولُ","translation":"সে বলতো","audioUrl":"wbw/037_052_001.mp3","charTypeName":"word"},{"id":50197,"position":2,"arabic":"أَءِنَّكَ","translation":"\"তুমি কি নিশ্চয়ই","audioUrl":"wbw/037_052_002.mp3","charTypeName":"word"},{"id":50198,"position":3,"arabic":"لَمِنَ","translation":"অবশ্যই অন্তর্ভুক্ত","audioUrl":"wbw/037_052_003.mp3","charTypeName":"word"},{"id":50199,"position":4,"arabic":"ٱلْمُصَدِّقِينَ","translation":"সত্যতা স্বীকারকারীদের","audioUrl":"wbw/037_052_004.mp3","charTypeName":"word"},{"id":50200,"position":5,"arabic":"٥٢","translation":"(৫২)","audioUrl":null,"charTypeName":"end"}]},{"number":53,"arabic":"أَءِذَا مِتْنَا وَكُنَّا تُرَابًۭا وَعِظَٰمًا أَءِنَّا لَمَدِينُونَ","translation":"[that] after we have died and become mere dust and bones we shall, forsooth, be brought to judgment?”’","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3841.mp3","surahId":37,"words":[{"id":50889,"position":1,"arabic":"أَءِذَا","translation":"কি যখন","audioUrl":"wbw/037_053_001.mp3","charTypeName":"word"},{"id":50890,"position":2,"arabic":"مِتْنَا","translation":"আমরা মারা যাবো","audioUrl":"wbw/037_053_002.mp3","charTypeName":"word"},{"id":50891,"position":3,"arabic":"وَكُنَّا","translation":"এবং আমরা হবো","audioUrl":"wbw/037_053_003.mp3","charTypeName":"word"},{"id":50892,"position":4,"arabic":"تُرَابًۭا","translation":"মাটি","audioUrl":"wbw/037_053_004.mp3","charTypeName":"word"},{"id":50893,"position":5,"arabic":"وَعِظَـٰمًا","translation":"ও হাড় (সর্বস্ব)","audioUrl":"wbw/037_053_005.mp3","charTypeName":"word"},{"id":50894,"position":6,"arabic":"أَءِنَّا","translation":"আমরা কি নিশ্চয়ই","audioUrl":"wbw/037_053_006.mp3","charTypeName":"word"},{"id":50895,"position":7,"arabic":"لَمَدِينُونَ","translation":"প্রতিফলপ্রাপ্ত হবো অবশ্যই\"","audioUrl":"wbw/037_053_007.mp3","charTypeName":"word"},{"id":50896,"position":8,"arabic":"٥٣","translation":"(৫৩)","audioUrl":null,"charTypeName":"end"}]},{"number":54,"arabic":"قَالَ هَلْ أَنتُم مُّطَّلِعُونَ","translation":"[And] he adds: “Would you like to look [and see him]?” –","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3842.mp3","surahId":37,"words":[{"id":51486,"position":1,"arabic":"قَالَ","translation":"বলবে","audioUrl":"wbw/037_054_001.mp3","charTypeName":"word"},{"id":51487,"position":2,"arabic":"هَلْ","translation":"\"কি","audioUrl":"wbw/037_054_002.mp3","charTypeName":"word"},{"id":51488,"position":3,"arabic":"أَنتُم","translation":"তোমরা","audioUrl":"wbw/037_054_003.mp3","charTypeName":"word"},{"id":51489,"position":4,"arabic":"مُّطَّلِعُونَ","translation":"(সেসব লোকদেরকে) উঁকি মেরে দেখতে পাও\"","audioUrl":"wbw/037_054_004.mp3","charTypeName":"word"},{"id":51490,"position":5,"arabic":"٥٤","translation":"(৫৪)","audioUrl":null,"charTypeName":"end"}]},{"number":55,"arabic":"فَٱطَّلَعَ فَرَءَاهُ فِى سَوَآءِ ٱلْجَحِيمِ","translation":"and then he looks and sees that [companion of his] in the midst of the blazing fire,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3843.mp3","surahId":37,"words":[{"id":51994,"position":1,"arabic":"فَٱطَّلَعَ","translation":"সে তখন উঁকি মেরে দেখবে","audioUrl":"wbw/037_055_001.mp3","charTypeName":"word"},{"id":51995,"position":2,"arabic":"فَرَءَاهُ","translation":"তাকে ফলে দেখতে পাবে","audioUrl":"wbw/037_055_002.mp3","charTypeName":"word"},{"id":51996,"position":3,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/037_055_003.mp3","charTypeName":"word"},{"id":51997,"position":4,"arabic":"سَوَآءِ","translation":"মাঝখানে","audioUrl":"wbw/037_055_004.mp3","charTypeName":"word"},{"id":51998,"position":5,"arabic":"ٱلْجَحِيمِ","translation":"জাহান্নামের","audioUrl":"wbw/037_055_005.mp3","ch