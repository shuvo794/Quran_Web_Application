ion":"অন্তর্ভুক্ত","audioUrl":"wbw/037_057_005.mp3","charTypeName":"word"},{"id":53044,"position":6,"arabic":"ٱلْمُحْضَرِينَ","translation":"(জাহান্নামে) উপস্থিত করা লোকদের","audioUrl":"wbw/037_057_006.mp3","charTypeName":"word"},{"id":53045,"position":7,"arabic":"٥٧","translation":"(৫৭)","audioUrl":null,"charTypeName":"end"}]},{"number":58,"arabic":"أَفَمَا نَحْنُ بِمَيِّتِينَ","translation":"But then, [O my friends in paradise,] is it [really] so that we are not to die","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3846.mp3","surahId":37,"words":[{"id":53591,"position":1,"arabic":"أَفَمَا","translation":"তবে কি না","audioUrl":"wbw/037_058_001.mp3","charTypeName":"word"},{"id":53592,"position":2,"arabic":"نَحْنُ","translation":"আমরা","audioUrl":"wbw/037_058_002.mp3","charTypeName":"word"},{"id":53593,"position":3,"arabic":"بِمَيِّتِينَ","translation":"মৃত্যুবরণকারী হবো","audioUrl":"wbw/037_058_003.mp3","charTypeName":"word"},{"id":53594,"position":4,"arabic":"٥٨","translation":"(৫৮)","audioUrl":null,"charTypeName":"end"}]},{"number":59,"arabic":"إِلَّا مَوْتَتَنَا ٱلْأُولَىٰ وَمَا نَحْنُ بِمُعَذَّبِينَ","translation":"[again,] beyond our previous death, and that we shall never [again] be made to suffer?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3847.mp3","surahId":37,"words":[{"id":54142,"position":1,"arabic":"إِلَّا","translation":"ব্যতীত","audioUrl":"wbw/037_059_001.mp3","charTypeName":"word"},{"id":54143,"position":2,"arabic":"مَوْتَتَنَا","translation":"আমাদের মৃত্যু","audioUrl":"wbw/037_059_002.mp3","charTypeName":"word"},{"id":54144,"position":3,"arabic":"ٱلْأُولَىٰ","translation":"প্রথম","audioUrl":"wbw/037_059_003.mp3","charTypeName":"word"},{"id":54145,"position":4,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/037_059_004.mp3","charTypeName":"word"},{"id":54146,"position":5,"arabic":"نَحْنُ","translation":"আমরা","audioUrl":"wbw/037_059_005.mp3","charTypeName":"word"},{"id":54147,"position":6,"arabic":"بِم