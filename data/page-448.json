َ","translation":"পূর্ববর্তীদের","audioUrl":"wbw/037_071_005.mp3","charTypeName":"word"},{"id":60331,"position":6,"arabic":"٧١","translation":"(৭১)","audioUrl":null,"charTypeName":"end"}]},{"number":72,"arabic":"وَلَقَدْ أَرْسَلْنَا فِيهِم مُّنذِرِينَ","translation":"although, verily, We had sent warners unto them:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3860.mp3","surahId":37,"words":[{"id":60585,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/037_072_001.mp3","charTypeName":"word"},{"id":60586,"position":2,"arabic":"أَرْسَلْنَا","translation":"আমরা পাঠিয়েছিলাম","audioUrl":"wbw/037_072_002.mp3","charTypeName":"word"},{"id":60587,"position":3,"arabic":"فِيهِم","translation":"তাদের মধ্যে","audioUrl":"wbw/037_072_003.mp3","charTypeName":"word"},{"id":60588,"position":4,"arabic":"مُّنذِرِينَ","translation":"সতর্ককারীদেরকে (রাসূলরূপে)","audioUrl":"wbw/037_072_004.mp3","charTypeName":"word"},{"id":60589,"position":5,"arabic":"٧٢","translation":"(৭২)","audioUrl":null,"charTypeName":"end"}]},{"number":73,"arabic":"فَٱنظُرْ كَيْفَ كَانَ عَٰقِبَةُ ٱلْمُنذَرِينَ","translation":"and behold what happened in the end to those that had been warned [to no avail]!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3861.mp3","surahId":37,"words":[{"id":61362,"position":1,"arabic":"فَٱنظُرْ","translation":"দেখো অতঃপর","audioUrl":"wbw/037_073_001.mp3","charTypeName":"word"},{"id":61363,"position":2,"arabic":"كَيْفَ","translation":"কেমন","audioUrl":"wbw/037_073_002.mp3","charTypeName":"word"},{"id":61364,"position":3,"arabic":"كَانَ","translation":"হয়েছিলো","audioUrl":"wbw/037_073_003.mp3","charTypeName":"word"},{"id":61365,"position":4,"arabic":"عَـٰقِبَةُ","translation":"পরিণাম (সেই লোকদের)","audioUrl":"wbw/037_073_004.mp3","charTypeName":"word"},{"id":61366,"position":5,"arabic":"ٱلْمُنذَرِينَ","translation":"যাদের সতর্ক করা হয়েছিলো","audioUrl":"wbw/037_073_005.mp3","charTypeName":"word"},{"id":61367,"position":6,"arabic":"٧٣","translation":"(৭৩)","audioUrl":null,"charTypeName":"end"}]},{"number":74,"arabic":"إِلَّا عِبَادَ ٱللَّهِ ٱلْمُخْلَصِينَ","translation":"EXCEPT for God’s true servants, [most people are apt to go astray.]","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3862.mp3","surahId":37,"words":[{"id":61452,"position":1,"arabic":"إِلَّا","translation":"তবে স্বতন্ত্র (কথা)","audioUrl":"wbw/037_074_001.mp3","charTypeName":"word"},{"id":61453,"position":2,"arabic":"عِبَادَ","translation":"দাসদের","audioUrl":"wbw/037_074_002.mp3","charTypeName":"word"},{"id":61454,"position":3,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/037_074_003.mp3","charTypeName":"word"},{"id":61455,"position":4,"arabic":"ٱلْمُخْلَصِينَ","translation":"খাঁটি (যাদের)","audioUrl":"wbw/037_074_004.mp3","charTypeName":"word"},{"id":61456,"position":5,"arabic":"٧٤","translation":"(৭৪)","audioUrl":null,"charTypeName":"end"}]},{"number":75,"arabic":"وَلَقَدْ نَادَىٰنَا نُوحٌۭ فَلَنِعْمَ ٱلْمُجِيبُونَ","translation":"And, indeed, [it was for this reason that] Noah cried unto Us - and how excellent was Our response:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3863.mp3","surahId":37,"words":[{"id":62050,"position":1,"arabic":"وَلَقَدْ","translation":"এবং নিশ্চয়ই","audioUrl":"wbw/037_075_001.mp3","charTypeName":"word"},{"id":62051,"position":2,"arabic":"نَادَىٰنَا","translation":"আমাদেরকে ডেকেছিলো","audioUrl":"wbw/037_075_002.mp3","charTypeName":"word"},{"id":62052,"position":3,"arabic":"نُوحٌۭ","translation":"নূহ","audioUrl":"wbw/037_075_003.mp3","charTypeName":"word"},{"id":62053,"position":4,"arabic":"فَلَنِعْمَ","translation":"অতঃপর কত উত্তম","audioUrl":"wbw/037_075_004.mp3","charTypeName":"word"},{"id":62054,"position":5,"arabic":"ٱلْمُجِيبُونَ","translation":"সাড়াদানকারী (আমরা)","audioUrl":"wbw/037_075_005.mp3","charTypeName":"word"},{"id":62055,"position":6,"arabic":"٧٥","translation":"(৭৫)","audioUrl":null,"charTypeName":"end"}]},{"number":76,"arabi