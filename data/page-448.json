"audioUrl":null,"charTypeName":"end"}]},{"number":62,"arabic":"أَذَٰلِكَ خَيْرٌۭ نُّزُلًا أَمْ شَجَرَةُ ٱلزَّقُّومِ","translation":"Is such [a paradise] the better welcome - or the [hellish] tree of deadly fruit?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3850.mp3","surahId":37,"words":[{"id":55882,"position":1,"arabic":"أَذَٰلِكَ","translation":"এটা কি","audioUrl":"wbw/037_062_001.mp3","charTypeName":"word"},{"id":55883,"position":2,"arabic":"خَيْرٌۭ","translation":"উত্তম","audioUrl":"wbw/037_062_002.mp3","charTypeName":"word"},{"id":55884,"position":3,"arabic":"نُّزُلًا","translation":"আপ্যায়ন","audioUrl":"wbw/037_062_003.mp3","charTypeName":"word"},{"id":55885,"position":4,"arabic":"أَمْ","translation":"না","audioUrl":"wbw/037_062_004.mp3","charTypeName":"word"},{"id":55886,"position":5,"arabic":"شَجَرَةُ","translation":"গাছ","audioUrl":"wbw/037_062_005.mp3","charTypeName":"word"},{"id":55887,"position":6,"arabic":"ٱلزَّقُّومِ","translation":"যাক্কুমের","audioUrl":"wbw/037_062_006.mp3","charTypeName":"word"},{"id":55888,"position":7,"arabic":"٦٢","translation":"(৬২)","audioUrl":null,"charTypeName":"end"}]},{"number":63,"arabic":"إِنَّا جَعَلْنَٰهَا فِتْنَةًۭ لِّلظَّٰلِمِينَ","translation":"Verily, We have caused it to be a trial for evildoers:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/3851.mp3","surahId":37,"words":[{"id":56431,"position":1,"arabic":"إِنَّا","translation":"নিশ্চয়ই আমরা","audioUrl":"wbw/037_063_001.mp3","charTypeName":"word"},{"id":56432,"position":2,"arabic":"جَعَلْنَـٰهَا","translation":"তা আমরা সৃষ্টি করেছি","audioUrl":"wbw/037_063_002.mp3","charTypeName":"word"},{"id":56433,"position":3,"arabic":"فِتْنَةًۭ","translation":"পরীক্ষা স্বরূপ","audioUrl":"wbw/037_063_003.mp3","charTypeName":"word"},{"id":56434,"position":4,"arabic":"لِّلظَّـٰلِمِينَ","translation":"সীমালঙ্ঘনকারীদের জন্যে","audioUrl":"wbw/037_063_004.mp3","charTypeName":"word"},{"id":56435,"position":5,"arabic":"٦٣","translation":"(৬৩)","a