{"id":344,"ayahs":[{"number":28,"arabic":"فَإِذَا ٱسْتَوَيْتَ أَنتَ وَمَن مَّعَكَ عَلَى ٱلْفُلْكِ فَقُلِ ٱلْحَمْدُ لِلَّهِ ٱلَّذِى نَجَّىٰنَا مِنَ ٱلْقَوْمِ ٱلظَّٰلِمِينَ","translation":"“And as soon as thou and those who are with thee are settled in the ark, say: ‘All praise is due to God, who has saved us from those evildoing folk!’","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2701.mp3","surahId":23,"words":[{"id":30972,"position":1,"arabic":"فَإِذَا","translation":"অতঃপর যখন","audioUrl":"wbw/023_028_001.mp3","charTypeName":"word"},{"id":30973,"position":2,"arabic":"ٱسْتَوَيْتَ","translation":"তুমি স্হির হবে","audioUrl":"wbw/023_028_002.mp3","charTypeName":"word"},{"id":30974,"position":3,"arabic":"أَنتَ","translation":"তুমি","audioUrl":"wbw/023_028_003.mp3","charTypeName":"word"},{"id":30975,"position":4,"arabic":"وَمَن","translation":"ও যারা","audioUrl":"wbw/023_028_004.mp3","charTypeName":"word"},{"id":30976,"position":5,"arabic":"مَّعَكَ","translation":"তোমার সাথে","audioUrl":"wbw/023_028_005.mp3","charTypeName":"word"},{"id":30977,"position":6,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/023_028_006.mp3","charTypeName":"word"},{"id":30978,"position":7,"arabic":"ٱلْفُلْكِ","translation":"নৌকার","audioUrl":"wbw/023_028_007.mp3","charTypeName":"word"},{"id":30979,"position":8,"arabic":"فَقُلِ","translation":"তখন বলো","audioUrl":"wbw/023_028_008.mp3","charTypeName":"word"},{"id":30980,"position":9,"arabic":"ٱلْحَمْدُ","translation":"\"সব প্রশংসা","audioUrl":"wbw/023_028_009.mp3","charTypeName":"word"},{"id":30981,"position":10,"arabic":"لِلَّهِ","translation":"জন্যে আল্লাহরই","audioUrl":"wbw/023_028_010.mp3","charTypeName":"word"},{"id":30982,"position":11,"arabic":"ٱلَّذِى","translation":"যিনি","audioUrl":"wbw/023_028_011.mp3","charTypeName":"word"},{"id":30983,"position":12,"arabic":"نَجَّىٰنَا","translation":"আমাদেরকে উদ্ধার করেছেন","audioUrl":"wbw/023_028_012.mp3","charTypeName":"word"},{"id":30984,"position":13,"arabic":"مِنَ","translation":"হ'তে","audioUrl":"wbw/023_028_013.mp3","charTypeName":"word"},{"id":30985,"position":14,"arabic":"ٱلْقَوْمِ","translation":"জাতি","audioUrl":"wbw/023_028_014.mp3","charTypeName":"word"},{"id":30986,"position":15,"arabic":"ٱلظَّـٰلِمِينَ","translation":"সীমালঙ্ঘনকারী\"","audioUrl":"wbw/023_028_015.mp3","charTypeName":"word"},{"id":30987,"position":16,"arabic":"٢٨","translation":"(২৮)","audioUrl":null,"charTypeName":"end"}]},{"number":29,"arabic":"وَقُل رَّبِّ أَنزِلْنِى مُنزَلًۭا مُّبَارَكًۭا وَأَنتَ خَيْرُ ٱلْمُنزِلِينَ","translation":"“And say: ‘O my Sustainer! Cause me to reach a destination blessed [by Thee] for Thou art the best to show man how to reach his [true] destination!’”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2702.mp3","surahId":23,"words":[{"id":31847,"position":1,"arabic":"وَقُل","translation":"এবং বলো","audioUrl":"wbw/023_029_001.mp3","charTypeName":"word"},{"id":31848,"position":2,"arabic":"رَّبِّ","translation":"\"হে আমার রব","audioUrl":"wbw/023_029_002.mp3","charTypeName":"word"},{"id":31849,"position":3,"arabic":"أَنزِلْنِى","translation":"আমাকে অবতরণ করাও","audioUrl":"wbw/023_029_003.mp3","charTypeName":"word"},{"id":31850,"position":4,"arabic":"مُنزَلًۭا","translation":"অবতরণস্থানে","audioUrl":"wbw/023_029_004.mp3","charTypeName":"word"},{"id":31851,"position":5,"arabic":"مُّبَارَكًۭا","translation":"কল্যাণকর","audioUrl":"wbw/023_029_005.mp3","charTypeName":"word"},{"id":31852,"position":6,"arabic":"وَأَنتَ","translation":"আর তুমি","audioUrl":"wbw/023_029_006.mp3","charTypeName":"word"},{"id":31853,"position":7,"arabic":"خَيْرُ","translation":"উত্তম","audioUrl":"wbw/023_029_007.mp3","charTypeName":"word"},{"id":31854,"position":8,"arabic":"ٱلْمُنزِلِينَ","translation":"অবতীর্ণকারীদের (মধ্যে)\"","audioUrl":"wbw/023_029_008.mp3","charTypeName":"word"},{"id":31855,"position":9,"arabic":"٢٩","translation":"(২৯)","audioUrl":null,"charTypeName":"end"}]},{"number":30,"arabic":"إِنَّ فِى ذَٰلِكَ لَءَايَٰتٍۢ وَإِن كُنَّا لَمُبْتَلِينَ","translation":"In this [story], behold, there are messages indeed [for those who think]: for, verily, We always put [man] to a test.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2703.mp3","surahId":23,"words":[{"id":32636,"position":1,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/023_030_001.mp3","charTypeName":"word"},{"id":32637,"position":2,"arabic":"فِى","translation":"মধ্যে (রয়েছে)","audioUrl":"wbw/023_030_002.mp3","charTypeName":"word"},{"id":32638,"position":3,"arabic":"ذَٰلِكَ","translation":"এর","audioUrl":"wbw/023_030_003.mp3","charTypeName":"word"},{"id":32639,"position":4,"arabic":"لَـَٔايَـٰتٍۢ","translation":"অবশ্যই নিদর্শন","audioUrl":"wbw/023_030_004.mp3","charTypeName":"word"},{"id":32640,"position":5,"arabic":"وَإِن","translation":"আর নিশ্চয়ই","audioUrl":"wbw/023_030_005.mp3","charTypeName":"word"},{"id":32641,"position":6,"arabic":"كُنَّا","translation":"আমরাই ছিলাম","audioUrl":"wbw/023_030_006.mp3","charTypeName":"word"},{"id":32642,"position":7,"arabic":"لَمُبْتَلِينَ","translation":"অবশ্যই পরীক্ষাকারী","audioUrl":"wbw/023_030_007.mp3","charTypeName":"word"},{"id":32643,"position":8,"arabic":"٣٠","translation":"(৩০)","audioUrl":null,"charTypeName":"end"}]},{"number":31,"arabic":"ثُمَّ أَنشَأْنَا مِنۢ بَعْدِهِمْ قَرْنًا ءَاخَرِينَ","translation":"AND AFTER those [people of old] We gave rise to new generations;","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2704.mp3","surahId":23,"words":[{"id":33509,"position":1,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/023_031_001.mp3","charTypeName":"word"},{"id":33510,"position":2,"arabic":"أَنشَأْنَا","translation":"আমরা সৃষ্টি করেছি","audioUrl":"wbw/023_031_002.mp3","charTypeName":"word"},{"id":33511,"position":3,"arabic":"مِنۢ","translation":"থেকে","audioUrl":"wbw/023_031_003.mp3","charTypeName":"word"},{"id":33512,"position":4,"arabic":"بَعْدِهِمْ","translation":"পর তাদের","audioUrl":"wbw/023_031_004.mp3","charTypeName":"word"},{"id":33513,"position":5,"arabic":"قَرْنًا","translation":"জাতি","audioUrl":"wbw/023_031_005.mp3","charTypeName":"word"},{"id":33514,"position":6,"arabic":"ءَاخَرِينَ","translation":"অন্য এক","audioUrl":"wbw/023_031_006.mp3","charTypeName":"word"},{"id":33515,"position":7,"arabic":"٣١","translation":"(৩১)","audioUrl":null,"charTypeName":"end"}]},{"number":32,"arabic":"فَأَرْسَلْنَا فِيهِمْ رَسُولًۭا مِّنْهُمْ أَنِ ٱعْبُدُوا۟ ٱللَّهَ مَا لَكُم مِّنْ إِلَٰهٍ غَيْرُهُۥٓ ۖ أَفَلَا تَتَّقُونَ","translation":"and [every time] We sent unto them an apostle from among themselves, [he told them:] “Worship God [alone]: you have no deity other than Him. Will you not, then, become conscious of Him?”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2705.mp3","surahId":23,"words":[{"id":34727,"position":1,"arabic":"فَأَرْسَلْنَا","translation":"অতঃপর আমরা পাঠিয়েছি","audioUrl":"wbw/023_032_001.mp3","charTypeName":"word"},{"id":34728,"position":2,"arabic":"فِيهِمْ","translation":"তাদের মধ্যে","audioUrl":"wbw/023_032_002.mp3","charTypeName":"word"},{"id":34729,"position":3,"arabic":"رَسُولًۭا","translation":"একজনকে রাসূলরূপে","audioUrl":"wbw/023_032_003.mp3","charTypeName":"word"},{"id":34730,"position":4,"arabic":"مِّنْهُمْ","translation":"তাদেরই মধ্য হ'তে","audioUrl":"wbw/023_032_004.mp3","charTypeName":"word"},{"id":34731,"position":5,"arabic":"أَنِ","translation":"(তার দাওয়াত এ ছিলো) যে","audioUrl":"wbw/023_032_005.mp3","charTypeName":"word"},{"id":34732,"position":6,"arabic":"ٱعْبُدُوا۟","translation":"\"তোমরা ইবাদাত করো","audioUrl":"wbw/023_032_006.mp3","charTypeName":"word"},{"id":34733,"position":7,"arabic":"ٱللَّهَ","translation":"আল্লাহর","audioUrl":"wbw/023_032_007.mp3","charTypeName":"word"},{"id":34734,"position":8,"arabic":"مَا","translation":"নেই","audioUrl":"wbw/023_032_008.mp3","charTypeName":"word"},{"id":34735,"position":9,"arabic":"لَكُم","translation":"জন্যে তোমাদের","audioUrl":"wbw/023_032_009.mp3","charTypeName":"word"},{"id":34736,"position":10,"arabic":"مِّنْ","translation":"কোন","audioUrl":"wbw/023_032_010.mp3","charTypeName":"word"},{"id":34737,"position":11,"arabic":"إِلَـٰهٍ","translation":"ইলাহ","audioUrl":"wbw/023_032_011.mp3","charTypeName":"word"},{"id":34738,"position":12,"arabic":"غَيْرُهُۥٓ ۖ","translation":"তিনি ছাড়া","audioUrl":"wbw/023_032_012.mp3","charTypeName":"word"},{"id":34740,"position":13,"arabic":"أَفَلَا","translation":"কি তবুও না","audioUrl":"wbw/023_032_014.mp3","charTypeName":"word"},{"id":34741,"position":14,"arabic":"تَتَّقُونَ","translation":"তোমরা সাবধান হবে\"","audioUrl":"wbw/023_032_015.mp3","charTypeName":"word"},{"id":34742,"position":15,"arabic":"٣٢","translation":"(৩২)","audioUrl":null,"charTypeName":"end"}]},{"number":33,"arabic":"وَقَالَ ٱلْمَلَأُ مِن قَوْمِهِ ٱلَّذِينَ كَفَرُوا۟ وَكَذَّبُوا۟ بِلِقَآءِ ٱلْءَاخِرَةِ وَأَتْرَفْنَٰهُمْ فِى ٱلْحَيَوٰةِ ٱلدُّنْيَا مَا هَٰذَآ إِلَّا بَشَرٌۭ مِّثْلُكُمْ يَأْكُلُ مِمَّا تَأْكُلُونَ مِنْهُ وَيَشْرَبُ مِمَّا تَشْرَبُونَ","translation":"And [every time] the great ones among his people, who refused to acknowledge the truth and gave the lie to the announcement of a life to come - [simply] because We had granted them ease and plenty in [their] worldly life, and they had become corrupted by it [every time] they would say: “This [man] is nothing hut a mortal like yourselves, eating of what you eat, and drinking of what you drink:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2706.mp3","surahId":23,"words":[{"id":35275,"position":1,"arabic":"وَقَالَ","translation":"এবং বলেছিলো","audioUrl":"wbw/023_033_001.mp3","charTypeName":"word"},{"id":35276,"position":2,"arabic":"ٱلْمَلَأُ","translation":"প্রধান ব্যক্তিরা","audioUrl":"wbw/023_033_002.mp3","charTypeName":"word"},{"id":35277,"position":3,"arabic":"مِن","translation":"মধ্য হ'তে","audioUrl":"wbw/023_033_003.mp3","charTypeName":"word"},{"id":35278,"position":4,"arabic":"قَوْمِهِ","translation":"তার জাতির","audioUrl":"wbw/023_033_004.mp3","charTypeName":"word"},{"id":35279,"position":5,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/023_033_005.mp3","charTypeName":"word"},{"id":35280,"position":6,"arabic":"كَفَرُوا۟","translation":"অস্বীকার করেছিলো","audioUrl":"wbw/023_033_006.mp3","charTypeName":"word"},{"id":35281,"position":7,"arabic":"وَكَذَّبُوا۟","translation":"ও মিথ্যারোপ করেছিলো","audioUrl":"wbw/023_033_007.mp3","charTypeName":"word"},{"id":35282,"position":8,"arabic":"بِلِقَآءِ","translation":"প্রতি সাক্ষাতের","audioUrl":"wbw/023_033_008.mp3","charTypeName":"word"},{"id":35283,"position":9,"arabic":"ٱلْـَٔاخِرَةِ","translation":"পরকালের","audioUrl":"wbw/023_033_009.mp3","charTypeName":"word"},{"id":35284,"position":10,"arabic":"وَأَتْرَفْنَـٰهُمْ","translation":"এবং তাদেরকে আমরা স্বাচ্ছন্দ্য দিয়েছিলাম","audioUrl":"wbw/023_033_010.mp3","charTypeName":"word"},{"id":35285,"position":11,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/023_033_011.mp3","charTypeName":"word"},{"id":35286,"position":12,"arabic":"ٱلْحَيَوٰةِ","translation":"জীবনের","audioUrl":"wbw/023_033_012.mp3","charTypeName":"word"},{"id":35287,"position":13,"arabic":"ٱلدُّنْيَا","translation":"দুনিয়ার","audioUrl":"wbw/023_033_013.mp3","charTypeName":"word"},{"id":35288,"position":14,"arabic":"مَا","translation":"\"নয়","audioUrl":"wbw/023_033_014.mp3","charTypeName":"word"},{"id":35289,"position":15,"arabic":"هَـٰذَآ","translation":"সে","audioUrl":"wbw/023_033_015.mp3","charTypeName":"word"},{"id":35290,"position":16,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/023_033_016.mp3","charTypeName":"word"},{"id":35291,"position":17,"arabic":"بَشَرٌۭ","translation":"একজন মানুষ","audioUrl":"wbw/023_033_017.mp3","charTypeName":"word"},{"id":35292,"position":18,"arabic":"مِّثْلُكُمْ","translation":"তোমাদেরই মতো","audioUrl":"wbw/023_033_018.mp3","charTypeName":"word"},{"id":35293,"position":19,"arabic":"يَأْكُلُ","translation":"সে খায়","audioUrl":"wbw/023_033_019.mp3","charTypeName":"word"},{"id":35294,"position":20,"arabic":"مِمَّا","translation":"তা হ'তে","audioUrl":"wbw/023_033_020.mp3","charTypeName":"word"},{"id":35295,"position":21,"arabic":"تَأْكُلُونَ","translation":"তোমরা খাও","audioUrl":"wbw/023_033_021.mp3","charTypeName":"word"},{"id":35296,"position":22,"arabic":"مِنْهُ","translation":"যা হ'তে","audioUrl":"wbw/023_033_022.mp3","charTypeName":"word"},{"id":35297,"position":23,"arabic":"وَيَشْرَبُ","translation":"এবং পান করে","audioUrl":"wbw/023_033_023.mp3","charTypeName":"word"},{"id":35298,"position":24,"arabic":"مِمَّا","translation":"তা হ'তে যা","audioUrl":"wbw/023_033_024.mp3","charTypeName":"word"},{"id":35299,"position":25,"arabic":"تَشْرَبُونَ","translation":"তোমরা পান করো","audioUrl":"wbw/023_033_025.mp3","charTypeName":"word"},{"id":35300,"position":26,"arabic":"٣٣","translation":"(৩৩)","audioUrl":null,"charTypeName":"end"}]},{"number":34,"arabic":"وَلَئِنْ أَطَعْتُم بَشَرًۭا مِّثْلَكُمْ إِنَّكُمْ إِذًۭا لَّخَٰسِرُونَ","translation":"and, indeed, if you pay heed to a mortal like your­selves, you will surely be the losers!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2707.mp3","surahId":23,"words":[{"id":36267,"position":1,"arabic":"وَلَئِنْ","translation":"আর অবশ্যই যদি","audioUrl":"wbw/023_034_001.mp3","charTypeName":"word"},{"id":36268,"position":2,"arabic":"أَطَعْتُم","translation":"তোমরা আনুগত্য করো","audioUrl":"wbw/023_034_002.mp3","charTypeName":"word"},{"id":36269,"position":3,"arabic":"بَشَرًۭا","translation":"একজন মানুষের","audioUrl":"wbw/023_034_003.mp3","charTypeName":"word"},{"id":36270,"position":4,"arabic":"مِّثْلَكُمْ","translation":"তোমাদের মতো","audioUrl":"wbw/023_034_004.mp3","charTypeName":"word"},{"id":36271,"position":5,"arabic":"إِنَّكُمْ","translation":"নিশ্চয়ই তোমরা","audioUrl":"wbw/023_034_005.mp3","charTypeName":"word"},{"id":36272,"position":6,"arabic":"إِذًۭا","translation":"তাহ'লে","audioUrl":"wbw/023_034_006.mp3","charTypeName":"word"},{"id":36273,"position":7,"arabic":"لَّخَـٰسِرُونَ","translation":"ক্ষতিগ্রস্ত হবে","audioUrl":"wbw/023_034_007.mp3","charTypeName":"word"},{"id":36274,"position":8,"arabic":"٣٤","translation":"(৩৪)","audioUrl":null,"charTypeName":"end"}]},{"number":35,"arabic":"أَيَعِدُكُمْ أَنَّكُمْ إِذَا مِتُّمْ وَكُنتُمْ تُرَابًۭا وَعِظَٰمًا أَنَّكُم مُّخْرَجُونَ","translation":"Does he promise you that, after you have died and become [mere] dust and bones, you shall be brought forth [to a new life]?","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2708.mp3","surahId":23,"words":[{"id":37340,"position":1,"arabic":"أَيَعِدُكُمْ","translation":"কি তোমাদেরকে প্রতিশ্রুতি দেয়","audioUrl":"wbw/023_035_001.mp3","charTypeName":"word"},{"id":37341,"position":2,"arabic":"أَنَّكُمْ","translation":"যে তোমরা","audioUrl":"wbw/023_035_002.mp3","charTypeName":"word"},{"id":37342,"position":3,"arabic":"إِذَا","translation":"যখন","audioUrl":"wbw/023_035_003.mp3","charTypeName":"word"},{"id":37343,"position":4,"arabic":"مِتُّمْ","translation":"মরে যাবে","audioUrl":"wbw/023_035_004.mp3","charTypeName":"word"},{"id":37344,"position":5,"arabic":"وَكُنتُمْ","translation":"ও তোমরা হবে","audioUrl":"wbw/023_035_005.mp3","charTypeName":"word"},{"id":37345,"position":6,"arabic":"تُرَابًۭا","translation":"মাটি","audioUrl":"wbw/023_035_006.mp3","charTypeName":"word"},{"id":37346,"position":7,"arabic":"وَعِظَـٰمًا","translation":"ও হাড়","audioUrl":"wbw/023_035_007.mp3","charTypeName":"word"},{"id":37347,"position":8,"arabic":"أَنَّكُم","translation":"নিশ্চয়ই তোমরা","audioUrl":"wbw/023_035_008.mp3","charTypeName":"word"},{"id":37348,"position":9,"arabic":"مُّخْرَجُونَ","translation":"(কবর হ'তে) তোমাদেরকে বের করা হবে","audioUrl":"wbw/023_035_009.mp3","charTypeName":"word"},{"id":37349,"position":10,"arabic":"٣٥","translation":"(৩৫)","audioUrl":null,"charTypeName":"end"}]},{"number":36,"arabic":"۞ هَيْهَاتَ هَيْهَاتَ لِمَا تُوعَدُونَ","translation":"Far-fetched, far-fetched indeed is what you are promised!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2709.mp3","surahId":23,"words":[{"id":37875,"position":1,"arabic":"۞ هَيْهَاتَ","translation":"(অসম্ভব) দূরে","audioUrl":"wbw/023_036_002.mp3","charTypeName":"word"},{"id":37876,"position":2,"arabic":"هَيْهَاتَ","translation":"(অসম্ভব) বহুদূরে","audioUrl":"wbw/023_036_003.mp3","charTypeName":"word"},{"id":37877,"position":3,"arabic":"لِمَا","translation":"বিষয়ে যার","audioUrl":"wbw/023_036_004.mp3","charTypeName":"word"},{"id":37878,"position":4,"arabic":"تُوعَدُونَ","translation":"তোমাদের প্রতিশ্রুতি দেয়া হচ্ছে","audioUrl":"wbw/023_036_005.mp3","charTypeName":"word"},{"id":37879,"position":5,"arabic":"٣٦","translation":"(৩৬)","audioUrl":null,"charTypeName":"end"}]},{"number":37,"arabic":"إِنْ هِىَ إِلَّا حَيَاتُنَا ٱلدُّنْيَا نَمُوتُ وَنَحْيَا وَمَا نَحْنُ بِمَبْعُوثِينَ","translation":"There is no life beyond our life in this world: we die and we live [but once], and we shall never be raised from the dead!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2710.mp3","surahId":23,"words":[{"id":38960,"position":1,"arabic":"إِنْ","translation":"না","audioUrl":"wbw/023_037_001.mp3","charTypeName":"word"},{"id":38961,"position":2,"arabic":"هِىَ","translation":"তা","audioUrl":"wbw/023_037_002.mp3","charTypeName":"word"},{"id":38962,"position":3,"arabic":"إِلَّا","translation":"এ ছাড়া যে","audioUrl":"wbw/023_037_003.mp3","charTypeName":"word"},{"id":38963,"position":4,"arabic":"حَيَاتُنَا","translation":"আমাদের জীবন","audioUrl":"wbw/023_037_004.mp3","charTypeName":"word"},{"id":38964,"position":5,"arabic":"ٱلدُّنْيَا","translation":"দুুনিয়ারই","audioUrl":"wbw/023_037_005.mp3","charTypeName":"word"},{"id":38965,"position":6,"arabic":"نَمُوتُ","translation":"(শুধু এখানেই) আমরা মরি","audioUrl":"wbw/023_037_006.mp3","charTypeName":"word"},{"id":38966,"position":7,"arabic":"وَنَحْيَا","translation":"ও আমরা বাঁচি","audioUrl":"wbw/023_037_007.mp3","charTypeName":"word"},{"id":38967,"position":8,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/023_037_008.mp3","charTypeName":"word"},{"id":38968,"position":9,"arabic":"نَحْنُ","translation":"আমরা","audioUrl":"wbw/023_037_009.mp3","charTypeName":"word"},{"id":38969,"position":10,"arabic":"بِمَبْعُوثِينَ","translation":"উত্থিত হবো","audioUrl":"wbw/023_037_010.mp3","charTypeName":"word"},{"id":38970,"position":11,"arabic":"٣٧","translation":"(৩৭)","audioUrl":null,"charTypeName":"end"}]},{"number":38,"arabic":"إِنْ هُوَ إِلَّا رَجُلٌ ٱفْتَرَىٰ عَلَى ٱللَّهِ كَذِبًۭا وَمَا نَحْنُ لَهُۥ بِمُؤْمِنِينَ","translation":"He is nothing but a man who attributes his own lying in­ventions to God, and we are not going to believe him!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2711.mp3","surahId":23,"words":[{"id":39826,"position":1,"arabic":"إِنْ","translation":"নয়","audioUrl":"wbw/023_038_001.mp3","charTypeName":"word"},{"id":39827,"position":2,"arabic":"هُوَ","translation":"সে","audioUrl":"wbw/023_038_002.mp3","charTypeName":"word"},{"id":39828,"position":3,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/023_038_003.mp3","charTypeName":"word"},{"id":39829,"position":4,"arabic":"رَجُلٌ","translation":"এক ব্যক্তি","audioUrl":"wbw/023_038_004.mp3","charTypeName":"word"},{"id":39830,"position":5,"arabic":"ٱفْتَرَىٰ","translation":"রচনা করেছে","audioUrl":"wbw/023_038_005.mp3","charTypeName":"word"},{"id":39831,"position":6,"arabic":"عَلَى","translation":"সম্পর্কে","audioUrl":"wbw/023_038_006.mp3","charTypeName":"word"},{"id":39832,"position":7,"arabic":"ٱللَّهِ","translation":"আল্লাহ","audioUrl":"wbw/023_038_007.mp3","charTypeName":"word"},{"id":39833,"position":8,"arabic":"كَذِبًۭا","translation":"মিথ্যা","audioUrl":"wbw/023_038_008.mp3","charTypeName":"word"},{"id":39834,"position":9,"arabic":"وَمَا","translation":"আর নই","audioUrl":"wbw/023_038_009.mp3","charTypeName":"word"},{"id":39835,"position":10,"arabic":"نَحْنُ","translation":"আমরা","audioUrl":"wbw/023_038_010.mp3","charTypeName":"word"},{"id":39836,"position":11,"arabic":"لَهُۥ","translation":"উপর তার","audioUrl":"wbw/023_038_011.mp3","charTypeName":"word"},{"id":39837,"position":12,"arabic":"بِمُؤْمِنِينَ","translation":"মু'মিন\"","audioUrl":"wbw/023_038_012.mp3","charTypeName":"word"},{"id":39838,"position":13,"arabic":"٣٨","translation":"(৩৮)","audioUrl":null,"charTypeName":"end"}]},{"number":39,"arabic":"قَالَ رَبِّ ٱنصُرْنِى بِمَا كَذَّبُونِ","translation":"[Whereupon the prophet] would say: “O my Sustainer! Succour me against their accusation of lying!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2712.mp3","surahId":23,"words":[{"id":40960,"position":1,"arabic":"قَالَ","translation":"(রাসূল) বলল","audioUrl":"wbw/023_039_001.mp3","charTypeName":"word"},{"id":40961,"position":2,"arabic":"رَبِّ","translation":"\"হে আমার রব","audioUrl":"wbw/023_039_002.mp3","charTypeName":"word"},{"id":40962,"position":3,"arabic":"ٱنصُرْنِى","translation":"আমাকে সাহায্য করো","audioUrl":"wbw/023_039_003.mp3","charTypeName":"word"},{"id":40963,"position":4,"arabic":"بِمَا","translation":"এ কারণে যে","audioUrl":"wbw/023_039_004.mp3","charTypeName":"word"},{"id":40964,"position":5,"arabic":"كَذَّبُونِ","translation":"আমার উপর তারা মিথ্যারোপ করেছে\"","audioUrl":"wbw/023_039_005.mp3","charTypeName":"word"},{"id":40965,"position":6,"arabic":"٣٩","translation":"(৩৯)","audioUrl":null,"charTypeName":"end"}]},{"number":40,"arabic":"قَالَ عَمَّا قَلِيلٍۢ لَّيُصْبِحُنَّ نَٰدِمِينَ","translation":"[And God] would say: “After a little while they will surely be smitten with remorse!”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2713.mp3","surahId":23,"words":[{"id":41401,"position":1,"arabic":"قَالَ","translation":"(আল্লাহ) বললেন","audioUrl":"wbw/023_040_001.mp3","charTypeName":"word"},{"id":41402,"position":2,"arabic":"عَمَّا","translation":"\"হ'তে ঐবিষয়","audioUrl":"wbw/023_040_002.mp3","charTypeName":"word"},{"id":41403,"position":3,"arabic":"قَلِيلٍۢ","translation":"\"অল্প পরে (অচিরেই)","audioUrl":"wbw/023_040_003.mp3","charTypeName":"word"},{"id":41404,"position":4,"arabic":"لَّيُصْبِحُنَّ","translation":"অবশ্যই তারা হবে","audioUrl":"wbw/023_040_004.mp3","charTypeName":"word"},{"id":41405,"position":5,"arabic":"نَـٰدِمِينَ","translation":"অনুতপ্ত\"","audioUrl":"wbw/023_040_005.mp3","charTypeName":"word"},{"id":41406,"position":6,"arabic":"٤٠","translation":"(৪০)","audioUrl":null,"charTypeName":"end"}]},{"number":41,"arabic":"فَأَخَذَتْهُمُ ٱلصَّيْحَةُ بِٱلْحَقِّ فَجَعَلْنَٰهُمْ غُثَآءًۭ ۚ فَبُعْدًۭا لِّلْقَوْمِ ٱلظَّٰلِمِينَ","translation":"And then the blast [of Our punishment] over­took them, justly and unavoidably, and We caused them to become as the flotsam of dead leaves and the scum borne on the surface of a torrent: and so - away with those evildoing folk!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2714.mp3","surahId":23,"words":[{"id":42216,"position":1,"arabic":"فَأَخَذَتْهُمُ","translation":"অতঃপর তাদেরকে ধরলো","audioUrl":"wbw/023_041_001.mp3","charTypeName":"word"},{"id":42217,"position":2,"arabic":"ٱلصَّيْحَةُ","translation":"এক মহাগর্জন","audioUrl":"wbw/023_041_002.mp3","charTypeName":"word"},{"id":42218,"position":3,"arabic":"بِٱلْحَقِّ","translation":"সাথে ন্যায়ের","audioUrl":"wbw/023_041_003.mp3","charTypeName":"word"},{"id":42219,"position":4,"arabic":"فَجَعَلْنَـٰهُمْ","translation":"অতঃপর তাদেরকে আমরা করেছিলাম","audioUrl":"wbw/023_041_004.mp3","charTypeName":"word"},{"id":42220,"position":5,"arabic":"غُثَآءًۭ ۚ","translation":"ঢেউ তাড়িত আবর্জনার (মতো)","audioUrl":"wbw/023_041_005.mp3","charTypeName":"word"},{"id":42222,"position":6,"arabic":"فَبُعْدًۭا","translation":"সুতরাং দূর হোক (অর্থাৎ ধ্বংস আসুক)","audioUrl":"wbw/023_041_007.mp3","charTypeName":"word"},{"id":42223,"position":7,"arabic":"لِّلْقَوْمِ","translation":"জন্যে (এমন) জাতির","audioUrl":"wbw/023_041_008.mp3","charTypeName":"word"},{"id":42224,"position":8,"arabic":"ٱلظَّـٰلِمِينَ","translation":"(যারা) সীমালঙ্ঘনকারী","audioUrl":"wbw/023_041_009.mp3","charTypeName":"word"},{"id":42225,"position":9,"arabic":"٤١","translation":"(৪১)","audioUrl":null,"charTypeName":"end"}]},{"number":42,"arabic":"ثُمَّ أَنشَأْنَا مِنۢ بَعْدِهِمْ قُرُونًا ءَاخَرِينَ","translation":"AND AFTER them We gave rise to new genera­tions:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2715.mp3","surahId":23,"words":[{"id":43340,"position":1,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/023_042_001.mp3","charTypeName":"word"},{"id":43341,"position":2,"arabic":"أَنشَأْنَا","translation":"আমরা সৃষ্টি করলাম","audioUrl":"wbw/023_042_002.mp3","charTypeName":"word"},{"id":43342,"position":3,"arabic":"مِنۢ","translation":"থেকে","audioUrl":"wbw/023_042_003.mp3","charTypeName":"word"},{"id":43343,"position":4,"arabic":"بَعْدِهِمْ","translation":"পর তাদের","audioUrl":"wbw/023_042_004.mp3","charTypeName":"word"},{"id":43344,"position":5,"arabic":"قُرُونًا","translation":"(বহু) জাতি","audioUrl":"wbw/023_042_005.mp3","charTypeName":"word"},{"id":43345,"position":6,"arabic":"ءَاخَرِينَ","translation":"অন্যান্য","audioUrl":"wbw/023_042_006.mp3","charTypeName":"word"},{"id":43346,"position":7,"arabic":"٤٢","translation":"(৪২)","audioUrl":null,"charTypeName":"end"}]}]}