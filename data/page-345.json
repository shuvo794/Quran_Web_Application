{"id":345,"ayahs":[{"number":43,"arabic":"مَا تَسْبِقُ مِنْ أُمَّةٍ أَجَلَهَا وَمَا يَسْتَـْٔخِرُونَ","translation":"[for,] no community can ever forestall [the end of] its term - and neither can they delay [its coming].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2716.mp3","surahId":23,"words":[{"id":43715,"position":1,"arabic":"مَا","translation":"না","audioUrl":"wbw/023_043_001.mp3","charTypeName":"word"},{"id":43716,"position":2,"arabic":"تَسْبِقُ","translation":"তাড়াতাড়ি এগিয়ে আনতে পারে","audioUrl":"wbw/023_043_002.mp3","charTypeName":"word"},{"id":43717,"position":3,"arabic":"مِنْ","translation":"কোন","audioUrl":"wbw/023_043_003.mp3","charTypeName":"word"},{"id":43718,"position":4,"arabic":"أُمَّةٍ","translation":"জাতি","audioUrl":"wbw/023_043_004.mp3","charTypeName":"word"},{"id":43719,"position":5,"arabic":"أَجَلَهَا","translation":"তার নির্ধারিত সময়","audioUrl":"wbw/023_043_005.mp3","charTypeName":"word"},{"id":43720,"position":6,"arabic":"وَمَا","translation":"আর না","audioUrl":"wbw/023_043_006.mp3","charTypeName":"word"},{"id":43721,"position":7,"arabic":"يَسْتَـْٔخِرُونَ","translation":"দেরি করতে পারে","audioUrl":"wbw/023_043_007.mp3","charTypeName":"word"},{"id":43722,"position":8,"arabic":"٤٣","translation":"(৪৩)","audioUrl":null,"charTypeName":"end"}]},{"number":44,"arabic":"ثُمَّ أَرْسَلْنَا رُسُلَنَا تَتْرَا ۖ كُلَّ مَا جَآءَ أُمَّةًۭ رَّسُولُهَا كَذَّبُوهُ ۚ فَأَتْبَعْنَا بَعْضَهُم بَعْضًۭا وَجَعَلْنَٰهُمْ أَحَادِيثَ ۚ فَبُعْدًۭا لِّقَوْمٍۢ لَّا يُؤْمِنُونَ","translation":"And We sent forth Our apostles, one after another: [and] every time their apostle came to a community, they gave him the lie: and so We caused them to follow one another [into the grave], and let them become [mere] tales: and so - away with the folk who would not believe!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2717.mp3","surahId":23,"words":[{"id":44788,"position":1,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/023_044_001.mp3","charTypeName":"word"},{"id":44789,"position":2,"arabic":"أَرْسَلْنَا","translation":"আমরা পাঠিয়েছি","audioUrl":"wbw/023_044_002.mp3","charTypeName":"word"},{"id":44790,"position":3,"arabic":"رُسُلَنَا","translation":"আমাদের রাসূলগণকে","audioUrl":"wbw/023_044_003.mp3","charTypeName":"word"},{"id":44791,"position":4,"arabic":"تَتْرَا ۖ","translation":"একের পর এক","audioUrl":"wbw/023_044_004.mp3","charTypeName":"word"},{"id":44793,"position":5,"arabic":"كُلَّ","translation":"যখনই","audioUrl":"wbw/023_044_006.mp3","charTypeName":"word"},{"id":44794,"position":6,"arabic":"مَا","translation":"যা","audioUrl":"wbw/023_044_007.mp3","charTypeName":"word"},{"id":44795,"position":7,"arabic":"جَآءَ","translation":"এসেছে","audioUrl":"wbw/023_044_008.mp3","charTypeName":"word"},{"id":44796,"position":8,"arabic":"أُمَّةًۭ","translation":"কোন জাতির (নিকট)","audioUrl":"wbw/023_044_009.mp3","charTypeName":"word"},{"id":44797,"position":9,"arabic":"رَّسُولُهَا","translation":"তার রাসূল","audioUrl":"wbw/023_044_010.mp3","charTypeName":"word"},{"id":44798,"position":10,"arabic":"كَذَّبُوهُ ۚ","translation":"তাকে তারা মিথ্যাবাদী বলেছে","audioUrl":"wbw/023_044_011.mp3","charTypeName":"word"},{"id":44800,"position":11,"arabic":"فَأَتْبَعْنَا","translation":"অতঃপর আমরা পিছনে চললাম (অর্থাৎ ধ্বংস করলাম)","audioUrl":"wbw/023_044_013.mp3","charTypeName":"word"},{"id":44801,"position":12,"arabic":"بَعْضَهُم","translation":"তাদের একের পর","audioUrl":"wbw/023_044_014.mp3","charTypeName":"word"},{"id":44802,"position":13,"arabic":"بَعْضًۭا","translation":"এক","audioUrl":"wbw/023_044_015.mp3","charTypeName":"word"},{"id":44803,"position":14,"arabic":"وَجَعَلْنَـٰهُمْ","translation":"ও আমরা বানিয়েছি তাদেরকে","audioUrl":"wbw/023_044_016.mp3","charTypeName":"word"},{"id":44804,"position":15,"arabic":"أَحَادِيثَ ۚ","translation":"কাহিনীর (মতো)","audioUrl":"wbw/023_044_017.mp3","charTypeName":"word"},{"id":44806,"position":16,"arabic":"فَبُعْدًۭا","translation":"সুতরাং দূর হোক (অর্থাৎ ধ্বংস আসুক)","audioUrl":"wbw/023_044_019.mp3","charTypeName":"word"},{"id":44807,"position":17,"arabic":"لِّقَوْمٍۢ","translation":"জন্যে (এমন) জাতির","audioUrl":"wbw/023_044_020.mp3","charTypeName":"word"},{"id":44808,"position":18,"arabic":"لَّا","translation":"(যারা) না","audioUrl":"wbw/023_044_021.mp3","charTypeName":"word"},{"id":44809,"position":19,"arabic":"يُؤْمِنُونَ","translation":"ঈমান আনে","audioUrl":"wbw/023_044_022.mp3","charTypeName":"word"},{"id":44810,"position":20,"arabic":"٤٤","translation":"(৪৪)","audioUrl":null,"charTypeName":"end"}]},{"number":45,"arabic":"ثُمَّ أَرْسَلْنَا مُوسَىٰ وَأَخَاهُ هَٰرُونَ بِـَٔايَٰتِنَا وَسُلْطَٰنٍۢ مُّبِينٍ","translation":"AND THEN We sent forth Moses and his brother Aaron with Our messages and a manifest authority [from Us]","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2718.mp3","surahId":23,"words":[{"id":45465,"position":1,"arabic":"ثُمَّ","translation":"এরপর","audioUrl":"wbw/023_045_001.mp3","charTypeName":"word"},{"id":45466,"position":2,"arabic":"أَرْسَلْنَا","translation":"আমরা পাঠালাম","audioUrl":"wbw/023_045_002.mp3","charTypeName":"word"},{"id":45467,"position":3,"arabic":"مُوسَىٰ","translation":"মূসাকে","audioUrl":"wbw/023_045_003.mp3","charTypeName":"word"},{"id":45468,"position":4,"arabic":"وَأَخَاهُ","translation":"ও তার ভাই","audioUrl":"wbw/023_045_004.mp3","charTypeName":"word"},{"id":45469,"position":5,"arabic":"هَـٰرُونَ","translation":"হারূনকে","audioUrl":"wbw/023_045_005.mp3","charTypeName":"word"},{"id":45470,"position":6,"arabic":"بِـَٔايَـٰتِنَا","translation":"সহ আমাদের নিদর্শনাবলী","audioUrl":"wbw/023_045_006.mp3","charTypeName":"word"},{"id":45471,"position":7,"arabic":"وَسُلْطَـٰنٍۢ","translation":"ও প্রমাণ (সহ)","audioUrl":"wbw/023_045_007.mp3","charTypeName":"word"},{"id":45472,"position":8,"arabic":"مُّبِينٍ","translation":"সুস্পষ্ট","audioUrl":"wbw/023_045_008.mp3","charTypeName":"word"},{"id":45473,"position":9,"arabic":"٤٥","translation":"(৪৫)","audioUrl":null,"charTypeName":"end"}]},{"number":46,"arabic":"إِلَىٰ فِرْعَوْنَ وَمَلَإِي۟هِۦ فَٱسْتَكْبَرُوا۟ وَكَانُوا۟ قَوْمًا عَالِينَ","translation":"unto Pharaoh and his great ones; but these behaved with arrogance, for they were people wont to glorify [only] themselves.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2719.mp3","surahId":23,"words":[{"id":46221,"position":1,"arabic":"إِلَىٰ","translation":"প্রতি","audioUrl":"wbw/023_046_001.mp3","charTypeName":"word"},{"id":46222,"position":2,"arabic":"فِرْعَوْنَ","translation":"ফিরআউনের","audioUrl":"wbw/023_046_002.mp3","charTypeName":"word"},{"id":46223,"position":3,"arabic":"وَمَلَإِي۟هِۦ","translation":"ও তার সভাষদদের (প্রতি)","audioUrl":"wbw/023_046_003.mp3","charTypeName":"word"},{"id":46224,"position":4,"arabic":"فَٱسْتَكْبَرُوا۟","translation":"কিন্তু তারা অহংকার করলো","audioUrl":"wbw/023_046_004.mp3","charTypeName":"word"},{"id":46225,"position":5,"arabic":"وَكَانُوا۟","translation":"ও তারা ছিলো","audioUrl":"wbw/023_046_005.mp3","charTypeName":"word"},{"id":46226,"position":6,"arabic":"قَوْمًا","translation":"জাতি","audioUrl":"wbw/023_046_006.mp3","charTypeName":"word"},{"id":46227,"position":7,"arabic":"عَالِينَ","translation":"উদ্ধত","audioUrl":"wbw/023_046_007.mp3","charTypeName":"word"},{"id":46228,"position":8,"arabic":"٤٦","translation":"(৪৬)","audioUrl":null,"charTypeName":"end"}]},{"number":47,"arabic":"فَقَالُوٓا۟ أَنُؤْمِنُ لِبَشَرَيْنِ مِثْلِنَا وَقَوْمُهُمَا لَنَا عَٰبِدُونَ","translation":"And so they said: “Shall we believe [them] two mortals like ourselves - although their people are our slaves?”","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2720.mp3","surahId":23,"words":[{"id":46835,"position":1,"arabic":"فَقَالُوٓا۟","translation":"অতঃপর তারা বললো","audioUrl":"wbw/023_047_001.mp3","charTypeName":"word"},{"id":46836,"position":2,"arabic":"أَنُؤْمِنُ","translation":"\"কি ঈমান আনবো আমরা","audioUrl":"wbw/023_047_002.mp3","charTypeName":"word"},{"id":46837,"position":3,"arabic":"لِبَشَرَيْنِ","translation":"মানুষের উপর দুজন","audioUrl":"wbw/023_047_003.mp3","charTypeName":"word"},{"id":46838,"position":4,"arabic":"مِثْلِنَا","translation":"আমাদের মতো","audioUrl":"wbw/023_047_004.mp3","charTypeName":"word"},{"id":46839,"position":5,"arabic":"وَقَوْمُهُمَا","translation":"অথচ তাদের উভয়ের জাতি","audioUrl":"wbw/023_047_005.mp3","charTypeName":"word"},{"id":46840,"position":6,"arabic":"لَنَا","translation":"জন্যে আমাদের","audioUrl":"wbw/023_047_006.mp3","charTypeName":"word"},{"id":46841,"position":7,"arabic":"عَـٰبِدُونَ","translation":"দাস-দাসী (হয়ে আছে)\"","audioUrl":"wbw/023_047_007.mp3","charTypeName":"word"},{"id":46842,"position":8,"arabic":"٤٧","translation":"(৪৭)","audioUrl":null,"charTypeName":"end"}]},{"number":48,"arabic":"فَكَذَّبُوهُمَا فَكَانُوا۟ مِنَ ٱلْمُهْلَكِينَ","translation":"Thus, they gave the lie to those two, and earned (thereby) their place among the doomed:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2721.mp3","surahId":23,"words":[{"id":47372,"position":1,"arabic":"فَكَذَّبُوهُمَا","translation":"অতএব উভয়কে তারা মিথ্যারোপ করলো","audioUrl":"wbw/023_048_001.mp3","charTypeName":"word"},{"id":47373,"position":2,"arabic":"فَكَانُوا۟","translation":"অতঃপর তারা হলো","audioUrl":"wbw/023_048_002.mp3","charTypeName":"word"},{"id":47374,"position":3,"arabic":"مِنَ","translation":"অন্তর্ভুক্ত","audioUrl":"wbw/023_048_003.mp3","charTypeName":"word"},{"id":47375,"position":4,"arabic":"ٱلْمُهْلَكِينَ","translation":"ধ্বংসপ্রাপ্তদের","audioUrl":"wbw/023_048_004.mp3","charTypeName":"word"},{"id":47376,"position":5,"arabic":"٤٨","translation":"(৪৮)","audioUrl":null,"charTypeName":"end"}]},{"number":49,"arabic":"وَلَقَدْ ءَاتَيْنَا مُوسَى ٱلْكِتَٰبَ لَعَلَّهُمْ يَهْتَدُونَ","translation":"for, indeed, We had vouchsafed revelation unto Moses in order that they might find the right way.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2722.mp3","surahId":23,"words":[{"id":47940,"position":1,"arabic":"وَلَقَدْ","translation":"আর নিশ্চয়ই","audioUrl":"wbw/023_049_001.mp3","charTypeName":"word"},{"id":47941,"position":2,"arabic":"ءَاتَيْنَا","translation":"আমরা দিয়েছিলাম","audioUrl":"wbw/023_049_002.mp3","charTypeName":"word"},{"id":47942,"position":3,"arabic":"مُوسَى","translation":"মূসাকে","audioUrl":"wbw/023_049_003.mp3","charTypeName":"word"},{"id":47943,"position":4,"arabic":"ٱلْكِتَـٰبَ","translation":"কিতাব","audioUrl":"wbw/023_049_004.mp3","charTypeName":"word"},{"id":47944,"position":5,"arabic":"لَعَلَّهُمْ","translation":"যাতে তারা","audioUrl":"wbw/023_049_005.mp3","charTypeName":"word"},{"id":47945,"position":6,"arabic":"يَهْتَدُونَ","translation":"সৎ পথ পায়","audioUrl":"wbw/023_049_006.mp3","charTypeName":"word"},{"id":47946,"position":7,"arabic":"٤٩","translation":"(৪৯)","audioUrl":null,"charTypeName":"end"}]},{"number":50,"arabic":"وَجَعَلْنَا ٱبْنَ مَرْيَمَ وَأُمَّهُۥٓ ءَايَةًۭ وَءَاوَيْنَٰهُمَآ إِلَىٰ رَبْوَةٍۢ ذَاتِ قَرَارٍۢ وَمَعِينٍۢ","translation":"And [as We exalted Moses, so, too,] We made the son of Mary and his mother a symbol [of Our grace], and provided for both an abode in a lofty place of lasting restfulness and unsullied springs.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2723.mp3","surahId":23,"words":[{"id":48941,"position":1,"arabic":"وَجَعَلْنَا","translation":"আর আমরা করেছি","audioUrl":"wbw/023_050_001.mp3","charTypeName":"word"},{"id":48942,"position":2,"arabic":"ٱبْنَ","translation":"পুত্রকে","audioUrl":"wbw/023_050_002.mp3","charTypeName":"word"},{"id":48943,"position":3,"arabic":"مَرْيَمَ","translation":"মারইয়ামের","audioUrl":"wbw/023_050_003.mp3","charTypeName":"word"},{"id":48944,"position":4,"arabic":"وَأُمَّهُۥٓ","translation":"ও তার মাকে","audioUrl":"wbw/023_050_004.mp3","charTypeName":"word"},{"id":48945,"position":5,"arabic":"ءَايَةًۭ","translation":"এক নিদর্শন","audioUrl":"wbw/023_050_005.mp3","charTypeName":"word"},{"id":48946,"position":6,"arabic":"وَءَاوَيْنَـٰهُمَآ","translation":"এবং উভয়কে আশ্রয় দিয়েছিলাম আমরা","audioUrl":"wbw/023_050_006.mp3","charTypeName":"word"},{"id":48947,"position":7,"arabic":"إِلَىٰ","translation":"দিকে","audioUrl":"wbw/023_050_007.mp3","charTypeName":"word"},{"id":48948,"position":8,"arabic":"رَبْوَةٍۢ","translation":"উচ্চভূমির","audioUrl":"wbw/023_050_008.mp3","charTypeName":"word"},{"id":48949,"position":9,"arabic":"ذَاتِ","translation":"উপযোগী","audioUrl":"wbw/023_050_009.mp3","charTypeName":"word"},{"id":48950,"position":10,"arabic":"قَرَارٍۢ","translation":"অবস্থানের","audioUrl":"wbw/023_050_010.mp3","charTypeName":"word"},{"id":48951,"position":11,"arabic":"وَمَعِينٍۢ","translation":"ও ঝর্ণা (বিশিষ্ট)","audioUrl":"wbw/023_050_011.mp3","charTypeName":"word"},{"id":48952,"position":12,"arabic":"٥٠","translation":"(৫০)","audioUrl":null,"charTypeName":"end"}]},{"number":51,"arabic":"يَٰٓأَيُّهَا ٱلرُّسُلُ كُلُوا۟ مِنَ ٱلطَّيِّبَٰتِ وَٱعْمَلُوا۟ صَٰلِحًا ۖ إِنِّى بِمَا تَعْمَلُونَ عَلِيمٌۭ","translation":"O YOU APOSTLES! Partake of the good things of life, and do righteous deeds: verily, I have full knowledge of all that you do.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/2724.mp3","surahId":23,"words":[{"id":49268,"position":1,"arabic":"يَـٰٓأَيُّهَا","translation":"(আর বলেছিলাম) হে","audioUrl":"wbw/023_051_001.mp3","charTypeName":"word"},{"id":49269,"position":2,"arabic":"ٱلرُّسُلُ","translation":"রাসূলরা","audioUrl":"wbw/023_051_002.mp3","charTypeName":"word"},{"id":49270,"position":3,"arabic":"كُلُوا۟","translation":"তোমরা খাও","audioUrl":"wbw/023_051_003.mp3","charTypeName":"word"},{"id":49271,"position":4,"arabic":"مِنَ","translation":"হ'তে","audioUrl":"wbw/023_051_004.mp3","charTypeName":"word"},{"id":49272,"position":5,"arabic":"ٱلطَّيِّبَـٰتِ","translation":"পবিত্র (বস্তু)","audioUrl":"wbw/023_051_005.mp3","charTypeName":"word"},{"id":49273,"position":6,"arabic":"وَٱعْمَلُوا۟","translation":"ও তোমরা কাজ করো","audioUrl":"wbw/023_051_006.mp3","charTypeName":"word"},{"id":49274,"position":7,"arabic":"صَـٰل