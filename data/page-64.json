{"id":64,"ayahs":[{"number":109,"arabic":"وَلِلَّهِ مَا فِى ٱلسَّمَٰوَٰتِ وَمَا فِى ٱلْأَرْضِ ۚ وَإِلَى ٱللَّهِ تُرْجَعُ ٱلْأُمُورُ","translation":"And unto God belongs all that is in the heavens and all that is on earth; and all things go back to God [as their source].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/402.mp3","surahId":3,"words":[{"id":73928,"position":1,"arabic":"وَلِلَّهِ","translation":"এবং আল্লাহর জন্যে","audioUrl":"wbw/003_109_001.mp3","charTypeName":"word"},{"id":73929,"position":2,"arabic":"مَا","translation":"যা কিছু","audioUrl":"wbw/003_109_002.mp3","charTypeName":"word"},{"id":73930,"position":3,"arabic":"فِى","translation":"মধ্যে আছে","audioUrl":"wbw/003_109_003.mp3","charTypeName":"word"},{"id":73931,"position":4,"arabic":"ٱلسَّمَـٰوَٰتِ","translation":"আসমানসমূহের","audioUrl":"wbw/003_109_004.mp3","charTypeName":"word"},{"id":73932,"position":5,"arabic":"وَمَا","translation":"ও যা কিছু","audioUrl":"wbw/003_109_005.mp3","charTypeName":"word"},{"id":73933,"position":6,"arabic":"فِى","translation":"মধ্যে আছে","audioUrl":"wbw/003_109_006.mp3","charTypeName":"word"},{"id":73934,"position":7,"arabic":"ٱلْأَرْضِ ۚ","translation":"যমীনের","audioUrl":"wbw/003_109_007.mp3","charTypeName":"word"},{"id":73936,"position":8,"arabic":"وَإِلَى","translation":"এবং দিকে","audioUrl":"wbw/003_109_009.mp3","charTypeName":"word"},{"id":73937,"position":9,"arabic":"ٱللَّهِ","translation":"আল্লাহরই","audioUrl":"wbw/003_109_010.mp3","charTypeName":"word"},{"id":73938,"position":10,"arabic":"تُرْجَعُ","translation":"ফিরানো হয়","audioUrl":"wbw/003_109_011.mp3","charTypeName":"word"},{"id":73939,"position":11,"arabic":"ٱلْأُمُورُ","translation":"সকল বিষয়","audioUrl":"wbw/003_109_012.mp3","charTypeName":"word"},{"id":73940,"position":12,"arabic":"١٠٩","translation":"(১০৯)","audioUrl":null,"charTypeName":"end"}]},{"number":110,"arabic":"كُنتُمْ خَيْرَ أُمَّةٍ أُخْرِجَتْ لِلنَّاسِ تَأْمُرُونَ بِٱلْمَعْرُوفِ وَتَنْهَوْنَ عَنِ ٱلْمُنكَرِ وَتُؤْمِنُونَ بِٱللَّهِ ۗ وَلَوْ ءَامَنَ أَهْلُ ٱلْكِتَٰبِ لَكَانَ خَيْرًۭا لَّهُم ۚ مِّنْهُمُ ٱلْمُؤْمِنُونَ وَأَكْثَرُهُمُ ٱلْفَٰسِقُونَ","translation":"YOU ARE indeed the best community that has ever been brought forth for [the good of] mankind: you enjoin the doing of what is right and forbid the doing of what is wrong, and you believe in God. Now if the followers of earlier revelation had attained to [this kind of] faith, it would have been for their own good; [but only few] among them are believers, while most of them are iniquitous:","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/403.mp3","surahId":3,"words":[{"id":74221,"position":1,"arabic":"كُنتُمْ","translation":"তোমরা হলে","audioUrl":"wbw/003_110_001.mp3","charTypeName":"word"},{"id":74222,"position":2,"arabic":"خَيْرَ","translation":"উত্তম","audioUrl":"wbw/003_110_002.mp3","charTypeName":"word"},{"id":74223,"position":3,"arabic":"أُمَّةٍ","translation":"জাতি","audioUrl":"wbw/003_110_003.mp3","charTypeName":"word"},{"id":74224,"position":4,"arabic":"أُخْرِجَتْ","translation":"(তোমাদেরকে) বের করা হয়েছে","audioUrl":"wbw/003_110_004.mp3","charTypeName":"word"},{"id":74225,"position":5,"arabic":"لِلنَّاسِ","translation":"মানুষের (কল্যাণের) জন্যে","audioUrl":"wbw/003_110_005.mp3","charTypeName":"word"},{"id":74226,"position":6,"arabic":"تَأْمُرُونَ","translation":"তোমরা নির্দেশ দাও","audioUrl":"wbw/003_110_006.mp3","charTypeName":"word"},{"id":74227,"position":7,"arabic":"بِٱلْمَعْرُوفِ","translation":"সৎকাজের","audioUrl":"wbw/003_110_007.mp3","charTypeName":"word"},{"id":74228,"position":8,"arabic":"وَتَنْهَوْنَ","translation":"ও তোমরা নিষেধ কর","audioUrl":"wbw/003_110_008.mp3","charTypeName":"word"},{"id":74229,"position":9,"arabic":"عَنِ","translation":"হতে","audioUrl":"wbw/003_110_009.mp3","charTypeName":"word"},{"id":74230,"position":10,"arabic":"ٱلْمُنكَرِ","translation":"অসৎকাজ","audioUrl":"wbw/003_110_010.mp3","charTypeName":"word"},{"id":74231,"position":11,"arabic":"وَتُؤْمِنُونَ","translation":"