{"id":229,"ayahs":[{"number":63,"arabic":"قَالَ يَٰقَوْمِ أَرَءَيْتُمْ إِن كُنتُ عَلَىٰ بَيِّنَةٍۢ مِّن رَّبِّى وَءَاتَىٰنِى مِنْهُ رَحْمَةًۭ فَمَن يَنصُرُنِى مِنَ ٱللَّهِ إِنْ عَصَيْتُهُۥ ۖ فَمَا تَزِيدُونَنِى غَيْرَ تَخْسِيرٍۢ","translation":"He retorted: \"O my people! What do you think? If [it be true that] I am taking my stand on a cleat evidence from my Sustainer, who has vouchsafed unto me grace from Himself -[if this be true,] who would shield me from God were I to rebel against Him? Hence, what you are offering me is no more than perdition!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1536.mp3","surahId":11,"words":[{"id":56240,"position":1,"arabic":"قَالَ","translation":"সে বললো","audioUrl":"wbw/011_063_001.mp3","charTypeName":"word"},{"id":56241,"position":2,"arabic":"يَـٰقَوْمِ","translation":"\"হে আমার জাতি","audioUrl":"wbw/011_063_002.mp3","charTypeName":"word"},{"id":56242,"position":3,"arabic":"أَرَءَيْتُمْ","translation":"তোমরা (ভেবে) দেখেছো কি","audioUrl":"wbw/011_063_003.mp3","charTypeName":"word"},{"id":56243,"position":4,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/011_063_004.mp3","charTypeName":"word"},{"id":56244,"position":5,"arabic":"كُنتُ","translation":"আমি থাকি","audioUrl":"wbw/011_063_005.mp3","charTypeName":"word"},{"id":56245,"position":6,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/011_063_006.mp3","charTypeName":"word"},{"id":56246,"position":7,"arabic":"بَيِّنَةٍۢ","translation":"স্পষ্ট প্রমাণের","audioUrl":"wbw/011_063_007.mp3","charTypeName":"word"},{"id":56247,"position":8,"arabic":"مِّن","translation":"পক্ষ হ'তে","audioUrl":"wbw/011_063_008.mp3","charTypeName":"word"},{"id":56248,"position":9,"arabic":"رَّبِّى","translation":"আমার রবের","audioUrl":"wbw/011_063_009.mp3","charTypeName":"word"},{"id":56249,"position":10,"arabic":"وَءَاتَىٰنِى","translation":"এবং তিনি আমাকে দান করে থাকেন","audioUrl":"wbw/011_063_010.mp3","charTypeName":"word"},{"id":56250,"position":11,"arabic":"مِنْهُ","translation":"তাঁর পক্ষ হ'তে","audioUrl":"wbw/011_063_011.mp3","charTypeName":"word"},{"id":56251,"position":12,"arabic":"رَحْمَةًۭ","translation":"অনুগ্রহ","audioUrl":"wbw/011_063_012.mp3","charTypeName":"word"},{"id":56252,"position":13,"arabic":"فَمَن","translation":"তবে কে","audioUrl":"wbw/011_063_013.mp3","charTypeName":"word"},{"id":56253,"position":14,"arabic":"يَنصُرُنِى","translation":"আমাকে সাহায্য করবে","audioUrl":"wbw/011_063_014.mp3","charTypeName":"word"},{"id":56254,"position":15,"arabic":"مِنَ","translation":"থেকে","audioUrl":"wbw/011_063_015.mp3","charTypeName":"word"},{"id":56255,"position":16,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/011_063_016.mp3","charTypeName":"word"},{"id":56256,"position":17,"arabic":"إِنْ","translation":"যদি","audioUrl":"wbw/011_063_017.mp3","charTypeName":"word"},{"id":56257,"position":18,"arabic":"عَصَيْتُهُۥ ۖ","translation":"তার আমি অবাধ্য হই","audioUrl":"wbw/011_063_018.mp3","charTypeName":"word"},{"id":56259,"position":19,"arabic":"فَمَا","translation":"অতএব না","audioUrl":"wbw/011_063_020.mp3","charTypeName":"word"},{"id":56260,"position":20,"arabic":"تَزِيدُونَنِى","translation":"আমাকে বৃদ্ধি করবে তোমরা","audioUrl":"wbw/011_063_021.mp3","charTypeName":"word"},{"id":56261,"position":21,"arabic":"غَيْرَ","translation":"ছাড়া","audioUrl":"wbw/011_063_022.mp3","charTypeName":"word"},{"id":56262,"position":22,"arabic":"تَخْسِيرٍۢ","translation":"ক্ষতি","audioUrl":"wbw/011_063_023.mp3","charTypeName":"word"},{"id":56263,"position":23,"arabic":"٦٣","translation":"(৬৩)","audioUrl":null,"charTypeName":"end"}]},{"number":64,"arabic":"وَيَٰقَوْمِ هَٰذِهِۦ نَاقَةُ ٱللَّهِ لَكُمْ ءَايَةًۭ فَذَرُوهَا تَأْكُلْ فِىٓ أَرْضِ ٱللَّهِ وَلَا تَمَسُّوهَا بِسُوٓءٍۢ فَيَأْخُذَكُمْ عَذَابٌۭ قَرِيبٌۭ","translation":"And [then he said]: \"O my people! This she-camel belonging to God shall be a token for you: so leave her alone to pasture on God's earth, and do her no harm, lest speedy chastisement befall you!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1537.mp3","surahId":11,"words":[{"id":56741,"position":1,"arabic":"وَيَـٰقَوْمِ","translation":"এবং হে আমার জাতি","audioUrl":"wbw/011_064_001.mp3","charTypeName":"word"},{"id":56742,"position":2,"arabic":"هَـٰذِهِۦ","translation":"এই","audioUrl":"wbw/011_064_002.mp3","charTypeName":"word"},{"id":56743,"position":3,"arabic":"نَاقَةُ","translation":"উষ্ট্রী","audioUrl":"wbw/011_064_003.mp3","charTypeName":"word"},{"id":56744,"position":4,"arabic":"ٱللَّهِ","translation":"আল্লাহর (পক্ষ হ'তে)","audioUrl":"wbw/011_064_004.mp3","charTypeName":"word"},{"id":56745,"position":5,"arabic":"لَكُمْ","translation":"তোমাদের জন্যে","audioUrl":"wbw/011_064_005.mp3","charTypeName":"word"},{"id":56746,"position":6,"arabic":"ءَايَةًۭ","translation":"একটি নিদর্শন","audioUrl":"wbw/011_064_006.mp3","charTypeName":"word"},{"id":56747,"position":7,"arabic":"فَذَرُوهَا","translation":"অতএব তাকে ছেড়ে দাও","audioUrl":"wbw/011_064_007.mp3","charTypeName":"word"},{"id":56748,"position":8,"arabic":"تَأْكُلْ","translation":"সে খাবে","audioUrl":"wbw/011_064_008.mp3","charTypeName":"word"},{"id":56749,"position":9,"arabic":"فِىٓ","translation":"মধ্যে","audioUrl":"wbw/011_064_009.mp3","charTypeName":"word"},{"id":56750,"position":10,"arabic":"أَرْضِ","translation":"জমির","audioUrl":"wbw/011_064_010.mp3","charTypeName":"word"},{"id":56751,"position":11,"arabic":"ٱللَّهِ","translation":"আল্লাহর","audioUrl":"wbw/011_064_011.mp3","charTypeName":"word"},{"id":56752,"position":12,"arabic":"وَلَا","translation":"এবং না","audioUrl":"wbw/011_064_012.mp3","charTypeName":"word"},{"id":56753,"position":13,"arabic":"تَمَسُّوهَا","translation":"তাকে স্পর্শ করবে","audioUrl":"wbw/011_064_013.mp3","charTypeName":"word"},{"id":56754,"position":14,"arabic":"بِسُوٓءٍۢ","translation":"নিয়ে খারাপ উদ্দেশ্যে","audioUrl":"wbw/011_064_014.mp3","charTypeName":"word"},{"id":56755,"position":15,"arabic":"فَيَأْخُذَكُمْ","translation":"তাহ'লে তোমাদেরকে ধরবে","audioUrl":"wbw/011_064_015.mp3","charTypeName":"word"},{"id":56756,"position":16,"arabic":"عَذَابٌۭ","translation":"শাস্তি","audioUrl":"wbw/011_064_016.mp3","charTypeName":"word"},{"id":56757,"position":17,"arabic":"قَرِيبٌۭ","translation":"শীঘ্রই\"","audioUrl":"wbw/011_064_017.mp3","charTypeName":"word"},{"id":56758,"position":18,"arabic":"٦٤","translation":"(৬৪)","audioUrl":null,"charTypeName":"end"}]},{"number":65,"arabic":"فَعَقَرُوهَا فَقَالَ تَمَتَّعُوا۟ فِى دَارِكُمْ ثَلَٰثَةَ أَيَّامٍۢ ۖ ذَٰلِكَ وَعْدٌ غَيْرُ مَكْذُوبٍۢ","translation":"But they cruelly slaughtered her. And thereupon [Salih] said: \"[Only] for three days [more] shall you enjoy life in your homes: this is a judgment which will not be belied!\"","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1538.mp3","surahId":11,"words":[{"id":57280,"position":1,"arabic":"فَعَقَرُوهَا","translation":"অতঃপর তাকে তারা হত্যা করলো","audioUrl":"wbw/011_065_001.mp3","charTypeName":"word"},{"id":57281,"position":2,"arabic":"فَقَالَ","translation":"তখন সে বললো","audioUrl":"wbw/011_065_002.mp3","charTypeName":"word"},{"id":57282,"position":3,"arabic":"تَمَتَّعُوا۟","translation":"\"তোমরা জীবন উপভোগ করো","audioUrl":"wbw/011_065_003.mp3","charTypeName":"word"},{"id":57283,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/011_065_004.mp3","charTypeName":"word"},{"id":57284,"position":5,"arabic":"دَارِكُمْ","translation":"তোমাদের ঘরের","audioUrl":"wbw/011_065_005.mp3","charTypeName":"word"},{"id":57285,"position":6,"arabic":"ثَلَـٰثَةَ","translation":"তিন","audioUrl":"wbw/011_065_006.mp3","charTypeName":"word"},{"id":57286,"position":7,"arabic":"أَيَّامٍۢ ۖ","translation":"দিন (পর্যন্ত)","audioUrl":"wbw/011_065_007.mp3","charTypeName":"word"},{"id":57288,"position":8,"arabic":"ذَٰلِكَ","translation":"এটা","audioUrl":"wbw/011_065_009.mp3","charTypeName":"word"},{"id":57289,"position":9,"arabic":"وَعْدٌ","translation":"একটি প্রতিশ্রুতি","audioUrl":"wbw/011_065_010.mp3","charTypeName":"word"},{"id":57290,"position":10,"arabic":"غَيْرُ","translation":"নয়","audioUrl":"wbw/011_065_011.mp3","charTypeName":"word"},{"id":57291,"position":11,"arabic":"مَكْذُوبٍۢ","translation":"মিথ্যা হওয়ার\"","audioUrl":"wbw/011_065_012.mp3","charTypeName":"word"},{"id":57292,"position":12,"arabic":"٦٥","translation":"(৬৫)","audioUrl":null,"charTypeName":"end"}]},{"number":66,"arabic":"فَلَمَّا جَآءَ أَمْرُنَا نَجَّيْنَا صَٰلِحًۭا وَٱلَّذِينَ ءَامَنُوا۟ مَعَهُۥ بِرَحْمَةٍۢ مِّنَّا وَمِنْ خِزْىِ يَوْمِئِذٍ ۗ إِنَّ رَبَّكَ هُوَ ٱلْقَوِىُّ ٱلْعَزِيزُ","translation":"And so, when Our judgment came to pass, by Our grace We saved Salih and those who shared his faith; and [We saved them, too,] from the ignominy of [Our rejection on] that Day [of Resurrection]. Verily, thy Sustainer alone is powerful, almighty!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1539.mp3","surahId":11,"words":[{"id":57801,"position":1,"arabic":"فَلَمَّا","translation":"অতঃপর যখন","audioUrl":"wbw/011_066_001.mp3","charTypeName":"word"},{"id":57802,"position":2,"arabic":"جَآءَ","translation":"আসলো","audioUrl":"wbw/011_066_002.mp3","charTypeName":"word"},{"id":57803,"position":3,"arabic":"أَمْرُنَا","translation":"আমাদের নির্দেশ (শাস্তি দেয়ার)","audioUrl":"wbw/011_066_003.mp3","charTypeName":"word"},{"id":57804,"position":4,"arabic":"نَجَّيْنَا","translation":"আমরা রক্ষা করলাম","audioUrl":"wbw/011_066_004.mp3","charTypeName":"word"},{"id":57805,"position":5,"arabic":"صَـٰلِحًۭا","translation":"সালিহকে","audioUrl":"wbw/011_066_005.mp3","charTypeName":"word"},{"id":57806,"position":6,"arabic":"وَٱلَّذِينَ","translation":"ও যারা","audioUrl":"wbw/011_066_006.mp3","charTypeName":"word"},{"id":57807,"position":7,"arabic":"ءَامَنُوا۟","translation":"ঈমান এনেছিলো","audioUrl":"wbw/011_066_007.mp3","charTypeName":"word"},{"id":57808,"position":8,"arabic":"مَعَهُۥ","translation":"তার সাথে (তাদেরকেও)","audioUrl":"wbw/011_066_008.mp3","charTypeName":"word"},{"id":57809,"position":9,"arabic":"بِرَحْمَةٍۢ","translation":"অনুগ্রহ দিয়ে","audioUrl":"wbw/011_066_009.mp3","charTypeName":"word"},{"id":57810,"position":10,"arabic":"مِّنَّا","translation":"আমাদের পক্ষ থেকে","audioUrl":"wbw/011_066_010.mp3","charTypeName":"word"},{"id":57811,"position":11,"arabic":"وَمِنْ","translation":"এবং হ'তে","audioUrl":"wbw/011_066_011.mp3","charTypeName":"word"},{"id":57812,"position":12,"arabic":"خِزْىِ","translation":"লাঞ্ছনা","audioUrl":"wbw/011_066_012.mp3","charTypeName":"word"},{"id":57813,"position":13,"arabic":"يَوْمِئِذٍ ۗ","translation":"সেদিনের","audioUrl":"wbw/011_066_013.mp3","charTypeName":"word"},{"id":57815,"position":14,"arabic":"إِنَّ","translation":"নিশ্চয়ই","audioUrl":"wbw/011_066_015.mp3","charTypeName":"word"},{"id":57816,"position":15,"arabic":"رَبَّكَ","translation":"তোমার রব","audioUrl":"wbw/011_066_016.mp3","charTypeName":"word"},{"id":57817,"position":16,"arabic":"هُوَ","translation":"তিনিই","audioUrl":"wbw/011_066_017.mp3","charTypeName":"word"},{"id":57818,"position":17,"arabic":"ٱلْقَوِىُّ","translation":"শক্তিমান","audioUrl":"wbw/011_066_018.mp3","charTypeName":"word"},{"id":57819,"position":18,"arabic":"ٱلْعَزِيزُ","translation":"পরাক্রমশালী","audioUrl":"wbw/011_066_019.mp3","charTypeName":"word"},{"id":57820,"position":19,"arabic":"٦٦","translation":"(৬৬)","audioUrl":null,"charTypeName":"end"}]},{"number":67,"arabic":"وَأَخَذَ ٱلَّذِينَ ظَلَمُوا۟ ٱلصَّيْحَةُ فَأَصْبَحُوا۟ فِى دِيَٰرِهِمْ جَٰثِمِينَ","translation":"And the blast [of God's punishment] overtook those who had been bent on evildoing: and then they lay lifeless, in their very homes, on the ground,","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1540.mp3","surahId":11,"words":[{"id":58291,"position":1,"arabic":"وَأَخَذَ","translation":"এবং ধরলো","audioUrl":"wbw/011_067_001.mp3","charTypeName":"word"},{"id":58292,"position":2,"arabic":"ٱلَّذِينَ","translation":"(তাদেরকে) যারা","audioUrl":"wbw/011_067_002.mp3","charTypeName":"word"},{"id":58293,"position":3,"arabic":"ظَلَمُوا۟","translation":"সীমালঙ্ঘ