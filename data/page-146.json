{"id":146,"ayahs":[{"number":138,"arabic":"وَقَالُوا۟ هَٰذِهِۦٓ أَنْعَٰمٌۭ وَحَرْثٌ حِجْرٌۭ لَّا يَطْعَمُهَآ إِلَّا مَن نَّشَآءُ بِزَعْمِهِمْ وَأَنْعَٰمٌ حُرِّمَتْ ظُهُورُهَا وَأَنْعَٰمٌۭ لَّا يَذْكُرُونَ ٱسْمَ ٱللَّهِ عَلَيْهَا ٱفْتِرَآءً عَلَيْهِ ۚ سَيَجْزِيهِم بِمَا كَانُوا۟ يَفْتَرُونَ","translation":"And they say, \"Such-and-such cattle and fruits of the field are sacred; none may eat thereof save those whom we will [to do so]\" -so they [falsely] claim; and [they declare that] it is forbidden to burden the backs of certain kinds of cattle; and there are cattle over which they do not pronounce God's name - falsely attributing [the origin of these customs] to Him. [But] He will requite them for all their false imagery.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/927.mp3","surahId":6,"words":[{"id":78892,"position":1,"arabic":"وَقَالُوا۟","translation":"এবং তারা বলে","audioUrl":"wbw/006_138_001.mp3","charTypeName":"word"},{"id":78893,"position":2,"arabic":"هَـٰذِهِۦٓ","translation":"\"এই","audioUrl":"wbw/006_138_002.mp3","charTypeName":"word"},{"id":78894,"position":3,"arabic":"أَنْعَـٰمٌۭ","translation":"গবাদিপশুগুলো","audioUrl":"wbw/006_138_003.mp3","charTypeName":"word"},{"id":78895,"position":4,"arabic":"وَحَرْثٌ","translation":"ও ক্ষেত ফসল","audioUrl":"wbw/006_138_004.mp3","charTypeName":"word"},{"id":78896,"position":5,"arabic":"حِجْرٌۭ","translation":"সুরক্ষিত","audioUrl":"wbw/006_138_005.mp3","charTypeName":"word"},{"id":78897,"position":6,"arabic":"لَّا","translation":"না","audioUrl":"wbw/006_138_006.mp3","charTypeName":"word"},{"id":78898,"position":7,"arabic":"يَطْعَمُهَآ","translation":"খাবে তা","audioUrl":"wbw/006_138_007.mp3","charTypeName":"word"},{"id":78899,"position":8,"arabic":"إِلَّا","translation":"এ ছাড়া","audioUrl":"wbw/006_138_008.mp3","charTypeName":"word"},{"id":78900,"position":9,"arabic":"مَن","translation":"যাকে","audioUrl":"wbw/006_138_009.mp3","charTypeName":"word"},{"id":78901,"position":10,"arabic":"نَّشَآءُ","translation":"ইচ্ছা করিবো আমরা\"","audioUrl":"wbw/006_138_010.mp3","charTypeName":"word"},{"id":78902,"position":11,"arabic":"بِزَعْمِهِمْ","translation":"অনুযায়ী ধারণা তাদের","audioUrl":"wbw/006_138_011.mp3","charTypeName":"word"},{"id":78903,"position":12,"arabic":"وَأَنْعَـٰمٌ","translation":"এবং (কিছু) গবাদিপশু","audioUrl":"wbw/006_138_012.mp3","charTypeName":"word"},{"id":78904,"position":13,"arabic":"حُرِّمَتْ","translation":"নিষিদ্ধ করা হয়েছে","audioUrl":"wbw/006_138_013.mp3","charTypeName":"word"},{"id":78905,"position":14,"arabic":"ظُهُورُهَا","translation":"পিঠগুলোতে তাদের(কিছু উঠাতে)","audioUrl":"wbw/006_138_014.mp3","charTypeName":"word"},{"id":78906,"position":15,"arabic":"وَأَنْعَـٰمٌۭ","translation":"ও (কিছু) গবাদিপশু","audioUrl":"wbw/006_138_015.mp3","charTypeName":"word"},{"id":78907,"position":16,"arabic":"لَّا","translation":"না","audioUrl":"wbw/006_138_016.mp3","charTypeName":"word"},{"id":78908,"position":17,"arabic":"يَذْكُرُونَ","translation":"তারা উচ্চারণ করে (জবাই করার সময়)","audioUrl":"wbw/006_138_017.mp3","charTypeName":"word"},{"id":78909,"position":18,"arabic":"ٱسْمَ","translation":"নাম","audioUrl":"wbw/006_138_018.mp3","charTypeName":"word"},{"id":78910,"position":19,"arabic":"ٱللَّهِ","translation":"আল্লাহ্‌র","audioUrl":"wbw/006_138_019.mp3","charTypeName":"word"},{"id":78911,"position":20,"arabic":"عَلَيْهَا","translation":"উপর তার","audioUrl":"wbw/006_138_020.mp3","charTypeName":"word"},{"id":78912,"position":21,"arabic":"ٱفْتِرَآءً","translation":"তারা মিথ্যা রচনা করে","audioUrl":"wbw/006_138_021.mp3","charTypeName":"word"},{"id":78913,"position":22,"arabic":"عَلَيْهِ ۚ","translation":"উপর তার","audioUrl":"wbw/006_138_022.mp3","charTypeName":"word"},{"id":78915,"position":23,"arabic":"سَيَجْزِيهِم","translation":"শীঘ্রই প্রতিফল দিবেন তাদের","audioUrl":"wbw/006_138_024.mp3","charTypeName":"word"},{"id":78916,"position":24,"arabic":"بِمَا","translation":"এ কারণে যা","audioUrl":"wbw/006_138_025.mp3","charTypeName":"word"},{"id":78917,"position":25,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/006_138_026.mp3","charTypeName":"word"},{"id":78918,"position":26,"arabic":"يَفْتَرُونَ","translation":"তারা মিথ্যা রচনা করতে","audioUrl":"wbw/006_138_027.mp3","charTypeName":"word"},{"id":78919,"position":27,"arabic":"١٣٨","translation":"(১৩৮)","audioUrl":null,"charTypeName":"end"}]},{"number":139,"arabic":"وَقَالُوا۟ مَا فِى بُطُونِ هَٰذِهِ ٱلْأَنْعَٰمِ خَالِصَةٌۭ لِّذُكُورِنَا وَمُحَرَّمٌ عَلَىٰٓ أَزْوَٰجِنَا ۖ وَإِن يَكُن مَّيْتَةًۭ فَهُمْ فِيهِ شُرَكَآءُ ۚ سَيَجْزِيهِمْ وَصْفَهُمْ ۚ إِنَّهُۥ حَكِيمٌ عَلِيمٌۭ","translation":"And they say, \"All that is in the wombs of such-and-such cattle is reserved for our males and forbidden to our women; but if it be stillborn, then both may have their share thereof.\" [God] will requite them for all that they [falsely] attribute [to Him]: behold, He is wise, all-knowing.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/928.mp3","surahId":6,"words":[{"id":78968,"position":1,"arabic":"وَقَالُوا۟","translation":"এবং তারা বলে","audioUrl":"wbw/006_139_001.mp3","charTypeName":"word"},{"id":78969,"position":2,"arabic":"مَا","translation":"\"যা কিছু","audioUrl":"wbw/006_139_002.mp3","charTypeName":"word"},{"id":78970,"position":3,"arabic":"فِى","translation":"মধ্যে (আছে)","audioUrl":"wbw/006_139_003.mp3","charTypeName":"word"},{"id":78971,"position":4,"arabic":"بُطُونِ","translation":"পেটের","audioUrl":"wbw/006_139_004.mp3","charTypeName":"word"},{"id":78972,"position":5,"arabic":"هَـٰذِهِ","translation":"এই","audioUrl":"wbw/006_139_005.mp3","charTypeName":"word"},{"id":78973,"position":6,"arabic":"ٱلْأَنْعَـٰمِ","translation":"গবাদিপশুগুলোর","audioUrl":"wbw/006_139_006.mp3","charTypeName":"word"},{"id":78974,"position":7,"arabic":"خَالِصَةٌۭ","translation":"বিশেষভাবে (নির্দিষ্ট)","audioUrl":"wbw/006_139_007.mp3","charTypeName":"word"},{"id":78975,"position":8,"arabic":"لِّذُكُورِنَا","translation":"জন্যে পুরুষদের আমাদের","audioUrl":"wbw/006_139_008.mp3","charTypeName":"word"},{"id":78976,"position":9,"arabic":"وَمُحَرَّمٌ","translation":"ও নিষিদ্ধ","audioUrl":"wbw/006_139_009.mp3","charTypeName":"word"},{"id":78977,"position":10,"arabic":"عَلَىٰٓ","translation":"জন্য","audioUrl":"wbw/006_139_010.mp3","charTypeName":"word"},{"id":78978,"position":11,"arabic":"أَزْوَٰجِنَا ۖ","translation":"স্ত্রীদের আমাদের","audioUrl":"wbw/006_139_011.mp3","charTypeName":"word"},{"id":78980,"position":12,"arabic":"وَإِن","translation":"এবং যদি","audioUrl":"wbw/006_139_013.mp3","charTypeName":"word"},{"id":78981,"position":13,"arabic":"يَكُن","translation":"তা হয়","audioUrl":"wbw/006_139_014.mp3","charTypeName":"word"},{"id":78982,"position":14,"arabic":"مَّيْتَةًۭ","translation":"মৃত","audioUrl":"wbw/006_139_015.mp3","charTypeName":"word"},{"id":78983,"position":15,"arabic":"فَهُمْ","translation":"তবে তারা (নারী পুরুষ উভয়)","audioUrl":"wbw/006_139_016.mp3","charTypeName":"word"},{"id":78984,"position":16,"arabic":"فِيهِ","translation":"মধ্যে তার\"","audioUrl":"wbw/006_139_017.mp3","charTypeName":"word"},{"id":78985,"position":17,"arabic":"شُرَكَآءُ ۚ","translation":"(খাওয়ায়) অংশীদার হবে\"","audioUrl":"wbw/006_139_018.mp3","charTypeName":"word"},{"id":78987,"position":18,"arabic":"سَيَجْزِيهِمْ","translation":"শীঘ্রই প্রতিফল দিবেন তিনি তাদের","audioUrl":"wbw/006_139_020.mp3","charTypeName":"word"},{"id":78988,"position":19,"arabic":"وَصْفَهُمْ ۚ","translation":"(এরূপ)বিশ্লেষণের তাদের","audioUrl":"wbw/006_139_021.mp3","charTypeName":"word"},{"id":78990,"position":20,"arabic":"إِنَّهُۥ","translation":"নিশ্চয়ই তিনি","audioUrl":"wbw/006_139_023.mp3","charTypeName":"word"},{"id":78991,"position":21,"arabic":"حَكِيمٌ","translation":"প্রজ্ঞাময়","audioUrl":"wbw/006_139_024.mp3","charTypeName":"word"},{"id":78992,"position":22,"arabic":"عَلِيمٌۭ","translation":"মহাজ্ঞানী","audioUrl":"wbw/006_139_025.mp3","charTypeName":"word"},{"id":78993,"position":23,"arabic":"١٣٩","translation":"(১৩৯)","audioUrl":null,"charTypeName":"end"}]},{"number":140,"arabic":"قَدْ خَسِرَ ٱلَّذِينَ قَتَلُوٓا۟ أَوْلَٰدَهُمْ سَفَهًۢا بِغَيْرِ عِلْمٍۢ وَحَرَّمُوا۟ مَا رَزَقَهُمُ ٱللَّهُ ٱفْتِرَآءً عَلَى ٱللَّهِ ۚ قَدْ ضَلُّوا۟ وَمَا كَانُوا۟ مُهْتَدِينَ","translation":"Lost, indeed, are they who, in their weak-minded ignorance, slay their children and declare as forbidden that which God has provided for them as sustenance, falsely ascribing [such prohibitions] to God: they have gone astray and have not found the right path.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/929.mp3","surahId":6,"words":[{"id":79131,"position":1,"arabic":"قَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/006_140_001.mp3","charTypeName":"word"},{"id":79132,"position":2,"arabic":"خَسِرَ","translation":"ক্ষতিগ্রস্ত হয়েছে","audioUrl":"wbw/006_140_002.mp3","charTypeName":"word"},{"id":79133,"position":3,"arabic":"ٱلَّذِينَ","translation":"যারা","audioUrl":"wbw/006_140_003.mp3","charTypeName":"word"},{"id":79134,"position":4,"arabic":"قَتَلُوٓا۟","translation":"হত্যা করেছে","audioUrl":"wbw/006_140_004.mp3","charTypeName":"word"},{"id":79135,"position":5,"arabic":"أَوْلَـٰدَهُمْ","translation":"সন্তানদেরকে তাদের","audioUrl":"wbw/006_140_005.mp3","charTypeName":"word"},{"id":79136,"position":6,"arabic":"سَفَهًۢا","translation":"নির্বুদ্ধিতার কারণে","audioUrl":"wbw/006_140_006.mp3","charTypeName":"word"},{"id":79137,"position":7,"arabic":"بِغَيْرِ","translation":"ছাড়া","audioUrl":"wbw/006_140_007.mp3","charTypeName":"word"},{"id":79138,"position":8,"arabic":"عِلْمٍۢ","translation":"কোনো জ্ঞান","audioUrl":"wbw/006_140_008.mp3","charTypeName":"word"},{"id":79139,"position":9,"arabic":"وَحَرَّمُوا۟","translation":"ও তারা নিষিদ্ধ করেছে","audioUrl":"wbw/006_140_009.mp3","charTypeName":"word"},{"id":79140,"position":10,"arabic":"مَا","translation":"যা","audioUrl":"wbw/006_140_010.mp3","charTypeName":"word"},{"id":79141,"position":11,"arabic":"رَزَقَهُمُ","translation":"জীবিকা‌ দিয়েছেন তাদের","audioUrl":"wbw/006_140_011.mp3","charTypeName":"word"},{"id":79142,"position":12,"arabic":"ٱللَّهُ","translation":"আল্লাহ্‌","audioUrl":"wbw/006_140_012.mp3","charTypeName":"word"},{"id":79143,"position":13,"arabic":"ٱفْتِرَآءً","translation":"মিথ্যা রচনা করে","audioUrl":"wbw/006_140_013.mp3","charTypeName":"word"},{"id":79144,"position":14,"arabic":"عَلَى","translation":"উপর","audioUrl":"wbw/006_140_014.mp3","charTypeName":"word"},{"id":79145,"position":15,"arabic":"ٱللَّهِ ۚ","translation":"আল্লাহ্‌র","audioUrl":"wbw/006_140_015.mp3","charTypeName":"word"},{"id":79147,"position":16,"arabic":"قَدْ","translation":"নিশ্চয়ই","audioUrl":"wbw/006_140_017.mp3","charTypeName":"word"},{"id":79148,"position":17,"arabic":"ضَلُّوا۟","translation":"তারা পথভ্রষ্ট হয়েছে","audioUrl":"wbw/006_140_018.mp3","charTypeName":"word"},{"id":79149,"position":18,"arabic":"وَمَا","translation":"এবং না","audioUrl":"wbw/006_140_019.mp3","charTypeName":"word"},{"id":79150,"position":19,"arabic":"كَانُوا۟","translation":"তারা ছিলো","audioUrl":"wbw/006_140_020.mp3","charTypeName":"word"},{"id":79151,"position":20,"arabic":"مُهْتَدِينَ","translation":"সৎপথ প্রাপ্ত","audioUrl":"wbw/006_140_021.mp3","charTypeName":"word"},{"id":79152,"position":21,"arabic":"١٤٠","translation":"(১৪০)","audioUrl":null,"charTypeName":"end"}]},{"number":141,"arabic":"۞ وَهُوَ ٱلَّذِىٓ أَنشَأَ جَنَّٰتٍۢ مَّعْرُوشَٰتٍۢ وَغَيْرَ مَعْرُوشَٰتٍۢ وَٱلنَّخْلَ وَٱلزَّرْعَ مُخْتَلِفًا أُكُلُهُۥ وَٱلزَّيْتُونَ وَٱلرُّمَّانَ مُتَشَٰبِهًۭا وَغَيْرَ مُتَشَٰبِهٍۢ ۚ كُلُوا۟ مِن ثَمَرِهِۦٓ إِذَآ أَثْمَرَ وَءَاتُوا۟ حَقَّهُۥ يَوْمَ حَصَادِهِۦ ۖ وَلَا تُسْرِفُوٓا۟ ۚ إِنَّهُۥ لَا يُحِبُّ ٱلْمُسْرِفِينَ","translation":"For it is He who has brought into being gardens-[both] the cultivated ones and those growing wild -and the date-palm, and fields bearing multiform produce, and the olive tree, and the pomegranate: [all] resembling one another and yet so different! Eat of their fruit when it comes to fruition, and give [unto the poor] their due on harvest day. And do not waste [God's bounties]: verily, He does not love the wasteful!","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/930.mp3","surahId":6,"words":[{"id":79259,"position":1,"arabic":"۞ وَهُوَ","translation":"এবং তিনিই","audioUrl":"wbw/006_141_002.mp3","charTypeName":"word"},{"id":79260,"position":2,"arabic":"ٱلَّذِىٓ","translation":"যিনি","audioUrl":"wbw/006_141_003.mp3","charTypeName":"word"},{"id":79261,"position":3,"arabic":"أَنشَأَ","translation":"সৃষ্টি করেছেন","audioUrl":"wbw/006_141_004.mp3","charTypeName":"word"},{"id":79262,"position":4,"arabic":"جَنَّـٰتٍۢ","translation":"বাগানসমূহ","audioUrl":"wbw/006_141_005.mp3","charTypeName":"word"},{"id":79263,"position":5,"arabic":"مَّعْرُوشَـٰتٍۢ","translation":"মাচার উপর চড়ান (অর্থাৎ লতা জাতীয়)","audioUrl":"wbw/006_141_006.mp3","charTypeName":"word"},{"id":79264,"position":6,"arabic":"وَغَيْرَ","translation":"ও নয়","audioUrl":"wbw/006_141_007.mp3","charTypeName":"word"},{"id":79265,"position":7,"arabic":"مَعْرُوشَـٰتٍۢ","translation":"মাচার উপর চড়ান (অর্থাৎ কান্ড বিশিষ্ট)","audioUrl":"wbw/006_141_008.mp3","charTypeName":"word"},{"id":79266,"position":8,"arabic":"وَٱلنَّخْلَ","translation":"এবং খেজুর গাছ","audioUrl":"wbw/006_141_009.mp3","charTypeName":"word"},{"id":79267,"position":9,"arabic":"وَٱلزَّرْعَ","translation":"ও ফসল","audioUrl":"wbw/006_141_010.mp3","charTypeName":"word"},{"id":79268,"position":10,"arabic":"مُخْتَلِفًا","translation":"বিভিন্ন","audioUrl":"wbw/006_141_011.mp3","charTypeName":"word"},{"id":79269,"position":11,"arabic":"أُكُلُهُۥ","translation":"স্বাদ তার","audioUrl":"wbw/006_141_012.mp3","charTypeName":"word"},{"id":79270,"position":12,"arabic":"وَٱلزَّيْتُونَ","translation":"ও জলপাই","audioUrl":"wbw/006_141_013.mp3","charTypeName":"word"},{"id":79271,"position":13,"arabic":"وَٱلرُّمَّانَ","translation":"ও আনার","audioUrl":"wbw/006_141_014.mp3","charTypeName":"word"},{"id":79272,"position":14,"arabic":"مُتَشَـٰبِهًۭا","translation":"সদৃশ","audioUrl":"wbw/006_141_015.