{"id":182,"ayahs":[{"number":41,"arabic":"۞ وَٱعْلَمُوٓا۟ أَنَّمَا غَنِمْتُم مِّن شَىْءٍۢ فَأَنَّ لِلَّهِ خُمُسَهُۥ وَلِلرَّسُولِ وَلِذِى ٱلْقُرْبَىٰ وَٱلْيَتَٰمَىٰ وَٱلْمَسَٰكِينِ وَٱبْنِ ٱلسَّبِيلِ إِن كُنتُمْ ءَامَنتُم بِٱللَّهِ وَمَآ أَنزَلْنَا عَلَىٰ عَبْدِنَا يَوْمَ ٱلْفُرْقَانِ يَوْمَ ٱلْتَقَى ٱلْجَمْعَانِ ۗ وَٱللَّهُ عَلَىٰ كُلِّ شَىْءٍۢ قَدِيرٌ","translation":"AND KNOW that whatever booty you acquire [in war], one-fifth thereof belongs to God and the Apostle, and the near of kin, and the orphans, and the needy, and the wayfarer. [This you must observe] if you believe in God and in what We bestowed from on high upon Our servant on the day when the true was distinguished from the false - the day when the two hosts met in battle. And God has the power to will anything.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1201.mp3","surahId":8,"words":[{"id":42087,"position":1,"arabic":"۞ وَٱعْلَمُوٓا۟","translation":"আর তোমরা জেনে রাখো","audioUrl":"wbw/008_041_002.mp3","charTypeName":"word"},{"id":42088,"position":2,"arabic":"أَنَّمَا","translation":"মূলতঃ","audioUrl":"wbw/008_041_003.mp3","charTypeName":"word"},{"id":42089,"position":3,"arabic":"غَنِمْتُم","translation":"গণীমত পেয়েছো তোমরা","audioUrl":"wbw/008_041_004.mp3","charTypeName":"word"},{"id":42090,"position":4,"arabic":"مِّن","translation":"থেকে","audioUrl":"wbw/008_041_005.mp3","charTypeName":"word"},{"id":42091,"position":5,"arabic":"شَىْءٍۢ","translation":"(যা) কিছু","audioUrl":"wbw/008_041_006.mp3","charTypeName":"word"},{"id":42092,"position":6,"arabic":"فَأَنَّ","translation":"তা নিশ্চয়ই","audioUrl":"wbw/008_041_007.mp3","charTypeName":"word"},{"id":42093,"position":7,"arabic":"لِلَّهِ","translation":"জন্যে আল্লাহর","audioUrl":"wbw/008_041_008.mp3","charTypeName":"word"},{"id":42094,"position":8,"arabic":"خُمُسَهُۥ","translation":"এক পঞ্চমাংশ তার","audioUrl":"wbw/008_041_009.mp3","charTypeName":"word"},{"id":42095,"position":9,"arabic":"وَلِلرَّسُولِ","translation":"এবং জন্যে  রাসূলের","audioUrl":"wbw/008_041_010.mp3","charTypeName":"word"},{"id":42096,"position":10,"arabic":"وَلِذِى","translation":"ও জন্যে সম্পন্ন","audioUrl":"wbw/008_041_011.mp3","charTypeName":"word"},{"id":42097,"position":11,"arabic":"ٱلْقُرْبَىٰ","translation":"নৈকট্য","audioUrl":"wbw/008_041_012.mp3","charTypeName":"word"},{"id":42098,"position":12,"arabic":"وَٱلْيَتَـٰمَىٰ","translation":"ও ইয়াতিমদের","audioUrl":"wbw/008_041_013.mp3","charTypeName":"word"},{"id":42099,"position":13,"arabic":"وَٱلْمَسَـٰكِينِ","translation":"ও দরিদ্রদের","audioUrl":"wbw/008_041_014.mp3","charTypeName":"word"},{"id":42100,"position":14,"arabic":"وَٱبْنِ","translation":"ও পুত্র","audioUrl":"wbw/008_041_015.mp3","charTypeName":"word"},{"id":42101,"position":15,"arabic":"ٱلسَّبِيلِ","translation":"পথের","audioUrl":"wbw/008_041_016.mp3","charTypeName":"word"},{"id":42102,"position":16,"arabic":"إِن","translation":"যদি","audioUrl":"wbw/008_041_017.mp3","charTypeName":"word"},{"id":42103,"position":17,"arabic":"كُنتُمْ","translation":"তোমরা থাকো","audioUrl":"wbw/008_041_018.mp3","charTypeName":"word"},{"id":42104,"position":18,"arabic":"ءَامَنتُم","translation":"তোমরা ঈমান এনে","audioUrl":"wbw/008_041_019.mp3","charTypeName":"word"},{"id":42105,"position":19,"arabic":"بِٱللَّهِ","translation":"উপর আল্লাহর","audioUrl":"wbw/008_041_020.mp3","charTypeName":"word"},{"id":42106,"position":20,"arabic":"وَمَآ","translation":"এবং যা","audioUrl":"wbw/008_041_021.mp3","charTypeName":"word"},{"id":42107,"position":21,"arabic":"أَنزَلْنَا","translation":"আমরা অবতীর্ণ করেছি","audioUrl":"wbw/008_041_022.mp3","charTypeName":"word"},{"id":42108,"position":22,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/008_041_023.mp3","charTypeName":"word"},{"id":42109,"position":23,"arabic":"عَبْدِنَا","translation":"আমাদের দাসদের (অর্থাৎ রাসূলের)","audioUrl":"wbw/008_041_024.mp3","charTypeName":"word"},{"id":42110,"position":24,"arabic":"يَوْمَ","translation":"দিন","audioUrl":"wbw/008_041_025.mp3","charTypeName":"word"},{"id":42111,"position":25,"arabic":"ٱلْفُرْقَانِ","translation":"মীমাংসার","audioUrl":"wbw/008_041_026.mp3","charTypeName":"word"},{"id":42112,"position":26,"arabic":"يَوْمَ","translation":"(অর্থাৎ) দিন","audioUrl":"wbw/008_041_027.mp3","charTypeName":"word"},{"id":42113,"position":27,"arabic":"ٱلْتَقَى","translation":"সাক্ষাতের","audioUrl":"wbw/008_041_028.mp3","charTypeName":"word"},{"id":42114,"position":28,"arabic":"ٱلْجَمْعَانِ ۗ","translation":"দু'দলের (বদরের যুদ্ধে)","audioUrl":"wbw/008_041_029.mp3","charTypeName":"word"},{"id":42116,"position":29,"arabic":"وَٱللَّهُ","translation":"এবং আল্লাহ","audioUrl":"wbw/008_041_031.mp3","charTypeName":"word"},{"id":42117,"position":30,"arabic":"عَلَىٰ","translation":"উপর","audioUrl":"wbw/008_041_032.mp3","charTypeName":"word"},{"id":42118,"position":31,"arabic":"كُلِّ","translation":"সব","audioUrl":"wbw/008_041_033.mp3","charTypeName":"word"},{"id":42119,"position":32,"arabic":"شَىْءٍۢ","translation":"কিছুরই","audioUrl":"wbw/008_041_034.mp3","charTypeName":"word"},{"id":42120,"position":33,"arabic":"قَدِيرٌ","translation":"শক্তিশালী","audioUrl":"wbw/008_041_035.mp3","charTypeName":"word"},{"id":42121,"position":34,"arabic":"٤١","translation":"(৪১)","audioUrl":null,"charTypeName":"end"}]},{"number":42,"arabic":"إِذْ أَنتُم بِٱلْعُدْوَةِ ٱلدُّنْيَا وَهُم بِٱلْعُدْوَةِ ٱلْقُصْوَىٰ وَٱلرَّكْبُ أَسْفَلَ مِنكُمْ ۚ وَلَوْ تَوَاعَدتُّمْ لَٱخْتَلَفْتُمْ فِى ٱلْمِيعَٰدِ ۙ وَلَٰكِن لِّيَقْضِىَ ٱللَّهُ أَمْرًۭا كَانَ مَفْعُولًۭا لِّيَهْلِكَ مَنْ هَلَكَ عَنۢ بَيِّنَةٍۢ وَيَحْيَىٰ مَنْ حَىَّ عَنۢ بَيِّنَةٍۢ ۗ وَإِنَّ ٱللَّهَ لَسَمِيعٌ عَلِيمٌ","translation":"[Remember that day] when you were at the near end of the valley [of Badr], and they were at its farthest end, while the caravan was below you. And if you had known that a battle was to take place, you would indeed have refused to accept the challenge: but [the battle was brought about none the less,] so that God might accomplish a thing [which He willed] to be done, [and] that he who would perish might perish in clear evidence of the truth, and that he who would remain alive might live in clear evidence of the truth. And, behold, God is indeed all-hearing, all-knowing.","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1202.mp3","surahId":8,"words":[{"id":42882,"position":1,"arabic":"إِذْ","translation":"(স্মরণ করো) যখন","audioUrl":"wbw/008_042_001.mp3","charTypeName":"word"},{"id":42883,"position":2,"arabic":"أَنتُم","translation":"তোমরা (ছিলে)","audioUrl":"wbw/008_042_002.mp3","charTypeName":"word"},{"id":42884,"position":3,"arabic":"بِٱلْعُدْوَةِ","translation":"প্রান্তে উপত্যকার","audioUrl":"wbw/008_042_003.mp3","charTypeName":"word"},{"id":42885,"position":4,"arabic":"ٱلدُّنْيَا","translation":"নিকটতর","audioUrl":"wbw/008_042_004.mp3","charTypeName":"word"},{"id":42886,"position":5,"arabic":"وَهُم","translation":"ও তারা (ছিলো)","audioUrl":"wbw/008_042_005.mp3","charTypeName":"word"},{"id":42887,"position":6,"arabic":"بِٱلْعُدْوَةِ","translation":"প্রান্তে উপত্যকার","audioUrl":"wbw/008_042_006.mp3","charTypeName":"word"},{"id":42888,"position":7,"arabic":"ٱلْقُصْوَىٰ","translation":"দূরবর্তী","audioUrl":"wbw/008_042_007.mp3","charTypeName":"word"},{"id":42889,"position":8,"arabic":"وَٱلرَّكْبُ","translation":"এবং উট বাহিনী  (বানিজ্য কাফেলা)","audioUrl":"wbw/008_042_008.mp3","charTypeName":"word"},{"id":42890,"position":9,"arabic":"أَسْفَلَ","translation":"নিম্নভূমিতে","audioUrl":"wbw/008_042_009.mp3","charTypeName":"word"},{"id":42891,"position":10,"arabic":"مِنكُمْ ۚ","translation":"হতে তোমাদের","audioUrl":"wbw/008_042_010.mp3","charTypeName":"word"},{"id":42893,"position":11,"arabic":"وَلَوْ","translation":"এবং যদি","audioUrl":"wbw/008_042_012.mp3","charTypeName":"word"},{"id":42894,"position":12,"arabic":"تَوَاعَدتُّمْ","translation":"পরস্পরে (যুদ্ধ) নির্ধারণ করতে তোমরা","audioUrl":"wbw/008_042_013.mp3","charTypeName":"word"},{"id":42895,"position":13,"arabic":"لَٱخْتَلَفْتُمْ","translation":"অবশ্যই মতভেদ করতে তোমরা","audioUrl":"wbw/008_042_014.mp3","charTypeName":"word"},{"id":42896,"position":14,"arabic":"فِى","translation":"ব্যাপারে","audioUrl":"wbw/008_042_015.mp3","charTypeName":"word"},{"id":42897,"position":15,"arabic":"ٱلْمِيعَـٰدِ ۙ","translation":"(যুদ্ধ) নির্ধারণের","audioUrl":"wbw/008_042_016.mp3","charTypeName":"word"},{"id":42899,"position":16,"arabic":"وَلَـٰكِن","translation":"কিন্তু","audioUrl":"wbw/008_042_018.mp3","charTypeName":"word"},{"id":42900,"position":17,"arabic":"لِّيَقْضِىَ","translation":"জন্যে মীমাংসা করার","audioUrl":"wbw/008_042_019.mp3","charTypeName":"word"},{"id":42901,"position":18,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/008_042_020.mp3","charTypeName":"word"},{"id":42902,"position":19,"arabic":"أَمْرًۭا","translation":"একটা বিষয়ে","audioUrl":"wbw/008_042_021.mp3","charTypeName":"word"},{"id":42903,"position":20,"arabic":"كَانَ","translation":"(যা) ছিলো","audioUrl":"wbw/008_042_022.mp3","charTypeName":"word"},{"id":42904,"position":21,"arabic":"مَفْعُولًۭا","translation":"ঘটার (যুদ্ধে সমবেত করানো)","audioUrl":"wbw/008_042_023.mp3","charTypeName":"word"},{"id":42905,"position":22,"arabic":"لِّيَهْلِكَ","translation":"যেন ধ্বংস হয়ে যায়","audioUrl":"wbw/008_042_024.mp3","charTypeName":"word"},{"id":42906,"position":23,"arabic":"مَنْ","translation":"যে (কেউ)","audioUrl":"wbw/008_042_025.mp3","charTypeName":"word"},{"id":42907,"position":24,"arabic":"هَلَكَ","translation":"ধ্বংস হওয়ার","audioUrl":"wbw/008_042_026.mp3","charTypeName":"word"},{"id":42908,"position":25,"arabic":"عَنۢ","translation":"ভিত্তিতে","audioUrl":"wbw/008_042_027.mp3","charTypeName":"word"},{"id":42909,"position":26,"arabic":"بَيِّنَةٍۢ","translation":"সুস্পষ্ট প্রমাণের","audioUrl":"wbw/008_042_028.mp3","charTypeName":"word"},{"id":42910,"position":27,"arabic":"وَيَحْيَىٰ","translation":"ও জীবিত থাকার","audioUrl":"wbw/008_042_029.mp3","charTypeName":"word"},{"id":42911,"position":28,"arabic":"مَنْ","translation":"যে (কেউ)","audioUrl":"wbw/008_042_030.mp3","charTypeName":"word"},{"id":42912,"position":29,"arabic":"حَىَّ","translation":"জীবিত থাকবে","audioUrl":"wbw/008_042_031.mp3","charTypeName":"word"},{"id":42913,"position":30,"arabic":"عَنۢ","translation":"ভিত্তিতে","audioUrl":"wbw/008_042_032.mp3","charTypeName":"word"},{"id":42914,"position":31,"arabic":"بَيِّنَةٍۢ ۗ","translation":"সুস্পষ্ট প্রমাণের","audioUrl":"wbw/008_042_033.mp3","charTypeName":"word"},{"id":42916,"position":32,"arabic":"وَإِنَّ","translation":"ও নিশ্চয়ই","audioUrl":"wbw/008_042_035.mp3","charTypeName":"word"},{"id":42917,"position":33,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/008_042_036.mp3","charTypeName":"word"},{"id":42918,"position":34,"arabic":"لَسَمِيعٌ","translation":"অবশ্যই সবকিছু শুনেন","audioUrl":"wbw/008_042_037.mp3","charTypeName":"word"},{"id":42919,"position":35,"arabic":"عَلِيمٌ","translation":"সবকিছু জানেন","audioUrl":"wbw/008_042_038.mp3","charTypeName":"word"},{"id":42920,"position":36,"arabic":"٤٢","translation":"(৪২)","audioUrl":null,"charTypeName":"end"}]},{"number":43,"arabic":"إِذْ يُرِيكَهُمُ ٱللَّهُ فِى مَنَامِكَ قَلِيلًۭا ۖ وَلَوْ أَرَىٰكَهُمْ كَثِيرًۭا لَّفَشِلْتُمْ وَلَتَنَٰزَعْتُمْ فِى ٱلْأَمْرِ وَلَٰكِنَّ ٱللَّهَ سَلَّمَ ۗ إِنَّهُۥ عَلِيمٌۢ بِذَاتِ ٱلصُّدُورِ","translation":"Lo! God showed them to thee in a dream as few: for, had He shown them to you as many, you would surely have lost heart, and would surely have disagreed with one another about what to do. But God saved [you from this]: verily, He has full knowledge of what is the hearts [of men].","audio":"https://cdn.islamic.network/quran/audio/128/ar.alafasy/1203.mp3","surahId":8,"words":[{"id":43618,"position":1,"arabic":"إِذْ","translation":"যখন","audioUrl":"wbw/008_043_001.mp3","charTypeName":"word"},{"id":43619,"position":2,"arabic":"يُرِيكَهُمُ","translation":"তোমাকে দেখান তাদেরকে","audioUrl":"wbw/008_043_002.mp3","charTypeName":"word"},{"id":43620,"position":3,"arabic":"ٱللَّهُ","translation":"আল্লাহ","audioUrl":"wbw/008_043_003.mp3","charTypeName":"word"},{"id":43621,"position":4,"arabic":"فِى","translation":"মধ্যে","audioUrl":"wbw/008_043_004.mp3","charTypeName":"word"},{"id":43622,"position":5,"arabic":"مَنَامِكَ","translation":"তোমার স্বপ্নের","audioUrl":"wbw/008_043_005.mp3","charTypeName":"word"},{"id":43623,"position":6,"arabic":"قَلِيلًۭا ۖ","translation":"স্বল্প (সংখ্যক)","audioUrl":"wbw/008_043_006.mp3","charTypeName":"word"},{"id":43625,"position":7,"arabic":"وَلَوْ","translation":"এবং যদি","audioUrl":"wbw/008_043_008.mp3","charTypeName":"word"},{"id":43626,"position":8,"arabic":"أَرَىٰكَهُمْ","translation":"তোমাকে দেখাতেন তাদেরকে","audioUrl":"wbw/008_043_009.mp3","charTypeName":"word"},{"id":43627,"position":9,"arabic":"كَثِيرًۭا","translation":"অধিক (সংখ্যক)","audioUrl":"wbw/008_043_010.mp3","charTypeName":"word"},{"id":43628,"position":10,"arabic":"لَّفَشِلْتُمْ","translation":"অবশ্যই সাহস হারাতে তোমরা","audioUrl":"wbw/008_043_011.mp3","charTypeName":"word"},{"id":43629,"position":11,"arabic":"وَلَتَنَـٰزَعْتُمْ","translation":"ও অবশ্যই বিবাদ করতে তোমরা","audioUrl":"wbw/008_043_012.mp3","charTypeName":"word"},{"id":43630,"position":12,"arabic":"فِى","translation":"ব্যাপারে","audioUrl":"wbw/008_043_013.mp3","charTypeName":"word"},{"id":43631,"position":13,"arabic":"ٱلْأَمْرِ","translation":"কাজের (অর্থাৎ যুদ্ধের)","audioUrl":"wbw/008_043_014.mp3","charTypeName":"word"},{"id":43632,"position":14,"arabic":"وَلَـٰكِنَّ","translation":"কিন্তু","audioUrl":"wbw/008_043_015.mp3","charTypeName":"word"},{"id":43633,"position":15,"arabic":"ٱللَّهَ","translation":"আল্লাহ","audioUrl":"wbw/008_043_016.mp3","charTypeName":"word"},{"id":43634,"position":16,"arabic":"سَلَّمَ ۗ","translation":"নিরাপদ করেছিলেন (তা থেকে)","audioUrl":"wbw/008_043_017.mp3","charTypeName":"word"},{"id":43636,"position":17,"arabic":"إِنَّهُۥ","translation":"নিশ্চয়ই তিনি","audioUrl":"wbw/008_043_019.mp3","charTypeName":"word"},{"id":43637,"position":18,"arabic":"عَلِيمٌۢ","translation":"খুব জানেন","audioUrl"